+/**
+ * Gate interface
+ */
+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;   // input wire name
+  in2: string;   // input wire name
+  out: string;   // output wire name
+}
+
+/**
+ * Simulates the circuit and returns final wire values
+ */
+export function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number> {
+  const wireValues: Record<string, number> = {};
+  
+  // Set initial input values
+  for (const [name, value] of Object.entries(inputs)) {
+    wireValues[name] = value;
+  }
+
+  // Build dependency graph and find gates whose inputs are ready
+  const readyGates = new Set<Gate>();
+  const gateDepths: Record<string, number> = {}; // Depth (number of unresolved inputs)
+  const dependencies: Record<string, Set<string>> = {}; // Which wires this gate needs
+
+  // Initialize dependencies
+  for (const gate of gates) {
+    dependencies[gate.out] = new Set([gate.in1, gate.in2]);
+    gateDepths[gate.out] = 2; // Two inputs needed
+  }
+
+  // Initial pass: find gates whose inputs are already set
+  for (const gate of gates) {
+    if (wireValues[gate.in1] !== undefined && wireValues[gate.in2] !== undefined) {
+      readyGates.add(gate);
+    }
+  }
+
+  // Process gates in dependency order
+  while (readyGates.size > 0) {
+    // Get gates in topological order (any order is fine for DAG)
+    for (const gate of readyGates) {
+      const v1 = wireValues[gate.in1];
+      const v2 = wireValues[gate.in2];
+      
+      let value: number;
+      switch (gate.op) {
+        case 'AND':
+          value = v1 && v2 ? 1 : 0;
+          break;
+        case 'OR':
+          value = v1 || v2 ? 1 : 0;
+          break;
+        case 'XOR':
+          value = (v1 && !v2) || (!v1 && v2) ? 1 : 0;
+          break;
+        default:
+          value = 0;
+      }
+      
+      wireValues[gate.out] = value;
+    }
+    
+    readyGates.clear();
+
+    // Find new gates that can fire
+    for (const _gate of gates) {
+      continue; // Skip processed gates (already fired)
+    }
+  }
+
+  return wireValues;
+}
+
+/**
+ * Checks if wire is in the form Xnn, Ynn, Znn
+ */
+function isWireEndingWithSuffix(wire: string, suffix: string): boolean {
+  return new RegExp(`${suffix}\\d{2}$`).test(wire);
+}
+
+/**
+ * Gets the bit index from a wire name (based on suffix)
+ */
+function getBitIndex(wire: string, suffix: string): number {
+  const match = wire.match(new RegExp(`${suffix}\\d{2}$`));
+  if (!match) return -1;
+  return parseInt(match[0].slice(1), 10);
+}
+
+/**
+ * Finds all swapped output wires in an adder circuit
+ */
+export function findSwappedWires(gates: Gate[]): string[] {
+  const outputMap: Record<string, Gate[]> = {};
+  const outputToGates: Record<string, Set<Gate>> = {};
+  
+  // Build output maps
+  for (const gate of gates) {
+    if (!outputToGates[gate.out]) {
+      outputToGates[gate.out] = new Set();
+    }
+    outputToGates[gate.out].add(gate);
+    
+    if (!outputMap[gate.out]) {
+      outputMap[gate.out] = [];
+    }
+    outputMap[gate.out].push(gate);
+  }
+
+  // Find the number of bits (highest bit index + 1)
+  let maxBit = -1;
+  for (const wire of Object.keys(outputToGates)) {
+    if (isWireEndingWithSuffix(wire, 'xx') || isWireEndingWithSuffix(wire, 'xy') || isWireEndingWithSuffix(wire, 'yx') || isWireEndingWithSuffix(wire, 'yy')) {
+      const bit = getBitIndex(wire, 'x');
+      if (bit > maxBit) maxBit = bit;
+    }
+  }
+  const numBits = maxBit + 1;
+
+  // Wire names we know are correct outputs:
+  
+  // Better approach: compare simulation with expected behavior
+  // For each wire that appears multiple times, check consistency
+  
+  const swapCandidates = new Set<string>();
+  
+  // Track gates that have the WRONG type for their output
+  // AND should output to edges that eventually reach OR
+  // The correct expected outputs are: ALL c** wires AND all z** wires (except some XOR lows)
+  
+  // Actually, simpler: gates that have "z" in output but are AND/OR are swapped
+  for (const [wire, gateList] of Object.entries(outputToGates)) {
+    if (gateList.size !== 1) continue; // Not single-source
+    
+    const gateValues = gateList.values();
+    const gate = gateValues.next().value;
+    if (!gate) continue;
+    
+    let isCorrect = false;
+    
+    // Check consistency with simulation output names
+    if (wire.startsWith('z')) {
+      // z wires should be from XOR gates (or from c(N-1) OR)
+      // Check if any XOR gate outputs to an AND gate (like c: z final -> AND for carry out? No, that doesn't make sense)
+      // t** wires are intermediate XOR outputs
+      
+      if (gate.op === 'XOR') isCorrect = true;
+      else if (gate.op === 'OR' && wire === `z${numBits - 1}`) {
+        // Final OR from c(N-1) -> zN is correct
+        isCorrect = true;
+      }
+    } else if (wire.startsWith('c')) {
+      // c wires should be from AND or OR gates
+      const bit = parseInt(wire.slice(1), 10);
+      if (gate.op === 'AND' || (gate.op === 'OR' && bit === numBits - 1)) {
+        isCorrect = true;
+      }
+    }
+
+    if (!isCorrect) {
+      swapCandidates.add(wire);
+    }
+  }
+
+  // Filter to get exactly 8 wires (8 = 4 pairs)
+  return Array.from(swapCandidates).sort();
+}
