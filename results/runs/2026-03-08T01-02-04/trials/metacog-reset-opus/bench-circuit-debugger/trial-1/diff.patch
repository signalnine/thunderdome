nsumers(out);\n          const hasXorConsumer = consumers.some((c) => c.op === 'XOR');\n          const hasAndConsumer = consumers.some((c) => c.op === 'AND');\n          if (!hasXorConsumer || !hasAndConsumer) {\n            swapped.add(out);\n          }\n        }\n      } else {\n        // Final sum XOR — MUST output z\n        if (!isZ) {\n          swapped.add(out);\n        }\n      }\n    } else if (g.op === 'AND') {\n      // AND gate output should never be z\n      if (isZ) {\n        swapped.add(out);\n      }\n      // Non-bit-0 AND must feed into OR\n      if (!isXYGateForBit(g, 0)) {\n        const consumers = findConsumers(out);\n        if (!consumers.some((c) => c.op === 'OR') && !isZ) {\n          swapped.add(out);\n        }\n      }\n    } else if (g.op === 'OR') {\n      // Carry OR must not output z (except last z)\n      if (isZ && !isLastZ) {\n        swapped.add(out);\n      }\n      // Must be consumed by both XOR and AND (except last z)\n      if (!isLastZ && !isZ) {\n        const consumers = findConsumers(out);\n        const hasXorConsumer = consumers.some((c) => c.op === 'XOR');\n        const hasAndConsumer = consumers.some((c) => c.op === 'AND');\n        if (!hasXorConsumer || !hasAndConsumer) {\n          swapped.add(out);\n        }\n      }\n    }\n  }\n\n  // Phase 2: Trace the adder bit-by-bit to detect position mismatches.\n  // This catches swaps that Phase 1 misses (carry↔carry, carry↔partial-sum,\n  // bit-0 swaps) by verifying that each gate's inputs come from the\n  // correct bit position.\n  let carry: string | null = null;\n\n  for (let bit = 0; bit < numBits; bit++) {\n    const x = `x${String(bit).padStart(2, '0')}`;\n    const y = `y${String(bit).padStart(2, '0')}`;\n    const z = `z${String(bit).padStart(2, '0')}`;\n\n    // Find the XOR(x_i, y_i) gate - this always exists and its inputs\n    // can't be swapped (only outputs get swapped)\n    const xorXY = gates.find(\n      (g) =>\n        g.op === 'XOR' &&\n   