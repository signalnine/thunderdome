uts): the XOR consumer's other input\n  // should be from a XOR(x,y) gate (partial sum).\n  // If not, this carry wire was swapped into the wrong position.\n  for (const g of gates) {\n    const out = g.out;\n    if (swapped.has(out)) continue;\n\n    if (g.op === 'OR' && out !== lastZ && !out.startsWith('z')) {\n      const consumers = findConsumers(out);\n      const xorConsumer = consumers.find((c) => c.op === 'XOR');\n      if (xorConsumer) {\n        const otherInput =\n          xorConsumer.in1 === out ? xorConsumer.in2 : xorConsumer.in1;\n        const otherProducer = gateByOutput.get(otherInput);\n        if (otherProducer && !(otherProducer.op === 'XOR' && readsXY(otherProducer))) {\n          if (!swapped.has(otherInput)) {\n            swapped.add(out);\n          }\n        }\n      }\n    }\n  }\n\n  // Phase 3: For carry-swap cases, also find the partner.\n  // When an OR gate's output was swapped with a XOR(x,y) gate's output,\n  // Phase 2 flags the OR output. Now find the XOR(x,y) output that's in\n  // the wrong position.\n  // A XOR(x,y) output is misplaced if its XOR consumer's other input\n  // comes from a non-carry source AND that non-carry source is also\n  // a XOR(x,y) output (meaning two partial sums are paired, which is wrong).\n  for (const g of gates) {\n    const out = g.out;\n    if (swapped.has(out)) continue;\n\n    if (g.op === 'XOR' && readsXY(g) && !isXYGateForBit(g, 0) && !out.startsWith('z')) {\n      const consumers = findConsumers(out);\n      const xorConsumer = consumers.find((c) => c.op === 'XOR');\n      if (xorConsumer) {\n        const otherInput =\n          xorConsumer.in1 === out ? xorConsumer.in2 : xorConsumer.in1;\n        const otherProducer = gateByOutput.get(otherInput);\n        if (otherProducer) {\n          // The other input should be a carry (OR or bit-0 AND)\n          const isCarry =\n            otherProducer.op === 'OR' ||\n            (otherProducer.op === 'AND' && isXYGateForBit(otherProducer, 0));\n