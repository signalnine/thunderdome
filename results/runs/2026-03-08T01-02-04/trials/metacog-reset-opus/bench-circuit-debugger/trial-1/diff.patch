e a simple XOR gate', () => {\n    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 0, b: 0 }).c).toBe(0);\n    expect(simulate(gates, { a: 1, b: 0 }).c).toBe(1);\n    expect(simulate(gates, { a: 0, b: 1 }).c).toBe(1);\n    expect(simulate(gates, { a: 1, b: 1 }).c).toBe(0);\n  });\n\n  it('should simulate chained gates in dependency order', () => {\n    const gates: Gate[] = [\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },\n    ];\n    expect(simulate(gates, { a: 1, b: 1, d: 0 }).e).toBe(1);\n    expect(simulate(gates, { a: 0, b: 1, d: 0 }).e).toBe(0);\n    expect(simulate(gates, { a: 0, b: 1, d: 1 }).e).toBe(1);\n  });\n\n  it('should handle gates listed out of dependency order', () => {\n    const gates: Gate[] = [\n      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n    ];\n    expect(simulate(gates, { a: 1, b: 1, d: 0 }).e).toBe(1);\n  });\n\n  it('should simulate a correct 4-bit adder for 3 + 5 = 8', () => {\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n      { op: 'OR', in1: 'a03', in2: 'b03', out: 'z04' },\n    ];\n    // 3 = 0011, 5 = 0101, 3+5=8 = 01000\n    const inputs: Record<string, number> = {\n      x00: 1, x01: 1, x02: 0, x03: 0,\n      y00: 1, y01: 0, y02: 1, y03: 0,\n    };\n    const result = simulate(gates, inputs);\n    expect(result.z00).toBe(0); // bit 0\n    expect(result.z01).toBe(0); // bit 1\n    expect(result.z02).toBe(0); // bit 2\n    expect(result.z03).toBe(1); // bit 3\n    expect(result.z04).toBe(0); // bit 4 (carry)\n  });\n\n  it('should simulate a 4-bit adder for 15 + 15 = 30', () => {\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n      { op: 'OR', in1: 'a03', in2: 'b03', out: 'z04' },\n    ];\n    // 15 = 1111\n    const inputs: Record<string, number> = {\n      x00: 1, x01: 1, x02: 1, x03: 1,\n      y00: 1, y01: 1, y02: 1, y03: 1,\n    };\n    const result = simulate(gates, inputs);\n    // 15+15=30 = 11110\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(1);\n    expect(result.z02).toBe(1);\n    expect(result.z03).toBe(1);\n    expect(result.z04).toBe(1);\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  function makeCorrectAdder(numBits: number): Gate[] {\n    const gates: Gate[] = [];\n    for (let i = 0; i < numBits; i++) {\n      const x = `x${String(i).padStart(2, '0')}`;\n      const y = `y${String(i).padStart(2, '0')}`;\n      const z = `z${String(i).padStart(2, '0')}`;\n      if (i === 0) {\n        gates.push({ op: 'XOR', in1: x, in2: y, out: z });\n        gates.push({ op: 'AND', in1: x, in2: y, out: `c${String(i).padStart(2, '0')}` });\n      } else {\n        const t = `t${String(i).padStart(2, '0')}`;\n        const a = `a${String(i).padStart(2, '0')}`;\n        const b = `b${String(i).padStart(2, '0')}`;\n        const c = `c${String(i).padStart(2, '0')}`;\n        const cPrev = `c${String(i - 1).padStart(2, '0')}`;\n        gates.push({ op: 'XOR', in1: x, in2: y, out: t });\n        gates.push({ op: 'XOR', in1: t, in2: cPrev, out: z });\n        gates.push({ op: 'AND', in1: x, in2: y, out: a });\n        gates.push({ op: 'AND', in1: t, in2: cPrev, out: b });\n        gates.push({ op: 'OR', in1: a, in2: b, out: c });\n      }\n    }\n    // Final carry -> last z bit\n    const lastZ = `z${String(numBits).padStart(2, '0')}`;\n    // For the last carry, we need a pass-through. Since we can't have\n    // a direct wire, in a real circuit this would just be an alias.\n    // But in our gate model, we don't have that last gate — the OR gate\n    // for the last bit already outputs what becomes the final z.\n    // Let's adjust: the last carry IS the last z.\n    // Actually in the example, c03 -> z04. This means the OR gate for\n    // bit 3 should output z04 directly.\n    // Let's fix: the carry of the last full-adder bit outputs z_N instead of c_N\n    if (numBits > 1) {\n      const lastGate = gates[gates.length - 1]; // The OR gate for carry of last bit\n      lastGate.out = lastZ;\n    } else {\n      // Only bit 0: AND gate output becomes z01\n      gates[1].out = lastZ;\n    }\n    return gates;\n  }\n\n  function swapOutputs(gates: Gate[], wire1: string, wire2: string): void {\n    const g1 = gates.find((g) => g.out === wire1)!;\n    const g2 = gates.find((g) => g.out === wire2)!;\n    g1.out = wire2;\n    g2.out = wire1;\n  }\n\n  it('should find 8 swapped wires in a small adder', () => {\n    const gates = makeCorrectAdder(8);\n    // Swap 4 pairs\n    swapOutputs(gates, 'z01', 'a01');\n    swapOutputs(gates, 'z03', 't03');\n    swapOutputs(gates, 'b05', 'c05');\n    swapOutputs(gates, 'z07', 'a07');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['a01', 'a07', 'b05', 'c05', 't03', 'z01', 'z03', 'z07'].sort()\n    );\n  });\n\n  it('should find swapped wires when carry wire is swapped', () => {\n    const gates = makeCorrectAdder(10);\n    // Swap carry with something\n    swapOutputs(gates, 'c02', 't04');\n    swapOutputs(gates, 'z05', 'a05');\n    swapOutputs(gates, 'b07', 'z08');\n    swapOutputs(gates, 'a09', 'z09');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['a05', 'a09', 'b07', 'c02', 't04', 'z05', 'z08', 'z09'].sort()\n    );\n  });\n\n  it('should handle a 45-bit adder with swaps', () => {\n    const gates = makeCorrectAdder(45);\n    swapOutputs(gates, 'z10', 'a10');\n    swapOutputs(gates, 't20', 'z20');\n    swapOutputs(gates, 'b30', 'c30');\n    swapOutputs(gates, 'z40', 'a40');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['a10', 'a40', 'b30', 'c30', 't20', 'z10', 'z20', 'z40'].sort()\n    );\n  });\n\n  function makeAdderWithRandomNames(numBits: number): { gates: Gate[], wireNames: Map<string, string> } {\n    const wireNames = new Map<string, string>();\n    let counter = 0;\n    function randomWire(): string {\n      const name = `w${String(counter++).padStart(3, '0')}`;\n      return name;\n    }\n\n    const gates: Gate[] = [];\n    const lastZ = `z${String(numBits).padStart(2, '0')}`;\n\n    for (let i = 0; i < numBits; i++) {\n      const x = `x${String(i).padStart(2, '0')}`;\n      const y = `y${String(i).padStart(2, '0')}`;\n      const z = `z${String(i).padStart(2, '0')}`;\n      if (i === 0) {\n        const carryName = randomWire();\n        wireNames.set(`c${String(i).padStart(2, '0')}`, carryName);\n        gates.push({ op: 'XOR', in1: x, in2: y, out: z });\n        gates.push({ op: 'AND', in1: x, in2: y, out: carryName });\n      } else {\n        const tName = randomWire();\n        const aName = randomWire();\n        const bName = randomWire();\n        const cPrevName = wireNames.get(`c${String(i - 1).padStart(2, '0')}`)!;\n        const cName = (i === numBits - 1) ? lastZ : randomWire();\n        wireNames.set(`t${String(i).padStart(2, '0')}`, tName);\n        wireNames.set(`a${String(i).padStart(2, '0')}`, aName);\n        wireNames.set(`b${String(i).padStart(2, '0')}`, bName);\n        wireNames.set(`c${String(i).padStart(2, '0')}`, cName);\n        gates.push({ op: 'XOR', in1: x, in2: y, out: tName });\n        gates.push({ op: 'XOR', in1: tName, in2: cPrevName, out: z });\n        gates.push({ op: 'AND', in1: x, in2: y, out: aName });\n        gates.push({ op: 'AND', in1: tName, in2: cPrevName, out: bName });\n        gates.push({ op: 'OR', in1: aName, in2: bName, out: cName });\n      }\n    }\n\n    return { gates, wireNames };\n  }\n\n  it('should find swaps in adder with random wire names', () => {\n    const { gates, wireNames } = makeAdderWithRandomNames(8);\n    const t03 = wireNames.get('t03')!;\n    const a05 = wireNames.get('a05')!;\n    const c06 = wireNames.get('c06')!;\n    // Swap z01 <-> t03 (partial sum XOR output <-> z wire)\n    swapOutputs(gates, 'z01', t03);\n    // Swap z04 <-> a05 (z wire <-> AND generate)\n    swapOutputs(gates, 'z04', a05);\n    // Swap c06 <-> z07\n    swapOutputs(gates, c06, 'z07');\n    // Swap b02 <-> z03\n    const b02 = wireNames.get('b02')!;\n    swapOutputs(gates, b02, 'z03');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      [t03, a05, c06, b02, 'z01', 'z04', 'z07', 'z03'].sort()\n    );\n  });\n\n  it('should find carry swaps with random wire names', () => {\n    const { gates, wireNames } = makeAdderWithRandomNames(10);\n    const c02 = wireNames.get('c02')!;\n    const t04 = wireNames.get('t04')!;\n    const a06 = wireNames.get('a06')!;\n    const b08 = wireNames.get('b08')!;\n\n    // Swap carry with partial sum from different bit\n    swapOutputs(gates, c02, t04);\n    // Swap z06 <-> a06\n    swapOutputs(gates, 'z06', a06);\n    // Swap b08 <-> z08\n    swapOutputs(gates, b08, 'z08');\n    // Swap z03 <-> a03 (but with random names for a03)\n    const a03 = wireNames.get('a03')!;\n    swapOutputs(gates, 'z03', a03);\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      [c02, t04, a06, b08, a03, 'z06', 'z08', 'z03'].sort()\n    );\n  });\n\n  it('should work with shuffled gate order', () => {\n    const { gates, wireNames } = makeAdderWithRandomNames(12);\n    const a03 = wireNames.get('a03')!;\n    const t07 = wireNames.get('t07')!;\n    const b10 = wireNames.get('b10')!;\n    const c05 = wireNames.get('c05')!;\n\n    swapOutputs(gates, 'z03', a03);\n    swapOutputs(gates, 'z07', t07);\n    swapOutputs(gates, b10, 'z10');\n    swapOutputs(gates, c05, 'z06');\n\n    // Shuffle gates randomly\n    for (let i = gates.length - 1; i > 0; i--) {\n      const j = Math.floor(Math.random() * (i + 1));\n      [gates[i], gates[j]] = [gates[j], gates[i]];\n    }\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      [a03, t07, b10, c05, 'z03', 'z07', 'z10', 'z06'].sort()\n    );\n  });\n\n  it('should handle swaps at bit 0', () => {\n    const { gates, wireNames } = makeAdderWithRandomNames(6);\n    const c00 = wireNames.get('c00')!;\n    const t02 = wireNames.get('t02')!;\n    const a04 = wireNames.get('a04')!;\n    const b03 = wireNames.get('b03')!;\n\n    // Swap z00 wi