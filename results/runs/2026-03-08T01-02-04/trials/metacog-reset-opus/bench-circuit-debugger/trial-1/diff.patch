.find(\n          (g) =>\n            g.op === 'OR' &&\n            (g.in1 === genWire || g.in2 === genWire)\n        );\n        if (orWithGen) {\n          const otherInput =\n            orWithGen.in1 === genWire\n              ? orWithGen.in2\n              : orWithGen.in1;\n          doSwap(propWire, otherInput);\n          carry = orWithGen.out;\n        } else {\n          const orWithProp = gates.find(\n            (g) =>\n              g.op === 'OR' &&\n              (g.in1 === propWire || g.in2 === propWire)\n          );\n          if (orWithProp) {\n            const otherInput =\n              orWithProp.in1 === propWire\n                ? orWithProp.in2\n                : orWithProp.in1;\n            doSwap(genWire, otherInput);\n            carry = orWithProp.out;\n          }\n        }\n      }\n\n      // Check if carry itself is z-wire (shouldn't be, except for final bit)\n      if (\n        carry.startsWith('z') &&\n        carry !== `z${String(numBits).padStart(2, '0')}`\n      ) {\n        // carry shouldn't be a z-wire (except the final output bit)\n        // This means it was swapped with something\n        // Find the OR gate that outputs this z-wire and figure out\n        // what it should be\n        // Actually we already set carry above, this is already handled\n        // by the structure check above. But as an extra safety check:\n        // The carry for bit i is output of the OR gate.\n        // If we get here, the OR gate's output was set to a z-wire,\n        // which is wrong. But we can't easily fix it here without more context.\n      }\n    }\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[{"oldStart":51,"oldLines":20,"newStart":51,"newLines":6,"lines":["     gateByOutput.set(g.out, g);","   }"," ","-  // Find a gate by its operation and input wires (order-independent)","-  function findGate(","-    op: Gate['op'],","-    in1: string,","-    in2: string","-  ): Gate | undefined {","-    return gates.find(","-