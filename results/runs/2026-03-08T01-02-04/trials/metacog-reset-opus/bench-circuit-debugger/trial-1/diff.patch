XOR consumer's output.\n      const xorOut = xorConsumer.out;\n      const expectedZ = `z${String(expectedNextBit).padStart(2, '0')}`;\n      const psExpectedZ = `z${String(psBit).padStart(2, '0')}`;\n\n      if (xorOut === expectedZ) {\n        // The XOR outputs z for bit orBit+1, meaning this carry is in the\n        // right position but the partial sum is wrong. Flag the partial sum.\n        if (!swapped.has(otherInput)) {\n          swapped.add(otherInput);\n        }\n      } else if (xorOut === psExpectedZ) {\n        // The XOR outputs z for the partial sum's bit, meaning the partial\n        // sum is in the right position but the carry is wrong. Flag the carry.\n        swapped.add(out);\n      } else {\n        // The XOR output doesn't match either expected z.\n        // Flag the carry (safer default — carry was displaced).\n        swapped.add(out);\n      }\n    }\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[{"oldStart":45,"oldLines":9,"newStart":45,"newLines":12,"lines":[" }"," "," export function findSwappedWires(gates: Gate[]): string[] {","+  // Deep copy to avoid mutating the input","+  const gs: Gate[] = gates.map((g) => ({ ...g }));","+","   // Determine the number of input bits","   let maxBit = 0;","-  for (const g of gates) {","+  for (const g of gs) {","     for (const w of [g.in1, g.in2]) {","       const m = w.match(/^x(\\d+)$/);","       if (m) {"]},{"oldStart":56,"oldLines":241,"newStart":59,"newLines":169,"lines":["     }","   }","   const numBits = maxBit + 1;","-  const lastZ = `z${String(numBits).padStart(2, '0')}`;"," ","   const swapped = new Set<string>();"," ","-  function isXY(w: string): boolean {","-    return /^[xy]\\d+$/.test(w);","+  // Build a lookup map from output wire name to gate","+  let gateByOutput = new Map<string, Gate>();","+  function rebuildLookup() {","+    gateByOutput = new Map<string, Gate>();","+    for (const g of gs) {","+      gateByOutput.set(g.out, g);","+    }","   }","+  rebuild