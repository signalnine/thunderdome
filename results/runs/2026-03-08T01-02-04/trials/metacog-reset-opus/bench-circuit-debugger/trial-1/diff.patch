rry inputs.\n  // When a XOR(x_i, y_i) partial sum's XOR consumer has a non-carry\n  // other input, one of the two is in the wrong position.\n  // Determine which by checking if the XOR consumer outputs the z-wire\n  // for this partial sum's bit — if so, this partial sum is correctly\n  // positioned and the other input is the swapped one.\n  for (const g of gates) {\n    const out = g.out;\n    if (swapped.has(out)) continue;\n\n    if (g.op === 'XOR' && readsXY(g) && !isXYGateForBit(g, 0) && !out.startsWith('z')) {\n      const ourBit = getBitFromXYGate(g);\n      const ourExpectedZ = `z${String(ourBit).padStart(2, '0')}`;\n\n      const consumers = findConsumers(out);\n      const xorConsumer = consumers.find((c) => c.op === 'XOR');\n      if (xorConsumer) {\n        const otherInput =\n          xorConsumer.in1 === out ? xorConsumer.in2 : xorConsumer.in1;\n        const otherProducer = gateByOutput.get(otherInput);\n        if (otherProducer) {\n          const isCarry =\n            otherProducer.op === 'OR' ||\n            (otherProducer.op === 'AND' && isXYGateForBit(otherProducer, 0));\n          if (!isCarry) {\n            // The other input is not a carry. Determine who is misplaced.\n            if (xorConsumer.out === ourExpectedZ) {\n              // This partial sum correctly feeds into z_ourBit.\n              // The other input is the misplaced wire.\n              if (!swapped.has(otherInput)) {\n                swapped.add(otherInput);\n              }\n            } else {\n              // This partial sum does NOT feed into its expected z_ourBit.\n              // We are in the wrong position.\n              swapped.add(out);\n            }\n          }\n        }\n      }\n    }\n  }\n\n  // Phase 4: Verify carry-to-bit-position consistency.\n  // For each OR gate (carry) or bit-0 AND gate (carry), determine which\n  // bit it belongs to, then verify that its XOR consumer pairs it with\n  // the correct bit's partial sum.\n  function getBitF