: string[] {\n  // Determine the number of input bits\n  let maxBit = 0;\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2]) {\n      const m = w.match(/^x(\\d+)$/);\n      if (m) {\n        maxBit = Math.max(maxBit, parseInt(m[1], 10));\n      }\n    }\n  }\n  const numBits = maxBit + 1;\n  const lastZ = `z${String(numBits).padStart(2, '0')}`;\n\n  const swapped = new Set<string>();\n\n  function isXY(w: string): boolean {\n    return /^[xy]\\d+$/.test(w);\n  }\n\n  function readsXY(g: Gate): boolean {\n    return isXY(g.in1) || isXY(g.in2);\n  }\n\n  function isXYGateForBit(g: Gate, bit: number): boolean {\n    const x = `x${String(bit).padStart(2, '0')}`;\n    const y = `y${String(bit).padStart(2, '0')}`;\n    return (\n      (g.in1 === x && g.in2 === y) || (g.in1 === y && g.in2 === x)\n    );\n  }\n\n  // Build lookup structures\n  const gateByOutput = new Map<string, Gate>();\n  for (const g of gates) {\n    gateByOutput.set(g.out, g);\n  }\n\n  function findConsumers(wire: string): Gate[] {\n    return gates.filter((g) => g.in1 === wire || g.in2 === wire);\n  }\n\n  function hasInputs(gate: Gate, a: string, b: string): boolean {\n    return (\n      (gate.in1 === a && gate.in2 === b) ||\n      (gate.in1 === b && gate.in2 === a)\n    );\n  }\n\n  function findGateByOpAndInputs(\n    op: Gate['op'],\n    a: string,\n    b: string\n  ): Gate | undefined {\n    return gates.find((g) => g.op === op && hasInputs(g, a, b));\n  }\n\n  // Phase 1: Structural rules to catch obvious violations.\n  for (const g of gates) {\n    const out = g.out;\n    const isZ = out.startsWith('z');\n    const isLastZ = out === lastZ;\n\n    if (g.op === 'XOR') {\n      if (readsXY(g)) {\n        // Partial sum XOR — should NOT output z (except z00)\n        if (isZ && out !== 'z00') {\n          swapped.add(out);\n        }\n        // For non-bit-0, should be consumed by both XOR and AND\n        if (!isXYGateForBit(g, 0) && !isZ) {\n          const consumers = findConsumers(out);\n          const hasXorConsumer = consumers.some((c) => c.op === 'XOR');\n          const hasAndConsumer = consumers.some((c) => c.op === 'AND');\n          if (!hasXorConsumer || !hasAndConsumer) {\n            swapped.add(out);\n          }\n        }\n      } else {\n        // Final sum XOR — MUST output z\n        if (!isZ) {\n          swapped.add(out);\n        }\n      }\n    } else if (g.op === 'AND') {\n      if (isZ) {\n        swapped.add(out);\n      }\n      // Non-bit-0 AND must feed into OR\n      if (!isXYGateForBit(g, 0)) {\n        const consumers = findConsumers(out);\n        if (!consumers.some((c) => c.op === 'OR') && !isZ) {\n          swapped.add(out);\n        }\n      }\n    } else if (g.op === 'OR') {\n      // Carry OR must not output z (except last z)\n      if (isZ && !isLastZ) {\n        swapped.add(out);\n      }\n      // Must be consumed by both XOR and AND (except last z)\n      if (!isLastZ && !isZ) {\n        const consumers = findConsumers(out);\n        const hasXorConsumer = consumers.some((c) => c.op === 'XOR');\n        const hasAndConsumer = consumers.some((c) => c.op === 'AND');\n        if (!hasXorConsumer || !hasAndConsumer) {\n          swapped.add(out);\n        }\n      }\n    }\n  }\n\n  // Phase 2: Cross-check carry connections.\n  // For carry wires (OR gate outputs): the XOR consumer's other input\n  // should be from a XOR(x,y) gate (partial sum).\n  // If not, this carry wire was swapped into the wrong position.\n  for (const g of gates) {\n    const out = g.out;\n    if (swapped.has(out)) continue;\n\n    if (g.op === 'OR' && out !== lastZ && !out.startsWith('z')) {\n      const consumers = findConsumers(out);\n      const xorConsumer = consumers.find((c) => c.op === 'XOR');\n      if (xorConsumer) {\n        const otherInput =\n          xorConsumer.in1 === out ? xorConsumer.in2 : xorConsumer.in1;\n        const otherProducer = gateByOutput.get(otherInput);\n        if (otherProducer && !(otherProducer.op === 'XOR' && readsXY(otherProducer))) {\n          if (!swapped.has(otherInput)) {\n            swapped.add(out);\n          }\n        }\n      }\n    }\n  }\n\n  // Phase 3: For carry-swap cases, also find the partner.\n  // When an OR gate's output was swapped with a XOR(x,y) gate's output,\n  // Phase 2 flags the OR output. Now find the XOR(x,y) output that ended\n  // up in a carry position.\n  // A XOR(x,y) output is misplaced if it's being used as a carry input\n  // (i.e., paired with another XOR(x,y) partial sum in a sum XOR gate).\n  for (const g of gates) {\n    const out = g.out;\n    if (swapped.has(out)) continue;\n\n    if (g.op === 'XOR' && readsXY(g) && !isXYGateForBit(g, 0) && !out.startsWith('z')) {\n      const consumers = findConsumers(out);\n      const xorConsumer = consumers.find((c) => c.op === 'XOR');\n      if (xorConsumer) {\n        const otherInput =\n          xorConsumer.in1 === out ? xorConsumer.in2 : xorConsumer.in1;\n        const otherProducer = gateByOutput.get(otherInput);\n        if (otherProducer) {\n          const isCarry =\n            otherProducer.op === 'OR' ||\n            (otherProducer.op === 'AND' && isXYGateForBit(otherProducer, 0));\n          if (!isCarry) {\n            // The other input is not a carry wire. This means the other\n            // input wire (otherInput) is in the wrong position — it's\n            // a carry impersonator. Flag it, not us.\n            if (!swapped.has(otherInput)) {\n              swapped.add(otherInput);\n            }\n          }\n        }\n      }\n    }\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[{"oldStart":86,"oldLines":21,"newStart":86,"newLines":6,"lines":["     return gates.filter((g) => g.in1 === wire || g.in2 === wire);","   }"," ","-  function hasInputs(gate: Gate, a: string, b: string): boolean {","-    return (","-      (gate.in1 === a && gate.in2 === b) ||","-      (gate.in1 === b && gate.in2 === a)","-    );","-  }","-","-  function find