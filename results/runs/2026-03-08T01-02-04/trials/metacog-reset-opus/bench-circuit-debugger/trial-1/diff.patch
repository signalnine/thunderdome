n  const numBits = maxBit + 1;\n  const lastZ = `z${String(numBits).padStart(2, '0')}`;\n\n  const swapped = new Set<string>();\n\n  function isXY(w: string): boolean {\n    return /^[xy]\\d+$/.test(w);\n  }\n\n  function readsXY(g: Gate): boolean {\n    return isXY(g.in1) || isXY(g.in2);\n  }\n\n  function isXYGateForBit(g: Gate, bit: number): boolean {\n    const x = `x${String(bit).padStart(2, '0')}`;\n    const y = `y${String(bit).padStart(2, '0')}`;\n    return (\n      (g.in1 === x && g.in2 === y) || (g.in1 === y && g.in2 === x)\n    );\n  }\n\n  function getBitFromXYGate(g: Gate): number {\n    for (const w of [g.in1, g.in2]) {\n      const m = w.match(/^[xy](\\d+)$/);\n      if (m) return parseInt(m[1], 10);\n    }\n    return -1;\n  }\n\n  // Build lookup structures\n  const gateByOutput = new Map<string, Gate>();\n  for (const g of gates) {\n    gateByOutput.set(g.out, g);\n  }\n\n  function findGate(op: Gate['op'], in1: string, in2: string): Gate | undefined {\n    return gates.find(\n      (g) =>\n        g.op === op &&\n        ((g.in1 === in1 && g.in2 === in2) || (g.in1 === in2 && g.in2 === in1))\n    );\n  }\n\n  function findConsumers(wire: string): Gate[] {\n    return gates.filter((g) => g.in1 === wire || g.in2 === wire);\n  }\n\n  // Phase 1: Structural rules — each gate type has constraints on what\n  // its output wire can be named and how it should be consumed.\n  for (const g of gates) {\n    const out = g.out;\n    const isZ = out.startsWith('z');\n    const isLastZ = out === lastZ;\n\n    if (g.op === 'XOR') {\n      if (readsXY(g)) {\n        // Partial sum XOR — should NOT output z (except z00)\n        if (isZ && out !== 'z00') {\n          swapped.add(out);\n        }\n        // For non-bit-0, should be consumed by both XOR and AND\n        if (!isXYGateForBit(g, 0) && !isZ) {\n          const consumers = findConsumers(out);\n          const hasXorConsumer = consumers.some((c) => c.op === 'XOR');\n          const hasAndConsumer = consumers.some((c) => c.op === 'AND');\n          if (!hasXorConsumer || !hasAndConsumer) {\n            swapped.add(out);\n          }\n        }\n      } else {\n        // Final sum XOR — MUST output z\n        if (!isZ) {\n          swapped.add(out);\n        }\n      }\n    } else if (g.op === 'AND') {\n      // AND gate output should never be z\n      if (isZ) {\n        swapped.add(out);\n      }\n      // Non-bit-0 AND must feed into OR\n      if (!isXYGateForBit(g, 0)) {\n        const consumers = findConsumers(out);\n        if (!consumers.some((c) => c.op === 'OR') && !isZ) {\n          swapped.add(out);\n        }\n      }\n    } else if (g.op === 'OR') {\n      // Carry OR must not output z (except last z)\n      if (isZ && !isLastZ) {\n        swapped.add(out);\n      }\n      // Must be consumed by both XOR and AND (except last z)\n      if (!isLastZ && !isZ) {\n        const consumers = findConsumers(out);\n        const hasXorConsumer = consumers.some((c) => c.op === 'XOR');\n        const hasAndConsumer = consumers.some((c) => c.op === 'AND');\n        if (!hasXorConsumer || !hasAndConsumer) {\n          swapped.add(out);\n        }\n      }\n    }\n  }\n\n  // Phase 2: Trace the adder bit-by-bit to detect position mismatches.\n  // This catches swaps that Phase 1 misses (carry↔carry, carry↔partial-sum,\n  // bit-0 swaps) by verifying that each gate's inputs come from the\n  // correct bit position.\n  let carry: string | null = null;\n  for (let bit = 0; bit < numBits; bit++) {\n    const x = `x${String(bit).padStart(2, '0')}`;\n    const y = `y${String(bit).padStart(2, '0')}`;\n    const z = `z${String(bit).padStart(2, '0')}`;\n\n    // Find the XOR(x_i, y_i) gate - this always exists and its inputs\n    // can't be swapped (only outputs get swapped)\n    const xorXY = gates.find(\n      (g) =>\n        g.op === 'XOR' &&\n        ((g.in1 === x && g.in2 === y) || (g.in1 === y && g.in2 === x))\n    );\n    // Find the AND(x_i, y_i) gate\n    const andXY = gates.find(\n      (g) =>\n        g.op === 'AND' &&\n        ((g.in1 === x && g.in2 === y) || (g.in1 === y && g.in2 === x))\n    );\n\n    if (!xorXY || !andXY) continue;\n\n    if (bit === 0) {\n      // Half adder: XOR → z00, AND → carry_0\n      // If XOR output is not z00, it's swapped\n      if (xorXY.out !== z && !swapped.has(xorXY.out)) {\n        // xorXY.out is wrong - it should be z00\n        // Find what IS outputting z00\n        const zProducer = gateByOutput.get(z);\n        if (zProducer) {\n          // The XOR should output z00 but outputs something else\n          // The z00 producer should output something else but outputs z00\n          // Both are swapped\n          swapped.add(xorXY.out);\n          swapped.add(z);\n        }\n      }\n      // The AND output is carry_0\n      carry = andXY.out;\n\n\n      // Check if carry is already flagged - if so, we need to figure out\n      // what carry should actually be\n      if (swapped.has(carry)) {\n        carry = null;\n\n      }\n      continue;\n    }\n\n    // Full adder for bit > 0\n    const ps = xorXY.out; // partial sum wire\n    const gen = andXY.out; // generate wire\n\n    if (carry === null) {\n      // We lost track of the carry chain. Try to recover by finding\n      // what feeds into the XOR consumer of ps alongside ps.\n      const xorConsumers = findConsumers(ps).filter((c) => c.op === 'XOR');\n      if (xorConsumers.length === 1) {\n        const otherInput =\n          xorConsumers[0].in1 === ps ? xorConsumers[0].in2 : xorConsumers[0].in1;\n        carry = otherInput;\n      }\n    }\n\n    if (carry === null) continue;\n\n    // If ps was already flagged by Phase 1, skip tracing for this bit\n    if (swapped.has(ps)) {\n      carry = null;\n      continue;\n    }\n\n    // Find XOR(ps, carry) → should produce z_i\n    let sumGate = findGate('XOR', ps, carry);\n    let actualPS = ps;  // tracks the real partial sum wire for this bit\n\n    if (!sumGate) {\n      // Can't find XOR(ps, carry). One of ps or carry is in the wrong position.\n\n      // Look at ps's XOR consumers to find what carry it's actually paired with.\n      const psXorConsumers = findConsumers(ps).filter(\n        (c) => c.op === 'XOR'\n      );\n\n      if (psXorConsumers.length > 0) {\n        const xc = psXorConsumers[0];\n        const otherWire = xc.in1 === ps ? xc.in2 : xc.in1;\n\n        // ps is paired with otherWire instead of carry.\n        // Determine which is wrong: is carry misplaced, or is ps misplaced?\n        //\n        // If carry's producer is a valid carry gate (OR or bit-0 AND),\n        // and carry is consumed by a XOR that also consumes a valid XOR(x,y),\n        // then carry is in the right position and ps is swapped.\n        // Otherwise, carry is swapped.\n        let carryIsCorrect = false;\n        const carryXorConsumers = findConsumers(carry).filter(\n          (c) => c.op === 'XOR'\n        );\n        for (const cxc of carryXorConsumers) {\n          const cOther = cxc.in1 === carry ? cxc.in2 : cxc.in1;\n          const cOtherProd = gateByOutput.get(cOther);\n          if (cOtherProd && cOtherProd.op === 'XOR' && readsXY(cOtherProd)) {\n            // Verify bit alignment: the partial sum should be for bit `bit`\n            const psBitNum = getBitFromXYGate(cOtherProd);\n            if (psBitNum === bit) {\n              carryIsCorrect = true;\n              actualPS = cOther;\n              sumGate = cxc;\n              break;\n            }\n          }\n        }\n\n        if (carryIsCorrect) {\n          // ps is swapped (it ended up in the wrong bit position)\n          swapped.add(ps);\n        } else {\n          // Neither carry's XOR consumer pairs with a bit-aligned partial sum.\n          // Use z-wire output to determine which is in the right position.\n          //\n          // ps's XOR consumer (xc) outputs xc.out.\n          // carry's XOR consumer outputs some z wire.\n          // Whichever XOR consumer outputs z_{bit} is in the right position.\n          const carryXC = carryXorConsumers[0];\n          const psProducesCorrectZ = xc.out === z;\n          const carryProducesCorrectZ = carryXC && carryXC.out === z;\n\n          if (carryProducesCorrectZ && !psProducesCorrectZ) {\n            // carry's XOR consumer produces z_{bit} → carry is correct, ps is wrong\n            swapped.add(ps);\n            actualPS = carryXC.in1 === carry ? carryXC.in2 : carryXC.in1;\n            sumGate = carryXC;\n          } else if (psProducesCorrectZ && !carryProducesCorrectZ) {\n            // ps's XOR consumer produces z_{bit} → ps is correct, carry is wrong\n            swapped.add(carry);\n            swapped.add(otherWire);\n            carry = otherWire;\n            sumGate = xc;\n          } else {\n            // Neither or both produce correct z. Flag carry and otherWire.\n            swapped.add(carry);\n            swapped.add(otherWire);\n            carry = otherWire;\n            sumGate = xc;\n          }\n        }\n      } else {\n        // ps has no XOR consumer. Skip this bit.\n        carry = null;\n        continue;\n      }\n    }\n\n    // Verify the sum gate outputs z_i\n    if (sumGate && sumGate.out !== z) {\n      if (!swapped.has(sumGate.out)) {\n        swapped.add(sumGate.out);\n      }\n      if (!swapped.has(z)) {\n        swapped.add(z);\n      }\n    }\n\n    // Find AND(actualPS, carry) → propagate\n    const propGate = findGate('AND', actualPS, carry);\n    let prop: string | null = null;\n    if (propGate) {\n      prop = propGate.out;\n    }\n\n    // Find OR(gen, prop) → carry for next bit\n    if (bit === numBits - 1) {\n      carry = null;\n    } else if (prop !== null && !swapped.has(gen) && !swapped.has(prop)) {\n      const orGate = findGate('OR', gen, prop);\n      if (orGate) {\n        carry = orGate.out;\n  \n        if (swapped.has(carry)) {\n          carry = null;\n  \n        }\n      } else {\n        carry = null;\n\n      }\n    } else {\n      carry = null;\n      carryIsTraced = false;\n    }\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[{"oldStart":353,"oldLines":7,"newStart":353,"newLines":6,"lines":["       }","     } else {","       carry = null;","-      carryIsTraced = false;","     }","   }"," "]}],"userModified":false,"replaceAll":false}}
