 gates have unsatisfied deps\n    }\n  }\n\n  return wireValues;\n}\n\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Determine the number of input bits\n  let maxBit = 0;\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2]) {\n      const m = w.match(/^x(\\d+)$/);\n      if (m) {\n        maxBit = Math.max(maxBit, parseInt(m[1], 10));\n      }\n    }\n  }\n  const numBits = maxBit + 1;\n  const lastZ = `z${String(numBits).padStart(2, '0')}`;\n\n  const swapped = new Set<string>();\n\n  function isXY(w: string): boolean {\n    return /^[xy]\\d+$/.test(w);\n  }\n\n  function readsXY(g: Gate): boolean {\n    return isXY(g.in1) || isXY(g.in2);\n  }\n\n  function isXYGateForBit(g: Gate, bit: number): boolean {\n    const x = `x${String(bit).padStart(2, '0')}`;\n    const y = `y${String(bit).padStart(2, '0')}`;\n    return (\n      (g.in1 === x && g.in2 === y) || (g.in1 === y && g.in2 === x)\n    );\n  }\n\n  function getBitFromXYGate(g: Gate): number {\n    for (const w of [g.in1, g.in2]) {\n      const m = w.match(/^[xy](\\d+)$/);\n      if (m) return parseInt(m[1], 10);\n    }\n    return -1;\n  }\n\n  function getBitFromGate(g: Gate): number {\n    for (const w of [g.in1, g.in2]) {\n      const m = w.match(/^[xy](\\d+)$/);\n      if (m) return parseInt(m[1], 10);\n    }\n    for (const w of [g.in1, g.in2]) {\n      const producer = gateByOutput.get(w);\n      if (producer) {\n        for (const w2 of [producer.in1, producer.in2]) {\n          const m = w2.match(/^[xy](\\d+)$/);\n          if (m) return parseInt(m[1], 10);\n        }\n      }\n    }\n    return -1;\n  }\n\n  // Build lookup structures\n  const gateByOutput = new Map<string, Gate>();\n  for (const g of gates) {\n    gateByOutput.set(g.out, g);\n  }\n\n  function findConsumers(wire: string): Gate[] {\n    return gates.filter((g) => g.in1 === wire || g.in2 === wire);\n  }\n\n  // Phase 1: Structural rules — each gate type has constraints on what\n  // its output wire can be named and how it should be consumed.\n  for (const g of gates) {\n    const out = g.out;\n    const isZ = out.startsWith('z');\n    const isLastZ = out === lastZ;\n\n    if (g.op === 'XOR') {\n      if (readsXY(g)) {\n        // Partial sum XOR — should NOT output z (except z00)\n        if (isZ && out !== 'z00') {\n          swapped.add(out);\n        }\n        // For non-bit-0, should be consumed by both XOR and AND\n        if (!isXYGateForBit(g, 0) && !isZ) {\n          const consumers = findConsumers(out);\n          const hasXorConsumer = consumers.some((c) => c.op === 'XOR');\n          const hasAndConsumer = consumers.some((c) => c.op === 'AND');\n          if (!hasXorConsumer || !hasAndConsumer) {\n            swapped.add(out);\n          }\n        }\n      } else {\n        // Final sum XOR — MUST output z\n        if (!isZ) {\n          swapped.add(out);\n        }\n      }\n    } else if (g.op === 'AND') {\n      // AND gate output should never be z\n      if (isZ) {\n        swapped.add(out);\n      }\n      // Non-bit-0 AND must feed into OR\n      if (!isXYGateForBit(g, 0)) {\n        const consumers = findConsumers(out);\n        if (!consumers.some((c) => c.op === 'OR') && !isZ) {\n          swapped.add(out);\n        }\n      }\n    } else if (g.op === 'OR') {\n      // Carry OR must not output z (except last z)\n      if (isZ && !isLastZ) {\n        swapped.add(out);\n      }\n      // Must be consumed by both XOR and AND (except last z)\n      if (!isLastZ && !isZ) {\n        const consumers = findConsumers(out);\n        const hasXorConsumer = consumers.some((c) => c.op === 'XOR');\n        const hasAndConsumer = consumers.some((c) => c.op === 'AND');\n        if (!hasXorConsumer || !hasAndConsumer) {\n          swapped.add(out);\n        }\n      }\n    }\n  }\n\n  // Phase 2: Cross-check carry connections (OR gate outputs).\n  // A carry wire's XOR consumer should have a XOR(x,y) partial sum as\n  // its other input. If not, the carry is misplaced.\n  for (const g of gates) {\n    const out = g.out;\n    if (swapped.has(out)) continue;\n\n    if (g.op === 'OR' && out !== lastZ && !out.startsWith('z')) {\n      const consumers = findConsumers(out);\n      const xorConsumer = consumers.find((c) => c.op === 'XOR');\n      if (xorConsumer) {\n        const otherInput =\n          xorConsumer.in1 === out ? xorConsumer.in2 : xorConsumer.in1;\n        const otherProducer = gateByOutput.get(otherInput);\n        if (\n          otherProducer &&\n          !(otherProducer.op === 'XOR' && readsXY(otherProducer))\n        ) {\n          if (!swapped.has(otherInput)) {\n            swapped.add(out);\n          }\n        }\n      }\n    }\n  }\n\n  // Phase 3: Verify carry-to-bit-position consistency.\n  // For each carry gate (OR or bit-0 AND), determine its bit number,\n  // then verify its XOR consumer pairs it with the partial sum of the\n  // NEXT bit. If mismatched, determine which wire is wrong.\n  for (const g of gates) {\n    const out = g.out;\n    if (swapped.has(out)) continue;\n\n    const isCarryGate =\n      (g.op === 'OR' && out !== lastZ && !out.startsWith('z')) ||\n      (g.op === 'AND' && isXYGateForBit(g, 0));\n\n    if (!isCarryGate) continue;\n\n    const carryBit = getBitFromGate(g);\n    if (carryBit < 0) continue;\n    const expectedNextBit = carryBit + 1;\n\n    const consumers = findConsumers(out);\n    const xorConsumer = consumers.find((c) => c.op === 'XOR');\n    if (!xorConsumer) continue;\n\n    const otherInput =\n      xorConsumer.in1 === out ? xorConsumer.in2 : xorConsumer.in1;\n    const otherProducer = gateByOutput.get(otherInput);\n\n    if (\n      !otherProducer ||\n      !(otherProducer.op === 'XOR' && readsXY(otherProducer))\n    ) {\n      // The other input is not a partial sum XOR(x,y).\n      // For bit-0 AND, this means carry is misplaced.\n      if (g.op === 'AND') {\n        swapped.add(out);\n      }\n      // For OR gates, this is already caught by Phase 2.\n      continue;\n    }\n\n    const psBit = getBitFromXYGate(otherProducer);\n    if (psBit === expectedNextBit) continue; // Correct pairing\n\n    // Mismatch: carry from bit carryBit is paired with partial sum\n    // from bit psBit instead of bit expectedNextBit.\n    // Determine which is wrong by checking the XOR consumer's output.\n    const xorOut = xorConsumer.out;\n    const expectedZ = `z${String(expectedNextBit).padStart(2, '0')}`;\n    const psExpectedZ = `z${String(psBit).padStart(2, '0')}`;\n\n    if (xorOut === psExpectedZ) {\n      // The XOR outputs z for the partial sum's bit — the partial sum\n      // is in the right position, so the carry is misplaced.\n      swapped.add(out);\n    } else if (xorOut === expectedZ) {\n      // The XOR outputs z for the carry's expected next bit — the carry\n      // is in the right position, so the partial sum is misplaced.\n      if (!swapped.has(otherInput)) {\n        swapped.add(otherInput);\n      }\n    } else {\n      // Neither matches. Flag the carry.\n      swapped.add(out);\n    }\n  }\n\n  // Phase 4: Verify partial-sum-to-bit-position consistency.\n  // For each XOR(x_i, y_i) partial sum (non-bit-0), check that its\n  // XOR consumer outputs z_i. If it outputs a different z, the partial\n  // sum is in the wrong bit position.\n  for (const g of gates) {\n    const out = g.out;\n    if (swapped.has(out)) continue;\n\n    if (g.op === 'XOR' && readsXY(g) && !isXYGateForBit(g, 0) && !out.startsWith('z')) {\n      const psBit = getBitFromXYGate(g);\n      const expectedZ = `z${String(psBit).padStart(2, '0')}`;\n\n      const consumers = findConsumers(out);\n      const xorConsumer = consumers.find((c) => c.op === 'XOR');\n      if (xorConsumer) {\n        if (xorConsumer.out !== expectedZ) {\n          // This partial sum feeds into a different z wire.\n          // Check if the z wire it feeds into is already flagged.\n          if (!swapped.has(xorConsumer.out)) {\n            swapped.add(out);\n         