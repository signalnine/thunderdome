 }\n  }\n\n  // Phase 5: Check bit-0 AND gate connectivity.\n  // The bit-0 AND output should be consumed by XOR and AND gates that\n  // process bit 1. Verify the XOR consumer has a XOR(x01,y01) partial\n  // sum as its other input.\n  for (const g of gates) {\n    const out = g.out;\n    if (swapped.has(out)) continue;\n\n    if (g.op === 'AND' && isXYGateForBit(g, 0)) {\n      const consumers = findConsumers(out);\n      const xorConsumer = consumers.find((c) => c.op === 'XOR');\n      if (xorConsumer) {\n        const otherInput =\n          xorConsumer.in1 === out ? xorConsumer.in2 : xorConsumer.in1;\n        const otherProducer = gateByOutput.get(otherInput);\n        if (otherProducer && otherProducer.op === 'XOR' && readsXY(otherProducer)) {\n          // Check the partial sum is for bit 1\n          if (!isXYGateForBit(otherProducer, 1)) {\n            swapped.add(out);\n          }\n        } else if (otherProducer) {\n          // Other input is not a XOR(x,y) — carry is misplaced\n          swapped.add(out);\n        }\n      }\n    }\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[{"oldStart":76,"oldLines":37,"newStart":76,"newLines":20,"lines":["     );","   }"," ","-  function getBitFromXYGate(g: Gate): number {","-    for (const w of [g.in1, g.in2]) {","-      const m = w.match(/^[xy](\\d+)$/);","-      if (m) return parseInt(m[1], 10);","-    }","-    return -1;","-  }","-","-  function getBitFromGate(g: Gate): number {","-    for (const w of [g.in1, g.in2]) {","-      const m = w.match(/^[xy](\\d+)$/);","-      if (m) return parseInt(m[1], 10);","-    }","-    for (const w of [g.in1, g.in2]) {","-      const producer = gateByOutput.get(w);","-      if (producer) {","-        for (const w2 of [producer.in1, producer.in2]) {","-          const m = w2.match(/^[xy](\\d+)$/);","-          if (m) return parseInt(m[1], 10);","-        }","-      }","-    }","-    return -1;","-  }","-","   // Build lookup structures","   const gateByOutput 