ept the last z)\n  // Rule 7: XOR gates with x/y inputs should feed into exactly one XOR gate\n  //         and one AND gate (except bit 0 which feeds z directly)\n  // Rule 8: AND gates with x/y inputs' outputs should be consumed by OR gates\n  // Rule 9: AND gates without x/y inputs' outputs should be consumed by OR gates\n\n  // Apply structural rules to find anomalies\n  for (const g of gates) {\n    const out = g.out;\n    const isZ = out.startsWith('z');\n    const isLastZ = out === lastZ;\n\n    if (g.op === 'XOR') {\n      if (readsXY(g)) {\n        // XOR with x/y inputs = partial sum gate\n        // Should output to z only for bit 0\n        if (isZ && out !== 'z00') {\n          // This partial sum XOR is incorrectly outputting to a z wire\n          swapped.add(out);\n        }\n        // For non-bit-0, the output should be consumed by exactly one XOR\n        // and one AND gate\n        if (!isXYGate(g, 0)) {\n          const consumers = findConsumers(out);\n          const xorConsumers = consumers.filter((c) => c.op === 'XOR');\n          const andConsumers = consumers.filter((c) => c.op === 'AND');\n          if (xorConsumers.length === 0 && andConsumers.length === 0 && !isZ) {\n            // Output is not consumed by any XOR or AND — it's swapped\n            swapped.add(out);\n          }\n        }\n      } else {\n        // XOR without x/y inputs = final sum gate\n        // Should always output to z\n        if (!isZ) {\n          swapped.add(out);\n        }\n      }\n    } else if (g.op === 'AND') {\n      // AND gate output should never be z\n      if (isZ && !isLastZ) {\n        swapped.add(out);\n      }\n      // AND gate output should be consumed by an OR gate (not by an XOR or AND)\n      // Exception: bit 0's AND (carry) feeds into XOR and AND of bit 1\n      if (!isXYGate(g, 0)) {\n        const consumers = findConsumers(out);\n        const orConsumers = consumers.filter((c) => c.op === 'OR');\n        if (orConsumers.length === 0 && !isZ) {\n          // Not consumed by OR — likely swapped\n          swapped.add(out);\n        }\n      }\n    } else if (g.op === 'OR') {\n      // OR gate produces carry — should not output to z (except last z)\n      if (isZ && !isLastZ) {\n        swapped.add(out);\n      }\n      // OR gate output should be consumed by XOR and AND gates (carry input)\n      // Exception: last bit's OR outputs to z_N\n      if (!isLastZ) {\n        const consumers = findConsumers(out);\n        const xorConsumers = consumers.filter((c) => c.op === 'XOR');\n        const andConsumers = consumers.filter((c) => c.op === 'AND');\n        if (xorConsumers.length === 0 || andConsumers.length === 0) {\n          // Carry not properly consumed\n          if (!isZ) {\n            swapped.add(out);\n          }\n        }\n      }\n    }\n  }\n\n  return [...swapped].sort();\n}","originalFile":"export interface Gate {\n  op: 'AND' | 'OR' | 'XOR';\n  in1: string;\n  in2: string;\n  out: string;\n}\n\nexport function simulate(\n  gates: Gate[],\n  inputs: Record<string, number>\n): Record<string, number> {\n  const wireValues: Record<string, number> = { ...inputs };\n  const remaining = [...gates];\n\n  while (remaining.length > 0) {\n    let progress = false;\n    for (let i = remaining.length - 1; i >= 0; i--) {\n      const gate = remaining[i];\n      const v1 = wireValues[gate.in1];\n      const v2 = wireValues[gate.in2];\n      if (v1 !== undefined && v2 !== undefined) {\n        let result: number;\n        switch (gate.op) {\n          case 'AND':\n            result = v1 & v2;\n            break;\n          case 'OR':\n            result = v1 | v2;\n            break;\n          case 'XOR':\n            result = v1 ^ v2;\n            break;\n        }\n        wireValues[gate.out] = result;\n        remaining.splice(i, 1);\n        progress = true;\n      }\n    }\n    if (!progress) {\n      break; // No gate could fire — remaining gates have unsatisfied deps\n    }\n  }\n\n  return wireValues;\n}\n\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Work on a deep copy so we don't mutate the input\n  const gs: Gate[] = gates.map((g) => ({ ...g }));\n\n  // Build lookup structures\n  const gateByOutput = new Map<string, Gate>();\n  for (const g of gs) {\n    gateByOutput.set(g.out, g);\n  }\n\n  // Determine the number of input bits by finding the highest x-input\n  let maxBit = 0;\n  for (const g of gs) {\n    for (const w of [g.in1, g.in2]) {\n      const m = w.match(/^x(\\d+)$/);\n      if (m) {\n        maxBit = Math.max(maxBit, parseInt(m[1], 10));\n      }\n    }\n  }\n  const numBits = maxBit + 1;\n\n  const swapped = new Set<string>();\n\n  // Swap two gate outputs and fix all references\n  function doSwap(wire1: string, wire2: string): void {\n    // Find gates producing these wires\n    const g1 = gateByOutput.get(wire1)!;\n    const g2 = gateByOutput.get(wire2)!;\n\n    // Swap outputs\n    g1.out = wire2;\n    g2.out = wire1;\n    gateByOutput.set(wire1, g2);\n    gateByOutput.set(wire2, g1);\n\n    // Swap all input references too (so the full circuit is repaired)\n    for (const g of gs) {\n      if (g.in1 === wire1) g.in1 = wire2;\n      else if (g.in1 === wire2) g.in1 = wire1;\n      if (g.in2 === wire1) g.in2 = wire2;\n      else if (g.in2 === wire2) g.in2 = wire1;\n    }\n\n    swapped.add(wire1);\n    swapped.add(wire2);\n  }\n\n  function hasInputs(gate: Gate, a: string, b: string): boolean {\n    return (\n      (gate.in1 === a && gate.in2 === b) ||\n      (gate.in1 === b && gate.in2 === a)\n    );\n  }\n\n  function findGateByOpAndInputs(\n    op: Gate['op'],\n    a: string,\n    b: string\n  ): Gate | undefined {\n    return gs.find((g) => g.op === op && hasInputs(g, a, b));\n  }\n\n  // Trace through the adder structure bit by bit\n  let carry = '';\n\n  for (let bit = 0; bit < numBits; bit++) {\n    const xWire = `x${String(bit).padStart(2, '0')}`;\n    const yWire = `y${String(bit).padStart(2, '0')}`;\n    const zWire = `z${String(bit).padStart(2, '0')}`;\n\n    if (bit === 0) {\n      // Bit 0: half adder\n      const xorGate = findGateByOpAndInputs('XOR', xWire, yWire);\n      if (xorGate) {\n        if (xorGate.out !== zWire) {\n          doSwap(xorGate.out, zWire);\n        }\n      }\n      const andGate = findGateByOpAndInputs('AND', xWire, yWire);\n      if (andGate) {\n        carry = andGate.out;\n      }\n    } else {\n      // Full adder for bit i\n      // Step 1: x_i XOR y_i -> t_i (partial sum)\n      const xorXY = findGateByOpAndInputs('XOR', xWire, yWire);\n      if (!xorXY) continue;\n      let tWire = xorXY.out;\n\n      // Step 2: t_i XOR carry -> z_i (final sum)\n      let xorTC = findGateByOpAndInputs('XOR', tWire, carry);\n\n      if (!xorTC) {\n        // tWire or carry might be swapped with something else\n        // Look for an XOR gate that has carry as an input (other than xorXY)\n        const xorWithCarry = gs.find(\n          (g) =>\n            g.op === 'XOR' &&\n            g !== xorXY &&\n            (g.in1 === carry || g.in2 === carry)\n        );\n        if (xorWithCarry) {\n          const otherInput =\n            xorWithCarry.in1 === carry\n              ? xorWithCarry.in2\n              : xorWithCarry.in1;\n          doSwap(tWire, otherInput);\n          tWire = otherInput;\n          xorTC = xorWithCarry;\n        } else {\n          // No XOR with carry — carry itself might be swapped\n          const xorWithT = gs.find(\n            (g) =>\n              g.op === 'XOR' &&\n              g !== xorXY &&\n              (g.in1 === tWire || g.in2 === tWire)\n          );\n          if (xorWithT) {\n            const otherInput =\n              xorWithT.in1 === tWire ? xorWithT.in2 : xorWithT.in1;\n            doSwap(carry, otherInput);\n            carry = otherInput;\n            xorTC = xorWithT;\n          }\n        }\n      }\n\n      if (xorTC) {\n        if (xorTC.out !== zWire) {\n          doSwap(xorTC.out, zWir