// Find OR gate with genWire as input\n          const orConsumer = gates.find(\n            (g) => g.op === 'OR' && (g.in1 === genWire || g.in2 === genWire)\n          );\n          if (orConsumer) {\n            carry = orConsumer.out;\n          }\n        }\n        continue;\n      }\n\n      // Look for the final sum XOR: tWire XOR carry -> zWire\n      const xorTC = findGateByOpAndInputs('XOR', tWire, carry);\n\n      if (!xorTC) {\n        // The gate for bit i's final sum should exist.\n        // Since tWire is not flagged, carry might be the problem.\n        // Look at the z-wire gate to find what the carry SHOULD be.\n        const zGate = gateByOutput.get(zWire);\n        if (zGate && zGate.op === 'XOR' && !swapped.has(zWire)) {\n          // One input should be tWire, the other should be the real carry\n          if (zGate.in1 === tWire || zGate.in2 === tWire) {\n            const realCarry =\n              zGate.in1 === tWire ? zGate.in2 : zGate.in1;\n            // carry was supposed to be realCarry but got swapped\n            if (realCarry !== carry) {\n              swapped.add(carry);\n              swapped.add(realCarry);\n              carry = realCarry;\n            }\n          } else {\n            // Neither input is tWire — both might be swapped\n            // Try: one input should be from XOR(x,y), the other from carry chain\n            // We already know tWire is the output of XOR(x,y) for this bit,\n            // but the z-gate doesn't use it. This means carry is in the z-gate\n            // and tWire should be there but isn't.\n            // The carry we're tracking must be wrong.\n            // Let me try finding XOR gate with tWire that's not xorXY\n            const altXor = gates.find(\n              (g) =>\n                g.op === 'XOR' &&\n                g !== xorXY &&\n                (g.in1 === tWire || g.in2 === tWire)\n            );\n            if (altXor) {\n              const otherInput =\n                altXor.in1 === tWire ? altXor.in2 : altXor.in1;\n              // The real carry is otherInput, and carry was swapped with something\n              swapped.add(carry);\n              swapped.add(otherInput);\n              carry = otherInput;\n            }\n          }\n        }\n      }\n\n      // Now find carry for next bit\n      // AND(x,y) -> genWire\n      const andXY = findGateByOpAndInputs('AND', xWire, yWire);\n      if (!andXY) continue;\n      const genWire = andXY.out;\n\n      // AND(tWire, carry) -> propWire\n      const andTC = findGateByOpAndInputs('AND', tWire, carry);\n      if (!andTC) continue;\n      const propWire = andTC.out;\n\n      // OR(genWire, propWire) -> next carry\n      const orGate = findGateByOpAndInputs('OR', genWire, propWire);\n      if (orGate) {\n        carry = orGate.out;\n      }\n    }\n  }\n\n  return [...swapped].sort();\n}","new_string":"  // Phase 2: Cross-check carry/partial-sum connections\n  // For each OR gate output (carry), verify that its XOR consumer's\n  // other input is from a XOR(x,y) gate. And vice versa.\n  // Only flag wires not already flagged in Phase 1.\n  for (const g of gates) {\n    const out = g.out;\n    if (swapped.has(out)) continue;\n\n    if (g.op === 'OR' && out !== lastZ && !out.startsWith('z')) {\n      // Carry wire: its XOR consumer's other input should be from XOR(x,y)\n      const consumers = findConsumers(out);\n      const xorConsumer = consumers.find((c) => c.op === 'XOR');\n      if (xorConsumer) {\n        const otherInput =\n          xorConsumer.in1 === out ? xorConsumer.in2 : xorConsumer.in1;\n        const otherProducer = gateByOutput.get(otherInput);\n        if (otherProducer && !(otherProducer.op === 'XOR' && readsXY(otherProducer))) {\n          // The other input is not from a partial sum XOR — this carry is misplaced\n          if (!swapped.has(otherInput)) {\n            swapped.add(out);\n          }\n        }\n      }\n    }\n\n    if (g.op === 'XOR' && readsXY(g) && !i