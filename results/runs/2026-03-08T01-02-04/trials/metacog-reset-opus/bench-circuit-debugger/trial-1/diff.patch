rt(2, '0')}`;\n\n    // Find the XOR(x_i, y_i) gate - this always exists and its inputs\n    // can't be swapped (only outputs get swapped)\n    const xorXY = gates.find(\n      (g) =>\n        g.op === 'XOR' &&\n        ((g.in1 === x && g.in2 === y) || (g.in1 === y && g.in2 === x))\n    );\n    // Find the AND(x_i, y_i) gate\n    const andXY = gates.find(\n      (g) =>\n        g.op === 'AND' &&\n        ((g.in1 === x && g.in2 === y) || (g.in1 === y && g.in2 === x))\n    );\n\n    if (!xorXY || !andXY) continue;\n\n    if (bit === 0) {\n      // Half adder: XOR → z00, AND → carry_0\n      // If XOR output is not z00, it's swapped\n      if (xorXY.out !== z && !swapped.has(xorXY.out)) {\n        // xorXY.out is wrong - it should be z00\n        // Find what IS outputting z00\n        const zProducer = gateByOutput.get(z);\n        if (zProducer) {\n          // The XOR should output z00 but outputs something else\n          // The z00 producer should output something else but outputs z00\n          // Both are swapped\n          swapped.add(xorXY.out);\n          swapped.add(z);\n        }\n      }\n      // The AND output is carry_0\n      carry = andXY.out;\n\n      // Check if carry is already flagged - if so, we need to figure out\n      // what carry should actually be\n      if (swapped.has(carry)) {\n        // carry was flagged by Phase 1 - we can't rely on it for tracing.\n        // Try to find the swap partner and use that instead.\n        carry = null;\n      }\n      continue;\n    }\n\n    // Full adder for bit > 0\n    const ps = xorXY.out; // partial sum wire\n    const gen = andXY.out; // generate wire\n\n    if (carry === null) {\n      // We lost track of the carry chain. Try to recover by finding\n      // what feeds into the XOR consumer of ps alongside ps.\n      const xorConsumers = findConsumers(ps).filter((c) => c.op === 'XOR');\n      if (xorConsumers.length === 1) {\n        const otherInput =\n          xorConsumers[0].in1 === ps ? xorConsumers[0].in2 : xorConsumers[0].in1;\n        carry = otherInput;\n      }\n    }\n\n    if (carry === null) continue;\n\n    // If ps was already flagged by Phase 1, skip tracing for this bit\n    if (swapped.has(ps)) {\n      carry = null;\n      continue;\n    }\n\n    // Find XOR(ps, carry) → should produce z_i\n    let sumGate = findGate('XOR', ps, carry);\n    let actualPS = ps;  // tracks the real partial sum wire for this bit\n\n    if (!sumGate) {\n      // Can't find XOR(ps, carry). One of ps or carry is in the wrong position.\n\n      // Look at ps's XOR consumers to find what carry it's actually paired with.\n      const psXorConsumers = findConsumers(ps).filter(\n        (c) => c.op === 'XOR'\n      );\n\n      if (psXorConsumers.length > 0) {\n        const xc = psXorConsumers[0];\n        const otherWire = xc.in1 === ps ? xc.in2 : xc.in1;\n\n        // ps is paired with otherWire instead of carry.\n        // Determine which is wrong: is carry misplaced, or is ps misplaced?\n        //\n        // If carry's producer is a valid carry gate (OR or bit-0 AND),\n        // and carry is consumed by a XOR that also consumes a valid XOR(x,y),\n        // then carry is in the right position and ps is swapped.\n        // Otherwise, carry is swapped.\n        let carryIsCorrect = false;\n        const carryXorConsumers = findConsumers(carry).filter(\n          (c) => c.op === 'XOR'\n        );\n        for (const cxc of carryXorConsumers) {\n          const cOther = cxc.in1 === carry ? cxc.in2 : cxc.in1;\n          const cOtherProd = gateByOutput.get(cOther);\n          if (cOtherProd && cOtherProd.op === 'XOR' && readsXY(cOtherProd)) {\n            carryIsCorrect = true;\n            // Use this gate as the sum gate and the other partial sum\n            actualPS = cOther;\n            sumGate = cxc;\n            break;\n          }\n        }\n\n        if (carryIsCorrect) {\n          // ps is swapped (it ended up in the wrong bit position)\n          swap