ld lookup structures\n  const gateByOutput = new Map<string, Gate>();\n  for (const g of gates) {\n    gateByOutput.set(g.out, g);\n  }\n\n  // Find a gate by its operation and input wires (order-independent)\n  function findGate(\n    op: Gate['op'],\n    in1: string,\n    in2: string\n  ): Gate | undefined {\n    return gates.find(\n      (g) =>\n        g.op === op &&\n        ((g.in1 === in1 && g.in2 === in2) ||\n          (g.in1 === in2 && g.in2 === in1))\n    );\n  }\n\n  // Determine the number of input bits by finding the highest x-input\n  let maxBit = 0;\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2]) {\n      const m = w.match(/^x(\\d+)$/);\n      if (m) {\n        maxBit = Math.max(maxBit, parseInt(m[1], 10));\n      }\n    }\n  }\n  const numBits = maxBit + 1;\n\n  const swapped = new Set<string>();\n\n  // Strategy: walk through each bit position of the adder and validate\n  // the structural pattern. When we find mismatches, identify swaps.\n  //\n  // For a ripple-carry adder:\n  //   Bit 0:  x00 XOR y00 -> z00,  x00 AND y00 -> carry0\n  //   Bit i:  x_i XOR y_i -> t_i\n  //           t_i XOR carry_{i-1} -> z_i\n  //           x_i AND y_i -> gen_i\n  //           t_i AND carry_{i-1} -> prop_i\n  //           gen_i OR prop_i -> carry_i\n  //   Final:  carry_{N-1} -> z_N\n\n  // We'll trace through the adder structure, tracking the carry wire at\n  // each bit. When we detect a structural violation, we identify the swap.\n\n  function hasInputs(gate: Gate, a: string, b: string): boolean {\n    return (\n      (gate.in1 === a && gate.in2 === b) ||\n      (gate.in1 === b && gate.in2 === a)\n    );\n  }\n\n  // Find gate by op and inputs\n  function findGateByOpAndInputs(\n    op: Gate['op'],\n    a: string,\n    b: string\n  ): Gate | undefined {\n    return gates.find((g) => g.op === op && hasInputs(g, a, b));\n  }\n\n  // Swap two gate outputs\n  function doSwap(wire1: string, wire2: string): void {\n    const g1 = gateByOutput.get(wire1)!;\n    const g2 = gateByOutput.get(wire2)!;\n    // Swap the out fields\n    g1.out = wire2;\n    g2.out = wire1;\n    gateByOutput.set(wire1, g2);\n    gateByOutput.set(wire2, g1);\n    swapped.add(wire1);\n    swapped.add(wire2);\n  }\n\n  // Verify/fix the adder structure bit by bit\n  let carry = '';\n\n  for (let bit = 0; bit < numBits; bit++) {\n    const xWire = `x${String(bit).padStart(2, '0')}`;\n    const yWire = `y${String(bit).padStart(2, '0')}`;\n    const zWire = `z${String(bit).padStart(2, '0')}`;\n\n    if (bit === 0) {\n      // Bit 0: half adder\n      // x00 XOR y00 -> z00\n      const xorGate = findGateByOpAndInputs('XOR', xWire, yWire);\n      if (xorGate) {\n        if (xorGate.out !== zWire) {\n          // The XOR output is swapped with something\n          doSwap(xorGate.out, zWire);\n        }\n      }\n      // x00 AND y00 -> carry\n      const andGate = findGateByOpAndInputs('AND', xWire, yWire);\n      if (andGate) {\n        carry = andGate.out;\n      }\n    } else {\n      // Full adder for bit i\n      // Step 1: x_i XOR y_i -> t_i (partial sum)\n      const xorXY = findGateByOpAndInputs('XOR', xWire, yWire);\n      if (!xorXY) continue;\n      let tWire = xorXY.out;\n\n      // Step 2: t_i XOR carry -> z_i (final sum)\n      let xorTC = findGateByOpAndInputs('XOR', tWire, carry);\n\n      if (!xorTC) {\n        // Maybe tWire or carry is swapped.\n        // Check: is there an XOR gate that uses carry as one input?\n        // If tWire was swapped with something, the actual partial sum\n        // might be somewhere else.\n        // Also check: is there an XOR gate outputting z_i? That could\n        // tell us what the correct partial sum wire should be.\n\n        // Strategy: Look for any XOR gate that has carry as an input\n        const xorWithCarry = gates.find(\n          (g) =>\n            g.op === 'XOR' &&\n            (g.in1 === carry || g.in2 === carry)\n        );\n        if (xorWithCarry) {\n          // The othe