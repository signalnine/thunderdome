...gates];\n\n  while (remaining.length > 0) {\n    let progress = false;\n    for (let i = remaining.length - 1; i >= 0; i--) {\n      const gate = remaining[i];\n      const v1 = wireValues[gate.in1];\n      const v2 = wireValues[gate.in2];\n      if (v1 !== undefined && v2 !== undefined) {\n        let result: number;\n        switch (gate.op) {\n          case 'AND':\n            result = v1 & v2;\n            break;\n          case 'OR':\n            result = v1 | v2;\n            break;\n          case 'XOR':\n            result = v1 ^ v2;\n            break;\n        }\n        wireValues[gate.out] = result;\n        remaining.splice(i, 1);\n        progress = true;\n      }\n    }\n    if (!progress) {\n      break; // No gate could fire — remaining gates have unsatisfied deps\n    }\n  }\n\n  return wireValues;\n}\n\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Build lookup structures\n  const gateByOutput = new Map<string, Gate>();\n  for (const g of gates) {\n    gateByOutput.set(g.out, g);\n  }\n\n  // Determine the number of input bits by finding the highest x-input\n  let maxBit = 0;\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2]) {\n      const m = w.match(/^x(\\d+)$/);\n      if (m) {\n        maxBit = Math.max(maxBit, parseInt(m[1], 10));\n      }\n    }\n  }\n  const numBits = maxBit + 1;\n\n  const swapped = new Set<string>();\n\n  // Strategy: walk through each bit position of the adder and validate\n  // the structural pattern. When we find mismatches, identify swaps.\n  //\n  // For a ripple-carry adder:\n  //   Bit 0:  x00 XOR y00 -> z00,  x00 AND y00 -> carry0\n  //   Bit i:  x_i XOR y_i -> t_i\n  //           t_i XOR carry_{i-1} -> z_i\n  //           x_i AND y_i -> gen_i\n  //           t_i AND carry_{i-1} -> prop_i\n  //           gen_i OR prop_i -> carry_i\n  //   Final:  carry_{N-1} -> z_N\n\n  // We'll trace through the adder structure, tracking the carry wire at\n  // each bit. When we detect a str