+// src/index.test.ts
+
+import { describe, it, expect, beforeEach, vi } from 'vitest';
+import { TimeTracker, TimeEntry, TimeTrackerConfig } from './index';
+import * as fs from 'node:fs/promises';
+import * as path from 'node:path';
+import { Console } from 'node:console';
+
+// Mock the file system operations
+vi.mock('node:fs/promises', () => ({
+  readFile: vi.fn(),
+  writeFile: vi.fn(),
+  mkdir: vi.fn(),
+}));
+
+// Suppress console.error in tests for expected errors
+const originalConsoleError = console.error;
+beforeEach(() => {
+  console.error = vi.fn();
+});
+
+describe('TimeTracker', () => {
+  const testFilePath = path.join(process.cwd(), 'test-data', 'time-tracker.json');
+  let tracker: TimeTracker;
+
+  beforeEach(async () => {
+    vi.useFakeTimers();
+    vi.restoreAllMocks(); // Restore all mocks to ensure a clean slate, especially for Date.now()
+    // Reset mocks before each test
+    vi.clearAllMocks();
+    // Default mock for readFile to return empty data (no existing file)
+    (fs.readFile as vi.Mock).mockResolvedValue('{}');
+    (fs.writeFile as vi.Mock).mockResolvedValue(undefined);
+    (fs.mkdir as vi.Mock).mockResolvedValue(undefined);
+
+    const config: TimeTrackerConfig = { filePath: testFilePath };
+    tracker = new TimeTracker(config);
+    await tracker.initialize();
+  });
+
+  // No need for afterAll for console.error as beforeEach sets it to vi.fn()
+  // afterAll(() => {
+  //   console.error = originalConsoleError;
+  // });
+
+  it('should initialize with no entries if file does not exist or is empty', async () => {
+    (fs.readFile as vi.Mock).mockResolvedValueOnce('{}'); // Ensure it reads an empty object
+    const config: TimeTrackerConfig = { filePath: testFilePath };
+    const newTracker = new TimeTracker(config);
+    await newTracker.initialize();
+    expect(newTracker.getAllEntries()).toEqual([]);
+  });
+
+  it('should load existing entries and current running entry from file', async () => {
+    const mockData = {
+      entries: [
+        { taskName: 'Task A', startTime: new Date('2023-01-01T09:00:00Z'), stopTime: new Date('2023-01-01T10:00:00Z') },
+      ],
+      currentRunningEntry: { taskName: 'Task B', startTime: new Date('2023-01-01T10:30:00Z'), stopTime: null },
+    };
+    (fs.readFile as vi.Mock).mockResolvedValueOnce(JSON.stringify(mockData));
+
+    const config: TimeTrackerConfig = { filePath: testFilePath };
+    const newTracker = new TimeTracker(config);
+    await newTracker.initialize();
+
+    expect(newTracker.getAllEntries().length).toBe(1);
+    expect(newTracker.getAllEntries()[0].taskName).toBe('Task A');
+    // For checking current running entry, we can't directly access private member.
+    // We'll rely on startTimer/stopTimer behavior for this.
+  });
+
+  it('should start a new timer', async () => {
+    await tracker.startTimer('Task 1');
+    expect(tracker.getAllEntries().length).toBe(1);
+    expect(tracker.getAllEntries()[0].taskName).toBe('Task 1');
+    expect(tracker.getAllEntries()[0].stopTime).toBeNull();
+    expect(fs.writeFile).toHaveBeenCalled();
+  });
+
+  it('should throw error when starting timer with empty task name', async () => {
+    await expect(tracker.startTimer('')).rejects.toThrow('Task name cannot be empty.');
+  });
+
+  it('should stop the currently running timer', async () => {
+    await tracker.startTimer('Task 2');
+    const stoppedEntry = await tracker.stopTimer();
+    expect(stoppedEntry.taskName).toBe('Task 2');
+    expect(stoppedEntry.stopTime).not.toBeNull();
+    expect(tracker.getAllEntries()[0].stopTime).not.toBeNull();
+    expect(fs.writeFile).toHaveBeenCalledTimes(2); // start + stop
+  });
+
+  it('should throw error when stopping timer if none is running', async () => {
+    await expect(tracker.stopTimer()).rejects.toThrow('No timer is currently running to stop.');
+  });
+
+  it('should automatically stop previous timer when a new one starts', async () => {
+    await tracker.startTimer('Task A');
+    await vi.advanceTimersByTime(100); // Simulate some time passing
+    await tracker.startTimer('Task B');
+
+    const entries = tracker.getAllEntries();
+    expect(entries.length).toBe(2);
+    expect(entries[0].taskName).toBe('Task A');
+    expect(entries[0].stopTime).not.toBeNull();
+    expect(entries[1].taskName).toBe('Task B');
+    expect(entries[1].stopTime).toBeNull();
+    expect(fs.writeFile).toHaveBeenCalledTimes(3); // One for Task A, one for stopping Task A, one for Task B
+  });
+
+  it('should retrieve all entries', async () => {
+    await tracker.startTimer('Task 1');
+    await tracker.stopTimer();
+    await tracker.startTimer('Task 2');
+    await tracker.stopTimer();
+
+    const allEntries = tracker.getAllEntries();
+    expect(allEntries.length).toBe(2);
+    expect(allEntries[0].taskName).toBe('Task 1');
+    expect(allEntries[1].taskName).toBe('Task 2');
+  });
+
+  it('should retrieve entries by date range', async () => {
+    // Setup specific dates for testing range queries
+    const config: TimeTrackerConfig = { filePath: testFilePath };
+    const datedTracker = new TimeTracker(config);
+    await datedTracker.initialize();
+
+    const d1 = new Date('2023-01-01T10:00:00Z');
+    const d2 = new Date('2023-01-01T11:00:00Z');
+    const d3 = new Date('2023-01-02T10:00:00Z');
+    const d4 = new Date('2023-01-02T11:00:00Z');
+    const d5 = new Date('2023-01-03T10:00:00Z');
+
+    // Mock Date.now() for precise control over entry times
+    vi.setSystemTime(d1);
+    await datedTracker.startTimer('Task X');
+    vi.setSystemTime(d2);
+    await datedTracker.stopTimer();
+
+    vi.setSystemTime(d3);
+    await datedTracker.startTimer('Task Y');
+    vi.setSystemTime(d4);
+    await datedTracker.stopTimer();
+
+    vi.setSystemTime(d5);
+    await datedTracker.startTimer('Task Z'); // Running task
+
+    const rangeStart = new Date('2023-01-01T00:00:00Z');
+    const rangeEnd = new Date('2023-01-01T23:59:59Z');
+
+    const entriesInRange = datedTracker.getEntriesByDateRange(rangeStart, rangeEnd);
+    expect(entriesInRange.length).toBe(1);
+    expect(entriesInRange[0].taskName).toBe('Task X');
+
+    const widerRangeStart = new Date('2023-01-01T00:00:00Z');
+    const widerRangeEnd = new Date('2023-01-03T23:59:59Z');
+    const entriesInWiderRange = datedTracker.getEntriesByDateRange(widerRangeStart, widerRangeEnd);
+    expect(entriesInWiderRange.length).toBe(3); // Task X, Y, Z (running)
+    expect(entriesInWiderRange.map(e => e.taskName)).toEqual(['Task X', 'Task Y', 'Task Z']);
+  });
+
+  it('should summarize time spent per task', async () => {
+    // Mock Date for consistent time measurements
+    vi.setSystemTime(new Date('2023-01-01T09:00:00Z'));
+    await tracker.startTimer('Dev');
+    vi.setSystemTime(new Date('2023-01-01T10:00:00Z'));
+    await tracker.stopTimer(); // Dev: 1 hour
+
+    vi.setSystemTime(new Date('2023-01-01T10:00:00Z'));
+    await tracker.startTimer('Meeting');
+    vi.setSystemTime(new Date('2023-01-01T10:30:00Z'));
+    await tracker.stopTimer(); // Meeting: 30 minutes
+
+    vi.setSystemTime(new Date('2023-01-01T11:00:00Z'));
+    await tracker.startTimer('Dev'); // Another Dev timer
+    vi.setSystemTime(new Date('2023-01-01T11:45:00Z'));
+    await tracker.stopTimer(); // Dev: 45 minutes
+
+    vi.setSystemTime(new Date('2023-01-01T12:00:00Z'));
+    await tracker.startTimer('Lunch'); // Running timer
+    // Current time for running task duration
+    vi.setSystemTime(new Date('2023-01-01T12:30:00Z'));
+
+    const summary = tracker.summarizeTime();
+
+    expect(summary.get('Dev')).toBe(60 * 60 * 1000 + 45 * 60 * 1000); // 1hr 45min
+    expect(summary.get('Meeting')).toBe(30 * 60 * 1000); // 30min
+    expect(summary.get('Lunch')).toBe(30 * 60 * 1000); // 30min (running)
+    expect(summary.size).toBe(3);
+  });
+
+  it('should handle unicode and emoji in task names', async () => {
+    await tracker.startTimer('Task ❤️');
+    await tracker.stopTimer();
+    await tracker.startTimer('日本語のタスク');
+    await tracker.stopTimer();
+
+    const allEntries = tracker.getAllEntries();
+    expect(allEntries.length).toBe(2);
+    expect(allEntries[0].taskName).toBe('Task ❤️');
+    expect(allEntries[1].taskName).toBe('日本語のタスク');
+
+    const summary = tracker.summarizeTime();
+    expect(summary.has('Task ❤️')).toBe(true);
+    expect(summary.has('日本語のタスク')).toBe(true);
+  });
+
+  it('should ensure currentRunningEntry is handled correctly across persistence', async () => {
+    // Start a timer
+    await tracker.startTimer('Persistent Task');
+    expect(tracker.getAllEntries()[0].stopTime).toBeNull();
+    
+    // Simulate re-initialization (new instance of TimeTracker)
+    // We need to mock the file system to return the state after the first startTimer
+    const savedData = (fs.writeFile as vi.Mock).mock.calls[(fs.writeFile as vi.Mock).mock.calls.length - 1][1];
+    (fs.readFile as vi.Mock).mockResolvedValueOnce(savedData);
+
+    const newTracker = new TimeTracker({ filePath: testFilePath });
+    await newTracker.initialize();
+
+    // The new tracker should have the 'Persistent Task' as its current running entry
+    // We can verify this by trying to stop it
+    const stoppedEntry = await newTracker.stopTimer();
+    expect(stoppedEntry.taskName).toBe('Persistent Task');
+    expect(stoppedEntry.stopTime).not.toBeNull();
+    expect(newTracker.getAllEntries()[0].stopTime).not.toBeNull(); // The original entry should now be stopped in newTracker
+  });
+
+  it('should create directories if they do not exist when saving', async () => {
+    const newConfig: TimeTrackerConfig = { filePath: '/new/path/to/data.json' };
+    const newTracker = new TimeTracker(newConfig);
+    await newTracker.initialize(); // This will try to load, creating dir is not part of load
+
+    await newTracker.startTimer('New Dir Task'); // This will trigger save, which calls mkdir
+    expect(fs.mkdir).toHaveBeenCalledWith(path.dirname(newConfig.filePath), { recursive: true });
+    expect(fs.writeFile).toHaveBeenCalled();
+  });
+});
