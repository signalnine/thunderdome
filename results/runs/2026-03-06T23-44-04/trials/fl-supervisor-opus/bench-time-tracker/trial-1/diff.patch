@@ -0,0 +1,172 @@
+// src/index.ts
+
+import * as fs from 'node:fs/promises';
+import * as path from 'node:path';
+
+export interface TimeEntry {
+  taskName: string;
+  startTime: Date;
+  stopTime: Date | null;
+}
+
+export interface TimeTrackerConfig {
+  filePath: string;
+}
+
+export class TimeTracker {
+  private entries: TimeEntry[] = [];
+  private currentRunningEntry: TimeEntry | null = null;
+  private config: TimeTrackerConfig;
+
+  constructor(config: TimeTrackerConfig) {
+    this.config = config;
+  }
+
+  public async initialize(): Promise<void> {
+    await this.loadEntries();
+  }
+
+  private async loadEntries(): Promise<void> {
+    try {
+      const data = await fs.readFile(this.config.filePath, 'utf-8');
+      const parsedData: { entries: TimeEntry[]; currentRunningEntry: TimeEntry | null } = JSON.parse(data);
+      this.entries = parsedData.entries.map(entry => ({
+        ...entry,
+        startTime: new Date(entry.startTime),
+        stopTime: entry.stopTime ? new Date(entry.stopTime) : null,
+      }));
+      // Find the current running entry from the rehydrated entries array
+      if (parsedData.currentRunningEntry) {
+        const rehydratedCurrent = this.entries.find(entry =>
+          entry.taskName === parsedData.currentRunningEntry!.taskName &&
+          entry.startTime.getTime() === new Date(parsedData.currentRunningEntry!.startTime).getTime()
+        );
+        this.currentRunningEntry = rehydratedCurrent || null;
+      } else {
+        this.currentRunningEntry = null;
+      }
+    } catch (error: unknown) {
+      if (error && typeof error === 'object' && 'code' in error && error.code === 'ENOENT') {
+        this.entries = [];
+        this.currentRunningEntry = null;
+      } else {
+        console.error('Error loading time entries:', error);
+        this.entries = [];
+        this.currentRunningEntry = null;
+      }
+    }
+  }
+
+  private async saveEntries(): Promise<void> {
+    const dir = path.dirname(this.config.filePath);
+    await fs.mkdir(dir, { recursive: true });
+    const dataToSave = {
+      entries: this.entries,
+      currentRunningEntry: this.currentRunningEntry,
+    };
+    await fs.writeFile(this.config.filePath, JSON.stringify(dataToSave, null, 2), 'utf-8');
+  }
+
+  /**
+   * Starts a new timer for a given task. If a timer is already running,
+   * it will be automatically stopped and recorded.
+   * @param taskName The name of the task to start.
+   * @throws Error if taskName is empty.
+   */
+  public async startTimer(taskName: string): Promise<void> {
+    if (!taskName) {
+      throw new Error('Task name cannot be empty.');
+    }
+
+    if (this.currentRunningEntry) {
+      await this.stopTimer(); // Automatically stop the previous timer
+    }
+
+    const newEntry: TimeEntry = {
+      taskName,
+      startTime: new Date(),
+      stopTime: null,
+    };
+    this.currentRunningEntry = newEntry;
+    this.entries.push(newEntry);
+    await this.saveEntries();
+  }
+
+  /**
+   * Stops the currently running timer.
+   * @returns The stopped TimeEntry.
+   * @throws Error if no timer is currently running.
+   */
+  public async stopTimer(): Promise<TimeEntry> {
+    if (!this.currentRunningEntry) {
+      throw new Error('No timer is currently running to stop.');
+    }
+
+    this.currentRunningEntry.stopTime = new Date();
+    const stoppedEntry = this.currentRunningEntry;
+    this.currentRunningEntry = null; // Clear the running entry
+    await this.saveEntries();
+    return stoppedEntry;
+  }
+
+  /**
+   * Retrieves all recorded time entries.
+   * @returns An array of all TimeEntry objects.
+   */
+  public getAllEntries(): TimeEntry[] {
+    // Return a copy to prevent external modification
+    return [...this.entries];
+  }
+
+  /**
+   * Retrieves time entries within a specified date range.
+   * @param startDate The start date for the filter (inclusive).
+   * @param endDate The end date for the filter (inclusive).
+   * @returns An array of TimeEntry objects within the specified range.
+   */
+  public getEntriesByDateRange(startDate: Date, endDate: Date): TimeEntry[] {
+    const start = startDate.getTime();
+    const end = endDate.getTime();
+
+    return this.entries.filter(entry => {
+      const entryStartTime = entry.startTime.getTime();
+      // An entry is considered within range if its start time is within the range.
+      // If it has a stop time, it's also considered if its stop time is within the range.
+      // Or if it started before the range and ended after the range (spanning the range).
+      const entryStopTime = entry.stopTime ? entry.stopTime.getTime() : new Date().getTime(); // Use current time for running tasks
+
+      return (
+        (entryStartTime >= start && entryStartTime <= end) ||
+        (entryStopTime >= start && entryStopTime <= end) ||
+        (entryStartTime < start && entryStopTime > end)
+      );
+    });
+  }
+
+  /**
+   * Summarizes the total time spent per task name.
+   * Running tasks use the current time for their duration.
+   * @returns A Map where keys are task names and values are total milliseconds spent.
+   */
+  public summarizeTime(): Map<string, number> {
+    const summary = new Map<string, number>();
+    const now = new Date().getTime();
+
+    this.entries.forEach(entry => {
+      const startTime = entry.startTime.getTime();
+      const stopTime = entry.stopTime ? entry.stopTime.getTime() : now;
+      const duration = stopTime - startTime;
+
+      if (summary.has(entry.taskName)) {
+        summary.set(entry.taskName, summary.get(entry.taskName)! + duration);
+      } else {
+        summary.set(entry.taskName, duration);
+      }
+    });
+
+    return summary;
+  }
+}
+
+
+
