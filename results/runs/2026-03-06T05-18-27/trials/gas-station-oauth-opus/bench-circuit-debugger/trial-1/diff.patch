+++ b/tests/index.test.ts
@@ -0,0 +1,306 @@
+import { describe, it, expect } from 'vitest';
+import { simulate, findSwappedWires, Gate } from '../src/index.js';
+
+// Helper to build a correct N-bit adder circuit
+function buildCorrectAdder(numBits: number): Gate[] {
+  const gates: Gate[] = [];
+  const pad = (n: number) => n.toString().padStart(2, '0');
+
+  // Bit 0: half adder
+  gates.push({ op: 'XOR', in1: `x00`, in2: `y00`, out: `z00` });
+  gates.push({ op: 'AND', in1: `x00`, in2: `y00`, out: `c00` });
+
+  for (let i = 1; i < numBits; i++) {
+    const x = `x${pad(i)}`;
+    const y = `y${pad(i)}`;
+    const z = `z${pad(i)}`;
+    const t = `t${pad(i)}`;
+    const a = `a${pad(i)}`;
+    const b = `b${pad(i)}`;
+    const c = `c${pad(i)}`;
+    const cPrev = `c${pad(i - 1)}`;
+
+    gates.push({ op: 'XOR', in1: x, in2: y, out: t });    // partial sum
+    gates.push({ op: 'XOR', in1: t, in2: cPrev, out: z }); // final sum
+    gates.push({ op: 'AND', in1: x, in2: y, out: a });     // generate
+    gates.push({ op: 'AND', in1: t, in2: cPrev, out: b }); // propagate
+    gates.push({ op: 'OR', in1: a, in2: b, out: c });      // carry out
+  }
+
+  return gates;
+}
+
+// Helper to swap two gate outputs
+function swapOutputs(gates: Gate[], w1: string, w2: string): Gate[] {
+  return gates.map(g => {
+    if (g.out === w1) return { ...g, out: w2 };
+    if (g.out === w2) return { ...g, out: w1 };
+    return { ...g };
+  });
+}
+
+// Helper to set up inputs for an adder
+function makeAdderInputs(x: bigint, y: bigint, numBits: number): Record<string, number> {
+  const inputs: Record<string, number> = {};
+  const pad = (n: number) => n.toString().padStart(2, '0');
+  for (let i = 0; i < numBits; i++) {
+    inputs[`x${pad(i)}`] = Number((x >> BigInt(i)) & 1n);
+    inputs[`y${pad(i)}`] = Number((y >> BigInt(i)) & 1n);
+  }
+  return inputs;
+}
+
+// Helper to read z output from wire values
+function readZOutput(wires: Record<string, number>, numBits: number): bigint {
+  const pad = (n: number) => n.toString().padStart(2, '0');
+  let result = 0n;
+  for (let i = 0; i <= numBits; i++) {
+    const val = wires[`z${pad(i)}`];
+    if (val !== undefined && val === 1) {
+      result |= (1n << BigInt(i));
+    }
+  }
+  return result;
+}
+
+describe('simulate', () => {
+  it('should simulate a single AND gate', () => {
+    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });
+    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 0 });
+    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 0 });
+    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });
+  });
+
+  it('should simulate a single OR gate', () => {
+    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });
+    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });
+    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });
+  });
+
+  it('should simulate a single XOR gate', () => {
+    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 0 });
+    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });
+    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });
+  });
+
+  it('should handle chained gates in dependency order', () => {
+    const gates: Gate[] = [
+      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },
+      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },
+    ];
+    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({
+      a: 1, b: 1, c: 1, d: 0, e: 1,
+    });
+  });
+
+  it('should handle gates listed out of dependency order', () => {
+    const gates: Gate[] = [
+      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },
+      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },
+    ];
+    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({
+      a: 1, b: 1, c: 1, d: 0, e: 1,
+    });
+  });
+
+  it('should simulate a correct 4-bit adder', () => {
+    const gates = buildCorrectAdder(4);
+    // 5 + 3 = 8
+    const inputs = makeAdderInputs(5n, 3n, 4);
+    const wires = simulate(gates, inputs);
+    expect(readZOutput(wires, 4)).toBe(8n);
+  });
+
+  it('should simulate a correct 4-bit adder - various additions', () => {
+    const gates = buildCorrectAdder(4);
+    // 7 + 7 = 14 (no overflow beyond 4 bits + carry)
+    let inputs = makeAdderInputs(7n, 7n, 4);
+    let wires = simulate(gates, inputs);
+    expect(readZOutput(wires, 4)).toBe(14n);
+
+    // 0 + 0 = 0
+    inputs = makeAdderInputs(0n, 0n, 4);
+    wires = simulate(gates, inputs);
+    expect(readZOutput(wires, 4)).toBe(0n);
+  });
+
+  it('should simulate larger adders', () => {
+    const gates = buildCorrectAdder(8);
+    // 200 + 55 = 255
+    const inputs = makeAdderInputs(200n, 55n, 8);
+    const wires = simulate(gates, inputs);
+    expect(readZOutput(wires, 8)).toBe(255n);
+  });
+});
+
+describe('findSwappedWires', () => {
+  it('should find swaps involving z-wires and internal wires', () => {
+    let gates = buildCorrectAdder(8);
+    // Swap z01 <-> a01: z output swapped with generate
+    gates = swapOutputs(gates, 'z01', 'a01');
+    // Swap t02 <-> z02: partial sum swapped with z output
+    gates = swapOutputs(gates, 't02', 'z02');
+    // Swap z05 <-> c05: z output swapped with carry
+    gates = swapOutputs(gates, 'z05', 'c05');
+    // Swap z07 <-> t07: z output swapped with partial sum
+    gates = swapOutputs(gates, 'z07', 't07');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(['a01', 'c05', 't02', 't07', 'z01', 'z02', 'z05', 'z07']);
+  });
+
+  it('should find swapped z-wire with internal wire across bits', () => {
+    let gates = buildCorrectAdder(8);
+    gates = swapOutputs(gates, 'z01', 't01');
+    gates = swapOutputs(gates, 'z03', 'a03');
+    gates = swapOutputs(gates, 'c04', 'z05');
+    gates = swapOutputs(gates, 'z07', 'c07');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(['a03', 'c04', 'c07', 't01', 'z01', 'z03', 'z05', 'z07']);
+  });
+
+  it('should handle swaps at bit 0', () => {
+    let gates = buildCorrectAdder(8);
+    // Swap z00 with c00 (bit 0 half adder outputs)
+    gates = swapOutputs(gates, 'z00', 'c00');
+    // Other swaps
+    gates = swapOutputs(gates, 'z02', 'a02');
+    gates = swapOutputs(gates, 't04', 'z04');
+    gates = swapOutputs(gates, 'z06', 'c06');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(['a02', 'c00', 'c06', 't04', 'z00', 'z02', 'z04', 'z06']);
+  });
+
+  it('should handle carry-involved swaps', () => {
+    let gates = buildCorrectAdder(10);
+    // Carry wire swaps that affect downstream bits
+    gates = swapOutputs(gates, 'c01', 'z02');
+    gates = swapOutputs(gates, 'z05', 't05');
+    gates = swapOutputs(gates, 'z07', 'a07');
+    gates = swapOutputs(gates, 'z09', 'c09');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(['a07', 'c01', 'c09', 't05', 'z02', 'z05', 'z07', 'z09']);
+  });
+
+  it('should handle a 45-bit adder with random-named wires', () => {
+    const numBits = 45;
+    const pad = (n: number) => n.toString().padStart(2, '0');
+    const gates: Gate[] = [];
+
+    let nameCounter = 0;
+    function uniqueName(): string {
+      const chars = 'abcdefghijklmnopqrstuvwxyz';
+      const n = nameCounter++;
+      const a = chars[n % 26];
+      const b = chars[Math.floor(n / 26) % 26];
+      const c = chars[Math.floor(n / 676) % 26];
+      return `${c}${b}${a}`;
+    }
+
+    // Bit 0
+    gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });
+    const c0 = uniqueName();
+    gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: c0 });
+
+    const wireMap: Record<string, string> = {};
+    let prevCarry = c0;
+
+    for (let i = 1; i < numBits; i++) {
+      const x = `x${pad(i)}`;
+      const y = `y${pad(i)}`;
+      const z = `z${pad(i)}`;
+      const t = uniqueName();
+      const a = uniqueName();
+      const b = uniqueName();
+      const c = uniqueName();
+
+      gates.push({ op: 'XOR', in1: x, in2: y, out: t });
+      gates.push({ op: 'XOR', in1: t, in2: prevCarry, out: z });
+      gates.push({ op: 'AND', in1: x, in2: y, out: a });
+      gates.push({ op: 'AND', in1: t, in2: prevCarry, out: b });
+      gates.push({ op: 'OR', in1: a, in2: b, out: c });
+
+      wireMap[`t${pad(i)}`] = t;
+      wireMap[`a${pad(i)}`] = a;
+      wireMap[`b${pad(i)}`] = b;
+      wireMap[`c${pad(i)}`] = c;
+      prevCarry = c;
+    }
+
+    // Swap 4 pairs: z-output with partial sum at various bits
+    const swapPairs: [string, string][] = [
+      [wireMap['t05'], 'z05'],       // partial sum <-> z output
+      [wireMap['t10'], 'z10'],       // partial sum <-> z output
+      [wireMap['c20'], 'z21'],       // carry <-> z output
+      [wireMap['t30'], 'z30'],       // partial sum <-> z output
+    ];
+
+    let swappedGates = [...gates.map(g => ({ ...g }))];
+    const expectedSwapped: string[] = [];
+    for (const [w1, w2] of swapPairs) {
+      swappedGates = swapOutputs(swappedGates, w1, w2);
+      expectedSwapped.push(w1, w2);
+    }
+    expectedSwapped.sort();
+
+    const result = findSwappedWires(swappedGates);
+    expect(result).toEqual(expectedSwapped);
+  });
