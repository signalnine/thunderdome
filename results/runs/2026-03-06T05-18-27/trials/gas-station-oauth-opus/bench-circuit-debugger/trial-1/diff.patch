+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+
+  let changed = true;
+  while (remaining.length > 0 && changed) {
+    changed = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        let result: number;
+        switch (gate.op) {
+          case 'AND':
+            result = a & b;
+            break;
+          case 'OR':
+            result = a | b;
+            break;
+          case 'XOR':
+            result = a ^ b;
+            break;
+        }
+        wires[gate.out] = result;
+        remaining.splice(i, 1);
+        changed = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+export function findSwappedWires(gates: Gate[]): string[] {
+  // Work on a copy so we can mutate outputs as we fix swaps
+  const gs: Gate[] = gates.map(g => ({ ...g }));
+
+  const pad = (n: number) => n.toString().padStart(2, '0');
+
+  // Find the number of input bits
+  let maxBit = 0;
+  for (const g of gs) {
+    for (const w of [g.in1, g.in2]) {
+      const mx = w.match(/^x(\d+)$/);
+      if (mx) {
+        maxBit = Math.max(maxBit, parseInt(mx[1]));
+      }
+    }
+  }
+  const numBits = maxBit + 1;
+  const lastZ = `z${pad(numBits)}`;
+
+  // Helper to check if inputs are from x/y registers
+  function hasXYInputs(g: Gate): boolean {
+    return (
+      (g.in1.startsWith('x') || g.in1.startsWith('y')) &&
+      (g.in2.startsWith('x') || g.in2.startsWith('y'))
+    );
+  }
+
+  function isFirstBitInput(g: Gate): boolean {
+    return (
+      (g.in1 === 'x00' || g.in1 === 'y00') &&
+      (g.in2 === 'x00' || g.in2 === 'y00')
+    );
+  }
+
+  // Find gate by op and inputs (order-independent)
+  function findGate(op: string, in1: string, in2: string): Gate | undefined {
+    for (const g of gs) {
+      if (g.op === op &&
+        ((g.in1 === in1 && g.in2 === in2) || (g.in1 === in2 && g.in2 === in1))
+      ) {
+        return g;
+      }
+    }
+    return undefined;
+  }
+
+  // Find gates that use a wire as input with a given op
+  function findGatesWithInput(op: string, wire: string): Gate[] {
+    return gs.filter(g => g.op === op && (g.in1 === wire || g.in2 === wire));
+  }
+
+  // Find gates that use a wire as input (any op)
+  function findGatesUsingInput(wire: string): Gate[] {
+    return gs.filter(g => g.in1 === wire || g.in2 === wire);
+  }
+
+  // Swap two gate outputs and record the swap
+  const swapped = new Set<string>();
+  function doSwap(w1: string, w2: string) {
+    if (w1 === w2) return;
+    swapped.add(w1);
+    swapped.add(w2);
+    const g1 = gs.find(g => g.out === w1);
+    const g2 = gs.find(g => g.out === w2);
+    if (g1 && g2) {
+      g1.out = w2;
+      g2.out = w1;
+    }
+  }
+
+  // Rule-based detection: apply structural rules to find violations,
+  // then trace bit-by-bit to identify exact swaps.
+  //
+  // Rule 1: z-outputs (except lastZ) must come from XOR gates
+  // Rule 2: XOR gates must either take x/y inputs or produce z-outputs
+  // Rule 3: AND gates (except bit-0 AND) must feed into OR gates
+  // Rule 4: OR gate outputs must not be z-wires (except lastZ)
+
+  // First pass: identify all structurally invalid outputs
+  const badWires = new Set<string>();
+
+  for (const g of gs) {
+    if (g.out.startsWith('z') && g.out !== lastZ) {
+      // Rule 1: z-outputs must be from XOR
+      if (g.op !== 'XOR') {
+        badWires.add(g.out);
+      }
+    }
+
+    if (g.op === 'XOR') {
+      // Rule 2: XOR gates with non-x/y inputs must output to z
+      if (!hasXYInputs(g) && !g.out.startsWith('z')) {
+        badWires.add(g.out);
+      }
+    }
+
+    if (g.op === 'AND' && !isFirstBitInput(g)) {
+      // Rule 3: AND gate outputs (except bit 0) should feed into OR gates
+      const consumers = findGatesUsingInput(g.out);
+      const feedsOR = consumers.some(c => c.op === 'OR');
+      if (!feedsOR) {
+        badWires.add(g.out);
+      }
+    }
+
+    if (g.op === 'OR') {
+      // Rule 4: OR outputs should not be z-wires (except lastZ)
+      if (g.out.startsWith('z') && g.out !== lastZ) {
+        badWires.add(g.out);
+      }
+    }
+  }
+
+  // If rule-based detection found exactly 8 wires, we're done
+  if (badWires.size === 8) {
+    return [...badWires].sort();
+  }
+
+  // Otherwise, use bit-by-bit tracing to find and fix swaps
+  swapped.clear();
+  // Reset gates
+  for (let i = 0; i < gs.length; i++) {
+    gs[i] = { ...gates[i] };
+  }
+
+  let carry: string | undefined;
+
+  for (let bit = 0; bit < numBits; bit++) {
+    const xw = `x${pad(bit)}`;
+    const yw = `y${pad(bit)}`;
+    const zw = `z${pad(bit)}`;
+
+    if (bit === 0) {
+      const xorGate = findGate('XOR', xw, yw);
+      if (xorGate && xorGate.out !== zw) {
+        doSwap(xorGate.out, zw);
+      }
+
+      const andGate = findGate('AND', xw, yw);
+      if (andGate) {
+        carry = andGate.out;
+      }
+    } else {
+      const xorGate = findGate('XOR', xw, yw);
+      if (!xorGate) continue;
+      let partialSum = xorGate.out;
+
+      let sumGate = findGate('XOR', partialSum, carry!);
+
+      if (!sumGate) {
+        const carryXors = findGatesWithInput('XOR', carry!).filter(
+          g => !hasXYInputs(g)
+        );
+
+        if (carryXors.length === 1) {
+          sumGate = carryXors[0];
+          const correctPartial = sumGate.in1 === carry ? sumGate.in2 : sumGate.in1;
+          if (correctPartial !== partialSum) {
+            doSwap(partialSum, correctPartial);
+            partialSum = correctPartial;
+          }
+        } else {
+          const psXors = findGatesWithInput('XOR', partialSum).filter(
+            g => !hasXYInputs(g)
+          );
+          if (psXors.length === 1) {
+            sumGate = psXors[0];
+            const correctCarry = sumGate.in1 === partialSum ? sumGate.in2 : sumGate.in1;
+            if (correctCarry !== carry) {
+              doSwap(carry!, correctCarry);
+              carry = correctCarry;
+            }
+          }
+        }
+      }
+
+      if (sumGate && sumGate.out !== zw) {
+        doSwap(sumGate.out, zw);
+      }
+
+      const genGate = findGate('AND', xw, yw);
+      const generate = genGate?.out;
+
+      const propGate = findGate('AND', partialSum, carry!);
+      const propagate = propGate?.out;
+
+      if (generate !== undefined && propagate !== undefined) {
+        let carryGate = findGate('OR', generate, propagate);
+        if (carryGate) {
+          carry = carryGate.out;
+        } else {
+          const genOrs = findGatesWithInput('OR', generate);
+          if (genOrs.length === 1) {
+            carryGate = genOrs[0];
+            const otherInput = carryGate.in1 === generate ? carryGate.in2 : carryGate.in1;
+            if (otherInput !== propagate) {
+              doSwap(propagate, otherInput);
+            }
+            carry = carryGate.out;
+          } else {
+            const propOrs = findGatesWithInput('OR', propagate);
+            if (propOrs.length === 1) {
+              carryGate = propOrs[0];
+              const otherInput = carryGate.in1 === propagate ? carryGate.in2 : carryGate.in1;
+              if (otherInput !== generate) {
+                doSwap(generate, otherInput);
+              }
+              carry = carryGate.out;
+            }
+          }
+        }
+      } else if (generate !== undefined) {
+        const propGate2 = findGate('AND', partialSum, carry!);
+        if (propGate2) {
+          const carryGate = findGate('OR', generate, propGate2.out);
+          if (carryGate) {
+            carry = carryGate.out;
+          }
+        }
+      }
+    }
+  }
+
+  return [...swapped].sort();
+}
diff --git a/tests/index.test.ts b/tests/index.test.ts
