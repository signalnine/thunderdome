+import { Request } from 'express';
+import { Database } from 'better-sqlite3';
+import { v4 as uuidv4 } from 'uuid';
+
+export interface User {
+  id: string;
+  email: string;
+  password_hash: string;
+  tenant_id: string;
+  role: string;
+  created_at: string;
+  deleted_at?: string;
+}
+
+export interface AuthenticatedRequest extends Request {
+  user?: {
+    id: string;
+    email: string;
+    tenant_id: string;
+    role: string;
+  };
+}
+
+let dbInstance: Database | null = null;
+export function db(): Database | null {
+  return dbInstance;
+}
+
+export function createDB(db: Database): any {
+  dbInstance = db;
+  return {
+    insertUser: (userId: string, email: string, passwordHash: string, tenantId: string, role: string = 'viewer') => {
+      const stmt = db.prepare('INSERT INTO users (id, email, password_hash, tenant_id, role, created_at) VALUES (?, ?, ?, ?, ?, datetime("now"))');
+      return stmt.run(userId, email, passwordHash, tenantId, role);
+    },
+    findUserById: (userId: string) => {
+      const stmt = db.prepare('SELECT * FROM users WHERE id = ? AND deleted_at IS NULL');
+      return stmt.get(userId) as User;
+    },
+    findUserByEmail: (email: string) => {
+      const stmt = db.prepare('SELECT * FROM users WHERE email = ? AND deleted_at IS NULL');
+      return stmt.get(email) as User;
+    },
+    updateUser: (userId: string, updates: { email?: string; role?: string }) => {
+      const fields: string[] = [];
+      const values: any[] = [];
+      if (updates.email !== undefined) { fields.push('email = ?'); values.push(updates.email); }
+      if (updates.role !== undefined) {
+        if (!['admin', 'viewer', 'editor'].includes(updates.role)) throw new Error('Invalid role');
+        fields.push('role = ?'); values.push(updates.role);
+      }
+      if (fields.length === 0) return;
+      values.push(userId);
+      db.prepare(`UPDATE users SET ${fields.join(', ')} WHERE id = ? AND deleted_at IS NULL`).run(...values);
+    },
+    deleteSoft: (userId: string) => {
+      db.prepare('UPDATE users SET deleted_at = datetime("now") WHERE id = ?').run(userId);
+    },
+    insertEvent: (eventId: string, tenantId: string, name: string, properties: Record<string, unknown>, timestamp: string, userId?: string, sessionId?: string) => {
+      const stmt = db.prepare('INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)');
+      return stmt.run(eventId, tenantId, name, JSON.stringify(properties), timestamp, userId || null, sessionId || null);
+    },
+    listEvents: (tenantId: string, filters: any) => {
+      let query = 'SELECT * FROM events WHERE tenant_id = ? AND deleted_at IS NULL';
+      const values: any[] = [tenantId];
+      if (filters.name) { query += ' AND name = ?'; values.push(filters.name); }
+      if (filters.fromTimestamp) { query += ' AND timestamp >= ?'; values.push(filters.fromTimestamp); }
+      if (filters.toTimestamp) { query += ' AND timestamp <= ?'; values.push(filters.toTimestamp); }
+      if (filters.propertyKey && filters.propertyValue) { query += ` AND properties LIKE '%"${filters.propertyKey}":"${filters.propertyValue}"%'`; }
+      query += ' ORDER BY timestamp DESC';
+      const stmt = db.prepare(query);
+      return stmt.all(...values);
+    },
+    eventCount: (tenantId: string, _name?: string) => {
+      let query = 'SELECT COUNT(*) as count FROM events WHERE tenant_id = ? AND deleted_at IS NULL';
+      const values: any[] = [tenantId];
+      if (_name) { query += ' AND name = ?'; values.push(_name); }
+      const stmt = db.prepare(query);
+      const result = stmt.get(...values);
+      return (result as any).count;
+    },
+    timeseriesData: (tenantId: string, _name?: string, fromTimestamp: string, toTimestamp: string, bucketSize: string = '1 day') => {
+      let query = `SELECT datetime(timestamp, '${bucketSize}', 'localtime') as bucket, COUNT(*) as count FROM events WHERE tenant_id = ? AND timestamp >= ? AND timestamp <= ? AND deleted_at IS NULL`;
+      const values: any[] = [tenantId, fromTimestamp, toTimestamp];
+      if (_name) { query += ' AND name = ?'; values.push(_name); }
+      query += ' GROUP BY bucket ORDER BY bucket';
+      const stmt = db.prepare(query);
+      return stmt.all(...values);
+    },
+    makeBreakdownData: (tenantId: string, _name?: string, fromTimestamp?: string, toTimestamp?: string, propertyKey: string) => {
+      let query = `SELECT properties->>'${propertyKey}' as key_name, COUNT(*) as count FROM events WHERE tenant_id = ? AND properties->>'${propertyKey}' IS NOT NULL AND deleted_at IS NULL`;
+      const values: any[] = [tenantId];
+      if (_name) { query += ' AND name = ?'; values.push(_name); }
+      if (fromTimestamp) { query += ' AND timestamp >= ?'; values.push(fromTimestamp); }
+      if (toTimestamp) { query += ' AND timestamp <= ?'; values.push(toTimestamp); }
+      query += ' GROUP BY key_name ORDER BY count DESC';
+      const stmt = db.prepare(query);
+      return stmt.all(...values);
+    },
+    insertDashboard: (dashboardId: string, tenantId: string, name: string, ownerId: string, config: Record<string, unknown> = {}) => {
+      const stmt = db.prepare('INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, datetime("now"), datetime("now"))');
+      return stmt.run(dashboardId, tenantId, name, ownerId, JSON.stringify(config));
+    },
+    findDashboardById: (dashboardId: string) => {
+      const stmt = db.prepare('SELECT * FROM dashboards WHERE id = ? AND deleted_at IS NULL');
+      return stmt.get(dashboardId);
+    },
+    listDashboards: (tenantId: string) => {
+      const stmt = db.prepare('SELECT * FROM dashboards WHERE tenant_id = ? AND deleted_at IS NULL ORDER BY updated_at DESC');
+      return stmt.all(tenantId);
+    },
+    updateDashboard: (dashboardId: string, updates: { name?: string; config?: Record<string, unknown> }) => {
+      const fields: string[] = [];
+      const values: any[] = [];
+      if (updates.name !== undefined) { fields.push('name = ?'); values.push(updates.name); }
+      if (updates.config !== undefined) { fields.push('config = ?'); values.push(JSON.stringify(updates.config)); }
+      if (fields.length === 0) return;
+      values.push(dashboardId);
+      db.prepare(`UPDATE dashboards SET ${fields.join(', ')} WHERE id = ? AND deleted_at IS NULL`).run(...values);
+    },
+    deleteDashboard: (dashboardId: string) => {
+      db.prepare('UPDATE dashboards SET deleted_at = datetime("now") WHERE id = ?').run(dashboardId);
+    },
+    insertWidget: (widgetId: string, dashboardId: string, type: string, config: Record<string, unknown> = {}, positionX: number = 0, positionY: number = 0, width: number = 1, height: number = 1) => {
+      if (!['counter', 'timeseries', 'breakdown', 'funnel'].includes(type)) throw new Error('Invalid widget type');
+      const stmt = db.prepare('INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)');
+      return stmt.run(widgetId, dashboardId, type, JSON.stringify(config), positionX, positionY, width, height);
+    },
+    listWidgets: (dashboardId: string) => {
+      const stmt = db.prepare('SELECT * FROM widgets WHERE dashboard_id = ? ORDER BY position_y, position_x');
+      return stmt.all(dashboardId);
+    },
+    updateWidget: (widgetId: string, updates: { type?: string; config?: Record<string, unknown>; positionX?: number; positionY?: number; width?: number; height?: number }) => {
+      const fields: string[] = [];
+      const values: any[] = [];
+      if (updates.type !== undefined) { if (!['counter', 'timeseries', 'breakdown', 'funnel'].includes(updates.type)) throw new Error('Invalid widget type'); fields.push('type = ?'); values.push(updates.type); }
+      if (updates.config !== undefined) { fields.push('config = ?'); values.push(JSON.stringify(updates.config)); }
+      if (updates.positionX !== undefined) { fields.push('position_x = ?'); values.push(updates.positionX); }
+      if (updates.positionY !== undefined) { fields.push('position_y = ?'); values.push(updates.positionY); }
+      if (updates.width !== undefined) { fields.push('width = ?'); values.push(updates.width); }
+      if (updates.height !== undefined) { fields.push('height = ?'); values.push(updates.height); }
+      if (fields.length === 0) return;
+      values.push(widgetId);
+      db.prepare(`UPDATE widgets SET ${fields.join(', ')} WHERE id = ?`).run(...values);
+    },
+    deleteWidget: (widgetId: string) => {
+      db.prepare('DELETE FROM widgets WHERE id = ?').run(widgetId);
+    }
+  };
+}
+
+export function hashPassword(password: string): string { return password; }
+export function verifyPassword(password: string, hash: string): boolean { return password === hash; }
+export function generateUUID() { return uuidv4(); }
