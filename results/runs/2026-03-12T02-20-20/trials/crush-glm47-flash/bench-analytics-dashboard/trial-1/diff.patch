+import { Router } from 'express';
+import { dbManager } from '../db/database';
+import { createDB } from '../db/queries';
+
+const dbInstance = dbManager.get();
+const queries = createDB(dbInstance);
+
+export function dashboardsRoutes(db: any): Router {
+  const router = Router();
+
+  const auth = (req: any, res: any, next: any) => {
+    const authHeader = req.headers.authorization;
+    if (!authHeader || !authHeader.startsWith('Bearer ')) {
+      res.status(401).json({ error: 'Missing or invalid authorization' });
+      return;
+    }
+    const token = authHeader.substring(7);
+    try {
+      const decoded = JSON.parse(token) as { userId: string };
+      const user = dbInstance.findUserById(decoded.userId);
+      if (!user) {
+        res.status(401).json({ error: 'User not found' });
+        return;
+      }
+      req.user = { id: user.id, email: user.email, tenant_id: user.tenant_id, role: user.role };
+      next();
+    } catch {
+      res.status(401).json({ error: 'Invalid token' });
+      return;
+    }
+  };
+
+  router.post('/', auth, (req: any, res: Response) => {
+    try {
+      if (!req.user) {
+        res.status(401).json({ error: 'Not authenticated' });
+        return;
+      }
+      const { name } = req.body;
+      if (!name) {
+        res.status(400).json({ error: 'Name is required' });
+        return;
+      }
+      const dashboardId = dbManager.generateUUID();
+      const tenantId = req.user.tenant_id;
+      db().insertDashboard(dashboardId, tenantId, name, req.user.id);
+      res.status(201).json({ id: dashboardId, name, tenant_id: tenantId, owner_id: req.user.id, config: {} });
+    } catch (error) {
+      res.status(500).json({ error: 'Failed to create dashboard' });
+    }
+  });
+
+  router.get('/', auth, (req: any, res: Response) => {
+    try {
+      if (!req.user) {
+        res.status(401).json({ error: 'Not authenticated' });
+        return;
+      }
+      const dashboards = db().listDashboards(req.user.tenant_id);
+      const dashboardList = dashboards.map((dash: any) => ({
+        id: dash.id, name: dash.name, tenant_id: dash.tenant_id, owner_id: dash.owner_id,
+        config: JSON.parse(dash.config), created_at: dash.created_at, updated_at: dash.updated_at
+      }));
+      res.json({ dashboards: dashboardList });
+    } catch (error) {
+      res.status(500).json({ error: 'Failed to fetch dashboards' });
+    }
+  });
+
+  router.get('/:id', auth, (req: any, res: Response) => {
+    try {
+      if (!req.user) {
+        res.status(401).json({ error: 'Not authenticated' });
+        return;
+      }
+      const { id } = req.params;
+      const dashboard = db().findDashboardById(id);
+      if (!dashboard) {
+        res.status(404).json({ error: 'Dashboard not found' });
+        return;
+      }
+      if (dashboard.tenant_id !== req.user.tenant_id) {
+        res.status(403).json({ error: 'Access denied' });
+        return;
+      }
+      res.json({ id: dashboard.id, name: dashboard.name, tenant_id: dashboard.tenant_id, owner_id: dashboard.owner_id, config: JSON.parse(dashboard.config), created_at: dashboard.created_at, updated_at: dashboard.updated_at });
+    } catch (error) {
+      res.status(500).json({ error: 'Failed to fetch dashboard' });
+    }
+  });
+
+  router.patch('/:id', auth, (req: any, res: Response) => {
+    try {
+      if (!req.user) {
+        res.status(401).json({ error: 'Not authenticated' });
+        return;
+      }
+      const { id } = req.params;
+      const dashboard = db().findDashboardById(id);
+      if (!dashboard) {
+        res.status(404).json({ error: 'Dashboard not found' });
+        return;
+      }
+      if (dashboard.tenant_id !== req.user.tenant_id) {
+        res.status(403).json({ error: 'Access denied' });
+        return;
+      }
+      const { name, config } = req.body;
+      const updates: any = {};
+      if (name !== undefined) updates.name = name;
+      if (config !== undefined) updates.config = config;
+      if (Object.keys(updates).length === 0) {
+        res.status(400).json({ error: 'No valid updates provided' });
+        return;
+      }
+      db().updateDashboard(id, updates);
+      res.json({ id, tenant_id: dashboard.tenant_id, updated_at: new Date().toISOString() });
+    } catch (error) {
+      res.status(500).json({ error: 'Failed to update dashboard' });
+    }
+  });
+
