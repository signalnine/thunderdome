+import { response } from 'express';
+import express, { Application } from 'express';
+import { dbManager } from './db/database';
+import { createDB } from './db/queries';
+import { registerRoutes, profileRoutes } from './routes/auth';
+import { eventsRoutes } from './routes/events';
+import { dashboardsRoutes } from './routes/dashboards';
+import { exportRoutes } from './routes/export';
+
+export function createApp(): Application {
+  const app = express();
+
+  const db = dbManager.initialize('./data/analytics.db');
+  const dbQueries = createDB(db);
+
+  app.use(express.json());
+
+  app.use('/api/auth', registerRoutes(dbQueries));
+  app.use('/api/profile', profileRoutes(dbQueries));
+  app.use('/api/events', eventsRoutes(dbQueries));
+  app.use('/api/dashboards', dashboardsRoutes(dbQueries));
+  app.use('/api/export', exportRoutes(dbQueries));
+
+  app.get('/health', (req: express.Request, res: express.Response) => {
+    res.json({ status: 'healthy' });
+  });
+
+  return app;
+}
