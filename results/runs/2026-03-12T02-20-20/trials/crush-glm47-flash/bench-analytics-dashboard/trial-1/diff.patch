@@ -0,0 +1,108 @@
+import { Router, Request, Response } from 'express';
+import { dbManager as DBManager } from '../db/database';
+import { createDB } from '../db/queries';
+
+const dbInstance = DBManager.get();
+const queries = createDB(dbInstance);
+
+export function eventsRoutes(db: any): Router {
+  const router = Router();
+
+  const auth = (req: any, res: any, next: any) => {
+    const authHeader = req.headers.authorization;
+    if (!authHeader || !authHeader.startsWith('Bearer ')) {
+      res.status(401).json({ error: 'Missing or invalid authorization' });
+      return;
+    }
+    const token = authHeader.substring(7);
+    try {
+      const decoded = JSON.parse(token) as { userId: string };
+      const user = dbInstance.findUserById(decoded.userId);
+      if (!user) {
+        res.status(401).json({ error: 'User not found' });
+        return;
+      }
+      req.user = { id: user.id, email: user.email, tenant_id: user.tenant_id, role: user.role };
+      next();
+    } catch {
+      res.status(401).json({ error: 'Invalid token' });
+      return;
+    }
+  };
+
+  router.post('/ingest', auth, async (req: any, res: Response) => {
+    try {
+      const { events } = req.body;
+      if (!Array.isArray(events)) {
+        res.status(400).json({ error: 'Events must be an array' });
+        return;
+      }
+      if (events.length === 0) {
+        res.json({ success: true, count: 0 });
+        return;
+      }
+      const tenantId = req.user.tenant_id;
+      const userId = req.user.id;
+      const results = events.map((event: any) => {
+        const eventId = dbManager.generateUUID();
+        const timestamp = event.timestamp || new Date().toISOString();
+        db().insertEvent(eventId, tenantId, event.name, event.properties || {}, timestamp, userId, event.session_id || null);
+        return { id: eventId };
+      });
+      res.json({ success: true, count: events.length, results });
+    } catch (error) {
+      res.status(500).json({ error: 'Ingestion failed' });
+    }
+  });
+
+  router.get('/queries/count', auth, (req: any, res: Response) => {
+    try {
+      const tenantId = req.user.tenant_id;
+      const count = db().eventCount(tenantId, req.query.name as string | undefined);
+      res.json({ count, tenant_id: tenantId });
+    } catch (error) {
+      res.status(500).json({ error: 'Query failed' });
+    }
+  });
+
+  router.get('/queries/timeseries', auth, (req: any, res: Response) => {
+    try {
+      const tenantId = req.user.tenant_id;
+      const data = db().timeseriesData(tenantId, req.query.name as string | undefined, req.body.from, req.body.to, req.body.bucketSize || '1 day');
+      res.json({ data, tenant_id: tenantId });
+    } catch (error) {
+      res.status(500).json({ error: 'Query failed' });
+    }
+  });
+
+  router.get('/queries/breakdown', auth, (req: any, res: Response) => {
+    try {
+      const tenantId = req.user.tenant_id;
+      let data;
+      if (req.body.from && req.body.to) {
+        data = db().breakdownData(tenantId, req.query.name as string | undefined, req.body.from, req.body.to, req.body.propertyKey);
+      } else {
+        data = db().breakdownData(tenantId, req.query.name as string | undefined, undefined, undefined, req.body.propertyKey);
+      }
+      res.json({ data, tenant_id: tenantId });
+    } catch (error) {
+      res.status(500).json({ error: 'Query failed' });
+    }
+  });
+
+  router.get('/queries', auth, (req: any, res: Response) => {
+    try {
+      const tenantId = req.user.tenant_id;
+      const events = db().listEvents(tenantId, { name: req.query.name, fromTimestamp: req.query.fromTimestamp, toTimestamp: req.query.toTimestamp, propertyKey: req.query.propertyKey, propertyValue: req.query.propertyValue });
+      res.json({ events, tenant_id: tenantId });
+    } catch (error) {
+      res.status(500).json({ error: 'Query failed' });
+    }
+  });
+
+  return router;
+}
+
+function db() {
+  return dbInstance;
+}
