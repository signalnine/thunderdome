+++ b/src/routes/export.ts
@@ -0,0 +1,80 @@
+import { Router } from 'express';
+import { dbManager } from '../db/database';
+import { createDB } from '../db/queries';
+
+const dbInstance = dbManager.get();
+const queries = createDB(dbInstance);
+
+export function exportRoutes(db: any): Router {
+  const router = Router();
+
+  const auth = (req: any, res: any, next: any) => {
+    const authHeader = req.headers.authorization;
+    if (!authHeader || !authHeader.startsWith('Bearer ')) {
+      res.status(401).json({ error: 'Missing or invalid authorization' });
+      return;
+    }
+    const token = authHeader.substring(7);
+    try {
+      const decoded = JSON.parse(token) as { userId: string };
+      const user = dbInstance.findUserById(decoded.userId);
+      if (!user) {
+        res.status(401).json({ error: 'User not found' });
+        return;
+      }
+      req.user = { id: user.id, email: user.email, tenant_id: user.tenant_id, role: user.role };
+      next();
+    } catch {
+      res.status(401).json({ error: 'Invalid token' });
+      return;
+    }
+  };
+
+  router.get('/events', auth, (req: any, res: Response) => {
+    try {
+      if (!req.user) {
+        res.status(401).json({ error: 'Not authenticated' });
+        return;
+      }
+      const { name, from, to } = req.query;
+      const toFormat = req.header('Accept') || 'json';
+      const events = db().listEvents(req.user!.tenant_id, { name, fromTimestamp: from, toTimestamp: to, propertyKey: null, propertyValue: null });
+      res.setHeader('Content-Type', toFormat === 'json' ? 'application/json' : 'text/csv');
+      res.setHeader('Content-Disposition', 'attachment; filename=events.csv');
+      if (toFormat === 'csv') {
+        const headers = ['id', 'name', 'properties', 'timestamp', 'user_id', 'session_id'];
+        const csvRows = events.map((event: any) => [ `"${event.id}"`, `"${event.name}"`, `"${event.properties}"`, `"${event.timestamp}"`, `"${event.user_id || ''}"`, `"${event.session_id || ''}"` ].join(',').replace(/,/g, ','));
+        res.send([ headers.join(','), ...csvRows ].join('\n'));
+      } else {
+        res.json(events);
+      }
+    } catch (error) {
+      res.status(500).json({ error: 'Failed to export events' });
+    }
+  });
+
+  router.get('/dashboards', auth, (req: any, res: Response) => {
+    try {
+      if (!req.user) {
+        res.status(401).json({ error: 'Not authenticated' });
+        return;
+      }
+      const { to = 'json' } = req.query;
+      const dashboards = db().listDashboards(req.user!.tenant_id);
+      res.setHeader('Content-Type', to === 'json' ? 'application/json' : 'text/csv');
+      res.setHeader('Content-Disposition', 'attachment; filename=dashboards.csv');
+      if (to === 'csv') {
+        const headers = ['id', 'name', 'tenant_id', 'owner_id', 'config', 'created_at', 'updated_at'];
+        const csvRows = dashboards.map((dash: any) => [ `"${dash.id}"`, `"${dash.name}"`, `"${dash.tenant_id}"`, `"${dash.owner_id}"`, `"${dash.config}"`, `"${dash.created_at}"`, `"${dash.updated_at}"` ].join(',').replace(/,/g, ','));
+        res.send([ headers.join(','), ...csvRows ].join('\n'));
+      } else {
+        const dashboardList = dashboards.map((dash: any) => ({ id: dash.id, name: dash.name, tenant_id: dash.tenant_id, owner_id: dash.owner_id, config: JSON.parse(dash.config), created_at: dash.created_at, updated_at: dash.updated_at }));
+        res.json(dashboardList);
+      }
+    } catch (error) {
+      res.status(500).json({ error: 'Failed to export dashboards' });
+    }
+  });
+
+  return router;
+}
