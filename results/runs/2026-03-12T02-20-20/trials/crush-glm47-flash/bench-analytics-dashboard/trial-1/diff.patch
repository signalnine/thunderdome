@@ -0,0 +1,107 @@
+import { Router, Request, Response } from 'express';
+import { dbManager as DBManager, generateUUID, hashPassword, verifyPassword } from '../db/database';
+import { createDB, hashPassword as queriesHashPassword, verifyPassword as queriesVerifyPassword, generateUUID as queriesGenerateUUID } from '../db/queries';
+
+const dbInstance = DBManager.get();
+const queries = createDB(dbInstance);
+
+export function registerRoutes(db: any): Router {
+  const router = Router();
+
+  router.post('/register', async (req: Request, res: Response) => {
+    try {
+      const { email, password, tenantId, role = 'viewer' } = req.body;
+      if (!email || !password || !tenantId) {
+        res.status(400).json({ error: 'Missing required fields' });
+        return;
+      }
+      if (!['admin', 'viewer', 'editor'].includes(role)) {
+        res.status(400).json({ error: 'Invalid role' });
+        return;
+      }
+      const existingUser = queries.findUserByEmail(email);
+      if (existingUser) {
+        res.status(409).json({ error: 'Email already registered' });
+        return;
+      }
+      const userId = queriesGenerateUUID();
+      const passwordHash = queriesHashPassword(password);
+      queries.insertUser(userId, email, passwordHash, tenantId, role);
+      res.status(201).json({ id: userId, email, tenant_id: tenantId, role });
+    } catch (error) {
+      res.status(500).json({ error: 'Registration failed' });
+    }
+  });
+
+  router.post('/login', async (req: Request, res: Response) => {
+    try {
+      const { email, password } = req.body;
+      if (!email || !password) {
+        res.status(400).json({ error: 'Missing email or password' });
+        return;
+      }
+      const user = queries.findUserByEmail(email);
+      if (!user) {
+        res.status(401).json({ error: 'Invalid credentials' });
+        return;
+      }
+      if (!queriesVerifyPassword(password, user.password_hash)) {
+        res.status(401).json({ error: 'Invalid credentials' });
+        return;
+      }
+      const token = JSON.stringify({ userId: user.id, role: user.role, exp: Math.floor(Date.now() / 1000) + 3600 });
+      const tenantId = user.tenant_id;
+      const loginUser = queries.findUserById(user.id);
+      if (!loginUser) {
+        res.status(401).json({ error: 'User not found' });
+        return;
+      }
+      res.json({ token, user: { id: loginUser.id, email: loginUser.email, tenant_id: tenantId, role: loginUser.role } });
+    } catch (error) {
+      res.status(500).json({ error: 'Login failed' });
+    }
+  });
+
+  return router;
+}
+
+export function profileRoutes(db: any): Router {
+  const router = Router();
+
+  const auth = (req: any, res: any, next: any) => {
+    const authHeader = req.headers.authorization;
+    if (!authHeader || !authHeader.startsWith('Bearer ')) {
+      res.status(401).json({ error: 'Missing or invalid authorization' });
+      return;
+    }
+    const token = authHeader.substring(7);
+    try {
+      const decoded = JSON.parse(token) as { userId: string };
+      const user = dbInstance.findUserById(decoded.userId);
+      if (!user) {
+        res.status(401).json({ error: 'User not found' });
+        return;
+      }
+      req.user = { id: user.id, email: user.email, tenant_id: user.tenant_id, role: user.role };
+    } catch {
+      res.status(401).json({ error: 'Invalid token' });
+      return;
+    }
+    next();
+  };
+
+  router.get('/profile', auth, (req: any, res: Response) => {
+    if (!req.user) {
+      res.status(401).json({ error: 'Not authenticated' });
+      return;
+    }
+    const user = dbInstance.findUserById(req.user.id);
+    if (!user) {
+      res.status(404).json({ error: 'User not found' });
+      return;
+    }
+    res.json({ id: user.id, email: user.email, tenant_id: user.tenant_id, role: user.role, created_at: user.created_at });
+  });
+
+  return router;
+}
