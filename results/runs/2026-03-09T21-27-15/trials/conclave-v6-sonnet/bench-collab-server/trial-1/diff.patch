+import { describe, it, expect, beforeEach, afterEach } from 'vitest';
+import { createApp } from '../src/server.js';
+import WebSocket from 'ws';
+import request from 'supertest';
+
+/**
+ * Connect a WebSocket and collect messages into a queue.
+ * This avoids the race condition where a sync message arrives before
+ * the test sets up its 'message' listener.
+ */
+function wsConnectWithQueue(port: number, docId: string): Promise<{
+  ws: WebSocket;
+  dequeue: () => Promise<unknown>;
+}> {
+  return new Promise((resolve, reject) => {
+    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/${docId}`);
+    const queue: unknown[] = [];
+    const waiters: Array<(msg: unknown) => void> = [];
+
+    // Set up message queuing BEFORE open fires, to capture early messages
+    ws.on('message', (data: Buffer) => {
+      let parsed: unknown;
+      try { parsed = JSON.parse(data.toString()); }
+      catch { parsed = data.toString(); }
+
+      if (waiters.length > 0) {
+        const resolve = waiters.shift()!;
+        resolve(parsed);
+      } else {
+        queue.push(parsed);
+      }
+    });
+
+    function dequeue(): Promise<unknown> {
+      if (queue.length > 0) {
+        return Promise.resolve(queue.shift()!);
+      }
+      return new Promise<unknown>((res) => {
+        waiters.push(res);
+      });
+    }
+
+    ws.once('open', () => resolve({ ws, dequeue }));
+    ws.once('error', reject);
+  });
+}
+
+type MsgType = { type: string };
+
+describe('WebSocket collaboration', () => {
+  let appInstance: ReturnType<typeof createApp>;
+  let port: number;
+  let docId: string;
+  const clients: WebSocket[] = [];
+
+  beforeEach(async () => {
+    appInstance = createApp(':memory:');
+    port = await appInstance.start(0);
+    const res = await request(appInstance.app).post('/documents').send({ title: 'Test Doc', content: 'hello' });
+    docId = res.body.id as string;
+  });
+
+  afterEach(async () => {
+    for (const ws of clients) {
+      if (ws.readyState === WebSocket.OPEN) ws.close();
+    }
+    clients.length = 0;
+    await appInstance.stop();
+  });
+
+  it('sends sync message on connect', async () => {
+    const { ws, dequeue } = await wsConnectWithQueue(port, docId);
+    clients.push(ws);
+    const msg = await dequeue() as { type: string; content: string; version: number };
+    expect(msg.type).toBe('sync');
+    expect(msg.content).toBe('hello');
+    expect(msg.version).toBe(0);
+    ws.close();
+  });
+
+  it('rejects connection to unknown document', async () => {
+    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/nonexistent`);
+    clients.push(ws);
+    await new Promise<void>((resolve) => {
+      ws.once('close', () => resolve());
+      ws.once('error', () => resolve());
+    });
+    expect(ws.readyState).not.toBe(WebSocket.OPEN);
+  });
+
+  it('applies insert operation and sends ack', async () => {
+    const { ws, dequeue } = await wsConnectWithQueue(port, docId);
+    clients.push(ws);
+    await dequeue(); // sync
+
+    ws.send(JSON.stringify({ type: 'op', version: 0, op: { type: 'insert', pos: 5, text: ' world' } }));
+    const ack = await dequeue() as MsgType;
+    expect(ack.type).toBe('ack');
+    ws.close();
+  });
+
+  it('broadcasts operation to other clients', async () => {
+    const conn1 = await wsConnectWithQueue(port, docId);
+    clients.push(conn1.ws);
+    await conn1.dequeue(); // sync
+
+    const conn2 = await wsConnectWithQueue(port, docId);
+    clients.push(conn2.ws);
+    await conn2.dequeue(); // sync
+
+    conn1.ws.send(JSON.stringify({ type: 'op', version: 0, op: { type: 'insert', pos: 5, text: '!' } }));
+
+    const ack = await conn1.dequeue() as MsgType;
+    expect(ack.type).toBe('ack');
+
+    const broadcast = await conn2.dequeue() as { type: string; op: { type: string } };
+    expect(broadcast.type).toBe('op');
+    expect(broadcast.op.type).toBe('insert');
+    conn1.ws.close();
+    conn2.ws.close();
+  });
+
+  it('two concurrent inserts converge - both preserved', async () => {
+    const conn1 = await wsConnectWithQueue(port, docId);
+    clients.push(conn1.ws);
+    await conn1.dequeue(); // sync
+
+    const conn2 = await wsConnectWithQueue(port, docId);
+    clients.push(conn2.ws);
+    await conn2.dequeue(); // sync
+
+    // Both send ops against version 0 (concurrent)
+    conn1.ws.send(JSON.stringify({ type: 'op', version: 0, op: { type: 'insert', pos: 0, text: 'A' } }));
+    conn2.ws.send(JSON.stringify({ type: 'op', version: 0, op: { type: 'insert', pos: 5, text: 'B' } }));
+
+    // Wait for ack/op on both sides
+    await Promise.all([
+      conn1.dequeue(),
+      conn2.dequeue(),
+    ]);
+
+    // Wait a tick for DB writes to settle
+    await new Promise(r => setTimeout(r, 100));
+
+    // Check final content via REST
+    const res = await request(appInstance.app).get(`/documents/${docId}`);
+    const finalContent = res.body.content as string;
+    // Both 'A' and 'B' must be present, as must original content
+    expect(finalContent).toContain('A');
+    expect(finalContent).toContain('B');
+    expect(finalContent).toContain('hello');
+    conn1.ws.close();
+    conn2.ws.close();
+  });
+
+  it('rejects out-of-bounds insert with error message', async () => {
+    const { ws, dequeue } = await wsConnectWithQueue(port, docId);
+    clients.push(ws);
+    await dequeue(); // sync
+
+    ws.send(JSON.stringify({ type: 'op', version: 0, op: { type: 'insert', pos: 9999, text: 'x' } }));
+    const errMsg = await dequeue() as { type: string; error: string };
+    expect(errMsg.type).toBe('error');
+    expect(typeof errMsg.error).toBe('string');
+    expect(errMsg.error.length).toBeGreaterThan(0);
+    ws.close();
+  });
+
+  it('rejects malformed JSON with error message', async () => {
+    const { ws, dequeue } = await wsConnectWithQueue(port, docId);
+    clients.push(ws);
+    await dequeue(); // sync
+
+    ws.send('not valid json');
+    const errMsg = await dequeue() as MsgType;
+    expect(errMsg.type).toBe('error');
+    ws.close();
+  });
+
+  it('rejects unknown message type', async () => {
+    const { ws, dequeue } = await wsConnectWithQueue(port, docId);
+    clients.push(ws);
+    await dequeue(); // sync
+
+    ws.send(JSON.stringify({ type: 'unknown', data: 'foo' }));
+    const errMsg = await dequeue() as MsgType;
+    expect(errMsg.type).toBe('error');
+    ws.close();
+  });
+
+  it('version history grows after operations', async () => {
+    const { ws, dequeue } = await wsConnectWithQueue(port, docId);
+    clients.push(ws);
+    await dequeue(); // sync
+
+    ws.send(JSON.stringify({ type: 'op', version: 0, op: { type: 'insert', pos: 5, text: ' world' } }));
+    await dequeue(); // ack
+
+    const res = await request(appInstance.app).get(`/documents/${docId}/history`);
+    expect(res.status).toBe(200);
+    // Should have version 0 (initial) and version 1 (after insert)
+    expect((res.body as unknown[]).length).toBeGreaterThanOrEqual(2);
+    ws.close();
+  });
+
+  it('handles 10 concurrent clients without corruption', async () => {
+    const NUM = 10;
+    const conns: Array<{ ws: WebSocket; dequeue: () => Promise<unknown> }> = [];
+
+    for (let i = 0; i < NUM; i++) {
+      const conn = await wsConnectWithQueue(port, docId);
+      clients.push(conn.ws);
+      conns.push(conn);
+      await conn.dequeue(); // sync
+    }
+
+    // Each sends an insert at position 0 against version 0 (all concurrent)
+    for (let i = 0; i < NUM; i++) {
+      conns[i].ws.send(JSON.stringify({ type: 'op', version: 0, op: { type: 'insert', pos: 0, text: `${i}` } }));
+    }
+
+    // Wait for all responses (ack or error, in case of OOB after transforms)
+    await Promise.all(conns.map(conn => conn.dequeue()));
+
+    await new Promise(r => setTimeout(r, 300));
+
+    // Server must not have crashed; document must be retrievable
+    const res = await request(appInstance.app).get(`/documents/${docId}`);
+    expect(res.status).toBe(200);
+    // Content must still contain 'hello'
+    expect(res.body.content as string).toContain('hello');
+
+    for (const conn of conns) conn.ws.close();
+  });
+
+  it('document content persists after operation', async () => {
+    const { ws, dequeue } = await wsConnectWithQueue(port, docId);
+    clients.push(ws);
+    await dequeue(); // sync
+
+    ws.send(JSON.stringify({ type: 'op', version: 0, op: { type: 'insert', pos: 5, text: '!' } }));
+    await dequeue(); // ack
+
+    const res = await request(appInstance.app).get(`/documents/${docId}`);
+    expect(res.body.content).toBe('hello!');
+    ws.close();
+  });
+});
