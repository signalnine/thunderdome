diff --git a/src/collaboration.ts b/src/collaboration.ts
new file mode 100644
index 0000000..827d77b
--- /dev/null
+++ b/src/collaboration.ts
@@ -0,0 +1,227 @@
+import { WebSocketServer, WebSocket } from 'ws';
+import type { IncomingMessage } from 'http';
+import type Database from 'better-sqlite3';
+import { applyOp, transformOp, type Op } from './ot.js';
+
+interface ClientOpMessage {
+  type: 'op';
+  version: number;
+  op: Op;
+}
+
+interface ServerOpMessage {
+  type: 'op';
+  version: number;
+  op: Op;
+}
+
+interface SyncMessage {
+  type: 'sync';
+  content: string;
+  version: number;
+}
+
+interface AckMessage {
+  type: 'ack';
+  version: number;
+}
+
+interface ErrorMessage {
+  type: 'error';
+  error: string;
+}
+
+interface DocRow {
+  id: string;
+  content: string;
+}
+
+/** Manages all clients editing a single document and serializes op application. */
+class DocumentRoom {
+  private clients = new Set<WebSocket>();
+
+  constructor(
+    private readonly docId: string,
+    private readonly db: Database.Database,
+  ) {}
+
+  addClient(ws: WebSocket): void {
+    this.clients.add(ws);
+  }
+
+  removeClient(ws: WebSocket): void {
+    this.clients.delete(ws);
+  }
+
+  get size(): number {
+    return this.clients.size;
+  }
+
+  getCurrentVersion(): number {
+    const row = this.db
+      .prepare('SELECT COALESCE(MAX(version), 0) as v FROM versions WHERE document_id = ?')
+      .get(this.docId) as { v: number };
+    return row.v;
+  }
+
+  getCurrentContent(): string {
+    const row = this.db
+      .prepare('SELECT content FROM documents WHERE id = ?')
+      .get(this.docId) as DocRow | undefined;
+    return row?.content ?? '';
+  }
+
+  /**
+   * Apply an incoming op with OT transformation against concurrent ops.
+   * This runs synchronously inside a SQLite transaction for atomicity.
+   */
+  applyClientOp(clientVersion: number, op: Op): { newVersion: number; transformedOp: Op } {
+    const result = (this.db.transaction(() => {
+      // Get all ops applied since clientVersion (concurrent with this op)
+      const concurrent = this.db
+        .prepare('SELECT operation FROM versions WHERE document_id = ? AND version > ? ORDER BY version ASC')
+        .all(this.docId, clientVersion) as { operation: string | null }[];
+
+      // Transform incoming op against each concurrent op that was applied first
+      let transformed: Op = op;
+      for (const row of concurrent) {
+        if (row.operation) {
+          const prior = JSON.parse(row.operation) as Op;
+          transformed = transformOp(transformed, prior);
+        }
+      }
+
+      // Apply to current content
+      const currentContent = this.getCurrentContent();
+      const newContent = applyOp(currentContent, transformed);
+      const newVersion = this.getCurrentVersion() + 1;
+      const now = new Date().toISOString();
+
+      this.db
+        .prepare('UPDATE documents SET content = ?, updated_at = ? WHERE id = ?')
+        .run(newContent, now, this.docId);
+      this.db
+        .prepare('INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)')
+        .run(this.docId, newVersion, newContent, JSON.stringify(transformed));
+
+      return { newVersion, transformedOp: transformed };
+    }))();
+
+    return result as { newVersion: number; transformedOp: Op };
+  }
+
+  broadcast(sender: WebSocket, msg: ServerOpMessage): void {
+    const payload = JSON.stringify(msg);
+    for (const client of this.clients) {
+      if (client !== sender && client.readyState === WebSocket.OPEN) {
+        client.send(payload);
+      }
+    }
+  }
+}
+
+export function attachWebSocket(wss: WebSocketServer, db: Database.Database): void {
+  const rooms = new Map<string, DocumentRoom>();
+
+  function getRoom(docId: string): DocumentRoom {
+    let room = rooms.get(docId);
+    if (!room) {
+      room = new DocumentRoom(docId, db);
+      rooms.set(docId, room);
+    }
+    return room;
+  }
+
+  wss.on('connection', (ws: WebSocket, req: IncomingMessage) => {
+    // Extract document ID from path /ws/documents/:id
+    const match = req.url?.match(/^\/ws\/documents\/([^/?#]+)/);
+    if (!match) {
+      ws.close(1008, 'Invalid path');
+      return;
+    }
+    const docId = match[1];
+
+    // Verify document exists
+    const doc = db.prepare('SELECT id, content FROM documents WHERE id = ?').get(docId) as DocRow | undefined;
+    if (!doc) {
+      ws.close(1008, 'Document not found');
+      return;
+    }
+
+    const room = getRoom(docId);
+    room.addClient(ws);
+
+    // Send initial sync
+    const syncMsg: SyncMessage = {
+      type: 'sync',
+      content: room.getCurrentContent(),
+      version: room.getCurrentVersion(),
+    };
+    ws.send(JSON.stringify(syncMsg));
+
+    ws.on('message', (data: Buffer) => {
+      let msg: ClientOpMessage;
+      try {
+        msg = JSON.parse(data.toString()) as ClientOpMessage;
+      } catch {
+        ws.send(JSON.stringify({ type: 'error', error: 'Invalid JSON' } satisfies ErrorMessage));
+        return;
+      }
+
+      if (msg.type !== 'op') {
+        ws.send(JSON.stringify({ type: 'error', error: `Unknown message type: ${String(msg.type)}` } satisfies ErrorMessage));
+        return;
+      }
+
+      if (!msg.op || typeof msg.op.type !== 'string') {
+        ws.send(JSON.stringify({ type: 'error', error: 'Missing or invalid op' } satisfies ErrorMessage));
+        return;
+      }
+
+      if (typeof msg.version !== 'number') {
+        ws.send(JSON.stringify({ type: 'error', error: 'Missing version' } satisfies ErrorMessage));
+        return;
+      }
+
+      // Validate op fields
+      const { op } = msg;
+      if (op.type === 'insert') {
+        if (typeof op.pos !== 'number' || typeof op.text !== 'string') {
+          ws.send(JSON.stringify({ type: 'error', error: 'Invalid insert op: pos must be number, text must be string' } satisfies ErrorMessage));
+          return;
+        }
+      } else if (op.type === 'delete') {
+        if (typeof op.pos !== 'number' || typeof op.len !== 'number' || op.len < 0) {
+          ws.send(JSON.stringify({ type: 'error', error: 'Invalid delete op: pos and len must be non-negative numbers' } satisfies ErrorMessage));
+          return;
+        }
+      } else {
+        ws.send(JSON.stringify({ type: 'error', error: `Unknown op type: ${String((op as { type: string }).type)}` } satisfies ErrorMessage));
+        return;
+      }
+
+      try {
+        const { newVersion, transformedOp } = room.applyClientOp(msg.version, op);
+
+        const ack: AckMessage = { type: 'ack', version: newVersion };
+        ws.send(JSON.stringify(ack));
+
+        const broadcast: ServerOpMessage = { type: 'op', version: newVersion, op: transformedOp };
+        room.broadcast(ws, broadcast);
+      } catch (err) {
+        const errMsg: ErrorMessage = {
+          type: 'error',
+          error: err instanceof Error ? err.message : String(err),
+        };
+        ws.send(JSON.stringify(errMsg));
+      }
+    });
+
+    ws.on('close', () => {
+      room.removeClient(ws);
+      if (room.size === 0) {
+        rooms.delete(docId);
+      }
+    });
+  });
+}
