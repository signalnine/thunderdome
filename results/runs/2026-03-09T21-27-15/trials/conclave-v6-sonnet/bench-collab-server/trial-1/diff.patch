ort: number, docId: string): Promise<WebSocket> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/${docId}`);\n    ws.once('open', () => resolve(ws));\n    ws.once('error', reject);\n  });\n}\n\nfunction nextMessage(ws: WebSocket): Promise<unknown> {\n  return new Promise((resolve, reject) => {\n    ws.once('message', (data: Buffer) => {\n      try { resolve(JSON.parse(data.toString())); }\n      catch (e) { reject(e); }\n    });\n    ws.once('close', () => reject(new Error('WebSocket closed before message')));\n    ws.once('error', reject);\n  });\n}\n\nfunction waitForMessage(ws: WebSocket, predicate: (msg: unknown) => boolean, timeoutMs = 3000): Promise<unknown> {\n  return new Promise((resolve, reject) => {\n    const timer = setTimeout(() => {\n      ws.off('message', onMessage);\n      reject(new Error('waitForMessage timeout'));\n    }, timeoutMs);\n\n    function onMessage(data: Buffer) {\n      try {\n        const msg = JSON.parse(data.toString()) as unknown;\n        if (predicate(msg)) {\n          clearTimeout(timer);\n          ws.off('message', onMessage);\n          resolve(msg);\n        }\n      } catch { /* skip non-JSON */ }\n    }\n    ws.on('message', onMessage);\n  });\n}\n\ntype MsgType = { type: string };\n\ndescribe('WebSocket collaboration', () => {\n  let appInstance: ReturnType<typeof createApp>;\n  let port: number;\n  let docId: string;\n  const clients: WebSocket[] = [];\n\n  beforeEach(async () => {\n    appInstance = createApp(':memory:');\n    port = await appInstance.start(0);\n    const res = await request(appInstance.app).post('/documents').send({ title: 'Test Doc', content: 'hello' });\n    docId = res.body.id as string;\n  });\n\n  afterEach(async () => {\n    for (const ws of clients) {\n      if (ws.readyState === WebSocket.OPEN) ws.close();\n    }\n    clients.length = 0;\n    await appInstance.stop();\n  });\n\n  it('sends sync message on connect', async () => {\n    const ws = await wsConnect(port, docId);\n    clients.push(ws);\n    const msg = await nextMessage(ws) as { type: string; content: string; version: number };\n    expect(msg.type).toBe('sync');\n    expect(msg.content).toBe('hello');\n    expect(msg.version).toBe(0);\n    ws.close();\n  });\n\n  it('rejects connection to unknown document', async () => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/nonexistent`);\n    clients.push(ws);\n    await new Promise<void>((resolve) => {\n      ws.once('close', () => resolve());\n      ws.once('error', () => resolve());\n    });\n    expect(ws.readyState).not.toBe(WebSocket.OPEN);\n  });\n\n  it('applies insert operation and sends ack', async () => {\n    const ws = await wsConnect(port, docId);\n    clients.push(ws);\n    await nextMessage(ws); // sync\n\n    ws.send(JSON.stringify({ type: 'op', version: 0, op: { type: 'insert', pos: 5, text: ' world' } }));\n    const ack = await nextMessage(ws) as MsgType;\n    expect(ack.type).toBe('ack');\n  });\n\n  it('broadcasts operation to other clients', async () => {\n    const ws1 = await wsConnect(port, docId);\n    clients.push(ws1);\n    await nextMessage(ws1); // sync\n\n    const ws2 = await wsConnect(port, docId);\n    clients.push(ws2);\n    await nextMessage(ws2); // sync\n\n    ws1.send(JSON.stringify({ type: 'op', version: 0, op: { type: 'insert', pos: 5, text: '!' } }));\n\n    const ack = await nextMessage(ws1) as MsgType;\n    expect(ack.type).toBe('ack');\n\n    const broadcast = await nextMessage(ws2) as { type: string; op: { type: string } };\n    expect(broadcast.type).toBe('op');\n    expect(broadcast.op.type).toBe('insert');\n  });\n\n  it('two concurrent inserts converge - both preserved', async () => {\n    const ws1 = await wsConnect(port, docId);\n    clients.push(ws1);\n    await nextMessage(ws1); // sync\n\n    const ws2 = await wsConnect(port, docId);\n    clients.push(ws2);\n    await nextMessage(ws2); // sync\n\n    // Both send ops against version 0 (concurrent)\n    ws1.send(JSON.stringify({ type: 'op', version: 0, op: { type: 'insert', pos: 0, text: 'A' } }));\n    ws2.send(JSON.stringify({ type: 'op', version: 0, op: { type: 'insert', pos: 5, text: 'B' } }));\n\n    // Wait for both to get a response\n    await Promise.all([\n      waitForMessage(ws1, m => (m as MsgType).type === 'ack' || (m as MsgType).type === 'op'),\n      waitForMessage(ws2, m => (m as MsgType).type === 'ack' || (m as MsgType).type === 'op'),\n    ]);\n\n    // Wait a tick for DB writes to settle\n    await new Promise(r => setTimeout(r, 100));\n\n    // Check final content via REST\n    const res = await request(appInstance.app).get(`/documents/${docId}`);\n    const finalContent = res.body.content as string;\n    // Both 'A' and 'B' must be present, as must original content\n    expect(finalContent).toContain('A');\n    expect(finalContent).toContain('B');\n    expect(finalContent).toContain('hello');\n  });\n\n  it('rejects out-of-bounds insert with error message', async () => {\n    const ws = await wsConnect(port, docId);\n    clients.push(ws);\n    await nextMessage(ws); // sync\n\n    ws.send(JSON.stringify({ type: 'op', version: 0, op: { type: 'insert', pos: 9999, text: 'x' } }));\n    const errMsg = await nextMessage(ws) as { type: string; error: string };\n    expect(errMsg.type).toBe('error');\n    expect(typeof errMsg.error).toBe('string');\n    expect(errMsg.error.length).toBeGreaterThan(0);\n  });\n\n  it('rejects malformed JSON with error message', async () => {\n    const ws = await wsConnect(port, docId);\n    clients.push(ws);\n    await nextMessage(ws); // sync\n\n    ws.send('not valid json');\n    const errMsg = await nextMessage(ws) as { type: string };\n    expect(errMsg.type).toBe('error');\n  });\n\n  it('rejects unknown message type', async () => {\n    const ws = await wsConnect(port, docId);\n    clients.push(ws);\n    await nextMessage(ws); // sync\n\n    ws.send(JSON.stringify({ type: 'unknown', data: 'foo' }));\n    const errMsg = await nextMessage(ws) as { type: string };\n    expect(errMsg.type).toBe('error');\n  });\n\n  it('version history grows after operations', async () => {\n    const ws = await wsConnect(port, docId);\n    clients.push(ws);\n    await nextMessage(ws); // sync\n\n    ws.send(JSON.stringify({ type: 'op', version: 0, op: { type: 'insert', pos: 5, text: ' world' } }));\n    await nextMessage(ws); // ack\n\n    const res = await request(appInstance.app).get(`/documents/${docId}/history`);\n    expect(res.status).toBe(200);\n    // Should have version 0 (initial) and version 1 (after insert)\n    expect(res.body.length).toBeGreaterThanOrEqual(2);\n  });\n\n  it('handles 10 concurrent clients without corruption', async () => {\n    const NUM = 10;\n    const sockets: WebSocket[] = [];\n\n    for (let i = 0; i < NUM; i++) {\n      const ws = await wsConnect(port, docId);\n      clients.push(ws);\n      sockets.push(ws);\n      await nextMessage(ws); // sync\n    }\n\n    // Each sends an insert at position 0 against version 0 (all concurrent)\n    const sends = sockets.map((ws, i) =>\n      ws.send(JSON.stringify({ type: 'op', version: 0, op: { type: 'insert', pos: 0, text: `${i}` } })),\n    );\n    void sends;\n\n    // Wait for all responses\n    await Promise.all(\n      sockets.map(ws =>\n        waitForMessage(ws, m => (m as MsgType).type === 'ack' || (m as MsgType).type === 'error' || (m as MsgType).type === 'op', 5000),\n      ),\n    );\n\n    await new Promise(r => setTimeout(r, 500));\n\n    // Server must not have crashed; document must be retrievable\n    const res = await request(appInstance.app).get(`/documents/${docId}`);\n    expect(res.status).toBe(200);\n    // Content must still contain 'hello'\n    expect(res.body.content as string).toContain('hello');\n\n    for (const ws of sockets) ws.close();\n  });\n\n  it('document content persists after reconnect (via new app with same DB)', async () => {\n    // Apply an op\n    const ws = await wsConnect(port, docId);\n    clients.push(ws);\n    await nextMessage(ws); // sync\n\n    ws.send(JSON.stringify({ type: 'op', version: 0, op: { type: 'insert', pos: 5, text: '!' } }));\n    await nextMessage(ws); // ack\n\n    // Verify via REST\n    const res = await request(appInstance.app).get(`/documents/${docId}`);\n    expect(res.body.content).toBe('hello!');\n  });\n});\n"}}
