ontain('B');\n    expect(finalContent).toContain('hello');\n    conn1.ws.close();\n    conn2.ws.close();\n  });\n\n  it('rejects out-of-bounds insert with error message', async () => {\n    const { ws, dequeue } = await wsConnectWithQueue(port, docId);\n    clients.push(ws);\n    await dequeue(); // sync\n\n    ws.send(JSON.stringify({ type: 'op', version: 0, op: { type: 'insert', pos: 9999, text: 'x' } }));\n    const errMsg = await dequeue() as { type: string; error: string };\n    expect(errMsg.type).toBe('error');\n    expect(typeof errMsg.error).toBe('string');\n    expect(errMsg.error.length).toBeGreaterThan(0);\n    ws.close();\n  });\n\n  it('rejects malformed JSON with error message', async () => {\n    const { ws, dequeue } = await wsConnectWithQueue(port, docId);\n    clients.push(ws);\n    await dequeue(); // sync\n\n    ws.send('not valid json');\n    const errMsg = await dequeue() as MsgType;\n    expect(errMsg.type).toBe('error');\n    ws.close();\n  });\n\n  it('rejects unknown message type', async () => {\n    const { ws, dequeue } = await wsConnectWithQueue(port, docId);\n    clients.push(ws);\n    await dequeue(); // sync\n\n    ws.send(JSON.stringify({ type: 'unknown', data: 'foo' }));\n    const errMsg = await dequeue() as MsgType;\n    expect(errMsg.type).toBe('error');\n    ws.close();\n  });\n\n  it('version history grows after operations', async () => {\n    const { ws, dequeue } = await wsConnectWithQueue(port, docId);\n    clients.push(ws);\n    await dequeue(); // sync\n\n    ws.send(JSON.stringify({ type: 'op', version: 0, op: { type: 'insert', pos: 5, text: ' world' } }));\n    await dequeue(); // ack\n\n    const res = await request(appInstance.app).get(`/documents/${docId}/history`);\n    expect(res.status).toBe(200);\n    // Should have version 0 (initial) and version 1 (after insert)\n    expect((res.body as unknown[]).length).toBeGreaterThanOrEqual(2);\n    ws.close();\n  });\n\n  it('handles 10 concurrent clients without corruption', async () => {\n    const NUM = 10;\n    const conns: Array<{ ws: WebSocket; dequeue: () => Promise<unknown> }> = [];\n\n    for (let i = 0; i < NUM; i++) {\n      const conn = await wsConnectWithQueue(port, docId);\n      clients.push(conn.ws);\n      conns.push(conn);\n      await conn.dequeue(); // sync\n    }\n\n    // Each sends an insert at position 0 against version 0 (all concurrent)\n    for (let i = 0; i < NUM; i++) {\n      conns[i].ws.send(JSON.stringify({ type: 'op', version: 0, op: { type: 'insert', pos: 0, text: `${i}` } }));\n    }\n\n    // Wait for all responses (ack or error, in case of OOB after transforms)\n    await Promise.all(conns.map(conn => conn.dequeue()));\n\n    await new Promise(r => setTimeout(r, 300));\n\n    // Server must not have crashed; document must be retrievable\n    const res = await request(appInstance.app).get(`/documents/${docId}`);\n    expect(res.status).toBe(200);\n    // Content must still contain 'hello'\n    expect(res.body.content as string).toContain('hello');\n\n    for (const conn of conns) conn.ws.close();\n  });\n\n  it('document content persists after operation', async () => {\n    const { ws, dequeue } = await wsConnectWithQueue(port, docId);\n    clients.push(ws);\n    await dequeue(); // sync\n\n    ws.send(JSON.stringify({ type: 'op', version: 0, op: { type: 'insert', pos: 5, text: '!' } }));\n    await dequeue(); // ack\n\n    const res = await request(appInstance.app).get(`/documents/${docId}`);\n    expect(res.body.content).toBe('hello!');\n    ws.close();\n  });\n});\n","structuredPatch":[{"oldStart":3,"oldLines":43,"newStart":3,"newLines":45,"lines":[" import WebSocket from 'ws';"," import request from 'supertest';"," ","-function wsConnect(port: number, docId: string): Promise<WebSocket> {","+/**","+ * Connect a WebSocket and collect messages into a queue.","+ * This avoids the race condition where a sync message arrives before","+ * the test sets up its 'message' listener.","+ */","+function wsC