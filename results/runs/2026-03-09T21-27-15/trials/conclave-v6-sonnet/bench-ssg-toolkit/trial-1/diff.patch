st', { assets: ['image.png', 'style.css'] });\n    53→    const ctx = makeCtx(new Map(), data);\n    54→    await plugin.hooks.afterBuild!(ctx);\n    55→    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    56→    expect(config.assetPaths).toContain('image.png');\n    57→    expect(config.assetPaths).toContain('style.css');\n    58→    const assetRoutes = config.routes.filter(r => r.handler === 'asset');\n    59→    expect(assetRoutes.length).toBeGreaterThanOrEqual(2);\n    60→  });\n    61→\n    62→  it('config includes search index path', async () => {\n    63→    const output = new Map<string, string>();\n    64→    output.set('search-index.json', '[]');\n    65→    const ctx = makeCtx(output);\n    66→    await plugin.hooks.afterBuild!(ctx);\n    67→    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    68→    expect(config.searchIndexPath).toBe('/search-index.json');\n    69→  });\n    70→\n    71→  it('config includes content routes', async () => {\n    72→    const output = new Map<string, string>();\n    73→    output.set('post-1.html', '<html></html>');\n    74→    output.set('post-2.html', '<html></html>');\n    75→    const ctx = makeCtx(output);\n    76→    await plugin.hooks.afterBuild!(ctx);\n    77→    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    78→    const contentRoutes = config.routes.filter(r => r.handler === 'static');\n    79→    expect(contentRoutes.length).toBe(2);\n    80→  });\n    81→\n    82→  it('default port is 3000', async () => {\n    83→    const ctx = makeCtx();\n    84→    await plugin.hooks.afterBuild!(ctx);\n    85→    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    86→    expect(config.port).toBe(3000);\n    87→  });\n    88→\n    89→  it('handles missing asset-pipeline data gracefully', async () => {\n    90→    const ctx = makeCtx();\n    91→    await plugin.hooks.afterBuild!(ctx);\n    92→    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    93→    expect(config.assetPaths).toEqual([]);\n    94→  });\n    95→});\n    96→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01A76Afdb4ipwHzsMTohHUix","session_id":"49516ca0-6110-4ce2-8417-b08fb2364615","uuid":"f1454de6-d345-4187-bde2-2d834be81909"}
