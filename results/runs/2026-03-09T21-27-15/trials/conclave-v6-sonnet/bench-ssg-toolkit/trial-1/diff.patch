+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+function getOrCreateManifest(ctx: BuildContext): { assets: string[] } {
+  if (!ctx.data.has('asset-manifest')) {
+    ctx.data.set('asset-manifest', { assets: [] });
+  }
+  return ctx.data.get('asset-manifest') as { assets: string[] };
+}
+
+function rewriteAssetUrls(content: string, manifest: { assets: string[] }): string {
+  // Rewrite relative src attributes (images, etc.)
+  content = content.replace(/src="(\.\/([^"]+))"/g, (_match, _full, filename) => {
+    if (!manifest.assets.includes(filename)) {
+      manifest.assets.push(filename);
+    }
+    return `src="/assets/${filename}"`;
+  });
+
+  // Rewrite relative href attributes (links to files like PDFs)
+  content = content.replace(/href="(\.\/([^"]+))"/g, (_match, _full, filename) => {
+    if (!manifest.assets.includes(filename)) {
+      manifest.assets.push(filename);
+    }
+    return `href="/assets/${filename}"`;
+  });
+
+  return content;
+}
+
+export function createAssetPipelinePlugin(): Plugin {
+  return {
+    name: 'asset-pipeline',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file: ContentFile, ctx: BuildContext): ContentFile {
+        const manifest = getOrCreateManifest(ctx);
+        const newContent = rewriteAssetUrls(file.content, manifest);
+        return { ...file, content: newContent };
+      },
+    },
+  };
+}
