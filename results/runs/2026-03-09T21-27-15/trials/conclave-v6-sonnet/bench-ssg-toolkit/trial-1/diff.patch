@@ -0,0 +1,66 @@
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+function escapeXml(str: string): string {
+  return str
+    .replace(/&/g, '&amp;')
+    .replace(/</g, '&lt;')
+    .replace(/>/g, '&gt;')
+    .replace(/"/g, '&quot;');
+}
+
+function getFileTags(file: ContentFile, ctx: BuildContext): string[] {
+  // Try to use taxonomy tags data if available
+  const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]> | undefined;
+  if (tagMap && file.tags) {
+    return file.tags.map(t => t.toLowerCase());
+  }
+  return file.tags ?? [];
+}
+
+function renderItem(file: ContentFile, baseUrl: string, ctx: BuildContext): string {
+  const link = `${baseUrl}/${file.slug}.html`;
+  const pubDate = file.date ? `\n      <pubDate>${file.date}</pubDate>` : '';
+  const tags = getFileTags(file, ctx);
+  const categories = tags.map(t => `\n      <category>${escapeXml(t)}</category>`).join('');
+  const description = `<![CDATA[${file.content}]]>`;
+
+  return `    <item>
+      <title>${escapeXml(file.title)}</title>
+      <link>${link}</link>${pubDate}${categories}
+      <description>${description}</description>
+    </item>`;
+}
+
+export function createRssFeedPlugin(): Plugin {
+  return {
+    name: 'rss-feed',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'taxonomy'],
+    hooks: {
+      afterBuild(ctx: BuildContext): void {
+        const { config, files } = ctx;
+
+        // Sort by date, newest first; undated files go last
+        const sorted = [...files].sort((a, b) => {
+          if (!a.date && !b.date) return 0;
+          if (!a.date) return 1;
+          if (!b.date) return -1;
+          return b.date.localeCompare(a.date);
+        });
+
+        const items = sorted.map(f => renderItem(f, config.baseUrl, ctx)).join('\n');
+
+        const feed = `<?xml version="1.0" encoding="UTF-8"?>
+<rss version="2.0">
+  <channel>
+    <title>${escapeXml(config.title)}</title>
+    <link>${config.baseUrl}</link>
+${items}
+  </channel>
+</rss>`;
+
+        ctx.output.set('feed.xml', feed);
+      },
+    },
+  };
+}
