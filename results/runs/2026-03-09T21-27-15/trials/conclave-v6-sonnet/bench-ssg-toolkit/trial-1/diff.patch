+import { marked } from 'marked';
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+function processAdmonitions(content: string): string {
+  return content.replace(/:::(\w+)\n([\s\S]*?):::/g, (_match, type, body) => {
+    const trimmed = body.trim();
+    return `<div class="admonition admonition-${type}">${trimmed}</div>`;
+  });
+}
+
+function processFootnotes(content: string): { content: string; footnotes: Array<{ id: number; text: string }> } {
+  const footnotes: Array<{ id: number; text: string }> = [];
+  const footnoteDefRegex = /^\[\^(\d+)\]:\s*(.+)$/gm;
+  let match;
+
+  while ((match = footnoteDefRegex.exec(content)) !== null) {
+    footnotes.push({ id: parseInt(match[1]), text: match[2] });
+  }
+
+  // Remove footnote definitions from content
+  let processed = content.replace(/^\[\^\d+\]:.+$/gm, '').trim();
+
+  // Replace footnote references with superscript links
+  processed = processed.replace(/\[\^(\d+)\]/g, (_m, id) => {
+    return `<sup><a href="#fn-${id}">${id}</a></sup>`;
+  });
+
+  return { content: processed, footnotes };
+}
+
+function renderMarkdown(raw: string): string {
+  // Process admonitions before markdown (to avoid markdown parsing inside)
+  const withAdmonitions = processAdmonitions(raw);
+
+  // Process footnotes
+  const { content: withRefs, footnotes } = processFootnotes(withAdmonitions);
+
+  // Render markdown
+  let html = marked.parse(withRefs) as string;
+
+  // Append footnotes section if any
+  if (footnotes.length > 0) {
+    const items = footnotes
+      .sort((a, b) => a.id - b.id)
+      .map(fn => `<li id="fn-${fn.id}">${fn.text}</li>`)
+      .join('\n');
+    html += `\n<section class="footnotes"><ol>\n${items}\n</ol></section>`;
+  }
+
+  return html;
+}
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file: ContentFile, _ctx: BuildContext): ContentFile {
+        return {
+          ...file,
+          content: renderMarkdown(file.content),
+        };
+      },
+    },
+  };
+}
