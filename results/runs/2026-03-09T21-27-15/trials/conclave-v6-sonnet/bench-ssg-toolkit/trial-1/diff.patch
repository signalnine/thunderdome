@@ -0,0 +1,50 @@
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+function buildTagIndex(files: ContentFile[]): Map<string, ContentFile[]> {
+  const tagMap = new Map<string, ContentFile[]>();
+
+  for (const file of files) {
+    if (file.tags && file.tags.length > 0) {
+      for (const tag of file.tags) {
+        const normalized = tag.toLowerCase();
+        if (!tagMap.has(normalized)) {
+          tagMap.set(normalized, []);
+        }
+        tagMap.get(normalized)!.push(file);
+      }
+    }
+  }
+
+  return tagMap;
+}
+
+function generateTagPage(tag: string, files: ContentFile[]): string {
+  const items = files
+    .map(f => `<li><a href="/${f.slug}.html">${f.title}</a></li>`)
+    .join('\n');
+  return `<html><body><h1>Tag: ${tag}</h1><ul>\n${items}\n</ul></body></html>`;
+}
+
+export function createTaxonomyPlugin(): Plugin {
+  return {
+    name: 'taxonomy',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      beforeBuild(ctx: BuildContext): void {
+        const tagMap = buildTagIndex(ctx.files);
+        ctx.data.set('taxonomy-tags', tagMap);
+      },
+
+      afterBuild(ctx: BuildContext): void {
+        const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]> | undefined;
+        if (!tagMap) return;
+
+        for (const [tag, files] of tagMap) {
+          const page = generateTagPage(tag, files);
+          ctx.output.set(`tags/${tag}.html`, page);
+        }
+      },
+    },
+  };
+}
