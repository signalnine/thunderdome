);\n\n        const items = sorted.map(f => renderItem(f, config.baseUrl, ctx)).join('\\n');\n\n        const feed = `<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<rss version=\"2.0\">\n  <channel>\n    <title>${escapeXml(config.title)}</title>\n    <link>${config.baseUrl}</link>\n${items}\n  </channel>\n</rss>`;\n\n        ctx.output.set('feed.xml', feed);\n      },\n    },\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":414,"cache_read_input_tokens":45363,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":414},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"49516ca0-6110-4ce2-8417-b08fb2364615","uuid":"2c333a4b-397d-4214-bc85-53471a00637b"}
