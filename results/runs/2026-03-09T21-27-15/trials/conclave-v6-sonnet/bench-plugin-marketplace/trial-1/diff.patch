+import { describe, it, expect, beforeEach } from 'vitest';
+import { createMarketplace } from './index.js';
+import type { PluginManifest } from './types.js';
+
+function makeManifest(overrides: Partial<PluginManifest> = {}): PluginManifest {
+  return {
+    name: 'my-plugin',
+    version: '1.0.0',
+    description: 'A test plugin',
+    author: 'Alice',
+    dependencies: {},
+    entryPoint: 'output = 42',
+    permissions: [],
+    ...overrides,
+  };
+}
+
+describe('createMarketplace', () => {
+  let marketplace: ReturnType<typeof createMarketplace>;
+
+  beforeEach(() => {
+    marketplace = createMarketplace();
+  });
+
+  it('exposes registry, resolver, runner, reviews, and deps services', () => {
+    expect(marketplace.registry).toBeDefined();
+    expect(marketplace.resolver).toBeDefined();
+    expect(marketplace.runner).toBeDefined();
+    expect(marketplace.reviews).toBeDefined();
+    expect(marketplace.deps).toBeDefined();
+  });
+
+  it('installs a plugin successfully with no dependencies', async () => {
+    const manifest = makeManifest();
+    const result = await marketplace.installPlugin(manifest);
+    expect(result.resolvedDependencies).toEqual([]);
+    expect(result.sandboxResult.success).toBe(true);
+    expect(result.sandboxResult.output).toBe(42);
+  });
+
+  it('registers the plugin in the registry after install', async () => {
+    const manifest = makeManifest();
+    await marketplace.installPlugin(manifest);
+    expect(marketplace.registry.get('my-plugin')).not.toBeNull();
+  });
+
+  it('rejects install when name is missing', async () => {
+    const manifest = makeManifest({ name: '' });
+    await expect(marketplace.installPlugin(manifest)).rejects.toThrow();
+  });
+
+  it('rejects install when version is missing', async () => {
+    const manifest = makeManifest({ version: '' });
+    await expect(marketplace.installPlugin(manifest)).rejects.toThrow();
+  });
+
+  it('rejects install when entryPoint is missing', async () => {
+    const manifest = makeManifest({ entryPoint: '' });
+    await expect(marketplace.installPlugin(manifest)).rejects.toThrow();
+  });
+
+  it('resolves dependency versions during install', async () => {
+    // First register a dependency
+    marketplace.registry.register({
+      name: 'dep-plugin',
+      version: '1.0.0',
+      description: 'A dep',
+      author: 'Bob',
+      dependencies: {},
+      entryPoint: '',
+      permissions: [],
+    });
+
+    const manifest = makeManifest({ dependencies: { 'dep-plugin': '^1.0.0' } });
+    const result = await marketplace.installPlugin(manifest);
+    expect(result.resolvedDependencies).toHaveLength(1);
+    expect(result.resolvedDependencies[0].name).toBe('dep-plugin');
+    expect(result.resolvedDependencies[0].version).toBe('1.0.0');
+  });
+
+  it('rejects install when plugin has circular dependencies', async () => {
+    // Register plugin-b which depends back on plugin-a
+    marketplace.registry.register({
+      name: 'plugin-b',
+      version: '1.0.0',
+      description: 'B',
+      author: 'Bob',
+      dependencies: { 'my-plugin': '1.0.0' },
+      entryPoint: '',
+      permissions: [],
+    });
+
+    const manifest = makeManifest({ dependencies: { 'plugin-b': '1.0.0' } });
+    await expect(marketplace.installPlugin(manifest)).rejects.toThrow(/circular/i);
+  });
