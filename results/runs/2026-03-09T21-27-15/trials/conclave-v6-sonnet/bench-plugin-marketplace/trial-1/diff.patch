new file mode 100644
index 0000000..6472cd7
--- /dev/null
+++ b/src/deps/deps.test.ts
@@ -0,0 +1,112 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { createDepsService } from './index.js';
+import { createRegistry } from '../registry/index.js';
+import type { PluginManifest } from '../types.js';
+
+function makeManifest(name: string, version: string, deps: Record<string, string> = {}): PluginManifest {
+  return {
+    name,
+    version,
+    description: '',
+    author: 'test',
+    dependencies: deps,
+    entryPoint: 'index.js',
+    permissions: [],
+  };
+}
+
+describe('DependencyGraph', () => {
+  let deps: ReturnType<typeof createDepsService>;
+  let registry: ReturnType<typeof createRegistry>;
+
+  beforeEach(() => {
+    deps = createDepsService();
+    registry = createRegistry();
+  });
+
+  it('builds a simple dependency tree with no deps', () => {
+    registry.register(makeManifest('plugin-a', '1.0.0'));
+    const tree = deps.buildTree('plugin-a', registry);
+    expect(tree.name).toBe('plugin-a');
+    expect(tree.version).toBe('1.0.0');
+    expect(tree.dependencies).toEqual([]);
+  });
+
+  it('builds a dependency tree with one level of deps', () => {
+    registry.register(makeManifest('plugin-b', '1.0.0'));
+    registry.register(makeManifest('plugin-a', '1.0.0', { 'plugin-b': '1.0.0' }));
+    const tree = deps.buildTree('plugin-a', registry);
+    expect(tree.dependencies).toHaveLength(1);
+    expect(tree.dependencies[0].name).toBe('plugin-b');
+    expect(tree.dependencies[0].version).toBe('1.0.0');
+  });
+
+  it('builds a multi-level dependency tree', () => {
+    registry.register(makeManifest('core', '1.0.0'));
+    registry.register(makeManifest('utils', '1.0.0', { core: '1.0.0' }));
+    registry.register(makeManifest('app', '1.0.0', { utils: '1.0.0' }));
+    const tree = deps.buildTree('app', registry);
+    expect(tree.dependencies[0].name).toBe('utils');
+    expect(tree.dependencies[0].dependencies[0].name).toBe('core');
+  });
+
+  it('detects no cycles in a simple tree', () => {
+    registry.register(makeManifest('b', '1.0.0'));
+    registry.register(makeManifest('a', '1.0.0', { b: '1.0.0' }));
+    expect(deps.detectCycles('a', registry)).toBeNull();
+    expect(deps.hasCircularDependency('a', registry)).toBe(false);
+  });
+
+  it('detects a direct circular dependency (a -> b -> a)', () => {
+    registry.register(makeManifest('a', '1.0.0', { b: '1.0.0' }));
+    registry.register(makeManifest('b', '1.0.0', { a: '1.0.0' }));
+    const cycles = deps.detectCycles('a', registry);
+    expect(cycles).not.toBeNull();
+    expect(cycles!.length).toBeGreaterThan(0);
+    expect(deps.hasCircularDependency('a', registry)).toBe(true);
+  });
+
+  it('detects an indirect circular dependency (a -> b -> c -> a)', () => {
+    registry.register(makeManifest('a', '1.0.0', { b: '1.0.0' }));
+    registry.register(makeManifest('b', '1.0.0', { c: '1.0.0' }));
+    registry.register(makeManifest('c', '1.0.0', { a: '1.0.0' }));
+    expect(deps.hasCircularDependency('a', registry)).toBe(true);
+  });
+
+  it('produces topological sort for a simple tree', () => {
+    registry.register(makeManifest('c', '1.0.0'));
+    registry.register(makeManifest('b', '1.0.0', { c: '1.0.0' }));
+    registry.register(makeManifest('a', '1.0.0', { b: '1.0.0' }));
+    const order = deps.topologicalSort('a', registry);
+    // c must come before b, b must come before a
+    expect(order.indexOf('c')).toBeLessThan(order.indexOf('b'));
+    expect(order.indexOf('b')).toBeLessThan(order.indexOf('a'));
+  });
+
+  it('flattens all transitive dependencies', () => {
+    registry.register(makeManifest('c', '1.0.0'));
+    registry.register(makeManifest('b', '1.0.0', { c: '1.0.0' }));
+    registry.register(makeManifest('a', '1.0.0', { b: '1.0.0' }));
+    const flat = deps.flattenDependencies('a', registry);
+    expect(flat).toContain('b');
+    expect(flat).toContain('c');
+    expect(flat).not.toContain('a'); // root not in its own deps
+  });
+
+  it('returns empty flat deps for plugin with no dependencies', () => {
+    registry.register(makeManifest('standalone', '1.0.0'));
+    const flat = deps.flattenDependencies('standalone', registry);
+    expect(flat).toEqual([]);
+  });
+
+  it('deduplicates shared transitive dependencies', () => {
+    // a -> b, a -> c, b -> d, c -> d  (d appears twice)
+    registry.register(makeManifest('d', '1.0.0'));
+    registry.register(makeManifest('b', '1.0.0', { d: '1.0.0' }));
+    registry.register(makeManifest('c', '1.0.0', { d: '1.0.0' }));
+    registry.register(makeManifest('a', '1.0.0', { b: '1.0.0', c: '1.0.0' }));
+    const flat = deps.flattenDependencies('a', registry);
+    const dCount = flat.filter(n => n === 'd').length;
+    expect(dCount).toBe(1);
+  });
+});
