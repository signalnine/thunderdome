+    service.flagReview(r2.id);
+    const avg = service.getAverageRating('pkg');
+    // Only the 5-star review counts (flagged one excluded)
+    expect(avg).toBe(5);
+  });
+
+  it('returns 0 average rating when no unflagged reviews', () => {
+    const r = service.addReview({ pluginName: 'pkg', pluginVersion: '1.0.0', userId: 'u1', rating: 3, comment: 'C' });
+    service.flagReview(r.id);
+    expect(service.getAverageRating('pkg')).toBe(0);
+  });
