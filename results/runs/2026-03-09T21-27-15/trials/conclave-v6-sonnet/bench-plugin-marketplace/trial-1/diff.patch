+  it('returns null for a specific version that does not exist', () => {
+    registry.register(makeManifest({ version: '1.0.0' }));
+    expect(registry.getVersion('my-plugin', '9.9.9')).toBeNull();
+  });
+
+  it('lists all registered plugins', () => {
+    const a = makeManifest({ name: 'plugin-a', version: '1.0.0' });
+    const b = makeManifest({ name: 'plugin-b', version: '1.0.0' });
+    registry.register(a);
+    registry.register(b);
+    const all = registry.list();
+    expect(all).toHaveLength(2);
+    expect(all).toContainEqual(a);
+    expect(all).toContainEqual(b);
+  });
+
+  it('returns latest version when getting plugin by name with multiple versions', () => {
+    const v1 = makeManifest({ version: '1.0.0' });
+    const v2 = makeManifest({ version: '2.0.0' });
+    registry.register(v1);
+    registry.register(v2);
+    // get() should return the latest registered (highest semver)
+    const result = registry.get('my-plugin');
+    expect(result?.version).toBe('2.0.0');
+  });
+
+  it('searches plugins by name', () => {
+    registry.register(makeManifest({ name: 'auth-plugin', version: '1.0.0', description: 'Auth' }));
+    registry.register(makeManifest({ name: 'logger', version: '1.0.0', description: 'Logging' }));
+    const results = registry.search('auth');
+    expect(results).toHaveLength(1);
+    expect(results[0].name).toBe('auth-plugin');
+  });
+
+  it('searches plugins by description', () => {
+    registry.register(makeManifest({ name: 'plugin-a', version: '1.0.0', description: 'Authentication helper' }));
+    registry.register(makeManifest({ name: 'plugin-b', version: '1.0.0', description: 'Logger tool' }));
+    const results = registry.search('Authentication');
+    expect(results).toHaveLength(1);
+    expect(results[0].name).toBe('plugin-a');
+  });
+
+  it('removes a specific version of a plugin', () => {
+    registry.register(makeManifest({ version: '1.0.0' }));
+    registry.register(makeManifest({ version: '2.0.0' }));
+    const removed = registry.remove('my-plugin', '1.0.0');
+    expect(removed).toBe(true);
+    expect(registry.getVersion('my-plugin', '1.0.0')).toBeNull();
+    expect(registry.getVersion('my-plugin', '2.0.0')).not.toBeNull();
+  });
+
+  it('returns false when removing a plugin that does not exist', () => {
+    expect(registry.remove('nonexistent', '1.0.0')).toBe(false);
+  });
+
+  it('lists all versions of a plugin', () => {
+    registry.register(makeManifest({ version: '1.0.0' }));
+    registry.register(makeManifest({ version: '2.0.0' }));
+    registry.register(makeManifest({ version: '3.0.0' }));
+    const versions = registry.listVersions('my-plugin');
+    expect(versions).toHaveLength(3);
+    expect(versions).toContain('1.0.0');
+    expect(versions).toContain('2.0.0');
+    expect(versions).toContain('3.0.0');
+  });
+
+  it('returns empty array for listVersions of nonexistent plugin', () => {
+    expect(registry.listVersions('nonexistent')).toEqual([]);
+  });
+
+  it('updates a plugin manifest', () => {
