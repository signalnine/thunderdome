+import { describe, it, expect } from 'vitest';
+import { createRunner } from './index.js';
+
+describe('SandboxedRunner', () => {
+  const runner = createRunner();
+
+  it('executes simple code and returns output', async () => {
+    const result = await runner.execute('output = 1 + 1');
+    expect(result.success).toBe(true);
+    expect(result.output).toBe(2);
+    expect(result.duration).toBeGreaterThanOrEqual(0);
+  });
+
+  it('passes context variables into sandbox', async () => {
+    const result = await runner.execute('output = x + y', { x: 3, y: 4 });
+    expect(result.success).toBe(true);
+    expect(result.output).toBe(7);
+  });
+
+  it('returns success=false and error message when code throws', async () => {
+    const result = await runner.execute('throw new Error("boom")');
+    expect(result.success).toBe(false);
+    expect(result.error).toContain('boom');
+  });
+
+  it('returns memoryUsed field', async () => {
+    const result = await runner.execute('output = 42');
+    expect(typeof result.memoryUsed).toBe('number');
+    expect(result.memoryUsed).toBeGreaterThanOrEqual(0);
+  });
+
+  it('returns duration field', async () => {
+    const result = await runner.execute('output = "hello"');
+    expect(typeof result.duration).toBe('number');
+    expect(result.duration).toBeGreaterThanOrEqual(0);
+  });
+
+  it('enforces timeout and returns failure for runaway code', async () => {
+    const result = await runner.executeWithTimeout(
+      'while(true){}',
+      100
+    );
+    expect(result.success).toBe(false);
+    expect(result.error).toBeDefined();
+  }, 5000);
+
+  it('executes code with timeout successfully when fast enough', async () => {
+    const result = await runner.executeWithTimeout('output = 99', 1000);
+    expect(result.success).toBe(true);
+    expect(result.output).toBe(99);
+  });
+
+  it('sandboxes code from accessing process', async () => {
+    const result = await runner.execute('output = typeof process');
+    // process should not be accessible in sandbox
+    expect(result.success).toBe(true);
+    expect(result.output).toBe('undefined');
+  });
+
+  it('handles code with no output assignment', async () => {
+    const result = await runner.execute('const x = 5;');
+    expect(result.success).toBe(true);
+    expect(result.output).toBeUndefined();
+  });
+
+  it('handles syntax errors gracefully', async () => {
+    const result = await runner.execute('this is not valid javascript !!!');
+    expect(result.success).toBe(false);
+    expect(result.error).toBeDefined();
+  });
+});
