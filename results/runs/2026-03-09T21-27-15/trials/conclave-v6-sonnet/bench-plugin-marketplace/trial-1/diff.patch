+        { lodash: ['4.17.21'] }
+      )
+    ).toThrow();
+  });
+
+  it('checks if a version satisfies a range', () => {
+    expect(resolver.satisfies('4.17.21', '^4.0.0')).toBe(true);
+    expect(resolver.satisfies('3.0.0', '^4.0.0')).toBe(false);
+    expect(resolver.satisfies('5.0.0', '>=4.0.0')).toBe(true);
+  });
+
+  it('finds max satisfying version from a list', () => {
+    expect(resolver.maxSatisfying(['1.0.0', '2.0.0', '3.0.0'], '^2.0.0')).toBe('2.0.0');
+    expect(resolver.maxSatisfying(['1.0.0', '2.5.0', '2.9.9'], '^2.0.0')).toBe('2.9.9');
+    expect(resolver.maxSatisfying(['1.0.0'], '^2.0.0')).toBeNull();
+  });
+
+  it('validates semver ranges', () => {
+    expect(resolver.validRange('^1.0.0')).toBe(true);
+    expect(resolver.validRange('>=2.0.0 <3.0.0')).toBe(true);
+    expect(resolver.validRange('not-a-range')).toBe(false);
