@@ -0,0 +1,63 @@
+import type { SandboxResult, RunnerService } from '../types.js';
+import vm from 'node:vm';
+
+export function createRunner(): RunnerService {
+  async function runCode(
+    code: string,
+    timeoutMs: number,
+    context?: Record<string, unknown>
+  ): Promise<SandboxResult> {
+    const memBefore = process.memoryUsage().heapUsed;
+    const start = Date.now();
+
+    // Create a clean sandbox with no access to Node globals
+    const sandbox: Record<string, unknown> = {
+      output: undefined,
+      ...context,
+    };
+
+    const ctx = vm.createContext(sandbox);
+
+    try {
+      const script = new vm.Script(code, { filename: 'plugin.js' });
+      script.runInContext(ctx, { timeout: timeoutMs });
+
+      const duration = Date.now() - start;
+      const memAfter = process.memoryUsage().heapUsed;
+      const memoryUsed = Math.max(0, memAfter - memBefore);
+
+      return {
+        success: true,
+        output: sandbox['output'],
+        duration,
+        memoryUsed,
+      };
+    } catch (err) {
+      const duration = Date.now() - start;
+      const memAfter = process.memoryUsage().heapUsed;
+      const memoryUsed = Math.max(0, memAfter - memBefore);
+
+      return {
+        success: false,
+        output: undefined,
+        duration,
+        memoryUsed,
+        error: err instanceof Error ? err.message : String(err),
+      };
+    }
+  }
+
+  return {
+    execute(code: string, context?: Record<string, unknown>): Promise<SandboxResult> {
+      return runCode(code, 5000, context);
+    },
+
+    executeWithTimeout(
+      code: string,
+      timeoutMs: number,
+      context?: Record<string, unknown>
+    ): Promise<SandboxResult> {
+      return runCode(code, timeoutMs, context);
+    },
+  };
+}
