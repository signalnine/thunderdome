@@ -0,0 +1,113 @@
+import type { DependencyNode, DepsService, RegistryService } from '../types.js';
+
+export function createDepsService(): DepsService {
+  function buildTreeHelper(
+    name: string,
+    registry: RegistryService,
+    visited: Set<string>
+  ): DependencyNode {
+    const manifest = registry.get(name);
+    if (!manifest) {
+      return { name, version: 'unknown', dependencies: [] };
+    }
+
+    // Prevent infinite recursion on cycles
+    if (visited.has(name)) {
+      return { name, version: manifest.version, dependencies: [] };
+    }
+
+    const newVisited = new Set(visited);
+    newVisited.add(name);
+
+    const children: DependencyNode[] = Object.keys(manifest.dependencies).map(depName =>
+      buildTreeHelper(depName, registry, newVisited)
+    );
+
+    return { name, version: manifest.version, dependencies: children };
+  }
+
+  function detectCyclesHelper(
+    name: string,
+    registry: RegistryService,
+    path: string[],
+    visited: Set<string>
+  ): string[][] {
+    const cycles: string[][] = [];
+    const manifest = registry.get(name);
+    if (!manifest) return cycles;
+
+    const depNames = Object.keys(manifest.dependencies);
+    for (const dep of depNames) {
+      const cycleStart = path.indexOf(dep);
+      if (cycleStart !== -1) {
+        // Found a cycle: path from cycle start to current + dep
+        cycles.push([...path.slice(cycleStart), name, dep]);
+      } else if (!visited.has(dep)) {
+        const subCycles = detectCyclesHelper(dep, registry, [...path, name], new Set(visited));
+        cycles.push(...subCycles);
+      }
+    }
+    visited.add(name);
+    return cycles;
+  }
+
+  function topoSortHelper(
+    name: string,
+    registry: RegistryService,
+    visited: Set<string>,
+    result: string[]
+  ): void {
+    if (visited.has(name)) return;
+    visited.add(name);
+    const manifest = registry.get(name);
+    if (manifest) {
+      for (const dep of Object.keys(manifest.dependencies)) {
+        topoSortHelper(dep, registry, visited, result);
+      }
+    }
+    result.push(name);
+  }
+
+  function flattenHelper(
+    name: string,
+    registry: RegistryService,
+    collected: Set<string>
+  ): void {
+    const manifest = registry.get(name);
+    if (!manifest) return;
+    for (const dep of Object.keys(manifest.dependencies)) {
+      if (!collected.has(dep)) {
+        collected.add(dep);
+        flattenHelper(dep, registry, collected);
+      }
+    }
+  }
+
+  return {
+    buildTree(name: string, registry: RegistryService): DependencyNode {
+      return buildTreeHelper(name, registry, new Set());
+    },
+
+    detectCycles(name: string, registry: RegistryService): string[][] | null {
+      const cycles = detectCyclesHelper(name, registry, [], new Set());
+      return cycles.length > 0 ? cycles : null;
+    },
+
+    topologicalSort(name: string, registry: RegistryService): string[] {
+      const result: string[] = [];
+      topoSortHelper(name, registry, new Set(), result);
+      return result;
+    },
+
+    flattenDependencies(name: string, registry: RegistryService): string[] {
+      const collected = new Set<string>();
+      flattenHelper(name, registry, collected);
+      return Array.from(collected);
+    },
+
+    hasCircularDependency(name: string, registry: RegistryService): boolean {
+      const cycles = detectCyclesHelper(name, registry, [], new Set());
+      return cycles.length > 0;
+    },
+  };
+}
