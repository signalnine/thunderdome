+import { describe, it, expect, beforeEach } from 'vitest';
+import { createResolver } from './index.js';
+
+describe('VersionResolver', () => {
+  let resolver: ReturnType<typeof createResolver>;
+
+  beforeEach(() => {
+    resolver = createResolver();
+  });
+
+  it('resolves a single exact version constraint', () => {
+    const result = resolver.resolve(
+      [{ name: 'lodash', range: '4.17.21' }],
+      { lodash: ['4.17.21', '4.16.0'] }
+    );
+    expect(result).toHaveLength(1);
+    expect(result[0]).toEqual({ name: 'lodash', version: '4.17.21', satisfies: '4.17.21' });
+  });
+
+  it('resolves a caret range constraint', () => {
+    const result = resolver.resolve(
+      [{ name: 'express', range: '^4.0.0' }],
+      { express: ['3.5.0', '4.0.0', '4.18.2'] }
+    );
+    expect(result).toHaveLength(1);
+    expect(result[0].name).toBe('express');
+    expect(result[0].version).toBe('4.18.2');
+    expect(result[0].satisfies).toBe('^4.0.0');
+  });
+
+  it('resolves multiple constraints', () => {
+    const result = resolver.resolve(
+      [
+        { name: 'lodash', range: '^4.0.0' },
+        { name: 'express', range: '>=3.0.0' },
+      ],
+      {
+        lodash: ['4.17.21', '3.10.0'],
+        express: ['3.0.0', '4.18.2'],
+      }
+    );
+    expect(result).toHaveLength(2);
+    const lodashResult = result.find(r => r.name === 'lodash');
+    const expressResult = result.find(r => r.name === 'express');
+    expect(lodashResult?.version).toBe('4.17.21');
+    expect(expressResult?.version).toBe('4.18.2');
+  });
+
+  it('throws when no version satisfies constraint', () => {
+    expect(() =>
+      resolver.resolve(
