ge rating when no unflagged reviews', () => {\n    const r = service.addReview({ pluginName: 'pkg', pluginVersion: '1.0.0', userId: 'u1', rating: 3, comment: 'C' });\n    service.flagReview(r.id);\n    expect(service.getAverageRating('pkg')).toBe(0);\n  });\n\n  it('flags a review', () => {\n    const review = service.addReview({ pluginName: 'pkg', pluginVersion: '1.0.0', userId: 'u1', rating: 2, comment: 'Bad' });\n    service.flagReview(review.id);\n    const flagged = service.getFlaggedReviews();\n    expect(flagged).toHaveLength(1);\n    expect(flagged[0].id).toBe(review.id);\n    expect(flagged[0].flagged).toBe(true);\n  });\n\n  it('returns all flagged reviews', () => {\n    const r1 = service.addReview({ pluginName: 'pkg', pluginVersion: '1.0.0', userId: 'u1', rating: 1, comment: 'Spam' });\n    service.addReview({ pluginName: 'pkg', pluginVersion: '1.0.0', userId: 'u2', rating: 5, comment: 'Fine' });\n    service.flagReview(r1.id);\n    expect(service.getFlaggedReviews()).toHaveLength(1);\n  });\n\n  it('removes a review by id', () => {\n    const r = service.addReview({ pluginName: 'pkg', pluginVersion: '1.0.0', userId: 'u1', rating: 3, comment: 'Meh' });\n    const removed = service.removeReview(r.id);\n    expect(removed).toBe(true);\n    expect(service.getReviews('pkg')).toHaveLength(0);\n  });\n\n  it('returns false when removing nonexistent review', () => {\n    expect(service.removeReview(9999)).toBe(false);\n  });\n\n  it('retrieves reviews by user', () => {\n    service.addReview({ pluginName: 'pkg-a', pluginVersion: '1.0.0', userId: 'alice', rating: 4, comment: 'A' });\n    service.addReview({ pluginName: 'pkg-b', pluginVersion: '1.0.0', userId: 'alice', rating: 5, comment: 'B' });\n    service.addReview({ pluginName: 'pkg-a', pluginVersion: '1.0.0', userId: 'bob', rating: 3, comment: 'C' });\n    const aliceReviews = service.getReviewsByUser('alice');\n    expect(aliceReviews).toHaveLength(2);\n    expect(aliceReviews.every(r => r.userId === 'alic