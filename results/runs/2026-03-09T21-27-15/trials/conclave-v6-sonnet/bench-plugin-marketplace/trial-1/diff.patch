+  it('computes correct average with multiple ratings', () => {
+    service.addReview({ pluginName: 'pkg', pluginVersion: '1.0.0', userId: 'u1', rating: 4, comment: 'A' });
+    service.addReview({ pluginName: 'pkg', pluginVersion: '1.0.0', userId: 'u2', rating: 2, comment: 'B' });
+    const avg = service.getAverageRating('pkg');
+    expect(avg).toBe(3);
+  });
+});
