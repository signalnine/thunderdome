+    registry.update('my-plugin', '1.0.0', { description: 'New description' });
+    const updated = registry.getVersion('my-plugin', '1.0.0');
+    expect(updated?.description).toBe('New description');
+  });
+
+  it('list returns one entry per plugin-version pair', () => {
+    registry.register(makeManifest({ version: '1.0.0' }));
+    registry.register(makeManifest({ version: '2.0.0' }));
+    const all = registry.list();
+    expect(all).toHaveLength(2);
+  });
+});
