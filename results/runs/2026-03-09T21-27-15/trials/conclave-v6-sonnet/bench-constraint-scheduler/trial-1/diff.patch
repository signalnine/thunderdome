+// Prerequisites
+// ---------------------------------------------------------------------------
+
+describe('prerequisite ordering', () => {
+  test('event B starts after event A when B has A as prerequisite', () => {
+    const events = [
+      makeEvent('A', 60),
+      makeEvent('B', 60, { prerequisites: ['A'] }),
+    ];
+    const rooms = [makeRoom('r1'), makeRoom('r2')];
+    const result = schedule(events, rooms, defaultOptions);
+    expect(result.assignments).toHaveLength(2);
+
+    const a = result.assignments.find(x => x.eventId === 'A')!;
+    const b = result.assignments.find(x => x.eventId === 'B')!;
+    // B must start after A ends (+ gap if same room)
+    expect(b.startTime).toBeGreaterThanOrEqual(a.endTime);
+  });
+
+  test('prerequisite gap applies between prerequisite and dependent event', () => {
+    const events = [
+      makeEvent('A', 60),
+      makeEvent('B', 60, { prerequisites: ['A'] }),
+    ];
+    const rooms = [makeRoom('r1'), makeRoom('r2')];
+    const options: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 15 };
+    const result = schedule(events, rooms, options);
+
+    const a = result.assignments.find(x => x.eventId === 'A')!;
+    const b = result.assignments.find(x => x.eventId === 'B')!;
+    expect(b.startTime).toBeGreaterThanOrEqual(a.endTime + 15);
+  });
+
+  test('chained prerequisites are respected: A -> B -> C', () => {
+    const events = [
+      makeEvent('A', 30),
+      makeEvent('B', 30, { prerequisites: ['A'] }),
+      makeEvent('C', 30, { prerequisites: ['B'] }),
+    ];
+    const rooms = [makeRoom('r1'), makeRoom('r2'), makeRoom('r3')];
+    const result = schedule(events, rooms, defaultOptions);
+    expect(result.assignments).toHaveLength(3);
+
+    const a = result.assignments.find(x => x.eventId === 'A')!;
+    const b = result.assignments.find(x => x.eventId === 'B')!;
+    const c = result.assignments.find(x => x.eventId === 'C')!;
+    expect(b.startTime).toBeGreaterThanOrEqual(a.endTime);
+    expect(c.startTime).toBeGreaterThanOrEqual(b.endTime);
+  });
+
+  test('event is unscheduled when prerequisite cannot be scheduled', () => {
+    // The prerequisite is too long to fit the window — so its dependent also cannot be placed
+    const events = [
+      makeEvent('A', 600), // too long for window
+      makeEvent('B', 30, { prerequisites: ['A'] }),
+    ];
+    const rooms = [makeRoom('r1')];
+    const result = schedule(events, rooms, defaultOptions);
+    expect(result.unscheduled).toContain('B');
+  });
+
+  test('multiple prerequisites must all finish before dependent starts', () => {
+    const events = [
+      makeEvent('A', 60),
+      makeEvent('B', 90),
+      makeEvent('C', 30, { prerequisites: ['A', 'B'] }),
+    ];
+    const rooms = [makeRoom('r1'), makeRoom('r2'), makeRoom('r3')];
+    const result = schedule(events, rooms, defaultOptions);
+    expect(result.assignments).toHaveLength(3);
+
+    const a = result.assignments.find(x => x.eventId === 'A')!;
+    const b = result.assignments.find(x => x.eventId === 'B')!;
+    const c = result.assignments.find(x => x.eventId === 'C')!;
+    const latestPrereqEnd = Math.max(a.endTime, b.endTime);
+    expect(c.startTime).toBeGreaterThanOrEqual(latestPrereqEnd);
+  });
+});
