+// ---------------------------------------------------------------------------
+// Room gap constraints
+// ---------------------------------------------------------------------------
+
+describe('room gap constraints', () => {
+  test('two events in the same room have at least default 15 min gap', () => {
+    const events = [makeEvent('e1', 60), makeEvent('e2', 60)];
+    const rooms = [makeRoom('r1')];
+    const result = schedule(events, rooms, defaultOptions);
+    expect(result.assignments).toHaveLength(2);
+
+    const [a1, a2] = result.assignments.sort((a, b) => a.startTime - b.startTime);
+    expect(a2.startTime - a1.endTime).toBeGreaterThanOrEqual(15);
+  });
+
+  test('gap option is respected', () => {
+    const events = [makeEvent('e1', 30), makeEvent('e2', 30)];
+    const rooms = [makeRoom('r1')];
+    const options: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 30 };
+    const result = schedule(events, rooms, options);
+    expect(result.assignments).toHaveLength(2);
+
+    const [a1, a2] = result.assignments.sort((a, b) => a.startTime - b.startTime);
+    expect(a2.startTime - a1.endTime).toBeGreaterThanOrEqual(30);
+  });
+
+  test('zero gap allows events to be placed back to back', () => {
+    const events = [makeEvent('e1', 60), makeEvent('e2', 60)];
+    const rooms = [makeRoom('r1')];
+    const options: ScheduleOptions = { startTime: 540, endTime: 660, gap: 0 };
+    const result = schedule(events, rooms, options);
+    expect(result.assignments).toHaveLength(2);
+  });
+
+  test('events in different rooms do not need a gap between them', () => {
+    const events = [makeEvent('e1', 60), makeEvent('e2', 60)];
+    const rooms = [makeRoom('r1'), makeRoom('r2')];
+    const options: ScheduleOptions = { startTime: 540, endTime: 600 };
+    const result = schedule(events, rooms, options);
+    // Both fit because they go in different rooms
+    expect(result.assignments).toHaveLength(2);
+  });
+
+  test('second event cannot fit if gap pushes it past window end', () => {
+    // window = 540..660 (120 min), event1 = 60 min, gap=15, event2 = 60 min
+    // after e1(60) + gap(15) = 75, e2 needs 60 more = 135 total > 120
+    const events = [makeEvent('e1', 60), makeEvent('e2', 60)];
+    const rooms = [makeRoom('r1')];
+    const options: ScheduleOptions = { startTime: 540, endTime: 660, gap: 15 };
+    const result = schedule(events, rooms, options);
+    // One fits, one doesn't (or both fit in separate rooms — but we only have one room)
+    expect(result.assignments).toHaveLength(1);
+    expect(result.unscheduled).toHaveLength(1);
+  });
+});
