--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,212 @@
+// ---------------------------------------------------------------------------
+// Types
+// ---------------------------------------------------------------------------
+
+export interface Event {
+  id: string;
+  name: string;
+  duration: number;
+  attendees?: number;
+  prerequisites?: string[];
+  preferredRoom?: string;
+}
+
+export interface Room {
+  id: string;
+  name: string;
+  capacity: number;
+}
+
+export interface ScheduleOptions {
+  startTime: number;
+  endTime: number;
+  gap?: number;
+}
+
+export interface Assignment {
+  eventId: string;
+  roomId: string;
+  startTime: number;
+  endTime: number;
+}
+
+export interface ScheduleResult {
+  assignments: Assignment[];
+  unscheduled: string[];
+}
+
+// ---------------------------------------------------------------------------
+// Topological sort + cycle detection
+// ---------------------------------------------------------------------------
+
+/**
+ * Returns events in topological order (prerequisites before dependents).
+ * Throws if the prerequisite graph contains a cycle.
+ */
+function topologicalSort(events: Event[]): Event[] {
+  const idToEvent = new Map<string, Event>();
+  for (const e of events) idToEvent.set(e.id, e);
+
+  // Verify all prerequisites reference known events
+  // (unknown prereqs are treated as unresolvable but not a cycle)
+
+  // Kahn's algorithm
+  const inDegree = new Map<string, number>();
+  const dependents = new Map<string, string[]>(); // prereq -> events that depend on it
+
+  for (const e of events) {
+    if (!inDegree.has(e.id)) inDegree.set(e.id, 0);
+    if (!dependents.has(e.id)) dependents.set(e.id, []);
+    for (const prereqId of e.prerequisites ?? []) {
+      inDegree.set(e.id, (inDegree.get(e.id) ?? 0) + 1);
+      if (!dependents.has(prereqId)) dependents.set(prereqId, []);
+      dependents.get(prereqId)!.push(e.id);
+    }
+  }
+
+  const queue: string[] = [];
+  for (const [id, deg] of inDegree) {
+    if (deg === 0) queue.push(id);
+  }
+
+  const sorted: Event[] = [];
+  while (queue.length > 0) {
+    const id = queue.shift()!;
+    const event = idToEvent.get(id);
+    if (event) sorted.push(event);
+
+    for (const depId of dependents.get(id) ?? []) {
+      const newDeg = (inDegree.get(depId) ?? 0) - 1;
+      inDegree.set(depId, newDeg);
+      if (newDeg === 0) queue.push(depId);
+    }
+  }
+
+  if (sorted.length !== events.length) {
+    throw new Error('Prerequisite cycle detected in event graph');
+  }
+
+  return sorted;
+}
+
+// ---------------------------------------------------------------------------
+// Room timeline management
+// ---------------------------------------------------------------------------
+
+/**
+ * Find the earliest start time >= `earliest` in a room that can fit an event
+ * of `duration` minutes, respecting the gap and window end.
+ */
+function findSlot(
+  roomSlots: { start: number; end: number }[],
+  earliest: number,
+  duration: number,
+  gap: number,
+  windowEnd: number,
+): number | null {
+  // Sort slots by start time
+  const sorted = [...roomSlots].sort((a, b) => a.start - b.start);
+
+  let candidateStart = earliest;
+
+  for (const slot of sorted) {
+    // If this existing slot starts after our candidate end we can place before it
+    if (candidateStart + duration <= slot.start) {
+      if (candidateStart + duration <= windowEnd) return candidateStart;
+      return null;
+    }
+    // Push candidate start past this slot + gap
+    const afterSlot = slot.end + gap;
+    if (afterSlot > candidateStart) {
+      candidateStart = afterSlot;
+    }
+  }
+
+  // After all slots
+  if (candidateStart + duration <= windowEnd) return candidateStart;
+  return null;
+}
+
+// ---------------------------------------------------------------------------
+// Main scheduler
+// ---------------------------------------------------------------------------
+
+export function schedule(
+  events: Event[],
+  rooms: Room[],
+  options: ScheduleOptions,
+): ScheduleResult {
+  const gap = options.gap ?? 15;
+
+  // 1. Detect cycles — throws on cycle
+  const sorted = topologicalSort(events);
+
+  // 2. Room slots: map roomId -> list of {start, end} for placed events
+  const roomSlots = new Map<string, { start: number; end: number }[]>();
+  for (const room of rooms) roomSlots.set(room.id, []);
+
+  // 3. Track assignment results
+  const assignments: Assignment[] = [];
+  const unscheduled: string[] = [];
+
+  // 4. Track when each event finishes (for prerequisite resolution)
+  const eventEndTime = new Map<string, number>();
+
+  // 5. Schedule events in topological order
+  for (const event of sorted) {
+    const attendees = event.attendees ?? 1;
+
+    // Eligible rooms: capacity >= attendees
+    const eligibleRooms = rooms.filter(r => r.capacity >= attendees);
+
+    if (eligibleRooms.length === 0) {
+      unscheduled.push(event.id);
+      continue;
+    }
+
+    // Compute earliest allowed start time based on prerequisites
+    let earliestStart = options.startTime;
+    for (const prereqId of event.prerequisites ?? []) {
+      const prereqEnd = eventEndTime.get(prereqId);
+      if (prereqEnd === undefined) {
+        // Prerequisite was not scheduled — this event cannot be scheduled
+        earliestStart = Infinity;
+        break;
+      }
+      earliestStart = Math.max(earliestStart, prereqEnd + gap);
+    }
+
+    if (earliestStart === Infinity) {
+      unscheduled.push(event.id);
+      continue;
+    }
+
+    // Try preferred room first, then remaining rooms
+    const orderedRooms = event.preferredRoom
+      ? [
+          ...eligibleRooms.filter(r => r.id === event.preferredRoom),
+          ...eligibleRooms.filter(r => r.id !== event.preferredRoom),
+        ]
+      : eligibleRooms;
+
+    let placed = false;
+    for (const room of orderedRooms) {
+      const slots = roomSlots.get(room.id)!;
+      const start = findSlot(slots, earliestStart, event.duration, gap, options.endTime);
+      if (start !== null) {
+        const end = start + event.duration;
+        slots.push({ start, end });
+        assignments.push({ eventId: event.id, roomId: room.id, startTime: start, endTime: end });
+        eventEndTime.set(event.id, end);
+        placed = true;
+        break;
+      }
+    }
+
+    if (!placed) {
+      unscheduled.push(event.id);
+    }
+  }
+
+  return { assignments, unscheduled };
+}
