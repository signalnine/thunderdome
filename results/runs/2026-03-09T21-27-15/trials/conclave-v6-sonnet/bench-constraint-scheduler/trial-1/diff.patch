+++ b/src/scheduler.test.ts
@@ -0,0 +1,425 @@
+import { describe, test, expect } from 'vitest';
+import { schedule } from './index.js';
+import type { Event, Room, ScheduleOptions } from './index.js';
+
+// ---------------------------------------------------------------------------
+// Helpers
+// ---------------------------------------------------------------------------
+
+function makeRoom(id: string, capacity = 100): Room {
+  return { id, name: id, capacity };
+}
+
+function makeEvent(id: string, duration: number, overrides: Partial<Event> = {}): Event {
+  return { id, name: id, duration, ...overrides };
+}
+
+const defaultOptions: ScheduleOptions = {
+  startTime: 540,  // 9:00 AM
+  endTime: 1020,   // 5:00 PM
+};
+
+// ---------------------------------------------------------------------------
+// Basic scheduling
+// ---------------------------------------------------------------------------
+
+describe('basic scheduling', () => {
+  test('schedules a single event into a room', () => {
+    const events = [makeEvent('e1', 60)];
+    const rooms = [makeRoom('r1')];
+    const result = schedule(events, rooms, defaultOptions);
+
+    expect(result.assignments).toHaveLength(1);
+    expect(result.unscheduled).toHaveLength(0);
+
+    const a = result.assignments[0];
+    expect(a.eventId).toBe('e1');
+    expect(a.roomId).toBe('r1');
+    expect(a.startTime).toBeGreaterThanOrEqual(540);
+    expect(a.endTime).toBeLessThanOrEqual(1020);
+    expect(a.endTime - a.startTime).toBe(60);
+  });
+
+  test('schedules multiple independent events into available rooms', () => {
+    const events = [makeEvent('e1', 60), makeEvent('e2', 60)];
+    const rooms = [makeRoom('r1'), makeRoom('r2')];
+    const result = schedule(events, rooms, defaultOptions);
+
+    expect(result.assignments).toHaveLength(2);
+    expect(result.unscheduled).toHaveLength(0);
+  });
+
+  test('returns empty assignments for empty input', () => {
+    const result = schedule([], [makeRoom('r1')], defaultOptions);
+    expect(result.assignments).toHaveLength(0);
+    expect(result.unscheduled).toHaveLength(0);
+  });
+
+  test('puts all events in unscheduled when no rooms available', () => {
+    const events = [makeEvent('e1', 60)];
+    const result = schedule(events, [], defaultOptions);
+    expect(result.assignments).toHaveLength(0);
+    expect(result.unscheduled).toEqual(['e1']);
+  });
+});
+
+// ---------------------------------------------------------------------------
+// Time window constraints
+// ---------------------------------------------------------------------------
+
+describe('time window constraints', () => {
+  test('event end time must not exceed window end', () => {
+    // 9:00 AM to 9:30 AM window — 60 min event cannot fit
+    const events = [makeEvent('e1', 60)];
+    const rooms = [makeRoom('r1')];
+    const options: ScheduleOptions = { startTime: 540, endTime: 570 };
+    const result = schedule(events, rooms, options);
+    expect(result.unscheduled).toContain('e1');
+    expect(result.assignments).toHaveLength(0);
+  });
+
+  test('event that exactly fits the window is scheduled', () => {
+    const events = [makeEvent('e1', 60)];
+    const rooms = [makeRoom('r1')];
+    const options: ScheduleOptions = { startTime: 540, endTime: 600 };
+    const result = schedule(events, rooms, options);
+    expect(result.assignments).toHaveLength(1);
+    expect(result.assignments[0].startTime).toBe(540);
+    expect(result.assignments[0].endTime).toBe(600);
+  });
+
+  test('all assignments start at or after startTime', () => {
+    const events = [makeEvent('e1', 30), makeEvent('e2', 45)];
+    const rooms = [makeRoom('r1')];
+    const result = schedule(events, rooms, defaultOptions);
+    for (const a of result.assignments) {
+      expect(a.startTime).toBeGreaterThanOrEqual(540);
+    }
+  });
+
+  test('all assignments end at or before endTime', () => {
+    const events = Array.from({ length: 5 }, (_, i) => makeEvent(`e${i}`, 60));
+    const rooms = [makeRoom('r1')];
+    const result = schedule(events, rooms, defaultOptions);
+    for (const a of result.assignments) {
+      expect(a.endTime).toBeLessThanOrEqual(1020);
+    }
+  });
+});
+
+// ---------------------------------------------------------------------------
+// Room capacity constraints
+// ---------------------------------------------------------------------------
+
+describe('room capacity constraints', () => {
+  test('event with more attendees than room capacity goes to unscheduled', () => {
