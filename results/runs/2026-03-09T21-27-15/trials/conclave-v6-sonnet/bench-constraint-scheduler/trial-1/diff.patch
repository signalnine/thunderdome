+// ---------------------------------------------------------------------------
+// Batch optimization / maximizing scheduled count
+// ---------------------------------------------------------------------------
+
+describe('batch optimization', () => {
+  test('schedules short events over a longer event when space is limited', () => {
+    // One 8-hour event vs eight 30-min events in one room (8h window)
+    // Scheduling the long event leaves the rest unscheduled
+    // But if we skip the long event we can fit more short ones
+    const events = [
+      makeEvent('long', 480),
+      ...Array.from({ length: 5 }, (_, i) => makeEvent(`short${i}`, 60)),
+    ];
+    const rooms = [makeRoom('r1')];
+    // 480 min window (9AM-5PM)
+    const result = schedule(events, rooms, defaultOptions);
+
+    // At minimum we want to verify the scheduler doesn't crash and
+    // produces valid assignments (no overlap, within window)
+    for (const a of result.assignments) {
+      expect(a.startTime).toBeGreaterThanOrEqual(540);
+      expect(a.endTime).toBeLessThanOrEqual(1020);
+    }
+
+    // All event IDs are accounted for
+    const allIds = new Set([...result.assignments.map(a => a.eventId), ...result.unscheduled]);
+    for (const e of events) {
+      expect(allIds.has(e.id)).toBe(true);
+    }
+  });
+
+  test('no two events overlap in the same room', () => {
+    const events = Array.from({ length: 8 }, (_, i) => makeEvent(`e${i}`, 45));
+    const rooms = [makeRoom('r1'), makeRoom('r2')];
+    const result = schedule(events, rooms, defaultOptions);
+
+    const byRoom = new Map<string, { start: number; end: number }[]>();
+    for (const a of result.assignments) {
+      if (!byRoom.has(a.roomId)) byRoom.set(a.roomId, []);
+      byRoom.get(a.roomId)!.push({ start: a.startTime, end: a.endTime });
+    }
+
+    for (const [, slots] of byRoom) {
+      const sorted = slots.sort((a, b) => a.start - b.start);
+      for (let i = 1; i < sorted.length; i++) {
+        // previous end + gap <= current start
+        expect(sorted[i].start).toBeGreaterThanOrEqual(sorted[i - 1].end + (result.assignments.length > 0 ? 15 : 0));
+      }
+    }
+  });
+
+  test('every event is either assigned or unscheduled', () => {
+    const events = [
+      makeEvent('e1', 60),
+      makeEvent('e2', 60, { attendees: 999 }), // too many
+      makeEvent('e3', 999),                     // too long
+    ];
+    const rooms = [makeRoom('r1', 10)];
+    const result = schedule(events, rooms, defaultOptions);
+
+    const scheduled = new Set(result.assignments.map(a => a.eventId));
+    const unscheduled = new Set(result.unscheduled);
+
+    for (const e of events) {
+      const inOne = scheduled.has(e.id) !== unscheduled.has(e.id);
+      expect(inOne).toBe(true); // exactly one set
+    }
+  });
