nit_price REAL NOT NULL,\n      FOREIGN KEY (invoice_id) REFERENCES invoices(id)\n    );\n  `);\n\n  return db;\n}\n```\n\n### Data Models (`/workspace/src/models/invoice.ts`)\n\n```typescript\nexport interface LineItem {\n  id?: number;\n  invoice_id?: number;\n  description: string;\n  quantity: number;\n  unit_price: number;\n}\n\nexport interface Invoice {\n  id?: number;\n  customer_id: string;\n  date: string; // ISO date string YYYY-MM-DD\n  subtotal: number;\n  discount_rate: number; // 0.0 to 1.0\n  tax_rate: number; // 0.0 to 1.0\n  total: number;\n  status: 'draft' | 'sent' | 'paid' | 'cancelled';\n  line_items?: LineItem[];\n}\n\nexport interface InvoiceCreateInput {\n  customer_id: string;\n  date: string;\n  discount_rate: number;\n  tax_rate: number;\n  status?: 'draft' | 'sent' | 'paid' | 'cancelled';\n  line_items: LineItem[];\n}\n\nexport interface InvoiceSummary {\n  month: number;\n  year: number;\n  count: number;\n  total_revenue: number;\n}\n\nexport interface CustomerReport {\n  customer_id: string;\n  invoice_count: number;\n  total_spent: number;\n  average_invoice: number;\n}\n```\n\n### Utility Functions\n\n**Date Utilities** (`/workspace/src/utils/dates.ts`):\n- `formatDate(date)` - Convert Date to ISO string (YYYY-MM-DD)\n- `parseDate(str)` - Parse ISO string to UTC Date\n- `getMonthRange(year, month)` - Get first and last day of a month\n- `isDateInRange(date, start, end)` - Check if date is in range\n\n**Formatting Utilities** (`/workspace/src/utils/format.ts`):\n- `formatCurrency(amount)` - Format as $X,XXX.XX\n- `formatPercentage(rate)` - Format as XX.X%\n- `calculateTax(amount, rate)` - **⚠️ BUG:** Applies rate as whole number instead of decimal\n\n### API Server (`/workspace/src/server.ts`)\n\nExpress server with endpoints:\n- `GET /invoices?start=YYYY-MM-DD&end=YYYY-MM-DD` - List invoices by date range\n- `GET /invoices/:id` - Get single invoice with line items\n- `POST /invoices` - Create new invoice\n- `GET /reports/monthly?year=YYYY` - Get monthly revenue report\n- `GET /reports/customer/:id` - Get customer report\n\n---\n\n## Key Observations\n\n1. **Dates are ISO strings (YYYY-MM-DD)** stored in the database\n2. **UTC handling** used throughout to avoid timezone issues\n3. **Rounding to 2 decimals** for all currency calculations\n4. **better-sqlite3** used for synchronous database operations\n5. **Known bugs:**\n   - `calculateTax()` in format.ts applies the rate incorrectly\n   - `calculateInvoiceTotal()` applies tax to original subtotal, not discounted amount\n   - `getInvoicesByDateRange()` documentation says inclusive but SQL uses exclusive end date"}],"totalDurationMs":25460,"totalTokens":21125,"totalToolUseCount":18,"usage":{"input_tokens":6,"cache_creation_input_tokens":3204,"cache_read_input_tokens":15537,"output_tokens":2378,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":3204,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[]}}}
