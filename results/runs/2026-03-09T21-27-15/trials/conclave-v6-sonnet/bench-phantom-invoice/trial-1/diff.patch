tity, unit_price)\n    VALUES (?, ?, ?, ?)\n  `);\n\n  const result = insertInvoice.run(\n    data.customer_id,\n    data.date,\n    data.subtotal,\n    data.discount_rate,\n    data.tax_rate,\n    data.total,\n    data.status || 'draft',\n  );\n\n  const invoiceId = result.lastInsertRowid as number;\n\n  if (data.line_items) {\n    for (const item of data.line_items) {\n      insertLineItem.run(invoiceId, item.description, item.quantity, item.unit_price);\n    }\n  }\n\n  return invoiceId;\n}\n\n/**\n * Retrieve all invoices for a specific customer.\n */\nexport function getInvoicesByCustomer(\n  db: Database.Database,\n  customerId: string,\n): Invoice[] {\n  const stmt = db.prepare(`\n    SELECT * FROM invoices\n    WHERE customer_id = ?\n    ORDER BY date ASC\n  `);\n  return stmt.all(customerId) as Invoice[];\n}\n","structuredPatch":[{"oldStart":11,"oldLines":7,"newStart":11,"newLines":7,"lines":[" ): Invoice[] {","   const stmt = db.prepare(`","     SELECT * FROM invoices","-    WHERE date >= ? AND date < ?","+    WHERE date >= ? AND date <= ?","     ORDER BY date ASC","   `);","   return stmt.all(startDate, endDate) as Invoice[];"]}],"userModified":false,"replaceAll":false}}
