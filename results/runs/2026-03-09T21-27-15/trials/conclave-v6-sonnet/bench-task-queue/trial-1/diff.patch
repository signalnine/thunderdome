 second = new Date('2024-01-01T10:01:00Z'); // 1 min later, not 5\n    system.tick(second);\n    expect(system.getPendingCount()).toBe(0);\n  });\n\n  it('tick enqueues after interval has passed', () => {\n    system.addSchedule('s1', 'default', '*/5 * * * *', {});\n    const first = new Date('2024-01-01T10:00:00Z');\n    system.tick(first);\n    system.getNextTask(); // consume\n\n    const third = new Date('2024-01-01T10:05:00Z'); // exactly 5 min later\n    system.tick(third);\n    expect(system.getPendingCount()).toBe(1);\n  });\n\n  it('removing a schedule stops future enqueuing', () => {\n    system.addSchedule('s1', 'default', '*/1 * * * *', {});\n    system.removeSchedule('s1');\n    system.tick(new Date());\n    expect(system.getPendingCount()).toBe(0);\n  });\n\n  it('recurring tasks are regular tasks subject to queue rules', () => {\n    system.addSchedule('s1', 'default', '*/1 * * * *', { priority: 3, label: 'recurring' });\n    system.tick(new Date());\n    const task = system.getNextTask()!;\n    expect(task.status).toBe('processing');\n    system.completeTask(task.id);\n    expect(system.getTask(task.id)?.status).toBe('completed');\n  });\n\n  it('multiple schedules can be active simultaneously', () => {\n    system.addSchedule('s1', 'default', '*/1 * * * *', { from: 's1' });\n    system.addSchedule('s2', 'default', '*/1 * * * *', { from: 's2' });\n    system.tick(new Date());\n    expect(system.getPendingCount()).toBe(2);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1536,"cache_read_input_tokens":71167,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1536},"output_tokens":18,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"e0d2d4d8-d6bc-4a7e-acf2-58b5c3d88583","uuid":"eda73d17-ba45-496e-a2be-14e8ed8136e6"}
