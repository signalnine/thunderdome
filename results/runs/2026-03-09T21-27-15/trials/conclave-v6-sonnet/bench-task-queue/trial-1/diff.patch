+{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_016DuujWR8Kuc3CUzvfYJqgr","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01SvSornyxzS7wZS4nK4KrZN","name":"Write","input":{"file_path":"/workspace/tests/phase-06.test.ts","content":"import { describe, it, expect, beforeEach } from 'vitest';\nimport { TaskQueueSystem } from '../src/index.js';\n\ndescribe('Phase 6: Dead Letter Queue', () => {\n  let system: TaskQueueSystem;\n\n  beforeEach(() => {\n    system = new TaskQueueSystem();\n  });\n\n  function exhaustRetries(sys: TaskQueueSystem, queueName = 'default') {\n    sys.addTask({ label: 'failing' }, { maxRetries: 0 }, queueName);\n    const task = sys.getNextTask(queueName)!;\n    sys.failTask(task.id, new Error('permanent failure'));\n    return task;\n  }\n\n  it('exhausted task is moved to DLQ', () => {\n    exhaustRetries(system);\n    expect(system.getDeadLetterTasks('default').length).toBe(1);\n  });\n\n  it('DLQ task retains error info', () => {\n    exhaustRetries(system);\n    const dlq = system.getDeadLetterTasks('default');\n    expect(dlq[0].error?.message).toBe('permanent failure');\n  });\n\n  it('DLQ task records total attempts', () => {\n    exhaustRetries(system);\n    const dlq = system.getDeadLetterTasks('default');\n    expect(dlq[0].totalAttempts).toBe(1);\n  });\n\n  it('DLQ task has failedAt timestamp', () => {\n    const before = new Date();\n    exhaustRetries(system);\n    const dlq = system.getDeadLetterTasks('default');\n    expect(dlq[0].failedAt).toBeInstanceOf(Date);\n    expect(dlq[0].failedAt.getTime()).toBeGreaterThanOrEqual(before.getTime());\n  });\n\n  it('can requeue a DLQ task for fresh processing', () => {\n    const task = exhaustRetries(system);\n    const requeued = system.requeueFromDLQ(task.id, 'default');\n    expect(requeued).not.toBeNull();\n    expect(system.getDeadLetterTasks('default').length).toBe(0);\n    expect(system.getPendingCount('default')).toBe(1);\n  });\n\n  it('requeued task has reset attempts and pending status', () => {\n    const task = exhaustRetries(system);\n    const requeued = system.requeueFromDLQ(task.id, 'default')!;\n    expect(requeued.attempts).toBe(0);\n    expect(requeued.status).toBe('pending');\n  });\n\n  it('can clear all DLQ tasks', () => {\n    exhaustRetries(system);\n    exhaustRetries(system);\n    system.clearDeadLetterQueue('default');\n    expect(system.getDeadLetterTasks('default').length).toBe(0);\n  });\n\n  it('each named queue has its own DLQ', () => {\n    exhaustRetries(system, 'q1');\n    exhaustRetries(system, 'q2');\n    expect(system.getDeadLetterTasks('q1').length).toBe(1);\n    expect(system.getDeadLetterTasks('q2').length).toBe(1);\n    system.clearDeadLetterQueue('q1');\n    expect(system.getDeadLetterTasks('q1').length).toBe(0);\n    expect(system.getDeadLetterTasks('q2').length).toBe(1);\n  });\n\n  it('returns empty array for queue with no DLQ tasks', () => {\n    expect(system.getDeadLetterTasks('default')).toEqual([]);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1151,"cache_read_input_tokens":66598,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1151},"output_tokens":18,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"e0d2d4d8-d6bc-4a7e-acf2-58b5c3d88583","uuid":"ad1bc0cc-9d50-46cd-a0e2-478dfb6198cc"}
