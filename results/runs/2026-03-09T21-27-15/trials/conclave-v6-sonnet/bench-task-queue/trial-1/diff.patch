+{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01578cH1uYq5Nf4wpGShjDbD","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01GKrGtdBBR4AwC1PtT5LQQH","name":"Write","input":{"file_path":"/workspace/tests/phase-05.test.ts","content":"import { describe, it, expect, beforeEach } from 'vitest';\nimport { TaskQueueSystem } from '../src/index.js';\n\ndescribe('Phase 5: Retry with Backoff', () => {\n  let system: TaskQueueSystem;\n\n  beforeEach(() => {\n    system = new TaskQueueSystem();\n  });\n\n  it('completeTask sets status to completed', () => {\n    system.addTask({});\n    const task = system.getNextTask()!;\n    system.completeTask(task.id);\n    expect(system.getTask(task.id)?.status).toBe('completed');\n  });\n\n  it('failing a task with retries remaining re-queues it', () => {\n    system.addTask({}, { maxRetries: 3, baseDelay: 100 });\n    const task = system.getNextTask()!;\n    system.failTask(task.id, new Error('boom'));\n    const refreshed = system.getTask(task.id)!;\n    expect(refreshed.status).toBe('pending');\n  });\n\n  it('retried task has a future availableAt (backoff delay)', () => {\n    system.addTask({}, { maxRetries: 3, baseDelay: 1000 });\n    const task = system.getNextTask()!;\n    const before = Date.now();\n    system.failTask(task.id, new Error('err'));\n    const refreshed = system.getTask(task.id)!;\n    expect(refreshed.availableAt.getTime()).toBeGreaterThan(before);\n  });\n\n  it('tracks attempt count across retries', () => {\n    system.addTask({}, { maxRetries: 3, baseDelay: 0 });\n    const t1 = system.getNextTask()!;\n    expect(t1.attempts).toBe(1);\n    system.failTask(t1.id, new Error('x'));\n\n    // Force availableAt to past so we can retrieve again\n    const task = system.getTask(t1.id)!;\n    task.availableAt = new Date(0);\n\n    const t2 = system.getNextTask()!;\n    expect(t2.attempts).toBe(2);\n    system.failTask(t2.id, new Error('x'));\n\n    task.availableAt = new Date(0);\n    const t3 = system.getNextTask()!;\n    expect(t3.attempts).toBe(3);\n  });\n\n  it('exponential backoff: baseDelay * 2^(attempt-1)', () => {\n    system.addTask({}, { maxRetries: 3, baseDelay: 1000 });\n    const task = system.getNextTask()!; // attempts = 1\n    const before = Date.now();\n    system.failTask(task.id, new Error('x'));\n    const refreshed = system.getTask(task.id)!;\n    // attempt 1 -> backoff = 1000 * 2^0 = 1000ms\n    expect(refreshed.availableAt.getTime() - before).toBeGreaterThanOrEqual(900);\n    expect(refreshed.availableAt.getTime() - before).toBeLessThan(2000);\n  });\n\n  it('task with maxRetries=0 goes straight to DLQ', () => {\n    system.addTask({}, { maxRetries: 0 });\n    const task = system.getNextTask()!;\n    system.failTask(task.id, new Error('fatal'));\n    expect(system.getDeadLetterTasks('default').length).toBe(1);\n    expect(system.getPendingCount()).toBe(0);\n  });\n\n  it('retried task keeps original queue and priority', () => {\n    system.addTask({}, { priority: 2, maxRetries: 1, baseDelay: 0 }, 'jobs');\n    const task = system.getNextTask('jobs')!;\n    system.failTask(task.id, new Error('x'));\n    const retried = system.getTask(task.id)!;\n    expect(retried.queueName).toBe('jobs');\n    expect(retried.priority).toBe(2);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":905,"cache_read_input_tokens":65693,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":905},"output_tokens":22,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"e0d2d4d8-d6bc-4a7e-acf2-58b5c3d88583","uuid":"63121d70-8c22-40d8-be69-41db11ebb091"}
