+**Step 5: Implement TaskQueueSystem class**
+
+```typescript
+// src/system.ts
+import { createTask } from './task.js';
+import { Queue } from './queue.js';
+import type {
+  Task, TaskOptions, DeadLetterTask, QueueStats,
+  ProgressListener, TaskProgress, MiddlewareFn, HandlerFn,
+  Schedule, ShutdownSummary
+} from './types.js';
+
+const DEFAULT_QUEUE = 'default';
+
+export class TaskQueueSystem {
+  private queues: Map<string, Queue> = new Map();
+  private allTasks: Map<string, { task: Task; queueName: string }> = new Map();
+  private schedules: Map<string, Schedule> = new Map();
+  private shutdownInitiated: boolean = false;
+  private shutdownPromise: Promise<ShutdownSummary> | null = null;
+
+  // ---- Phase 1: Basic FIFO ----
+
+  addTask<T>(payload: T, options: TaskOptions = {}, queueName: string = DEFAULT_QUEUE): Task<T> {
+    if (this.shutdownInitiated) {
+      throw new Error('System is shutting down, cannot add new tasks');
+    }
+
+    const queue = this.getOrCreateQueue(queueName);
+
+    // Validate dependencies (Phase 7)
+    if (options.dependsOn && options.dependsOn.length > 0) {
+      for (const depId of options.dependsOn) {
+        if (!this.allTasks.has(depId)) {
+          throw new Error(`Dependency task ${depId} does not exist`);
+        }
+      }
+    }
+
+    const task = createTask(payload, queueName, options) as Task<T>;
+
+    // Handle dependencies (Phase 7)
+    if (task.dependsOn.length > 0) {
+      if (queue.hasCircularDependency(task.id, task.dependsOn)) {
+        throw new Error(`Circular dependency detected for task ${task.id}`);
+      }
+      const allCompleted = task.dependsOn.every(depId => {
+        const dep = this.allTasks.get(depId);
+        return dep?.task.status === 'completed';
+      });
+      if (!allCompleted) {
+        task.status = 'blocked';
+      }
+    }
+
+    queue.addTask(task as Task);
+    this.allTasks.set(task.id, { task: task as Task, queueName });
+    return task;
+  }
+
+  getNextTask(queueName: string = DEFAULT_QUEUE): Task | null {
+    const queue = this.queues.get(queueName);
+    if (!queue) return null;
+    return queue.getNextTask();
+  }
+
+  getPendingCount(queueName: string = DEFAULT_QUEUE): number {
+    const queue = this.queues.get(queueName);
+    if (!queue) return 0;
+    return queue.getPendingCount();
+  }
+
+  // ---- Phase 2: Named queues ----
+
+  getQueueNames(): string[] {
+    return Array.from(this.queues.keys());
+  }
+
+  // ---- Phase 5: Complete/fail tasks ----
+
+  completeTask(taskId: string): void {
+    const entry = this.allTasks.get(taskId);
+    if (!entry) throw new Error(`Task ${taskId} not found`);
+    const queue = this.queues.get(entry.queueName)!;
+    queue.completeTask(taskId);
+    // After completing, unblock dependents across ALL queues
+    this.checkAllBlockedTasks();
+  }
+
+  failTask(taskId: string, error: Error = new Error('Task failed')): void {
+    const entry = this.allTasks.get(taskId);
+    if (!entry) throw new Error(`Task ${taskId} not found`);
+    const queue = this.queues.get(entry.queueName)!;
+    queue.failTask(taskId, error, (task) => {
+      // task already modified in place (status=pending, new availableAt)
+      // ensure allTasks reference is still valid
+      this.allTasks.set(task.id, { task, queueName: entry.queueName });
+    });
+  }
+
+  getTask(taskId: string): Task | null {
+    return this.allTasks.get(taskId)?.task ?? null;
+  }
+
+  // ---- Phase 6: Dead Letter Queue ----
+
+  getDeadLetterTasks(queueName: string = DEFAULT_QUEUE): DeadLetterTask[] {
+    return this.queues.get(queueName)?.getDeadLetterTasks() ?? [];
+  }
+
+  requeueFromDLQ(taskId: string, queueName: string = DEFAULT_QUEUE): Task | null {
+    const queue = this.queues.get(queueName);
+    if (!queue) return null;
+    const task = queue.requeueFromDLQ(taskId);
+    if (task) {
+      this.allTasks.set(task.id, { task, queueName });
+    }
+    return task;
+  }
+
+  clearDeadLetterQueue(queueName: string = DEFAULT_QUEUE): void {
+    this.queues.get(queueName)?.clearDLQ();
+  }
+
+  // ---- Phase 7: Dependencies ----
+
+  getTaskDependencyStatus(taskId: string): {
+    task: Task;
+    resolvedDeps: string[];
+    pendingDeps: string[];
+  } | null {
+    const entry = this.allTasks.get(taskId);
+    if (!entry) return null;
+    const task = entry.task;
+    const resolvedDeps: string[] = [];
+    const pendingDeps: string[] = [];
+    for (const depId of task.dependsOn) {
+      const dep = this.allTasks.get(depId);
+      if (dep?.task.status === 'completed') {
+        resolvedDeps.push(depId);
+      } else {
+        pendingDeps.push(depId);
+      }
+    }
+    return { task, resolvedDeps, pendingDeps };
+  }
+
+  // ---- Phase 8: Concurrency ----
+
+  setConcurrencyLimit(queueName: string, limit: number | null): void {
+    const queue = this.getOrCreateQueue(queueName);
+    queue.setConcurrencyLimit(limit);
+  }
+
+  getConcurrencyLimit(queueName: string): number | null {
+    return this.queues.get(queueName)?.getConcurrencyLimit() ?? null;
+  }
+
+  getActiveCount(queueName: string): number {
+    return this.queues.get(queueName)?.getActiveCount() ?? 0;
+  }
+
+  getQueueStats(queueName: string): QueueStats | null {
+    const queue = this.queues.get(queueName);
+    if (!queue) return null;
+    return {
+      name: queueName,
+      pending: queue.getPendingCount(),
+      processing: queue.getActiveCount(),
+      concurrencyLimit: queue.getConcurrencyLimit(),
+      activeCount: queue.getActiveCount(),
+    };
+  }
+
+  // ---- Phase 9: Progress & cancellation ----
+
+  updateProgress(taskId: string, percent: number, message?: string): void {
+    if (percent < 0 || percent > 100) throw new RangeError('Progress must be 0-100');
+    const entry = this.allTasks.get(taskId);
+    if (!entry) throw new Error(`Task ${taskId} not found`);
+    const queue = this.queues.get(entry.queueName)!;
+    queue.updateProgress(taskId, { percent, message });
+  }
+
+  getProgress(taskId: string): TaskProgress | null {
+    return this.allTasks.get(taskId)?.task.progress ?? null;
+  }
+
+  subscribeToProgress(taskId: string, listener: ProgressListener): () => void {
+    const entry = this.allTasks.get(taskId);
+    if (!entry) throw new Error(`Task ${taskId} not found`);
+    const queue = this.queues.get(entry.queueName)!;
+    return queue.subscribeToProgress(taskId, listener);
+  }
+
+  cancelTask(taskId: string): boolean {
+    const entry = this.allTasks.get(taskId);
+    if (!entry) return false;
+    const queue = this.queues.get(entry.queueName)!;
+    return queue.cancelTask(taskId);
+  }
+
+  // ---- Phase 10: Recurring tasks ----
+
+  addSchedule(
+    id: string,
+    queueName: string,
+    cronExpression: string,
+    payload: unknown
+  ): Schedule {
+    const schedule: Schedule = {
+      id,
+      queueName,
+      cronExpression,
+      payload,
+    };
+    this.schedules.set(id, schedule);
+    return schedule;
+  }
+
+  removeSchedule(id: string): boolean {
+    return this.schedules.delete(id);
+  }
+
+  listSchedules(): Schedule[] {
+    return Array.from(this.schedules.values());
+  }
+
+  tick(now: Date = new Date()): void {
+    for (const schedule of this.schedules.values()) {
+      if (this.isScheduleDue(schedule, now)) {
+        this.addTask(schedule.payload, {}, schedule.queueName);
+        schedule.lastRun = now;
+      }
+    }
+  }
+
+  // ---- Phase 11: Middleware ----
+
+  use<T = unknown>(queueName: string, middleware: MiddlewareFn<T>): void {
+    const queue = this.getOrCreateQueue(queueName);
+    queue.addMiddleware(middleware as MiddlewareFn);
+  }
+
+  setHandler<T = unknown>(queueName: string, handler: HandlerFn<T>): void {
+    const queue = this.getOrCreateQueue(queueName);
+    queue.setHandler(handler as HandlerFn);
+  }
+
+  async processNext(queueName: string = DEFAULT_QUEUE): Promise<boolean> {
+    const queue = this.queues.get(queueName);
+    if (!queue) return false;
+    const task = queue.getNextTask();
+    if (!task) return false;
+
+    const middleware = queue.getMiddleware();
+    const handler = queue.getHandler();
+
+    try {
+      await this.runMiddleware(task, middleware, async () => {
+        if (handler) await handler(task);
+      });
+      queue.completeTask(task.id);
+      this.checkAllBlockedTasks();
+    } catch (err) {
+      queue.failTask(task.id, err instanceof Error ? err : new Error(String(err)), (t) => {
+        this.allTasks.set(t.id, { task: t, queueName });
+      });
+    }
+    return true;
+  }
+
+  // ---- Phase 12: Graceful shutdown ----
+
+  async shutdown(timeoutMs: number = 30000): Promise<ShutdownSummary> {
+    if (this.shutdownPromise) return this.shutdownPromise;
+
+    this.shutdownInitiated = true;
+    const startTime = Date.now();
+
+    this.shutdownPromise = this.doShutdown(timeoutMs, startTime);
+    return this.shutdownPromise;
+  }
+
+  isShuttingDown(): boolean {
+    return this.shutdownInitiated;
+  }
+
+  // ---- Private helpers ----
+
+  private getOrCreateQueue(name: string): Queue {
+    if (!this.queues.has(name)) {
+      this.queues.set(name, new Queue(name));
+    }
+    return this.queues.get(name)!;
+  }
+
+  private checkAllBlockedTasks(): void {
+    for (const [, entry] of this.allTasks) {
+      const task = entry.task;
+      if (task.status === 'blocked') {
+        const allDone = task.dependsOn.every(depId => {
+          const dep = this.allTasks.get(depId);
+          return dep?.task.status === 'completed';
+        });
+        if (allDone) {
+          task.status = 'pending';
+        }
+      }
+    }
+  }
+
+  private async runMiddleware(
+    task: Task,
+    middleware: MiddlewareFn[],
+    final: () => Promise<void>
+  ): Promise<void> {
+    let index = 0;
+    const next = async (): Promise<void> => {
+      if (index < middleware.length) {
+        const fn = middleware[index++];
+        await fn(task, next);
+      } else {
+        await final();
+      }
+    };
+    await next();
+  }
+
+  private isScheduleDue(schedule: Schedule, now: Date): boolean {
+    const expr = schedule.cronExpression.trim();
+    const lastRun = schedule.lastRun;
+
+    // Parse cron: "*/N * * * *" | "0 * * * *" | "0 0 * * *"
+    const parts = expr.split(' ');
+    if (parts.length !== 5) return false;
+
+    const [minute, hour] = parts;
+
+    // Every N minutes: */N * * * *
+    if (minute.startsWith('*/') && hour === '*') {
+      const n = parseInt(minute.slice(2), 10);
+      if (isNaN(n) || n <= 0) return false;
+      if (!lastRun) return true;
+      const diffMs = now.getTime() - lastRun.getTime();
+      return diffMs >= n * 60 * 1000;
+    }
+
+    // Every hour: 0 * * * *
+    if (minute === '0' && hour === '*') {
+      if (!lastRun) return true;
+      return (
+        now.getFullYear() === lastRun.getFullYear() &&
+        now.getMonth() === lastRun.getMonth() &&
+        now.getDate() === lastRun.getDate()
+          ? now.getHours() > lastRun.getHours()
+          : true
+      );
+    }
+
+    // Every day at midnight: 0 0 * * *
+    if (minute === '0' && hour === '0') {
+      if (!lastRun) return now.getHours() === 0;
+      const lastDate = new Date(lastRun);
+      lastDate.setHours(0, 0, 0, 0);
+      const nowDate = new Date(now);
+      nowDate.setHours(0, 0, 0, 0);
+      return nowDate.getTime() > lastDate.getTime() && now.getHours() === 0;
+    }
+
+    return false;
+  }
+
+  private async doShutdown(timeoutMs: number, startTime: number): Promise<ShutdownSummary> {
+    const deadline = startTime + timeoutMs;
+    let completed = 0;
+    let forceCancelled = 0;
+
+    // Poll until all processing tasks are done or timeout
+    while (Date.now() < deadline) {
+      const processingTasks = Array.from(this.allTasks.values()).filter(
+        e => e.task.status === 'processing'
+      );
+      if (processingTasks.length === 0) break;
+      await new Promise(resolve => setTimeout(resolve, 50));
+    }
+
+    // Force-cancel any remaining processing tasks
+    for (const [, entry] of this.allTasks) {
+      if (entry.task.status === 'processing') {
+        entry.task.status = 'cancelled';
+        forceCancelled++;
+        const queue = this.queues.get(entry.queueName);
+        if (queue) {
+          (queue as Queue)['activeCount'] = Math.max(0, (queue as Queue)['activeCount'] - 1);
+        }
+      } else if (entry.task.status === 'completed') {
+        completed++;
+      }
+    }
+
+    // Count completed tasks (not force-cancelled)
+    for (const [, entry] of this.allTasks) {
+      if (entry.task.status === 'completed') {
+        completed++;
+      }
+    }
+
+    const durationMs = Date.now() - startTime;
+    return { completed, forceCancelled, durationMs };
+  }
+}
