const task = system.getNextTask()!;\n    system.subscribeToProgress(task.id, l1);\n    system.subscribeToProgress(task.id, l2);\n    system.updateProgress(task.id, 50);\n    expect(l1).toHaveBeenCalledTimes(1);\n    expect(l2).toHaveBeenCalledTimes(1);\n  });\n\n  it('unsubscribed listener stops receiving updates', () => {\n    const listener = vi.fn();\n    system.addTask({});\n    const task = system.getNextTask()!;\n    const unsub = system.subscribeToProgress(task.id, listener);\n    unsub();\n    system.updateProgress(task.id, 50);\n    expect(listener).not.toHaveBeenCalled();\n  });\n\n  it('can cancel a pending task', () => {\n    const task = system.addTask({});\n    system.cancelTask(task.id);\n    expect(system.getTask(task.id)?.status).toBe('cancelled');\n  });\n\n  it('cancelled pending task is not returned by getNextTask', () => {\n    const task = system.addTask({});\n    system.cancelTask(task.id);\n    expect(system.getNextTask()).toBeNull();\n  });\n\n  it('can cancel a processing task', () => {\n    system.addTask({});\n    const task = system.getNextTask()!;\n    system.cancelTask(task.id);\n    expect(system.getTask(task.id)?.status).toBe('cancelled');\n  });\n\n  it('cancelling a processing task frees its concurrency slot', () => {\n    system.setConcurrencyLimit('default', 1);\n    system.addTask({});\n    system.addTask({});\n    const t1 = system.getNextTask()!;\n    system.cancelTask(t1.id);\n    expect(system.getNextTask()).not.toBeNull();\n  });\n\n  it('cancelled tasks are never retried', () => {\n    system.addTask({}, { maxRetries: 3 });\n    const task = system.getNextTask()!;\n    system.cancelTask(task.id);\n    // No retry should happen — cancelled\n    expect(system.getPendingCount()).toBe(0);\n    expect(system.getDeadLetterTasks().length).toBe(0);\n  });\n\n  it('cancelTask returns false for non-existent task', () => {\n    expect(system.cancelTask('nonexistent')).toBe(false);\n  });\n\n  it('initial task progress is 0', () => {\n    system.addTask({});\n    const task = system.getNextTask()!;\n    expect(system.getProgress(task.id)?.percent).toBe(0);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1102,"cache_read_input_tokens":70065,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1102},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"e0d2d4d8-d6bc-4a7e-acf2-58b5c3d88583","uuid":"f0355c31-751a-4f70-9271-8330ef42ccd7"}
