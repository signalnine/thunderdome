ing task', () => {\n    system.addTask({});\n    const task = system.getNextTask()!;\n    system.updateProgress(task.id, 50, 'halfway');\n    const progress = system.getProgress(task.id)!;\n    expect(progress.percent).toBe(50);\n    expect(progress.message).toBe('halfway');\n  });\n\n  it('throws on invalid progress percent', () => {\n    system.addTask({});\n    const task = system.getNextTask()!;\n    expect(() => system.updateProgress(task.id, -1)).toThrow();\n    expect(() => system.updateProgress(task.id, 101)).toThrow();\n  });\n\n  it('listeners receive progress updates', () => {\n    const listener = vi.fn();\n    system.addTask({});\n    const task = system.getNextTask()!;\n    system.subscribeToProgress(task.id, listener);\n    system.updateProgress(task.id, 75);\n    expect(listener).toHaveBeenCalledWith({ percent: 75, message: undefined });\n  });\n\n  it('unsubscribed listener stops receiving updates', () => {\n    const listener = vi.fn();\n    system.addTask({});\n    const task = system.getNextTask()!;\n    const unsub = system.subscribeToProgress(task.id, listener);\n    unsub();\n    system.updateProgress(task.id, 50);\n    expect(listener).not.toHaveBeenCalled();\n  });\n\n  it('can cancel a pending task', () => {\n    const task = system.addTask({});\n    system.cancelTask(task.id);\n    expect(system.getTask(task.id)?.status).toBe('cancelled');\n    expect(system.getNextTask()).toBeNull();\n  });\n\n  it('can cancel a processing task', () => {\n    system.addTask({});\n    const task = system.getNextTask()!;\n    system.cancelTask(task.id);\n    expect(system.getTask(task.id)?.status).toBe('cancelled');\n  });\n\n  it('cancelled tasks are not retried', () => {\n    system.addTask({}, { maxRetries: 3 });\n    const task = system.getNextTask()!;\n    system.cancelTask(task.id);\n    // No requeue should happen\n    expect(system.getPendingCount()).toBe(0);\n  });\n});\n```\n\n**Step 2: Run tests**\n\nRun: `npm test -- tests/phase-09.test.ts`\nExpected: All PASS (note: cancelled processing tasks should NOT trigger retry logic in failTask)\n\n**Step 3: Adjust cancellation to skip retry**\n\nIn `Queue.cancelTask`, when cancelling a processing task, just set status to 'cancelled'. Ensure `failTask` checks for cancelled status before requeueing — but since `cancelTask` is separate from `failTask`, this should already work.\n\n**Step 4: Commit**\n\n```bash\ngit add tests/phase-09.test.ts\ngit commit -m \"feat(phase-9): progress tracking and cancellation\"\n```\n\n---\n\n### Task 11: Phase 10 – Recurring Tasks\n\n**Files:**\n- Create: `tests/phase-10.test.ts`\n\n**Dependencies:** Task 10\n\n**Step 1: Write failing tests**\n\n```typescript\n// tests/phase-10.test.ts\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { TaskQueueSystem } from '../src/index.js';\n\ndescribe('Phase 10: Recurring Tasks', () => {\n  let system: TaskQueueSystem;\n\n  beforeEach(() => {\n    system = new TaskQueueSystem();\n  });\n\n  it('can add a schedule', () => {\n    const schedule = system.addSchedule('s1', 'default', '*/5 * * * *', { job: 'cleanup' });\n    expect(schedule.id).toBe('s1');\n  });\n\n  it('can list schedules', () => {\n    system.addSchedule('s1', 'default', '*/5 * * * *', {});\n    system.addSchedule('s2', 'jobs', '0 * * * *', {});\n    expect(system.listSchedules().length).toBe(2);\n  });\n\n  it('can remove a schedule', () => {\n    system.addSchedule('s1', 'default', '*/5 * * * *', {});\n    system.removeSchedule('s1');\n    expect(system.listSchedules().length).toBe(0);\n  });\n\n  it('tick enqueues task on first run (no lastRun)', () => {\n    system.addSchedule('s1', 'default', '*/1 * * * *', { recurring: true });\n    system.tick(new Date());\n    expect(system.getPendingCount('default')).toBe(1);\n  });\n\n  it('tick enqueues task after interval has passed', () => {\n    system.addSchedule('s1', 'default', '*/5 * * * *', { recurring: true });\n    const firstTick = new Date('2024-01-01T10:00:00Z');\n    system.tick(firstTick);\n    expect(system.getPendingCount()).toBe(1);\n    // Second tick just 1 minute later — not due yet\n    system.getNextTask(); // consume first task\n    const secondTick = new Date('2024-01-01T10:01:00Z');\n    system.tick(secondTick);\n    expect(system.getPendingCount()).toBe(0);\n    // Third tick 5 minutes after first — now due\n    const thirdTick = new Date('2024-01-01T10:05:00Z');\n    system.tick(thirdTick);\n    expect(system.getPendingCount()).toBe(1);\n  });\n\n  it('removing schedule stops future task creation', () => {\n    system.addSchedule('s1', 'default', '*/1 * * * *', {});\n    system.removeSchedule('s1');\n    system.tick(new Date());\n    expect(system.getPendingCount()).toBe(0);\n  });\n});\n```\n\n**Step 2: Run tests**\n\nRun: `npm test -- tests/phase-10.test.ts`\nExpected: All PASS\n\n**Step 3: Commit**\n\n```bash\ngit add tests/phase-10.test.ts\ngit commit -m \"feat(phase-10): recurring tasks with cron-like scheduling\"\n```\n\n---\n\n### Task 12: Phase 11 – Middleware\n\n**Files:**\n- Create: `tests/phase-11.test.ts`\n\n**Dependencies:** Task 11\n\n**Step 1: Write failing tests**\n\n```typescript\n// tests/phase-11.test.ts\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { TaskQueueSystem } from '../src/index.js';\n\ndescribe('Phase 11: Middleware', () => {\n  let system: TaskQueueSystem;\n\n  beforeEach(() => {\n    system = new TaskQueueSystem();\n  });\n\n  it('middleware runs in registration order', async () => {\n    const order: number[] = [];\n    system.use('default', async (task, next) => { order.push(1); await next(); });\n    system.use('default', async (task, next) => { order.push(2); await next(); });\n    system.setHandler('default', async () => { order.push(3); });\n    system.addTask({});\n    await system.processNext('default');\n    expect(order).toEqual([1, 2, 3]);\n  });\n\n  it('middleware can modify task payload', async () => {\n    let captured: unknown;\n    system.use('default', async (task, next) => {\n      (task.payload as Record<string, unknown>).enriched = true;\n      await next();\n    });\n    system.setHandler('default', async (task) => {\n      captured = task.payload;\n    });\n    system.addTask({ original: true });\n    await system.processNext('default');\n    expect((captured as Record<string, unknown>).enriched).toBe(true);\n  });\n\n  it('middleware not calling next skips handler', async () => {\n    let handlerCalled = false;\n    system.use('default', async (_task, _next) => {\n      // intentionally not calling next\n    });\n    system.setHandler('default', async () => { handlerCalled = true; });\n    system.addTask({});\n    await system.processNext('default');\n    expect(handlerCalled).toBe(false);\n  });\n\n  it('middleware error marks task as failed', async () => {\n    system.use('default', async () => {\n      throw new Error('middleware boom');\n    });\n    system.addTask({}, { maxRetries: 0 });\n    await system.processNext('default');\n    expect(system.getDeadLetterTasks('default').length).toBe(1);\n  });\n\n  it('each queue has independent middleware', async () => {\n    const q1calls: string[] = [];\n    const q2calls: string[] = [];\n    system.use('q1', async (task, next) => { q1calls.push('mw'); await next(); });\n    system.use('q2', async (task, next) => { q2calls.push('mw'); await next(); });\n    system.addTask({}, {}, 'q1');\n    system.addTask({}, {}, 'q2');\n    await system.processNext('q1');\n    await system.processNext('q2');\n    expect(q1calls).toEqual(['mw']);\n    expect(q2calls).toEqual(['mw']);\n  });\n});\n```\n\n**Step 2: Run tests**\n\nRun: `npm test -- tests/phase-11.test.ts`\nExpected: All PASS\n\n**Step 3: Commit**\n\n```bash\ngit add tests/phase-11.test.ts\ngit commit -m \"feat(phase-11): middleware pipeline\"\n```\n\n---\n\n### Task 13: Phase 12 – Graceful Shutdown\n\n**Files:**\n- Create: `tests/phase-12.test.ts`\n\n**Dependencies:** Task 12\n\n**Step 1: Write failing tests**\n\n```typescript\n// tests/phase-12.test.ts\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { TaskQueueSystem } from '../src/index.js';\n\ndescribe('Phase 12: Graceful Shutdown', () => {\n  let system: TaskQueueSystem;\n\n  beforeEach(() => {\n    system = new TaskQueueSystem();\n  });\n\n  it('shutdown prevents adding new tasks', async () => {\n    system.shutdown(100);\n    expect(() => system.addTask({})).toThrow();\n  });\n\n  it('shutdown with no processing tasks completes immediately', async () => {\n    const result = await system.shutdown(1000);\n    expect(result.forceCancelled).toBe(0);\n    expect(result.durationMs).toBeLessThan(500);\n  });\n\n  it('shutdown waits for processing tasks to finish', async () => {\n    system.addTask({});\n    const task = system.getNextTask()!;\n\n    // Complete the task after a short delay\n    setTimeout(() => system.completeTask(task.id), 50);\n\n    const result = await system.shutdown(2000);\n    expect(result.forceCancelled).toBe(0);\n  });\n\n  it('force-cancels tasks that exceed timeout', async () => {\n    system.addTask({});\n    system.getNextTask(); // put in processing, never complete\n\n    const result = await system.shutdown(100);\n    expect(result.forceCancelled).toBe(1);\n  });\n\n  it('calling shutdown multiple times returns same result', async () => {\n    const p1 = system.shutdown(1000);\n    const p2 = system.shutdown(1000);\n    expect(p1).toBe(p2);\n  });\n\n  it('shutdown summary includes duration', async () => {\n    const result = await system.shutdown(1000);\n    expect(result.durationMs).toBeGreaterThanOrEqual(0);\n  });\n});\n```\n\n**Step 2: Run tests**\n\nRun: `npm test -- tests/phase-12.test.ts`\nExpected: All PASS\n\n**Step 3: Fix shutdown completed count**\n\nThe `doShutdown` method double-counts completed tasks. Fix it: count completed tasks that were completed BEFORE shutdown, plus any that finish during the wait window. The simplest approach: after the wait loop, count all completed tasks in `allTasks`.\n\n```typescript\n// In doShutdown, replace the counting logic:\nprivate async doShutdown(timeoutMs: number, startTime: number): Promise<ShutdownSummary> {\n  const deadline = startTime + timeoutMs;\n\n  while (Date.now() < deadline) {\n    const processing = Array.from(this.allTasks.values()).filter(\n      e => e.task.status === 'processing'\n    );\n    if (processing.length === 0) break;\n    await new Promise(resolve => setTimeout(resolve, 50));\n  }\n\n  let forceCancelled = 0;\n  for (const [, entry] of this.allTasks) {\n    if (entry.task.status === 'processing') {\n      entry.task.status = 'cancelled';\n      forceCancelled++;\n      const queue = this.queues.get(entry.queueName);\n      if (queue) {\n        // Access private field via casting\n        (queue as unknown as { activeCount: number }).activeCount =\n          Math.max(0, (queue as unknown as { activeCount: number }).activeCount - 1);\n      }\n    }\n  }\n\n  const completed = Array.from(this.allTasks.values()).filter(\n    e => e.task.status === 'completed'\n  ).length;\n\n  const durationMs = Date.now() - startTime;\n  return { completed, forceCancelled, durationMs };\n}\n```\n\n**Step 4: Run all tests**\n\nRun: `npm test`\nExpected: All PASS\n\n**Step 5: Run build and lint**\n\nRun: `npm run build && npm run lint`\nExpected: PASS\n\n**Step 6: Commit**\n\n```bash\ngit add tests/phase-12.test.ts\ngit commit -m \"feat(phase-12): graceful shutdown\"\n```\n\n---\n\n### Task 14: Final Integration and Cleanup\n\n**Files:**\n- Review all src/ files for type safety, lint issues\n- Ensure `src/index.ts` exports everything needed\n\n**Dependencies:** Task 13\n\n**Step 1: Run full test suite**\n\nRun: `npm test`\nExpected: All tests PASS\n\n**Step 2: Run build**\n\nRun: `npm run build`\nExpected: PASS with no errors\n\n**Step 3: Run lint**\n\nRun: `npm run lint`\nExpected: No errors. Fix any issues found.\n\n**Step 4: Check private field access in doShutdown**\n\nThe `doShutdown` method accesses private `activeCount` field of Queue via casting. Clean this up by adding a package-internal method to Queue:\n\n```typescript\n// In Queue class, add:\ndecrementActiveCount(): void {\n  this.activeCount = Math.max(0, this.activeCount - 1);\n}\n```\n\nThen use `queue.decrementActiveCount()` in `doShutdown`.\n\n**Step 5: Verify no dead code, no debug artifacts**\n\nReview `src/system.ts` `isScheduleDue` for correctness with edge cases.\n\n**Step 6: Final commit**\n\n```bash\ngit add -A\ngit commit -m \"feat: complete 12-phase task queue system\"\n```\n\n---\n\n## Implementation Notes\n\n### Key Design Decisions\n\n1. **Cross-queue task references**: `allTasks` map in `TaskQueueSystem` stores all tasks regardless of queue. This allows Phase 7 dependency checking across named queues.\n\n2. **Retry vs. Cancel**: `failTask` checks status before requeueing. Cancelled tasks set status to 'cancelled' via `cancelTask`, so `failTask` never retries them.\n\n3. **Blocked task unblocking**: `checkAllBlockedTasks()` is called after every `completeTask`. It iterates all tasks across all queues checking if blocked tasks can now be unblocked.\n\n4. **DLQ storage**: Dead-lettered tasks are removed from main task map and stored in `Queue.deadLetterTasks`. They are NOT in `allTasks` after being dead-lettered (this is by design -- they are permanently failed).\n\n5. **Middleware processNext**: The `processNext` method is the middleware entry point. Direct `getNextTask` + `completeTask`/`failTask` bypasses middleware (used in phases 1-10 tests).\n\n6. **Shutdown polling**: Uses 50ms polling interval to check for processing tasks. This is simple and avoids event complexity.\n\n### Edge Cases to Watch\n\n- `getNextTask` must use the CURRENT time to evaluate `availableAt` — pass `new Date()` to queue method\n- Priority sort: lower number = higher priority (1 = most urgent)\n- FIFO tiebreaker uses `createdAt`, not `availableAt`\n- `baseDelay * 2^(attempt-1)`: attempt 1 = baseDelay*1, attempt 2 = baseDelay*2, attempt 3 = baseDelay*4\n- Blocked tasks are excluded from `getNextTask` filtering\n- Circular dependency detection must traverse the whole dependency graph, not just direct deps\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":158,"cache_read_input_tokens":27323,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":158},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"e0d2d4d8-d6bc-4a7e-acf2-58b5c3d88583","uuid":"af03479b-99c4-4278-8182-892712c24250"}
+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PDJW2b4gBfTFP1N4MAvBQ1","type":"tool_result","content":"File created successfully at: /workspace/docs/plans/2026-03-09-task-queue-system.md"}]},"parent_tool_use_id":null,"session_id":"e0d2d4d8-d6bc-4a7e-acf2-58b5c3d88583","uuid":"2de0e191-be3e-45cf-bf76-74951f7f85f8","tool_use_result":{"type":"create","filePath":"/workspace/docs/plans/2026-03-09-task-queue-system.md","content":"# Task Queue System Implementation Plan\n\n> **For Claude:** REQUIRED SUB-SKILL: Use conclave:executing-plans to implement this plan task-by-task.\n\n**Goal:** Build a fully-featured in-memory task queue system supporting 12 phases of capability including priorities, delays, retries, dependencies, concurrency, progress tracking, recurring tasks, middleware, and graceful shutdown.\n\n**Architecture:** A central `TaskQueueSystem` class orchestrates multiple named `Queue` instances. Tasks are represented by a `Task` class with rich lifecycle metadata. Features compose cleanly: a task retrieved from a queue passes through middleware, subject to concurrency limits, with delay/priority/dependency gating.\n\n**Tech Stack:** TypeScript (strict), Node.js ESM, Vitest for testing, no runtime dependencies.\n\n---\n\n## File Structure\n\n```\nsrc/\n  types.ts          # All shared types and interfaces\n  task.ts           # Task class\n  queue.ts          # Queue class (single named queue)\n  scheduler.ts      # Recurring task scheduler\n  system.ts         # TaskQueueSystem orchestrator\n  index.ts          # Public API exports\ntests/\n  phase-01.test.ts  through phase-12.test.ts\n```\n\n---\n\n### Task 1: Project scaffolding and types\n\n**Files:**\n- Create: `src/types.ts`\n- Create: `src/index.ts`\n\n**Dependencies:** none\n\n**Step 1: Create core types**\n\n```typescript\n// src/types.ts\nexport type TaskStatus =\n  | 'pending'\n  | 'processing'\n  | 'completed'\n  | 'failed'\n  | 'cancelled'\n  | 'blocked';  // waiting on dependencies\n\nexport interface TaskOptions {\n  priority?: number;          // 1 (highest) to 10 (lowest), default 5\n  delay?: number;             // ms delay before task becomes available\n  availableAt?: Date;         // absolute time to become available\n  maxRetries?: number;        // default 3\n  baseDelay?: number;         // backoff base in ms, default 1000\n  dependsOn?: string[];       // task IDs that must complete first\n}\n\nexport interface TaskProgress {\n  percent: number;            // 0-100\n  message?: string;\n}\n\nexport interface Task<T = unknown> {\n  id: string;\n  queueName: string;\n  payload: T;\n  status: TaskStatus;\n  priority: number;\n  createdAt: Date;\n  availableAt: Date;          // when task becomes eligible for processing\n  attempts: number;           // how many times attempted\n  maxRetries: number;\n  baseDelay: number;\n  dependsOn: string[];        // task IDs\n  progress: TaskProgress;\n  error?: Error;\n}\n\nexport interface DeadLetterTask<T = unknown> extends Task<T> {\n  failedAt: Date;\n  totalAttempts: number;\n}\n\nexport interface QueueStats {\n  name: string;\n  pending: number;\n  processing: number;\n  concurrencyLimit: number | null;\n  activeCount: number;\n}\n\nexport type MiddlewareFn<T = unknown> = (\n  task: Task<T>,\n  next: () => Promise<void>\n) => Promise<void>;\n\nexport type HandlerFn<T = unknown> = (task: Task<T>) => Promise<void>;\n\nexport type ProgressListener = (progress: TaskProgress) => void;\n\nexport interface Schedule {\n  id: string;\n  queueName: string;\n  cronExpression: string;\n  payload: unknown;\n  lastRun?: Date;\n}\n\nexport interface ShutdownSummary {\n  completed: number;\n  forceCancelled: number;\n  durationMs: number;\n}\n```\n\n**Step 2: Create barrel export**\n\n```typescript\n// src/index.ts  (stub – will be filled as phases progress)\nexport * from './types.js';\nexport * from './task.js';\nexport * from './queue.js';\nexport * from './system.js';\n```\n\n**Step 3: Build**\n\nRun: `npm run build`\nExpected: PASS (no errors, or only \"cannot find module\" for missing files – fix stubs as needed)\n\n**Step 4: Commit**\n\n```bash\ngit add src/types.ts src/index.ts\ngit commit -m \"feat: add core types and project scaffold\"\n```\n\n---\n\n### Task 2: Phase 1 – Basic FIFO Queue\n\n**Files:**\n- Create: `src/task.ts`\n- Create: `src/queue.ts`\n- Create: `src/system.ts`\n- Modify: `src/index.ts`\n- Create: `tests/phase-01.test.ts`\n\n**Dependencies:** Task 1\n\n**Step 1: Write the failing tests**\n\n```typescript\n// tests/phase-01.test.ts\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { TaskQueueSystem } from '../src/index.js';\n\ndescribe('Phase 1: Basic FIFO Queue', () => {\n  let system: TaskQueueSystem;\n\n  beforeEach(() => {\n    system = new TaskQueueSystem();\n  });\n\n  it('adds a task and returns a task object with id, status, createdAt', () => {\n    const task = system.addTask({ data: 'hello' });\n    expect(task.id).toBeTypeOf('string');\n    expect(task.status).toBe('pending');\n    expect(task.createdAt).toBeInstanceOf(Date);\n  });\n\n  it('retrieves the oldest pending task (FIFO) and transitions it to processing', () => {\n    const t1 = system.addTask({ n: 1 });\n    const t2 = system.addTask({ n: 2 });\n    const next = system.getNextTask();\n    expect(next?.id).toBe(t1.id);\n    expect(next?.status).toBe('processing');\n  });\n\n  it('returns null when queue is empty', () => {\n    expect(system.getNextTask()).toBeNull();\n  });\n\n  it('returns pending count', () => {\n    system.addTask({});\n    system.addTask({});\n    expect(system.getPendingCount()).toBe(2);\n    system.getNextTask();\n    expect(system.getPendingCount()).toBe(1);\n  });\n});\n```\n\n**Step 2: Run tests to verify they fail**\n\nRun: `npm test -- tests/phase-01.test.ts`\nExpected: FAIL with \"cannot find module\"\n\n**Step 3: Implement Task class**\n\n```typescript\n// src/task.ts\nimport { randomUUID } from 'crypto';\nimport type { Task, TaskStatus, TaskOptions, TaskProgress } from './types.js';\n\nexport function createTask<T>(\n  payload: T,\n  queueName: string,\n  options: TaskOptions = {}\n): Task<T> {\n  const now = new Date();\n  const priority = options.priority ?? 5;\n  if (priority < 1 || priority > 10) {\n    throw new RangeError(`Priority must be 1-10, got ${priority}`);\n  }\n\n  let availableAt: Date;\n  if (options.availableAt) {\n    availableAt = options.availableAt;\n  } else if (options.delay) {\n    availableAt = new Date(now.getTime() + options.delay);\n  } else {\n    availableAt = now;\n  }\n\n  return {\n    id: randomUUID(),\n    queueName,\n    payload,\n    status: 'pending' as TaskStatus,\n    priority,\n    createdAt: now,\n    availableAt,\n    attempts: 0,\n    maxRetries: options.maxRetries ?? 3,\n    baseDelay: options.baseDelay ?? 1000,\n    dependsOn: options.dependsOn ?? [],\n    progress: { percent: 0 },\n  };\n}\n```\n\n**Step 4: Implement Queue class**\n\n```typescript\n// src/queue.ts\nimport type { Task, DeadLetterTask, MiddlewareFn, HandlerFn, ProgressListener, TaskProgress } from './types.js';\n\nexport class Queue<T = unknown> {\n  readonly name: string;\n  private tasks: Map<string, Task<T>> = new Map();\n  private deadLetterTasks: Map<string, DeadLetterTask<T>> = new Map();\n  private concurrencyLimit: number | null = null;\n  private activeCount: number = 0;\n  private middleware: MiddlewareFn<T>[] = [];\n  private handler: HandlerFn<T> | null = null;\n  private progressListeners: Map<string, Set<ProgressListener>> = new Map();\n\n  constructor(name: string) {\n    this.name = name;\n  }\n\n  addTask(task: Task<T>): void {\n    this.tasks.set(task.id, task);\n  }\n\n  getNextTask(now: Date = new Date()): Task<T> | null {\n    if (this.concurrencyLimit !== null && this.activeCount >= this.concurrencyLimit) {\n      return null;\n    }\n\n    // Filter to available pending tasks\n    const available = Array.from(this.tasks.values()).filter(t =>\n      t.status === 'pending' &&\n      t.availableAt <= now &&\n      t.dependsOn.every(depId => {\n        const dep = this.tasks.get(depId);\n        return dep?.status === 'completed';\n      })\n    );\n\n    if (available.length === 0) return null;\n\n    // Sort: priority ASC (lower number = higher priority), then createdAt ASC (FIFO)\n    available.sort((a, b) => {\n      if (a.priority !== b.priority) return a.priority - b.priority;\n      return a.availableAt.getTime() - b.availableAt.getTime() ||\n             a.createdAt.getTime() - b.createdAt.getTime();\n    });\n\n    const task = available[0];\n    task.status = 'processing';\n    task.attempts += 1;\n    this.activeCount += 1;\n    return task;\n  }\n\n  getPendingCount(now: Date = new Date()): number {\n    return Array.from(this.tasks.values()).filter(\n      t => t.status === 'pending' && t.availableAt <= now\n    ).length;\n  }\n\n  getTask(id: string): Task<T> | undefined {\n    return this.tasks.get(id);\n  }\n\n  getAllTasks(): Task<T>[] {\n    return Array.from(this.tasks.values());\n  }\n\n  completeTask(id: string): void {\n    const task = this.tasks.get(id);\n    if (!task || task.status !== 'processing') return;\n    task.status = 'completed';\n    this.activeCount = Math.max(0, this.activeCount - 1);\n    this.checkBlockedTasks();\n  }\n\n  failTask(id: string, error: Error, requeueFn: (task: Task<T>) => void): void {\n    const task = this.tasks.get(id);\n    if (!task || task.status !== 'processing') return;\n    task.error = error;\n    this.activeCount = Math.max(0, this.activeCount - 1);\n\n    if (task.attempts <= task.maxRetries) {\n      // Retry with exponential backoff\n      const backoffMs = task.baseDelay * Math.pow(2, task.attempts - 1);\n      task.status = 'pending';\n      task.availableAt = new Date(Date.now() + backoffMs);\n      requeueFn(task);\n    } else {\n      task.status = 'failed';\n      // Move to DLQ\n      const dlqTask: DeadLetterTask<T> = {\n        ...(task as Task<T>),\n        failedAt: new Date(),\n        totalAttempts: task.attempts,\n      };\n      this.deadLetterTasks.set(id, dlqTask);\n      this.tasks.delete(id);\n    }\n  }\n\n  cancelTask(id: string): boolean {\n    const task = this.tasks.get(id);\n    if (!task) return false;\n    if (task.status !== 'pending' && task.status !== 'processing' && task.status !== 'blocked') return false;\n    if (task.status === 'processing') {\n      this.activeCount = Math.max(0, this.activeCount - 1);\n    }\n    task.status = 'cancelled';\n    // Cancelled tasks are not retried\n    return true;\n  }\n\n  updateProgress(id: string, progress: TaskProgress): void {\n    const task = this.tasks.get(id);\n    if (!task || task.status !== 'processing') return;\n    task.progress = progress;\n    const listeners = this.progressListeners.get(id);\n    if (listeners) {\n      for (const listener of listeners) {\n        listener(progress);\n      }\n    }\n  }\n\n  subscribeToProgress(id: string, listener: ProgressListener): () => void {\n    if (!this.progressListeners.has(id)) {\n      this.progressListeners.set(id, new Set());\n    }\n    this.progressListeners.get(id)!.add(listener);\n    return () => {\n      this.progressListeners.get(id)?.delete(listener);\n    };\n  }\n\n  getDeadLetterTasks(): DeadLetterTask<T>[] {\n    return Array.from(this.deadLetterTasks.values());\n  }\n\n  requeueFromDLQ(id: string): Task<T> | null {\n    const dlqTask = this.deadLetterTasks.get(id);\n    if (!dlqTask) return null;\n    const task: Task<T> = {\n      ...dlqTask,\n      status: 'pending',\n      attempts: 0,\n      availableAt: new Date(),\n    };\n    this.deadLetterTasks.delete(id);\n    this.tasks.set(id, task);\n    return task;\n  }\n\n  clearDLQ(): void {\n    this.deadLetterTasks.clear();\n  }\n\n  setConcurrencyLimit(limit: number | null): void {\n    this.concurrencyLimit = limit;\n  }\n\n  getConcurrencyLimit(): number | null {\n    return this.concurrencyLimit;\n  }\n\n  getActiveCount(): number {\n    return this.activeCount;\n  }\n\n  addMiddleware(fn: MiddlewareFn<T>): void {\n    this.middleware.push(fn);\n  }\n\n  setHandler(fn: HandlerFn<T>): void {\n    this.handler = fn;\n  }\n\n  getMiddleware(): MiddlewareFn<T>[] {\n    return this.middleware;\n  }\n\n  getHandler(): HandlerFn<T> | null {\n    return this.handler;\n  }\n\n  private checkBlockedTasks(): void {\n    for (const task of this.tasks.values()) {\n      if (task.status === 'blocked') {\n        const allDone = task.dependsOn.every(depId => {\n          const dep = this.tasks.get(depId);\n          return dep?.status === 'completed';\n        });\n        if (allDone) {\n          task.status = 'pending';\n        }\n      }\n    }\n  }\n\n  hasCircularDependency(taskId: string, dependsOn: string[]): boolean {\n    // Check if taskId would create a cycle if it depends on `dependsOn`\n    const visited = new Set<string>();\n    const stack = [...dependsOn];\n    while (stack.length > 0) {\n      const current = stack.pop()!;\n      if (current === taskId) return true;\n      if (visited.has(current)) continue;\n      visited.add(current);\n      const dep = this.tasks.get(current);\n      if (dep) {\n        stack.push(...dep.dependsOn);\n      }\n    }\n    return false;\n  }\n}\n```\n\n**Step 5: Implement TaskQueueSystem class**\n\n```typescript\n// src/system.ts\nimport { createTask } from './task.js';\nimport { Queue } from './queue.js';\nimport type {\n  Task, TaskOptions, DeadLetterTask, QueueStats,\n  ProgressListener, TaskProgress, MiddlewareFn, HandlerFn,\n  Schedule, ShutdownSummary\n} from './types.js';\n\nconst DEFAULT_QUEUE = 'default';\n\nexport class TaskQueueSystem {\n  private queues: Map<string, Queue> = new Map();\n  private allTasks: Map<string, { task: Task; queueName: string }> = new Map();\n  private schedules: Map<string, Schedule> = new Map();\n  private shutdownInitiated: boolean = false;\n  private shutdownPromise: Promise<ShutdownSummary> | null = null;\n\n  // ---- Phase 1: Basic FIFO ----\n\n  addTask<T>(payload: T, options: TaskOptions = {}, queueName: string = DEFAULT_QUEUE): Task<T> {\n    if (this.shutdownInitiated) {\n      throw new Error('System is shutting down, cannot add new tasks');\n    }\n\n    const queue = this.getOrCreateQueue(queueName);\n\n    // Validate dependencies (Phase 7)\n    if (options.dependsOn && options.dependsOn.length > 0) {\n      for (const depId of options.dependsOn) {\n        if (!this.allTasks.has(depId)) {\n          throw new Error(`Dependency task ${depId} does not exist`);\n        }\n      }\n    }\n\n    const task = createTask(payload, queueName, options) as Task<T>;\n\n    // Handle dependencies (Phase 7)\n    if (task.dependsOn.length > 0) {\n      if (queue.hasCircularDependency(task.id, task.dependsOn)) {\n        throw new Error(`Circular dependency detected for task ${task.id}`);\n      }\n      const allCompleted = task.dependsOn.every(depId => {\n        const dep = this.allTasks.get(depId);\n        return dep?.task.status === 'completed';\n      });\n      if (!allCompleted) {\n        task.status = 'blocked';\n      }\n    }\n\n    queue.addTask(task as Task);\n    this.allTasks.set(task.id, { task: task as Task, queueName });\n    return task;\n  }\n\n  getNextTask(queueName: string = DEFAULT_QUEUE): Task | null {\n    const queue = this.queues.get(queueName);\n    if (!queue) return null;\n    return queue.getNextTask();\n  }\n\n  getPendingCount(queueName: string = DEFAULT_QUEUE): number {\n    const queue = this.queues.get(queueName);\n    if (!queue) return 0;\n    return queue.getPendingCount();\n  }\n\n  // ---- Phase 2: Named queues ----\n\n  getQueueNames(): string[] {\n    return Array.from(this.queues.keys());\n  }\n\n  // ---- Phase 5: Complete/fail tasks ----\n\n  completeTask(taskId: string): void {\n    const entry = this.allTasks.get(taskId);\n    if (!entry) throw new Error(`Task ${taskId} not found`);\n    const queue = this.queues.get(entry.queueName)!;\n    queue.completeTask(taskId);\n    // After completing, unblock dependents across ALL queues\n    this.checkAllBlockedTasks();\n  }\n\n  failTask(taskId: string, error: Error = new Error('Task failed')): void {\n    const entry = this.allTasks.get(taskId);\n    if (!entry) throw new Error(`Task ${taskId} not found`);\n    const queue = this.queues.get(entry.queueName)!;\n    queue.failTask(taskId, error, (task) => {\n      // task already modified in place (status=pending, new availableAt)\n      // ensure allTasks reference is still valid\n      this.allTasks.set(task.id, { task, queueName: entry.queueName });\n    });\n  }\n\n  getTask(taskId: string): Task | null {\n    return this.allTasks.get(taskId)?.task ?? null;\n  }\n\n  // ---- Phase 6: Dead Letter Queue ----\n\n  getDeadLetterTasks(queueName: string = DEFAULT_QUEUE): DeadLetterTask[] {\n    return this.queues.get(queueName)?.getDeadLetterTasks() ?? [];\n  }\n\n  requeueFromDLQ(taskId: string, queueName: string = DEFAULT_QUEUE): Task | null {\n    const queue = this.queues.get(queueName);\n    if (!queue) return null;\n    const task = queue.requeueFromDLQ(taskId);\n    if (task) {\n      this.allTasks.set(task.id, { task, queueName });\n    }\n    return task;\n  }\n\n  clearDeadLetterQueue(queueName: string = DEFAULT_QUEUE): void {\n    this.queues.get(queueName)?.clearDLQ();\n  }\n\n  // ---- Phase 7: Dependencies ----\n\n  getTaskDependencyStatus(taskId: string): {\n    task: Task;\n    resolvedDeps: string[];\n    pendingDeps: string[];\n  } | null {\n    const entry = this.allTasks.get(taskId);\n    if (!entry) return null;\n    const task = entry.task;\n    const resolvedDeps: string[] = [];\n    const pendingDeps: string[] = [];\n    for (const depId of task.dependsOn) {\n      const dep = this.allTasks.get(depId);\n      if (dep?.task.status === 'completed') {\n        resolvedDeps.push(depId);\n      } else {\n        pendingDeps.push(depId);\n      }\n    }\n    return { task, resolvedDeps, pendingDeps };\n  }\n\n  // ---- Phase 8: Concurrency ----\n\n  setConcurrencyLimit(queueName: string, limit: number | null): void {\n    const queue = this.getOrCreateQueue(queueName);\n    queue.setConcurrencyLimit(limit);\n  }\n\n  getConcurrencyLimit(queueName: string): number | null {\n    return this.queues.get(queueName)?.getConcurrencyLimit() ?? null;\n  }\n\n  getActiveCount(queueName: string): number {\n    return this.queues.get(queueName)?.getActiveCount() ?? 0;\n  }\n\n  getQueueStats(queueName: string): QueueStats | null {\n    const queue = this.queues.get(queueName);\n    if (!queue) return null;\n    return {\n      name: queueName,\n      pending: queue.getPendingCount(),\n      processing: queue.getActiveCount(),\n      concurrencyLimit: queue.getConcurrencyLimit(),\n      activeCount: queue.getActiveCount(),\n    };\n  }\n\n  // ---- Phase 9: Progress & cancellation ----\n\n  updateProgress(taskId: string, percent: number, message?: string): void {\n    if (percent < 0 || percent > 100) throw new RangeError('Progress must be 0-100');\n    const entry = this.allTasks.get(taskId);\n    if (!entry) throw new Error(`Task ${taskId} not found`);\n    const queue = this.queues.get(entry.queueName)!;\n    queue.updateProgress(taskId, { percent, message });\n  }\n\n  getProgress(taskId: string): TaskProgress | null {\n    return this.allTasks.get(taskId)?.task.progress ?? null;\n  }\n\n  subscribeToProgress(taskId: string, listener: ProgressListener): () => void {\n    const entry = this.allTasks.get(taskId);\n    if (!entry) throw new Error(`Task ${taskId} not found`);\n    const queue = this.queues.get(entry.queueName)!;\n    return queue.subscribeToProgress(taskId, listener);\n  }\n\n  cancelTask(taskId: string): boolean {\n    const entry = this.allTasks.get(taskId);\n    if (!entry) return false;\n    const queue = this.queues.get(entry.queueName)!;\n    return queue.cancelTask(taskId);\n  }\n\n  // ---- Phase 10: Recurring tasks ----\n\n  addSchedule(\n    id: string,\n    queueName: string,\n    cronExpression: string,\n    payload: unknown\n  ): Schedule {\n    const schedule: Schedule = {\n      id,\n      queueName,\n      cronExpression,\n      payload,\n    };\n    this.schedules.set(id, schedule);\n    return schedule;\n  }\n\n  removeSchedule(id: string): boolean {\n    return this.schedules.delete(id);\n  }\n\n  listSchedules(): Schedule[] {\n    return Array.from(this.schedules.values());\n  }\n\n  tick(now: Date = new Date()): void {\n    for (const schedule of this.schedules.values()) {\n      if (this.isScheduleDue(schedule, now)) {\n        this.addTask(schedule.payload, {}, schedule.queueName);\n        schedule.lastRun = now;\n      }\n    }\n  }\n\n  // ---- Phase 11: Middleware ----\n\n  use<T = unknown>(queueName: string, middleware: MiddlewareFn<T>): void {\n    const queue = this.getOrCreateQueue(queueName);\n    queue.addMiddleware(middleware as MiddlewareFn);\n  }\n\n  setHandler<T = unknown>(queueName: string, handler: HandlerFn<T>): void {\n    const queue = this.getOrCreateQueue(queueName);\n    queue.setHandler(handler as HandlerFn);\n  }\n\n  async processNext(queueName: string = DEFAULT_QUEUE): Promise<boolean> {\n    const queue = this.queues.get(queueName);\n    if (!queue) return false;\n    const task = queue.getNextTask();\n    if (!task) return false;\n\n    const middleware = queue.getMiddleware();\n    const handler = queue.getHandler();\n\n    try {\n      await this.runMiddleware(task, middleware, async () => {\n        if (handler) await handler(task);\n      });\n      queue.completeTask(task.id);\n      this.checkAllBlockedTasks();\n    } catch (err) {\n      queue.failTask(task.id, err instanceof Error ? err : new Error(String(err)), (t) => {\n        this.allTasks.set(t.id, { task: t, queueName });\n      });\n    }\n    return true;\n  }\n\n  // ---- Phase 12: Graceful shutdown ----\n\n  async shutdown(timeoutMs: number = 30000): Promise<ShutdownSummary> {\n    if (this.shutdownPromise) return this.shutdownPromise;\n\n    this.shutdownInitiated = true;\n    const startTime = Date.now();\n\n    this.shutdownPromise = this.doShutdown(timeoutMs, startTime);\n    return this.shutdownPromise;\n  }\n\n  isShuttingDown(): boolean {\n    return this.shutdownInitiated;\n  }\n\n  // ---- Private helpers ----\n\n  private getOrCreateQueue(name: string): Queue {\n    if (!this.queues.has(name)) {\n      this.queues.set(name, new Queue(name));\n    }\n    return this.queues.get(name)!;\n  }\n\n  private checkAllBlockedTasks(): void {\n    for (const [, entry] of this.allTasks) {\n      const task = entry.task;\n      if (task.status === 'blocked') {\n        const allDone = task.dependsOn.every(depId => {\n          const dep = this.allTasks.get(depId);\n          return dep?.task.status === 'completed';\n        });\n        if (allDone) {\n          task.status = 'pending';\n        }\n      }\n    }\n  }\n\n  private async runMiddleware(\n    task: Task,\n    middleware: MiddlewareFn[],\n    final: () => Promise<void>\n  ): Promise<void> {\n    let index = 0;\n    const next = async (): Promise<void> => {\n      if (index < middleware.length) {\n        const fn = middleware[index++];\n        await fn(task, next);\n      } else {\n        await final();\n      }\n    };\n    await next();\n  }\n\n  private isScheduleDue(schedule: Schedule, now: Date): boolean {\n    const expr = schedule.cronExpression.trim();\n    const lastRun = schedule.lastRun;\n\n    // Parse cron: \"*/N * * * *\" | \"0 * * * *\" | \"0 0 * * *\"\n    const parts = expr.split(' ');\n    if (parts.length !== 5) return false;\n\n    const [minute, hour] = parts;\n\n    // Every N minutes: */N * * * *\n    if (minute.startsWith('*/') && hour === '*') {\n      const n = parseInt(minute.slice(2), 10);\n      if (isNaN(n) || n <= 0) return false;\n      if (!lastRun) return true;\n      const diffMs = now.getTime() - lastRun.getTime();\n      return diffMs >= n * 60 * 1000;\n    }\n\n    // Every hour: 0 * * * *\n    if (minute === '0' && hour === '*') {\n      if (!lastRun) return true;\n      return (\n        now.getFullYear() === lastRun.getFullYear() &&\n        now.getMonth() === lastRun.getMonth() &&\n        now.getDate() === lastRun.getDate()\n          ? now.getHours() > lastRun.getHours()\n          : true\n      );\n    }\n\n    // Every day at midnight: 0 0 * * *\n    if (minute === '0' && hour === '0') {\n      if (!lastRun) return now.getHours() === 0;\n      const lastDate = new Date(lastRun);\n      lastDate.setHours(0, 0, 0, 0);\n      const nowDate = new Date(now);\n      nowDate.setHours(0, 0, 0, 0);\n      return nowDate.getTime() > lastDate.getTime() && now.getHours() === 0;\n    }\n\n    return false;\n  }\n\n  private async doShutdown(timeoutMs: number, startTime: number): Promise<ShutdownSummary> {\n    const deadline = startTime + timeoutMs;\n    let completed = 0;\n    let forceCancelled = 0;\n\n    // Poll until all processing tasks are done or timeout\n    while (Date.now() < deadline) {\n      const processingTasks = Array.from(this.allTasks.values()).filter(\n        e => e.task.status === 'processing'\n      );\n      if (processingTasks.length === 0) break;\n      await new Promise(resolve => setTimeout(resolve, 50));\n    }\n\n    // Force-cancel any remaining processing tasks\n    for (const [, entry] of this.allTasks) {\n      if (entry.task.status === 'processing') {\n        entry.task.status = 'cancelled';\n        forceCancelled++;\n        const queue = this.queues.get(entry.queueName);\n        if (queue) {\n          (queue as Queue)['activeCount'] = Math.max(0, (queue as Queue)['activeCount'] - 1);\n        }\n      } else if (entry.task.status === 'completed') {\n        completed++;\n      }\n    }\n\n    // Count completed tasks (not force-cancelled)\n    for (const [, entry] of this.allTasks) {\n      if (entry.task.status === 'completed') {\n        completed++;\n      }\n    }\n\n    const durationMs = Date.now() - startTime;\n    return { completed, forceCancelled, durationMs };\n  }\n}\n```\n\n**Step 6: Update barrel export**\n\n```typescript\n// src/index.ts\nexport * from './types.js';\nexport * from './task.js';\nexport * from './queue.js';\nexport * from './system.js';\n```\n\n**Step 7: Run Phase 1 tests**\n\nRun: `npm test -- tests/phase-01.test.ts`\nExpected: All PASS\n\n**Step 8: Run build and lint**\n\nRun: `npm run build && npm run lint`\nExpected: PASS\n\n**Step 9: Commit**\n\n```bash\ngit add src/ tests/phase-01.test.ts\ngit commit -m \"feat(phase-1): basic FIFO queue\"\n```\n\n---\n\n### Task 3: Phase 2 – Named Queues\n\n**Files:**\n- Create: `tests/phase-02.test.ts`\n- No new source files needed (system already supports named queues)\n\n**Dependencies:** Task 2\n\n**Step 1: Write failing tests**\n\n```typescript\n// tests/phase-02.test.ts\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { TaskQueueSystem } from '../src/index.js';\n\ndescribe('Phase 2: Named Queues', () => {\n  let system: TaskQueueSystem;\n\n  beforeEach(() => {\n    system = new TaskQueueSystem();\n  });\n\n  it('uses default queue when no name given', () => {\n    const task = system.addTask({ x: 1 });\n    expect(task.queueName).toBe('default');\n  });\n\n  it('adds tasks to named queues independently', () => {\n    system.addTask({ a: 1 }, {}, 'alpha');\n    system.addTask({ b: 2 }, {}, 'beta');\n    expect(system.getPendingCount('alpha')).toBe(1);\n    expect(system.getPendingCount('beta')).toBe(1);\n    expect(system.getNextTask('alpha')?.payload).toEqual({ a: 1 });\n    expect(system.getPendingCount('beta')).toBe(1);\n  });\n\n  it('creating a named queue happens implicitly on first addTask', () => {\n    system.addTask({}, {}, 'foo');\n    expect(system.getQueueNames()).toContain('foo');\n  });\n\n  it('returns null from non-existent queue', () => {\n    expect(system.getNextTask('nonexisten