@@ -0,0 +1,39 @@
+import { randomUUID } from 'crypto';
+import type { Task, TaskOptions } from './types.js';
+
+export function createTask<T>(
+  payload: T,
+  queueName: string,
+  options: TaskOptions = {}
+): Task<T> {
+  const now = new Date();
+  const priority = options.priority ?? 5;
+
+  if (priority < 1 || priority > 10) {
+    throw new RangeError(`Priority must be between 1 and 10, got ${priority}`);
+  }
+
+  let availableAt: Date;
+  if (options.availableAt) {
+    availableAt = options.availableAt;
+  } else if (options.delay != null && options.delay > 0) {
+    availableAt = new Date(now.getTime() + options.delay);
+  } else {
+    availableAt = now;
+  }
+
+  return {
+    id: randomUUID(),
+    queueName,
+    payload,
+    status: 'pending',
+    priority,
+    createdAt: now,
+    availableAt,
+    attempts: 0,
+    maxRetries: options.maxRetries ?? 3,
+    baseDelay: options.baseDelay ?? 1000,
+    dependsOn: options.dependsOn ?? [],
+    progress: { percent: 0 },
+  };
+}
diff --git a/src/types.ts b/src/types.ts
new file mode 100644
index 0000000..f5c74b9
--- /dev/null
+++ b/src/types.ts
@@ -0,0 +1,73 @@
+export type TaskStatus =
+  | 'pending'
+  | 'processing'
+  | 'completed'
+  | 'failed'
+  | 'cancelled'
+  | 'blocked';
+
+export interface TaskOptions {
+  priority?: number;
+  delay?: number;
+  availableAt?: Date;
+  maxRetries?: number;
+  baseDelay?: number;
+  dependsOn?: string[];
+}
+
+export interface TaskProgress {
+  percent: number;
+  message?: string;
+}
+
+export interface Task<T = unknown> {
+  id: string;
+  queueName: string;
+  payload: T;
+  status: TaskStatus;
+  priority: number;
+  createdAt: Date;
+  availableAt: Date;
+  attempts: number;
+  maxRetries: number;
+  baseDelay: number;
+  dependsOn: string[];
+  progress: TaskProgress;
+  error?: Error;
+}
+
+export interface DeadLetterTask<T = unknown> extends Task<T> {
+  failedAt: Date;
+  totalAttempts: number;
+}
+
+export interface QueueStats {
+  name: string;
+  pending: number;
+  processing: number;
+  concurrencyLimit: number | null;
+  activeCount: number;
+}
+
+export type MiddlewareFn<T = unknown> = (
+  task: Task<T>,
+  next: () => Promise<void>
+) => Promise<void>;
+
+export type HandlerFn<T = unknown> = (task: Task<T>) => Promise<void>;
+
+export type ProgressListener = (progress: TaskProgress) => void;
+
+export interface Schedule {
+  id: string;
+  queueName: string;
+  cronExpression: string;
+  payload: unknown;
+  lastRun?: Date;
+}
+
+export interface ShutdownSummary {
+  completed: number;
+  forceCancelled: number;
+  durationMs: number;
+}
