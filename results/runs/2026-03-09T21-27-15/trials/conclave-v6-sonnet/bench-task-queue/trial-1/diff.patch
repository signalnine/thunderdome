k({});\n    const d2 = system.addTask({});\n    const child = system.addTask({}, { dependsOn: [d1.id, d2.id] });\n\n    const t1 = system.getNextTask()!;\n    system.completeTask(t1.id);\n    // child still blocked (d2 not done)\n    expect(system.getTask(child.id)?.status).toBe('blocked');\n\n    const t2 = system.getNextTask()!;\n    system.completeTask(t2.id);\n    expect(system.getTask(child.id)?.status).toBe('pending');\n  });\n\n  it('rejects dependency on non-existent task', () => {\n    expect(() =>\n      system.addTask({}, { dependsOn: ['nonexistent-id'] })\n    ).toThrow();\n  });\n\n  it('failed dependency does NOT fail its dependents', () => {\n    const dep = system.addTask({});\n    const child = system.addTask({}, { dependsOn: [dep.id] });\n    const task = system.getNextTask()!;\n    system.failTask(task.id, new Error('dep failed'));\n    // child should remain blocked, not failed\n    expect(system.getTask(child.id)?.status).toBe('blocked');\n  });\n\n  it('getTaskDependencyStatus shows resolved and pending deps', () => {\n    const d1 = system.addTask({});\n    const d2 = system.addTask({});\n    const child = system.addTask({}, { dependsOn: [d1.id, d2.id] });\n\n    const t1 = system.getNextTask()!;\n    system.completeTask(t1.id);\n\n    const status = system.getTaskDependencyStatus(child.id)!;\n    expect(status.resolvedDeps).toContain(d1.id);\n    expect(status.pendingDeps).toContain(d2.id);\n  });\n\n  it('getTaskDependencyStatus returns null for unknown task', () => {\n    expect(system.getTaskDependencyStatus('no-such-id')).toBeNull();\n  });\n\n  it('task with all deps already completed starts as pending', () => {\n    const dep = system.addTask({});\n    const depTask = system.getNextTask()!;\n    system.completeTask(depTask.id);\n    // Now add child that depends on already-completed dep\n    const child = system.addTask({}, { dependsOn: [dep.id] });\n    expect(child.status).toBe('pending');\n  });\n});\n"},"caller":{"type":"direct"}}],