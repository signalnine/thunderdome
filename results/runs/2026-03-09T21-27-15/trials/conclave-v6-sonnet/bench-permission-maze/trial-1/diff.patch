cuments/${doc.body.id}`).set(auth(bob.token));\n    expect(noAccess.status).toBe(403);\n\n    // Share folder with bob as viewer\n    await request(app)\n      .post(`/folders/${folder.body.id}/share`)\n      .set(auth(alice.token))\n      .send({ targetUserId: bob.userId, targetRole: 'viewer' });\n\n    const access = await request(app).get(`/documents/${doc.body.id}`).set(auth(bob.token));\n    expect(access.status).toBe(200);\n    expect(access.body.role).toBe('viewer');\n  });\n\n  it('most permissive role wins when multiple paths exist', async () => {\n    const app = makeApp();\n    const alice = await registerAndLogin(app, 'alice');\n    const bob = await registerAndLogin(app, 'bob');\n    const folder = await request(app).post('/folders').set(auth(alice.token)).send({ name: 'F' });\n    const doc = await request(app)\n      .post('/documents')\n      .set(auth(alice.token))\n      .send({ title: 'Doc', folderId: folder.body.id });\n\n    // Share folder as viewer\n    await request(app)\n      .post(`/folders/${folder.body.id}/share`)\n      .set(auth(alice.token))\n      .send({ targetUserId: bob.userId, targetRole: 'viewer' });\n\n    // Share document directly as editor\n    await request(app)\n      .post(`/documents/${doc.body.id}/share`)\n      .set(auth(alice.token))\n      .send({ targetUserId: bob.userId, targetRole: 'editor' });\n\n    const res = await request(app).get(`/documents/${doc.body.id}`).set(auth(bob.token));\n    expect(res.status).toBe(200);\n    expect(res.body.role).toBe('editor'); // editor wins over viewer\n\n    // Bob can edit (editor role)\n    const update = await request(app)\n      .patch(`/documents/${doc.body.id}`)\n      .set(auth(bob.token))\n      .send({ title: 'Bob edit' });\n    expect(update.status).toBe(200);\n  });\n\n  it('folder share propagates through nested folders', async () => {\n    const app = makeApp();\n    const alice = await registerAndLogin(app, 'alice');\n    const bob = await registerAndLogin(app, '