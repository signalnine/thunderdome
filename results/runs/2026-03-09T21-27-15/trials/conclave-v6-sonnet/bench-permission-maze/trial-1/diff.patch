dy.id });\n    await request(app)\n      .patch(`/documents/${doc.body.id}`)\n      .set(auth(token))\n      .send({ title: 'Updated' });\n\n    const res = await request(app).get('/activity').set(auth(token));\n    const entry = res.body.find((e: { action: string }) => e.action === 'document.updated');\n    expect(entry).toBeDefined();\n  });\n\n  it('logs document deletion', async () => {\n    const app = makeApp();\n    const { token } = await registerAndLogin(app);\n    const folder = await request(app).post('/folders').set(auth(token)).send({ name: 'F' });\n    const doc = await request(app)\n      .post('/documents')\n      .set(auth(token))\n      .send({ title: 'Doc', folderId: folder.body.id });\n    await request(app).delete(`/documents/${doc.body.id}`).set(auth(token));\n\n    const res = await request(app).get('/activity').set(auth(token));\n    const entry = res.body.find((e: { action: string }) => e.action === 'document.deleted');\n    expect(entry).toBeDefined();\n  });\n\n  it('logs sharing events', async () => {\n    const app = makeApp();\n    const alice = await registerAndLogin(app, 'alice');\n    const bob = await registerAndLogin(app, 'bob');\n    const folder = await request(app).post('/folders').set(auth(alice.token)).send({ name: 'F' });\n    await request(app)\n      .post(`/folders/${folder.body.id}/share`)\n      .set(auth(alice.token))\n      .send({ targetUserId: bob.userId, targetRole: 'viewer' });\n\n    const res = await request(app).get('/activity').set(auth(alice.token));\n    const entry = res.body.find((e: { action: string }) => e.action === 'folder.shared');\n    expect(entry).toBeDefined();\n  });\n\n  it('requires authentication to view activity', async () => {\n    const app = makeApp();\n    const res = await request(app).get('/activity');\n    expect(res.status).toBe(401);\n  });\n});\n","structuredPatch":[],"originalFile":null}}
