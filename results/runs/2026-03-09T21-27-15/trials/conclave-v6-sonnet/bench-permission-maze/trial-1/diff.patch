mission[] = [];\n  const activity: ActivityEntry[] = [];\n  return { users, tokens, folders, documents, permissions, activity };\n}\n\nexport type Store = ReturnType<typeof createStore>;\n\n// ─── Helpers ──────────────────────────────────────────────────────────────────\n\nfunction newId(): string {\n  return crypto.randomUUID();\n}\n\nfunction hashPassword(password: string): string {\n  return crypto.createHash('sha256').update(password).digest('hex');\n}\n\nfunction generateToken(): string {\n  return crypto.randomBytes(32).toString('hex');\n}\n\nconst ROLE_ORDER: Role[] = ['viewer', 'editor', 'owner'];\n\nfunction maxRole(a: Role, b: Role): Role {\n  return ROLE_ORDER.indexOf(a) >= ROLE_ORDER.indexOf(b) ? a : b;\n}\n\nfunction hasPermission(required: Role, effective: Role): boolean {\n  return ROLE_ORDER.indexOf(effective) >= ROLE_ORDER.indexOf(required);\n}\n\n// ─── Permission Resolution ────────────────────────────────────────────────────\n\nfunction getEffectiveDocumentRole(\n  store: Store,\n  userId: string,\n  doc: Document\n): Role | null {\n  let role: Role | null = null;\n\n  // Owner always has owner role\n  if (doc.ownerId === userId) {\n    role = 'owner';\n  }\n\n  // Direct document permissions\n  for (const p of store.permissions) {\n    if (p.resourceId === doc.id && p.resourceType === 'document' && p.userId === userId) {\n      role = role ? maxRole(role, p.role) : p.role;\n    }\n  }\n\n  // Folder permissions (traverse up the hierarchy)\n  let currentFolderId: string | null = doc.folderId;\n  while (currentFolderId) {\n    const folder = store.folders.get(currentFolderId);\n    if (!folder) break;\n\n    // Folder owner check\n    if (folder.ownerId === userId) {\n      role = role ? maxRole(role, 'owner') : 'owner';\n    }\n\n    for (const p of store.permissions) {\n      if (p.resourceId === currentFolderId && p.resourceType === 'folder' && p.userId === userId) {\n        role = role ? maxRole(role, p.role) : p.role;\n      }\n    }\n\n    currentFolderId = folder.parentId;\n  }\n\n  return role;\n}\n\nfunction getEffectiveFolderRole(\n  store: Store,\n  userId: string,\n  folder: Folder\n): Role | null {\n  let role: Role | null = null;\n\n  if (folder.ownerId === userId) {\n    role = 'owner';\n  }\n\n  // Direct folder permissions + ancestor folder permissions\n  let currentFolderId: string | null = folder.id;\n  while (currentFolderId) {\n    const f = store.folders.get(currentFolderId);\n    if (!f) break;\n\n    if (f.ownerId === userId && currentFolderId !== folder.id) {\n      role = role ? maxRole(role, 'owner') : 'owner';\n    }\n\n    for (const p of store.permissions) {\n      if (p.resourceId === currentFolderId && p.resourceType === 'folder' && p.userId === userId) {\n        role = role ? maxRole(role, p.role) : p.role;\n      }\n    }\n\n    currentFolderId = f.parentId;\n  }\n\n  return role;\n}\n\n// ─── Auth Middleware ──────────────────────────────────────────────────────────\n\nfunction makeAuthMiddleware(store: Store) {\n  return function requireAuth(req: Request, res: Response, next: NextFunction) {\n    const authHeader = req.headers.authorization;\n    if (!authHeader?.startsWith('Bearer ')) {\n      res.status(401).json({ error: 'Unauthorized' });\n      return;\n    }\n    const token = authHeader.slice(7);\n    const userId = store.tokens.get(token);\n    if (!userId) {\n      res.status(401).json({ error: 'Unauthorized' });\n      return;\n    }\n    res.locals.userId = userId;\n    next();\n  };\n}\n\n// ─── Activity Logging ─────────────────────────────────────────────────────────\n\nfunction logActivity(\n  store: Store,\n  action: string,\n  userId: string,\n  resourceId: string,\n  resourceType: string\n) {\n  store.activity.push({\n    id: newId(),\n    action,\n    userId,\n    resourceId,\n    resourceType,\n    timestamp: new Date(),\n  });\n}\n\n// ─── App Factory ──────────────────────────────────────────────────────────────\n\nexport function createApp(store: Store = createStore()): express.Application {\n  const app = express();\n  app.use(express.json());\n\n  const requireAuth = makeAuthMiddleware(store);\n\n  // ── Auth Routes ────────────────────────────────────────────────────────────\n\n  app.post('/auth/register', (req: Request, res: Response) => {\n    const { username, password } = req.body;\n    if (!username || !password) {\n      res.status(400).json({ error: 'username and password are required' });\n      return;\n    }\n\n    // Check uniqueness\n    for (const u of store.users.values()) {\n      if (u.username === username) {\n        res.status(409).json({ error: 'Username already taken' });\n        return;\n      }\n    }\n\n    const user: User = {\n      id: newId(),\n      username,\n      passwordHash: hashPassword(password),\n    };\n    store.users.set(user.id, user);\n    res.status(201).json({ id: user.id, username: user.username });\n  });\n\n  app.post('/auth/login', (req: Request, res: Response) => {\n    const { username, password } = req.body;\n    if (!username || !password) {\n      res.status(400).json({ error: 'username and password are required' });\n      return;\n    }\n\n    let found: User | null = null;\n    for (const u of store.users.values()) {\n      if (u.username === username) { found = u; break; }\n    }\n\n    if (!found || found.passwordHash !== hashPassword(password)) {\n      res.status(401).json({ error: 'Invalid credentials' });\n      return;\n    }\n\n    const token = generateToken();\n    store.tokens.set(token, found.id);\n    res.json({ token, userId: found.id });\n  });\n\n  // ── Folder Routes ──────────────────────────────────────────────────────────\n\n  app.post('/folders', requireAuth, (req: Request, res: Response) => {\n    const userId = res.locals.userId as string;\n    const { name, parentId } = req.body;\n\n    if (!name) {\n      res.status(400).json({ error: 'name is required' });\n      return;\n    }\n\n    if (parentId) {\n      const parent = s