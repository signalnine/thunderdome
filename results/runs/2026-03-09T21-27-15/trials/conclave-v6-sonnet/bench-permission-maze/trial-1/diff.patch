+{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01Qzb7raapPtR6L8J5RmF9Kx","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01KjQuYmHZMJ5MciAkrBzGXv","name":"Write","input":{"file_path":"/workspace/src/app.ts","content":"import express, { Request, Response, NextFunction } from 'express';\nimport crypto from 'crypto';\n\n// ─── Types ────────────────────────────────────────────────────────────────────\n\ntype Role = 'viewer' | 'editor' | 'owner';\n\ninterface User {\n  id: string;\n  username: string;\n  passwordHash: string;\n}\n\ninterface Folder {\n  id: string;\n  name: string;\n  parentId: string | null;\n  ownerId: string;\n  createdAt: Date;\n}\n\ninterface Document {\n  id: string;\n  title: string;\n  content: string;\n  folderId: string;\n  ownerId: string;\n  createdAt: Date;\n  updatedAt: Date;\n}\n\ninterface Permission {\n  userId: string;\n  resourceId: string;\n  resourceType: 'folder' | 'document';\n  role: Role;\n}\n\ninterface ActivityEntry {\n  id: string;\n  action: string;\n  userId: string;\n  resourceId: string;\n  resourceType: string;\n  timestamp: Date;\n}\n\n// ─── In-Memory Storage ────────────────────────────────────────────────────────\n\nfunction createStore() {\n  const users = new Map<string, User>();\n  const tokens = new Map<string, string>(); // token → userId\n  const folders = new Map<string, Folder>();\n  const documents = new Map<string, Document>();\n  const permissions: Permission[] = [];\n  const activity: ActivityEntry[] = [];\n  return { users, tokens, folders, documents, permissions, activity };\n}\n\nexport type Store = ReturnType<typeof createStore>;\n\n// ─── Helpers ──────────────────────────────────────────────────────────────────\n\nfunction newId(): string {\n  return crypto.randomUUID();\n}\n\nfunction hashPassword(password: string): string {\n  return crypto.createHash('sha256').update(password).digest('hex');\n}\n\nfunction generateToken(): string {\n  return crypto.randomBytes(32).toString('hex');\n}\n\nconst ROLE_ORDER: Role[] = ['viewer', 'editor', 'owner'];\n\nfunction maxRole(a: Role, b: Role): Role {\n  return ROLE_ORDER.indexOf(a) >= ROLE_ORDER.indexOf(b) ? a : b;\n}\n\nfunction hasPermission(required: Role, effective: Role): boolean {\n  return ROLE_ORDER.indexOf(effective) >= ROLE_ORDER.indexOf(required);\n}\n\n// ─── Permission Resolution ────────────────────────────────────────────────────\n\nfunction getEffectiveDocumentRole(\n  store: Store,\n  userId: string,\n  doc: Document\n): Role | null {\n  let role: Role | null = null;\n\n  // Owner always has owner role\n  if (doc.ownerId === userId) {\n    role = 'owner';\n  }\n\n  // Direct document permissions\n  for (const p of store.permissions) {\n    if (p.resourceId === doc.id && p.resourceType === 'document' && p.userId === userId) {\n      role = role ? maxRole(role, p.role) : p.role;\n    }\n  }\n\n  // Folder permissions (traverse up the hierarchy)\n  let currentFolderId: string | null = doc.folderId;\n  while (currentFolderId) {\n    const folder = store.folders.get(currentFolderId);\n    if (!folder) break;\n\n    // Folder owner check\n    if (folder.ownerId === userId) {\n      role = role ? maxRole(role, 'owner') : 'owner';\n    }\n\n    for (const p of store.permissions) {\n      if (p.resourceId === currentFolderId && p.resourceType === 'folder' && p.userId === userId) {\n        role = role ? maxRole(role, p.role) : p.role;\n      }\n    }\n\n    currentFolderId = folder.parentId;\n  }\n\n  return role;\n}\n\nfunction getEffectiveFolderRole(\n  store: Store,\n  userId: string,\n  folder: Folder\n): Role | null {\n  let role: Role | null = null;\n\n  if (folder.ownerId === userId) {\n    role = 'owner';\n  }\n\n  // Direct folder permissions + ancestor folder permissions\n  let currentFolderId: string | null = folder.id;\n  while (currentFolderId) {\n    const f = store.folders.get(currentFolderId);\n    if (!f) break;\n\n    if (f.ownerId === userId && currentFolderId !== folder.id) {\n      role = role ? maxRole(role, 'owner') : 'owner';\n    }\n\n    for (const p of store.permissions) {\n      if (p.resourceId === currentFolderId && p.resourceType === 'folder' && p.userId === userId) {\n        role = role ? maxRole(role, p.role) : p.role;\n      }\n    }\n\n    currentFolderId = f.parentId;\n  }\n\n  return role;\n}\n\n// ─── Auth Middleware ──────────────────────────────────────────────────────────\n\nfunction makeAuthMiddleware(store: Store) {\n  return function requireAuth(req: Request, res: Response, next: NextFunction) {\n    const authHeader = req.headers.authorization;\n    if (!authHeader?.startsWith('Bearer ')) {\n      res.status(401).json({ error: 'Unauthorized' });\n      return;\n    }\n    const token = authHeader.slice(7);\n    const userId = store.tokens.get(token);\n    if (!userId) {\n      res.status(401).json({ error: 'Unauthorized' });\n      return;\n    }\n    res.locals.userId = userId;\n    next();\n  };\n}\n\n// ─── Activity Logging ─────────────────────────────────────────────────────────\n\nfunction logActivity(\n  store: Store,\n  action: string,\n  userId: string,\n  resourceId: string,\n  resourceType: string\n) {\n  store.activity.push({\n    id: newId(),\n    action,\n    userId,\n    resourceId,\n    resourceType,\n    timestamp: new Date(),\n  });\n}\n\n// ─── App Factory ──────────────────────────────────────────────────────────────\n\nexport function createApp(store: Store = createStore()): express.Application {\n  const app = express();\n  app.use(express.json());\n\n  const requireAuth = makeAuthMiddleware(store);\n\n  // ── Auth Routes ────────────────────────────────────────────────────────────\n\n  app.post('/auth/register', (req: Request, res: Response) => {\n    const { username, password } = req.body;\n    if (!username || !password) {\n      res.status(400).json({ error: 'username and password are required' });\n      return;\n    }\n\n    // Check uniqueness\n    for (const u of store.users.values()) {\n      if (u.username === username) {\n        res.status(409).json({ error: 'Username already taken' });\n        return;\n      }\n    }\n\n    const user: User = {\n      id: newId(),\n      username,\n      passwordHash: hashPassword(password),\n    };\n    store.users.set(user.id, user);\n    res.status(201).json({ id: user.id, username: user.username });\n  });\n\n  app.post('/auth/login', (req: Request, res: Response) => {\n    const { username, password } = req.body;\n    if (!username || !password) {\n      res.status(400).json({ error: 'username and password are required' });\n      return;\n    }\n\n    let found: User | null = null;\n    for (const u of store.users.values()) {\n      if (u.username === username) { found = u; break; }\n    }\n\n    if (!found || found.passwordHash !== hashPassword(password)) {\n      res.status(401).json({ error: 'Invalid credentials' });\n      return;\n    }\n\n    const token = generateToken();\n    store.tokens.set(token, found.id);\n    res.json({ token, userId: found.id });\n  });\n\n  // ── Folder Routes ──────────────────────────────────────────────────────────\n\n  app.post('/folders', requireAuth, (req: Request, res: Response) => {\n    const userId = res.locals.userId as string;\n    const { name, parentId } = req.body;\n\n    if (!name) {\n      res.status(400).json({ error: 'name is required' });\n      return;\n    }\n\n    if (parentId) {\n      const parent = store.folders.get(parentId);\n      if (!parent) {\n        res.status(404).json({ error: 'Parent folder not found' });\n        return;\n      }\n      // User must have at least editor access to parent to create a child\n      const parentRole = getEffectiveFolderRole(store, userId, parent);\n      if (!parentRole || !hasPermission('editor', parentRole)) {\n        res.status(403).json({ error: 'Forbidden' });\n        return;\n      }\n    }\n\n    const folder: Folder = {\n      id: newId(),\n      name,\n      parentId: parentId ?? null,\n      ownerId: userId,\n      createdAt: new Date(),\n    };\n    store.folders.set(folder.id, folder);\n\n    res.status(201).json(folder);\n  });\n\n  app.get('/folders/:id', requireAuth, (req: Request, res: Response) => {\n    const userId = res.locals.userId as string;\n    const folder = store.folders.get(req.params.id);\n    if (!folder) { res.status(404).json({ error: 'Folder not found' }); return; }\n\n    const role = getEffectiveFolderRole(store, userId, folder);\n    if (!role) { res.status(403).json({ error: 'Forbidden' }); return; }\n\n    res.json({ ...folder, role });\n  });\n\n  app.patch('/folders/:id', requireAuth, (req: Request, res: Response) => {\n    const userId = res.locals.userId as string;\n    const folder = store.folders.get(req.params.id);\n    if (!folder) { res.status(404).json({ error: 'Folder not found' }); return; }\n\n    const role = getEffectiveFolderRole(store, userId, folder);\n    if (!role || !hasPermission('editor', role)) {\n      res.status(403).json({ error: 'Forbidden' }); return;\n    }\n\n    if (req.body.name !== undefined) folder.name = req.body.name;\n    res.json(folder);\n  });\n\n  app.delete('/folders/:id', requireAuth, (req: Request, res: Response) => {\n    const userId = res.locals.userId as string;\n    const folder = store.folders.get(req.params.id);\n    if (!folder) { res.status(404).json({ error: 'Folder not found' }); return; }\n\n    const role = getEffectiveFolderRole(store, userId, folder);\n    if (!role || !hasPermission('owner', role)) {\n      res.status(403).json({ error: 'Forbidden' }); return;\n    }\n\n    store.folders.delete(folder.id);\n    // Remove associated permissions\n    const toRemove = store.permissions.filter(\n      p => p.resourceId === folder.id && p.resourceType === 'folder'\n    );\n    for (const p of toRemove) {\n      store.permissions.splice(store.permissions.indexOf(p), 1);\n    }\n\n    res.status(204).send();\n  });\n\n  // ── Document Routes ────────────────────────────────────────────────────────\n\n  app.post('/documents', requireAuth, (req: Request, res: Response) => {\n    const userId = res.locals.userId as string;\n    const { title, content, folderId } = req.body;\n\n    if (!title || !folderId) {\n      res.status(400).json({ error: 'title and folderId are required' });\n      return;\n    }\n\n    const folder = store.folders.get(folderId);\n    if (!folder) { res.status(404).json({ error: 'Folder not found' }); return; }\n\n    const folderRole = getEffectiveFolderRole(store, userId, folder);\n    if (!folderRole || !hasPermission('editor', folderRole)) {\n      res.status(403).json({ error: 'Forbidden' }); return;\n    }\n\n    const doc: Document = {\n      id: newId(),\n      title,\n      content: content ?? '',\n      folderId,\n      ownerId: userId,\n      createdAt: new Date(),\n      updatedAt: new Date(),\n    };\n    store.documents.set(doc.id, doc);\n\n    logActivity(store, 'document.created', userId, doc.id, 'document');\n\n    res.status(201).json(doc);\n  });\n\n  app.get('/documents/:id', requireAuth, (req: Request, res: Response) => {\n    const userId = res.locals.userId as string;\n    const doc = store.documents.get(req.params.id);\n    if (!doc) { res.status(404).json({ error: 'Document not found' }); return; }\n\n    const role = getEffectiveDocumentRole(store, userId, doc);\n    if (!role) { res.status(403).json({ error: 'Forbidden' }); return; }\n\n    res.json({ ...doc, role });\n  });\n\n  app.patch('/documents/:id', requireAuth, (req: Request, res: Response) => {\n    const userId = res.locals.userId as string;\n    const doc = store.documents.get(req.params.id);\n    if (!doc) { res.status(404).json({ error: 'Document not found' }); return; }\n\n    const role = getEffectiveDocumentRole(store, userId, doc);\n    if (!role || !hasPermission('editor', role)) {\n      res.status(403).json({ error: 'Forbidden' }); return;\n    }\n\n    if (req.body.title !== undefined) doc.title = req.body.title;\n    if (req.body.content !== undefined) doc.content = req.body.content;\n    doc.updatedAt = new Date();\n\n    logActivity(store, 'document.updated', userId, doc.id, 'document');\n\n    res.json(doc);\n  });\n\n  app.delete('/documents/:id', requireAuth, (req: Request, res: Response) => {\n    const userId = res.locals.userId as string;\n    const doc = store.documents.get(req.params.id);\n    if (!doc) { res.status(404).json({ error: 'Document not found' }); return; }\n\n    const role = getEffectiveDocumentRole(store, userId, doc);\n    if (!role || !hasPermission('owner', role)) {\n      res.status(403).json({ error: 'Forbidden' }); return;\n    }\n\n    store.documents.delete(doc.id);\n    const toRemove = store.permissions.filter(\n      p => p.resourceId === doc.id && p.resourceType === 'document'\n    );\n    for (const p of toRemove) {\n      store.permissions.splice(store.permissions.indexOf(p), 1);\n    }\n\n    logActivity(store, 'document.deleted', userId, doc.id, 'document');\n\n    res.status(204).send();\n  });\n\n  // ── Sharing Routes ─────────────────────────────────────────────────────────\n\n  // POST /folders/:id/share\n  app.post('/folders/:id/share', requireAuth, (req: Request, res: Response) => {\n    const userId = res.locals.userId as string;\n    const folder = store.folders.get(req.params.id);\n    if (!folder) { res.status(404).json({ error: 'Folder not found' }); return; }\n\n    const role = getEffectiveFolderRole(store, userId, folder);\n    if (!role || !hasPermission('editor', role)) {\n      res.status(403).json({ error: 'Forbidden' }); return;\n    }\n\n    const { targetUserId, targetRole } = req.body as { targetUserId: string; targetRole: Role };\n    if (!targetUserId || !targetRole) {\n      res.status(400).json({ error: 'targetUserId and targetRole are required' });\n      return;\n    }\n    if (!ROLE_ORDER.includes(targetRole)) {\n      res.status(400).json({ error: 'Invalid role' }); return;\n    }\n\n    // Editors cannot grant owner role\n    if (targetRole === 'owner' && !hasPermission('owner', role)) {\n      res.status(403).json({ error: 'Editors cannot grant owner role' }); return;\n    }\n\n    if (!store.users.has(targetUserId)) {\n      res.status(404).json({ error: 'Target user not found' }); return;\n    }\n\n    // Upsert permission\n    const existing = store.permissions.find(\n      p => p.resourceId === folder.id && p.resourceType === 'folder' && p.userId === targetUserId\n    );\n    if (existing) {\n      existing.role = targetRole;\n    } else {\n      store.permissions.push({\n        userId: targetUserId,\n        resourceId: folder.id,\n        resourceType: 'folder',\n        role: targetRole,\n      });\n    }\n\n    logActivity(store, 'folder.shared', userId, folder.id, 'folder');\n\n    res.status(201).json({ resourceId: folder.id, resourceType: 'folder', targetUserId, role: targetRole });\n  });\n\n  // POST /documents/:id/share\n  app.post('/documents/:id/share', requireAuth, (req: Request, res: Response) => {\n    const userId = res.locals.userId as string;\n    const doc = store.documents.get(req.params.id);\n    if (!doc) { res.status(404).json({ error: 'Document not found' }); return; }\n\n    const role = getEffectiveDocumentRole(store, userId, doc);\n    if (!role || !hasPermission('editor', role)) {\n      res.status(403).json({ error: 'Forbidden' }); return;\n    }\n\n    const { targetUserId, targetRole } = req.body as { targetUserId: string; targetRole: Role };\n    if (!targetUserId || !targetRole) {\n      res.status(400).json({ error: 'targetUserId and targetRole are required' });\n      return;\n    }\n    if (!ROLE_ORDER.includes(targetRole)) {\n      res.status(400).json({ error: 'Invalid role' }); return;\n    }\n\n    if (targetRole === 'owner' && !hasPermission('owner', role)) {\n      res.status(403).json({ error: 'Editors cannot grant owner role' }); return;\n    }\n\n    if (!store.users.has(targetUserId)) {\n      res.status(404).json({ error: 'Target user not found' }); return;\n    }\n\n    const existing = store.permissions.find(\n      p => p.resourceId === doc.id && p.resourceType === 'document' && p.userId === targetUserId\n    );\n    if (existing) {\n      existing.role = targetRole;\n    } else {\n      store.permissions.push({\n        userId: targetUserId,\n        resourceId: doc.id,\n        resourceType: 'document',\n        role: targetRole,\n      });\n    }\n\n    logActivity(store, 'document.shared', userId, doc.id, 'document');\n\n    res.status(201).json({ resourceId: doc.id, resourceType: 'document', targetUserId, role: targetRole });\n  });\n\n  // ── Activity Log ───────────────────────────────────────────────────────────\n\n  app.get('/activity', requireAuth, (req: Request, res: Response) => {\n    const userId = res.locals.userId as string;\n    // Return all activity (or filter by query params in future)\n    const { resourceId, resourceType } = req.query;\n    let entries = store.activity.slice();\n\n    if (resourceId) entries = entries.filter(e => e.resourceId === resourceId);\n    if (resourceType) entries = entries.filter(e => e.resourceType === resourceType);\n\n    // Only show entries the user has access to (owner sees all, others see what they can access)\n    // For simplicity: return all entries (log is global, admin-style)\n    res.json(entries);\n  });\n\n  return app;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":476,"cache_read_input_tokens":22641,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":476},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"729cc72d-cb4b-4fa9-bd7a-85748bbb676c","uuid":"4769f252-48f9-4ecc-a896-7f50b1a9c018"}
+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KjQuYmHZMJ5MciAkrBzGXv","type":"tool_result","content":"File created successfully at: /workspace/src/app.ts"}]},"parent_tool_use_id":null,"session_id":"729cc72d-cb4b-4fa9-bd7a-85748bbb676c","uuid":"a8ccf792-c599-4fff-ad53-c8738785d328","tool_use_result":{"type":"create","filePath":"/workspace/src/app.ts","content":"import express, { Request, Response, NextFunction } from 'express';\nimport crypto from 'crypto';\n\n// ─── Types ────────────────────────────────────────────────────────────────────\n\ntype Role = 'viewer' | 'editor' | 'owner';\n\ninterface User {\n  id: string;\n  username: string;\n  passwordHash: string;\n}\n\ninterface Folder {\n  id: string;\n  name: string;\n  parentId: string | null;\n  ownerId: string;\n  createdAt: Date;\n}\n\ninterface Document {\n  id: string;\n  title: string;\n  content: string;\n  folderId: string;\n  ownerId: string;\n  createdAt: Date;\n  updatedAt: Date;\n}\n\ninterface Permission {\n  userId: string;\n  resourceId: string;\n  resourceType: 'folder' | 'document';\n  role: Role;\n}\n\ninterface ActivityEntry {\n  id: string;\n  action: string;\n  userId: string;\n  resourceId: string;\n  resourceType: string;\n  timestamp: Date;\n}\n\n// ─── In-Memory Storage ────────────────────────────────────────────────────────\n\nfunction createStore() {\n  const users = new Map<string, User>();\n  const tokens = new Map<string, string>(); // token → userId\n  const folders = new Map<string, Folder>();\n  const documents = new Map<string, Document>();\n  const permissions: Permission[] = [];\n  const activity: ActivityEntry[] = [];\n  return { users, tokens, folders, documents, permissions, activity };\n}\n\nexport type Store = ReturnType<typeof createStore>;\n\n// ─── Helpers ──────────────────────────────────────────────────────────────────\n\nfunction newId(): string {\n  return crypto.randomUUID();\n}\n\nfunction hashPassword(password: string): string {\n  return crypto.createHash('sha256').update(password).digest('hex');\n}\n\nfunction generateToken(): string {\n  return crypto.randomBytes(32).toString('hex');\n}\n\nconst ROLE_ORDER: Role[] = ['viewer', 'editor', 'owner'];\n\nfunction maxRole(a: Role, b: Role): Role {\n  return ROLE_ORDER.indexOf(a) >= ROLE_ORDER.indexOf(b) ? a : b;\n}\n\nfunction hasPermission(required: Role, effective: Role): boolean {\n  return ROLE_ORDER.indexOf(effective) >= ROLE_ORDER.indexOf(required);\n}\n\n// ─── Permission Resolution ────────────────────────────────────────────────────\n\nfunction getEffectiveDocumentRole(\n  store: Store,\n  userId: string,\n  doc: Document\n): Role | null {\n  let role: Role | null = null;\n\n  // Owner always has owner role\n  if (doc.ownerId === userId) {\n    role = 'owner';\n  }\n\n  // Direct document permissions\n  for (const p of store.permissions) {\n    if (p.resourceId === doc.id && p.resourceType === 'document' && p.userId === userId) {\n      role = role ? maxRole(role, p.role) : p.role;\n    }\n  }\n\n  // Folder permissions (traverse up the hierarchy)\n  let currentFolderId: string | null = doc.folderId;\n  while (currentFolderId) {\n    const folder = store.folders.get(currentFolderId);\n    if (!folder) break;\n\n    // Folder owner check\n    if (folder.ownerId === userId) {\n      role = role ? maxRole(role, 'owner') : 'owner';\n    }\n\n    for (const p of store.permissions) {\n      if (p.resourceId === currentFolderId && p.resourceType === 'folder' && p.userId === userId) {\n        role = role ? maxRole(role, p.role) : p.role;\n      }\n    }\n\n    currentFolderId = folder.parentId;\n  }\n\n  return role;\n}\n\nfunction getEffectiveFolderRole(\n  store: Store,\n  userId: string,\n  folder: Folder\n): Role | null {\n  let role: Role | null = null;\n\n  if (folder.ownerId === userId) {\n    role = 'owner';\n  }\n\n  // Direct folder permissions + ancestor folder permissions\n  let currentFolderId: string | null = folder.id;\n  while (currentFolderId) {\n    const f = store.folders.get(currentFolderId);\n    if (!f) break;\n\n    if (f.ownerId === userId && currentFolderId !== folder.id) {\n      role = role ? maxRole(role, 'owner') : 'owner';\n    }\n\n    for (const p of store.permissions) {\n      if (p.resourceId === currentFolderId && p.resourceType === 'folder' && p.userId === userId) {\n        role = role ? maxRole(role, p.role) : p.role;\n      }\n    }\n\n    currentFolderId = f.parentId;\n  }\n\n  return role;\n}\n\n// ─── Auth Middleware ──────────────────────────────────────────────────────────\n\nfunction makeAuthMiddleware(store: Store) {\n  return function requireAuth(req: Request, res: Response, next: NextFunction) {\n    const authHeader = req.headers.authorization;\n    if (!authHeader?.startsWith('Bearer ')) {\n      res.status(401).json({ error: 'Unauthorized' });\n      return;\n    }\n    const token = authHeader.slice(7);\n    const userId = store.tokens.get(token);\n    if (!userId) {\n      res.status(401).json({ error: 'Unauthorized' });\n      return;\n    }\n    res.locals.userId = userId;\n    next();\n  };\n}\n\n// ─── Activity Logging ─────────────────────────────────────────────────────────\n\nfunction logActivity(\n  store: Store,\n  action: string,\n  userId: string,\n  resourceId: string,\n  resourceType: string\n) {\n  store.activity.push({\n    id: newId(),\n    action,\n    userId,\n    resourceId,\n    resourceType,\n    timestamp: new Date(),\n  });\n}\n\n// ─── App Factory ──────────────────────────────────────────────────────────────\n\nexport function createApp(store: Store = createStore()): express.Application {\n  const app = express();\n  app.use(express.json());\n\n  const requireAuth = makeAuthMiddleware(store);\n\n  // ── Auth Routes ────────────────────────────────────────────────────────────\n\n  app.post('/auth/register', (req: Request, res: Response) => {\n    const { username, password } = req.body;\n    if (!username || !password) {\n      res.status(400).json({ error: 'username and password are required' });\n      return;\n    }\n\n    // Check uniqueness\n    for (const u of store.users.values()) {\n      if (u.username === username) {\n        res.status(409).json({ error: 'Username already taken' });\n        return;\n      }\n    }\n\n    const user: User = {\n      id: newId(),\n      username,\n      passwordHash: hashPassword(password),\n    };\n    store.users.set(user.id, user);\n    res.status(201).json({ id: user.id, username: user.username });\n  });\n\n  app.post('/auth/login', (req: Request, res: Response) => {\n    const { username, password } = req.body;\n    if (!username || !password) {\n      res.status(400).json({ error: 'username and password are required' });\n      return;\n    }\n\n    let found: User | null = null;\n    for (const u of store.users.values()) {\n      if (u.username === username) { found = u; break; }\n    }\n\n    if (!found || found.passwordHash !== hashPassword(password)) {\n      res.status(401).json({ error: 'Invalid credentials' });\n      return;\n    }\n\n    const token = generateToken();\n    store.tokens.set(token, found.id);\n    res.json({ token, userId: found.id });\n  });\n\n  // ── Folder Routes ──────────────────────────────────────────────────────────\n\n  app.post('/folders', requireAuth, (req: Request, res: Response) => {\n    const userId = res.locals.userId as string;\n    const { name, parentId } = req.body;\n\n    if (!name) {\n      res.status(400).json({ error: 'name is required' });\n      return;\n    }\n\n    if (parentId) {\n      const parent = store.folders.get(parentId);\n      if (!parent) {\n        res.status(404).json({ error: 'Parent folder not found' });\n        return;\n      }\n      // User must have at least editor access to parent to create a child\n      const parentRole = getEffectiveFolderRole(store, userId, parent);\n      if (!parentRole || !hasPermission('editor', parentRole)) {\n        res.status(403).json({ error: 'Forbidden' });\n        return;\n      }\n    }\n\n    const folder: Folder = {\n      id: newId(),\n      name,\n      parentId: parentId ?? null,\n      ownerId: userId,\n      createdAt: new Date(),\n    };\n    store.folders.set(folder.id, folder);\n\n    res.status(201).json(folder);\n  });\n\n  app.get('/folders/:id', requireAuth, (req: Request, res: Response) => {\n    const userId = res.locals.userId as string;\n    const folder = store.folders.get(req.params.id);\n    if (!folder) { res.status(404).json({ error: 'Folder not found' }); return; }\n\n    const role = getEffectiveFolderRole(store, userId, folder);\n    if (!role) { res.status(403).json({ error: 'Forbidden' }); return; }\n\n    res.json({ ...folder, role });\n  });\n\n  app.patch('/folders/:id', requireAuth, (req: Request, res: Response) => {\n    const userId = res.locals.userId as string;\n    const folder = store.folders.get(req.params.id);\n    if (!folder) { res.status(404).json({ error: 'Folder not found' }); return; }\n\n    const role = getEffectiveFolderRole(store, userId, folder);\n    if (!role || !hasPermission('editor', role)) {\n      res.status(403).json({ error: 'Forbidden' }); return;\n    }\n\n    if (req.body.name !== undefined) folder.name = req.body.name;\n    res.json(folder);\n  });\n\n  app.delete('/folders/:id', requireAuth, (req: Request, res: Response) => {\n    const userId = res.locals.userId as string;\n    const folder = store.folders.get(req.params.id);\n    if (!folder) { res.status(404).json({ error: 'Folder not found' }); return; }\n\n    const role = getEffectiveFolderRole(store, userId, folder);\n    if (!role || !hasPermission('owner', role)) {\n      res.status(403).json({ error: 'Forbidden' }); return;\n    }\n\n    store.folders.delete(folder.id);\n    // Remove associated permissions\n    const toRemove = store.permissions.filter(\n      p => p.resourceId === folder.id && p.resourceType === 'folder'\n    );\n    for (const p of toRemove) {\n      store.permissions.splice(store.permissions.indexOf(p), 1);\n    }\n\n    res.status(204).send();\n  });\n\n  // ── Document Routes ────────────────────────────────────────────────────────\n\n  app.post('/documents', requireAuth, (req: Request, res: Response) => {\n    const userId = res.locals.userId as string;\n    const { title, content, folderId } = req.body;\n\n    if (!title || !folderId) {\n      res.status(400).json({ error: 'title and folderId are required' });\n      return;\n    }\n\n    const folder = store.folders.get(folderId);\n    if (!folder) { res.status(404).json({ error: 'Folder not found' }); return; }\n\n    const folderRole = getEffectiveFolderRole(store, userId, folder);\n    if (!folderRole || !hasPermission('editor', folderRole)) {\n      res.status(403).json({ error: 'Forbidden' }); return;\n    }\n\n    const doc: Document = {\n      id: newId(),\n      title,\n      content: content ?? '',\n      folderId,\n      ownerId: userId,\n      createdAt: new Date(),\n      updatedAt: new Date(),\n    };\n    store.documents.set(doc.id, doc);\n\n    logActivity(store, 'document.created', userId, doc.id, 'document');\n\n    res.status(201).json(doc);\n  });\n\n  app.get('/documents/:id', requireAuth, (req: Request, res: Response) => {\n    const userId = res.locals.userId as string;\n    const doc = store.documents.get(req.params.id);\n    if (!doc) { res.status(404).json({ error: 'Document not found' }); return; }\n\n    const role = getEffectiveDocumentRole(store, userId, doc);\n    if (!role) { res.status(403).json({ error: 'Forbidden' }); return; }\n\n    res.json({ ...doc, role });\n  });\n\n  app.patch('/documents/:id', requireAuth, (req: Request, res: Response) => {\n    const userId = res.locals.userId as string;\n    const doc = store.documents.get(req.params.id);\n    if (!doc) { res.status(404).json({ error: 'Document not found' }); return; }\n\n    const role = getEffectiveDocumentRole(store, userId, doc);\n    if (!role || !hasPerm