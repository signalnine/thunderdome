hit by a different branch that also sends down-right to col X\n+    //\n+    // S at (0,3)\n+    // ^ at (1,3): sends (2,2,down-left) and (2,4,down-right)\n+    // ^ at (2,2): sends (3,1,down-left) and (3,3,down-right)\n+    // ^ at (2,4): sends (3,3,down-left) and (3,5,down-right)\n+    // Both (3,3,down-right) from (2,2) and (3,3,down-left) from (2,4) arrive at (3,3) but different dirs\n+    // Actually to get same dir convergence: need two beams both going down-right to same cell\n+    //\n+    // Simpler: paths through a diamond\n+    //   S at (0,3)\n+    //   ^ at (1,3) -> (2,2,DL) and (2,4,DR)\n+    //   ^ at (2,2) -> (3,1,DL) and (3,3,DR)\n+    //   ^ at (2,4) -> (3,3,DL) and (3,5,DR)\n+    //   Total paths = 4 (each leaf exits grid)\n+    const grid = [\n+      ['.', '.', '.', 'S', '.', '.', '.'],\n+      ['.', '.', '.', '^', '.', '.', '.'],\n+      ['.', '.', '^', '.', '^', '.', '.'],\n+      ['.', '.', '.', '.', '.', '.', '.'],\n+    ];\n+    // From (2,2)^: -> (3,1) and (3,3)\n+    // From (2,4)^: -> (3,3) and (3,5)\n+    // All 4 beams exit at row 4 (out of bounds) -> 4 paths\n+    expect(countBeamPaths(grid)).toBe(4n);\n+    // Cells: (0,3),(1,3),(2,2),(2,4),(3,1),(3,3),(3,5) = 7\n+    expect(countBeamCells(grid)).toBe(7);\n+  });\n+\n+  test('performance: 200x200 grid with 50 splitters completes under 5 seconds', () => {\n+    const rows = 200;\n+    const cols = 200;\n+    const grid: string[][] = Array.from({ length: rows }, () => Array(cols).fill('.'));\n+    grid[0][100] = 'S';\n+\n+    // Place 50 splitters in a binary-tree pattern along the beam paths\n+    // Row 1: col 100 (directly below S)\n+    // Then spread out in a pattern that stays in bounds\n+    let splitterCount = 0;\n+    const positions: [number, number][] = [[1, 100]];\n+    const nextPositions: [number, number][] = [];\n+\n+    for (const [r, c] of positions) {\n+      if (splitterCount >= 50) break;\n+      if (r < rows && c >= 0 && c < cols) {\n+        grid[r][c] = '^';\n+   