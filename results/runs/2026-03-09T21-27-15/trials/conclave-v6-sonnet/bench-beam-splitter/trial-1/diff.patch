onst grid = [\n      ['.', '.', '.', 'S', '.', '.', '.'],\n      ['.', '.', '.', '^', '.', '.', '.'],\n      ['.', '.', '^', '.', '^', '.', '.'],\n      ['.', '.', '.', '.', '.', '.', '.'],\n    ];\n    // From (2,2)^: -> (3,1) and (3,3)\n    // From (2,4)^: -> (3,3) and (3,5)\n    // All 4 beams exit at row 4 (out of bounds) -> 4 paths\n    expect(countBeamPaths(grid)).toBe(4n);\n    // Cells: (0,3),(1,3),(2,2),(2,4),(3,1),(3,3),(3,5) = 7\n    expect(countBeamCells(grid)).toBe(7);\n  });\n\n  test('performance: 200x200 grid with 50 splitters completes under 5 seconds', () => {\n    const rows = 200;\n    const cols = 200;\n    const grid: string[][] = Array.from({ length: rows }, () => Array(cols).fill('.'));\n    grid[0][100] = 'S';\n\n    // Place 50 splitters in a binary-tree pattern along the beam paths\n    // Row 1: col 100 (directly below S)\n    // Then spread out in a pattern that stays in bounds\n    let splitterCount = 0;\n    const positions: [number, number][] = [[1, 100]];\n    const nextPositions: [number, number][] = [];\n\n    for (const [r, c] of positions) {\n      if (splitterCount >= 50) break;\n      if (r < rows && c >= 0 && c < cols) {\n        grid[r][c] = '^';\n        splitterCount++;\n        if (r + 2 < rows) {\n          if (c - 1 >= 0) nextPositions.push([r + 2, c - 1]);\n          if (c + 1 < cols) nextPositions.push([r + 2, c + 1]);\n        }\n      }\n    }\n\n    // Add more splitters from next level\n    for (const [r, c] of nextPositions) {\n      if (splitterCount >= 50) break;\n      if (r < rows && c >= 0 && c < cols && grid[r][c] === '.') {\n        grid[r][c] = '^';\n        splitterCount++;\n      }\n    }\n\n    const start = Date.now();\n    const cells = countBeamCells(grid);\n    const paths = countBeamPaths(grid);\n    const elapsed = Date.now() - start;\n\n    expect(cells).toBeGreaterThan(0);\n    expect(paths).toBeGreaterThan(0n);\n    expect(elapsed).toBeLessThan(5000);\n  });\n\n  test('many splitters returns large bigint correctly', () => {","originalFile":"import { describe, test, expect } from 'vitest';\nimport { countBeamCells, countBeamPaths } from './index.js';\n\ndescribe('countBeamCells', () => {\n  test('source cell alone counts as 1 visited cell', () => {\n    // S in a 1x1 grid — beam immediately exits after source\n    const grid = [['S']];\n    expect(countBeamCells(grid)).toBe(1);\n  });\n\n  test('beam travels straight down through empty cells', () => {\n    // S\n    // .\n    // .\n    const grid = [['S'], ['.'], ['.']];\n    expect(countBeamCells(grid)).toBe(3);\n  });\n\n  test('single splitter example from spec', () => {\n    const grid = [\n      ['.', 'S', '.', '.', '.'],\n      ['.', '.', '.', '.', '.'],\n      ['.', '^', '.', '.', '.'],\n      ['.', '.', '.', '.', '.'],\n    ];\n    // Visited: (0,1), (1,1), (2,1), (3,0), (3,2) = 5\n    expect(countBeamCells(grid)).toBe(5);\n  });\n\n  test('two splitters example from spec', () => {\n    const grid = [\n      ['.', 'S', '.', '.', '.'],\n      ['.', '^', '.', '.', '.'],\n      ['^', '.', '^', '.', '.'],\n      ['.', '.', '.', '.', '.'],\n    ];\n    // Visited: (0,1), (1,1), (2,0), (2,2), (3,1), (3,3) = 6\n    expect(countBeamCells(grid)).toBe(6);\n  });\n\n  test('beam going down-left exits at left boundary', () => {\n    // S at col 1, splitter at row 1 col 1\n    // down-left beam exits at col 0 row 2, down-right at col 2 row 2\n    const grid = [\n      ['.', 'S', '.'],\n      ['.', '^', '.'],\n      ['.', '.', '.'],\n    ];\n    // Visited: (0,1), (1,1), (2,0), (2,2) = 4\n    expect(countBeamCells(grid)).toBe(4);\n  });\n\n  test('two beams hitting same cell counts once', () => {\n    // Two beams converging on same cell — only counted once\n    const grid = [\n      ['.', 'S', '.', '.', '.'],\n      ['.', '^', '.', '.', '.'],\n      ['^', '.', '^', '.', '.'],\n      ['.', '.', '.', '.', '.'],\n    ];\n    // (3,1) is hit by two beams but counted once\n    expect(countBeamCells(grid)).toBe(6);\n  });\n\n  test('beam absorbed at left boundary does not add cells', () => {\n    // Source at leftmost column, splitter directly below\n    // down-left beam exits immediately (col -1), down-right continues\n    const grid = [\n      ['S', '.'],\n      ['^', '.'],\n      ['.', '.'],\n    ];\n    // Visited: (0,0), (1,0)[splitter], (2,1) = 3\n    expect(countBeamCells(grid)).toBe(3);\n  });\n\n  test('splitter on last row — split beams exit immediately', () => {\n    const grid = [\n      ['S'],\n      ['^'],\n    ];\n    // Visited: (0,0), (1,0) — split goes to row 2 which is out of bounds\n    expect(countBeamCells(grid)).toBe(2);\n  });\n\n  test('no splitters, beam exits bottom', () => {\n    const grid = [\n      ['S', '.'],\n      ['.', '.'],\n    ];\n    // Visited: (0,0), (1,0)\n    expect(countBeamCells(grid)).toBe(2);\n  });\n});\n\ndescribe('countBeamPaths', () => {\n  test('no splitters means 1 path', () => {\n    const grid = [\n      ['S', '.'],\n      ['.', '.'],\n    ];\n    expect(countBeamPaths(grid)).toBe(1n);\n  });\n\n  test('single splitter example from spec gives 2 paths', () => {\n    const grid = [\n      ['.', 'S', '.', '.', '.'],\n      ['.', '.', '.', '.', '.'],\n      ['.', '^', '.', '.', '.'],\n      ['.', '.', '.', '.', '.'],\n    ];\n    expect(countBeamPaths(grid)).toBe(2n);\n  });\n\n  test('two splitters both hit gives 4 paths', () => {\n    const grid = [\n      ['.', 'S', '.', '.', '.'],\n      ['.', '^', '.', '.', '.'],\n      ['^', '.', '^', '.', '.'],\n      ['.', '.', '.', '.', '.'],\n    ];\n    // 4 paths exit (including the one absorbed at col -1)\n    expect(countBeamPaths(grid)).toBe(4n);\n  });\n\n  test('splitter with one branch absorbed still counts both paths', () => {\n    // Source at col 0, splitter below — left branch absorbed, right continues\n    const grid = [\n      ['S', '.'],\n      ['^', '.'],\n      ['.', '.'],\n    ];\n    // 2 paths: one absorbed at col -1, one exits normally\n    expect(countBeamPaths(grid)).toBe(2n);\n  });\n\n  test('1x1 source-only grid has 1 path', () => {\n    const grid = [['S']];\n    expect(countBeamPaths(grid)).toBe(1n);\n  });\n\n  test('chained splitters double paths exponentially', () => {\n    // S hits splitter, each branch hits another splitter = 4 paths\n    const grid = [\n      ['S', '.', '.'],\n      ['^', '.', '.'],\n      ['.', '^', '.'],\n      ['.', '.', '.'],\n    ];\n    // (0,0) -> (1,0) splitter -> (2,-1) absorbed + (2,1) splitter -> (3,0) + (3,2)\n    // So: 3 exit paths (1 absorbed left at row 2, then 2 from row 2 col 1 splitter)\n    // Actually: path 1 exits absorbed at (2,-1), path 2 from splitter at (2,1) -> (3,0), path 3 -> (3,2)\n    // Total paths = 1 (absorbed) + 2 = but spec says absorbed = exits too\n    // So 3 total paths exiting the grid\n    expect(countBeamPaths(grid)).toBe(3n);\n  });\n\n  test('returns bigint type', () => {\n    const grid = [\n      ['S'],\n    ];\n    const result = countBeamPaths(grid);\n    expect(typeof result).toBe('bigint');\n  });\n\n  test('many splitters returns large bigint correctly', () => {\n    // Build a 10-row grid where every row except first has a splitter directly below source\n    // Actually that won't work — let's build a chain where each split creates new splits\n    // Linear chain: S at col 5, splitter at each row col 5 (straight down)\n    // Each splitter splits but since down-left/down-right won't hit more splitters, it doubles each time\n    // Row 0: S at col 5\n    // Row 1: ^ at col 5 -> 2 beams: (2,4) and (2,6)\n    // No more splitters -> 2 paths\n    const rows = 12;\n    const cols = 25;\n    const grid: string[][] = Array.from({ length: rows }, () => Array(cols).fill('.'));\n    grid[0][12] = 'S';\n    // Place splitters in a full binary tree pattern going down\n    // Row 1: col 12 (hit by down beam from S)\n    grid[1][12] = '^';\n    // Row 2: col 11 and col 13 (hit by down-left and down-right)\n    grid[2][11] = '^';\n    grid[2][13] = '^';\n    // Row 3: col 10, 12, 12, 14 — but col 12 would be hit by both, let's just use col 10 and col 14\n    grid[3][10] = '^';\n    grid[3][14] = '^';\n    // 3 levels of splitting: 2^3 = 8 paths\n    // But some beams from row 2 don't hit row 3 splitters\n    // (2,11) -> (3,10) hits ^ and (3,12) misses; (2,13) -> (3,12) misses and (3,14) hits ^\n    // So 2 more splits at row 3 -> 4 terminal beams from (2,11): (4,9) + (4,11); from (2,13): nothing extra\n    // This is getting complex — just test a simple known case\n    const simpleGrid = [\n      ['.', 'S', '.'],\n      ['.', '^', '.'],\n      ['.', '^', '.'],\n      ['.', '.', '.'],\n    ];\n    // S -> (1,1) splitter -> (2,0) and (2,2)\n    // (2,0): hits nothing (splitter at (2,1) not (2,0)) -> exits at (3,0)\n    // Wait, the splitter is at (2,1) not (2,0)\n    // (1,1) splits to (2,0) and (2,2) — neither hits the splitter at (2,1)\n    // So 2 paths total\n    expect(countBeamPaths(simpleGrid)).toBe(2n);\n  });\n});\n","structuredPatch":[{"oldStart":163,"oldLines":6,"newStart":163,"newLines":84,"lines":["     expect(typeof result).toBe('bigint');","   });"," ","+  test('two beams converging on same (row,col,dir) state are counted correctly', () => {","+    // Two beams from two different splitters both send a down-right beam to the same cell","+    // Grid (6 rows x 7 cols):","+    //   . S . S . . .   <- two sources would be unusual; let's use a single source + splitter pattern","+    // Actually: use one source, one splitter that sends down-right to col X,","+    // and another splitter hit by a different branch that also sends down-right to col X","+    //","+    // S at (0,3)","+    // ^ at (1,3): sends (2,2,down-left) and (2,4,down-right)","+    // ^ at (2,2): sends (3,1,down-left) and (3,3,down-right)","+    // ^ at (2,4): sends (3,3,down-left) and (3,5,down-right)","+    // Both (3,3,down-right) from (2,2) and (3,3,down-left) from (2,4) arrive at (3,3) but different dirs","+    // Actually to get same dir convergence: need two beams both going down-right to same cell","+    //","+    // Simpler: paths through a diamond","+    //   S at (0,3)","+    //   ^ at (1,3) -> (2,2,DL) and (2,4,DR)","+    //   ^ at (2,2) -> (3,1,DL) and (3,3,DR)","+    //   ^ at (2,4) -> (3,3,DL) and (3,5,DR)","+    //   Total paths = 4 (each leaf exits grid)","+    const grid = [","+      ['.', '.', '.', 'S', '.', '.', '.'],","+      ['.', '.', '.', '^', '.', '.', '.'],","+      ['.', '.', '^', '.', '^', '.', '.'],","+      ['.', '.', '.', '.', '.', '.', '.'],","+    ];","+    // From (2,2)^: -> (3,1) and (3,3)","+    // From (2,4)^: -> (3,3) and (3,5)","+    // All 4 beams exit at row 4 (out of bounds) -> 4 paths","+    expect(countBeamPaths(grid)).toBe(4n);","+    // Cells: (0,3),(1,3),(2,2),(2,4),(3,1),(3,3),(3,5) = 7","+    expect(countBeamCells(grid)).toBe(7);","+  });","+","+  test('performance: 200x200 grid with 50 splitters completes under 5 seconds', () => {","+    const rows = 200;","+    const cols = 200;","+    const grid: string[][] = Array.from({ length: rows }, () => Array(cols).fill('.'));","+    grid[0][100] = 'S';","+","+    // Place 50 splitters in a binary-tree pattern along the beam paths","+    // Row 1: col 100 (directly below S)","+    // Then spread out in a pattern that stays in bounds","+    let splitterCount = 0;","+    const positions: [number, number][] = [[1, 100]];","+    const nextPositions: [number, number][] = [];","+","+    for (const [r, c] of positions) {","+      if (splitterCount >= 50) break;","+      if (r < rows && c >= 0 && c < cols) {","+        grid[r][c] = '^';","+        splitterCount++;","+        if (r + 2 < rows) {","+          if (c - 1 >= 0) nextPositions.push([r + 2, c - 1]);","+          if (c + 1 < cols) nextPositions.push([r + 2, c + 1]);","+        }","+      }","+    }","+","+    // Add more splitters from next level","+    for (const [r, c] of nextPositions) {","+      if (splitterCount >= 50) break;","+      if (r < rows && c >= 0 && c < cols && grid[r][c] === '.') {","+        grid[r][c] = '^';","+        splitterCount++;","+      }","+    }","+","+    const start = Date.now();","+    const cells = countBeamCells(grid);","+    const paths = countBeamPaths(grid);","+    const elapsed = Date.now() - start;","+","+    expect(cells).toBeGreaterThan(0);","+    expect(paths).toBeGreaterThan(0n);","+    expect(elapsed).toBeLessThan(5000);","+  });","+","   test('many splitters returns large bigint correctly', () => {","     // Build a 10-row grid where every row except first has a splitter directly below source","     // Actually that won't work — let's build a chain where each split creates new splits"]}],"userModified":false,"replaceAll":false}}
