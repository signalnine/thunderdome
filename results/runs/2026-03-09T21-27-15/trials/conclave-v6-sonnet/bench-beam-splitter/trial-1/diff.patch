+// Beam directions
+type Direction = 'down' | 'down-left' | 'down-right';
+
+interface BeamState {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+function nextPosition(row: number, col: number, dir: Direction): [number, number] {
+  if (dir === 'down') return [row + 1, col];
+  if (dir === 'down-left') return [row + 1, col - 1];
+  return [row + 1, col + 1];
+}
+
+function findSource(grid: string[][]): [number, number] {
+  for (let col = 0; col < grid[0].length; col++) {
+    if (grid[0][col] === 'S') return [0, col];
+  }
+  throw new Error('No source found');
+}
+
+/**
+ * Count distinct cells visited by any beam.
+ */
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const [srcRow, srcCol] = findSource(grid);
+
+  const visited = new Set<string>();
+  const seen = new Set<string>(); // beam states to avoid infinite loops
+  const queue: BeamState[] = [{ row: srcRow, col: srcCol, dir: 'down' }];
+
+  while (queue.length > 0) {
+    const { row, col, dir } = queue.shift()!;
+
+    if (row < 0 || row >= rows || col < 0 || col >= cols) continue;
+
+    const stateKey = `${row},${col},${dir}`;
+    if (seen.has(stateKey)) continue;
+    seen.add(stateKey);
+
+    visited.add(`${row},${col}`);
+
+    const cell = grid[row][col];
+
+    if (cell === '^') {
+      // Split into down-left and down-right
+      const [dlRow, dlCol] = nextPosition(row, col, 'down-left');
+      const [drRow, drCol] = nextPosition(row, col, 'down-right');
+      queue.push({ row: dlRow, col: dlCol, dir: 'down-left' });
+      queue.push({ row: drRow, col: drCol, dir: 'down-right' });
+    } else {
+      // Continue in current direction (source or empty cell)
+      const [nr, nc] = nextPosition(row, col, dir);
+      queue.push({ row: nr, col: nc, dir });
+    }
+  }
+
+  return visited.size;
+}
+
+/**
+ * Count total distinct source-to-exit paths.
+ *
+ * Since beams always advance to row+1, the beam graph is a DAG.
+ * We propagate path counts layer by layer (row by row) without cycles.
+ * Multiple beams can accumulate at the same (row, col, dir) state —
+ * we collect all incoming counts before processing each state.
+ */
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const [srcRow, srcCol] = findSource(grid);
+
+  // pathCounts[row][stateKey] = accumulated bigint count of paths reaching this state
+  // We process row by row to ensure all incoming counts are accumulated before processing.
+  // Out-of-bounds states are captured in exitCount.
+  const layerCounts: Map<string, bigint>[] = Array.from(
+    { length: rows + 1 },
+    () => new Map<string, bigint>()
+  );
+  let exitCount = 0n;
+
+  // Initialize source
+  const srcKey = `${srcCol},down`;
+  layerCounts[srcRow].set(srcKey, 1n);
+
+  function addToLayer(row: number, col: number, dir: Direction, count: bigint): void {
+    if (row < 0 || row >= rows || col < 0 || col >= cols) {
+      exitCount += count;
+      return;
+    }
+    const key = `${col},${dir}`;
+    const layer = layerCounts[row];
+    layer.set(key, (layer.get(key) ?? 0n) + count);
+  }
+
+  for (let row = 0; row < rows; row++) {
+    const layer = layerCounts[row];
+    for (const [key, count] of layer) {
+      if (count === 0n) continue;
+      const [colStr, dir] = key.split(',') as [string, Direction];
+      const col = parseInt(colStr, 10);
+      const cell = grid[row][col];
+
+      if (cell === '^') {
+        const [dlRow, dlCol] = nextPosition(row, col, 'down-left');
+        const [drRow, drCol] = nextPosition(row, col, 'down-right');
+        addToLayer(dlRow, dlCol, 'down-left', count);
+        addToLayer(drRow, drCol, 'down-right', count);
+      } else {
+        const [nr, nc] = nextPosition(row, col, dir as Direction);
+        addToLayer(nr, nc, dir as Direction, count);
+      }
+    }
+  }
+
+  return exitCount;
+}
