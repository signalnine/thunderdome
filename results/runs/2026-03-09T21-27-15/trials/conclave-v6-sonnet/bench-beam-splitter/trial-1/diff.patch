+import { describe, test, expect } from 'vitest';
+import { countBeamCells, countBeamPaths } from './index.js';
+
+describe('countBeamCells', () => {
+  test('source cell alone counts as 1 visited cell', () => {
+    // S in a 1x1 grid — beam immediately exits after source
+    const grid = [['S']];
+    expect(countBeamCells(grid)).toBe(1);
+  });
+
+  test('beam travels straight down through empty cells', () => {
+    // S
+    // .
+    // .
+    const grid = [['S'], ['.'], ['.']];
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  test('single splitter example from spec', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    // Visited: (0,1), (1,1), (2,1), (3,0), (3,2) = 5
+    expect(countBeamCells(grid)).toBe(5);
+  });
+
+  test('two splitters example from spec', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    // Visited: (0,1), (1,1), (2,0), (2,2), (3,1), (3,3) = 6
+    expect(countBeamCells(grid)).toBe(6);
+  });
+
+  test('beam going down-left exits at left boundary', () => {
+    // S at col 1, splitter at row 1 col 1
+    // down-left beam exits at col 0 row 2, down-right at col 2 row 2
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '^', '.'],
+      ['.', '.', '.'],
+    ];
+    // Visited: (0,1), (1,1), (2,0), (2,2) = 4
+    expect(countBeamCells(grid)).toBe(4);
+  });
+
+  test('two beams hitting same cell counts once', () => {
+    // Two beams converging on same cell — only counted once
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    // (3,1) is hit by two beams but counted once
+    expect(countBeamCells(grid)).toBe(6);
+  });
+
+  test('beam absorbed at left boundary does not add cells', () => {
+    // Source at leftmost column, splitter directly below
+    // down-left beam exits immediately (col -1), down-right continues
+    const grid = [
+      ['S', '.'],
+      ['^', '.'],
+      ['.', '.'],
+    ];
+    // Visited: (0,0), (1,0)[splitter], (2,1) = 3
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  test('splitter on last row — split beams exit immediately', () => {
+    const grid = [
+      ['S'],
+      ['^'],
+    ];
+    // Visited: (0,0), (1,0) — split goes to row 2 which is out of bounds
+    expect(countBeamCells(grid)).toBe(2);
+  });
+
+  test('no splitters, beam exits bottom', () => {
+    const grid = [
+      ['S', '.'],
+      ['.', '.'],
+    ];
+    // Visited: (0,0), (1,0)
+    expect(countBeamCells(grid)).toBe(2);
+  });
+});
+
+describe('countBeamPaths', () => {
+  test('no splitters means 1 path', () => {
+    const grid = [
+      ['S', '.'],
+      ['.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  test('single splitter example from spec gives 2 paths', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  test('two splitters both hit gives 4 paths', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    // 4 paths exit (including the one absorbed at col -1)
+    expect(countBeamPaths(grid)).toBe(4n);
+  });
+
+  test('splitter with one branch absorbed still counts both paths', () => {
+    // Source at col 0, splitter below — left branch absorbed, right continues
+    const grid = [
+      ['S', '.'],
+      ['^', '.'],
+      ['.', '.'],
+    ];
+    // 2 paths: one absorbed at col -1, one exits normally
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  test('1x1 source-only grid has 1 path', () => {
+    const grid = [['S']];
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  test('chained splitters double paths exponentially', () => {
