+import { describe, it, expect, beforeEach } from 'vitest';
+import { EventBus } from '../bus.js';
+import { createCartService } from './index.js';
+
+describe('CartService', () => {
+  let bus: EventBus;
+  let cart: ReturnType<typeof createCartService>;
+
+  beforeEach(() => {
+    bus = new EventBus();
+    cart = createCartService(bus);
+  });
+
+  describe('createCart', () => {
+    it('returns a unique cart id', () => {
+      const id1 = cart.createCart('user-1');
+      const id2 = cart.createCart('user-2');
+      expect(id1).toBeTruthy();
+      expect(id2).toBeTruthy();
+      expect(id1).not.toBe(id2);
+    });
+  });
+
+  describe('getCart', () => {
+    it('returns cart with empty items initially', () => {
+      const cartId = cart.createCart('user-1');
+      const c = cart.getCart(cartId);
+      expect(c).toMatchObject({ id: cartId, userId: 'user-1', items: [] });
+    });
+
+    it('returns null for unknown cart', () => {
+      expect(cart.getCart('nonexistent')).toBeNull();
+    });
+  });
+
+  describe('addItem', () => {
+    it('adds a new item to the cart', () => {
+      const cartId = cart.createCart('user-1');
+      cart.addItem(cartId, 'prod-1', 2);
+      const c = cart.getCart(cartId);
+      expect(c?.items).toHaveLength(1);
+      expect(c?.items[0]).toMatchObject({ productId: 'prod-1', quantity: 2 });
+    });
+
+    it('consolidates duplicate product by adding quantities', () => {
+      const cartId = cart.createCart('user-1');
+      cart.addItem(cartId, 'prod-1', 2);
+      cart.addItem(cartId, 'prod-1', 3);
+      const c = cart.getCart(cartId);
+      expect(c?.items).toHaveLength(1);
+      expect(c?.items[0].quantity).toBe(5);
+    });
+
+    it('adds multiple different products', () => {
+      const cartId = cart.createCart('user-1');
+      cart.addItem(cartId, 'prod-1', 1);
+      cart.addItem(cartId, 'prod-2', 2);
+      expect(cart.getCart(cartId)?.items).toHaveLength(2);
+    });
+  });
+
+  describe('removeItem', () => {
+    it('removes an item from the cart', () => {
+      const cartId = cart.createCart('user-1');
+      cart.addItem(cartId, 'prod-1', 2);
+      cart.removeItem(cartId, 'prod-1');
+      expect(cart.getCart(cartId)?.items).toHaveLength(0);
+    });
+  });
+
+  describe('updateQuantity', () => {
+    it('updates quantity for existing item', () => {
+      const cartId = cart.createCart('user-1');
+      cart.addItem(cartId, 'prod-1', 2);
+      cart.updateQuantity(cartId, 'prod-1', 10);
+      expect(cart.getCart(cartId)?.items[0].quantity).toBe(10);
+    });
+  });
+
+  describe('clearCart', () => {
+    it('removes all items from the cart', () => {
+      const cartId = cart.createCart('user-1');
+      cart.addItem(cartId, 'prod-1', 2);
+      cart.addItem(cartId, 'prod-2', 1);
+      cart.clearCart(cartId);
+      expect(cart.getCart(cartId)?.items).toHaveLength(0);
+    });
+  });
+});
