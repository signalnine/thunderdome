@@ -0,0 +1,58 @@
+import { EventBus } from '../bus.js';
+import { NotificationService, Events, OrderCreatedEvent, OrderStatusChangedEvent, PaymentProcessedEvent } from '../types.js';
+
+type Notification = { type: string; message: string; timestamp: number };
+
+export function createNotificationService(bus: EventBus): NotificationService {
+  const subscribers = new Set<string>();
+  const notifications = new Map<string, Notification[]>();
+  const orderUserMap = new Map<string, string>(); // orderId -> userId
+
+  bus.on(Events.ORDER_CREATED, (payload) => {
+    const { orderId, userId } = payload as OrderCreatedEvent;
+    orderUserMap.set(orderId, userId);
+  });
+
+  bus.on(Events.ORDER_STATUS_CHANGED, (payload) => {
+    const { orderId, status } = payload as OrderStatusChangedEvent;
+    const userId = orderUserMap.get(orderId);
+    if (!userId || !subscribers.has(userId)) return;
+
+    const notif: Notification = {
+      type: 'order:status',
+      message: `Order ${orderId} status changed to ${status}`,
+      timestamp: Date.now(),
+    };
+    const list = notifications.get(userId) ?? [];
+    list.push(notif);
+    notifications.set(userId, list);
+  });
+
+  bus.on(Events.PAYMENT_PROCESSED, (payload) => {
+    const { orderId, status } = payload as PaymentProcessedEvent;
+    const userId = orderUserMap.get(orderId);
+    if (!userId || !subscribers.has(userId)) return;
+
+    const notif: Notification = {
+      type: 'payment:processed',
+      message: `Payment for order ${orderId} ${status}`,
+      timestamp: Date.now(),
+    };
+    const list = notifications.get(userId) ?? [];
+    list.push(notif);
+    notifications.set(userId, list);
+  });
+
+  return {
+    subscribe(userId: string) {
+      subscribers.add(userId);
+      if (!notifications.has(userId)) {
+        notifications.set(userId, []);
+      }
+    },
+
+    getNotifications(userId: string): Notification[] {
+      return notifications.get(userId) ?? [];
+    },
+  };
+}
