+import { v4 as uuidv4 } from 'uuid';
+import { EventBus } from '../bus.js';
+import { CartService } from '../types.js';
+
+type CartData = { id: string; userId: string; items: Map<string, number> };
+
+export function createCartService(_bus: EventBus): CartService {
+  const carts = new Map<string, CartData>();
+
+  function toCartResult(cart: CartData) {
+    return {
+      id: cart.id,
+      userId: cart.userId,
+      items: Array.from(cart.items.entries()).map(([productId, quantity]) => ({ productId, quantity })),
+    };
+  }
+
+  return {
+    createCart(userId: string): string {
+      const id = uuidv4();
+      carts.set(id, { id, userId, items: new Map() });
+      return id;
+    },
+
+    addItem(cartId: string, productId: string, quantity: number) {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+      const existing = cart.items.get(productId) ?? 0;
+      cart.items.set(productId, existing + quantity);
+    },
+
+    removeItem(cartId: string, productId: string) {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+      cart.items.delete(productId);
+    },
+
+    getCart(cartId: string) {
+      const cart = carts.get(cartId);
+      return cart ? toCartResult(cart) : null;
+    },
+
+    clearCart(cartId: string) {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+      cart.items.clear();
+    },
+
+    updateQuantity(cartId: string, productId: string, quantity: number) {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+      cart.items.set(productId, quantity);
+    },
+  };
+}
