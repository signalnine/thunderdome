@@ -0,0 +1,43 @@
+import { v4 as uuidv4 } from 'uuid';
+import { EventBus } from '../bus.js';
+import { PaymentService, PaymentStatus, Events, PaymentProcessedEvent } from '../types.js';
+
+interface PaymentOptions {
+  scenario?: 'success' | 'failure' | 'timeout';
+  timeoutMs?: number;
+}
+
+export function createPaymentService(bus: EventBus, options: PaymentOptions = {}): PaymentService {
+  const { scenario = 'success', timeoutMs = 5000 } = options;
+  const transactions = new Set<string>();
+
+  return {
+    async processPayment(orderId: string, _amount: number): Promise<{ status: PaymentStatus; transactionId?: string; error?: string }> {
+      if (scenario === 'timeout') {
+        await new Promise(resolve => setTimeout(resolve, timeoutMs));
+        const payload: PaymentProcessedEvent = { orderId, status: PaymentStatus.TIMEOUT };
+        await bus.emit(Events.PAYMENT_PROCESSED, payload);
+        return { status: PaymentStatus.TIMEOUT };
+      }
+
+      if (scenario === 'failure') {
+        const payload: PaymentProcessedEvent = { orderId, status: PaymentStatus.FAILED, error: 'Payment declined' };
+        await bus.emit(Events.PAYMENT_PROCESSED, payload);
+        return { status: PaymentStatus.FAILED, error: 'Payment declined' };
+      }
+
+      // success
+      const transactionId = uuidv4();
+      transactions.add(transactionId);
+      const payload: PaymentProcessedEvent = { orderId, status: PaymentStatus.SUCCESS, transactionId };
+      await bus.emit(Events.PAYMENT_PROCESSED, payload);
+      return { status: PaymentStatus.SUCCESS, transactionId };
+    },
+
+    async refund(transactionId: string): Promise<boolean> {
+      if (!transactions.has(transactionId)) return false;
+      transactions.delete(transactionId);
+      return true;
+    },
+  };
+}
