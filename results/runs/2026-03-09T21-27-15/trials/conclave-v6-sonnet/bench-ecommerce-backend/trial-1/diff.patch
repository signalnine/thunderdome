e: 'Widget', price: 9.99, category: 'tools' });\n    });\n\n    it('returns null for unknown id', () => {\n      expect(catalog.getProduct('nonexistent')).toBeNull();\n    });\n  });\n\n  describe('listProducts', () => {\n    it('lists all products when no category filter', () => {\n      catalog.createProduct('Widget', 9.99, 'tools');\n      catalog.createProduct('Gadget', 19.99, 'electronics');\n      const products = catalog.listProducts();\n      expect(products).toHaveLength(2);\n    });\n\n    it('filters by category when provided', () => {\n      catalog.createProduct('Widget', 9.99, 'tools');\n      catalog.createProduct('Gadget', 19.99, 'electronics');\n      const tools = catalog.listProducts('tools');\n      expect(tools).toHaveLength(1);\n      expect(tools[0].name).toBe('Widget');\n    });\n\n    it('returns empty array when category has no products', () => {\n      catalog.createProduct('Widget', 9.99, 'tools');\n      expect(catalog.listProducts('nonexistent')).toHaveLength(0);\n    });\n  });\n\n  describe('searchProducts', () => {\n    it('finds products matching query in name (case insensitive)', () => {\n      catalog.createProduct('Widget', 9.99, 'tools');\n      catalog.createProduct('Gadget', 19.99, 'electronics');\n      const results = catalog.searchProducts('widget');\n      expect(results).toHaveLength(1);\n      expect(results[0].name).toBe('Widget');\n    });\n\n    it('finds products matching query in category', () => {\n      catalog.createProduct('Widget', 9.99, 'tools');\n      catalog.createProduct('Gadget', 19.99, 'electronics');\n      const results = catalog.searchProducts('electro');\n      expect(results).toHaveLength(1);\n      expect(results[0].name).toBe('Gadget');\n    });\n\n    it('returns empty array when no match', () => {\n      catalog.createProduct('Widget', 9.99, 'tools');\n      expect(catalog.searchProducts('xyz')).toHaveLength(0);\n    });\n  });\n\n  describe('updateProduct', () => {\n    it('updates product name', () => {\n      const id = catalog.createProduct('Widget', 9.99, 'tools');\n      catalog.updateProduct(id, { name: 'Super Widget' });\n      expect(catalog.getProduct(id)?.name).toBe('Super Widget');\n    });\n\n    it('updates product price', () => {\n      const id = catalog.createProduct('Widget', 9.99, 'tools');\n      catalog.updateProduct(id, { price: 14.99 });\n      expect(catalog.getProduct(id)?.price).toBe(14.99);\n    });\n\n    it('does not affect unupdated fields', () => {\n      const id = catalog.createProduct('Widget', 9.99, 'tools');\n      catalog.updateProduct(id, { price: 14.99 });\n      const product = catalog.getProduct(id);\n      expect(product?.name).toBe('Widget');\n      expect(product?.category).toBe('tools');\n    });\n  });\n\n  describe('removeProduct', () => {\n    it('removes product and returns true', () => {\n      const id = catalog.createProduct('Widget', 9.99, 'tools');\n      expect(catalog.removeProduct(id)).toBe(true);\n      expect(catalog.getProduct(id)).toBeNull();\n    });\n\n    it('returns false for nonexistent product', () => {\n      expect(catalog.removeProduct('nonexistent')).toBe(false);\n    });\n  });\n});\n","structuredPatch":[{"oldStart":23,"oldLines":7,"newStart":23,"newLines":7,"lines":[" ","     it('emits PRODUCT_CREATED event with correct payload', async () => {","       const events: unknown[] = [];","-      bus.on(Events.PRODUCT_CREATED, (payload) => events.push(payload));","+      bus.on(Events.PRODUCT_CREATED, (payload) => { events.push(payload); });"," ","       const id = catalog.createProduct('Widget', 9.99, 'tools');"," "]}],"userModified":false,"replaceAll":false}}
