+    it('resolves with success status and transactionId', async () => {
+      const payment = createPaymentService(bus, { scenario: 'success' });
+      const result = await payment.processPayment('order-1', 99.99);
+      expect(result.status).toBe(PaymentStatus.SUCCESS);
+      expect(result.transactionId).toBeTruthy();
+    });
+
+    it('emits PAYMENT_PROCESSED event with success status', async () => {
+      const events: unknown[] = [];
+      bus.on(Events.PAYMENT_PROCESSED, (p) => { events.push(p); });
+
+      const payment = createPaymentService(bus, { scenario: 'success' });
+      await payment.processPayment('order-1', 99.99);
+
+      expect(events).toHaveLength(1);
+      expect(events[0]).toMatchObject({ orderId: 'order-1', status: PaymentStatus.SUCCESS });
+    });
+  });
+
+  describe('processPayment - failure scenario', () => {
+    it('resolves with failed status', async () => {
+      const payment = createPaymentService(bus, { scenario: 'failure' });
+      const result = await payment.processPayment('order-1', 99.99);
+      expect(result.status).toBe(PaymentStatus.FAILED);
+    });
+
+    it('emits PAYMENT_PROCESSED event with failed status', async () => {
+      const events: unknown[] = [];
+      bus.on(Events.PAYMENT_PROCESSED, (p) => { events.push(p); });
+
+      const payment = createPaymentService(bus, { scenario: 'failure' });
+      await payment.processPayment('order-1', 99.99);
+
+      expect(events[0]).toMatchObject({ orderId: 'order-1', status: PaymentStatus.FAILED });
+    });
+  });
+
+  describe('processPayment - timeout scenario', () => {
+    it('resolves with timeout status', async () => {
+      const payment = createPaymentService(bus, { scenario: 'timeout' });
+      const result = await payment.processPayment('order-1', 99.99);
+      expect(result.status).toBe(PaymentStatus.TIMEOUT);
+    }, 10000);
+  });
+
+  describe('refund', () => {
+    it('refunds a successful transaction and returns true', async () => {
+      const payment = createPaymentService(bus, { scenario: 'success' });
+      const result = await payment.processPayment('order-1', 99.99);
+      const refunded = await payment.refund(result.transactionId!);
+      expect(refunded).toBe(true);
+    });
+
+    it('returns false for unknown transactionId', async () => {
+      const payment = createPaymentService(bus, { scenario: 'success' });
+      const refunded = await payment.refund('fake-txn-id');
+      expect(refunded).toBe(false);
+    });
+  });
+});
