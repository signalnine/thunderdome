 pricing.calculateTotal([]);\n      expect(result.subtotal).toBe(0);\n      expect(result.tax).toBe(0);\n      expect(result.total).toBe(0);\n    });\n  });\n\n  describe('getPrice', () => {\n    it('returns price stored from product:created event', async () => {\n      await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'Widget', price: 9.99, category: 'tools' });\n      expect(pricing.getPrice('p1')).toBe(9.99);\n    });\n\n    it('returns 0 for unknown product', () => {\n      expect(pricing.getPrice('unknown')).toBe(0);\n    });\n  });\n\n  describe('addDiscountCode', () => {\n    it('stores discount code for later use', () => {\n      pricing.addDiscountCode('HALF', 50);\n      const items = [{ productId: 'p1', quantity: 1, price: 200 }];\n      const result = pricing.calculateTotal(items, 'HALF');\n      expect(result.discount).toBe(100);\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1090,"cache_read_input_tokens":30650,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1090},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"9213ce38-66e4-4d31-9ba3-4c08f45bdd16","uuid":"e991b7a5-d913-474e-997f-768125e2efc4"}
