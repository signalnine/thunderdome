ds multiple different products', () => {\n      const cartId = cart.createCart('user-1');\n      cart.addItem(cartId, 'prod-1', 1);\n      cart.addItem(cartId, 'prod-2', 2);\n      expect(cart.getCart(cartId)?.items).toHaveLength(2);\n    });\n  });\n\n  describe('removeItem', () => {\n    it('removes an item from the cart', () => {\n      const cartId = cart.createCart('user-1');\n      cart.addItem(cartId, 'prod-1', 2);\n      cart.removeItem(cartId, 'prod-1');\n      expect(cart.getCart(cartId)?.items).toHaveLength(0);\n    });\n  });\n\n  describe('updateQuantity', () => {\n    it('updates quantity for existing item', () => {\n      const cartId = cart.createCart('user-1');\n      cart.addItem(cartId, 'prod-1', 2);\n      cart.updateQuantity(cartId, 'prod-1', 10);\n      expect(cart.getCart(cartId)?.items[0].quantity).toBe(10);\n    });\n  });\n\n  describe('clearCart', () => {\n    it('removes all items from the cart', () => {\n      const cartId = cart.createCart('user-1');\n      cart.addItem(cartId, 'prod-1', 2);\n      cart.addItem(cartId, 'prod-2', 1);\n      cart.clearCart(cartId);\n      expect(cart.getCart(cartId)?.items).toHaveLength(0);\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1048,"cache_read_input_tokens":29602,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1048},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"9213ce38-66e4-4d31-9ba3-4c08f45bdd16","uuid":"53e47d81-3ee2-4125-bcaf-543735fdcdda"}
