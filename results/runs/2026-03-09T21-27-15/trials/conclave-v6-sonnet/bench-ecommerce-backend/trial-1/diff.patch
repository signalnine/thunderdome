+import { describe, it, expect, beforeEach } from 'vitest';
+import { EventBus } from '../bus.js';
+import { Events } from '../types.js';
+import { createPricingService } from './index.js';
+
+describe('PricingService', () => {
+  let bus: EventBus;
+  let pricing: ReturnType<typeof createPricingService>;
+
+  beforeEach(() => {
+    bus = new EventBus();
+    pricing = createPricingService(bus);
+  });
+
+  describe('calculateTotal', () => {
+    it('calculates subtotal, 10% tax, and total with no discount', () => {
+      const items = [
+        { productId: 'p1', quantity: 2, price: 10 },
+        { productId: 'p2', quantity: 1, price: 5 },
+      ];
+      const result = pricing.calculateTotal(items);
+      expect(result.subtotal).toBeCloseTo(25);
+      expect(result.discount).toBe(0);
+      expect(result.tax).toBeCloseTo(2.5);
+      expect(result.total).toBeCloseTo(27.5);
+    });
+
+    it('applies percentage discount code to subtotal before tax', () => {
+      pricing.addDiscountCode('SAVE10', 10); // 10% off
+      const items = [{ productId: 'p1', quantity: 1, price: 100 }];
+      const result = pricing.calculateTotal(items, 'SAVE10');
+      expect(result.subtotal).toBe(100);
+      expect(result.discount).toBe(10); // 10% of 100
+      expect(result.tax).toBeCloseTo(9); // 10% of (100-10)=90
+      expect(result.total).toBeCloseTo(99); // 90 + 9
+    });
+
+    it('applies no discount for unknown code', () => {
+      const items = [{ productId: 'p1', quantity: 1, price: 100 }];
+      const result = pricing.calculateTotal(items, 'INVALID');
+      expect(result.discount).toBe(0);
+    });
+
+    it('returns zero totals for empty items', () => {
+      const result = pricing.calculateTotal([]);
+      expect(result.subtotal).toBe(0);
+      expect(result.tax).toBe(0);
+      expect(result.total).toBe(0);
+    });
+  });
+
+  describe('getPrice', () => {
+    it('returns price stored from product:created event', async () => {
+      await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'Widget', price: 9.99, category: 'tools' });
+      expect(pricing.getPrice('p1')).toBe(9.99);
+    });
+
+    it('returns 0 for unknown product', () => {
+      expect(pricing.getPrice('unknown')).toBe(0);
+    });
+  });
+
+  describe('addDiscountCode', () => {
+    it('stores discount code for later use', () => {
+      pricing.addDiscountCode('HALF', 50);
+      const items = [{ productId: 'p1', quantity: 1, price: 200 }];
+      const result = pricing.calculateTotal(items, 'HALF');
+      expect(result.discount).toBe(100);
+    });
+  });
+});
