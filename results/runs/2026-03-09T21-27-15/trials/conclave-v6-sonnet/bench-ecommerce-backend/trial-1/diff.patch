+import { describe, it, expect, beforeEach } from 'vitest';
+import { EventBus } from '../bus.js';
+import { Events } from '../types.js';
+import { createInventoryService } from './index.js';
+
+describe('InventoryService', () => {
+  let bus: EventBus;
+  let inventory: ReturnType<typeof createInventoryService>;
+
+  beforeEach(() => {
+    bus = new EventBus();
+    inventory = createInventoryService(bus);
+  });
+
+  describe('setStock and getStock', () => {
+    it('sets and retrieves stock for a product', () => {
+      inventory.setStock('prod-1', 100);
+      expect(inventory.getStock('prod-1')).toBe(100);
+    });
+
+    it('returns 0 for unknown product', () => {
+      expect(inventory.getStock('unknown')).toBe(0);
+    });
+  });
+
+  describe('reserve', () => {
+    it('reserves stock and returns true when sufficient', () => {
+      inventory.setStock('prod-1', 10);
+      const result = inventory.reserve('prod-1', 5);
+      expect(result).toBe(true);
+      expect(inventory.getStock('prod-1')).toBe(5);
+    });
+
+    it('returns false and does not reduce stock when insufficient', () => {
+      inventory.setStock('prod-1', 3);
+      const result = inventory.reserve('prod-1', 5);
+      expect(result).toBe(false);
+      expect(inventory.getStock('prod-1')).toBe(3);
+    });
+
+    it('returns false for product with no stock set', () => {
+      expect(inventory.reserve('unknown', 1)).toBe(false);
+    });
+  });
+
+  describe('release', () => {
+    it('adds quantity back to stock', () => {
+      inventory.setStock('prod-1', 10);
+      inventory.reserve('prod-1', 5);
+      inventory.release('prod-1', 3);
+      expect(inventory.getStock('prod-1')).toBe(8);
+    });
+  });
+
+  describe('low stock alerts', () => {
+    it('emits LOW_STOCK_ALERT when stock falls below threshold after reserve', async () => {
+      const alerts: unknown[] = [];
+      bus.on(Events.LOW_STOCK_ALERT, (p) => { alerts.push(p); });
+
+      inventory.setStock('prod-1', 10);
+      inventory.setLowStockThreshold('prod-1', 5);
+      inventory.reserve('prod-1', 6); // drops to 4, below threshold of 5
+
+      expect(alerts).toHaveLength(1);
+      expect(alerts[0]).toMatchObject({ productId: 'prod-1', currentQuantity: 4, threshold: 5 });
+    });
+
+    it('does not emit LOW_STOCK_ALERT when stock stays at or above threshold', () => {
+      const alerts: unknown[] = [];
+      bus.on(Events.LOW_STOCK_ALERT, (p) => { alerts.push(p); });
+
+      inventory.setStock('prod-1', 10);
+      inventory.setLowStockThreshold('prod-1', 5);
+      inventory.reserve('prod-1', 5); // drops to exactly 5, at threshold
+
+      expect(alerts).toHaveLength(0);
+    });
+
+    it('does not emit LOW_STOCK_ALERT when no threshold set', () => {
+      const alerts: unknown[] = [];
+      bus.on(Events.LOW_STOCK_ALERT, (p) => { alerts.push(p); });
+
+      inventory.setStock('prod-1', 10);
+      inventory.reserve('prod-1', 9); // drops to 1
+
+      expect(alerts).toHaveLength(0);
+    });
+  });
+});
