 });\n  });\n\n  describe('low stock alerts', () => {\n    it('emits LOW_STOCK_ALERT when stock falls below threshold after reserve', async () => {\n      const alerts: unknown[] = [];\n      bus.on(Events.LOW_STOCK_ALERT, (p) => alerts.push(p));\n\n      inventory.setStock('prod-1', 10);\n      inventory.setLowStockThreshold('prod-1', 5);\n      inventory.reserve('prod-1', 6); // drops to 4, below threshold of 5\n\n      expect(alerts).toHaveLength(1);\n      expect(alerts[0]).toMatchObject({ productId: 'prod-1', currentQuantity: 4, threshold: 5 });\n    });\n\n    it('does not emit LOW_STOCK_ALERT when stock stays at or above threshold', () => {\n      const alerts: unknown[] = [];\n      bus.on(Events.LOW_STOCK_ALERT, (p) => alerts.push(p));\n\n      inventory.setStock('prod-1', 10);\n      inventory.setLowStockThreshold('prod-1', 5);\n      inventory.reserve('prod-1', 5); // drops to exactly 5, at threshold\n\n      expect(alerts).toHaveLength(0);\n    });\n\n    it('does not emit LOW_STOCK_ALERT when no threshold set', () => {\n      const alerts: unknown[] = [];\n      bus.on(Events.LOW_STOCK_ALERT, (p) => alerts.push(p));\n\n      inventory.setStock('prod-1', 10);\n      inventory.reserve('prod-1', 9); // drops to 1\n\n      expect(alerts).toHaveLength(0);\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1500,"cache_read_input_tokens":28102,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1500},"output_tokens":18,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"9213ce38-66e4-4d31-9ba3-4c08f45bdd16","uuid":"16dd38dc-ff0a-4235-a510-5daa1a4085bd"}
