--- /dev/null
+++ b/src/tracker.ts
@@ -0,0 +1,92 @@
+import { readFileSync, writeFileSync, mkdirSync, existsSync } from 'node:fs';
+import { dirname } from 'node:path';
+import { randomUUID } from 'node:crypto';
+import type { TimeEntry, QueryOptions, TrackerData } from './types.js';
+
+export class TimeTracker {
+  private readonly filePath: string;
+  private data: TrackerData;
+
+  constructor(filePath: string) {
+    this.filePath = filePath;
+    this.data = this.load();
+  }
+
+  private load(): TrackerData {
+    if (!existsSync(this.filePath)) {
+      return { entries: [] };
+    }
+    const raw = readFileSync(this.filePath, 'utf-8');
+    return JSON.parse(raw) as TrackerData;
+  }
+
+  private save(): void {
+    const dir = dirname(this.filePath);
+    mkdirSync(dir, { recursive: true });
+    writeFileSync(this.filePath, JSON.stringify(this.data, null, 2), 'utf-8');
+  }
+
+  private runningEntry(): TimeEntry | undefined {
+    return this.data.entries.find(e => e.stopTime === null);
+  }
+
+  start(name: string): void {
+    if (!name) {
+      throw new Error('Task name must not be empty');
+    }
+
+    const running = this.runningEntry();
+    if (running) {
+      running.stopTime = new Date().toISOString();
+    }
+
+    const entry: TimeEntry = {
+      id: randomUUID(),
+      name,
+      startTime: new Date().toISOString(),
+      stopTime: null,
+    };
+    this.data.entries.push(entry);
+    this.save();
+  }
+
+  stop(): void {
+    const running = this.runningEntry();
+    if (!running) {
+      throw new Error('No timer is currently running');
+    }
+    running.stopTime = new Date().toISOString();
+    this.save();
+  }
+
+  getEntries(options?: QueryOptions): TimeEntry[] {
+    let entries = this.data.entries;
+
+    if (options?.from !== undefined) {
+      const from = options.from.getTime();
+      entries = entries.filter(e => new Date(e.startTime).getTime() >= from);
+    }
+
+    if (options?.to !== undefined) {
+      const to = options.to.getTime();
+      entries = entries.filter(e => new Date(e.startTime).getTime() <= to);
+    }
+
+    return entries;
+  }
+
+  getSummary(): Record<string, number> {
+    const now = Date.now();
+    const summary: Record<string, number> = {};
+
+    for (const entry of this.data.entries) {
+      const start = new Date(entry.startTime).getTime();
+      const stop = entry.stopTime !== null ? new Date(entry.stopTime).getTime() : now;
+      const duration = stop - start;
+
+      summary[entry.name] = (summary[entry.name] ?? 0) + duration;
+    }
+
+    return summary;
+  }
+}
