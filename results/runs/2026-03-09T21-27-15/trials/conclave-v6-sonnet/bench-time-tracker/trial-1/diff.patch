+export interface TimeEntry {
+  id: string;
+  name: string;
+  startTime: string; // ISO 8601
+  stopTime: string | null; // ISO 8601, null if still running
+}
+
+export interface QueryOptions {
+  from?: Date;
+  to?: Date;
+}
+
+export interface TrackerData {
+  entries: TimeEntry[];
+}
