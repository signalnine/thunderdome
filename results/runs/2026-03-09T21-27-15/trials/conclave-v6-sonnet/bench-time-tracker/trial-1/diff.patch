diff --git a/src/tracker.test.ts b/src/tracker.test.ts
new file mode 100644
index 0000000..c44f5cf
--- /dev/null
+++ b/src/tracker.test.ts
@@ -0,0 +1,189 @@
+import { describe, it, expect, beforeEach, afterEach } from 'vitest';
+import { rmSync, existsSync } from 'node:fs';
+import { join } from 'node:path';
+import { tmpdir } from 'node:os';
+import { TimeTracker } from './tracker.js';
+
+const TEST_DIR = join(tmpdir(), 'time-tracker-test-' + process.pid);
+const TEST_FILE = join(TEST_DIR, 'data.json');
+
+function makeTracker() {
+  return new TimeTracker(TEST_FILE);
+}
+
+beforeEach(() => {
+  // start fresh
+  if (existsSync(TEST_DIR)) {
+    rmSync(TEST_DIR, { recursive: true });
+  }
+});
+
+afterEach(() => {
+  if (existsSync(TEST_DIR)) {
+    rmSync(TEST_DIR, { recursive: true });
+  }
+});
+
+describe('TimeTracker - file persistence', () => {
+  it('creates the data file and parent directories automatically', () => {
+    const t = makeTracker();
+    t.start('task1');
+    expect(existsSync(TEST_FILE)).toBe(true);
+  });
+
+  it('persists data across instances', () => {
+    const t1 = makeTracker();
+    t1.start('task1');
+    t1.stop();
+
+    const t2 = makeTracker();
+    const entries = t2.getEntries();
+    expect(entries).toHaveLength(1);
+    expect(entries[0].name).toBe('task1');
+  });
+});
+
+describe('TimeTracker - start/stop', () => {
+  it('starts a timer and creates an entry', () => {
+    const t = makeTracker();
+    const before = Date.now();
+    t.start('coding');
+    const after = Date.now();
+
+    const entries = t.getEntries();
+    expect(entries).toHaveLength(1);
+    expect(entries[0].name).toBe('coding');
+    expect(new Date(entries[0].startTime).getTime()).toBeGreaterThanOrEqual(before);
+    expect(new Date(entries[0].startTime).getTime()).toBeLessThanOrEqual(after);
+    expect(entries[0].stopTime).toBeNull();
+  });
+
+  it('stops a running timer and records stop time', () => {
+    const t = makeTracker();
+    t.start('coding');
+    const before = Date.now();
+    t.stop();
+    const after = Date.now();
+
+    const entries = t.getEntries();
+    expect(entries[0].stopTime).not.toBeNull();
+    const stopMs = new Date(entries[0].stopTime!).getTime();
+    expect(stopMs).toBeGreaterThanOrEqual(before);
+    expect(stopMs).toBeLessThanOrEqual(after);
+  });
+
+  it('auto-stops the previous timer when starting a new one', () => {
+    const t = makeTracker();
+    t.start('task1');
+    t.start('task2');
+
+    const entries = t.getEntries();
+    expect(entries).toHaveLength(2);
+    expect(entries[0].name).toBe('task1');
+    expect(entries[0].stopTime).not.toBeNull();
+    expect(entries[1].name).toBe('task2');
+    expect(entries[1].stopTime).toBeNull();
+  });
+
+  it('throws when starting a timer with an empty name', () => {
+    const t = makeTracker();
+    expect(() => t.start('')).toThrow();
+  });
+
+  it('throws when stopping with nothing running', () => {
+    const t = makeTracker();
+    expect(() => t.stop()).toThrow();
+  });
+});
+
+describe('TimeTracker - querying', () => {
+  it('returns all entries with getEntries()', () => {
+    const t = makeTracker();
+    t.start('a');
+    t.stop();
+    t.start('b');
+    t.stop();
+
+    expect(t.getEntries()).toHaveLength(2);
+  });
+
+  it('filters entries by date range', () => {
+    const t = makeTracker();
+    const past = new Date('2020-01-01T00:00:00Z');
+    const future = new Date('2020-01-02T00:00:00Z');
+
+    // current entry starts now (not in 2020 range)
+    t.start('now-task');
+    t.stop();
+
+    const entries = t.getEntries({ from: past, to: future });
+    expect(entries).toHaveLength(0);
+  });
+
+  it('includes entries that started within the date range', () => {
+    const t = makeTracker();
+    t.start('task-a');
+    t.stop();
+
+    const from = new Date(Date.now() - 5000);
+    const to = new Date(Date.now() + 5000);
+    const entries = t.getEntries({ from, to });
+    expect(entries).toHaveLength(1);
+    expect(entries[0].name).toBe('task-a');
+  });
+});
+
+describe('TimeTracker - summarizing', () => {
+  it('returns total time per task name in ms', async () => {
+    const t = makeTracker();
+    t.start('coding');
+    await new Promise(r => setTimeout(r, 50));
+    t.stop();
+
+    const summary = t.getSummary();
+    expect(summary['coding']).toBeGreaterThan(0);
+    expect(summary['coding']).toBeLessThan(5000);
+  });
+
+  it('sums multiple entries with the same task name', async () => {
+    const t = makeTracker();
+    t.start('coding');
+    await new Promise(r => setTimeout(r, 20));
+    t.stop();
+    t.start('coding');
+    await new Promise(r => setTimeout(r, 20));
+    t.stop();
+
+    const summary = t.getSummary();
+    expect(summary['coding']).toBeGreaterThanOrEqual(40);
+  });
+
+  it('uses current time for running tasks in summary', async () => {
+    const t = makeTracker();
+    t.start('running');
+    await new Promise(r => setTimeout(r, 30));
+
+    const summary = t.getSummary();
+    expect(summary['running']).toBeGreaterThan(0);
+  });
+});
+
+describe('TimeTracker - unicode support', () => {
+  it('handles unicode task names', () => {
+    const t = makeTracker();
+    t.start('写代码');
+    t.stop();
+
+    const entries = t.getEntries();
+    expect(entries[0].name).toBe('写代码');
+  });
+
+  it('handles emoji task names', () => {
+    const t = makeTracker();
+    t.start('🚀 launch');
+    t.stop();
+
+    const entries = t.getEntries();
+    expect(entries[0].name).toBe('🚀 launch');
+  });
+});
