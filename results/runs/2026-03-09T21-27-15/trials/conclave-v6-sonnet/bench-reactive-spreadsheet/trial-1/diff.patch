e: ${fn}`);\n  }\n}\n\n// ─── Spreadsheet ──────────────────────────────────────────────────────────\n\ninterface CellState {\n  raw: string | number | boolean;      // what was set\n  computed: CellValue;                 // evaluated result\n  deps: Set<string>;                   // cells this cell depends on\n}\n\nexport class Spreadsheet {\n  private cells = new Map<string, CellState>();\n  // reverse deps: dependents[X] = set of cells that depend on X\n  private dependents = new Map<string, Set<string>>();\n\n  set(cell: string, value: string | number | boolean): void {\n    // Normalise cell ref to uppercase\n    cell = cell.toUpperCase();\n\n    // If value is a formula, we need to check for circular refs BEFORE committing\n    if (typeof value === 'string' && value.startsWith('=')) {\n      // Compute new deps without committing\n      const newDeps = this.extractDeps(value, cell);\n\n      // Circular ref detection: DFS from each dep; if we reach `cell`, it's a cycle\n      for (const dep of newDeps) {\n        if (this.reachable(dep, cell)) {\n          throw new Error(`Circular reference detected: ${cell} -> ... -> ${cell}`);\n        }\n      }\n\n      // Also check: direct self-reference (cell in its own deps)\n      if (newDeps.has(cell)) {\n        throw new Error(`Circular reference detected: ${cell} references itself`);\n      }\n    }\n\n    // Remove old reverse-dep edges for this cell\n    const old = this.cells.get(cell);\n    if (old) {\n      for (const dep of old.deps) {\n        const s = this.dependents.get(dep);\n        if (s) s.delete(cell);\n      }\n    }\n\n    // Evaluate and store\n    const state = this.evaluate(cell, value);\n    this.cells.set(cell, state);\n\n    // Register new reverse-dep edges\n    for (const dep of state.deps) {\n      if (!this.dependents.has(dep)) this.dependents.set(dep, new Set());\n      this.dependents.get(dep)!.add(cell);\n    }\n\n    // Propagate reactively\n    this.propagate(cell, new Set([cell]))