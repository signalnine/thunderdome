+// ─── Cell reference utilities ─────────────────────────────────────────────
+
+/** Convert a column letter(s) string (e.g. "A", "AA") to a 1-based column index. */
+function colToIndex(col: string): number {
+  let index = 0;
+  for (let i = 0; i < col.length; i++) {
+    index = index * 26 + (col.charCodeAt(i) - 64);
+  }
+  return index;
+}
+
+/** Parse a cell reference like "A1" or "AA100" into { col, row }. */
+function parseRef(ref: string): { col: string; row: number } {
+  const match = ref.match(/^([A-Z]+)(\d+)$/);
+  if (!match) throw new Error(`Invalid cell reference: ${ref}`);
+  return { col: match[1], row: parseInt(match[2], 10) };
+}
+
+/** Expand a range like "A1:C3" into all cell references in the rectangle. */
+function expandRange(range: string): string[] {
+  const parts = range.split(':');
+  if (parts.length !== 2) throw new Error(`Invalid range: ${range}`);
+  const start = parseRef(parts[0]);
+  const end = parseRef(parts[1]);
+
+  const startCol = colToIndex(start.col);
+  const endCol = colToIndex(end.col);
+  const startRow = Math.min(start.row, end.row);
+  const endRow = Math.max(start.row, end.row);
+
+  const cells: string[] = [];
+  for (let c = Math.min(startCol, endCol); c <= Math.max(startCol, endCol); c++) {
+    const colStr = indexToCol(c);
+    for (let r = startRow; r <= endRow; r++) {
+      cells.push(`${colStr}${r}`);
+    }
+  }
+  return cells;
+}
+
+/** Convert a 1-based column index back to letter(s). */
+function indexToCol(index: number): string {
+  let result = '';
+  while (index > 0) {
+    const rem = (index - 1) % 26;
+    result = String.fromCharCode(65 + rem) + result;
+    index = Math.floor((index - 1) / 26);
+  }
+  return result;
+}
+
+// ─── Tokenizer ────────────────────────────────────────────────────────────
+
+type Token =
+  | { type: 'NUMBER'; value: number }
+  | { type: 'STRING'; value: string }
+  | { type: 'BOOL'; value: boolean }
+  | { type: 'CELL'; value: string }
+  | { type: 'RANGE'; value: string }
+  | { type: 'FUNC'; value: string }
+  | { type: 'OP'; value: string }
+  | { type: 'LPAREN' }
+  | { type: 'RPAREN' }
+  | { type: 'COMMA' };
+
+function tokenize(expr: string): Token[] {
+  const tokens: Token[] = [];
+  let i = 0;
+
+  while (i < expr.length) {
+    const ch = expr[i];
+
+    // Skip whitespace
+    if (/\s/.test(ch)) { i++; continue; }
+
+    // String literal
+    if (ch === '"') {
+      let str = '';
+      i++;
+      while (i < expr.length && expr[i] !== '"') {
+        str += expr[i++];
+      }
+      i++; // closing quote
+      tokens.push({ type: 'STRING', value: str });
+      continue;
+    }
+
+    // Number
+    if (/\d/.test(ch) || (ch === '.' && /\d/.test(expr[i + 1] || ''))) {
+      let num = '';
+      while (i < expr.length && /[\d.]/.test(expr[i])) {
+        num += expr[i++];
+      }
+      tokens.push({ type: 'NUMBER', value: parseFloat(num) });
+      continue;
+    }
+
+    // Identifier: function name, cell reference, TRUE/FALSE
+    if (/[A-Za-z]/.test(ch)) {
+      let ident = '';
+      while (i < expr.length && /[A-Za-z0-9]/.test(expr[i])) {
+        ident += expr[i++];
+      }
+
+      const upper = ident.toUpperCase();
+
+      // Boolean literals
+      if (upper === 'TRUE') { tokens.push({ type: 'BOOL', value: true }); continue; }
+      if (upper === 'FALSE') { tokens.push({ type: 'BOOL', value: false }); continue; }
+
+      // Function call: identifier followed by '('
+      if (i < expr.length && expr[i] === '(') {
+        tokens.push({ type: 'FUNC', value: upper });
+        continue;
+      }
+
+      // Cell reference: letters then digits, possibly followed by ':' (range)
+      if (/^[A-Z]+\d+$/.test(upper)) {
+        // Check for range
+        if (i < expr.length && expr[i] === ':') {
+          i++; // consume ':'
+          let endRef = '';
+          while (i < expr.length && /[A-Za-z0-9]/.test(expr[i])) {
+            endRef += expr[i++];
+          }
+          tokens.push({ type: 'RANGE', value: `${upper}:${endRef.toUpperCase()}` });
+          continue;
+        }
+        tokens.push({ type: 'CELL', value: upper });
+        continue;
+      }
+
+      // Otherwise treat as unknown identifier — shouldn't happen with valid input
+      throw new Error(`Unknown identifier: ${ident}`);
+    }
+
+    // Two-char operators
+    if (i + 1 < expr.length) {
+      const two = expr.slice(i, i + 2);
+      if (two === '>=' || two === '<=' || two === '<>') {
+        tokens.push({ type: 'OP', value: two });
+        i += 2;
+        continue;
+      }
+    }
+
+    // Single-char operators and punctuation
+    if ('+-*/()=<>,'.includes(ch)) {
+      if (ch === '(') { tokens.push({ type: 'LPAREN' }); i++; continue; }
+      if (ch === ')') { tokens.push({ type: 'RPAREN' }); i++; continue; }
+      if (ch === ',') { tokens.push({ type: 'COMMA' }); i++; continue; }
+      tokens.push({ type: 'OP', value: ch });
+      i++;
+      continue;
+    }
+
+    throw new Error(`Unexpected character: ${ch}`);
+  }
+
+  return tokens;
+}
+
+// ─── Parser / Evaluator ──────────────────────────────────────────────────
+
+type CellValue = string | number | boolean | null;
+
+/**
+ * Recursive-descent parser that evaluates a tokenized formula expression.
+ * `getCellValue` resolves cell references.
+ * `collectDeps` is called for each cell reference encountered (for dependency tracking).
+ */
+class ExprEvaluator {
+  private pos = 0;
+
+  constructor(
+    private tokens: Token[],
+    private getCellValue: (ref: string) => CellValue,
+    private getCellsInRange: (range: string) => string[],
+    private collectDep: (ref: string) => void,
+  ) {}
+
+  private peek(): Token | undefined { return this.tokens[this.pos]; }
+  private consume(): Token { return this.tokens[this.pos++]; }
+
+  private expectOp(op: string): void {
+    const t = this.consume();
+    if (t.type !== 'OP' || t.value !== op) throw new Error(`Expected operator '${op}'`);
+  }
+
+  /** expr = comparison (entry point) */
+  evaluate(): CellValue {
+    return this.parseComparison();
+  }
+
+  /** comparison = additive (( '>' | '<' | '>=' | '<=' | '=' | '<>' ) additive)? */
+  private parseComparison(): CellValue {
+    const left = this.parseAdditive();
+    const t = this.peek();
+    if (t && t.type === 'OP' && ['>', '<', '>=', '<=', '=', '<>'].includes(t.value)) {
+      const op = t.value;
+      this.consume();
+      const right = this.parseAdditive();
+      return this.compare(left, op, right);
+    }
+    return left;
+  }
+
+  private compare(left: CellValue, op: string, right: CellValue): boolean {
+    switch (op) {
+      case '>':  return (left as number) > (right as number);
+      case '<':  return (left as number) < (right as number);
+      case '>=': return (left as number) >= (right as number);
+      case '<=': return (left as number) <= (right as number);
+      case '=':  return left === right;
+      case '<>': return left !== right;
+    }
+    throw new Error(`Unknown comparison operator: ${op}`);
+  }
+
+  /** additive = multiplicative (('+' | '-') multiplicative)* */
+  private parseAdditive(): CellValue {
+    let left = this.parseMultiplicative();
+    for (;;) {
+      const t = this.peek();
+      if (!t || t.type !== 'OP' || (t.value !== '+' && t.value !== '-')) break;
+      const op = t.value;
+      this.consume();
+      const right = this.parseMultiplicative();
+      left = op === '+' ? (left as number) + (right as number) : (left as number) - (right as number);
+    }
+    return left;
+  }
+
+  /** multiplicative = unary (('*' | '/') unary)* */
+  private parseMultiplicative(): CellValue {
+    let left = this.parseUnary();
+    for (;;) {
+      const t = this.peek();
+      if (!t || t.type !== 'OP' || (t.value !== '*' && t.value !== '/')) break;
+      const op = t.value;
+      this.consume();
+      const right = this.parseUnary();
+      left = op === '*' ? (left as number) * (right as number) : (left as number) / (right as number);
+    }
+    return left;
+  }
+
+  /** unary = '-' unary | primary */
+  private parseUnary(): CellValue {
+    const t = this.peek();
+    if (t && t.type === 'OP' && t.value === '-') {
+      this.consume();
+      return -(this.parseUnary() as number);
+    }
+    return this.parsePrimary();
+  }
+
+  /** primary = NUMBER | STRING | BOOL | CELL | FUNC '(' args ')' | '(' expr ')' */
+  private parsePrimary(): CellValue {
+    const t = this.peek();
+    if (!t) throw new Error('Unexpected end of expression');
+
+    if (t.type === 'NUMBER') { this.consume(); return t.value; }
+    if (t.type === 'STRING') { this.consume(); return t.value; }
+    if (t.type === 'BOOL')   { this.consume(); return t.value; }
+
+    if (t.type === 'CELL') {
+      this.consume();
+      this.collectDep(t.value);
+      return this.getCellValue(t.value) ?? 0;
+    }
+
+    if (t.type === 'FUNC') {
+      this.consume();
+      // consume '('
+      const lp = this.consume();
+      if (lp.type !== 'LPAREN') throw new Error('Expected ( after function name');
+      const result = this.callFunction(t.value);
+      // consume ')'
+      const rp = this.consume();
+      if (rp.type !== 'RPAREN') throw new Error('Expected ) after function arguments');
+      return result;
+    }
+
+    if (t.type === 'LPAREN') {
+      this.consume();
+      const val = this.evaluate();
+      const rp = this.consume();
+      if (rp.type !== 'RPAREN') throw new Error('Expected closing )');
+      return val;
+    }
+
+    throw new Error(`Unexpected token: ${JSON.stringify(t)}`);
+  }
+
+  private callFunction(name: string): CellValue {
+    switch (name) {
+      case 'SUM':
+      case 'AVERAGE':
+      case 'MIN':
+      case 'MAX':
+      case 'COUNT': {
+        const nums = this.collectRangeNumbers();
+        return this.applyAgg(name, nums);
+      }
+      case 'IF': {
+        const condition = this.evaluate();
+        this.consume(); // COMMA
+        const trueVal = this.evaluate();
+        this.consume(); // COMMA
+        const falseVal = this.evaluate();
+        return condition ? trueVal : falseVal;
+      }
+      default:
+        throw new Error(`Unknown function: ${name}`);
+    }
+  }
+
+  private collectRangeNumbers(): number[] {
+    const t = this.peek();
+    if (!t) throw new Error('Expected range argument');
+
+    if (t.type === 'RANGE') {
+      this.consume();
+      const cells = this.getCellsInRange(t.value);
+      cells.forEach(c => this.collectDep(c));
+      return cells
+        .map(c => this.getCellValue(c))
+        .filter((v): v is number => typeof v === 'number');
+    }
+
+    // Single cell or expression
+    const val = this.evaluate();
+    return typeof val === 'number' ? [val] : [];
+  }
+
+  private applyAgg(fn: string, nums: number[]): number {
+    switch (fn) {
+      case 'SUM':     return nums.reduce((a, b) => a + b, 0);
+      case 'AVERAGE': return nums.length === 0 ? 0 : nums.reduce((a, b) => a + b, 0) / nums.length;
+      case 'MIN':     return nums.length === 0 ? 0 : Math.min(...nums);
+      case 'MAX':     return nums.length === 0 ? 0 : Math.max(...nums);
+      case 'COUNT':   return nums.length;
+    }
+    throw new Error(`Unknown aggregate: ${fn}`);
+  }
+}
+
+// ─── Spreadsheet ──────────────────────────────────────────────────────────
+
+interface CellState {
+  raw: string | number | boolean;      // what was set
+  computed: CellValue;                 // evaluated result
+  deps: Set<string>;                   // cells this cell depends on
+}
+
+export class Spreadsheet {
