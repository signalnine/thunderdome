    sheet.set('Z100', 'end');\n    expect(sheet.get('Z100')).toBe('end');\n  });\n});\n\n// ─── getDisplay ─────────────────────────────────────────────────────────────\n\ndescribe('getDisplay', () => {\n  test('displays number as string', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 42);\n    expect(sheet.getDisplay('A1')).toBe('42');\n  });\n\n  test('displays float', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 3.14);\n    expect(sheet.getDisplay('A1')).toBe('3.14');\n  });\n\n  test('displays string as-is', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 'hello');\n    expect(sheet.getDisplay('A1')).toBe('hello');\n  });\n\n  test('displays boolean true', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', true);\n    expect(sheet.getDisplay('A1')).toBe('true');\n  });\n\n  test('displays empty cell as empty string', () => {\n    const sheet = new Spreadsheet();\n    expect(sheet.getDisplay('A1')).toBe('');\n  });\n});\n\n// ─── getCells ───────────────────────────────────────────────────────────────\n\ndescribe('getCells', () => {\n  test('returns empty map for blank sheet', () => {\n    const sheet = new Spreadsheet();\n    expect(sheet.getCells().size).toBe(0);\n  });\n\n  test('returns non-empty cells', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 10);\n    sheet.set('B2', 'hi');\n    const cells = sheet.getCells();\n    expect(cells.get('A1')).toBe(10);\n    expect(cells.get('B2')).toBe('hi');\n  });\n});\n\n// ─── Arithmetic formulas ────────────────────────────────────────────────────\n\ndescribe('arithmetic formulas', () => {\n  test('formula with a literal number', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', '=5');\n    expect(sheet.get('A1')).toBe(5);\n  });\n\n  test('addition of two literals', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', '=3+4');\n    expect(sheet.get('A1')).toBe(7);\n  });\n\n  test('subtraction', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', '=10-3');\n    expect(sheet.get('A1')).toBe(7);\n  });\n\n  test('multiplication', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', '=3*4');\n    expect(sheet.get('A1')).toBe(12);\n  });\n\n  test('division', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', '=10/4');\n    expect(sheet.get('A1')).toBe(2.5);\n  });\n\n  test('operator precedence: multiplication before addition', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', '=2+3*4');\n    expect(sheet.get('A1')).toBe(14);\n  });\n\n  test('parentheses override precedence', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', '=(2+3)*4');\n    expect(sheet.get('A1')).toBe(20);\n  });\n\n  test('cell reference in formula', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 10);\n    sheet.set('B1', '=A1');\n    expect(sheet.get('B1')).toBe(10);\n  });\n\n  test('formula adding two cell references', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 10);\n    sheet.set('A2', 20);\n    sheet.set('A3', '=A1+A2');\n    expect(sheet.get('A3')).toBe(30);\n  });\n\n  test('formula referencing empty cell treats it as 0', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', '=B1+5');\n    expect(sheet.get('A1')).toBe(5);\n  });\n});\n\n// ─── Reactive updates ───────────────────────────────────────────────────────\n\ndescribe('reactive updates', () => {\n  test('dependent cell updates when source changes', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 5);\n    sheet.set('B1', '=A1+1');\n    expect(sheet.get('B1')).toBe(6);\n\n    sheet.set('A1', 10);\n    expect(sheet.get('B1')).toBe(11);\n  });\n\n  test('transitive dependency updates', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 1);\n    sheet.set('B1', '=A1+1');\n    sheet.set('C1', '=B1+1');\n    expect(sheet.get('C1')).toBe(3);\n\n    sheet.