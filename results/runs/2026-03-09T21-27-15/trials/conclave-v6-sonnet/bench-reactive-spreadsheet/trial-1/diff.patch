--- /dev/null
+++ b/src/index.test.ts
@@ -0,0 +1,411 @@
+import { describe, test, expect } from 'vitest';
+import { Spreadsheet } from './index.js';
+
+// ─── Basic get/set ──────────────────────────────────────────────────────────
+
+describe('basic get/set', () => {
+  test('empty cell returns null', () => {
+    const sheet = new Spreadsheet();
+    expect(sheet.get('A1')).toBeNull();
+  });
+
+  test('set and get a number', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', 42);
+    expect(sheet.get('A1')).toBe(42);
+  });
+
+  test('set and get a float', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('B2', 3.14);
+    expect(sheet.get('B2')).toBe(3.14);
+  });
+
+  test('set and get a string', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('C3', 'hello');
+    expect(sheet.get('C3')).toBe('hello');
+  });
+
+  test('set and get a boolean true', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('D4', true);
+    expect(sheet.get('D4')).toBe(true);
+  });
+
+  test('set and get a boolean false', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('E5', false);
+    expect(sheet.get('E5')).toBe(false);
+  });
+
+  test('overwriting a cell updates its value', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', 10);
+    sheet.set('A1', 99);
+    expect(sheet.get('A1')).toBe(99);
+  });
+
+  test('cell references with multi-letter columns like AA1', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('AA1', 7);
+    expect(sheet.get('AA1')).toBe(7);
+  });
+
+  test('row numbers above 1', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('Z100', 'end');
+    expect(sheet.get('Z100')).toBe('end');
+  });
+});
+
+// ─── getDisplay ─────────────────────────────────────────────────────────────
+
+describe('getDisplay', () => {
+  test('displays number as string', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', 42);
+    expect(sheet.getDisplay('A1')).toBe('42');
+  });
+
+  test('displays float', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', 3.14);
+    expect(sheet.getDisplay('A1')).toBe('3.14');
+  });
+
+  test('displays string as-is', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', 'hello');
+    expect(sheet.getDisplay('A1')).toBe('hello');
+  });
+
+  test('displays boolean true', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', true);
+    expect(sheet.getDisplay('A1')).toBe('true');
+  });
+
+  test('displays empty cell as empty string', () => {
+    const sheet = new Spreadsheet();
+    expect(sheet.getDisplay('A1')).toBe('');
+  });
+});
+
+// ─── getCells ───────────────────────────────────────────────────────────────
+
+describe('getCells', () => {
+  test('returns empty map for blank sheet', () => {
+    const sheet = new Spreadsheet();
+    expect(sheet.getCells().size).toBe(0);
+  });
+
+  test('returns non-empty cells', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', 10);
+    sheet.set('B2', 'hi');
+    const cells = sheet.getCells();
+    expect(cells.get('A1')).toBe(10);
+    expect(cells.get('B2')).toBe('hi');
+  });
+});
+
+// ─── Arithmetic formulas ────────────────────────────────────────────────────
+
+describe('arithmetic formulas', () => {
+  test('formula with a literal number', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', '=5');
+    expect(sheet.get('A1')).toBe(5);
