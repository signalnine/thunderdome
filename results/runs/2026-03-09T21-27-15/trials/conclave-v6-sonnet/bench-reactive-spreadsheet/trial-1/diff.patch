urn true;\n      if (visited.has(node)) continue;\n      visited.add(node);\n      const state = this.cells.get(node);\n      if (state) {\n        for (const dep of state.deps) stack.push(dep);\n      }\n    }\n    return false;\n  }\n\n  /** Re-evaluate all cells that depend on `changed`, in topological order. */\n  private propagate(changed: string, visited: Set<string>): void {\n    const deps = this.dependents.get(changed);\n    if (!deps) return;\n    for (const dep of deps) {\n      if (visited.has(dep)) continue;\n      visited.add(dep);\n      const state = this.cells.get(dep);\n      if (!state) continue;\n      // Re-evaluate using same raw formula\n      const newState = this.evaluate(dep, state.raw);\n      // Update reverse deps (deps may change if formula references changed)\n      for (const d of state.deps) {\n        const s = this.dependents.get(d);\n        if (s) s.delete(dep);\n      }\n      this.cells.set(dep, newState);\n      for (const d of newState.deps) {\n        if (!this.dependents.has(d)) this.dependents.set(d, new Set());\n        this.dependents.get(d)!.add(dep);\n      }\n      this.propagate(dep, visited);\n    }\n  }\n}\n","structuredPatch":[{"oldStart":234,"oldLines":7,"newStart":234,"newLines":7,"lines":["   /** multiplicative = unary (('*' | '/') unary)* */","   private parseMultiplicative(): CellValue {","     let left = this.parseUnary();","-    while (true) {","+    for (;;) {","       const t = this.peek();","       if (!t || t.type !== 'OP' || (t.value !== '*' && t.value !== '/')) break;","       const op = t.value;"]}],"userModified":false,"replaceAll":false}}
