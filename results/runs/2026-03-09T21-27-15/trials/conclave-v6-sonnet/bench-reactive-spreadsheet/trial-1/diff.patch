+      const newDeps = this.extractDeps(value, cell);
+
+      // Circular ref detection: DFS from each dep; if we reach `cell`, it's a cycle
+      for (const dep of newDeps) {
+        if (this.reachable(dep, cell)) {
+          throw new Error(`Circular reference detected: ${cell} -> ... -> ${cell}`);
+        }
+      }
+
+      // Also check: direct self-reference (cell in its own deps)
+      if (newDeps.has(cell)) {
+        throw new Error(`Circular reference detected: ${cell} references itself`);
+      }
+    }
+
+    // Remove old reverse-dep edges for this cell
+    const old = this.cells.get(cell);
+    if (old) {
+      for (const dep of old.deps) {
+        const s = this.dependents.get(dep);
+        if (s) s.delete(cell);
+      }
+    }
+
+    // Evaluate and store
+    const state = this.evaluate(cell, value);
+    this.cells.set(cell, state);
+
+    // Register new reverse-dep edges
+    for (const dep of state.deps) {
+      if (!this.dependents.has(dep)) this.dependents.set(dep, new Set());
+      this.dependents.get(dep)!.add(cell);
+    }
+
+    // Propagate reactively
+    this.propagate(cell, new Set([cell]));
+  }
+
+  get(cell: string): CellValue {
+    cell = cell.toUpperCase();
+    return this.cells.get(cell)?.computed ?? null;
+  }
+
+  getDisplay(cell: string): string {
+    const val = this.get(cell);
+    if (val === null) return '';
+    return String(val);
+  }
+
+  getCells(): Map<string, CellValue> {
+    const result = new Map<string, CellValue>();
+    for (const [ref, state] of this.cells) {
+      result.set(ref, state.computed);
+    }
+    return result;
+  }
+
+  // ─── Internal helpers ──────────────────────────────────────────────────
+
+  private evaluate(cell: string, raw: string | number | boolean): CellState {
+    const deps = new Set<string>();
+
+    let computed: CellValue;
+    if (typeof raw === 'string' && raw.startsWith('=')) {
+      const expr = raw.slice(1);
+      computed = this.evalExpr(expr, deps);
+    } else if (typeof raw === 'string') {
+      computed = raw;
+    } else {
+      computed = raw;
+    }
+
+    return { raw, computed, deps };
+  }
+
+  private evalExpr(expr: string, deps: Set<string>): CellValue {
+    const tokens = tokenize(expr);
+    const evaluator = new ExprEvaluator(
+      tokens,
+      (ref) => this.cells.get(ref)?.computed ?? null,
+      (range) => expandRange(range),
+      (ref) => deps.add(ref),
+    );
+    return evaluator.evaluate();
+  }
+
+  /** Extract deps from a formula without storing anything. */
+  private extractDeps(formula: string, _forCell: string): Set<string> {
+    const deps = new Set<string>();
+    try {
+      this.evalExpr(formula.slice(1), deps);
+    } catch {
+      // Partial evaluation is fine here; we only need the deps parsed so far
+    }
+    return deps;
+  }
+
+  /** Check if `target` is reachable from `start` through dependency edges. */
+  private reachable(start: string, target: string): boolean {
+    const visited = new Set<string>();
+    const stack = [start];
+    while (stack.length > 0) {
+      const node = stack.pop()!;
+      if (node === target) return true;
+      if (visited.has(node)) continue;
+      visited.add(node);
+      const state = this.cells.get(node);
+      if (state) {
+        for (const dep of state.deps) stack.push(dep);
+      }
+    }
+    return false;
+  }
+
+  /** Re-evaluate all cells that depend on `changed`, in topological order. */
+  private propagate(changed: string, visited: Set<string>): void {
+    const deps = this.dependents.get(changed);
+    if (!deps) return;
+    for (const dep of deps) {
+      if (visited.has(dep)) continue;
+      visited.add(dep);
+      const state = this.cells.get(dep);
+      if (!state) continue;
+      // Re-evaluate using same raw formula
+      const newState = this.evaluate(dep, state.raw);
+      // Update reverse deps (deps may change if formula references changed)
+      for (const d of state.deps) {
+        const s = this.dependents.get(d);
+        if (s) s.delete(dep);
+      }
+      this.cells.set(dep, newState);
+      for (const d of newState.deps) {
+        if (!this.dependents.has(d)) this.dependents.set(d, new Set());
+        this.dependents.get(d)!.add(dep);
+      }
+      this.propagate(dep, visited);
+    }
+  }
+}
