4v(z);\n      if (best === null || isBetterVec(z, w, best, bestW)) { best = z; bestW = w; }\n    }\n  }\n  if (bestW === 0) return best!;\n\n  // Search radius 1: flip each bit of vB and look for match\n  for (const vB of sideBArr) {\n    // Try flipping each of the BITS bit positions\n    for (let b = 0; b < BITS; b++) {\n      const query = vec64SetBit(vB, b);\n      // Check if we already had this bit set (XOR gives flip)\n      const flipped = vec64Bit(vB, b) ?\n        (b < 32 ? [vB[0], vB[1] & ~(1 << b)] as Vec64 : [vB[0] & ~(1 << (b - 32)), vB[1]] as Vec64) :\n        query;\n      const vA = sideAMap.get(vec64Key(flipped));\n      if (vA !== undefined) {\n        const z = vec64Xor(vA, vB);\n        const w = popcount64v(z);\n        if (best === null || isBetterVec(z, w, best, bestW)) { best = z; bestW = w; }\n      }\n    }\n  }\n  if (bestW <= 1) return best!;\n\n  // Search radius 2: flip 2 bits of vB\n  for (const vB of sideBArr) {\n    for (let b1 = 0; b1 < BITS; b1++) {\n      for (let b2 = b1 + 1; b2 < BITS; b2++) {\n        let q = vec64Bit(vB, b1) ?\n          (b1 < 32 ? [vB[0], vB[1] & ~(1 << b1)] as Vec64 : [vB[0] & ~(1 << (b1-32)), vB[1]] as Vec64) :\n          (b1 < 32 ? [vB[0], vB[1] | (1 << b1)] as Vec64 : [vB[0] | (1 << (b1-32)), vB[1]] as Vec64);\n        q = vec64Bit(vB, b2) ?\n          (b2 < 32 ? [q[0], q[1] & ~(1 << b2)] as Vec64 : [q[0] & ~(1 << (b2-32)), q[1]] as Vec64) :\n          (b2 < 32 ? [q[0], q[1] | (1 << b2)] as Vec64 : [q[0] | (1 << (b2-32)), q[1]] as Vec64);\n        const vA = sideAMap.get(vec64Key(q));\n        if (vA !== undefined) {\n          const z = vec64Xor(vA, vB);\n          const w = popcount64v(z);\n          if (best === null || isBetterVec(z, w, best, bestW)) { best = z; bestW = w; }\n        }\n      }\n    }\n  }\n  if (bestW <= 2) return best!;\n\n  // For higher radii, fall back to sorted enumeration\n  const sideAArr: Vec64[] = Array.from(sideAMap.values());\n  const sideASorted = sideAArr.sort((a, b) =>