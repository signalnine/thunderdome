+  return vec64ToArray(bestVec, numButtons);
+}
+
+/**
+ * Find the lex-smallest subset of exactly w buttons that is a valid solution.
+ * Enumerates all C(numButtons, w) subsets in lex order using Gosper's hack.
+ * Returns null if no valid subset found.
+ */
+function findLexSmallestWeight(
+  w: number,
+  numButtons: number,
+  isInCoset: (lo: number, hi: number) => boolean
+): number[] | null {
+  if (w === 0) {
+    if (isInCoset(0, 0)) return [];
+    return null;
+  }
+  if (w > numButtons) return null;
+
+  // Enumerate all w-element subsets of {0..numButtons-1} in lexicographic order.
+  // We represent each subset as a bitmask split into lo (bits 0-31) and hi (bits 32-39).
+  // Use recursive enumeration for up to 5 elements, which avoids Gosper's hack
+  // complications with 64-bit masks.
+
+  // State: chosen[0..w-1] = button indices in increasing order
+  const chosen = new Array(w).fill(0);
+  for (let i = 0; i < w; i++) chosen[i] = i; // start with [0,1,...,w-1]
+
+  let exhausted = false;
+  while (!exhausted) {
+    // Build lo and hi from chosen
+    let lo = 0, hi = 0;
+    for (const b of chosen) {
+      if (b < 32) lo |= (1 << b);
+      else hi |= (1 << (b - 32));
+    }
+
+    if (isInCoset(lo, hi)) {
+      return chosen.slice();
+    }
+
+    // Advance to next lex subset
+    // Find rightmost position i that can be incremented
+    let pos = w - 1;
+    while (pos >= 0 && chosen[pos] >= numButtons - (w - pos)) {
+      pos--;
+    }
+    if (pos < 0) { exhausted = true; break; }
+
+    chosen[pos]++;
+    for (let k = pos + 1; k < w; k++) {
+      chosen[k] = chosen[k - 1] + 1;
+    }
+  }
+
+  return null;
+}
+
+/**
+ * Compute solution with given free variable values.
+ * freeVals: Vec64 where bit freeCols[fi] = value of free variable fi.
+ */
+function computeSolutionVec(
+  freeVals: Vec64,
+  augRows: Vec64[],
+  pivotCols: number[],
+  freeCols: number[],
+  colToRow: Map<number, number>,
+  rhsBit: number,
+  _numButtons: number
+): Vec64 {
+  let x = vec64Zero();
+  // Set free variable bits
+  for (const fc of freeCols) {
+    if (vec64Bit(freeVals, fc)) x = vec64SetBit(x, fc);
+  }
+
+  // Back-substitute pivot variables
+  for (const j of pivotCols) {
+    const r = colToRow.get(j)!;
+    const row = augRows[r];
+    let rhs = vec64Bit(row, rhsBit) ? 1 : 0;
+    // XOR in contributions from other columns (those set in row & x)
+    // In RREF, only free columns can be non-zero in this row (besides pivot j)
+    for (const fc of freeCols) {
+      if (vec64Bit(row, fc) && vec64Bit(x, fc)) rhs ^= 1;
+    }
+    if (rhs) x = vec64SetBit(x, j);
+  }
