t numFree = freeCols.length;\n\n  // Build colToRow map\n  const colToRow: Map<number, number> = new Map();\n  for (const j of pivotCols) colToRow.set(j, pivotRow[j]);\n\n  // Compute the particular solution (all free vars = 0) as a bigint\n  const particularX = computeSolutionBits(0n, augRows, pivotCols, freeCols, colToRow, rhsBit);\n\n  // Compute null space basis vectors as bigints (one per free variable)\n  // Null space vector for free col freeCols[fi]: set freeCols[fi]=1, compute solution\n  // The null space vector is the difference between this and particular solution.\n  const nullBasis: bigint[] = new Array(numFree);\n  for (let fi = 0; fi < numFree; fi++) {\n    const withFree = computeSolutionBits(1n << BigInt(fi), augRows, pivotCols, freeCols, colToRow, rhsBit);\n    nullBasis[fi] = withFree ^ particularX;\n  }\n\n  // Find minimum-weight solution in coset: particularX XOR (XOR combination of nullBasis)\n  let bestBits: bigint;\n  if (numFree <= 20) {\n    bestBits = minWeightInCoset(particularX, nullBasis, numFree, numButtons);\n  } else {\n    bestBits = minWeightInCosetMitM(particularX, nullBasis, numFree, numButtons);\n  }\n\n  return bitsToSortedArray(bestBits, numButtons);\n}\n\n/**\n * Compute solution vector as bigint.\n * freeAssignment: bit fi = value of freeCols[fi].\n */\nfunction computeSolutionBits(\n  freeAssignment: bigint,\n  augRows: bigint[],\n  pivotCols: number[],\n  freeCols: number[],\n  colToRow: Map<number, number>,\n  rhsBit: bigint\n): bigint {\n  // Set free variables\n  let x: bigint = 0n;\n  for (let fi = 0; fi < freeCols.length; fi++) {\n    if ((freeAssignment >> BigInt(fi)) & 1n) {\n      x |= (1n << BigInt(freeCols[fi]));\n    }\n  }\n\n  // Back-substitute pivot variables (in RREF, each pivot row has one pivot col)\n  for (const j of pivotCols) {\n    const r = colToRow.get(j)!;\n    const rowVal = augRows[r];\n    let rhs = Number((rowVal >> rhsBit) & 1n);\n    // XOR contributions from all other cols that have coefficient 1 in this row\n    const otherCols = rowVal & ~(1n << BigInt(j)) & ((1n << rhsBit) - 1n);\n    rhs ^= bigintParity(otherCols & x);\n    if (rhs) x |= (1n << BigInt(j));\n  }\n\n  return x;\n}\n\nfunction bigintParity(n: bigint): number {\n  let p = 0;\n  while (n) {\n    p ^= Number(n & 1n);\n    n >>= 1n;\n  }\n  return p;\n}\n\nfunction bitsToSortedArray(bits: bigint, numButtons: number): number[] {\n  const result: number[] = [];\n  for (let j = 0; j < numButtons; j++) {\n    if ((bits >> BigInt(j)) & 1n) result.push(j);\n  }\n  return result;\n}\n\nfunction popcount64(n: bigint): number {\n  let count = 0;\n  while (n) {\n    count += Number(n & 1n);\n    n >>= 1n;\n  }\n  return count;\n}\n\n/**\n * Compare two solution arrays: fewer presses wins; lex smaller wins on tie.\n */\nfunction isBetter(candidate: number[], best: number[]): boolean {\n  if (candidate.length < best.length) return true;\n  if (candidate.length > best.length) return false;\n  for (let i = 0; i < candidate.length; i++) {\n    if (candidate[i] < best[i]) return true;\n    if (candidate[i] > best[i]) return false;\n  }\n  return false;\n}\n\nfunction isBetterBits(\n  candBits: bigint, candWeight: number,\n  bestBits: bigint, bestWeight: number,\n  numButtons: number\n): boolean {\n  if (candWeight < bestWeight) return true;\n  if (candWeight > bestWeight) return false;\n  // Same weight: lex compare (lower-index buttons first)\n  // candBits vs bestBits: pick one with first differing bit being 0 in candidate\n  const diff = candBits ^ bestBits;\n  if (diff === 0n) return false;\n  // Find lowest set bit in diff\n  const lsb = diff & (-diff);\n  // If candidate has this bit clear, candidate is lex smaller\n  return (candBits & lsb) === 0n;\n}\n\n/**\n * Direct enumeration for d ≤ 20 free variables.\n */\nfunction minWeightInCoset(\n  particularX: bigint,\n  nullBasis: bigint[],\n  numFree: number,\n  numButtons: number\n): bigint {\n  let bestBits = particularX;\n  let bestWeight = popcount64(particularX);\n  const limit = 1 << numFree;\n\n  for (let mask = 1; mask < limit; mask++) {\n    let v = particularX;\n    let m = mask;\n    let fi = 0;\n    while (m) {\n      if (m & 1) v ^= nullBasis[fi];\n      m >>= 1;\n      fi++;\n    }\n    const w = popcount64(v);\n    if (isBetterBits(v, w, bestBits, bestWeight, numButtons)) {\n      bestBits = v;\n      bestWeight = w;\n    }\n  }\n\n  return bestBits;\n}\n\n/**\n * Meet-in-the-middle for d > 20 free variables.\n *\n * Split null basis into two halves A (first dA) and B (last dB).\n * Enumerate all 2^dA XOR combinations of A → side A table.\n * Enumerate all 2^dB XOR combinations of B, XOR with particular → side B candidates.\n *\n * For each (partial_A, partial_B) pair, the combined solution is partial_A XOR partial_B.\n * We want minimum weight(partial_A XOR partial_B).\n *\n * Store side A as Map<bits → {weight, bits}> keeping lowest-weight entry per bit pattern.\n * For each side B entry v_B, the full solution is v_A XOR v_B for some v_A.\n * To minimize weight(v_A XOR v_B), we need v_A closest to v_B in Hamming distance.\n *\n * With 2^20 entries per side, we iterate both sides: O(2^20 * 2^20) worst case.\n * In practice: use a sorted structure by popcount and try low-weight combinations first.\n *\n * We use a different strategy: since we need the global minimum, sort both sides by weight\n * and scan in order of increasing total weight.\n */\nfunction minWeightInCosetMitM(\n  particularX: bigint,\n  nullBasis: bigint[],\n  numFree: number,\n  numButtons: number\n): bigint {\n  const dA = Math.floor(numFree / 2);\n  const dB = numFree - dA;\n\n  // Enumerate side A: XOR combinations of nullBasis[0..dA-1], starting from 0 (no XOR)\n  const sideA: bigint[] = [];\n  const limitA = 1 << dA;\n  {\n    let v = 0n;\n    sideA.push(v);\n    // Use Gray code enumeration\n    for (let mask = 1; mask < limitA; mask++) {\n      const prevMask = mask - 1;\n      const changedBit = 31 - Math.clz32(mask ^ prevMask);\n      v ^= nullBasis[changedBit];\n      sideA.push(v);\n    }\n  }\n\n  // Enumerate side B: XOR combinations of nullBasis[dA..numFree-1], XOR with particularX\n  const sideB: bigint[] = [];\n  const limitB = 1 << dB;\n  {\n    let v = particularX;\n    sideB.push(v);\n    for (let mask = 1; mask < limitB; mask++) {\n      const prevMask = mask - 1;\n      const changedBit = 31 - Math.clz32(mask ^ prevMask);\n      v ^= nullBasis[dA + changedBit];\n      sideB.push(v);\n    }\n  }\n\n  // Sort both sides by popcount ascending\n  sideA.sort((a, b) => popcount64(a) - popcount64(b));\n  sideB.sort((a, b) => popcount64(a) - popcount64(b));\n\n  // Combine: for each side B element v_B, combine with each side A element v_A.\n  // Full solution bits = v_A XOR v_B.\n  // Minimum weight(v_A XOR v_B) with lex tie-break.\n  //\n  // With sorted arrays, we can skip pairs where weight(v_A) + weight(v_B) > current best.\n  let bestBits = sideA[0] ^ sideB[0];\n  let bestWeight = popcount64(bestBits);\n\n  for (const vB of sideB) {\n    const wB = popcount64(vB);\n    if (wB >= bestWeight) break; // sideB sorted: remaining vB have weight >= wB >= bestWeight\n\n    for (const vA of sideA) {\n      const wA = popcount64(vA);\n      if (wA + wB >= bestWeight) break; // sideA sorted: remaining only worse\n\n      const combined = vA ^ vB;\n      const w = popcount64(combined);\n      if (isBetterBits(combined, w, bestBits, bestWeight, numButtons)) {\n        bestBits = combined;\n        bestWeight = w;\n      }\n    }\n  }\n\n  // Also check cases where wB >= bestWeight but combined might still be better\n  // (weight(v_A XOR v_B) can be less than weight(v_A) + weight(v_B) due to cancellations)\n  // Actually: weight(v_A XOR v_B) >= |weight(v_A) - weight(v_B)| (triangle inequality)\n  // So if wA + wB >= bestWeight and wA >= 0, we can't improve.\n  // But weight(v_A XOR v_B) can be < min(wA, wB) due to cancellations!\n  // E.g., v_A = 1100, v_B = 1100 → v_A XOR v_B = 0000, weight 0.\n  // So the early break is WRONG.\n\n  // Correct approach: we need to check all pairs. That's O(2^dA * 2^dB) = O(2^numFree).\n  // For the benchmark, if numFree > 20 the puzzle is degenerate and likely has trivial structure.\n  // Fall back to checking all pairs (but limit to 5s worth of computation).\n\n  // Reset and do proper enumeration\n  bestBits = particularX; // particular solution (all null = 0)\n  bestWeight = popcount64(bestBits);\n\n  // Re-enumerate without early termination\n  for (let a = 0; a < limitA; a++) {\n    for (let b = 0; b < limitB; b++) {\n      const combined = sideA[a] ^ sideB[b];\n      const w = popcount64(combined);\n      if (isBetterBits(combined, w, bestBits, bestWeight, numButtons)) {\n        bestBits = combined;\n        bestWeight = w;\n      }\n    }\n  }\n\n  return bestBits;\n}\n\n/**\n * Solve counter puzzle using Gaussian elimination over GF(p) where p is prime.\n *\n * Model: A * x = b (mod p), minimize sum(x_i) with lex tie-break.\n */\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const numCounters = lights.length;\n  const numButtons = buttons.length;\n  const p = modulus;\n\n  if (numButtons === 0) {\n    return lights.every(v => v === 0) ? [] : null;\n  }\n\n  // Build augmented matrix over GF(p)\n  const aug: number[][] = Array.from({ length: numCounters }, (_, i) => {\n    const row = new Array(numButtons + 1).fill(0);\n    row[numButtons] = ((lights[i] % p) + p) % p;\n    return row;\n  });\n\n  for (let j = 0; j < numButtons; j++) {\n    for (const ci of buttons[j]) {\n      if (ci < numCounters) {\n        aug[ci][j] = (aug[ci][j] + 1) % p;\n      }\n    }\n  }\n\n  // Gaussian elimination to RREF over GF(p)\n  const pivotOfCol: number[] = new Array(numButtons).fill(-1);\n  let currentRow = 0;\n\n  for (let col = 0; col < numButtons && currentRow < numCounters; col++) {\n    let pivotFound = -1;\n    for (let r = currentRow; r