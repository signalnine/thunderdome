target: boolean[];\n  buttons: number[][];\n}\n\n// 64-bit vector representation using two 32-bit unsigned integers [hi, lo]\n// hi = bits 32-39 (upper 8 bits for buttons 32-39)\n// lo = bits 0-31  (lower 32 bits for buttons 0-31)\ntype Vec64 = [number, number]; // [hi, lo]\n\nfunction vec64Zero(): Vec64 { return [0, 0]; }\nfunction vec64Xor(a: Vec64, b: Vec64): Vec64 { return [a[0] ^ b[0], a[1] ^ b[1]]; }\nfunction vec64Bit(v: Vec64, bit: number): boolean {\n  if (bit < 32) return !!(v[1] >>> bit & 1);\n  return !!(v[0] >>> (bit - 32) & 1);\n}\nfunction vec64SetBit(v: Vec64, bit: number): Vec64 {\n  if (bit < 32) return [v[0], v[1] | (1 << bit)];\n  return [v[0] | (1 << (bit - 32)), v[1]];\n}\n\nfunction popcount32(n: number): number {\n  n = n >>> 0;\n  n -= (n >>> 1) & 0x55555555;\n  n = (n & 0x33333333) + ((n >>> 2) & 0x33333333);\n  n = (n + (n >>> 4)) & 0x0f0f0f0f;\n  return ((n * 0x01010101) >>> 24) & 0xff;\n}\n\nfunction popcount64v(v: Vec64): number {\n  return popcount32(v[0]) + popcount32(v[1]);\n}\n\n// Compare two solutions represented as Vec64: fewer bits wins; lex smaller wins on tie.\n// \"Lex smaller\" means the first (lowest index) differing button is present in candidate.\nfunction isBetterVec(\n  cand: Vec64, candW: number,\n  best: Vec64, bestW: number\n): boolean {\n  if (candW < bestW) return true;\n  if (candW > bestW) return false;\n  // Same weight: lex compare by lowest differing button index\n  const dlo = cand[1] ^ best[1];\n  if (dlo !== 0) {\n    const lsb = dlo & (-dlo);\n    return (cand[1] & lsb) !== 0;\n  }\n  const dhi = cand[0] ^ best[0];\n  if (dhi !== 0) {\n    const lsb = dhi & (-dhi);\n    return (cand[0] & lsb) !== 0;\n  }\n  return false;\n}\n\nfunction vec64ToArray(v: Vec64, numButtons: number): number[] {\n  const result: number[] = [];\n  for (let j = 0; j < numButtons; j++) {\n    if (vec64Bit(v, j)) result.push(j);\n  }\n  return result;\n}\n\n// Use a single 64-bit float as key. For 40-bit vectors, hi is ≤ 8 bits, lo ≤ 32 bits.\n// Key = hi * 2^32 + lo (as a float, exact for values ≤ 2^53)\nfunction vec64Key(v: Vec64): number {\n  return (v[0] >>> 0) * 4294967296 + (v[1] >>> 0);\n}\n\n/**\n * Solve toggle puzzle using Gaussian elimination over GF(2).\n * Finds minimum Hamming weight solution, lex smallest on ties.\n */\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const numLights = target.length;\n  const numButtons = buttons.length;\n\n  if (numButtons === 0) {\n    return target.every(v => !v) ? [] : null;\n  }\n\n  // Augmented matrix over GF(2): row i = button coefficients | rhs for light i\n  // Using Vec64 for rows (buttons 0-39 in lo/hi, rhs in bit numButtons)\n  // But numButtons can be up to 40, so rhs bit = bit 40 = bit 8 of hi-word.\n  // Let's use regular arrays of numbers for the augmented matrix.\n  // Row = two 32-bit ints for up to 64 bits. We need numButtons+1 bits.\n  // For numButtons=40, we need 41 bits. Use [hi (bits 32-40), lo (bits 0-31)].\n\n  const RHS_BIT = numButtons; // bit position of rhs\n  // Use Vec64 where bit RHS_BIT = rhs\n  const augRows: Vec64[] = new Array(numLights).fill(null).map(() => vec64Zero());\n\n  for (let i = 0; i < numLights; i++) {\n    if (target[i]) augRows[i] = vec64SetBit(augRows[i], RHS_BIT);\n  }\n  for (let j = 0; j < numButtons; j++) {\n    for (const lightIdx of buttons[j]) {\n      if (lightIdx < numLights) {\n        augRows[lightIdx] = vec64Xor(augRows[lightIdx], vec64SetBit(vec64Zero(), j));\n      }\n    }\n  }\n\n  // Gaussian elimination to RREF over GF(2)\n  const pivotRow: number[] = new Array(numButtons).fill(-1);\n  let currentRow = 0;\n\n  for (let col = 0; col < numButtons && currentRow < numLights; col++) {\n    let pivotFound = -1;\n    for (let r = currentRow; r < numLights; r++) {\n      if (vec64Bit(augRows[r], col)) { pivotFound = r; break; }\n    }\n    if (pivotFound === -1) continue;\n\n    [augRows[currentRow], augRows[pivotFound]] = [augRows[pivotFound], augRows[currentRow]];\n    pivotRow[col] = currentRow;\n\n    for (let r = 0; r < numLights; r++) {\n      if (r !== currentRow && vec64Bit(augRows[r], col)) {\n        augRows[r] = vec64Xor(augRows[r], augRows[currentRow]);\n      }\n    }\n    currentRow++;\n  }\n\n  // Check consistency\n  for (let r = 0; r < numLights; r++) {\n    let hasCoeff = false;\n    for (let j = 0; j < numButtons; j++) {\n      if (vec64Bit(augRows[r], j)) { hasCoeff = true; break; }\n    }\n    if (!hasCoeff && vec64Bit(augRows[r], RHS_BIT)) return null;\n  }\n\n  // Identify pivot and free columns\n  const freeCols: number[] = [];\n  const pivotCols: number[] = [];\n  for (let j = 0; j < numButtons; j++) {\n    if (pivotRow[j] !== -1) pivotCols.push(j);\n    else freeCols.push(j);\n  }\n\n  const numFree = freeCols.length;\n  const colToRow: Map<number, number> = new Map();\n  for (const j of pivotCols) colToRow.set(j, pivotRow[j]);\n\n  // Compute particular solution (all free = 0)\n  const particularX = computeSolutionVec(\n    vec64Zero(), augRows, pivotCols, freeCols, colToRow, RHS_BIT, numButtons\n  );\n\n  // Compute null space basis vectors\n  const nullBasis: Vec64[] = new Array(numFree);\n  for (let fi = 0; fi < numFree; fi++) {\n    const withFree = computeSolutionVec(\n      vec64SetBit(vec64Zero(), freeCols[fi]),\n      augRows, pivotCols, freeCols, colToRow, RHS_BIT, numButtons\n    );\n    nullBasis[fi] = vec64Xor(withFree, particularX);\n  }\n\n  // Find minimum weight solution in coset\n  let bestVec: Vec64;\n  if (numFree <= 20) {\n    bestVec = minWeightDirect(particularX, nullBasis, numFree);\n  } else {\n    bestVec = minWeightMitM(particularX, nullBasis, numFree);\n  }\n\n  return vec64ToArray(bestVec, numButtons);\n}\n\n/**\n * Compute solution with given free variable values.\n * freeVals: Vec64 where bit freeCols[fi] = value of free variable fi.\n */\nfunction computeSolutionVec(\n  freeVals: Vec64,\n  augRows: Vec64[],\n  pivotCols: number[],\n  freeCols: number[],\n  colToRow: Map<number, number>,\n  rhsBit: number,\n  _numButtons: number\n): Vec64 {\n  let x = vec64Zero();\n  // Set free variable bits\n  for (const fc of freeCols) {\n    if (vec64Bit(freeVals, fc)) x = vec64SetBit(x, fc);\n  }\n\n  // Back-substitute pivot variables\n  for (const j of pivotCols) {\n    const r = colToRow.get(j)!;\n    const row = augRows[r];\n    let rhs = vec64Bit(row, rhsBit) ? 1 : 0;\n    // XOR in contributions from other columns (those set in row & x)\n    // In RREF, only free columns can be non-zero in this row (besides pivot j)\n    for (const fc of freeCols) {\n      if (vec64Bit(row, fc) && vec64Bit(x, fc)) rhs ^= 1;\n    }\n    if (rhs) x = vec64SetBit(x, j);\n  }\n\n  return x;\n}\n\n/**\n * Direct enumeration for numFree ≤ 20.\n */\nfunction minWeightDirect(\n  particularX: Vec64,\n  nullBasis: Vec64[],\n  numFree: number\n): Vec64 {\n  let best = particularX;\n  let bestW = popcount64v(particularX);\n\n  // Gray code enumeration for efficiency\n  let v = particularX;\n  const limit = 1 << numFree;\n  for (let mask = 1; mask < limit; mask++) {\n    const changedBit = 31 - Math.clz32(mask ^ (mask - 1));\n    v = vec64Xor(v, nullBasis[changedBit]);\n    const w = popcount64v(v);\n    if (isBetterVec(v, w, best, bestW)) {\n      best = v;\n      bestW = w;\n    }\n  }\n\n  return best;\n}\n\n/**\n * Meet-in-the-middle for numFree > 20.\n *\n * Key insight: full solution = v_A XOR v_B where v_B incorporates particularX.\n * We want min weight(v_A XOR v_B).\n *\n * For each v_B, we want the v_A in side A minimizing dist(v_A, v_B).\n * Approach: search by increasing Hamming radius from v_B.\n * - Radius 0: look for exact v_B in sideA map → O(2^dB * 1)\n * - Radius 1: try each 1-bit-flip of v_B → O(2^dB * 40)\n * - Radius k: O(2^dB * C(40, k))\n *\n * We sweep increasing minimum distance k_min until we find a match.\n * All 2^dB queries at each radius level are batched, so total work is\n * O(2^dB * sum_{k=0}^{k_min} C(40, k)).\n * For k_min ≤ 4: O(2^20 * ~91K) ≈ 95B ops → marginal but feasible.\n * For k_min ≤ 3: O(2^20 * ~10K) ≈ 10B ops → too slow in JS.\n * For k_min ≤ 2: O(2^20 * ~800) ≈ 800M ops → ~1-2s in JS.\n * For k_min ≤ 1: O(2^20 * 40) = 40M ops → fast.\n *\n * After finding the minimum weight at radius r, still need lex-smallest.\n * Use side-A map lookup to find all v_A values at distance r from each v_B.\n */\nfunction vec64FlipBit(v: Vec64, bit: number): Vec64 {\n  if (bit < 32) return [v[0], v[1] ^ (1 << bit)];\n  return [v[0] ^ (1 << (bit - 32)), v[1]];\n}\n\n/**\n * Meet-in-the-middle for numFree > 20.\n *\n * Enumerate side A (2^dA vectors) and store in hash map.\n * Enumerate side B (2^dB vectors, incorporating particularX).\n *\n * For each v_B, find v_A in side A map minimizing weight(v_A XOR v_B).\n * Use increasing Hamming radius search: try all 1-flip, 2-flip, etc. variants of v_B,\n * look each up in side A map. Stop at radius r when we find matches and bestW ≤ r.\n *\n * Complexity: O(2^dB * sum_{k=0}^{r} C(41, k)) where r is the minimum weight.\n * For r ≤ 2: O(2^20 * ~820) ≈ 860M ops — tight but feasible.\n * Fall back to sorted full scan for r > 2.\n */\nfunction minWeightMitM(\n  particularX: Vec64,\n  nullBasis: Vec64[],\n  numFree: number\n): Vec64 {\n  const dA = Math.floor(numFree / 2);\n  const dB = numFree - dA;\n  const limitA = 1 << dA;\n  const limitB = 1 << dB;\n  const N_BITS = 41; // bit positions 0..40 (up to 40 buttons + rhs bit; we use 0..39)\n\n  // Enumerate side A with Gray code, store in hash map\n  const sideAMap = new Map<number, Vec64>();\n  const sideAArr: Vec64[] = [];\n  {\n    let v: Vec64 = [0, 0];\n    sideAArr.push(v);\n    sideAMap.set(vec64Key(v), v);\n    for (let mask = 1; mask < limitA; mask++) {\n      const cb = 31 - Math.clz32(mask ^ (mask - 1));\n      v = vec64Xor(v, nullBasis[cb]);\n      sideAArr.push(v);\n      const k = vec64Key(v);\n      if (!sideAMap.has(k)) sideAMap.set(k, v);\n    }\n  }\n\n  // Enumerate side B with Gray code\n  const sideBArr: Vec64[] = [];\n  {\n    let v = particularX;\n    sideBArr.push(v);\n    for (let mask = 1; mask < limitB; mask++) {\n      const cb = 31 - Math.clz32(mask ^ (mask - 1));\n      v = vec64Xor(v, nullBasis[dA + cb]);\n      sideBArr.push(v);\n    }\n  }\n\n  // Initialize with particular solution (first vB XOR zero vA = particularX)\n  let best: Vec64 = particularX;\n  let bestW = popcount64v(particularX);\n\n  // Early exit: if best is already 0 or 1, that's optimal (0 only possible for all-off target)\n  if (bestW <= 1) return best;\n\n  // Radius 0: exact match\n  for (const vB of sideBArr) {\n    const vA = sideAMap.get(vec64Key(vB));\n    if (vA !== undefined) {\n      const z = vec64Xor(vA, vB);\n      const w = popcount64v(z);\n      if (isBetterVec(z, w, best, bestW)) { best = z; bestW = w; }\n    }\n  }\n  if (bestW === 0) return best!;\n\n  // Radius 1: 1-bit flip of vB\n  for (const vB of sideBArr) {\n    for (let b = 0; b < N_BITS; b++) {\n      const q = vec64FlipBit(vB, b);\n      const vA = sideAMap.get(vec64Key(q));\n      if (vA !== undefined) {\n        const z = vec64Xor(vA, vB);\n        const w = popcount64v(z);\n        if (isBetterVec(z, w, best, bestW)) { best = z; bestW = w; }\n      }\n    }\n  }\n  if (bestW <= 1) return best!;\n\n  // Radius 2: 2-bit flip of vB\n  for (const vB of sideBArr) {\n    for (let b1 = 0; b1 < N_BITS; b1++) {\n      const q1 = vec64FlipBit(vB, b1);\n      for (let b2 = b1 + 1; b2 < N_BITS; b2++) {\n        const q = vec64FlipBit(q1, b2);\n        const vA = sideAMap.get(vec64Key(q));\n        if (vA !== undefined) {\n          const z = vec64Xor(vA, vB);\n          const w = popcount64v(z);\n          if (isBetterVec(z, w, best, bestW)) { best = z; bestW = w; }\n        }\n      }\n    }\n  }\n  if (bestW <= 2) return best!;\n\n  // For radius > 2, fall back to sorted pairwise scan.\n  // Note: early termination using triangle inequality is still incorrect\n  // (weight can decrease when bits cancel), but we use it as a heuristic bound.\n  const sideASorted = [...sideAArr].sort((a, b) => popcount64v(a) - popcount64v(b));\n  for (const vB of sideBArr) {\n    const wB = popcount64v(vB);\n    for (const vA of sideASorted) {\n      const wA = popcount64v(vA);\n      // Triangle inequality lower bound: |wA - wB| <= weight(vA XOR vB)\n      // If |wA - wB| >= bestW, this pair can't improve.\n      const lb = Math.abs(wA - wB);\n      if (lb >= bestW && wA > wB) break; // wA increasing: all future wA > wB + bestW\n      if (lb >= bestW) continue;\n      const z = vec64Xor(vA, vB);\n      const w = popcount64v(z);\n      if (isBetterVec(z, w, best, bestW)) { best = z; bestW = w; }\n    }\n  }\n\n  return best;\n}\n\n/**\n * Solve counter puzzle using Gaussian elimination over GF(p) where p is prime.\n * Finds minimum total presses, lex smallest on ties.\n */\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const numCounters = lights.length;\n  const numButtons = buttons.length;\n  const p = modulus;\n\n  if (numButtons === 0) {\n    return lights.every(v => v === 0) ? [] : null;\n  }\n\n  // Build augmented matrix over GF(p)\n  const aug: number[][] = Array.from({ length: numCounters }, (_, i) => {\n    const row = new Array(numButtons + 1).fill(0);\n    row[numButtons] = ((lights[i] % p) + p) % p;\n    return row;\n  });\n\n  for (let j = 0; j < numButtons; j++) {\n    for (const ci of buttons[j]) {\n      if (ci < numCounters) {\n        aug[ci][j] = (aug[ci][j] + 1) % p;\n      }\n    }\n  }\n\n  // Gaussian elimination to RREF over GF(p)\n  const pivotOfCol: number[] = new Array(numButtons).fill(-1);\n  let currentRow = 0;\n\n  for (let col = 0; col < numButtons && currentRow < numCounters; col++) {\n    let pivotFound = -1;\n    for (let r = currentRow; r < numCounters; r++) {\n      if (aug[r][col] !== 0) { pivotFound = r; break; }\n    }\n    if (pivotFound === -1) continue;\n\n    [aug[currentRow], aug[pivotFound]] = [aug[pivotFound], aug[currentRow]];\n\n    const inv = modInverse(aug[currentRow][col], p);\n    for (let c = 0; c <= numButtons; c++) {\n      aug[currentRow][c] = (aug[currentRow][c] * inv) % p;\n    }\n\n    for (let r = 0; r < numCounters; r++) {\n      if (r !== currentRow && aug[r][col] !== 0) {\n        const factor = aug[r][col];\n        for (let c = 0; c <= numButtons; c++) {\n          aug[r][c] = ((aug[r][c] - factor * aug[currentRow][c]) % p + p) % p;\n        }\n      }\n    }\n\n    pivotOfCol[col] = currentRow;\n    currentRow++;\n  }\n\n  // Check consistency\n  for (let r = 0; r < numCounters; r++) {\n    if (aug[r].slice(0, numButtons).every(v => v === 0) && aug[r][numButtons] !== 0) {\n      return null;\n    }\n  }\n\n  const pivotCols: number[] = [];\n  const freeCols: number[] = [];\n  for (let j = 0; j < numButtons; j++) {\n    if (pivotOfCol[j] !== -1) pivotCols.push(j);\n    else freeCols.push(j);\n  }\n\n  const numFree = freeCols.length;\n\n  // Compute particular solution (all free vars = 0)\n  function computeX(freeValsArr: number[]): number[] {\n    const x = new Array(numButtons).fill(0);\n    for (let fi = 0; fi < numFree; fi++) x[freeCols[fi]] = freeValsArr[fi];\n    for (const j of pivotCols) {\n      const r = pivotOfCol[j];\n      let val = aug[r][numButtons];\n      for (let k = 0; k < numButtons; k++) {\n        if (k !== j && aug[r][k] !== 0) {\n          val = ((val - aug[r][k] * x[k]) % p + p) % p;\n        }\n      }\n      x[j] = val;\n    }\n    return x;\n  }\n\n  const totalCombinations = Math.pow(p, numFree);\n  const ENUM_LIMIT = 2000000; // enumerate up to 2M combinations\n\n  if (totalCombinations <= ENUM_LIMIT) {\n    // Full enumeration\n    const freeVals = new Array(numFree).fill(0);\n    let best: number[] | null = null;\n\n    for (let iter = 0; iter < totalCombinations; iter++) {\n      const x = computeX(freeVals);\n      if (best === null || i