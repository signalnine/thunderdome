+import { describe, test, expect } from 'vitest';
+import { solveToggle } from '../src/index.js';
+import type { Machine } from '../src/index.js';
+
+describe('solveToggle', () => {
+  test('returns empty array when target is all off', () => {
+    const machine: Machine = {
+      target: [false, false, false],
+      buttons: [[0], [1], [2]],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  test('returns null for unsolvable puzzle (example from spec)', () => {
+    // From the task description: target [T,T,F,T] with the given buttons has no solution
+    const machine: Machine = {
+      target: [true, true, false, true],
+      buttons: [
+        [0, 1],
+        [1, 2, 3],
+        [0, 3],
+      ],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  test('single button single light', () => {
+    const machine: Machine = {
+      target: [true],
+      buttons: [[0]],
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  test('two buttons, one solution', () => {
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [
+        [0],
+        [1],
+      ],
+    };
+    expect(solveToggle(machine)).toEqual([0, 1]);
+  });
+
+  test('picks minimum button presses when multiple solutions exist', () => {
+    // Button 0 toggles light 0
+    // Button 1 toggles light 0 too
+    // Target: light 0 on
+    // Solutions: [0] or [1] — both have 1 press, so pick [0] (lex smallest)
+    const machine: Machine = {
+      target: [true],
+      buttons: [[0], [0]],
+    };
+    const result = solveToggle(machine);
+    expect(result).not.toBeNull();
+    expect(result!.length).toBe(1);
+    expect(result).toEqual([0]);
+  });
+
+  test('picks lexicographically smallest when tied on press count', () => {
+    // Button 0 toggles [0, 1]
+    // Button 1 toggles [0, 1]
+    // They cancel each other: pressing both = no change
+    // Target: [false, false] => press nothing
+    // Or press neither => also valid
+    // Solutions: [] (0 presses) wins
+    const machine: Machine = {
+      target: [false, false],
+      buttons: [[0, 1], [0, 1]],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  test('three buttons, only one valid combo of two', () => {
+    // Button 0 toggles [0]
+    // Button 1 toggles [1]
+    // Button 2 toggles [0, 1]
+    // Target: [true, true]
+    // Solutions: [0,1] (2 presses) or [2] (1 press) — pick [2]
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [[0], [1], [0, 1]],
+    };
+    expect(solveToggle(machine)).toEqual([2]);
+  });
+
+  test('no buttons returns null when target non-trivial', () => {
+    const machine: Machine = {
+      target: [true],
+      buttons: [],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  test('no buttons returns empty when target all off', () => {
+    const machine: Machine = {
+      target: [false, false],
+      buttons: [],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  test('larger puzzle - prefers fewer presses over lex order', () => {
+    // 4 lights, 4 buttons
+    // Button 0: toggles [0]
+    // Button 1: toggles [1]
+    // Button 2: toggles [2]
+    // Button 3: toggles [0, 1, 2]
+    // Target: [true, true, true]
+    // Solutions: [0,1,2] (3 presses) or [3] (1 press) — pick [3]
+    const machine: Machine = {
+      target: [true, true, true],
+      buttons: [[0], [1], [2], [0, 1, 2]],
+    };
+    expect(solveToggle(machine)).toEqual([3]);
+  });
+
+  test('puzzle with redundant buttons - picks lex smallest minimal', () => {
+    // Button 0: toggles [0]
+    // Button 1: toggles [0]  (same as button 0)
+    // Button 2: toggles [1]
+    // Target: [true, true]
+    // Solutions of size 2: [0,2] or [1,2]  — pick [0,2]
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [[0], [0], [1]],
+    };
+    expect(solveToggle(machine)).toEqual([0, 2]);
+  });
+});
