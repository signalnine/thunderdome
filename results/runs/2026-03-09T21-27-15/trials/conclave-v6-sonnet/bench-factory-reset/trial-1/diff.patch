1;\n    for (let fi = numFree - 1; fi >= 0 && carry; fi--) {\n      freeVals[fi] += carry;\n      if (freeVals[fi] >= p) { freeVals[fi] = 0; carry = 1; }\n      else carry = 0;\n    }\n  }\n\n  return best;\n}\n\nfunction isBetterCounter(candidate: number[], best: number[]): boolean {\n  const candSum = candidate.reduce((a, b) => a + b, 0);\n  const bestSum = best.reduce((a, b) => a + b, 0);\n  if (candSum < bestSum) return true;\n  if (candSum > bestSum) return false;\n  for (let i = 0; i < candidate.length; i++) {\n    if (candidate[i] < best[i]) return true;\n    if (candidate[i] > best[i]) return false;\n  }\n  return false;\n}\n\nfunction modInverse(a: number, p: number): number {\n  return modPow(a, p - 2, p);\n}\n\nfunction modPow(base: number, exp: number, mod: number): number {\n  let result = 1;\n  base = base % mod;\n  while (exp > 0) {\n    if (exp & 1) result = (result * base) % mod;\n    exp >>= 1;\n    base = (base * base) % mod;\n  }\n  return result;\n}\n","structuredPatch":[{"oldStart":6,"oldLines":68,"newStart":6,"newLines":44,"lines":[" /**","  * Solve toggle puzzle using Gaussian elimination over GF(2).","  *","- * We model the problem as a system of linear equations over GF(2):","- *   A * x = b  (mod 2)","- * where A[i][j] = 1 if button j toggles light i, b[i] = target[i], x[j] = press button j.","+ * Model: A * x = b (mod 2), find minimum Hamming weight x satisfying Ax = b.","  *","- * Steps:","- * 1. Build augmented matrix [A | b] and row-reduce over GF(2).","- * 2. Check consistency (no row [0...0 | 1]).","- * 3. Enumerate free variables to find minimum-weight solution, tie-break lex.","+ * After Gaussian elimination to RREF, free variables parameterize the solution space.","+ * Each free variable assignment yields a unique solution via back-substitution.","+ *","+ * For few free variables (≤ 20): enumerate all 2^d possibilities directly.","+ * For many free variables: use meet-in-the-middle on null space basis vectors.","  */"," export fun