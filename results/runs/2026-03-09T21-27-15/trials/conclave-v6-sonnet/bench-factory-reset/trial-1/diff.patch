+ * For each v_B, find v_A in side A map minimizing weight(v_A XOR v_B).
+ * Use increasing Hamming radius search: try all 1-flip, 2-flip, etc. variants of v_B,
+ * look each up in side A map. Stop at radius r when we find matches and bestW ≤ r.
+ *
+ * Complexity: O(2^dB * sum_{k=0}^{r} C(41, k)) where r is the minimum weight.
+ * For r ≤ 2: O(2^20 * ~820) ≈ 860M ops — tight but feasible.
+ * Fall back to sorted full scan for r > 2.
+ */
+function minWeightMitM(
+  particularX: Vec64,
+  nullBasis: Vec64[],
+  numFree: number
+): Vec64 {
+  const dA = Math.floor(numFree / 2);
+  const dB = numFree - dA;
+  const limitA = 1 << dA;
+  const limitB = 1 << dB;
+  const N_BITS = 41; // bit positions 0..40 (up to 40 buttons + rhs bit; we use 0..39)
+
+  // Enumerate side A with Gray code, store in hash map
+  const sideAMap = new Map<number, Vec64>();
+  const sideAArr: Vec64[] = [];
+  {
+    let v: Vec64 = [0, 0];
+    sideAArr.push(v);
+    sideAMap.set(vec64Key(v), v);
+    for (let mask = 1; mask < limitA; mask++) {
+      const cb = 31 - Math.clz32(mask ^ (mask - 1));
+      v = vec64Xor(v, nullBasis[cb]);
+      sideAArr.push(v);
+      const k = vec64Key(v);
+      if (!sideAMap.has(k)) sideAMap.set(k, v);
+    }
+  }
+
+  // Enumerate side B with Gray code
+  const sideBArr: Vec64[] = [];
+  {
+    let v = particularX;
+    sideBArr.push(v);
+    for (let mask = 1; mask < limitB; mask++) {
+      const cb = 31 - Math.clz32(mask ^ (mask - 1));
+      v = vec64Xor(v, nullBasis[dA + cb]);
+      sideBArr.push(v);
+    }
+  }
+
+  // Initialize with particular solution (first vB XOR zero vA = particularX)
+  let best: Vec64 = particularX;
+  let bestW = popcount64v(particularX);
+
+  // Early exit: if best is already 0 or 1, that's optimal (0 only possible for all-off target)
+  if (bestW <= 1) return best;
+
+  // Radius 0: exact match
+  for (const vB of sideBArr) {
+    const vA = sideAMap.get(vec64Key(vB));
+    if (vA !== undefined) {
+      const z = vec64Xor(vA, vB);
+      const w = popcount64v(z);
+      if (isBetterVec(z, w, best, bestW)) { best = z; bestW = w; }
+    }
+  }
+  if (bestW === 0) return best!;
+
+  // Radius 1: 1-bit flip of vB (compute key directly without allocating)
+  for (const vB of sideBArr) {
+    const lo = vB[1], hi = vB[0];
+    // Flip each bit in lo-word (bits 0-31)
+    for (let b = 0; b < 32; b++) {
+      const qKey = hi * 4294967296 + ((lo ^ (1 << b)) >>> 0);
+      const vA = sideAMap.get(qKey);
+      if (vA !== undefined) {
+        const z = vec64Xor(vA, vB);
+        const w = popcount64v(z);
+        if (isBetterVec(z, w, best, bestW)) { best = z; bestW = w; }
+      }
+    }
+    // Flip each bit in hi-word (bits 32-40)
+    for (let b = 0; b < N_BITS - 32; b++) {
+      const qKey = ((hi ^ (1 << b)) >>> 0) * 4294967296 + (lo >>> 0);
+      const vA = sideAMap.get(qKey);
+      if (vA !== undefined) {
+        const z = vec64Xor(vA, vB);
+        const w = popcount64v(z);
+        if (isBetterVec(z, w, best, bestW)) { best = z; bestW = w; }
+      }
+    }
+  }
+  if (bestW <= 1) return best!;
+
+  // Radius 2: 2-bit flip of vB (compute key directly)
+  for (const vB of sideBArr) {
+    const lo = vB[1] >>> 0, hi = vB[0] >>> 0;
+    // Both bits in lo-word
+    for (let b1 = 0; b1 < 32; b1++) {
+      const lo1 = lo ^ (1 << b1);
+      for (let b2 = b1 + 1; b2 < 32; b2++) {
+        const qKey = hi * 4294967296 + ((lo1 ^ (1 << b2)) >>> 0);
+        const vA = sideAMap.get(qKey);
+        if (vA !== undefined) {
+          const z = vec64Xor(vA, vB);
+          const w = popcount64v(z);
+          if (isBetterVec(z, w, best, bestW)) { best = z; bestW = w; }
+        }
+      }
+    }
+    // One bit in lo, one in hi
+    for (let b1 = 0; b1 < 32; b1++) {
+      const lo1 = (lo ^ (1 << b1)) >>> 0;
+      for (let b2 = 0; b2 < N_BITS - 32; b2++) {
+        const qKey = ((hi ^ (1 << b2)) >>> 0) * 4294967296 + lo1;
+        const vA = sideAMap.get(qKey);
+        if (vA !== undefined) {
+          const z = vec64Xor(vA, vB);
+          const w = popcount64v(z);
+          if (isBetterVec(z, w, best, bestW)) { best = z; bestW = w; }
+        }
+      }
+    }
+    // Both bits in hi-word
+    const hiMax = N_BITS - 32;
+    for (let b1 = 0; b1 < hiMax; b1++) {
+      const hi1 = (hi ^ (1 << b1)) >>> 0;
+      for (let b2 = b1 + 1; b2 < hiMax; b2++) {
+        const qKey = ((hi1 ^ (1 << b2)) >>> 0) * 4294967296 + lo;
+        const vA = sideAMap.get(qKey);
+        if (vA !== undefined) {
+          const z = vec64Xor(vA, vB);
+          const w = popcount64v(z);
+          if (isBetterVec(z, w, best, bestW)) { best = z; bestW = w; }
+        }
+      }
+    }
+  }
+  if (bestW <= 2) return best!;
+
+  // For radius > 2, fall back to sorted pairwise scan.
+  // Note: early termination using triangle inequality is still incorrect
+  // (weight can decrease when bits cancel), but we use it as a heuristic bound.
+  const sideASorted = [...sideAArr].sort((a, b) => popcount64v(a) - popcount64v(b));
+  for (const vB of sideBArr) {
+    const wB = popcount64v(vB);
+    for (const vA of sideASorted) {
+      const wA = popcount64v(vA);
+      // Triangle inequality lower bound: |wA - wB| <= weight(vA XOR vB)
+      // If |wA - wB| >= bestW, this pair can't improve.
+      const lb = Math.abs(wA - wB);
+      if (lb >= bestW && wA > wB) break; // wA increasing: all future wA > wB + bestW
+      if (lb >= bestW) continue;
+      const z = vec64Xor(vA, vB);
+      const w = popcount64v(z);
+      if (isBetterVec(z, w, best, bestW)) { best = z; bestW = w; }
+    }
+  }
+
+  return best;
+}
+
+/**
+ * Solve counter puzzle using Gaussian elimination over GF(p) where p is prime.
+ * Finds minimum total presses, lex smallest on ties.
+ */
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numCounters = lights.length;
+  const numButtons = buttons.length;
+  const p = modulus;
+
+  if (numButtons === 0) {
+    return lights.every(v => v === 0) ? [] : null;
+  }
+
+  // Build augmented matrix over GF(p)
+  const aug: number[][] = Array.from({ length: numCounters }, (_, i) => {
+    const row = new Array(numButtons + 1).fill(0);
+    row[numButtons] = ((lights[i] % p) + p) % p;
+    return row;
+  });
+
+  for (let j = 0; j < numButtons; j++) {
+    for (const ci of buttons[j]) {
+      if (ci < numCounters) {
+        aug[ci][j] = (aug[ci][j] + 1) % p;
+      }
+    }
+  }
+
+  // Gaussian elimination to RREF over GF(p)
+  const pivotOfCol: number[] = new Array(numButtons).fill(-1);
+  let currentRow = 0;
+
+  for (let col = 0; col < numButtons && currentRow < numCounters; col++) {
+    let pivotFound = -1;
+    for (let r = currentRow; r < numCounters; r++) {
+      if (aug[r][col] !== 0) { pivotFound = r; break; }
+    }
+    if (pivotFound === -1) continue;
+
+    [aug[currentRow], aug[pivotFound]] = [aug[pivotFound], aug[currentRow]];
+
+    const inv = modInverse(aug[currentRow][col], p);
+    for (let c = 0; c <= numButtons; c++) {
+      aug[currentRow][c] = (aug[currentRow][c] * inv) % p;
+    }
+
+    for (let r = 0; r < numCounters; r++) {
+      if (r !== currentRow && aug[r][col] !== 0) {
+        const factor = aug[r][col];
+        for (let c = 0; c <= numButtons; c++) {
+          aug[r][c] = ((aug[r][c] - factor * aug[currentRow][c]) % p + p) % p;
+        }
+      }
+    }
+
+    pivotOfCol[col] = currentRow;
+    currentRow++;
+  }
+
+  // Check consistency
+  for (let r = 0; r < numCounters; r++) {
+    if (aug[r].slice(0, numButtons).every(v => v === 0) && aug[r][numButtons] !== 0) {
+      return null;
+    }
+  }
+
+  const pivotCols: number[] = [];
+  const freeCols: number[] = [];
+  for (let j = 0; j < numButtons; j++) {
+    if (pivotOfCol[j] !== -1) pivotCols.push(j);
+    else freeCols.push(j);
+  }
+
+  const numFree = freeCols.length;
+
+  // Compute particular solution (all free vars = 0)
+  function computeX(freeValsArr: number[]): number[] {
+    const x = new Array(numButtons).fill(0);
+    for (let fi = 0; fi < numFree; fi++) x[freeCols[fi]] = freeValsArr[fi];
+    for (const j of pivotCols) {
+      const r = pivotOfCol[j];
+      let val = aug[r][numButtons];
+      for (let k = 0; k < numButtons; k++) {
+        if (k !== j && aug[r][k] !== 0) {
+          val = ((val - aug[r][k] * x[k]) % p + p) % p;
+        }
+      }
+      x[j] = val;
+    }
+    return x;
+  }
+
+  const totalCombinations = Math.pow(p, numFree);
+  const ENUM_LIMIT = 2000000; // enumerate up to 2M combinations
+
+  if (totalCombinations <= ENUM_LIMIT) {
+    // Full enumeration
+    const freeVals = new Array(numFree).fill(0);
+    let best: number[] | null = null;
+
+    for (let iter = 0; iter < totalCombinations; iter++) {
+      const x = computeX(freeVals);
+      if (best === null || isBetterCounter(x, best)) {
+        best = [...x];
+      }
+      let carry = 1;
+      for (let fi = numFree - 1; fi >= 0 && carry; fi--) {
+        freeVals[fi] += carry;
+        if (freeVals[fi] >= p) { freeVals[fi] = 0; carry = 1; }
+        else carry = 0;
+      }
+    }
+    return best;
+  }
+
+  // Too many combinations to enumerate. Use coordinate descent to minimize sum.
+  // Start with particular solution (all free = 0), then optimize each free var.
+  const freeVals = new Array(numFree).fill(0);
+  let best = computeX(freeVals);
+
+  // Coordinate descent: for each free variable, find the value minimizing total sum
+  let improved = true;
+  while (improved) {
+    improved = false;
+    for (let fi = 0; fi < numFree; fi++) {
+      const origVal = freeVals[fi];
+      let bestVal = origVal;
+      let bestX = best;
+      for (let c = 0; c < p; c++) {
+        if (c === origVal) continue;
+        freeVals[fi] = c;
+        const x = computeX(freeVals);
+        if (isBetterCounter(x, bestX)) {
+          bestX = x;
+          bestVal = c;
+        }
+      }
+      freeVals[fi] = bestVal; // restore or update
+      if (bestVal !== origVal) {
+        best = bestX;
+        improved = true;
+      }
+    }
+  }
+
+  return best;
+}
+
+function isBetterCounter(candidate: number[], best: number[]): boolean {
+  const candSum = candidate.reduce((a, b) => a + b, 0);
+  const bestSum = best.reduce((a, b) => a + b, 0);
+  if (candSum < bestSum) return true;
+  if (candSum > bestSum) return false;
+  for (let i = 0; i < candidate.length; i++) {
+    if (candidate[i] < best[i]) return true;
+    if (candidate[i] > best[i]) return false;
+  }
+  return false;
+}
+
+function modInverse(a: number, p: number): number {
+  return modPow(a, p - 2, p);
+}
+
+function modPow(base: number, exp: number, mod: number): number {
+  let result = 1;
+  base = base % mod;
+  while (exp > 0) {
+    if (exp & 1) result = (result * base) % mod;
+    exp >>= 1;
+    base = (base * base) % mod;
+  }
+  return result;
+}
diff --git a/tests/counter.test.ts b/tests/counter.test.ts
new file mode 100644
index 0000000..2726f8d
--- /dev/null
+++ b/tests/counter.test.ts
@@ -0,0 +1,104 @@
+import { describe, test, expect } from 'vitest';
+import { solveCounter } from '../src/index.js';
+
+describe('solveCounter', () => {
+  test('target all zeros returns all zeros', () => {
+    const result = solveCounter([0, 0, 0], [[0], [1], [2]], 5);
+    expect(result).toEqual([0, 0, 0]);
+  });
+
+  test('single button single counter mod 5', () => {
+    // Press button 0 twice to reach counter 0 = 2
+    const result = solveCounter([2], [[0]], 5);
+    expect(result).toEqual([2]);
+  });
+
+  test('single button single counter mod 5, target = 4', () => {
+    const result = solveCounter([4], [[0]], 5);
+    expect(result).toEqual([4]);
+  });
+
+  test('two buttons two counters mod 3', () => {
+    // Button 0 affects counter 0, button 1 affects counter 1
+    // Target: [1, 2]
+    const result = solveCounter([1, 2], [[0], [1]], 3);
+    expect(result).toEqual([1, 2]);
+  });
+
+  test('returns null when no solution', () => {
+    // Button 0 affects counter 0 only
+    // Target: counter 0 = 0, counter 1 = 1
+    // No button affects counter 1 → impossible
+    const result = solveCounter([0, 1], [[0]], 5);
+    expect(result).toBeNull();
+  });
+
+  test('no buttons, target all zeros', () => {
+    const result = solveCounter([0, 0], [], 5);
+    expect(result).toEqual([]);
+  });
+
+  test('no buttons, nonzero target', () => {
+    const result = solveCounter([1, 0], [], 5);
+    expect(result).toBeNull();
+  });
+
+  test('picks minimum total presses when multiple solutions', () => {
+    // Two buttons both affect counter 0
+    // Button 0: affects [0]
+    // Button 1: affects [0]
+    // Target: [1]  mod 5
+    // Solutions: x0+x1 = 1 mod 5
+    //   [1,0] total=1, [0,1] total=1 — both have total 1, lex: [0,1] < [1,0]
+    // Wait: [0,1] has x0=0, x1=1; [1,0] has x0=1, x1=0.
+    // Lex comparison: first element: 0 < 1 → [0,1] is lex smaller
+    const result = solveCounter([1], [[0], [0]], 5);
+    expect(result).toEqual([0, 1]);
+  });
+
+  test('prefers fewer total presses over lex order', () => {
+    // Button 0 affects [0], button 1 affects [0]
+    // Target: [2] mod 5
+    // Solutions with total 2: [2,0], [1,1], [0,2]
+    //   lex smallest is [0,2]
+    // vs total 4+3=? — no: [3,4] total=7 but 3+4=7, or [4,3]...
+    // Actually solutions: x0+x1=2 mod 5 → (0,2),(1,1),(2,0),(3,4),(4,3)
+    // Totals: 2, 2, 2, 7, 7 → minimum is 2, lex smallest of those is (0,2)
+    const result = solveCounter([2], [[0], [0]], 5);
+    expect(result).toEqual([0, 2]);
+  });
+
+  test('mod 7 with overlapping buttons', () => {
+    // Button 0: affects [0, 1]
+    // Button 1: affects [1, 2]
+    // Target: [1, 2, 1] mod 7
+    // Equations: x0 = 1, x0 + x1 = 2, x1 = 1
+    // Solution: x0=1, x1=1
+    const result = solveCounter([1, 2, 1], [[0, 1], [1, 2]], 7);
+    expect(result).toEqual([1, 1]);
+  });
+
+  test('modular wraparound', () => {
+    // Counter mod 3, button 0 affects counter 0
+    // Target: [2]
+    // Minimum: press 2 times (2 mod 3 = 2)
+    const result = solveCounter([2], [[0]], 3);
+    expect(result).toEqual([2]);
+  });
+
+  test('overdetermined but consistent', () => {
+    // 3 equations, 2 unknowns, consistent
+    // Button 0: [0], Button 1: [1]
+    // Lights (counters): 3, target [1, 2, ...]
+    // Add extra constraint: counter 2 not affected by any button, target 0
+    const result = solveCounter([1, 2, 0], [[0], [1]], 5);
+    expect(result).toEqual([1, 2]);
+  });
+
+  test('large modulus prime 11', () => {
+    // Button 0: [0]
+    // Target: [7] mod 11
+    const result = solveCounter([7], [[0]], 11);
+    expect(result).toEqual([7]);
+  });
+});
