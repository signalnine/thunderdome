+    nullBasis[fi] = vec64Xor(withFree, particularX);
+  }
+
+  // Build null-space membership checker.
+  // A vector v is in the null space iff for each pivot col j in row r:
+  //   v[j] = XOR of {v[k] : k is free, a[r][k]=1}
+  // Equivalently: v XOR particularX is in null space iff v is a valid solution.
+  // So we check: is the candidate z = (v XOR particularX) consistent with RREF?
+  // Build per-pivot row: list of free columns with coefficient 1
+  const pivotFreeCoeffs: number[][] = pivotCols.map(j => {
+    const r = colToRow.get(j)!;
+    return freeCols.filter(fc => vec64Bit(augRows[r], fc));
+  });
+
+  // isInCoset(z): true if z is a valid solution (z XOR particularX in null space)
+  // Equivalently: z satisfies back-substitution from RREF with rhs = target.
+  // z is valid solution iff applying the buttons in z achieves the target.
+  // We check: for each pivot col j (in row r of RREF):
+  //   z[j] == rhsBit(row r) XOR (XOR of z[k] for free k with coeff 1 in row r)
+  function isInCoset(zLo: number, zHi: number): boolean {
+    for (let pi = 0; pi < pivotCols.length; pi++) {
+      const j = pivotCols[pi];
+      const r = colToRow.get(j)!;
+      // Expected value of z[j] from rhs and free contributions
+      let expected = vec64Bit(augRows[r], RHS_BIT) ? 1 : 0;
+      for (const fc of pivotFreeCoeffs[pi]) {
+        const bit: boolean = fc < 32 ? !!(zLo >>> fc & 1) : !!(zHi >>> (fc - 32) & 1);
+        if (bit) expected ^= 1;
+      }
+      // Actual z[j]
+      const actual: boolean = j < 32 ? !!(zLo >>> j & 1) : !!(zHi >>> (j - 32) & 1);
+      if ((actual ? 1 : 0) !== expected) return false;
+    }
+    return true;
+  }
+
+  // Find minimum weight solution in coset.
+  // Strategy: enumerate all C(numButtons, w) subsets for w = 0, 1, 2, ... in lex order.
+  // Stop at the first w where we find a valid subset (lex-smallest minimum weight solution).
+  // For large w (> BFS_LIMIT), fall back to null space enumeration.
+  const BFS_LIMIT = 5; // enumerate directly for weight ≤ 5
+
+  for (let w = 0; w <= Math.min(BFS_LIMIT, numButtons); w++) {
+    const found = findLexSmallestWeight(w, numButtons, isInCoset);
+    if (found !== null) {
+      return found;
+    }
+  }
+
+  // w > BFS_LIMIT: fall back to null-space enumeration
+  let bestVec: Vec64;
+  if (numFree <= 20) {
+    bestVec = minWeightDirect(particularX, nullBasis, numFree);
+  } else {
+    bestVec = minWeightMitM(particularX, nullBasis, numFree);
+  }
