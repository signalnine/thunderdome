e target.\n  // We check: for each pivot col j (in row r of RREF):\n  //   z[j] == rhsBit(row r) XOR (XOR of z[k] for free k with coeff 1 in row r)\n  function isInCoset(zLo: number, zHi: number): boolean {\n    for (let pi = 0; pi < pivotCols.length; pi++) {\n      const j = pivotCols[pi];\n      const r = colToRow.get(j)!;\n      // Expected value of z[j] from rhs and free contributions\n      let expected = vec64Bit(augRows[r], RHS_BIT) ? 1 : 0;\n      for (const fc of pivotFreeCoeffs[pi]) {\n        const bit: boolean = fc < 32 ? !!(zLo >>> fc & 1) : !!(zHi >>> (fc - 32) & 1);\n        if (bit) expected ^= 1;\n      }\n      // Actual z[j]\n      const actual: boolean = j < 32 ? !!(zLo >>> j & 1) : !!(zHi >>> (j - 32) & 1);\n      if ((actual ? 1 : 0) !== expected) return false;\n    }\n    return true;\n  }\n\n  // Find minimum weight solution in coset.\n  // Strategy: enumerate all C(numButtons, w) subsets for w = 0, 1, 2, ... in lex order.\n  // Stop at the first w where we find a valid subset (lex-smallest minimum weight solution).\n  // For large w (> BFS_LIMIT), fall back to null space enumeration.\n  const BFS_LIMIT = 5; // enumerate directly for weight ≤ 5\n\n  for (let w = 0; w <= Math.min(BFS_LIMIT, numButtons); w++) {\n    const found = findLexSmallestWeight(w, numButtons, isInCoset);\n    if (found !== null) {\n      return found;\n    }\n  }\n\n  // w > BFS_LIMIT: fall back to null-space enumeration\n  let bestVec: Vec64;\n  if (numFree <= 20) {\n    bestVec = minWeightDirect(particularX, nullBasis, numFree);\n  } else {\n    bestVec = minWeightMitM(particularX, nullBasis, numFree);\n  }\n\n  return vec64ToArray(bestVec, numButtons);\n}\n\n/**\n * Find the lex-smallest subset of exactly w buttons that is a valid solution.\n * Enumerates all C(numButtons, w) subsets in lex order using Gosper's hack.\n * Returns null if no valid subset found.\n */\nfunction findLexSmallestWeight(\n  w: number,\n  numButtons: number,\n  isInCoset: (lo: number, hi: number) => boolean\n): number[] | null {\n  if (w === 0) {\n    if (isInCoset(0, 0)) return [];\n    return null;\n  }\n  if (w > numButtons) return null;\n\n  // Enumerate all w-element subsets of {0..numButtons-1} in lexicographic order.\n  // We represent each subset as a bitmask split into lo (bits 0-31) and hi (bits 32-39).\n  // Use recursive enumeration for up to 5 elements, which avoids Gosper's hack\n  // complications with 64-bit masks.\n\n  // State: chosen[0..w-1] = button indices in increasing order\n  const chosen = new Array(w).fill(0);\n  for (let i = 0; i < w; i++) chosen[i] = i; // start with [0,1,...,w-1]\n\n  while (true) {\n    // Build lo and hi from chosen\n    let lo = 0, hi = 0;\n    for (const b of chosen) {\n      if (b < 32) lo |= (1 << b);\n      else hi |= (1 << (b - 32));\n    }\n\n    if (isInCoset(lo, hi)) {\n      return chosen.slice();\n    }\n\n    // Advance to next lex subset\n    // Find rightmost position i that can be incremented\n    let pos = w - 1;\n    while (pos >= 0 && chosen[pos] >= numButtons - (w - pos)) {\n      pos--;\n    }\n    if (pos < 0) break; // all subsets exhausted\n\n    chosen[pos]++;\n    for (let k = pos + 1; k < w; k++) {\n      chosen[k] = chosen[k - 1] + 1;\n    }\n  }\n\n  return null;\n}\n\n/**\n * Compute solution with given free variable values.\n * freeVals: Vec64 where bit freeCols[fi] = value of free variable fi.\n */\nfunction computeSolutionVec(\n  freeVals: Vec64,\n  augRows: Vec64[],\n  pivotCols: number[],\n  freeCols: number[],\n  colToRow: Map<number, number>,\n  rhsBit: number,\n  _numButtons: number\n): Vec64 {\n  let x = vec64Zero();\n  // Set free variable bits\n  for (const fc of freeCols) {\n    if (vec64Bit(freeVals, fc)) x = vec64SetBit(x, fc);\n  }\n\n  // Back-substitute pivot variables\n  for (const j of pivotCols) {\n    const r = colToRow.get(j)!;\n    const row = augRows[r];\n    let rhs = vec64Bit(row, rhsBit) ? 1 : 0;\n    // XOR in contributions from other columns (those s