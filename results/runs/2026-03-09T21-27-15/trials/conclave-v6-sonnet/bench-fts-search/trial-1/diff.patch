esults: SearchResult[];\n      let total: number;\n\n      try {\n        // Sanitize query for FTS5: allow quoted phrases, strip dangerous chars\n        const safeQuery = sanitizeFtsQuery(query);\n\n        const countStmt = db.prepare(`\n          SELECT COUNT(*) as count\n          FROM notes_fts\n          WHERE notes_fts MATCH ?\n        `);\n        const countRow = countStmt.get(safeQuery) as { count: number };\n        total = countRow.count;\n\n        const searchStmt = db.prepare(`\n          SELECT\n            notes.id,\n            notes.title,\n            snippet(notes_fts, 1, '<mark>', '</mark>', '...', 20) AS snippet,\n            bm25(notes_fts) AS rank\n          FROM notes_fts\n          JOIN notes ON notes.id = notes_fts.rowid\n          WHERE notes_fts MATCH ?\n          ORDER BY rank\n          LIMIT ? OFFSET ?\n        `);\n        results = searchStmt.all(safeQuery, perPage, offset) as SearchResult[];\n      } catch {\n        results = [];\n        total = 0;\n      }\n\n      res.json({ results, total, page, perPage });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // GET /notes - List all notes (with optional tag filter)","originalFile":"import { Router, Request, Response, NextFunction } from 'express';\nimport Database from 'better-sqlite3';\nimport { Note, NoteInput, SearchResult, SuggestResult } from './models.js';\nimport { NotFoundError, ValidationError } from './errors.js';\n\nexport function createRoutes(db: Database.Database): Router {\n  const router = Router();\n\n  // GET /notes - List all notes (with optional tag filter)\n  router.get('/notes', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const tag = req.query.tag as string | undefined;\n\n      let notes: Note[];\n      if (tag) {\n        // Use a join with json_each for tag filtering\n        const tagStmt = db.prepare(`\n          SELECT DISTINCT notes.* FROM notes, json_each(notes.tags)\n          WHERE json_each.value = ?\n      