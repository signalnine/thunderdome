onst prev = String(i - 1).padStart(2, '0');\n    const carryOut = i === 7 ? `z08` : `c${n}`;\n    gates.push(\n      { op: 'XOR', in1: `x${n}`, in2: `y${n}`, out: `t${n}` },\n      { op: 'XOR', in1: `t${n}`, in2: `c${prev}`, out: `z${n}` },\n      { op: 'AND', in1: `x${n}`, in2: `y${n}`, out: `a${n}` },\n      { op: 'AND', in1: `t${n}`, in2: `c${prev}`, out: `b${n}` },\n      { op: 'OR',  in1: `a${n}`, in2: `b${n}`, out: carryOut },\n    );\n  }\n  return gates;\n}\n\nfunction buildSwapped8BitAdder(swapPairs: [string, string][]): Gate[] {\n  return applySwaps(buildCorrect8BitAdder(), swapPairs);\n}\n\nfunction applySwaps(gates: Gate[], swapPairs: [string, string][]): Gate[] {\n  const swapMap = new Map<string, string>();\n  for (const [a, b] of swapPairs) {\n    swapMap.set(a, b);\n    swapMap.set(b, a);\n  }\n  return gates.map(g => ({\n    ...g,\n    out: swapMap.get(g.out) ?? g.out,\n  }));\n}\n\nfunction makeInputs(x: number, y: number, bits: number): Record<string, number> {\n  const inputs: Record<string, number> = {};\n  for (let i = 0; i < bits; i++) {\n    inputs[`x${String(i).padStart(2, '0')}`] = (x >> i) & 1;\n    inputs[`y${String(i).padStart(2, '0')}`] = (y >> i) & 1;\n  }\n  return inputs;\n}\n\nfunction readZ(wires: Record<string, number>, bits: number): number {\n  let value = 0;\n  for (let i = 0; i < bits; i++) {\n    const name = `z${String(i).padStart(2, '0')}`;\n    if (wires[name] === 1) value |= (1 << i);\n  }\n  return value;\n}\n","structuredPatch":[{"oldStart":61,"oldLines":56,"newStart":61,"newLines":26,"lines":["   });"," ","   test('4-bit adder computes 3 + 5 = 8', () => {","-    // Correct 4-bit adder from the spec","-    const gates: Gate[] = [","-      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },","-      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },","-","-      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },","-      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },","-      { op: 'AND', in1: 'x01', in2: 'y01', out: 