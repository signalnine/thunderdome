+import { describe, test, expect } from 'vitest';
+import { simulate, findSwappedWires } from './index.js';
+import type { Gate } from './index.js';
+
+// ─── simulate() tests ───────────────────────────────────────────────────────
+
+describe('simulate', () => {
+  test('AND gate: 1 AND 1 = 1', () => {
+    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];
+    const result = simulate(gates, { a: 1, b: 1 });
+    expect(result['c']).toBe(1);
+  });
+
+  test('AND gate: 1 AND 0 = 0', () => {
+    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];
+    const result = simulate(gates, { a: 1, b: 0 });
+    expect(result['c']).toBe(0);
+  });
+
+  test('OR gate: 0 OR 1 = 1', () => {
+    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];
+    const result = simulate(gates, { a: 0, b: 1 });
+    expect(result['c']).toBe(1);
+  });
+
+  test('OR gate: 0 OR 0 = 0', () => {
+    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];
+    const result = simulate(gates, { a: 0, b: 0 });
+    expect(result['c']).toBe(0);
+  });
+
+  test('XOR gate: 1 XOR 1 = 0', () => {
+    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];
+    const result = simulate(gates, { a: 1, b: 1 });
+    expect(result['c']).toBe(0);
+  });
+
+  test('XOR gate: 1 XOR 0 = 1', () => {
+    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];
+    const result = simulate(gates, { a: 1, b: 0 });
+    expect(result['c']).toBe(1);
+  });
+
+  test('returns all wire values including inputs', () => {
+    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];
+    const result = simulate(gates, { a: 1, b: 0 });
+    expect(result['a']).toBe(1);
+    expect(result['b']).toBe(0);
+    expect(result['c']).toBe(0);
+  });
+
+  test('processes gates in dependency order', () => {
+    // c depends on a AND b, d depends on c AND b
+    const gates: Gate[] = [
+      { op: 'AND', in1: 'c', in2: 'b', out: 'd' },
+      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },
+    ];
+    const result = simulate(gates, { a: 1, b: 1 });
+    expect(result['c']).toBe(1);
+    expect(result['d']).toBe(1);
+  });
+
+  test('4-bit adder computes 3 + 5 = 8', () => {
+    // Correct 4-bit adder — last carry directly becomes z04
+    const gates = buildCorrect4BitAdder();
+    const inputs: Record<string, number> = {
+      x00: 1, x01: 1, x02: 0, x03: 0,
+      y00: 1, y01: 0, y02: 1, y03: 0,
+    };
+    const result = simulate(gates, inputs);
+    expect(result['z00']).toBe(0); // bit 0: 1+1=0, carry 1
+    expect(result['z01']).toBe(0); // bit 1: 1+0+1=0, carry 1
+    expect(result['z02']).toBe(0); // bit 2: 0+1+1=0, carry 1
+    expect(result['z03']).toBe(1); // bit 3: 0+0+1=1, carry 0
+    expect(result['z04']).toBe(0); // final carry = 0
+  });
+});
+
+// ─── findSwappedWires() tests ─────────────────────────────────────────────
+
+describe('findSwappedWires', () => {
+  test('correct 4-bit adder computes the right sum (sanity check)', () => {
+    const gates = buildCorrect4BitAdder();
+    const inputs = makeInputs(3, 5, 4);
+    const result = simulate(gates, inputs);
+    const z = readZ(result, 5);
+    expect(z).toBe(8); // 3 + 5 = 8
+  });
+
+  test('finds 1 pair of swapped wires in a 4-bit adder', () => {
+    // Swap z01 <-> a01
+    const gates = buildSwapped4BitAdder([['z01', 'a01']]);
+    const swapped = findSwappedWires(gates);
+    expect(swapped).toEqual(['a01', 'z01']);
+  });
+
+  test('finds 2 pairs of swapped wires in a 4-bit adder', () => {
+    // Swap z01 <-> a01, and z02 <-> b02
+    const gates = buildSwapped4BitAdder([['z01', 'a01'], ['z02', 'b02']]);
+    const swapped = findSwappedWires(gates);
+    expect(swapped.sort()).toEqual(['a01', 'b02', 'z01', 'z02'].sort());
+  });
+
+  test('returns sorted array', () => {
+    const gates = buildSwapped4BitAdder([['z01', 'a01']]);
+    const swapped = findSwappedWires(gates);
+    const sorted = [...swapped].sort();
+    expect(swapped).toEqual(sorted);
+  });
+
+  test('handles 4 pairs of swaps in a larger circuit', () => {
+    const swapPairs: [string, string][] = [
+      ['z01', 'a01'],
+      ['z03', 't03'],
+      ['c04', 'b05'],
+      ['z06', 'a06'],
+    ];
+    const gates = buildSwapped8BitAdder(swapPairs);
+    const swapped = findSwappedWires(gates);
+    const expected = ['a01', 'a06', 'b05', 'c04', 't03', 'z01', 'z03', 'z06'];
+    expect(swapped).toEqual(expected);
+  });
+});
+
+// ─── Helper functions for test circuits ──────────────────────────────────
+
+/**
+ * Correct 4-bit adder where the last full adder's carry out IS z04 directly.
+ * Structure per spec: last carry wire becomes z(N).
+ */
+function buildCorrect4BitAdder(): Gate[] {
+  return [
+    { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+    { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+
+    { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },
+    { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },
+    { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },
+    { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },
+    { op: 'OR',  in1: 'a01', in2: 'b01', out: 'c01' },
+
+    { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },
+    { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },
+    { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },
+    { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },
+    { op: 'OR',  in1: 'a02', in2: 'b02', out: 'c02' },
+
+    { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },
+    { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },
+    { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },
+    { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },
+    { op: 'OR',  in1: 'a03', in2: 'b03', out: 'z04' }, // carry directly = z04
+  ];
+}
+
+function buildSwapped4BitAdder(swapPairs: [string, string][]): Gate[] {
+  return applySwaps(buildCorrect4BitAdder(), swapPairs);
+}
+
+/**
+ * Correct 8-bit adder where the last full adder's carry out IS z08 directly.
+ */
+function buildCorrect8BitAdder(): Gate[] {
+  const gates: Gate[] = [
+    { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+    { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+  ];
+  for (let i = 1; i <= 7; i++) {
+    const n = String(i).padStart(2, '0');
+    const prev = String(i - 1).padStart(2, '0');
+    const carryOut = i === 7 ? `z08` : `c${n}`;
+    gates.push(
+      { op: 'XOR', in1: `x${n}`, in2: `y${n}`, out: `t${n}` },
+      { op: 'XOR', in1: `t${n}`, in2: `c${prev}`, out: `z${n}` },
+      { op: 'AND', in1: `x${n}`, in2: `y${n}`, out: `a${n}` },
+      { op: 'AND', in1: `t${n}`, in2: `c${prev}`, out: `b${n}` },
+      { op: 'OR',  in1: `a${n}`, in2: `b${n}`, out: carryOut },
+    );
+  }
+  return gates;
+}
+
+function buildSwapped8BitAdder(swapPairs: [string, string][]): Gate[] {
+  return applySwaps(buildCorrect8BitAdder(), swapPairs);
+}
+
+function applySwaps(gates: Gate[], swapPairs: [string, string][]): Gate[] {
+  const swapMap = new Map<string, string>();
+  for (const [a, b] of swapPairs) {
+    swapMap.set(a, b);
+    swapMap.set(b, a);
+  }
+  return gates.map(g => ({
+    ...g,
+    out: swapMap.get(g.out) ?? g.out,
+  }));
+}
+
+function makeInputs(x: number, y: number, bits: number): Record<string, number> {
+  const inputs: Record<string, number> = {};
+  for (let i = 0; i < bits; i++) {
+    inputs[`x${String(i).padStart(2, '0')}`] = (x >> i) & 1;
+    inputs[`y${String(i).padStart(2, '0')}`] = (y >> i) & 1;
+  }
+  return inputs;
+}
+
+function readZ(wires: Record<string, number>, bits: number): number {
+  let value = 0;
+  for (let i = 0; i < bits; i++) {
+    const name = `z${String(i).padStart(2, '0')}`;
+    if (wires[name] === 1) value |= (1 << i);
+  }
+  return value;
+}
