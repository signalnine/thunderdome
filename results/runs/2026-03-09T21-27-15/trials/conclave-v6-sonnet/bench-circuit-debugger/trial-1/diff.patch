   expect(swapped).toEqual(sorted);\n  });\n\n  test('handles 4 pairs of swaps in a larger circuit', () => {\n    const gates = buildCorrect8BitAdder();\n    const swapPairs: [string, string][] = [\n      ['z01', 'a01'],\n      ['z03', 't03'],\n      ['c04', 'b05'],\n      ['z06', 'a06'],\n    ];\n    const swapped = findSwappedWires(buildSwapped8BitAdder(swapPairs));\n    const expected = ['a01', 'a06', 'b05', 'c04', 't03', 'z01', 'z03', 'z06'];\n    expect(swapped).toEqual(expected);\n  });\n});\n\n// ─── Helper functions for test circuits ──────────────────────────────────\n\nfunction buildCorrect4BitAdder(): Gate[] {\n  return [\n    { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n    { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n\n    { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n    { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n    { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n    { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n    { op: 'OR',  in1: 'a01', in2: 'b01', out: 'c01' },\n\n    { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n    { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n    { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n    { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n    { op: 'OR',  in1: 'a02', in2: 'b02', out: 'c02' },\n\n    { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n    { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n    { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n    { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n    { op: 'OR',  in1: 'a03', in2: 'b03', out: 'c03' },\n\n    { op: 'OR',  in1: 'c03', in2: 'c03', out: 'z04' },\n  ];\n}\n\nfunction buildSwapped4BitAdder(swapPairs: [string, string][]): Gate[] {\n  return applySwaps(buildCorrect4BitAdder(), swapPairs);\n}\n\nfunction buildCorrect8BitAdder(): Gate[] {\n  const gates: Gate[] = [\n    { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n    { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n  ];\n  for 