\n    { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n    { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n    { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n    { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n    { op: 'OR',  in1: 'a03', in2: 'b03', out: 'c03' },\n\n    { op: 'OR',  in1: 'c03', in2: 'c03', out: 'z04' },\n  ];\n}\n\nfunction buildSwapped4BitAdder(swapPairs: [string, string][]): Gate[] {\n  return applySwaps(buildCorrect4BitAdder(), swapPairs);\n}\n\nfunction buildCorrect8BitAdder(): Gate[] {\n  const gates: Gate[] = [\n    { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n    { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n  ];\n  for (let i = 1; i <= 7; i++) {\n    const n = String(i).padStart(2, '0');\n    const prev = String(i - 1).padStart(2, '0');\n    gates.push(\n      { op: 'XOR', in1: `x${n}`, in2: `y${n}`, out: `t${n}` },\n      { op: 'XOR', in1: `t${n}`, in2: `c${prev}`, out: `z${n}` },\n      { op: 'AND', in1: `x${n}`, in2: `y${n}`, out: `a${n}` },\n      { op: 'AND', in1: `t${n}`, in2: `c${prev}`, out: `b${n}` },\n      { op: 'OR',  in1: `a${n}`, in2: `b${n}`, out: `c${n}` },\n    );\n  }\n  gates.push({ op: 'OR', in1: 'c07', in2: 'c07', out: 'z08' });\n  return gates;\n}\n\nfunction buildSwapped8BitAdder(swapPairs: [string, string][]): Gate[] {\n  return applySwaps(buildCorrect8BitAdder(), swapPairs);\n}\n\nfunction applySwaps(gates: Gate[], swapPairs: [string, string][]): Gate[] {\n  const swapMap = new Map<string, string>();\n  for (const [a, b] of swapPairs) {\n    swapMap.set(a, b);\n    swapMap.set(b, a);\n  }\n  return gates.map(g => ({\n    ...g,\n    out: swapMap.get(g.out) ?? g.out,\n  }));\n}\n\nfunction makeInputs(x: number, y: number, bits: number): Record<string, number> {\n  const inputs: Record<string, number> = {};\n  for (let i = 0; i < bits; i++) {\n    inputs[`x${String(i).padStart(2, '0')}`] = (x >> i) & 1;\n    inputs[`y${String(i).padStart(2, '0')}`] = (y >> i) & 1;\n  }\n  return inputs;\n}\