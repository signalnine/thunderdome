+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+/**
+ * Simulate the circuit and return final values of every wire.
+ */
+export function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const pending = [...gates];
+
+  while (pending.length > 0) {
+    const before = pending.length;
+    for (let i = pending.length - 1; i >= 0; i--) {
+      const gate = pending[i];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        switch (gate.op) {
+          case 'AND': wires[gate.out] = a & b; break;
+          case 'OR':  wires[gate.out] = a | b; break;
+          case 'XOR': wires[gate.out] = a ^ b; break;
+        }
+        pending.splice(i, 1);
+      }
+    }
+    if (pending.length === before) {
+      break;
+    }
+  }
+
+  return wires;
+}
+
+/**
+ * Find the 8 wires involved in 4 swap pairs in a broken binary adder circuit.
+ *
+ * Greedy structural repair per bit position. For each bit, we:
+ *  1. Find the half-XOR gate (XOR of xN, yN)
+ *  2. Find the sum-XOR gate (XOR with carry-in) → should output zN
+ *  3. Find gen AND gate, prop AND gate
+ *  4. Find carry-out OR gate
+ *
+ * When we can't find a gate (due to a swap), we identify and fix the swap,
+ * then continue. The carry wire for the next stage is discovered from the
+ * circuit structure rather than blindly trusting our accumulated state.
+ */
+export function findSwappedWires(gates: Gate[]): string[] {
+  const numBits = getNumBits(gates);
+  const swapped = new Set<string>();
+
+  // Work on a mutable copy so we can fix swaps as we discover them
+  const gl = gates.map(g => ({ ...g }));
+
+  let carryWire: string | null = null;
+
+  for (let bit = 0; bit < numBits; bit++) {
+    const n = String(bit).padStart(2, '0');
+    const xWire = `x${n}`;
+    const yWire = `y${n}`;
+    const zWire = `z${n}`;
+    const lastBit = bit === numBits - 1;
+    const lastZ = `z${String(numBits).padStart(2, '0')}`;
+
+    if (bit === 0) {
+      // Half adder
+      const xorGate = findGate(gl, 'XOR', xWire, yWire);
+      const andGate = findGate(gl, 'AND', xWire, yWire);
+      if (!xorGate || !andGate) break;
+
+      if (xorGate.out !== zWire) {
+        swapped.add(xorGate.out);
+        swapped.add(zWire);
+        swapOutputs(gl, xorGate.out, zWire);
+      }
+
+      carryWire = andGate.out;
+    } else {
+      // Full adder
+      const halfXor = findGate(gl, 'XOR', xWire, yWire);
+      if (!halfXor) break;
+
+      let halfSumWire = halfXor.out;
+
+      // Find XOR(halfSum, carryIn) -> zN
+      // First, check if the halfSum XOR exists with carryWire
+      let sumXor = findGate(gl, 'XOR', halfSumWire, carryWire!);
+
+      if (!sumXor) {
+        // halfSumWire might be swapped with something else.
+        // Find any XOR that uses carryWire — its other input should be halfSum.
+        const altSumXor = findGateByOpAndOneInput(gl, 'XOR', carryWire!);
+        if (altSumXor) {
+          const otherInput = altSumXor.in1 === carryWire ? altSumXor.in2 : altSumXor.in1;
+          // halfSumWire and otherInput are the swapped pair
+          swapped.add(halfSumWire);
+          swapped.add(otherInput);
+          swapOutputs(gl, halfSumWire, otherInput);
+          halfSumWire = otherInput;
+          sumXor = altSumXor;
+        } else {
+          // carryWire itself might be the swapped wire.
+          // The real carry-in is what feeds XOR with halfSumWire.
+          const altSumXor2 = findGateByOpAndOneInput(gl, 'XOR', halfSumWire);
+          if (altSumXor2) {
+            const actualCarryIn = altSumXor2.in1 === halfSumWire ? altSumXor2.in2 : altSumXor2.in1;
+            // carryWire is swapped with actualCarryIn
+            swapped.add(carryWire!);
+            swapped.add(actualCarryIn);
+            swapOutputs(gl, carryWire!, actualCarryIn);
+            carryWire = actualCarryIn;
+            sumXor = altSumXor2;
+          } else {
+            break;
+          }
+        }
+      }
+
+      // sumXor should output zN
+      if (sumXor.out !== zWire) {
+        swapped.add(sumXor.out);
+        swapped.add(zWire);
+        swapOutputs(gl, sumXor.out, zWire);
+      }
+
+      // AND(xN, yN) -> gen
+      const genAnd = findGate(gl, 'AND', xWire, yWire);
+      if (!genAnd) break;
+
+      // AND(halfSum, carryIn) -> prop
+      const propAnd = findGate(gl, 'AND', halfSumWire, carryWire!);
+      if (!propAnd) break;
+
+      // OR(gen, prop) -> carryOut
+      let carryOr = findGate(gl, 'OR', genAnd.out, propAnd.out);
+      if (!carryOr) {
+        const orWithGen = findGateByOpAndOneInput(gl, 'OR', genAnd.out);
+        const orWithProp = findGateByOpAndOneInput(gl, 'OR', propAnd.out);
+
+        if (orWithGen && !orWithProp) {
+          const otherInput = orWithGen.in1 === genAnd.out ? orWithGen.in2 : orWithGen.in1;
+          swapped.add(propAnd.out);
+          swapped.add(otherInput);
+          swapOutputs(gl, propAnd.out, otherInput);
+          carryOr = orWithGen;
+        } else if (orWithProp && !orWithGen) {
+          const otherInput = orWithProp.in1 === propAnd.out ? orWithProp.in2 : orWithProp.in1;
+          swapped.add(genAnd.out);
+          swapped.add(otherInput);
+          swapOutputs(gl, genAnd.out, otherInput);
+          carryOr = orWithProp;
+        } else {
+          break;
+        }
+      }
+
+      // For the last bit: OR gate must output z(numBits)
+      if (lastBit && carryOr.out !== lastZ) {
+        swapped.add(carryOr.out);
+        swapped.add(lastZ);
+        swapOutputs(gl, carryOr.out, lastZ);
+      }
+
+      carryWire = carryOr.out;
+    }
+  }
+
+  return [...swapped].sort();
+}
+
+function getNumBits(gates: Gate[]): number {
+  let max = 0;
+  for (const g of gates) {
+    for (const w of [g.in1, g.in2]) {
+      const m = w.match(/^x(\d+)$/);
+      if (m) max = Math.max(max, parseInt(m[1], 10));
+    }
+  }
+  return max + 1;
+}
+
+function findGate(gates: Gate[], op: Gate['op'], a: string, b: string): Gate | null {
+  return gates.find(
+    g => g.op === op && ((g.in1 === a && g.in2 === b) || (g.in1 === b && g.in2 === a))
+  ) ?? null;
+}
+
+function findGateByOpAndOneInput(gates: Gate[], op: Gate['op'], input: string): Gate | null {
+  return gates.find(g => g.op === op && (g.in1 === input || g.in2 === input)) ?? null;
+}
+
+function swapOutputs(gates: Gate[], a: string, b: string): void {
+  for (const g of gates) {
+    if (g.out === a) g.out = b;
+    else if (g.out === b) g.out = a;
+  }
+}
