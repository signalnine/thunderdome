@@ -0,0 +1,105 @@
+import { Router, Response } from 'express';
+import Database from 'better-sqlite3';
+import { authenticate, AuthRequest } from '../middleware/auth.js';
+
+export function createQueryRouter(db: Database.Database): Router {
+  const router = Router();
+
+  router.post('/count', authenticate, (req: AuthRequest, res: Response) => {
+    const { eventName, startDate, endDate } = req.body;
+    const tenantId = req.user!.tenantId;
+
+    let sql = 'SELECT COUNT(*) as count FROM events WHERE tenant_id = ?';
+    const params: string[] = [tenantId];
+
+    if (eventName) {
+      sql += ' AND name = ?';
+      params.push(eventName);
+    }
+    if (startDate) {
+      sql += ' AND timestamp >= ?';
+      params.push(startDate);
+    }
+    if (endDate) {
+      sql += ' AND timestamp <= ?';
+      params.push(endDate);
+    }
+
+    const result = db.prepare(sql).get(...params) as { count: number };
+    res.json({ count: result.count });
+  });
+
+  router.post('/timeseries', authenticate, (req: AuthRequest, res: Response) => {
+    const { eventName, interval = 'day', startDate, endDate } = req.body;
+    const tenantId = req.user!.tenantId;
+
+    let dateFormat: string;
+    switch (interval) {
+      case 'hour':
+        dateFormat = '%Y-%m-%dT%H:00:00Z';
+        break;
+      case 'week':
+        dateFormat = '%Y-W%W';
+        break;
+      case 'month':
+        dateFormat = '%Y-%m';
+        break;
+      default:
+        dateFormat = '%Y-%m-%d';
+    }
+
+    let sql = `SELECT strftime('${dateFormat}', timestamp) as date, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: string[] = [tenantId];
+
+    if (eventName) {
+      sql += ' AND name = ?';
+      params.push(eventName);
+    }
+    if (startDate) {
+      sql += ' AND timestamp >= ?';
+      params.push(startDate);
+    }
+    if (endDate) {
+      sql += ' AND timestamp <= ?';
+      params.push(endDate);
+    }
+
+    sql += ' GROUP BY date ORDER BY date ASC';
+
+    const data = db.prepare(sql).all(...params) as Array<{ date: string; count: number }>;
+    res.json({ data });
+  });
+
+  router.post('/breakdown', authenticate, (req: AuthRequest, res: Response) => {
+    const { eventName, property, startDate, endDate } = req.body;
+    const tenantId = req.user!.tenantId;
+
+    if (!property) {
+      res.status(400).json({ error: 'property is required' });
+      return;
+    }
+
+    let sql = `SELECT json_extract(properties, '$.${property}') as value, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: string[] = [tenantId];
+
+    if (eventName) {
+      sql += ' AND name = ?';
+      params.push(eventName);
+    }
+    if (startDate) {
+      sql += ' AND timestamp >= ?';
+      params.push(startDate);
+    }
+    if (endDate) {
+      sql += ' AND timestamp <= ?';
+      params.push(endDate);
+    }
+
+    sql += ' GROUP BY value ORDER BY count DESC';
+
+    const data = db.prepare(sql).all(...params) as Array<{ value: string; count: number }>;
+    res.json({ data });
+  });
+
+  return router;
+}
diff --git a/src/routes/users.ts b/src/routes/users.ts
new file mode 100644
index 0000000..ed8ca18
