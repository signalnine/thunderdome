+          { name: 'page_view', properties: { url: '/about' }, timestamp: '2024-01-01T11:00:00Z' },
+          { name: 'page_view', properties: { url: '/home' }, timestamp: '2024-01-02T10:00:00Z' },
+          { name: 'click', properties: { button: 'signup' }, timestamp: '2024-01-02T11:00:00Z' },
+        ]
+      });
+
+    // Ingest events for other tenant
+    await request(app)
+      .post('/api/events/batch')
+      .set('Authorization', `Bearer ${otherToken}`)
+      .send({
+        events: [
+          { name: 'page_view', properties: { url: '/other' }, timestamp: '2024-01-01T10:00:00Z' },
