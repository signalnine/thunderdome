+import { describe, it, expect, beforeEach } from 'vitest';
+import request from 'supertest';
+import { createApp } from '../app.js';
+
+describe('Data Ingestion', () => {
+  let app: ReturnType<typeof createApp>;
+  let token: string;
+
+  beforeEach(async () => {
+    app = createApp(':memory:');
+    const reg = await request(app)
+      .post('/api/auth/register')
+      .send({ email: 'admin@acme.com', password: 'secret123', tenantId: 'acme' });
+    token = reg.body.token;
+  });
+
+  describe('POST /api/events', () => {
+    it('ingests a single event', async () => {
+      const res = await request(app)
+        .post('/api/events')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'page_view', properties: { url: '/home' } });
+
+      expect(res.status).toBe(201);
+      expect(res.body.id).toBeDefined();
+      expect(res.body.name).toBe('page_view');
+    });
+
+    it('ingests event with default timestamp', async () => {
+      const res = await request(app)
+        .post('/api/events')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'click' });
+
+      expect(res.status).toBe(201);
+      expect(res.body.timestamp).toBeDefined();
+    });
+
+    it('ingests event with custom timestamp', async () => {
+      const ts = '2024-01-15T12:00:00.000Z';
+      const res = await request(app)
+        .post('/api/events')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'purchase', timestamp: ts });
+
+      expect(res.status).toBe(201);
+      expect(res.body.timestamp).toBe(ts);
+    });
+
+    it('requires authentication', async () => {
+      const res = await request(app)
+        .post('/api/events')
+        .send({ name: 'page_view' });
+      expect(res.status).toBe(401);
+    });
+
+    it('requires event name', async () => {
+      const res = await request(app)
+        .post('/api/events')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ properties: { url: '/home' } });
+      expect(res.status).toBe(400);
+    });
+  });
+
+  describe('POST /api/events/batch', () => {
+    it('ingests multiple events at once', async () => {
+      const res = await request(app)
+        .post('/api/events/batch')
+        .set('Authorization', `Bearer ${token}`)
+        .send({
+          events: [
+            { name: 'page_view', properties: { url: '/home' } },
+            { name: 'page_view', properties: { url: '/about' } },
+            { name: 'click', properties: { button: 'signup' } },
+          ]
+        });
+
+      expect(res.status).toBe(201);
+      expect(res.body.count).toBe(3);
+    });
+
+    it('requires authentication', async () => {
+      const res = await request(app)
+        .post('/api/events/batch')
+        .send({ events: [{ name: 'page_view' }] });
+      expect(res.status).toBe(401);
+    });
+
+    it('rejects empty batch', async () => {
+      const res = await request(app)
+        .post('/api/events/batch')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ events: [] });
+      expect(res.status).toBe(400);
+    });
+  });
+});
