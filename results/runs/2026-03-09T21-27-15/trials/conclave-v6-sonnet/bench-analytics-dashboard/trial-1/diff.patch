cord<string, string> | undefined;\n\n    if (!dashboard) {\n      res.status(404).json({ error: 'Dashboard not found' });\n      return;\n    }\n\n    res.json({ ...dashboard, config: JSON.parse(dashboard.config) });\n  });\n\n  router.patch('/:id', authenticate, (req: AuthRequest, res: Response) => {\n    const { id } = req.params;\n    const tenantId = req.user!.tenantId;\n\n    const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(id, tenantId) as Record<string, string> | undefined;\n    if (!dashboard) {\n      res.status(404).json({ error: 'Dashboard not found' });\n      return;\n    }\n\n    const name = req.body.name ?? dashboard.name;\n    const config = req.body.config !== undefined ? JSON.stringify(req.body.config) : dashboard.config;\n    const now = new Date().toISOString();\n\n    db.prepare('UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?')\n      .run(name, config, now, id);\n\n    const updated = db.prepare('SELECT * FROM dashboards WHERE id = ?').get(id) as Record<string, string>;\n    res.json({ ...updated, config: JSON.parse(updated.config) });\n  });\n\n  router.delete('/:id', authenticate, (req: AuthRequest, res: Response) => {\n    const { id } = req.params;\n    const tenantId = req.user!.tenantId;\n\n    const dashboard = db.prepare('SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?').get(id, tenantId);\n    if (!dashboard) {\n      res.status(404).json({ error: 'Dashboard not found' });\n      return;\n    }\n\n    db.prepare('DELETE FROM dashboards WHERE id = ?').run(id);\n    res.status(204).send();\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1035,"cache_read_input_tokens":42519,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1035},"output_tokens":22,"service_tier":"standard","inference_geo":"not_available"},"context_management":n