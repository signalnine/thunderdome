me.com', password: 'secret123', tenantId: 'acme' });\n\n      const res = await request(app)\n        .post('/api/auth/register')\n        .send({ email: 'user@acme.com', password: 'other', tenantId: 'acme' });\n\n      expect(res.status).toBe(409);\n    });\n\n    it('rejects missing fields', async () => {\n      const res = await request(app)\n        .post('/api/auth/register')\n        .send({ email: 'user@acme.com' });\n\n      expect(res.status).toBe(400);\n    });\n  });\n\n  describe('POST /api/auth/login', () => {\n    beforeEach(async () => {\n      await request(app)\n        .post('/api/auth/register')\n        .send({ email: 'user@acme.com', password: 'secret123', tenantId: 'acme' });\n    });\n\n    it('logs in with correct credentials', async () => {\n      const res = await request(app)\n        .post('/api/auth/login')\n        .send({ email: 'user@acme.com', password: 'secret123' });\n\n      expect(res.status).toBe(200);\n      expect(res.body.token).toBeDefined();\n    });\n\n    it('rejects wrong password', async () => {\n      const res = await request(app)\n        .post('/api/auth/login')\n        .send({ email: 'user@acme.com', password: 'wrong' });\n\n      expect(res.status).toBe(401);\n    });\n\n    it('rejects unknown email', async () => {\n      const res = await request(app)\n        .post('/api/auth/login')\n        .send({ email: 'nobody@acme.com', password: 'secret123' });\n\n      expect(res.status).toBe(401);\n    });\n  });\n\n  describe('GET /api/auth/me', () => {\n    it('returns profile for authenticated user', async () => {\n      const reg = await request(app)\n        .post('/api/auth/register')\n        .send({ email: 'user@acme.com', password: 'secret123', tenantId: 'acme' });\n\n      const res = await request(app)\n        .get('/api/auth/me')\n        .set('Authorization', `Bearer ${reg.body.token}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body.email).toBe('user@acme.com');\n      expect(res.body.ten