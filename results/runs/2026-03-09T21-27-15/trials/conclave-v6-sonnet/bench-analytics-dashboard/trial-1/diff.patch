sh(eventName);\n    }\n    if (startDate) {\n      sql += ' AND timestamp >= ?';\n      params.push(startDate);\n    }\n    if (endDate) {\n      sql += ' AND timestamp <= ?';\n      params.push(endDate);\n    }\n\n    sql += ' GROUP BY date ORDER BY date ASC';\n\n    const data = db.prepare(sql).all(...params) as Array<{ date: string; count: number }>;\n    res.json({ data });\n  });\n\n  router.post('/breakdown', authenticate, (req: AuthRequest, res: Response) => {\n    const { eventName, property, startDate, endDate } = req.body;\n    const tenantId = req.user!.tenantId;\n\n    if (!property) {\n      res.status(400).json({ error: 'property is required' });\n      return;\n    }\n\n    let sql = `SELECT json_extract(properties, '$.${property}') as value, COUNT(*) as count FROM events WHERE tenant_id = ?`;\n    const params: string[] = [tenantId];\n\n    if (eventName) {\n      sql += ' AND name = ?';\n      params.push(eventName);\n    }\n    if (startDate) {\n      sql += ' AND timestamp >= ?';\n      params.push(startDate);\n    }\n    if (endDate) {\n      sql += ' AND timestamp <= ?';\n      params.push(endDate);\n    }\n\n    sql += ' GROUP BY value ORDER BY count DESC';\n\n    const data = db.prepare(sql).all(...params) as Array<{ value: string; count: number }>;\n    res.json({ data });\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1105,"cache_read_input_tokens":41414,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1105},"output_tokens":18,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"3a9aa767-bd8b-44c5-bb29-855c3862ca3d","uuid":"6f42f3de-47be-4f60-a3dc-647a8d048642"}
