     ]\n      });\n  });\n\n  describe('POST /api/query/count', () => {\n    it('counts all events for tenant', async () => {\n      const res = await request(app)\n        .post('/api/query/count')\n        .set('Authorization', `Bearer ${acmeToken}`)\n        .send({});\n\n      expect(res.status).toBe(200);\n      expect(res.body.count).toBe(4);\n    });\n\n    it('counts events by name filter', async () => {\n      const res = await request(app)\n        .post('/api/query/count')\n        .set('Authorization', `Bearer ${acmeToken}`)\n        .send({ eventName: 'page_view' });\n\n      expect(res.status).toBe(200);\n      expect(res.body.count).toBe(3);\n    });\n\n    it('respects tenant isolation', async () => {\n      const res = await request(app)\n        .post('/api/query/count')\n        .set('Authorization', `Bearer ${otherToken}`)\n        .send({});\n\n      expect(res.status).toBe(200);\n      expect(res.body.count).toBe(2);\n    });\n\n    it('requires authentication', async () => {\n      const res = await request(app).post('/api/query/count').send({});\n      expect(res.status).toBe(401);\n    });\n  });\n\n  describe('POST /api/query/timeseries', () => {\n    it('returns daily event counts', async () => {\n      const res = await request(app)\n        .post('/api/query/timeseries')\n        .set('Authorization', `Bearer ${acmeToken}`)\n        .send({\n          eventName: 'page_view',\n          interval: 'day',\n          startDate: '2024-01-01',\n          endDate: '2024-01-02',\n        });\n\n      expect(res.status).toBe(200);\n      expect(Array.isArray(res.body.data)).toBe(true);\n      expect(res.body.data.length).toBeGreaterThan(0);\n      const jan1 = res.body.data.find((d: { date: string }) => d.date.startsWith('2024-01-01'));\n      expect(jan1).toBeDefined();\n      expect(jan1.count).toBe(2);\n    });\n\n    it('respects tenant isolation in timeseries', async () => {\n      const res = await request(app)\n        .post('/api/query/timeseries')\n        .set('Authorization', `Bearer ${otherToken}`)\n        .send({ eventName: 'page_view', interval: 'day', startDate: '2024-01-01', endDate: '2024-01-02' });\n\n      expect(res.status).toBe(200);\n      const total = res.body.data.reduce((sum: number, d: { count: number }) => sum + d.count, 0);\n      expect(total).toBe(2);\n    });\n  });\n\n  describe('POST /api/query/breakdown', () => {\n    it('groups events by a property', async () => {\n      const res = await request(app)\n        .post('/api/query/breakdown')\n        .set('Authorization', `Bearer ${acmeToken}`)\n        .send({ eventName: 'page_view', property: 'url' });\n\n      expect(res.status).toBe(200);\n      expect(Array.isArray(res.body.data)).toBe(true);\n      const home = res.body.data.find((d: { value: string }) => d.value === '/home');\n      expect(home).toBeDefined();\n      expect(home.count).toBe(2);\n      const about = res.body.data.find((d: { value: string }) => d.value === '/about');\n      expect(about.count).toBe(1);\n    });\n\n    it('respects tenant isolation in breakdown', async () => {\n      const res = await request(app)\n        .post('/api/query/breakdown')\n        .set('Authorization', `Bearer ${otherToken}`)\n        .send({ eventName: 'page_view', property: 'url' });\n\n      expect(res.status).toBe(200);\n      const values = res.body.data.map((d: { value: string }) => d.value);\n      expect(values).not.toContain('/home');\n      expect(values).not.toContain('/about');\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1087,"cache_read_input_tokens":35187,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1087},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"3a9aa767-bd8b-44c5-bb29-855c3862ca3d","uuid":"871abb12-cc29-4200-99a6-b9d011e