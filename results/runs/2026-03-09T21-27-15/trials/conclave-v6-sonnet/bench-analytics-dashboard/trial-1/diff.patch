+  });
+
+  describe('POST /api/dashboards', () => {
+    it('creates a dashboard', async () => {
+      const res = await request(app)
+        .post('/api/dashboards')
+        .set('Authorization', `Bearer ${acmeToken}`)
+        .send({ name: 'Main Dashboard' });
+
+      expect(res.status).toBe(201);
+      expect(res.body.id).toBeDefined();
+      expect(res.body.name).toBe('Main Dashboard');
+    });
+
+    it('requires authentication', async () => {
+      const res = await request(app).post('/api/dashboards').send({ name: 'Main' });
+      expect(res.status).toBe(401);
+    });
+
+    it('requires name', async () => {
+      const res = await request(app)
+        .post('/api/dashboards')
+        .set('Authorization', `Bearer ${acmeToken}`)
+        .send({});
+      expect(res.status).toBe(400);
+    });
+  });
+
+  describe('GET /api/dashboards', () => {
+    it('lists dashboards for tenant', async () => {
+      await request(app)
+        .post('/api/dashboards')
+        .set('Authorization', `Bearer ${acmeToken}`)
+        .send({ name: 'Dash 1' });
+      await request(app)
+        .post('/api/dashboards')
+        .set('Authorization', `Bearer ${acmeToken}`)
+        .send({ name: 'Dash 2' });
+      await request(app)
+        .post('/api/dashboards')
+        .set('Authorization', `Bearer ${otherToken}`)
+        .send({ name: 'Other Dash' });
+
+      const res = await request(app)
+        .get('/api/dashboards')
+        .set('Authorization', `Bearer ${acmeToken}`);
+
+      expect(res.status).toBe(200);
+      expect(res.body.length).toBe(2);
+      const names = res.body.map((d: { name: string }) => d.name);
+      expect(names).toContain('Dash 1');
+      expect(names).toContain('Dash 2');
+      expect(names).not.toContain('Other Dash');
+    });
+  });
+
+  describe('GET /api/dashboards/:id', () => {
+    it('returns a specific dashboard', async () => {
+      const create = await request(app)
+        .post('/api/dashboards')
+        .set('Authorization', `Bearer ${acmeToken}`)
+        .send({ name: 'My Dashboard' });
+
+      const res = await request(app)
+        .get(`/api/dashboards/${create.body.id}`)
+        .set('Authorization', `Bearer ${acmeToken}`);
+
+      expect(res.status).toBe(200);
+      expect(res.body.name).toBe('My Dashboard');
+    });
+
+    it('returns 404 for dashboard from another tenant', async () => {
+      const create = await request(app)
+        .post('/api/dashboards')
+        .set('Authorization', `Bearer ${otherToken}`)
+        .send({ name: 'Other Dashboard' });
+
+      const res = await request(app)
+        .get(`/api/dashboards/${create.body.id}`)
+        .set('Authorization', `Bearer ${acmeToken}`);
+
+      expect(res.status).toBe(404);
+    });
+  });
+
+  describe('PATCH /api/dashboards/:id', () => {
+    it('updates a dashboard', async () => {
+      const create = await request(app)
+        .post('/api/dashboards')
+        .set('Authorization', `Bearer ${acmeToken}`)
+        .send({ name: 'Old Name' });
+
+      const res = await request(app)
+        .patch(`/api/dashboards/${create.body.id}`)
+        .set('Authorization', `Bearer ${acmeToken}`)
+        .send({ name: 'New Name' });
+
+      expect(res.status).toBe(200);
+      expect(res.body.name).toBe('New Name');
+    });
+
+    it('cannot update dashboard from another tenant', async () => {
