ns token', async () => {\n      const res = await request(app)\n        .post('/api/auth/register')\n        .send({ email: 'user@acme.com', password: 'secret123', tenantId: 'acme' });\n\n      expect(res.status).toBe(201);\n      expect(res.body.token).toBeDefined();\n      expect(res.body.user.email).toBe('user@acme.com');\n      expect(res.body.user.role).toBe('viewer');\n      expect(res.body.user.password_hash).toBeUndefined();\n    });\n\n    it('first user in a tenant becomes admin', async () => {\n      const res = await request(app)\n        .post('/api/auth/register')\n        .send({ email: 'admin@acme.com', password: 'secret123', tenantId: 'acme' });\n\n      expect(res.status).toBe(201);\n      expect(res.body.user.role).toBe('admin');\n    });\n\n    it('second user in same tenant is viewer', async () => {\n      await request(app)\n        .post('/api/auth/register')\n        .send({ email: 'admin@acme.com', password: 'secret123', tenantId: 'acme' });\n\n      const res = await request(app)\n        .post('/api/auth/register')\n        .send({ email: 'user@acme.com', password: 'secret123', tenantId: 'acme' });\n\n      expect(res.body.user.role).toBe('viewer');\n    });\n\n    it('rejects duplicate email', async () => {\n      await request(app)\n        .post('/api/auth/register')\n        .send({ email: 'user@acme.com', password: 'secret123', tenantId: 'acme' });\n\n      const res = await request(app)\n        .post('/api/auth/register')\n        .send({ email: 'user@acme.com', password: 'other', tenantId: 'acme' });\n\n      expect(res.status).toBe(409);\n    });\n\n    it('rejects missing fields', async () => {\n      const res = await request(app)\n        .post('/api/auth/register')\n        .send({ email: 'user@acme.com' });\n\n      expect(res.status).toBe(400);\n    });\n  });\n\n  describe('POST /api/auth/login', () => {\n    beforeEach(async () => {\n      await request(app)\n        .post('/api/auth/register')\n        .send({ email: 'user@acme.com', password: 'secret123', tenantId: 'acme' });\n    });\n\n    it('logs in with correct credentials', async () => {\n      const res = await request(app)\n        .post('/api/auth/login')\n        .send({ email: 'user@acme.com', password: 'secret123' });\n\n      expect(res.status).toBe(200);\n      expect(res.body.token).toBeDefined();\n    });\n\n    it('rejects wrong password', async () => {\n      const res = await request(app)\n        .post('/api/auth/login')\n        .send({ email: 'user@acme.com', password: 'wrong' });\n\n      expect(res.status).toBe(401);\n    });\n\n    it('rejects unknown email', async () => {\n      const res = await request(app)\n        .post('/api/auth/login')\n        .send({ email: 'nobody@acme.com', password: 'secret123' });\n\n      expect(res.status).toBe(401);\n    });\n  });\n\n  describe('GET /api/auth/me', () => {\n    it('returns profile for authenticated user', async () => {\n      const reg = await request(app)\n        .post('/api/auth/register')\n        .send({ email: 'user@acme.com', password: 'secret123', tenantId: 'acme' });\n\n      const res = await request(app)\n        .get('/api/auth/me')\n        .set('Authorization', `Bearer ${reg.body.token}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body.email).toBe('user@acme.com');\n      expect(res.body.tenantId).toBe('acme');\n    });\n\n    it('returns 401 without token', async () => {\n      const res = await request(app).get('/api/auth/me');\n      expect(res.status).toBe(401);\n    });\n  });\n\n  describe('PATCH /api/users/:id/role', () => {\n    it('admin can change another user role', async () => {\n      const adminReg = await request(app)\n        .post('/api/auth/register')\n        .send({ email: 'admin@acme.com', password: 'secret123', tenantId: 'acme' });\n\n      const userReg = await request(app)\n        .post('/api/auth/register')\n        .send({ email: 'user@acme.com', password: 'secret123', tenantId: 'acme' });\n\n      const res = await request(app)\n        .patch(`/api/users/${userReg.body.user.id}/role`)\n        .set('Authorization', `Bearer ${adminReg.body.token}`)\n        .send({ role: 'editor' });\n\n      expect(res.status).toBe(200);\n      expect(res.body.role).toBe('editor');\n    });\n\n    it('non-admin cannot change roles', async () => {\n      const adminReg = await request(app)\n        .post('/api/auth/register')\n        .send({ email: 'admin@acme.com', password: 'secret123', tenantId: 'acme' });\n\n      const userReg = await request(app)\n        .post('/api/auth/register')\n        .send({ email: 'user@acme.com', password: 'secret123', tenantId: 'acme' });\n\n      const res = await request(app)\n        .patch(`/api/users/${adminReg.body.user.id}/role`)\n        .set('Authorization', `Bearer ${userReg.body.token}`)\n        .send({ role: 'editor' });\n\n      expect(res.status).toBe(403);\n    });\n\n    it('admin cannot change role of user in different tenant', async () => {\n      const adminReg = await request(app)\n        .post('/api/auth/register')\n        .send({ email: 'admin@acme.com', password: 'secret123', tenantId: 'acme' });\n\n      const otherReg = await request(app)\n        .post('/api/auth/register')\n        .send({ email: 'other@other.com', password: 'secret123', tenantId: 'other' });\n\n      const res = await request(app)\n        .patch(`/api/users/${otherReg.body.user.id}/role`)\n        .set('Authorization', `Bearer ${adminReg.body.token}`)\n        .send({ role: 'editor' });\n\n      expect(res.status).toBe(404);\n    });\n  });\n});\n","structuredPatch":[{"oldStart":11,"oldLines":6,"newStart":11,"newLines":11,"lines":[" ","   describe('POST /api/auth/register', () => {","     it('registers a new user and returns token', async () => {","+      // Make first user (admin), then register second user (viewer)","+      await request(app)","+        .post('/api/auth/register')","+        .send({ email: 'admin@acme.com', password: 'adminpass