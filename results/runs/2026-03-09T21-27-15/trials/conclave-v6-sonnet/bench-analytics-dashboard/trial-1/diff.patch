+import { Router, Response } from 'express';
+import Database from 'better-sqlite3';
+import { v4 as uuidv4 } from 'uuid';
+import { authenticate, AuthRequest } from '../middleware/auth.js';
+
+export function createDashboardsRouter(db: Database.Database): Router {
+  const router = Router();
+
+  router.post('/', authenticate, (req: AuthRequest, res: Response) => {
+    const { name, config } = req.body;
+    if (!name) {
+      res.status(400).json({ error: 'Dashboard name is required' });
+      return;
+    }
+
+    const id = uuidv4();
+    const tenantId = req.user!.tenantId;
+    const ownerId = req.user!.userId;
+    const now = new Date().toISOString();
+
+    db.prepare('INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)')
+      .run(id, tenantId, name, ownerId, JSON.stringify(config || {}), now, now);
+
+    const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ?').get(id) as Record<string, string>;
+    res.status(201).json({ ...dashboard, config: JSON.parse(dashboard.config) });
+  });
+
+  router.get('/', authenticate, (req: AuthRequest, res: Response) => {
+    const tenantId = req.user!.tenantId;
+    const dashboards = db.prepare('SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC').all(tenantId) as Array<Record<string, string>>;
+    res.json(dashboards.map(d => ({ ...d, config: JSON.parse(d.config) })));
+  });
+
+  router.get('/:id', authenticate, (req: AuthRequest, res: Response) => {
+    const { id } = req.params;
+    const tenantId = req.user!.tenantId;
+    const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(id, tenantId) as Record<string, string> | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+
+    res.json({ ...dashboard, config: JSON.parse(dashboard.config) });
+  });
+
+  router.patch('/:id', authenticate, (req: AuthRequest, res: Response) => {
+    const { id } = req.params;
+    const tenantId = req.user!.tenantId;
+
+    const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(id, tenantId) as Record<string, string> | undefined;
+    if (!dashboard) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+
+    const name = req.body.name ?? dashboard.name;
+    const config = req.body.config !== undefined ? JSON.stringify(req.body.config) : dashboard.config;
+    const now = new Date().toISOString();
+
+    db.prepare('UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?')
+      .run(name, config, now, id);
+
+    const updated = db.prepare('SELECT * FROM dashboards WHERE id = ?').get(id) as Record<string, string>;
+    res.json({ ...updated, config: JSON.parse(updated.config) });
+  });
+
+  router.delete('/:id', authenticate, (req: AuthRequest, res: Response) => {
+    const { id } = req.params;
+    const tenantId = req.user!.tenantId;
+
+    const dashboard = db.prepare('SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?').get(id, tenantId);
+    if (!dashboard) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+
+    db.prepare('DELETE FROM dashboards WHERE id = ?').run(id);
+    res.status(204).send();
+  });
+
+  return router;
+}
