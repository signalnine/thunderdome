@@ -0,0 +1,31 @@
+import { Router, Response } from 'express';
+import Database from 'better-sqlite3';
+import { authenticate, requireAdmin, AuthRequest } from '../middleware/auth.js';
+
+export function createUsersRouter(db: Database.Database): Router {
+  const router = Router();
+
+  router.patch('/:id/role', authenticate, requireAdmin, (req: AuthRequest, res: Response) => {
+    const { id } = req.params;
+    const { role } = req.body;
+
+    if (!['admin', 'editor', 'viewer'].includes(role)) {
+      res.status(400).json({ error: 'Invalid role. Must be admin, editor, or viewer' });
+      return;
+    }
+
+    // Only allow changing roles within own tenant
+    const user = db.prepare('SELECT id, email, tenant_id as tenantId, role FROM users WHERE id = ? AND tenant_id = ?')
+      .get(id, req.user!.tenantId) as Record<string, string> | undefined;
+
+    if (!user) {
+      res.status(404).json({ error: 'User not found' });
+      return;
+    }
+
+    db.prepare('UPDATE users SET role = ? WHERE id = ?').run(role, id);
+    res.json({ ...user, role });
+  });
+
+  return router;
+}
