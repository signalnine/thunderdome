@@ -0,0 +1,72 @@
+import { Router, Response } from 'express';
+import Database from 'better-sqlite3';
+import { authenticate, AuthRequest } from '../middleware/auth.js';
+
+function toCsv(rows: Array<Record<string, unknown>>): string {
+  if (rows.length === 0) return '';
+  const headers = Object.keys(rows[0]);
+  const lines = [
+    headers.join(','),
+    ...rows.map(row =>
+      headers.map(h => {
+        const val = row[h];
+        const str = val === null || val === undefined ? '' : String(val);
+        return str.includes(',') || str.includes('"') || str.includes('\n')
+          ? `"${str.replace(/"/g, '""')}"`
+          : str;
+      }).join(',')
+    ),
+  ];
+  return lines.join('\n');
+}
+
+export function createExportRouter(db: Database.Database): Router {
+  const router = Router();
+
+  router.get('/events.json', authenticate, (req: AuthRequest, res: Response) => {
+    const tenantId = req.user!.tenantId;
+    const events = db.prepare('SELECT id, tenant_id as tenantId, name, properties, timestamp, user_id as userId FROM events WHERE tenant_id = ? ORDER BY timestamp DESC').all(tenantId) as Array<Record<string, string>>;
+    const parsed = events.map(e => ({ ...e, properties: JSON.parse(e.properties) }));
+    res.json(parsed);
+  });
+
+  router.get('/events.csv', authenticate, (req: AuthRequest, res: Response) => {
+    const tenantId = req.user!.tenantId;
+    const events = db.prepare('SELECT id, tenant_id as tenantId, name, properties, timestamp, user_id as userId FROM events WHERE tenant_id = ? ORDER BY timestamp DESC').all(tenantId) as Array<Record<string, string>>;
+    const csv = toCsv(events as unknown as Array<Record<string, unknown>>);
+    res.setHeader('Content-Type', 'text/csv');
+    res.setHeader('Content-Disposition', 'attachment; filename="events.csv"');
+    res.send(csv);
+  });
+
+  router.get('/dashboards/:id.json', authenticate, (req: AuthRequest, res: Response) => {
+    const { id } = req.params;
+    const tenantId = req.user!.tenantId;
+    const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(id, tenantId) as Record<string, string> | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+
+    res.json({ ...dashboard, config: JSON.parse(dashboard.config) });
+  });
+
+  router.get('/dashboards/:id.csv', authenticate, (req: AuthRequest, res: Response) => {
+    const { id } = req.params;
+    const tenantId = req.user!.tenantId;
+    const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(id, tenantId) as Record<string, string> | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+
+    const csv = toCsv([dashboard as unknown as Record<string, unknown>]);
+    res.setHeader('Content-Type', 'text/csv');
+    res.setHeader('Content-Disposition', `attachment; filename="dashboard-${id}.csv"`);
+    res.send(csv);
+  });
+
+  return router;
+}
