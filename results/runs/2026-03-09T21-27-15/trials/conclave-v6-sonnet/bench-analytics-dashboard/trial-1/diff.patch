t('/api/dashboards')\n        .set('Authorization', `Bearer ${acmeToken}`)\n        .send({ name: 'Dash 1' });\n      await request(app)\n        .post('/api/dashboards')\n        .set('Authorization', `Bearer ${acmeToken}`)\n        .send({ name: 'Dash 2' });\n      await request(app)\n        .post('/api/dashboards')\n        .set('Authorization', `Bearer ${otherToken}`)\n        .send({ name: 'Other Dash' });\n\n      const res = await request(app)\n        .get('/api/dashboards')\n        .set('Authorization', `Bearer ${acmeToken}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body.length).toBe(2);\n      const names = res.body.map((d: { name: string }) => d.name);\n      expect(names).toContain('Dash 1');\n      expect(names).toContain('Dash 2');\n      expect(names).not.toContain('Other Dash');\n    });\n  });\n\n  describe('GET /api/dashboards/:id', () => {\n    it('returns a specific dashboard', async () => {\n      const create = await request(app)\n        .post('/api/dashboards')\n        .set('Authorization', `Bearer ${acmeToken}`)\n        .send({ name: 'My Dashboard' });\n\n      const res = await request(app)\n        .get(`/api/dashboards/${create.body.id}`)\n        .set('Authorization', `Bearer ${acmeToken}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe('My Dashboard');\n    });\n\n    it('returns 404 for dashboard from another tenant', async () => {\n      const create = await request(app)\n        .post('/api/dashboards')\n        .set('Authorization', `Bearer ${otherToken}`)\n        .send({ name: 'Other Dashboard' });\n\n      const res = await request(app)\n        .get(`/api/dashboards/${create.body.id}`)\n        .set('Authorization', `Bearer ${acmeToken}`);\n\n      expect(res.status).toBe(404);\n    });\n  });\n\n  describe('PATCH /api/dashboards/:id', () => {\n    it('updates a dashboard', async () => {\n      const create = await request(app)\n        .post('/api/dashboards')\n        .set('Autho