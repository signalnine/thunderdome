+import { Router, Response } from 'express';
+import Database from 'better-sqlite3';
+import { v4 as uuidv4 } from 'uuid';
+import { authenticate, AuthRequest } from '../middleware/auth.js';
+
+export function createEventsRouter(db: Database.Database): Router {
+  const router = Router();
+
+  router.post('/', authenticate, (req: AuthRequest, res: Response) => {
+    const { name, properties, timestamp } = req.body;
+    if (!name) {
+      res.status(400).json({ error: 'Event name is required' });
+      return;
+    }
+
+    const id = uuidv4();
+    const ts = timestamp || new Date().toISOString();
+    const props = JSON.stringify(properties || {});
+    const tenantId = req.user!.tenantId;
+    const userId = req.user!.userId;
+
+    db.prepare('INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id) VALUES (?, ?, ?, ?, ?, ?)')
+      .run(id, tenantId, name, props, ts, userId);
+
+    const event = db.prepare('SELECT id, tenant_id as tenantId, name, properties, timestamp, user_id as userId FROM events WHERE id = ?').get(id) as Record<string, string>;
+    res.status(201).json({ ...event, properties: JSON.parse(event.properties) });
+  });
+
+  router.post('/batch', authenticate, (req: AuthRequest, res: Response) => {
+    const { events } = req.body;
+    if (!Array.isArray(events) || events.length === 0) {
+      res.status(400).json({ error: 'events must be a non-empty array' });
+      return;
+    }
+
+    const tenantId = req.user!.tenantId;
+    const userId = req.user!.userId;
+
+    const insert = db.prepare('INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id) VALUES (?, ?, ?, ?, ?, ?)');
+    const insertMany = db.transaction((evts: Array<{ name?: string; properties?: Record<string, unknown>; timestamp?: string }>) => {
+      for (const evt of evts) {
+        if (!evt.name) throw new Error('Each event must have a name');
+        insert.run(uuidv4(), tenantId, evt.name, JSON.stringify(evt.properties || {}), evt.timestamp || new Date().toISOString(), userId);
+      }
+    });
+
+    try {
+      insertMany(events);
+    } catch (err: unknown) {
+      if (err instanceof Error) {
+        res.status(400).json({ error: err.message });
+        return;
+      }
+      throw err;
+    }
+
+    res.status(201).json({ count: events.length });
+  });
+
+  return router;
+}
