+export function countBeamCells(grid: string[][]): number {
+    const rows = grid.length;
+    if (rows === 0) return 0;
+    const cols = grid[0].length;
+
+    let has_D = new Array(cols).fill(false);
+    let has_L = new Array(cols).fill(false);
+    let has_R = new Array(cols).fill(false);
+
+    for (let c = 0; c < cols; c++) {
+        if (grid[0][c] === 'S') {
+            has_D[c] = true;
+        }
+    }
+
+    let visitedCount = 0;
+
+    for (let r = 0; r < rows; r++) {
+        let next_D = new Array(cols).fill(false);
+        let next_L = new Array(cols).fill(false);
+        let next_R = new Array(cols).fill(false);
+
+        for (let c = 0; c < cols; c++) {
+            const incoming = has_D[c] || has_L[c] || has_R[c];
+
+            if (incoming) {
+                visitedCount++;
+                const cell = grid[r][c];
+
+                if (cell === '^') {
+                    if (c - 1 >= 0) next_L[c - 1] = true;
+                    if (c + 1 < cols) next_R[c + 1] = true;
+                } else {
+                    if (has_D[c]) {
+                        next_D[c] = true;
+                    }
+                    if (has_L[c]) {
+                        if (c - 1 >= 0) next_L[c - 1] = true;
+                    }
+                    if (has_R[c]) {
+                        if (c + 1 < cols) next_R[c + 1] = true;
+                    }
+                }
+            }
+        }
+
+        has_D = next_D;
+        has_L = next_L;
+        has_R = next_R;
+    }
+
+    return visitedCount;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+    const rows = grid.length;
+    if (rows === 0) return 0n;
+    const cols = grid[0].length;
+
+    let paths_D = new Array(cols).fill(0n);
+    let paths_L = new Array(cols).fill(0n);
+    let paths_R = new Array(cols).fill(0n);
+
+    let totalPaths = 0n;
+
+    for (let c = 0; c < cols; c++) {
+        if (grid[0][c] === 'S') {
+            paths_D[c] = 1n;
+            totalPaths += 1n;
+        }
+    }
+
+    for (let r = 0; r < rows; r++) {
+        let next_D = new Array(cols).fill(0n);
+        let next_L = new Array(cols).fill(0n);
+        let next_R = new Array(cols).fill(0n);
+
+        for (let c = 0; c < cols; c++) {
+            const cell = grid[r][c];
+            const incoming = paths_D[c] + paths_L[c] + paths_R[c];
+
+            if (incoming > 0n) {
+                if (cell === '^') {
+                    totalPaths += incoming;
+                    if (c - 1 >= 0) next_L[c - 1] += incoming;
+                    if (c + 1 < cols) next_R[c + 1] += incoming;
+                } else {
+                    if (paths_D[c] > 0n) {
+                        next_D[c] += paths_D[c];
+                    }
+                    if (paths_L[c] > 0n) {
+                        if (c - 1 >= 0) next_L[c - 1] += paths_L[c];
+                    }
+                    if (paths_R[c] > 0n) {
+                        if (c + 1 < cols) next_R[c + 1] += paths_R[c];
+                    }
+                }
+            }
+        }
+
+        paths_D = next_D;
+        paths_L = next_L;
+        paths_R = next_R;
+    }
+
+    return totalPaths;
+}
