@@ -0,0 +1,170 @@
+import { describe, it, expect, beforeEach, afterEach, vi } from 'vitest';
+import * as fs from 'node:fs';
+import * as path from 'node:path';
+import { TimeTracker } from './index.js';
+
+describe('TimeTracker', () => {
+  const testDir = path.join(__dirname, '..', 'test-data');
+  const testFile = path.join(testDir, 'time-entries.json');
+
+  beforeEach(() => {
+    if (fs.existsSync(testFile)) {
+      fs.rmSync(testFile);
+    }
+    if (fs.existsSync(testDir)) {
+      fs.rmSync(testDir, { recursive: true, force: true });
+    }
+    vi.useFakeTimers();
+  });
+
+  afterEach(() => {
+    vi.useRealTimers();
+    if (fs.existsSync(testFile)) {
+      fs.rmSync(testFile);
+    }
+    if (fs.existsSync(testDir)) {
+      fs.rmSync(testDir, { recursive: true, force: true });
+    }
+  });
+
+  it('should create file and parent directories if they do not exist', () => {
+    new TimeTracker(testFile);
+    expect(fs.existsSync(testFile)).toBe(true);
+  });
+
+  it('should throw an error when starting a timer with empty name', () => {
+    const tracker = new TimeTracker(testFile);
+    expect(() => tracker.start('')).toThrow('Task name cannot be empty');
+    expect(() => tracker.start('   ')).toThrow('Task name cannot be empty');
+  });
+
