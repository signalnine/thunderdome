+++ b/src/index.ts
@@ -0,0 +1,104 @@
+import * as fs from 'node:fs';
+import * as path from 'node:path';
+
+export interface TimeEntry {
+  task: string;
+  startTime: number;
+  endTime?: number;
+}
+
+export class TimeTracker {
+  private filePath: string;
+
+  constructor(filePath: string) {
+    this.filePath = path.resolve(filePath);
+    this.ensureFileExists();
+  }
+
+  private ensureFileExists(): void {
+    const dir = path.dirname(this.filePath);
+    if (!fs.existsSync(dir)) {
+      fs.mkdirSync(dir, { recursive: true });
+    }
+    if (!fs.existsSync(this.filePath)) {
+      fs.writeFileSync(this.filePath, JSON.stringify([], null, 2), 'utf8');
+    }
+  }
+
+  private getEntries(): TimeEntry[] {
+    try {
+      if (!fs.existsSync(this.filePath)) {
+        return [];
+      }
+      const data = fs.readFileSync(this.filePath, 'utf8');
+      return JSON.parse(data) as TimeEntry[];
+    } catch {
+      return [];
+    }
+  }
+
+  private saveEntries(entries: TimeEntry[]): void {
+    this.ensureFileExists();
+    fs.writeFileSync(this.filePath, JSON.stringify(entries, null, 2), 'utf8');
+  }
+
+  public start(taskName: string): void {
+    if (!taskName || taskName.trim() === '') {
+      throw new Error('Task name cannot be empty');
+    }
+
+    const entries = this.getEntries();
+    
+    // Stop any running timer
+    const runningEntry = entries.find((e) => e.endTime === undefined);
+    if (runningEntry) {
+      runningEntry.endTime = Date.now();
+    }
+
+    entries.push({
+      task: taskName,
+      startTime: Date.now()
+    });
+
+    this.saveEntries(entries);
+  }
+
+  public stop(): void {
+    const entries = this.getEntries();
+    const runningEntry = entries.find((e) => e.endTime === undefined);
+
+    if (!runningEntry) {
+      throw new Error('No timer is currently running');
+    }
+
+    runningEntry.endTime = Date.now();
+    this.saveEntries(entries);
+  }
+
+  public getAllEntries(): TimeEntry[] {
+    return this.getEntries();
+  }
+
+  public getEntriesByDateRange(start: number | Date, end: number | Date): TimeEntry[] {
+    const startMs = start instanceof Date ? start.getTime() : start;
+    const endMs = end instanceof Date ? end.getTime() : end;
+    const entries = this.getEntries();
+    return entries.filter((e) => e.startTime >= startMs && e.startTime <= endMs);
+  }
+
+  public summarizeTime(): Record<string, number> {
+    const entries = this.getEntries();
+    const summary: Record<string, number> = {};
+    const now = Date.now();
+
+    for (const entry of entries) {
+      const duration = (entry.endTime ?? now) - entry.startTime;
+      if (!summary[entry.task]) {
+        summary[entry.task] = 0;
+      }
+      summary[entry.task] += duration;
+    }
+
+    return summary;
+  }
+}
