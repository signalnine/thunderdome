+++ b/src/index.ts
@@ -0,0 +1,98 @@
+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number> {
+  const wireValues = { ...inputs };
+  const pendingGates = [...gates];
+
+  let progress = true;
+  while (pendingGates.length > 0 && progress) {
+    progress = false;
+    for (let i = 0; i < pendingGates.length; i++) {
+      const gate = pendingGates[i];
+      if (wireValues[gate.in1] !== undefined && wireValues[gate.in2] !== undefined) {
+        const v1 = wireValues[gate.in1];
+        const v2 = wireValues[gate.in2];
+        let outValue: number = 0;
+        
+        if (gate.op === 'AND') {
+          outValue = v1 & v2;
+        } else if (gate.op === 'OR') {
+          outValue = v1 | v2;
+        } else if (gate.op === 'XOR') {
+          outValue = v1 ^ v2;
+        }
+
+        wireValues[gate.out] = outValue;
+        pendingGates.splice(i, 1);
+        i--;
+        progress = true;
+      }
+    }
+  }
+
+  return wireValues;
+}
+
+export function findSwappedWires(gates: Gate[]): string[] {
+  const badWires = new Set<string>();
+
+  let maxZ = 'z00';
+  for (const gate of gates) {
+    if (gate.out.startsWith('z') && gate.out > maxZ) {
+      maxZ = gate.out;
+    }
+  }
+
+  for (const gate of gates) {
+    const { op, in1, in2, out } = gate;
+
+    const isInputX_Y = (in1.startsWith('x') && in2.startsWith('y')) || (in1.startsWith('y') && in2.startsWith('x'));
+    const isInput00 = isInputX_Y && (in1.endsWith('00') && in2.endsWith('00'));
+    const isOutputZ = out.startsWith('z');
+
+    // Rule 1: Output is zXX (but not maxZ), MUST be XOR
+    if (isOutputZ && out !== maxZ && op !== 'XOR') {
+      badWires.add(out);
+    }
+
+    // Rule 2: XOR gate, inputs are NOT xXX/yXX, MUST output zXX
+    if (op === 'XOR' && !isInputX_Y && !isOutputZ) {
+      badWires.add(out);
+    }
+
+    // Rule 3: XOR gate, inputs ARE xXX/yXX (but not 00), output MUST be used by another XOR
+    if (op === 'XOR' && isInputX_Y && !isInput00) {
+      let usedInXor = false;
+      for (const g of gates) {
+        if (g.op === 'XOR' && (g.in1 === out || g.in2 === out)) {
+          usedInXor = true;
+          break;
+        }
+      }
+      if (!usedInXor) {
+        badWires.add(out);
+      }
+    }
+
+    // Rule 4: AND gate, inputs are NOT x00/y00, output MUST be used by an OR
+    if (op === 'AND' && !isInput00) {
+      let usedInOr = false;
+      for (const g of gates) {
+        if (g.op === 'OR' && (g.in1 === out || g.in2 === out)) {
+          usedInOr = true;
+          break;
+        }
+      }
+      if (!usedInOr) {
+        badWires.add(out);
+      }
+    }
+  }
+
+  return Array.from(badWires).sort();
+}
