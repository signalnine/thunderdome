+import { Gate, findSwappedWires, simulate } from './index';
+
+function createAdder(bits: number): Gate[] {
+  const gates: Gate[] = [];
+  
+  // bit 0
+  gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });
+  gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });
+
+  for (let i = 1; i < bits; i++) {
+    const p = i.toString().padStart(2, '0');
+    const prevP = (i - 1).toString().padStart(2, '0');
+    const x = `x${p}`;
+    const y = `y${p}`;
+    const t = `t${p}`;
+    const a = `a${p}`;
+    const b = `b${p}`;
+    const c = `c${p}`;
+    const prevC = `c${prevP}`;
+    const z = `z${p}`;
+
+    gates.push({ op: 'XOR', in1: x, in2: y, out: t });
+    gates.push({ op: 'AND', in1: x, in2: y, out: a });
+    gates.push({ op: 'XOR', in1: t, in2: prevC, out: z });
+    gates.push({ op: 'AND', in1: t, in2: prevC, out: b });
+    
+    // last bit carry is the final z
+    if (i === bits - 1) {
+      const finalZ = `z${(i + 1).toString().padStart(2, '0')}`;
+      gates.push({ op: 'OR', in1: a, in2: b, out: finalZ });
+    } else {
+      gates.push({ op: 'OR', in1: a, in2: b, out: c });
+    }
+  }
+
+  return gates;
+}
+
+const gates = createAdder(4);
+const originalGates = JSON.parse(JSON.stringify(gates));
+
+// swap exactly 4 pairs of output wires
+const swaps = [
+  ['z01', 'a01'], // 1
+  ['c02', 'z03'], // 2
+  ['b02', 't03'], // 3
+  ['z00', 'c00']  // 4
+];
+
+const flatSwaps = swaps.flat().sort();
+
+for (const [w1, w2] of swaps) {
+  const g1 = gates.find(g => g.out === w1)!;
+  const g2 = gates.find(g => g.out === w2)!;
+  g1.out = w2;
+  g2.out = w1;
+}
+
+const result = findSwappedWires(gates);
+console.log('Expected:', flatSwaps);
+console.log('Result:', result);
+console.log('Matches:', JSON.stringify(flatSwaps) === JSON.stringify(result));
