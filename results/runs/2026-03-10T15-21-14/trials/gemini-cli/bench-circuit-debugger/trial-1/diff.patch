+import { Gate, findSwappedWires } from './index';
+
+function createAdder(bits: number): Gate[] {
+  const gates: Gate[] = [];
+  gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });
+  gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });
+  for (let i = 1; i < bits; i++) {
+    const p = i.toString().padStart(2, '0');
+    const prevP = (i - 1).toString().padStart(2, '0');
+    gates.push({ op: 'XOR', in1: `x${p}`, in2: `y${p}`, out: `t${p}` });
+    gates.push({ op: 'AND', in1: `x${p}`, in2: `y${p}`, out: `a${p}` });
+    gates.push({ op: 'XOR', in1: `t${p}`, in2: `c${prevP}`, out: `z${p}` });
+    gates.push({ op: 'AND', in1: `t${p}`, in2: `c${prevP}`, out: `b${p}` });
+    if (i === bits - 1) {
+      gates.push({ op: 'OR', in1: `a${p}`, in2: `b${p}`, out: `z${(i + 1).toString().padStart(2, '0')}` });
+    } else {
+      gates.push({ op: 'OR', in1: `a${p}`, in2: `b${p}`, out: `c${p}` });
+    }
+  }
+  return gates;
+}
+
+const gates = createAdder(4);
+const swaps = [['c00', 't01']];
+for (const [w1, w2] of swaps) {
+  const g1 = gates.find(g => g.out === w1)!;
+  const g2 = gates.find(g => g.out === w2)!;
+  g1.out = w2;
+  g2.out = w1;
+}
+
+const result = findSwappedWires(gates);
+console.log('Result:', result);
