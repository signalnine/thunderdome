@@ -0,0 +1,19 @@
+import Database from 'better-sqlite3';
+const db = new Database(':memory:');
+db.exec('CREATE VIRTUAL TABLE t USING fts5(x); INSERT INTO t VALUES("test&test"); INSERT INTO t VALUES("hello world"); INSERT INTO t VALUES("a/b");');
+const queries = ['"exact phrase"', 'test&test', 'hello world', "it's", '<script>', 'foo+bar', 'a/b'];
+for (const q of queries) {
+  try {
+    const res = db.prepare('SELECT * FROM t WHERE t MATCH ?').all(q);
+    console.log(`Query ${q}: Success, matches: ${res.length}`);
+  } catch (e) {
+    console.log(`Query ${q}: Error: ${e.message}`);
+    const safeQ = '"' + q.replace(/"/g, '""') + '"';
+    try {
+      const res2 = db.prepare('SELECT * FROM t WHERE t MATCH ?').all(safeQ);
+      console.log(`  Fallback ${safeQ}: Success, matches: ${res2.length}`);
+    } catch (e2) {
+      console.log(`  Fallback Error: ${e2.message}`);
+    }
+  }
+}
