tId)).toBe(48);\n\n    // 6. Subscribe user and create order\n    notifications.subscribe('user1');\n    const orderId = orders.createOrder('user1', cartId, total.total);\n\n    // 7. Process payment\n    const payResult = await payment.processPayment(orderId, total.total);\n    expect(payResult.status).toBe(PaymentStatus.SUCCESS);\n\n    // 8. Update order status\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    orders.updateStatus(orderId, OrderStatus.SHIPPED);\n    orders.updateStatus(orderId, OrderStatus.DELIVERED);\n\n    await new Promise(r => setTimeout(r, 10));\n\n    // 9. Verify notifications\n    const userNotifs = notifications.getNotifications('user1');\n    expect(userNotifs.length).toBeGreaterThanOrEqual(3); // created, payment, status changes\n\n    // 10. Verify analytics\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(1);\n    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBe(1);\n    expect(analytics.getRevenue()).toBe(total.total);\n    expect(analytics.getConversionRate()).toBeGreaterThan(0);\n\n    const topProducts = analytics.getTopProducts(1);\n    expect(topProducts).toHaveLength(1);\n    expect(topProducts[0].productId).toBe(productId);\n    expect(topProducts[0].count).toBe(2);\n  });\n});\n","structuredPatch":[],"originalFile":null}}
