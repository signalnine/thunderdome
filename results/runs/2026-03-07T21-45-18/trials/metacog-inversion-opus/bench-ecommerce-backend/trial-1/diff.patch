+// ─── Integration ───────────────────────────────────────────
+describe('Integration: Full E-Commerce Flow', () => {
+  it('runs through a complete purchase flow', async () => {
+    const catalog = createCatalogService(bus);
+    const inventory = createInventoryService(bus);
+    const cartService = createCartService(bus);
+    const pricing = createPricingService(bus);
+    const orders = createOrderService(bus);
+    const payment = createPaymentService(bus);
+    const notifications = createNotificationService(bus);
+    const analytics = createAnalyticsService(bus);
+
+    // 1. Setup products
+    const productId = catalog.createProduct('Laptop', 999, 'electronics');
+    await new Promise(r => setTimeout(r, 10));
+    inventory.setStock(productId, 50);
+    inventory.setLowStockThreshold(productId, 5);
+
+    // 2. Verify pricing tracks the product
+    expect(pricing.getPrice(productId)).toBe(999);
+
+    // 3. Create cart and add items
+    const cartId = cartService.createCart('user1');
+    cartService.addItem(cartId, productId, 2);
+
+    const cartData = cartService.getCart(cartId)!;
+    expect(cartData.items).toHaveLength(1);
+
+    // 4. Calculate pricing
+    const items = cartData.items.map(i => ({
+      productId: i.productId,
+      quantity: i.quantity,
+      price: pricing.getPrice(i.productId),
+    }));
+    pricing.addDiscountCode('WELCOME', 5);
+    const total = pricing.calculateTotal(items, 'WELCOME');
+    // subtotal = 999*2 = 1998, discount = 99.9, discounted = 1898.1, tax = 189.81, total = 2087.91
+    expect(total.subtotal).toBe(1998);
+    expect(total.discount).toBe(99.9);
+
+    // 5. Reserve inventory
+    expect(inventory.reserve(productId, 2)).toBe(true);
+    expect(inventory.getStock(productId)).toBe(48);
+
+    // 6. Subscribe user and create order
+    notifications.subscribe('user1');
+    const orderId = orders.createOrder('user1', cartId, total.total);
+
+    // 7. Process payment
+    const payResult = await payment.processPayment(orderId, total.total);
+    expect(payResult.status).toBe(PaymentStatus.SUCCESS);
+
+    // 8. Update order status
+    orders.updateStatus(orderId, OrderStatus.CONFIRMED);
+    orders.updateStatus(orderId, OrderStatus.SHIPPED);
+    orders.updateStatus(orderId, OrderStatus.DELIVERED);
+
+    await new Promise(r => setTimeout(r, 10));
+
+    // 9. Verify notifications
+    const userNotifs = notifications.getNotifications('user1');
+    expect(userNotifs.length).toBeGreaterThanOrEqual(3); // created, payment, status changes
+
+    // 10. Verify analytics
+    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(1);
+    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBe(1);
+    expect(analytics.getRevenue()).toBe(total.total);
+    expect(analytics.getConversionRate()).toBeGreaterThan(0);
+
+    const topProducts = analytics.getTopProducts(1);
+    expect(topProducts).toHaveLength(1);
+    expect(topProducts[0].productId).toBe(productId);
+    expect(topProducts[0].count).toBe(2);
+  });
+});
