+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01FsjDEGtLfP6E1ZZ6FaS2bP","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01GsCKDerVrCABsnh6ovSwg7","name":"Write","input":{"file_path":"/workspace/tests/services.test.ts","content":"import { describe, it, expect, beforeEach } from 'vitest';\nimport { EventBus } from '../src/bus.js';\nimport {\n  createCatalogService,\n  createInventoryService,\n  createCartService,\n  createPricingService,\n  createOrderService,\n  createPaymentService,\n  createNotificationService,\n  createAnalyticsService,\n} from '../src/index.js';\nimport { OrderStatus, PaymentStatus, Events } from '../src/types.js';\n\nlet bus: EventBus;\n\nbeforeEach(() => {\n  bus = new EventBus();\n});\n\n// ─── Catalog ───────────────────────────────────────────────\ndescribe('CatalogService', () => {\n  it('creates a product and returns its id', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    expect(id).toBeDefined();\n    expect(typeof id).toBe('string');\n  });\n\n  it('retrieves a product by id', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    const product = catalog.getProduct(id);\n    expect(product).toEqual({ id, name: 'Widget', price: 9.99, category: 'gadgets' });\n  });\n\n  it('returns null for unknown product', () => {\n    const catalog = createCatalogService(bus);\n    expect(catalog.getProduct('nonexistent')).toBeNull();\n  });\n\n  it('lists products, optionally filtered by category', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('A', 1, 'cat1');\n    catalog.createProduct('B', 2, 'cat2');\n    catalog.createProduct('C', 3, 'cat1');\n\n    expect(catalog.listProducts()).toHaveLength(3);\n    expect(catalog.listProducts('cat1')).toHaveLength(2);\n    expect(catalog.listProducts('cat2')).toHaveLength(1);\n  });\n\n  it('searches products by name or category', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('Blue Widget', 5, 'electronics');\n    catalog.createProduct('Red Gizmo', 10, 'electronics');\n    catalog.createProduct('Green Widget', 15, 'toys');\n\n    expect(catalog.searchProducts('widget')).toHaveLength(2);\n    expect(catalog.searchProducts('electronics')).toHaveLength(2);\n    expect(catalog.searchProducts('gizmo')).toHaveLength(1);\n  });\n\n  it('updates a product', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    catalog.updateProduct(id, { price: 19.99, name: 'Super Widget' });\n    const product = catalog.getProduct(id);\n    expect(product!.price).toBe(19.99);\n    expect(product!.name).toBe('Super Widget');\n    expect(product!.category).toBe('gadgets');\n  });\n\n  it('removes a product', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    expect(catalog.removeProduct(id)).toBe(true);\n    expect(catalog.getProduct(id)).toBeNull();\n    expect(catalog.removeProduct(id)).toBe(false);\n  });\n\n  it('emits product:created event', async () => {\n    const catalog = createCatalogService(bus);\n    const events: unknown[] = [];\n    bus.on(Events.PRODUCT_CREATED, (payload) => { events.push(payload); });\n    catalog.createProduct('Widget', 9.99, 'gadgets');\n    // wait for async emit\n    await new Promise(r => setTimeout(r, 10));\n    expect(events).toHaveLength(1);\n  });\n});\n\n// ─── Inventory ─────────────────────────────────────────────\ndescribe('InventoryService', () => {\n  it('sets and gets stock', () => {\n    const inv = createInventoryService(bus);\n    inv.setStock('p1', 100);\n    expect(inv.getStock('p1')).toBe(100);\n  });\n\n  it('reserves stock', () => {\n    const inv = createInventoryService(bus);\n    inv.setStock('p1', 10);\n    expect(inv.reserve('p1', 5)).toBe(true);\n    expect(inv.getStock('p1')).toBe(5);\n  });\n\n  it('fails to reserve when insufficient stock', () => {\n    const inv = createInventoryService(bus);\n    inv.setStock('p1', 3);\n    expect(inv.reserve('p1', 5)).toBe(false);\n    expect(inv.getStock('p1')).toBe(3);\n  });\n\n  it('releases reserved stock', () => {\n    const inv = createInventoryService(bus);\n    inv.setStock('p1', 10);\n    inv.reserve('p1', 5);\n    inv.release('p1', 3);\n    expect(inv.getStock('p1')).toBe(8);\n  });\n\n  it('emits low stock alert when threshold is breached', async () => {\n    const inv = createInventoryService(bus);\n    const alerts: unknown[] = [];\n    bus.on(Events.LOW_STOCK_ALERT, (payload) => { alerts.push(payload); });\n    inv.setStock('p1', 10);\n    inv.setLowStockThreshold('p1', 5);\n    inv.reserve('p1', 6);\n    await new Promise(r => setTimeout(r, 10));\n    expect(alerts.length).toBeGreaterThanOrEqual(1);\n  });\n\n  it('returns 0 for unknown product stock', () => {\n    const inv = createInventoryService(bus);\n    expect(inv.getStock('unknown')).toBe(0);\n  });\n});\n\n// ─── Cart ──────────────────────────────────────────────────\ndescribe('CartService', () => {\n  it('creates a cart and retrieves it', () => {\n    const cart = createCartService(bus);\n    const cartId = cart.createCart('user1');\n    const c = cart.getCart(cartId);\n    expect(c).not.toBeNull();\n    expect(c!.userId).toBe('user1');\n    expect(c!.items).toHaveLength(0);\n  });\n\n  it('adds items to cart', () => {\n    const cart = createCartService(bus);\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 2);\n    const c = cart.getCart(cartId);\n    expect(c!.items).toHaveLength(1);\n    expect(c!.items[0]).toEqual({ productId: 'p1', quantity: 2 });\n  });\n\n  it('consolidates duplicate product additions', () => {\n    const cart = createCartService(bus);\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 2);\n    cart.addItem(cartId, 'p1', 3);\n    const c = cart.getCart(cartId);\n    expect(c!.items).toHaveLength(1);\n    expect(c!.items[0].quantity).toBe(5);\n  });\n\n  it('removes items from cart', () => {\n    const cart = createCartService(bus);\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 2);\n    cart.addItem(cartId, 'p2', 1);\n    cart.removeItem(cartId, 'p1');\n    const c = cart.getCart(cartId);\n    expect(c!.items).toHaveLength(1);\n    expect(c!.items[0].productId).toBe('p2');\n  });\n\n  it('clears cart', () => {\n    const cart = createCartService(bus);\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 2);\n    cart.clearCart(cartId);\n    expect(cart.getCart(cartId)!.items).toHaveLength(0);\n  });\n\n  it('updates item quantity', () => {\n    const cart = createCartService(bus);\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 2);\n    cart.updateQuantity(cartId, 'p1', 10);\n    expect(cart.getCart(cartId)!.items[0].quantity).toBe(10);\n  });\n\n  it('returns null for unknown cart', () => {\n    const cart = createCartService(bus);\n    expect(cart.getCart('nonexistent')).toBeNull();\n  });\n});\n\n// ─── Pricing ───────────────────────────────────────────────\ndescribe('PricingService', () => {\n  it('calculates total with 10% tax', () => {\n    const pricing = createPricingService(bus);\n    const result = pricing.calculateTotal([\n      { productId: 'p1', quantity: 2, price: 10 },\n    ]);\n    expect(result.subtotal).toBe(20);\n    expect(result.discount).toBe(0);\n    expect(result.tax).toBe(2);\n    expect(result.total).toBe(22);\n  });\n\n  it('applies discount codes before tax', () => {\n    const pricing = createPricingService(bus);\n    pricing.addDiscountCode('SAVE10', 10);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'SAVE10'\n    );\n    // subtotal=100, discount=10, discountedSubtotal=90, tax=9, total=99\n    expect(result.subtotal).toBe(100);\n    expect(result.discount).toBe(10);\n    expect(result.tax).toBe(9);\n    expect(result.total).toBe(99);\n  });\n\n  it('ignores invalid discount codes', () => {\n    const pricing = createPricingService(bus);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'INVALID'\n    );\n    expect(result.discount).toBe(0);\n    expect(result.total).toBe(110);\n  });\n\n  it('tracks prices from product:created events', async () => {\n    const pricing = createPricingService(bus);\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 25, 'gadgets');\n    // wait for event propagation\n    await new Promise(r => setTimeout(r, 10));\n    expect(pricing.getPrice(id)).toBe(25);\n  });\n\n  it('returns 0 for unknown product price', () => {\n    const pricing = createPricingService(bus);\n    expect(pricing.getPrice('unknown')).toBe(0);\n  });\n});\n\n// ─── Orders ────────────────────────────────────────────────\ndescribe('OrderService', () => {\n  it('creates an order with PENDING status', () => {\n    const orders = createOrderService(bus);\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    const order = orders.getOrder(orderId);\n    expect(order).not.toBeNull();\n    expect(order!.status).toBe(OrderStatus.PENDING);\n    expect(order!.total).toBe(100);\n  });\n\n  it('updates order status and includes previousStatus in event', async () => {\n    const orders = createOrderService(bus);\n    const events: unknown[] = [];\n    bus.on(Events.ORDER_STATUS_CHANGED, (payload) => { events.push(payload); });\n\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    await new Promise(r => setTimeout(r, 10));\n\n    expect(orders.getOrder(orderId)!.status).toBe(OrderStatus.CONFIRMED);\n    expect(events).toHaveLength(1);\n    const evt = events[0] as { previousStatus: string; status: string };\n    expect(evt.previousStatus).toBe(OrderStatus.PENDING);\n    expect(evt.status).toBe(OrderStatus.CONFIRMED);\n  });\n\n  it('lists orders for a user', () => {\n    const orders = createOrderService(bus);\n    orders.createOrder('user1', 'c1', 50);\n    orders.createOrder('user1', 'c2', 75);\n    orders.createOrder('user2', 'c3', 100);\n    expect(orders.listOrders('user1')).toHaveLength(2);\n    expect(orders.listOrders('user2')).toHaveLength(1);\n  });\n\n  it('returns null for unknown order', () => {\n    const orders = createOrderService(bus);\n    expect(orders.getOrder('nonexistent')).toBeNull();\n  });\n\n  it('emits order:created event', async () => {\n    const orders = createOrderService(bus);\n    const events: unknown[] = [];\n    bus.on(Events.ORDER_CREATED, (payload) => { events.push(payload); });\n    orders.createOrder('user1', 'cart1', 100);\n    await new Promise(r => setTimeout(r, 10));\n    expect(events).toHaveLength(1);\n  });\n});\n\n// ─── Payment ───────────────────────────────────────────────\ndescribe('PaymentService', () => {\n  it('processes a successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.SUCCESS);\n    expect(result.transactionId).toBeDefined();\n  });\n\n  it('simulates payment failure', async () => {\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.FAILED);\n    expect(result.error).toBeDefined();\n  });\n\n  it('simulates payment timeout', async () => {\n    const payment = createPaymentService(bus, { simulateTimeout: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.TIMEOUT);\n    expect(result.error).toBeDefined();\n  });\n\n  it('refunds a successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    const refunded = await payment.refund(result.transactionId!);\n    expect(refunded).toBe(true);\n  });\n\n  it('cannot refund a non-existent transaction', async () => {\n    const payment = createPaymentService(bus);\n    const refunded = await payment.refund('nonexistent');\n    expect(refunded).toBe(false);\n  });\n\n  it('emits payment:processed event', async () => {\n    const events: unknown[] = [];\n    bus.on(Events.PAYMENT_PROCESSED, (payload) => { events.push(payload); });\n    const payment = createPaymentService(bus);\n    await payment.processPayment('order1', 100);\n    expect(events).toHaveLength(1);\n  });\n});\n\n// ─── Notifications ─────────────────────────────────────────\ndescribe('NotificationService', () => {\n  it('sends notifications for order events to subscribed users', async () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n\n    notifications.subscribe('user1');\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    // wait for event propagation\n    await new Promise(r => setTimeout(r, 10));\n\n    const userNotifications = notifications.getNotifications('user1');\n    expect(userNotifications.length).toBeGreaterThanOrEqual(1);\n    expect(userNotifications.some(n => n.type === 'order_created')).toBe(true);\n  });\n\n  it('sends notification on order status change', async () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n\n    notifications.subscribe('user1');\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    await new Promise(r => setTimeout(r, 10));\n\n    const userNotifications = notifications.getNotifications('user1');\n    expect(userNotifications.some(n => n.type === 'order_status')).toBe(true);\n  });\n\n  it('sends notification on payment', async () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n\n    notifications.subscribe('user1');\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    await payment.processPayment(orderId, 100);\n    await new Promise(r => setTimeout(r, 10));\n\n    const userNotifications = notifications.getNotifications('user1');\n    expect(userNotifications.some(n => n.type === 'payment')).toBe(true);\n  });\n\n  it('does not notify unsubscribed users', async () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n\n    orders.createOrder('user1', 'cart1', 100);\n    await new Promise(r => setTimeout(r, 10));\n\n    expect(notifications.getNotifications('user1')).toHaveLength(0);\n  });\n\n  it('returns empty array for user with no notifications', () => {\n    const notifications = createNotificationService(bus);\n    expect(notifications.getNotifications('user1')).toHaveLength(0);\n  });\n});\n\n// ─── Analytics ─────────────────────────────────────────────\ndescribe('AnalyticsService', () => {\n  it('counts events by type', async () => {\n    const analytics = createAnalyticsService(bus);\n    const catalog = createCatalogService(bus);\n\n    catalog.createProduct('A', 10, 'cat1');\n    catalog.createProduct('B', 20, 'cat1');\n    await new Promise(r => setTimeout(r, 10));\n\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n  });\n\n  it('tracks revenue from successful payments', async () => {\n    const analytics = createAnalyticsService(bus);\n    const cart = createCartService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 2);\n    const orderId = orders.createOrder('user1', cartId, 100);\n    await payment.processPayment(orderId, 100);\n\n    expect(analytics.getRevenue()).toBe(100);\n  });\n\n  it('does not count failed payments as revenue', async () => {\n    const analytics = createAnalyticsService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus, { simulateFailure: true });\n\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    await payment.processPayment(orderId, 100);\n\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  it('calculates conversion rate', async () => {\n    const analytics = createAnalyticsService(bus);\n    const cart = createCartService(bus);\n    const orders = createOrderService(bus);\n\n    const c1 = cart.createCart('user1');\n    cart.addItem(c1, 'p1', 1);\n    const c2 = cart.createCart('user2');\n    cart.addItem(c2, 'p2', 1);\n    const c3 = cart.createCart('user3');\n    cart.addItem(c3, 'p3', 1);\n\n    // Only 1 order from 3 carts\n    orders.createOrder('user1', c1, 50);\n    await new Promise(r => setTimeout(r, 10));\n\n    expect(analytics.getConversionRate()).toBeCloseTo(1 / 3);\n  });\n\n  it('returns 0 conversion rate with no carts', () => {\n    const analytics = createAnalyticsService(bus);\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n\n  it('tracks top products by order quantity', async () => {\n    const analytics = createAnalyticsService(bus);\n    const cart = createCartService(bus);\n    const orders = createOrderService(bus);\n\n    const c1 = cart.createCart('user1');\n    cart.addItem(c1, 'p1', 5);\n    cart.addItem(c1, 'p2', 2);\n    orders.createOrder('user1', c1, 70);\n\n    const c2 = cart.createCart('user2');\n    cart.addItem(c2, 'p2', 10);\n    orders.createOrder('user2', c2, 200);\n\n    await new Promise(r => setTimeout(r, 10));\n\n    const top = analytics.getTopProducts(2);\n    expect(top).toHaveLength(2);\n    expect(top[0].productId).toBe('p2');\n    expect(top[0].count).toBe(12);\n    expect(top[1].productId).toBe('p1');\n    expect(top[1].count).toBe(5);\n  });\n});\n\n// ─── Integration ───────────────────────────────────────────\ndescribe('Integration: Full E-Commerce Flow', () => {\n  it('runs through a complete purchase flow', async () => {\n    const catalog = createCatalogService(bus);\n    const inventory = createInventoryService(bus);\n    const cartService = createCartService(bus);\n    const pricing = createPricingService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    const notifications = createNotificationService(bus);\n    const analytics = createAnalyticsService(bus);\n\n    // 1. Setup products\n    const productId = catalog.createProduct('Laptop', 999, 'electronics');\n    await new Promise(r => setTimeout(r, 10));\n    inventory.setStock(productId, 50);\n    inventory.setLowStockThreshold(productId, 5);\n\n    // 2. Verify pricing tracks the product\n    expect(pricing.getPrice(productId)).toBe(999);\n\n    // 3. Create cart and add items\n    const cartId = cartService.createCart('user1');\n    cartService.addItem(cartId, productId, 2);\n\n    const cartData = cartService.getCart(cartId)!;\n    expect(cartData.items).toHaveLength(1);\n\n    // 4. Calculate pricing\n    const items = cartData.items.map(i => ({\n      productId: i.productId,\n      quantity: i.quantity,\n      price: pricing.getPrice(i.productId),\n    }));\n    pricing.addDiscountCode('WELCOME', 5);\n    const total = pricing.calculateTotal(items, 'WELCOME');\n    // subtotal = 999*2 = 1998, discount = 99.9, discounted = 1898.1, tax = 189.81, total = 2087.91\n    expect(total.subtotal).toBe(1998);\n    expect(total.discount).toBe(99.9);\n\n    // 5. Reserve inventory\n    expect(inventory.reserve(productId, 2)).toBe(true);\n    expect(inventory.getStock(productId)).toBe(48);\n\n    // 6. Subscribe user and create order\n    notifications.subscribe('user1');\n    const orderId = orders.createOrder('user1', cartId, total.total);\n\n    // 7. Process payment\n    const payResult = await payment.processPayment(orderId, total.total);\n    expect(payResult.status).toBe(PaymentStatus.SUCCESS);\n\n    // 8. Update order status\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    orders.updateStatus(orderId, OrderStatus.SHIPPED);\n    orders.updateStatus(orderId, OrderStatus.DELIVERED);\n\n    await new Promise(r => setTimeout(r, 10));\n\n    // 9. Verify notifications\n    const userNotifs = notifications.getNotifications('user1');\n    expect(userNotifs.length).toBeGreaterThanOrEqual(3); // created, payment, status changes\n\n    // 10. Verify analytics\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(1);\n    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBe(1);\n    expect(analytics.getRevenue()).toBe(total.total);\n    expect(analytics.getConversionRate()).toBeGreaterThan(0);\n\n    const topProducts = analytics.getTopProducts(1);\n    expect(topProducts).toHaveLength(1);\n    expect(topProducts[0].productId).toBe(productId);\n    expect(topProducts[0].count).toBe(2);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":252,"cache_read_input_tokens":30026,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":252},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"57da012e-5252-47de-93f0-6908592b393d","uuid":"f322911f-bf29-4899-be1d-70e528741bb7"}
+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GsCKDerVrCABsnh6ovSwg7","type":"tool_result","content":"File created successfully at: /workspace/tests/services.test.ts"}]},"parent_tool_use_id":null,"session_id":"57da012e-5252-47de-93f0-6908592b393d","uuid":"ccf8dca8-c0cd-4f36-b449-eabeb5f7fed9","tool_use_result":{"type":"create","filePath":"/workspace/tests/services.test.ts","content":"import { describe, it, expect, beforeEach } from 'vitest';\nimport { EventBus } from '../src/bus.js';\nimport {\n  createCatalogService,\n  createInventoryService,\n  createCartService,\n  createPricingService,\n  createOrderService,\n  createPaymentService,\n  createNotificationService,\n  createAnalyticsService,\n} from '../src/index.js';\nimport { OrderStatus, PaymentStatus, Events } from '../src/types.js';\n\nlet bus: EventBus;\n\nbeforeEach(() => {\n  bus = new EventBus();\n});\n\n// ─── Catalog ───────────────────────────────────────────────\ndescribe('CatalogService', () => {\n  it('creates a product and returns its id', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    expect(id).toBeDefined();\n    expect(typeof id).toBe('string');\n  });\n\n  it('retrieves a product by id', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    const product = catalog.getProduct(id);\n    expect(product).toEqual({ id, name: 'Widget', price: 9.99, category: 'gadgets' });\n  });\n\n  it('returns null for unknown product', () => {\n    const catalog = createCatalogService(bus);\n    expect(catalog.getProduct('nonexistent')).toBeNull();\n  });\n\n  it('lists products, optionally filtered by category', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('A', 1, 'cat1');\n    catalog.createProduct('B', 2, 'cat2');\n    catalog.createProduct('C', 3, 'cat1');\n\n    expect(catalog.listProducts()).toHaveLength(3);\n    expect(catalog.listProducts('cat1')).toHaveLength(2);\n    expect(catalog.listProducts('cat2')).toHaveLength(1);\n  });\n\n  it('searches products by name or category', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('Blue Widget', 5, 'electronics');\n    catalog.createProduct('Red Gizmo', 10, 'electronics');\n    catalog.createProduct('Green Widget', 15, 'toys');\n\n    expect(catalog.searchProducts('widget')).toHaveLength(2);\n    expect(catalog.searchProducts('electronics')).toHaveLength(2);\n    expect(catalog.searchProducts('gizmo')).toHaveLength(1);\n  });\n\n  it('updates a product', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    catalog.updateProduct(id, { price: 19.99, name: 'Super Widget' });\n    const product = catalog.getProduct(id);\n    expect(product!.price).toBe(19.99);\n    expect(product!.name).toBe('Super Widget');\n    expect(product!.category).toBe('gadgets');\n  });\n\n  it('removes a product', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    expect(catalog.removeProduct(id)).toBe(true);\n    expect(catalog.getProduct(id)).toBeNull();\n    expect(catalog.removeProduct(id)).toBe(false);\n  });\n\n  it('emits product:created event', async () => {\n    const catalog = createCatalogService(bus);\n    const events: unknown[] = [];\n    bus.on(Events.PRODUCT_CREATED, (payload) => { events.push(payload); });\n    catalog.createProduct('Widget', 9.99, 'gadgets');\n    // wait for async emit\n    await new Promise(r => setTimeout(r, 10));\n    expect(events).toHaveLength(1);\n  });\n});\n\n// ─── Inventory ─────────────────────────────────────────────\ndescribe('InventoryService', () => {\n  it('sets and gets stock', () => {\n    const inv = createInventoryService(bus);\n    inv.setStock('p1', 100);\n    expect(inv.getStock('p1')).toBe(100);\n  });\n\n  it('reserves stock', () => {\n    const inv = createInventoryService(bus);\n    inv.setStock('p1', 10);\n    expect(inv.reserve('p1', 5)).toBe(true);\n    expect(inv.getStock('p1')).toBe(5);\n  });\n\n  it('fails to reserve when insufficient stock', () => {\n    const inv = createInventoryService(bus);\n    inv.setStock('p1', 3);\n    expect(inv.reserve('p1', 5)).toBe(false);\n    expect(inv.getStock('p1')).toBe(3);\n  });\n\n  it('releases reserved stock', () => {\n    const inv = createInventoryService(bus);\n    inv.setStock('p1', 10);\n    inv.reserve('p1', 5);\n    inv.release('p1', 3);\n    expect(inv.getStock('p1')).toBe(8);\n  });\n\n  it('emits low stock alert when threshold is breached', async () => {\n    const inv = createInventoryService(bus);\n    const alerts: unknown[] = [];\n    bus.on(Events.LOW_STOCK_ALERT, (payload) => { alerts.push(payload); });\n    inv.setStock('p1', 10);\n    inv.setLowStockThreshold('p1', 5);\n    inv.reserve('p1', 6);\n    await new Promise(r => setTimeout(r, 10));\n    expect(alerts.length).toBeGreaterThanOrEqual(1);\n  });\n\n  it('returns 0 for unknown product stock', () => {\n    const inv = createInventoryService(bus);\n    expect(inv.getStock('unknown')).toBe(0);\n  });\n});\n\n// ─── Cart ──────────────────────────────────────────────────\ndescribe('CartService', () => {\n  it('creates a cart and retrieves it', () => {\n    const cart = createCartService(bus);\n    const cartId = cart.createCart('user1');\n    const c = cart.getCart(cartId);\n    expect(c).not.toBeNull();\n    expect(c!.userId).toBe('user1');\n    expect(c!.items).toHaveLength(0);\n  });\n\n  it('adds items to cart', () => {\n    const cart = createCartService(bus);\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 2);\n    const c = cart.getCart(cartId);\n    expect(c!.items).toHaveLength(1);\n    expect(c!.items[0]).toEqual({ productId: 'p1', quantity: 2 });\n  });\n\n  it('consolidates duplicate product additions', () => {\n    const cart = createCartService(bus);\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 2);\n    cart.addItem(cartId, 'p1', 3);\n    const c = cart.getCart(cartId);\n    expect(c!.items).toHaveLength(1);\n    expect(c!.items[0].quantity).toBe(5);\n  });\n\n  it('removes items from cart', () => {\n    const cart = createCartService(bus);\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 2);\n    cart.addItem(cartId, 'p2', 1);\n    cart.removeItem(cartId, 'p1');\n    const c = cart.getCart(cartId);\n    expect(c!.items).toHaveLength(1);\n    expect(c!.items[0].productId).toBe('p2');\n  });\n\n  it('clears cart', () => {\n    const cart = createCartService(bus);\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 2);\n    cart.clearCart(cartId);\n    expect(cart.getCart(cartId)!.items).toHaveLength(0);\n  });\n\n  it('updates item quantity', () => {\n    const cart = createCartService(bus);\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 2);\n    cart.updateQuantity(cartId, 'p1', 10);\n    expect(cart.getCart(cartId)!.items[0].quantity).toBe(10);\n  });\n\n  it('returns null for unknown cart', () => {\n    const cart = createCartService(bus);\n    expect(cart.getCart('nonexistent')).toBeNull();\n  });\n});\n\n// ─── Pricing ───────────────────────────────────────────────\ndescribe('PricingService', () => {\n  it('calculates total with 10% tax', () => {\n    const pricing = createPricingService(bus);\n    const result = pricing.calculateTotal([\n      { productId: 'p1', quantity: 2, price: 10 },\n    ]);\n    expect(result.subtotal).toBe(20);\n    expect(result.discount).toBe(0);\n    expect(result.tax).toBe(2);\n    expect(result.total).toBe(22);\n  });\n\n  it('applies discount codes before tax', () => {\n    const pricing = createPricingService(bus);\n    pricing.addDiscountCode('SAVE10', 10);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'SAVE10'\n    );\n    // subtotal=100, discount=10, discountedSubtotal=90, tax=9, total=99\n    expect(result.subtotal).toBe(100);\n    expect(result.discount).toBe(10);\n    expect(result.tax).toBe(9);\n    expect(result.total).toBe(99);\n  });\n\n  it('ignores invalid discount codes', () => {\n    const pricing = createPricingService(bus);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'INVALID'\n    );\n    expect(result.discount).toBe(0);\n    expect(result.total).toBe(110);\n  });\n\n  it('tracks prices from product:created events', async () => {\n    const pricing = createPricingService(bus);\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 25, 'gadgets');\n    // wait for event propagation\n    await new Promise(r => setTimeout(r, 10));\n    expect(pricing.getPrice(id)).toBe(25);\n  });\n\n  it('returns 0 for unknown product price', () => {\n    const pricing = createPricingService(bus);\n    expect(pricing.getPrice('unknown')).toBe(0);\n  });\n});\n\n// ─── Orders ────────────────────────────────────────────────\ndescribe('OrderService', () => {\n  it('creates an order with PENDING status', () => {\n    const orders = createOrderService(bus);\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    const order = orders.getOrder(orderId);\n    expect(order).not.toBeNull();\n    expect(order!.status).toBe(OrderStatus.PENDING);\n    expect(order!.total).toBe(100);\n  });\n\n  it('updates order status and includes previousStatus in event', async () => {\n    const orders = createOrderService(bus);\n    const events: unknown[] = [];\n    bus.on(Events.ORDER_STATUS_CHANGED, (payload) => { events.push(payload); });\n\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    await new Promise(r => setTimeout(r, 10));\n\n    expect(orders.getOrder(orderId)!.status).toBe(OrderStatus.CONFIRMED);\n    expect(events).toHaveLength(1);\n    const evt = events[0] as { previousStatus: string; status: string };\n    expect(evt.previousStatus).toBe(OrderStatus.PENDING);\n    expect(evt.status).toBe(OrderStatus.CONFIRMED);\n  });\n\n  it('lists orders for a user', () => {\n    const orders = createOrderService(bus);\n    orders.createOrder('user1', 'c1', 50);\n    orders.createOrder('user1', 'c2', 75);\n    orders.createOrder('user2', 'c3', 100);\n    expect(orders.listOrders('user1')).toHaveLength(2);\n    expect(orders.listOrders('user2')).toHaveLength(1);\n  });\n\n  it('returns null for unknown order', () => {\n    const orders = createOrderService(bus);\n    expect(orders.getOrder('nonexistent')).toBeNull();\n  });\n\n  it('emits order:created event', async () => {\n    const orders = createOrderService(bus);\n    const events: unknown[] = [];\n    bus.on(Events.ORDER_CREATED, (payload) => { events.push(payload); });\n    orders.createOrder('user1', 'cart1', 100);\n    await new Promise(r => setTimeout(r, 10));\n    expect(events).toHaveLength(1);\n  });\n});\n\n// ─── Payment ───────────────────────────────────────────────\ndescribe('PaymentService', () => {\n  it('processes a successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.SUCCESS);\n    expect(result.transactionId).toBeDefined();\n  });\n\n  it('simulates payment failure', async () => {\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.FAILED);\n    expect(result.error).toBeDefined();\n  });\n\n  it('simulates payment timeout', async () => {\n    const payment = createPaymentService(bus, { simulateTimeout: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.TIMEOUT);\n    expect(result.error).toBeDefined();\n  });\n\n  it('refunds a successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    const refunded = await payment.refund(result.transactionId!);\n    expect(refunded).toBe(true);\n  });\n\n  it('cannot refund a non-existent transaction', async () => {\n    const payment = createPaymentService(bus);\n    const refunded = await payment.refund('nonexistent');\n    expect(refunded).toBe(false);\n  });\n\n  it('emits payment:processed event', async () => {\n    const events: unknown[] = [];\n    bus.on(Events.PAYMENT_PROCESSED, (payload) => { events.push(payload); });\n    const payment = createPaymentService(bus);\n    await payment.processPayment('order1', 100);\n    expect(events).toHaveLength(1);\n  });\n});\n\n// ─── Notifications ─────────────────────────────────────────\ndescribe('NotificationService', () => {\n  it('sends notifications for order events to subscribed users', async () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n\n    notifications.subscribe('user1');\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    // wait for event propagation\n    await new Promise(r => setTimeout(r, 10));\n\n    const userNotifications = notifications.getNotifications('user1');\n    expect(userNotifications.length).toBeGreaterThanOrEqual(1);\n    expect(userNotifications.some(n => n.type === 'order_created')).toBe(true);\n  });\n\n  it('sends notification on order status change', async () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n\n    notifications.subscribe('user1');\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    await new Promise(r => setTimeout(r, 10));\n\n    const userNotifications = notifications.getNotifications('user1');\n    expect(userNotifications.some(n => n.type === 'order_status')).toBe(true);\n  });\n\n  it('sends notification on payment', async () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n\n    notifications.subscribe('user1');\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    await payment.processPayment(orderId, 100);\n    await new Promise(r => setTimeout(r, 10));\n\n    const userNotifications = notifications.getNotifications('user1');\n    expect(userNotifications.some(n => n.type === 'payment')).toBe(true);\n  });\n\n  it('does not notify unsubscribed users', async () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n\n    orders.createOrder('user1', 'cart1', 100);\n    await new Promise(r => setTimeout(r, 10));\n\n    expect(notifications.getNotifications('user1')).toHaveLength(0);\n  });\n\n  it('returns empty array for user with no notifications', () => {\n    const notifications = createNotificationService(bus);\n    expect(notifications.getNotifications('user1')).toHaveLength(0);\n  });\n});\n\n// ─── Analytics ─────────────────────────────────────────────\ndescribe('AnalyticsService', () => {\n  it('counts events by type', async () => {\n    const analytics = createAnalyticsService(bus);\n    const catalog = createCatalogService(bus);\n\n    catalog.createProduct('A', 10, 'cat1');\n    catalog.createProduct('B', 20, 'cat1');\n    await new Promise(r => setTimeout(r, 10));\n\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n  });\n\n  it('tracks revenue from successful payments', async () => {\n    const analytics = createAnalyticsService(bus);\n    const cart = createCartService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 2);\n    const orderId = orders.createOrder('user1', cartId, 100);\n    await payment.processPayment(orderId, 100);\n\n    expect(analytics.getRevenue()).toBe(100);\n  });\n\n  it('does not count failed payments as revenue', async () => {\n    const analytics = createAnalyticsService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus, { simulateFailure: true });\n\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    await payment.processPayment(orderId, 100);\n\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  it('calculates conversion rate', async () => {\n    const analytics = createAnalyticsService(bus);\n    const cart = createCartService(bus);\n    const orders = createOrderService(bus);\n\n    const c1 = cart.createCart('user1');\n    cart.addItem(c1, 'p1', 1);\n    const c2 = cart.createCart('user2');\n    cart.addItem(c2, 'p2', 1);\n    const c3 = cart.createCart('user3');\n    cart.addItem(c3, 'p3', 1);\n\n    // Only 1 order from 3 carts\n    orders.createOrder('user1', c1, 50);\n    await new Promise(r => setTimeout(r, 10));\n\n    expect(analytics.getConversionRate()).toBeCloseTo(1 / 3);\n  });\n\n  it('returns 0 conversion rate with no carts', () => {\n    const analytics = createAnalyticsService(bus);\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n\n  it('tracks top products by order quantity', async () => {\n    const analytics = createAnalyticsService(bus);\n    const cart = createCartService(bus);\n    const orders = createOrderService(bus);\n\n    const c1 = cart.createCart('user1');\n    cart.addItem(c1, 'p1', 5);\n    cart.addItem(c1, 'p2', 2);\n    orders.createOrder('user1', c1, 70);\n\n    const c2 = cart.createCart('user2');\n    cart.addItem(c2, 'p2', 10);\n    orders.createOrder('user2', c2, 200);\n\n    await new Promise(r => setTimeout(r, 10));\n\n    const top