d`\nExpected: Clean compilation, no errors.\n\n**Step 4: Verify lint passes**\n\nRun: `npm run lint`\nExpected: No lint errors.\n\n**Step 5: Commit**\n\n```bash\ngit add src/index.ts\ngit rm src/.gitkeep 2>/dev/null || true\ngit commit -m \"feat: add stub exports for countBeamCells and countBeamPaths\"\n```\n\n---\n\n### Task 2: Write Tests for countBeamCells\n\n**Files:**\n- Create: `tests/index.test.ts`\n\n**Dependencies:** Task 1\n\n**Step 1: Write tests for countBeamCells**\n\n```typescript\nimport { describe, it, expect } from 'vitest';\nimport { countBeamCells, countBeamPaths } from '../src/index.js';\n\ndescribe('countBeamCells', () => {\n  it('single source, no splitters — beam goes straight down', () => {\n    const grid = [\n      ['.', 'S', '.'],\n      ['.', '.', '.'],\n      ['.', '.', '.'],\n    ];\n    // Visited: (0,1), (1,1), (2,1) = 3\n    expect(countBeamCells(grid)).toBe(3);\n  });\n\n  it('example 1: one splitter', () => {\n    const grid = [\n      ['.', 'S', '.', '.', '.'],\n      ['.', '.', '.', '.', '.'],\n      ['.', '^', '.', '.', '.'],\n      ['.', '.', '.', '.', '.'],\n    ];\n    // Visited: (0,1), (1,1), (2,1), (3,0), (3,2) = 5\n    expect(countBeamCells(grid)).toBe(5);\n  });\n\n  it('example 2: two splitters on row 2', () => {\n    const grid = [\n      ['.', 'S', '.', '.', '.'],\n      ['.', '^', '.', '.', '.'],\n      ['^', '.', '^', '.', '.'],\n      ['.', '.', '.', '.', '.'],\n    ];\n    // Visited: (0,1), (1,1), (2,0), (2,2), (3,1), (3,3) = 6\n    // (3,-1) is out of bounds so not counted\n    expect(countBeamCells(grid)).toBe(6);\n  });\n\n  it('source at edge, beam exits immediately if grid has 1 row', () => {\n    const grid = [['S']];\n    // Only the source cell is visited = 1\n    expect(countBeamCells(grid)).toBe(1);\n  });\n\n  it('splitter immediately below source', () => {\n    const grid = [\n      ['.', 'S', '.'],\n      ['.', '^', '.'],\n      ['.', '.', '.'],\n    ];\n    // (0,1), (1,1), (2,0), (2,2) = 4\n    expect(countBeamCells(grid)).toBe(4);\n  });\n\n  it('beam exits sideways (out of column bounds)', () => {\n    const grid = [\n      ['S', '.', '.'],\n      ['^', '.', '.'],\n      ['.', '.', '.'],\n    ];\n    // Source at (0,0), moves to (1,0) hits splitter\n    // down-left: (2,-1) out of bounds — not visited\n    // down-right: (2,1) visited\n    // Visited: (0,0), (1,0), (2,1) = 3\n    expect(countBeamCells(grid)).toBe(3);\n  });\n\n  it('overlapping beam paths count cells once', () => {\n    const grid = [\n      ['.', '.', 'S', '.', '.'],\n      ['.', '.', '^', '.', '.'],\n      ['.', '^', '.', '^', '.'],\n      ['.', '.', '^', '.', '.'],\n      ['.', '.', '.', '.', '.'],\n    ];\n    // S at (0,2), down to (1,2) splitter\n    // Left to (2,1) splitter, Right to (2,3) splitter\n    // (2,1) → (3,0) and (3,2) splitter\n    // (2,3) → (3,2) splitter and (3,4)\n    // (3,2) splitter from left beam: (4,1) and (4,3)\n    // (3,2) splitter from right beam: (4,1) and (4,3)\n    // Visited: (0,2),(1,2),(2,1),(2,3),(3,0),(3,2),(3,4),(4,1),(4,3) = 9\n    expect(countBeamCells(grid)).toBe(9);\n  });\n});\n```\n\n**Step 2: Run tests to verify they fail**\n\nRun: `npm test`\nExpected: All tests FAIL with \"Not implemented\".\n\n**Step 3: Commit**\n\n```bash\ngit add tests/index.test.ts\ngit commit -m \"test: add countBeamCells test cases\"\n```\n\n---\n\n### Task 3: Implement countBeamCells\n\n**Files:**\n- Modify: `src/index.ts`\n\n**Dependencies:** Task 2\n\n**Step 1: Implement helper types, findSource, traceBeam, and countBeamCells**\n\n```typescript\ntype Direction = 'down' | 'down-left' | 'down-right';\n\nconst DELTAS: Record<Direction, [number, number]> = {\n  'down': [1, 0],\n  'down-left': [1, -1],\n  'down-right': [1, 1],\n};\n\nfunction findSource(grid: string[][]): [number, number] {\n  for (let col = 0; col < grid[0].length; col++) {\n    if (grid[0][col] === 'S') return [0, col];\n  }\n  throw new Error('No source found');\n}\n\ninterface TraceResult {\n  visitedCells: [number, number][];\n  hitSplitter: [number, number] | null;\n}\n\nfunction traceBeam(\n  grid: string[][],\n  startRow: number,\n  startCol: number,\n  dir: Direction,\n): TraceResult {\n  const rows = grid.length;\n  const cols = grid[0].length;\n  const [dRow, dCol] = DELTAS[dir];\n  const visited: [number, number][] = [];\n\n  let r = startRow;\n  let c = startCol;\n\n  while (r >= 0 && r < rows && c >= 0 && c < cols) {\n    visited.push([r, c]);\n    if (grid[r][c] === '^' && (r !== startRow || c !== startCol)) {\n      return { visitedCells: visited, hitSplitter: [r, c] };\n    }\n    r += dRow;\n    c += dCol;\n  }\n\n  return { visitedCells: visited, hitSplitter: null };\n}\n\nexport function countBeamCells(grid: string[][]): number {\n  const [sRow, sCol] = findSource(grid);\n  const visited = new Set<string>();\n  visited.add(`${sRow},${sCol}`);\n\n  // BFS through splitter graph\n  // Start: trace beam down from source position (from the cell below source)\n  const queue: Array<{ row: number; col: number; dir: Direction }> = [];\n\n  // Initial beam goes down from source\n  const initResult = traceBeam(grid, sRow + 1, sCol, 'down');\n  for (const [r, c] of initResult.visitedCells) {\n    visited.add(`${r},${c}`);\n  }\n  if (initResult.hitSplitter) {\n    queue.push({ row: initResult.hitSplitter[0], col: initResult.hitSplitter[1], dir: 'down' });\n  }\n\n  // Track processed splitters to avoid reprocessing\n  const processedSplitters = new Set<string>();\n\n  while (queue.length > 0) {\n    const { row, col } = queue.shift()!;\n    const key = `${row},${col}`;\n    if (processedSplitters.has(key)) continue;\n    processedSplitters.add(key);\n\n    // Splitter emits down-left and down-right from the next cells\n    for (const dir of ['down-left', 'down-right'] as Direction[]) {\n      const [dRow, dCol] = DELTAS[dir];\n      const nextRow = row + dRow;\n      const nextCol = col + dCol;\n      const result = traceBeam(grid, nextRow, nextCol, dir);\n      for (const [r, c] of result.visitedCells) {\n        visited.add(`${r},${c}`);\n      }\n      if (result.hitSplitter) {\n        queue.push({ row: result.hitSplitter[0], col: result.hitSplitter[1], dir });\n      }\n    }\n  }\n\n  return visited.size;\n}\n```\n\nWait — there's a subtlety. The `traceBeam` function starts at `startRow, startCol` and the first cell it checks could itself be a splitter. But we only want to stop at a splitter that's NOT the starting position (since the starting position is the splitter we're tracing FROM). However, the initial beam from the source starts at `(sRow+1, sCol)` which is the first cell below the source — this cell could be a splitter.\n\nLet me reconsider: `traceBeam` should start from a given position and trace in a direction. The starting position of the trace is the first cell the beam enters AFTER leaving its origin (source or previous splitter). So we check each cell: if it's a splitter, we stop and record it. We need to handle the case where the very first cell of a trace is a splitter.\n\nRevised `traceBeam`: Remove the \"skip starting position\" logic. The beam starts at `(startRow, startCol)` and if that cell is a splitter, it immediately hits it.\n\n```typescript\nfunction traceBeam(\n  grid: string[][],\n  startRow: number,\n  startCol: number,\n  dir: Direction,\n): TraceResult {\n  const rows = grid.length;\n  const cols = grid[0].length;\n  const [dRow, dCol] = DELTAS[dir];\n  const visited: [number, number][] = [];\n\n  let r = startRow;\n  let c = startCol;\n\n  while (r >= 0 && r < rows && c >= 0 && c < cols) {\n    visited.push([r, c]);\n    if (grid[r][c] === '^') {\n      return { visitedCells: visited, hitSplitter: [r, c] };\n    }\n    r += dRow;\n    c += dCol;\n  }\n\n  return { visitedCells: visited, hitSplitter: null };\n}\n```\n\nAnd the caller for `countBeamCells` traces from `(sRow + 1, sCol)` with direction `'down'` for the initial beam after the source. Splitters then trace from `(row + dRow, col + dCol)` for each outgoing direction.\n\n**Step 2: Run tests**\n\nRun: `npm test`\nExpected: All countBeamCells tests pass.\n\n**Step 3: Run build and lint**\n\nRun: `npm run build && npm run lint`\nExpected: No errors.\n\n**Step 4: Commit**\n\n```bash\ngit add src/index.ts\ngit commit -m \"feat: implement countBeamCells with splitter-graph BFS\"\n```\n\n---\n\n### Task 4: Write Tests for countBeamPaths\n\n**Files:**\n- Modify: `tests/index.test.ts`\n\n**Dependencies:** Task 3\n\n**Step 1: Add countBeamPaths test cases**\n\n```typescript\ndescribe('countBeamPaths', () => {\n  it('no splitters — single path straight down', () => {\n    const grid = [\n      ['.', 'S', '.'],\n      ['.', '.', '.'],\n      ['.', '.', '.'],\n    ];\n    expect(countBeamPaths(grid)).toBe(1n);\n  });\n\n  it('example 1: one splitter → 2 paths', () => {\n    const grid = [\n      ['.', 'S', '.', '.', '.'],\n      ['.', '.', '.', '.', '.'],\n      ['.', '^', '.', '.', '.'],\n      ['.', '.', '.', '.', '.'],\n    ];\n    expect(countBeamPaths(grid)).toBe(2n);\n  });\n\n  it('example 2: three splitters → 4 paths', () => {\n    const grid = [\n      ['.', 'S', '.', '.', '.'],\n      ['.', '^', '.', '.', '.'],\n      ['^', '.', '^', '.', '.'],\n      ['.', '.', '.', '.', '.'],\n    ];\n    expect(countBeamPaths(grid)).toBe(4n);\n  });\n\n  it('single row grid — 1 path (exits immediately)', () => {\n    const grid = [['S']];\n    expect(countBeamPaths(grid)).toBe(1n);\n  });\n\n  it('source at edge with splitter — one path absorbed sideways', () => {\n    const grid = [\n      ['S', '.', '.'],\n      ['^', '.', '.'],\n      ['.', '.', '.'],\n    ];\n    // Splitter at (1,0): down-left goes to (2,-1) exits, down-right goes to (2,1) exits\n    // Both exit = 2 paths\n    expect(countBeamPaths(grid)).toBe(2n);\n  });\n\n  it('chain of splitters — exponential paths', () => {\n    // S at col 4, splitters arranged so each splits into two that each hit another splitter\n    const grid = [\n      ['.', '.', '.', '.', 'S', '.', '.', '.', '.'],\n      ['.', '.', '.', '.', '^', '.', '.', '.', '.'],\n      ['.', '.', '.', '^', '.', '^', '.', '.', '.'],\n      ['.', '.', '^', '.', '.', '.', '^', '.', '.'],\n      ['.', '.', '.', '.', '.', '.', '.', '.', '.'],\n    ];\n    // S(0,4) → (1,4) splitter → (2,3) splitter + (2,5) splitter\n    // (2,3) splitter → (3,2) splitter + (3,4) exits\n    // (2,5) splitter → (3,4) exits + (3,6) splitter\n    // (3,2) splitter → (4,1) + (4,3) = 2 paths\n    // (3,6) splitter → (4,5) + (4,7) = 2 paths\n    // Total: 2 + 1 + 1 + 2 = 6 paths\n    expect(countBeamPaths(grid)).toBe(6n);\n  });\n\n  it('diamond pattern — same splitter reachable from multiple parents', () => {\n    const grid = [\n      ['.', '.', 'S', '.', '.'],\n      ['.', '.', '^', '.', '.'],\n      ['.', '^', '.', '^', '.'],\n      ['.', '.', '^', '.', '.'],\n      ['.', '.', '.', '.', '.'],\n    ];\n    // S(0,2) → (1,2) split\n    // Left: (2,1) split → (3,0) exit + (3,2) split\n    // Right: (2,3) split → (3,2) split + (3,4) exit\n    // (3,2) reached from both (2,1) and (2,3)\n    // (3,2) split → (4,1) exit + (4,3) exit = 2 paths from this splitter\n    // From (2,1): 1 (exit at (3,0)) + 2 (through (3,2)) = 3\n    // From (2,3): 2 (through (3,2)) + 1 (exit at (3,4)) = 3\n    // Total: 3 + 3 = 6\n    expect(countBeamPaths(grid)).toBe(6n);\n  });\n});\n```\n\n**Step 2: Run tests to verify countBeamPaths tests fail**\n\nRun: `npm test`\nExpected: countBeamCells tests pass, countBeamPaths tests fail with \"Not implemented\".\n\n**Step 3: Commit**\n\n```bash\ngit add tests/index.test.ts\ngit commit -m \"test: add countBeamPaths test cases\"\n```\n\n---\n\n### Task 5: Implement countBeamPaths\n\n**Files:**\n- Modify: `src/index.ts`\n\n**Dependencies:** Task 4\n\n**Step 1: Implement countBeamPaths using memoized DP**\n\nAdd a helper `traceBeamTarget` that traces from a position/direction and returns only whether it hit a splitter (and which one) or exited, without collecting cells. Then implement the DP:\n\n```typescript\ninterface BeamTarget {\n  hitSplitter: [number, number] | null;  // null means exits grid\n}\n\nfunction traceBeamTarget(\n  grid: string[][],\n  startRow: number,\n  startCol: number,\n  dir: Direction,\n): BeamTarget {\n  const rows = grid.length;\n  const cols = grid[0].length;\n  const [dRow, dCol] = DELTAS[dir];\n\n  let r = startRow;\n  let c = startCol;\n\n  while (r >= 0 && r < rows && c >= 0 && c < cols) {\n    if (grid[r][c] === '^') {\n      return { hitSplitter: [r, c] };\n    }\n    r += dRow;\n    c += dCol;\n  }\n\n  return { hitSplitter: null };\n}\n\nexport function countBeamPaths(grid: string[][]): bigint {\n  if (grid.length <= 1) return 1n;\n\n  const [sRow, sCol] = findSource(grid);\n  const memo = new Map<string, bigint>();\n\n  function pathsFrom(row: number, col: number): bigint {\n    const key = `${row},${col}`;\n    if (memo.has(key)) return memo.get(key)!;\n\n    let total = 0n;\n\n    for (const dir of ['down-left', 'down-right'] as Direction[]) {\n      const [dRow, dCol] = DELTAS[dir];\n      const target = traceBeamTarget(grid, row + dRow, col + dCol, dir);\n      if (target.hitSplitter) {\n        total += pathsFrom(target.hitSplitter[0], target.hitSplitter[1]);\n      } else {\n        total += 1n;  // beam exits grid = one complete path\n      }\n    }\n\n    memo.set(key, total);\n    return total;\n  }\n\n  // Trace initial beam down from source\n  const initTarget = traceBeamTarget(grid, sRow + 1, sCol, 'down');\n  if (initTarget.hitSplitter) {\n    return pathsFrom(initTarget.hitSplitter[0], initTarget.hitSplitter[1]);\n  }\n  return 1n;  // beam exits without hitting any splitter\n}\n```\n\n**Step 2: Run all tests**\n\nRun: `npm test`\nExpected: All tests pass.\n\n**Step 3: Run build and lint**\n\nRun: `npm run build && npm run lint`\nExpected: No errors.\n\n**Step 4: Commit**\n\n```bash\ngit add src/index.ts\ngit commit -m \"feat: implement countBeamPaths with me