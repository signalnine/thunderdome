= DELTAS[dir];\n\n  let r = startRow;\n  let c = startCol;\n\n  while (r >= 0 && r < rows && c >= 0 && c < cols) {\n    if (grid[r][c] === '^') {\n      return { hitSplitter: [r, c] };\n    }\n    r += dRow;\n    c += dCol;\n  }\n\n  return { hitSplitter: null };\n}\n\nexport function countBeamPaths(grid: string[][]): bigint {\n  if (grid.length <= 1) return 1n;\n\n  const [sRow, sCol] = findSource(grid);\n  const memo = new Map<string, bigint>();\n\n  function pathsFrom(row: number, col: number): bigint {\n    const key = `${row},${col}`;\n    if (memo.has(key)) return memo.get(key)!;\n\n    let total = 0n;\n\n    for (const dir of ['down-left', 'down-right'] as Direction[]) {\n      const [dRow, dCol] = DELTAS[dir];\n      const target = traceBeamTarget(grid, row + dRow, col + dCol, dir);\n      if (target.hitSplitter) {\n        total += pathsFrom(target.hitSplitter[0], target.hitSplitter[1]);\n      } else {\n        total += 1n;  // beam exits grid = one complete path\n      }\n    }\n\n    memo.set(key, total);\n    return total;\n  }\n\n  // Trace initial beam down from source\n  const initTarget = traceBeamTarget(grid, sRow + 1, sCol, 'down');\n  if (initTarget.hitSplitter) {\n    return pathsFrom(initTarget.hitSplitter[0], initTarget.hitSplitter[1]);\n  }\n  return 1n;  // beam exits without hitting any splitter\n}\n```\n\n**Step 2: Run all tests**\n\nRun: `npm test`\nExpected: All tests pass.\n\n**Step 3: Run build and lint**\n\nRun: `npm run build && npm run lint`\nExpected: No errors.\n\n**Step 4: Commit**\n\n```bash\ngit add src/index.ts\ngit commit -m \"feat: implement countBeamPaths with memoized DP on splitter graph\"\n```\n\n---\n\n### Task 6: Performance Test and Edge Cases\n\n**Files:**\n- Modify: `tests/index.test.ts`\n\n**Dependencies:** Task 5\n\n**Step 1: Add performance test for large grid**\n\n```typescript\ndescribe('performance', () => {\n  it('200x200 grid with 50 splitters completes in under 5 seconds', () => {\n    const rows = 200;\n  