+      ['.', '.', '.', '.', 'S', '.', '.', '.', '.'],
+      ['.', '.', '.', '.', '^', '.', '.', '.', '.'],
+      ['.', '.', '.', '^', '.', '^', '.', '.', '.'],
+      ['.', '.', '^', '.', '.', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(6n);
+  });
+
+  it('diamond pattern — same splitter reachable from multiple parents', () => {
+    const grid = [
+      ['.', '.', 'S', '.', '.'],
+      ['.', '.', '^', '.', '.'],
+      ['.', '^', '.', '^', '.'],
+      ['.', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(6n);
+  });
+});
+
+describe('performance', () => {
+  it('200x200 grid with 50 splitters completes in under 5 seconds', () => {
+    const rows = 200;
+    const cols = 200;
+    const grid: string[][] = Array.from({ length: rows }, () =>
+      Array.from({ length: cols }, () => '.')
+    );
+
+    grid[0][100] = 'S';
+
+    let splitterPositions: [number, number][] = [[3, 100]];
+    grid[3][100] = '^';
+    let count = 1;
+
+    for (let _depth = 1; count < 50; _depth++) {
+      const newPositions: [number, number][] = [];
+      for (const [r, c] of splitterPositions) {
+        if (count >= 50) break;
+        const nextRow = r + 3;
+        if (nextRow >= rows) break;
+
+        const leftCol = c - 3;
+        const rightCol = c + 3;
+
+        if (leftCol >= 0 && leftCol < cols && count < 50) {
+          grid[nextRow][leftCol] = '^';
+          newPositions.push([nextRow, leftCol]);
+          count++;
+        }
+        if (rightCol >= 0 && rightCol < cols && count < 50) {
+          grid[nextRow][rightCol] = '^';
+          newPositions.push([nextRow, rightCol]);
+          count++;
+        }
+      }
+      splitterPositions = newPositions;
+      if (newPositions.length === 0) break;
+    }
+
+    const start = performance.now();
+    const cells = countBeamCells(grid);
+    const paths = countBeamPaths(grid);
+    const elapsed = performance.now() - start;
+
+    expect(cells).toBeGreaterThan(0);
+    expect(paths).toBeGreaterThan(0n);
+    expect(elapsed).toBeLessThan(5000);
+  });
+});
