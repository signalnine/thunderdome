+type Direction = 'down' | 'down-left' | 'down-right';
+
+const DELTAS: Record<Direction, [number, number]> = {
+  'down': [1, 0],
+  'down-left': [1, -1],
+  'down-right': [1, 1],
+};
+
+function findSource(grid: string[][]): [number, number] {
+  for (let col = 0; col < grid[0].length; col++) {
+    if (grid[0][col] === 'S') return [0, col];
+  }
+  throw new Error('No source found');
+}
+
+interface TraceResult {
+  visitedCells: [number, number][];
+  hitSplitter: [number, number] | null;
+}
+
+function traceBeam(
+  grid: string[][],
+  startRow: number,
+  startCol: number,
+  dir: Direction,
+): TraceResult {
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const [dRow, dCol] = DELTAS[dir];
+  const visited: [number, number][] = [];
+
+  let r = startRow;
+  let c = startCol;
+
+  while (r >= 0 && r < rows && c >= 0 && c < cols) {
+    visited.push([r, c]);
+    if (grid[r][c] === '^' && (r !== startRow || c !== startCol)) {
+      return { visitedCells: visited, hitSplitter: [r, c] };
+    }
+    r += dRow;
+    c += dCol;
+  }
+
+  return { visitedCells: visited, hitSplitter: null };
+}
+
+export function countBeamCells(grid: string[][]): number {
+  const [sRow, sCol] = findSource(grid);
+  const visited = new Set<string>();
+  visited.add(`${sRow},${sCol}`);
+
+  // BFS through splitter graph
+  // Start: trace beam down from source position (from the cell below source)
+  const queue: Array<{ row: number; col: number; dir: Direction }> = [];
+
+  // Initial beam goes down from source
+  const initResult = traceBeam(grid, sRow + 1, sCol, 'down');
+  for (const [r, c] of initResult.visitedCells) {
+    visited.add(`${r},${c}`);
+  }
+  if (initResult.hitSplitter) {
+    queue.push({ row: initResult.hitSplitter[0], col: initResult.hitSplitter[1], dir: 'down' });
+  }
+
+  // Track processed splitters to avoid reprocessing
+  const processedSplitters = new Set<string>();
+
+  while (queue.length > 0) {
+    const { row, col } = queue.shift()!;
+    const key = `${row},${col}`;
+    if (processedSplitters.has(key)) continue;
+    processedSplitters.add(key);
+
+    // Splitter emits down-left and down-right from the next cells
+    for (const dir of ['down-left', 'down-right'] as Direction[]) {
+      const [dRow, dCol] = DELTAS[dir];
+      const nextRow = row + dRow;
+      const nextCol = col + dCol;
+      const result = traceBeam(grid, nextRow, nextCol, dir);
+      for (const [r, c] of result.visitedCells) {
+        visited.add(`${r},${c}`);
+      }
+      if (result.hitSplitter) {
+        queue.push({ row: result.hitSplitter[0], col: result.hitSplitter[1], dir });
+      }
+    }
+  }
+
+  return visited.size;
+}
+```
+
+Wait — there's a subtlety. The `traceBeam` function starts at `startRow, startCol` and the first cell it checks could itself be a splitter. But we only want to stop at a splitter that's NOT the starting position (since the starting position is the splitter we're tracing FROM). However, the initial beam from the source starts at `(sRow+1, sCol)` which is the first cell below the source — this cell could be a splitter.
+
+Let me reconsider: `traceBeam` should start from a given position and trace in a direction. The starting position of the trace is the first cell the beam enters AFTER leaving its origin (source or previous splitter). So we check each cell: if it's a splitter, we stop and record it. We need to handle the case where the very first cell of a trace is a splitter.
+
+Revised `traceBeam`: Remove the "skip starting position" logic. The beam starts at `(startRow, startCol)` and if that cell is a splitter, it immediately hits it.
+
+```typescript
+function traceBeam(
+  grid: string[][],
+  startRow: number,
+  startCol: number,
+  dir: Direction,
+): TraceResult {
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const [dRow, dCol] = DELTAS[dir];
+  const visited: [number, number][] = [];
+
+  let r = startRow;
+  let c = startCol;
+
+  while (r >= 0 && r < rows && c >= 0 && c < cols) {
+    visited.push([r, c]);
+    if (grid[r][c] === '^') {
+      return { visitedCells: visited, hitSplitter: [r, c] };
+    }
+    r += dRow;
+    c += dCol;
+  }
+
+  return { visitedCells: visited, hitSplitter: null };
+}
+```
+
+And the caller for `countBeamCells` traces from `(sRow + 1, sCol)` with direction `'down'` for the initial beam after the source. Splitters then trace from `(row + dRow, col + dCol)` for each outgoing direction.
