f paths from an object. For non-object values (including arrays),\n   118→ * the path terminates there.\n   119→ */\n   120→function collectPaths(obj: any, prefix: string[] = []): string[][] {\n   121→  const paths: string[][] = [];\n   122→  if (obj === null || obj === undefined || typeof obj !== 'object' || Array.isArray(obj)) {\n   123→    paths.push(prefix);\n   124→    return paths;\n   125→  }\n   126→  const keys = Object.keys(obj);\n   127→  if (keys.length === 0) {\n   128→    paths.push(prefix);\n   129→    return paths;\n   130→  }\n   131→  for (const key of keys) {\n   132→    const childPaths = collectPaths(obj[key], [...prefix, key]);\n   133→    paths.push(...childPaths);\n   134→  }\n   135→  return paths;\n   136→}\n   137→\n   138→/**\n   139→ * Deep equality check.\n   140→ */\n   141→function deepEqual(a: any, b: any): boolean {\n   142→  if (a === b) return true;\n   143→  if (a === null || b === null) return a === b;\n   144→  if (a === undefined || b === undefined) return a === b;\n   145→  if (typeof a !== typeof b) return false;\n   146→  if (typeof a !== 'object') return a === b;\n   147→  if (Array.isArray(a) !== Array.isArray(b)) return false;\n   148→  if (Array.isArray(a)) {\n   149→    if (a.length !== b.length) return false;\n   150→    for (let i = 0; i < a.length; i++) {\n   151→      if (!deepEqual(a[i], b[i])) return false;\n   152→    }\n   153→    return true;\n   154→  }\n   155→  const keysA = Object.keys(a);\n   156→  const keysB = Object.keys(b);\n   157→  if (keysA.length !== keysB.length) return false;\n   158→  for (const key of keysA) {\n   159→    if (!Object.prototype.hasOwnProperty.call(b, key)) return false;\n   160→    if (!deepEqual(a[key], b[key])) return false;\n   161→  }\n   162→  return true;\n   163→}\n   164→\n   165→// Sentinel representing a value that doesn't exist (distinct from undefined)\n   166→const ABSENT = Symbol('ABSENT');\n   167→\n   168→/**\n   169→ * Three-way merge of two objects against a c