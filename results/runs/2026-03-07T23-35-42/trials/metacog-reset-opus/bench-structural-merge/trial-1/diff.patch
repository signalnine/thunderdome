l) && Object.keys(baseVal).length > 0;\n   260→\n   261→    if (oursIsObj && theirsIsObj && baseIsObj) {\n   262→      // All three are objects - children will handle field-level comparison\n   263→      continue;\n   264→    }\n   265→    if (oursIsObj && theirsIsObj && !baseExists) {\n   266→      // Both sides added objects - children will handle\n   267→      continue;\n   268→    }\n   269→\n   270→    // Determine changes from base\n   271→    const oursChanged = !valEqual(baseV, oursV);\n   272→    const theirsChanged = !valEqual(baseV, theirsV);\n   273→\n   274→    if (!oursChanged && !theirsChanged) {\n   275→      // No changes - nothing to do\n   276→      continue;\n   277→    }\n   278→\n   279→    if (oursChanged && !theirsChanged) {\n   280→      // Only ours changed - already in merged (since we started from ours)\n   281→      continue;\n   282→    }\n   283→\n   284→    if (!oursChanged && theirsChanged) {\n   285→      // Only theirs changed - apply their change\n   286→      if (theirsV === ABSENT) {\n   287→        deleteAtPath(merged, path);\n   288→      } else {\n   289→        setAtPath(merged, path, deepClone(theirsVal));\n   290→      }\n   291→      continue;\n   292→    }\n   293→\n   294→    // Both changed\n   295→    if (valEqual(oursV, theirsV)) {\n   296→      // Both changed to same value - no conflict\n   297→      continue;\n   298→    }\n   299→\n   300→    // Conflict! If both have child objects, let children handle it instead\n   301→    if (oursIsObj && theirsIsObj) {\n   302→      continue;\n   303→    }\n   304→\n   305→    // Record conflict\n   306→    conflicts.push({\n   307→      documentId,\n   308→      path: pathStr,\n   309→      base: baseV === ABSENT ? undefined : deepClone(baseVal),\n   310→      ours: oursV === ABSENT ? undefined : deepClone(oursVal),\n   311→      theirs: theirsV === ABSENT ? undefined : deepClone(theirsVal),\n   312→    });\n   313→    conflictedParents.add(pathStr);\n   314→  }\n   315→\n   316→  return { merged, conflicts };\n   317→}\n   318→\n   319→function hasPath(obj: any, path: string[]): boolean {\n   320→  let current = obj;\n   321→  for (let i = 0; i < path.length; i++) {\n   322→    if (current === null || current === undefined || typeof current !== 'object') {\n   323→      return false;\n   324→    }\n   325→    if (!Object.prototype.hasOwnProperty.call(current, path[i])) {\n   326→      return false;\n   327→    }\n   328→    current = current[path[i]];\n   329→  }\n   330→  return true;\n   331→}\n   332→\n   333→function valEqual(a: any, b: any): boolean {\n   334→  if (a === ABSENT && b === ABSENT) return true;\n   335→  if (a === ABSENT || b === ABSENT) return false;\n   336→  return deepEqual(a, b);\n   337→}\n   338→\n   339→// ── DocumentStore ───────────────────────────────────────────────────────\n   340→\n   341→export class DocumentStore {\n   342→  private branches: Map<string, BranchData> = new Map();\n   343→  private currentBranch: string = 'main';\n   344→\n   345→  constructor() {\n   346→    this.branches.set('main', {\n   347→      documents: new Map(),\n   348→      forkPoint: null,\n   349→      forkedFrom: null,\n   350→    });\n   351→  }\n   352→\n   353→  // ── CRUD ────────────────────────────────────────────────────────────\n   354→\n   355→  create(id: string, content: object): void {\n   356→    const branch = this.getCurrentBranchData();\n   357→    const existing = branch.documents.get(id);\n   358→    if (existing && !existing.deleted) {\n   359→      throw new Error(`Document '${id}' already exists`);\n   360→    }\n   361→    const clonedContent = deepClone(content);\n   362→    const version: Version = {\n   363→      id: generateVersionId(),\n   364→      timestamp: Date.now(),\n   365→      content: deepClone(content),\n   366→    };\n   367→    branch.documents.set(id, {\n   368→      content: clonedContent,\n   369→      versions: existing ? [...existing.versions, version] : [version],\n   370→    