+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+    doc.content = clonedContent;
+    doc.versions.push(version);
+  }
+
+  delete(id: string): void {
+    const branch = this.getCurrentBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document '${id}' not found`);
+    }
+    doc.deleted = true;
+  }
+
+  getHistory(id: string): Version[] {
+    const branch = this.getCurrentBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc) {
+      throw new Error(`Document '${id}' not found`);
+    }
+    return doc.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    }));
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const branch = this.getCurrentBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc) {
+      throw new Error(`Document '${id}' not found`);
+    }
+    const version = doc.versions.find(v => v.id === versionId);
+    if (!version) {
+      throw new Error(`Version '${versionId}' not found for document '${id}'`);
+    }
+    return deepClone(version.content);
+  }
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch '${name}' already exists`);
+    }
+    const sourceName = fromBranch ?? this.currentBranch;
+    const source = this.branches.get(sourceName);
+    if (!source) {
+      throw new Error(`Branch '${sourceName}' not found`);
+    }
+    const clonedDocs = cloneDocumentMap(source.documents);
+    const forkSnapshot = cloneDocumentMap(source.documents);
+    this.branches.set(name, {
+      documents: clonedDocs,
+      forkPoint: forkSnapshot,
+      forkedFrom: sourceName,
+    });
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch '${name}' not found`);
+    }
+    this.currentBranch = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranch;
+  }
+
+  listBranches(): string[] {
+    return Array.from(this.branches.keys());
+  }
+
+  merge(sourceBranch: string): MergeResult {
+    if (!this.branches.has(sourceBranch)) {
+      throw new Error(`Branch '${sourceBranch}' not found`);
+    }
+
+    const target = this.getCurrentBranchData();
+    const source = this.branches.get(sourceBranch)!;
+
+    const base = this.findCommonAncestor(sourceBranch, this.currentBranch);
+
+    const allDocIds = new Set<string>();
+    for (const id of target.documents.keys()) allDocIds.add(id);
+    for (const id of source.documents.keys()) allDocIds.add(id);
+    if (base) {
+      for (const id of base.keys()) allDocIds.add(id);
+    }
+
+    const merged: Record<string, object> = {};
+    const allConflicts: Conflict[] = [];
+
+    for (const docId of allDocIds) {
+      const baseEntry = base?.get(docId);
+      const oursEntry = target.documents.get(docId);
+      const theirsEntry = source.documents.get(docId);
+
+      const baseContent = baseEntry && !baseEntry.deleted ? baseEntry.content : null;
+      const oursContent = oursEntry && !oursEntry.deleted ? oursEntry.content : null;
+      const theirsContent = theirsEntry && !theirsEntry.deleted ? theirsEntry.content : null;
+
+      const baseDeleted = baseEntry ? baseEntry.deleted : true;
+      const oursDeleted = oursEntry ? oursEntry.deleted : true;
+      const theirsDeleted = theirsEntry ? theirsEntry.deleted : true;
+
+      const oursDocChanged = !deepEqual(baseContent, oursContent) || baseDeleted !== oursDeleted;
+      const theirsDocChanged = !deepEqual(baseContent, theirsContent) || baseDeleted !== theirsDeleted;
+
+      if (!oursDocChanged && !theirsDocChanged) {
+        continue;
+      }
+
+      if (!oursDocChanged && theirsDocChanged) {
+        if (theirsContent !== null) {
+          merged[docId] = deepClone(theirsContent);
+        }
+        continue;
+      }
+
+      if (oursDocChanged && !theirsDocChanged) {
+        if (oursContent !== null) {
+          merged[docId] = deepClone(oursContent);
+        }
+        continue;
+      }
+
+      if (oursDeleted && theirsDeleted) {
+        continue;
+      }
+
+      if (oursDeleted && !theirsDeleted) {
+        merged[docId] = deepClone(theirsContent!);
+        continue;
+      }
+
+      if (!oursDeleted && theirsDeleted) {
+        if (oursContent !== null) {
+          merged[docId] = deepClone(oursContent);
+        }
+        continue;
+      }
+
+      const { merged: mergedContent, conflicts } = threeWayMerge(
+        baseContent,
+        oursContent,
+        theirsContent,
+        docId,
+      );
+
+      merged[docId] = mergedContent;
+      allConflicts.push(...conflicts);
+    }
+
+    const applied = allConflicts.length === 0;
+
+    if (applied) {
+      for (const docId of allDocIds) {
+        const baseEntry = base?.get(docId);
+        const oursEntry = target.documents.get(docId);
+        const theirsEntry = source.documents.get(docId);
+
+        const baseContent = baseEntry && !baseEntry.deleted ? baseEntry.content : null;
+        const oursContent = oursEntry && !oursEntry.deleted ? oursEntry.content : null;
+        const theirsContent = theirsEntry && !theirsEntry.deleted ? theirsEntry.content : null;
+
+        const baseDeleted = baseEntry ? baseEntry.deleted : true;
+        const oursDeleted = oursEntry ? oursEntry.deleted : true;
+        const theirsDeleted = theirsEntry ? theirsEntry.deleted : true;
+
+        const oursDocChanged = !deepEqual(baseContent, oursContent) || baseDeleted !== oursDeleted;
+        const theirsDocChanged = !deepEqual(baseContent, theirsContent) || baseDeleted !== theirsDeleted;
+
+        if (!theirsDocChanged) continue;
+
+        if (theirsDeleted && !oursDeleted) {
+          if (!oursDocChanged) {
+            const doc = target.documents.get(docId);
+            if (doc) doc.deleted = true;
+          }
+          continue;
+        }
+
+        if (theirsDeleted) {
+          const doc = target.documents.get(docId);
+          if (doc) doc.deleted = true;
+          continue;
+        }
+
+        if (docId in merged) {
+          const mergedContent = deepClone(merged[docId]);
+          const existingDoc = target.documents.get(docId);
+          if (existingDoc && !existingDoc.deleted) {
+            const version: Version = {
+              id: generateVersionId(),
+              timestamp: Date.now(),
+              content: deepClone(merged[docId]),
+            };
+            existingDoc.content = mergedContent;
+            existingDoc.versions.push(version);
+          } else {
+            const version: Version = {
+              id: generateVersionId(),
+              timestamp: Date.now(),
+              content: deepClone(merged[docId]),
+            };
+            target.documents.set(docId, {
+              content: mergedContent,
+              versions: existingDoc ? [...existingDoc.versions, version] : [version],
+              deleted: false,
+            });
+          }
+        }
+      }
+    }
+
+    return { merged, conflicts: allConflicts, applied };
+  }
+
+  private getCurrentBranchData(): BranchData {
+    return this.branches.get(this.currentBranch)!;
+  }
+
+  private findCommonAncestor(
+    branchA: string,
+    branchB: string,
+  ): Map<string, DocumentEntry> | null {
+    const dataA = this.branches.get(branchA)!;
+    const dataB = this.branches.get(branchB)!;
+
+    if (dataA.forkedFrom === branchB) {
+      return dataA.forkPoint;
+    }
+
+    if (dataB.forkedFrom === branchA) {
+      return dataB.forkPoint;
+    }
+
+    const ancestorsA = this.getForkChain(branchA);
+    const ancestorsB = this.getForkChain(branchB);
+
+    for (const [name] of ancestorsA) {
+      for (const [nameB] of ancestorsB) {
+        if (name === nameB) {
+          const aFromCommon = dataA.forkedFrom === name ? dataA.forkPoint :
+            this.findForkPointFrom(branchA, name);
+          const bFromCommon = dataB.forkedFrom === name ? dataB.forkPoint :
+            this.findForkPointFrom(branchB, name);
+
+          if (aFromCommon) return aFromCommon;
+          if (bFromCommon) return bFromCommon;
+        }
+      }
+    }
+
+    return new Map();
+  }
+
+  private getForkChain(branchName: string): [string, BranchData][] {
+    const chain: [string, BranchData][] = [];
+    let current = branchName;
+    const visited = new Set<string>();
+    while (current && !visited.has(current)) {
+      visited.add(current);
+      const data = this.branches.get(current);
+      if (!data) break;
+      chain.push([current, data]);
+      if (data.forkedFrom) {
+        current = data.forkedFrom;
+      } else {
+        break;
+      }
+    }
+    return chain;
+  }
+
+  private findForkPointFrom(
+    branchName: string,
+    ancestorName: string,
+  ): Map<string, DocumentEntry> | null {
+    let current = branchName;
+    const visited = new Set<string>();
+    while (current && !visited.has(current)) {
+      visited.add(current);
+      const data = this.branches.get(current);
+      if (!data) return null;
+      if (data.forkedFrom === ancestorName) {
+        return data.forkPoint;
+      }
+      if (data.forkedFrom) {
+        current = data.forkedFrom;
+      } else {
+        break;
+      }
+    }
+    return null;
+  }
+}
