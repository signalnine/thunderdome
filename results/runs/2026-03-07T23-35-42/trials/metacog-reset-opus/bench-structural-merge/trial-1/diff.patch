delete('doc1');\n      expect(() => store.get('doc1')).toThrow();\n    });\n\n    it('should throw when deleting a non-existent document', () => {\n      expect(() => store.delete('nonexistent')).toThrow();\n    });\n\n    it('should throw when deleting an already deleted document', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.delete('doc1');\n      expect(() => store.delete('doc1')).toThrow();\n    });\n\n    it('should deep clone on create and get (no mutation)', () => {\n      const content = { nested: { value: 1 } };\n      store.create('doc1', content);\n      content.nested.value = 999;\n      const retrieved = store.get('doc1') as any;\n      expect(retrieved.nested.value).toBe(1);\n      retrieved.nested.value = 888;\n      expect((store.get('doc1') as any).nested.value).toBe(1);\n    });\n  });\n\n  describe('Version history', () => {\n    it('should track versions on create', () => {\n      store.create('doc1', { name: 'v1' });\n      const history = store.getHistory('doc1');\n      expect(history).toHaveLength(1);\n      expect(history[0].content).toEqual({ name: 'v1' });\n    });\n\n    it('should track versions on update', () => {\n      store.create('doc1', { name: 'v1' });\n      store.update('doc1', { name: 'v2' });\n      store.update('doc1', { name: 'v3' });\n      const history = store.getHistory('doc1');\n      expect(history).toHaveLength(3);\n      expect(history[0].content).toEqual({ name: 'v1' });\n      expect(history[1].content).toEqual({ name: 'v2' });\n      expect(history[2].content).toEqual({ name: 'v3' });\n    });\n\n    it('should return versions in chronological order', () => {\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n      store.update('doc1', { v: 3 });\n      const history = store.getHistory('doc1');\n      for (let i = 1; i < history.length; i++) {\n        expect(history[i].timestamp).toBeGreaterThanOrEqual(history[i - 1].timestamp);\n      }\n    });\n\n    it('should get a specific version', () => {\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n      const history = store.getHistory('doc1');\n      const v1Content = store.getVersion('doc1', history[0].id);\n      expect(v1Content).toEqual({ v: 1 });\n      const v2Content = store.getVersion('doc1', history[1].id);\n      expect(v2Content).toEqual({ v: 2 });\n    });\n\n    it('should throw for non-existent version', () => {\n      store.create('doc1', { v: 1 });\n      expect(() => store.getVersion('doc1', 'nonexistent')).toThrow();\n    });\n\n    it('should throw for non-existent document in getHistory', () => {\n      expect(() => store.getHistory('nonexistent')).toThrow();\n    });\n\n    it('should deep clone version contents', () => {\n      store.create('doc1', { nested: { val: 1 } });\n      const history = store.getHistory('doc1');\n      (history[0].content as any).nested.val = 999;\n      expect((store.getHistory('doc1')[0].content as any).nested.val).toBe(1);\n    });\n  });\n\n  describe('Branching', () => {\n    it('should start on main branch', () => {\n      expect(store.getBranch()).toBe('main');\n    });\n\n    it('should create and switch branches', () => {\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      expect(store.getBranch()).toBe('feature');\n    });\n\n    it('should list branches', () => {\n      store.createBranch('feature');\n      store.createBranch('bugfix');\n      expect(store.listBranches()).toContain('main');\n      expect(store.listBranches()).toContain('feature');\n      expect(store.listBranches()).toContain('bugfix');\n    });\n\n    it('should throw when creating a duplicate branch', () => {\n      store.createBranch('feature');\n      expect(() => store.createBranch('feature')).toThrow();\n    });\n\n    it('should throw when switching to non-existent branch', () => {\n      expect(() => store.switchBranch('nonexistent')).toThrow();\n    });\n\n    it('should isolate changes between branches', () => {\n      store.create('doc1', { value: 'original' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { value: 'modified' });\n      expect(store.get('doc1')).toEqual({ value: 'modified' });\n\n      store.switchBranch('main');\n      expect(store.get('doc1')).toEqual({ value: 'original' });\n    });\n\n    it('should copy existing docs when creating a branch', () => {\n      store.create('doc1', { value: 'hello' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      expect(store.get('doc1')).toEqual({ value: 'hello' });\n    });\n\n    it('should support creating a branch from a specific branch', () => {\n      store.create('doc1', { value: 'main-val' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { value: 'feature-val' });\n\n      store.switchBranch('main');\n      store.createBranch('from-feature', 'feature');\n      store.switchBranch('from-feature');\n      expect(store.get('doc1')).toEqual({ value: 'feature-val' });\n    });\n\n    it('should not show docs created on another branch', () => {\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.create('feature-doc', { value: 'feature-only' });\n\n      store.switchBranch('main');\n      expect(() => store.get('feature-doc')).toThrow();\n    });\n  });\n\n  describe('Merging', () => {\n    it('should merge non-conflicting changes from source to target', () => {\n      store.create('doc1', { a: 1, b: 2, c: 3 });\n      store.createBranch('feature');\n\n      // Modify on feature\n      store.switchBranch('feature');\n      store.update('doc1', { a: 1, b: 20, c: 3 });\n\n      // Merge feature into main\n      store.switchBranch('main');\n      const result = store.merge('feature');\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(result.merged['