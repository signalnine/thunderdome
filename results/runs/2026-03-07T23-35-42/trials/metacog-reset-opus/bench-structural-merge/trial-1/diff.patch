+/* eslint-disable @typescript-eslint/no-explicit-any */
+
+// ── Interfaces ──────────────────────────────────────────────────────────
+
+export interface Version {
+  id: string;
+  timestamp: number;
+  content: object;
+}
+
+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
