f (!doc) {\n   427→      throw new Error(`Document '${id}' not found`);\n   428→    }\n   429→    const version = doc.versions.find(v => v.id === versionId);\n   430→    if (!version) {\n   431→      throw new Error(`Version '${versionId}' not found for document '${id}'`);\n   432→    }\n   433→    return deepClone(version.content);\n   434→  }\n   435→\n   436→  // ── Branching ───────────────────────────────────────────────────────\n   437→\n   438→  createBranch(name: string, fromBranch?: string): void {\n   439→    if (this.branches.has(name)) {\n   440→      throw new Error(`Branch '${name}' already exists`);\n   441→    }\n   442→    const sourceName = fromBranch ?? this.currentBranch;\n   443→    const source = this.branches.get(sourceName);\n   444→    if (!source) {\n   445→      throw new Error(`Branch '${sourceName}' not found`);\n   446→    }\n   447→    const clonedDocs = cloneDocumentMap(source.documents);\n   448→    const forkSnapshot = cloneDocumentMap(source.documents);\n   449→    this.branches.set(name, {\n   450→      documents: clonedDocs,\n   451→      forkPoint: forkSnapshot,\n   452→      forkedFrom: sourceName,\n   453→    });\n   454→\n   455→    // Also record the fork point on the source branch side if it doesn't already have one\n   456→    // We need it to find the common ancestor during merge.\n   457→    // Actually - we store the fork point on the NEW branch. When merging, we use the\n   458→    // new branch's forkPoint as the common ancestor state.\n   459→  }\n   460→\n   461→  switchBranch(name: string): void {\n   462→    if (!this.branches.has(name)) {\n   463→      throw new Error(`Branch '${name}' not found`);\n   464→    }\n   465→    this.currentBranch = name;\n   466→  }\n   467→\n   468→  getBranch(): string {\n   469→    return this.currentBranch;\n   470→  }\n   471→\n   472→  listBranches(): string[] {\n   473→    return Array.from(this.branches.keys());\n   474→  }\n   475→\n   476→  // ── Merging ───────────────────