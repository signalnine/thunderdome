ct;\n}\n\nexport interface MergeResult {\n  merged: Record<string, object>;\n  conflicts: Conflict[];\n  applied: boolean;\n}\n\nexport interface Conflict {\n  documentId: string;\n  path: string;\n  base: any;\n  ours: any;\n  theirs: any;\n}\n\n// ── Internal types ──────────────────────────────────────────────────────\n\ninterface DocumentEntry {\n  content: object;\n  versions: Version[];\n  deleted: boolean;\n}\n\ninterface BranchData {\n  documents: Map<string, DocumentEntry>;\n  /** Snapshot of source branch documents at the time this branch was created */\n  forkPoint: Map<string, DocumentEntry> | null;\n  /** Name of the branch this was forked from (null for main) */\n  forkedFrom: string | null;\n}\n\n// ── Helpers ─────────────────────────────────────────────────────────────\n\nlet versionCounter = 0;\n\nfunction generateVersionId(): string {\n  return `v_${++versionCounter}_${Date.now()}`;\n}\n\nfunction deepClone<T>(value: T): T {\n  if (value === null || value === undefined) return value;\n  return JSON.parse(JSON.stringify(value));\n}\n\nfunction cloneDocumentEntry(entry: DocumentEntry): DocumentEntry {\n  return {\n    content: deepClone(entry.content),\n    versions: entry.versions.map(v => ({\n      id: v.id,\n      timestamp: v.timestamp,\n      content: deepClone(v.content),\n    })),\n    deleted: entry.deleted,\n  };\n}\n\nfunction cloneDocumentMap(docs: Map<string, DocumentEntry>): Map<string, DocumentEntry> {\n  const cloned = new Map<string, DocumentEntry>();\n  for (const [id, entry] of docs) {\n    cloned.set(id, cloneDocumentEntry(entry));\n  }\n  return cloned;\n}\n\n/**\n * Get a value at a dot-separated path in an object.\n */\nfunction getAtPath(obj: any, path: string[]): any {\n  let current = obj;\n  for (const key of path) {\n    if (current === null || current === undefined || typeof current !== 'object') {\n      return undefined;\n    }\n    current = current[key];\n  }\n  return current;\n}\n\n/**\n * Set a value at a dot-separated path in an object, creating intermediate objects as needed.\n */\nfunction setAtPath(obj: any, path: string[], value: any): void {\n  let current = obj;\n  for (let i = 0; i < path.length - 1; i++) {\n    const key = path[i];\n    if (current[key] === null || current[key] === undefined || typeof current[key] !== 'object') {\n      current[key] = {};\n    }\n    current = current[key];\n  }\n  current[path[path.length - 1]] = value;\n}\n\n/**\n * Delete a key at a dot-separated path in an object.\n */\nfunction deleteAtPath(obj: any, path: string[]): void {\n  let current = obj;\n  for (let i = 0; i < path.length - 1; i++) {\n    const key = path[i];\n    if (current[key] === null || current[key] === undefined || typeof current[key] !== 'object') {\n      return;\n    }\n    current = current[key];\n  }\n  delete current[path[path.length - 1]];\n}\n\n/**\n * Collect all leaf paths from an object. For non-object values (including arrays),\n * the path terminates there.\n */\nfunction collectPaths(obj: any, prefix: string[] = []): string[][] {\n  const paths: string[][] = [];\n  if (obj === null || obj === undefined || typeof obj !== 'object' || Array.isArray(obj)) {\n    paths.push(prefix);\n    return paths;\n  }\n  const keys = Object.keys(obj);\n  if (keys.length === 0) {\n    paths.push(prefix);\n    return paths;\n  }\n  for (const key of keys) {\n    const childPaths = collectPaths(obj[key], [...prefix, key]);\n    paths.push(...childPaths);\n  }\n  return paths;\n}\n\n/**\n * Deep equality check.\n */\nfunction deepEqual(a: any, b: any): boolean {\n  if (a === b) return true;\n  if (a === null || b === null) return a === b;\n  if (a === undefined || b === undefined) return a === b;\n  if (typeof a !== typeof b) return false;\n  if (typeof a !== 'object') return a === b;\n  if (Array.isArray(a) !== Array.isArray(b)) return false;\n  if (Array.isArray(a)) {\n    if (a.length !== b.length) return false;\n    for (let i = 0; i < a.length; i++) {\n      if (!deepEqual(a[i], b[i])) return false;\n    }\n    return true;\n  }\n  const keysA = Object.keys(a);\n  const keysB = Object.keys(b);\n  if (keysA.length !== keysB.length) return false;\n  for (const key of keysA) {\n    if (!Object.prototype.hasOwnProperty.call(b, key)) return false;\n    if (!deepEqual(a[key], b[key])) return false;\n  }\n  return true;\n}\n\n// Sentinel representing a value that doesn't exist (distinct from undefined)\nconst ABSENT = Symbol('ABSENT');\n\n/**\n * Three-way merge of two objects against a common base.\n * Returns the merged result and any conflicts.\n */\nfunction threeWayMerge(\n  base: any,\n  ours: any,\n  theirs: any,\n  documentId: string,\n): { merged: object; conflicts: Conflict[] } {\n  const conflicts: Conflict[] = [];\n\n  // Collect all unique paths from base, ours, and theirs\n  const allPathStrs = new Set<string>();\n  const pathMap = new Map<string, string[]>();\n\n  function addPaths(obj: any) {\n    if (obj === null || obj === undefined || typeof obj !== 'object' || Array.isArray(obj)) return;\n    const paths = collectPaths(obj);\n    for (const p of paths) {\n      if (p.length > 0) {\n        const key = p.join('.');\n        allPathStrs.add(key);\n        pathMap.set(key, p);\n      }\n    }\n  }\n\n  addPaths(base);\n  addPaths(ours);\n  addPaths(theirs);\n\n  // Also collect top-level and intermediate keys that may have been objects turned into scalars\n  function collectAllKeys(obj: any, prefix: string[] = []) {\n    if (obj === null || obj === undefined || typeof obj !== 'object' || Array.isArray(obj)) return;\n    for (const key of Object.keys(obj)) {\n      const p = [...prefix, key];\n      const pathStr = p.join('.');\n      allPathStrs.add(pathStr);\n      pathMap.set(pathStr, p);\n      collectAllKeys(obj[key], p);\n    }\n  }\n\n  collectAllKeys(base);\n  collectAllKeys(ours);\n  collectAllKeys(theirs);\n\n  // Sort paths so we process shorter (parent) paths before longer (child) paths\n  const sortedPaths = Array.from(allPathStrs).sort((a, b) => {\n    const depthA = a.split('.').length;\n    const depthB = b.split('.').length;\n    if (depthA !== depthB) return depthA - depthB;\n    return a.localeCompare(b);\n  });\n\n  // Start with a deep clone of ours as the base result (conflicts resolve \"ours\")\n  const merged = deepClone(ours) as any;\n\n  // Track which paths have been handled via conflict on a parent\n  const conflictedParents = new Set<string>();\n\n  for (const pathStr of sortedPaths) {\n    const path = pathMap.get(pathStr)!;\n\n    // Skip if a parent path already produced a conflict\n    let skipDueToParent = false;\n    for (const cp of conflictedParents) {\n      if (pathStr.startsWith(cp + '.')) {\n        skipDueToParent = true;\n        break;\n      }\n    }\n    if (skipDueToParent) continue;\n\n    const baseVal = base ? getAtPath(base, path) : undefined;\n    const oursVal = getAtPath(ours, path);\n    const theirsVal = getAtPath(theirs, path);\n\n    const baseExists = base ? hasPath(base, path) : false;\n    const oursExists = hasPath(ours, path);\n    const theirsExists = hasPath(theirs, path);\n\n    const baseV = baseExists ? baseVal : ABSENT;\n    const oursV = oursExists ? oursVal : ABSENT;\n    const theirsV = theirsExists ? theirsVal : ABSENT;\n\n    // Check if this is a \"leaf\" comparison point - we compare at the leaf level\n    // If both ours and theirs have object children at this path, skip (children handle it)\n    const oursIsObj = oursExists && oursVal !== null && typeof oursVal === 'object' && !Array.isArray(oursVal) && Object.keys(oursVal).length > 0;\n    const theirsIsObj = theirsExists && theirsVal !== null && typeof theirsVal === 'object' && !Array.isArray(theirsVal) && Object.keys(theirsVal).length > 0;\n    const baseIsObj = baseExists && baseVal !== null && typeof baseVal === 'object' && !Array.isArray(baseVal) && Object.keys(baseVal).length > 0;\n\n    if (oursIsObj && theirsIsObj && baseIsObj) {\n      // All three are objects - children will handle field-level comparison\n      continue;\n    }\n    if (oursIsObj && theirsIsObj && !baseExists) {\n      // Both sides added objects - children will handle\n      continue;\n    }\n\n    // Determine changes from base\n    const oursChanged = !valEqual(baseV, oursV);\n    const theirsChanged = !valEqual(baseV, theirsV);\n\n    if (!oursChanged && !theirsChanged) {\n      // No changes - nothing to do\n      continue;\n    }\n\n    if (oursChanged && !theirsChanged) {\n      // Only ours changed - already in merged (since we started from ours)\n      continue;\n    }\n\n    if (!oursChanged && theirsChanged) {\n      // Only theirs changed - apply their change\n      if (theirsV === ABSENT) {\n        deleteAtPath(merged, path);\n      } else {\n        setAtPath(merged, path, deepClone(theirsVal));\n      }\n      continue;\n    }\n\n    // Both changed\n    if (valEqual(oursV, theirsV)) {\n      // Both changed to same value - no conflict\n      continue;\n    }\n\n    // Conflict! If both have child objects, let children handle it instead\n    if (oursIsObj && theirsIsObj) {\n      continue;\n    }\n\n    // Record conflict\n    conflicts.push({\n      documentId,\n      path: pathStr,\n      base: baseV === ABSENT ? undefined : deepClone(baseVal),\n      ours: oursV === ABSENT ? undefined : deepClone(oursVal),\n      theirs: theirsV === ABSENT ? undefined : deepClone(theirsVal),\n    });\n    conflictedParents.add(pathStr);\n  }\n\n  return { merged, conflicts };\n}\n\nfunction hasPath(obj: any, path: string[]): boolean {\n  let current = obj;\n  for (let i = 0; i < path.length; i++) {\n    if (current === null || current === undefined || typeof current !== 'object') {\n      return false;\n    }\n    if (!Object.prototype.hasOwnProperty.call(current, path[i])) {\n      return false;\n    }\n    current = current[path[i]];\n  }\n  return true;\n}\n\nfunction valEqual(a: any, b: any): boolean {\n  if (a === ABSENT && b === ABSENT) return true;\n  if (a === ABSENT || b === ABSENT) return false;\n  return deepEqual(a, b);\n}\n\n// ── DocumentStore ───────────────────────────────────────────────────────\n\nexport class DocumentStore {\n  private branches: Map<string, BranchData> = new Map();\n  private currentBranch: string = 'main';\n\n  constructor() {\n    this.branches.set('main', {\n      documents: new Map(),\n      forkPoint: null,\n      forkedFrom: null,\n    });\n  }\n\n  // ── CRUD ────────────────────────────────────────────────────────────\n\n  create(id: string, content: object): void {\n    const branch = this.getCurrentBranchData();\n    const existing = branch.documents.get(id);\n    if (existing && !existing.deleted) {\n      throw new Error(`Document '${id}' already exists`);\n    }\n    const clonedContent = deepClone(content);\n    const version: Version = {\n      id: generateVersionId(),\n      timestamp: Date.now(),\n      content: deepClone(content),\n    };\n    branch.documents.set(id, {\n      content: clonedContent,\n      versions: existing ? [...existing.versions, version] : [version],\n      deleted: false,\n    });\n  }\n\n  get(id: string): object {\n    const branch = this.getCurrentBranchData();\n    const doc = branch.documents.get(id);\n    if (!doc || doc.deleted) {\n      throw new Error(`Document '${id}' not found`);\n    }\n    return deepClone(doc.content);\n  }\n\n  update(id: string, content: object): void {\n    const branch = this.getCurrentBranchData();\n    const doc = branch.documents.get(id);\n    if (!doc || doc.deleted) {\n      throw new Error(`Document '${id}' not found`);\n    }\n    const clonedContent = deepClone(content);\n    const version: Version = {\n      id: generateVersionId(),\n      timestamp: Date.now(),\n      content: deepClone(content),\n    };\n    doc.content = clonedContent;\n    doc.versions.push(version);\n  }\n\n  delete(id: string): void {\n    const branch = this.getCurrentBranchData();\n    const doc = branch.documents.get(id);\n    if (!doc || doc.deleted) {\n      throw new Error(`Document '${id}' not found`);\n    }\n    doc.deleted = true;\n  }\n\n  // ── Version History ─────────────────────────────────────────────────\n\n  getHistory(id: string): Version[] {\n    const branch = this.getCurrentBranchData();\n    const doc = branch.documents.get(id);\n    if (!doc) {\n      throw new Error(`Document '${id}' not found`);\n    }\n    return doc.versions.map(v => ({\n      id: v.id,\n      timestamp: v.timestamp,\n      content: deepClone(v.content),\n    }));\n  }\n\n  getVersion(id: string, versionId: string): object {\n    const branch = this.getCurrentBranchData();\n    const doc = branch.documents.get(id);\n    if (!doc) {\n      throw new Error(`Document '${id}' not found`);\n    }\n    const version = doc.versions.find(v => v.id === versionId);\n    if (!version) {\n      throw new Error(`Version '${versionId}' not found for document '${id}'`);\n    }\n    return deepClone(version.content);\n  }\n\n  // ── Branching ───────────────────────────────────────────────────────\n\n  createBranch(name: string, fromBranch?: string): void {\n    if (this.branches.has(name)) {\n      throw new Error(`Branch '${name}' already exists`);\n    }\n    const sourceName = fromBranch ?? this.currentBranch;\n    const source = this.branches.get(sourceName);\n    if (!source) {\n      throw new Error(`Branch '${sourceName}' not found`);\n    }\n    const clonedDocs = cloneDocumentMap(source.documents);\n    const forkSnapshot = cloneDocumentMap(source.documents);\n    this.branches.set(name, {\n      documents: clonedDocs,\n      forkPoint: forkSnapshot,\n      forkedFrom: sourceName,\n    });\n\n    // Also record the fork point on the source branch side if it doesn't already have one\n    // We need it to find the common ancestor during merge.\n    // Actually - we store the fork point on the NEW branch. When merging, we use the\n    // new branch's forkPoint as the common ancestor state.\n  }\n\n  switchBranch(name: string): void {\n    if (!this.branches.has(name)) {\n      throw new Error(`Branch '${name}' not found`);\n    }\n    this.currentBranch = name;\n  }\n\n  getBranch(): string {\n    return this.currentBranch;\n  }\n\n  listBranches(): string[] {\n    return Array.from(this.branches.keys());\n  }\n\n  // ── Merging ─────────────────────────────────────────────────────────\n\n  merge(sourceBranch: string): MergeResult {\n    if (!this.branches.has(sourceBranch)) {\n      throw new Error(`Branch '${sourceBranch}' not found`);\n    }\n\n    const target = this.getCurrentBranchData();\n    const source = this.branches.get(sourceBranch)!;\n\n    // Find the common ancestor (fork point).\n    // The source branch's forkPoint is the state of the parent at branch creation time.\n    // If source was forked from target (current branch), that's our base.\n    // If target was forked from source, target's forkPoint is the base.\n    // For simplicity, check both directions.\n    const base = this.findCommonAncestor(sourceBranch, this.currentBranch);\n\n    const allDocIds = new Set<string>();\n    for (const id of target.documents.keys()) allDocIds.add(id);\n    for (const id of source.documents.keys()) allDocIds.add(id);\n    if (base) {\n      for (const id of base.keys()) allDocIds.add(id);\n    }\n\n    const merged: Record<string, object> = {};\n    const allConflicts: Conflict[] = [];\n\n    for (const docId of allDocIds) {\n      const baseEntry = base?.get(docId);\n      const oursEntry = target.documents.get(docId);\n      const theirsEntry = source.documents.get(docId);\n\n      const baseContent = baseEntry && !baseEntry.deleted ? baseEntry.content : null;\n      const oursContent = oursEntry && !oursEntry.deleted ? oursEntry.content : null;\n      const theirsContent = theirsEntry && !theirsEntry.deleted ? theirsEntry.content : null;\n\n      const baseDeleted = baseEntry ? baseEntry.deleted : true;\n      const oursDeleted = oursEntry ? oursEntry.deleted : true;\n      const theirsDeleted = theirsEntry ? theirsEntry.deleted : true;\n\n      // Determine if anything changed relative to base\n      const oursDocChanged = !deepEqual(baseContent, oursContent) || baseDeleted !== oursDeleted;\n      const theirsDocChanged = !deepEqual(baseContent, theirsContent) || baseDeleted !== theirsDeleted;\n\n      if (!oursDocChanged && !theirsDocChanged) {\n        // No changes to this doc - skip (fast-forward / no-op)\n        continue;\n      }\n\n      if (!oursDocChanged && theirsDocChanged) {\n        // Only source changed - take theirs\n        if (theirsContent !== null) {\n          merged[docId] = deepClone(theirsContent);\n        }\n        // If theirs deleted it, we handle that in the apply step\n        continue;\n      }\n\n      if (oursDocChanged && !theirsDocChanged) {\n        // Only target changed - keep ours (already on our branch)\n        if (oursContent !== null) {\n          merged[docId] = deepClone(oursContent);\n        }\n        continue;\n      }\n\n      // Both changed\n      if (oursDeleted && theirsDeleted) {\n        // Both deleted - no conflict, no merge needed\n        continue;\n      }\n\n      if (oursDeleted && !theirsDeleted) {\n        // We deleted, they modified - take ours (deleted) for merged display\n        // This is a document-level divergence; we keep ours\n        merged[docId] = deepClone(theirsContent!);\n        continue;\n      }\n\n      if (!oursDeleted && theirsDeleted) {\n        // They deleted, we modified - keep ours\n        if (oursContent !== null) {\n          merged[docId] = deepClone(oursContent);\n        }\n        continue;\n      }\n\n      // Both modified the document - do three-way structural merge\n      const { merged: mergedContent, conflicts } = threeWayMerge(\n        baseContent,\n        oursContent,\n        theirsContent,\n        docId,\n      );\n\n      merged[docId] = mergedContent;\n      allConflicts.push(...conflicts);\n    }\n\n    const applied = allConflicts.length === 0;\n\n    if (applied) {\n      // Apply merged changes to current branch\n      for (const docId of allDocIds) {\n        const baseEntry = base?.get(docId);\n        const oursEntry = target.documents.get(docId);\n        const theirsEntry = source.documents.get(docId);\n\n        const baseContent = baseEntry && !baseEntry.deleted ? baseEntry.content : null;\n        const oursContent = oursEntry && !oursEntry.deleted ? oursEntry.content : null;\n        const theirsContent = theirsEntry && !theirsEntry.deleted ? theirsEntry.content : null;\n\n        const baseDeleted = baseEntry ? baseEntry.deleted : true;\n        const oursDeleted = oursEntry ? oursEntry.deleted : true;\n        const theirsDeleted = theirsEntry ? theirsEntry.deleted : true;\n\n        const oursDocChanged = !deepEqual(baseContent, oursContent) || baseDeleted !== oursDeleted;\n        const theirsDocChanged = !deepEqual(baseContent, theirsContent) || baseDeleted !== theirsDeleted;\n\n        if (!theirsDocChanged) continue; // Nothing from source to apply\n\n        if (theirsDeleted && !oursDeleted) {\n          // They deleted, we didn't - skip deletion when only they changed\n          if (!oursDocChanged) {\n            // Only they changed - apply their deletion\n            const doc = target.documents.get(docId);\n            if (doc) doc.deleted = true;\n          }\n          continue;\n        }\n\n        if (theirsDeleted) {\n          // Both deleted or only they deleted\n          const doc = target.documents.get(docId);\n          if (doc) doc.deleted = true;\n          continue;\n        }\n\n        if (docId in merged) {\n          const mergedContent = deepClone(merged[docId]);\n          const existingDoc = target.documents.get(docId);\n          if (existingDoc && !existingDoc.deleted) {\n            // Update existing doc\n            const version: Version = {\n              id: generateVersionId(),\n              timestamp: Date.now(),\n              content: deepClone(merged[docId]),\n            };\n            existingDoc.content = mergedContent;\n            existingDoc.versions.push(version);\n          } else {\n            // Create doc on target branch\n            const version: Version = {\n              id: generateVersionId(),\n              timestamp: Date.now(),\n              content: deepClone(merged[docId]),\n            };\n            target.documents.set(docId, {\n              content: mergedContent,\n              versions: existingDoc ? [...existingDoc.versions, version] : [version],\n              deleted: false,\n            });\n          }\n        }\n      }\n    }\n\n    return { merged, conflicts: allConflicts, applied };\n  }\n\n  // ── Private helpers ─────────────────────────────────────────────────\n\n  private getCurrentBranchData(): BranchData {\n    return this.branches.get(this.currentBranch)!;\n  }\n\n  /**\n   * Find the common ancestor between two branches.\n   * Returns the fork-point document map, or null if none exists (both are main).\n   */\n  private findCommonAncestor(\n    branchA: string,\n    branchB: string,\n  ): Map<string, DocumentEntry> | null {\n    const dataA = this.branches.get(branchA)!;\n    const dataB = this.branches.get(branchB)!;\n\n    // If A was forked from B, A's forkPoint is the common ancestor\n    if (dataA.forkedFrom === branchB) {\n      return dataA.forkPoint;\n    }\n\n    // If B was forked from A, B's forkPoint is the common ancestor\n    if (dataB.forkedFrom === branchA) {\n      return dataB.forkPoint;\n    }\n\n    // If both were forked from the same parent, we need to find common ancestor\n    // through the fork chain. For simplicity, walk up both chains.\n    // Check if they share a common ancestor through fork chain\n    const ancestorsA = this.getForkChain(branchA);\n    const ancestorsB = this.getForkChain(branchB);\n\n    // Find the first common ancestor\n    for (const