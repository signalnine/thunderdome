me or category', () => {\n    catalog.createProduct('Blue Widget', 5, 'gadgets');\n    catalog.createProduct('Red Gizmo', 10, 'tools');\n\n    expect(catalog.searchProducts('widget')).toHaveLength(1);\n    expect(catalog.searchProducts('tools')).toHaveLength(1);\n    expect(catalog.searchProducts('xyz')).toHaveLength(0);\n  });\n\n  it('should update a product', () => {\n    const id = catalog.createProduct('Old', 5, 'cat');\n    catalog.updateProduct(id, { name: 'New', price: 10 });\n    const p = catalog.getProduct(id);\n    expect(p?.name).toBe('New');\n    expect(p?.price).toBe(10);\n    expect(p?.category).toBe('cat');\n  });\n\n  it('should remove a product', () => {\n    const id = catalog.createProduct('X', 1, 'c');\n    expect(catalog.removeProduct(id)).toBe(true);\n    expect(catalog.getProduct(id)).toBeNull();\n    expect(catalog.removeProduct(id)).toBe(false);\n  });\n\n  it('should emit product:created event', async () => {\n    catalog.createProduct('Test', 5, 'cat');\n    // Allow async emit to complete\n    await new Promise(r => setTimeout(r, 10));\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.PRODUCT_CREATED)).toBe(true);\n  });\n});\n\ndescribe('InventoryService', () => {\n  let bus: EventBus;\n  let inventory: ReturnType<typeof createInventoryService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    inventory = createInventoryService(bus);\n  });\n\n  it('should set and get stock', () => {\n    inventory.setStock('p1', 100);\n    expect(inventory.getStock('p1')).toBe(100);\n  });\n\n  it('should return 0 for unknown product', () => {\n    expect(inventory.getStock('unknown')).toBe(0);\n  });\n\n  it('should reserve stock and reduce available', () => {\n    inventory.setStock('p1', 10);\n    expect(inventory.reserve('p1', 3)).toBe(true);\n    expect(inventory.getStock('p1')).toBe(7);\n  });\n\n  it('should fail reservation if insufficient', () => {\n    inventory.setStock('p1', 5);\n    expect(inventory.reserve('p1', 10)).toBe(false);\n    expect(inventory.getStock('p1')).toBe(5);\n  });\n\n  it('should release reserved stock', () => {\n    inventory.setStock('p1', 10);\n    inventory.reserve('p1', 5);\n    inventory.release('p1', 3);\n    expect(inventory.getStock('p1')).toBe(8);\n  });\n\n  it('should emit low stock alert', async () => {\n    let alertFired = false;\n    bus.on(Events.LOW_STOCK_ALERT, () => { alertFired = true; });\n    inventory.setStock('p1', 5);\n    inventory.setLowStockThreshold('p1', 10);\n    await new Promise(r => setTimeout(r, 10));\n    expect(alertFired).toBe(true);\n  });\n});\n\ndescribe('CartService', () => {\n  let bus: EventBus;\n  let cart: ReturnType<typeof createCartService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    cart = createCartService(bus);\n  });\n\n  it('should create a cart and retrieve it', () => {\n    const id = cart.createCart('user1');\n    const c = cart.getCart(id);\n    expect(c).toEqual({ id, userId: 'user1', items: [] });\n  });\n\n  it('should return null for unknown cart', () => {\n    expect(cart.getCart('nope')).toBeNull();\n  });\n\n  it('should add items and consolidate same product', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p1', 3);\n    const c = cart.getCart(id);\n    expect(c?.items).toEqual([{ productId: 'p1', quantity: 5 }]);\n  });\n\n  it('should remove items', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p2', 1);\n    cart.removeItem(id, 'p1');\n    expect(cart.getCart(id)?.items).toEqual([{ productId: 'p2', quantity: 1 }]);\n  });\n\n  it('should clear cart', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.clearCart(id);\n    expect(cart.getCart(id)?.items).toEqual([]);\n  });\n\n  it('should update quantity', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.updateQuantity(id, 'p1', 10);\n    expect(cart.getCart(id)?.items).toEqual([{ productId: 'p1', quantity: 10 }]);\n  });\n});\n\ndescribe('PricingService', () => {\n  let bus: EventBus;\n  let pricing: ReturnType<typeof createPricingService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    pricing = createPricingService(bus);\n  });\n\n  it('should calculate total with tax', () => {\n    const result = pricing.calculateTotal([{ productId: 'p1', quantity: 2, price: 10 }]);\n    expect(result.subtotal).toBe(20);\n    expect(result.discount).toBe(0);\n    expect(result.tax).toBe(2);\n    expect(result.total).toBe(22);\n  });\n\n  it('should apply discount code', () => {\n    pricing.addDiscountCode('SAVE10', 10);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'SAVE10'\n    );\n    expect(result.subtotal).toBe(100);\n    expect(result.discount).toBe(10);\n    expect(result.tax).toBe(9);\n    expect(result.total).toBe(99);\n  });\n\n  it('should ignore unknown discount code', () => {\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'INVALID'\n    );\n    expect(result.discount).toBe(0);\n    expect(result.total).toBe(110);\n  });\n\n  it('should track prices from product:created events', async () => {\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'X', price: 25, category: 'c' });\n    expect(pricing.getPrice('p1')).toBe(25);\n  });\n\n  it('should return 0 for unknown product price', () => {\n    expect(pricing.getPrice('unknown')).toBe(0);\n  });\n});\n\ndescribe('OrderService', () => {\n  let bus: EventBus;\n  let orders: ReturnType<typeof createOrderService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    orders = createOrderService(bus);\n  });\n\n  it('should create an order in pending state', () => {\n    const id = orders.createOrder('user1', 'cart1', 50);\n    const o = orders.getOrder(id);\n    expect(o?.status).toBe(OrderStatus.PENDING);\n    expect(o?.total).toBe(50);\n  });\n\n  it('should update order status', async () => {\n    const id = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    expect(orders.getOrder(id)?.status).toBe(OrderStatus.CONFIRMED);\n\n    // Check event includes previous status\n    await new Promise(r => setTimeout(r, 10));\n    const log = bus.getLog();\n    const statusEvent = log.find(e => e.event === Events.ORDER_STATUS_CHANGED);\n    expect(statusEvent).toBeDefined();\n    const payload = statusEvent?.payload as { previousStatus: string };\n    expect(payload.previousStatus).toBe(OrderStatus.PENDING);\n  });\n\n  it('should list orders by user', () => {\n    orders.createOrder('user1', 'c1', 10);\n    orders.createOrder('user2', 'c2', 20);\n    orders.createOrder('user1', 'c3', 30);\n\n    expect(orders.listOrders('user1')).toHaveLength(2);\n    expect(orders.listOrders('user2')).toHaveLength(1);\n  });\n\n  it('should cancel an order', () => {\n    const id = orders.createOrder('user1', 'c1', 10);\n    orders.updateStatus(id, OrderStatus.CANCELLED);\n    expect(orders.getOrder(id)?.status).toBe(OrderStatus.CANCELLED);\n  });\n\n  it('should return null for unknown order', () => {\n    expect(orders.getOrder('fake')).toBeNull();\n  });\n});\n\ndescribe('PaymentService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should process successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.SUCCESS);\n    expect(result.transactionId).toBeDefined();\n  });\n\n  it('should simulate failure', async () => {\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.FAILED);\n    expect(result.error).toBeDefined();\n  });\n\n  it('should simulate timeout', async () => {\n    const payment = createPaymentService(bus, { simulateTimeout: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.TIMEOUT);\n  });\n\n  it('should refund a successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    const refunded = await payment.refund(result.transactionId!);\n    expect(refunded).toBe(true);\n  });\n\n  it('should not refund unknown transaction', async () => {\n    const payment = createPaymentService(bus);\n    const refunded = await payment.refund('fake-tx');\n    expect(refunded).toBe(false);\n  });\n\n  it('should emit payment:processed event', async () => {\n    const payment = createPaymentService(bus);\n    await payment.processPayment('order1', 100);\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.PAYMENT_PROCESSED)).toBe(true);\n  });\n});\n\ndescribe('NotificationService', () => {\n  let bus: EventBus;\n  let notifications: ReturnType<typeof createNotificationService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    notifications = createNotificationService(bus);\n  });\n\n  it('should send notifications to subscribed users on order status change', async () => {\n    notifications.subscribe('user1');\n    // Simulate order creation so notification service tracks the user\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 50 });\n    await bus.emit(Events.ORDER_STATUS_CHANGED, { orderId: 'o1', status: OrderStatus.CONFIRMED, previousStatus: OrderStatus.PENDING });\n\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThan(0);\n    expect(notifs[0].type).toBe('order_status');\n  });\n\n  it('should send notifications on payment events', async () => {\n    notifications.subscribe('user1');\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 50 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 'tx1' });\n\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.some(n => n.type === 'payment')).toBe(true);\n  });\n\n  it('should not notify unsubscribed users', async () => {\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 50 });\n    await bus.emit(Events.ORDER_STATUS_CHANGED, { orderId: 'o1', status: OrderStatus.CONFIRMED, previousStatus: OrderStatus.PENDING });\n\n    expect(notifications.getNotifications('user1')).toHaveLength(0);\n  });\n\n  it('should return empty for user with no notifications', () => {\n    expect(notifications.getNotifications('nobody')).toEqual([]);\n  });\n});\n\ndescribe('AnalyticsService', () => {\n  let bus: EventBus;\n  let analytics: ReturnType<typeof createAnalyticsService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    analytics = createAnalyticsService(bus);\n  });\n\n  it('should count events', async () => {\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'X', price: 10, category: 'c' });\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p2', name: 'Y', price: 20, category: 'c' });\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n  });\n\n  it('should track revenue from successful payments', async () => {\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 'tx1' });\n    expect(analytics.getRevenue()).toBe(100);\n  });\n\n  it('should not count failed payments as revenue', async () => {\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.FAILED, error: 'fail' });\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  it('should calculate conversion rate', async () => {\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [] });\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c2', userId: 'u2', items: [] });\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 50 });\n    expect(analytics.getConversionRate()).toBe(0.5);\n  });\n\n  it('should return 0 conversion when no carts', () => {\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n\n  it('should track top products', async () => {\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [{ productId: 'p1', quantity: 5 }, { productId: 'p2', quantity: 2 }] });\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 50 });\n\n    const top = analytics.getTopProducts(2);\n    expect(top[0].productId).toBe('p1');\n    expect(top[0].count).toBe(5);\n    expect(top[1].productId).toBe('p2');\n    expect(top[1].count).toBe(2);\n  });\n});\n\ndescribe('Integration: Full Order Flow', () => {\n  it('should complete a full e-commerce flow', async () => {\n    const bus = new EventBus();\n\n    // Create all services - analytics first so it catches all events\n    const analytics = createAnalyticsService(bus);\n    const catalog = createCatalogService(bus);\n    const inventory = createInventoryService(bus);\n    const cartService = createCartService(bus);\n    const pricing = createPricingService(bus);\n    const orderService = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    const notificationService = createNotificationService(bus);\n\n    // Subscribe user for notifications\n    notificationService.subscribe('user1');\n\n    // 1. Add products to catalog\n    const productId = catalog.createProduct('Laptop', 999.99, 'electronics');\n    await new Promise(r => setTimeout(r, 10)); // let events propagate\n\n    // 2. Set inventory\n    inventory.setStock(productId, 50);\n\n    // 3. Verify pricing service picked up the price\n    expect(pricing.getPrice(productId)).toBe(999.99);\n\n    // 4. Create cart and add item\n    const cartId = cartService.createCart('user1');\n    cartService.addItem(cartId, productId, 2);\n\n    // 5. Calculate total\n    const cart = cartService.getCart(cartId)!;\n    const items = cart.items.map(i => ({\n      productId: i.productId,\n      quantity: i.quantity,\n      price: pricing.getPrice(i.productId),\n    }));\n    const total = pricing.calculateTotal(items);\n    expect(total.subtotal).toBe(1999.98);\n    expect(total.tax).toBeCloseTo(200, 0);\n\n    // 6. Reserve inventory\n    expect(inventory.reserve(productId, 2)).toBe(true);\n    expect(inventory.getStock(productId)).toBe(48);\n\n    // 7. Create order\n    const orderId = orderService.createOrder('user1', cartId, total.total);\n    await new Promise(r => setTimeout(r, 10));\n\n    expect(orderService.getOrder(orderId)?.status).toBe(OrderStatus.PENDING);\n\n    // 8. Process payment\n    const paymentResult = await payment.processPayment(orderId, total.total);\n    expect(paymentResult.status).toBe(PaymentStatus.SUCCESS);\n\n    // 9. Confirm order\n    orderService.updateStatus(orderId, OrderStatus.CONFIRMED);\n    await new Promise(r => setTimeout(r, 10));\n\n    // 10. Check notifications\n    const notifs = notificationService.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThan(0);\n\n    // 11. Check analytics\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBeGreaterThan(0);\n    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBe(1);\n    expect(analytics.getRevenue()).toBe(total.total);\n    expect(analytics.getConversionRate()).toBeGreaterThan(0);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_in