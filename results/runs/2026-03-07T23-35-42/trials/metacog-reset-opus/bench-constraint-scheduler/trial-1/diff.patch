  }\n      }\n    }\n\n    if (!prereqsMet) {\n      unscheduled.push(eventId);\n      continue;\n    }\n\n    const earliest = getEarliestStartAfterPrereqs(eventId, eventMap, assignments, gap, startTime);\n\n    if (earliest + duration > endTime) {\n      unscheduled.push(eventId);\n      continue;\n    }\n\n    // Try preferred room first\n    let assigned = false;\n    const roomOrder = [...sortedRooms];\n\n    if (event.preferredRoom) {\n      const prefIdx = roomOrder.findIndex(r => r.id === event.preferredRoom);\n      if (prefIdx > 0) {\n        const [preferred] = roomOrder.splice(prefIdx, 1);\n        roomOrder.unshift(preferred);\n      }\n    }\n\n    // Find best assignment: earliest start time among all valid rooms\n    let bestStart: number | null = null;\n    let bestRoomId: string | null = null;\n\n    for (const room of roomOrder) {\n      if (room.capacity < attendees) continue;\n\n      const timeline = timelines.get(room.id)!;\n      const slotStart = findEarliestSlot(timeline, duration, earliest, endTime, gap);\n\n      if (slotStart !== null) {\n        // Prefer the preferred room if it can provide an equally early or close start\n        if (bestStart === null) {\n          bestStart = slotStart;\n          bestRoomId = room.id;\n        } else if (slotStart < bestStart) {\n          bestStart = slotStart;\n          bestRoomId = room.id;\n        }\n      }\n    }\n\n    if (bestStart !== null && bestRoomId !== null) {\n      const assignment: Assignment = {\n        eventId,\n        roomId: bestRoomId,\n        startTime: bestStart,\n        endTime: bestStart + duration,\n      };\n      assignments.set(eventId, assignment);\n      insertSlot(timelines.get(bestRoomId)!, bestStart, bestStart + duration);\n      assigned = true;\n    }\n\n    if (!assigned) {\n      unscheduled.push(eventId);\n    }\n  }\n\n  return {\n    assignments: Array.from(assignments.values()),\n    unscheduled,\n  };\n}\n","structuredPatch":[{"oldStart":161,"oldLin