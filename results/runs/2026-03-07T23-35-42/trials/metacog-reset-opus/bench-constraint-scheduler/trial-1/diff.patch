+export interface Event {
+  id: string;
+  name: string;
+  duration: number;
+  attendees?: number;
+  prerequisites?: string[];
+  preferredRoom?: string;
+}
+
+export interface Room {
+  id: string;
+  name: string;
+  capacity: number;
+}
+
+export interface ScheduleOptions {
+  startTime: number;
+  endTime: number;
+  gap?: number;
+}
+
+export interface Assignment {
+  eventId: string;
+  roomId: string;
+  startTime: number;
+  endTime: number;
+}
+
+export interface ScheduleResult {
+  assignments: Assignment[];
+  unscheduled: string[];
+}
+
+interface RoomTimeline {
+  slots: { start: number; end: number }[];
+}
+
+function detectCyclesAndTopologicalSort(events: Event[]): string[] {
+  const eventMap = new Map<string, Event>();
+  for (const e of events) {
+    eventMap.set(e.id, e);
+  }
+
+  // Build adjacency list and in-degree count (Kahn's algorithm)
+  const inDegree = new Map<string, number>();
+  const adjList = new Map<string, string[]>();
+
+  for (const e of events) {
+    if (!inDegree.has(e.id)) inDegree.set(e.id, 0);
+    if (!adjList.has(e.id)) adjList.set(e.id, []);
+
+    if (e.prerequisites) {
+      for (const prereq of e.prerequisites) {
+        // Self-reference is a cycle
+        if (prereq === e.id) {
+          throw new Error(`Cycle detected: event "${e.id}" has a self-referencing prerequisite`);
+        }
+
+        // Only consider prerequisites that are in the event list
+        if (!eventMap.has(prereq)) continue;
+
+        if (!adjList.has(prereq)) adjList.set(prereq, []);
+        adjList.get(prereq)!.push(e.id);
+        inDegree.set(e.id, (inDegree.get(e.id) || 0) + 1);
+      }
+    }
+  }
+
+  const queue: string[] = [];
+  for (const e of events) {
+    if ((inDegree.get(e.id) || 0) === 0) {
+      queue.push(e.id);
+    }
+  }
+
+  const sorted: string[] = [];
+  while (queue.length > 0) {
+    const node = queue.shift()!;
+    sorted.push(node);
+
+    const neighbors = adjList.get(node) || [];
+    for (const neighbor of neighbors) {
+      const deg = inDegree.get(neighbor)! - 1;
+      inDegree.set(neighbor, deg);
+      if (deg === 0) {
+        queue.push(neighbor);
+      }
+    }
+  }
+
+  if (sorted.length !== events.length) {
+    throw new Error('Cycle detected in prerequisite graph');
+  }
+
+  return sorted;
+}
+
+function getEarliestStartAfterPrereqs(
+  eventId: string,
+  eventMap: Map<string, Event>,
+  assignments: Map<string, Assignment>,
+  gap: number,
+  windowStart: number,
+): number {
+  const event = eventMap.get(eventId)!;
+  let earliest = windowStart;
+
+  if (event.prerequisites) {
+    for (const prereqId of event.prerequisites) {
+      const prereqAssignment = assignments.get(prereqId);
+      if (prereqAssignment) {
+        earliest = Math.max(earliest, prereqAssignment.endTime + gap);
+      }
+    }
+  }
+
+  return earliest;
+}
+
+function findEarliestSlot(
+  timeline: RoomTimeline,
+  duration: number,
+  earliest: number,
+  windowEnd: number,
+  gap: number,
+): number | null {
+  // If no events in room yet, try earliest
+  if (timeline.slots.length === 0) {
+    if (earliest + duration <= windowEnd) {
+      return earliest;
+    }
+    return null;
+  }
+
+  // Try before first event
+  const firstSlot = timeline.slots[0];
+  if (earliest + duration + gap <= firstSlot.start) {
+    return earliest;
+  }
+
+  // Try between events
+  for (let i = 0; i < timeline.slots.length; i++) {
+    const slotEnd = timeline.slots[i].end + gap;
+    const candidateStart = Math.max(earliest, slotEnd);
+
+    const nextStart = i + 1 < timeline.slots.length
+      ? timeline.slots[i + 1].start
+      : windowEnd + gap; // allow fitting at the end
+
+    if (candidateStart + duration + (i + 1 < timeline.slots.length ? gap : 0) <= nextStart
+        && candidateStart + duration <= windowEnd) {
+      return candidateStart;
+    }
+  }
+
+  return null;
+}
+
+function insertSlot(timeline: RoomTimeline, start: number, end: number): void {
+  let i = 0;
+  while (i < timeline.slots.length && timeline.slots[i].start < start) {
+    i++;
+  }
+  timeline.slots.splice(i, 0, { start, end });
+}
+
+/**
+ * Compute the "depth" of each event in the prerequisite DAG.
+ * Events with no prerequisites have depth 0.
+ */
+function computeDepths(events: Event[], topoOrder: string[]): Map<string, number> {
+  const depths = new Map<string, number>();
+  const eventMap = new Map<string, Event>();
+  for (const e of events) {
+    eventMap.set(e.id, e);
+  }
+
+  for (const id of topoOrder) {
+    const event = eventMap.get(id)!;
+    let maxPrereqDepth = -1;
+    if (event.prerequisites) {
+      for (const prereq of event.prerequisites) {
+        if (depths.has(prereq)) {
+          maxPrereqDepth = Math.max(maxPrereqDepth, depths.get(prereq)!);
+        }
+      }
+    }
+    depths.set(id, maxPrereqDepth + 1);
+  }
+
+  return depths;
+}
+
+export function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {
+  if (events.length === 0) {
+    return { assignments: [], unscheduled: [] };
+  }
+
+  const gap = options.gap ?? 15;
+  const { startTime, endTime } = options;
+
+  // Validate and get topological order (throws on cycles)
+  const topoOrder = detectCyclesAndTopologicalSort(events);
+
+  const eventMap = new Map<string, Event>();
+  for (const e of events) {
+    eventMap.set(e.id, e);
+  }
+
+  // Sort rooms by capacity (ascending) for efficient packing
+  const sortedRooms = [...rooms].sort((a, b) => a.capacity - b.capacity);
+
+  // Compute depths for ordering
+  const depths = computeDepths(events, topoOrder);
+
+  // Count valid rooms per event (constraint tightness)
+  const validRoomCount = new Map<string, number>();
+  for (const e of events) {
+    const attendees = e.attendees ?? 1;
+    const count = sortedRooms.filter(r => r.capacity >= attendees).length;
+    validRoomCount.set(e.id, count);
+  }
+
+  // Order events: respect topological order, but within same depth level,
+  // prioritize by constraint tightness (fewer valid rooms first, then longer duration first)
+  const orderedEventIds = [...topoOrder].sort((a, b) => {
+    const depthDiff = depths.get(a)! - depths.get(b)!;
+    if (depthDiff !== 0) return depthDiff;
+
+    // Fewer valid rooms = more constrained = schedule first
+    const roomDiff = validRoomCount.get(a)! - validRoomCount.get(b)!;
+    if (roomDiff !== 0) return roomDiff;
+
+    // Longer events first (harder to fit)
+    const durA = eventMap.get(a)!.duration;
+    const durB = eventMap.get(b)!.duration;
+    return durB - durA;
+  });
+
+  // Try scheduling with the computed order
+  const result = trySchedule(orderedEventIds, eventMap, sortedRooms, gap, startTime, endTime);
+
+  // If there are unscheduled events, try alternative orderings to maximize placements
+  if (result.unscheduled.length > 0) {
+    // Try pure topological order
+    const result2 = trySchedule(topoOrder, eventMap, sortedRooms, gap, startTime, endTime);
+    if (result2.unscheduled.length < result.unscheduled.length) {
+      return result2;
+    }
+
+    // Try reverse constraint tightness within depth levels
+    const reverseOrder = [...topoOrder].sort((a, b) => {
+      const depthDiff = depths.get(a)! - depths.get(b)!;
+      if (depthDiff !== 0) return depthDiff;
+
+      // More constrained last (opposite)
+      const roomDiff = validRoomCount.get(b)! - validRoomCount.get(a)!;
+      if (roomDiff !== 0) return roomDiff;
+
+      const durA = eventMap.get(a)!.duration;
+      const durB = eventMap.get(b)!.duration;
+      return durA - durB;
+    });
+
+    const result3 = trySchedule(reverseOrder, eventMap, sortedRooms, gap, startTime, endTime);
+    if (result3.unscheduled.length < result.unscheduled.length) {
+      return result3;
+    }
+
+    // Try with shortest-first within depth levels
+    const shortFirst = [...topoOrder].sort((a, b) => {
+      const depthDiff = depths.get(a)! - depths.get(b)!;
+      if (depthDiff !== 0) return depthDiff;
+      return eventMap.get(a)!.duration - eventMap.get(b)!.duration;
+    });
+
+    const result4 = trySchedule(shortFirst, eventMap, sortedRooms, gap, startTime, endTime);
+    if (result4.unscheduled.length < result.unscheduled.length) {
+      return result4;
+    }
+  }
+
+  return result;
+}
+
+function trySchedule(
+  orderedEventIds: string[],
+  eventMap: Map<string, Event>,
+  sortedRooms: Room[],
+  gap: number,
+  startTime: number,
+  endTime: number,
+): ScheduleResult {
+  const timelines = new Map<string, RoomTimeline>();
+  for (const room of sortedRooms) {
+    timelines.set(room.id, { slots: [] });
+  }
+
+  const assignments = new Map<string, Assignment>();
+  const unscheduled: string[] = [];
+
+  for (const eventId of orderedEventIds) {
+    const event = eventMap.get(eventId)!;
+    const attendees = event.attendees ?? 1;
+    const duration = event.duration;
+
+    // Check if all prerequisites are scheduled
+    let prereqsMet = true;
+    if (event.prerequisites) {
+      for (const prereqId of event.prerequisites) {
+        if (eventMap.has(prereqId) && !assignments.has(prereqId)) {
+          prereqsMet = false;
+          break;
+        }
+      }
+    }
+
+    if (!prereqsMet) {
+      unscheduled.push(eventId);
+      continue;
+    }
+
+    const earliest = getEarliestStartAfterPrereqs(eventId, eventMap, assignments, gap, startTime);
+
+    if (earliest + duration > endTime) {
+      unscheduled.push(eventId);
+      continue;
+    }
+
+    let assigned = false;
+    let bestStart: number | null = null;
+    let bestRoomId: string | null = null;
+
+    // Try preferred room first - if it works, use it
+    if (event.preferredRoom) {
+      const prefRoom = sortedRooms.find(r => r.id === event.preferredRoom);
+      if (prefRoom && prefRoom.capacity >= attendees) {
+        const timeline = timelines.get(prefRoom.id)!;
+        const slotStart = findEarliestSlot(timeline, duration, earliest, endTime, gap);
+        if (slotStart !== null) {
+          bestStart = slotStart;
+          bestRoomId = prefRoom.id;
+        }
+      }
+    }
+
+    // If preferred room didn't work, find best among all valid rooms
+    if (bestStart === null) {
+      for (const room of sortedRooms) {
+        if (room.capacity < attendees) continue;
+
+        const timeline = timelines.get(room.id)!;
+        const slotStart = findEarliestSlot(timeline, duration, earliest, endTime, gap);
+
+        if (slotStart !== null) {
+          if (bestStart === null || slotStart < bestStart) {
+            bestStart = slotStart;
+            bestRoomId = room.id;
+          }
+        }
+      }
+    }
+
+    if (bestStart !== null && bestRoomId !== null) {
+      const assignment: Assignment = {
+        eventId,
+        roomId: bestRoomId,
+        startTime: bestStart,
+        endTime: bestStart + duration,
+      };
+      assignments.set(eventId, assignment);
+      insertSlot(timelines.get(bestRoomId)!, bestStart, bestStart + duration);
+      assigned = true;
+    }
+
+    if (!assigned) {
+      unscheduled.push(eventId);
+    }
+  }
+
+  return {
+    assignments: Array.from(assignments.values()),
+    unscheduled,
+  };
+}
