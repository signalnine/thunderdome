+import { describe, it, expect } from 'vitest';
+import { schedule } from '../scheduler.js';
+import type { Event, Room, ScheduleOptions } from '../scheduler.js';
+
+describe('schedule', () => {
+  const defaultOptions: ScheduleOptions = {
+    startTime: 540, // 9:00 AM
+    endTime: 1020,  // 5:00 PM
+  };
+
+  it('should schedule a single event into a single room', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60 },
+    ];
+    const rooms: Room[] = [
+      { id: 'r1', name: 'Room 1', capacity: 10 },
+    ];
+
+    const result = schedule(events, rooms, defaultOptions);
+    expect(result.assignments).toHaveLength(1);
+    expect(result.unscheduled).toHaveLength(0);
+    expect(result.assignments[0].eventId).toBe('e1');
+    expect(result.assignments[0].roomId).toBe('r1');
+    expect(result.assignments[0].startTime).toBe(540);
+    expect(result.assignments[0].endTime).toBe(600);
+  });
+
+  it('should respect room capacity', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60, attendees: 20 },
+    ];
+    const rooms: Room[] = [
+      { id: 'r1', name: 'Small Room', capacity: 10 },
+    ];
+
+    const result = schedule(events, rooms, defaultOptions);
+    expect(result.assignments).toHaveLength(0);
+    expect(result.unscheduled).toContain('e1');
+  });
+
+  it('should respect time window', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 600 }, // 10 hours
+    ];
+    const rooms: Room[] = [
+      { id: 'r1', name: 'Room 1', capacity: 10 },
+    ];
+
+    const options: ScheduleOptions = {
+      startTime: 540,
+      endTime: 600, // only 1 hour window
+    };
+
+    const result = schedule(events, rooms, options);
+    expect(result.assignments).toHaveLength(0);
+    expect(result.unscheduled).toContain('e1');
+  });
+
+  it('should maintain gap between events in same room', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60 },
+      { id: 'e2', name: 'Event 2', duration: 60 },
+    ];
+    const rooms: Room[] = [
+      { id: 'r1', name: 'Room 1', capacity: 10 },
+    ];
+
+    const result = schedule(events, rooms, defaultOptions);
+    expect(result.assignments).toHaveLength(2);
+
+    const a1 = result.assignments.find(a => a.eventId === 'e1')!;
+    const a2 = result.assignments.find(a => a.eventId === 'e2')!;
+
+    // Default gap is 15 minutes
+    const [first, second] = a1.startTime < a2.startTime ? [a1, a2] : [a2, a1];
+    expect(second.startTime - first.endTime).toBeGreaterThanOrEqual(15);
+  });
+
+  it('should respect prerequisites', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60 },
+      { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },
+    ];
+    const rooms: Room[] = [
+      { id: 'r1', name: 'Room 1', capacity: 10 },
+      { id: 'r2', name: 'Room 2', capacity: 10 },
+    ];
+
+    const result = schedule(events, rooms, defaultOptions);
+    expect(result.assignments).toHaveLength(2);
+
+    const a1 = result.assignments.find(a => a.eventId === 'e1')!;
+    const a2 = result.assignments.find(a => a.eventId === 'e2')!;
+
+    expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + 15);
+  });
+
+  it('should throw on prerequisite cycles', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['e2'] },
+      { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },
+    ];
+    const rooms: Room[] = [
+      { id: 'r1', name: 'Room 1', capacity: 10 },
+    ];
+
+    expect(() => schedule(events, rooms, defaultOptions)).toThrow();
+  });
+
+  it('should throw on self-referencing prerequisites', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['e1'] },
+    ];
+    const rooms: Room[] = [
+      { id: 'r1', name: 'Room 1', capacity: 10 },
+    ];
+
+    expect(() => schedule(events, rooms, defaultOptions)).toThrow();
+  });
+
+  it('should honor preferred room when possible', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60, preferredRoom: 'r2' },
+    ];
+    const rooms: Room[] = [
+      { id: 'r1', name: 'Room 1', capacity: 10 },
+      { id: 'r2', name: 'Room 2', capacity: 10 },
+    ];
+
+    const result = schedule(events, rooms, defaultOptions);
+    expect(result.assignments).toHaveLength(1);
+    expect(result.assignments[0].roomId).toBe('r2');
+  });
+
+  it('should handle empty events', () => {
+    const result = schedule([], [{ id: 'r1', name: 'Room 1', capacity: 10 }], defaultOptions);
+    expect(result.assignments).toHaveLength(0);
+    expect(result.unscheduled).toHaveLength(0);
+  });
+
+  it('should schedule multiple events across rooms', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60, attendees: 15 },
+      { id: 'e2', name: 'Event 2', duration: 60, attendees: 8 },
+      { id: 'e3', name: 'Event 3', duration: 60, attendees: 25 },
+    ];
+    const rooms: Room[] = [
+      { id: 'r1', name: 'Small', capacity: 10 },
+      { id: 'r2', name: 'Medium', capacity: 20 },
+      { id: 'r3', name: 'Large', capacity: 30 },
+    ];
+
+    const result = schedule(events, rooms, defaultOptions);
+    expect(result.assignments).toHaveLength(3);
+    expect(result.unscheduled).toHaveLength(0);
+
+    const a1 = result.assignments.find(a => a.eventId === 'e1')!;
+    const a3 = result.assignments.find(a => a.eventId === 'e3')!;
+
+    // e1 (15 attendees) must be in r2 or r3
+    expect(['r2', 'r3']).toContain(a1.roomId);
+    // e3 (25 attendees) must be in r3
+    expect(a3.roomId).toBe('r3');
+  });
+
+  it('should use custom gap', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60 },
+      { id: 'e2', name: 'Event 2', duration: 60 },
+    ];
+    const rooms: Room[] = [
+      { id: 'r1', name: 'Room 1', capacity: 10 },
+    ];
+
+    const options: ScheduleOptions = {
+      startTime: 540,
+      endTime: 1020,
+      gap: 30,
+    };
+
+    const result = schedule(events, rooms, options);
+    expect(result.assignments).toHaveLength(2);
+
+    const a1 = result.assignments.find(a => a.eventId === 'e1')!;
+    const a2 = result.assignments.find(a => a.eventId === 'e2')!;
+
+    const [first, second] = a1.startTime < a2.startTime ? [a1, a2] : [a2, a1];
+    expect(second.startTime - first.endTime).toBeGreaterThanOrEqual(30);
+  });
+
+  it('should maximize scheduled events', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60 },
+      { id: 'e2', name: 'Event 2', duration: 60 },
+      { id: 'e3', name: 'Event 3', duration: 60 },
+    ];
+    const rooms: Room[] = [
+      { id: 'r1', name: 'Room 1', capacity: 10 },
+    ];
+
+    const options: ScheduleOptions = {
+      startTime: 540,
+      endTime: 795, // 1:15 PM - exactly enough for 3 events with 15 min gaps
+      gap: 15,
+    };
+
+    const result = schedule(events, rooms, options);
+    expect(result.assignments).toHaveLength(3);
+    expect(result.unscheduled).toHaveLength(0);
+  });
+
+  it('should handle zero gap', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60 },
+      { id: 'e2', name: 'Event 2', duration: 60 },
+    ];
+    const rooms: Room[] = [
+      { id: 'r1', name: 'Room 1', capacity: 10 },
+    ];
+
+    const options: ScheduleOptions = {
+      startTime: 540,
+      endTime: 660,
+      gap: 0,
+    };
+
+    const result = schedule(events, rooms, options);
+    expect(result.assignments).toHaveLength(2);
+    expect(result.unscheduled).toHaveLength(0);
+  });
+
+  it('should handle prerequisite chain ordering', () => {
+    const events: Event[] = [
+      { id: 'e3', name: 'Event 3', duration: 30, prerequisites: ['e2'] },
+      { id: 'e1', name: 'Event 1', duration: 30 },
+      { id: 'e2', name: 'Event 2', duration: 30, prerequisites: ['e1'] },
+    ];
+    const rooms: Room[] = [
+      { id: 'r1', name: 'Room 1', capacity: 10 },
+    ];
+
+    const result = schedule(events, rooms, defaultOptions);
+    expect(result.assignments).toHaveLength(3);
+
+    const a1 = result.assignments.find(a => a.eventId === 'e1')!;
+    const a2 = result.assignments.find(a => a.eventId === 'e2')!;
+    const a3 = result.assignments.find(a => a.eventId === 'e3')!;
+
+    expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + 15);
+    expect(a3.startTime).toBeGreaterThanOrEqual(a2.endTime + 15);
+  });
+
+  it('should throw on 3-event cycle', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 30, prerequisites: ['e3'] },
+      { id: 'e2', name: 'Event 2', duration: 30, prerequisites: ['e1'] },
+      { id: 'e3', name: 'Event 3', duration: 30, prerequisites: ['e2'] },
+    ];
+    const rooms: Room[] = [
+      { id: 'r1', name: 'Room 1', capacity: 10 },
+    ];
+
+    expect(() => schedule(events, rooms, defaultOptions)).toThrow();
+  });
+
+  it('should place event in fallback room when preferred is full', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 480, preferredRoom: 'r1' }, // fills r1 all day
+      { id: 'e2', name: 'Event 2', duration: 60, preferredRoom: 'r1' }, // prefers r1 but can't fit
+    ];
+    const rooms: Room[] = [
+      { id: 'r1', name: 'Room 1', capacity: 10 },
+      { id: 'r2', name: 'Room 2', capacity: 10 },
+    ];
+
+    const result = schedule(events, rooms, defaultOptions);
+    expect(result.assignments).toHaveLength(2);
+    expect(result.unscheduled).toHaveLength(0);
+
+    // e2 should be assigned to r2 since r1 is essentially full
+    const a2 = result.assignments.find(a => a.eventId === 'e2')!;
+    expect(a2).toBeDefined();
+  });
+
+  it('should default attendees to 1', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60 }, // no attendees specified
+    ];
+    const rooms: Room[] = [
+      { id: 'r1', name: 'Room 1', capacity: 1 },
+    ];
+
+    const result = schedule(events, rooms, defaultOptions);
+    expect(result.assignments).toHaveLength(1);
+  });
+});
