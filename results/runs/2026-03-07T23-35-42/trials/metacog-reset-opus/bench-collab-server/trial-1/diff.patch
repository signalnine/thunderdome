      operation: {\n        version: 0,\n        components: [\n          { type: 'retain', count: 2 },\n          { type: 'insert', text: '!' },\n        ],\n      },\n    }));\n\n    await waitForMessage(ws1); // ack\n\n    const broadcast = await broadcastPromise;\n    expect(broadcast.type).toBe('operation');\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should handle concurrent edits from multiple clients', async () => {\n    const created = await api('POST', '/documents', { title: 'Concurrent', content: 'hello' });\n\n    const ws1 = await connectWs(created.body.id);\n    const ws2 = await connectWs(created.body.id);\n\n    await waitForMessage(ws1); // sync\n    await waitForMessage(ws2); // sync\n\n    // Both operations are based on version 0\n    // ws1: insert \"X\" at beginning\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      operation: {\n        version: 0,\n        components: [\n          { type: 'insert', text: 'X' },\n        ],\n      },\n    }));\n\n    const ack1 = await waitForMessage(ws1);\n    expect(ack1.type).toBe('ack');\n\n    // ws2 also based on version 0 but arrives after ws1's was processed\n    // ws2: insert \"Y\" at end\n    const broadcastPromise = waitForMessage(ws1);\n    ws2.send(JSON.stringify({\n      type: 'operation',\n      operation: {\n        version: 0,\n        components: [\n          { type: 'retain', count: 5 },\n          { type: 'insert', text: 'Y' },\n        ],\n      },\n    }));\n\n    // ws2 should get ack\n    const ack2 = await waitForMessage(ws2);\n    expect(ack2.type).toBe('ack');\n\n    // ws1 should get broadcast\n    const broadcast = await broadcastPromise;\n    expect(broadcast.type).toBe('operation');\n\n    // Verify final document state via REST\n    const { body } = await api('GET', `/documents/${created.body.id}`);\n    // Both insertions should be present: \"XhelloY\"\n    expect(body.content).toContain('X');\n    expect(body.content).toContain('Y');\n    expect(body.content).toContain('hello');\n    expect(body.content).toBe('XhelloY');\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should handle 10 concurrent clients', async () => {\n    const created = await api('POST', '/documents', { title: 'Many Clients', content: '' });\n\n    const clients: WebSocket[] = [];\n    for (let i = 0; i < 10; i++) {\n      const ws = await connectWs(created.body.id);\n      await waitForMessage(ws); // sync\n      clients.push(ws);\n    }\n\n    // Each client sends an insert at position 0 sequentially\n    // so each one must be based on the version after the previous ack\n    let currentVersion = 0;\n    for (let i = 0; i < 10; i++) {\n      const ws = clients[i];\n\n      // Drain any pending broadcasts from prior operations\n      const drainPromise = new Promise<void>((resolve) => {\n        const timer = setTimeout(resolve, 50);\n        const handler = () => {\n          clearTimeout(timer);\n          ws.off('message', handler);\n          resolve();\n        };\n        // Already handled messages will not be re-delivered\n        // We use a small timeout as a fallback\n        ws.on('message', handler);\n      });\n      await drainPromise;\n\n      ws.send(JSON.stringify({\n        type: 'operation',\n        operation: {\n          version: currentVersion,\n          components: [\n            { type: 'insert', text: String(i) },\n          ],\n        },\n      }));\n\n      const ack = await waitForMessage(ws);\n      expect(ack.type).toBe('ack');\n      currentVersion = ack.version as number;\n    }\n\n    // Verify final document contains all digits\n    const { body } = await api('GET', `/documents/${created.body.id}`);\n    for (let i = 0; i < 10; i++) {\n      expect(body.content).toContain(String(i));\n    }\n    expect(body.content.length).toBe(10);\n\n    for (const ws of clients) {\n      ws.close();\n    }\n  });\n\n  it('should reject invalid operations', async () => {\n    const created = await api('POST', '/documents', { title: 'Invalid', content: 'test' });\n    const ws = await connectWs(created.body.id);\n    await waitForMessage(ws); // sync\n\n    // Send operation with bad component\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: {\n        version: 0,\n        components: [\n          { type: 'retain', count: 1000 }, // overflow\n          { type: 'insert', text: 'x' },\n        ],\n      },\n    }));\n\n    const msg = await waitForMessage(ws);\n    expect(msg.type).toBe('error');\n\n    ws.close();\n  });\n\n  it('should reject operations with future version', async () => {\n    const created = await api('POST', '/documents', { title: 'Future', content: 'test' });\n    const ws = await connectWs(created.body.id);\n    await waitForMessage(ws); // sync\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: {\n        version: 999,\n        components: [\n          { type: 'insert', text: 'x' },\n        ],\n      },\n    }));\n\n    const msg = await waitForMessage(ws);\n    expect(msg.type).toBe('error');\n\n    ws.close();\n  });\n\n  it('should handle malformed JSON', async () => {\n    const created = await api('POST', '/documents', { title: 'Malformed', content: 'test' });\n    const ws = await connectWs(created.body.id);\n    await waitForMessage(ws); // sync\n\n    ws.send('not valid json');\n\n    const msg = await waitForMessage(ws);\n    expect(msg.type).toBe('error');\n\n    ws.close();\n  });\n});\n\ndescribe('Persistence', () => {\n  it('should persist documents across restarts', async () => {\n    const tmpDb = `/tmp/test-collab-${Date.now()}.db`;\n\n    // First server instance\n    const app1 = createApp(tmpDb);\n    const port1 = await app1.start(0);\n\n    const res = await fetch(`http://localhost:${port1}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Persistent', content: 'survive restart' }),\n    });\n    const doc = await res.json();\n    await app1.stop();\n\n    // Second server instance with same DB\n    const app2 = createApp(tmpDb);\n    const port2 = await app2.start(0);\n\n    const res2 = await fetch(`http://localhost:${port2}/api/documents/${doc.id}`);\n    const doc2 = await res2.json();\n    expect(doc2.title).toBe('Persistent');\n    expect(doc2.content).toBe('survive restart');\n    await app2.stop();\n  });\n\n  it('should persist version history', async () => {\n    const tmpDb = `/tmp/test-versions-${Date.now()}.db`;\n\n    const app1 = createApp(tmpDb);\n    const port1 = await app1.start(0);\n\n    const res = await fetch(`http://localhost:${port1}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Versioned', content: 'v0' }),\n    });\n    const doc = await res.json();\n\n    // Make an edit via WebSocket to create a version\n    const ws = await new Promise<WebSocket>((resolve, reject) => {\n      const w = new WebSocket(`ws://localhost:${port1}/ws/documents/${doc.id}`);\n      w.on('open', () => resolve(w));\n      w.on('error', reject);\n    });\n    await waitForMessage(ws); // sync\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: {\n        version: 0,\n        components: [\n          { type: 'retain', count: 2 },\n          { type: 'insert', text: '1' },\n        ],\n      },\n    }));\n    await waitForMessage(ws); // ack\n    ws.close();\n    await app1.stop();\n\n    // Check persistence\n    const app2 = createApp(tmpDb);\n    const port2 = await app2.start(0);\n\n    const versionsRes = await fetch(`http://localhost:${port2}/api/documents/${doc.id}/versions`);\n    const versions = await versionsRes.json();\n    expect(versions.length).toBe(2); // v0 + v1\n    expect(versions[1].content).toBe('v01');\n    await app2.stop();\n  });\n});\n","numLines":392,"startLine":65,"totalLines":456}}}
