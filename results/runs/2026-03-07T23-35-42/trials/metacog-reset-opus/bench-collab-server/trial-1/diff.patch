new file mode 100644
index 0000000..716a571
--- /dev/null
+++ b/src/collaboration.ts
@@ -0,0 +1,258 @@
+import { WebSocketServer, WebSocket } from 'ws';
+import type { Server as HttpServer } from 'http';
+import type { DocumentStore } from './db.js';
+import { apply, transform, type Operation, type Component } from './ot.js';
+
+interface ClientConnection {
+  ws: WebSocket;
+  clientId: string;
+  docId: string;
+}
+
+interface DocumentSession {
+  docId: string;
+  content: string;
+  version: number;
+  clients: Map<string, ClientConnection>;
+  /** Server-side history of operations, indexed by the version they produced. */
+  history: Operation[];
+}
+
+interface ClientMessage {
+  type: 'operation';
+  operation: {
+    version: number;
+    components: Component[];
+  };
+  clientId?: string;
+}
+
+export class CollaborationManager {
+  private sessions: Map<string, DocumentSession> = new Map();
+  private wss: WebSocketServer | null = null;
+  private store: DocumentStore;
+
+  constructor(store: DocumentStore) {
+    this.store = store;
+  }
+
+  attach(server: HttpServer): void {
+    this.wss = new WebSocketServer({ noServer: true });
+
+    // Handle upgrade manually to parse the doc ID from the URL
+    server.on('upgrade', (request, socket, head) => {
+      const url = new URL(request.url ?? '/', `http://${request.headers.host}`);
+      const match = url.pathname.match(/^\/ws\/documents\/([^/]+)$/);
+
+      if (!match) {
+        socket.write('HTTP/1.1 404 Not Found\r\n\r\n');
+        socket.destroy();
+        return;
+      }
+
+      const docId = match[1];
+      const doc = this.store.getDocument(docId);
+      if (!doc) {
+        socket.write('HTTP/1.1 404 Not Found\r\n\r\n');
+        socket.destroy();
+        return;
+      }
+
+      this.wss!.handleUpgrade(request, socket, head, (ws) => {
+        this.wss!.emit('connection', ws, request, docId);
+      });
+    });
+
+    this.wss.on('connection', (ws: WebSocket, _request: unknown, docId: string) => {
+      this.handleConnection(ws, docId);
+    });
+  }
+
+  private getOrCreateSession(docId: string): DocumentSession {
+    let session = this.sessions.get(docId);
+    if (!session) {
+      const doc = this.store.getDocument(docId);
+      if (!doc) throw new Error(`Document ${docId} not found`);
+
+      const latestVersion = this.store.getLatestVersion(docId);
+      const version = latestVersion ? latestVersion.version : 0;
+
+      session = {
+        docId,
+        content: doc.content,
+        version,
+        clients: new Map(),
+        history: [],
+      };
+      this.sessions.set(docId, session);
+    }
+    return session;
+  }
+
+  private handleConnection(ws: WebSocket, docId: string): void {
+    const session = this.getOrCreateSession(docId);
+    const clientId = Math.random().toString(36).slice(2, 10);
+
+    const client: ClientConnection = { ws, clientId, docId };
+    session.clients.set(clientId, client);
+
+    // Send sync message
+    ws.send(JSON.stringify({
+      type: 'sync',
+      content: session.content,
+      version: session.version,
+      clientId,
+    }));
+
+    ws.on('message', (data: Buffer | string) => {
+      try {
+        const raw = typeof data === 'string' ? data : data.toString('utf-8');
+        const message = JSON.parse(raw) as ClientMessage;
+        this.handleMessage(session, client, message);
+      } catch (err) {
+        const errorMessage = err instanceof Error ? err.message : 'Unknown error';
+        ws.send(JSON.stringify({ type: 'error', message: errorMessage }));
+      }
+    });
+
+    ws.on('close', () => {
+      session.clients.delete(clientId);
+      if (session.clients.size === 0) {
+        // Keep session around for quick reconnects, but we could clean up
+      }
+    });
+
+    ws.on('error', () => {
+      session.clients.delete(clientId);
+    });
+  }
+
+  private handleMessage(
+    session: DocumentSession,
+    client: ClientConnection,
+    message: ClientMessage
+  ): void {
+    if (message.type !== 'operation') {
+      client.ws.send(JSON.stringify({ type: 'error', message: `Unknown message type: ${message.type}` }));
+      return;
+    }
+
+    const { operation } = message;
+    if (!operation || !Array.isArray(operation.components)) {
+      client.ws.send(JSON.stringify({ type: 'error', message: 'Invalid operation: missing components' }));
+      return;
+    }
+
+    if (typeof operation.version !== 'number' || operation.version < 0) {
+      client.ws.send(JSON.stringify({ type: 'error', message: 'Invalid operation: bad version' }));
+      return;
+    }
+
+    // Validate components
+    for (const comp of operation.components) {
+      if (!comp || !comp.type) {
+        client.ws.send(JSON.stringify({ type: 'error', message: 'Invalid component: missing type' }));
+        return;
+      }
+      if (comp.type === 'insert' && typeof comp.text !== 'string') {
+        client.ws.send(JSON.stringify({ type: 'error', message: 'Invalid insert component: missing text' }));
+        return;
+      }
+      if (comp.type === 'retain' && (typeof comp.count !== 'number' || comp.count < 0)) {
+        client.ws.send(JSON.stringify({ type: 'error', message: 'Invalid retain component: bad count' }));
+        return;
+      }
+      if (comp.type === 'delete' && (typeof comp.count !== 'number' || comp.count < 0)) {
+        client.ws.send(JSON.stringify({ type: 'error', message: 'Invalid delete component: bad count' }));
+        return;
+      }
+      if (!['insert', 'retain', 'delete'].includes(comp.type)) {
+        client.ws.send(JSON.stringify({ type: 'error', message: `Invalid component type: ${comp.type}` }));
+        return;
+      }
+    }
+
+    let op: Operation = {
+      docId: session.docId,
+      version: operation.version,
+      components: operation.components,
+      clientId: client.clientId,
+    };
+
+    // Transform against any operations that happened since the client's version
+    const clientVersion = op.version;
+    if (clientVersion > session.version) {
+      client.ws.send(JSON.stringify({ type: 'error', message: 'Operation version is ahead of server' }));
+      return;
+    }
+
+    // Transform the operation against all ops that happened since the client's base version
+    for (let i = clientVersion; i < session.version; i++) {
+      const serverOp = session.history[i];
+      if (!serverOp) {
+        client.ws.send(JSON.stringify({ type: 'error', message: 'Missing server operation for transform' }));
+        return;
+      }
+      const [transformedClient] = transform(op, serverOp);
+      op = transformedClient;
+    }
+
+    // Apply the transformed operation to the server document
+    try {
+      session.content = apply(session.content, op);
+    } catch (err) {
+      const errorMessage = err instanceof Error ? err.message : 'Apply failed';
+      client.ws.send(JSON.stringify({ type: 'error', message: errorMessage }));
+      return;
+    }
+
+    session.version++;
+    op.version = session.version;
+
+    // Store in history (indexed by the version it was based on, for future transforms)
+    session.history[session.version - 1] = op;
+
+    // Persist to database
+    this.store.updateDocument(session.docId, null, session.content);
+    this.store.saveVersion(
+      session.docId,
+      session.version,
+      session.content,
+      JSON.stringify(op.components)
+    );
+
+    // Send ack to the originating client
+    client.ws.send(JSON.stringify({
+      type: 'ack',
+      version: session.version,
+    }));
+
+    // Broadcast to all other clients
+    for (const [id, other] of session.clients) {
+      if (id === client.clientId) continue;
+      if (other.ws.readyState === WebSocket.OPEN) {
+        other.ws.send(JSON.stringify({
+          type: 'operation',
+          operation: {
+            version: session.version,
+            components: op.components,
+          },
+          clientId: client.clientId,
+        }));
+      }
+    }
+  }
+
+  closeAll(): void {
+    for (const session of this.sessions.values()) {
+      for (const client of session.clients.values()) {
+        client.ws.close();
+      }
+    }
+    this.sessions.clear();
+    if (this.wss) {
+      this.wss.close();
+      this.wss = null;
+    }
+  }
+}
diff --git a/src/db.ts b/src/db.ts
new file mode 100644
index 0000000..a9cbcc8
--- /dev/null
+++ b/src/db.ts
@@ -0,0 +1,137 @@
+import Database from 'better-sqlite3';
+import { randomUUID } from 'crypto';
+
+export interface DocumentRow {
+  id: string;
+  title: string;
+  content: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface VersionRow {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operation: string | null;
+  created_at: string;
+}
+
+export function createDb(dbPath: string = ':memory:'): Database.Database {
+  const db = new Database(dbPath);
+  db.pragma('journal_mode = WAL');
+  db.pragma('foreign_keys = ON');
+
+  db.exec(`
+    CREATE TABLE IF NOT EXISTS documents (
+      id TEXT PRIMARY KEY,
+      title TEXT NOT NULL,
+      content TEXT NOT NULL DEFAULT '',
+      created_at TEXT NOT NULL DEFAULT (datetime('now')),
+      updated_at TEXT NOT NULL DEFAULT (datetime('now'))
+    );
+
+    CREATE TABLE IF NOT EXISTS versions (
+      id INTEGER PRIMARY KEY AUTOINCREMENT,
+      document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
+      version INTEGER NOT NULL,
+      content TEXT NOT NULL,
+      operation TEXT,
+      created_at TEXT NOT NULL DEFAULT (datetime('now')),
+      UNIQUE(document_id, version)
+    );
+  `);
+
+  return db;
+}
+
+export class DocumentStore {
+  private db: Database.Database;
+
+  private stmts: {
+    insertDoc: Database.Statement;
+    getDoc: Database.Statement;
+    listDocs: Database.Statement;
+    updateDoc: Database.Statement;
+    deleteDoc: Database.Statement;
+    insertVersion: Database.Statement;
+    getVersions: Database.Statement;
+    getLatestVersion: Database.Statement;
+    getVersion: Database.Statement;
+  };
+
+  constructor(db: Database.Database) {
+    this.db = db;
+    this.stmts = {
+      insertDoc: db.prepare(
+        `INSERT INTO documents (id, title, content) VALUES (?, ?, ?)`
+      ),
+      getDoc: db.prepare(`SELECT * FROM documents WHERE id = ?`),
+      listDocs: db.prepare(`SELECT * FROM documents ORDER BY updated_at DESC`),
+      updateDoc: db.prepare(
+        `UPDATE documents SET title = COALESCE(?, title), content = ?, updated_at = datetime('now') WHERE id = ?`
+      ),
+      deleteDoc: db.prepare(`DELETE FROM documents WHERE id = ?`),
+      insertVersion: db.prepare(
+        `INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)`
+      ),
+      getVersions: db.prepare(
+        `SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC`
+      ),
+      getLatestVersion: db.prepare(
+        `SELECT * FROM versions WHERE document_id = ? ORDER BY version DESC LIMIT 1`
+      ),
+      getVersion: db.prepare(
+        `SELECT * FROM versions WHERE document_id = ? AND version = ?`
+      ),
+    };
+  }
+
+  createDocument(title: string, content: string = ''): DocumentRow {
+    const id = randomUUID();
+    this.stmts.insertDoc.run(id, title, content);
+    // Save initial version (version 0)
+    this.stmts.insertVersion.run(id, 0, content, null);
+    return this.stmts.getDoc.get(id) as DocumentRow;
+  }
+
+  getDocument(id: string): DocumentRow | undefined {
+    return this.stmts.getDoc.get(id) as DocumentRow | undefined;
+  }
+
+  listDocuments(): DocumentRow[] {
+    return this.stmts.listDocs.all() as DocumentRow[];
+  }
+
+  updateDocument(id: string, title: string | null, content: string): DocumentRow | undefined {
+    const result = this.stmts.updateDoc.run(title, content, id);
+    if (result.changes === 0) return undefined;
+    return this.stmts.getDoc.get(id) as DocumentRow;
+  }
+
+  deleteDocument(id: string): boolean {
+    const result = this.stmts.deleteDoc.run(id);
+    return result.changes > 0;
+  }
+
+  saveVersion(docId: string, version: number, content: string, operation?: string): void {
+    this.stmts.insertVersion.run(docId, version, content, operation ?? null);
+  }
+
+  getVersions(docId: string): VersionRow[] {
+    return this.stmts.getVersions.all(docId) as VersionRow[];
+  }
+
+  getLatestVersion(docId: string): VersionRow | undefined {
+    return this.stmts.getLatestVersion.get(docId) as VersionRow | undefined;
+  }
+
+  getVersion(docId: string, version: number): VersionRow | undefined {
+    return this.stmts.getVersion.get(docId, version) as VersionRow | undefined;
+  }
+
+  close(): void {
+    this.db.close();
+  }
+}
