@@ -0,0 +1,339 @@
+/**
+ * Operational Transform engine for collaborative text editing.
+ *
+ * Operations are sequences of components that, applied in order, transform
+ * a document from one state to another. Components are:
+ *   - retain(n): skip n characters unchanged
+ *   - insert(s): insert string s at the current position
+ *   - delete(n): delete n characters at the current position
+ *
+ * The key function is `transform(a, b)` which takes two concurrent operations
+ * based on the same document state and returns [a', b'] such that
+ * apply(apply(doc, a), b') === apply(apply(doc, b), a').
+ */
+
+export type Component =
+  | { type: 'retain'; count: number }
+  | { type: 'insert'; text: string }
+  | { type: 'delete'; count: number };
+
+export interface Operation {
+  docId: string;
+  version: number;  // the document version this op was generated against
+  components: Component[];
+  clientId?: string;
+}
+
+/** Apply an operation to a document string, returning the new string. */
+export function apply(doc: string, op: Operation): string {
+  let pos = 0;
+  let result = '';
+
+  for (const comp of op.components) {
+    switch (comp.type) {
+      case 'retain':
+        if (pos + comp.count > doc.length) {
+          throw new Error(
+            `Retain overflows document: pos=${pos}, count=${comp.count}, docLen=${doc.length}`
+          );
+        }
+        result += doc.slice(pos, pos + comp.count);
+        pos += comp.count;
+        break;
+
+      case 'insert':
+        result += comp.text;
+        break;
+
+      case 'delete':
+        if (pos + comp.count > doc.length) {
+          throw new Error(
+            `Delete overflows document: pos=${pos}, count=${comp.count}, docLen=${doc.length}`
+          );
+        }
+        pos += comp.count;
+        break;
+    }
+  }
+
+  // Any remaining characters are implicitly retained
+  result += doc.slice(pos);
+
+  return result;
+}
+
+/** Compute the input length an operation expects. */
+export function inputLength(op: Operation): number {
+  let len = 0;
+  for (const comp of op.components) {
+    if (comp.type === 'retain') len += comp.count;
+    else if (comp.type === 'delete') len += comp.count;
+  }
+  return len;
+}
+
+/** Compute the output length an operation produces. */
+export function outputLength(op: Operation): number {
+  let len = 0;
+  for (const comp of op.components) {
+    if (comp.type === 'retain') len += comp.count;
+    else if (comp.type === 'insert') len += comp.text.length;
+  }
+  return len;
+}
+
+/**
+ * Transform two concurrent operations a and b (both based on the same document)
+ * into a' and b' such that apply(apply(doc, a), b') === apply(apply(doc, b), a').
+ *
+ * Returns [aPrime, bPrime].
+ */
+export function transform(
+  a: Operation,
+  b: Operation
+): [Operation, Operation] {
+  // Pad both operations to the same input length so transform can proceed.
+  // Operations may implicitly retain trailing characters (apply does this),
+  // so we add explicit trailing retains to match the longer input length.
+  const aComps = normalizeComponents(a.components);
+  const bComps = normalizeComponents(b.components);
+
+  const aInputLen = compsInputLength(aComps);
+  const bInputLen = compsInputLength(bComps);
+  const maxInputLen = Math.max(aInputLen, bInputLen);
+
+  const aPadded = [...aComps];
+  const bPadded = [...bComps];
+  if (aInputLen < maxInputLen) {
+    aPadded.push({ type: 'retain', count: maxInputLen - aInputLen });
+  }
+  if (bInputLen < maxInputLen) {
+    bPadded.push({ type: 'retain', count: maxInputLen - bInputLen });
+  }
+
+  const aPrime: Component[] = [];
+  const bPrime: Component[] = [];
+
+  let ai = 0;
+  let bi = 0;
+
+  // Mutable copies for splitting
+  const aMut = aPadded.map(cloneComp);
+  const bMut = bPadded.map(cloneComp);
+
+  while (ai < aMut.length || bi < bMut.length) {
+    const aComp = aMut[ai];
+    const bComp = bMut[bi];
+
+    // If a inserts, it goes into aPrime and bPrime retains over it
+    if (aComp && aComp.type === 'insert') {
+      aPrime.push({ type: 'insert', text: aComp.text });
+      bPrime.push({ type: 'retain', count: aComp.text.length });
+      ai++;
+      continue;
+    }
+
+    // If b inserts, it goes into bPrime and aPrime retains over it
+    if (bComp && bComp.type === 'insert') {
+      bPrime.push({ type: 'insert', text: bComp.text });
+      aPrime.push({ type: 'retain', count: bComp.text.length });
+      bi++;
+      continue;
+    }
+
+    if (!aComp || !bComp) {
+      // One side exhausted but the other has non-insert components left
+      // This means the operations don't match the same input length
+      if (aComp || bComp) {
+        throw new Error('Transform: operations have mismatched input lengths');
+      }
+      break;
+    }
+
+    // Both are retain or delete
+    const aLen = compLength(aComp);
+    const bLen = compLength(bComp);
+    const minLen = Math.min(aLen, bLen);
+
+    if (aComp.type === 'retain' && bComp.type === 'retain') {
+      aPrime.push({ type: 'retain', count: minLen });
+      bPrime.push({ type: 'retain', count: minLen });
+    } else if (aComp.type === 'delete' && bComp.type === 'delete') {
+      // Both delete the same region — neither needs to do anything
+    } else if (aComp.type === 'delete' && bComp.type === 'retain') {
+      aPrime.push({ type: 'delete', count: minLen });
+      // b doesn't need to retain these chars because a deleted them
+    } else if (aComp.type === 'retain' && bComp.type === 'delete') {
+      bPrime.push({ type: 'delete', count: minLen });
+      // a doesn't need to retain these chars because b deleted them
+    }
+
+    // Shrink the larger component by minLen
+    if (aLen > minLen) {
+      shrinkComp(aMut, ai, minLen);
+    } else {
+      ai++;
+    }
+    if (bLen > minLen) {
+      shrinkComp(bMut, bi, minLen);
+    } else {
+      bi++;
+    }
+  }
+
+  return [
+    { docId: a.docId, version: a.version, components: mergeComponents(aPrime), clientId: a.clientId },
+    { docId: b.docId, version: b.version, components: mergeComponents(bPrime), clientId: b.clientId },
+  ];
+}
+
+/**
+ * Compose two sequential operations into a single operation.
+ * compose(a, b) returns op c such that apply(doc, c) === apply(apply(doc, a), b).
+ */
+export function compose(a: Operation, b: Operation): Operation {
+  const aComps = normalizeComponents(a.components);
+  const bComps = normalizeComponents(b.components);
+
+  const result: Component[] = [];
+  let ai = 0;
+  let bi = 0;
+
+  const aMut = aComps.map(cloneComp);
+  const bMut = bComps.map(cloneComp);
+
+  while (ai < aMut.length || bi < bMut.length) {
+    const aComp = aMut[ai];
+    const bComp = bMut[bi];
+
+    // a deletes: passes through directly (consumes input, doesn't produce output for b)
+    if (aComp && aComp.type === 'delete') {
+      result.push({ type: 'delete', count: aComp.count });
+      ai++;
+      continue;
+    }
+
+    // b inserts: passes through directly (doesn't consume a's output)
+    if (bComp && bComp.type === 'insert') {
+      result.push({ type: 'insert', text: bComp.text });
+      bi++;
+      continue;
+    }
+
+    if (!aComp || !bComp) {
+      if (aComp || bComp) {
+        throw new Error('Compose: mismatched operation lengths');
+      }
+      break;
+    }
+
+    // a=retain, b=retain
+    if (aComp.type === 'retain' && bComp.type === 'retain') {
+      const minLen = Math.min(aComp.count, bComp.count);
+      result.push({ type: 'retain', count: minLen });
+      if (aComp.count > minLen) shrinkComp(aMut, ai, minLen); else ai++;
+      if (bComp.count > minLen) shrinkComp(bMut, bi, minLen); else bi++;
+    }
+    // a=insert, b=retain
+    else if (aComp.type === 'insert' && bComp.type === 'retain') {
+      const minLen = Math.min(aComp.text.length, bComp.count);
+      result.push({ type: 'insert', text: aComp.text.slice(0, minLen) });
+      if (aComp.text.length > minLen) {
+        aMut[ai] = { type: 'insert', text: aComp.text.slice(minLen) };
+      } else {
+        ai++;
+      }
+      if (bComp.count > minLen) shrinkComp(bMut, bi, minLen); else bi++;
+    }
+    // a=retain, b=delete
+    else if (aComp.type === 'retain' && bComp.type === 'delete') {
+      const minLen = Math.min(aComp.count, bComp.count);
+      result.push({ type: 'delete', count: minLen });
+      if (aComp.count > minLen) shrinkComp(aMut, ai, minLen); else ai++;
+      if (bComp.count > minLen) shrinkComp(bMut, bi, minLen); else bi++;
+    }
+    // a=insert, b=delete
+    else if (aComp.type === 'insert' && bComp.type === 'delete') {
+      const minLen = Math.min(aComp.text.length, bComp.count);
+      // Insert then delete cancel out
+      if (aComp.text.length > minLen) {
+        aMut[ai] = { type: 'insert', text: aComp.text.slice(minLen) };
+      } else {
+        ai++;
+      }
+      if (bComp.count > minLen) shrinkComp(bMut, bi, minLen); else bi++;
+    }
+  }
+
+  return {
+    docId: a.docId,
+    version: a.version,
+    components: mergeComponents(result),
+    clientId: a.clientId,
+  };
+}
+
+// ---- Helpers ----
+
+function compsInputLength(comps: Component[]): number {
+  let len = 0;
+  for (const c of comps) {
+    if (c.type === 'retain') len += c.count;
+    else if (c.type === 'delete') len += c.count;
+  }
+  return len;
+}
+
+function cloneComp(c: Component): Component {
+  if (c.type === 'insert') return { type: 'insert', text: c.text };
+  if (c.type === 'retain') return { type: 'retain', count: c.count };
+  return { type: 'delete', count: c.count };
+}
+
+function compLength(c: Component): number {
+  if (c.type === 'insert') return c.text.length;
+  if (c.type === 'retain') return c.count;
+  return c.count;
+}
+
+function shrinkComp(arr: Component[], idx: number, by: number): void {
+  const c = arr[idx];
+  if (c.type === 'insert') {
+    arr[idx] = { type: 'insert', text: c.text.slice(by) };
+  } else if (c.type === 'retain') {
+    arr[idx] = { type: 'retain', count: c.count - by };
+  } else {
+    arr[idx] = { type: 'delete', count: c.count - by };
+  }
+}
+
+/** Filter out zero-length components. */
+function normalizeComponents(comps: Component[]): Component[] {
+  return comps.filter(c => {
+    if (c.type === 'insert') return c.text.length > 0;
+    return (c as { count: number }).count > 0;
+  });
+}
+
+/** Merge adjacent components of the same type. */
+function mergeComponents(comps: Component[]): Component[] {
+  const result: Component[] = [];
+  for (const c of comps) {
+    if (c.type === 'insert' && c.text.length === 0) continue;
+    if ((c.type === 'retain' || c.type === 'delete') && c.count === 0) continue;
+
+    const last = result[result.length - 1];
+    if (last && last.type === c.type) {
+      if (last.type === 'insert' && c.type === 'insert') {
+        last.text += c.text;
+      } else if (last.type === 'retain' && c.type === 'retain') {
+        last.count += c.count;
+      } else if (last.type === 'delete' && c.type === 'delete') {
+        last.count += c.count;
+      }
+    } else {
+      result.push(cloneComp(c));
+    }
+  }
+  return result;
+}
