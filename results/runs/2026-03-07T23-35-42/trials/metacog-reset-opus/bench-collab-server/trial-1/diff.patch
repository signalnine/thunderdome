d).toBeDefined();\n  });\n\n  it('should list documents', async () => {\n    await api('POST', '/documents', { title: 'Doc 1' });\n    await api('POST', '/documents', { title: 'Doc 2' });\n    const { body } = await api('GET', '/documents');\n    expect(body.length).toBe(2);\n  });\n\n  it('should get a document by id', async () => {\n    const created = await api('POST', '/documents', { title: 'My Doc', content: 'text' });\n    const { body } = await api('GET', `/documents/${created.body.id}`);\n    expect(body.title).toBe('My Doc');\n    expect(body.content).toBe('text');\n  });\n\n  it('should return 404 for missing document', async () => {\n    const { status } = await api('GET', '/documents/nonexistent');\n    expect(status).toBe(404);\n  });\n\n  it('should update a document', async () => {\n    const created = await api('POST', '/documents', { title: 'Original', content: 'old' });\n    const { body } = await api('PUT', `/documents/${created.body.id}`, { title: 'Updated', content: 'new' });\n    expect(body.title).toBe('Updated');\n    expect(body.content).toBe('new');\n  });\n\n  it('should delete a document', async () => {\n    const created = await api('POST', '/documents', { title: 'Delete Me' });\n    const { status } = await api('DELETE', `/documents/${created.body.id}`);\n    expect(status).toBe(204);\n    const { status: getStatus } = await api('GET', `/documents/${created.body.id}`);\n    expect(getStatus).toBe(404);\n  });\n\n  it('should return 400 for missing title', async () => {\n    const { status } = await api('POST', '/documents', {});\n    expect(status).toBe(400);\n  });\n\n  it('should get version history', async () => {\n    const created = await api('POST', '/documents', { title: 'Versioned', content: 'v0' });\n    const { body } = await api('GET', `/documents/${created.body.id}/versions`);\n    expect(body.length).toBe(1);\n    expect(body[0].version).toBe(0);\n    expect(body[0].content).toBe('v0');\n  });\n\n  it('should get a specific