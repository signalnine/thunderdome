\n          throw new Error(\n            `Delete overflows document: pos=${pos}, count=${comp.count}, docLen=${doc.length}`\n          );\n        }\n        pos += comp.count;\n        break;\n    }\n  }\n\n  // Any remaining characters are implicitly retained\n  result += doc.slice(pos);\n\n  return result;\n}\n\n/** Compute the input length an operation expects. */\nexport function inputLength(op: Operation): number {\n  let len = 0;\n  for (const comp of op.components) {\n    if (comp.type === 'retain') len += comp.count;\n    else if (comp.type === 'delete') len += comp.count;\n  }\n  return len;\n}\n\n/** Compute the output length an operation produces. */\nexport function outputLength(op: Operation): number {\n  let len = 0;\n  for (const comp of op.components) {\n    if (comp.type === 'retain') len += comp.count;\n    else if (comp.type === 'insert') len += comp.text.length;\n  }\n  return len;\n}\n\n/**\n * Transform two concurrent operations a and b (both based on the same document)\n * into a' and b' such that apply(apply(doc, a), b') === apply(apply(doc, b), a').\n *\n * Returns [aPrime, bPrime].\n */\nexport function transform(\n  a: Operation,\n  b: Operation\n): [Operation, Operation] {\n  const aComps = normalizeComponents(a.components);\n  const bComps = normalizeComponents(b.components);\n\n  const aPrime: Component[] = [];\n  const bPrime: Component[] = [];\n\n  let ai = 0;\n  let bi = 0;\n\n  // Mutable copies for splitting\n  const aMut = aComps.map(cloneComp);\n  const bMut = bComps.map(cloneComp);\n\n  while (ai < aMut.length || bi < bMut.length) {\n    const aComp = aMut[ai];\n    const bComp = bMut[bi];\n\n    // If a inserts, it goes into aPrime and bPrime retains over it\n    if (aComp && aComp.type === 'insert') {\n      aPrime.push({ type: 'insert', text: aComp.text });\n      bPrime.push({ type: 'retain', count: aComp.text.length });\n      ai++;\n      continue;\n    }\n\n    // If b inserts, it goes into bPrime and aPrime retains ove