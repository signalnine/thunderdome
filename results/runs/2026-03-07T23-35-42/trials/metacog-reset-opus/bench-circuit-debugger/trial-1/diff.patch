+      }
+    }
+  }
+
+  // Rule: AND gate outputs (except the one for bit 0) should feed into OR gates only.
+  // If an AND gate's output feeds into something other than OR, it's swapped.
+  for (const g of gates) {
+    if (g.op === 'AND') {
+      const isHalfAdderAnd =
+        (g.in1 === 'x00' && g.in2 === 'y00') ||
+        (g.in1 === 'y00' && g.in2 === 'x00');
+      if (isHalfAdderAnd) continue;
+
+      // Check what gates consume this output
+      for (const consumer of gates) {
+        if (consumer.in1 === g.out || consumer.in2 === g.out) {
+          if (consumer.op !== 'OR') {
+            swapped.add(g.out);
+          }
+        }
+      }
+    }
+  }
+
+  // Rule: XOR gates whose inputs are xNN/yNN (first-level XOR, producing partial sum)
+  // should only feed into XOR and AND gates, never OR.
+  for (const g of gates) {
+    if (g.op === 'XOR') {
+      const isInputXor =
+        (g.in1.startsWith('x') && g.in2.startsWith('y')) ||
+        (g.in1.startsWith('y') && g.in2.startsWith('x'));
+      if (!isInputXor) continue;
+
+      for (const consumer of gates) {
+        if (consumer.in1 === g.out || consumer.in2 === g.out) {
+          if (consumer.op === 'OR') {
+            swapped.add(g.out);
+          }
+        }
+      }
