+
+  // Rule: XOR gate outputs that are not z-wires and whose inputs are not x/y
+  // are wrong (in a correct adder, the second XOR always outputs to z)
+  for (const g of gates) {
+    if (g.op === 'XOR') {
+      const isInputXor =
+        (g.in1.startsWith('x') && g.in2.startsWith('y')) ||
+        (g.in1.startsWith('y') && g.in2.startsWith('x'));
+      if (!isInputXor && !g.out.startsWith('z')) {
