+      const yi = `y${String(i).padStart(2, '0')}`;
+      const zi = `z${String(i).padStart(2, '0')}`;
+
+      // Find the first XOR for this bit (xN XOR yN)
+      const xorInput = findGate('XOR', xi, yi);
+      if (!xorInput) continue;
+
+      // Find the AND for this bit (xN AND yN)
+      const andInput = findGate('AND', xi, yi);
+      if (!andInput) continue;
+
+      // The z output gate should be a XOR gate
+      const zGate = gateByOutput.get(zi);
+      if (!zGate) continue;
+
+      if (zGate.op === 'XOR') {
+        // z gate is correct type. Check if xorInput.out is one of its inputs
+        if (zGate.in1 !== xorInput.out && zGate.in2 !== xorInput.out) {
+          // The partial sum wire isn't feeding into the z gate - something is swapped
+          // The other input of zGate should be the carry-in
+          // xorInput.out should have been swapped with something
+        }
+      }
+    }
+  }
+
+  return [...swapped].sort();
+}
