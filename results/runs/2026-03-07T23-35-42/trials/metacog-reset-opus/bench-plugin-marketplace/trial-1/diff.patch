ser('user1')).toHaveLength(2);\n    expect(reviews.getReviewsByUser('user2')).toHaveLength(1);\n  });\n\n  it('gets review count', () => {\n    reviews.addReview({\n      pluginName: 'a',\n      pluginVersion: '1.0.0',\n      userId: 'user1',\n      rating: 5,\n      comment: '',\n    });\n    reviews.addReview({\n      pluginName: 'a',\n      pluginVersion: '1.0.0',\n      userId: 'user2',\n      rating: 4,\n      comment: '',\n    });\n    expect(reviews.getReviewCount('a')).toBe(2);\n    expect(reviews.getReviewCount('b')).toBe(0);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":387,"cache_read_input_tokens":29891,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":387},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"0bf1db29-f1e9-4140-be47-0158273a19c4","uuid":"e4e70434-33b0-4293-851b-0d6cbec1f9d5"}
