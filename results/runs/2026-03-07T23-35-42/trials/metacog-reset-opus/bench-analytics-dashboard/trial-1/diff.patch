@@ -0,0 +1,162 @@
+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { authenticate, AuthRequest } from "../middleware/auth.js";
+
+interface EventRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string | null;
+  session_id: string | null;
+}
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+interface WidgetRow {
+  id: string;
+  dashboard_id: string;
+  type: string;
+  config: string;
+  position_x: number;
+  position_y: number;
+  width: number;
+  height: number;
+}
+
+function eventsToCsv(events: EventRow[]): string {
+  const header = "id,tenant_id,name,properties,timestamp,user_id,session_id";
+  const rows = events.map(e => {
+    const props = e.properties.replace(/"/g, '""');
+    return `${e.id},${e.tenant_id},${e.name},"${props}",${e.timestamp},${e.user_id || ""},${e.session_id || ""}`;
+  });
+  return [header, ...rows].join("\n");
+}
+
+function dashboardsToCsv(dashboards: DashboardRow[]): string {
+  const header = "id,tenant_id,name,owner_id,config,created_at,updated_at";
+  const rows = dashboards.map(d => {
+    const config = d.config.replace(/"/g, '""');
+    return `${d.id},${d.tenant_id},${d.name},${d.owner_id},"${config}",${d.created_at},${d.updated_at}`;
+  });
+  return [header, ...rows].join("\n");
+}
+
+export function createExportRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Export events as JSON
+  router.get("/events/json", authenticate, (req: AuthRequest, res: Response) => {
+    const tenantId = req.user!.tenantId;
+
+    let sql = "SELECT id, tenant_id, name, properties, timestamp, user_id, session_id FROM events WHERE tenant_id = ?";
+    const params: string[] = [tenantId];
+
+    if (req.query.eventName) {
+      sql += " AND name = ?";
+      params.push(req.query.eventName as string);
+    }
+
+    if (req.query.startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(req.query.startDate as string);
+    }
+
+    if (req.query.endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(req.query.endDate as string);
+    }
+
+    sql += " ORDER BY timestamp DESC";
+
+    const events = db.prepare(sql).all(...params) as EventRow[];
+    const parsed = events.map(e => ({
+      ...e,
+      properties: JSON.parse(e.properties)
+    }));
+
+    res.setHeader("Content-Type", "application/json");
+    res.setHeader("Content-Disposition", "attachment; filename=events.json");
+    res.json(parsed);
+  });
+
+  // Export events as CSV
+  router.get("/events/csv", authenticate, (req: AuthRequest, res: Response) => {
+    const tenantId = req.user!.tenantId;
+
+    let sql = "SELECT id, tenant_id, name, properties, timestamp, user_id, session_id FROM events WHERE tenant_id = ?";
+    const params: string[] = [tenantId];
+
+    if (req.query.eventName) {
+      sql += " AND name = ?";
+      params.push(req.query.eventName as string);
+    }
+
+    if (req.query.startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(req.query.startDate as string);
+    }
+
+    if (req.query.endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(req.query.endDate as string);
+    }
+
+    sql += " ORDER BY timestamp DESC";
+
+    const events = db.prepare(sql).all(...params) as EventRow[];
+
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader("Content-Disposition", "attachment; filename=events.csv");
+    res.send(eventsToCsv(events));
+  });
+
+  // Export dashboards as JSON
+  router.get("/dashboards/json", authenticate, (req: AuthRequest, res: Response) => {
+    const tenantId = req.user!.tenantId;
+
+    const dashboards = db.prepare(
+      "SELECT id, tenant_id, name, owner_id, config, created_at, updated_at FROM dashboards WHERE tenant_id = ?"
+    ).all(tenantId) as DashboardRow[];
+
+    const result = dashboards.map(d => {
+      const widgets = db.prepare(
+        "SELECT id, dashboard_id, type, config, position_x, position_y, width, height FROM widgets WHERE dashboard_id = ?"
+      ).all(d.id) as WidgetRow[];
+
+      return {
+        ...d,
+        config: JSON.parse(d.config),
+        widgets: widgets.map(w => ({ ...w, config: JSON.parse(w.config) }))
+      };
+    });
+
+    res.setHeader("Content-Type", "application/json");
+    res.setHeader("Content-Disposition", "attachment; filename=dashboards.json");
+    res.json(result);
+  });
+
+  // Export dashboards as CSV
+  router.get("/dashboards/csv", authenticate, (req: AuthRequest, res: Response) => {
+    const tenantId = req.user!.tenantId;
+
+    const dashboards = db.prepare(
+      "SELECT id, tenant_id, name, owner_id, config, created_at, updated_at FROM dashboards WHERE tenant_id = ?"
+    ).all(tenantId) as DashboardRow[];
+
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader("Content-Disposition", "attachment; filename=dashboards.csv");
+    res.send(dashboardsToCsv(dashboards));
+  });
+
+  return router;
+}
