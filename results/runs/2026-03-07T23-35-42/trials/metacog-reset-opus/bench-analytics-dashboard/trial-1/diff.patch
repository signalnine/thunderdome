NTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)\"\n    ).run(id, req.params.id, type, widgetConfig, positionX || 0, positionY || 0, width || 1, height || 1);\n\n    res.status(201).json({\n      id,\n      dashboardId: req.params.id,\n      type,\n      config: config || {},\n      positionX: positionX || 0,\n      positionY: positionY || 0,\n      width: width || 1,\n      height: height || 1\n    });\n  });\n\n  // Delete widget\n  router.delete(\"/:dashboardId/widgets/:widgetId\", authenticate, (req: AuthRequest, res: Response) => {\n    const tenantId = req.user!.tenantId;\n\n    const dashboard = db.prepare(\n      \"SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?\"\n    ).get(req.params.dashboardId, tenantId);\n\n    if (!dashboard) {\n      res.status(404).json({ error: \"Dashboard not found\" });\n      return;\n    }\n\n    const widget = db.prepare(\n      \"SELECT id FROM widgets WHERE id = ? AND dashboard_id = ?\"\n    ).get(req.params.widgetId, req.params.dashboardId);\n\n    if (!widget) {\n      res.status(404).json({ error: \"Widget not found\" });\n      return;\n    }\n\n    db.prepare(\"DELETE FROM widgets WHERE id = ?\").run(req.params.widgetId);\n\n    res.status(204).send();\n  });\n\n  return router;\n}\n","structuredPatch":[],"originalFile":null}}
