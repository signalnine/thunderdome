viewer, editor) is required\" });\n      return;\n    }\n\n    // Ensure the target user is in the same tenant\n    const targetUser = db.prepare(\n      \"SELECT id, tenant_id FROM users WHERE id = ?\"\n    ).get(userId) as { id: string; tenant_id: string } | undefined;\n\n    if (!targetUser || targetUser.tenant_id !== req.user!.tenantId) {\n      res.status(404).json({ error: \"User not found in your tenant\" });\n      return;\n    }\n\n    db.prepare(\"UPDATE users SET role = ? WHERE id = ?\").run(role, userId);\n\n    res.json({ userId, role });\n  });\n\n  return router;\n}\n","structuredPatch":[],"originalFile":null}}
