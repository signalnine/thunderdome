@@ -0,0 +1,143 @@
+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { authenticate, AuthRequest } from "../middleware/auth.js";
+
+export function createQueryRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Count events matching filters
+  router.post("/count", authenticate, (req: AuthRequest, res: Response) => {
+    const tenantId = req.user!.tenantId;
+    const { eventName, startDate, endDate, filters } = req.body;
+
+    let sql = "SELECT COUNT(*) as count FROM events WHERE tenant_id = ?";
+    const params: (string | number)[] = [tenantId];
+
+    if (eventName) {
+      sql += " AND name = ?";
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value as string);
+      }
+    }
+
+    const result = db.prepare(sql).get(...params) as { count: number };
+    res.json({ count: result.count });
+  });
+
+  // Timeseries query - bucket event counts over time
+  router.post("/timeseries", authenticate, (req: AuthRequest, res: Response) => {
+    const tenantId = req.user!.tenantId;
+    const { eventName, startDate, endDate, interval, filters } = req.body;
+
+    if (!interval || !["hour", "day", "week", "month"].includes(interval)) {
+      res.status(400).json({ error: "interval must be one of: hour, day, week, month" });
+      return;
+    }
+
+    let dateFormat: string;
+    switch (interval) {
+      case "hour":
+        dateFormat = "%Y-%m-%dT%H:00:00";
+        break;
+      case "day":
+        dateFormat = "%Y-%m-%d";
+        break;
+      case "week":
+        dateFormat = "%Y-W%W";
+        break;
+      case "month":
+        dateFormat = "%Y-%m";
+        break;
+      default:
+        dateFormat = "%Y-%m-%d";
+    }
+
+    let sql = `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: (string | number)[] = [tenantId];
+
+    if (eventName) {
+      sql += " AND name = ?";
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value as string);
+      }
+    }
+
+    sql += " GROUP BY bucket ORDER BY bucket";
+
+    const results = db.prepare(sql).all(...params) as { bucket: string; count: number }[];
+    res.json({ interval, data: results });
+  });
+
+  // Breakdown query - group event counts by a property value
+  router.post("/breakdown", authenticate, (req: AuthRequest, res: Response) => {
+    const tenantId = req.user!.tenantId;
+    const { eventName, property, startDate, endDate, filters } = req.body;
+
+    if (!property) {
+      res.status(400).json({ error: "property is required for breakdown queries" });
+      return;
+    }
+
+    let sql = `SELECT json_extract(properties, ?) as property_value, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: (string | number)[] = [`$.${property}`, tenantId];
+
+    if (eventName) {
+      sql += " AND name = ?";
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value as string);
+      }
+    }
+
+    sql += " GROUP BY property_value ORDER BY count DESC";
+
+    const results = db.prepare(sql).all(...params) as { property_value: string; count: number }[];
+    res.json({ property, data: results });
+  });
+
+  return router;
+}
diff --git a/src/routes/users.ts b/src/routes/users.ts
new file mode 100644
index 0000000..ea58c59
--- /dev/null
+++ b/src/routes/users.ts
@@ -0,0 +1,122 @@
+import { Router, Response } from "express";
+import { createHash } from "crypto";
+import jwt from "jsonwebtoken";
+import { v4 as uuidv4 } from "uuid";
+import Database from "better-sqlite3";
+import { authenticate, AuthRequest, JWT_SECRET } from "../middleware/auth.js";
+
+function hashPassword(password: string): string {
+  return createHash("sha256").update(password).digest("hex");
+}
+
+export function createUserRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Register
+  router.post("/register", (req: AuthRequest, res: Response) => {
+    const { email, password, tenantId } = req.body;
+
+    if (!email || !password || !tenantId) {
+      res.status(400).json({ error: "email, password, and tenantId are required" });
+      return;
+    }
+
+    const existing = db.prepare("SELECT id FROM users WHERE email = ?").get(email);
+    if (existing) {
+      res.status(409).json({ error: "Email already registered" });
+      return;
+    }
+
+    // First user in a tenant becomes admin
+    const tenantUsers = db.prepare("SELECT COUNT(*) as count FROM users WHERE tenant_id = ?").get(tenantId) as { count: number };
+    const role = tenantUsers.count === 0 ? "admin" : "viewer";
+
+    const id = uuidv4();
+    const passwordHash = hashPassword(password);
+
+    db.prepare(
+      "INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)"
+    ).run(id, email, passwordHash, tenantId, role);
+
+    const token = jwt.sign(
+      { userId: id, email, tenantId, role },
+      JWT_SECRET,
+      { expiresIn: "24h" }
+    );
+
+    res.status(201).json({ id, email, tenantId, role, token });
+  });
+
+  // Login
+  router.post("/login", (req: AuthRequest, res: Response) => {
+    const { email, password } = req.body;
+
+    if (!email || !password) {
+      res.status(400).json({ error: "email and password are required" });
+      return;
+    }
+
+    const user = db.prepare(
+      "SELECT id, email, password_hash, tenant_id, role FROM users WHERE email = ?"
+    ).get(email) as { id: string; email: string; password_hash: string; tenant_id: string; role: string } | undefined;
+
+    if (!user || user.password_hash !== hashPassword(password)) {
+      res.status(401).json({ error: "Invalid email or password" });
+      return;
+    }
+
+    const token = jwt.sign(
+      { userId: user.id, email: user.email, tenantId: user.tenant_id, role: user.role },
+      JWT_SECRET,
+      { expiresIn: "24h" }
+    );
+
+    res.json({ token, userId: user.id, email: user.email, tenantId: user.tenant_id, role: user.role });
+  });
+
+  // Get profile
+  router.get("/profile", authenticate, (req: AuthRequest, res: Response) => {
+    const user = db.prepare(
+      "SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?"
+    ).get(req.user!.userId) as { id: string; email: string; tenant_id: string; role: string; created_at: string } | undefined;
+
+    if (!user) {
+      res.status(404).json({ error: "User not found" });
+      return;
+    }
+
+    res.json(user);
+  });
+
+  // Change user role (admin only)
+  router.put("/users/:userId/role", authenticate, (req: AuthRequest, res: Response) => {
+    if (req.user!.role !== "admin") {
+      res.status(403).json({ error: "Admin access required" });
+      return;
+    }
+
+    const { role } = req.body;
+    const { userId } = req.params;
+
+    if (!role || !["admin", "viewer", "editor"].includes(role)) {
+      res.status(400).json({ error: "Valid role (admin, viewer, editor) is required" });
+      return;
+    }
+
+    // Ensure the target user is in the same tenant
+    const targetUser = db.prepare(
+      "SELECT id, tenant_id FROM users WHERE id = ?"
+    ).get(userId) as { id: string; tenant_id: string } | undefined;
+
+    if (!targetUser || targetUser.tenant_id !== req.user!.tenantId) {
+      res.status(404).json({ error: "User not found in your tenant" });
+      return;
+    }
+
+    db.prepare("UPDATE users SET role = ? WHERE id = ?").run(role, userId);
+
+    res.json({ userId, role });
+  });
+
+  return router;
+}
