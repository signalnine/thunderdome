d create a dashboard\", async () => {\n      const res = await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ name: \"My Dashboard\", config: { theme: \"dark\" } });\n\n      expect(res.status).toBe(201);\n      expect(res.body.name).toBe(\"My Dashboard\");\n      dashboardId = res.body.id;\n    });\n\n    it(\"should list dashboards\", async () => {\n      const res = await request(app)\n        .get(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body).toBeInstanceOf(Array);\n      expect(res.body.length).toBeGreaterThanOrEqual(1);\n    });\n\n    it(\"should get single dashboard\", async () => {\n      const res = await request(app)\n        .get(`/api/dashboards/${dashboardId}`)\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe(\"My Dashboard\");\n      expect(res.body.widgets).toBeInstanceOf(Array);\n    });\n\n    it(\"should update dashboard\", async () => {\n      const res = await request(app)\n        .put(`/api/dashboards/${dashboardId}`)\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ name: \"Updated Dashboard\" });\n\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe(\"Updated Dashboard\");\n    });\n\n    it(\"should add widget to dashboard\", async () => {\n      const res = await request(app)\n        .post(`/api/dashboards/${dashboardId}/widgets`)\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ type: \"counter\", config: { eventName: \"page_view\" }, positionX: 0, positionY: 0 });\n\n      expect(res.status).toBe(201);\n      expect(res.body.type).toBe(\"counter\");\n      widgetId = res.body.id;\n    });\n\n    it(\"should delete widget\", async () => {\n      const res = await request(app)\n        .delete(`/api/dashboards/${dashboardId}/widgets/${widgetId}`)\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n\n      expect(res.status).toBe(204);\n    });\n\n    it(\"should delete dashboard\", async () => {\n      const res = await request(app)\n        .delete(`/api/dashboards/${dashboardId}`)\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n\n      expect(res.status).toBe(204);\n    });\n\n    it(\"should return 404 for deleted dashboard\", async () => {\n      const res = await request(app)\n        .get(`/api/dashboards/${dashboardId}`)\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n\n      expect(res.status).toBe(404);\n    });\n  });\n\n  describe(\"Data Export\", () => {\n    it(\"should export events as JSON\", async () => {\n      const res = await request(app)\n        .get(\"/api/export/events/json\")\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n\n      expect(res.status).toBe(200);\n      expect(res.headers[\"content-type\"]).toContain(\"json\");\n      expect(res.body).toBeInstanceOf(Array);\n      expect(res.body.length).toBeGreaterThanOrEqual(1);\n    });\n\n    it(\"should export events as CSV\", async () => {\n      const res = await request(app)\n        .get(\"/api/export/events/csv\")\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n\n      expect(res.status).toBe(200);\n      expect(res.headers[\"content-type\"]).toContain(\"csv\");\n      expect(res.text).toContain(\"id,tenant_id,name\");\n    });\n\n    it(\"should export dashboards as JSON\", async () => {\n      // First create a dashboard for this test\n      await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ name: \"Export Test Dashboard\" });\n\n      const res = await request(app)\n        .get(\"/api/export/dashboards/json\")\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body).toBeInstanceOf(Array);\n    });\n\n    it(\"