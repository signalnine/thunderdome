   .send({ email: \"admin@test.com\", password: \"password123\" });\n\n      expect(res.status).toBe(200);\n      expect(res.body.token).toBeDefined();\n      adminToken = res.body.token;\n    });\n\n    it(\"should reject invalid login\", async () => {\n      const res = await request(app)\n        .post(\"/api/auth/login\")\n        .send({ email: \"admin@test.com\", password: \"wrong\" });\n\n      expect(res.status).toBe(401);\n    });\n\n    it(\"should get profile\", async () => {\n      const res = await request(app)\n        .get(\"/api/auth/profile\")\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body.email).toBe(\"admin@test.com\");\n      expect(res.body.role).toBe(\"admin\");\n    });\n\n    it(\"should return 401 without token\", async () => {\n      const res = await request(app).get(\"/api/auth/profile\");\n      expect(res.status).toBe(401);\n    });\n\n    it(\"should change user role (admin only)\", async () => {\n      const res = await request(app)\n        .put(`/api/auth/users/${viewerUserId}/role`)\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ role: \"editor\" });\n\n      expect(res.status).toBe(200);\n      expect(res.body.role).toBe(\"editor\");\n    });\n\n    it(\"should reject role change from non-admin\", async () => {\n      const res = await request(app)\n        .put(`/api/auth/users/${adminUserId}/role`)\n        .set(\"Authorization\", `Bearer ${viewerToken}`)\n        .send({ role: \"admin\" });\n\n      expect(res.status).toBe(403);\n    });\n  });\n\n  describe(\"Tenant Isolation\", () => {\n    let tenant2Token: string;\n\n    beforeAll(async () => {\n      const res = await request(app)\n        .post(\"/api/auth/register\")\n        .send({ email: \"other@tenant2.com\", password: \"password123\", tenantId: \"tenant-2\" });\n      tenant2Token = res.body.token;\n    });\n\n    it(\"should not see other tenant's events\", async () => {\n      // Ingest event to tenant-1\n      await request(app)\n        .post(\"/api/events\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ name: \"isolation_test\" });\n\n      // Query from tenant-2\n      const res = await request(app)\n        .post(\"/api/queries/count\")\n        .set(\"Authorization\", `Bearer ${tenant2Token}`)\n        .send({ eventName: \"isolation_test\" });\n\n      expect(res.body.count).toBe(0);\n    });\n  });\n\n  describe(\"Event Ingestion\", () => {\n    it(\"should ingest a single event\", async () => {\n      const res = await request(app)\n        .post(\"/api/events\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ name: \"page_view\", properties: { url: \"/home\", browser: \"Chrome\" } });\n\n      expect(res.status).toBe(201);\n      expect(res.body.name).toBe(\"page_view\");\n    });\n\n    it(\"should ingest batch events\", async () => {\n      const res = await request(app)\n        .post(\"/api/events/batch\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({\n          events: [\n            { name: \"page_view\", properties: { url: \"/about\" } },\n            { name: \"page_view\", properties: { url: \"/contact\" } },\n            { name: \"click\", properties: { button: \"signup\" } },\n          ]\n        });\n\n      expect(res.status).toBe(201);\n      expect(res.body.inserted).toBe(3);\n    });\n\n    it(\"should require auth for event ingestion\", async () => {\n      const res = await request(app)\n        .post(\"/api/events\")\n        .send({ name: \"page_view\" });\n\n      expect(res.status).toBe(401);\n    });\n  });\n\n  describe(\"Query Engine\", () => {\n    it(\"should count events\", async () => {\n      const res = await request(app)\n        .post(\"/api/queries/count\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ eventName: \"page_view\" });\n\n      expect(res.status).toBe(200);\n      e