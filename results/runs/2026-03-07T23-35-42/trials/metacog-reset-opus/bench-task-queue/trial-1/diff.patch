+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_018X28byx9epGwzUZKiJ28TB","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01LmpEPEaYZobdVuhSQFVzhF","name":"Write","input":{"file_path":"/workspace/src/TaskQueue.ts","content":"import { randomUUID } from 'node:crypto';\nimport {\n  Task,\n  TaskStatus,\n  TaskOptions,\n  QueueOptions,\n  ProgressListener,\n  MiddlewareFn,\n  HandlerFn,\n  Schedule,\n  ShutdownResult,\n} from './types.js';\nimport { parseCron, shouldRun, CronFields } from './cron.js';\n\nconst DEFAULT_QUEUE = 'default';\n\ninterface InternalQueue {\n  name: string;\n  concurrency: number | null;\n  activeCount: number;\n  middlewares: MiddlewareFn[];\n  handler: HandlerFn | null;\n}\n\ninterface InternalSchedule {\n  id: string;\n  cron: string;\n  fields: CronFields;\n  queue: string;\n  payload: unknown;\n  options?: Omit<TaskOptions, 'queue' | 'dependencies' | 'delay' | 'availableAt'>;\n  lastRun?: Date;\n  active: boolean;\n}\n\nexport class TaskQueue {\n  private tasks: Map<string, Task> = new Map();\n  private queues: Map<string, InternalQueue> = new Map();\n  private deadLetterQueues: Map<string, Task[]> = new Map();\n  private progressListeners: Map<string, Set<ProgressListener>> = new Map();\n  private schedules: Map<string, InternalSchedule> = new Map();\n  private isShutdown = false;\n  private shutdownPromise: Promise<ShutdownResult> | null = null;\n  private shutdownCallbacks: (() => void | Promise<void>)[] = [];\n\n  // ─── Phase 1: Basic FIFO Queue ─────────────────────────────────\n\n  addTask<T = unknown>(payload: T, options?: TaskOptions): Task<T> {\n    if (this.isShutdown) {\n      throw new Error('Queue system is shut down; cannot add new tasks');\n    }\n\n    const queueName = options?.queue ?? DEFAULT_QUEUE;\n    const priority = options?.priority ?? 5;\n\n    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    }\n\n    // Validate dependencies exist and check for circular deps\n    const dependencies = options?.dependencies ?? [];\n    for (const depId of dependencies) {\n      if (!this.tasks.has(depId)) {\n        throw new Error(`Dependency task \"${depId}\" does not exist`);\n      }\n    }\n    if (dependencies.length > 0) {\n      // We'll do circular check after creating the task ID\n    }\n\n    const now = new Date();\n    let availableAt = now;\n    if (options?.availableAt) {\n      availableAt = options.availableAt;\n    } else if (options?.delay != null && options.delay > 0) {\n      availableAt = new Date(now.getTime() + options.delay);\n    }\n\n    const resolvedDependencies = new Set<string>();\n    for (const depId of dependencies) {\n      const dep = this.tasks.get(depId)!;\n      if (dep.status === 'completed') {\n        resolvedDependencies.add(depId);\n      }\n    }\n\n    const hasUnresolvedDeps = dependencies.length > 0 && resolvedDependencies.size < dependencies.length;\n\n    const task: Task<T> = {\n      id: randomUUID(),\n      payload,\n      status: hasUnresolvedDeps ? 'blocked' : 'pending',\n      priority,\n      queue: queueName,\n      createdAt: now,\n      updatedAt: now,\n      availableAt,\n      attempt: 0,\n      maxRetries: options?.maxRetries ?? 3,\n      backoffDelay: options?.backoffDelay ?? 1000,\n      dependencies: [...dependencies],\n      resolvedDependencies,\n      progress: 0,\n      metadata: {},\n    };\n\n    // Check for circular dependencies\n    if (dependencies.length > 0) {\n      this.tasks.set(task.id, task);\n      if (this.hasCircularDependency(task.id)) {\n        this.tasks.delete(task.id);\n        throw new Error(`Circular dependency detected for task \"${task.id}\"`);\n      }\n    } else {\n      this.tasks.set(task.id, task);\n    }\n\n    this.ensureQueue(queueName);\n    return task;\n  }\n\n  getNextTask(queueName?: string): Task | null {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const queue = this.queues.get(name);\n    if (!queue) return null;\n\n    // Check concurrency limit\n    if (queue.concurrency !== null && queue.activeCount >= queue.concurrency) {\n      return null;\n    }\n\n    const now = new Date();\n    const candidates: Task[] = [];\n\n    for (const task of this.tasks.values()) {\n      if (\n        task.queue === name &&\n        task.status === 'pending' &&\n        task.availableAt <= now\n      ) {\n        candidates.push(task);\n      }\n    }\n\n    if (candidates.length === 0) return null;\n\n    // Sort by priority (lower = higher priority), then by availableAt, then by createdAt (FIFO)\n    candidates.sort((a, b) => {\n      if (a.priority !== b.priority) return a.priority - b.priority;\n      const availDiff = a.availableAt.getTime() - b.availableAt.getTime();\n      if (availDiff !== 0) return availDiff;\n      return a.createdAt.getTime() - b.createdAt.getTime();\n    });\n\n    const task = candidates[0];\n    task.status = 'processing';\n    task.attempt++;\n    task.updatedAt = new Date();\n\n    queue.activeCount++;\n\n    return task;\n  }\n\n  pendingCount(queueName?: string): number {\n    const name = queueName ?? DEFAULT_QUEUE;\n    let count = 0;\n    for (const task of this.tasks.values()) {\n      if (task.queue === name && task.status === 'pending') {\n        count++;\n      }\n    }\n    return count;\n  }\n\n  // ─── Phase 2: Named Queues ─────────────────────────────────────\n\n  getQueueNames(): string[] {\n    return [...this.queues.keys()];\n  }\n\n  // ─── Phase 5: Task Lifecycle ───────────────────────────────────\n\n  completeTask(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task \"${taskId}\" not found`);\n    if (task.status !== 'processing') {\n      throw new Error(`Task \"${taskId}\" is not in processing state (current: ${task.status})`);\n    }\n\n    task.status = 'completed';\n    task.progress = 100;\n    task.updatedAt = new Date();\n\n    const queue = this.queues.get(task.queue);\n    if (queue) {\n      queue.activeCount = Math.max(0, queue.activeCount - 1);\n    }\n\n    // Check dependent tasks\n    this.resolveDependents(taskId);\n  }\n\n  failTask(taskId: string, error?: Error | string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task \"${taskId}\" not found`);\n    if (task.status !== 'processing') {\n      throw new Error(`Task \"${taskId}\" is not in processing state (current: ${task.status})`);\n    }\n\n    task.error = error;\n    task.updatedAt = new Date();\n\n    const queue = this.queues.get(task.queue);\n    if (queue) {\n      queue.activeCount = Math.max(0, queue.activeCount - 1);\n    }\n\n    // Check if retries are available\n    if (task.attempt < task.maxRetries) {\n      // Re-queue with backoff\n      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);\n      task.status = 'pending';\n      task.availableAt = new Date(Date.now() + delay);\n      // Keep same queue and priority\n    } else {\n      // Exhausted retries -> dead letter queue\n      task.status = 'failed';\n      this.addToDeadLetterQueue(task);\n    }\n  }\n\n  // ─── Phase 6: Dead Letter Queue ────────────────────────────────\n\n  getDeadLetterTasks(queueName?: string): Task[] {\n    const name = queueName ?? DEFAULT_QUEUE;\n    return [...(this.deadLetterQueues.get(name) ?? [])];\n  }\n\n  reprocessDeadLetterTask(taskId: string): Task {\n    // Find the task in a DLQ\n    for (const [queueName, dlq] of this.deadLetterQueues.entries()) {\n      const idx = dlq.findIndex((t) => t.id === taskId);\n      if (idx !== -1) {\n        const task = dlq.splice(idx, 1)[0];\n        // Reset for fresh round\n        task.status = 'pending';\n        task.attempt = 0;\n        task.error = undefined;\n        task.progress = 0;\n        task.availableAt = new Date();\n        task.updatedAt = new Date();\n        // It's already in this.tasks, just reset it\n        this.ensureQueue(queueName);\n        return task;\n      }\n    }\n    throw new Error(`Task \"${taskId}\" not found in any dead letter queue`);\n  }\n\n  clearDeadLetterQueue(queueName?: string): void {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const dlq = this.deadLetterQueues.get(name);\n    if (dlq) {\n      // Remove the tasks from main store too\n      for (const task of dlq) {\n        this.tasks.delete(task.id);\n      }\n      dlq.length = 0;\n    }\n  }\n\n  // ─── Phase 7: Task Dependencies ────────────────────────────────\n\n  getTaskDependencyStatus(taskId: string): {\n    dependencies: string[];\n    resolved: string[];\n    unresolved: string[];\n  } {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task \"${taskId}\" not found`);\n\n    const resolved = [...task.resolvedDependencies];\n    const unresolved = task.dependencies.filter(\n      (d) => !task.resolvedDependencies.has(d)\n    );\n\n    return {\n      dependencies: [...task.dependencies],\n      resolved,\n      unresolved,\n    };\n  }\n\n  // ─── Phase 8: Concurrency Control ──────────────────────────────\n\n  setQueueConcurrency(queueName: string, concurrency: number | null): void {\n    const queue = this.ensureQueue(queueName);\n    queue.concurrency = concurrency;\n  }\n\n  getQueueConcurrency(queueName?: string): { limit: number | null; active: number } {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const queue = this.queues.get(name);\n    if (!queue) return { limit: null, active: 0 };\n    return { limit: queue.concurrency, active: queue.activeCount };\n  }\n\n  // ─── Phase 9: Progress & Cancellation ──────────────────────────\n\n  reportProgress(taskId: string, progress: number, message?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task \"${taskId}\" not found`);\n    if (task.status !== 'processing') {\n      throw new Error(`Task \"${taskId}\" is not in processing state`);\n    }\n    if (progress < 0 || progress > 100) {\n      throw new Error(`Invalid progress value: ${progress}. Must be between 0 and 100.`);\n    }\n\n    task.progress = progress;\n    task.progressMessage = message;\n    task.updatedAt = new Date();\n\n    // Notify listeners\n    const listeners = this.progressListeners.get(taskId);\n    if (listeners) {\n      for (const listener of listeners) {\n        listener(progress, message);\n      }\n    }\n  }\n\n  getProgress(taskId: string): { progress: number; message?: string } {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task \"${taskId}\" not found`);\n    return { progress: task.progress, message: task.progressMessage };\n  }\n\n  onProgress(taskId: string, listener: ProgressListener): () => void {\n    if (!this.progressListeners.has(taskId)) {\n      this.progressListeners.set(taskId, new Set());\n    }\n    this.progressListeners.get(taskId)!.add(listener);\n\n    // Return unsubscribe function\n    return () => {\n      const listeners = this.progressListeners.get(taskId);\n      if (listeners) {\n        listeners.delete(listener);\n        if (listeners.size === 0) {\n          this.progressListeners.delete(taskId);\n        }\n      }\n    };\n  }\n\n  cancelTask(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task \"${taskId}\" not found`);\n\n    if (task.status !== 'pending' && task.status !== 'processing' && task.status !== 'blocked') {\n      throw new Error(\n        `Task \"${taskId}\" cannot be cancelled (current status: ${task.status})`\n      );\n    }\n\n    const wasProcessing = task.status === 'processing';\n    task.status = 'cancelled';\n    task.updatedAt = new Date();\n\n    if (wasProcessing) {\n      const queue = this.queues.get(task.queue);\n      if (queue) {\n        queue.activeCount = Math.max(0, queue.activeCount - 1);\n      }\n    }\n  }\n\n  // ─── Phase 10: 