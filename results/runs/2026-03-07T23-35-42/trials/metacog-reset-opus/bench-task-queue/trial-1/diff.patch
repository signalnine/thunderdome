--- /dev/null
+++ b/src/types.ts
@@ -0,0 +1,66 @@
+export type TaskStatus =
+  | 'pending'
+  | 'processing'
+  | 'completed'
+  | 'failed'
+  | 'cancelled'
+  | 'blocked';
+
+export interface Task<T = unknown> {
+  id: string;
+  payload: T;
+  status: TaskStatus;
+  priority: number;
+  queue: string;
+  createdAt: Date;
+  updatedAt: Date;
+  availableAt: Date;
+  attempt: number;
+  maxRetries: number;
+  backoffDelay: number;
+  error?: Error | string;
+  dependencies: string[];
+  resolvedDependencies: Set<string>;
+  progress: number;
+  progressMessage?: string;
+  metadata: Record<string, unknown>;
+}
+
+export interface TaskOptions {
+  priority?: number;
+  delay?: number;
+  availableAt?: Date;
+  maxRetries?: number;
+  backoffDelay?: number;
+  dependencies?: string[];
+  queue?: string;
+}
+
+export interface QueueOptions {
+  concurrency?: number;
+}
+
+export type ProgressListener = (progress: number, message?: string) => void;
+
+export type MiddlewareFn = (
+  task: Task,
+  next: () => Promise<void>
+) => Promise<void> | void;
+
+export type HandlerFn = (task: Task) => Promise<void> | void;
+
+export interface Schedule {
+  id: string;
+  cron: string;
+  queue: string;
+  payload: unknown;
+  options?: Omit<TaskOptions, 'queue' | 'dependencies' | 'delay' | 'availableAt'>;
+  lastRun?: Date;
+  active: boolean;
+}
+
+export interface ShutdownResult {
+  completed: number;
+  forceCancelled: number;
+  elapsed: number;
+}
