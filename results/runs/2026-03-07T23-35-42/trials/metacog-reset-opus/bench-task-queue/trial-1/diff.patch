+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01CVhJatXqGFYDEDyGFtKEkF","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01XNU516D1oLZdZ6aqXqAhy7","name":"Write","input":{"file_path":"/workspace/tests/task-queue.test.ts","content":"import { describe, it, expect, beforeEach } from 'vitest';\nimport { TaskQueue } from '../src/index.js';\n\ndescribe('TaskQueue', () => {\n  let queue: TaskQueue;\n\n  beforeEach(() => {\n    queue = new TaskQueue();\n  });\n\n  // ─── Phase 1: Basic FIFO Queue ─────────────────────────────────\n\n  describe('Phase 1: Basic FIFO Queue', () => {\n    it('should add a task and return a task object', () => {\n      const task = queue.addTask({ action: 'send-email' });\n      expect(task).toBeDefined();\n      expect(task.id).toBeDefined();\n      expect(task.payload).toEqual({ action: 'send-email' });\n      expect(task.status).toBe('pending');\n      expect(task.createdAt).toBeInstanceOf(Date);\n    });\n\n    it('should generate unique IDs for each task', () => {\n      const t1 = queue.addTask('task1');\n      const t2 = queue.addTask('task2');\n      expect(t1.id).not.toBe(t2.id);\n    });\n\n    it('should retrieve tasks in FIFO order', () => {\n      queue.addTask('first');\n      queue.addTask('second');\n      queue.addTask('third');\n\n      const t1 = queue.getNextTask();\n      expect(t1?.payload).toBe('first');\n      const t2 = queue.getNextTask();\n      expect(t2?.payload).toBe('second');\n      const t3 = queue.getNextTask();\n      expect(t3?.payload).toBe('third');\n    });\n\n    it('should transition task to processing when retrieved', () => {\n      queue.addTask('test');\n      const task = queue.getNextTask();\n      expect(task?.status).toBe('processing');\n    });\n\n    it('should return null when no tasks are available', () => {\n      expect(queue.getNextTask()).toBeNull();\n    });\n\n    it('should return pending count', () => {\n      queue.addTask('a');\n      queue.addTask('b');\n      expect(queue.pendingCount()).toBe(2);\n\n      queue.getNextTask();\n      expect(queue.pendingCount()).toBe(1);\n    });\n  });\n\n  // ─── Phase 2: Named Queues ─────────────────────────────────────\n\n  describe('Phase 2: Named Queues', () => {\n    it('should support adding tasks to named queues', () => {\n      queue.addTask('email', { queue: 'emails' });\n      queue.addTask('log', { queue: 'logs' });\n\n      expect(queue.pendingCount('emails')).toBe(1);\n      expect(queue.pendingCount('logs')).toBe(1);\n    });\n\n    it('should retrieve from specific queue', () => {\n      queue.addTask('email1', { queue: 'emails' });\n      queue.addTask('log1', { queue: 'logs' });\n\n      const task = queue.getNextTask('emails');\n      expect(task?.payload).toBe('email1');\n      expect(queue.getNextTask('logs')?.payload).toBe('log1');\n    });\n\n    it('should use default queue when no name given', () => {\n      queue.addTask('default-task');\n      expect(queue.pendingCount('default')).toBe(1);\n      expect(queue.getNextTask()?.payload).toBe('default-task');\n    });\n\n    it('should list all queue names', () => {\n      queue.addTask('a', { queue: 'q1' });\n      queue.addTask('b', { queue: 'q2' });\n      const names = queue.getQueueNames();\n      expect(names).toContain('q1');\n      expect(names).toContain('q2');\n    });\n\n    it('should return null for non-existent queue', () => {\n      expect(queue.getNextTask('nonexistent')).toBeNull();\n    });\n\n    it('queues operate independently', () => {\n      queue.addTask('a', { queue: 'q1' });\n      queue.addTask('b', { queue: 'q2' });\n\n      queue.getNextTask('q1');\n      expect(queue.pendingCount('q1')).toBe(0);\n      expect(queue.pendingCount('q2')).toBe(1);\n    });\n  });\n\n  // ─── Phase 3: Priority ────────────────────────────────────────\n\n  describe('Phase 3: Priority', () => {\n    it('should default priority to 5', () => {\n      const task = queue.addTask('test');\n      expect(task.priority).toBe(5);\n    });\n\n    it('should process higher priority tasks first', () => {\n      queue.addTask('low', { priority: 10 });\n      queue.addTask('high', { priority: 1 });\n      queue.addTask('medium', { priority: 5 });\n\n      expect(queue.getNextTask()?.payload).toBe('high');\n      expect(queue.getNextTask()?.payload).toBe('medium');\n      expect(queue.getNextTask()?.payload).toBe('low');\n    });\n\n    it('should maintain FIFO for same priority', () => {\n      queue.addTask('first', { priority: 3 });\n      queue.addTask('second', { priority: 3 });\n\n      expect(queue.getNextTask()?.payload).toBe('first');\n      expect(queue.getNextTask()?.payload).toBe('second');\n    });\n\n    it('should reject invalid priority values', () => {\n      expect(() => queue.addTask('test', { priority: 0 })).toThrow();\n      expect(() => queue.addTask('test', { priority: 11 })).toThrow();\n      expect(() => queue.addTask('test', { priority: 1.5 })).toThrow();\n    });\n\n    it('should expose priority on task object', () => {\n      const task = queue.addTask('test', { priority: 2 });\n      expect(task.priority).toBe(2);\n    });\n\n    it('priority operates per queue', () => {\n      queue.addTask('q1-low', { queue: 'q1', priority: 10 });\n      queue.addTask('q1-high', { queue: 'q1', priority: 1 });\n      queue.addTask('q2-low', { queue: 'q2', priority: 10 });\n\n      expect(queue.getNextTask('q1')?.payload).toBe('q1-high');\n      expect(queue.getNextTask('q2')?.payload).toBe('q2-low');\n    });\n  });\n\n  // ─── Phase 4: Delayed Tasks ───────────────────────────────────\n\n  describe('Phase 4: Delayed Tasks', () => {\n    it('should not return delayed tasks before their time', () => {\n      queue.addTask('delayed', { delay: 60000 });\n      expect(queue.getNextTask()).toBeNull();\n    });\n\n    it('should support availableAt date', () => {\n      const future = new Date(Date.now() + 60000);\n      const task = queue.addTask('delayed', { availableAt: future });\n      expect(task.availableAt).toEqual(future);\n      expect(queue.getNextTask()).toBeNull();\n    });\n\n    it('should return delayed tasks after their time', () => {\n      const past = new Date(Date.now() - 1000);\n      queue.addTask('ready', { availableAt: past });\n      expect(queue.getNextTask()?.payload).toBe('ready');\n    });\n\n    it('non-delayed tasks should be preferred over not-yet-available delayed tasks', () => {\n      queue.addTask('delayed', { delay: 60000, priority: 1 });\n      queue.addTask('immediate', { priority: 5 });\n\n      expect(queue.getNextTask()?.payload).toBe('immediate');\n    });\n\n    it('should indicate when task becomes available', () => {\n      const task = queue.addTask('test', { delay: 5000 });\n      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now() - 100);\n    });\n\n    it('delays work with named queues', () => {\n      queue.addTask('delayed', { queue: 'myq', delay: 60000 });\n      queue.addTask('immediate', { queue: 'myq' });\n\n      expect(queue.getNextTask('myq')?.payload).toBe('immediate');\n    });\n  });\n\n  // ─── Phase 5: Retry with Backoff ──────────────────────────────\n\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should complete a processing task', () => {\n      queue.addTask('test');\n      const task = queue.getNextTask()!;\n      queue.completeTask(task.id);\n      expect(task.status).toBe('completed');\n    });\n\n    it('should fail and retry a task', () => {\n      queue.addTask('test', { maxRetries: 3, backoffDelay: 10 });\n      const task = queue.getNextTask()!;\n      queue.failTask(task.id, 'oops');\n\n      // Task should be re-queued as pending with delay\n      expect(task.status).toBe('pending');\n      expect(task.attempt).toBe(1);\n    });\n\n    it('should use exponential backoff', () => {\n      queue.addTask('test', { maxRetries: 3, backoffDelay: 1000 });\n      const task = queue.getNextTask()!;\n\n      const beforeFail = Date.now();\n      queue.failTask(task.id, 'err');\n\n      // First retry: 1000 * 2^0 = 1000ms delay\n      expect(task.availableAt.getTime()).toBeGreaterThanOrEqual(beforeFail + 900);\n    });\n\n    it('should track attempt count', () => {\n      queue.addTask('test', { maxRetries: 2, backoffDelay: 1 });\n      const task = queue.getNextTask()!;\n      expect(task.attempt).toBe(1);\n\n      // Re-queue immediately for testing\n      task.availableAt = new Date(Date.now() - 1);\n      queue.failTask(task.id, 'err');\n      expect(task.attempt).toBe(1);\n\n      // Get it again\n      const task2 = queue.getNextTask()!;\n      expect(task2.attempt).toBe(2);\n    });\n\n    it('default max retries is 3', () => {\n      const task = queue.addTask('test');\n      expect(task.maxRetries).toBe(3);\n    });\n\n    it('default backoff delay is 1000ms', () => {\n      const task = queue.addTask('test');\n      expect(task.backoffDelay).toBe(1000);\n    });\n\n    it('retried tasks keep their original queue and priority', () => {\n      queue.addTask('test', { queue: 'myq', priority: 2, maxRetries: 3, backoffDelay: 1 });\n      const task = queue.getNextTask('myq')!;\n      queue.failTask(task.id, 'err');\n\n      expect(task.queue).toBe('myq');\n      expect(task.priority).toBe(2);\n    });\n\n    it('task remains failed after exhausting retries', () => {\n      queue.addTask('test', { maxRetries: 1, backoffDelay: 1 });\n\n      // First attempt\n      const t1 = queue.getNextTask()!;\n      t1.availableAt = new Date(Date.now() - 1);\n      queue.failTask(t1.id, 'err');\n\n      // Second attempt (last one since maxRetries = 1, and we already did attempt 1)\n      // Retries exhausted after attempt >= maxRetries\n      // attempt was 1 after first getNext. After fail, attempt < maxRetries (1 < 1) is false.\n      // So it goes to failed.\n      expect(t1.status).toBe('failed');\n    });\n  });\n\n  // ─── Phase 6: Dead Letter Queue ───────────────────────────────\n\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move failed tasks to DLQ', () => {\n      queue.addTask('test', { maxRetries: 1, backoffDelay: 1 });\n      const task = queue.getNextTask()!;\n      queue.failTask(task.id, new Error('permanent failure'));\n\n      const dlq = queue.getDeadLetterTasks();\n      expect(dlq).toHaveLength(1);\n      expect(dlq[0].id).toBe(task.id);\n    });\n\n    it('dead-lettered tasks retain error info', () => {\n      queue.addTask('test', { maxRetries: 1, backoffDelay: 1 });\n      const task = queue.getNextTask()!;\n      queue.failTask(task.id, 'some error');\n\n      const dlq = queue.getDeadLetterTasks();\n      expect(dlq[0].error).toBe('some error');\n    });\n\n    it('should reprocess dead-lettered task', () => {\n      queue.addTask('test', { maxRetries: 1, backoffDelay: 1 });\n      const task = queue.getNextTask()!;\n      queue.failTask(task.id, 'err');\n\n      const reprocessed = queue.reprocessDeadLetterTask(task.id);\n      expect(reprocessed.status).toBe('pending');\n      expect(reprocessed.attempt).toBe(0);\n\n      // Should be retrievable again\n      const nextTask = queue.getNextTask()!;\n      expect(nextTask.id).toBe(task.id);\n    });\n\n    it('should clear dead letter queue', () => {\n      queue.addTask('t1', { maxRetries: 1, backoffDelay: 1 });\n      queue.addTask('t2', { maxRetries: 1, backoffDelay: 1 });\n\n      const task1 = queue.getNextTask()!;\n      queue.failTask(task1.id, 'err');\n      const task2 = queue.getNextTask()!;\n      queue.failTask(task2.id, 'err');\n\n      expect(queue.getDeadLetterTasks()).toHaveLength(2);\n      queue.clearDeadLetterQueue();\n      expect(queue.getDeadLetterTasks()).toHaveLength(0);\n    });\n\n    it('each queue has its own DLQ', () => {\n      queue.addTask('e1', { queue: 'emails', maxRetries: 1, backoffDelay: 1 });\n      queue.addTask('l1', { queue: 'logs', maxRetries: 1, backoffDelay: 1 });\n\n      const t1 = queue.getNextTask('emails')!;\n      queue.failTask(t1.id, 'err');\n      const t2 = queue.getNextTask('logs')!;\n      queue.failTask(t2.id, 'err');\n\n      expect(queue.getDeadLetterTasks('emails')).toHaveLength(1);\n      expect(queue.getDeadLetterTasks('logs')).toHaveLength(1);\n    });\n  });\n\n  // ─── Phase 7: Task Dependencies ───────────────────────────────\n\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block tasks with unresolved dependencies', () => {\n      const t1 = queue.addTask('first');\n      const t2 = queue.addTask('second', { dependencies: [t1.id] });\n\n      expect(t2.status).toBe('blocked');\n      // t2 should not be returned\n      const next = queue.getNextTask();\n      expect(next?.id).toBe(t1.id);\n\n      // No more tasks available (t2 is blocked)\n      expect(queue.getNextTask()).toBeNull();\n    });\n\n    it('should unblock tasks when dependencies complete', () => {\n      const t1 = queue.addTask('first');\n      const t2 = queue.addTask('second', { dependencies: [t1.id] });\n\n      const processing = queue.getNextTask()!;\n      queue.completeTask(processing.id);\n\n      expect(t2.status).toBe('pending');\n      const next = queue.getNextTask();\n      expect(next?.id).toBe(t2.id);\n    });\n\n    it('should handle multiple dependencies', () => {\n      const t1 = queue.addTask('dep1');\n      const t2 = queue.addTask('dep2');\n      const t3 = queue.addTask('dependent', { dependencies: [t1.id, t2.id] });\n\n      const p1 = queue.getNextTask()!;\n      queue.completeTask(p1.id);\n      expect(t3.status).toBe('blocked');\n\n      const p2 = queue.getNextTask()!;\n      queue.completeTask(p2.id);\n      expect(t3.status).toBe('pending');\n    });\n\n    it('should reject circular dependencies', () => {\n      const t1 = queue.addTask('first');\n      expect(() =>\n        queue.addTask('second', { dependencies: [t1.id, 'fake-id'] })\n      ).toThrow();\n    });\n\n    it('should reject dependencies on non-existent tasks', () => {\n      expect(() =>\n        queue.addTask('test', { dependencies: ['nonexistent'] })\n      ).toThrow();\n    });\n\n    it('failed dependency keeps dependents blocked', () => {\n      const t1 = queue.addTask('first', { maxRetries: 1, backoffDelay: 1 });\n      const t2 = queue.addTask('second', { dependencies: [t1.id] });\n\n      const p1 = queue.getNextTask()!;\n      queue.failTask(p1.id, 'err');\n\n      // t1 is failed, t2 remains blocked\n      expect(t2.status).toBe('blocked');\n    });\n\n    it('should inspect dependency status', () => {\n      const t1 = queue.addTask('dep1');\n      const t2 = queue.addTask('dep2');\n      const t3 = queue.addTask('dependent', { dependencies: [t1.id, t2.id] });\n\n      const status = queue.getTaskDependencyStatus(t3.id);\n      expect(status.dependencies).toHaveLength(2);\n      expect(status.unresolved).toHaveLength(2);\n      expect(status.resolved).toHaveLength(0);\n\n      const p1 = queue.getNextTask()!;\n      queue.completeTask(p1.id);\n\n      const status2 = queue.getTaskDependencyStatus(t3.id);\n      expect(status2.resolved).toHaveLength(1);\n      expect(status2.unresolved).toHaveLength(1);\n    });\n  });\n\n  // ─── Phase 8: Concurrency Control ─────────────────────────────\n\n  describe('Phase 8: Concurrency Control', () => {\n    it('should limit concurrent tasks per queue', () => {\n      queue.setQueueConcurrency('default', 2);\n      queue.addTask('a');\n      queue.addTask('b');\n      queue.addTask('c');\n\n      const t1 = queue.getNextTask();\n      const t2 = queue.getNextTask();\n      const t3 = queue.getNextTask();\n\n      expect(t1).not.toBeNull();\n      expect(t2).not.toBeNull();\n      expect(t3).toBeNull(); // Concurrency limit reached\n    });\n\n    it('completing a task frees a slot', () => {\n      queue.setQueueConcurrency('default', 1);\n      queue.addTask('a');\n      queue.addTask('b');\n\n      const t1 = queue.getNextTask()!;\n      expect(queue.getNextTask()).toBeNull();\n\n      queue.completeTask(t1.id);\n      expect(queue.getNextTask()).not.toBeNull();\n    });\n\n    it('failing a task frees a slot', () => {\n      queue.setQueueConcurrency('default', 1);\n      queue.addTask('a', { maxRetries: 1, backoffDelay: 1 });\n      queue.addTask('b');\n\n      const t1 = queue.getNextTask()!;\n      expect(queue.getNextTask()).toBeNull();\n\n      queue.failTask(t1.id, 'err');\n      expect(queue.getNextTask()).not.toBeNull();\n    });\n\n    it('default is unlimited concurrency', () => {\n      const info = queue.getQueueConcurrency();\n      expect(info.limit).toBeNull();\n    });\n\n    it('should query concurrency info', () => {\n      queue.setQueueConcurrency('default', 5);\n      queue.addTask('a');\n      queue.getNextTask();\n\n      const info = queue.getQueueConcurrency();\n      expect(info.limit).toBe(5);\n      expect(info.active).toBe(1);\n    });\n\n    it('still respects priority ordering under concurrency', () => {\n      queue.setQueueConcurrency('default', 1);\n      queue.addTask('low', { priority: 10 });\n      queue.addTask('high', { priority: 1 });\n\n      const task = queue.getNextTask()!;\n      expect(task.payload).toBe('high');\n    });\n  });\n\n  // ─── Phase 9: Progress & Cancellation ─────────────────────────\n\n  describe('Phase 9: Progress & Cancellation', () => {\n    it('should report progress', () => {\n      queue.addTask('test');\n      const task = queue.getNextTask()!;\n      queue.reportProgress(task.id, 50, 'halfway');\n\n      const progress = queue.getProgress(task.id);\n      expect(progress.progress).toBe(50);\n      expect(progress.message).toBe('halfway');\n    });\n\n    it('should notify progress listeners', () => {\n      queue.addTask('test');\n      const task = queue.getNextTask()!;\n\n      const updates: number[] = [];\n      queue.onProgress(task.id, (p) => updates.push(p));\n\n      queue.reportProgress(task.id, 25);\n      queue.reportProgress(task.id, 50);\n      queue.reportProgress(task.id, 75);\n\n      expect(updates).toEqual([25, 50, 75]);\n    });\n\n    it('should support unsubscribe', () => {\n      queue.addTask('test');\n      const task = queue.getNextTask()!;\n\n      const updates: number[] = [];\n      const unsub = queue.onProgress(task.id, (p) => updates.push(p));\n\n      queue.reportProgress(task.id, 25);\n      unsub();\n      queue.reportProgress(task.id, 50);\n\n      expect(updates).toEqual([25]);\n    });\n\n    it('should cancel a pending task', () => {\n      const task = queue.addTask('test');\n      queue.cancelTask(task.id);\n\n      expect(task.status).toBe('cancelled');\n      expect(queue.getNextTask()).toBeNull();\n    });\n\n    it('should cancel a processing task', () => {\n      queue.addTask('test');\n      const task = queue.getNextTask()!;\n      queue.cancelTask(task.id);\n\n      expect(task.status).toBe('cancelled');\n    });\n\n    it('cancelled tasks are never retried', () => {\n      queue.addTask('test', { maxRetries: 3 });\n      const task = queue.getNextTask()!;\n      queue.cancelTask(task.id);\n\n      expect(task.status).toBe('cancelled');\n      expect(queue.getNextTask()).toBeNull();\n    });\n\n    it('should reject invalid progress values', () => {\n      queue.addTask('test');\n      const task = queue.getNextTask()!;\n      expect(() => queue.reportProgress(task.id, -1)).toThrow();\n      expect(() => queue.reportProgress(task.id, 101)).toThrow();\n    });\n\n    it('cancelling a processing task frees a concurrency slot', () => {\n      queue.setQueueConcurrency('default', 1);\n      queue.addTask('a');\n      queue.addTask('b');\n\n      const t1 = queue.getNextTask()!;\n      expect(queue.getNextTask()).toBeNull();\n\n      queue.cancelTask(t1.id);\n      expect(queue.getNextTask()).not.toBeNull();\n    });\n  });\n\n  // ─── Phase 10: Recurring Tasks ────────────────────────────────\n\n  describe('Phase 10: Recurring Tasks', () => {\n    it('should create a schedule', () => {\n      const schedule = queue.addSchedule('every-5', '*/5 * * * *', 'default', { type: 'cleanup' });\n      expect(schedule.id).toBe('every-5');\n      expect(schedule.cron).toBe('*/5 * * * *');\n      expect(schedule.active).toBe(true);\n    });\n\n    it('should list active schedules', () => {\n      queue.addSchedule('s1', '*/5 * * * *', 'default', 'p1');\n      queue.addSchedule('s2', '0 * * * *', 'default', 'p2');\n\n      const schedules = queue.getSchedules();\n      expect(schedules).toHaveLength(2);\n    });\n\n    it('should remove a schedule', () => {\n      queue.addSchedule('s1', '*/5 * * * *', 'default', 'p1');\n      queue.removeSchedule('s1');\n\n      expect(queue.getSchedules()).toHaveLength(0);\n    });\n\n    it('tick should create tasks when schedule is due', () => {\n      queue.addSchedule('hourly', '0 * * * *', 'default', { type: 'hourly' });\n\n      // Simulate a time when minute = 0\n      const time = new Date(2025, 0, 1, 10, 0, 0);\n      const tasks = queue.tick(time);\n      expect(tasks).toHaveLength(1);\n      expect(tasks[0].payload).toEqual({ type: 'hourly' });\n    });\n\n    it('tick should not create duplicate tasks for same minute', () => {\n      queue.addSchedule('hourly', '0 * * * *', 'default', 'p');\n\n      const time = new Date(2025, 0, 1, 10, 0, 0);\n      queue.tick(time);\n      const tasks2 = queue.tick(time);\n      expect(tasks2).toHaveLength(0);\n    });\n\n    it('removed schedule should stop creating tasks', () => {\n      queue.addSchedule('s1', '*/5 * * * *', 'default', 'p');\n      queue.removeSchedule('s1');\n\n      const time = new Date(2025, 0, 1, 10, 0, 0);\n      const tasks = queue.tick(time);\n      expect(tasks).toHaveLength(0);\n    });\n\n    it('recurring tasks are regular tasks', () => {\n      queue.addSchedule('s1', '0 * * * *', 'default', 'payload', { priority: 2 });\n\n      const time = new Date(2025, 0, 1, 10, 0, 0);\n      const tasks = queue.tick(time);\n\n      expect(tasks[0].priority).toBe(2);\n      expect(tasks[0].status).toBe('pending');\n    });\n  });\n\n  // ─── Phase 11: Middleware Pipeline ────────────────────────────\n\n  describe('Phase 11: Middleware Pipeline', () => {\n    it('should run middleware before handler', async () => {\n      const order: string[] = [];\n      queue.use('default', async (_task, next) => {\n        order.push('middleware1');\n        await next();\n      });\n      queue.setHandler('default', async () => {\n        order.push('handler');\n      });\n\n      queue.addTask('test');\n      await queue.processTask();\n\n      expect(order).toEqual(['middleware1', 'handler']);\n    });\n\n    it('should run multiple middleware in order', async () => {\n      const order: string[] = [];\n      queue.use('default', async (_task, next) => {\n        order.push('m1');\n        await next();\n      });\n      queue.use('default', async (_task, next) => {\n        order.push('m2');\n        await next();\n      });\n      queue.setHandler('default', async () => {\n        order.push('handler');\n      });\n\n      queue.addTask('test');\n      await queue.processTask();\n\n      expect(order).toEqual(['m1', 'm2', 'handler']);\n    });\n\n    it('middleware can skip processing by not calling next', async () => {\n      const order: string[] = [];\n      queue.use('default', async () => {\n        order.push('m1');\n        // No next() call\n      });\n      queue.setHandler('default', async () => {\n        order.push('handler');\n      });\n\n      queue.addTask('test');\n      await queue.processTask();\n\n      expect(order).toEqual(['m1']);\n    });\n\n    it('middleware can modify task', async () => {\n      queue.use('default', async (task, next) => {\n        task.metadata['modified'] = true;\n        await next();\n      });\n\n      let capturedTask: unknown;\n      queue.setHandler('default', async (task) => {\n        capturedTask = task;\n      });\n\n      queue.addTask('test');\n      await queue.processTask();\n\n      expect((capturedTask as { metadata: Record<string, unknown> }).metadata['modified']).toBe(true);\n    });\n\n    it('middleware error should fail the task', async () => {\n      queue.use('default', async () => {\n        throw new Error('middleware error');\n      });\n\n      queue.addTask('test', { maxRetries: 1 });\n      const task = await queue.processTask();\n\n      expect(task?.status).toBe('failed');\n    });\n\n    it('each queue has independent middleware stack', async () => {\n      const q1Order: string[] = [];\n      const q2Order: string[] = [];\n\n      queue.use('q1', async (_task, next) => {\n        q1Order.push('q1-middleware');\n        await next();\n      });\n      queue.use('q2', async (_task, next) => {\n        q2Order.push('q2-middleware');\n        await next();\n      });\n      queue.setHandler('q1', async () => { q1Order.push('q1-handler'); });\n      queue.setHandler('q2', async () => { q2Order.push('q2-handler'); });\n\n      queue.addTask('a', { queue: 'q1' });\n      queue.addTask('b', { queue: 'q2' });\n\n      await queue.processTask('q1');\n      await queue.processTask('q2');\n\n      expect(q1Order).toEqual(['q1-middleware', 'q1-handler']);\n      expect(q2Order).toEqual(['q2-middleware', 'q2-handler']);\n    });\n\n    it('processTask returns null for empty queue', async () => {\n      const result = await queue.processTask();\n      expect(result).toBeNull();\n    });\n\n    it('auto-completes if no handler and middleware calls next', async () => {\n      queue.use('default', async (_task, next) => {\n        await next();\n      });\n\n      queue.addTask('test');\n      const task = await queue.processTask();\n      expect(task?.status).toBe('completed');\n    });\n  });\n\n  // ─── Phase 12: Graceful Shutdown ──────────────────────────────\n\n  describe('Phase 12: Graceful Shutdown', () => {\n    it('should reject new tasks after shutdown', async () => {\n      await queue.shutdown();\n      expect(() => queue.addTask('test')).toThrow('shut down');\n    });\n\n    it('should complete immediately if no processing tasks', async () => {\n      const result = await queue.shutdown();\n      expect(result.completed).toBe(0);\n      expect(result.forceCancelled).toBe(0);\n      expect(result.elapsed).toBeDefined();\n    });\n\n    it('should force-cancel tasks that exceed timeout', async () => {\n      queue.addTask('long-running');\n      queue.getNextTask(); // Put into processing\n\n      const result = await queue.shutdown(50);\n      expect(result.forceCancelled).toBe(1);\n    });\n\n    it('should run shutdown callbacks', async () => {\n      let called = false;\n      queue.onShutdown(() => { called = true; });\n      await queue.shutdown();\n      expect(called).toBe(true);\n    });\n\n    it('calling shutdown multiple times returns same result', async () => {\n      const r1 = queue.shutdown();\n      const r2 = queue.shutdown();\n      expect(await r1).toEqual(await r2);\n    });\n\n    it('should report completed tasks during shutdown', async () => {\n      queue.addTask('quick');\n      const task = queue.getNextTask()!;\n\n      // Complete the task before shutdown finishes\n      setTimeout(() => queue.completeTask(task.id), 10);\n\n      const result = await queue.shutdown(5000);\n      expect(result.completed).toBe(1);\n      expect(result.forceCancelled).toBe(0);\n    });\n\n    it('isShuttingDown should reflect state', () => {\n      expect(queue.isShuttingDown).toBe(false);\n      queue.shutdown();\n      expect(queue.isShuttingDown).toBe(true);\n    });\n  });\n\n  // ─── Integration Tests ────────────────────────────────────────\n\n  describe('Integration', () => {\n    it('priority + delay interaction', () => {\n      const past = new Date(Date.now() - 1000);\n      queue.addTask('high-delayed', { priority: 1, availableAt: past });\n      queue.addTask('low-immediate', { priority: 10 });\n\n      // Both available, high priority wins\n      expect(queue