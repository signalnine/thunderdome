+++ b/src/cron.ts
@@ -0,0 +1,109 @@
+/**
+ * Simple cron expression parser supporting:
+ *   * /N * * * *  -- every N minutes
+ *   0 * * * *     -- every hour on the hour
+ *   0 0 * * *     -- every day at midnight
+ */
+
+export interface CronFields {
+  minute: number | { every: number };
+  hour: number | '*';
+  // day, month, weekday are always wildcards in our subset
+}
+
+export function parseCron(expr: string): CronFields {
+  const parts = expr.trim().split(/\s+/);
+  if (parts.length !== 5) {
+    throw new Error(`Invalid cron expression: "${expr}" (expected 5 fields)`);
+  }
+
+  const [minutePart, hourPart, dayPart, monthPart, weekdayPart] = parts;
+
+  // We only support * for day, month, weekday
+  if (dayPart !== '*' || monthPart !== '*' || weekdayPart !== '*') {
+    throw new Error(`Unsupported cron expression: "${expr}" (only * supported for day/month/weekday)`);
+  }
+
+  let minute: CronFields['minute'];
+  if (minutePart.startsWith('*/')) {
+    const n = parseInt(minutePart.slice(2), 10);
+    if (isNaN(n) || n <= 0) {
+      throw new Error(`Invalid cron interval: "${minutePart}"`);
+    }
+    minute = { every: n };
+  } else if (minutePart === '*') {
+    minute = { every: 1 };
+  } else {
+    const n = parseInt(minutePart, 10);
+    if (isNaN(n) || n < 0 || n > 59) {
+      throw new Error(`Invalid minute value: "${minutePart}"`);
+    }
+    minute = n;
+  }
+
+  let hour: CronFields['hour'];
+  if (hourPart === '*') {
+    hour = '*';
+  } else {
+    const n = parseInt(hourPart, 10);
+    if (isNaN(n) || n < 0 || n > 23) {
+      throw new Error(`Invalid hour value: "${hourPart}"`);
+    }
+    hour = n;
+  }
+
+  return { minute, hour };
+}
+
+export function shouldRun(fields: CronFields, now: Date, lastRun: Date | undefined): boolean {
+  const currentMinute = now.getMinutes();
+  const currentHour = now.getHours();
+
+  if (typeof fields.minute === 'object') {
+    // */N pattern - every N minutes
+    const interval = fields.minute.every;
+
+    if (fields.hour !== '*' && currentHour !== fields.hour) {
+      return false;
+    }
+
+    if (currentMinute % interval !== 0) {
+      return false;
+    }
+
+    // Check we haven't already run for this minute
+    if (lastRun) {
+      const lastMinute = lastRun.getMinutes();
+      const lastHour = lastRun.getHours();
+      const lastDate = lastRun.toDateString();
+      const nowDate = now.toDateString();
+      if (lastDate === nowDate && lastHour === currentHour && lastMinute === currentMinute) {
+        return false;
+      }
+    }
+
+    return true;
+  }
+
+  // Specific minute value
+  if (currentMinute !== fields.minute) {
+    return false;
+  }
+
+  if (fields.hour !== '*' && currentHour !== fields.hour) {
+    return false;
+  }
+
+  // Check we haven't already run for this time slot
+  if (lastRun) {
+    const lastMinute = lastRun.getMinutes();
+    const lastHour = lastRun.getHours();
+    const lastDate = lastRun.toDateString();
+    const nowDate = now.toDateString();
+    if (lastDate === nowDate && lastHour === currentHour && lastMinute === currentMinute) {
+      return false;
+    }
+  }
+
+  return true;
+}
