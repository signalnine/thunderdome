new file mode 100644
index 0000000..0e6d560
--- /dev/null
+++ b/src/__tests__/deps.test.ts
@@ -0,0 +1,100 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { createDependencyGraph } from '../deps/index.js';
+import { createRegistry } from '../registry/index.js';
+import type { PluginManifest } from '../types.js';
+
+describe('DependencyGraph', () => {
+  let deps: ReturnType<typeof createDependencyGraph>;
+  let registry: ReturnType<typeof createRegistry>;
+
+  beforeEach(() => {
+    deps = createDependencyGraph();
+    registry = createRegistry();
+  });
+
+  const createManifest = (
+    name: string,
+    version: string,
+    dependencies: Record<string, string> = {}
+  ): PluginManifest => ({
+    name,
+    version,
+    description: `Plugin ${name}`,
+    author: 'Test',
+    dependencies,
+    entryPoint: '',
+    permissions: [],
+  });
+
+  it('should build dependency tree', () => {
+    registry.register(createManifest('base', '1.0.0'));
+    registry.register(createManifest('middle', '1.0.0', { base: '^1.0.0' }));
+    registry.register(createManifest('top', '1.0.0', { middle: '^1.0.0' }));
+
+    const tree = deps.buildTree('top', registry);
+    expect(tree.name).toBe('top');
+    expect(tree.dependencies).toHaveLength(1);
+    expect(tree.dependencies[0].name).toBe('middle');
+    expect(tree.dependencies[0].dependencies[0].name).toBe('base');
+  });
+
+  it('should detect circular dependencies', () => {
+    registry.register(createManifest('a', '1.0.0', { b: '^1.0.0' }));
+    registry.register(createManifest('b', '1.0.0', { c: '^1.0.0' }));
+    registry.register(createManifest('c', '1.0.0', { a: '^1.0.0' }));
+
+    const cycles = deps.detectCycles('a', registry);
+    expect(cycles).not.toBeNull();
+    expect(cycles).toHaveLength(1);
+    expect(cycles![0]).toContain('a');
+    expect(cycles![0]).toContain('b');
+    expect(cycles![0]).toContain('c');
+  });
+
+  it('should return null when no cycles', () => {
+    registry.register(createManifest('base', '1.0.0'));
+    registry.register(createManifest('derived', '1.0.0', { base: '^1.0.0' }));
+
+    const cycles = deps.detectCycles('derived', registry);
+    expect(cycles).toBeNull();
+  });
+
+  it('should check for circular dependencies', () => {
+    registry.register(createManifest('a', '1.0.0', { b: '^1.0.0' }));
+    registry.register(createManifest('b', '1.0.0', { a: '^1.0.0' }));
+
+    expect(deps.hasCircularDependency('a', registry)).toBe(true);
+  });
+
+  it('should produce topological sort', () => {
+    registry.register(createManifest('base', '1.0.0'));
+    registry.register(createManifest('middle', '1.0.0', { base: '^1.0.0' }));
+    registry.register(createManifest('top', '1.0.0', { middle: '^1.0.0' }));
+
+    const sorted = deps.topologicalSort('top', registry);
+    expect(sorted).toContain('base');
+    expect(sorted).toContain('middle');
+    expect(sorted).toContain('top');
+    // base should come before middle, middle before top
+    expect(sorted.indexOf('base')).toBeLessThan(sorted.indexOf('middle'));
+    expect(sorted.indexOf('middle')).toBeLessThan(sorted.indexOf('top'));
+  });
+
+  it('should throw on topological sort with cycles', () => {
+    registry.register(createManifest('a', '1.0.0', { b: '^1.0.0' }));
+    registry.register(createManifest('b', '1.0.0', { a: '^1.0.0' }));
+
+    expect(() => deps.topologicalSort('a', registry)).toThrow();
+  });
+
+  it('should flatten dependencies', () => {
+    registry.register(createManifest('base', '1.0.0'));
+    registry.register(createManifest('middle', '1.0.0', { base: '^1.0.0' }));
+    registry.register(createManifest('top', '1.0.0', { middle: '^1.0.0', base: '^1.0.0' }));
+
+    const flat = deps.flattenDependencies('top', registry);
+    expect(flat).toContain('base');
+    expect(flat).toContain('middle');
+    expect(flat).toHaveLength(2);
+  });
+});
