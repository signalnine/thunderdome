@@ -0,0 +1,73 @@
+import { describe, it, expect } from 'vitest';
+import { createResolver } from '../resolver/index.js';
+import type { VersionConstraint } from '../types.js';
+
+describe('VersionResolver', () => {
+  const resolver = createResolver();
+
+  describe('satisfies', () => {
+    it('should check if version satisfies range', () => {
+      expect(resolver.satisfies('1.0.0', '^1.0.0')).toBe(true);
+      expect(resolver.satisfies('1.1.0', '^1.0.0')).toBe(true);
+      expect(resolver.satisfies('2.0.0', '^1.0.0')).toBe(false);
+      expect(resolver.satisfies('1.0.0', '~1.0.0')).toBe(true);
+      expect(resolver.satisfies('1.0.1', '~1.0.0')).toBe(true);
+      expect(resolver.satisfies('1.1.0', '~1.0.0')).toBe(false);
+    });
+  });
+
+  describe('maxSatisfying', () => {
+    it('should find max satisfying version', () => {
+      const versions = ['1.0.0', '1.1.0', '2.0.0', '2.1.0'];
+      expect(resolver.maxSatisfying(versions, '^1.0.0')).toBe('1.1.0');
+      expect(resolver.maxSatisfying(versions, '^2.0.0')).toBe('2.1.0');
+      expect(resolver.maxSatisfying(versions, '>=1.0.0')).toBe('2.1.0');
+    });
+
+    it('should return null if no version satisfies', () => {
+      const versions = ['1.0.0', '1.1.0'];
+      expect(resolver.maxSatisfying(versions, '^2.0.0')).toBeNull();
+    });
+  });
+
+  describe('validRange', () => {
+    it('should validate semver ranges', () => {
+      expect(resolver.validRange('^1.0.0')).toBe(true);
+      expect(resolver.validRange('~1.0.0')).toBe(true);
+      expect(resolver.validRange('>=1.0.0')).toBe(true);
+      expect(resolver.validRange('invalid')).toBe(false);
+    });
+  });
+
+  describe('resolve', () => {
+    it('should resolve version constraints', () => {
+      const constraints: VersionConstraint[] = [
+        { name: 'dep-a', range: '^1.0.0' },
+        { name: 'dep-b', range: '~2.0.0' },
+      ];
+      const available = {
+        'dep-a': ['1.0.0', '1.1.0', '2.0.0'],
+        'dep-b': ['2.0.0', '2.0.5', '2.1.0', '3.0.0'],
+      };
+
+      const resolved = resolver.resolve(constraints, available);
+      expect(resolved).toHaveLength(2);
+      expect(resolved[0]).toEqual({ name: 'dep-a', version: '1.1.0', satisfies: '^1.0.0' });
+      expect(resolved[1]).toEqual({ name: 'dep-b', version: '2.0.5', satisfies: '~2.0.0' });
+    });
+
+    it('should skip unavailable dependencies', () => {
+      const constraints: VersionConstraint[] = [
+        { name: 'dep-a', range: '^1.0.0' },
+        { name: 'missing', range: '^1.0.0' },
+      ];
+      const available = {
+        'dep-a': ['1.0.0', '1.1.0'],
+      };
+
+      const resolved = resolver.resolve(constraints, available);
+      expect(resolved).toHaveLength(1);
+      expect(resolved[0].name).toBe('dep-a');
+    });
+  });
+});
