--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,162 @@
+import type {
+  PluginManifest,
+  RegistryService,
+  ResolverService,
+  RunnerService,
+  ReviewService,
+  DepsService,
+  VersionConstraint,
+  ResolvedVersion,
+  SandboxResult,
+} from './types.js';
+import { createRegistry } from './registry/index.js';
+import { createResolver } from './resolver/index.js';
+import { createRunner } from './runner/index.js';
+import { createReviewSystem } from './reviews/index.js';
+import { createDependencyGraph } from './deps/index.js';
+
+export interface Marketplace {
+  registry: RegistryService;
+  resolver: ResolverService;
+  runner: RunnerService;
+  reviews: ReviewService;
+  deps: DepsService;
+  installPlugin: (
+    manifest: PluginManifest
+  ) => Promise<{
+    success: boolean;
+    resolvedDependencies: ResolvedVersion[];
+    sandboxResult: SandboxResult;
+    error?: string;
+  }>;
+}
+
+export interface CreateMarketplaceOptions {
+  dbPath?: string;
+}
+
+export function createMarketplace(options: CreateMarketplaceOptions = {}): Marketplace {
+  const registry = createRegistry(options.dbPath);
+  const resolver = createResolver();
+  const runner = createRunner();
+  const reviews = createReviewSystem(options.dbPath);
+  const deps = createDependencyGraph();
+
+  async function installPlugin(
+    manifest: PluginManifest
+  ): Promise<{
+    success: boolean;
+    resolvedDependencies: ResolvedVersion[];
+    sandboxResult: SandboxResult;
+    error?: string;
+  }> {
+    // Validate required fields
+    if (!manifest.name || typeof manifest.name !== 'string') {
+      return {
+        success: false,
+        resolvedDependencies: [],
+        sandboxResult: {
+          success: false,
+          output: null,
+          duration: 0,
+          memoryUsed: 0,
+          error: 'Plugin name is required',
+        },
+        error: 'Plugin name is required',
+      };
+    }
+
+    if (!manifest.version || typeof manifest.version !== 'string') {
+      return {
+        success: false,
+        resolvedDependencies: [],
+        sandboxResult: {
+          success: false,
+          output: null,
+          duration: 0,
+          memoryUsed: 0,
+          error: 'Plugin version is required',
+        },
+        error: 'Plugin version is required',
+      };
+    }
+
+    if (!manifest.entryPoint || typeof manifest.entryPoint !== 'string') {
+      return {
+        success: false,
+        resolvedDependencies: [],
+        sandboxResult: {
+          success: false,
+          output: null,
+          duration: 0,
+          memoryUsed: 0,
+          error: 'Plugin entryPoint is required',
+        },
+        error: 'Plugin entryPoint is required',
+      };
+    }
+
+    // Register the plugin
+    registry.register(manifest);
+
+    // Build available versions from registry
+    const allPlugins = registry.list();
+    const available: Record<string, string[]> = {};
+    for (const plugin of allPlugins) {
+      if (!available[plugin.name]) {
+        available[plugin.name] = [];
+      }
+      if (!available[plugin.name].includes(plugin.version)) {
+        available[plugin.name].push(plugin.version);
+      }
+    }
+
+    // Resolve dependencies
+    const constraints: VersionConstraint[] = Object.entries(manifest.dependencies).map(
+      ([name, range]) => ({ name, range })
+    );
+    const resolvedDependencies = resolver.resolve(constraints, available);
+
+    // Check for circular dependencies
+    const hasCycles = deps.hasCircularDependency(manifest.name, registry);
+    if (hasCycles) {
+      return {
+        success: false,
+        resolvedDependencies,
+        sandboxResult: {
+          success: false,
+          output: null,
+          duration: 0,
+          memoryUsed: 0,
+          error: 'Circular dependency detected',
+        },
+        error: 'Circular dependency detected',
+      };
+    }
+
+    // Execute entry point in sandbox
+    const sandboxResult = await runner.execute(manifest.entryPoint, {
+      pluginName: manifest.name,
+      pluginVersion: manifest.version,
+      dependencies: resolvedDependencies,
+    });
+
+    return {
+      success: sandboxResult.success,
+      resolvedDependencies,
+      sandboxResult,
+    };
+  }
+
+  return {
+    registry,
+    resolver,
+    runner,
+    reviews,
+    deps,
+    installPlugin,
+  };
+}
+
+// Re-export types
+export * from './types.js';
