+import { describe, it, expect, beforeEach } from 'vitest';
+import { createMarketplace } from '../index.js';
+import type { PluginManifest } from '../types.js';
+
+describe('createMarketplace', () => {
+  let marketplace: ReturnType<typeof createMarketplace>;
+
+  beforeEach(() => {
+    marketplace = createMarketplace();
+  });
+
+  const createManifest = (
+    name: string,
+    version: string,
+    dependencies: Record<string, string> = {},
+    entryPoint: string = '"hello"'
+  ): PluginManifest => ({
+    name,
+    version,
+    description: `Plugin ${name}`,
+    author: 'Test',
+    dependencies,
+    entryPoint,
+    permissions: [],
+  });
+
+  it('should export all services', () => {
+    expect(marketplace.registry).toBeDefined();
+    expect(marketplace.resolver).toBeDefined();
+    expect(marketplace.runner).toBeDefined();
+    expect(marketplace.reviews).toBeDefined();
+    expect(marketplace.deps).toBeDefined();
+    expect(marketplace.installPlugin).toBeDefined();
+  });
+
+  it('should install a plugin successfully', async () => {
+    const manifest = createManifest('test-plugin', '1.0.0');
+    const result = await marketplace.installPlugin(manifest);
+
+    expect(result.success).toBe(true);
+    expect(result.resolvedDependencies).toEqual([]);
+    expect(result.sandboxResult.success).toBe(true);
+    expect(result.sandboxResult.output).toBe('hello');
+  });
+
+  it('should reject plugin without name', async () => {
+    const manifest = createManifest('', '1.0.0');
+    const result = await marketplace.installPlugin(manifest);
+
+    expect(result.success).toBe(false);
+    expect(result.error).toContain('name');
+  });
+
+  it('should reject plugin without version', async () => {
+    const manifest = createManifest('test', '');
+    const result = await marketplace.installPlugin(manifest);
+
+    expect(result.success).toBe(false);
+    expect(result.error).toContain('version');
+  });
+
+  it('should reject plugin without entryPoint', async () => {
+    const manifest = { ...createManifest('test', '1.0.0'), entryPoint: '' };
+    const result = await marketplace.installPlugin(manifest);
+
+    expect(result.success).toBe(false);
+    expect(result.error).toContain('entryPoint');
+  });
+
+  it('should resolve dependencies during install', async () => {
+    const base = createManifest('base', '1.0.0', {}, '"base"');
+    const derived = createManifest('derived', '1.0.0', { base: '^1.0.0' }, '"derived"');
+
+    await marketplace.installPlugin(base);
+    const result = await marketplace.installPlugin(derived);
+
+    expect(result.success).toBe(true);
+    expect(result.resolvedDependencies).toHaveLength(1);
+    expect(result.resolvedDependencies[0].name).toBe('base');
+    expect(result.resolvedDependencies[0].version).toBe('1.0.0');
+  });
+
+  it('should detect circular dependencies', async () => {
+    const a = createManifest('a', '1.0.0', { b: '^1.0.0' }, '"a"');
+    const b = createManifest('b', '1.0.0', { a: '^1.0.0' }, '"b"');
+
+    await marketplace.installPlugin(a);
+    const result = await marketplace.installPlugin(b);
+
+    expect(result.success).toBe(false);
+    expect(result.error).toContain('Circular');
+  });
+
+  it('should register plugin in catalog after install', async () => {
+    const manifest = createManifest('test-plugin', '1.0.0');
+    await marketplace.installPlugin(manifest);
+
+    const retrieved = marketplace.registry.get('test-plugin');
+    expect(retrieved).not.toBeNull();
+    expect(retrieved?.version).toBe('1.0.0');
+  });
+
+  it('should execute entry point with context', async () => {
+    const manifest = createManifest(
+      'context-test',
+      '1.0.0',
+      {},
+      'typeof pluginName + "-" + typeof pluginVersion + "-" + typeof dependencies'
+    );
+    const result = await marketplace.installPlugin(manifest);
+
+    expect(result.success).toBe(true);
+    expect(result.sandboxResult.output).toBe('string-string-object');
+  });
+});
