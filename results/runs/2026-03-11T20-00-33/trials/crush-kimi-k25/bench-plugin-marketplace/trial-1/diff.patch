@@ -0,0 +1,152 @@
+import type {
+  DepsService,
+  DependencyNode,
+  RegistryService,
+} from '../types.js';
+
+export class DependencyGraph implements DepsService {
+  buildTree(name: string, registry: RegistryService): DependencyNode {
+    const manifest = registry.get(name);
+    if (!manifest) {
+      throw new Error(`Plugin ${name} not found`);
+    }
+
+    const dependencies: DependencyNode[] = [];
+    for (const [depName] of Object.entries(manifest.dependencies)) {
+      try {
+        const depNode = this.buildTree(depName, registry);
+        dependencies.push(depNode);
+      } catch {
+        // Dependency not found, add placeholder
+        dependencies.push({
+          name: depName,
+          version: 'unknown',
+          dependencies: [],
+        });
+      }
+    }
+
+    return {
+      name: manifest.name,
+      version: manifest.version,
+      dependencies,
+    };
+  }
+
+  detectCycles(name: string, registry: RegistryService): string[][] | null {
+    const cycles: string[][] = [];
+    const visited = new Set<string>();
+    const path: string[] = [];
+    const pathSet = new Set<string>();
+
+    const visit = (pluginName: string): void => {
+      if (pathSet.has(pluginName)) {
+        // Found cycle
+        const cycleStart = path.indexOf(pluginName);
+        const cycle = path.slice(cycleStart).concat([pluginName]);
+        cycles.push(cycle);
+        return;
+      }
+
+      if (visited.has(pluginName)) {
+        return;
+      }
+
+      const manifest = registry.get(pluginName);
+      if (!manifest) {
+        return;
+      }
+
+      visited.add(pluginName);
+      path.push(pluginName);
+      pathSet.add(pluginName);
+
+      for (const depName of Object.keys(manifest.dependencies)) {
+        visit(depName);
+      }
+
+      path.pop();
+      pathSet.delete(pluginName);
+    };
+
+    visit(name);
+
+    return cycles.length > 0 ? cycles : null;
+  }
+
+  hasCircularDependency(name: string, registry: RegistryService): boolean {
+    const cycles = this.detectCycles(name, registry);
+    return cycles !== null && cycles.length > 0;
+  }
+
+  topologicalSort(name: string, registry: RegistryService): string[] {
+    if (this.hasCircularDependency(name, registry)) {
+      throw new Error('Cannot topological sort: circular dependency detected');
+    }
+
+    const result: string[] = [];
+    const visited = new Set<string>();
+    const tempMark = new Set<string>();
+
+    const visit = (pluginName: string): void => {
+      if (tempMark.has(pluginName)) {
+        throw new Error('Circular dependency detected');
+      }
+
+      if (visited.has(pluginName)) {
+        return;
+      }
+
+      const manifest = registry.get(pluginName);
+      if (!manifest) {
+        return;
+      }
+
+      tempMark.add(pluginName);
+
+      for (const depName of Object.keys(manifest.dependencies)) {
+        visit(depName);
+      }
+
+      tempMark.delete(pluginName);
+      visited.add(pluginName);
+      result.push(pluginName);
+    };
+
+    visit(name);
+
+    return result;
+  }
+
+  flattenDependencies(name: string, registry: RegistryService): string[] {
+    const allDeps = new Set<string>();
+
+    const collect = (pluginName: string, visited: Set<string>): void => {
+      if (visited.has(pluginName)) {
+        return;
+      }
+
+      visited.add(pluginName);
+      const manifest = registry.get(pluginName);
+
+      if (!manifest) {
+        return;
+      }
+
+      for (const depName of Object.keys(manifest.dependencies)) {
+        if (depName !== name) {
+          allDeps.add(depName);
+        }
+        collect(depName, visited);
+      }
+    };
+
+    collect(name, new Set<string>());
+
+    return Array.from(allDeps);
+  }
+}
+
+export function createDependencyGraph(): DependencyGraph {
+  return new DependencyGraph();
+}
