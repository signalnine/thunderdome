@@ -0,0 +1,63 @@
+import { runInNewContext } from 'vm';
+import type { RunnerService, SandboxResult } from '../types.js';
+
+export class SandboxedRunner implements RunnerService {
+  async execute(
+    code: string,
+    context?: Record<string, unknown>
+  ): Promise<SandboxResult> {
+    return this.executeWithTimeout(code, 5000, context);
+  }
+
+  async executeWithTimeout(
+    code: string,
+    timeoutMs: number,
+    context?: Record<string, unknown>
+  ): Promise<SandboxResult> {
+    const startTime = Date.now();
+    const startMemory = process.memoryUsage().heapUsed;
+
+    const sandboxContext: Record<string, unknown> = {
+      console,
+      setTimeout,
+      clearTimeout,
+      setInterval,
+      clearInterval,
+      ...context,
+    };
+
+    try {
+      const result = runInNewContext(code, sandboxContext, {
+        timeout: timeoutMs,
+        displayErrors: true,
+      });
+
+      const duration = Date.now() - startTime;
+      const endMemory = process.memoryUsage().heapUsed;
+      const memoryUsed = endMemory - startMemory;
+
+      return {
+        success: true,
+        output: result,
+        duration,
+        memoryUsed: Math.max(0, memoryUsed),
+      };
+    } catch (error) {
+      const duration = Date.now() - startTime;
+      const endMemory = process.memoryUsage().heapUsed;
+      const memoryUsed = endMemory - startMemory;
+
+      return {
+        success: false,
+        output: null,
+        duration,
+        memoryUsed: Math.max(0, memoryUsed),
+        error: error instanceof Error ? error.message : String(error),
+      };
+    }
