+import { describe, it, expect, beforeEach } from 'vitest';
+import { createRegistry } from '../registry/index.js';
+import type { PluginManifest } from '../types.js';
+
+describe('PluginRegistry', () => {
+  let registry: ReturnType<typeof createRegistry>;
+
+  beforeEach(() => {
+    registry = createRegistry();
+  });
+
+  const samplePlugin: PluginManifest = {
+    name: 'test-plugin',
+    version: '1.0.0',
+    description: 'A test plugin',
+    author: 'Test Author',
+    dependencies: {},
+    entryPoint: 'module.exports = "hello";',
+    permissions: ['read', 'write'],
+  };
+
+  it('should register a plugin', () => {
+    registry.register(samplePlugin);
+    const retrieved = registry.get('test-plugin');
+    expect(retrieved).not.toBeNull();
+    expect(retrieved?.name).toBe('test-plugin');
+    expect(retrieved?.version).toBe('1.0.0');
+  });
+
+  it('should get a specific version', () => {
+    registry.register(samplePlugin);
+    const retrieved = registry.getVersion('test-plugin', '1.0.0');
+    expect(retrieved).not.toBeNull();
+    expect(retrieved?.version).toBe('1.0.0');
+  });
+
+  it('should return null for non-existent plugin', () => {
+    const retrieved = registry.get('non-existent');
+    expect(retrieved).toBeNull();
+  });
+
+  it('should list all plugins', () => {
+    registry.register(samplePlugin);
+    registry.register({ ...samplePlugin, name: 'another-plugin', version: '1.0.0' });
+    const list = registry.list();
+    expect(list).toHaveLength(2);
+  });
+
+  it('should search plugins', () => {
+    registry.register(samplePlugin);
+    registry.register({ ...samplePlugin, name: 'another-plugin', description: 'Another plugin', author: 'Another Author' });
+    const results = registry.search('test');
+    expect(results).toHaveLength(1);
+    expect(results[0].name).toBe('test-plugin');
+  });
+
+  it('should remove a specific version', () => {
+    registry.register(samplePlugin);
+    const removed = registry.remove('test-plugin', '1.0.0');
+    expect(removed).toBe(true);
+    expect(registry.get('test-plugin')).toBeNull();
+  });
+
+  it('should list versions for a plugin', () => {
+    registry.register(samplePlugin);
+    registry.register({ ...samplePlugin, version: '1.1.0' });
+    const versions = registry.listVersions('test-plugin');
+    expect(versions).toHaveLength(2);
+    expect(versions).toContain('1.0.0');
+    expect(versions).toContain('1.1.0');
+  });
+
+  it('should update a plugin', () => {
+    registry.register(samplePlugin);
+    registry.update('test-plugin', '1.0.0', { description: 'Updated description' });
+    const retrieved = registry.get('test-plugin');
+    expect(retrieved?.description).toBe('Updated description');
+  });
+});
