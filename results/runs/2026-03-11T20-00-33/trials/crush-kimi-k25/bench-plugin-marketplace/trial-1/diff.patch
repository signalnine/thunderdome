+    reviews.addReview({
+      pluginName: 'test-plugin',
+      pluginVersion: '1.0.0',
+      userId: 'user-2',
+      rating: 3,
+      comment: 'Okay',
+    });
+
+    expect(reviews.getReviewCount('test-plugin')).toBe(2);
+    reviews.flagReview(review1.id);
+    expect(reviews.getReviewCount('test-plugin')).toBe(1);
+  });
+});
