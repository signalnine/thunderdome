+import { EventBus } from '../bus';
+import { Events, ProductCreatedEvent } from '../types';
+
+export interface CatalogService {
+  createProduct(name: string, price: number, category: string): string;
+  getProduct(productId: string): { id: string; name: string; price: number; category: string } | null;
+  listProducts(category?: string): Array<{ id: string; name: string; price: number; category: string }>;
+  searchProducts(query: string): Array<{ id: string; name: string; price: number; category: string }>;
+  updateProduct(productId: string, updates: Partial<{ name: string; price: number; category: string }>): void;
+  removeProduct(productId: string): boolean;
+}
+
+export function createCatalogService(bus: EventBus): CatalogService {
+  const products: Record<string, { id: string; name: string; price: number; category: string }> = {};
+  let productIdCounter = 1;
+
+  function createProduct(name: string, price: number, category: string): string {
+    const productId = `product_${productIdCounter++}`;
+    const product = { id: productId, name, price, category };
+    products[productId] = product;
+    bus.emit(Events.PRODUCT_CREATED, { productId, name, price, category } as ProductCreatedEvent);
+    return productId;
+  }
+
+  function getProduct(productId: string): { id: string; name: string; price: number; category: string } | null {
+    return products[productId] ?? null;
+  }
+
+  function listProducts(category?: string): Array<{ id: string; name: string; price: number; category: string }> {
+    return Object.values(products).filter(
+      (product) => !category || product.category === category
+    );
+  }
+
+  function searchProducts(query: string): Array<{ id: string; name: string; price: number; category: string }> {
+    const lowerQuery = query.toLowerCase();
+    return Object.values(products).filter(
+      (product) =>
+        product.name.toLowerCase().includes(lowerQuery) ||
+        product.category.toLowerCase().includes(lowerQuery)
+    );
+  }
+
+  function updateProduct(productId: string, updates: Partial<{ name: string; price: number; category: string }>): void {
+    const product = products[productId];
+    if (!product) return;
+    if (updates.name !== undefined) product.name = updates.name;
+    if (updates.price !== undefined) product.price = updates.price;
+    if (updates.category !== undefined) product.category = updates.category;
+  }
+
+  function removeProduct(productId: string): boolean {
+    if (products[productId]) {
+      delete products[productId];
+      return true;
+    }
+    return false;
+  }
+
+  return {
+    createProduct,
+    getProduct,
+    listProducts,
+    searchProducts,
+    updateProduct,
+    removeProduct,
+  };
+}
