+import { EventBus } from '../bus';
+import { Events, OrderStatus } from '../types';
+
+export interface OrderService {
+  createOrder(userId: string, cartId: string, total: number): string;
+  getOrder(orderId: string): { id: string; userId: string; status: OrderStatus; total: number } | null;
+  updateStatus(orderId: string, status: OrderStatus): void;
+  listOrders(userId: string): Array<{ id: string; status: OrderStatus; total: number }>;
+}
+
+export function createOrderService(bus: EventBus): OrderService {
+  const orders: Record<string, {
+    id: string;
+    userId: string;
+    cartId: string;
+    status: OrderStatus;
+    total: number;
+  }> = {};
+  let orderIdCounter = 1;
+
+  function createOrder(userId: string, cartId: string, total: number): string {
+    const orderId = `order_${orderIdCounter++}`;
+    const order = {
+      id: orderId,
+      userId,
+      cartId,
+      status: OrderStatus.PENDING,
+      total,
+    };
+    orders[orderId] = order;
+    bus.emit(Events.ORDER_CREATED, {
+      orderId,
+      userId,
+      cartId,
+      total,
+    } as { orderId: string; userId: string; cartId: string; total: number });
+    return orderId;
+  }
+
+  function getOrder(orderId: string): { id: string; userId: string; status: OrderStatus; total: number } | null {
+    const order = orders[orderId];
+    if (!order) return null;
+    return {
+      id: order.id,
+      userId: order.userId,
+      status: order.status,
+      total: order.total,
+    };
+  }
+
+  function updateStatus(orderId: string, status: OrderStatus): void {
+    const order = orders[orderId];
+    if (!order) return;
+    const previousStatus = order.status;
+    if (previousStatus === status) return; // No change
+    order.status = status;
+    bus.emit(Events.ORDER_STATUS_CHANGED, {
+      orderId,
+      status,
+      previousStatus,
+    } as { orderId: string; status: OrderStatus; previousStatus: OrderStatus });
+  }
+
+  function listOrders(userId: string): Array<{ id: string; status: OrderStatus; total: number }> {
+    return Object.values(orders)
+      .filter(order => order.userId === userId)
+      .map(order => ({
+        id: order.id,
+        status: order.status,
+        total: order.total,
+      }));
