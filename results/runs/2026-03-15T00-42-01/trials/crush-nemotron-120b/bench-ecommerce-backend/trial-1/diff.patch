+import { EventBus } from '../bus';
+import { Events, InventoryUpdatedEvent, LowStockAlertEvent } from '../types';
+
+export interface InventoryService {
+  setStock(productId: string, quantity: number): void;
+  getStock(productId: string): number;
+  reserve(productId: string, quantity: number): boolean;
+  release(productId: string, quantity: number): void;
+  setLowStockThreshold(productId: string, threshold: number): void;
+}
+
+export function createInventoryService(bus: EventBus): InventoryService {
+  // productId -> { total: number, reserved: number, threshold: number | null, belowAlerted: boolean }
+  const inventory: Record<string, {
+    total: number;
+    reserved: number;
+    threshold: number | null;
+    belowAlerted: boolean;
+  }> = {};
+
+  // Initialize product when created
+  bus.on(Events.PRODUCT_CREATED, (payload: unknown) => {
+    const event = payload as { productId: string };
+    if (!inventory[event.productId]) {
+      inventory[event.productId] = {
+        total: 0,
+        reserved: 0,
+        threshold: null,
+        belowAlerted: false,
+      };
+    }
+  });
+
+  const updateInventory = (productId: string): void => {
+    const item = inventory[productId];
+    if (!item) return;
+
+    const available = item.total - item.reserved;
+    // Emit inventory updated event
+    bus.emit(Events.INVENTORY_UPDATED, { productId, quantity: available } as InventoryUpdatedEvent);
+
+    // Check low stock alert
+    if (item.threshold !== null) {
+      const below = available < item.threshold;
+      if (below && !item.belowAlerted) {
+        bus.emit(Events.LOW_STOCK_ALERT, {
+          productId,
+          currentQuantity: available,
+          threshold: item.threshold,
+        } as LowStockAlertEvent);
+        item.belowAlerted = true;
+      } else if (!below && item.belowAlerted) {
+        item.belowAlerted = false;
+      }
+    }
+  };
+
+  function setStock(productId: string, quantity: number): void {
+    if (!inventory[productId]) {
+      inventory[productId] = {
+        total: 0,
+        reserved: 0,
+        threshold: null,
+        belowAlerted: false,
+      };
+    }
+    inventory[productId].total = quantity;
+    updateInventory(productId);
+  }
+
+  function getStock(productId: string): number {
+    const item = inventory[productId];
+    if (!item) return 0;
+    return item.total - item.reserved;
+  }
+
+  function reserve(productId: string, quantity: number): boolean {
+    const item = inventory[productId];
+    if (!item) {
+      // Initialize if not exists
+      inventory[productId] = {
+        total: 0,
+        reserved: 0,
+        threshold: null,
+        belowAlerted: false,
+      };
+      return false; // No stock to reserve
+    }
+    const available = item.total - item.reserved;
+    if (available >= quantity) {
+      item.reserved += quantity;
+      updateInventory(productId);
+      return true;
+    }
+    return false;
+  }
+
+  function release(productId: string, quantity: number): void {
+    const item = inventory[productId];
+    if (!item) {
+      // Initialize if not exists
+      inventory[productId] = {
+        total: 0,
+        reserved: 0,
+        threshold: null,
+        belowAlerted: false,
+      };
+    }
+    item.reserved = Math.max(0, item.reserved - quantity);
+    updateInventory(productId);
+  }
+
+  function setLowStockThreshold(productId: string, threshold: number): void {
+    if (!inventory[productId]) {
+      inventory[productId] = {
+        total: 0,
+        reserved: 0,
+        threshold: null,
+        belowAlerted: false,
+      };
+    }
+    inventory[productId].threshold = threshold;
+    // Check current state after setting threshold
+    updateInventory(productId);
+  }
+
+  return {
+    setStock,
+    getStock,
+    reserve,
+    release,
+    setLowStockThreshold,
+  };
+}
