+import { EventBus } from '../bus';
+import { Events, CartUpdatedEvent } from '../types';
+
+export interface CartService {
+  createCart(userId: string): string;
+  addItem(cartId: string, productId: string, quantity: number): void;
+  removeItem(cartId: string, productId: string): void;
+  getCart(cartId: string): { id: string; userId: string; items: Array<{ productId: string; quantity: number> } } | null;
+  clearCart(cartId: string): void;
+  updateQuantity(cartId: string, productId: string, quantity: number): void;
+}
+
+export function createCartService(bus: EventBus): CartService {
+  const carts: Record<string, { id: string; userId: string; items: Record<string, number> }> = {};
+  let cartIdCounter = 1;
+
+  const emitCartUpdated = (cartId: string): void => {
+    const cart = carts[cartId];
+    if (!cart) return;
+    bus.emit(Events.CART_UPDATED, {
+      cartId: cart.id,
+      userId: cart.userId,
+      items: Object.entries(cart.items).map(([productId, quantity]) => ({ productId, quantity: Number(quantity) }))
+    } as CartUpdatedEvent);
+  };
+
+  function createCart(userId: string): string {
+    const cartId = `cart_${cartIdCounter++}`;
+    carts[cartId] = { id: cartId, userId, items: {} };
+    // Emit initial empty cart
+    emitCartUpdated(cartId);
+    return cartId;
+  }
+
+  function addItem(cartId: string, productId: string, quantity: number): void {
+    const cart = carts[cartId];
+    if (!cart) return;
+    cart.items[productId] = (cart.items[productId] || 0) + quantity;
+    emitCartUpdated(cartId);
+  }
+
+  function removeItem(cartId: string, productId: string): void {
+    const cart = carts[cartId];
+    if (!cart) return;
+    delete cart.items[productId];
+    emitCartUpdated(cartId);
+  }
+
+  function getCart(cartId: string): { id: string; userId: string; items: Array<{ productId: string; quantity: number> } } | null {
+    const cart = carts[cartId];
+    if (!cart) return null;
+    return {
+      id: cart.id,
+      userId: cart.userId,
+      items: Object.entries(cart.items).map(([productId, quantity]) => ({ productId, quantity: Number(quantity) }))
+    };
+  }
+
+  function clearCart(cartId: string): void {
+    const cart = carts[cartId];
+    if (!cart) return;
+    cart.items = {};
+    emitCartUpdated(cartId);
+  }
+
+  function updateQuantity(cartId: string, productId: string, quantity: number): void {
+    const cart = carts[cartId];
+    if (!cart) return;
+    if (quantity <= 0) {
+      delete cart.items[productId];
+    } else {
+      cart.items[productId] = quantity;
+    }
+    emitCartUpdated(cartId);
+  }
+
+  return {
+    createCart,
+    addItem,
+    removeItem,
+    getCart,
+    clearCart,
+    updateQuantity,
+  };
+}
