+++ b/src/payment/index.ts
@@ -0,0 +1,96 @@
+import { EventBus } from '../bus';
+import { Events, PaymentStatus } from '../types';
+
+export interface PaymentService {
+  processPayment(orderId: string, amount: number): Promise<{ status: PaymentStatus; transactionId?: string; error?: string }>;
+  refund(transactionId: string): Promise<boolean>;
+}
+
+export function createPaymentService(bus: EventBus, options: { 
+  successRate?: number; 
+  failureRate?: number; 
+  timeoutRate?: number; 
+  delay?: number 
+} = {}): PaymentService {
+  const {
+    successRate = 1.0, // default to 100% success
+    failureRate = 0.0,
+    timeoutRate = 0.0,
+    delay = 0
+  } = options;
+
+  // Ensure rates are valid
+  const total = successRate + failureRate + timeoutRate;
+  const normalizedSuccess = successRate / total;
+  const normalizedFailure = failureRate / total;
+  const normalizedTimeout = timeoutRate / total;
+
+  // Store payment records for refunds: transactionId -> { orderId, amount, status }
+  const paymentRecords: Record<string, { orderId: string; amount: number; status: PaymentStatus }> = {};
+  let transactionIdCounter = 1;
+
+  const simulatePayment = (): Promise<{ status: PaymentStatus; transactionId?: string; error?: string }> => {
+    return new Promise((resolve) => {
+      setTimeout(() => {
+        const rand = Math.random();
+        let status: PaymentStatus;
+        let transactionId: string | undefined;
+        let error: string | undefined;
+
+        if (rand < normalizedTimeout) {
+          status = PaymentStatus.TIMEOUT;
+          error = 'Payment timeout';
+        } else if (rand < normalizedTimeout + normalizedFailure) {
+          status = PaymentStatus.FAILED;
+          error = 'Payment failed';
+        } else {
+          status = PaymentStatus.SUCCESS;
+          transactionId = `txn_${transactionIdCounter++}`;
+        }
+
+        resolve({ status, transactionId, error });
+      }, delay);
+    });
+  };
+
+  async function processPayment(orderId: string, amount: number): Promise<{ status: PaymentStatus; transactionId?: string; error?: string }> {
+    const result = await simulatePayment();
+    
+    // Record the payment for potential refunds
+    if (result.status === PaymentStatus.SUCCESS && result.transactionId) {
+      paymentRecords[result.transactionId] = {
+        orderId,
+        amount,
+        status: result.status
+      };
+    }
+
+    // Emit payment processed event
+    bus.emit(Events.PAYMENT_PROCESSED, {
+      orderId,
+      status: result.status,
+      transactionId: result.transactionId,
+      error: result.error
+    } as { orderId: string; status: PaymentStatus; transactionId?: string; error?: string });
+
+    return result;
+  }
+
+  async function refund(transactionId: string): Promise<boolean> {
+    const record = paymentRecords[transactionId];
+    if (!record || record.status !== PaymentStatus.SUCCESS) {
+      return false;
+    }
+    
+    // In a real system, we would contact a payment gateway here.
+    // For simulation, we always succeed if the original payment was successful.
+    // Update the record to indicate refunded? We'll just return true.
+    // Optionally, we could emit a payment refunded event, but not required by interfaces.
+    return true;
+  }
+
+  return {
+    processPayment,
+    refund
+  };
+}
