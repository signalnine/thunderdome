+import { EventBus } from '../bus';
+import { Events, OrderStatus, PaymentStatus } from '../types';
+
+export interface NotificationService {
+  subscribe(userId: string): void;
+  getNotifications(userId: string): Array<{ type: string; message: string; timestamp: number }>;
+}
+
+export function createNotificationService(bus: EventBus): NotificationService {
+  // Store notifications per user: userId -> array of notifications
+  const notifications: Record<string, Array<{ type: string; message: string; timestamp: number }>> = {};
+  // Map orderId to userId to know which user to notify for order-related events
+  const orderToUserMap: Record<string, string> = {};
+
+  // Subscribe to order created events to track which user owns which order
+  bus.on(Events.ORDER_CREATED, (payload: unknown) => {
+    const event = payload as { orderId: string; userId: string };
+    orderToUserMap[event.orderId] = event.userId;
+    // Initialize notifications array for the user if not present
+    if (!notifications[event.userId]) {
+      notifications[event.userId] = [];
+    }
+  });
+
+  // Helper to add a notification for a user
+  const addNotification = (userId: string, type: string, message: string): void => {
+    if (!notifications[userId]) {
+      notifications[userId] = [];
+    }
+    notifications[userId].push({
+      type,
+      message,
+      timestamp: Date.now(),
+    });
+  };
+
+  // Listen for order status changes
+  bus.on(Events.ORDER_STATUS_CHANGED, (payload: unknown) => {
+    const event = payload as { orderId: string; status: OrderStatus; previousStatus: OrderStatus };
+    const userId = orderToUserMap[event.orderId];
+    if (userId) {
+      const message = `Order ${event.orderId} status changed from ${event.previousStatus} to ${event.status}`;
+      addNotification(userId, 'order_status_changed', message);
+    }
+  });
+
+  // Listen for payment processed events
+  bus.on(Events.PAYMENT_PROCESSED, (payload: unknown) => {
+    const event = payload as { orderId: string; status: PaymentStatus; transactionId?: string; error?: string };
+    const userId = orderToUserMap[event.orderId];
+    if (userId) {
+      let message = `Payment for order ${event.orderId} `;
+      switch (event.status) {
+        case PaymentStatus.SUCCESS:
+          message += `was successful with transaction ID ${event.transactionId}`;
+          break;
+        case PaymentStatus.FAILED:
+          message += `failed: ${event.error || 'Unknown error'}`;
+          break;
+        case PaymentStatus.TIMEOUT:
+          message += `timed out`;
+          break;
+        case PaymentStatus.PENDING:
+          message += `is pending`;
+          break;
+      }
+      addNotification(userId, 'payment_processed', message);
+    }
+  });
+
+  function subscribe(userId: string): void {
+    // Ensure the user has a notifications array
+    if (!notifications[userId]) {
+      notifications[userId] = [];
+    }
+  }
+
+  function getNotifications(userId: string): Array<{ type: string; message: string; timestamp: number }> {
+    return notifications[userId] || [];
+  }
+
+  return {
+    subscribe,
+    getNotifications,
+  };
+}
