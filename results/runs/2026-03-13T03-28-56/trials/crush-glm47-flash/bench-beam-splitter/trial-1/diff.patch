+export function countBeamCells(grid: string[][]): number {
+  if (grid.length === 0 || grid[0].length === 0) return 0;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const visited = new Set<string>();
+
+  let beams: Beam[] = [];
+
+  for (const [r, c] of findSource(grid)) {
+    beams.push({ row: r, col: c, dr: 1, dc: 0 });
+  }
+
+  let steps = 0;
+  const maxSteps = rows * cols;
+
+  while (beams.length > 0 && steps < maxSteps) {
+    const newBeams: Beam[] = [];
+
+    for (const beam of beams) {
+      const { row, col, dr, dc } = beam;
+
+      if (row < 0 || row >= rows || col < 0 || col >= cols) {
+        continue;
+      }
+
+      const key = `${row},${col}`;
+      visited.add(key);
+
+      const cell = grid[row][col];
+
+      if (cell === '^') {
+        newBeams.push({ row: row + dr, col: col - 1, dr: 1, dc: -1 });
+        newBeams.push({ row: row + dr, col: col + 1, dr: 1, dc: 1 });
+      } else {
+        newBeams.push({ row: row + dr, col: col + dc, dr, dc });
+      }
+    }
+
+    beams = newBeams;
+    steps++;
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  if (grid.length === 0 || grid[0].length === 0) return 0n;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+
+  const srcCols = findSourceColumns(grid);
+  if (srcCols.length === 0) return 0n;
+
+  const paths = new Set<string>();
+
+  for (const src of srcCols) {
+    for (let param = 1; param < rows; param++) {
+      if ((src + param) <= cols) {
+        const key = `${src}-${param}`;
+        paths.add(key);
+      }
+    }
+  }
+
+  return BigInt(paths.size);
+}
+
+interface Beam {
+  row: number;
+  col: number;
+  dr: number;
+  dc: number;
+}
+
+function findSource(grid: string[][]): [number, number][] {
+  const result: [number, number][] = [];
+  const cols = grid[0].length;
+
+  for (let col = 0; col < cols; col++) {
+    if (grid[0][col] === 'S') {
+      result.push([0, col]);
+    }
+  }
+
+  return result;
+}
+
+function findSourceColumns(grid: string[][]): number[] {
+  const result: number[] = [];
+  const cols = grid[0].length;
+
+  for (let col = 0; col < cols; col++) {
+    if (grid[0][col] === 'S') {
+      result.push(col);
+    }
+  }
+
+  return result;
+}
