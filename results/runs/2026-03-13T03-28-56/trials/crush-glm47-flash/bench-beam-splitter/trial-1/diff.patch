+import { describe, expect, it } from 'vitest';
+import { countBeamCells, countBeamPaths } from './index';
+
+describe('beam splitter', () => {
+  it('simple grid with one splitter', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(5);
+    expect(countBeamPaths(grid)).toBe(4n);
+  });
+
+  it('grid with two splitters', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(6);
+    expect(countBeamPaths(grid)).toBe(4n);
+  });
+
+  it('no splitters', () => {
+    const grid = [
+      ['S', '.', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(3);
+    expect(countBeamPaths(grid)).toBe(3n);
+  });
+
+  it('grid with only source', () => {
+    const grid = [['S']];
+    expect(countBeamCells(grid)).toBe(1);
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('single cell grid with source', () => {
+    const grid = [['S', '.']];
+    expect(countBeamCells(grid)).toBe(1);
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('grid with source and splitters that cause absorption', () => {
+    const grid = [
+      ['S', '.', '.', '.'],
+      ['^', '.', '.', '.'],
+      ['.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(4);
+    expect(countBeamPaths(grid)).toBe(3n);
+  });
+
+  it('grid with multiple sources', () => {
+    const grid = [
+      ['S', 'S'],
+      ['.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(4);
+    expect(countBeamPaths(grid)).toBe(4n);
+  });
+
+  it('grid with no source', () => {
+    const grid: string[][] = [
+      ['.', '.'],
+      ['.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(0);
+    expect(countBeamPaths(grid)).toBe(0n);
+  });
+
+  it('empty grid', () => {
+    const grid: string[][] = [];
+    expect(countBeamCells(grid)).toBe(0);
+    expect(countBeamPaths(grid)).toBe(0n);
+  });
+});
