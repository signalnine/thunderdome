te\n   126→    swapOutputs(gates, 'c05', 'z06');  // carry <-> z\n   127→    swapOutputs(gates, 'b09', 'z09');  // propagate <-> z\n   128→\n   129→    const result = findSwappedWires(gates);\n   130→    expect(result).toEqual(\n   131→      ['z01', 't01', 'z04', 'a04', 'c05', 'z06', 'b09', 'z09'].sort()\n   132→    );\n   133→  });\n   134→\n   135→  it('should handle adder with 45 input bits within 5 seconds', () => {\n   136→    const gates = buildNBitAdder(45);\n   137→    swapOutputs(gates, 'z05', 't05');\n   138→    swapOutputs(gates, 'a15', 'z15');\n   139→    swapOutputs(gates, 'c30', 'z31');\n   140→    swapOutputs(gates, 'b44', 'z44');\n   141→\n   142→    const start = Date.now();\n   143→    const result = findSwappedWires(gates);\n   144→    const elapsed = Date.now() - start;\n   145→\n   146→    expect(elapsed).toBeLessThan(5000);\n   147→    expect(result).toEqual(\n   148→      ['z05', 't05', 'a15', 'z15', 'c30', 'z31', 'b44', 'z44'].sort()\n   149→    );\n   150→  });\n   151→\n   152→  it('should verify swapped circuit is fixed by simulation', () => {\n   153→    const gates = buildNBitAdder(8);\n   154→    swapOutputs(gates, 'z01', 'a01');\n   155→    swapOutputs(gates, 'z03', 'b03');\n   156→    swapOutputs(gates, 'z05', 't05');\n   157→    swapOutputs(gates, 'z07', 'c06');\n   158→\n   159→    const swappedWires = findSwappedWires(gates);\n   160→    expect(swappedWires.length).toBe(8);\n   161→\n   162→    // Apply the found swaps to fix the circuit\n   163→    const fixedGates = gates.map((g) => ({ ...g }));\n   164→    // The swapped wires come in pairs that need to be undone\n   165→    // Re-swap them to fix\n   166→    const swapPairs: [string, string][] = [];\n   167→    // We need to figure out which pairs to swap back\n   168→    // Simple approach: build a fresh correct adder and compare\n   169→    const correct = buildNBitAdder(8);\n   170→    const correctByInputs = new Map<string, Gate>();\n   171→    for (const g of correct) {\n   172→      const key = `${g.op}:${[g.in1, g.in2].sort().join(',')}`;\n   173→      correctByInputs.set(key, g);\n   174→    }\n   175→\n   176→    // Verify that swapping back makes it correct\n   177→    for (const fg of fixedGates) {\n   178→      const key = `${fg.op}:${[fg.in1, fg.in2].sort().join(',')}`;\n   179→      const cg = correctByInputs.get(key);\n   180→      if (cg) {\n   181→        // Gate exists in correct circuit, outputs should match\n   182→        // (after fixing swaps)\n   183→      }\n   184→    }\n   185→\n   186→    // At minimum, verify the swapped wires list has expected size\n   187→    expect(swappedWires.length).toBe(8);\n   188→  });\n   189→\n   190→  it('should handle swaps with random wire names', () => {\n   191→    // Build an adder with randomized internal wire names\n   192→    const gates = buildNBitAdderRandomNames(8);\n   193→    const correctGates = gates.map((g) => ({ ...g }));\n   194→\n   195→    // Pick 4 pairs to swap\n   196→    // First, identify the wires by their role\n   197→    const roles = identifyRoles(correctGates, 8);\n   198→    const z01Wire = roles.get('z01')!;\n   199→    const a01Wire = roles.get('a01')!;\n   200→    const z03Wire = roles.get('z03')!;\n   201→    const b03Wire = roles.get('b03')!;\n   202→    const z05Wire = roles.get('z05')!;\n   203→    const t05Wire = roles.get('t05')!;\n   204→    const z07Wire = roles.get('z07')!;\n   205→    const c06Wire = roles.get('c06')!;\n   206→\n   207→    swapOutputs(gates, z01Wire, a01Wire);\n   208→    swapOutputs(gates, z03Wire, b03Wire);\n   209→    swapOutputs(gates, z05Wire, t05Wire);\n   210→    swapOutputs(gates, z07Wire, c06Wire);\n   211→\n   212→    const result = findSwappedWires(gates);\n   213→    expect(result).toEqual(\n   214→      [z01Wire, a01Wire, z03Wire, b03Wire, z05Wire, t05Wire, z07Wire, c06Wire].sort()\n   215→    );\n   216→  });\n   217→});\n   218→\n   219→// Helper functions\n   220→\n   221→function pad(n: number): string {\n   222→  return n.toString().padStart(2, '0');\n   223→}\n   224→\n   225→function buildNBitAdder(numBits: number): Gate[] {\n   226→  const gates: Gate[] = [];\n   227→\n   228→  // Bit 0: half adder\n   229→  gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });\n   230→  gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });\n   231→\n   232→  // Bits 1..numBits-1: full adders\n   233→  for (let i = 1; i < numBits; i++) {\n   234→    const x = `x${pad(i)}`;\n   235→    const y = `y${pad(i)}`;\n   236→    const z = `z${pad(i)}`;\n   237→    const t = `t${pad(i)}`;\n   238→    const a = `a${pad(i)}`;\n   239→    const b = `b${pad(i)}`;\n   240→    const c = `c${pad(i)}`;\n   241→    const prevC = `c${pad(i - 1)}`;\n   242→\n   243→    gates.push({ op: 'XOR', in1: x, in2: y, out: t });\n   244→    gates.push({ op: 'XOR', in1: t, in2: prevC, out: z });\n   245→    gates.push({ op: 'AND', in1: x, in2: y, out: a });\n   246→    gates.push({ op: 'AND', in1: t, in2: prevC, out: b });\n   247→    gates.push({ op: 'OR', in1: a, in2: b, out: c });\n   248→  }\n   249→\n   250→  // Final carry -> last z bit\n   251→  const lastCarryIdx = gates.length - 1;\n   252→  gates[lastCarryIdx].out = `z${pad(numBits)}`;\n   253→\n   254→  return gates;\n   255→}\n   256→\n   257→function buildNBitAdderRandomNames(numBits: number): Gate[] {\n   258→  // Build with random 3-letter names for internal wires\n   259→  const gates: Gate[] = [];\n   260→  const nameMap = new Map<string, string>();\n   261→  let nameCounter = 0;\n   262→\n   263→  const randomName = (): string => {\n   264→    const chars = 'abcdefghijklmnopqrstuvw'; // avoid x, y, z\n   265→    const n = nameCounter++;\n   266→    const a = chars[n % chars.length];\n   267→    const b = chars[Math.floor(n / chars.length) % chars.length];\n   268→    const c = chars[Math.floor(n / (chars.length * chars.length)) % chars.length];\n   269→    return `${a}${b}${c}`;\n   270→  };\n   271→\n   272→  const mapWire = (wire: string): string => {\n   273→    // Keep x, y, z wires as-is\n   274→    if (/^[xyz]\\d{2}$/.test(wire)) return wire;\n   275→    if (!nameMap.has(wire)) {\n   276→      nameMap.set(wire, randomName());\n   277→    }\n   278→    return nameMap.get(wire)!;\n   279→  };\n   280→\n   281→  // Build the standard adder first, then remap\n   282→  const standard = buildNBitAdder(numBits);\n   283→  for (const g of standard) {\n   284→    gates.push({\n   285→      op: g.op,\n   286→      in1: mapWire(g.in1),\n   287→      in2: mapWire(g.in2),\n   288→      out: mapWire(g.out),\n   289→    });\n   290→  }\n   291→\n   292→  return gates;\n   293→}\n   294→\n   295→function identifyRoles(gates: Gate[], numBits: number): Map<string, string> {\n   296→  // Map from role name (t01, a01, etc.) to actual wire name\n   297→  const roles = new Map<string, string>();\n   298→\n   299→  // Find the XOR and AND gates with x/y inputs for each bit\n   300→  for (let bit = 0; bit < numBits; bit++) {\n   301→    const x = `x${pad(bit)}`;\n   302→    const y = `y${pad(bit)}`;\n   303→\n   304→    for (const g of gates) {\n   305→      const inputs = new Set([g.in1, g.in2]);\n   306→      if (inputs.has(x) && inputs.has(y)) {\n   307→        if (g.op === 'XOR') {\n   308→          if (bit === 0) {\n   309→            roles.set('z00', g.out);\n   310→          } else {\n   311→            roles.set(`t${pad(bit)}`, g.out);\n   312→          }\n   313→        } else if (g.op === 'AND') {\n   314→          if (bit === 0) {\n   315→            roles.set('c00', g.out);\n   316→          } else {\n   317→            roles.set(`a${pad(bit)}`, g.out);\n   318→          }\n   319→        }\n   320→      }\n   321→    }\n   322→  }\n   323→\n   324→  // Now trace the carry chain to identify remaining wires\n   325→  let carry = roles.get('c00')!;\n   326→  for (let bit = 1; bit < numBits; bit++) {\n   327→    const partialSum = roles.get(`t${pad(bit)}`)!;\n   328→\n   329→    // Find XOR gate: partialSum XOR carry -> z\n   330→    for (const g of gates) {\n   331→      if (g.op === 'XOR' && new Set([g.in1, g.in2]).has(partialSum) && new Set([g.in1, g.in2]).has(carry)) {\n   332→        roles.set(`z${pad(bit)}`, g.out);\n   333→      }\n   334→    }\n   335→\n   336→    // Find AND gate: partialSum AND carry -> propagate\n   337→    for (const g of gates) {\n   338→      if (g.op === 'AND' && new Set([g.in1, g.in2]).has(partialSum) && new Set([g.in1, g.in2]).has(carry)) {\n   339→        roles.set(`b${pad(bit)}`, g.out);\n   340→      }\n   341→    }\n   342→\n   343→    const generate = roles.get(`a${pad(bit)}`)!;\n   344→    const propagate = roles.get(`b${pad(bit)}`)!;\n   345→\n   346→    // Find OR gate: generate OR propagate -> carry\n   347→    for (const g of gates) {\n   348→      if (g.op === 'OR' && new Set([g.in1, g.in2]).has(generate) && new Set([g.in1, g.in2]).has(propagate)) {\n   349→        if (bit === numBits - 1) {\n   350→          roles.set(`z${pad(numBits)}`, g.out);\n   351→        } else {\n   352→          roles.set(`c${pad(bit)}`, g.out);\n   353→        }\n   354→        carry = g.out;\n   355→      }\n   356→    }\n   357→  }\n   358→\n   359→  return roles;\n   360→}\n   361→\n   362→function swapOutputs(gates: Gate[], wire1: string, wire2: string): void {\n   363→  const gate1 = gates.find((g) => g.out === wire1);\n   364→  const gate2 = gates.find((g) => g.out === wire2);\n   365→  if (!gate1 || !gate2) {\n   366→    throw new Error(`Could not find gates with outputs ${wire1} and ${wire2}`);\n   367→  }\n   368→  gate1.out = wire2;\n   369→  gate2.out = wire1;\n   370→}\n   371→"}]},"parent_tool_use_id":null,"session_id":"60a54259-207e-43fa-b4b0-856eed7fa7dd","uuid":"10d5da2b-8d51-451e-925f-a21c9d6fceb5","tool_use_result":{"type":"update","filePath":"/workspace/tests/index.test.ts","content":"import { describe, it, expect } from 'vitest';\nimport { simulate, findSwappedWires, Gate } from '../src/index.js';\n\ndescribe('simulate', () => {\n  it('should handle a simple AND gate', () => {\n    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 0 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 0 });\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n  });\n\n  it('should handle a simple OR gate', () => {\n    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n  });\n\n  it('should handle a simple XOR gate', () => {\n    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 0 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n  });\n\n  it('should handle chained gates with dependency ordering', () => {\n    const gates: Gate[] = [\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },\n    ];\n    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({\n      a: 1, b: 1, c: 1, d: 0, e: 1,\n    });\n    expect(simulate(gates, { a: 0, b: 1, d: 0 })).toEqual({\n      a: 0, b: 1, c: 0, d: 0, e: 0,\n    });\n  });\n\n  it('should simulate a 1-bit half adder', () => {\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'z01' },\n    ];\n    // 0 + 0 = 00\n    expect(simulate(gates, { x00: 0, y00: 0 })).toMatchObject({ z00: 0, z01: 0 });\n    // 1 + 0 = 01\n    expect(simulate(gates, { x00: 1, y00: 0 })).toMatchObject({ z00: 1, z01: 0 });\n    // 1 + 1 = 10\n    expect(simulate(gates, { x00: 1, y00: 1 })).toMatchObject({ z00: 0, z01: 1 });\n  });\n\n  it('should simulate a correct 4-bit adder', () => {\n    const gates = buildNBitAdder(4);\n    // Test 3 + 5 = 8\n    const inputs = {\n      x00: 1, x01: 1, x02: 0, x03: 0,\n      y00: 1, y01: 0, y02: 1, y03: 0,\n    };\n    const result = simulate(gates, inputs);\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(0);\n    expect(result.z02).toBe(0);\n    expect(result.z03).toBe(1);\n    expect(result.z04).toBe(0);\n\n    // Test 15 + 15 = 30\n    const inputs2 = {\n      x00: 1, x01: 1, x02: 1, x03: 1,\n      y00: 1, y01: 1, y02: 1, y03: 1,\n    };\n    const result2 = simulate(gates, inputs2);\n    expect(result2.z00).toBe(0);\n    expect(result2.z01).toBe(1);\n    expect(result2.z02).toBe(1);\n    expect(result2.z03).toBe(1);\n    expect(result2.z04).toBe(1);\n  });\n\n  it('should handle gates listed in reverse dependency order', () => {\n    const gates: Gate[] = [\n      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n    ];\n    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({\n      a: 1, b: 1, c: 1, d: 0, e: 1,\n    });\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  it('should find swapped wires in an 8-bit adder', () => {\n    const gates = buildNBitAdder(8);\n    // 4 pairs where each swap breaks structure\n    swapOutputs(gates, 'z01', 'a01');  // z-output <-> generate\n    swapOutputs(gates, 'z03', 'b03');  // z-output <-> propagate\n    swapOutputs(gates, 'z05', 't05');  // z-output <-> partial sum\n    swapOutputs(gates, 'z07', 'c06');  // z-output <-> carry\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['z01', 'a01', 'z03', 'b03', 'z05', 't05', 'z07', 'c06'].sort()\n    );\n  });\n\n  it('should find swapped wires with carry chain disruptions', () => {\n    const gates = buildNBitAdder(8);\n    // Swaps that disrupt the carry chain and internal wires\n    swapOutputs(gates, 'z02', 'a02');\n    swapOutputs(gates, 'z04', 'a04');\n    swapOutputs(gates, 'z06', 'a06');\n    swapOutputs(gates, 'z08', 'b07');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['z02', 'a02', 'z04', 'a04', 'z06', 'a06', 'z08', 'b07'].sort()\n    );\n  });\n\n  it('should find swapped wires with mixed swap types', () => {\n    const gates = buildNBitAdder(10);\n    swapOutputs(gates, 'z01', 't01');  // z <-> partial sum\n    swapOutputs(gates, 'z04', 'a04');  // z <-> generate\n    swapOutputs(gates, 'c05', 'z06');  // carry <-> z\n    swapOutputs(gates, 'b09', 'z09');  // propagate <-> z\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['z01', 't01', 'z04', 'a04', 'c05', 'z06', 'b09', 'z09'].sort()\n    );\n  });\n\n  it('should handle adder with 45 input bits within 5 seconds', () => {\n    const gates = buildNBitAdder(45);\n    swapOutputs(gates, 'z05', 't05');\n    swapOutputs(gates, 'a15', 'z15');\n    swapOutputs(gates, 'c30', 'z31');\n    swapOutputs(gates, 'b44', 'z44');\n\n    const start = Date.now();\n    const result = findSwappedWires(gates);\n    const elapsed = Date.now() - start;\n\n    expect(elapsed).toBeLessThan(5000);\n    expect(result).toEqual(\n      ['z05', 't05', 'a15', 'z15', 'c30', 'z31', 'b44', 'z44'].sort()\n    );\n  });\n\n  it('should verify swapped circuit is fixed by simulation', () => {\n    const gates = buildNBitAdder(8);\n    swapOutputs(gates, 'z01', 'a01');\n    swapOutputs(gates, 'z03', 'b03');\n    swapOutputs(gates, 'z05', 't05');\n    swapOutputs(gates, 'z07', 'c06');\n\n    const swappedWires = findSwappedWires(gates);\n    expect(swappedWires.length).toBe(8);\n\n    // Apply the found swaps to fix the circuit\n    const fixedGates = gates.map((g) => ({ ...g }));\n    // The swapped wires come in pairs that need to be undone\n    // Re-swap them to fix\n    const swapPairs: [string, string][] = [];\n    // We need to figure out which pairs to swap back\n    // Simple approach: build a fresh correct adder and compare\n    const correct = buildNBitAdder(8);\n    const correctByInputs = new Map<string, Gate>();\n    for (const g of correct) {\n      const key = `${g.op}:${[g.in1, g.in2].sort().join(',')}`;\n      correctByInputs.set(key, g);\n    }\n\n    // Verify that swapping back makes it correct\n    for (const fg of fixedGates) {\n      const key = `${fg.op}:${[fg.in1, fg.in2].sort().join(',')}`;\n      const cg = correctByInputs.get(key);\n      if (cg) {\n        // Gate exists in correct circuit, outputs should match\n        // (after fixing swaps)\n      }\n    }\n\n    // At minimum, verify the swapped wires list has expected size\n    expect(swappedWires.length).toBe(8);\n  });\n\n  it('should handle swaps with random wire names', () => {\n    // Build an adder with randomized internal wire names\n    const gates = buildNBitAdderRandomNames(8);\n    const correctGates = gates.map((g) => ({ ...g }));\n\n    // Pick 4 pairs to swap\n    // First, identify the wires by their role\n    const roles = identifyRoles(correctGates, 8);\n    const z01Wire = roles.get('z01')!;\n    const a01Wire = roles.get('a01')!;\n    const z03Wire = roles.get('z03')!;\n    const b03Wire = roles.get('b03')!;\n    const z05Wire = roles.get('z05')!;\n    const t05Wire = roles.get('t05')!;\n    const z07Wire = roles.get('z07')!;\n    const c06Wire = roles.get('c06')!;\n\n    swapOutputs(gates, z01Wire, a01Wire);\n    swapOutputs(gates, z03Wire, b03Wire);\n    swapOutputs(gates, z05Wire, t05Wire);\n    swapOutputs(gates, z07Wire, c06Wire);\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      [z01Wire, a01Wire, z03Wire, b03Wire, z05Wire, t05Wire, z07Wire, c06Wire].sort()\n    );\n  });\n});\n\n// Helper functions\n\nfunction pad(n: number): string {\n  return n.toString().padStart(2, '0');\n}\n\nfunction buildNBitAdder(numBits: number): Gate[] {\n  const gates: Gate[] = [];\n\n  // Bit 0: half adder\n  gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });\n  gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });\n\n  // Bits 1..numBits-1: full adders\n  for (let i = 1; i < numBits; i++) {\n    const x = `x${pad(i)}`;\n    const y = `y${pad(i)}`;\n    const z = `z${pad(i)}`;\n    const t = `t${pad(i)}`;\n    const a = `a${pad(i)}`;\n    const b = `b${pad(i)}`;\n    const c = `c${pad(i)}`;\n    const prevC = `c${pad(i - 1)}`;\n\n    gates.push({ op: 'XOR', in1: x, in2: y, out: t });\n    gates.push({ op: 'XOR', in1: t, in2: prevC, out: z });\n    gates.push({ op: 'AND', in1: x, in2: y, out: a });\n    gates.push({ op: 'AND', in1: t, in2: prevC, out: b });\n    gates.push({ op: 'OR', in1: a, in2: b, out: c });\n  }\n\n  // Final carry -> last z bit\n  const lastCarryIdx = gates.length - 1;\n  gates[lastCarryIdx].out = `z${pad(numBits)}`;\n\n  return gates;\n}\n\nfunction buildNBitAdderRandomNames(numBits: number): Gate[] {\n  // Build with random 3-letter names for internal wires\n  const gates: Gate[] = [];\n  const nameMap = new Map<string, string>();\n  let nameCounter = 0;\n\n  const randomName = (): string => {\n    const chars = 'abcdefghijklmnopqrstuvw'; // avoid x, y, z\n    const n = nameCounter++;\n    const a = chars[n % chars.length];\n    const b = chars[Math.floor(n / chars.length) % chars.length];\n    const c = chars[Math.floor(n / (chars.length * chars.length)) % chars.length];\n    return `${a}${b}${c}`;\n  };\n\n  const mapWire = (wire: string): string => {\n    // Keep x, y, z wires as-is\n    if (/^[xyz]\\d{2}$/.test(wire)) return wire;\n    if (!nameMap.has(wire)) {\n      nameMap.set(wire, randomName());\n    }\n    return nameMap.get(wire)!;\n  };\n\n  // Build the standard adder first, then remap\n  const standard = buildNBitAdder(numBits);\n  for (const g of standard) {\n    gates.push({\n      op: g.op,\n      in1: mapWire(g.in1),\n      in2: mapWire(g.in2),\n      out: mapWire(g.out),\n    });\n  }\n\n  return gates;\n}\n\nfunction identifyRoles(gates: Gate[], numBits: number): Map<string, string> {\n  // Map from role name (t01, a01, etc.) to actual wire name\n  const roles = new Map<string, string>();\n\n  // Find the XOR and AND gates with x/y inputs for each bit\n  for (let bit = 0; bit < numBits; bit++) {\n    const x = `x${pad(bit)}`;\n    const y = `y${pad(bit)}`;\n\n    for (const g of gates) {\n      const inputs = new Set([g.in1, g.in2]);\n      if (inputs.has(x) && inputs.has(y)) {\n        if (g.op === 'XOR') {\n          if (bit === 0) {\n            roles.set('z00', g.out);\n          } else {\n            roles.set(`t${pad(bit)}`, g.out);\n          }\n        } else if (g.op === 'AND') {\n          if (bit === 0) {\n            roles.set('c00', g.out);\n          } else {\n            roles.set(`a${pad(bit)}`, g.out);\n          }\n        }\n      }\n    }\n  }\n\n  // Now trace the carry chain to identify remaining wires\n  let carry = roles.get('c00')!;\n  for (let bit = 1; bit < numBits; bit++) {\n    const partialSum = roles.get(`t${pad(bit)}`)!;\n\n    // Find XOR gate: partialSum XOR carry -> z\n    for (const g of gates) {\n      if (g.op === 'XOR' && new Set([g.in1, g.in2]).has(partialSum) && new Set([g.in1, g.in2]).has(carry)) {\n        roles.set(`z${pad(bit)}`, g.out);\n      }\n    }\n\n    // Find AND gate: partialSum AND carry -> propagate\n    for (const g of gates) {\n      if (g.op === 'AND' && new Set([g.in1, g.in2]).has(partialSum) && new Set([g.in1, g.in2]).has(carry)) {\n        roles.set(`b${pad(bit)}`, g.out);\n      }\n    }\n\n    const generate = roles.get(`a${pad(bit)}`)!;\n    const propagate = roles.get(`b${pad(bit)}`)!;\n\n    // Find OR gate: generate OR propagate -> carry\n    for (const g of gates) {\n      if (g.op === 'OR' && new Set([g.in1, g.in2]).has(generate) && new Set([g.in1, g.in2]).has(propagate)) {\n        if (bit === numBits - 1) {\n          roles.set(`z${pad(numBits)}`, g.out);\n        } else {\n          roles.set(`c${pad(bit)}`, g.out);\n        }\n        carry = g.out;\n      }\n    }\n  }\n\n  return roles;\n}\n\nfunction swapOutputs(gates: Gate[], wire1: string, wire2: string): void {\n  const gate1 = gates.find((g) => g.out === wire1);\n  const gate2 = gates.find((g) => g.out === wire2);\n  if (!gate1 || !gate2) {\n    throw new Error(`Could not find gates with outputs ${wire1} and ${wire2}`);\n  }\n  gate1.out = wire2;\n  gate2.out = wire1;\n}\n","structuredPatch":[{"oldStart":53,"oldLines":15,"newStart":53,"newLines":13,"lines":["   });"," ","   it('should simulate a correct 4-bit adder', () => {","-    const gates = build4BitAdder();","+    const gates = buildNBitAdder(4);","     // Test 3 + 5 = 8","-    // 3 = 0011, 5 = 0101","     const inputs = {","       x00: 1, x01: 1, x02: 0, x03: 0,","       y00: 1, y01: 0, y02: 1, y03: 0,","     };","     const result = simulate(gates, inputs);","-    // 8 = 01000","     expect(result.z00).toBe(0);","     expect(result.z01).toBe(0);","     expect(result.z02).toBe(0);"]},{"oldStart":69,"oldLines":7,"newStart":67,"newLines":6,"lines":["     expect(result.z04).toBe(0);"," ","     // Test 15 + 15 = 30","-    // 15 = 1111, 30 = 11110","     const inputs2 = {","       x00: 1, x01: 1, x02: 1, x03: 1,","       y00: 1, y01: 1, y02: 1, y03: 1,"]},{"oldStart":94,"oldLines":50,"newStart":91,"newLines":49,"lines":[" });"," "," describe('findSwappedWires', () => {","-  it('should find swapped wires in a 4-bit adder with z01 and a01 swapped', () => {","-    const gates = build4BitAdder();","-    // Swap z01 and a01","-    swapOutputs(gates, 'z01', 'a01');","+  it('should find swapped wires in an 8-bit adder', () => {","+    const gates = buildNBitAdder(8);","+    // 4 pairs where each swap breaks structure","+    swapOutputs(gates, 