ND':\n            result = a & b;\n            break;\n          case 'OR':\n            result = a | b;\n            break;\n          case 'XOR':\n            result = a ^ b;\n            break;\n        }\n        wires[gate.out] = result;\n        remaining.delete(idx);\n        changed = true;\n      }\n    }\n  }\n\n  return wires;\n}\n\n/**\n * Find the 8 swapped output wires in a broken ripple-carry adder circuit.\n *\n * A correct N-bit ripple-carry adder has this structure for each bit i:\n *\n * Bit 0 (half adder):\n *   x00 XOR y00 -> z00\n *   x00 AND y00 -> c00\n *\n * Bit i > 0 (full adder):\n *   xNN XOR yNN -> tNN       (partial sum)\n *   tNN XOR c(N-1) -> zNN    (final sum)\n *   xNN AND yNN -> aNN       (generate carry)\n *   tNN AND c(N-1) -> bNN    (propagate carry)\n *   aNN OR bNN -> cNN        (carry out)\n *\n * Last bit:\n *   c(N-1) -> z(N+1)         (final carry = MSB output)\n *\n * With 4 pairs of swapped outputs, we need to identify structural violations.\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Build lookup structures\n  const gateByOutput = new Map<string, Gate>();\n  for (const gate of gates) {\n    gateByOutput.set(gate.out, gate);\n  }\n\n  // Helper: check if a wire is an input wire (xNN or yNN)\n  const isInputWire = (w: string): boolean =>\n    /^[xy]\\d{2}$/.test(w);\n\n  // Helper: check if a gate has given inputs (order-independent)\n  const gateHasInputs = (g: Gate, a: string, b: string): boolean =>\n    (g.in1 === a && g.in2 === b) || (g.in1 === b && g.in2 === a);\n\n  // Helper: find a gate by op and inputs\n  const findGate = (op: string, a: string, b: string): Gate | undefined => {\n    return gates.find(\n      (g) => g.op === op && gateHasInputs(g, a, b)\n    );\n  };\n\n  // Helper: check if a gate's inputs include a given wire\n  const gateHasInput = (g: Gate, w: string): boolean =>\n    g.in1 === w || g.in2 === w;\n\n  // Helper: get other input of a gate\n  const otherInput = (g: Gate, w: string): string =>\n    g.in1 === w ? g.in2 : g.in1;\n\n  // Determine the number of input bits\n  let maxBit = 0;\n  for (const gate of gates) {\n    const mx = gate.in1.match(/^x(\\d+)$/);\n    const my = gate.in2.match(/^x(\\d+)$/);\n    if (mx) maxBit = Math.max(maxBit, parseInt(mx[1]));\n    if (my) maxBit = Math.max(maxBit, parseInt(my[1]));\n  }\n  const numBits = maxBit + 1;\n\n  const swapped: Set<string> = new Set();\n\n  // Swap two gate outputs and update our lookup\n  const doSwap = (a: string, b: string) => {\n    const gateA = gateByOutput.get(a)!;\n    const gateB = gateByOutput.get(b)!;\n    // Swap the output fields\n    gateA.out = b;\n    gateB.out = a;\n    // Update the lookup map\n    gateByOutput.set(a, gateB);\n    gateByOutput.set(b, gateA);\n    swapped.add(a);\n    swapped.add(b);\n  };\n\n  // Strategy: Walk through each bit position and verify the adder structure.\n  // When we find a violation, identify the swap and fix it, then continue.\n\n  // For bit 0: expect xNN XOR yNN -> z00, xNN AND yNN -> carry\n  // For bit i: expect the full adder pattern\n\n  const pad = (n: number): string => n.toString().padStart(2, '0');\n\n  // Track the carry wire for each bit\n  let carry = '';\n\n  for (let bit = 0; bit < numBits; bit++) {\n    const xWire = `x${pad(bit)}`;\n    const yWire = `y${pad(bit)}`;\n    const zWire = `z${pad(bit)}`;\n\n    if (bit === 0) {\n      // Half adder: x00 XOR y00 -> z00\n      const xorGate = findGate('XOR', xWire, yWire);\n      if (!xorGate) continue; // shouldn't happen\n\n      if (xorGate.out !== zWire) {\n        // xorGate.out should be z00 — find what's producing z00 and swap\n        doSwap(xorGate.out, zWire);\n      }\n\n      // x00 AND y00 -> carry\n      const andGate = findGate('AND', xWire, yWire);\n      if (!andGate) continue;\n      carry = andGate.out;\n\n      // Carry should not be a z-wire (unless it's the final z)\n      if (carry.startsWith('z') && carry !== `z${pad(numBits)}`) {\n        // This carry wire is wrongly named as a z-output. Find what should be there.\n        // We'll detect this during the next bit's processing.\n      }\n    } else {\n      // Full adder for bit i:\n      // Step 1: xNN XOR yNN -> partial_sum (tNN)\n      const xorXY = findGate('XOR', xWire, yWire);\n      if (!xorXY) continue;\n      let partialSum = xorXY.out;\n\n      // Step 2: partial_sum XOR carry_in -> zNN\n      let xorFinal = findGate('XOR', partialSum, carry);\n\n      if (!xorFinal) {\n        // Either partialSum or carry is wrong.\n        // Check: is there a XOR gate that takes carry as input?\n        // If so, its other input should be partialSum — that tells us partialSum was swapped.\n        const xorWithCarry = gates.find(\n          (g) => g.op === 'XOR' && gateHasInput(g, carry) && !isInputWire(otherInput(g, carry))\n        );\n        if (xorWithCarry) {\n          const correctPartialSum = otherInput(xorWithCarry, carry);\n          // partialSum should have been correctPartialSum\n          doSwap(partialSum, correctPartialSum);\n          partialSum = correctPartialSum;\n          xorFinal = xorWithCarry;\n        } else {\n          // Check: is there a XOR gate that takes partialSum as input (not x/y inputs)?\n          const xorWithPartial = gates.find(\n            (g) =>\n              g.op === 'XOR' &&\n              gateHasInput(g, partialSum) &&\n              !isInputWire(otherInput(g, partialSum))\n          );\n          if (xorWithPartial) {\n            const correctCarry = otherInput(xorWithPartial, partialSum);\n            doSwap(carry, correctCarry);\n            carry = correctCarry;\n            xorFinal = xorWithPartial;\n          }\n        }\n      }\n\n      if (!xorFinal) continue;\n\n      // xorFinal should output zNN\n      if (xorFinal.out !== zWire) {\n        doSwap(xorFinal.out, zWire);\n      }\n\n      // Step 3: xNN AND yNN -> generate\n      const andXY = findGate('AND', xWire, yWire);\n      if 