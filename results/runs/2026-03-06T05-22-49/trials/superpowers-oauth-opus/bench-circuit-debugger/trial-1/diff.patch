pped', () => {\n    const gates = build4BitAdder();\n    // Swap z01 and a01\n    swapOutputs(gates, 'z01', 'a01');\n\n    // Need 4 pairs = 8 wires. Add 3 more swaps.\n    swapOutputs(gates, 'z02', 'b02');\n    swapOutputs(gates, 't03', 'c02');\n    swapOutputs(gates, 'z03', 'a03');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a01', 'a03', 'b02', 'c02', 't03', 'z01', 'z02', 'z03'].sort());\n  });\n\n  it('should find swapped wires when carry output is swapped with z wire', () => {\n    const gates = build4BitAdder();\n    // Swap carry c01 with z02\n    swapOutputs(gates, 'c01', 'z02');\n    // Swap t02 with a02\n    swapOutputs(gates, 't02', 'a02');\n    // Swap b03 with z03\n    swapOutputs(gates, 'b03', 'z03');\n    // Swap c00 with t01\n    swapOutputs(gates, 'c00', 't01');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a02', 'b03', 'c00', 'c01', 't01', 't02', 'z02', 'z03'].sort());\n  });\n\n  it('should work with a larger adder (8-bit)', () => {\n    const gates = buildNBitAdder(8);\n    // Swap 4 pairs\n    swapOutputs(gates, 'z01', 't01');\n    swapOutputs(gates, 'z04', 'a04');\n    swapOutputs(gates, 'c05', 'z06');\n    swapOutputs(gates, 'b07', 'z07');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a04', 'b07', 'c05', 't01', 'z01', 'z04', 'z06', 'z07'].sort());\n  });\n\n  it('should handle adder with 45 input bits within 5 seconds', () => {\n    const gates = buildNBitAdder(45);\n    // Swap 4 pairs at various positions\n    swapOutputs(gates, 'z05', 't05');\n    swapOutputs(gates, 'a15', 'z15');\n    swapOutputs(gates, 'c30', 'z31');\n    swapOutputs(gates, 'b44', 'z44');\n\n    const start = Date.now();\n    const result = findSwappedWires(gates);\n    const elapsed = Date.now() - start;\n\n    expect(elapsed).toBeLessThan(5000);\n    expect(result).toEqual(['a15', 'b44', 'c30', 't05', 'z05', 'z15', 'z31', 'z44'].sort());\n  });\n});\n\n// Helper functions\n\nfu