+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+/**
+ * Simulate a circuit of logic gates given initial wire values.
+ * Process gates in dependency order until all gates have fired.
+ */
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = new Set<number>(gates.map((_, i) => i));
+
+  let changed = true;
+  while (changed && remaining.size > 0) {
+    changed = false;
+    for (const idx of remaining) {
+      const gate = gates[idx];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        let result: number;
+        switch (gate.op) {
+          case 'AND':
+            result = a & b;
+            break;
+          case 'OR':
+            result = a | b;
+            break;
+          case 'XOR':
+            result = a ^ b;
+            break;
+        }
+        wires[gate.out] = result;
+        remaining.delete(idx);
+        changed = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+/**
+ * Find the 8 swapped output wires in a broken ripple-carry adder circuit.
+ *
+ * Strategy: Walk through each bit position of the adder and verify the
+ * expected structure. When a structural violation is found, identify which
+ * wires must be swapped and fix them in-place, then continue.
+ */
+export function findSwappedWires(gates: Gate[]): string[] {
+  // Work on a copy so we don't mutate the input
+  const gatesCopy: Gate[] = gates.map((g) => ({ ...g }));
+
+  // Build lookup structures
+  const gateByOutput = new Map<string, Gate>();
+  for (const gate of gatesCopy) {
+    gateByOutput.set(gate.out, gate);
+  }
+
+  // Helper to find a gate by op and inputs (order-independent)
+  const findGate = (op: Gate['op'], a: string, b: string): Gate | undefined => {
+    return gatesCopy.find(
+      (g) =>
+        g.op === op &&
+        ((g.in1 === a && g.in2 === b) || (g.in1 === b && g.in2 === a))
+    );
+  };
+
+  // Helper: check if a wire is an input wire (xNN or yNN)
+  const isInputWire = (w: string): boolean => /^[xy]\d{2}$/.test(w);
+
+  const gateHasInput = (g: Gate, w: string): boolean =>
+    g.in1 === w || g.in2 === w;
+
+  const otherInput = (g: Gate, w: string): string =>
+    g.in1 === w ? g.in2 : g.in1;
+
+  // Determine the number of input bits
+  let maxBit = 0;
+  for (const gate of gatesCopy) {
+    for (const wire of [gate.in1, gate.in2]) {
+      const m = wire.match(/^x(\d+)$/);
+      if (m) maxBit = Math.max(maxBit, parseInt(m[1]));
+    }
+  }
+  const numBits = maxBit + 1;
+
+  const swapped: Set<string> = new Set();
+
+  // Swap two gate outputs and update lookup
+  const doSwap = (a: string, b: string) => {
+    const gateA = gateByOutput.get(a)!;
+    const gateB = gateByOutput.get(b)!;
+    gateA.out = b;
+    gateB.out = a;
+    gateByOutput.set(a, gateB);
+    gateByOutput.set(b, gateA);
+    swapped.add(a);
+    swapped.add(b);
+  };
+
+  const pad = (n: number): string => n.toString().padStart(2, '0');
+
+  let carry = '';
+
+  for (let bit = 0; bit < numBits; bit++) {
+    const xWire = `x${pad(bit)}`;
+    const yWire = `y${pad(bit)}`;
+    const zWire = `z${pad(bit)}`;
+
+    if (bit === 0) {
+      // Half adder: x00 XOR y00 -> z00
+      const xorGate = findGate('XOR', xWire, yWire);
+      if (!xorGate) continue;
+
+      if (xorGate.out !== zWire) {
+        doSwap(xorGate.out, zWire);
+      }
+
+      // x00 AND y00 -> carry
+      const andGate = findGate('AND', xWire, yWire);
+      if (!andGate) continue;
+      carry = andGate.out;
+    } else {
+      // Full adder for bit i:
+      // 1) xNN XOR yNN -> partialSum
+      const xorXY = findGate('XOR', xWire, yWire);
+      if (!xorXY) continue;
+      let partialSum = xorXY.out;
+
+      // 2) partialSum XOR carry -> zNN
+      let xorFinal = findGate('XOR', partialSum, carry);
+
+      if (!xorFinal) {
+        // Either partialSum or carry is wrong (one of them was swapped).
+        // Look for any XOR gate that uses carry (not an x/y input gate)
+        const xorWithCarry = gatesCopy.find(
+          (g) =>
+            g.op === 'XOR' &&
+            gateHasInput(g, carry) &&
+            !isInputWire(g.in1) &&
+            !isInputWire(g.in2)
+        );
+        if (xorWithCarry) {
+          // The other input should be the correct partialSum
+          const correctPartialSum = otherInput(xorWithCarry, carry);
+          doSwap(partialSum, correctPartialSum);
+          partialSum = correctPartialSum;
+          xorFinal = xorWithCarry;
+        } else {
+          // Look for any XOR gate that uses partialSum (not an x/y input gate)
+          const xorWithPartial = gatesCopy.find(
+            (g) =>
+              g.op === 'XOR' &&
+              gateHasInput(g, partialSum) &&
+              !isInputWire(g.in1) &&
+              !isInputWire(g.in2)
+          );
+          if (xorWithPartial) {
+            const correctCarry = otherInput(xorWithPartial, partialSum);
+            doSwap(carry, correctCarry);
+            carry = correctCarry;
+            xorFinal = xorWithPartial;
+          }
+        }
+      }
+
+      if (!xorFinal) continue;
+
+      // xorFinal should output zNN
+      if (xorFinal.out !== zWire) {
+        doSwap(xorFinal.out, zWire);
+      }
+
+      // 3) xNN AND yNN -> generate
+      const andXY = findGate('AND', xWire, yWire);
+      if (!andXY) continue;
+      const generate = andXY.out;
+
+      // 4) partialSum AND carry -> propagate
+      const andPC = findGate('AND', partialSum, carry);
+      if (!andPC) continue;
+      const propagate = andPC.out;
+
+      // 5) generate OR propagate -> carryOut
+      let orGate = findGate('OR', generate, propagate);
+      if (!orGate) {
+        // One of generate or propagate is swapped
+        const orWithGen = gatesCopy.find(
+          (g) => g.op === 'OR' && gateHasInput(g, generate)
+        );
+        if (orWithGen) {
+          const correctProp = otherInput(orWithGen, generate);
+          doSwap(propagate, correctProp);
+          orGate = orWithGen;
+        } else {
+          const orWithProp = gatesCopy.find(
+            (g) => g.op === 'OR' && gateHasInput(g, propagate)
+          );
+          if (orWithProp) {
+            const correctGen = otherInput(orWithProp, propagate);
+            doSwap(generate, correctGen);
+            orGate = orWithProp;
+          }
+        }
+      }
+
+      if (!orGate) continue;
+      carry = orGate.out;
+    }
+  }
+
+  return [...swapped].sort();
+}
