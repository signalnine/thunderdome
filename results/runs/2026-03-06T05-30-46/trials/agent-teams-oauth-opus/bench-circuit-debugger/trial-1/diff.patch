 })).toEqual({ a: 1, b: 0, c: 0 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 0 });\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n  });\n\n  it('should simulate a simple OR gate', () => {\n    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });\n  });\n\n  it('should simulate a simple XOR gate', () => {\n    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 0 });\n  });\n\n  it('should handle gates in dependency order', () => {\n    const gates: Gate[] = [\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },\n    ];\n    const result = simulate(gates, { a: 1, b: 1, d: 0 });\n    expect(result).toEqual({ a: 1, b: 1, c: 1, d: 0, e: 1 });\n  });\n\n  it('should handle gates listed out of dependency order', () => {\n    const gates: Gate[] = [\n      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n    ];\n    const result = simulate(gates, { a: 1, b: 0, d: 1 });\n    expect(result).toEqual({ a: 1, b: 0, c: 0, d: 1, e: 1 });\n  });\n\n  it('should simulate a 2-bit adder correctly', () => {\n    // Bit 0: half adder\n    // Bit 1: full adder\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },\n    ];\n    // 3 + 3 = 6 -> binary: 11 + 11 = 110\n    const result = simulate(gates, { x00: 1, x01: 1, y00: 1, y01: 1 });\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(1);\n    expect(result.z02).toBe(1);\n\n    // 2 + 1 = 3 -> binary: 10 + 01 = 011\n    const result2 = simulate(gates, { x00: 0, x01: 1, y00: 1, y01: 0 });\n    expect(result2.z00).toBe(1);\n    expect(result2.z01).toBe(1);\n    expect(result2.z02).toBe(0);\n  });\n\n  it('should simulate a multi-step chain', () => {\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'a', in2: 'b', out: 'p' },\n      { op: 'AND', in1: 'p', in2: 'c', out: 'q' },\n      { op: 'OR', in1: 'q', in2: 'd', out: 'r' },\n    ];\n    const result = simulate(gates, { a: 1, b: 0, c: 1, d: 0 });\n    expect(result.p).toBe(1);\n    expect(result.q).toBe(1);\n    expect(result.r).toBe(1);\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  function make4BitAdder(): Gate[] {\n    return [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n      { op: 'OR', in1: 'a03', in2: 'b03', out: 'z04' },\n    ];\n  }\n\n  function swapOutputWires(gates: Gate[], w1: string, w2: string) {\n    const g1 = gates.find((g) => g.out === w1)!;\n    const g2 = gates.find((g) => g.out === w2)!;\n    g1.out = w2;\n    g2.out = w1;\n  }\n\n  it('should find 4 pairs of swapped wires in a 4-bit adder', () => {\n    const gates = make4BitAdder();\n    // Swap 4 pairs\n    swapOutputWires(gates, 'z01', 'a01');\n    swapOutputWires(gates, 'z02', 'b02');\n    swapOutputWires(gates, 'c00', 't01');\n    swapOutputWires(gates, 'z03', 'c02');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['z01', 'a01', 'z02', 'b02', 'c00', 't01', 'z03', 'c02'].sort()\n    );\n  });\n\n  it('should find swaps when z00 is swapped', () => {\n    const gates = make4BitAdder();\n    swapOutputWires(gates, 'z00', 'c00');\n    swapOutputWires(gates, 'z01', 'a01');\n    swapOutputWires(gates, 't02', 'a02');\n    swapOutputWires(gates, 'z04', 'c02');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['z00', 'c00', 'z01', 'a01', 't02', 'a02', 'z04', 'c02'].sort()\n    );\n  });\n\n  it('should handle a larger adder (8-bit)', () => {\n    // Build an 8-bit adder\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n    ];\n    for (let i = 1; i < 8; i++) {\n      const xi = `x${String(i).padStart(2, '0')}`;\n      const yi = `y${String(i).padStart(2, '0')}`;\n      const zi = `z${String(i).padStart(2, '0')}`;\n      const ti = `t${String(i).padStart(2, '0')}`;\n      const ai = `a${String(i).padStart(2, '0')}`;\n      const bi = `b${String(i).padStart(2, '0')}`;\n      const ci = `c${String(i).padStart(2, '0')}`;\n      const prevC = `c${String(i - 1).padStart(2, '0')}`;\n      gates.push(\n        { op: 'XOR', in1: xi, in2: yi, out: ti },\n        { op: 'XOR', in1: ti, in2: prevC, out: zi },\n        { op: 'AND', in1: xi, in2: yi, out: ai },\n        { op: 'AND', in1: ti, in2: prevC, out: bi },\n        { op: 'OR', in1: ai, in2: bi, out: ci }\n      );\n    }\n    // Last carry -> z08\n    const lastGateIdx = gates.length - 1;\n    gates[lastGateIdx].out = 'z08';\n\n    // Swap 4 pairs\n    swapOutputWires(gates, 'z01', 't01');\n    swapOutputWires(gates, 'a03', 'b03');\n    swapOutputWires(gates, 'z05', 'c04');\n    swapOutputWires(gates, 'z07', 'a07');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['z01', 't01', 'a03', 'b03', 'z05', 'c04', 'z07', 'a07'].sort()\n    );\n  });\n\n  it('should handle swaps involving the final carry output', () => {\n    const gates = make4BitAdder();\n    swapOutputWires(gates, 'z04', 'b03');\n    swapOutputWires(gates, 'z01', 'b01');\n    swapOutputWires(gates, 't02', 'c01');\n    swapOutputWires(gates, 'a03', 't03');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['z04', 'b03', 'z01', 'b01', 't02', 'c01', 'a03', 't03'].sort()\n    );\n  });\n\n  it('should return a sorted array of 8 wire names', () => {\n    const gates = make4BitAdder();\n    swapOutputWires(gates, 'z00', 'c00');\n    swapOutputWires(gates, 'z01', 'a01');\n    swapOutputWires(gates, 'z02', 'a02');\n    swapOutputWires(gates, 'z03', 'a03');\n\n    const result = findSwappedWires(gates);\n    expect(result).toHaveLength(8);\n    // Check sorted\n    const sorted = [...result].sort();\n    expect(result).toEqual(sorted);\n  });\n});\n"},"sourceToolAssistantUUID":"f5d95cfd-293b-4f6a-907a-fb628378258e"}
