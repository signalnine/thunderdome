   swapOutputWires(gates, 'z04', 'c01');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['z00', 'c00', 'z01', 'a01', 'z02', 'a02', 'z04', 'c01'].sort()\n    );\n  });\n\n  it('should handle a larger adder (8-bit)', () => {\n    const gates = makeAdder(8);\n    swapOutputWires(gates, 'z01', 't01');\n    swapOutputWires(gates, 'z03', 'b03');\n    swapOutputWires(gates, 'z05', 'c04');\n    swapOutputWires(gates, 'z07', 'a07');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['z01', 't01', 'z03', 'b03', 'z05', 'c04', 'z07', 'a07'].sort()\n    );\n  });\n\n  it('should handle swaps involving the final carry output', () => {\n    const gates = makeAdder(4);\n    swapOutputWires(gates, 'z04', 'b03');\n    swapOutputWires(gates, 'z01', 'b01');\n    swapOutputWires(gates, 'a03', 't03');\n    swapOutputWires(gates, 'z02', 'a02');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['z04', 'b03', 'z01', 'b01', 'a03', 't03', 'z02', 'a02'].sort()\n    );\n  });\n\n  it('should return a sorted array of 8 wire names', () => {\n    const gates = makeAdder(4);\n    swapOutputWires(gates, 'z00', 'c00');\n    swapOutputWires(gates, 'z01', 'a01');\n    swapOutputWires(gates, 'z02', 'a02');\n    swapOutputWires(gates, 'z03', 'a03');\n\n    const result = findSwappedWires(gates);\n    expect(result).toHaveLength(8);\n    const sorted = [...result].sort();\n    expect(result).toEqual(sorted);\n  });\n\n  it('should handle cross-bit swaps', () => {\n    const gates = makeAdder(6);\n    // Swap carry output from bit 1 with z output of bit 4\n    swapOutputWires(gates, 'c01', 'z04');\n    // Swap partial sum of bit 3 with generate of bit 5\n    swapOutputWires(gates, 't03', 'a05');\n    // Swap z output with propagate\n    swapOutputWires(gates, 'z02', 'b02');\n    // Swap final carry with propagate\n    swapOutputWires(gates, 'z06', 'b05');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['c01', 'z04', 't03', 'a05', 'z02', 'b02', 'z06', 'b05'].sort()\n    );\n  });\n});\n","structuredPatch":[{"oldStart":45,"oldLines":8,"newStart":45,"newLines":6,"lines":["   });"," ","   it('should simulate a 2-bit adder correctly', () => {","-    // Bit 0: half adder","-    // Bit 1: full adder","     const gates: Gate[] = [","       { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },","       { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },"]},{"oldStart":83,"oldLines":26,"newStart":81,"newLines":30,"lines":[" });"," "," describe('findSwappedWires', () => {","-  function make4BitAdder(): Gate[] {","-    return [","+  function makeAdder(numBits: number): Gate[] {","+    const gates: Gate[] = [","       { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },","       { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },","-      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },","-      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },","-      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },","-      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },","-      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },","-      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },","-      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },","-      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },","-      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },","-      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },","-      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },","-      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },","-      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },","-      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },","-      { op: 'OR', in1: 'a03', in2: 'b03', out: 'z04' },","     ];","+    for (let i = 1; i < numBits; i++) {","+      const nn = String(i).padStart(2, '0');","+      const xi = `x${nn}`;","+      const yi = `y${nn}`;","+      const zi = `z${nn}`;","+      const ti = `t${nn}`;","+      const ai = `a${