+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+
+  let changed = true;
+  while (remaining.length > 0 && changed) {
+    changed = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const g = remaining[i];
+      if (wires[g.in1] !== undefined && wires[g.in2] !== undefined) {
+        const a = wires[g.in1];
+        const b = wires[g.in2];
+        let result: number;
+        switch (g.op) {
+          case 'AND':
+            result = a & b;
+            break;
+          case 'OR':
+            result = a | b;
+            break;
+          case 'XOR':
+            result = a ^ b;
+            break;
+        }
+        wires[g.out] = result;
+        remaining.splice(i, 1);
+        changed = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+/**
+ * A correct ripple-carry adder for bit i (i >= 1) has this structure:
+ *   xNN XOR yNN -> tNN          (partial sum)
+ *   tNN XOR carry_in -> zNN     (final sum)
+ *   xNN AND yNN -> aNN          (generate)
+ *   tNN AND carry_in -> bNN     (propagate carry)
+ *   aNN OR bNN -> cNN           (carry out)
+ *
+ * For bit 0 (half adder):
+ *   x00 XOR y00 -> z00
+ *   x00 AND y00 -> c00
+ *
+ * The last carry becomes the MSB output z(N+1).
+ *
+ * We identify swapped wires by analyzing the structural pattern.
+ */
+export function findSwappedWires(gates: Gate[]): string[] {
+  // Build lookup structures
+  const gateByOutput = new Map<string, Gate>();
+  for (const g of gates) {
+    gateByOutput.set(g.out, g);
+  }
+
+  // Find the number of input bits by looking at x/y inputs
+  let maxBit = 0;
+  for (const g of gates) {
+    for (const w of [g.in1, g.in2]) {
+      const m = w.match(/^[xy](\d+)$/);
+      if (m) {
+        maxBit = Math.max(maxBit, parseInt(m[1]));
+      }
+    }
+  }
+  const numBits = maxBit + 1;
+
+  // Helper: find a gate by op and input set
+  function findGate(
+    op: Gate['op'],
+    in1: string,
+    in2: string
+  ): Gate | undefined {
+    for (const g of gates) {
+      if (
+        g.op === op &&
+        ((g.in1 === in1 && g.in2 === in2) || (g.in1 === in2 && g.in2 === in1))
+      ) {
+        return g;
+      }
+    }
+    return undefined;
+  }
+
+  // We'll iteratively identify swaps by checking structural invariants.
+  // Each swap we find, we fix (swap the outputs back) and continue.
+  const swapped: string[] = [];
+
+  function swapOutputs(w1: string, w2: string) {
+    const g1 = gateByOutput.get(w1)!;
+    const g2 = gateByOutput.get(w2)!;
+    g1.out = w2;
+    g2.out = w1;
+    gateByOutput.set(w1, g2);
+    gateByOutput.set(w2, g1);
+    swapped.push(w1, w2);
+  }
+
+  // Verify bit 0: x00 XOR y00 -> z00, x00 AND y00 -> carry
+  const x0 = 'x00',
+    y0 = 'y00';
+  const xorGate0 = findGate('XOR', x0, y0);
+  const andGate0 = findGate('AND', x0, y0);
+
+  if (!xorGate0 || !andGate0) {
+    throw new Error('Cannot find bit 0 gates');
+  }
+
+  // The XOR gate for bit 0 must output z00
+  if (xorGate0.out !== 'z00') {
+    // z00 is swapped with something
+    // If andGate0 outputs z00, swap them
+    if (andGate0.out === 'z00') {
+      swapOutputs(xorGate0.out, andGate0.out);
+    } else {
+      // z00 is swapped with xorGate0.out
+      swapOutputs(xorGate0.out, 'z00');
+    }
+  }
+
+  let carry = andGate0.out;
+
+  // Process bits 1..numBits-1
+  for (let i = 1; i < numBits; i++) {
+    const xi = `x${String(i).padStart(2, '0')}`;
+    const yi = `y${String(i).padStart(2, '0')}`;
+    const zi = `z${String(i).padStart(2, '0')}`;
+
+    // Step 1: Find the XOR of xi, yi (partial sum)
+    const xorXY = findGate('XOR', xi, yi);
+    if (!xorXY) throw new Error(`Missing XOR for bit ${i}`);
+
+    // Step 2: Find the AND of xi, yi (generate)
+    const andXY = findGate('AND', xi, yi);
+    if (!andXY) throw new Error(`Missing AND for bit ${i}`);
+
+    let partialSum = xorXY.out;
+
+    // Step 3: Find the XOR of partialSum with carry -> should be zi
+    let xorWithCarry = findGate('XOR', partialSum, carry);
+
+    if (!xorWithCarry) {
+      // Either partialSum or carry is swapped with something.
+      // Check if there's an XOR gate that uses carry with some other wire
+      // or an XOR gate that uses partialSum with some other wire.
+
+      // Strategy: Look for an XOR gate that outputs zi - that should be the sum gate
+      const ziGate = gateByOutput.get(zi);
+      if (ziGate && ziGate.op === 'XOR') {
+        // One of ziGate's inputs should be carry. If not, partialSum might be wrong.
+        const ziInputs = [ziGate.in1, ziGate.in2];
+        if (ziInputs.includes(carry)) {
+          // The other input should be partialSum but isn't -> partialSum is swapped
+          const otherInput = ziInputs[0] === carry ? ziInputs[1] : ziInputs[0];
+          swapOutputs(partialSum, otherInput);
+          partialSum = otherInput;
+          xorWithCarry = ziGate;
+        } else if (ziInputs.includes(partialSum)) {
+          // carry is wrong - this shouldn't happen as we track carry ourselves
+          const otherInput =
+            ziInputs[0] === partialSum ? ziInputs[1] : ziInputs[0];
+          swapOutputs(carry, otherInput);
+          carry = otherInput;
+          xorWithCarry = ziGate;
+        } else {
+          // Neither input matches - complex swap
+          // Try: find XOR gates that use carry
+          for (const g of gates) {
+            if (
+              g.op === 'XOR' &&
+              g !== xorXY &&
+              (g.in1 === carry || g.in2 === carry)
+            ) {
+              const other = g.in1 === carry ? g.in2 : g.in1;
+              // partialSum should be swapped with other
+              swapOutputs(partialSum, other);
+              partialSum = other;
+              xorWithCarry = g;
+              break;
+            }
+          }
+        }
+      } else {
+        // zi doesn't come from an XOR gate, or zi gate is wrong
+        // Find an XOR that takes carry as input (other than xorXY)
+        for (const g of gates) {
+          if (
+            g.op === 'XOR' &&
+            g !== xorXY &&
+            (g.in1 === carry || g.in2 === carry)
+          ) {
+            const other = g.in1 === carry ? g.in2 : g.in1;
+            if (other !== partialSum) {
+              swapOutputs(partialSum, other);
+              partialSum = other;
+            }
+            xorWithCarry = g;
+            break;
+          }
+        }
+        if (!xorWithCarry) {
+          // Try finding XOR with partialSum
+          for (const g of gates) {
+            if (
+              g.op === 'XOR' &&
+              g !== xorXY &&
+              (g.in1 === partialSum || g.in2 === partialSum)
+            ) {
+              const other =
+                g.in1 === partialSum ? g.in2 : g.in1;
+              if (other !== carry) {
+                swapOutputs(carry, other);
+                carry = other;
+              }
+              xorWithCarry = g;
+              break;
+            }
+          }
+        }
+      }
+    }
+
+    if (!xorWithCarry) {
+      throw new Error(`Cannot resolve XOR for bit ${i}`);
+    }
+
+    // The XOR with carry must output zi
+    if (xorWithCarry.out !== zi) {
+      swapOutputs(xorWithCarry.out, zi);
+    }
+
+    // Step 4: Find the AND of partialSum with carry (propagate carry)
+    const andPropCarry = findGate('AND', partialSum, carry);
+    if (!andPropCarry) {
+      throw new Error(`Missing propagate AND for bit ${i}`);
+    }
+
+    // Step 5: Find the OR of andXY.out with andPropCarry.out (carry out)
+    const generateOut = andXY.out;
+    const propagateOut = andPropCarry.out;
+    let orCarry = findGate('OR', generateOut, propagateOut);
+
+    if (!orCarry) {
+      // One of generateOut or propagateOut may be swapped
+      // Find an OR gate that uses one of them
+      for (const g of gates) {
+        if (g.op === 'OR') {
+          const orInputs = [g.in1, g.in2];
+          if (orInputs.includes(generateOut)) {
+            const other =
+              orInputs[0] === generateOut ? orInputs[1] : orInputs[0];
+            swapOutputs(propagateOut, other);
+            orCarry = g;
+            break;
+          }
+          if (orInputs.includes(propagateOut)) {
+            const other =
+              orInputs[0] === propagateOut ? orInputs[1] : orInputs[0];
+            swapOutputs(generateOut, other);
+            orCarry = g;
+            break;
+          }
+        }
+      }
+    }
+
+    if (!orCarry) {
+      throw new Error(`Missing carry OR for bit ${i}`);
+    }
+
+    carry = orCarry.out;
+  }
+
+  // The last carry should be z(numBits) - the final output bit
+  const lastZ = `z${String(numBits).padStart(2, '0')}`;
+  if (carry !== lastZ) {
+    swapOutputs(carry, lastZ);
+  }
+
+  return [...swapped].sort();
+}
