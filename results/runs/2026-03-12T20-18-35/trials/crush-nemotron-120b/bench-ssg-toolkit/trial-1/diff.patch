+import { Plugin } from '../core/types.js';
+
+export function createSyntaxHighlightPlugin(): Plugin {
+  return {
+    name: 'syntax-highlight',
+    version: '1.0.0',
+    dependencies: [], // Wave 1: no dependencies
+    hooks: {
+      transformContent: async (file, ctx) => {
+        if (!file.content) {
+          return file;
+        }
+
+        // Regex to match <pre><code class="language-...">...</code></pre>
+        // We capture the language and the inner content
+        const regex = /<pre>\s*<code class="language-([^"]+)">([\s\S]*?)<\/code>\s*<\/pre>/g;
+
+        // We'll replace each match with:
+        // <pre data-language="$1"><code class="language-$1 highlighted">$2</code></pre>
+        let processed = file.content;
+        let match;
+        while ((match = regex.exec(processed)) !== null) {
+          const [fullMatch, language, innerContent] = match;
+          const replacement = `<pre data-language="${language}"><code class="language-${language} highlighted">${innerContent}</code></pre>`;
+          processed = processed.replace(fullMatch, replacement);
+          // Reset lastIndex because we changed the string length and we want to continue from the end of the replacement
+          // But note: we are using a while loop with exec on the same regex, and we are modifying the string we're matching against.
+          // This can lead to infinite loops. Instead, we should use a different approach: split and rebuild, or use a single replace with a function.
+          // Let's change to using replace with a function.
+        }
+
+        // Instead of the while loop, we can do:
+        // processed = file.content.replace(regex, (_, language, innerContent) => {
+        //   return `<pre data-language="${language}"><code class="language-${language} highlighted">${innerContent}</code></pre>`;
+        // });
+
+        // Let's do that to avoid the infinite loop issue.
+
+        processed = file.content.replace(regex, (_, language, innerContent) => {
+          return `<pre data-language="${language}"><code class="language-${language} highlighted">${innerContent}</code></pre>`;
+        });
+
+        return {
+          ...file,
+          content: processed,
+        };
+      },
+    },
+  };
+}
