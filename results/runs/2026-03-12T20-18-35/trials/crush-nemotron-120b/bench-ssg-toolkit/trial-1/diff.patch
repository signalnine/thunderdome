+import { Plugin } from '../core/types.js';
+
+export function createRssFeedPlugin(): Plugin {
+  return {
+    name: 'rss-feed',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'taxonomy'], // Wave 2: depends on markdown-ext and taxonomy
+    hooks: {
+      afterBuild: async (ctx) => {
+        const { title: siteTitle, baseUrl } = ctx.config;
+        const tagMap = ctx.data.get('taxonomy-tags') as Map<string, string[]> | undefined;
+
+        // Get all files, sort by date descending (newest first)
+        const sortedFiles = [...ctx.files].sort((a, b) => {
+          const dateA = a.date || '';
+          const dateB = b.date || '';
+          // If both have dates, compare them; if one is missing, treat as older
+          if (dateA && dateB) {
+            return dateB.localeCompare(dateA); // descending
+          }
+          if (dateA) return -1; // a has date, b doesn't -> a is newer
+          if (dateB) return 1; // b has date, a doesn't -> b is newer
+          return 0; // both no date, keep original order
+        });
+
+        let rss = `<?xml version="1.0" encoding="UTF-8"?>
+<rss version="2.0">
+  <channel>
+    <title>${siteTitle}</title>
+    <link>${baseUrl}</link>
+    <description>Latest posts from ${siteTitle}</description>
+    <language>en-us</language>
+`;
+
+        for (const file of sortedFiles) {
+          const fileUrl = `${baseUrl}/${file.slug}.html`;
+          const pubDate = file.date ? new Date(file.date).toUTCString() : undefined;
+
+          rss += `    <item>
+      <title>${file.title}</title>
+      <link>${fileUrl}</link>
+      <description><![CDATA[${file.content}]]></description>
+      <pubDate>${pubDate || ''}</pubDate>
+      <guid>${fileUrl}</guid>`;
+
+          // Add categories from file.tags if available
+          if (file.tags && file.tags.length > 0) {
+            for (const tag of file.tags) {
+              rss += `\n      <category>${tag}</category>`;
+            }
+          }
+
+          rss += `\n    </item>`;
+        }
+
+        rss += `
+  </channel>
+</rss>`;
+
+        ctx.output.set('feed.xml', rss);
+      },
+    },
+  };
+}
