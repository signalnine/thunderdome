+import { Plugin } from '../core/types.js';
+import { marked } from 'marked';
+
+export interface MarkdownExtPluginOptions {
+  // Options can be added here if needed
+}
+
+export function createMarkdownExtPlugin(): Plugin {
+  // Configure marked to handle basic markdown
+  const renderer = new marked.Renderer();
+
+  // We'll keep default rendering for now, but we can override if needed
+
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [], // Wave 1: no dependencies
+    hooks: {
+      transformContent: async (file, ctx) => {
+        if (!file.content) {
+          return file;
+        }
+
+        // First, process admonition containers (:::note, :::warning, :::tip)
+        let processed = file.content
+          .replace(/:::(note|warning|tip)\n([\s\S]*?)\n:::/g, (_, type, content) => {
+            const admonitionType = type.toLowerCase();
+            return `<div class="admonition admonition-${admonitionType}">\n${content}\n</div>`;
+          });
+
+        // Process footnotes: [^1] style references and [^1]: definition
+        // We'll parse the content to extract footnote definitions and replace references
+        const footnoteRegex = /\[\^(\d+)\]/g;
+        const footnoteDefRegex = /^\s*\[\^(\d+)\]:\s*(.*)$/gm;
+
+        // Find all footnote definitions
+        const footnotes: Record<string, string> = {};
+        let match;
+        while ((match = footnoteDefRegex.exec(processed)) !== null) {
+          const id = match[1];
+          const def = match[2];
+          footnotes[id] = def;
+        }
+
+        // Remove footnote definitions from content (they will be placed in a section)
+        processed = processed.replace(footnoteDefRegex, '');
+
+        // Replace footnote references with superscript links
+        processed = processed.replace(footnoteRegex, (_, id) => {
+          if (footnotes[id]) {
+            return `<sup><a href="#fn-${id}">${id}</a></sup>`;
+          }
+          // If definition not found, leave as is?
+          return _; // return the whole match (which is the same as `[^${id}]`)
+        });
+
+        // If there are footnotes, add a footnote section at the end
+        if (Object.keys(footnotes).length > 0) {
+          let footnotesSection = '<section class="footnotes"><ol>';
+          for (const [id, def] of Object.entries(footnotes)) {
+            footnotesSection += `<li id="fn-${id}">${def}</li>`;
+          }
+          footnotesSection += '</ol></section>';
+          processed += footnotesSection;
+        }
+
+        // Now run marked on the processed content (which now has HTML from admonitions and footnotes)
+        // Set up marked options
+        marked.setOptions({
+          breaks: true,
+          gfm: true,
+        });
+
+        const htmlContent = marked.parse(processed);
+
+        return {
+          ...file,
+          content: htmlContent,
+        };
+      },
+    },
+  };
+}
