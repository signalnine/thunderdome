+import { Plugin } from '../core/types.js';
+
+export function createTaxonomyPlugin(): Plugin {
+  return {
+    name: 'taxonomy',
+    version: '1.0.0',
+    dependencies: [], // Wave 1: no dependencies
+    hooks: {
+      beforeBuild: async (ctx) => {
+        const tagMap = new Map<string, ContentFile[]>();
+
+        for (const file of ctx.files) {
+          const tags = file.tags as string[] | undefined;
+          if (!tags || tags.length === 0) {
+            continue;
+          }
+
+          for (const tag of tags) {
+            const normalizedTag = tag.toLowerCase();
+            if (!tagMap.has(normalizedTag)) {
+              tagMap.set(normalizedTag, []);
+            }
+            tagMap.get(normalizedTag)!.push(file);
+          }
+        }
+
+        ctx.data.set('taxonomy-tags', tagMap);
+      },
+      afterBuild: async (ctx) => {
+        const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]> | undefined;
+        if (!tagMap) {
+          return;
+        }
+
+        for (const [tag, files] of tagMap.entries()) {
+          let html = `<!DOCTYPE html>\n<html>\n<head>\n  <meta charset="utf-8">\n  <title>Tag: ${tag}</title>\n</head>\n<body>\n  <h1>Tag: ${tag}</h1>\n  <ul>\n`;
+          for (const file of files) {
+            html += `    <li>${file.title}</li>\n`;
+          }
+          html += `  </ul>\n</body>\n</html>`;
+
+          ctx.output.set(`tags/${tag}.html`, html);
+        }
+      },
+    },
+  };
+}
