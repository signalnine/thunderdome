+import { Plugin } from '../core/types.js';
+
+export function createAssetPipelinePlugin(): Plugin {
+  return {
+    name: 'asset-pipeline',
+    version: '1.0.0',
+    dependencies: [], // Wave 1: no dependencies
+    hooks: {
+      transformContent: async (file, ctx) => {
+        if (!file.content) {
+          return file;
+        }
+
+        // Initialize asset manifest in ctx.data if not present
+        let manifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;
+        if (!manifest) {
+          manifest = { assets: [] };
+          ctx.data.set('asset-manifest', manifest);
+        }
+
+        // Regex to match src or href attributes with relative URLs starting with ./
+        // We capture the attribute name (src or href) and the filename (without the ./ prefix)
+        const regex = /(src|href)="\.\/([^"]+)"/g;
+        let match;
+
+        // We'll collect assets found in this file to avoid duplicates in the manifest
+        const fileAssets = new Set<string>();
+
+        // Replace each match and collect the filename
+        let processed = file.content.replace(regex, (_, attribute, filename) => {
+          fileAssets.add(filename);
+          return `${attribute}="/assets/${filename}"`;
+        });
+
+        // Add new assets to the manifest
+        for (const filename of fileAssets) {
+          if (!manifest.assets.includes(filename)) {
+            manifest.assets.push(filename);
+          }
+        }
+
+        return {
+          ...file,
+          content: processed,
+        };
+      },
+    },
+  };
+}
