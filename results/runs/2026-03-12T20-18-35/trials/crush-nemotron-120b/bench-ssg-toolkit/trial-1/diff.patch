+import { Plugin } from '../core/types.js';
+
+export function createSearchIndexPlugin(): Plugin {
+  return {
+    name: 'search-index',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'syntax-highlight'], // Wave 2: depends on markdown-ext and syntax-highlight
+    hooks: {
+      afterBuild: async (ctx) => {
+        const index = [];
+
+        for (const file of ctx.files) {
+          // Strip HTML tags from content to get plain text
+          // Replace all HTML tags with a space, then collapse multiple whitespace
+          let plainText = file.content.replace(/<[^>]*>/g, ' ');
+          // Replace multiple whitespace (including newlines) with a single space and trim
+          plainText = plainText.replace(/\s+/g, ' ').trim();
+
+          const entry: any = {
+            slug: file.slug,
+            title: file.title,
+            content: plainText,
+          };
+
+          // Include tags if present
+          if (file.tags && file.tags.length > 0) {
+            entry.tags = file.tags;
+          }
+
+          index.push(entry);
+        }
+
+        // Write the index to output
+        ctx.output.set('search-index.json', JSON.stringify(index, null, 2));
+      },
+    },
+  };
+}
