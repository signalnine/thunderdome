@@ -0,0 +1,433 @@
+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+/**
+ * Solve a toggle puzzle over GF(2) using Gaussian elimination.
+ * Find minimum set of buttons, then lexicographically smallest among ties.
+ */
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const numLights = target.length;
+  const numButtons = buttons.length;
+
+  // Build augmented matrix over GF(2) using bigint bitmasks for efficient XOR.
+  // Bit layout: bits 0..numButtons-1 are button columns, bit numButtons is the target.
+  const rows: bigint[] = [];
+  for (let light = 0; light < numLights; light++) {
+    let row = 0n;
+    for (let btn = 0; btn < numButtons; btn++) {
+      if (buttons[btn].includes(light)) {
+        row |= 1n << BigInt(btn);
+      }
+    }
+    if (target[light]) {
+      row |= 1n << BigInt(numButtons);
+    }
+    rows.push(row);
+  }
+
+  // Gaussian elimination over GF(2) — full reduced row echelon form
+  const pivotCol: number[] = new Array(numLights).fill(-1);
+  let currentRow = 0;
+
+  for (let col = 0; col < numButtons && currentRow < numLights; col++) {
+    let pivotRow = -1;
+    for (let r = currentRow; r < numLights; r++) {
+      if ((rows[r] >> BigInt(col)) & 1n) {
+        pivotRow = r;
+        break;
+      }
+    }
+    if (pivotRow === -1) continue;
+
+    [rows[currentRow], rows[pivotRow]] = [rows[pivotRow], rows[currentRow]];
+    pivotCol[currentRow] = col;
+
+    for (let r = 0; r < numLights; r++) {
+      if (r !== currentRow && (rows[r] >> BigInt(col)) & 1n) {
+        rows[r] ^= rows[currentRow];
+      }
+    }
+    currentRow++;
+  }
+
+  const rank = currentRow;
+
+  // Check for inconsistency
+  for (let r = rank; r < numLights; r++) {
+    if ((rows[r] >> BigInt(numButtons)) & 1n) {
+      return null;
+    }
+  }
+
+  // Identify free variables
+  const pivotVars = new Set<number>();
+  for (let r = 0; r < rank; r++) {
+    pivotVars.add(pivotCol[r]);
+  }
+
+  const freeVars: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (!pivotVars.has(col)) {
+      freeVars.push(col);
+    }
+  }
+
+  const numFree = freeVars.length;
+
+  // Compute base solution (all free vars = 0) as a bitmask
+  let baseSol = 0n;
+  for (let r = 0; r < rank; r++) {
+    if ((rows[r] >> BigInt(numButtons)) & 1n) {
+      baseSol |= 1n << BigInt(pivotCol[r]);
+    }
+  }
+
+  // Compute flip mask for each free variable:
+  // toggling free var i flips bit freeVars[i] and all pivot vars it affects
+  const flipMasks: bigint[] = [];
+  for (let fi = 0; fi < numFree; fi++) {
+    const fv = freeVars[fi];
+    let mask = 1n << BigInt(fv);
+    for (let r = 0; r < rank; r++) {
+      if ((rows[r] >> BigInt(fv)) & 1n) {
+        mask |= 1n << BigInt(pivotCol[r]);
+      }
+    }
+    flipMasks.push(mask);
+  }
+
+  if (numFree <= 20) {
+    // Enumerate all 2^numFree combinations using Gray code-like XOR approach
+    const totalCombinations = 1 << numFree;
+    let bestSolution: number[] | null = null;
+    let bestCount = numButtons + 1;
+
+    // Use incremental XOR: sol starts as baseSol
+    // For each mask, compute sol = baseSol XOR (selected flipMasks)
+    // We enumerate masks 0..2^numFree-1 and compute solutions
+    let currentSol = baseSol;
+    let prevMask = 0;
+
+    for (let mask = 0; mask < totalCombinations; mask++) {
+      // Gray code optimization: XOR only the changed bits
+      const diff = mask ^ prevMask;
+      for (let i = 0; i < numFree; i++) {
+        if ((diff >> i) & 1) {
+          currentSol ^= flipMasks[i];
+        }
+      }
+      prevMask = mask;
+
+      const count = popcount64(currentSol);
+      if (count < bestCount) {
+        bestCount = count;
+        bestSolution = bitmaskToArray(currentSol, numButtons);
+      } else if (count === bestCount) {
+        const pressed = bitmaskToArray(currentSol, numButtons);
+        if (lexSmaller(pressed, bestSolution!)) {
+          bestSolution = pressed;
+        }
+      }
+    }
+
+    return bestSolution;
+  }
+
+  // For numFree > 20: coordinate descent over GF(2)
+  // For each free variable, check if toggling it reduces the total weight
+  const freeSettings = new Array(numFree).fill(0);
+  let sol = baseSol;
+  let improved = true;
+
+  while (improved) {
+    improved = false;
+    for (let fi = 0; fi < numFree; fi++) {
+      const toggled = sol ^ flipMasks[fi];
+      const currentCount = popcount64(sol);
+      const toggledCount = popcount64(toggled);
+      if (toggledCount < currentCount) {
+        sol = toggled;
+        freeSettings[fi] ^= 1;
+        improved = true;
+      } else if (toggledCount === currentCount) {
+        // Check lex order
+        const currentArr = bitmaskToArray(sol, numButtons);
+        const toggledArr = bitmaskToArray(toggled, numButtons);
+        if (lexSmaller(toggledArr, currentArr)) {
+          sol = toggled;
+          freeSettings[fi] ^= 1;
+          improved = true;
+        }
+      }
+    }
+  }
+
+  return bitmaskToArray(sol, numButtons);
+}
+
+function bitmaskToArray(mask: bigint, numBits: number): number[] {
+  const result: number[] = [];
+  for (let i = 0; i < numBits; i++) {
+    if ((mask >> BigInt(i)) & 1n) {
+      result.push(i);
+    }
+  }
+  return result;
+}
+
+function lexSmaller(a: number[], b: number[]): boolean {
+  const len = Math.min(a.length, b.length);
+  for (let i = 0; i < len; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return a.length < b.length;
+}
+
+function popcount64(n: bigint): number {
+  let count = 0;
+  while (n > 0n) {
+    n &= n - 1n;
+    count++;
+  }
+  return count;
+}
+
+// ---- Modular arithmetic helpers ----
+
+function mod(a: number, m: number): number {
+  return ((a % m) + m) % m;
+}
+
+function modPow(base: number, exp: number, m: number): number {
+  let result = 1;
+  base = mod(base, m);
+  while (exp > 0) {
+    if (exp & 1) {
+      result = (result * base) % m;
+    }
+    exp >>= 1;
+    base = (base * base) % m;
+  }
+  return result;
+}
+
+/**
+ * Solve a counter puzzle over GF(p) using Gaussian elimination.
+ */
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numCounters = lights.length;
+  const numButtons = buttons.length;
+
+  if (numButtons === 0) {
+    for (let i = 0; i < numCounters; i++) {
+      if (mod(lights[i], modulus) !== 0) return null;
+    }
+    return [];
+  }
+
+  // Build augmented matrix over GF(modulus)
+  const matrix: number[][] = [];
+  for (let counter = 0; counter < numCounters; counter++) {
+    const row = new Array(numButtons + 1).fill(0);
+    for (let btn = 0; btn < numButtons; btn++) {
+      if (buttons[btn].includes(counter)) {
+        row[btn] = 1;
+      }
+    }
+    row[numButtons] = mod(lights[counter], modulus);
+    matrix.push(row);
+  }
+
+  // Precompute modular inverses using Fermat's little theorem (p is prime)
+  const inv = new Array(modulus).fill(0);
+  for (let i = 1; i < modulus; i++) {
+    inv[i] = modPow(i, modulus - 2, modulus);
+  }
+
+  // Gaussian elimination over GF(modulus) — full RREF
+  const pivotCol: number[] = new Array(numCounters).fill(-1);
+  let currentRow = 0;
+
+  for (let col = 0; col < numButtons && currentRow < numCounters; col++) {
+    let pivotRow = -1;
+    for (let r = currentRow; r < numCounters; r++) {
+      if (matrix[r][col] !== 0) {
+        pivotRow = r;
+        break;
+      }
+    }
+    if (pivotRow === -1) continue;
+
+    [matrix[currentRow], matrix[pivotRow]] = [matrix[pivotRow], matrix[currentRow]];
+    pivotCol[currentRow] = col;
+
+    // Normalize pivot row
+    const pivotInv = inv[matrix[currentRow][col]];
+    for (let c = col; c <= numButtons; c++) {
+      matrix[currentRow][c] = (matrix[currentRow][c] * pivotInv) % modulus;
+    }
+
+    // Eliminate this column from all other rows
+    for (let r = 0; r < numCounters; r++) {
+      if (r !== currentRow && matrix[r][col] !== 0) {
+        const factor = matrix[r][col];
+        for (let c = col; c <= numButtons; c++) {
+          matrix[r][c] = mod(matrix[r][c] - factor * matrix[currentRow][c], modulus);
+        }
+      }
+    }
+    currentRow++;
+  }
+
+  const rank = currentRow;
+
+  // Check for inconsistency
+  for (let r = rank; r < numCounters; r++) {
+    if (matrix[r][numButtons] !== 0) {
+      return null;
+    }
+  }
+
+  // Identify free variables
+  const pivotVars = new Set<number>();
+  for (let r = 0; r < rank; r++) {
+    pivotVars.add(pivotCol[r]);
+  }
+
+  const freeVars: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (!pivotVars.has(col)) {
+      freeVars.push(col);
+    }
+  }
+
+  const numFree = freeVars.length;
+
+  if (numFree === 0) {
+    const solution = new Array(numButtons).fill(0);
+    for (let r = 0; r < rank; r++) {
+      solution[pivotCol[r]] = matrix[r][numButtons];
+    }
+    return solution;
+  }
+
+  // Precompute coefficients for back-substitution
+  const pivotCoeffs: number[][] = [];
+  const pivotConstants: number[] = [];
+  for (let r = 0; r < rank; r++) {
+    const coeffs: number[] = [];
+    for (let fi = 0; fi < numFree; fi++) {
+      coeffs.push(matrix[r][freeVars[fi]]);
+    }
+    pivotCoeffs.push(coeffs);
+    pivotConstants.push(matrix[r][numButtons]);
+  }
+
+  // Compute solution from free variable values
+  const computeSolution = (freeValues: number[]): number[] => {
+    const solution = new Array(numButtons).fill(0);
+    for (let i = 0; i < numFree; i++) {
+      solution[freeVars[i]] = freeValues[i];
+    }
+    for (let r = 0; r < rank; r++) {
+      let val = pivotConstants[r];
+      for (let fi = 0; fi < numFree; fi++) {
+        val -= pivotCoeffs[r][fi] * freeValues[fi];
+      }
+      solution[pivotCol[r]] = mod(val, modulus);
+    }
+    return solution;
+  };
+
+  const computeSum = (solution: number[]): number => {
+    let s = 0;
+    for (let i = 0; i < numButtons; i++) s += solution[i];
+    return s;
+  };
+
+  // Check feasibility of full enumeration
+  // For modulus p and numFree free vars, total = p^numFree
+  // Feasible when total <= ~10M
+  let totalCombinations = 1;
+  let feasible = true;
+  for (let i = 0; i < numFree; i++) {
+    totalCombinations *= modulus;
+    if (totalCombinations > 10_000_000) {
+      feasible = false;
+      break;
+    }
+  }
+
+  if (feasible) {
+    // Direct enumeration
+    let bestSolution: number[] | null = null;
+    let bestSum = Infinity;
+    const freeValues = new Array(numFree).fill(0);
+
+    for (let iter = 0; iter < totalCombinations; iter++) {
+      const solution = computeSolution(freeValues);
+      const sum = computeSum(solution);
+
+      if (sum < bestSum || (sum === bestSum && lexSmallerArray(solution, bestSolution!))) {
+        bestSum = sum;
+        bestSolution = solution;
+      }
+
+      // Increment mixed-radix counter
+      for (let i = 0; i < numFree; i++) {
+        freeValues[i]++;
+        if (freeValues[i] < modulus) break;
+        freeValues[i] = 0;
+      }
+    }
+
+    return bestSolution;
+  }
+
+  // Coordinate descent for large search spaces
+  const freeValues = new Array(numFree).fill(0);
+  let bestSolution = computeSolution(freeValues);
+  let bestSum = computeSum(bestSolution);
+
+  let improved = true;
+  while (improved) {
+    improved = false;
+    for (let fi = 0; fi < numFree; fi++) {
+      const origVal = freeValues[fi];
+      let bestVal = origVal;
+
+      for (let v = 0; v < modulus; v++) {
+        if (v === origVal) continue;
+        freeValues[fi] = v;
+        const solution = computeSolution(freeValues);
+        const sum = computeSum(solution);
+        if (sum < bestSum || (sum === bestSum && lexSmallerArray(solution, bestSolution))) {
+          bestSum = sum;
+          bestVal = v;
+          bestSolution = solution;
+          improved = true;
+        }
+      }
+
+      freeValues[fi] = bestVal;
+    }
+  }
+
+  return bestSolution;
+}
+
+function lexSmallerArray(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return false;
+}
