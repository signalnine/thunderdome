+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter, Machine } from './index.js';
+
+// Helper to verify a toggle solution
+function verifyToggle(machine: Machine, solution: number[] | null): boolean {
+  if (solution === null) return true; // we just check non-null solutions
+  const lights = new Array(machine.target.length).fill(false);
+  for (const btn of solution) {
+    for (const light of machine.buttons[btn]) {
+      lights[light] = !lights[light];
+    }
+  }
+  return machine.target.every((t, i) => t === lights[i]);
+}
+
+// Helper to verify a counter solution
+function verifyCounter(lights: number[], buttons: number[][], modulus: number, solution: number[] | null): boolean {
+  if (solution === null) return true;
+  const counters = new Array(lights.length).fill(0);
+  for (let btn = 0; btn < buttons.length; btn++) {
+    for (const counter of buttons[btn]) {
+      counters[counter] = (counters[counter] + solution[btn]) % modulus;
+    }
+  }
+  return lights.every((t, i) => t === counters[i]);
+}
+
+describe('solveToggle', () => {
+  it('returns empty array when target is all off', () => {
+    const machine: Machine = {
+      target: [false, false, false],
+      buttons: [[0, 1], [1, 2]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([]);
+  });
+
+  it('returns null when no solution exists', () => {
+    const machine: Machine = {
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('solves a simple single-button case', () => {
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [[0, 1]],
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('solves a two-button case', () => {
+    const machine: Machine = {
+      target: [true, false],
+      buttons: [[0, 1], [1]],
+    };
+    expect(solveToggle(machine)).toEqual([0, 1]);
+  });
+
+  it('returns minimum press count', () => {
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [[0], [1], [0, 1]],
+    };
+    expect(solveToggle(machine)).toEqual([2]);
+  });
+
+  it('returns lexicographically smallest for tied press count', () => {
+    const machine: Machine = {
+      target: [true],
+      buttons: [[0], [0]],
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('handles no buttons with non-zero target', () => {
+    const machine: Machine = {
+      target: [true],
+      buttons: [],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('handles no buttons with zero target', () => {
+    const machine: Machine = {
+      target: [false, false],
+      buttons: [],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('handles larger puzzle', () => {
+    const machine: Machine = {
+      target: [true, false, true, false, true],
+      buttons: [[0], [1], [2], [3], [4]],
+    };
+    expect(solveToggle(machine)).toEqual([0, 2, 4]);
+  });
+
+  it('handles overlapping buttons', () => {
+    const machine: Machine = {
+      target: [true, true, true],
+      buttons: [[0, 1, 2], [0], [1], [2]],
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('handles 20 lights and 20 buttons (performance)', () => {
+    // Create an identity-like system with some overlap
+    const n = 20;
+    const buttons: number[][] = [];
+    for (let i = 0; i < n; i++) {
+      buttons.push([i, (i + 1) % n]);
+    }
+    const target = new Array(n).fill(true);
+    const machine: Machine = { target, buttons };
+    const result = solveToggle(machine);
+    if (result !== null) {
+      expect(verifyToggle(machine, result)).toBe(true);
+    }
+  });
+
+  it('handles redundant buttons preferring fewer presses', () => {
+    // 2 lights, 4 buttons, many solutions
+    // Buttons: [0], [1], [0,1], [0]
+    // Target: [T, T]
+    // Solutions: {0,1} (2), {2} (1), {0,3,1} (3)
+    // Best: {2} (1 press)
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [[0], [1], [0, 1], [0]],
+    };
+    expect(solveToggle(machine)).toEqual([2]);
+  });
+
+  it('returns sorted indices', () => {
+    const machine: Machine = {
+      target: [true, true, true],
+      buttons: [[0], [1], [2]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0, 1, 2]);
+    // Verify sorted
+    if (result) {
+      for (let i = 1; i < result.length; i++) {
+        expect(result[i]).toBeGreaterThan(result[i - 1]);
+      }
+    }
+  });
+});
+
+describe('solveCounter', () => {
+  it('returns all zeros when target is all zeros', () => {
+    expect(solveCounter([0, 0, 0], [[0, 1], [1, 2]], 5)).toEqual([0, 0]);
+  });
+
+  it('solves a simple single-button case', () => {
+    expect(solveCounter([3, 3], [[0, 1]], 5)).toEqual([3]);
+  });
+
+  it('returns null when no solution exists', () => {
+    expect(solveCounter([1, 1], [[0]], 3)).toBeNull();
+  });
+
+  it('solves with multiple buttons', () => {
+    expect(solveCounter([2, 3], [[0], [1]], 5)).toEqual([2, 3]);
+  });
+
+  it('returns minimum total presses', () => {
+    expect(solveCounter([4], [[0]], 5)).toEqual([4]);
+  });
+
+  it('handles modular arithmetic with lex tie-breaking', () => {
+    // 1 counter, mod 3, target = 1
+    // Button 0: [0], Button 1: [0]
+    // In GF(3): b0 + b1 ≡ 1 (mod 3)
+    // Solutions: (0,1)sum=1, (1,0)sum=1, (2,2)sum=4
+    // Min sum = 1, lex smallest = [0,1]
+    expect(solveCounter([1], [[0], [0]], 3)).toEqual([0, 1]);
+  });
+
+  it('handles no buttons with non-zero target', () => {
+    expect(solveCounter([1], [], 3)).toBeNull();
+  });
+
+  it('handles no buttons with zero target', () => {
+    expect(solveCounter([0, 0], [], 3)).toEqual([]);
+  });
+
+  it('prefers minimum sum', () => {
+    expect(solveCounter([1], [[0]], 7)).toEqual([1]);
+  });
+
+  it('solves counter puzzle with wrapping', () => {
+    expect(solveCounter([0, 1], [[0, 1], [0]], 3)).toEqual([1, 2]);
+  });
+
+  it('handles larger modulus', () => {
+    // mod 97, simple case
+    expect(solveCounter([50], [[0]], 97)).toEqual([50]);
+  });
+
+  it('verifies solution correctness for multi-button case', () => {
+    const lights = [1, 2, 3];
+    const buttons = [[0, 1], [1, 2], [0, 2]];
+    const modulus = 5;
+    const result = solveCounter(lights, buttons, modulus);
+    if (result !== null) {
+      expect(verifyCounter(lights, buttons, modulus, result)).toBe(true);
+    }
+  });
+
+  it('handles 10 counters, 10 buttons, mod 7 (performance)', () => {
+    const n = 10;
+    const buttons: number[][] = [];
+    for (let i = 0; i < n; i++) {
+      buttons.push([i, (i + 1) % n]);
+    }
+    const lights = new Array(n).fill(0).map((_, i) => (i + 1) % 7);
+    const result = solveCounter(lights, buttons, 7);
+    if (result !== null) {
+      expect(verifyCounter(lights, buttons, 7, result)).toBe(true);
+      expect(result.every(v => v >= 0 && v < 7)).toBe(true);
+    }
+  });
+});
