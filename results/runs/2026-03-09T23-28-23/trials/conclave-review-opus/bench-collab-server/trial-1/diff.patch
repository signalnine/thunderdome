+      .post('/api/documents')
+      .send({ title: 'Concurrent Test', content: '' });
+
+    const docId = createRes.body.id;
+    const numClients = 10;
+    const clients: { ws: WebSocket; sync: { content: string; version: number } }[] = [];
+
+    // Connect all clients
+    for (let i = 0; i < numClients; i++) {
