ce ClientConnection {\n  id: string;\n  ws: WebSocket;\n  documentId: string;\n}\n\ninterface DocumentState {\n  version: number;\n  content: string;\n  /** History of operations since initial version, indexed by version. ops[i] transforms version i to version i+1. */\n  ops: OTOperation[];\n}\n\nexport class CollaborationServer {\n  private wss: WebSocketServer;\n  private clients: Map<string, ClientConnection> = new Map();\n  private documents: Map<string, DocumentState> = new Map();\n  private db: DocumentDB;\n\n  constructor(server: HttpServer, db: DocumentDB) {\n    this.db = db;\n    this.wss = new WebSocketServer({ server, path: undefined });\n\n    // Handle upgrades manually to parse document ID from URL\n    server.on('upgrade', (request: IncomingMessage, socket, head) => {\n      const url = new URL(request.url || '', `http://${request.headers.host || 'localhost'}`);\n      const match = url.pathname.match(/^\\/ws\\/documents\\/([^/]+)$/);\n\n      if (!match) {\n        socket.destroy();\n        return;\n      }\n\n      const docId = match[1];\n\n      this.wss.handleUpgrade(request, socket, head, (ws) => {\n        this.handleConnection(ws, docId);\n      });\n    });\n  }\n\n  private getDocumentState(docId: string): DocumentState | null {\n    let state = this.documents.get(docId);\n    if (state) return state;\n\n    // Load from database\n    const doc = this.db.getDocument(docId);\n    if (!doc) return null;\n\n    const latestVersion = this.db.getLatestVersion(docId);\n    const version = latestVersion ? latestVersion.version : 0;\n\n    state = {\n      version,\n      content: doc.content,\n      ops: [],\n    };\n    this.documents.set(docId, state);\n    return state;\n  }\n\n  private handleConnection(ws: WebSocket, docId: string): void {\n    const clientId = randomUUID();\n    const state = this.getDocumentState(docId);\n\n    if (!state) {\n      const errorMsg: ServerMessage = { type: 'error', message: 'Document not found' };\n      ws.send(JSON.stringify(errorMsg));\n      ws.close();\n      return;\n    }\n\n    const client: ClientConnection = { id: clientId, ws, documentId: docId };\n    this.clients.set(clientId, client);\n\n    // Send sync message\n    const syncMsg: ServerMessage = {\n      type: 'sync',\n      content: state.content,\n      version: state.version,\n    };\n    ws.send(JSON.stringify(syncMsg));\n\n    ws.on('message', (data) => {\n      try {\n        const raw = data.toString();\n        let msg: unknown;\n        try {\n          msg = JSON.parse(raw);\n        } catch {\n          this.sendError(ws, 'Invalid JSON');\n          return;\n        }\n\n        if (!msg || typeof msg !== 'object') {\n          this.sendError(ws, 'Message must be an object');\n          return;\n        }\n\n        const message = msg as Record<string, unknown>;\n\n        if (message.type !== 'operation') {\n          this.sendError(ws, `Unknown message type: ${String(message.type)}`);\n          return;\n        }\n\n        this.handleOperation(client, message);\n      } catch (err) {\n        this.sendError(ws, `Internal error: ${err instanceof Error ? err.message : String(err)}`);\n      }\n    });\n\n    ws.on('close', () => {\n      this.clients.delete(clientId);\n    });\n\n    ws.on('error', () => {\n      this.clients.delete(clientId);\n    });\n  }\n\n  private handleOperation(client: ClientConnection, message: Record<string, unknown>): void {\n    const state = this.getDocumentState(client.documentId);\n    if (!state) {\n      this.sendError(client.ws, 'Document not found');\n      return;\n    }\n\n    const clientVersion = message.version;\n    if (typeof clientVersion !== 'number' || !Number.isInteger(clientVersion)) {\n      this.sendError(client.ws, 'Version must be an integer');\n      return;\n    }\n\n    let operation = message.operation;\n    if (!Array.isArray(operation)) {\n      this.sendError(client.ws, 'Operation must be an array');\n      return;\n    }\n\n    operation = operation as OTOperation;\n\n    // The client's version tells us what document state it was based on.\n    // We need to transform the operation against all operations that happened\n    // between the client's version and the current server version.\n    const baseVersion = clientVersion;\n    const serverVersion = state.version;\n\n    if (baseVersion < 0 || baseVersion > serverVersion) {\n      this.sendError(client.ws, `Invalid version: ${baseVersion}. Server is at version ${serverVersion}`);\n      return;\n    }\n\n    // Transform against all ops that happened since the client's version\n    let transformedOp = operation as OTOperation;\n    for (let i = baseVersion; i < serverVersion; i++) {\n      const serverOp = state.ops[i - (state.version - state.ops.length)];\n      if (!serverOp) {\n        this.sendError(client.ws, 'Cannot transform: missing operation history');\n        return;\n      }\n      const [clientPrime] = transform(transformedOp, serverOp);\n      transformedOp = clientPrime;\n    }\n\n    // Validate the transformed operation against current document\n    const validationError = validate(transformedOp, state.content.length);\n    if (validationError) {\n      this.sendError(client.ws, `Invalid operation: ${validationError}`);\n      return;\n    }\n\n    // Apply the operation\n    const newContent = apply(state.content, transformedOp);\n    state.content = newContent;\n    state.version++;\n    state.ops.push(transformedOp);\n\n    // Persist to database\n    this.db.updateDocumentContent(\n      client.documentId,\n      newContent,\n      { op: transformedOp, clientId: client.id }\n    );\n\n    // Send ack to the client that sent the operation\n    const ackMsg: ServerMessage = { type: 'ack', version: state.version };\n    client.ws.send(JSON.stringify(ackMsg));\n\n    // Broadcast to all other clients on the same document\n    const broadcastMsg: ServerMessage = {\n      type: 'operation',\n      operation: transformedOp,\n      version: state.version,\n      clientId: client.id,\n    };\n\n    for (const [, otherClient] of this.clients) {\n      if (otherClient.id !== client.id && otherClient.documentId === client.documentId) {\n        if (otherClient.ws.readyState === WebSocket.OPEN) {\n          otherClient.ws.send(JSON.stringify(broadcastMsg));\n        }\n      }\n    }\n  }\n\n  private sendError(ws: WebSocket, message: string): void {\n    const errorMsg: ServerMessage = { type: 'error', message };\n    if (ws.readyState === WebSocket.OPEN) {\n      ws.send(JSON.stringify(errorMsg));\n    }\n  }\n\n  closeAll(): void {\n    for (const [, client] of this.clients) {\n      client.ws.close();\n    }\n    this.clients.clear();\n    this.documents.clear();\n    this.wss.close();\n  }\n}\n","structuredPatch":[{"oldStart":25,"oldLines":9,"newStart":25,"newLines":8,"lines":[" ","   constructor(server: HttpServer, db: DocumentDB) {","     this.db = db;","-    this.wss = new WebSocketServer({ server, path: undefined });","+    this.wss = new WebSocketServer({ noServer: true });"," ","-    // Handle upgrades manually to parse document ID from URL","     server.on('upgrade', (request: IncomingMessage, socket, head) => {","       const url = new URL(request.url || '', `http://${request.headers.host || 'localhost'}`);","       const match = url.pathname.match(/^\\/ws\\/documents\\/([^/]+)$/);"]}],"userModified":false,"replaceAll":false}}
