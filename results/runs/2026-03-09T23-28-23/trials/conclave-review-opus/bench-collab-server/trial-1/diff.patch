diff --git a/src/db.ts b/src/db.ts
new file mode 100644
index 0000000..a1f08dd
--- /dev/null
+++ b/src/db.ts
@@ -0,0 +1,162 @@
+import Database from 'better-sqlite3';
+import { randomUUID } from 'crypto';
+import * as fs from 'fs';
+import * as path from 'path';
+import { fileURLToPath } from 'url';
+
+const __filename = fileURLToPath(import.meta.url);
+const __dirname = path.dirname(__filename);
+
+export interface Document {
+  id: string;
+  title: string;
+  content: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface Version {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operation: string | null;
+  created_at: string;
+}
+
+export class DocumentDB {
+  private db: Database.Database;
+
+  constructor(dbPath?: string) {
+    this.db = new Database(dbPath || ':memory:');
+    this.db.pragma('journal_mode = WAL');
+    this.db.pragma('foreign_keys = ON');
+    this.initSchema();
+  }
+
+  private initSchema(): void {
+    const schemaPath = path.join(__dirname, '..', 'schema.sql');
+    let schema: string;
+    if (fs.existsSync(schemaPath)) {
+      schema = fs.readFileSync(schemaPath, 'utf-8');
+    } else {
+      schema = `
+        CREATE TABLE IF NOT EXISTS documents (
+          id TEXT PRIMARY KEY,
+          title TEXT NOT NULL,
+          content TEXT NOT NULL DEFAULT '',
+          created_at TEXT NOT NULL DEFAULT (datetime('now')),
+          updated_at TEXT NOT NULL DEFAULT (datetime('now'))
+        );
+        CREATE TABLE IF NOT EXISTS versions (
+          id INTEGER PRIMARY KEY AUTOINCREMENT,
+          document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
+          version INTEGER NOT NULL,
+          content TEXT NOT NULL,
+          operation TEXT,
+          created_at TEXT NOT NULL DEFAULT (datetime('now')),
+          UNIQUE(document_id, version)
+        );
+        CREATE TABLE IF NOT EXISTS active_connections (
+          id TEXT PRIMARY KEY,
+          document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
+          connected_at TEXT NOT NULL DEFAULT (datetime('now'))
+        );
+      `;
+    }
+    this.db.exec(schema);
+  }
+
+  createDocument(title: string, content: string = ''): Document {
+    const id = randomUUID();
+    const stmt = this.db.prepare(
+      'INSERT INTO documents (id, title, content) VALUES (?, ?, ?)'
+    );
+    stmt.run(id, title, content);
+
+    // Create initial version
+    this.db.prepare(
+      'INSERT INTO versions (document_id, version, content, operation) VALUES (?, 1, ?, NULL)'
+    ).run(id, content);
+
+    return this.getDocument(id)!;
+  }
+
+  getDocument(id: string): Document | undefined {
+    return this.db.prepare('SELECT * FROM documents WHERE id = ?').get(id) as Document | undefined;
+  }
+
+  listDocuments(): Document[] {
+    return this.db.prepare('SELECT * FROM documents ORDER BY updated_at DESC').all() as Document[];
+  }
+
+  updateDocument(id: string, updates: { title?: string; content?: string }): Document | undefined {
+    const doc = this.getDocument(id);
+    if (!doc) return undefined;
+
+    const title = updates.title ?? doc.title;
+    const content = updates.content ?? doc.content;
+
+    const txn = this.db.transaction(() => {
+      this.db.prepare(
+        "UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?"
+      ).run(title, content, id);
+
+      // If content changed, create a version entry
+      if (content !== doc.content) {
+        const currentVersion = this.getLatestVersion(id);
+        const nextVersion = currentVersion ? currentVersion.version + 1 : 1;
+        this.db.prepare(
+          'INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, NULL)'
+        ).run(id, nextVersion, content);
+      }
+    });
+
+    txn();
+    return this.getDocument(id);
+  }
+
+  deleteDocument(id: string): boolean {
+    const result = this.db.prepare('DELETE FROM documents WHERE id = ?').run(id);
+    return result.changes > 0;
+  }
+
+  updateDocumentContent(id: string, content: string, operation?: object): void {
+    const currentVersion = this.getLatestVersion(id);
+    const nextVersion = currentVersion ? currentVersion.version + 1 : 1;
+
+    const txn = this.db.transaction(() => {
+      this.db.prepare(
+        "UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?"
+      ).run(content, id);
+
+      this.db.prepare(
+        'INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)'
+      ).run(id, nextVersion, content, operation ? JSON.stringify(operation) : null);
+    });
+
+    txn();
+  }
+
+  getVersionHistory(docId: string): Version[] {
+    return this.db.prepare(
+      'SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC'
+    ).all(docId) as Version[];
+  }
+
+  getLatestVersion(docId: string): Version | undefined {
+    return this.db.prepare(
+      'SELECT * FROM versions WHERE document_id = ? ORDER BY version DESC LIMIT 1'
+    ).get(docId) as Version | undefined;
+  }
+
+  getVersion(docId: string, version: number): Version | undefined {
+    return this.db.prepare(
+      'SELECT * FROM versions WHERE document_id = ? AND version = ?'
+    ).get(docId, version) as Version | undefined;
+  }
+
+  close(): void {
+    this.db.close();
+  }
+}
diff --git a/src/ot.test.ts b/src/ot.test.ts
new file mode 100644
index 0000000..2d211fb
--- /dev/null
+++ b/src/ot.test.ts
@@ -0,0 +1,286 @@
+import { describe, it, expect } from 'vitest';
+import {
+  apply,
+  transform,
+  compose,
+  normalize,
+  createInsert,
+  createDelete,
+  validate,
+  inputLength,
+  outputLength,
+  OTOperation,
+} from './ot.js';
+
+describe('OT basics', () => {
+  it('should apply insert at beginning', () => {
+    expect(apply('hello', ['world ', 5])).toBe('world hello');
+  });
+
+  it('should apply insert at end', () => {
+    expect(apply('hello', [5, ' world'])).toBe('hello world');
+  });
+
+  it('should apply insert in middle', () => {
+    expect(apply('hllo', [1, 'e', 3])).toBe('hello');
+  });
+
+  it('should apply delete', () => {
+    expect(apply('hello', [1, -3, 1])).toBe('ho');
+  });
+
+  it('should apply delete at beginning', () => {
+    expect(apply('hello', [-2, 3])).toBe('llo');
+  });
+
+  it('should apply retain only (noop)', () => {
+    expect(apply('hello', [5])).toBe('hello');
+  });
+
+  it('should apply to empty document (insert)', () => {
+    expect(apply('', ['hello'])).toBe('hello');
+  });
+
+  it('should throw on length mismatch', () => {
+    expect(() => apply('hello', [3])).toThrow();
+  });
+
+  it('should calculate input length', () => {
+    expect(inputLength([3, 'abc', -2, 4])).toBe(9);
+  });
+
+  it('should calculate output length', () => {
+    expect(outputLength([3, 'abc', -2, 4])).toBe(10);
+  });
+});
+
+describe('normalize', () => {
+  it('should merge adjacent retains', () => {
+    expect(normalize([3, 2])).toEqual([5]);
+  });
+
+  it('should merge adjacent inserts', () => {
+    expect(normalize(['ab', 'cd'])).toEqual(['abcd']);
+  });
+
+  it('should merge adjacent deletes', () => {
+    expect(normalize([-2, -3])).toEqual([-5]);
+  });
+
+  it('should remove zero-length components', () => {
+    expect(normalize([0, 'hello', 0])).toEqual(['hello']);
+  });
+
+  it('should remove empty strings', () => {
+    expect(normalize(['', 5, ''])).toEqual([5]);
+  });
+});
+
+describe('createInsert / createDelete', () => {
+  it('should create insert at position 0', () => {
+    const op = createInsert(5, 0, 'xx');
+    expect(apply('hello', op)).toBe('xxhello');
+  });
+
+  it('should create insert at end', () => {
+    const op = createInsert(5, 5, 'xx');
+    expect(apply('hello', op)).toBe('helloxx');
+  });
+
+  it('should create insert in middle', () => {
+    const op = createInsert(5, 2, 'xx');
+    expect(apply('hello', op)).toBe('hexxllo');
+  });
+
+  it('should create delete at position 0', () => {
+    const op = createDelete(5, 0, 2);
+    expect(apply('hello', op)).toBe('llo');
+  });
+
+  it('should create delete at end', () => {
+    const op = createDelete(5, 3, 2);
+    expect(apply('hello', op)).toBe('hel');
+  });
+});
+
+describe('validate', () => {
+  it('should accept valid operations', () => {
+    expect(validate([5], 5)).toBeNull();
+    expect(validate(['hello'], 0)).toBeNull();
+    expect(validate([3, 'x', 2], 5)).toBeNull();
+    expect(validate([2, -3], 5)).toBeNull();
+  });
+
+  it('should reject non-array', () => {
+    expect(validate('hello' as unknown as OTOperation, 5)).not.toBeNull();
+  });
+
+  it('should reject wrong input length', () => {
+    expect(validate([3], 5)).not.toBeNull();
+  });
+
+  it('should reject zero components', () => {
+    expect(validate([0, 5], 5)).not.toBeNull();
+  });
+
+  it('should reject empty string components', () => {
+    expect(validate(['', 5], 5)).not.toBeNull();
+  });
+});
+
+describe('transform', () => {
+  it('should transform two inserts at different positions', () => {
+    // doc = "abc"
+    // op1: insert "x" at pos 1 → "axbc"
+    // op2: insert "y" at pos 2 → "abyc"
+    const op1 = createInsert(3, 1, 'x');
+    const op2 = createInsert(3, 2, 'y');
+
+    const [op1p, op2p] = transform(op1, op2);
+
+    const doc = 'abc';
+    const result1 = apply(apply(doc, op1), op2p);
+    const result2 = apply(apply(doc, op2), op1p);
+    expect(result1).toBe(result2);
+    // Both inserts should be present
+    expect(result1).toContain('x');
+    expect(result1).toContain('y');
+  });
+
+  it('should transform two inserts at the same position (op1 has priority)', () => {
+    // doc = "abc"
+    // Both insert at position 1
+    const op1 = createInsert(3, 1, 'x');
+    const op2 = createInsert(3, 1, 'y');
+
+    const [op1p, op2p] = transform(op1, op2);
+
+    const doc = 'abc';
+    const result1 = apply(apply(doc, op1), op2p);
+    const result2 = apply(apply(doc, op2), op1p);
+    expect(result1).toBe(result2);
+    expect(result1).toContain('x');
+    expect(result1).toContain('y');
+  });
+
+  it('should transform insert vs delete', () => {
+    // doc = "abcde"
+    // op1: insert "x" at pos 2 → "abxcde"
+    // op2: delete 2 chars at pos 1 → "ade"
+    const op1 = createInsert(5, 2, 'x');
+    const op2 = createDelete(5, 1, 2);
+
+    const [op1p, op2p] = transform(op1, op2);
+
+    const doc = 'abcde';
+    const result1 = apply(apply(doc, op1), op2p);
+    const result2 = apply(apply(doc, op2), op1p);
+    expect(result1).toBe(result2);
+    expect(result1).toContain('x');
+  });
+
+  it('should transform delete vs insert', () => {
+    const op1 = createDelete(5, 1, 2);
+    const op2 = createInsert(5, 2, 'x');
+
+    const [op1p, op2p] = transform(op1, op2);
+
+    const doc = 'abcde';
+    const result1 = apply(apply(doc, op1), op2p);
+    const result2 = apply(apply(doc, op2), op1p);
+    expect(result1).toBe(result2);
+  });
+
+  it('should transform two deletes at same position', () => {
+    const op1 = createDelete(5, 1, 2);
+    const op2 = createDelete(5, 1, 2);
+
+    const [op1p, op2p] = transform(op1, op2);
+
+    const doc = 'abcde';
+    const result1 = apply(apply(doc, op1), op2p);
+    const result2 = apply(apply(doc, op2), op1p);
+    expect(result1).toBe(result2);
+    expect(result1).toBe('ade');
+  });
+
+  it('should transform two retains (noop)', () => {
+    const op1: OTOperation = [5];
+    const op2: OTOperation = [5];
+
+    const [op1p, op2p] = transform(op1, op2);
+
+    const doc = 'hello';
+    expect(apply(apply(doc, op1), op2p)).toBe('hello');
+    expect(apply(apply(doc, op2), op1p)).toBe('hello');
+  });
+
+  it('should handle overlapping deletes', () => {
+    // doc = "abcde"
+    // op1: delete positions 1-2 (bc) → "ade"
+    // op2: delete positions 2-3 (cd) → "abe"
+    const op1 = createDelete(5, 1, 2);
+    const op2 = createDelete(5, 2, 2);
+
+    const [op1p, op2p] = transform(op1, op2);
+
+    const doc = 'abcde';
+    const result1 = apply(apply(doc, op1), op2p);
+    const result2 = apply(apply(doc, op2), op1p);
+    expect(result1).toBe(result2);
+    expect(result1).toBe('ae');
+  });
+});
+
+describe('compose', () => {
+  it('should compose two sequential inserts', () => {
+    const doc = 'abc';
+    const op1 = createInsert(3, 1, 'x');
+    const op2 = createInsert(4, 3, 'y');
+
+    const composed = compose(op1, op2);
+    const result1 = apply(apply(doc, op1), op2);
+    const result2 = apply(doc, composed);
+    expect(result1).toBe(result2);
+  });
+
+  it('should compose insert then delete', () => {
+    const doc = 'abc';
+    const op1 = createInsert(3, 1, 'x');
+    const op2 = createDelete(4, 1, 1); // delete the x we just inserted
+
+    const composed = compose(op1, op2);
+    const result1 = apply(apply(doc, op1), op2);
+    const result2 = apply(doc, composed);
+    expect(result1).toBe(result2);
+  });
+});
+
+describe('convergence with multiple concurrent edits', () => {
+  it('should converge with 3 concurrent insertions', () => {
+    const doc = 'hello';
+    const op1 = createInsert(5, 0, 'A');
+    const op2 = createInsert(5, 3, 'B');
+    const op3 = createInsert(5, 5, 'C');
+
+    // Apply op1 first, then transform op2 and op3 against it
+    let doc1 = apply(doc, op1);
+    const [, op2t] = transform(op1, op2);
+    const [, op3t] = transform(op1, op3);
+
+    doc1 = apply(doc1, op2t);
+    // Now transform op3t against op2t
+    const [, op3tt] = transform(op2t, op3t);
+    doc1 = apply(doc1, op3tt);
+
+    // All three insertions should be present
+    expect(doc1).toContain('A');
+    expect(doc1).toContain('B');
+    expect(doc1).toContain('C');
+    // Original characters should all still be present
+    expect(doc1.length).toBe(8); // 'hello' (5) + 'A' + 'B' + 'C'
+    for (const ch of 'hello') {
+      expect(doc1).toContain(ch);
+    }
+  });
+});
