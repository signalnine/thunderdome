ould create a document', async () => {\n    const res = await request(server.app)\n      .post('/api/documents')\n      .send({ title: 'Test Doc', content: 'Hello' })\n      .expect(201);\n\n    expect(res.body.id).toBeDefined();\n    expect(res.body.title).toBe('Test Doc');\n    expect(res.body.content).toBe('Hello');\n  });\n\n  it('should reject document creation without title', async () => {\n    await request(server.app)\n      .post('/api/documents')\n      .send({ content: 'Hello' })\n      .expect(400);\n  });\n\n  it('should list documents', async () => {\n    await request(server.app)\n      .post('/api/documents')\n      .send({ title: 'Doc 1' });\n    await request(server.app)\n      .post('/api/documents')\n      .send({ title: 'Doc 2' });\n\n    const res = await request(server.app)\n      .get('/api/documents')\n      .expect(200);\n\n    expect(res.body.length).toBe(2);\n  });\n\n  it('should get a document by id', async () => {\n    const createRes = await request(server.app)\n      .post('/api/documents')\n      .send({ title: 'Test', content: 'Content' });\n\n    const res = await request(server.app)\n      .get(`/api/documents/${createRes.body.id}`)\n      .expect(200);\n\n    expect(res.body.title).toBe('Test');\n    expect(res.body.content).toBe('Content');\n  });\n\n  it('should return 404 for non-existent document', async () => {\n    await request(server.app)\n      .get('/api/documents/nonexistent')\n      .expect(404);\n  });\n\n  it('should update a document', async () => {\n    const createRes = await request(server.app)\n      .post('/api/documents')\n      .send({ title: 'Test', content: 'Content' });\n\n    const res = await request(server.app)\n      .put(`/api/documents/${createRes.body.id}`)\n      .send({ title: 'Updated', content: 'New Content' })\n      .expect(200);\n\n    expect(res.body.title).toBe('Updated');\n    expect(res.body.content).toBe('New Content');\n  });\n\n  it('should delete a document', async () => {\n    const createRes = await request(server.app)\n      .post('/api/documents')\n      .send({ title: 'Test' });\n\n    await request(server.app)\n      .delete(`/api/documents/${createRes.body.id}`)\n      .expect(204);\n\n    await request(server.app)\n      .get(`/api/documents/${createRes.body.id}`)\n      .expect(404);\n  });\n\n  it('should get version history', async () => {\n    const createRes = await request(server.app)\n      .post('/api/documents')\n      .send({ title: 'Test', content: 'v1' });\n\n    const res = await request(server.app)\n      .get(`/api/documents/${createRes.body.id}/versions`)\n      .expect(200);\n\n    expect(res.body.length).toBe(1);\n    expect(res.body[0].version).toBe(1);\n    expect(res.body[0].content).toBe('v1');\n  });\n\n  it('should get a specific version', async () => {\n    const createRes = await request(server.app)\n      .post('/api/documents')\n      .send({ title: 'Test', content: 'v1' });\n\n    const res = await request(server.app)\n      .get(`/api/documents/${createRes.body.id}/versions/1`)\n      .expect(200);\n\n    expect(res.body.version).toBe(1);\n    expect(res.body.content).toBe('v1');\n  });\n});\n\ndescribe('WebSocket Collaboration', () => {\n  beforeEach(async () => {\n    server = createApp();\n    port = await server.start(0);\n  });\n\n  afterEach(async () => {\n    await server.stop();\n  });\n\n  it('should receive sync message on connect', async () => {\n    const createRes = await request(server.app)\n      .post('/api/documents')\n      .send({ title: 'Test', content: 'hello' });\n\n    const { ws, sync } = await connectWs(createRes.body.id);\n    expect(sync.content).toBe('hello');\n    expect(sync.version).toBeDefined();\n    ws.close();\n  });\n\n  it('should receive error when connecting to non-existent document', async () => {\n    const ws = new WebSocket(wsUrl('nonexistent'));\n    const msg = await new Promise<Record<string, unknown>>((resolve) => {\n      ws.on('message', (data) => {\n        resolve(JSON.parse(data.toString()));\n      });\n    });\n    expect(msg.type).toBe('error');\n    ws.close();\n  });\n\n  it('should apply insert operation and receive ack', async () => {\n    const createRes = await request(server.app)\n      .post('/api/documents')\n      .send({ title: 'Test', content: 'hello' });\n\n    const { ws, sync } = await connectWs(createRes.body.id);\n\n    const op = createInsert(5, 5, ' world');\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: op,\n      version: sync.version,\n      clientId: 'client1',\n    }));\n\n    const ack = await waitForMessage(ws, 'ack');\n    expect(ack.type).toBe('ack');\n    expect(ack.version).toBe(sync.version + 1);\n\n    // Verify via REST\n    const docRes = await request(server.app)\n      .get(`/api/documents/${createRes.body.id}`)\n      .expect(200);\n    expect(docRes.body.content).toBe('hello world');\n\n    ws.close();\n  });\n\n  it('should broadcast operation to other clients', async () => {\n    const createRes = await request(server.app)\n      .post('/api/documents')\n      .send({ title: 'Test', content: 'hello' });\n\n    const { ws: ws1, sync: sync1 } = await connectWs(createRes.body.id);\n    const { ws: ws2 } = await connectWs(createRes.body.id);\n\n    const broadcastPromise = waitForMessage(ws2, 'operation');\n\n    const op = createInsert(5, 5, ' world');\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      operation: op,\n      version: sync1.version,\n      clientId: 'client1',\n    }));\n\n    const broadcast = await broadcastPromise;\n    expect(broadcast.type).toBe('operation');\n    expect(broadcast.operation).toBeDefined();\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should handle concurrent edits from two clients', async () => {\n    const createRes = await request(server.app)\n      .post('/api/documents')\n      .send({ title: 'Test', content: 'abc' });\n\n    const { ws: ws1, sync: sync1 } = await connectWs(createRes.body.id);\n    const { ws: ws2, sync: sync2 } = await connectWs(createRes.body.id);\n\n    // Client 1: insert \"X\" at position 0\n    const op1 = createInsert(3, 0, 'X');\n    // Client 2: insert \"Y\" at position 3\n    const op2 = createInsert(3, 3, 'Y');\n\n    const ack1Promise = waitForMessage(ws1, 'ack');\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      operation: op1,\n      version: sync1.version,\n      clientId: 'client1',\n    }));\n\n    await ack1Promise;\n\n    const ack2Promise = waitForMessage(ws2, 'ack');\n    // client2 still thinks it's at sync2.version (same as sync1.version)\n    // The server should transform op2 against op1\n    ws2.send(JSON.stringify({\n      type: 'operation',\n      operation: op2,\n      version: sync2.version,\n      clientId: 'client2',\n    }));\n\n    await ack2Promise;\n\n    // Verify the document\n    const docRes = await request(server.app)\n      .get(`/api/documents/${createRes.body.id}`)\n      .expect(200);\n\n    // Both X and Y should be present\n    expect(docRes.body.content).toContain('X');\n    expect(docRes.body.content).toContain('Y');\n    expect(docRes.body.content).toContain('abc');\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should handle delete operation', async () => {\n    const createRes = await request(server.app)\n      .post('/api/documents')\n      .send({ title: 'Test', content: 'hello world' });\n\n    const { ws, sync } = await connectWs(createRes.body.id);\n\n    // Delete \" world\" (6 chars starting at pos 5)\n    const op = createDelete(11, 5, 6);\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: op,\n      version: sync.version,\n      clientId: 'client1',\n    }));\n\n    await waitForMessage(ws, 'ack');\n\n    const docRes = await request(server.app)\n      .get(`/api/documents/${createRes.body.id}`)\n      .expect(200);\n    expect(docRes.body.content).toBe('hello');\n\n    ws.close();\n  });\n\n  it('should reject malformed operations gracefully', async () => {\n    const createRes = await request(server.app)\n      .post('/api/documents')\n      .send({ title: 'Test', content: 'hello' });\n\n    const { ws } = await connectWs(createRes.body.id);\n\n    // Send invalid JSON\n    ws.send('not json');\n    const errMsg1 = await waitForMessage(ws, 'error');\n    expect(errMsg1.type).toBe('error');\n\n    // Send operation with wrong type\n    ws.send(JSON.stringify({ type: 'unknown' }));\n    const errMsg2 = await waitForMessage(ws, 'error');\n    expect(errMsg2.type).toBe('error');\n\n    // Send operation with invalid version\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: [5],\n      version: 999,\n      clientId: 'c1',\n    }));\n    const errMsg3 = await waitForMessage(ws, 'error');\n    expect(errMsg3.type).toBe('error');\n\n    ws.close();\n  });\n\n  it('should persist changes across server restarts', async () => {\n    const dbPath = '/tmp/test-persist-' + Date.now() + '.db';\n\n    const server1 = createApp(dbPath);\n    const port1 = await server1.start(0);\n\n    // Create a document\n    const createRes = await request(server1.app)\n      .post('/api/documents')\n      .send({ title: 'Persist Test', content: 'original' });\n\n    const docId = createRes.body.id;\n\n    // Connect and edit\n    const { ws, sync } = await connectWs(docId);\n    const op = createInsert(8, 8, ' modified');\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: op,\n      version: sync.version,\n      clientId: 'c1',\n    }));\n    await waitForMessage(ws, 'ack');\n    ws.close();\n\n    // Stop server 1\n    await server1.stop();\n\n    // Start server 2 with same database\n    const server2 = createApp(dbPath);\n    const _port2 = await server2.start(0);\n\n    // Verify document is persisted\n    const docRes = await request(server2.app)\n      .get(`/api/documents/${docId}`)\n      .expect(200);\n\n    expect(docRes.body.content).toBe('original modified');\n\n    // Verify version history\n    const versionsRes = await request(server2.app)\n      .get(`/api/documents/${docId}/versions`)\n      .expect(200);\n\n    expect(versionsRes.body.length).toBeGreaterThan(1);\n\n    await server2.stop();\n\n    // Clean up\n    const { unlinkSync } = await import('fs');\n    try { unlinkSync(dbPath); } catch { /* ignore */ }\n    try { unlinkSync(dbPath + '-wal'); } catch { /* ignore */ }\n    try { unlinkSync(dbPath + '-shm'); } catch { /* ignore */ }\n\n    function connectWs(docId: string): Promise<{ ws: WebSocket; sync: { content: string; version: number } }> {\n      return new Promise((resolve, reject) => {\n        const ws = new WebSocket(`ws://localhost:${port1}/ws/documents/${docId}`);\n        ws.on('message', (data) => {\n          const msg = JSON.parse(data.toString());\n          if (msg.type === 'sync') {\n            resolve({ ws, sync: msg });\n          } else if (msg.type === 'error') {\n            reject(new Error(msg.message));\n          }\n        });\n        ws.on('error', reject);\n      });\n    }\n  });\n\n  it('should handle 10 concurrent clients on the same document', async () => {\n    const createRes = await request(server.app)\n      .post('/api/documents')\n      .send({ title: 'Concurrent Test', content: '' });\n\n    const docId = createRes.body.id;\n    const numClients = 10;\n    const clients: { ws: WebSocket; sync: { content: string; version: number } }[] = [];\n\n    // Connect all clients\n    for (let i = 0; i < numClients; i++) {\n      const client = await connectWs(docId);\n      clients.push(client);\n    }\n\n    // Each client sends an insert operation sequentially\n    // (each based on the previous version to simplify)\n    for (let i = 0; i < numClients; i++) {\n      const client = clients[i];\n      // Insert character at position i (document grows)\n      const op: OTOperation = [];\n      if (i > 0) op.push(i);\n      op.push(String(i));\n      // Remaining is the version sync content length\n      // The client might not have seen all previous ops yet,\n      // so we base it on version 0 (empty doc) and let the server OT handle it\n      const baseOp = createInsert(0, 0, String(i));\n\n      const ackPromise = waitForMessage(client.ws, 'ack');\n      client.ws.send(JSON.stringify({\n        type: 'operation',\n        operation: baseOp,\n        version: client.sync.version,\n        clientId: `client${i}`,\n      }));\n\n      await ackPromise;\n    }\n\n    // Wait a bit for everything to settle\n    await new Promise(r => setTimeout(r, 100));\n\n    // Verify the document has all characters\n    const docRes = await request(server.app)\n      .get(`/api/documents/${docId}`)\n      .expect(200);\n\n    const content = docRes.body.content;\n    // All digits 0-9 should be present\n    for (let i = 0; i < numClients; i++) {\n      expect(content).toContain(String(i));\n    }\n    expect(content.length).toBe(numClients);\n\n    // Clean up\n    for (const client of clients) {\n      client.ws.close();\n    }\n  });\n\n  it('should handle truly concurrent edits without corruption', async () => {\n    const createRes = await request(server.app)\n      .post('/api/documents')\n      .send({ title: 'True Concurrent', content: 'base' });\n\n    const docId = createRes.body.id;\n\n    // Connect 5 clients\n    const clients: { ws: WebSocket; sync: { content: string; version: number } }[] = [];\n    for (let i = 0; i < 5; i++) {\n      clients.push(await connectWs(docId));\n    }\n\n    // All clients send operations based on the same version (truly concurrent)\n    const ackPromises: Promise<Record<string, unknown>>[] = [];\n    for (let i = 0; i < 5; i++) {\n      const op = createInsert(4, 4, String.fromCharCode(65 + i)); // A, B, C, D, E\n      ackPromises.push(waitForMessage(clients[i].ws, 'ack'));\n      clients[i].ws.send(JSON.stringify({\n        type: 'operation',\n        operation: op,\n        version: clients[i].sync.version,\n        clientId: `client${i}`,\n      }));\n    }\n\n    // Wait for all acks\n    await Promise.all(ackPromises);\n\n    // Give a moment for everything to propagate\n    await new Promise(r => setTimeout(r, 100));\n\n    // Verify document\n    const docRes = await request(server.app)\n      .get(`/api/documents/${docId}`)\n      .expect(200);\n\n    const content = docRes.body.content;\n    expect(content).toContain('base');\n    // All 5 insertions should be present\n    for (let i = 0; i < 5; i++) {\n      expect(content).toContain(String.fromCharCode(65 + i));\n    }\n    expect(content.length).toBe(9); // 'base' + 5 chars\n\n    // Verify version history shows all operations\n    const versionsRes = await request(server.app)\n      .get(`/api/documents/${docId}/versions`)\n      .expect(200);\n    expect(versionsRes.body.length).toBeGreaterThanOrEqual(6); // initial + 5 ops\n\n    for (const client of clients) {\n      client.ws.close();\n    }\n  });\n});\n","structuredPatch":[{"oldStart":378,"oldLines":7,"newStart":378,"newLines":7,"lines":[" ","     // Start server 2 with same database","     const server2 = createApp(dbPath);","-    const _port2 = await server2.start(0);","+    await server2.start(0);"," ","     // Verify document is persisted","     const docRes = await request(server2.app)"]}],"userModified":false,"replaceAll":false}}
