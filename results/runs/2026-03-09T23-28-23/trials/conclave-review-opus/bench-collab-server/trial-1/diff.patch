ld remove zero-length components', () => {\n    expect(normalize([0, 'hello', 0])).toEqual(['hello']);\n  });\n\n  it('should remove empty strings', () => {\n    expect(normalize(['', 5, ''])).toEqual([5]);\n  });\n});\n\ndescribe('createInsert / createDelete', () => {\n  it('should create insert at position 0', () => {\n    const op = createInsert(5, 0, 'xx');\n    expect(apply('hello', op)).toBe('xxhello');\n  });\n\n  it('should create insert at end', () => {\n    const op = createInsert(5, 5, 'xx');\n    expect(apply('hello', op)).toBe('helloxx');\n  });\n\n  it('should create insert in middle', () => {\n    const op = createInsert(5, 2, 'xx');\n    expect(apply('hello', op)).toBe('hexxllo');\n  });\n\n  it('should create delete at position 0', () => {\n    const op = createDelete(5, 0, 2);\n    expect(apply('hello', op)).toBe('llo');\n  });\n\n  it('should create delete at end', () => {\n    const op = createDelete(5, 3, 2);\n    expect(apply('hello', op)).toBe('hel');\n  });\n});\n\ndescribe('validate', () => {\n  it('should accept valid operations', () => {\n    expect(validate([5], 5)).toBeNull();\n    expect(validate(['hello'], 0)).toBeNull();\n    expect(validate([3, 'x', 2], 5)).toBeNull();\n    expect(validate([2, -3], 5)).toBeNull();\n  });\n\n  it('should reject non-array', () => {\n    expect(validate('hello' as unknown as OTOperation, 5)).not.toBeNull();\n  });\n\n  it('should reject wrong input length', () => {\n    expect(validate([3], 5)).not.toBeNull();\n  });\n\n  it('should reject zero components', () => {\n    expect(validate([0, 5], 5)).not.toBeNull();\n  });\n\n  it('should reject empty string components', () => {\n    expect(validate(['', 5], 5)).not.toBeNull();\n  });\n});\n\ndescribe('transform', () => {\n  it('should transform two inserts at different positions', () => {\n    // doc = \"abc\"\n    // op1: insert \"x\" at pos 1 → \"axbc\"\n    // op2: insert \"y\" at pos 2 → \"abyc\"\n    const op1 = createInsert(3, 1, 'x');\n    const op2 = createInsert(3, 2, 'y');\n\n    const [op1p, op2p] = transform(op1, op2);\n\n    const doc = 'abc';\n    const result1 = apply(apply(doc, op1), op2p);\n    const result2 = apply(apply(doc, op2), op1p);\n    expect(result1).toBe(result2);\n    // Both inserts should be present\n    expect(result1).toContain('x');\n    expect(result1).toContain('y');\n  });\n\n  it('should transform two inserts at the same position (op1 has priority)', () => {\n    // doc = \"abc\"\n    // Both insert at position 1\n    const op1 = createInsert(3, 1, 'x');\n    const op2 = createInsert(3, 1, 'y');\n\n    const [op1p, op2p] = transform(op1, op2);\n\n    const doc = 'abc';\n    const result1 = apply(apply(doc, op1), op2p);\n    const result2 = apply(apply(doc, op2), op1p);\n    expect(result1).toBe(result2);\n    expect(result1).toContain('x');\n    expect(result1).toContain('y');\n  });\n\n  it('should transform insert vs delete', () => {\n    // doc = \"abcde\"\n    // op1: insert \"x\" at pos 2 → \"abxcde\"\n    // op2: delete 2 chars at pos 1 → \"ade\"\n    const op1 = createInsert(5, 2, 'x');\n    const op2 = createDelete(5, 1, 2);\n\n    const [op1p, op2p] = transform(op1, op2);\n\n    const doc = 'abcde';\n    const result1 = apply(apply(doc, op1), op2p);\n    const result2 = apply(apply(doc, op2), op1p);\n    expect(result1).toBe(result2);\n    expect(result1).toContain('x');\n  });\n\n  it('should transform delete vs insert', () => {\n    const op1 = createDelete(5, 1, 2);\n    const op2 = createInsert(5, 2, 'x');\n\n    const [op1p, op2p] = transform(op1, op2);\n\n    const doc = 'abcde';\n    const result1 = apply(apply(doc, op1), op2p);\n    const result2 = apply(apply(doc, op2), op1p);\n    expect(result1).toBe(result2);\n  });\n\n  it('should transform two deletes at same position', () => {\n    const op1 = createDelete(5, 1, 2);\n    const op2 = createDelete(5, 1, 2);\n\n    const [op1p, op2p] = transform(op1, op2);\n\n    const doc = 'abcde';\n    const result1 = apply(apply(doc, op1), op2p);\n    const result2 = apply(apply(doc, op2), op1p);\n    expect(result1).toBe(result2);\n    expect(result1).toBe('ade');\n  });\n\n  it('should transform two retains (noop)', () => {\n    const op1: OTOperation = [5];\n    const op2: OTOperation = [5];\n\n    const [op1p, op2p] = transform(op1, op2);\n\n    const doc = 'hello';\n    expect(apply(apply(doc, op1), op2p)).toBe('hello');\n    expect(apply(apply(doc, op2), op1p)).toBe('hello');\n  });\n\n  it('should handle overlapping deletes', () => {\n    // doc = \"abcde\"\n    // op1: delete positions 1-2 (bc) → \"ade\"\n    // op2: delete positions 2-3 (cd) → \"abe\"\n    const op1 = createDelete(5, 1, 2);\n    const op2 = createDelete(5, 2, 2);\n\n    const [op1p, op2p] = transform(op1, op2);\n\n    const doc = 'abcde';\n    const result1 = apply(apply(doc, op1), op2p);\n    const result2 = apply(apply(doc, op2), op1p);\n    expect(result1).toBe(result2);\n    expect(result1).toBe('ae');\n  });\n});\n\ndescribe('compose', () => {\n  it('should compose two sequential inserts', () => {\n    const doc = 'abc';\n    const op1 = createInsert(3, 1, 'x');\n    const op2 = createInsert(4, 3, 'y');\n\n    const composed = compose(op1, op2);\n    const result1 = apply(apply(doc, op1), op2);\n    const result2 = apply(doc, composed);\n    expect(result1).toBe(result2);\n  });\n\n  it('should compose insert then delete', () => {\n    const doc = 'abc';\n    const op1 = createInsert(3, 1, 'x');\n    const op2 = createDelete(4, 1, 1); // delete the x we just inserted\n\n    const composed = compose(op1, op2);\n    const result1 = apply(apply(doc, op1), op2);\n    const result2 = apply(doc, composed);\n    expect(result1).toBe(result2);\n  });\n});\n\ndescribe('convergence with multiple concurrent edits', () => {\n  it('should converge with 3 concurrent insertions', () => {\n    const doc = 'hello';\n    const op1 = createInsert(5, 0, 'A');\n    const op2 = createInsert(5, 3, 'B');\n    const op3 = createInsert(5, 5, 'C');\n\n    // Apply op1 first, then transform op2 and op3 against it\n    let doc1 = apply(doc, op1);\n    const [, op2t] = transform(op1, op2);\n    const [, op3t] = transform(op1, op3);\n\n    doc1 = apply(doc1, op2t);\n    // Now transform op3t against op2t\n    const [, op3tt] = transform(op2t, op3t);\n    doc1 = apply(doc1, op3tt);\n\n    // All three insertions should be present\n    expect(doc1).toContain('A');\n    expect(doc1).toContain('B');\n    expect(doc1).toContain('C');\n    expect(doc1).toContain('hello');\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":822,"cache_read_input_tokens":31494,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":822},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"2b228799-baf7-4472-bcd7-5cdb40ebfa65","uuid":"c591fb39-df1e-45d0-8c10-b23b25b1aed8"}
