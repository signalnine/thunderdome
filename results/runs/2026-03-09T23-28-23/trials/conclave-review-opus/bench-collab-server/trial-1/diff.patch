+    // Each client sends an insert operation sequentially
+    // (each based on the previous version to simplify)
+    for (let i = 0; i < numClients; i++) {
+      const client = clients[i];
+      // Insert character at position i (document grows)
+      const op: OTOperation = [];
+      if (i > 0) op.push(i);
+      op.push(String(i));
+      // Remaining is the version sync content length
+      // The client might not have seen all previous ops yet,
+      // so we base it on version 0 (empty doc) and let the server OT handle it
+      const baseOp = createInsert(0, 0, String(i));
