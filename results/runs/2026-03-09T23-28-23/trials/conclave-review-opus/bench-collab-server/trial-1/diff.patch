 const ack2Promise = waitForMessage(ws2, 'ack');\n   270→    // client2 still thinks it's at sync2.version (same as sync1.version)\n   271→    // The server should transform op2 against op1\n   272→    ws2.send(JSON.stringify({\n   273→      type: 'operation',\n   274→      operation: op2,\n   275→      version: sync2.version,\n   276→      clientId: 'client2',\n   277→    }));\n   278→\n   279→    await ack2Promise;\n   280→\n   281→    // Verify the document\n   282→    const docRes = await request(server.app)\n   283→      .get(`/api/documents/${createRes.body.id}`)\n   284→      .expect(200);\n   285→\n   286→    // Both X and Y should be present\n   287→    expect(docRes.body.content).toContain('X');\n   288→    expect(docRes.body.content).toContain('Y');\n   289→    expect(docRes.body.content).toContain('abc');\n   290→\n   291→    ws1.close();\n   292→    ws2.close();\n   293→  });\n   294→\n   295→  it('should handle delete operation', async () => {\n   296→    const createRes = await request(server.app)\n   297→      .post('/api/documents')\n   298→      .send({ title: 'Test', content: 'hello world' });\n   299→\n   300→    const { ws, sync } = await connectWs(createRes.body.id);\n   301→\n   302→    // Delete \" world\" (6 chars starting at pos 5)\n   303→    const op = createDelete(11, 5, 6);\n   304→    ws.send(JSON.stringify({\n   305→      type: 'operation',\n   306→      operation: op,\n   307→      version: sync.version,\n   308→      clientId: 'client1',\n   309→    }));\n   310→\n   311→    await waitForMessage(ws, 'ack');\n   312→\n   313→    const docRes = await request(server.app)\n   314→      .get(`/api/documents/${createRes.body.id}`)\n   315→      .expect(200);\n   316→    expect(docRes.body.content).toBe('hello');\n   317→\n   318→    ws.close();\n   319→  });\n   320→\n   321→  it('should reject malformed operations gracefully', async () => {\n   322→    const createRes = await request(server.app)\n   323→      .post('/api/documents')\n   