+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XAxX9mKo5tYJebhqdC4SbQ","type":"tool_result","content":"     1→import { WebSocketServer, WebSocket } from 'ws';\n     2→import { IncomingMessage, Server as HttpServer } from 'http';\n     3→import { DocumentDB } from './db.js';\n     4→import { OTOperation, apply, transform, validate, ServerMessage } from './ot.js';\n     5→import { randomUUID } from 'crypto';\n     6→\n     7→interface ClientConnection {\n     8→  id: string;\n     9→  ws: WebSocket;\n    10→  documentId: string;\n    11→}\n    12→\n    13→interface DocumentState {\n    14→  version: number;\n    15→  content: string;\n    16→  /** History of operations since initial version, indexed by version. ops[i] transforms version i to version i+1. */\n    17→  ops: OTOperation[];\n    18→}\n    19→\n    20→export class CollaborationServer {\n    21→  private wss: WebSocketServer;\n    22→  private clients: Map<string, ClientConnection> = new Map();\n    23→  private documents: Map<string, DocumentState> = new Map();\n    24→  private db: DocumentDB;\n    25→\n    26→  constructor(server: HttpServer, db: DocumentDB) {\n    27→    this.db = db;\n    28→    this.wss = new WebSocketServer({ noServer: true });\n    29→\n    30→    server.on('upgrade', (request: IncomingMessage, socket, head) => {\n    31→      const url = new URL(request.url || '', `http://${request.headers.host || 'localhost'}`);\n    32→      const match = url.pathname.match(/^\\/ws\\/documents\\/([^/]+)$/);\n    33→\n    34→      if (!match) {\n    35→        socket.destroy();\n    36→        return;\n    37→      }\n    38→\n    39→      const docId = match[1];\n    40→\n    41→      this.wss.handleUpgrade(request, socket, head, (ws) => {\n    42→        this.handleConnection(ws, docId);\n    43→      });\n    44→    });\n    45→  }\n    46→\n    47→  private getDocumentState(docId: string): DocumentState | null {\n    48→    let state = this.documents.get(docId);\n    49→    if (state) return state;\n    50→\n    51→    // Load from database\n    52→    const doc = this.db.getDocument(docId);\n    53→    if (!doc) return null;\n    54→\n    55→    const latestVersion = this.db.getLatestVersion(docId);\n    56→    const version = latestVersion ? latestVersion.version : 0;\n    57→\n    58→    state = {\n    59→      version,\n    60→      content: doc.content,\n    61→      ops: [],\n    62→    };\n    63→    this.documents.set(docId, state);\n    64→    return state;\n    65→  }\n    66→\n    67→  private handleConnection(ws: WebSocket, docId: string): void {\n    68→    const clientId = randomUUID();\n    69→    const state = this.getDocumentState(docId);\n    70→\n    71→    if (!state) {\n    72→      const errorMsg: ServerMessage = { type: 'error', message: 'Document not found' };\n    73→      ws.send(JSON.stringify(errorMsg));\n    74→      ws.close();\n    75→      return;\n    76→    }\n    77→\n    78→    const client: ClientConnection = { id: clientId, ws, documentId: docId };\n    79→    this.clients.set(clientId, client);\n    80→\n    81→    // Send sync message\n    82→    const syncMsg: ServerMessage = {\n    83→      type: 'sync',\n    84→      content: state.content,\n    85→      version: state.version,\n    86→    };\n    87→    ws.send(JSON.stringify(syncMsg));\n    88→\n    89→    ws.on('message', (data) => {\n    90→      try {\n    91→        const raw = data.toString();\n    92→        let msg: unknown;\n    93→        try {\n    94→          msg = JSON.parse(raw);\n    95→        } catch {\n    96→          this.sendError(ws, 'Invalid JSON');\n    97→          return;\n    98→        }\n    99→\n   100→        if (!msg || typeof msg !== 'object') {\n   101→          this.sendError(ws, 'Message must be an object');\n   102→          return;\n   103→        }\n   104→\n   105→        const message = msg as Record<string, unknown>;\n   106→\n   107→        if (message.type !== 'operation') {\n   108→          this.sendError(ws, `Unknown message type: ${String(message.type)}`);\n   109→          return;\n   110→        }\n   111→\n   112→        this.handleOperation(client, message);\n   113→      } catch (err) {\n   114→        this.sendError(ws, `Internal error: ${err instanceof Error ? err.message : String(err)}`);\n   115→      }\n   116→    });\n   117→\n   118→    ws.on('close', () => {\n   119→      this.clients.delete(clientId);\n   120→    });\n   121→\n   122→    ws.on('error', () => {\n   123→      this.clients.delete(clientId);\n   124→    });\n   125→  }\n   126→\n   127→  private handleOperation(client: ClientConnection, message: Record<string, unknown>): void {\n   128→    const state = this.getDocumentState(client.documentId);\n   129→    if (!state) {\n   130→      this.sendError(client.ws, 'Document not found');\n   131→      return;\n   132→    }\n   133→\n   134→    const clientVersion = message.version;\n   135→    if (typeof clientVersion !== 'number' || !Number.isInteger(clientVersion)) {\n   136→      this.sendError(client.ws, 'Version must be an integer');\n   137→      return;\n   138→    }\n   139→\n   140→    let operation = message.operation;\n   141→    if (!Array.isArray(operation)) {\n   142→      this.sendError(client.ws, 'Operation must be an array');\n   143→      return;\n   144→    }\n   145→\n   146→    operation = operation as OTOperation;\n   147→\n   148→    // The client's version tells us what document state it was based on.\n   149→    // We need to transform the operation against all operations that happened\n   150→    // between the client's version and the current server version.\n   151→    const baseVersion = clientVersion;\n   152→    const serverVersion = state.version;\n   153→\n   154→    if (baseVersion < 0 || baseVersion > serverVersion) {\n   155→      this.sendError(client.ws, `Invalid version: ${baseVersion}. Server is at version ${serverVersion}`);\n   156→      return;\n   157→    }\n   158→\n   159→    // Transform against all ops that happened since the client's version\n   160→    let transformedOp = operation as OTOperation;\n   161→    for (let i = baseVersion; i < serverVersion; i++) {\n   162→      const serverOp = state.ops[i - (state.version - state.ops.length)];\n   163→      if (!serverOp) {\n   164→        this.sendError(client.ws, 'Cannot transform: missing operation history');\n   165→        return;\n   166→      }\n   167→      const [clientPrime] = transform(transformedOp, serverOp);\n   168→      transformedOp = clientPrime;\n   169→    }\n   170→\n   171→    // Validate the transformed operation against current document\n   172→    const validationError = validate(transformedOp, state.content.length);\n   173→    if (validationError) {\n   174→      this.sendError(client.ws, `Invalid operation: ${validationError}`);\n   175→      return;\n   176→    }\n   177→\n   178→    // Apply the operation\n   179→    const newContent = apply(state.content, transformedOp);\n   180→    state.content = newContent;\n   181→    state.version++;\n   182→    state.ops.push(transformedOp);\n   183→\n   184→    // Persist to database\n   185→    this.db.updateDocumentContent(\n   186→      client.documentId,\n   187→      newContent,\n   188→      { op: transformedOp, clientId: client.id }\n   189→    );\n   190→\n   191→    // Send ack to the client that sent the operation\n   192→    const ackMsg: ServerMessage = { type: 'ack', version: state.version };\n   193→    client.ws.send(JSON.stringify(ackMsg));\n   194→\n   195→    // Broadcast to all other clients on the same document\n   196→    const broadcastMsg: ServerMessage = {\n   197→      type: 'operation',\n   198→      operation: transformedOp,\n   199→      version: state.version,\n   200→      clientId: client.id,\n   201→    };\n   202→\n   203→    for (const [, otherClient] of this.clients) {\n   204→      if (otherClient.id !== client.id && otherClient.documentId === client.documentId) {\n   205→        if (otherClient.ws.readyState === WebSocket.OPEN) {\n   206→          otherClient.ws.send(JSON.stringify(broadcastMsg));\n   207→        }\n   208→      }\n   209→    }\n   210→  }\n   211→\n   212→  private sendError(ws: WebSocket, message: string): void {\n   213→    const errorMsg: ServerMessage = { type: 'error', message };\n   214→    if (ws.readyState === WebSocket.OPEN) {\n   215→      ws.send(JSON.stringify(errorMsg));\n   216→    }\n   217→  }\n   218→\n   219→  closeAll(): void {\n   220→    for (const [, client] of this.clients) {\n   221→      client.ws.close();\n   222→    }\n   223→    this.clients.clear();\n   224→    this.documents.clear();\n   225→    this.wss.close();\n   226→  }\n   227→}\n   228→"}]},"parent_tool_use_id":"toolu_011RGUoDznqUEBAg332afDRs","session_id":"2b228799-baf7-4472-bcd7-5cdb40ebfa65","uuid":"89994278-f7b9-418d-9779-160982e0d79c"}
