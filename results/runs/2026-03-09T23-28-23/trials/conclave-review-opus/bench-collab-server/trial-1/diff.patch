   const deleted = db.deleteDocument(req.params.id);\n    if (!deleted) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    res.status(204).send();\n  });\n\n  // Get version history\n  router.get('/documents/:id/versions', (req: Request, res: Response) => {\n    const doc = db.getDocument(req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n\n    const versions = db.getVersionHistory(req.params.id);\n    res.json(versions);\n  });\n\n  // Get specific version\n  router.get('/documents/:id/versions/:version', (req: Request, res: Response) => {\n    const doc = db.getDocument(req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n\n    const version = db.getVersion(req.params.id, parseInt(req.params.version, 10));\n    if (!version) {\n      res.status(404).json({ error: 'Version not found' });\n      return;\n    }\n    res.json(version);\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":297,"cache_read_input_tokens":25625,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":297},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"2b228799-baf7-4472-bcd7-5cdb40ebfa65","uuid":"3def7f71-e88e-4ba3-bd9d-c58620a93586"}
