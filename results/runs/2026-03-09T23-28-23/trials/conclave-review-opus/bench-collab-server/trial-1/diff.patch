@@ -0,0 +1,346 @@
+/**
+ * Operational Transformation (OT) engine for collaborative text editing.
+ *
+ * Operations are arrays of components:
+ * - number > 0: retain N characters
+ * - string: insert the string
+ * - number < 0: delete |N| characters
+ *
+ * The sum of "input lengths" (retain + |delete|) must equal the document length.
+ * The output length is: retain + insert length.
+ */
+
+export type OTComponent = number | string;
+export type OTOperation = OTComponent[];
+
+export interface OperationMessage {
+  type: 'operation';
+  operation: OTOperation;
+  version: number;
+  clientId: string;
+}
+
+export interface SyncMessage {
+  type: 'sync';
+  content: string;
+  version: number;
+}
+
+export interface AckMessage {
+  type: 'ack';
+  version: number;
+}
+
+export interface ErrorMessage {
+  type: 'error';
+  message: string;
+}
+
+export type ServerMessage = SyncMessage | AckMessage | ErrorMessage | (OperationMessage & { type: 'operation' });
+export type ClientMessage = OperationMessage;
+
+/** Calculate the input length of an operation (the length of document it expects). */
+export function inputLength(op: OTOperation): number {
+  let len = 0;
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) len += c;       // retain
+      else len += Math.abs(c);   // delete
+    }
+    // inserts don't consume input
+  }
+  return len;
+}
+
+/** Calculate the output length of an operation (the length of document it produces). */
+export function outputLength(op: OTOperation): number {
+  let len = 0;
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) len += c;       // retain
+      // delete produces nothing
+    } else {
+      len += c.length;           // insert
+    }
+  }
+  return len;
+}
+
+/** Apply an operation to a document string. */
+export function apply(doc: string, op: OTOperation): string {
+  const inLen = inputLength(op);
+  if (inLen !== doc.length) {
+    throw new Error(`Operation input length (${inLen}) does not match document length (${doc.length})`);
+  }
+
+  let result = '';
+  let pos = 0;
+
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) {
+        // retain
+        result += doc.slice(pos, pos + c);
+        pos += c;
+      } else {
+        // delete
+        pos += Math.abs(c);
+      }
+    } else {
+      // insert
+      result += c;
+    }
+  }
+
+  return result;
+}
+
+/** Normalize an operation by merging adjacent same-type components. */
+export function normalize(op: OTOperation): OTOperation {
+  const result: OTOperation = [];
+
+  for (const c of op) {
+    if (typeof c === 'number' && c === 0) continue;
+    if (typeof c === 'string' && c === '') continue;
+
+    if (result.length === 0) {
+      result.push(c);
+      continue;
+    }
+
+    const last = result[result.length - 1];
+
+    if (typeof c === 'number' && typeof last === 'number') {
+      // Both are numbers - merge if same sign
+      if ((c > 0 && last > 0) || (c < 0 && last < 0)) {
+        result[result.length - 1] = last + c;
+      } else {
+        result.push(c);
+      }
+    } else if (typeof c === 'string' && typeof last === 'string') {
+      result[result.length - 1] = last + c;
+    } else {
+      result.push(c);
+    }
+  }
+
+  return result;
+}
+
+/**
+ * Iterator over operation components, yielding one character-level unit at a time.
+ */
+class OpIterator {
+  private ops: OTOperation;
+  private index: number = 0;
+  private offset: number = 0;
+
+  constructor(ops: OTOperation) {
+    this.ops = ops;
+  }
+
+  hasNext(): boolean {
+    return this.index < this.ops.length;
+  }
+
+  /** Peek at the type of the current component: 'retain', 'insert', or 'delete'. */
+  peekType(): 'retain' | 'insert' | 'delete' {
+    const c = this.ops[this.index];
+    if (typeof c === 'string') return 'insert';
+    if (c > 0) return 'retain';
+    return 'delete';
+  }
+
+  /** Take up to `n` units from the current component. */
+  take(n: number): OTComponent {
+    const c = this.ops[this.index];
+
+    if (typeof c === 'string') {
+      // Insert
+      const remaining = c.length - this.offset;
+      const take = Math.min(n, remaining);
+      const result = c.slice(this.offset, this.offset + take);
+      this.offset += take;
+      if (this.offset >= c.length) {
+        this.index++;
+        this.offset = 0;
+      }
+      return result;
+    } else {
+      // Retain or delete
+      const abs = Math.abs(c);
+      const remaining = abs - this.offset;
+      const take = Math.min(n, remaining);
+      this.offset += take;
+      if (this.offset >= abs) {
+        this.index++;
+        this.offset = 0;
+      }
+      return c > 0 ? take : -take;
+    }
+  }
+
+  /** Get remaining length of current component. */
+  peekLength(): number {
+    if (!this.hasNext()) return Infinity;
+    const c = this.ops[this.index];
+    if (typeof c === 'string') return c.length - this.offset;
+    return Math.abs(c) - this.offset;
+  }
+}
+
+/**
+ * Transform two concurrent operations (op1, op2) against each other.
+ * Returns [op1', op2'] such that:
+ *   apply(apply(doc, op1), op2') === apply(apply(doc, op2), op1')
+ *
+ * op1 has priority (its inserts come first in case of tie).
+ */
+export function transform(op1: OTOperation, op2: OTOperation): [OTOperation, OTOperation] {
+  const iter1 = new OpIterator(op1);
+  const iter2 = new OpIterator(op2);
+  const op1prime: OTOperation = [];
+  const op2prime: OTOperation = [];
+
+  while (iter1.hasNext() || iter2.hasNext()) {
+    // Inserts from op1 go first (op1 has priority)
+    if (iter1.hasNext() && iter1.peekType() === 'insert') {
+      const s = iter1.take(iter1.peekLength());
+      op1prime.push(s);
+      // op2' must retain over op1's insert
+      op2prime.push(typeof s === 'string' ? s.length : 0);
+      continue;
+    }
+
+    // Then inserts from op2
+    if (iter2.hasNext() && iter2.peekType() === 'insert') {
+      const s = iter2.take(iter2.peekLength());
+      op2prime.push(s);
+      // op1' must retain over op2's insert
+      op1prime.push(typeof s === 'string' ? s.length : 0);
+      continue;
+    }
+
+    // Both must have retain or delete
+    if (!iter1.hasNext() && !iter2.hasNext()) break;
+
+    const len = Math.min(iter1.peekLength(), iter2.peekLength());
+
+    const type1 = iter1.hasNext() ? iter1.peekType() : 'retain';
+    const type2 = iter2.hasNext() ? iter2.peekType() : 'retain';
+
+    if (type1 === 'retain' && type2 === 'retain') {
+      op1prime.push(len);
+      op2prime.push(len);
+      iter1.take(len);
+      iter2.take(len);
+    } else if (type1 === 'delete' && type2 === 'delete') {
+      // Both delete the same text - neither needs to do anything
+      iter1.take(len);
+      iter2.take(len);
+    } else if (type1 === 'delete' && type2 === 'retain') {
+      op1prime.push(-len);
+      // op2' doesn't need to do anything for deleted text
+      iter1.take(len);
+      iter2.take(len);
+    } else if (type1 === 'retain' && type2 === 'delete') {
+      op2prime.push(-len);
+      // op1' doesn't need to do anything for deleted text
+      iter1.take(len);
+      iter2.take(len);
+    }
+  }
+
+  return [normalize(op1prime), normalize(op2prime)];
+}
+
+/**
+ * Compose two sequential operations into one.
+ * apply(apply(doc, op1), op2) === apply(doc, compose(op1, op2))
+ */
+export function compose(op1: OTOperation, op2: OTOperation): OTOperation {
+  const iter1 = new OpIterator(op1);
+  const iter2 = new OpIterator(op2);
+  const result: OTOperation = [];
+
+  while (iter1.hasNext() || iter2.hasNext()) {
+    // Delete from op1 passes through
+    if (iter1.hasNext() && iter1.peekType() === 'delete') {
+      result.push(iter1.take(iter1.peekLength()));
+      continue;
+    }
+
+    // Insert from op2 passes through
+    if (iter2.hasNext() && iter2.peekType() === 'insert') {
+      result.push(iter2.take(iter2.peekLength()));
+      continue;
+    }
+
+    if (!iter1.hasNext() && !iter2.hasNext()) break;
+
+    const len = Math.min(iter1.peekLength(), iter2.peekLength());
+    const type1 = iter1.hasNext() ? iter1.peekType() : 'retain';
+    const type2 = iter2.hasNext() ? iter2.peekType() : 'retain';
+
+    if (type1 === 'retain' && type2 === 'retain') {
+      result.push(len);
+      iter1.take(len);
+      iter2.take(len);
+    } else if (type1 === 'insert' && type2 === 'retain') {
+      result.push(iter1.take(len));
+      iter2.take(len);
+    } else if (type1 === 'retain' && type2 === 'delete') {
+      result.push(-len);
+      iter1.take(len);
+      iter2.take(len);
+    } else if (type1 === 'insert' && type2 === 'delete') {
+      // Insert then delete cancel out
+      iter1.take(len);
+      iter2.take(len);
+    }
+  }
+
+  return normalize(result);
+}
+
+/** Create an insert operation at a position within a document of given length. */
+export function createInsert(docLength: number, position: number, text: string): OTOperation {
+  const op: OTOperation = [];
+  if (position > 0) op.push(position);
+  op.push(text);
+  if (position < docLength) op.push(docLength - position);
+  return normalize(op);
+}
+
+/** Create a delete operation at a position within a document. */
+export function createDelete(docLength: number, position: number, count: number): OTOperation {
+  const op: OTOperation = [];
+  if (position > 0) op.push(position);
+  op.push(-count);
+  const remaining = docLength - position - count;
+  if (remaining > 0) op.push(remaining);
+  return normalize(op);
+}
+
+/** Validate that an operation is well-formed for a document of the given length. */
+export function validate(op: OTOperation, docLength: number): string | null {
+  if (!Array.isArray(op)) return 'Operation must be an array';
+
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (!Number.isInteger(c)) return 'Numeric components must be integers';
+      if (c === 0) return 'Numeric components must not be zero';
+    } else if (typeof c === 'string') {
+      if (c.length === 0) return 'String components must not be empty';
+    } else {
+      return 'Components must be numbers or strings';
+    }
+  }
+
+  const inLen = inputLength(op);
+  if (inLen !== docLength) {
+    return `Operation input length (${inLen}) does not match document length (${docLength})`;
+  }
+
+  return null;
+}
