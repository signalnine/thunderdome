+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013FvGLboxFKJgwzfvCzMURo","type":"tool_result","content":"     1→import Database from 'better-sqlite3';\n     2→import { randomUUID } from 'crypto';\n     3→import * as fs from 'fs';\n     4→import * as path from 'path';\n     5→import { fileURLToPath } from 'url';\n     6→\n     7→const __filename = fileURLToPath(import.meta.url);\n     8→const __dirname = path.dirname(__filename);\n     9→\n    10→export interface Document {\n    11→  id: string;\n    12→  title: string;\n    13→  content: string;\n    14→  created_at: string;\n    15→  updated_at: string;\n    16→}\n    17→\n    18→export interface Version {\n    19→  id: number;\n    20→  document_id: string;\n    21→  version: number;\n    22→  content: string;\n    23→  operation: string | null;\n    24→  created_at: string;\n    25→}\n    26→\n    27→export class DocumentDB {\n    28→  private db: Database.Database;\n    29→\n    30→  constructor(dbPath?: string) {\n    31→    this.db = new Database(dbPath || ':memory:');\n    32→    this.db.pragma('journal_mode = WAL');\n    33→    this.db.pragma('foreign_keys = ON');\n    34→    this.initSchema();\n    35→  }\n    36→\n    37→  private initSchema(): void {\n    38→    const schemaPath = path.join(__dirname, '..', 'schema.sql');\n    39→    let schema: string;\n    40→    if (fs.existsSync(schemaPath)) {\n    41→      schema = fs.readFileSync(schemaPath, 'utf-8');\n    42→    } else {\n    43→      schema = `\n    44→        CREATE TABLE IF NOT EXISTS documents (\n    45→          id TEXT PRIMARY KEY,\n    46→          title TEXT NOT NULL,\n    47→          content TEXT NOT NULL DEFAULT '',\n    48→          created_at TEXT NOT NULL DEFAULT (datetime('now')),\n    49→          updated_at TEXT NOT NULL DEFAULT (datetime('now'))\n    50→        );\n    51→        CREATE TABLE IF NOT EXISTS versions (\n    52→          id INTEGER PRIMARY KEY AUTOINCREMENT,\n    53→          document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,\n    54→          version INTEGER NOT NULL,\n    55→          content TEXT NOT NULL,\n    56→          operation TEXT,\n    57→          created_at TEXT NOT NULL DEFAULT (datetime('now')),\n    58→          UNIQUE(document_id, version)\n    59→        );\n    60→        CREATE TABLE IF NOT EXISTS active_connections (\n    61→          id TEXT PRIMARY KEY,\n    62→          document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,\n    63→          connected_at TEXT NOT NULL DEFAULT (datetime('now'))\n    64→        );\n    65→      `;\n    66→    }\n    67→    this.db.exec(schema);\n    68→  }\n    69→\n    70→  createDocument(title: string, content: string = ''): Document {\n    71→    const id = randomUUID();\n    72→    const stmt = this.db.prepare(\n    73→      'INSERT INTO documents (id, title, content) VALUES (?, ?, ?)'\n    74→    );\n    75→    stmt.run(id, title, content);\n    76→\n    77→    // Create initial version\n    78→    this.db.prepare(\n    79→      'INSERT INTO versions (document_id, version, content, operation) VALUES (?, 1, ?, NULL)'\n    80→    ).run(id, content);\n    81→\n    82→    return this.getDocument(id)!;\n    83→  }\n    84→\n    85→  getDocument(id: string): Document | undefined {\n    86→    return this.db.prepare('SELECT * FROM documents WHERE id = ?').get(id) as Document | undefined;\n    87→  }\n    88→\n    89→  listDocuments(): Document[] {\n    90→    return this.db.prepare('SELECT * FROM documents ORDER BY updated_at DESC').all() as Document[];\n    91→  }\n    92→\n    93→  updateDocument(id: string, updates: { title?: string; content?: string }): Document | undefined {\n    94→    const doc = this.getDocument(id);\n    95→    if (!doc) return undefined;\n    96→\n    97→    const title = updates.title ?? doc.title;\n    98→    const content = updates.content ?? doc.content;\n    99→\n   100→    this.db.prepare(\n   101→      \"UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?\"\n   102→    ).run(title, content, id);\n   103→\n   104→    return this.getDocument(id);\n   105→  }\n   106→\n   107→  deleteDocument(id: string): boolean {\n   108→    const result = this.db.prepare('DELETE FROM documents WHERE id = ?').run(id);\n   109→    return result.changes > 0;\n   110→  }\n   111→\n   112→  updateDocumentContent(id: string, content: string, operation?: object): void {\n   113→    const currentVersion = this.getLatestVersion(id);\n   114→    const nextVersion = currentVersion ? currentVersion.version + 1 : 1;\n   115→\n   116→    const txn = this.db.transaction(() => {\n   117→      this.db.prepare(\n   118→        \"UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?\"\n   119→      ).run(content, id);\n   120→\n   121→      this.db.prepare(\n   122→        'INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)'\n   123→      ).run(id, nextVersion, content, operation ? JSON.stringify(operation) : null);\n   124→    });\n   125→\n   126→    txn();\n   127→  }\n   128→\n   129→  getVersionHistory(docId: string): Version[] {\n   130→    return this.db.prepare(\n   131→      'SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC'\n   132→    ).all(docId) as Version[];\n   133→  }\n   134→\n   135→  getLatestVersion(docId: string): Version | undefined {\n   136→    return this.db.prepare(\n   137→      'SELECT * FROM versions WHERE document_id = ? ORDER BY version DESC LIMIT 1'\n   138→    ).get(docId) as Version | undefined;\n   139→  }\n   140→\n   141→  getVersion(docId: string, version: number): Version | undefined {\n   142→    return this.db.prepare(\n   143→      'SELECT * FROM versions WHERE document_id = ? AND version = ?'\n   144→    ).get(docId, version) as Version | undefined;\n   145→  }\n   146→\n   147→  close(): void {\n   148→    this.db.close();\n   149→  }\n   150→}\n   151→"}]},"parent_tool_use_id":