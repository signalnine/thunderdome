+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01J7bQfjyNDnkrsS65JGfiXf","type":"tool_result","content":"     1→/**\n     2→ * Operational Transformation (OT) engine for collaborative text editing.\n     3→ *\n     4→ * Operations are arrays of components:\n     5→ * - number > 0: retain N characters\n     6→ * - string: insert the string\n     7→ * - number < 0: delete |N| characters\n     8→ *\n     9→ * The sum of \"input lengths\" (retain + |delete|) must equal the document length.\n    10→ * The output length is: retain + insert length.\n    11→ */\n    12→\n    13→export type OTComponent = number | string;\n    14→export type OTOperation = OTComponent[];\n    15→\n    16→export interface OperationMessage {\n    17→  type: 'operation';\n    18→  operation: OTOperation;\n    19→  version: number;\n    20→  clientId: string;\n    21→}\n    22→\n    23→export interface SyncMessage {\n    24→  type: 'sync';\n    25→  content: string;\n    26→  version: number;\n    27→}\n    28→\n    29→export interface AckMessage {\n    30→  type: 'ack';\n    31→  version: number;\n    32→}\n    33→\n    34→export interface ErrorMessage {\n    35→  type: 'error';\n    36→  message: string;\n    37→}\n    38→\n    39→export type ServerMessage = SyncMessage | AckMessage | ErrorMessage | (OperationMessage & { type: 'operation' });\n    40→export type ClientMessage = OperationMessage;\n    41→\n    42→/** Calculate the input length of an operation (the length of document it expects). */\n    43→export function inputLength(op: OTOperation): number {\n    44→  let len = 0;\n    45→  for (const c of op) {\n    46→    if (typeof c === 'number') {\n    47→      if (c > 0) len += c;       // retain\n    48→      else len += Math.abs(c);   // delete\n    49→    }\n    50→    // inserts don't consume input\n    51→  }\n    52→  return len;\n    53→}\n    54→\n    55→/** Calculate the output length of an operation (the length of document it produces). */\n    56→export function outputLength(op: OTOperation): number {\n    57→  let len = 0;\n    58→  for (const c of op) {\n    59→    if (typeof c === 'number') {\n    60→      if (c > 0) len += c;       // retain\n    61→      // delete produces nothing\n    62→    } else {\n    63→      len += c.length;           // insert\n    64→    }\n    65→  }\n    66→  return len;\n    67→}\n    68→\n    69→/** Apply an operation to a document string. */\n    70→export function apply(doc: string, op: OTOperation): string {\n    71→  const inLen = inputLength(op);\n    72→  if (inLen !== doc.length) {\n    73→    throw new Error(`Operation input length (${inLen}) does not match document length (${doc.length})`);\n    74→  }\n    75→\n    76→  let result = '';\n    77→  let pos = 0;\n    78→\n    79→  for (const c of op) {\n    80→    if (typeof c === 'number') {\n    81→      if (c > 0) {\n    82→        // retain\n    83→        result += doc.slice(pos, pos + c);\n    84→        pos += c;\n    85→      } else {\n    86→        // delete\n    87→        pos += Math.abs(c);\n    88→      }\n    89→    } else {\n    90→      // insert\n    91→      result += c;\n    92→    }\n    93→  }\n    94→\n    95→  return result;\n    96→}\n    97→\n    98→/** Normalize an operation by merging adjacent same-type components. */\n    99→export function normalize(op: OTOperation): OTOperation {\n   100→  const result: OTOperation = [];\n   101→\n   102→  for (const c of op) {\n   103→    if (typeof c === 'number' && c === 0) continue;\n   104→    if (typeof c === 'string' && c === '') continue;\n   105→\n   106→    if (result.length === 0) {\n   107→      result.push(c);\n   108→      continue;\n   109→    }\n   110→\n   111→    const last = result[result.length - 1];\n   112→\n   113→    if (typeof c === 'number' && typeof last === 'number') {\n   114→      // Both are numbers - merge if same sign\n   115→      if ((c > 0 && last > 0) || (c < 0 && last < 0)) {\n   116→        result[result.length - 1] = last + c;\n   117→      } else {\n   118→        result.push(c);\n   119→      }\n   120→    } else if (typeof c === 'string' && typeof last === 'string') {\n   121→      result[result.length - 1] = last + c;\n   122→    } else {\n   123→      result.push(c);\n   124→    }\n   125→  }\n   126→\n   127→  return result;\n   128→}\n   129→\n   130→/**\n   131→ * Iterator over operation components, yielding one character-level unit at a time.\n   132→ */\n   133→class OpIterator {\n   134→  private ops: OTOperation;\n   135→  private index: number = 0;\n   136→  private offset: number = 0;\n   137→\n   138→  constructor(ops: OTOperation) {\n   139→    this.ops = ops;\n   140→  }\n   141→\n   142→  hasNext(): boolean {\n   143→    return this.index < this.ops.length;\n   144→  }\n   145→\n   146→  /** Peek at the type of the current component: 'retain', 'insert', or 'delete'. */\n   147→  peekType(): 'retain' | 'insert' | 'delete' {\n   148→    const c = this.ops[this.index];\n   149→    if (typeof c === 'string') return 'insert';\n   150→    if (c > 0) return 'retain';\n   151→    return 'delete';\n   152→  }\n   153→\n   154→  /** Take up to `n` units from the current component. */\n   155→  take(n: number): OTComponent {\n   156→    const c = this.ops[this.index];\n   157→\n   158→    if (typeof c === 'string') {\n   159→      // Insert\n   160→      const remaining = c.length - this.offset;\n   161→      const take = Math.min(n, remaining);\n   162→      const result = c.slice(this.offset, this.offset + take);\n   163→      this.offset += take;\n   164→      if (this.offset >= c.length) {\n   165→        this.index++;\n   166→        this.offset = 0;\n   167→      }\n   168→      return result;\n   169→    } else {\n   170→      // Retain or delete\n   171→      const abs = Math.abs(c);\n   172→      const remaining = abs - this.offset;\n   173→      const take = Math.min(n, remaining);\n   174→      this.offset += take;\n   175→      if (this.offset >= abs) {\n   176→        this.index++;\n   177→        this.offset = 0;\n   178→      }\n   179→      return c > 0 ? take : -take;\n   180→    }\n   181→  }\n   182→\n   183→  /** Get remaining length of current component. */\n   184→  peekLength(): number {\n   185→    if (!this.hasNext()) return Infinity;\n   186→    const c = this.ops[this.index];\n   187→    if (typeof c === 'string') return c.length - this.offset;\n   188→    return Math.abs(c) - this.offset;\n   189→  }\n   190→}\n   191→\n   192→/**\n   193→ * Transform two concurrent operations (op1, op2) against each other.\n   194→ * Returns [op1', op2'] such that:\n   195→ *   apply(apply(doc, op1), op2') === apply(apply(doc, op2), op1')\n   196→ *\n   197→ * op1 has priority (its inserts come first in case of tie).\n   198→ */\n   199→export function transform(op1: OTOperation, op2: OTOperation): [OTOperation, OTOperation] {\n   200→  const iter1 = new OpIterator(op1);\n   201→  const iter2 = new OpIterator(op2);\n   202→  const op1prime: OTOperation = [];\n   203→  const op2prime: OTOperation = [];\n   204→\n   205→  while (iter1.hasNext() || iter2.hasNext()) {\n   206→    // Inserts from op1 go first (op1 has priority)\n   207→    if (iter1.hasNext() && iter1.peekType() === 'insert') {\n   208→      const s = iter1.take(iter1.peekLength());\n   209→      op1prime.push(s);\n   210→      // op2' must retain over op1's insert\n   211→      op2prime.push(typeof s === 'string' ? s.length : 0);\n   212→      continue;\n   213→    }\n   214→\n   215→    // Then inserts from op2\n   216→    if (iter2.hasNext() && iter2.peekType() === 'insert') {\n   217→      const s = iter2.take(iter2.peekLength());\n   218→      op2prime.push(s);\n   219→      // op1' must retain over op2's insert\n   220→      op1prime.push(typeof s === 'string' ? s.length : 0);\n   221→      continue;\n   222→    }\n   223→\n   224→    // Both must have retain or delete\n   225→    if (!iter1.hasNext() && !iter2.hasNext()) break;\n   226→\n   227→    const len = Math.min(iter1.peekLength(), iter2.peekLength());\n   228→\n   229→    const type1 = iter1.hasNext() ? iter1.peekType() : 'retain';\n   230→    const type2 = iter2.hasNext() ? iter2.peekType() : 'retain';\n   231→\n   232→    if (type1 === 'retain' && type2 === 'retain') {\n   233→      op1prime.push(len);\n   234→      op2prime.push(len);\n   235→      iter1.take(len);\n   236→      iter2.take(len);\n   237→    } else if (type1 === 'delete' && type2 === 'delete') {\n   238→      // Both delete the same text - neither needs to do anything\n   239→      iter1.take(len);\n   240→      iter2.take(len);\n   241→    } else if (type1 === 'delete' && type2 === 'retain') {\n   242→      op1prime.push(-len);\n   243→      // op2' doesn't need to do anything for deleted text\n   244→      iter1.take(len);\n   245→      iter2.take(len);\n   246→    } else if (type1 === 'retain' && type2 === 'delete') {\n   247→      op2prime.push(-len);\n   248→      // op1' doesn't need to do anything for deleted text\n   249→      iter1.take(len);\n   250→      iter2.take(len);\n   251→    }\n   252→  }\n   253→\n   254→  return [normalize(op1prime), normalize(op2prime)];\n   255→}\n   256→\n   257→/**\n   258→ * Compose two sequential operations into one.\n   259→ * apply(apply(doc, op1), op2) === apply(doc, compose(op1, op2))\n   260→ */\n   261→export function compose(op1: OTOperation, op2: OTOperation): OTOperation {\n   262→  const iter1 = new OpIterator(op1);\n   263→  const iter2 = new OpIterator(op2);\n   264→  const result: OTOperation = [];\n   265→\n   266→  while (iter1.hasNext() || iter2.hasNext()) {\n   267→    // Delete from op1 passes through\n   268→    if (iter1.hasNext() && iter1.peekType() === 'delete') {\n   269→      result.push(iter1.take(iter1.peekLength()));\n   270→      continue;\n   271→    }\n   272→\n   273→    // Insert from op2 passes through\n   274→    if (iter2.hasNext() && iter2.peekType() === 'insert') {\n   275→      result.push(iter2.take(iter2.peekLength()));\n   276→      continue;\n   277→    }\n   278→\n   279→    if (!iter1.hasNext() && !iter2.hasNext()) break;\n   280→\n   281→    const len = Math.min(iter1.peekLength(), iter2.peekLength());\n   282→    const type1 = iter1.hasNext() ? iter1.peekType() : 'retain';\n   283→    const type2 = iter2.hasNext() ? iter2.peekType() : 'retain';\n   284→\n   285→    if (type1 === 'retain' && type2 === 'retain') {\n   286→      result.push(len);\n   287→      iter1.take(len);\n   288→      iter2.take(len);\n   289→    } else if (type1 === 'insert' && type2 === 'retain') {\n   290→      result.push(iter1.take(len));\n   291→      iter2.take(len);\n   292→    } else if (type1 === 'retain' && type2 === 'delete') {\n   293→      result.push(-len);\n   294→      iter1.take(len);\n   295→      iter2.take(len);\n   296→    } else if (type1 === 'insert' && type2 === 'delete') {\n   297→      // Insert then delete cancel out\n   298→      iter1.take(len);\n   299→      iter2.take(len);\n   300→    }\n   301→  }\n   302→\n   303→  return normalize(result);\n   304→}\n   305→\n   306→/** Create an insert operation at a position within a document of given length. */\n   307→export function createInsert(docLength: number, position: number, text: string): OTOperation {\n   308→  const op: OTOperation = [];\n   309→  if (position > 0) op.push(position);\n   310→  op.push(text);\n   311→  if (position < docLength) op.push(docLength - position);\n   312→  return normalize(op);\n   313→}\n   314→\n   315→/** Create a delete operation at a position within a document. */\n   316→export function createDelete(docLength: number, position: number, count: number): OTOperation {\n   317→  const op: OTOperation = [];\n   318→  if (position > 0) op.push(position);\n   319→  op.push(-count);\n   320→  const remaining = docLength - position - count;\n   321→  if (remaining > 0) op.push(remaining);\n   322→  return normalize(op);\n   323→}\n   324→\n   325→/** Validate that an operation is well-formed for a document of the given length. */\n   326→export function validate(op: OTOperation, docLength: number): string | null {\n   327→  if (!Array.isArray(op)) return 'Operation must be an array';\n   328→\n   329→  for (const c of op) {\n   330→    if (typeof c === 'number') {\n   331→      if (!Number.isInteger(c)) return 'Numeric components must be integers';\n   332→      if (c === 0) return 'Numeric components must not be zero';\n   333→    } else if (typeof c === 'string') {\n   334→      if (c.length === 0) return 'String components must not be empty';\n   335→    } else {\n   336→      return 'Components must be numbers or strings';\n   337→    }\n   338→  }\n   339→\n   340→  const inLen = inputLength(op);\n   341→  if (inLen !== docLength) {\n   342→    return `Operation input length (${inLen}) does not match document length (${docLength})`;\n   343→  }\n   344→\n   345→  return null;\n   346→}\n   347→"}]},"parent_tool_use_id":"toolu_011RGUoDznqUEBAg332afDRs","session_id":"2b228799-baf7-4472-bcd7-5cdb40ebfa65","uuid":"b620f890-d95c-4ffd-8b31-066c795153ed"}
