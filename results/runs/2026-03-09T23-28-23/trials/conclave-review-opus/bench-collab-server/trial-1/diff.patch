   ws.close();\n  });\n\n  it('should apply insert operation and receive ack', async () => {\n    const createRes = await request(server.app)\n      .post('/api/documents')\n      .send({ title: 'Test', content: 'hello' });\n\n    const { ws, sync } = await connectWs(createRes.body.id);\n\n    const op = createInsert(5, 5, ' world');\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: op,\n      version: sync.version,\n      clientId: 'client1',\n    }));\n\n    const ack = await waitForMessage(ws, 'ack');\n    expect(ack.type).toBe('ack');\n    expect(ack.version).toBe(sync.version + 1);\n\n    // Verify via REST\n    const docRes = await request(server.app)\n      .get(`/api/documents/${createRes.body.id}`)\n      .expect(200);\n    expect(docRes.body.content).toBe('hello world');\n\n    ws.close();\n  });\n\n  it('should broadcast operation to other clients', async () => {\n    const createRes = await request(server.app)\n      .post('/api/documents')\n      .send({ title: 'Test', content: 'hello' });\n\n    const { ws: ws1, sync: sync1 } = await connectWs(createRes.body.id);\n    const { ws: ws2 } = await connectWs(createRes.body.id);\n\n    const broadcastPromise = waitForMessage(ws2, 'operation');\n\n    const op = createInsert(5, 5, ' world');\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      operation: op,\n      version: sync1.version,\n      clientId: 'client1',\n    }));\n\n    const broadcast = await broadcastPromise;\n    expect(broadcast.type).toBe('operation');\n    expect(broadcast.operation).toBeDefined();\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should handle concurrent edits from two clients', async () => {\n    const createRes = await request(server.app)\n      .post('/api/documents')\n      .send({ title: 'Test', content: 'abc' });\n\n    const { ws: ws1, sync: sync1 } = await connectWs(createRes.body.id);\n    const { ws: ws2, sync: sync2 } = await connectWs(createRes.body.id);\n\n    // Client 1