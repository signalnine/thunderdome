{ ws: WebSocket; sync: { content: string; version: number } }[] = [];\n   429→\n   430→    // Connect all clients\n   431→    for (let i = 0; i < numClients; i++) {\n   432→      const client = await connectWs(docId);\n   433→      clients.push(client);\n   434→    }\n   435→\n   436→    // Each client sends an insert operation sequentially\n   437→    // (each based on the previous version to simplify)\n   438→    for (let i = 0; i < numClients; i++) {\n   439→      const client = clients[i];\n   440→      // Insert character at position i (document grows)\n   441→      const op: OTOperation = [];\n   442→      if (i > 0) op.push(i);\n   443→      op.push(String(i));\n   444→      // Remaining is the version sync content length\n   445→      // The client might not have seen all previous ops yet,\n   446→      // so we base it on version 0 (empty doc) and let the server OT handle it\n   447→      const baseOp = createInsert(0, 0, String(i));\n   448→\n   449→      const ackPromise = waitForMessage(client.ws, 'ack');\n   450→      client.ws.send(JSON.stringify({\n   451→        type: 'operation',\n   452→        operation: baseOp,\n   453→        version: client.sync.version,\n   454→        clientId: `client${i}`,\n   455→      }));\n   456→\n   457→      await ackPromise;\n   458→    }\n   459→\n   460→    // Wait a bit for everything to settle\n   461→    await new Promise(r => setTimeout(r, 100));\n   462→\n   463→    // Verify the document has all characters\n   464→    const docRes = await request(server.app)\n   465→      .get(`/api/documents/${docId}`)\n   466→      .expect(200);\n   467→\n   468→    const content = docRes.body.content;\n   469→    // All digits 0-9 should be present\n   470→    for (let i = 0; i < numClients; i++) {\n   471→      expect(content).toContain(String(i));\n   472→    }\n   473→    expect(content.length).toBe(numClients);\n   474→\n   475→    // Clean up\n   476→    for (const client of clients) {\n   477→      client.ws.close();