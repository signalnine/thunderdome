e: 'Test', content: 'Content' });\n   108→\n   109→    const res = await request(server.app)\n   110→      .put(`/api/documents/${createRes.body.id}`)\n   111→      .send({ title: 'Updated', content: 'New Content' })\n   112→      .expect(200);\n   113→\n   114→    expect(res.body.title).toBe('Updated');\n   115→    expect(res.body.content).toBe('New Content');\n   116→  });\n   117→\n   118→  it('should delete a document', async () => {\n   119→    const createRes = await request(server.app)\n   120→      .post('/api/documents')\n   121→      .send({ title: 'Test' });\n   122→\n   123→    await request(server.app)\n   124→      .delete(`/api/documents/${createRes.body.id}`)\n   125→      .expect(204);\n   126→\n   127→    await request(server.app)\n   128→      .get(`/api/documents/${createRes.body.id}`)\n   129→      .expect(404);\n   130→  });\n   131→\n   132→  it('should get version history', async () => {\n   133→    const createRes = await request(server.app)\n   134→      .post('/api/documents')\n   135→      .send({ title: 'Test', content: 'v1' });\n   136→\n   137→    const res = await request(server.app)\n   138→      .get(`/api/documents/${createRes.body.id}/versions`)\n   139→      .expect(200);\n   140→\n   141→    expect(res.body.length).toBe(1);\n   142→    expect(res.body[0].version).toBe(1);\n   143→    expect(res.body[0].content).toBe('v1');\n   144→  });\n   145→\n   146→  it('should get a specific version', async () => {\n   147→    const createRes = await request(server.app)\n   148→      .post('/api/documents')\n   149→      .send({ title: 'Test', content: 'v1' });\n   150→\n   151→    const res = await request(server.app)\n   152→      .get(`/api/documents/${createRes.body.id}/versions/1`)\n   153→      .expect(200);\n   154→\n   155→    expect(res.body.version).toBe(1);\n   156→    expect(res.body.content).toBe('v1');\n   157→  });\n   158→});\n   159→\n   160→describe('WebSocket Collaboration', () => {\n   161→  beforeEach(async () => {\n  