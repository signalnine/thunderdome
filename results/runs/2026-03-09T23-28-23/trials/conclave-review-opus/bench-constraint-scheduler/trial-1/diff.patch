tion: 60, prerequisites: ['e1'] },\n      ];\n      expect(() => schedule(events, [medRoom], defaultOptions)).toThrow();\n    });\n\n    it('throws on two-event cycle', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['e2'] },\n        { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },\n      ];\n      expect(() => schedule(events, [medRoom], defaultOptions)).toThrow();\n    });\n\n    it('throws on three-event cycle', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['e3'] },\n        { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },\n        { id: 'e3', name: 'Event 3', duration: 60, prerequisites: ['e2'] },\n      ];\n      expect(() => schedule(events, [medRoom], defaultOptions)).toThrow();\n    });\n\n    it('does not throw for valid DAG', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n        { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },\n        { id: 'e3', name: 'Event 3', duration: 60, prerequisites: ['e1'] },\n        { id: 'e4', name: 'Event 4', duration: 60, prerequisites: ['e2', 'e3'] },\n      ];\n      expect(() => schedule(events, [medRoom, largeRoom], defaultOptions)).not.toThrow();\n    });\n  });\n\n  describe('preferred room', () => {\n    it('honors preferred room when possible', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, preferredRoom: 'large' },\n      ];\n      const result = schedule(events, [smallRoom, medRoom, largeRoom], defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('large');\n    });\n\n    it('falls back when preferred room capacity is insufficient', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, attendees: 50, preferredRoom: 'small' },\n      ];\n      const result = schedule(events, [smallRoom, largeRoom], defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('large');\n    });\n\n    it('falls back when preferred room is full', () => {\n      // Fill up the small room\n      const events: Event[] = [];\n      // Fill with events so no more fit\n      for (let i = 0; i < 10; i++) {\n        events.push({ id: `fill${i}`, name: `Filler ${i}`, duration: 45 });\n      }\n      events.push({ id: 'target', name: 'Target', duration: 60, preferredRoom: 'small' });\n      const result = schedule(events, [smallRoom, medRoom], { ...defaultOptions, gap: 0 });\n      // Target should be scheduled (maybe in small or med depending on room availability)\n      const target = getAssignment(result, 'target');\n      expect(target).toBeDefined();\n    });\n  });\n\n  describe('unscheduled events', () => {\n    it('marks events unscheduled when no room has sufficient capacity', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Huge Event', duration: 60, attendees: 200 },\n      ];\n      const result = schedule(events, [smallRoom, medRoom, largeRoom], defaultOptions);\n      expect(result.unscheduled).toEqual(['e1']);\n    });\n\n    it('marks events unscheduled when time window is full', () => {\n      // 2 hour window, 15 min gap, 60 min events = 1 event per room\n      // With 1 room and 3 events, some won't fit\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n        { id: 'e2', name: 'Event 2', duration: 60 },\n        { id: 'e3', name: 'Event 3', duration: 60 },\n      ];\n      // 120 minutes window, each event is 60 + 15 gap = 75, so only 1 fits (60 for event, needs 75 for next one starting at 75, which would end at 135 > 120)\n      // Actually: first event 0-60, gap 60-75, second event starts at 75, ends at 135 > 120\n      // So only 1 event fits per room with gap\n      // Wait: 540 to 660 = 120 min. Event: 540-600, next at 615-675 > 660. Only 1.\n      const result = schedule(events, [medRoom], { startTime: 540, endTime: 660 });\n      expect(result.assignments).toHaveLength(1);\n      expect(result.unscheduled).toHaveLength(2);\n    });\n  });\n\n  describe('batch optimization', () => {\n    it('maximizes number of scheduled events', () => {\n      // One big event or two small events - should prefer scheduling more events\n      // Room fits 240 minutes. One 200-min event OR two 100-min events with gap = 215 total.\n      // With gap=15, two 100-min events take 100+15+100 = 215 min.\n      // With 240 min window, both fit.\n      const events: Event[] = [\n        { id: 'big', name: 'Big', duration: 200, attendees: 5 },\n        { id: 's1', name: 'Small 1', duration: 100, attendees: 5 },\n        { id: 's2', name: 'Small 2', duration: 100, attendees: 5 },\n      ];\n      // Only one room, 4-hour (240 min) window\n      // big takes 200 min, leaving 40 min — not enough for either small\n      // s1+s2 take 100+15+100 = 215 min — both fit\n      const result = schedule(events, [smallRoom], { startTime: 540, endTime: 780 });\n      // Should schedule 2 events (the two small ones) rather than 1 big one\n      expect(result.assignments.length).toBeGreaterThanOrEqual(2);\n    });\n\n    it('schedules events when ordering matters', () => {\n      // Test that the scheduler doesn't just do first-come first-served\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n        { id: 'e2', name: 'Event 2', duration: 60 },\n        { id: 'e3', name: 'Event 3', duration: 60 },\n        { id: 'e4', name: 'Event 4', duration: 60 },\n      ];\n      // Two rooms, 2.5 hour window: each room fits 60+15+60 = 135 min, so 2 per room = 4 total\n      const result = schedule(events, [medRoom, largeRoom], { startTime: 540, endTime: 675 });\n      expect(result.assignments).toHaveLength(4);\n      expect(result.unscheduled).toHaveLength(0);\n    });\n  });\n\n  describe('complex scenarios', () => {\n    it('handles a conference-like schedule', () => {\n      const rooms: Room[] = [\n        { id: 'main', name: 'Main Hall', capacity: 200 },\n        { id: 'a', name: 'Room A', capacity: 50 },\n        { id: 'b', name: 'Room B', capacity: 30 },\n      ];\n\n      const events: Event[] = [\n        { id: 'keynote', name: 'Keynote', duration: 90, attendees: 150, preferredRoom: 'main' },\n        { id: 'talk1', name: 'Talk 1', duration: 45, attendees: 40, prerequisites: ['keynote'] },\n        { id: 'talk2', name: 'Talk 2', duration: 45, attendees: 25, prerequisites: ['keynote'] },\n        { id: 'talk3', name: 'Talk 3', duration: 45, attendees: 20 },\n        { id: 'workshop', name: 'Workshop', duration: 120, attendees: 20, prerequisites: ['talk1'] },\n        { id: 'closing', name: 'Closing', duration: 30, attendees: 150, prerequisites: ['workshop', 'talk2'] },\n      ];\n\n      const result = schedule(events, rooms, { startTime: 540, endTime: 1020 });\n      expect(result.unscheduled).toHaveLength(0);\n\n      // Verify keynote is in main hall\n      const keynote = getAssignment(result, 'keynote')!;\n      expect(keynote.roomId).toBe('main');\n\n      // Verify prerequisite ordering\n      const talk1 = getAssignment(result, 'talk1')!;\n      const talk2 = getAssignment(result, 'talk2')!;\n      const workshop = getAssignment(result, 'workshop')!;\n      const closing = getAssignment(result, 'closing')!;\n\n      expect(talk1.startTime).toBeGreaterThanOrEqual(keynote.endTime + 15);\n      expect(talk2.startTime).toBeGreaterThanOrEqual(keynote.endTime + 15);\n      expect(workshop.startTime).toBeGreaterThanOrEqual(talk1.endTime + 15);\n      expect(closing.startTime).toBeGreaterThanOrEqual(workshop.endTime + 15);\n      expect(closing.startTime).toBeGreaterThanOrEqual(talk2.endTime + 15);\n    });\n\n    it('handles events with mixed capacity requirements', () => {\n      const rooms: Room[] = [\n        { id: 'tiny', name: 'Tiny', capacity: 2 },\n        { id: 'small', name: 'Small', capacity: 10 },\n        { id: 'big', name: 'Big', capacity: 50 },\n      ];\n\n      const events: Event[] = [\n        { id: 'e1', name: 'Solo', duration: 60, attendees: 1 },\n        { id: 'e2', name: 'Small Group', duration: 60, attendees: 8 },\n        { id: 'e3', name: 'Medium Group', duration: 60, attendees: 30 },\n        { id: 'e4', name: 'Too Big', duration: 60, attendees: 100 },\n      ];\n\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(3);\n      expect(result.unscheduled).toEqual(['e4']);\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
