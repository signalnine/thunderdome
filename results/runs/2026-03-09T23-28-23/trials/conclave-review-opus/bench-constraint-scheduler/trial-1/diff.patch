@@ -0,0 +1,413 @@
+import { describe, it, expect } from 'vitest';
+import { schedule, Event, Room, ScheduleOptions, ScheduleResult } from './index.js';
+
+const defaultOptions: ScheduleOptions = {
+  startTime: 540, // 9:00 AM
+  endTime: 1020,  // 5:00 PM
+};
+
+const smallRoom: Room = { id: 'small', name: 'Small Room', capacity: 5 };
+const medRoom: Room = { id: 'med', name: 'Medium Room', capacity: 20 };
+const largeRoom: Room = { id: 'large', name: 'Large Room', capacity: 100 };
+
+function getAssignment(result: ScheduleResult, eventId: string) {
+  return result.assignments.find(a => a.eventId === eventId);
+}
+
+describe('schedule', () => {
+  describe('basic scheduling', () => {
+    it('schedules a single event', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+      ];
+      const result = schedule(events, [medRoom], defaultOptions);
+      expect(result.assignments).toHaveLength(1);
+      expect(result.unscheduled).toHaveLength(0);
+      expect(result.assignments[0].eventId).toBe('e1');
+      expect(result.assignments[0].roomId).toBe('med');
+      expect(result.assignments[0].endTime - result.assignments[0].startTime).toBe(60);
+    });
+
+    it('handles empty events', () => {
+      const result = schedule([], [medRoom], defaultOptions);
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toHaveLength(0);
+    });
+
+    it('handles no rooms', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+      ];
+      const result = schedule(events, [], defaultOptions);
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toEqual(['e1']);
+    });
+
+    it('schedules multiple events in one room', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+        { id: 'e2', name: 'Event 2', duration: 60 },
+      ];
+      const result = schedule(events, [medRoom], defaultOptions);
+      expect(result.assignments).toHaveLength(2);
+      expect(result.unscheduled).toHaveLength(0);
+
+      const a1 = getAssignment(result, 'e1')!;
+      const a2 = getAssignment(result, 'e2')!;
+      // They should not overlap, and should have a gap
+      const [first, second] = a1.startTime < a2.startTime ? [a1, a2] : [a2, a1];
+      expect(second.startTime).toBeGreaterThanOrEqual(first.endTime + 15);
+    });
+
+    it('schedules events across multiple rooms', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+        { id: 'e2', name: 'Event 2', duration: 60 },
+      ];
+      const result = schedule(events, [smallRoom, medRoom], defaultOptions);
+      expect(result.assignments).toHaveLength(2);
+      expect(result.unscheduled).toHaveLength(0);
+    });
+  });
+
