+++ b/src/index.ts
@@ -0,0 +1,328 @@
+export interface Event {
+  id: string;
+  name: string;
+  duration: number;
+  attendees?: number;
+  prerequisites?: string[];
+  preferredRoom?: string;
+}
+
+export interface Room {
+  id: string;
+  name: string;
+  capacity: number;
+}
+
+export interface ScheduleOptions {
+  startTime: number;
+  endTime: number;
+  gap?: number;
+}
+
+export interface Assignment {
+  eventId: string;
+  roomId: string;
+  startTime: number;
+  endTime: number;
+}
+
+export interface ScheduleResult {
+  assignments: Assignment[];
+  unscheduled: string[];
+}
+
+function detectCycle(events: Event[]): void {
+  const eventMap = new Map<string, Event>();
+  for (const e of events) eventMap.set(e.id, e);
+
+  const WHITE = 0, GRAY = 1, BLACK = 2;
+  const color = new Map<string, number>();
+  for (const e of events) color.set(e.id, WHITE);
+
+  function dfs(id: string): void {
+    color.set(id, GRAY);
+    const event = eventMap.get(id);
+    if (event?.prerequisites) {
+      for (const pre of event.prerequisites) {
+        if (pre === id || color.get(pre) === GRAY) {
+          throw new Error('Prerequisite cycle detected');
+        }
+        if (color.get(pre) === WHITE) {
+          dfs(pre);
+        }
+      }
+    }
+    color.set(id, BLACK);
+  }
+
+  for (const e of events) {
+    if (color.get(e.id) === WHITE) dfs(e.id);
+  }
+}
+
+function topologicalSort(events: Event[]): string[] {
+  const ids = new Set(events.map(e => e.id));
+  const inDegree = new Map<string, number>();
+  const dependents = new Map<string, string[]>();
+
+  for (const e of events) {
+    inDegree.set(e.id, 0);
+    dependents.set(e.id, []);
+  }
+
+  for (const e of events) {
+    if (e.prerequisites) {
+      for (const pre of e.prerequisites) {
+        if (ids.has(pre)) {
+          inDegree.set(e.id, (inDegree.get(e.id) ?? 0) + 1);
+          dependents.get(pre)!.push(e.id);
+        }
+      }
+    }
+  }
+
+  const queue: string[] = [];
+  for (const [id, deg] of inDegree) {
+    if (deg === 0) queue.push(id);
+  }
+
+  const result: string[] = [];
+  while (queue.length > 0) {
+    const id = queue.shift()!;
+    result.push(id);
+    for (const dep of dependents.get(id) ?? []) {
+      const newDeg = (inDegree.get(dep) ?? 1) - 1;
+      inDegree.set(dep, newDeg);
+      if (newDeg === 0) queue.push(dep);
+    }
+  }
+
+  return result;
+}
+
+function getDepth(eventId: string, eventMap: Map<string, Event>, cache: Map<string, number>): number {
+  if (cache.has(eventId)) return cache.get(eventId)!;
+  const event = eventMap.get(eventId);
+  if (!event?.prerequisites?.length) {
+    cache.set(eventId, 0);
+    return 0;
+  }
+  let maxDepth = 0;
+  for (const pre of event.prerequisites) {
+    if (eventMap.has(pre)) {
+      maxDepth = Math.max(maxDepth, getDepth(pre, eventMap, cache) + 1);
+    }
+  }
+  cache.set(eventId, maxDepth);
+  return maxDepth;
+}
+
+function ensureTopoValid(ordering: string[], eventMap: Map<string, Event>): string[] {
+  const placed = new Set<string>();
+  const valid: string[] = [];
+  const remaining: string[] = [];
+
+  for (const id of ordering) {
+    const event = eventMap.get(id)!;
+    const ok = !event.prerequisites || event.prerequisites.every(p =>
+      !eventMap.has(p) || placed.has(p)
+    );
+    if (ok) {
+      valid.push(id);
+      placed.add(id);
+    } else {
+      remaining.push(id);
+    }
+  }
+
+  // Repeatedly try to place remaining events
+  let changed = true;
+  while (changed && remaining.length > 0) {
+    changed = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const id = remaining[i];
+      const event = eventMap.get(id)!;
+      const ok = !event.prerequisites || event.prerequisites.every(p =>
+        !eventMap.has(p) || placed.has(p)
+      );
+      if (ok) {
+        valid.push(id);
+        placed.add(id);
+        remaining.splice(i, 1);
+        changed = true;
+      }
+    }
+  }
+
+  // Any truly stuck go at the end
+  for (const id of remaining) valid.push(id);
+
+  return valid;
+}
+
+function greedySchedule(
+  ordering: string[],
+  eventMap: Map<string, Event>,
+  sortedRooms: Room[],
+  gap: number,
+  options: ScheduleOptions
+): ScheduleResult {
+  const roomSlots = new Map<string, Assignment[]>();
+  for (const room of sortedRooms) roomSlots.set(room.id, []);
+
+  const assignments: Assignment[] = [];
+  const assignmentMap = new Map<string, Assignment>();
+  const scheduled = new Set<string>();
+
+  function earliestStart(eventId: string): number {
+    const event = eventMap.get(eventId)!;
+    let earliest = options.startTime;
+    if (event.prerequisites) {
+      for (const preId of event.prerequisites) {
+        const preAssign = assignmentMap.get(preId);
+        if (!preAssign) return -1;
+        earliest = Math.max(earliest, preAssign.endTime + gap);
+      }
+    }
+    return earliest;
+  }
+
+  function findSlot(roomId: string, earliest: number, duration: number): number | null {
+    const slots = roomSlots.get(roomId)!;
+    let candidate = earliest;
+
+    for (const a of slots) {
+      if (candidate + duration + gap <= a.startTime) break;
+      candidate = Math.max(candidate, a.endTime + gap);
+    }
+
+    return candidate + duration <= options.endTime ? candidate : null;
+  }
+
+  function insertSlot(roomId: string, assignment: Assignment): void {
+    const slots = roomSlots.get(roomId)!;
+    let i = 0;
+    while (i < slots.length && slots[i].startTime < assignment.startTime) i++;
+    slots.splice(i, 0, assignment);
+  }
+
+  const validOrdering = ensureTopoValid(ordering, eventMap);
+
+  for (const eventId of validOrdering) {
+    const event = eventMap.get(eventId)!;
+    const attendees = event.attendees ?? 1;
+    const earliest = earliestStart(eventId);
+    if (earliest === -1) continue;
+
+    const eligibleRooms = sortedRooms.filter(r => r.capacity >= attendees);
+    if (eligibleRooms.length === 0) continue;
+
+    let placed = false;
+
+    if (event.preferredRoom) {
+      const prefRoom = eligibleRooms.find(r => r.id === event.preferredRoom);
+      if (prefRoom) {
+        const slot = findSlot(prefRoom.id, earliest, event.duration);
+        if (slot !== null) {
+          const a: Assignment = { eventId, roomId: prefRoom.id, startTime: slot, endTime: slot + event.duration };
+          insertSlot(prefRoom.id, a);
+          assignments.push(a);
+          assignmentMap.set(eventId, a);
+          scheduled.add(eventId);
+          placed = true;
+        }
+      }
+    }
+
+    if (!placed) {
+      let bestSlot: number | null = null;
+      let bestRoomId: string | null = null;
+
+      for (const room of eligibleRooms) {
+        const slot = findSlot(room.id, earliest, event.duration);
+        if (slot !== null && (bestSlot === null || slot < bestSlot)) {
+          bestSlot = slot;
+          bestRoomId = room.id;
+        }
+      }
+
+      if (bestRoomId !== null && bestSlot !== null) {
+        const a: Assignment = { eventId, roomId: bestRoomId, startTime: bestSlot, endTime: bestSlot + event.duration };
+        insertSlot(bestRoomId, a);
+        assignments.push(a);
+        assignmentMap.set(eventId, a);
+        scheduled.add(eventId);
+      }
+    }
+  }
+
+  const unscheduled = [...eventMap.keys()].filter(id => !scheduled.has(id));
+  return { assignments, unscheduled };
+}
+
+export function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {
+  if (events.length === 0) return { assignments: [], unscheduled: [] };
+  if (rooms.length === 0) return { assignments: [], unscheduled: events.map(e => e.id) };
+
+  detectCycle(events);
+
+  const gap = options.gap ?? 15;
+  const eventMap = new Map<string, Event>();
+  for (const e of events) eventMap.set(e.id, e);
+
+  const sortedRooms = [...rooms].sort((a, b) => a.capacity - b.capacity);
+  const topoOrder = topologicalSort(events);
+  const depthCache = new Map<string, number>();
+
+  // Generate multiple orderings that respect topological constraints
+  const orderings: string[][] = [topoOrder];
+
+  // Sort by depth first, then by secondary criteria
+  const makeSorted = (comparator: (a: string, b: string) => number): string[] => {
+    return [...topoOrder].sort((a, b) => {
+      const da = getDepth(a, eventMap, depthCache);
+      const db = getDepth(b, eventMap, depthCache);
+      if (da !== db) return da - db;
+      return comparator(a, b);
+    });
+  };
+
+  // Shortest duration first
+  orderings.push(makeSorted((a, b) =>
+    eventMap.get(a)!.duration - eventMap.get(b)!.duration
+  ));
+
+  // Longest duration first
+  orderings.push(makeSorted((a, b) =>
+    eventMap.get(b)!.duration - eventMap.get(a)!.duration
+  ));
+
+  // Most attendees first (most constrained)
+  orderings.push(makeSorted((a, b) =>
+    (eventMap.get(b)!.attendees ?? 1) - (eventMap.get(a)!.attendees ?? 1)
+  ));
+
+  // Fewest attendees first
+  orderings.push(makeSorted((a, b) =>
+    (eventMap.get(a)!.attendees ?? 1) - (eventMap.get(b)!.attendees ?? 1)
+  ));
+
+  // Most constrained: fewest eligible rooms first
+  orderings.push(makeSorted((a, b) => {
+    const eligA = sortedRooms.filter(r => r.capacity >= (eventMap.get(a)!.attendees ?? 1)).length;
+    const eligB = sortedRooms.filter(r => r.capacity >= (eventMap.get(b)!.attendees ?? 1)).length;
+    return eligA - eligB;
+  }));
+
+  let bestResult: ScheduleResult = { assignments: [], unscheduled: events.map(e => e.id) };
+
+  for (const ordering of orderings) {
+    const result = greedySchedule(ordering, eventMap, sortedRooms, gap, options);
+    if (result.assignments.length > bestResult.assignments.length) {
+      bestResult = result;
+      if (result.unscheduled.length === 0) break;
+    }
+  }
+
+  return bestResult;
+}
