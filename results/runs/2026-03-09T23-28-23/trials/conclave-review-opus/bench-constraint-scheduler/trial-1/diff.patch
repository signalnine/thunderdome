+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XCagaLeGtPPDrBvZHRoaVL","type":"tool_result","content":"     1→export interface Event {\n     2→  id: string;\n     3→  name: string;\n     4→  duration: number;\n     5→  attendees?: number;\n     6→  prerequisites?: string[];\n     7→  preferredRoom?: string;\n     8→}\n     9→\n    10→export interface Room {\n    11→  id: string;\n    12→  name: string;\n    13→  capacity: number;\n    14→}\n    15→\n    16→export interface ScheduleOptions {\n    17→  startTime: number;\n    18→  endTime: number;\n    19→  gap?: number;\n    20→}\n    21→\n    22→export interface Assignment {\n    23→  eventId: string;\n    24→  roomId: string;\n    25→  startTime: number;\n    26→  endTime: number;\n    27→}\n    28→\n    29→export interface ScheduleResult {\n    30→  assignments: Assignment[];\n    31→  unscheduled: string[];\n    32→}\n    33→\n    34→function detectCycle(events: Event[]): void {\n    35→  const eventMap = new Map<string, Event>();\n    36→  for (const e of events) eventMap.set(e.id, e);\n    37→\n    38→  const WHITE = 0, GRAY = 1, BLACK = 2;\n    39→  const color = new Map<string, number>();\n    40→  for (const e of events) color.set(e.id, WHITE);\n    41→\n    42→  function dfs(id: string): void {\n    43→    color.set(id, GRAY);\n    44→    const event = eventMap.get(id);\n    45→    if (event?.prerequisites) {\n    46→      for (const pre of event.prerequisites) {\n    47→        if (pre === id || color.get(pre) === GRAY) {\n    48→          throw new Error('Prerequisite cycle detected');\n    49→        }\n    50→        if (color.get(pre) === WHITE) {\n    51→          dfs(pre);\n    52→        }\n    53→      }\n    54→    }\n    55→    color.set(id, BLACK);\n    56→  }\n    57→\n    58→  for (const e of events) {\n    59→    if (color.get(e.id) === WHITE) dfs(e.id);\n    60→  }\n    61→}\n    62→\n    63→function topologicalSort(events: Event[]): string[] {\n    64→  const ids = new Set(events.map(e => e.id));\n    65→  const inDegree = new Map<string, number>();\n    66→  const dependents = new Map<string, string[]>();\n    67→\n    68→  for (const e of events) {\n    69→    inDegree.set(e.id, 0);\n    70→    dependents.set(e.id, []);\n    71→  }\n    72→\n    73→  for (const e of events) {\n    74→    if (e.prerequisites) {\n    75→      for (const pre of e.prerequisites) {\n    76→        if (ids.has(pre)) {\n    77→          inDegree.set(e.id, (inDegree.get(e.id) ?? 0) + 1);\n    78→          dependents.get(pre)!.push(e.id);\n    79→        }\n    80→      }\n    81→    }\n    82→  }\n    83→\n    84→  const queue: string[] = [];\n    85→  for (const [id, deg] of inDegree) {\n    86→    if (deg === 0) queue.push(id);\n    87→  }\n    88→\n    89→  const result: string[] = [];\n    90→  while (queue.length > 0) {\n    91→    const id = queue.shift()!;\n    92→    result.push(id);\n    93→    for (const dep of dependents.get(id) ?? []) {\n    94→      const newDeg = (inDegree.get(dep) ?? 1) - 1;\n    95→      inDegree.set(dep, newDeg);\n    96→      if (newDeg === 0) queue.push(dep);\n    97→    }\n    98→  }\n    99→\n   100→  return result;\n   101→}\n   102→\n   103→function getDepth(eventId: string, eventMap: Map<string, Event>, cache: Map<string, number>): number {\n   104→  if (cache.has(eventId)) return cache.get(eventId)!;\n   105→  const event = eventMap.get(eventId);\n   106→  if (!event?.prerequisites?.length) {\n   107→    cache.set(eventId, 0);\n   108→    return 0;\n   109→  }\n   110→  let maxDepth = 0;\n   111→  for (const pre of event.prerequisites) {\n   112→    if (eventMap.has(pre)) {\n   113→      maxDepth = Math.max(maxDepth, getDepth(pre, eventMap, cache) + 1);\n   114→    }\n   115→  }\n   116→  cache.set(eventId, maxDepth);\n   117→  return maxDepth;\n   118→}\n   119→\n   120→function ensureTopoValid(ordering: string[], eventMap: Map<string, Event>): string[] {\n   121→  const placed = new Set<string>();\n   122→  const valid: string[] = [];\n   123→  const remaining: string[] = [];\n   124→\n   125→  for (const id of ordering) {\n   126→    const event = eventMap.get(id)!;\n   127→    const ok = !event.prerequisites || event.prerequisites.every(p =>\n   128→      !eventMap.has(p) || placed.has(p)\n   129→    );\n   130→    if (ok) {\n   131→      valid.push(id);\n   132→      placed.add(id);\n   133→    } else {\n   134→      remaining.push(id);\n   135→    }\n   136→  }\n   137→\n   138→  // Repeatedly try to place remaining events\n   139→  let changed = true;\n   140→  while (changed && remaining.length > 0) {\n   141→    changed = false;\n   142→    for (let i = remaining.length - 1; i >= 0; i--) {\n   143→      const id = remaining[i];\n   144→      const event = eventMap.get(id)!;\n   145→      const ok = !event.prerequisites || event.prerequisites.every(p =>\n   146→        !eventMap.has(p) || placed.has(p)\n   147→      );\n   148→      if (ok) {\n   149→        valid.push(id);\n   150→        placed.add(id);\n   151→        remaining.splice(i, 1);\n   152→        changed = true;\n   153→      }\n   154→    }\n   155→  }\n   156→\n   157→  // Any truly stuck go at the end\n   158→  for (const id of remaining) valid.push(id);\n   159→\n   160→  return valid;\n   161→}\n   162→\n   163→function greedySchedule(\n   164→  ordering: string[],\n   165→  eventMap: Map<string, Event>,\n   166→  sortedRooms: Room[],\n   167→  gap: number,\n   168→  options: ScheduleOptions\n   169→): ScheduleResult {\n   170→  const roomSlots = new Map<string, Assignment[]>();\n   171→  for (const room of sortedRooms) roomSlots.set(room.id, []);\n   172→\n   173→  const assignments: Assignment[] = [];\n   174→  const scheduled = new Set<string>();\n   175→\n   176→  function earliestStart(eventId: string): number {\n   177→    const event = eventMap.get(eventId)!;\n   178→    let earliest = options.startTime;\n   179→    if (event.prerequisites) {\n   180→      for (const preId of event.prerequisites) {\n   181→        const preAssign = assignments.find(a => a.eventId === preId);\n   182→        if (!preAssign) return -1;\n   183→        earliest = Math.max(earliest, preAssign.endTime + gap);\n   184→      }\n   185→    }\n   186→    return earliest;\n   187→  }\n   188→\n   189→  function findSlot(roomId: string, earliest: number, duration: number): number | null {\n   190→    const slots = roomSlots.get(roomId)!;\n   191→    let candidate = earliest;\n   192→\n   193→    for (const a of slots) {\n   194→      if (candidate + duration <= a.startTime) break;\n   195→      candidate = Math.max(candidate, a.endTime + gap);\n   196→    }\n   197→\n   198→    return candidate + duration <= options.endTime ? candidate : null;\n   199→  }\n   200→\n   201→  function insertSlot(roomId: string, assignment: Assignment): void {\n   202→    const slots = roomSlots.get(roomId)!;\n   203→    let i = 0;\n   204→    while (i < slots.length && slots[i].startTime < assignment.startTime) i++;\n   205→    slots.splice(i, 0, assignment);\n   206→  }\n   207→\n   208→  const validOrdering = ensureTopoValid(ordering, eventMap);\n   209→\n   210→  for (const eventId of validOrdering) {\n   211→    const event = eventMap.get(eventId)!;\n   212→    const attendees = event.attendees ?? 1;\n   213→    const earliest = earliestStart(eventId);\n   214→    if (earliest === -1) continue;\n   215→\n   216→    const eligibleRooms = sortedRooms.filter(r => r.capacity >= attendees);\n   217→    if (eligibleRooms.length === 0) continue;\n   218→\n   219→    let placed = false;\n   220→\n   221→    if (event.preferredRoom) {\n   222→      const prefRoom = eligibleRooms.find(r => r.id === event.preferredRoom);\n   223→      if (prefRoom) {\n   224→        const slot = findSlot(prefRoom.id, earliest, event.duration);\n   225→        if (slot !== null) {\n   226→          const a: Assignment = { eventId, roomId: prefRoom.id, startTime: slot, endTime: slot + event.duration };\n   227→          insertSlot(prefRoom.id, a);\n   228→          assignments.push(a);\n   229→          scheduled.add(eventId);\n   230→          placed = true;\n   231→        }\n   232→      }\n   233→    }\n   234→\n   235→    if (!placed) {\n   236→      let bestSlot: number | null = null;\n   237→      let bestRoomId: string | null = null;\n   238→\n   239→      for (const room of eligibleRooms) {\n   240→        const slot = findSlot(room.id, earliest, event.duration);\n   241→        if (slot !== null && (bestSlot === null || slot < bestSlot)) {\n   242→          bestSlot = slot;\n   243→          bestRoomId = room.id;\n   244→        }\n   245→      }\n   246→\n   247→      if (bestRoomId !== null && bestSlot !== null) {\n   248→        const a: Assignment = { eventId, roomId: bestRoomId, startTime: bestSlot, endTime: bestSlot + event.duration };\n   249→        insertSlot(bestRoomId, a);\n   250→        assignments.push(a);\n   251→        scheduled.add(eventId);\n   252→      }\n   253→    }\n   254→  }\n   255→\n   256→  const unscheduled = [...eventMap.keys()].filter(id => !scheduled.has(id));\n   257→  return { assignments, unscheduled };\n   258→}\n   259→\n   260→export function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {\n   261→  if (events.length === 0) return { assignments: [], unscheduled: [] };\n   262→  if (rooms.length === 0) return { assignments: [], unscheduled: events.map(e => e.id) };\n   263→\n   264→  detectCycle(events);\n   265→\n   266→  const gap = options.gap ?? 15;\n   267→  const eventMap = new Map<string, Event>();\n   268→  for (const e of events) eventMap.set(e.id, e);\n   269→\n   270→  const sortedRooms = [...rooms].sort((a, b) => a.capacity - b.capacity);\n   271→  const topoOrder = topologicalSort(events);\n   272→  const depthCache = new Map<string, number>();\n   273→\n   274→  // Generate multiple orderings that respect topological constraints\n   275→  const orderings: string[][] = [topoOrder];\n   276→\n   277→  // Sort by depth first, then by secondary criteria\n   278→  const makeSorted = (comparator: (a: string, b: string) => number): string[] => {\n   279→    return [...topoOrder].sort((a, b) => {\n   280→      const da = getDepth(a, eventMap, depthCache);\n   281→      const db = getDepth(b, eventMap, depthCache);\n   282→      if (da !== db) return da - db;\n   283→      return comparator(a, b);\n   284→    });\n   285→  };\n   286→\n   287→  // Shortest duration first\n   288→  orderings.push(makeSorted((a, b) =>\n   289→    eventMap.get(a)!.duration - eventMap.get(b)!.duration\n   290→  ));\n   291→\n   292→  // Longest duration first\n   293→  orderings.push(makeSorted((a, b) =>\n   294→    eventMap.get(b)!.duration - eventMap.get(a)!.duration\n   295→  ));\n   296→\n   297→  // Most attendees first (most constrained)\n   298→  orderings.push(makeSorted((a, b) =>\n   299→    (eventMap.get(b)!.attendees ?? 1) - (eventMap.get(a)!.attendees ?? 1)\n   300→  ));\n   301→\n   302→  // Fewest attendees first\n   303→  orderings.push(makeSorted((a, b) =>\n   304→    (eventMap.get(a)!.attendees ?? 1) - (eventMap.get(b)!.attendees ?? 1)\n   305→  ));\n   306→\n   307→  // Most constrained: fewest eligible rooms first\n   308→  orderings.push(makeSorted((a, b) => {\n   309→    const eligA = sortedRooms.filter(r => r.capacity >= (eventMap.get(a)!.attendees ?? 1)).length;\n   310→    const eligB = sortedRooms.filter(r => r.capacity >= (eventMap.get(b)!.attendees ?? 1)).length;\n   311→    return eligA - eligB;\n   312→  }));\n   313→\n   314→  let bestResult: ScheduleResult = { assignments: [], unscheduled: events.map(e => e.id) };\n   315→\n   316→  for (const ordering of orderings) {\n   317→    const result = greedySchedule(ordering, eventMap, sortedRooms, gap, options);\n   318→    if (result.assignments.length > bestResult.assignments.length) {\n   319→      bestResult = result;\n   320→      if (result.unscheduled.length === 0) break;\n   321→    }\n   322→  }\n   323→\n   324→  return bestResult;\n   325→}\n   326→"}]},"parent_tool_use_id":"toolu_01STnFFzuhCYH8D416rZoiV3","session_id":"93a648c7-50d2-4ad9-a07e-73c9a4dc8bb0","uuid":"5c1123da-2c48-4733-9320-53d3ef37216f"}
