{"filePath":"/workspace/src/index.ts","content":"export interface Event {\n  id: string;\n  name: string;\n  duration: number;\n  attendees?: number;\n  prerequisites?: string[];\n  preferredRoom?: string;\n}\n\nexport interface Room {\n  id: string;\n  name: string;\n  capacity: number;\n}\n\nexport interface ScheduleOptions {\n  startTime: number;\n  endTime: number;\n  gap?: number;\n}\n\nexport interface Assignment {\n  eventId: string;\n  roomId: string;\n  startTime: number;\n  endTime: number;\n}\n\nexport interface ScheduleResult {\n  assignments: Assignment[];\n  unscheduled: string[];\n}\n\nfunction detectCycle(events: Event[]): void {\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  const WHITE = 0, GRAY = 1, BLACK = 2;\n  const color = new Map<string, number>();\n  for (const e of events) {\n    color.set(e.id, WHITE);\n  }\n\n  function dfs(id: string): void {\n    color.set(id, GRAY);\n    const event = eventMap.get(id);\n    if (event?.prerequisites) {\n      for (const pre of event.prerequisites) {\n        const c = color.get(pre);\n        if (c === GRAY) {\n          throw new Error(`Prerequisite cycle detected involving event \"${pre}\"`);\n        }\n        if (c === WHITE) {\n          dfs(pre);\n        }\n      }\n    }\n    color.set(id, BLACK);\n  }\n\n  for (const e of events) {\n    if (color.get(e.id) === WHITE) {\n      dfs(e.id);\n    }\n  }\n}\n\nfunction topologicalSort(events: Event[]): string[] {\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  const inDegree = new Map<string, number>();\n  for (const e of events) {\n    inDegree.set(e.id, 0);\n  }\n  for (const e of events) {\n    if (e.prerequisites) {\n      for (const pre of e.prerequisites) {\n        if (eventMap.has(pre)) {\n          inDegree.set(e.id, (inDegree.get(e.id) ?? 0) + 1);\n        }\n      }\n    }\n  }\n\n  const queue: string[] = [];\n  for (const [id, deg] of inDegree) {\n    if (deg === 0) queue.push(id);\n  }\n\n  const result: string[] = [];\n  while (queue.length > 0) {\n    const id = queue.shift()!;\n    result.push(id);\n    for (const e of events) {\n      if (e.prerequisites?.includes(id)) {\n        const newDeg = (inDegree.get(e.id) ?? 1) - 1;\n        inDegree.set(e.id, newDeg);\n        if (newDeg === 0) {\n          queue.push(e.id);\n        }\n      }\n    }\n  }\n\n  return result;\n}\n\nexport function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {\n  const gap = options.gap ?? 15;\n\n  // Check for self-references first (they are cycles)\n  for (const e of events) {\n    if (e.prerequisites?.includes(e.id)) {\n      throw new Error(`Prerequisite cycle detected involving event \"${e.id}\"`);\n    }\n  }\n\n  detectCycle(events);\n\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  // Sort rooms by capacity ascending for better packing\n  const sortedRooms = [...rooms].sort((a, b) => a.capacity - b.capacity);\n\n  // Get topological order\n  const topoOrder = topologicalSort(events);\n\n  // Use backtracking to maximize the number of scheduled events\n  // State: for each room, list of assigned events with times\n  interface RoomState {\n    assignments: Assignment[];\n  }\n\n  const bestResult = backtrackSchedule(events, eventMap, sortedRooms, topoOrder, gap, options);\n  return bestResult;\n}\n\nfunction backtrackSchedule(\n  events: Event[],\n  eventMap: Map<string, Event>,\n  sortedRooms: Room[],\n  topoOrder: string[],\n  gap: number,\n  options: ScheduleOptions\n): ScheduleResult {\n  // For each room, track occupied intervals\n  const roomSchedules = new Map<string, Assignment[]>();\n  for (const room of sortedRooms) {\n    roomSchedules.set(room.id, []);\n  }\n\n  const assignments: Assignment[] = [];\n  const scheduled = new Set<string>();\n\n  // Compute the earliest p