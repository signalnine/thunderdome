econd] = a1.startTime < a2.startTime ? [a1, a2] : [a2, a1];\n   166→      expect(second.startTime).toBeGreaterThanOrEqual(first.endTime);\n   167→    });\n   168→  });\n   169→\n   170→  describe('prerequisites', () => {\n   171→    it('schedules prerequisite before dependent event', () => {\n   172→      const events: Event[] = [\n   173→        { id: 'e1', name: 'Intro', duration: 60 },\n   174→        { id: 'e2', name: 'Advanced', duration: 60, prerequisites: ['e1'] },\n   175→      ];\n   176→      const result = schedule(events, [medRoom], defaultOptions);\n   177→      expect(result.assignments).toHaveLength(2);\n   178→      const a1 = getAssignment(result, 'e1')!;\n   179→      const a2 = getAssignment(result, 'e2')!;\n   180→      expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + 15);\n   181→    });\n   182→\n   183→    it('handles chain of prerequisites', () => {\n   184→      const events: Event[] = [\n   185→        { id: 'e1', name: 'Part 1', duration: 60 },\n   186→        { id: 'e2', name: 'Part 2', duration: 60, prerequisites: ['e1'] },\n   187→        { id: 'e3', name: 'Part 3', duration: 60, prerequisites: ['e2'] },\n   188→      ];\n   189→      const result = schedule(events, [medRoom], defaultOptions);\n   190→      expect(result.assignments).toHaveLength(3);\n   191→      const a1 = getAssignment(result, 'e1')!;\n   192→      const a2 = getAssignment(result, 'e2')!;\n   193→      const a3 = getAssignment(result, 'e3')!;\n   194→      expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + 15);\n   195→      expect(a3.startTime).toBeGreaterThanOrEqual(a2.endTime + 15);\n   196→    });\n   197→\n   198→    it('handles multiple prerequisites', () => {\n   199→      const events: Event[] = [\n   200→        { id: 'e1', name: 'Prereq 1', duration: 60 },\n   201→        { id: 'e2', name: 'Prereq 2', duration: 60 },\n   202→        { id: 'e3', name: 'Main', duration: 60, prerequisites: ['e1', 'e2'] },\n   203→      ];\n   204→      const result = schedule(events, [medRoom, largeRoom], defaultOptions);\n   205→      expect(result.assignments).toHaveLength(3);\n   206→      const a1 = getAssignment(result, 'e1')!;\n   207→      const a2 = getAssignment(result, 'e2')!;\n   208→      const a3 = getAssignment(result, 'e3')!;\n   209→      expect(a3.startTime).toBeGreaterThanOrEqual(a1.endTime + 15);\n   210→      expect(a3.startTime).toBeGreaterThanOrEqual(a2.endTime + 15);\n   211→    });\n   212→\n   213→    it('applies gap between prerequisite and dependent', () => {\n   214→      const events: Event[] = [\n   215→        { id: 'e1', name: 'Intro', duration: 60 },\n   216→        { id: 'e2', name: 'Advanced', duration: 60, prerequisites: ['e1'] },\n   217→      ];\n   218→      const result = schedule(events, [medRoom, largeRoom], { ...defaultOptions, gap: 30 });\n   219→      expect(result.assignments).toHaveLength(2);\n   220→      const a1 = getAssignment(result, 'e1')!;\n   221→      const a2 = getAssignment(result, 'e2')!;\n   222→      expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + 30);\n   223→    });\n   224→  });\n   225→\n   226→  describe('cycle detection', () => {\n   227→    it('throws on self-referencing prerequisite', () => {\n   228→      const events: Event[] = [\n   229→        { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['e1'] },\n   230→      ];\n   231→      expect(() => schedule(events, [medRoom], defaultOptions)).toThrow();\n   232→    });\n   233→\n   234→    it('throws on two-event cycle', () => {\n   235→      const events: Event[] = [\n   236→        { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['e2'] },\n   237→        { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },\n   238→      ];\n   239→      expect(() => schedule(events, [medRoom], defaultOptions)).toThrow();\n   240→    });\n   241→\n   242→    it('throws on three-event cycle', () => {\n   243→      const events: Event[] = [\n   244→        { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['e3'] },\n   245→        { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },\n   246→        { id: 'e3', name: 'Event 3', duration: 60, prerequisites: ['e2'] },\n   247→      ];\n   248→      expect(() => schedule(events, [medRoom], defaultOptions)).toThrow();\n   249→    });\n   250→\n   251→    it('does not throw for valid DAG', () => {\n   252→      const events: Event[] = [\n   253→        { id: 'e1', name: 'Event 1', duration: 60 },\n   254→        { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },\n   255→        { id: 'e3', name: 'Event 3', duration: 60, prerequisites: ['e1'] },\n   256→        { id: 'e4', name: 'Event 4', duration: 60, prerequisites: ['e2', 'e3'] },\n   257→      ];\n   258→      expect(() => schedule(events, [medRoom, largeRoom], defaultOptions)).not.toThrow();\n   259→    });\n   260→  });\n   261→\n   262→  describe('preferred room', () => {\n   263→    it('honors preferred room when possible', () => {\n   264→      const events: Event[] = [\n   265→        { id: 'e1', name: 'Event 1', duration: 60, preferredRoom: 'large' },\n   266→      ];\n   267→      const result = schedule(events, [smallRoom, medRoom, largeRoom], defaultOptions);\n   268→      expect(result.assignments).toHaveLength(1);\n   269→      expect(result.assignments[0].roomId).toBe('large');\n   270→    });\n   271→\n   272→    it('falls back when preferred room capacity is insufficient', () => {\n   273→      const events: Event[] = [\n   274→        { id: 'e1', name: 'Event 1', duration: 60, attendees: 50, preferredRoom: 'small' },\n   275→      ];\n   276→      const result = schedule(events, [smallRoom, largeRoom], defaultOptions);\n   277→      expect(result.assignments).toHaveLength(1);\n   278→      expect(result.assignments[0].roomId).toBe('large');\n   279→    });\n   280→\n   281→    it('falls back when preferred room is full', () => {\n   282→      // Fill up the small room\n   283→      const events: Event[] = [];\n   284→      // Fill with events so no more fit\n   285→      for (let i = 0; i < 10; i++) {\n   286→        events.push({ id: `fill${i}`, name: `Filler ${i}`, duration: 45 });\n   287→      }\n   288→      events.push({ id: 'target', name: 'Target', duration: 60, preferredRoom: 'small' });\n   289→      const result = schedule(events, [smallRoom, medRoom], { ...defaultOptions, gap: 0 });\n   290→      // Target should be scheduled (maybe in small or med depending on room availability)\n   291→      const target = getAssignment(result, 'target');\n   292→      expect(target).toBeDefined();\n   293→    });\n   294→  });\n   295→\n   296→  describe('unscheduled events', () => {\n   297→    it('marks events unscheduled when no room has sufficient capacity', () => {\n   298→      const events: Event[] = [\n   299→        { id: 'e1', name: 'Huge Event', duration: 60, attendees: 200 },\n   300→      ];\n   301→      const result = schedule(events, [smallRoom, medRoom, largeRoom], defaultOptions);\n   302→      expect(result.unscheduled).toEqual(['e1']);\n   303→    });\n   304→\n   305→    it('marks events unscheduled when time window is full', () => {\n   306→      // 2 hour window, 15 min gap, 60 min events = 1 event per room\n   307→      // With 1 room and 3 events, some won't fit\n   308→      const events: Event[] = [\n   309→        { id: 'e1', name: 'Event 1', duration: 60 },\n   310→        { id: 'e2', name: 'Event 2', duration: 60 },\n   311→        { id: 'e3', name: 'Event 3', duration: 60 },\n   312→      ];\n   313→      // 120 minutes window, each event is 60 + 15 gap = 75, so only 1 fits (60 for event, needs 75 for next one starting at 75, which would end at 135 > 120)\n   314→      // Actually: first event 0-60, gap 60-75, second event starts at 75, ends at 135 > 120\n   315→      // So only 1 event fits per room with gap\n   316→      // Wait: 540 to 660 = 120 min. Event: 540-600, next at 615-675 > 660. Only 1.\n   317→      const result = schedule(events, [medRoom], { startTime: 540, endTime: 660 });\n   318→      expect(result.assignments).toHaveLength(1);\n   319→      expect(result.unscheduled).toHaveLength(2);\n   320→    });\n   321→  });\n   322→\n   323→  describe('batch optimization', () => {\n   324→    it('maximizes number of scheduled events', () => {\n   325→      // One big event or two small events - should prefer scheduling more events\n   326→      // Room fits 240 minutes. One 200-min event OR two 100-min events with gap = 215 total.\n   327→      // With gap=15, two 100-min events take 100+15+100 = 215 min.\n   328→      // With 240 min window, both fit.\n   329→      const events: Event[] = [\n   330→        { id: 'big', name: 'Big', duration: 200, attendees: 5 },\n   331→        { id: 's1', name: 'Small 1', duration: 100, attendees: 5 },\n   332→        { id: 's2', name: 'Small 2', duration: 100, attendees: 5 },\n   333→      ];\n   334→      // Only one room, 4-hour (240 min) window\n   335→      // big takes 200 min, leaving 40 min — not enough for either small\n   336→      // s1+s2 take 100+15+100 = 215 min — both fit\n   337→      const result = schedule(events, [smallRoom], { startTime: 540, endTime: 780 });\n   338→      // Should schedule 2 events (the two small ones) rather than 1 big one\n   339→      expect(result.assignments.length).toBeGreaterThanOrEqual(2);\n   340→    });\n   341→\n   342→    it('schedules events when ordering matters', () => {\n   343→      // Test that the scheduler doesn't just do first-come first-served\n   344→      const events: Event[] = [\n   345→        { id: 'e1', name: 'Event 1', duration: 60 },\n   346→        { id: 'e2', name: 'Event 2', duration: 60 },\n   347→        { id: 'e3', name: 'Event 3', duration: 60 },\n   348→        { id: 'e4', name: 'Event 4', duration: 60 },\n   349→      ];\n   350→      // Two rooms, 2.5 hour window: each room fits 60+15+60 = 135 min, so 2 per room = 4 total\n   351→      const result = schedule(events, [medRoom, largeRoom], { startTime: 540, endTime: 675 });\n   352→      expect(result.assignments).toHaveLength(4);\n   353→      expect(result.unscheduled).toHaveLength(0);\n   354→    });\n   355→  });\n   356→\n   357→  describe('complex scenarios', () => {\n   358→    it('handles a conference-like schedule', () => {\n   359→      const rooms: Room[] = [\n   360→        { id: 'main', name: 'Main Hall', capacity: 200 },\n   361→        { id: 'a', name: 'Room A', capacity: 50 },\n   362→        { id: 'b', name: 'Room B', capacity: 30 },\n   363→      ];\n   364→\n   365→      const events: Event[] = [\n   366→        { id: 'keynote', name: 'Keynote', duration: 90, attendees: 150, preferredRoom: 'main' },\n   367→        { id: 'talk1', name: 'Talk 1', duration: 45, attendees: 40, prerequisites: ['keynote'] },\n   368→        { id: 'talk2', name: 'Talk 2', duration: 45, attendees: 25, prerequisites: ['keynote'] },\n   369→        { id: 'talk3', name: 'Talk 3', duration: 45, attendees: 20 },\n   370→        { id: 'workshop', name: 'Workshop', duration: 120, attendees: 20, prerequisites: ['talk1'] },\n   371→        { id: 'closing', name: 'Closing', duration: 30, attendees: 150, prerequisites: ['workshop', 'talk2'] },\n   372→      ];\n   373→\n   374→      const result = schedule(events, rooms, { startTime: 540, endTime: 1020 });\n   375→      expect(result.unscheduled).toHaveLength(0);\n   376→\n   377→      // Verify keynote is in main hall\n   378→      const keynote = getAssignment(result, 'keynote')!;\n   379→      expect(keynote.roomId).toBe('main');\n   380→\n   381→      // Verify prerequisite ordering\n   382→      const talk1 = getAssignment(result, 'talk1')!;\n   383→      const talk2 = getAssignment(result, 'talk2')!;\n   384→      const workshop = getAssignment(result, 'workshop')!;\n   385→      const closing = getAssignment(result, 'closing')!;\n   386→\n   387→      expect(talk1.startTime).toBeGreaterThanOrEqual(keynote.endTime + 15);\n   388→      expect(talk2.startTime).toBeGreaterThanOrEqual(keynote.endTime + 15);\n   389→      expect(workshop.startTime).toBeGreaterThanOrEqual(talk1.endTime + 15);\n   390→      expect(closing.startTime).toBeGreaterThanOrEqual(workshop.endTime + 15);\n   391→      expect(closing.startTime).toBeGreaterThanOrEqual(talk2.endTime + 15);\n   392→    });\n   393→\n   394→    it('handles events with mixed capacity requirements', () => {\n   395→      const rooms: Room[] = [\n   396→        { id: 'tiny', name: 'Tiny', capacity: 2 },\n   397→        { id: 'small', name: 'Small', capacity: 10 },\n   398→        { id: 'big', name: 'Big', capacity: 50 },\n   399→      ];\n   400→\n   401→      const events: Event[] = [\n   402→        { id: 'e1', name: 'Solo', duration: 60, attendees: 1 },\n   403→        { id: 'e2', name: 'Small Group', duration: 60, attendees: 8 },\n   404→        { id: 'e3', name: 'Medium Group', duration: 60, attendees: 30 },\n   405→        { id: 'e4', name: 'Too Big', duration: 60, attendees: 100 },\n   406→      ];\n   407→\n   408→      const result = schedule(events, rooms, defaultOptions);\n   409→      expect(result.assignments).toHaveLength(3);\n   410→      expect(result.unscheduled).toEqual(['e4']);\n   411→    });\n   412→  });\n   413→});\n   414→"}]},"parent_tool_use_id":"toolu_01STnFFzuhCYH8D416rZoiV3","session_id":"93a648c7-50d2-4ad9-a07e-73c9a4dc8bb0","uuid":"1236e39a-a89f-4298-a2cc-4a2a57d23019"}
