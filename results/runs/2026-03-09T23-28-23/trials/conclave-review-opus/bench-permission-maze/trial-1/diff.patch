+import { Store, Role } from './types.js';
+
+const ROLE_HIERARCHY: Record<Role, number> = {
+  viewer: 1,
+  editor: 2,
+  owner: 3,
+};
+
+export function getEffectiveRole(
+  store: Store,
+  userId: string,
+  resourceType: 'folder' | 'document',
+  resourceId: string
+): Role | null {
+  let bestRole: Role | null = null;
+
+  // Check if user is the owner of the resource
+  if (resourceType === 'folder') {
+    const folder = store.folders.get(resourceId);
+    if (folder && folder.ownerId === userId) {
+      return 'owner';
+    }
+  } else {
+    const doc = store.documents.get(resourceId);
+    if (doc && doc.ownerId === userId) {
+      return 'owner';
+    }
+  }
+
+  // Check direct shares for this resource
+  for (const share of store.shares) {
+    if (
+      share.userId === userId &&
+      share.resourceType === resourceType &&
+      share.resourceId === resourceId
+    ) {
+      if (!bestRole || ROLE_HIERARCHY[share.role] > ROLE_HIERARCHY[bestRole]) {
+        bestRole = share.role;
+      }
+    }
+  }
+
+  // If the resource is a document, check folder-level shares
+  if (resourceType === 'document') {
+    const doc = store.documents.get(resourceId);
+    if (doc) {
+      const folderRole = getEffectiveFolderRole(store, userId, doc.folderId);
+      if (folderRole) {
+        if (!bestRole || ROLE_HIERARCHY[folderRole] > ROLE_HIERARCHY[bestRole]) {
+          bestRole = folderRole;
+        }
+      }
+    }
+  }
+
+  // If the resource is a folder, check parent folder shares (inherited)
+  if (resourceType === 'folder') {
+    const folder = store.folders.get(resourceId);
+    if (folder && folder.parentId) {
+      const parentRole = getEffectiveFolderRole(store, userId, folder.parentId);
+      if (parentRole) {
+        if (!bestRole || ROLE_HIERARCHY[parentRole] > ROLE_HIERARCHY[bestRole]) {
+          bestRole = parentRole;
+        }
+      }
+    }
+  }
+
+  return bestRole;
+}
+
+function getEffectiveFolderRole(
+  store: Store,
+  userId: string,
+  folderId: string
+): Role | null {
+  let bestRole: Role | null = null;
+
+  // Check if owner
+  const folder = store.folders.get(folderId);
+  if (folder && folder.ownerId === userId) {
+    return 'owner';
+  }
+
+  // Check direct shares on this folder
+  for (const share of store.shares) {
+    if (
+      share.userId === userId &&
+      share.resourceType === 'folder' &&
+      share.resourceId === folderId
+    ) {
+      if (!bestRole || ROLE_HIERARCHY[share.role] > ROLE_HIERARCHY[bestRole]) {
+        bestRole = share.role;
+      }
+    }
+  }
+
+  // Check parent folder shares (recursive)
+  if (folder && folder.parentId) {
+    const parentRole = getEffectiveFolderRole(store, userId, folder.parentId);
+    if (parentRole) {
+      if (!bestRole || ROLE_HIERARCHY[parentRole] > ROLE_HIERARCHY[bestRole]) {
+        bestRole = parentRole;
+      }
+    }
+  }
+
+  return bestRole;
+}
+
+export function hasPermission(
+  store: Store,
+  userId: string,
+  resourceType: 'folder' | 'document',
+  resourceId: string,
+  requiredRole: Role
+): boolean {
+  const effectiveRole = getEffectiveRole(store, userId, resourceType, resourceId);
+  if (!effectiveRole) return false;
+  return ROLE_HIERARCHY[effectiveRole] >= ROLE_HIERARCHY[requiredRole];
+}
diff --git a/src/routes/activity.ts b/src/routes/activity.ts
new file mode 100644
index 0000000..352e130
--- /dev/null
+++ b/src/routes/activity.ts
@@ -0,0 +1,30 @@
+import { Router } from 'express';
+import { Store } from '../types.js';
+import { AuthRequest, requireAuth } from '../middleware.js';
+
+export function createActivityRouter(store: Store): Router {
+  const router = Router();
+
+  // Get activity log
+  router.get('/activity', requireAuth, (req: AuthRequest, res) => {
+    // Return activity log, optionally filtered
+    const { resourceType, resourceId } = req.query;
+
+    let logs = [...store.activityLog];
+
+    if (resourceType && typeof resourceType === 'string') {
+      logs = logs.filter((l) => l.resourceType === resourceType);
+    }
+
+    if (resourceId && typeof resourceId === 'string') {
+      logs = logs.filter((l) => l.resourceId === resourceId);
+    }
+
+    // Return newest first
+    logs.sort((a, b) => new Date(b.timestamp).getTime() - new Date(a.timestamp).getTime());
+
+    res.json(logs);
+  });
+
+  return router;
+}
