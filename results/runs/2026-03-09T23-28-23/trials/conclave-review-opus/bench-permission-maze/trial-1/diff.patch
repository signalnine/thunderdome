ound' });\n      return;\n    }\n\n    // Cannot share with yourself\n    if (userId === currentUser.id) {\n      res.status(400).json({ error: 'Cannot share with yourself' });\n      return;\n    }\n\n    // To share, you need at least editor role, and to grant owner you must be owner\n    if (role === 'owner') {\n      if (!hasPermission(store, currentUser.id, resourceType, resourceId, 'owner')) {\n        res.status(403).json({ error: 'Only owners can grant owner role' });\n        return;\n      }\n    } else {\n      if (!hasPermission(store, currentUser.id, resourceType, resourceId, 'editor')) {\n        res.status(403).json({ error: 'Insufficient permissions to share' });\n        return;\n      }\n    }\n\n    // Check if there's already a share for this user/resource combo, update if so\n    const existingShare = store.shares.find(\n      (s) =>\n        s.userId === userId &&\n        s.resourceType === resourceType &&\n        s.resourceId === resourceId\n    );\n\n    const now = new Date().toISOString();\n\n    if (existingShare) {\n      existingShare.role = role;\n      existingShare.grantedBy = currentUser.id;\n      existingShare.createdAt = now;\n\n      store.activityLog.push({\n        id: generateId(store),\n        action: 'share_updated',\n        userId: currentUser.id,\n        resourceType,\n        resourceId,\n        details: `Shared with user ${userId} as ${role}`,\n        timestamp: now,\n      });\n\n      res.json(existingShare);\n    } else {\n      const share = {\n        id: generateId(store),\n        resourceType,\n        resourceId,\n        userId,\n        role,\n        grantedBy: currentUser.id,\n        createdAt: now,\n      };\n      store.shares.push(share);\n\n      store.activityLog.push({\n        id: generateId(store),\n        action: 'share_created',\n        userId: currentUser.id,\n        resourceType,\n        resourceId,\n        details: `Shared with user ${userId} as ${role}`,\n        timestamp: now,\n      });\n\n      res.status(201).json(share);\n    }\n  });\n\n  // Share via resource-specific route\n  router.post('/folders/:id/share', requireAuth, (req: AuthRequest, res) => {\n    const resourceId = req.params.id;\n    const { userId, role } = req.body;\n    const currentUser = req.user!;\n\n    if (!userId || !role) {\n      res.status(400).json({ error: 'userId and role are required' });\n      return;\n    }\n\n    if (!VALID_ROLES.includes(role)) {\n      res.status(400).json({ error: 'role must be \"viewer\", \"editor\", or \"owner\"' });\n      return;\n    }\n\n    if (!store.folders.has(resourceId)) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n\n    if (!store.users.has(userId)) {\n      res.status(404).json({ error: 'User not found' });\n      return;\n    }\n\n    if (userId === currentUser.id) {\n      res.status(400).json({ error: 'Cannot share with yourself' });\n      return;\n    }\n\n    if (role === 'owner') {\n      if (!hasPermission(store, currentUser.id, 'folder', resourceId, 'owner')) {\n        res.status(403).json({ error: 'Only owners can grant owner role' });\n        return;\n      }\n    } else {\n      if (!hasPermission(store, currentUser.id, 'folder', resourceId, 'editor')) {\n        res.status(403).json({ error: 'Insufficient permissions to share' });\n        return;\n      }\n    }\n\n    const existingShare = store.shares.find(\n      (s) =>\n        s.userId === userId &&\n        s.resourceType === 'folder' &&\n        s.resourceId === resourceId\n    );\n\n    const now = new Date().toISOString();\n\n    if (existingShare) {\n      existingShare.role = role;\n      existingShare.grantedBy = currentUser.id;\n      existingShare.createdAt = now;\n\n      store.activityLog.push({\n        id: generateId(store),\n        action: 'share_updated',\n        userId: currentUser.id,\n        resourceType: 'folder',\n        resourceId,\n        details: `Shared with user ${userId} as ${role