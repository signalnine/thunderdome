   } else {\n   159→      if (!hasPermission(store, currentUser.id, 'folder', resourceId, 'editor')) {\n   160→        res.status(403).json({ error: 'Insufficient permissions to share' });\n   161→        return;\n   162→      }\n   163→    }\n   164→\n   165→    const existingShare = store.shares.find(\n   166→      (s) =>\n   167→        s.userId === userId &&\n   168→        s.resourceType === 'folder' &&\n   169→        s.resourceId === resourceId\n   170→    );\n   171→\n   172→    const now = new Date().toISOString();\n   173→\n   174→    if (existingShare) {\n   175→      existingShare.role = role;\n   176→      existingShare.grantedBy = currentUser.id;\n   177→      existingShare.createdAt = now;\n   178→\n   179→      store.activityLog.push({\n   180→        id: generateId(store),\n   181→        action: 'share_updated',\n   182→        userId: currentUser.id,\n   183→        resourceType: 'folder',\n   184→        resourceId,\n   185→        details: `Shared with user ${userId} as ${role}`,\n   186→        timestamp: now,\n   187→      });\n   188→\n   189→      res.json(existingShare);\n   190→    } else {\n   191→      const share = {\n   192→        id: generateId(store),\n   193→        resourceType: 'folder' as const,\n   194→        resourceId,\n   195→        userId,\n   196→        role: role as Role,\n   197→        grantedBy: currentUser.id,\n   198→        createdAt: now,\n   199→      };\n   200→      store.shares.push(share);\n   201→\n   202→      store.activityLog.push({\n   203→        id: generateId(store),\n   204→        action: 'share_created',\n   205→        userId: currentUser.id,\n   206→        resourceType: 'folder',\n   207→        resourceId,\n   208→        details: `Shared with user ${userId} as ${role}`,\n   209→        timestamp: now,\n   210→      });\n   211→\n   212→      res.status(201).json(share);\n   213→    }\n   214→  });\n   215→\n   216→  // Share document via resource-specific route\n   217→  router.post('/docume