@@ -0,0 +1,62 @@
+import { Router } from 'express';
+import { Store } from '../types.js';
+import { generateId, generateToken } from '../store.js';
+import { AuthRequest } from '../middleware.js';
+
+export function createAuthRouter(store: Store): Router {
+  const router = Router();
+
+  // Register
+  router.post('/auth/register', (req: AuthRequest, res) => {
+    const { username, password } = req.body;
+
+    if (!username || !password) {
+      res.status(400).json({ error: 'Username and password are required' });
+      return;
+    }
+
+    if (typeof username !== 'string' || typeof password !== 'string') {
+      res.status(400).json({ error: 'Username and password must be strings' });
+      return;
+    }
+
+    // Check if username already exists
+    for (const user of store.users.values()) {
+      if (user.username === username) {
+        res.status(409).json({ error: 'Username already exists' });
+        return;
+      }
+    }
+
+    const id = generateId(store);
+    const token = generateToken();
+    const user = { id, username, password, token };
+    store.users.set(id, user);
+
+    res.status(201).json({ id, username, token });
+  });
+
+  // Login
+  router.post('/auth/login', (req: AuthRequest, res) => {
+    const { username, password } = req.body;
+
+    if (!username || !password) {
+      res.status(400).json({ error: 'Username and password are required' });
+      return;
+    }
+
+    for (const user of store.users.values()) {
+      if (user.username === username && user.password === password) {
+        // Generate a new token on login
+        const token = generateToken();
+        user.token = token;
+        res.json({ id: user.id, username: user.username, token });
+        return;
+      }
+    }
+
+    res.status(401).json({ error: 'Invalid credentials' });
+  });
+
+  return router;
+}
diff --git a/src/routes/documents.ts b/src/routes/documents.ts
new file mode 100644
index 0000000..246239b
--- /dev/null
+++ b/src/routes/documents.ts
@@ -0,0 +1,208 @@
+import { Router } from 'express';
+import { Store } from '../types.js';
+import { generateId } from '../store.js';
+import { AuthRequest, requireAuth } from '../middleware.js';
+import { hasPermission } from '../permissions.js';
+
+export function createDocumentRouter(store: Store): Router {
+  const router = Router();
+
+  // Create document
+  router.post('/documents', requireAuth, (req: AuthRequest, res) => {
+    const { title, content, folderId } = req.body;
+    const user = req.user!;
+
+    if (!title || typeof title !== 'string') {
+      res.status(400).json({ error: 'Document title is required' });
+      return;
+    }
+
+    if (content === undefined || content === null) {
+      res.status(400).json({ error: 'Document content is required' });
+      return;
+    }
+
+    if (!folderId) {
+      res.status(400).json({ error: 'Folder ID is required' });
+      return;
+    }
+
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    // User must have at least editor on the folder to create docs in it
+    if (!hasPermission(store, user.id, 'folder', folderId, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions on folder' });
+      return;
+    }
+
+    const id = generateId(store);
+    const now = new Date().toISOString();
+    const doc = {
+      id,
+      title,
+      content: String(content),
+      folderId,
+      ownerId: user.id,
+      createdAt: now,
+      updatedAt: now,
+    };
+    store.documents.set(id, doc);
+
+    // Activity log
+    store.activityLog.push({
+      id: generateId(store),
+      action: 'document_created',
+      userId: user.id,
+      resourceType: 'document',
+      resourceId: id,
+      timestamp: now,
+    });
+
+    res.status(201).json(doc);
+  });
+
+  // Create document under a folder (alternative route)
+  router.post('/folders/:folderId/documents', requireAuth, (req: AuthRequest, res) => {
+    const { title, content } = req.body;
+    const user = req.user!;
+    const folderId = req.params.folderId;
+
+    if (!title || typeof title !== 'string') {
+      res.status(400).json({ error: 'Document title is required' });
+      return;
+    }
+
+    if (content === undefined || content === null) {
+      res.status(400).json({ error: 'Document content is required' });
+      return;
+    }
+
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!hasPermission(store, user.id, 'folder', folderId, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions on folder' });
+      return;
+    }
+
+    const id = generateId(store);
+    const now = new Date().toISOString();
+    const doc = {
+      id,
+      title,
+      content: String(content),
+      folderId,
+      ownerId: user.id,
+      createdAt: now,
+      updatedAt: now,
+    };
+    store.documents.set(id, doc);
+
+    store.activityLog.push({
+      id: generateId(store),
+      action: 'document_created',
+      userId: user.id,
+      resourceType: 'document',
+      resourceId: id,
+      timestamp: now,
+    });
+
+    res.status(201).json(doc);
+  });
+
+  // Get document
+  router.get('/documents/:id', requireAuth, (req: AuthRequest, res) => {
+    const doc = store.documents.get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!hasPermission(store, req.user!.id, 'document', doc.id, 'viewer')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    res.json(doc);
+  });
+
+  // Update document
+  router.put('/documents/:id', requireAuth, (req: AuthRequest, res) => {
+    const doc = store.documents.get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!hasPermission(store, req.user!.id, 'document', doc.id, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const { title, content } = req.body;
+    if (title !== undefined) {
+      if (typeof title !== 'string' || !title) {
+        res.status(400).json({ error: 'Document title must be a non-empty string' });
+        return;
+      }
+      doc.title = title;
+    }
+    if (content !== undefined) {
+      doc.content = String(content);
+    }
+    doc.updatedAt = new Date().toISOString();
+
+    store.activityLog.push({
+      id: generateId(store),
+      action: 'document_updated',
+      userId: req.user!.id,
+      resourceType: 'document',
+      resourceId: doc.id,
+      timestamp: doc.updatedAt,
+    });
+
+    res.json(doc);
+  });
+
+  // Delete document
+  router.delete('/documents/:id', requireAuth, (req: AuthRequest, res) => {
+    const doc = store.documents.get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!hasPermission(store, req.user!.id, 'document', doc.id, 'owner')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const now = new Date().toISOString();
+    store.documents.delete(doc.id);
+
+    // Remove shares for this document
+    store.shares = store.shares.filter(
+      (s) => !(s.resourceType === 'document' && s.resourceId === doc.id)
+    );
+
+    store.activityLog.push({
+      id: generateId(store),
+      action: 'document_deleted',
+      userId: req.user!.id,
+      resourceType: 'document',
+      resourceId: doc.id,
+      timestamp: now,
+    });
+
+    res.status(204).send();
+  });
+
+  return router;
+}
