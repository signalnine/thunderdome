new file mode 100644
index 0000000..d831957
--- /dev/null
+++ b/src/routes/folders.ts
@@ -0,0 +1,187 @@
+import { Router } from 'express';
+import { Store } from '../types.js';
+import { generateId } from '../store.js';
+import { AuthRequest, requireAuth } from '../middleware.js';
+import { hasPermission } from '../permissions.js';
+
+export function createFolderRouter(store: Store): Router {
+  const router = Router();
+
+  // Create folder
+  router.post('/folders', requireAuth, (req: AuthRequest, res) => {
+    const { name, parentId } = req.body;
+    const user = req.user!;
+
+    if (!name || typeof name !== 'string') {
+      res.status(400).json({ error: 'Folder name is required' });
+      return;
+    }
+
+    // If parentId is given, verify parent exists and user has permission
+    if (parentId !== undefined && parentId !== null) {
+      const parent = store.folders.get(parentId);
+      if (!parent) {
+        res.status(404).json({ error: 'Parent folder not found' });
+        return;
+      }
+      if (!hasPermission(store, user.id, 'folder', parentId, 'editor')) {
+        res.status(403).json({ error: 'Insufficient permissions on parent folder' });
+        return;
+      }
+    }
+
+    const id = generateId(store);
+    const folder = {
+      id,
+      name,
+      parentId: parentId || null,
+      ownerId: user.id,
+      createdAt: new Date().toISOString(),
+    };
+    store.folders.set(id, folder);
+
+    res.status(201).json(folder);
+  });
+
+  // Get folder
+  router.get('/folders/:id', requireAuth, (req: AuthRequest, res) => {
+    const folder = store.folders.get(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!hasPermission(store, req.user!.id, 'folder', folder.id, 'viewer')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    // Get subfolders and documents
+    const subfolders = Array.from(store.folders.values()).filter(
+      (f) => f.parentId === folder.id
+    );
+    const documents = Array.from(store.documents.values()).filter(
+      (d) => d.folderId === folder.id
+    );
+
+    res.json({ ...folder, subfolders, documents });
+  });
+
+  // Update folder
+  router.put('/folders/:id', requireAuth, (req: AuthRequest, res) => {
+    const folder = store.folders.get(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!hasPermission(store, req.user!.id, 'folder', folder.id, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const { name, parentId } = req.body;
+
+    if (name !== undefined) {
+      if (typeof name !== 'string' || !name) {
+        res.status(400).json({ error: 'Folder name must be a non-empty string' });
+        return;
+      }
+      folder.name = name;
+    }
+
+    if (parentId !== undefined) {
+      if (parentId !== null) {
+        const parent = store.folders.get(parentId);
+        if (!parent) {
+          res.status(404).json({ error: 'Parent folder not found' });
+          return;
+        }
+        // Prevent circular reference (walk up ancestor chain)
+        if (wouldCreateCycle(store, folder.id, parentId)) {
+          res.status(400).json({ error: 'Cannot move folder: would create a circular reference' });
+          return;
+        }
+      }
+      folder.parentId = parentId;
+    }
+
+    res.json(folder);
+  });
+
+  // Delete folder
+  router.delete('/folders/:id', requireAuth, (req: AuthRequest, res) => {
+    const folder = store.folders.get(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!hasPermission(store, req.user!.id, 'folder', folder.id, 'owner')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    // Delete all documents in the folder and their shares
+    for (const [docId, doc] of store.documents.entries()) {
+      if (doc.folderId === folder.id) {
+        store.documents.delete(docId);
+        store.shares = store.shares.filter(
+          (s) => !(s.resourceType === 'document' && s.resourceId === docId)
+        );
+      }
+    }
+
+    // Delete subfolders recursively
+    deleteFolderRecursive(store, folder.id);
+
+    store.folders.delete(folder.id);
+
+    // Remove shares for this folder
+    store.shares = store.shares.filter(
+      (s) => !(s.resourceType === 'folder' && s.resourceId === folder.id)
+    );
+
+    res.status(204).send();
+  });
+
+  return router;
+}
+
+function wouldCreateCycle(store: Store, folderId: string, proposedParentId: string): boolean {
+  let current: string | null = proposedParentId;
+  while (current) {
+    if (current === folderId) return true;
+    const folder = store.folders.get(current);
+    current = folder ? folder.parentId : null;
+  }
+  return false;
+}
+
+function deleteFolderRecursive(store: Store, folderId: string) {
+  const subfolders = Array.from(store.folders.values()).filter(
+    (f) => f.parentId === folderId
+  );
+
+  for (const subfolder of subfolders) {
+    // Delete documents in subfolder and their shares
+    for (const [docId, doc] of store.documents.entries()) {
+      if (doc.folderId === subfolder.id) {
+        store.documents.delete(docId);
+        store.shares = store.shares.filter(
+          (s) => !(s.resourceType === 'document' && s.resourceId === docId)
+        );
+      }
+    }
+
+    // Recursively delete subfolders
+    deleteFolderRecursive(store, subfolder.id);
+
+    store.folders.delete(subfolder.id);
+
+    // Remove shares for this subfolder
+    store.shares = store.shares.filter(
+      (s) => !(s.resourceType === 'folder' && s.resourceId === subfolder.id)
+    );
+  }
+}
diff --git a/src/routes/sharing.ts b/src/routes/sharing.ts
new file mode 100644
index 0000000..a9e4ba7
--- /dev/null
+++ b/src/routes/sharing.ts
@@ -0,0 +1,311 @@
+import { Router } from 'express';
+import { Store, Role } from '../types.js';
+import { generateId } from '../store.js';
+import { AuthRequest, requireAuth } from '../middleware.js';
+import { hasPermission } from '../permissions.js';
+
+const VALID_ROLES: Role[] = ['viewer', 'editor', 'owner'];
+
+export function createSharingRouter(store: Store): Router {
+  const router = Router();
+
+  // Share a resource
+  router.post('/share', requireAuth, (req: AuthRequest, res) => {
+    const { resourceType, resourceId, userId, role } = req.body;
+    const currentUser = req.user!;
+
+    if (!resourceType || !resourceId || !userId || !role) {
+      res.status(400).json({ error: 'resourceType, resourceId, userId, and role are required' });
+      return;
+    }
+
+    if (resourceType !== 'folder' && resourceType !== 'document') {
+      res.status(400).json({ error: 'resourceType must be "folder" or "document"' });
+      return;
+    }
+
+    if (!VALID_ROLES.includes(role)) {
+      res.status(400).json({ error: 'role must be "viewer", "editor", or "owner"' });
+      return;
+    }
+
+    // Check the resource exists
+    if (resourceType === 'folder') {
+      if (!store.folders.has(resourceId)) {
+        res.status(404).json({ error: 'Folder not found' });
+        return;
+      }
+    } else {
+      if (!store.documents.has(resourceId)) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+    }
+
+    // Check user exists
+    if (!store.users.has(userId)) {
+      res.status(404).json({ error: 'User not found' });
+      return;
+    }
+
+    // Cannot share with yourself
+    if (userId === currentUser.id) {
+      res.status(400).json({ error: 'Cannot share with yourself' });
+      return;
+    }
+
+    // To share, you need at least editor role, and to grant owner you must be owner
+    if (role === 'owner') {
+      if (!hasPermission(store, currentUser.id, resourceType, resourceId, 'owner')) {
+        res.status(403).json({ error: 'Only owners can grant owner role' });
+        return;
+      }
+    } else {
+      if (!hasPermission(store, currentUser.id, resourceType, resourceId, 'editor')) {
+        res.status(403).json({ error: 'Insufficient permissions to share' });
+        return;
+      }
+    }
+
+    // Check if there's already a share for this user/resource combo, update if so
+    const existingShare = store.shares.find(
+      (s) =>
+        s.userId === userId &&
+        s.resourceType === resourceType &&
+        s.resourceId === resourceId
+    );
+
+    const now = new Date().toISOString();
+
+    if (existingShare) {
+      existingShare.role = role;
+      existingShare.grantedBy = currentUser.id;
+      existingShare.createdAt = now;
+
+      store.activityLog.push({
+        id: generateId(store),
+        action: 'share_updated',
+        userId: currentUser.id,
+        resourceType,
+        resourceId,
+        details: `Shared with user ${userId} as ${role}`,
+        timestamp: now,
+      });
+
+      res.json(existingShare);
+    } else {
+      const share = {
+        id: generateId(store),
+        resourceType,
+        resourceId,
+        userId,
+        role,
+        grantedBy: currentUser.id,
+        createdAt: now,
+      };
+      store.shares.push(share);
+
+      store.activityLog.push({
+        id: generateId(store),
+        action: 'share_created',
+        userId: currentUser.id,
+        resourceType,
+        resourceId,
+        details: `Shared with user ${userId} as ${role}`,
+        timestamp: now,
+      });
+
+      res.status(201).json(share);
+    }
+  });
+
+  // Share via resource-specific route
+  router.post('/folders/:id/share', requireAuth, (req: AuthRequest, res) => {
+    const resourceId = req.params.id;
+    const { userId, role } = req.body;
+    const currentUser = req.user!;
+
+    if (!userId || !role) {
+      res.status(400).json({ error: 'userId and role are required' });
+      return;
+    }
+
+    if (!VALID_ROLES.includes(role)) {
+      res.status(400).json({ error: 'role must be "viewer", "editor", or "owner"' });
+      return;
+    }
+
+    if (!store.folders.has(resourceId)) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!store.users.has(userId)) {
