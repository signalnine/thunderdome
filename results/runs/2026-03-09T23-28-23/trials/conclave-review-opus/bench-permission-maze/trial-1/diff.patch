password) {\n    50→        // Generate a new token on login\n    51→        const token = generateToken();\n    52→        user.token = token;\n    53→        res.json({ id: user.id, username: user.username, token });\n    54→        return;\n    55→      }\n    56→    }\n    57→\n    58→    res.status(401).json({ error: 'Invalid credentials' });\n    59→  });\n    60→\n    61→  return router;\n    62→}\n    63→"}]},"parent_tool_use_id":"toolu_01CoVR7ULpSWTSZEZM4DJdUj","session_id":"6e31066c-a8ad-4667-833e-bf0517b50028","uuid":"22859fca-88e4-4473-a5b5-8189e31d6dca"}
