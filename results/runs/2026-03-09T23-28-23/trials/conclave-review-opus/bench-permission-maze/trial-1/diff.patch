+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XV6a13wZm3VjDFNA8QHXuH","type":"tool_result","content":"     1→import { Router } from 'express';\n     2→import { Store } from '../types.js';\n     3→import { generateId } from '../store.js';\n     4→import { AuthRequest, requireAuth } from '../middleware.js';\n     5→import { hasPermission } from '../permissions.js';\n     6→\n     7→export function createFolderRouter(store: Store): Router {\n     8→  const router = Router();\n     9→\n    10→  // Create folder\n    11→  router.post('/folders', requireAuth, (req: AuthRequest, res) => {\n    12→    const { name, parentId } = req.body;\n    13→    const user = req.user!;\n    14→\n    15→    if (!name || typeof name !== 'string') {\n    16→      res.status(400).json({ error: 'Folder name is required' });\n    17→      return;\n    18→    }\n    19→\n    20→    // If parentId is given, verify parent exists and user has permission\n    21→    if (parentId !== undefined && parentId !== null) {\n    22→      const parent = store.folders.get(parentId);\n    23→      if (!parent) {\n    24→        res.status(404).json({ error: 'Parent folder not found' });\n    25→        return;\n    26→      }\n    27→      if (!hasPermission(store, user.id, 'folder', parentId, 'editor')) {\n    28→        res.status(403).json({ error: 'Insufficient permissions on parent folder' });\n    29→        return;\n    30→      }\n    31→    }\n    32→\n    33→    const id = generateId(store);\n    34→    const folder = {\n    35→      id,\n    36→      name,\n    37→      parentId: parentId || null,\n    38→      ownerId: user.id,\n    39→      createdAt: new Date().toISOString(),\n    40→    };\n    41→    store.folders.set(id, folder);\n    42→\n    43→    res.status(201).json(folder);\n    44→  });\n    45→\n    46→  // Get folder\n    47→  router.get('/folders/:id', requireAuth, (req: AuthRequest, res) => {\n    48→    const folder = store.folders.get(req.params.id);\n    49→    if (!folder) {\n    50→      res.status(404).json({ error: 'Folder not found' });\n    51→      return;\n    52→    }\n    53→\n    54→    if (!hasPermission(store, req.user!.id, 'folder', folder.id, 'viewer')) {\n    55→      res.status(403).json({ error: 'Insufficient permissions' });\n    56→      return;\n    57→    }\n    58→\n    59→    // Get subfolders and documents\n    60→    const subfolders = Array.from(store.folders.values()).filter(\n    61→      (f) => f.parentId === folder.id\n    62→    );\n    63→    const documents = Array.from(store.documents.values()).filter(\n    64→      (d) => d.folderId === folder.id\n    65→    );\n    66→\n    67→    res.json({ ...folder, subfolders, documents });\n    68→  });\n    69→\n    70→  // Update folder\n    71→  router.put('/folders/:id', requireAuth, (req: AuthRequest, res) => {\n    72→    const folder = store.folders.get(req.params.id);\n    73→    if (!folder) {\n    74→      res.status(404).json({ error: 'Folder not found' });\n    75→      return;\n    76→    }\n    77→\n    78→    if (!hasPermission(store, req.user!.id, 'folder', folder.id, 'editor')) {\n    79→      res.status(403).json({ error: 'Insufficient permissions' });\n    80→      return;\n    81→    }\n    82→\n    83→    const { name, parentId } = req.body;\n    84→\n    85→    if (name !== undefined) {\n    86→      if (typeof name !== 'string' || !name) {\n    87→        res.status(400).json({ error: 'Folder name must be a non-empty string' });\n    88→        return;\n    89→      }\n    90→      folder.name = name;\n    91→    }\n    92→\n    93→    if (parentId !== undefined) {\n    94→      if (parentId !== null) {\n    95→        const parent = store.folders.get(parentId);\n    96→        if (!parent) {\n    97→          res.status(404).json({ error: 'Parent folder not found' });\n    98→          return;\n    99→        }\n   100→        // Prevent circular reference\n   101→        if (parentId === folder.id) {\n   102→          res.status(400).json({ error: 'Folder cannot be its own parent' });\n   103→          return;\n   104→        }\n   105→      }\n   106→      folder.parentId = parentId;\n   107→    }\n   108→\n   109→    res.json(folder);\n   110→  });\n   111→\n   112→  // Delete folder\n   113→  router.delete('/folders/:id', requireAuth, (req: AuthRequest, res) => {\n   114→    const folder = store.folders.get(req.params.id);\n   115→    if (!folder) {\n   116→      res.status(404).json({ error: 'Folder not found' });\n   117→      return;\n   118→    }\n   119→\n   120→    if (!hasPermission(store, req.user!.id, 'folder', folder.id, 'owner')) {\n   121→      res.status(403).json({ error: 'Insufficient permissions' });\n   122→      return;\n   123→    }\n   124→\n   125→    // Delete all documents in the folder\n   126→    for (const [docId, doc] of store.documents.entries()) {\n   127→      if (doc.folderId === folder.id) {\n   128→        store.documents.delete(docId);\n   129→      }\n   130→    }\n   131→\n   132→    // Delete subfolders recursively\n   133→    deleteFolderRecursive(store, folder.id);\n   134→\n   135→    store.folders.delete(folder.id);\n   136→\n   137→    // Remove shares for this folder\n   138→    store.shares = store.shares.filter(\n   139→      (s) => !(s.resourceType === 'folder' && s.resourceId === folder.id)\n   140→    );\n   141→\n   142→    res.status(204).send();\n   143→  });\n   144→\n   145→  return router;\n   146→}\n   147→\n   148→function deleteFolderRecursive(store: Store, folderId: string) {\n   149→  const subfolders = Array.from(store.folders.values()).filter(\n   150→    (f) => f.parentId === folderId\n   151→  );\n   152→\n   153→  for (const subfolder of subfolders) {\n   154→    // Delete documents in subfolder\n   155→    for (const [docId, doc] of store.documents.entries()) {\n   156→      if (doc.folderId === subfolder.id) {\n   157→        store.documents.delete(docId);\n   158→      }\n   159→    }\n   160→\n   161→    // Recursively delete subfolders\n   162→    deleteFolderRecursive(store, subfolder.id);\n   163→\n   164→    store.folders.delete(subfolder.id);\n   165→\n   166→    // Remove shares\n   167→    store.shares = store.shares.filter(\n   168→      (s) => !(s.resourceType === 'folder' && s.resourceId === subfolder.id)\n   169→    );\n   170→  }\n   171→}\n   172→"}]},"parent_tool_use_id":"toolu_01CoVR7ULpSWTSZEZM4DJdUj","session_id":"6e31066c-a8ad-4667-833e-bf0517b50028","uuid":"f4cffe67-28f5-49d9-b9f1-03a742f26afc"}
