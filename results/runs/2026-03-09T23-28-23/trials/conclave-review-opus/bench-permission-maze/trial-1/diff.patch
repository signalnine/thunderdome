+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RnH8jtfADfaZgbSgadyGJv","type":"tool_result","content":"     1→import { Store, Role } from './types.js';\n     2→\n     3→const ROLE_HIERARCHY: Record<Role, number> = {\n     4→  viewer: 1,\n     5→  editor: 2,\n     6→  owner: 3,\n     7→};\n     8→\n     9→export function getEffectiveRole(\n    10→  store: Store,\n    11→  userId: string,\n    12→  resourceType: 'folder' | 'document',\n    13→  resourceId: string\n    14→): Role | null {\n    15→  let bestRole: Role | null = null;\n    16→\n    17→  // Check if user is the owner of the resource\n    18→  if (resourceType === 'folder') {\n    19→    const folder = store.folders.get(resourceId);\n    20→    if (folder && folder.ownerId === userId) {\n    21→      return 'owner';\n    22→    }\n    23→  } else {\n    24→    const doc = store.documents.get(resourceId);\n    25→    if (doc && doc.ownerId === userId) {\n    26→      return 'owner';\n    27→    }\n    28→  }\n    29→\n    30→  // Check direct shares for this resource\n    31→  for (const share of store.shares) {\n    32→    if (\n    33→      share.userId === userId &&\n    34→      share.resourceType === resourceType &&\n    35→      share.resourceId === resourceId\n    36→    ) {\n    37→      if (!bestRole || ROLE_HIERARCHY[share.role] > ROLE_HIERARCHY[bestRole]) {\n    38→        bestRole = share.role;\n    39→      }\n    40→    }\n    41→  }\n    42→\n    43→  // If the resource is a document, check folder-level shares\n    44→  if (resourceType === 'document') {\n    45→    const doc = store.documents.get(resourceId);\n    46→    if (doc) {\n    47→      const folderRole = getEffectiveFolderRole(store, userId, doc.folderId);\n    48→      if (folderRole) {\n    49→        if (!bestRole || ROLE_HIERARCHY[folderRole] > ROLE_HIERARCHY[bestRole]) {\n    50→          bestRole = folderRole;\n    51→        }\n    52→      }\n    53→    }\n    54→  }\n    55→\n    56→  // If the resource is a folder, check parent folder shares (inherited)\n    57→  if (resourceType === 'folder') {\n    58→    const folder = store.folders.get(resourceId);\n    59→    if (folder && folder.parentId) {\n    60→      const parentRole = getEffectiveFolderRole(store, userId, folder.parentId);\n    61→      if (parentRole) {\n    62→        if (!bestRole || ROLE_HIERARCHY[parentRole] > ROLE_HIERARCHY[bestRole]) {\n    63→          bestRole = parentRole;\n    64→        }\n    65→      }\n    66→    }\n    67→  }\n    68→\n    69→  return bestRole;\n    70→}\n    71→\n    72→function getEffectiveFolderRole(\n    73→  store: Store,\n    74→  userId: string,\n    75→  folderId: string\n    76→): Role | null {\n    77→  let bestRole: Role | null = null;\n    78→\n    79→  // Check if owner\n    80→  const folder = store.folders.get(folderId);\n    81→  if (folder && folder.ownerId === userId) {\n    82→    return 'owner';\n    83→  }\n    84→\n    85→  // Check direct shares on this folder\n    86→  for (const share of store.shares) {\n    87→    if (\n    88→      share.userId === userId &&\n    89→      share.resourceType === 'folder' &&\n    90→      share.resourceId === folderId\n    91→    ) {\n    92→      if (!bestRole || ROLE_HIERARCHY[share.role] > ROLE_HIERARCHY[bestRole]) {\n    93→        bestRole = share.role;\n    94→      }\n    95→    }\n    96→  }\n    97→\n    98→  // Check parent folder shares (recursive)\n    99→  if (folder && folder.parentId) {\n   100→    const parentRole = getEffectiveFolderRole(store, userId, folder.parentId);\n   101→    if (parentRole) {\n   102→      if (!bestRole || ROLE_HIERARCHY[parentRole] > ROLE_HIERARCHY[bestRole]) {\n   103→        bestRole = parentRole;\n   104→      }\n   105→    }\n   106→  }\n   107→\n   108→  return bestRole;\n   109→}\n   110→\n   111→export function hasPermission(\n   112→  store: Store,\n   113→  userId: string,\n   114→  resourceType: 'folder' | 'document',\n   115→  resourceId: string,\n   116→  requiredRole: Role\n   117→): boolean {\n   118→  const effectiveRole = getEffectiveRole(store, userId, resourceType, resourceId);\n   119→  if (!effectiveRole) return false;\n   120→  return ROLE_HIERARCHY[effectiveRole] >= ROLE_HIERARCHY[requiredRole];\n   121→}\n   122→"}]},"parent_tool_use_id":"toolu_01CoVR7ULpSWTSZEZM4DJdUj","session_id":"6e31066c-a8ad-4667-833e-bf0517b50028","uuid":"923938f1-78b2-45ba-8109-65c07d68f933"}
