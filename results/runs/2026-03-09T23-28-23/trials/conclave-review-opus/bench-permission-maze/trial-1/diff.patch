+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SXRC6kNBFo9WsjsvSvh37r","type":"tool_result","content":"     1→import { Router } from 'express';\n     2→import { Store } from '../types.js';\n     3→import { generateId } from '../store.js';\n     4→import { AuthRequest, requireAuth } from '../middleware.js';\n     5→import { hasPermission } from '../permissions.js';\n     6→\n     7→export function createDocumentRouter(store: Store): Router {\n     8→  const router = Router();\n     9→\n    10→  // Create document\n    11→  router.post('/documents', requireAuth, (req: AuthRequest, res) => {\n    12→    const { title, content, folderId } = req.body;\n    13→    const user = req.user!;\n    14→\n    15→    if (!title || typeof title !== 'string') {\n    16→      res.status(400).json({ error: 'Document title is required' });\n    17→      return;\n    18→    }\n    19→\n    20→    if (content === undefined || content === null) {\n    21→      res.status(400).json({ error: 'Document content is required' });\n    22→      return;\n    23→    }\n    24→\n    25→    if (!folderId) {\n    26→      res.status(400).json({ error: 'Folder ID is required' });\n    27→      return;\n    28→    }\n    29→\n    30→    const folder = store.folders.get(folderId);\n    31→    if (!folder) {\n    32→      res.status(404).json({ error: 'Folder not found' });\n    33→      return;\n    34→    }\n    35→\n    36→    // User must have at least editor on the folder to create docs in it\n    37→    if (!hasPermission(store, user.id, 'folder', folderId, 'editor')) {\n    38→      res.status(403).json({ error: 'Insufficient permissions on folder' });\n    39→      return;\n    40→    }\n    41→\n    42→    const id = generateId(store);\n    43→    const now = new Date().toISOString();\n    44→    const doc = {\n    45→      id,\n    46→      title,\n    47→      content: String(content),\n    48→      folderId,\n    49→      ownerId: user.id,\n    50→      createdAt: now,\n    51→      updatedAt: now,\n    52→    };\n    53→    store.documents.set(id, doc);\n    54→\n    55→    // Activity log\n    56→    store.activityLog.push({\n    57→      id: generateId(store),\n    58→      action: 'document_created',\n    59→      userId: user.id,\n    60→      resourceType: 'document',\n    61→      resourceId: id,\n    62→      timestamp: now,\n    63→    });\n    64→\n    65→    res.status(201).json(doc);\n    66→  });\n    67→\n    68→  // Create document under a folder (alternative route)\n    69→  router.post('/folders/:folderId/documents', requireAuth, (req: AuthRequest, res) => {\n    70→    const { title, content } = req.body;\n    71→    const user = req.user!;\n    72→    const folderId = req.params.folderId;\n    73→\n    74→    if (!title || typeof title !== 'string') {\n    75→      res.status(400).json({ error: 'Document title is required' });\n    76→      return;\n    77→    }\n    78→\n    79→    if (content === undefined || content === null) {\n    80→      res.status(400).json({ error: 'Document content is required' });\n    81→      return;\n    82→    }\n    83→\n    84→    const folder = store.folders.get(folderId);\n    85→    if (!folder) {\n    86→      res.status(404).json({ error: 'Folder not found' });\n    87→      return;\n    88→    }\n    89→\n    90→    if (!hasPermission(store, user.id, 'folder', folderId, 'editor')) {\n    91→      res.status(403).json({ error: 'Insufficient permissions on folder' });\n    92→      return;\n    93→    }\n    94→\n    95→    const id = generateId(store);\n    96→    const now = new Date().toISOString();\n    97→    const doc = {\n    98→      id,\n    99→      title,\n   100→      content: String(content),\n   101→      folderId,\n   102→      ownerId: user.id,\n   103→      createdAt: now,\n   104→      updatedAt: now,\n   105→    };\n   106→    store.documents.set(id, doc);\n   107→\n   108→    store.activityLog.push({\n   109→      id: generateId(store),\n   110→      action: 'document_created',\n   111→      userId: user.id,\n   112→      resourceType: 'document',\n   113→      resourceId: id,\n   114→      timestamp: now,\n   115→    });\n   116→\n   117→    res.status(201).json(doc);\n   118→  });\n   119→\n   120→  // Get document\n   121→  router.get('/documents/:id', requireAuth, (req: AuthRequest, res) => {\n   122→    const doc = store.documents.get(req.params.id);\n   123→    if (!doc) {\n   124→      res.status(404).json({ error: 'Document not found' });\n   125→      return;\n   126→    }\n   127→\n   128→    if (!hasPermission(store, req.user!.id, 'document', doc.id, 'viewer')) {\n   129→      res.status(403).json({ error: 'Insufficient permissions' });\n   130→      return;\n   131→    }\n   132→\n   133→    res.json(doc);\n   134→  });\n   135→\n   136→  // Update document\n   137→  router.put('/documents/:id', requireAuth, (req: AuthRequest, res) => {\n   138→    const doc = store.documents.get(req.params.id);\n   139→    if (!doc) {\n   140→      res.status(404).json({ error: 'Document not found' });\n   141→      return;\n   142→    }\n   143→\n   144→    if (!hasPermission(store, req.user!.id, 'document', doc.id, 'editor')) {\n   145→      res.status(403).json({ error: 'Insufficient permissions' });\n   146→      return;\n   147→    }\n   148→\n   149→    const { title, content } = req.body;\n   150→    if (title !== undefined) {\n   151→      if (typeof title !== 'string' || !title) {\n   152→        res.status(400).json({ error: 'Document title must be a non-empty string' });\n   153→        return;\n   154→      }\n   155→      doc.title = title;\n   156→    }\n   157→    if (content !== undefined) {\n   158→      doc.content = String(content);\n   159→    }\n   160→    doc.updatedAt = new Date().toISOString();\n   161→\n   162→    store.activityLog.push({\n   163→      id: generateId(store),\n   164→      action: 'document_updated',\n   165→      userId: req.user!.id,\n   166→      resourceType: 'document',\n   167→      resourceId: doc.id,\n   168→      timestamp: doc.updatedAt,\n   169→    });\n   170→\n   171→    res.json(doc);\n   172→  });\n   173→\n   174→  // Delete document\n   175→  router.delete('/documents/:id', requireAuth, (req: AuthRequest, res) => {\n   176→    const doc = store.documents.get(req.params.id);\n   177→    if (!doc) {\n   178→      res.status(404).json({ error: 'Document not found' });\n   179→      return;\n   180→    }\n   181→\n   182→    if (!hasPermission(store, req.user!.id, 'document', doc.id, 'owner')) {\n   183→      res.status(403).json({ error: 'Insufficient permissions' });\n   184→      return;\n   185→    }\n   186→\n   187→    const now = new Date().toISOString();\n   188→    store.documents.delete(doc.id);\n   189→\n   190→    // Remove shares for this document\n   191→    store.shares = store.shares.filter(\n   192→      (s) => !(s.resourceType === 'document' && s.resourceId === doc.id)\n   193→    );\n   194→\n   195→    store.activityLog.push({\n   196→      id: generateId(store),\n   197→      action: 'document_deleted',\n   198→      userId: req.user!.id,\n   199→      resourceType: 'document',\n   200→      resourceId: doc.id,\n   201→      timestamp: now,\n   202→    });\n   203→\n   204→    res.status(204).send();\n   205→  });\n   206→\n   207→  return router;\n   208→}\n   209→"}]},"parent_tool_use_id":"toolu_01CoVR7ULpSWTSZEZM4DJdUj","session_id":"6e31066c-a8ad-4667-833e-bf0517b50028","uuid":"d41679ac-9f05-47d2-82f6-c1c34cbf420d"}
