+import express from 'express';
+import { createStore } from './store.js';
+import { authMiddleware } from './middleware.js';
+import { createAuthRouter } from './routes/auth.js';
+import { createFolderRouter } from './routes/folders.js';
+import { createDocumentRouter } from './routes/documents.js';
+import { createSharingRouter } from './routes/sharing.js';
+import { createActivityRouter } from './routes/activity.js';
+
+export function createApp() {
+  const app = express();
+  const store = createStore();
+
+  app.use(express.json());
+  app.use(authMiddleware(store));
+
+  app.use(createAuthRouter(store));
+  app.use(createFolderRouter(store));
+  app.use(createDocumentRouter(store));
+  app.use(createSharingRouter(store));
+  app.use(createActivityRouter(store));
+
+  return app;
+}
