+      base: deepClone(baseVal),
+      ours: deepClone(oursVal),
+      theirs: deepClone(theirsVal),
+    });
+  }
+
+  return { merged, conflicts };
+}
+
+export class DocumentStore {
+  private branches: Map<string, BranchState> = new Map();
+  private currentBranch: string = 'main';
+  private versionCounter = 0;
+
+  constructor() {
+    this.branches.set('main', {
+      documents: new Map(),
+      forkPoint: null,
+      forkedFrom: null,
+    });
+  }
+
+  private generateVersionId(): string {
+    return `v_${++this.versionCounter}_${Date.now()}`;
+  }
+
+  // ---- Document CRUD ----
+
+  create(id: string, content: object): void {
+    const branch = this.getCurrentBranchState();
+    const existing = branch.documents.get(id);
+    if (existing && !existing.deleted) {
+      throw new Error(`Document "${id}" already exists`);
+    }
+
+    const version: Version = {
+      id: this.generateVersionId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+
+    branch.documents.set(id, {
+      content: deepClone(content),
+      versions: existing?.deleted ? [...existing.versions, version] : [version],
+      deleted: false,
+    });
+  }
+
+  get(id: string): object {
+    const branch = this.getCurrentBranchState();
+    const entry = branch.documents.get(id);
+    if (!entry || entry.deleted) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    return deepClone(entry.content);
+  }
+
+  update(id: string, content: object): void {
+    const branch = this.getCurrentBranchState();
+    const entry = branch.documents.get(id);
+    if (!entry || entry.deleted) {
+      throw new Error(`Document "${id}" not found`);
+    }
+
+    const version: Version = {
+      id: this.generateVersionId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+
+    entry.content = deepClone(content);
+    entry.versions.push(version);
+  }
+
+  delete(id: string): void {
+    const branch = this.getCurrentBranchState();
+    const entry = branch.documents.get(id);
+    if (!entry || entry.deleted) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    entry.deleted = true;
+  }
+
+  // ---- Version History ----
+
+  getHistory(id: string): Version[] {
+    const branch = this.getCurrentBranchState();
+    const entry = branch.documents.get(id);
+    if (!entry) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    return entry.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    }));
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const branch = this.getCurrentBranchState();
+    const entry = branch.documents.get(id);
+    if (!entry) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    const version = entry.versions.find(v => v.id === versionId);
+    if (!version) {
+      throw new Error(`Version "${versionId}" not found for document "${id}"`);
+    }
+    return deepClone(version.content);
+  }
+
+  // ---- Branching ----
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch "${name}" already exists`);
+    }
+
+    const sourceName = fromBranch ?? this.currentBranch;
+    const source = this.branches.get(sourceName);
+    if (!source) {
+      throw new Error(`Branch "${sourceName}" not found`);
+    }
+
+    this.branches.set(name, {
+      documents: cloneDocumentMap(source.documents),
+      forkPoint: cloneDocumentMap(source.documents),
+      forkedFrom: sourceName,
+    });
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch "${name}" not found`);
+    }
+    this.currentBranch = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranch;
+  }
+
+  listBranches(): string[] {
+    return Array.from(this.branches.keys());
+  }
+
+  // ---- Merging ----
+
+  merge(sourceBranch: string): MergeResult {
+    const source = this.branches.get(sourceBranch);
+    if (!source) {
+      throw new Error(`Branch "${sourceBranch}" not found`);
+    }
+
+    const target = this.getCurrentBranchState();
+    const base = this.findCommonAncestor(sourceBranch, this.currentBranch);
+
+    const allDocIds = new Set<string>();
+    if (base) {
+      for (const id of base.keys()) allDocIds.add(id);
+    }
+    for (const id of source.documents.keys()) allDocIds.add(id);
+    for (const id of target.documents.keys()) allDocIds.add(id);
+
+    const merged: Record<string, object> = {};
+    const conflicts: Conflict[] = [];
+    const mergedEntries = new Map<string, { content: object; deleted: boolean }>();
+
+    for (const docId of allDocIds) {
+      const baseEntry = base?.get(docId);
+      const sourceEntry = source.documents.get(docId);
+      const targetEntry = target.documents.get(docId);
+
+      const baseContent = baseEntry && !baseEntry.deleted ? baseEntry.content : null;
+      const sourceContent = sourceEntry && !sourceEntry.deleted ? sourceEntry.content : null;
+      const targetContent = targetEntry && !targetEntry.deleted ? targetEntry.content : null;
+
+      const baseDeleted = baseEntry ? baseEntry.deleted : true;
+      const sourceDeleted = sourceEntry ? sourceEntry.deleted : true;
+      const targetDeleted = targetEntry ? targetEntry.deleted : true;
+
+      const sourceExists = sourceEntry !== undefined && !sourceEntry.deleted;
+      const targetExists = targetEntry !== undefined && !targetEntry.deleted;
+
+      // Check if base didn't exist at all (not present in ancestor)
+      const baseNotPresent = baseEntry === undefined;
+
+      const sourceChanged = !deepEqual(baseContent, sourceContent) || baseDeleted !== sourceDeleted;
+      const targetChanged = !deepEqual(baseContent, targetContent) || baseDeleted !== targetDeleted;
+
+      if (!sourceChanged && !targetChanged) {
+        if (targetExists) {
+          merged[docId] = deepClone(targetContent!);
+          mergedEntries.set(docId, { content: deepClone(targetContent!), deleted: false });
+        }
+        continue;
+      }
+
+      if (sourceChanged && !targetChanged) {
+        if (sourceExists) {
+          merged[docId] = deepClone(sourceContent!);
+          mergedEntries.set(docId, { content: deepClone(sourceContent!), deleted: false });
+        } else {
+          mergedEntries.set(docId, { content: {}, deleted: true });
+        }
+        continue;
+      }
+
+      if (!sourceChanged && targetChanged) {
+        if (targetExists) {
+          merged[docId] = deepClone(targetContent!);
+          mergedEntries.set(docId, { content: deepClone(targetContent!), deleted: false });
+        }
+        continue;
+      }
+
+      // Both sides changed
+      if (sourceDeleted && targetDeleted) {
+        mergedEntries.set(docId, { content: {}, deleted: true });
+        continue;
+      }
+
+      // Both created the same doc (didn't exist at base)
+      if (baseNotPresent && sourceExists && targetExists) {
+        // Both created - do field-level merge
+        const result = threeWayMerge({}, targetContent, sourceContent, docId);
+        merged[docId] = result.merged;
+        conflicts.push(...result.conflicts);
+        mergedEntries.set(docId, { content: deepClone(result.merged), deleted: false });
+        continue;
+      }
+
+      if (sourceDeleted && !targetDeleted) {
+        merged[docId] = deepClone(targetContent!);
+        conflicts.push({
+          documentId: docId,
+          path: '',
+          base: deepClone(baseContent),
+          ours: deepClone(targetContent),
+          theirs: null,
+        });
+        mergedEntries.set(docId, { content: deepClone(targetContent!), deleted: false });
+        continue;
+      }
+
+      if (!sourceDeleted && targetDeleted) {
+        conflicts.push({
+          documentId: docId,
+          path: '',
+          base: deepClone(baseContent),
+          ours: null,
+          theirs: deepClone(sourceContent),
+        });
+        mergedEntries.set(docId, { content: {}, deleted: true });
+        continue;
+      }
+
+      // Both sides modified the document
+      const result = threeWayMerge(baseContent, targetContent, sourceContent, docId);
+      merged[docId] = result.merged;
+      conflicts.push(...result.conflicts);
+      mergedEntries.set(docId, { content: deepClone(result.merged), deleted: false });
+    }
+
+    const applied = conflicts.length === 0;
+
+    if (applied) {
+      for (const [docId, entry] of mergedEntries) {
+        const existingEntry = target.documents.get(docId);
+        if (entry.deleted) {
+          if (existingEntry) {
+            existingEntry.deleted = true;
+          }
+        } else {
+          if (existingEntry) {
+            // M3 fix: Only add a version if content actually changed
+            if (!deepEqual(existingEntry.content, entry.content)) {
+              existingEntry.content = deepClone(entry.content);
+              existingEntry.deleted = false;
+              const version: Version = {
+                id: this.generateVersionId(),
+                timestamp: Date.now(),
+                content: deepClone(entry.content),
+              };
+              existingEntry.versions.push(version);
+            }
+          } else {
+            const sourceEntry = source.documents.get(docId);
+            if (sourceEntry) {
+              target.documents.set(docId, cloneDocumentEntry(sourceEntry));
+            } else {
+              const version: Version = {
+                id: this.generateVersionId(),
+                timestamp: Date.now(),
+                content: deepClone(entry.content),
+              };
+              target.documents.set(docId, {
+                content: deepClone(entry.content),
+                versions: [version],
+                deleted: false,
+              });
+            }
+          }
+        }
+      }
+
+      // H1 fix: Update the fork point of the source branch after a successful merge
+      // so that subsequent merges use the post-merge state as the common ancestor
+      source.forkPoint = cloneDocumentMap(target.documents);
+      source.forkedFrom = this.currentBranch;
+    }
+
+    return { merged, conflicts, applied };
+  }
+
+  // ---- Private helpers ----
+
+  private getCurrentBranchState(): BranchState {
+    const state = this.branches.get(this.currentBranch);
+    if (!state) {
+      throw new Error(`Branch "${this.currentBranch}" not found`);
+    }
+    return state;
+  }
+
+  private findCommonAncestor(
+    branch1: string,
+    branch2: string
+  ): Map<string, DocumentEntry> | null {
+    const state1 = this.branches.get(branch1);
+    const state2 = this.branches.get(branch2);
+    if (!state1 || !state2) return null;
+
+    // If branch1 was forked from branch2, use branch1's fork point
+    if (state1.forkedFrom === branch2 && state1.forkPoint) {
+      return state1.forkPoint;
+    }
+
+    // If branch2 was forked from branch1, use branch2's fork point
+    if (state2.forkedFrom === branch1 && state2.forkPoint) {
+      return state2.forkPoint;
+    }
+
+    // H2 fix: Walk up ancestry chains to find common ancestor
+    const ancestry1 = this.getAncestryChain(branch1);
+    const ancestry2 = this.getAncestryChain(branch2);
+
+    // Find the first common branch in the ancestry chains
+    for (const ancestor of ancestry1) {
+      if (ancestry2.includes(ancestor)) {
+        // Found common ancestor branch. Use the fork point from whichever
+        // branch is closer to the common ancestor.
+        const forkPoint1 = this.getForkPointForAncestor(branch1, ancestor);
+        const forkPoint2 = this.getForkPointForAncestor(branch2, ancestor);
+
+        // Use the earlier fork point (the one that was created first is the true base)
+        // In practice, both should be valid; use branch1's path to the ancestor
+        if (forkPoint1) return forkPoint1;
+        if (forkPoint2) return forkPoint2;
+        break;
+      }
+    }
+
+    // Default: no common ancestor
+    return new Map();
+  }
+
+  private getAncestryChain(branchName: string): string[] {
+    const chain: string[] = [];
+    let current = branchName;
+    const visited = new Set<string>();
+
+    while (current) {
+      if (visited.has(current)) break;
+      visited.add(current);
+      chain.push(current);
+      const state = this.branches.get(current);
+      if (!state || !state.forkedFrom) break;
+      current = state.forkedFrom;
+    }
+
+    return chain;
+  }
+
+  private getForkPointForAncestor(
+    branchName: string,
+    ancestorName: string
+  ): Map<string, DocumentEntry> | null {
+    let current = branchName;
+    const visited = new Set<string>();
+
+    while (current && current !== ancestorName) {
+      if (visited.has(current)) break;
+      visited.add(current);
+      const state = this.branches.get(current);
+      if (!state) break;
+      if (state.forkedFrom === ancestorName && state.forkPoint) {
+        return state.forkPoint;
+      }
+      current = state.forkedFrom!;
+    }
+
+    return null;
+  }
+}
