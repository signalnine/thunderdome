+      (isPlainObject(baseVal) && !isPlainObject(oursVal) && oursVal !== undefined) ||
+      (isPlainObject(baseVal) && !isPlainObject(theirsVal) && theirsVal !== undefined) ||
+      (!isPlainObject(baseVal) && isPlainObject(oursVal)) ||
+      (!isPlainObject(baseVal) && isPlainObject(theirsVal))
