ete current[parts[parts.length - 1]];\n}\n\n/**\n * Collect all leaf paths from an object.\n */\n// eslint-disable-next-line @typescript-eslint/no-explicit-any\nfunction collectPaths(obj: any, prefix: string = ''): string[] {\n  const paths: string[] = [];\n  if (obj === null || obj === undefined || typeof obj !== 'object' || Array.isArray(obj)) {\n    // Leaf value\n    if (prefix) {\n      paths.push(prefix);\n    }\n    return paths;\n  }\n  const keys = Object.keys(obj);\n  if (keys.length === 0 && prefix) {\n    // Empty object is a leaf\n    paths.push(prefix);\n    return paths;\n  }\n  for (const key of keys) {\n    const newPrefix = prefix ? `${prefix}.${key}` : key;\n    paths.push(...collectPaths(obj[key], newPrefix));\n  }\n  return paths;\n}\n\n// eslint-disable-next-line @typescript-eslint/no-explicit-any\nfunction deepEqual(a: any, b: any): boolean {\n  if (a === b) return true;\n  if (a === null || b === null) return a === b;\n  if (a === undefined || b === undefined) return a === b;\n  if (typeof a !== typeof b) return false;\n  if (typeof a !== 'object') return a === b;\n  return JSON.stringify(a) === JSON.stringify(b);\n}\n\n/**\n * Three-way merge of two objects against a common base.\n * Returns the merged result and any conflicts.\n */\nfunction threeWayMerge(\n  base: object | null,\n  ours: object | null,\n  theirs: object | null,\n  documentId: string\n): { merged: object; conflicts: Conflict[] } {\n  const conflicts: Conflict[] = [];\n\n  const baseObj = base ?? {};\n  const oursObj = ours ?? {};\n  const theirsObj = theirs ?? {};\n\n  // Collect all unique paths across all three objects\n  const allPaths = new Set<string>();\n  for (const p of collectPaths(baseObj)) allPaths.add(p);\n  for (const p of collectPaths(oursObj)) allPaths.add(p);\n  for (const p of collectPaths(theirsObj)) allPaths.add(p);\n\n  const merged = deepClone(oursObj);\n\n  for (const path of allPaths) {\n    const baseVal = getAtPath(baseObj, path);\n    const oursVal