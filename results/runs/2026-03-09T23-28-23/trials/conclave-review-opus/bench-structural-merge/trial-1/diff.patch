Array.from(this.branches.keys());\n   349→  }\n   350→\n   351→  // ---- Merging ----\n   352→\n   353→  merge(sourceBranch: string): MergeResult {\n   354→    const source = this.branches.get(sourceBranch);\n   355→    if (!source) {\n   356→      throw new Error(`Branch \"${sourceBranch}\" not found`);\n   357→    }\n   358→\n   359→    const target = this.getCurrentBranchState();\n   360→\n   361→    // Find the common ancestor (fork point).\n   362→    // The fork point is the state of the documents when the branch was created.\n   363→    // We need to find the common ancestor between source and target.\n   364→    const base = this.findCommonAncestor(sourceBranch, this.currentBranch);\n   365→\n   366→    // Collect all document IDs across base, source, and target\n   367→    const allDocIds = new Set<string>();\n   368→    if (base) {\n   369→      for (const id of base.keys()) allDocIds.add(id);\n   370→    }\n   371→    for (const id of source.documents.keys()) allDocIds.add(id);\n   372→    for (const id of target.documents.keys()) allDocIds.add(id);\n   373→\n   374→    const merged: Record<string, object> = {};\n   375→    const conflicts: Conflict[] = [];\n   376→    const mergedEntries = new Map<string, { content: object; deleted: boolean }>();\n   377→\n   378→    for (const docId of allDocIds) {\n   379→      const baseEntry = base?.get(docId);\n   380→      const sourceEntry = source.documents.get(docId);\n   381→      const targetEntry = target.documents.get(docId);\n   382→\n   383→      const baseContent = baseEntry && !baseEntry.deleted ? baseEntry.content : null;\n   384→      const sourceContent = sourceEntry && !sourceEntry.deleted ? sourceEntry.content : null;\n   385→      const targetContent = targetEntry && !targetEntry.deleted ? targetEntry.content : null;\n   386→\n   387→      const baseDeleted = baseEntry ? baseEntry.deleted : true;\n   388→      const sourceDeleted = sourceEntry ? sourceEntry.deleted : true;\n   389→      const targe