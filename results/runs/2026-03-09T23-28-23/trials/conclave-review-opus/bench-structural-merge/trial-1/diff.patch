+function collectPaths(obj: any, prefix: string = ''): string[] {
+  const paths: string[] = [];
+  if (obj === null || obj === undefined || typeof obj !== 'object' || Array.isArray(obj)) {
+    if (prefix) {
+      paths.push(prefix);
+    }
+    return paths;
+  }
+  const keys = Object.keys(obj);
+  if (keys.length === 0 && prefix) {
+    paths.push(prefix);
+    return paths;
+  }
