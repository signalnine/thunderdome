g(\"getHistory on deleted doc returned:\", h.length, \"versions (spec says should this be accessible?)\");\n} catch(e) {\n  console.log(\"getHistory on deleted doc threw (note: spec unclear on this)\");\n}\nconsole.log();\n\n// PROBE D: Merging same branch that has been previously merged\nconsole.log(\"=== PROBE D: Double merge ===\");\nconst s4 = new DocumentStore();\ns4.create(\"doc1\", { a: 1 });\ns4.createBranch(\"feature\");\ns4.switchBranch(\"feature\");\ns4.update(\"doc1\", { a: 2 });\ns4.switchBranch(\"main\");\nconst r4a = s4.merge(\"feature\");\nconsole.log(\"First merge applied:\", r4a.applied);\nconsole.log(\"doc1 after first merge:\", JSON.stringify(s4.get(\"doc1\")));\n\n// Now feature updates again\ns4.switchBranch(\"feature\");\ns4.update(\"doc1\", { a: 3 });\ns4.switchBranch(\"main\");\nconst r4b = s4.merge(\"feature\");\nconsole.log(\"Second merge applied:\", r4b.applied);\nconsole.log(\"doc1 after second merge:\", JSON.stringify(s4.get(\"doc1\")));\nconsole.log(\"Conflicts:\", JSON.stringify(r4b.conflicts));\n// The fork point is still the original state, so base={a:1}, ours={a:2}, theirs={a:3}\n// This means ours and theirs both changed from base -> CONFLICT!\n// But semantically we already merged, so the second merge should use updated base\nconsole.log();\n\n// PROBE E: Conflict a.b path when ours has scalar 'a' - does conflict have correct ours value?\nconsole.log(\"=== PROBE E: Conflict path detail when one side has scalar parent ===\");\nconst s5 = new DocumentStore();\ns5.create(\"doc1\", { a: { b: 1, c: 2 } });\ns5.createBranch(\"feature\");\ns5.switchBranch(\"feature\");\ns5.update(\"doc1\", { a: { b: 10, c: 2 } });\ns5.switchBranch(\"main\");\ns5.update(\"doc1\", { a: \"scalar\" });\nconst r5 = s5.merge(\"feature\");\nconsole.log(\"Conflicts:\");\nfor (const c of r5.conflicts) {\n  console.log(\"  path:\", c.path, \"base:\", JSON.stringify(c.base), \"ours:\", JSON.stringify(c.ours), \"theirs:\", JSON.stringify(c.theirs));\n}\nconsole.log();\nENDTEST\nnpx tsx src/probe2.ts 2>&1","description":"Run additional probe tests for edge cases","timeout":30000},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":136,"cache_read_input_tokens":33485,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":136},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01V7i57qwLXryk75CwVvMeuE","session_id":"8a8abe8a-01cb-4077-a42a-7211a72e5a8d","uuid":"e8de682e-f4bd-46ef-8aed-3b09deea374c"}
