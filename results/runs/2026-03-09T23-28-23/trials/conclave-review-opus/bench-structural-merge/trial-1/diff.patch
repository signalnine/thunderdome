t content, same doc\n\nconst r4 = s4.merge(\"feature\");\nconsole.log(\"Applied:\", r4.applied);\nconsole.log(\"Conflicts:\", JSON.stringify(r4.conflicts, null, 2));\nconsole.log(\"Merged:\", JSON.stringify(r4.merged, null, 2));\nconsole.log();\n\n// ===== PROBE 4: Document deleted on target, modified on source =====\nconsole.log(\"=== PROBE 4: Delete on target, modify on source ===\");\nconst s5 = new DocumentStore();\ns5.create(\"doc1\", { a: 1, b: 2 });\ns5.createBranch(\"feature\");\n\ns5.switchBranch(\"feature\");\ns5.update(\"doc1\", { a: 10, b: 2 });\n\ns5.switchBranch(\"main\");\ns5.delete(\"doc1\");\n\nconst r5 = s5.merge(\"feature\");\nconsole.log(\"Applied:\", r5.applied);\nconsole.log(\"Conflicts:\", JSON.stringify(r5.conflicts, null, 2));\nconsole.log(\"Merged:\", JSON.stringify(r5.merged, null, 2));\n// Doc should still be deleted on main since \"ours\" is delete\ntry {\n  s5.get(\"doc1\");\n  console.log(\"ERROR: doc1 should have been deleted on main but is accessible\");\n} catch {\n  console.log(\"OK: doc1 still deleted on main after conflict\");\n}\nconsole.log();\n\n// ===== PROBE 5: Document delete on source, modify on target - check merged contains ours =====\nconsole.log(\"=== PROBE 5: Delete on source, modify on target - merged should contain ours ===\");\nconst s6 = new DocumentStore();\ns6.create(\"doc1\", { a: 1, b: 2 });\ns6.createBranch(\"feature\");\n\ns6.switchBranch(\"feature\");\ns6.delete(\"doc1\");\n\ns6.switchBranch(\"main\");\ns6.update(\"doc1\", { a: 10, b: 2 });\n\nconst r6 = s6.merge(\"feature\");\nconsole.log(\"Applied:\", r6.applied);\nconsole.log(\"Merged has doc1:\", \"doc1\" in r6.merged);\nconsole.log(\"Merged doc1:\", JSON.stringify(r6.merged[\"doc1\"]));\nconsole.log(\"Conflicts:\", JSON.stringify(r6.conflicts, null, 2));\nconsole.log();\n\n// ===== PROBE 6: Version history preserved through merges =====\nconsole.log(\"=== PROBE 6: Version history after merge ===\");\nconst s7 = new DocumentStore();\ns7.create(\"doc1\",