ransformContent?: (file: ContentFile, ctx: BuildContext) => Promise<ContentFile> | ContentFile;\n  afterBuild?: (ctx: BuildContext) => Promise<void> | void;\n}\n\nexport interface Plugin {\n  name: string;\n  version: string;\n  dependencies: string[];  // names of plugins this depends on\n  hooks: PluginHooks;\n}\n\nexport interface Template {\n  name: string;\n  render: (content: string, data: Record<string, unknown>) => string;\n}\n```\n\n#### **B. /workspace/src/core/engine.ts** (117 lines)\n```typescript\nimport { BuildContext, ContentFile, Plugin, SiteConfig, Template } from './types.js';\n\nexport class BuildEngine {\n  private plugins: Plugin[] = [];\n  private templates: Map<string, Template> = new Map();\n\n  constructor(private config: SiteConfig) {}\n\n  registerPlugin(plugin: Plugin): void {\n    this.plugins.push(plugin);\n  }\n\n  registerTemplate(template: Template): void {\n    this.templates.set(template.name, template);\n  }\n\n  // Resolve plugin execution order using topological sort\n  resolvePluginOrder(): Plugin[] {\n    const sorted: Plugin[] = [];\n    const visited = new Set<string>();\n    const visiting = new Set<string>();\n    const pluginMap = new Map(this.plugins.map(p => [p.name, p]));\n\n    const visit = (name: string) => {\n      if (visited.has(name)) return;\n      if (visiting.has(name)) {\n        throw new Error(`Circular dependency detected: ${name}`);\n      }\n      visiting.add(name);\n      const plugin = pluginMap.get(name);\n      if (plugin) {\n        for (const dep of plugin.dependencies) {\n          if (!pluginMap.has(dep)) {\n            throw new Error(`Missing dependency: ${name} requires ${dep}`);\n          }\n          visit(dep);\n        }\n      }\n      visiting.delete(name);\n      visited.add(name);\n      if (plugin) sorted.push(plugin);\n    };\n\n    for (const plugin of this.plugins) {\n      visit(plugin.name);\n    }\n    return sorted;\n  }\n\n  async build(files: ContentFile[]): Promise<BuildContext> {\n    const ctx: BuildContext = {\n      config: this.config,\n      files: [...files],\n      output: new Map(),\n      assets: new Map(),\n      data: new Map(),\n    };\n\n    const orderedPlugins = this.resolvePluginOrder();\n\n    // beforeBuild hooks\n    for (const plugin of orderedPlugins) {\n      if (plugin.hooks.beforeBuild) {\n        await plugin.hooks.beforeBuild(ctx);\n      }\n    }\n\n    // transformContent hooks (applied to each file in plugin order)\n    for (const plugin of orderedPlugins) {\n      if (plugin.hooks.transformContent) {\n        const transformed: ContentFile[] = [];\n        for (const file of ctx.files) {\n          transformed.push(await plugin.hooks.transformContent(file, ctx));\n        }\n        ctx.files = transformed;\n      }\n    }\n\n    // Render templates\n    for (const file of ctx.files) {\n      const templateName = file.template || 'default';\n      const template = this.templates.get(templateName);\n      if (template) {\n        const rendered = template.render(file.content, {\n          title: file.title,\n          slug: file.slug,\n          date: file.date,\n          tags: file.tags,\n          ...file.metadata,\n          siteTitle: this.config.title,\n          baseUrl: this.config.baseUrl,\n        });\n        ctx.output.set(`${file.slug}.html`, rendered);\n      } else {\n        ctx.output.set(`${file.slug}.html`, file.content);\n      }\n    }\n\n    // afterBuild hooks\n    for (const plugin of orderedPlugins) {\n      if (plugin.hooks.afterBuild) {\n        await plugin.hooks.afterBuild(ctx);\n      }\n    }\n\n    return ctx;\n  }\n\n  getPlugins(): Plugin[] {\n    return [...this.plugins];\n  }\n\n  getTemplates(): Map<string, Template> {\n    return new Map(this.templates);\n  }\n}\n```\n\n#### **C. /workspace/src/core/templates.ts** (43 lines)\n```typescript\nimport { Template } from './types.js';\n\nexport function createDefaultTemplate(): Template {\n  return {\n    name: 'default',\n    render: (content: string, data: Record<string, unknown>) => {\n      return `<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>${data.title || ''} | ${data.siteTitle || ''}</title>\n</head>\n<body>\n  <article>\n    <h1>${data.title || ''}</h1>\n    ${data.date ? `<time>${data.date}</time>` : ''}\n    <div class=\"content\">${content}</div>\n  </article>\n</body>\n</html>`;\n    }\n  };\n}\n\nexport function createListTemplate(): Template {\n  return {\n    name: 'list',\n    render: (content: string, data: Record<string, unknown>) => {\n      return `<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>${data.title || ''} | ${data.siteTitle || ''}</title>\n</head>\n<body>\n  <h1>${data.title || ''}</h1>\n  <div class=\"list\">${content}</div>\n</body>\n</html>`;\n    }\n  };\n}\n```\n\n#### **D. /workspace/src/core/index.ts** (4 lines)\n```typescript\nexport { BuildEngine } from './engine.js';\nexport { createDefaultTemplate, createListTemplate } from './templates.js';\nexport type { BuildContext, ContentFile, Plugin, PluginHooks, SiteConfig, Template } from './types.js';\n```\n\n---\n\n### 3. ALL TEST FILES IN tests/ - COMPLETE CONTENTS\n\n#### **A. /workspace/tests/core.test.ts** (195 lines)\n\n**Test Suite: BuildEngine** - Tests the core build engine functionality\n\n**15 Test Cases:**\n1. `registers plugins` - Validates plugin registration and retrieval\n2. `registers templates` - Validates template registration\n3. `builds with default template and renders HTML` - Tests HTML output with default template\n4. `builds with list template and renders list HTML` - Tests list template rendering\n5. `outputs raw content when no matching template` - Tests fallback to raw content\n6. `calls plugin beforeBuild hook` - Validates beforeBuild hook execution\n7. `calls plugin transformContent hook to transform files` - Validates transformContent hook\n8. `calls plugin afterBuild hook` - Validates afterBuild hook execution\n9. `executes plugins in dependency order` - Tests topological sort of dependencies\n10. `throws on circular dependency` - Validates circular dependency detection\n11. `throws on missing dependency` - Validates missing dependency detection\n12. `applies multiple plugins transformContent in order` - Tests sequential plugin execution\n13. `provides shared data store in build context` - Tests ctx.data Map\n14. `retains file metadata through build` - Tests metadata, date, and tags preservation\n15. `produces empty output for empty file list` - Tests edge case with no files\n\n**Key Features Tested:**\n- Plugin registration and management\n- Template registration and rendering\n- Hook execution (beforeBuild, transformContent, afterBuild)\n- Dependency resolution using topological sort\n- Error handling for circular and missing dependencies\n- Content file transformation pipeline\n- Metadata preservation\n\n---\n\n#### **B. /workspace/tests/plugins/asset-pipeline.test.ts** (107 lines)\n\n**Plugin: asset-pipeline**\n- **Name:** `asset-pipeline`\n- **Dependencies:** None (Wave 1)\n- **Purpose:** Rewrite relative asset URLs to `/assets/` path and generate manifest\n\n**8 Test Cases:**\n1. `rewrites relative image URLs to /assets/ path` - `./image.png` → `/assets/image.png`\n2. `rewrites relative link URLs to /assets/ path` - `./doc.pdf` → `/assets/doc.pdf`\n3. `leaves absolute URLs unchanged` - HTTPS URLs unchanged\n4. `generates asset manifest in ctx.data` - Creates asset-manifest with assets array\n5. `handles files with no asset references` - Returns unchanged content\n6. `handles multiple assets in one file` - Processes multiple assets in same file\n7. `asset manifest includes all discovered assets` - Accumulates assets across files\n8. `does not double-process already-rewritten URLs` - Skips `/assets/` URLs\n\n**Hook:** `transformContent`\n- Finds and rewrites relative URLs (src, href attributes)\n- Builds asset manifest in `ctx.data.set('asset-manifest', { assets: string[] })`\n\n---\n\n#### **C. /workspace/tests/plugins/dev-server.test.ts** (95 lines)\n\n**Plugin: dev-server**\n- **Name:** `dev-server`\n- **Dependencies:** asset-pipeline, search-index (Wave 3)\n- **Purpose:** Generate dev server configuration\n\n**8 Test Cases:**\n1. `stores dev-server-config in ctx.data` - Creates config object\n2. `config includes port setting` - Default port 3000\n3. `config includes asset routes from asset-pipeline` - Reads asset-manifest\n4. `config includes search index path` - Detects search-index.json\n5. `config includes content routes` - Lists HTML files as routes\n6. `default port is 3000` - Validates default port\n7. `handles missing asset-pipeline data gracefully` - Empty assetPaths if no manifest\n8. (Implicit validation of DevServerConfig interface structure)\n\n**Hook:** `afterBuild`\n- Creates `ctx.data.set('dev-server-config', config)`\n- Config structure:\n  ```typescript\n  {\n    port: number;\n    routes: Array<{ path: string; handler: string }>;\n    assetPaths: string[];\n    searchIndexPath: string;\n  }\n  ```\n\n---\n\n#### **D. /workspace/tests/plugins/markdown-ext.test.ts** (90 lines)\n\n**Plugin: markdown-ext**\n- **Name:** `markdown-ext`\n- **Dependencies:** None (Wave 1)\n- **Purpose:** Convert Markdown to HTML with footnotes and admonition containers\n\n**8 Test Cases:**\n1. `converts basic markdown to HTML` - Headers, bold text\n2. `handles footnotes with [^1] syntax` - Converts to `<sup><a href=\"#fn-1\">1</a></sup>`\n3. `renders footnote section at bottom of content` - `<section class=\"footnotes\">` with footnote list\n4. `converts :::note container to admonition div` - `<div class=\"admonition admonition-note\">`\n5. `converts :::warning container to admonition div` - `<div class=\"admonition admonition-warning\">`\n6. `converts :::tip container to admonition div` - `<div class=\"admonition admonition-tip\">`\n7. `preserves existing HTML in content` - Mixed HTML/markdown\n8. `handles empty content` - Returns defined c