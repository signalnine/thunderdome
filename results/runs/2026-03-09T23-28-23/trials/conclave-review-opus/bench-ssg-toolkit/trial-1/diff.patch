st', { assets: ['image.png', 'style.css'] });\n    53→    const ctx = makeCtx(new Map(), data);\n    54→    await plugin.hooks.afterBuild!(ctx);\n    55→    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    56→    expect(config.assetPaths).toContain('image.png');\n    57→    expect(config.assetPaths).toContain('style.css');\n    58→    const assetRoutes = config.routes.filter(r => r.handler === 'asset');\n    59→    expect(assetRoutes.length).toBeGreaterThanOrEqual(2);\n    60→  });\n    61→\n    62→  it('config includes search index path', async () => {\n    63→    const output = new Map<string, string>();\n    64→    output.set('search-index.json', '[]');\n    65→    const ctx = makeCtx(output);\n    66→    await plugin.hooks.afterBuild!(ctx);\n    67→    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    68→    expect(config.searchIndexPath).toBe('/search-index.json');\n    69→  });\n    70→\n    71→  it('config includes content routes', async () => {\n    72→    const output = new Map<string, string>();\n    73→    output.set('post-1.html', '<html></html>');\n    74→    output.set('post-2.html', '<html></html>');\n    75→    const ctx = makeCtx(output);\n    76→    await plugin.hooks.afterBuild!(ctx);\n    77→    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    78→    const contentRoutes = config.routes.filter(r => r.handler === 'static');\n    79→    expect(contentRoutes.length).toBe(2);\n    80→  });\n    81→\n    82→  it('default port is 3000', async () => {\n    83→    const ctx = makeCtx();\n    84→    await plugin.hooks.afterBuild!(ctx);\n    85→    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    86→    expect(config.port).toBe(3000);\n    87→  });\n    88→\n    89→  it('handles missing asset-pipeline data gracefully', async () => {\n    90→    const ctx = makeCtx();\n    91→    await plugin.hooks.afterBuild!(ctx);\n    92→    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    93→    expect(config.assetPaths).toEqual([]);\n    94→  });\n    95→});\n    96→"}]},"parent_tool_use_id":"toolu_01NJh44qmUPUxNHXeKU4yaDQ","session_id":"f65b5497-b408-4c6b-885d-7c400d283f02","uuid":"83480a89-8355-4ab9-9bac-8e102f275d0a"}
