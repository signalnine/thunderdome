le>\n    <link>${config.baseUrl}</link>\n    <description>${config.title} RSS Feed</description>\n${items}\n  </channel>\n</rss>`;\n\n        ctx.output.set('feed.xml', rss);\n      },\n    },\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":396,"cache_read_input_tokens":40488,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":396},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"f65b5497-b408-4c6b-885d-7c400d283f02","uuid":"c7587c87-58c0-4a16-9c9d-d49e7bf387b3"}
