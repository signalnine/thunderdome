+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018y8mSdRusY3gRogB6cApmN","type":"tool_result","content":"     1→import { Router, Response } from \"express\";\n     2→import Database from \"better-sqlite3\";\n     3→import { AuthenticatedRequest, authMiddleware } from \"../auth.js\";\n     4→\n     5→interface EventRow {\n     6→  id: string;\n     7→  tenant_id: string;\n     8→  name: string;\n     9→  properties: string;\n    10→  timestamp: string;\n    11→  user_id: string | null;\n    12→  session_id: string | null;\n    13→}\n    14→\n    15→interface DashboardRow {\n    16→  id: string;\n    17→  tenant_id: string;\n    18→  name: string;\n    19→  owner_id: string;\n    20→  config: string;\n    21→  created_at: string;\n    22→  updated_at: string;\n    23→}\n    24→\n    25→function escapeCsvValue(value: string): string {\n    26→  if (value.includes(\",\") || value.includes('\"') || value.includes(\"\\n\")) {\n    27→    return `\"${value.replace(/\"/g, '\"\"')}\"`;\n    28→  }\n    29→  return value;\n    30→}\n    31→\n    32→function eventsToCsv(events: EventRow[]): string {\n    33→  const headers = [\"id\", \"name\", \"properties\", \"timestamp\", \"user_id\", \"session_id\"];\n    34→  const lines = [headers.join(\",\")];\n    35→\n    36→  for (const event of events) {\n    37→    const row = [\n    38→      escapeCsvValue(event.id),\n    39→      escapeCsvValue(event.name),\n    40→      escapeCsvValue(event.properties),\n    41→      escapeCsvValue(event.timestamp),\n    42→      escapeCsvValue(event.user_id || \"\"),\n    43→      escapeCsvValue(event.session_id || \"\"),\n    44→    ];\n    45→    lines.push(row.join(\",\"));\n    46→  }\n    47→\n    48→  return lines.join(\"\\n\");\n    49→}\n    50→\n    51→function dashboardsToCsv(dashboards: DashboardRow[]): string {\n    52→  const headers = [\"id\", \"name\", \"owner_id\", \"config\", \"created_at\", \"updated_at\"];\n    53→  const lines = [headers.join(\",\")];\n    54→\n    55→  for (const dash of dashboards) {\n    56→    const row = [\n    57→      escapeCsvValue(dash.id),\n    58→      escapeCsvValue(dash.name),\n    59→      escapeCsvValue(dash.owner_id),\n    60→      escapeCsvValue(dash.config),\n    61→      escapeCsvValue(dash.created_at),\n    62→      escapeCsvValue(dash.updated_at),\n    63→    ];\n    64→    lines.push(row.join(\",\"));\n    65→  }\n    66→\n    67→  return lines.join(\"\\n\");\n    68→}\n    69→\n    70→export function createExportRoutes(db: Database.Database): Router {\n    71→  const router = Router();\n    72→\n    73→  // Export events\n    74→  router.get(\"/export/events\", authMiddleware, (req: AuthenticatedRequest, res: Response) => {\n    75→    const format = (req.query.format as string) || \"json\";\n    76→    const eventName = req.query.eventName as string | undefined;\n    77→\n    78→    let query = \"SELECT * FROM events WHERE tenant_id = ?\";\n    79→    const params: unknown[] = [req.user!.tenantId];\n    80→\n    81→    if (eventName) {\n    82→      query += \" AND name = ?\";\n    83→      params.push(eventName);\n    84→    }\n    85→\n    86→    query += \" ORDER BY timestamp DESC\";\n    87→\n    88→    const events = db.prepare(query).all(...params) as EventRow[];\n    89→\n    90→    if (format === \"csv\") {\n    91→      res.setHeader(\"Content-Type\", \"text/csv\");\n    92→      res.setHeader(\"Content-Disposition\", \"attachment; filename=events.csv\");\n    93→      res.send(eventsToCsv(events));\n    94→    } else {\n    95→      res.json({\n    96→        events: events.map((e) => ({\n    97→          id: e.id,\n    98→          name: e.name,\n    99→          properties: JSON.parse(e.properties),\n   100→          timestamp: e.timestamp,\n   101→          userId: e.user_id,\n   102→          sessionId: e.session_id,\n   103→        })),\n   104→      });\n   105→    }\n   106→  });\n   107→\n   108→  // Export dashboards\n   109→  router.get(\"/export/dashboards\", authMiddleware, (req: AuthenticatedRequest, res: Response) => {\n   110→    const format = (req.query.format as string) || \"json\";\n   111→\n   112→    const dashboards = db\n   113→      .prepare(\"SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC\")\n   114→      .all(req.user!.tenantId) as DashboardRow[];\n   115→\n   116→    if (format === \"csv\") {\n   117→      res.setHeader(\"Content-Type\", \"text/csv\");\n   118→      res.setHeader(\"Content-Disposition\", \"attachment; filename=dashboards.csv\");\n   119→      res.send(dashboardsToCsv(dashboards));\n   120→    } else {\n   121→      res.json({\n   122→        dashboards: dashboards.map((d) => ({\n   123→          id: d.id,\n   124→          name: d.name,\n   125→          ownerId: d.owner_id,\n   126→          config: JSON.parse(d.config),\n   127→          createdAt: d.created_at,\n   128→          updatedAt: d.updated_at,\n   129→        })),\n   130→      });\n   131→    }\n   132→  });\n   133→\n   134→  return router;\n   135→}\n   136→"}]},"parent_tool_use_id":"toolu_01FiyYocY51eRkiU1NVfk9wB","session_id":"00b4f704-3a54-431d-8967-3003562af3d1","uuid":"b5c2d337-1300-488b-97a9-5820ab24c2db"}
