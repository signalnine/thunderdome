+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011xFP4qnWAuKnyxqxY3i2Db","type":"tool_result","content":"     1→import { Request, Response, NextFunction } from \"express\";\n     2→import jwt from \"jsonwebtoken\";\n     3→\n     4→const JWT_SECRET = process.env.JWT_SECRET || \"analytics-dashboard-secret\";\n     5→\n     6→export interface JwtPayload {\n     7→  userId: string;\n     8→  email: string;\n     9→  tenantId: string;\n    10→  role: string;\n    11→}\n    12→\n    13→export interface AuthenticatedRequest extends Request {\n    14→  user?: JwtPayload;\n    15→}\n    16→\n    17→export function signToken(payload: JwtPayload): string {\n    18→  return jwt.sign(payload, JWT_SECRET, { expiresIn: \"24h\" });\n    19→}\n    20→\n    21→export function verifyToken(token: string): JwtPayload {\n    22→  return jwt.verify(token, JWT_SECRET) as JwtPayload;\n    23→}\n    24→\n    25→export function authMiddleware(\n    26→  req: AuthenticatedRequest,\n    27→  res: Response,\n    28→  next: NextFunction\n    29→): void {\n    30→  const authHeader = req.headers.authorization;\n    31→  if (!authHeader || !authHeader.startsWith(\"Bearer \")) {\n    32→    res.status(401).json({ error: \"Authentication required\" });\n    33→    return;\n    34→  }\n    35→\n    36→  const token = authHeader.slice(7);\n    37→  try {\n    38→    const payload = verifyToken(token);\n    39→    req.user = payload;\n    40→    next();\n    41→  } catch {\n    42→    res.status(401).json({ error: \"Invalid or expired token\" });\n    43→  }\n    44→}\n    45→"}]},"parent_tool_use_id":"toolu_01FiyYocY51eRkiU1NVfk9wB","session_id":"00b4f704-3a54-431d-8967-3003562af3d1","uuid":"a2bb9ce1-95c3-4160-ac45-45fdce853caa"}
