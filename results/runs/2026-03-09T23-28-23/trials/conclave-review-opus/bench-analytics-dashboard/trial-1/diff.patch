+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014vgKEzSe1CvDQgAHUbn3ag","type":"tool_result","content":"     1→import { Router, Response } from \"express\";\n     2→import Database from \"better-sqlite3\";\n     3→import { v4 as uuidv4 } from \"uuid\";\n     4→import { AuthenticatedRequest, authMiddleware } from \"../auth.js\";\n     5→\n     6→interface DashboardRow {\n     7→  id: string;\n     8→  tenant_id: string;\n     9→  name: string;\n    10→  owner_id: string;\n    11→  config: string;\n    12→  created_at: string;\n    13→  updated_at: string;\n    14→}\n    15→\n    16→export function createDashboardRoutes(db: Database.Database): Router {\n    17→  const router = Router();\n    18→\n    19→  // Create dashboard\n    20→  router.post(\"/dashboards\", authMiddleware, (req: AuthenticatedRequest, res: Response) => {\n    21→    const { name, config } = req.body;\n    22→    if (!name) {\n    23→      res.status(400).json({ error: \"Dashboard name is required\" });\n    24→      return;\n    25→    }\n    26→\n    27→    const id = uuidv4();\n    28→    const now = new Date().toISOString();\n    29→    const dashConfig = JSON.stringify(config || {});\n    30→\n    31→    db.prepare(\n    32→      \"INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)\"\n    33→    ).run(id, req.user!.tenantId, name, req.user!.userId, dashConfig, now, now);\n    34→\n    35→    res.status(201).json({\n    36→      id,\n    37→      tenantId: req.user!.tenantId,\n    38→      name,\n    39→      ownerId: req.user!.userId,\n    40→      config: config || {},\n    41→      createdAt: now,\n    42→      updatedAt: now,\n    43→    });\n    44→  });\n    45→\n    46→  // List dashboards for tenant\n    47→  router.get(\"/dashboards\", authMiddleware, (req: AuthenticatedRequest, res: Response) => {\n    48→    const rows = db\n    49→      .prepare(\"SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC\")\n    50→      .all(req.user!.tenantId) as DashboardRow[];\n    51→\n    52→    const dashboards = rows.map((row) => ({\n    53→      id: row.id,\n    54→      tenantId: row.tenant_id,\n    55→      name: row.name,\n    56→      ownerId: row.owner_id,\n    57→      config: JSON.parse(row.config),\n    58→      createdAt: row.created_at,\n    59→      updatedAt: row.updated_at,\n    60→    }));\n    61→\n    62→    res.json({ dashboards });\n    63→  });\n    64→\n    65→  // Get single dashboard\n    66→  router.get(\"/dashboards/:id\", authMiddleware, (req: AuthenticatedRequest, res: Response) => {\n    67→    const row = db\n    68→      .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n    69→      .get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;\n    70→\n    71→    if (!row) {\n    72→      res.status(404).json({ error: \"Dashboard not found\" });\n    73→      return;\n    74→    }\n    75→\n    76→    res.json({\n    77→      id: row.id,\n    78→      tenantId: row.tenant_id,\n    79→      name: row.name,\n    80→      ownerId: row.owner_id,\n    81→      config: JSON.parse(row.config),\n    82→      createdAt: row.created_at,\n    83→      updatedAt: row.updated_at,\n    84→    });\n    85→  });\n    86→\n    87→  // Update dashboard\n    88→  router.put(\"/dashboards/:id\", authMiddleware, (req: AuthenticatedRequest, res: Response) => {\n    89→    const existing = db\n    90→      .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n    91→      .get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;\n    92→\n    93→    if (!existing) {\n    94→      res.status(404).json({ error: \"Dashboard not found\" });\n    95→      return;\n    96→    }\n    97→\n    98→    const name = req.body.name || existing.name;\n    99→    const config = req.body.config !== undefined ? JSON.stringify(req.body.config) : existing.config;\n   100→    const now = new Date().toISOString();\n   101→\n   102→    db.prepare(\"UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?\").run(\n   103→      name,\n   104→      config,\n   105→      now,\n   106→      req.params.id\n   107→    );\n   108→\n   109→    res.json({\n   110→      id: existing.id,\n   111→      tenantId: existing.tenant_id,\n   112→      name,\n   113→      ownerId: existing.owner_id,\n   114→      config: JSON.parse(config),\n   115→      createdAt: existing.created_at,\n   116→      updatedAt: now,\n   117→    });\n   118→  });\n   119→\n   120→  // Delete dashboard\n   121→  router.delete(\"/dashboards/:id\", authMiddleware, (req: AuthenticatedRequest, res: Response) => {\n   122→    const existing = db\n   123→      .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n   124→      .get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;\n   125→\n   126→    if (!existing) {\n   127→      res.status(404).json({ error: \"Dashboard not found\" });\n   128→      return;\n   129→    }\n   130→\n   131→    db.prepare(\"DELETE FROM dashboards WHERE id = ?\").run(req.params.id);\n   132→    res.json({ message: \"Dashboard deleted\" });\n   133→  });\n   134→\n   135→  return router;\n   136→}\n   137→"}]},"parent_tool_use_id":"toolu_01FiyYocY51eRkiU1NVfk9wB","session_id":"00b4f704-3a54-431d-8967-3003562af3d1","uuid":"4cddd98d-f0a8-4098-a331-4caf92c6ed21"}
