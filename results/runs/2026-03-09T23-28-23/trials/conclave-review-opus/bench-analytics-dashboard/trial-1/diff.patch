+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Jng37HUcwxV2cMKMLGML2Z","type":"tool_result","content":"     1→import { Router, Response } from \"express\";\n     2→import Database from \"better-sqlite3\";\n     3→import { AuthenticatedRequest, authMiddleware } from \"../auth.js\";\n     4→\n     5→interface QueryFilter {\n     6→  eventName?: string;\n     7→  startDate?: string;\n     8→  endDate?: string;\n     9→}\n    10→\n    11→function buildWhereClause(\n    12→  tenantId: string,\n    13→  filters: QueryFilter\n    14→): { clause: string; params: unknown[] } {\n    15→  const conditions: string[] = [\"tenant_id = ?\"];\n    16→  const params: unknown[] = [tenantId];\n    17→\n    18→  if (filters.eventName) {\n    19→    conditions.push(\"name = ?\");\n    20→    params.push(filters.eventName);\n    21→  }\n    22→\n    23→  if (filters.startDate) {\n    24→    conditions.push(\"timestamp >= ?\");\n    25→    params.push(filters.startDate);\n    26→  }\n    27→\n    28→  if (filters.endDate) {\n    29→    conditions.push(\"timestamp <= ?\");\n    30→    params.push(filters.endDate);\n    31→  }\n    32→\n    33→  return { clause: conditions.join(\" AND \"), params };\n    34→}\n    35→\n    36→export function createQueryRoutes(db: Database.Database): Router {\n    37→  const router = Router();\n    38→\n    39→  // Count query\n    40→  router.post(\"/queries/count\", authMiddleware, (req: AuthenticatedRequest, res: Response) => {\n    41→    const filters: QueryFilter = req.body;\n    42→    const { clause, params } = buildWhereClause(req.user!.tenantId, filters);\n    43→\n    44→    const result = db\n    45→      .prepare(`SELECT COUNT(*) as count FROM events WHERE ${clause}`)\n    46→      .get(...params) as { count: number } | undefined;\n    47→\n    48→    res.json({ count: result?.count ?? 0 });\n    49→  });\n    50→\n    51→  // Timeseries query\n    52→  router.post(\"/queries/timeseries\", authMiddleware, (req: AuthenticatedRequest, res: Response) => {\n    53→    const { interval, ...filters } = req.body as QueryFilter & { interval?: string };\n    54→    const { clause, params } = buildWhereClause(req.user!.tenantId, filters);\n    55→\n    56→    let dateFormat: string;\n    57→    switch (interval) {\n    58→      case \"hour\":\n    59→        dateFormat = \"%Y-%m-%dT%H:00:00\";\n    60→        break;\n    61→      case \"month\":\n    62→        dateFormat = \"%Y-%m-01\";\n    63→        break;\n    64→      case \"day\":\n    65→      default:\n    66→        dateFormat = \"%Y-%m-%d\";\n    67→        break;\n    68→    }\n    69→\n    70→    const rows = db\n    71→      .prepare(\n    72→        `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count\n    73→         FROM events WHERE ${clause}\n    74→         GROUP BY bucket ORDER BY bucket`\n    75→      )\n    76→      .all(...params) as Array<{ bucket: string; count: number }>;\n    77→\n    78→    res.json({ timeseries: rows });\n    79→  });\n    80→\n    81→  // Breakdown query\n    82→  router.post(\"/queries/breakdown\", authMiddleware, (req: AuthenticatedRequest, res: Response) => {\n    83→    const { property, ...filters } = req.body as QueryFilter & { property?: string };\n    84→\n    85→    if (!property) {\n    86→      res.status(400).json({ error: \"property is required for breakdown queries\" });\n    87→      return;\n    88→    }\n    89→\n    90→    const { clause, params } = buildWhereClause(req.user!.tenantId, filters);\n    91→\n    92→    const rows = db\n    93→      .prepare(\n    94→        `SELECT json_extract(properties, '$.' || ?) as value, COUNT(*) as count\n    95→         FROM events WHERE ${clause}\n    96→         GROUP BY value ORDER BY count DESC`\n    97→      )\n    98→      .all(property, ...params) as Array<{ value: string | null; count: number }>;\n    99→\n   100→    res.json({ breakdown: rows });\n   101→  });\n   102→\n   103→  return router;\n   104→}\n   105→"}]},"parent_tool_use_id":"toolu_01FiyYocY51eRkiU1NVfk9wB","session_id":"00b4f704-3a54-431d-8967-3003562af3d1","uuid":"243c62c1-785a-45ca-8abb-f291c836da09"}
