 event of events) {\n        if (!event.name) continue;\n        const id = uuidv4();\n        const eventTimestamp = event.timestamp || new Date().toISOString();\n        const eventProperties = JSON.stringify(event.properties || {});\n        insertStmt.run(\n          id,\n          req.user!.tenantId,\n          event.name,\n          eventProperties,\n          eventTimestamp,\n          req.user!.userId,\n          event.sessionId || null\n        );\n        results.push({ id, name: event.name });\n      }\n    });\n\n    insertAll();\n    res.status(201).json({ inserted: results.length, events: results });\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":323,"cache_read_input_tokens":23520,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":323},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"00b4f704-3a54-431d-8967-3003562af3d1","uuid":"2724deae-8dc0-4462-8b2a-2aa4259fe760"}
