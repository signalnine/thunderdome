+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { v4 as uuidv4 } from "uuid";
+import { AuthenticatedRequest, authMiddleware } from "../auth.js";
+
+export function createEventRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Ingest single event
+  router.post("/events", authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+    const { name, properties, timestamp, sessionId } = req.body;
+    if (!name) {
+      res.status(400).json({ error: "Event name is required" });
+      return;
+    }
+
+    const id = uuidv4();
+    const eventTimestamp = timestamp || new Date().toISOString();
+    const eventProperties = JSON.stringify(properties || {});
+
+    db.prepare(
+      "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    ).run(id, req.user!.tenantId, name, eventProperties, eventTimestamp, req.user!.userId, sessionId || null);
+
+    res.status(201).json({ id, name, tenantId: req.user!.tenantId, timestamp: eventTimestamp });
+  });
+
+  // Ingest batch events
+  router.post("/events/batch", authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+    const { events } = req.body;
+    if (!Array.isArray(events) || events.length === 0) {
+      res.status(400).json({ error: "events array is required" });
+      return;
+    }
+
+    const insertStmt = db.prepare(
+      "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    );
+
+    const results: Array<{ id: string; name: string }> = [];
+
+    const insertAll = db.transaction(() => {
+      for (const event of events) {
+        if (!event.name) continue;
+        const id = uuidv4();
+        const eventTimestamp = event.timestamp || new Date().toISOString();
+        const eventProperties = JSON.stringify(event.properties || {});
+        insertStmt.run(
+          id,
+          req.user!.tenantId,
+          event.name,
+          eventProperties,
+          eventTimestamp,
+          req.user!.userId,
+          event.sessionId || null
+        );
+        results.push({ id, name: event.name });
+      }
+    });
+
+    insertAll();
+    res.status(201).json({ inserted: results.length, events: results });
+  });
+
+  return router;
+}
diff --git a/src/routes/exports.ts b/src/routes/exports.ts
new file mode 100644
index 0000000..99c25f3
--- /dev/null
+++ b/src/routes/exports.ts
@@ -0,0 +1,135 @@
+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { AuthenticatedRequest, authMiddleware } from "../auth.js";
+
+interface EventRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string | null;
+  session_id: string | null;
+}
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+function escapeCsvValue(value: string): string {
+  if (value.includes(",") || value.includes('"') || value.includes("\n")) {
+    return `"${value.replace(/"/g, '""')}"`;
+  }
+  return value;
+}
+
+function eventsToCsv(events: EventRow[]): string {
+  const headers = ["id", "name", "properties", "timestamp", "user_id", "session_id"];
+  const lines = [headers.join(",")];
+
+  for (const event of events) {
+    const row = [
+      escapeCsvValue(event.id),
+      escapeCsvValue(event.name),
+      escapeCsvValue(event.properties),
+      escapeCsvValue(event.timestamp),
+      escapeCsvValue(event.user_id || ""),
+      escapeCsvValue(event.session_id || ""),
+    ];
+    lines.push(row.join(","));
+  }
+
+  return lines.join("\n");
+}
+
+function dashboardsToCsv(dashboards: DashboardRow[]): string {
+  const headers = ["id", "name", "owner_id", "config", "created_at", "updated_at"];
+  const lines = [headers.join(",")];
+
+  for (const dash of dashboards) {
+    const row = [
+      escapeCsvValue(dash.id),
+      escapeCsvValue(dash.name),
+      escapeCsvValue(dash.owner_id),
+      escapeCsvValue(dash.config),
+      escapeCsvValue(dash.created_at),
+      escapeCsvValue(dash.updated_at),
+    ];
+    lines.push(row.join(","));
+  }
+
+  return lines.join("\n");
+}
+
+export function createExportRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Export events
+  router.get("/export/events", authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+    const format = (req.query.format as string) || "json";
+    const eventName = req.query.eventName as string | undefined;
+
+    let query = "SELECT * FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [req.user!.tenantId];
+
+    if (eventName) {
+      query += " AND name = ?";
+      params.push(eventName);
+    }
+
+    query += " ORDER BY timestamp DESC";
+
+    const events = db.prepare(query).all(...params) as EventRow[];
+
+    if (format === "csv") {
+      res.setHeader("Content-Type", "text/csv");
+      res.setHeader("Content-Disposition", "attachment; filename=events.csv");
+      res.send(eventsToCsv(events));
+    } else {
+      res.json({
+        events: events.map((e) => ({
+          id: e.id,
+          name: e.name,
+          properties: JSON.parse(e.properties),
+          timestamp: e.timestamp,
+          userId: e.user_id,
+          sessionId: e.session_id,
+        })),
+      });
+    }
+  });
+
+  // Export dashboards
+  router.get("/export/dashboards", authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+    const format = (req.query.format as string) || "json";
+
+    const dashboards = db
+      .prepare("SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC")
+      .all(req.user!.tenantId) as DashboardRow[];
+
+    if (format === "csv") {
+      res.setHeader("Content-Type", "text/csv");
+      res.setHeader("Content-Disposition", "attachment; filename=dashboards.csv");
+      res.send(dashboardsToCsv(dashboards));
+    } else {
+      res.json({
+        dashboards: dashboards.map((d) => ({
+          id: d.id,
+          name: d.name,
+          ownerId: d.owner_id,
+          config: JSON.parse(d.config),
+          createdAt: d.created_at,
+          updatedAt: d.updated_at,
+        })),
+      });
+    }
+  });
+
+  return router;
+}
diff --git a/src/routes/queries.ts b/src/routes/queries.ts
new file mode 100644
index 0000000..e98931d
--- /dev/null
+++ b/src/routes/queries.ts
@@ -0,0 +1,97 @@
+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { AuthenticatedRequest, authMiddleware } from "../auth.js";
+
+interface QueryFilter {
+  eventName?: string;
+  startDate?: string;
+  endDate?: string;
+}
+
+function buildWhereClause(
+  tenantId: string,
+  filters: QueryFilter
+): { clause: string; params: unknown[] } {
+  const conditions: string[] = ["tenant_id = ?"];
+  const params: unknown[] = [tenantId];
+
+  if (filters.eventName) {
+    conditions.push("name = ?");
+    params.push(filters.eventName);
+  }
+
+  if (filters.startDate) {
+    conditions.push("timestamp >= ?");
+    params.push(filters.startDate);
+  }
+
+  if (filters.endDate) {
+    conditions.push("timestamp <= ?");
+    params.push(filters.endDate);
+  }
+
+  return { clause: conditions.join(" AND "), params };
+}
+
+export function createQueryRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Count query
+  router.post("/queries/count", authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+    const filters: QueryFilter = req.body;
+    const { clause, params } = buildWhereClause(req.user!.tenantId, filters);
+
+    const result = db
+      .prepare(`SELECT COUNT(*) as count FROM events WHERE ${clause}`)
+      .get(...params) as { count: number } | undefined;
+
+    res.json({ count: result?.count ?? 0 });
+  });
+
+  // Timeseries query
+  router.post("/queries/timeseries", authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+    const { interval, ...filters } = req.body as QueryFilter & { interval?: string };
+    const { clause, params } = buildWhereClause(req.user!.tenantId, filters);
+
+    const ALLOWED_FORMATS: Record<string, string> = {
+      hour: "%Y-%m-%dT%H:00:00",
+      month: "%Y-%m-01",
+      day: "%Y-%m-%d",
+    };
+    const dateFormat = ALLOWED_FORMATS[interval as string] ?? ALLOWED_FORMATS["day"];
+
+    const rows = db
+      .prepare(
+        `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count
+         FROM events WHERE ${clause}
+         GROUP BY bucket ORDER BY bucket`
+      )
+      .all(...params) as Array<{ bucket: string; count: number }>;
+
+    res.json({ timeseries: rows });
+  });
+
+  // Breakdown query
+  router.post("/queries/breakdown", authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+    const { property, ...filters } = req.body as QueryFilter & { property?: string };
+
+    if (!property) {
+      res.status(400).json({ error: "property is required for breakdown queries" });
+      return;
+    }
+
+    const { clause, params } = buildWhereClause(req.user!.tenantId, filters);
+
+    const rows = db
+      .prepare(
+        `SELECT json_extract(properties, '$.' || ?) as value, COUNT(*) as count
+         FROM events WHERE ${clause}
+         GROUP BY value ORDER BY count DESC`
+      )
+      .all(property, ...params) as Array<{ value: string | null; count: number }>;
+
+    res.json({ breakdown: rows });
+  });
+
+  return router;
+}
