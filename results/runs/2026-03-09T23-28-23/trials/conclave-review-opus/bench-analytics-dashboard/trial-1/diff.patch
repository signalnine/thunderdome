+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013yJpY2LnDp9TPcKkzmd3br","type":"tool_result","content":"     1→import { Router, Response } from \"express\";\n     2→import Database from \"better-sqlite3\";\n     3→import { v4 as uuidv4 } from \"uuid\";\n     4→import * as crypto from \"node:crypto\";\n     5→import { AuthenticatedRequest, authMiddleware, signToken } from \"../auth.js\";\n     6→\n     7→function hashPassword(password: string): string {\n     8→  return crypto.createHash(\"sha256\").update(password).digest(\"hex\");\n     9→}\n    10→\n    11→export function createUserRoutes(db: Database.Database): Router {\n    12→  const router = Router();\n    13→\n    14→  // Register\n    15→  router.post(\"/auth/register\", (req: AuthenticatedRequest, res: Response) => {\n    16→    const { email, password, tenantId, role } = req.body;\n    17→    if (!email || !password || !tenantId) {\n    18→      res.status(400).json({ error: \"email, password, and tenantId are required\" });\n    19→      return;\n    20→    }\n    21→\n    22→    const userRole = role && [\"admin\", \"viewer\", \"editor\"].includes(role) ? role : \"viewer\";\n    23→    const id = uuidv4();\n    24→    const passwordHash = hashPassword(password);\n    25→\n    26→    try {\n    27→      db.prepare(\n    28→        \"INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)\"\n    29→      ).run(id, email, passwordHash, tenantId, userRole);\n    30→\n    31→      const token = signToken({ userId: id, email, tenantId, role: userRole });\n    32→      res.status(201).json({ id, email, tenantId, role: userRole, token });\n    33→    } catch (err: unknown) {\n    34→      if (err instanceof Error && err.message.includes(\"UNIQUE\")) {\n    35→        res.status(409).json({ error: \"Email already registered\" });\n    36→      } else {\n    37→        res.status(500).json({ error: \"Internal server error\" });\n    38→      }\n    39→    }\n    40→  });\n    41→\n    42→  // Login\n    43→  router.post(\"/auth/login\", (req: AuthenticatedRequest, res: Response) => {\n    44→    const { email, password } = req.body;\n    45→    if (!email || !password) {\n    46→      res.status(400).json({ error: \"email and password are required\" });\n    47→      return;\n    48→    }\n    49→\n    50→    const user = db.prepare(\"SELECT * FROM users WHERE email = ?\").get(email) as\n    51→      | { id: string; email: string; password_hash: string; tenant_id: string; role: string }\n    52→      | undefined;\n    53→\n    54→    if (!user || user.password_hash !== hashPassword(password)) {\n    55→      res.status(401).json({ error: \"Invalid credentials\" });\n    56→      return;\n    57→    }\n    58→\n    59→    const token = signToken({\n    60→      userId: user.id,\n    61→      email: user.email,\n    62→      tenantId: user.tenant_id,\n    63→      role: user.role,\n    64→    });\n    65→    res.json({ token, user: { id: user.id, email: user.email, tenantId: user.tenant_id, role: user.role } });\n    66→  });\n    67→\n    68→  // Get profile\n    69→  router.get(\"/auth/profile\", authMiddleware, (req: AuthenticatedRequest, res: Response) => {\n    70→    const user = db.prepare(\"SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?\").get(\n    71→      req.user!.userId\n    72→    ) as { id: string; email: string; tenant_id: string; role: string; created_at: string } | undefined;\n    73→\n    74→    if (!user) {\n    75→      res.status(404).json({ error: \"User not found\" });\n    76→      return;\n    77→    }\n    78→\n    79→    res.json({\n    80→      id: user.id,\n    81→      email: user.email,\n    82→      tenantId: user.tenant_id,\n    83→      role: user.role,\n    84→      createdAt: user.created_at,\n    85→    });\n    86→  });\n    87→\n    88→  // Update user role (admin only)\n    89→  router.put(\"/auth/users/:userId/role\", authMiddleware, (req: AuthenticatedRequest, res: Response) => {\n    90→    if (req.user!.role !== \"admin\") {\n    91→      res.status(403).json({ error: \"Only admins can change roles\" });\n    92→      return;\n    93→    }\n    94→\n    95→    const { role } = req.body;\n    96→    if (!role || ![\"admin\", \"viewer\", \"editor\"].includes(role)) {\n    97→      res.status(400).json({ error: \"Valid role is required (admin, viewer, editor)\" });\n    98→      return;\n    99→    }\n   100→\n   101→    const targetUser = db.prepare(\"SELECT * FROM users WHERE id = ?\").get(req.params.userId) as\n   102→      | { id: string; tenant_id: string }\n   103→      | undefined;\n   104→\n   105→    if (!targetUser) {\n   106→      res.status(404).json({ error: \"User not found\" });\n   107→      return;\n   108→    }\n   109→\n   110→    if (targetUser.tenant_id !== req.user!.tenantId) {\n   111→      res.status(403).json({ error: \"Cannot modify users in other tenants\" });\n   112→      return;\n   113→    }\n   114→\n   115→    db.prepare(\"UPDATE users SET role = ? WHERE id = ?\").run(role, req.params.userId);\n   116→    res.json({ message: \"Role updated\", userId: req.params.userId, role });\n   117→  });\n   118→\n   119→  return router;\n   120→}\n   121→"}]},"parent_tool_use_id":"toolu_01FiyYocY51eRkiU1NVfk9wB","session_id":"00b4f704-3a54-431d-8967-3003562af3d1","uuid":"c6b7fdbb-ad43-4e66-8fbf-44ad5440f1ce"}
