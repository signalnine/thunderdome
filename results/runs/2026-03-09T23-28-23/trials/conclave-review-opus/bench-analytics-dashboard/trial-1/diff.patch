+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { v4 as uuidv4 } from "uuid";
+import { AuthenticatedRequest, authMiddleware } from "../auth.js";
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export function createDashboardRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Create dashboard
+  router.post("/dashboards", authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+    const { name, config } = req.body;
+    if (!name) {
+      res.status(400).json({ error: "Dashboard name is required" });
+      return;
+    }
+
+    const id = uuidv4();
+    const now = new Date().toISOString();
+    const dashConfig = JSON.stringify(config || {});
+
+    db.prepare(
+      "INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    ).run(id, req.user!.tenantId, name, req.user!.userId, dashConfig, now, now);
+
+    res.status(201).json({
+      id,
+      tenantId: req.user!.tenantId,
+      name,
+      ownerId: req.user!.userId,
+      config: config || {},
+      createdAt: now,
+      updatedAt: now,
+    });
+  });
+
+  // List dashboards for tenant
+  router.get("/dashboards", authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+    const rows = db
+      .prepare("SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC")
+      .all(req.user!.tenantId) as DashboardRow[];
+
+    const dashboards = rows.map((row) => ({
+      id: row.id,
+      tenantId: row.tenant_id,
+      name: row.name,
+      ownerId: row.owner_id,
+      config: JSON.parse(row.config),
+      createdAt: row.created_at,
+      updatedAt: row.updated_at,
+    }));
+
+    res.json({ dashboards });
+  });
+
+  // Get single dashboard
+  router.get("/dashboards/:id", authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+    const row = db
+      .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;
+
+    if (!row) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    res.json({
+      id: row.id,
+      tenantId: row.tenant_id,
+      name: row.name,
+      ownerId: row.owner_id,
+      config: JSON.parse(row.config),
+      createdAt: row.created_at,
+      updatedAt: row.updated_at,
+    });
+  });
+
+  // Update dashboard
+  router.put("/dashboards/:id", authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+    const existing = db
+      .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;
+
+    if (!existing) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const name = req.body.name || existing.name;
+    const config = req.body.config !== undefined ? JSON.stringify(req.body.config) : existing.config;
+    const now = new Date().toISOString();
+
+    db.prepare("UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?").run(
+      name,
+      config,
+      now,
+      req.params.id
+    );
+
+    res.json({
+      id: existing.id,
+      tenantId: existing.tenant_id,
+      name,
+      ownerId: existing.owner_id,
+      config: JSON.parse(config),
+      createdAt: existing.created_at,
+      updatedAt: now,
+    });
+  });
+
+  // Delete dashboard
+  router.delete("/dashboards/:id", authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+    const existing = db
+      .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;
+
+    if (!existing) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    db.prepare("DELETE FROM dashboards WHERE id = ?").run(req.params.id);
+    res.json({ message: "Dashboard deleted" });
+  });
+
+  return router;
+}
