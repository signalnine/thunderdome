+    it('should update multiple dependents', () => {
+      sheet.set('A1', 10);
+      sheet.set('B1', '=A1+1');
+      sheet.set('C1', '=A1+2');
+      sheet.set('D1', '=A1+3');
+
+      sheet.set('A1', 100);
+      expect(sheet.get('B1')).toBe(101);
+      expect(sheet.get('C1')).toBe(102);
+      expect(sheet.get('D1')).toBe(103);
+    });
+
+    it('should handle diamond dependencies', () => {
+      sheet.set('A1', 5);
+      sheet.set('B1', '=A1+1');
+      sheet.set('C1', '=A1+2');
+      sheet.set('D1', '=B1+C1');
+      expect(sheet.get('D1')).toBe(13);
+
+      sheet.set('A1', 10);
+      expect(sheet.get('B1')).toBe(11);
+      expect(sheet.get('C1')).toBe(12);
+      expect(sheet.get('D1')).toBe(23);
+    });
+
+    it('should update aggregate functions reactively', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', 30);
+      sheet.set('B1', '=SUM(A1:A3)');
+      expect(sheet.get('B1')).toBe(60);
+
+      sheet.set('A2', 50);
+      expect(sheet.get('B1')).toBe(90);
+    });
+
+    it('should handle overwriting formulas with values', () => {
+      sheet.set('A1', 10);
+      sheet.set('B1', '=A1+5');
+      expect(sheet.get('B1')).toBe(15);
+
+      sheet.set('B1', 99);
+      expect(sheet.get('B1')).toBe(99);
+
+      // Changing A1 should NOT affect B1 anymore
+      sheet.set('A1', 999);
+      expect(sheet.get('B1')).toBe(99);
+    });
+
+    it('should handle overwriting formulas with new formulas', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('B1', '=A1+5');
+      expect(sheet.get('B1')).toBe(15);
+
+      sheet.set('B1', '=A2+5');
+      expect(sheet.get('B1')).toBe(25);
+
+      // Changing A1 should NOT affect B1 anymore
+      sheet.set('A1', 999);
+      expect(sheet.get('B1')).toBe(25);
+
+      // Changing A2 should affect B1
+      sheet.set('A2', 100);
+      expect(sheet.get('B1')).toBe(105);
+    });
+
+    it('should reactively update IF formulas', () => {
+      sheet.set('A1', 50);
+      sheet.set('B1', '=IF(A1>30, "big", "small")');
+      expect(sheet.get('B1')).toBe('big');
+
+      sheet.set('A1', 10);
+      expect(sheet.get('B1')).toBe('small');
+    });
+  });
+
+  describe('circular reference detection', () => {
+    it('should detect direct circular reference', () => {
+      sheet.set('A1', '=B1');
+      expect(() => sheet.set('B1', '=A1')).toThrow(/[Cc]ircular/);
+    });
+
+    it('should detect self-reference', () => {
+      expect(() => sheet.set('A1', '=A1')).toThrow(/[Cc]ircular/);
+    });
+
+    it('should detect indirect circular reference', () => {
+      sheet.set('A1', '=B1');
+      sheet.set('B1', '=C1');
+      expect(() => sheet.set('C1', '=A1')).toThrow(/[Cc]ircular/);
+    });
+
+    it('should allow non-circular references', () => {
+      sheet.set('A1', 10);
+      sheet.set('B1', '=A1');
+      sheet.set('C1', '=B1');
+      expect(sheet.get('C1')).toBe(10);
+    });
+  });
+
+  describe('column references', () => {
+    it('should handle multi-letter columns', () => {
+      sheet.set('AA1', 100);
+      expect(sheet.get('AA1')).toBe(100);
+    });
+
+    it('should handle formulas with multi-letter columns', () => {
+      sheet.set('AA1', 10);
+      sheet.set('AB1', 20);
+      sheet.set('AC1', '=AA1+AB1');
+      expect(sheet.get('AC1')).toBe(30);
+    });
+
+    it('should handle ranges with multi-letter columns', () => {
+      sheet.set('AA1', 1);
+      sheet.set('AB1', 2);
+      sheet.set('AC1', 3);
+      sheet.set('AD1', '=SUM(AA1:AC1)');
+      expect(sheet.get('AD1')).toBe(6);
+    });
+  });
+
+  describe('example from spec', () => {
+    it('should handle the complete example', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.get('A3')).toBe(30);
+      expect(sheet.getDisplay('A3')).toBe('30');
+
+      sheet.set('A1', 50);
+      expect(sheet.get('A3')).toBe(70);
+
+      sheet.set('B1', '=SUM(A1:A2)');
+      expect(sheet.get('B1')).toBe(70);
+
+      sheet.set('C1', '=IF(A1>30, "big", "small")');
+      expect(sheet.get('C1')).toBe('big');
+    });
+  });
+
+  describe('edge cases', () => {
+    it('should handle empty cells in formulas as 0', () => {
+      sheet.set('A1', '=B1+5');
+      expect(sheet.get('A1')).toBe(5);
+    });
+
+    it('should handle boolean values in formulas', () => {
+      sheet.set('A1', '=true');
+      expect(sheet.get('A1')).toBe(true);
+      sheet.set('A2', '=false');
+      expect(sheet.get('A2')).toBe(false);
+    });
+
+    it('should handle string literals in formulas', () => {
+      sheet.set('A1', 50);
+      sheet.set('B1', '=IF(A1>30, "big", "small")');
+      expect(sheet.get('B1')).toBe('big');
+    });
+  });
