      i++;\n   378→        continue;\n   379→      }\n   380→\n   381→      // Parentheses\n   382→      if (ch === '(' || ch === ')') {\n   383→        tokens.push({ type: 'paren', value: ch });\n   384→        i++;\n   385→        continue;\n   386→      }\n   387→\n   388→      // Comma\n   389→      if (ch === ',') {\n   390→        tokens.push({ type: 'comma', value: ',' });\n   391→        i++;\n   392→        continue;\n   393→      }\n   394→\n   395→      // Colon (standalone, shouldn't happen in well-formed formulas)\n   396→      if (ch === ':') {\n   397→        i++;\n   398→        continue;\n   399→      }\n   400→\n   401→      throw new Error(`Unexpected character: ${ch}`);\n   402→    }\n   403→\n   404→    return tokens;\n   405→  }\n   406→\n   407→  private evaluate(formula: string): CellValue {\n   408→    const tokens = this.tokenize(formula);\n   409→    let pos = 0;\n   410→\n   411→    const peek = (): Token | null => tokens[pos] ?? null;\n   412→    const consume = (): Token => tokens[pos++];\n   413→\n   414→    const parseExpression = (): CellValue => {\n   415→      return parseComparison();\n   416→    };\n   417→\n   418→    const parseComparison = (): CellValue => {\n   419→      let left = parseAddSub();\n   420→      while (peek() && peek()!.type === 'comparison') {\n   421→        const op = consume().value;\n   422→        const right = parseAddSub();\n   423→        left = applyComparison(op, left, right);\n   424→      }\n   425→      return left;\n   426→    };\n   427→\n   428→    const applyComparison = (op: string, left: CellValue, right: CellValue): boolean => {\n   429→      const l = typeof left === 'number' ? left : Number(left);\n   430→      const r = typeof right === 'number' ? right : Number(right);\n   431→      switch (op) {\n   432→        case '>': return l > r;\n   433→        case '<': return l < r;\n   434→        case '>=': return l >= r;\n   435→        case '<=': return l <= r;\n   436→        case '=': return left === right;\n   437→        case '<>': return left !== right;\n   438→        default: throw new Error(`Unknown comparison: ${op}`);\n   439→      }\n   440→    };\n   441→\n   442→    const parseAddSub = (): CellValue => {\n   443→      let left = parseMulDiv();\n   444→      while (peek() && peek()!.type === 'operator' && (peek()!.value === '+' || peek()!.value === '-')) {\n   445→        const op = consume().value;\n   446→        const right = parseMulDiv();\n   447→        if (typeof left === 'number' && typeof right === 'number') {\n   448→          left = op === '+' ? left + right : left - right;\n   449→        } else {\n   450→          // String concatenation for + with strings\n   451→          if (op === '+' && (typeof left === 'string' || typeof right === 'string')) {\n   452→            left = String(left) + String(right);\n   453→          } else {\n   454→            left = op === '+' ? Number(left) + Number(right) : Number(left) - Number(right);\n   455→          }\n   456→        }\n   457→      }\n   458→      return left;\n   459→    };\n   460→\n   461→    const parseMulDiv = (): CellValue => {\n   462→      let left = parseUnary();\n   463→      while (peek() && peek()!.type === 'operator' && (peek()!.value === '*' || peek()!.value === '/')) {\n   464→        const op = consume().value;\n   465→        const right = parseUnary();\n   466→        const l = typeof left === 'number' ? left : Number(left);\n   467→        const r = typeof right === 'number' ? right : Number(right);\n   468→        left = op === '*' ? l * r : l / r;\n   469→      }\n   470→      return left;\n   471→    };\n   472→\n   473→    const parseUnary = (): CellValue => {\n   474→      if (peek() && peek()!.type === 'operator' && peek()!.value === '-') {\n   475→        consume();\n   476→        const val = parsePrimary();\n   477→        return -(typeof val === 'number' ? val : Number(val));\n   478→      }\n   479→      if (peek() && peek()!.type === 'operator' && peek()!.value === '+') {\n   480→        consume();\n   481→        return parsePrimary();\n   482→      }\n   483→      return parsePrimary();\n   484→    };\n   485→\n   486→    const parsePrimary = (): CellValue => {\n   487→      const token = peek();\n   488→      if (!token) throw new Error('Unexpected end of formula');\n   489→\n   490→      switch (token.type) {\n   491→        case 'number': {\n   492→          consume();\n   493→          return parseFloat(token.value);\n   494→        }\n   495→        case 'string': {\n   496→          consume();\n   497→          return token.value;\n   498→        }\n   499→        case 'boolean': {\n   500→          consume();\n   501→          return token.value === 'TRUE';\n   502→        }\n   503→        case 'cell': {\n   504→          consume();\n   505→          const val = this.get(token.value);\n   506→          return val === null ? 0 : val;\n   507→        }\n   508→        case 'function': {\n   509→          return parseFunction();\n   510→        }\n   511→        case 'paren': {\n   512→          if (token.value === '(') {\n   513→            consume(); // skip '('\n   514→            const val = parseExpression();\n   515→            if (peek() && peek()!.value === ')') {\n   516→              consume(); // skip ')'\n   517→            }\n   518→            return val;\n   519→          }\n   520→          throw new Error('Unexpected )');\n   521→        }\n   522→        default:\n   523→          throw new Error(`Unexpected token: ${token.type} ${token.value}`);\n   524→      }\n   525→    };\n   526→\n   527→    const parseFunction = (): CellValue => {\n   528→      const funcToken = consume(); // function name\n   529→      consume(); // skip '('\n   530→\n   531→      const funcName = funcToken.value;\n   532→\n   533→      if (funcName === 'IF') {\n   534→        const condition = parseExpression();\n   535→        if (peek()?.value === ',') consume(); // skip comma\n   536→        const trueVa