ing | number | boolean | null;\n\ninterface CellData {\n  raw: string | number | boolean;\n  computed: CellValue;\n  formula: boolean;\n  dependencies: Set<string>;\n}\n\ninterface Token {\n  type: 'number' | 'string' | 'boolean' | 'cell' | 'range' | 'function' | 'operator' | 'paren' | 'comma' | 'comparison';\n  value: string;\n}\n\nexport class Spreadsheet {\n  private cells: Map<string, CellData> = new Map();\n  private dependents: Map<string, Set<string>> = new Map();\n\n  set(cell: string, value: string | number | boolean): void {\n    const ref = this.normalizeRef(cell);\n    const oldDeps = this.cells.get(ref)?.dependencies ?? new Set<string>();\n\n    // Remove old reverse dependencies\n    for (const dep of oldDeps) {\n      this.dependents.get(dep)?.delete(ref);\n    }\n\n    if (typeof value === 'string' && value.startsWith('=')) {\n      const formula = value.slice(1);\n      const deps = this.extractDependencies(formula);\n\n      // Check for circular dependencies before committing\n      this.checkCircular(ref, deps);\n\n      const cellData: CellData = {\n        raw: value,\n        computed: null,\n        formula: true,\n        dependencies: deps,\n      };\n      this.cells.set(ref, cellData);\n\n      // Add reverse dependencies\n      for (const dep of deps) {\n        if (!this.dependents.has(dep)) {\n          this.dependents.set(dep, new Set());\n        }\n        this.dependents.get(dep)!.add(ref);\n      }\n\n      cellData.computed = this.evaluate(formula);\n    } else {\n      this.cells.set(ref, {\n        raw: value,\n        computed: value,\n        formula: false,\n        dependencies: new Set(),\n      });\n    }\n\n    // Propagate updates to dependents\n    this.propagate(ref);\n  }\n\n  get(cell: string): CellValue {\n    const ref = this.normalizeRef(cell);\n    const data = this.cells.get(ref);\n    if (!data) return null;\n    return data.computed;\n  }\n\n  getDisplay(cell: string): string {\n    const val = this.get(cell)