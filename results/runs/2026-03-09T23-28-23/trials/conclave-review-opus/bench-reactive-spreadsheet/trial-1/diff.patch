+import { describe, it, expect, beforeEach } from 'vitest';
+import { Spreadsheet } from './index.js';
+
+describe('Spreadsheet', () => {
+  let sheet: Spreadsheet;
+
+  beforeEach(() => {
+    sheet = new Spreadsheet();
+  });
+
+  describe('basic values', () => {
+    it('should store and retrieve numbers', () => {
+      sheet.set('A1', 42);
+      expect(sheet.get('A1')).toBe(42);
+    });
+
+    it('should store and retrieve floating point numbers', () => {
+      sheet.set('A1', 3.14);
+      expect(sheet.get('A1')).toBe(3.14);
+    });
+
+    it('should store and retrieve strings', () => {
+      sheet.set('A1', 'hello');
+      expect(sheet.get('A1')).toBe('hello');
+    });
+
+    it('should store and retrieve booleans', () => {
+      sheet.set('A1', true);
+      expect(sheet.get('A1')).toBe(true);
+      sheet.set('A2', false);
+      expect(sheet.get('A2')).toBe(false);
+    });
+
+    it('should return null for empty cells', () => {
+      expect(sheet.get('A1')).toBe(null);
+    });
+
+    it('should handle case-insensitive cell references', () => {
+      sheet.set('a1', 10);
+      expect(sheet.get('A1')).toBe(10);
+      expect(sheet.get('a1')).toBe(10);
+    });
+  });
+
+  describe('getDisplay', () => {
+    it('should display numbers', () => {
+      sheet.set('A1', 42);
+      expect(sheet.getDisplay('A1')).toBe('42');
+    });
+
+    it('should display strings', () => {
+      sheet.set('A1', 'hello');
+      expect(sheet.getDisplay('A1')).toBe('hello');
+    });
+
+    it('should display booleans', () => {
+      sheet.set('A1', true);
+      expect(sheet.getDisplay('A1')).toBe('true');
+    });
+
+    it('should display empty string for empty cells', () => {
+      expect(sheet.getDisplay('A1')).toBe('');
+    });
+
+    it('should display formula results', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.getDisplay('A3')).toBe('30');
+    });
+  });
+
+  describe('getCells', () => {
+    it('should return all non-empty cells', () => {
+      sheet.set('A1', 10);
+      sheet.set('B1', 20);
+      sheet.set('C1', '=A1+B1');
+      const cells = sheet.getCells();
+      expect(cells.size).toBe(3);
+      expect(cells.get('A1')).toBe(10);
+      expect(cells.get('B1')).toBe(20);
+      expect(cells.get('C1')).toBe(30);
+    });
+  });
+
+  describe('formulas - arithmetic', () => {
+    it('should evaluate addition', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should evaluate subtraction', () => {
+      sheet.set('A1', 50);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1-A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should evaluate multiplication', () => {
+      sheet.set('A1', 5);
+      sheet.set('A2', 6);
+      sheet.set('A3', '=A1*A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should evaluate division', () => {
+      sheet.set('A1', 100);
+      sheet.set('A2', 4);
+      sheet.set('A3', '=A1/A2');
+      expect(sheet.get('A3')).toBe(25);
+    });
+
+    it('should respect operator precedence', () => {
+      sheet.set('A1', 2);
+      sheet.set('A2', 3);
+      sheet.set('A3', 4);
+      sheet.set('A4', '=A1+A2*A3');
+      expect(sheet.get('A4')).toBe(14);
+    });
+
+    it('should handle parentheses', () => {
+      sheet.set('A1', 2);
+      sheet.set('A2', 3);
+      sheet.set('A3', 4);
+      sheet.set('A4', '=(A1+A2)*A3');
+      expect(sheet.get('A4')).toBe(20);
+    });
+
+    it('should handle negative numbers with unary minus', () => {
+      sheet.set('A1', 5);
+      sheet.set('A2', '=-A1');
+      expect(sheet.get('A2')).toBe(-5);
+    });
+
+    it('should handle constant expressions', () => {
+      sheet.set('A1', '=2+3');
+      expect(sheet.get('A1')).toBe(5);
+    });
+
+    it('should handle mixed cell refs and constants', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', '=A1*2+5');
+      expect(sheet.get('A2')).toBe(25);
+    });
+  });
+
+  describe('formulas - functions', () => {
+    it('should evaluate SUM', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', 30);
+      sheet.set('B1', '=SUM(A1:A3)');
+      expect(sheet.get('B1')).toBe(60);
+    });
+
+    it('should evaluate AVERAGE', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', 30);
+      sheet.set('B1', '=AVERAGE(A1:A3)');
+      expect(sheet.get('B1')).toBe(20);
+    });
+
+    it('should evaluate MIN', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 5);
+      sheet.set('A3', 30);
+      sheet.set('B1', '=MIN(A1:A3)');
+      expect(sheet.get('B1')).toBe(5);
+    });
+
+    it('should evaluate MAX', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 5);
+      sheet.set('A3', 30);
+      sheet.set('B1', '=MAX(A1:A3)');
+      expect(sheet.get('B1')).toBe(30);
+    });
+
+    it('should evaluate COUNT', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', 30);
+      sheet.set('B1', '=COUNT(A1:A3)');
+      expect(sheet.get('B1')).toBe(3);
+    });
+
+    it('should skip non-numeric values in aggregate functions', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 'hello');
+      sheet.set('A3', 30);
+      sheet.set('B1', '=SUM(A1:A3)');
+      expect(sheet.get('B1')).toBe(40);
+      sheet.set('B2', '=COUNT(A1:A3)');
+      expect(sheet.get('B2')).toBe(2);
+    });
+
+    it('should handle IF with true condition', () => {
+      sheet.set('A1', 50);
+      sheet.set('B1', '=IF(A1>30, "big", "small")');
+      expect(sheet.get('B1')).toBe('big');
+    });
+
+    it('should handle IF with false condition', () => {
+      sheet.set('A1', 10);
+      sheet.set('B1', '=IF(A1>30, "big", "small")');
+      expect(sheet.get('B1')).toBe('small');
+    });
+
+    it('should handle IF with numeric results', () => {
+      sheet.set('A1', 10);
+      sheet.set('B1', '=IF(A1>5, A1*2, 0)');
+      expect(sheet.get('B1')).toBe(20);
+    });
+  });
+
+  describe('comparison operators', () => {
+    it('should handle greater than', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 5);
+      sheet.set('A3', '=IF(A1>A2, 1, 0)');
+      expect(sheet.get('A3')).toBe(1);
+    });
+
+    it('should handle less than', () => {
+      sheet.set('A1', 3);
+      sheet.set('A2', 5);
+      sheet.set('A3', '=IF(A1<A2, 1, 0)');
+      expect(sheet.get('A3')).toBe(1);
+    });
+
+    it('should handle greater than or equal', () => {
+      sheet.set('A1', 5);
+      sheet.set('A2', 5);
+      sheet.set('A3', '=IF(A1>=A2, 1, 0)');
+      expect(sheet.get('A3')).toBe(1);
+    });
+
+    it('should handle less than or equal', () => {
+      sheet.set('A1', 5);
+      sheet.set('A2', 5);
+      sheet.set('A3', '=IF(A1<=A2, 1, 0)');
+      expect(sheet.get('A3')).toBe(1);
+    });
+
+    it('should handle equality', () => {
+      sheet.set('A1', 5);
+      sheet.set('A2', 5);
+      sheet.set('A3', '=IF(A1=A2, 1, 0)');
+      expect(sheet.get('A3')).toBe(1);
+    });
+
+    it('should handle not equal', () => {
+      sheet.set('A1', 5);
+      sheet.set('A2', 6);
+      sheet.set('A3', '=IF(A1<>A2, 1, 0)');
+      expect(sheet.get('A3')).toBe(1);
+    });
+  });
+
+  describe('ranges', () => {
+    it('should handle column ranges', () => {
+      sheet.set('A1', 1);
+      sheet.set('A2', 2);
+      sheet.set('A3', 3);
+      sheet.set('A4', 4);
+      sheet.set('A5', 5);
+      sheet.set('B1', '=SUM(A1:A5)');
+      expect(sheet.get('B1')).toBe(15);
+    });
+
+    it('should handle row ranges', () => {
+      sheet.set('A1', 1);
+      sheet.set('B1', 2);
+      sheet.set('C1', 3);
+      sheet.set('D1', '=SUM(A1:C1)');
+      expect(sheet.get('D1')).toBe(6);
+    });
+
+    it('should handle block ranges', () => {
+      sheet.set('A1', 1);
+      sheet.set('A2', 2);
+      sheet.set('B1', 3);
+      sheet.set('B2', 4);
+      sheet.set('C1', '=SUM(A1:B2)');
+      expect(sheet.get('C1')).toBe(10);
+    });
+  });
+
+  describe('reactive updates', () => {
+    it('should update direct dependents', () => {
+      sheet.set('A1', 10);
+      sheet.set('B1', '=A1+1');
+      expect(sheet.get('B1')).toBe(11);
+
+      sheet.set('A1', 50);
+      expect(sheet.get('B1')).toBe(51);
+    });
+
+    it('should update transitive dependents', () => {
+      sheet.set('A1', 5);
+      sheet.set('B1', '=A1*2');
+      sheet.set('C1', '=B1+10');
