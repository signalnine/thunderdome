nst ch = formula[i];\n   279→\n   280→      if (ch === ' ' || ch === '\\t') {\n   281→        i++;\n   282→        continue;\n   283→      }\n   284→\n   285→      // String literal\n   286→      if (ch === '\"') {\n   287→        let str = '';\n   288→        i++; // skip opening quote\n   289→        while (i < formula.length && formula[i] !== '\"') {\n   290→          str += formula[i];\n   291→          i++;\n   292→        }\n   293→        i++; // skip closing quote\n   294→        tokens.push({ type: 'string', value: str });\n   295→        continue;\n   296→      }\n   297→\n   298→      // Comparison operators (must be checked before single-char operators)\n   299→      if (ch === '<' && formula[i + 1] === '>') {\n   300→        tokens.push({ type: 'comparison', value: '<>' });\n   301→        i += 2;\n   302→        continue;\n   303→      }\n   304→      if (ch === '>' && formula[i + 1] === '=') {\n   305→        tokens.push({ type: 'comparison', value: '>=' });\n   306→        i += 2;\n   307→        continue;\n   308→      }\n   309→      if (ch === '<' && formula[i + 1] === '=') {\n   310→        tokens.push({ type: 'comparison', value: '<=' });\n   311→        i += 2;\n   312→        continue;\n   313→      }\n   314→      if (ch === '>' || ch === '<') {\n   315→        tokens.push({ type: 'comparison', value: ch });\n   316→        i++;\n   317→        continue;\n   318→      }\n   319→      if (ch === '=') {\n   320→        tokens.push({ type: 'comparison', value: '=' });\n   321→        i++;\n   322→        continue;\n   323→      }\n   324→\n   325→      // Numbers\n   326→      if ((ch >= '0' && ch <= '9') || (ch === '.' && i + 1 < formula.length && formula[i + 1] >= '0' && formula[i + 1] <= '9')) {\n   327→        let num = '';\n   328→        while (i < formula.length && ((formula[i] >= '0' && formula[i] <= '9') || formula[i] === '.')) {\n   329→          num += formula[i];\n   330→          i++;\n   331→        }\n   332→        tokens.push({ 