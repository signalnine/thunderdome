    sheet.set('B1', '=SUM(A1:A5)');\n      expect(sheet.get('B1')).toBe(15);\n    });\n\n    it('should handle row ranges', () => {\n      sheet.set('A1', 1);\n      sheet.set('B1', 2);\n      sheet.set('C1', 3);\n      sheet.set('D1', '=SUM(A1:C1)');\n      expect(sheet.get('D1')).toBe(6);\n    });\n\n    it('should handle block ranges', () => {\n      sheet.set('A1', 1);\n      sheet.set('A2', 2);\n      sheet.set('B1', 3);\n      sheet.set('B2', 4);\n      sheet.set('C1', '=SUM(A1:B2)');\n      expect(sheet.get('C1')).toBe(10);\n    });\n  });\n\n  describe('reactive updates', () => {\n    it('should update direct dependents', () => {\n      sheet.set('A1', 10);\n      sheet.set('B1', '=A1+1');\n      expect(sheet.get('B1')).toBe(11);\n\n      sheet.set('A1', 50);\n      expect(sheet.get('B1')).toBe(51);\n    });\n\n    it('should update transitive dependents', () => {\n      sheet.set('A1', 5);\n      sheet.set('B1', '=A1*2');\n      sheet.set('C1', '=B1+10');\n      expect(sheet.get('C1')).toBe(20);\n\n      sheet.set('A1', 10);\n      expect(sheet.get('B1')).toBe(20);\n      expect(sheet.get('C1')).toBe(30);\n    });\n\n    it('should update multiple dependents', () => {\n      sheet.set('A1', 10);\n      sheet.set('B1', '=A1+1');\n      sheet.set('C1', '=A1+2');\n      sheet.set('D1', '=A1+3');\n\n      sheet.set('A1', 100);\n      expect(sheet.get('B1')).toBe(101);\n      expect(sheet.get('C1')).toBe(102);\n      expect(sheet.get('D1')).toBe(103);\n    });\n\n    it('should handle diamond dependencies', () => {\n      sheet.set('A1', 5);\n      sheet.set('B1', '=A1+1');\n      sheet.set('C1', '=A1+2');\n      sheet.set('D1', '=B1+C1');\n      expect(sheet.get('D1')).toBe(13);\n\n      sheet.set('A1', 10);\n      expect(sheet.get('B1')).toBe(11);\n      expect(sheet.get('C1')).toBe(12);\n      expect(sheet.get('D1')).toBe(23);\n    });\n\n    it('should update aggregate functions reactively', () => {\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n  