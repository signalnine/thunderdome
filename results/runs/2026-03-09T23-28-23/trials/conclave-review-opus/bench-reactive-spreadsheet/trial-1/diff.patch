+++ b/src/index.ts
@@ -0,0 +1,536 @@
+type CellValue = string | number | boolean | null;
+
+interface CellData {
+  raw: string | number | boolean;
+  computed: CellValue;
+  formula: boolean;
+  dependencies: Set<string>;
+}
+
+interface Token {
+  type: 'number' | 'string' | 'boolean' | 'cell' | 'range' | 'function' | 'operator' | 'paren' | 'comma' | 'comparison';
+  value: string;
+}
+
+export class Spreadsheet {
+  private cells: Map<string, CellData> = new Map();
+  private dependents: Map<string, Set<string>> = new Map();
+
+  set(cell: string, value: string | number | boolean): void {
+    const ref = this.normalizeRef(cell);
+    const oldDeps = this.cells.get(ref)?.dependencies ?? new Set<string>();
+
+    // Remove old reverse dependencies
+    for (const dep of oldDeps) {
+      this.dependents.get(dep)?.delete(ref);
+    }
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      const formula = value.slice(1);
+      const deps = this.extractDependencies(formula);
+
+      // Check for circular dependencies before committing
+      this.checkCircular(ref, deps);
+
+      const cellData: CellData = {
+        raw: value,
+        computed: null,
+        formula: true,
+        dependencies: deps,
+      };
+      this.cells.set(ref, cellData);
+
+      // Add reverse dependencies
+      for (const dep of deps) {
+        if (!this.dependents.has(dep)) {
+          this.dependents.set(dep, new Set());
+        }
+        this.dependents.get(dep)!.add(ref);
+      }
+
+      cellData.computed = this.evaluate(formula);
+    } else {
+      this.cells.set(ref, {
+        raw: value,
+        computed: value,
+        formula: false,
+        dependencies: new Set(),
+      });
+    }
+
+    // Propagate updates to dependents
+    this.propagate(ref);
+  }
+
+  get(cell: string): CellValue {
+    const ref = this.normalizeRef(cell);
+    const data = this.cells.get(ref);
+    if (!data) return null;
+    return data.computed;
+  }
+
+  getDisplay(cell: string): string {
+    const val = this.get(cell);
+    if (val === null) return '';
+    return String(val);
+  }
+
+  getCells(): Map<string, CellValue> {
+    const result = new Map<string, CellValue>();
+    for (const [ref, data] of this.cells) {
+      result.set(ref, data.computed);
+    }
+    return result;
+  }
+
+  private normalizeRef(ref: string): string {
+    return ref.toUpperCase();
+  }
+
+  private parseRef(ref: string): { col: number; row: number } {
+    const match = ref.match(/^([A-Z]+)(\d+)$/);
+    if (!match) throw new Error(`Invalid cell reference: ${ref}`);
+    return { col: this.colToNum(match[1]), row: parseInt(match[2], 10) };
+  }
+
+  private colToNum(col: string): number {
+    let n = 0;
+    for (let i = 0; i < col.length; i++) {
+      n = n * 26 + (col.charCodeAt(i) - 64);
+    }
+    return n;
+  }
+
+  private numToCol(n: number): string {
+    let s = '';
+    while (n > 0) {
+      n--;
+      s = String.fromCharCode(65 + (n % 26)) + s;
+      n = Math.floor(n / 26);
+    }
+    return s;
+  }
+
+  private expandRange(start: string, end: string): string[] {
+    const s = this.parseRef(start);
+    const e = this.parseRef(end);
+    const minCol = Math.min(s.col, e.col);
+    const maxCol = Math.max(s.col, e.col);
+    const minRow = Math.min(s.row, e.row);
+    const maxRow = Math.max(s.row, e.row);
+    const refs: string[] = [];
+    for (let c = minCol; c <= maxCol; c++) {
+      for (let r = minRow; r <= maxRow; r++) {
+        refs.push(this.numToCol(c) + r);
+      }
+    }
+    return refs;
+  }
+
+  private extractDependencies(formula: string): Set<string> {
+    const deps = new Set<string>();
+    const rangeRegex = /([A-Z]+\d+):([A-Z]+\d+)/gi;
+    const cellRegex = /\b([A-Z]+\d+)\b/gi;
+
+    // Extract ranges first
+    const processed = formula.replace(rangeRegex, (_, start, end) => {
+      const refs = this.expandRange(start.toUpperCase(), end.toUpperCase());
+      for (const r of refs) deps.add(r);
+      return '';
+    });
+
+    // Extract individual cell references from remaining
+    let match: RegExpExecArray | null;
+    while ((match = cellRegex.exec(processed)) !== null) {
+      // Make sure it's not a function name like SUM, IF, etc.
+      const val = match[1].toUpperCase();
+      if (!this.isFunction(val)) {
+        deps.add(val);
+      }
+    }
+
+    return deps;
+  }
+
+  private isFunction(name: string): boolean {
+    return ['SUM', 'AVERAGE', 'MIN', 'MAX', 'COUNT', 'IF', 'TRUE', 'FALSE'].includes(name);
+  }
+
+  private checkCircular(cell: string, deps: Set<string>): void {
+    const visited = new Set<string>();
+    const stack = [...deps];
+    while (stack.length > 0) {
+      const current = stack.pop()!;
+      if (current === cell) {
+        throw new Error(`Circular reference detected involving ${cell}`);
+      }
+      if (visited.has(current)) continue;
+      visited.add(current);
+      const data = this.cells.get(current);
+      if (data) {
+        for (const dep of data.dependencies) {
+          stack.push(dep);
+        }
+      }
+    }
+  }
+
+  private propagate(changed: string): void {
+    const order = this.topologicalSort(changed);
+    for (const ref of order) {
+      const data = this.cells.get(ref);
+      if (data && data.formula) {
+        const formula = (data.raw as string).slice(1);
+        data.computed = this.evaluate(formula);
+      }
+    }
+  }
+
+  private topologicalSort(start: string): string[] {
+    // BFS to find all affected cells (dependents of the changed cell)
+    const affected = new Set<string>();
+    const queue = [start];
+    const visited = new Set<string>([start]);
+    while (queue.length > 0) {
+      const current = queue.shift()!;
+      const deps = this.dependents.get(current);
+      if (deps) {
+        for (const dep of deps) {
+          if (!visited.has(dep)) {
+            visited.add(dep);
+            affected.add(dep);
+            queue.push(dep);
+          }
+        }
+      }
+    }
+
+    // Topological sort: evaluate cells whose dependencies are satisfied first
+    const sorted = new Set<string>();
+    const order: string[] = [];
+
+    const topoVisit = (ref: string): void => {
+      if (sorted.has(ref)) return;
+      sorted.add(ref);
+      const data = this.cells.get(ref);
+      if (data) {
+        for (const dep of data.dependencies) {
+          if (affected.has(dep)) {
+            topoVisit(dep);
+          }
+        }
+      }
+      order.push(ref);
+    };
+
+    for (const ref of affected) {
+      topoVisit(ref);
+    }
+
+    return order;
+  }
+
+  // ---- Formula Parser and Evaluator ----
+
+  private tokenize(formula: string): Token[] {
+    const tokens: Token[] = [];
+    let i = 0;
+
+    while (i < formula.length) {
+      const ch = formula[i];
+
+      if (ch === ' ' || ch === '\t') {
+        i++;
+        continue;
+      }
+
+      // String literal
+      if (ch === '"') {
+        let str = '';
+        i++; // skip opening quote
+        while (i < formula.length && formula[i] !== '"') {
+          str += formula[i];
+          i++;
+        }
+        i++; // skip closing quote
+        tokens.push({ type: 'string', value: str });
+        continue;
+      }
+
+      // Comparison operators (must be checked before single-char operators)
+      if (ch === '<' && formula[i + 1] === '>') {
+        tokens.push({ type: 'comparison', value: '<>' });
+        i += 2;
+        continue;
+      }
+      if (ch === '>' && formula[i + 1] === '=') {
+        tokens.push({ type: 'comparison', value: '>=' });
+        i += 2;
+        continue;
+      }
+      if (ch === '<' && formula[i + 1] === '=') {
+        tokens.push({ type: 'comparison', value: '<=' });
+        i += 2;
+        continue;
+      }
+      if (ch === '>' || ch === '<') {
+        tokens.push({ type: 'comparison', value: ch });
+        i++;
+        continue;
+      }
+      if (ch === '=') {
+        tokens.push({ type: 'comparison', value: '=' });
+        i++;
+        continue;
+      }
+
+      // Numbers
+      if ((ch >= '0' && ch <= '9') || (ch === '.' && i + 1 < formula.length && formula[i + 1] >= '0' && formula[i + 1] <= '9')) {
+        let num = '';
+        while (i < formula.length && ((formula[i] >= '0' && formula[i] <= '9') || formula[i] === '.')) {
+          num += formula[i];
+          i++;
+        }
+        tokens.push({ type: 'number', value: num });
+        continue;
+      }
+
+      // Identifiers (cell refs, function names, booleans, ranges)
+      if ((ch >= 'A' && ch <= 'Z') || (ch >= 'a' && ch <= 'z')) {
+        let ident = '';
+        while (i < formula.length && ((formula[i] >= 'A' && formula[i] <= 'Z') || (formula[i] >= 'a' && formula[i] <= 'z') || (formula[i] >= '0' && formula[i] <= '9'))) {
+          ident += formula[i];
+          i++;
+        }
+        const upper = ident.toUpperCase();
+
+        // Check for range (IDENT:IDENT)
+        if (i < formula.length && formula[i] === ':') {
+          i++; // skip colon
+          let ident2 = '';
+          while (i < formula.length && ((formula[i] >= 'A' && formula[i] <= 'Z') || (formula[i] >= 'a' && formula[i] <= 'z') || (formula[i] >= '0' && formula[i] <= '9'))) {
+            ident2 += formula[i];
+            i++;
+          }
+          tokens.push({ type: 'range', value: upper + ':' + ident2.toUpperCase() });
+          continue;
+        }
+
+        // Check for booleans
+        if (upper === 'TRUE' || upper === 'FALSE') {
+          tokens.push({ type: 'boolean', value: upper });
+          continue;
+        }
+
+        // Check for function (followed by '(')
+        if (i < formula.length && formula[i] === '(' && this.isFunction(upper)) {
+          tokens.push({ type: 'function', value: upper });
+          continue;
+        }
+
+        // Must be a cell reference
+        tokens.push({ type: 'cell', value: upper });
+        continue;
+      }
+
+      // Operators
+      if (ch === '+' || ch === '-' || ch === '*' || ch === '/') {
+        tokens.push({ type: 'operator', value: ch });
+        i++;
+        continue;
+      }
+
+      // Parentheses
+      if (ch === '(' || ch === ')') {
+        tokens.push({ type: 'paren', value: ch });
+        i++;
+        continue;
+      }
+
+      // Comma
+      if (ch === ',') {
+        tokens.push({ type: 'comma', value: ',' });
+        i++;
+        continue;
+      }
+
+      // Colon (standalone, shouldn't happen in well-formed formulas)
+      if (ch === ':') {
+        i++;
+        continue;
+      }
+
+      throw new Error(`Unexpected character: ${ch}`);
+    }
+
+    return tokens;
+  }
+
+  private evaluate(formula: string): CellValue {
+    const tokens = this.tokenize(formula);
+    let pos = 0;
+
+    const peek = (): Token | null => tokens[pos] ?? null;
+    const consume = (): Token => tokens[pos++];
+
+    const parseExpression = (): CellValue => {
+      return parseComparison();
+    };
+
+    const parseComparison = (): CellValue => {
+      let left = parseAddSub();
+      while (peek() && peek()!.type === 'comparison') {
+        const op = consume().value;
+        const right = parseAddSub();
+        left = applyComparison(op, left, right);
+      }
+      return left;
+    };
+
+    const applyComparison = (op: string, left: CellValue, right: CellValue): boolean => {
+      const l = typeof left === 'number' ? left : Number(left);
+      const r = typeof right === 'number' ? right : Number(right);
+      switch (op) {
+        case '>': return l > r;
+        case '<': return l < r;
+        case '>=': return l >= r;
+        case '<=': return l <= r;
+        case '=': return left === right;
+        case '<>': return left !== right;
+        default: throw new Error(`Unknown comparison: ${op}`);
+      }
+    };
+
+    const parseAddSub = (): CellValue => {
+      let left = parseMulDiv();
+      while (peek() && peek()!.type === 'operator' && (peek()!.value === '+' || peek()!.value === '-')) {
+        const op = consume().value;
+        const right = parseMulDiv();
+        if (typeof left === 'number' && typeof right === 'number') {
+          left = op === '+' ? left + right : left - right;
+        } else {
+          // String concatenation for + with strings
+          if (op === '+' && (typeof left === 'string' || typeof right === 'string')) {
+            left = String(left) + String(right);
+          } else {
+            left = op === '+' ? Number(left) + Number(right) : Number(left) - Number(right);
+          }
+        }
+      }
+      return left;
+    };
+
+    const parseMulDiv = (): CellValue => {
+      let left = parseUnary();
+      while (peek() && peek()!.type === 'operator' && (peek()!.value === '*' || peek()!.value === '/')) {
+        const op = consume().value;
+        const right = parseUnary();
+        const l = typeof left === 'number' ? left : Number(left);
+        const r = typeof right === 'number' ? right : Number(right);
+        left = op === '*' ? l * r : l / r;
+      }
+      return left;
+    };
+
+    const parseUnary = (): CellValue => {
+      if (peek() && peek()!.type === 'operator' && peek()!.value === '-') {
+        consume();
+        const val = parsePrimary();
+        return -(typeof val === 'number' ? val : Number(val));
+      }
+      if (peek() && peek()!.type === 'operator' && peek()!.value === '+') {
+        consume();
+        return parsePrimary();
+      }
+      return parsePrimary();
+    };
+
+    const parsePrimary = (): CellValue => {
+      const token = peek();
+      if (!token) throw new Error('Unexpected end of formula');
+
+      switch (token.type) {
+        case 'number': {
+          consume();
+          return parseFloat(token.value);
+        }
+        case 'string': {
+          consume();
+          return token.value;
+        }
+        case 'boolean': {
+          consume();
+          return token.value === 'TRUE';
+        }
+        case 'cell': {
+          consume();
+          const val = this.get(token.value);
+          return val === null ? 0 : val;
+        }
+        case 'function': {
+          return parseFunction();
+        }
+        case 'paren': {
+          if (token.value === '(') {
+            consume(); // skip '('
+            const val = parseExpression();
+            if (peek() && peek()!.value === ')') {
+              consume(); // skip ')'
+            }
+            return val;
+          }
+          throw new Error('Unexpected )');
+        }
+        default:
+          throw new Error(`Unexpected token: ${token.type} ${token.value}`);
+      }
+    };
+
+    const parseFunction = (): CellValue => {
+      const funcToken = consume(); // function name
+      consume(); // skip '('
+
+      const funcName = funcToken.value;
+
+      if (funcName === 'IF') {
+        const condition = parseExpression();
+        if (peek()?.value === ',') consume(); // skip comma
+        const trueVal = parseExpression();
+        if (peek()?.value === ',') consume(); // skip comma
+        const falseVal = parseExpression();
+        if (peek()?.value === ')') consume(); // skip ')'
+        return condition ? trueVal : falseVal;
+      }
+
+      // Aggregate functions: collect values from ranges or individual values
+      const values: number[] = [];
+      while (peek() && peek()!.value !== ')') {
+        if (peek()!.type === 'range') {
+          const rangeToken = consume();
+          const [start, end] = rangeToken.value.split(':');
+          const refs = this.expandRange(start, end);
+          for (const r of refs) {
+            const v = this.get(r);
+            if (typeof v === 'number') values.push(v);
+          }
+        } else {
+          const v = parseExpression();
+          if (typeof v === 'number') values.push(v);
+        }
+        if (peek()?.value === ',') consume();
+      }
+      if (peek()?.value === ')') consume();
+
+      switch (funcName) {
+        case 'SUM': return values.reduce((a, b) => a + b, 0);
+        case 'AVERAGE': return values.length > 0 ? values.reduce((a, b) => a + b, 0) / values.length : 0;
+        case 'MIN': return values.length > 0 ? Math.min(...values) : 0;
+        case 'MAX': return values.length > 0 ? Math.max(...values) : 0;
+        case 'COUNT': return values.length;
+        default: throw new Error(`Unknown function: ${funcName}`);
+      }
+    };
+
+    return parseExpression();
+  }
+}
