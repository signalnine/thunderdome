     sheet.set('B1', '=A1');\n      sheet.set('C1', '=B1');\n      expect(sheet.get('C1')).toBe(10);\n    });\n  });\n\n  describe('column references', () => {\n    it('should handle multi-letter columns', () => {\n      sheet.set('AA1', 100);\n      expect(sheet.get('AA1')).toBe(100);\n    });\n\n    it('should handle formulas with multi-letter columns', () => {\n      sheet.set('AA1', 10);\n      sheet.set('AB1', 20);\n      sheet.set('AC1', '=AA1+AB1');\n      expect(sheet.get('AC1')).toBe(30);\n    });\n\n    it('should handle ranges with multi-letter columns', () => {\n      sheet.set('AA1', 1);\n      sheet.set('AB1', 2);\n      sheet.set('AC1', 3);\n      sheet.set('AD1', '=SUM(AA1:AC1)');\n      expect(sheet.get('AD1')).toBe(6);\n    });\n  });\n\n  describe('example from spec', () => {\n    it('should handle the complete example', () => {\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', '=A1+A2');\n      expect(sheet.get('A3')).toBe(30);\n      expect(sheet.getDisplay('A3')).toBe('30');\n\n      sheet.set('A1', 50);\n      expect(sheet.get('A3')).toBe(70);\n\n      sheet.set('B1', '=SUM(A1:A2)');\n      expect(sheet.get('B1')).toBe(70);\n\n      sheet.set('C1', '=IF(A1>30, \"big\", \"small\")');\n      expect(sheet.get('C1')).toBe('big');\n    });\n  });\n\n  describe('edge cases', () => {\n    it('should handle empty cells in formulas as 0', () => {\n      sheet.set('A1', '=B1+5');\n      expect(sheet.get('A1')).toBe(5);\n    });\n\n    it('should handle boolean values in formulas', () => {\n      sheet.set('A1', '=true');\n      expect(sheet.get('A1')).toBe(true);\n      sheet.set('A2', '=false');\n      expect(sheet.get('A2')).toBe(false);\n    });\n\n    it('should handle string literals in formulas', () => {\n      sheet.set('A1', 50);\n      sheet.set('B1', '=IF(A1>30, \"big\", \"small\")');\n      expect(sheet.get('B1')).toBe('big');\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
