diff --git a/tests/marketplace.test.ts b/tests/marketplace.test.ts
new file mode 100644
index 0000000..cee9e98
--- /dev/null
+++ b/tests/marketplace.test.ts
@@ -0,0 +1,153 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { createMarketplace, type Marketplace } from '../src/index.js';
+import type { PluginManifest } from '../src/types.js';
+
+function makeManifest(overrides: Partial<PluginManifest> = {}): PluginManifest {
+  return {
+    name: 'test-plugin',
+    version: '1.0.0',
+    description: 'A test plugin',
+    author: 'tester',
+    dependencies: {},
+    entryPoint: '2 + 2',
+    permissions: [],
+    ...overrides,
+  };
+}
+
+describe('Marketplace Integration', () => {
+  let marketplace: Marketplace;
+
+  beforeEach(() => {
+    marketplace = createMarketplace();
+  });
+
+  it('should install a simple plugin', async () => {
+    const result = await marketplace.installPlugin(makeManifest());
+    expect(result.sandboxResult.success).toBe(true);
+    expect(result.sandboxResult.output).toBe(4);
+    expect(result.resolved).toHaveLength(0);
+  });
+
+  it('should register plugin in registry on install', async () => {
+    await marketplace.installPlugin(makeManifest());
+    const found = marketplace.registry.get('test-plugin');
+    expect(found).not.toBeNull();
+    expect(found!.name).toBe('test-plugin');
+  });
+
+  it('should reject plugin without name', async () => {
+    await expect(
+      marketplace.installPlugin(makeManifest({ name: '' }))
+    ).rejects.toThrow(/[Ii]nvalid/);
+  });
+
+  it('should reject plugin without version', async () => {
+    await expect(
+      marketplace.installPlugin(makeManifest({ version: '' }))
+    ).rejects.toThrow(/[Ii]nvalid/);
+  });
+
+  it('should reject plugin without entryPoint', async () => {
+    await expect(
+      marketplace.installPlugin(makeManifest({ entryPoint: '' }))
+    ).rejects.toThrow(/[Ii]nvalid/);
+  });
+
+  it('should resolve dependencies during install', async () => {
+    marketplace.registry.register(
+      makeManifest({ name: 'dep-lib', version: '1.0.0', entryPoint: '"dep"' })
+    );
+    marketplace.registry.register(
+      makeManifest({ name: 'dep-lib', version: '1.1.0', entryPoint: '"dep"' })
+    );
+
+    const result = await marketplace.installPlugin(
+      makeManifest({
+        name: 'my-plugin',
+        dependencies: { 'dep-lib': '^1.0.0' },
+        entryPoint: '"hello"',
+      })
+    );
+
+    expect(result.resolved).toHaveLength(1);
+    expect(result.resolved[0].name).toBe('dep-lib');
+    expect(result.resolved[0].version).toBe('1.1.0');
+  });
+
+  it('should reject plugin with circular dependencies', async () => {
+    marketplace.registry.register(
+      makeManifest({
+        name: 'dep-a',
+        version: '1.0.0',
+        dependencies: { 'circular-plugin': '^1.0.0' },
+        entryPoint: '"a"',
+      })
+    );
+
+    await expect(
+      marketplace.installPlugin(
+        makeManifest({
+          name: 'circular-plugin',
+          dependencies: { 'dep-a': '^1.0.0' },
+          entryPoint: '"circ"',
+        })
+      )
+    ).rejects.toThrow(/[Cc]ircular/);
+  });
+
+  it('should handle plugin execution failure gracefully', async () => {
+    const result = await marketplace.installPlugin(
+      makeManifest({ entryPoint: 'throw new Error("init failed")' })
+    );
+    expect(result.sandboxResult.success).toBe(false);
+    expect(result.sandboxResult.error).toBe('init failed');
+  });
+
+  it('should compose all services', () => {
+    expect(marketplace.registry).toBeDefined();
+    expect(marketplace.resolver).toBeDefined();
+    expect(marketplace.runner).toBeDefined();
+    expect(marketplace.reviews).toBeDefined();
+    expect(marketplace.deps).toBeDefined();
+  });
+
+  it('end-to-end: install, review, search', async () => {
+    const manifest = makeManifest({
+      name: 'awesome-plugin',
+      description: 'Does awesome things',
+      entryPoint: '"installed"',
+    });
+
+    await marketplace.installPlugin(manifest);
+
+    marketplace.reviews.addReview({
+      pluginName: 'awesome-plugin',
+      pluginVersion: '1.0.0',
+      userId: 'user1',
+      rating: 5,
+      comment: 'Love it!',
+    });
+    marketplace.reviews.addReview({
+      pluginName: 'awesome-plugin',
+      pluginVersion: '1.0.0',
+      userId: 'user2',
+      rating: 4,
+      comment: 'Pretty good',
+    });
+
+    const results = marketplace.registry.search('awesome');
+    expect(results).toHaveLength(1);
+
+    expect(marketplace.reviews.getAverageRating('awesome-plugin')).toBe(4.5);
+    expect(marketplace.reviews.getReviewCount('awesome-plugin')).toBe(2);
+  });
+
+  it('should support return statements in entry point', async () => {
+    const result = await marketplace.installPlugin(
+      makeManifest({ entryPoint: 'return 2 + 3;' })
+    );
+    expect(result.sandboxResult.success).toBe(true);
+    expect(result.sandboxResult.output).toBe(5);
+  });
+});
