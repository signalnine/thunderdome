+import { describe, it, expect } from 'vitest';
+import { countBeamCells, countBeamPaths } from './index.js';
+
+describe('countBeamCells', () => {
+  it('basic example: beam goes straight down', () => {
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    // S at (0,1), beam visits (0,1), (1,1), (2,1)
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  it('example from spec: one splitter', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    // Visited: (0,1), (1,1), (2,1), (3,0), (3,2) = 5
+    expect(countBeamCells(grid)).toBe(5);
+  });
+
+  it('example from spec: two splitters', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    // Visited: (0,1), (1,1), (2,0), (2,2), (3,1), (3,3) = 6
+    // Note: (3,-1) is out of bounds, (3,1) visited by two beams but counts once
+    expect(countBeamCells(grid)).toBe(6);
+  });
+
+  it('source on single row grid', () => {
+    const grid = [['S']];
+    // Only the source cell
+    expect(countBeamCells(grid)).toBe(1);
+  });
+
+  it('beam exits left boundary via splitter', () => {
+    const grid = [
+      ['S', '.', '.'],
+      ['^', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    // S at (0,0), beam to (1,0) hits splitter
+    // down-left: (2,-1) out of bounds
+    // down-right: (2,1) in bounds
+    // Visited: (0,0), (1,0), (2,1) = 3
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  it('no splitters, beam goes straight down', () => {
+    const grid = [
+      ['.', '.', 'S'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    // Visited: (0,2), (1,2), (2,2), (3,2) = 4
+    expect(countBeamCells(grid)).toBe(4);
+  });
+
+  it('splitter immediately below source', () => {
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '^', '.'],
+      ['.', '.', '.'],
+    ];
+    // S(0,1) -> (1,1) splitter -> down-left(2,0), down-right(2,2)
+    // Visited: (0,1), (1,1), (2,0), (2,2) = 4
+    expect(countBeamCells(grid)).toBe(4);
+  });
+
+  it('chain of splitters on diagonal', () => {
+    const grid = [
+      ['.', '.', 'S', '.', '.'],
+      ['.', '.', '^', '.', '.'],
+      ['.', '.', '.', '^', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    // S(0,2) -> (1,2) splitter
+    // down-left: (2,1) -> (3,0) exit. Visited: (2,1), (3,0)
+    // down-right: (2,3) hits splitter
+    //   -> down-left: (3,2). down-right: (3,4)
+    // Visited: (0,2), (1,2), (2,1), (2,3), (3,0), (3,2), (3,4) = 7
+    expect(countBeamCells(grid)).toBe(7);
+  });
+});
+
+describe('countBeamPaths', () => {
+  it('no splitters: single path', () => {
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('example from spec: one splitter = 2 paths', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it('example from spec: two splitters = 4 paths', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(4n);
+  });
+
+  it('single row: source only = 1 path', () => {
+    const grid = [['S']];
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('splitter at edge: one path absorbed, one exits', () => {
+    const grid = [
+      ['S', '.', '.'],
+      ['^', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    // Splitter at (1,0): down-left exits at (2,-1), down-right to (2,1)
+    // Both are paths: 2
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it('chain of splitters: 2^n paths', () => {
+    // 3 splitters in a chain: first splits, each child hits a splitter
+    const grid = [
+      ['.', '.', '.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '^', '.', '.', '.'],
+      ['.', '.', '^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.', '.', '.'],
+    ];
+    // First splitter: 2 beams, each hits a splitter: 4 paths total
+    expect(countBeamPaths(grid)).toBe(4n);
+  });
+
+  it('deeply chained splitters: exponential paths', () => {
+    // Build a grid where each split leads to more splits
+    // Row 0: source at col 4
+    // Row 1: splitter at col 4
+    // Row 2: splitters at col 3 and 5
+    // Row 3: splitters at col 2, 4, 6
+    // etc.
+    const size = 10;
+    const grid: string[][] = [];
+    for (let r = 0; r < size; r++) {
+      grid.push(new Array(2 * size).fill('.'));
+    }
+    const sourceCol = size;
+    grid[0][sourceCol] = 'S';
+
+    // Place splitters in a binary tree pattern
+    // Row 1: splitter at sourceCol
+    grid[1][sourceCol] = '^';
+    // Row 2: splitters at sourceCol-1, sourceCol+1
+    grid[2][sourceCol - 1] = '^';
+    grid[2][sourceCol + 1] = '^';
+    // Row 3: splitters at sourceCol-2, sourceCol, sourceCol+2
+    grid[3][sourceCol - 2] = '^';
+    grid[3][sourceCol] = '^';
+    grid[3][sourceCol + 2] = '^';
+
+    // After 3 levels of splitting: 2^3 = 8 paths
+    // But some beams from row 2 splitters converge at sourceCol in row 3
+    // Left splitter at (2, sourceCol-1) -> down-left (3, sourceCol-2) [splitter], down-right (3, sourceCol) [splitter]
+    // Right splitter at (2, sourceCol+1) -> down-left (3, sourceCol) [splitter], down-right (3, sourceCol+2) [splitter]
+    // So (3, sourceCol) is hit by 2 beams, each producing 2 paths = 4 from that splitter
+    // Total: from (3, sourceCol-2): 2 paths, from (3, sourceCol) via left: 2 paths,
+    //   from (3, sourceCol) via right: 2 paths, from (3, sourceCol+2): 2 paths = 8 paths
+    expect(countBeamPaths(grid)).toBe(8n);
+  });
+
+  it('performance: large grid with many splitters', () => {
+    const rows = 200;
+    const cols = 200;
+    const grid: string[][] = [];
+    for (let r = 0; r < rows; r++) {
+      grid.push(new Array(cols).fill('.'));
+    }
+    grid[0][100] = 'S';
+
+    // Place ~50 splitters in a chain pattern
+    const col = 100;
+    for (let i = 1; i <= 50 && i < rows; i++) {
+      grid[i * 3][col] = '^';
+      // Alternate: place a splitter that one branch will hit
+    }
+
+    const start = performance.now();
+    const result = countBeamPaths(grid);
+    const elapsed = performance.now() - start;
+
+    expect(elapsed).toBeLessThan(5000);
+    expect(result).toBeGreaterThan(0n);
+  });
+});
