@@ -0,0 +1,143 @@
+type Direction = 'down' | 'down-left' | 'down-right';
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+function nextPos(row: number, col: number, dir: Direction): [number, number] {
+  switch (dir) {
+    case 'down':
+      return [row + 1, col];
+    case 'down-left':
+      return [row + 1, col - 1];
+    case 'down-right':
+      return [row + 1, col + 1];
+  }
+}
+
+function findSource(grid: string[][]): [number, number] {
+  for (let c = 0; c < grid[0].length; c++) {
+    if (grid[0][c] === 'S') {
+      return [0, c];
+    }
+  }
+  throw new Error('No source found');
+}
+
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  if (grid.length === 0 || grid[0].length === 0) return 0;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const [sr, sc] = findSource(grid);
+
+  const visitedSet = new Set<string>();
+  const processedBeams = new Set<string>();
+  const queue: Beam[] = [];
+
+  // Source cell is visited
+  visitedSet.add(`${sr},${sc}`);
+
+  // Initial beam moves down from source
+  const firstStep = nextPos(sr, sc, 'down');
+  if (inBounds(firstStep[0], firstStep[1], rows, cols)) {
+    const beamKey = `${firstStep[0]},${firstStep[1]},down`;
+    processedBeams.add(beamKey);
+    queue.push({ row: firstStep[0], col: firstStep[1], dir: 'down' });
+  }
+
+  while (queue.length > 0) {
+    const beam = queue.pop()!;
+    const { dir } = beam;
+    let { row, col } = beam;
+
+    while (inBounds(row, col, rows, cols)) {
+      visitedSet.add(`${row},${col}`);
+
+      if (grid[row][col] === '^') {
+        // Split into two beams
+        const [lr, lc] = nextPos(row, col, 'down-left');
+        const [rr, rc] = nextPos(row, col, 'down-right');
+        if (inBounds(lr, lc, rows, cols)) {
+          const leftKey = `${lr},${lc},down-left`;
+          if (!processedBeams.has(leftKey)) {
+            processedBeams.add(leftKey);
+            queue.push({ row: lr, col: lc, dir: 'down-left' });
+          }
+        }
+        if (inBounds(rr, rc, rows, cols)) {
+          const rightKey = `${rr},${rc},down-right`;
+          if (!processedBeams.has(rightKey)) {
+            processedBeams.add(rightKey);
+            queue.push({ row: rr, col: rc, dir: 'down-right' });
+          }
+        }
+        break; // Original beam consumed
+      }
+
+      [row, col] = nextPos(row, col, dir);
+    }
+  }
+
+  return visitedSet.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  if (grid.length === 0 || grid[0].length === 0) return 0n;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const [sr, sc] = findSource(grid);
+
+  // Memoize: for a beam entering cell (r,c) with direction dir,
+  // how many paths does it produce?
+  const memo = new Map<string, bigint>();
+
+  function countFrom(row: number, col: number, dir: Direction): bigint {
+    const key = `${row},${col},${dir}`;
+    const cached = memo.get(key);
+    if (cached !== undefined) return cached;
+
+    let r = row;
+    let c = col;
+
+    while (inBounds(r, c, rows, cols)) {
+      if (grid[r][c] === '^') {
+        // Split: count paths from both children
+        const [lr, lc] = nextPos(r, c, 'down-left');
+        const [rr, rc] = nextPos(r, c, 'down-right');
+
+        const leftPaths = inBounds(lr, lc, rows, cols)
+          ? countFrom(lr, lc, 'down-left')
+          : 1n; // exits grid = 1 path
+        const rightPaths = inBounds(rr, rc, rows, cols)
+          ? countFrom(rr, rc, 'down-right')
+          : 1n; // exits grid = 1 path
+
+        const result = leftPaths + rightPaths;
+        memo.set(key, result);
+        return result;
+      }
+
+      [r, c] = nextPos(r, c, dir);
+    }
+
+    // Beam exited the grid = 1 path
+    memo.set(key, 1n);
+    return 1n;
+  }
+
+  // Start: beam goes down from source
+  const [firstR, firstC] = nextPos(sr, sc, 'down');
+  if (!inBounds(firstR, firstC, rows, cols)) {
+    return 1n; // Beam immediately exits = 1 path
+  }
+
+  return countFrom(firstR, firstC, 'down');
+}
