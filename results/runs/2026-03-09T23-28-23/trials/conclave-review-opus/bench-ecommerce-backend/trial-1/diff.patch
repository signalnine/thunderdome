   328→  beforeEach(() => {\n   329→    bus = new EventBus();\n   330→  });\n   331→\n   332→  it('should notify subscribed users on order status change', async () => {\n   333→    const notifications = createNotificationService(bus);\n   334→    notifications.subscribe('user1');\n   335→\n   336→    // Simulate order created event to register order-user mapping\n   337→    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 50 });\n   338→    // Simulate order status change\n   339→    await bus.emit(Events.ORDER_STATUS_CHANGED, { orderId: 'o1', status: 'confirmed', previousStatus: 'pending' });\n   340→\n   341→    const notifs = notifications.getNotifications('user1');\n   342→    expect(notifs).toHaveLength(1);\n   343→    expect(notifs[0].type).toBe('order_status');\n   344→  });\n   345→\n   346→  it('should notify on payment events', async () => {\n   347→    const notifications = createNotificationService(bus);\n   348→    notifications.subscribe('user1');\n   349→\n   350→    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 50 });\n   351→    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: 'success', transactionId: 't1' });\n   352→\n   353→    const notifs = notifications.getNotifications('user1');\n   354→    expect(notifs).toHaveLength(1);\n   355→    expect(notifs[0].type).toBe('payment');\n   356→  });\n   357→\n   358→  it('should not notify unsubscribed users', async () => {\n   359→    const notifications = createNotificationService(bus);\n   360→\n   361→    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 50 });\n   362→    await bus.emit(Events.ORDER_STATUS_CHANGED, { orderId: 'o1', status: 'confirmed', previousStatus: 'pending' });\n   363→\n   364→    expect(notifications.getNotifications('user1')).toHaveLength(0);\n   365→  });\n   366→});\n   367→\n   368→describe('AnalyticsService', () => {\n   369→ 