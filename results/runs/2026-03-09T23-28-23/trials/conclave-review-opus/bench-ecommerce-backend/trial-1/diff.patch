r order ${event.orderId}: ${event.status}`);\n    }\n  });\n\n  return {\n    subscribe(userId: string): void {\n      subscribers.add(userId);\n    },\n\n    getNotifications(userId: string) {\n      return (notifications.get(userId) ?? []).map(n => ({ ...n }));\n    },\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":379,"cache_read_input_tokens":22961,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":379},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"9c21e810-48f4-4316-8514-8e2b4ccafd11","uuid":"ae57fceb-0158-4c4d-886c-d0cc9870d599"}
