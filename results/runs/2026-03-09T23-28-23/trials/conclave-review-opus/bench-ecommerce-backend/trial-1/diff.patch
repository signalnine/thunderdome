antity: 2, price: 10 }]);\n   192→    expect(result.subtotal).toBe(20);\n   193→    expect(result.discount).toBe(0);\n   194→    expect(result.tax).toBe(2); // 10%\n   195→    expect(result.total).toBe(22);\n   196→  });\n   197→\n   198→  it('should apply discount code before tax', () => {\n   199→    const pricing = createPricingService(bus);\n   200→    pricing.addDiscountCode('SAVE10', 10);\n   201→    const result = pricing.calculateTotal([{ productId: 'p1', quantity: 1, price: 100 }], 'SAVE10');\n   202→    expect(result.subtotal).toBe(100);\n   203→    expect(result.discount).toBe(10);\n   204→    expect(result.tax).toBe(9); // 10% of 90\n   205→    expect(result.total).toBe(99);\n   206→  });\n   207→\n   208→  it('should track prices from product:created events', async () => {\n   209→    const pricing = createPricingService(bus);\n   210→    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'Test', price: 25, category: 'cat' });\n   211→    expect(pricing.getPrice('p1')).toBe(25);\n   212→  });\n   213→\n   214→  it('should return 0 for unknown product price', () => {\n   215→    const pricing = createPricingService(bus);\n   216→    expect(pricing.getPrice('unknown')).toBe(0);\n   217→  });\n   218→\n   219→  it('should ignore invalid discount codes', () => {\n   220→    const pricing = createPricingService(bus);\n   221→    const result = pricing.calculateTotal([{ productId: 'p1', quantity: 1, price: 100 }], 'INVALID');\n   222→    expect(result.discount).toBe(0);\n   223→    expect(result.total).toBe(110);\n   224→  });\n   225→});\n   226→\n   227→describe('OrderService', () => {\n   228→  let bus: EventBus;\n   229→\n   230→  beforeEach(() => {\n   231→    bus = new EventBus();\n   232→  });\n   233→\n   234→  it('should create and retrieve an order', () => {\n   235→    const orders = createOrderService(bus);\n   236→    const id = orders.createOrder('user1', 'cart1', 50);\n   237→    const order = orders.getOrder(id);\n   238→    expec