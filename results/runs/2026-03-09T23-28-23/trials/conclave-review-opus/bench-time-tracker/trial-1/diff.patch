@@ -0,0 +1,101 @@
+import { readFileSync, writeFileSync, mkdirSync } from "node:fs";
+import { dirname } from "node:path";
+
+export interface TimeEntry {
+  task: string;
+  start: string;
+  stop: string | null;
+}
+
+interface StoredData {
+  entries: TimeEntry[];
+}
+
+export class TimeTracker {
+  private entries: TimeEntry[] = [];
+  private filePath: string;
+
+  constructor(filePath: string) {
+    this.filePath = filePath;
+    this.load();
+  }
+
+  private load(): void {
+    try {
+      const raw = readFileSync(this.filePath, "utf-8");
+      const data: StoredData = JSON.parse(raw) as StoredData;
+      this.entries = data.entries;
+    } catch {
+      this.entries = [];
+    }
+  }
+
+  private save(): void {
+    const dir = dirname(this.filePath);
+    mkdirSync(dir, { recursive: true });
+    const data: StoredData = { entries: this.entries };
+    writeFileSync(this.filePath, JSON.stringify(data, null, 2), "utf-8");
+  }
+
+  start(task: string): void {
+    if (!task || task.trim().length === 0) {
+      throw new Error("Task name cannot be empty");
+    }
+
+    // Auto-stop any running timer
+    const running = this.getRunningEntry();
+    if (running) {
+      running.stop = new Date().toISOString();
+    }
+
+    this.entries.push({
+      task,
+      start: new Date().toISOString(),
+      stop: null,
+    });
+
+    this.save();
+  }
+
+  stop(): TimeEntry {
+    const running = this.getRunningEntry();
+    if (!running) {
+      throw new Error("No timer is currently running");
+    }
+
+    running.stop = new Date().toISOString();
+    this.save();
+    return { ...running };
+  }
+
+  getEntries(from?: Date, to?: Date): TimeEntry[] {
+    return this.entries.filter((entry) => {
+      const entryStart = new Date(entry.start);
+      if (from && entryStart < from) return false;
+      if (to && entryStart > to) return false;
+      return true;
+    });
+  }
+
+  getSummary(): Record<string, number> {
+    const summary: Record<string, number> = {};
+    const now = new Date();
+
+    for (const entry of this.entries) {
+      const start = new Date(entry.start);
+      const end = entry.stop ? new Date(entry.stop) : now;
+      const duration = end.getTime() - start.getTime();
+
+      if (summary[entry.task] === undefined) {
+        summary[entry.task] = 0;
+      }
+      summary[entry.task] += duration;
+    }
+
+    return summary;
+  }
+
+  private getRunningEntry(): TimeEntry | undefined {
+    return this.entries.find((e) => e.stop === null);
+  }
+}
