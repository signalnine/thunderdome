+import { describe, it, expect, beforeEach, afterEach } from "vitest";
+import { TimeTracker } from "./tracker.js";
+import { mkdtempSync, rmSync } from "node:fs";
+import { join } from "node:path";
+import { tmpdir } from "node:os";
+
+let tempDir: string;
+let filePath: string;
+
+beforeEach(() => {
+  tempDir = mkdtempSync(join(tmpdir(), "tracker-test-"));
+  filePath = join(tempDir, "data.json");
+});
+
+afterEach(() => {
+  rmSync(tempDir, { recursive: true, force: true });
+});
+
+describe("TimeTracker", () => {
+  describe("start/stop", () => {
+    it("should start and stop a timer", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("coding");
+      const entry = tracker.stop();
+      expect(entry.task).toBe("coding");
+      expect(entry.start).toBeTruthy();
+      expect(entry.stop).toBeTruthy();
+    });
+
+    it("should throw when starting with empty name", () => {
+      const tracker = new TimeTracker(filePath);
+      expect(() => tracker.start("")).toThrow("Task name cannot be empty");
+      expect(() => tracker.start("   ")).toThrow("Task name cannot be empty");
+    });
+
+    it("should throw when stopping with no running timer", () => {
+      const tracker = new TimeTracker(filePath);
+      expect(() => tracker.stop()).toThrow("No timer is currently running");
+    });
+
+    it("should auto-stop previous timer when starting new one", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("task1");
+      tracker.start("task2");
+
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(2);
+      expect(entries[0].task).toBe("task1");
+      expect(entries[0].stop).toBeTruthy();
+      expect(entries[1].task).toBe("task2");
+      expect(entries[1].stop).toBeNull();
+    });
+  });
+
+  describe("persistence", () => {
+    it("should persist entries to file", () => {
+      const tracker1 = new TimeTracker(filePath);
+      tracker1.start("work");
+      tracker1.stop();
+
+      const tracker2 = new TimeTracker(filePath);
+      const entries = tracker2.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].task).toBe("work");
+    });
+
+    it("should create parent directories automatically", () => {
+      const deepPath = join(tempDir, "a", "b", "c", "data.json");
+      const tracker = new TimeTracker(deepPath);
+      tracker.start("deep");
+      tracker.stop();
+
+      const tracker2 = new TimeTracker(deepPath);
+      expect(tracker2.getEntries()).toHaveLength(1);
+    });
+  });
+
+  describe("getEntries with date filtering", () => {
+    it("should return all entries without filters", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("a");
+      tracker.stop();
+      tracker.start("b");
+      tracker.stop();
+
+      expect(tracker.getEntries()).toHaveLength(2);
+    });
+
+    it("should filter by date range", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("a");
+      tracker.stop();
+
+      const afterFirst = new Date();
+      tracker.start("b");
+      tracker.stop();
+
+      const filtered = tracker.getEntries(afterFirst);
+      expect(filtered.length).toBeGreaterThanOrEqual(1);
+      expect(filtered[filtered.length - 1].task).toBe("b");
+    });
+  });
+
+  describe("getSummary", () => {
+    it("should sum durations per task", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("coding");
+      tracker.stop();
+      tracker.start("coding");
+      tracker.stop();
+      tracker.start("review");
+      tracker.stop();
+
+      const summary = tracker.getSummary();
+      expect(summary["coding"]).toBeGreaterThanOrEqual(0);
+      expect(summary["review"]).toBeGreaterThanOrEqual(0);
+      expect(Object.keys(summary)).toHaveLength(2);
+    });
+
+    it("should use current time for running tasks", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("running");
+
+      const summary = tracker.getSummary();
+      expect(summary["running"]).toBeGreaterThanOrEqual(0);
+    });
+  });
+
+  describe("unicode support", () => {
+    it("should handle unicode task names", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("日本語タスク");
+      tracker.stop();
+
+      const entries = tracker.getEntries();
+      expect(entries[0].task).toBe("日本語タスク");
+    });
+
+    it("should handle emoji task names", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("🚀 Deploy");
+      tracker.stop();
+
+      // Persistence check
+      const tracker2 = new TimeTracker(filePath);
+      const entries = tracker2.getEntries();
+      expect(entries[0].task).toBe("🚀 Deploy");
+    });
+
+    it("should handle mixed unicode and emoji", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("café ☕ работа 🔧");
+      tracker.stop();
+
+      const summary = tracker.getSummary();
+      expect(summary["café ☕ работа 🔧"]).toBeGreaterThanOrEqual(0);
+    });
+  });
+});
