+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 2: Named Queues', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  it('should use "default" queue when no name is specified', () => {
+    const task = tq.add('test');
+    expect(task.queue).toBe('default');
+  });
+
+  it('should add tasks to specific named queues', () => {
+    tq.add('email', { queue: 'emails' });
+    tq.add('sms', { queue: 'notifications' });
+
+    expect(tq.size('emails')).toBe(1);
+    expect(tq.size('notifications')).toBe(1);
+    expect(tq.size('default')).toBe(0);
+  });
+
+  it('should retrieve tasks from specific queues', () => {
+    tq.add('email-task', { queue: 'emails' });
+    tq.add('sms-task', { queue: 'notifications' });
+
+    const emailTask = tq.next('emails');
+    expect(emailTask?.payload).toBe('email-task');
+
+    const smsTask = tq.next('notifications');
+    expect(smsTask?.payload).toBe('sms-task');
+  });
+
+  it('should return null for non-existent queue', () => {
+    expect(tq.next('nonexistent')).toBeNull();
+  });
+
+  it('should list all queue names', () => {
+    tq.add('a', { queue: 'q1' });
+    tq.add('b', { queue: 'q2' });
+    tq.add('c'); // default
+
+    const names = tq.listQueues();
+    expect(names).toContain('q1');
+    expect(names).toContain('q2');
+    expect(names).toContain('default');
+  });
+
+  it('queues operate independently', () => {
+    tq.add('a', { queue: 'q1' });
+    tq.add('b', { queue: 'q2' });
+
+    expect(tq.size('q1')).toBe(1);
+    tq.next('q1');
+    expect(tq.size('q1')).toBe(0);
+    expect(tq.size('q2')).toBe(1);
+  });
+});
