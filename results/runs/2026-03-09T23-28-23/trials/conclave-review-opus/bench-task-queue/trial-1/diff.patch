failCount).toBe(0);\n\n    expect(tq.getDeadLetterQueue()).toHaveLength(0);\n    expect(tq.size()).toBe(1);\n  });\n\n  it('should clear dead letter queue', () => {\n    const t1 = tq.add('a', { maxRetries: 1 });\n    const t2 = tq.add('b', { maxRetries: 1 });\n\n    tq.next();\n    tq.fail(t1.id);\n    tq.next();\n    tq.fail(t2.id);\n\n    expect(tq.getDeadLetterQueue()).toHaveLength(2);\n    tq.clearDeadLetterQueue();\n    expect(tq.getDeadLetterQueue()).toHaveLength(0);\n  });\n\n  it('should have independent DLQs per named queue', () => {\n    const t1 = tq.add('a', { queue: 'q1', maxRetries: 1 });\n    const t2 = tq.add('b', { queue: 'q2', maxRetries: 1 });\n\n    tq.next('q1');\n    tq.fail(t1.id);\n    tq.next('q2');\n    tq.fail(t2.id);\n\n    expect(tq.getDeadLetterQueue('q1')).toHaveLength(1);\n    expect(tq.getDeadLetterQueue('q2')).toHaveLength(1);\n\n    tq.clearDeadLetterQueue('q1');\n    expect(tq.getDeadLetterQueue('q1')).toHaveLength(0);\n    expect(tq.getDeadLetterQueue('q2')).toHaveLength(1);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1066,"cache_read_input_tokens":32701,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1066},"output_tokens":18,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"39620430-694a-4989-ac58-ce8fd865b6a5","uuid":"bba3906d-e404-411f-99f6-2a5603de0b34"}
