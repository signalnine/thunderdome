+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0146faRbm71JCrq2g1KbG3Ex","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach, vi, afterEach } from 'vitest';\n     2→import { TaskQueue } from '../src/index.js';\n     3→\n     4→describe('Phase 5: Retry with Backoff', () => {\n     5→  let tq: TaskQueue;\n     6→\n     7→  beforeEach(() => {\n     8→    tq = new TaskQueue();\n     9→    vi.useFakeTimers();\n    10→  });\n    11→\n    12→  afterEach(() => {\n    13→    vi.useRealTimers();\n    14→  });\n    15→\n    16→  it('should complete a task', () => {\n    17→    const task = tq.add('work');\n    18→    tq.next();\n    19→    tq.complete(task.id);\n    20→    expect(task.status).toBe('completed');\n    21→  });\n    22→\n    23→  it('should fail a task and retry with backoff', () => {\n    24→    const task = tq.add('work', { maxRetries: 3, backoffDelay: 1000 });\n    25→\n    26→    // First attempt\n    27→    tq.next();\n    28→    expect(task.attempt).toBe(1);\n    29→    tq.fail(task.id, new Error('fail1'));\n    30→    expect(task.status).toBe('pending');\n    31→    expect(task.failCount).toBe(1);\n    32→\n    33→    // Should not be available immediately (1000ms backoff)\n    34→    expect(tq.next()).toBeNull();\n    35→    vi.advanceTimersByTime(1000);\n    36→\n    37→    // Second attempt\n    38→    const r2 = tq.next();\n    39→    expect(r2?.attempt).toBe(2);\n    40→    tq.fail(task.id, new Error('fail2'));\n    41→    expect(task.failCount).toBe(2);\n    42→\n    43→    // 2000ms backoff\n    44→    expect(tq.next()).toBeNull();\n    45→    vi.advanceTimersByTime(2000);\n    46→\n    47→    // Third attempt\n    48→    const r3 = tq.next();\n    49→    expect(r3?.attempt).toBe(3);\n    50→    tq.fail(task.id, new Error('fail3'));\n    51→\n    52→    // All retries exhausted\n    53→    expect(task.status).toBe('failed');\n    54→    expect(task.failCount).toBe(3);\n    55→  });\n    56→\n    57→  it('should use default maxRetries of 3', () => {\n    58→    const task = tq.add('work');\n    59→    expect(task.maxRetries).toBe(3);\n    60→  });\n    61→\n    62→  it('should use default backoffDelay of 1000ms', () => {\n    63→    const task = tq.add('work');\n    64→    expect(task.backoffDelay).toBe(1000);\n    65→  });\n    66→\n    67→  it('should allow configurable retries per task', () => {\n    68→    const task = tq.add('work', { maxRetries: 1, backoffDelay: 500 });\n    69→    expect(task.maxRetries).toBe(1);\n    70→    expect(task.backoffDelay).toBe(500);\n    71→  });\n    72→\n    73→  it('should retain original queue and priority on retry', () => {\n    74→    const task = tq.add('work', { queue: 'special', priority: 2, maxRetries: 2, backoffDelay: 100 });\n    75→    tq.next('special');\n    76→    tq.fail(task.id);\n    77→\n    78→    expect(task.queue).toBe('special');\n    79→    expect(task.priority).toBe(2);\n    80→\n    81→    vi.advanceTimersByTime(100);\n    82→    const retried = tq.next('special');\n    83→    expect(retried?.queue).toBe('special');\n    84→    expect(retried?.priority).toBe(2);\n    85→  });\n    86→\n    87→  it('should throw when completing a non-processing task', () => {\n    88→    const task = tq.add('work');\n    89→    expect(() => tq.complete(task.id)).toThrow();\n    90→  });\n    91→\n    92→  it('should throw when failing a non-processing task', () => {\n    93→    const task = tq.add('work');\n    94→    expect(() => tq.fail(task.id)).toThrow();\n    95→  });\n    96→});\n    97→"}]},"parent_tool_use_id":"toolu_01EiN2LBzJgtEnc2nAR1jW9R","session_id":"39620430-694a-4989-ac58-ce8fd865b6a5","uuid":"6e58ec7a-e4d8-4f03-8d6b-9bfcc4e256d2"}
