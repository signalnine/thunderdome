+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GRdo95wRBcixpyf46ZmZM7","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach } from 'vitest';\n     2→import { TaskQueue } from '../src/index.js';\n     3→\n     4→describe('Phase 10: Recurring Tasks', () => {\n     5→  let tq: TaskQueue;\n     6→\n     7→  beforeEach(() => {\n     8→    tq = new TaskQueue();\n     9→  });\n    10→\n    11→  it('should create a schedule', () => {\n    12→    const schedule = tq.addSchedule('*/5 * * * *', 'default', { job: 'cleanup' });\n    13→    expect(schedule.id).toBeDefined();\n    14→    expect(schedule.expression).toBe('*/5 * * * *');\n    15→    expect(schedule.queue).toBe('default');\n    16→  });\n    17→\n    18→  it('should list active schedules', () => {\n    19→    tq.addSchedule('*/5 * * * *', 'default', 'a');\n    20→    tq.addSchedule('0 * * * *', 'default', 'b');\n    21→\n    22→    expect(tq.listSchedules()).toHaveLength(2);\n    23→  });\n    24→\n    25→  it('should remove a schedule', () => {\n    26→    const s = tq.addSchedule('*/5 * * * *', 'default', 'a');\n    27→    tq.removeSchedule(s.id);\n    28→    expect(tq.listSchedules()).toHaveLength(0);\n    29→  });\n    30→\n    31→  it('should throw when removing non-existent schedule', () => {\n    32→    expect(() => tq.removeSchedule('nonexistent')).toThrow();\n    33→  });\n    34→\n    35→  it('should enqueue tasks on tick when due (every N minutes)', () => {\n    36→    tq.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });\n    37→\n    38→    // At minute 0 (divisible by 5) -> should fire\n    39→    const t0 = new Date('2024-01-01T00:00:00Z');\n    40→    const created = tq.tick(t0);\n    41→    expect(created).toHaveLength(1);\n    42→    expect(created[0].payload).toEqual({ type: 'cleanup' });\n    43→  });\n    44→\n    45→  it('should not enqueue tasks when not due', () => {\n    46→    tq.addSchedule('*/5 * * * *', 'default', 'cleanup');\n    47→\n    48→    // At minute 3 (not divisible by 5) -> should not fire\n    49→    const t3 = new Date('2024-01-01T00:03:00Z');\n    50→    expect(tq.tick(t3)).toHaveLength(0);\n    51→  });\n    52→\n    53→  it('should not double-fire in the same minute', () => {\n    54→    tq.addSchedule('*/5 * * * *', 'default', 'cleanup');\n    55→\n    56→    const t0 = new Date('2024-01-01T00:00:00Z');\n    57→    tq.tick(t0);\n    58→    const second = tq.tick(new Date('2024-01-01T00:00:30Z'));\n    59→    expect(second).toHaveLength(0);\n    60→  });\n    61→\n    62→  it('should support hourly schedule', () => {\n    63→    tq.addSchedule('0 * * * *', 'default', 'hourly');\n    64→\n    65→    // On the hour -> should fire\n    66→    expect(tq.tick(new Date('2024-01-01T01:00:00Z'))).toHaveLength(1);\n    67→    // Not on the hour -> should not fire\n    68→    expect(tq.tick(new Date('2024-01-01T01:30:00Z'))).toHaveLength(0);\n    69→  });\n    70→\n    71→  it('should support daily schedule', () => {\n    72→    tq.addSchedule('0 0 * * *', 'default', 'daily');\n    73→\n    74→    // Midnight -> should fire\n    75→    expect(tq.tick(new Date('2024-01-01T00:00:00Z'))).toHaveLength(1);\n    76→    // Not midnight -> should not fire\n    77→    expect(tq.tick(new Date('2024-01-01T12:00:00Z'))).toHaveLength(0);\n    78→  });\n    79→\n    80→  it('should stop scheduling after removal', () => {\n    81→    const s = tq.addSchedule('*/5 * * * *', 'default', 'cleanup');\n    82→\n    83→    expect(tq.tick(new Date('2024-01-01T00:00:00Z'))).toHaveLength(1);\n    84→    tq.removeSchedule(s.id);\n    85→    expect(tq.tick(new Date('2024-01-01T00:05:00Z'))).toHaveLength(0);\n    86→  });\n    87→\n    88→  it('should apply priority from schedule', () => {\n    89→    tq.addSchedule('*/5 * * * *', 'default', 'urgent', 1);\n    90→\n    91→    const tasks = tq.tick(new Date('2024-01-01T00:00:00Z'));\n    92→    expect(tasks[0].priority).toBe(1);\n    93→  });\n    94→});\n 