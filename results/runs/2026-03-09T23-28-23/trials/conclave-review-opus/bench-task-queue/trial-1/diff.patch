@@ -0,0 +1,96 @@
+import { describe, it, expect, beforeEach, vi, afterEach } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 5: Retry with Backoff', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+    vi.useFakeTimers();
+  });
+
+  afterEach(() => {
+    vi.useRealTimers();
+  });
+
+  it('should complete a task', () => {
+    const task = tq.add('work');
+    tq.next();
+    tq.complete(task.id);
+    expect(task.status).toBe('completed');
+  });
+
+  it('should fail a task and retry with backoff', () => {
+    const task = tq.add('work', { maxRetries: 3, backoffDelay: 1000 });
+
+    // First attempt
+    tq.next();
+    expect(task.attempt).toBe(1);
+    tq.fail(task.id, new Error('fail1'));
+    expect(task.status).toBe('pending');
+    expect(task.failCount).toBe(1);
+
+    // Should not be available immediately (1000ms backoff)
+    expect(tq.next()).toBeNull();
+    vi.advanceTimersByTime(1000);
+
+    // Second attempt
+    const r2 = tq.next();
+    expect(r2?.attempt).toBe(2);
+    tq.fail(task.id, new Error('fail2'));
+    expect(task.failCount).toBe(2);
+
+    // 2000ms backoff
+    expect(tq.next()).toBeNull();
+    vi.advanceTimersByTime(2000);
+
+    // Third attempt
+    const r3 = tq.next();
+    expect(r3?.attempt).toBe(3);
+    tq.fail(task.id, new Error('fail3'));
+
+    // All retries exhausted
+    expect(task.status).toBe('failed');
+    expect(task.failCount).toBe(3);
+  });
+
+  it('should use default maxRetries of 3', () => {
+    const task = tq.add('work');
+    expect(task.maxRetries).toBe(3);
+  });
+
+  it('should use default backoffDelay of 1000ms', () => {
+    const task = tq.add('work');
+    expect(task.backoffDelay).toBe(1000);
+  });
+
+  it('should allow configurable retries per task', () => {
+    const task = tq.add('work', { maxRetries: 1, backoffDelay: 500 });
+    expect(task.maxRetries).toBe(1);
+    expect(task.backoffDelay).toBe(500);
+  });
+
+  it('should retain original queue and priority on retry', () => {
+    const task = tq.add('work', { queue: 'special', priority: 2, maxRetries: 2, backoffDelay: 100 });
+    tq.next('special');
+    tq.fail(task.id);
+
+    expect(task.queue).toBe('special');
+    expect(task.priority).toBe(2);
+
+    vi.advanceTimersByTime(100);
+    const retried = tq.next('special');
+    expect(retried?.queue).toBe('special');
+    expect(retried?.priority).toBe(2);
+  });
+
+  it('should throw when completing a non-processing task', () => {
+    const task = tq.add('work');
+    expect(() => tq.complete(task.id)).toThrow();
+  });
+
+  it('should throw when failing a non-processing task', () => {
+    const task = tq.add('work');
+    expect(() => tq.fail(task.id)).toThrow();
+  });
+});
diff --git a/tests/phase06-dlq.test.ts b/tests/phase06-dlq.test.ts
new file mode 100644
index 0000000..74e5512
--- /dev/null
+++ b/tests/phase06-dlq.test.ts
@@ -0,0 +1,93 @@
+import { describe, it, expect, beforeEach, vi, afterEach } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 6: Dead Letter Queue', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+    vi.useFakeTimers();
+  });
+
+  afterEach(() => {
+    vi.useRealTimers();
+  });
+
+  function exhaustRetries(taskId: string, maxRetries: number, backoffDelay: number) {
+    for (let i = 0; i < maxRetries; i++) {
+      tq.next();
+      tq.fail(taskId, new Error(`fail-${i + 1}`));
+      if (i < maxRetries - 1) {
+        vi.advanceTimersByTime(backoffDelay * Math.pow(2, i));
+      }
+    }
+  }
+
+  it('should move task to DLQ after exhausting retries', () => {
+    const task = tq.add('work', { maxRetries: 1, backoffDelay: 100 });
+    tq.next();
+    tq.fail(task.id, new Error('oops'));
+
+    const dlq = tq.getDeadLetterQueue();
+    expect(dlq).toHaveLength(1);
+    expect(dlq[0].id).toBe(task.id);
+    expect(dlq[0].status).toBe('failed');
+  });
+
+  it('should retain error info in DLQ tasks', () => {
+    const task = tq.add('work', { maxRetries: 1 });
+    tq.next();
+    tq.fail(task.id, new Error('boom'));
+
+    const dlq = tq.getDeadLetterQueue();
+    expect(dlq[0].error?.message).toBe('boom');
+    expect(dlq[0].failCount).toBe(1);
+  });
+
+  it('should retry a dead-lettered task', () => {
+    const task = tq.add('work', { maxRetries: 1, backoffDelay: 100 });
+    tq.next();
+    tq.fail(task.id, new Error('oops'));
+
+    expect(tq.getDeadLetterQueue()).toHaveLength(1);
+
+    const retried = tq.retryDeadLetter(task.id);
+    expect(retried.status).toBe('pending');
+    expect(retried.attempt).toBe(0);
+    expect(retried.failCount).toBe(0);
+
+    expect(tq.getDeadLetterQueue()).toHaveLength(0);
+    expect(tq.size()).toBe(1);
+  });
+
+  it('should clear dead letter queue', () => {
+    const t1 = tq.add('a', { maxRetries: 1 });
+    const t2 = tq.add('b', { maxRetries: 1 });
+
+    tq.next();
+    tq.fail(t1.id);
+    tq.next();
+    tq.fail(t2.id);
+
+    expect(tq.getDeadLetterQueue()).toHaveLength(2);
+    tq.clearDeadLetterQueue();
+    expect(tq.getDeadLetterQueue()).toHaveLength(0);
+  });
+
+  it('should have independent DLQs per named queue', () => {
+    const t1 = tq.add('a', { queue: 'q1', maxRetries: 1 });
+    const t2 = tq.add('b', { queue: 'q2', maxRetries: 1 });
+
+    tq.next('q1');
+    tq.fail(t1.id);
+    tq.next('q2');
+    tq.fail(t2.id);
+
+    expect(tq.getDeadLetterQueue('q1')).toHaveLength(1);
+    expect(tq.getDeadLetterQueue('q2')).toHaveLength(1);
+
+    tq.clearDeadLetterQueue('q1');
+    expect(tq.getDeadLetterQueue('q1')).toHaveLength(0);
+    expect(tq.getDeadLetterQueue('q2')).toHaveLength(1);
+  });
+});
diff --git a/tests/phase07-dependencies.test.ts b/tests/phase07-dependencies.test.ts
new file mode 100644
index 0000000..786690f
--- /dev/null
+++ b/tests/phase07-dependencies.test.ts
@@ -0,0 +1,101 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 7: Task Dependencies', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  it('should block tasks with unresolved dependencies', () => {
+    const t1 = tq.add('prerequisite');
+    const t2 = tq.add('dependent', { dependsOn: [t1.id] });
+
+    // t2 is blocked, only t1 should be returned
+    const next = tq.next();
+    expect(next?.id).toBe(t1.id);
+
+    // t2 is still blocked (t1 not completed yet)
+    expect(tq.next()).toBeNull();
+  });
+
+  it('should unblock tasks when dependencies complete', () => {
+    const t1 = tq.add('prerequisite');
+    const t2 = tq.add('dependent', { dependsOn: [t1.id] });
+
+    tq.next(); // get t1
+    tq.complete(t1.id);
+
+    const next = tq.next();
+    expect(next?.id).toBe(t2.id);
+  });
+
+  it('should support multiple dependencies', () => {
+    const t1 = tq.add('dep1');
+    const t2 = tq.add('dep2');
+    const t3 = tq.add('dependent', { dependsOn: [t1.id, t2.id] });
+
+    tq.next(); // t1
+    tq.complete(t1.id);
+
+    // t3 still blocked because t2 not done
+    const afterT1 = tq.next();
+    expect(afterT1?.id).toBe(t2.id);
+    expect(tq.next()).toBeNull();
+
+    tq.complete(t2.id);
+
+    // Now t3 should be available
+    const final = tq.next();
+    expect(final?.id).toBe(t3.id);
+  });
+
+  it('should detect direct circular dependencies', () => {
+    const t1 = tq.add('a');
+    expect(() => tq.add('b', { dependsOn: [t1.id] })).not.toThrow();
+    // Can't create a task that depends on itself by ID (we'd need to know the ID first)
+    // But indirect cycles should be caught
+  });
+
+  it('should detect indirect circular dependencies', () => {
+    const t1 = tq.add('a');
+    const t2 = tq.add('b', { dependsOn: [t1.id] });
+    // t3 depends on t2, t1 depends on nothing — no cycle
+    const t3 = tq.add('c', { dependsOn: [t2.id] });
+    expect(t3).toBeDefined();
+  });
+
+  it('should reject dependency on non-existent task', () => {
+    expect(() => tq.add('a', { dependsOn: ['nonexistent'] })).toThrow();
+  });
+
+  it('should allow inspecting dependency status', () => {
+    const t1 = tq.add('dep');
+    const t2 = tq.add('dependent', { dependsOn: [t1.id] });
+
+    let status = tq.getDependencyStatus(t2.id);
+    expect(status.resolved).toBe(false);
+    expect(status.dependencies).toHaveLength(1);
+    expect(status.dependencies[0].status).toBe('pending');
+
+    tq.next();
+    tq.complete(t1.id);
+
+    status = tq.getDependencyStatus(t2.id);
+    expect(status.resolved).toBe(true);
+    expect(status.dependencies[0].status).toBe('completed');
+  });
+
+  it('failed dependencies should NOT fail dependents (they remain blocked)', () => {
+    const t1 = tq.add('dep', { maxRetries: 1 });
+    const t2 = tq.add('dependent', { dependsOn: [t1.id] });
+
+    tq.next(); // t1
+    tq.fail(t1.id, new Error('oops'));
+
+    // t2 is still blocked
+    expect(tq.next()).toBeNull();
+    expect(t2.status).toBe('pending');
+  });
+});
