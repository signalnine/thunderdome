s})`);\n    }\n\n    const wasProcessing = task.status === 'processing';\n    task.status = 'cancelled';\n    // Ensure cancelled tasks are never retried\n    task.maxRetries = 0;\n\n    const q = this.getQueue(task.queue);\n    if (q) {\n      if (wasProcessing) {\n        q.activeCount = Math.max(0, q.activeCount - 1);\n      }\n      q.tasks.delete(task.id);\n    }\n  }\n\n  // ---- Phase 10: Recurring Tasks ----\n\n  addSchedule(expression: string, queueName: string, payload: unknown, priority?: number): CronSchedule {\n    // Validate the cron expression by parsing it\n    parseCron(expression);\n\n    const schedule: CronSchedule = {\n      id: randomUUID(),\n      expression,\n      queue: queueName,\n      payload,\n      priority,\n    };\n\n    this.schedules.set(schedule.id, schedule);\n    return schedule;\n  }\n\n  removeSchedule(scheduleId: string): void {\n    if (!this.schedules.has(scheduleId)) {\n      throw new Error(`Schedule \"${scheduleId}\" not found`);\n    }\n    this.schedules.delete(scheduleId);\n  }\n\n  listSchedules(): CronSchedule[] {\n    return Array.from(this.schedules.values());\n  }\n\n  tick(now?: Date): Task[] {\n    const currentTime = now ?? new Date();\n    // Truncate to minute boundary for cron matching\n    const matchTime = new Date(currentTime);\n    matchTime.setSeconds(0, 0);\n\n    const created: Task[] = [];\n\n    for (const schedule of this.schedules.values()) {\n      const cron = parseCron(schedule.expression);\n      if (!cron.matches(matchTime)) continue;\n\n      // Avoid double-firing in the same minute\n      if (schedule.lastRun) {\n        const lastMinute = new Date(schedule.lastRun);\n        lastMinute.setSeconds(0, 0);\n        if (lastMinute.getTime() === matchTime.getTime()) continue;\n      }\n\n      schedule.lastRun = currentTime;\n\n      const task = this.add(schedule.payload, {\n        queue: schedule.queue,\n        priority: schedule.priority,\n      });\n      created.push(task);\n    }\n\n