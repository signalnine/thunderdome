sk.id);\n    55→\n    56→    vi.advanceTimersByTime(100);\n    57→    const result = await shutdownPromise;\n    58→\n    59→    expect(result.completed).toBe(1);\n    60→    expect(result.forceCancelled).toBe(0);\n    61→  });\n    62→\n    63→  it('should run shutdown callbacks', async () => {\n    64→    let callbackRan = false;\n    65→    tq.onShutdown(() => {\n    66→      callbackRan = true;\n    67→    });\n    68→\n    69→    const promise = tq.shutdown();\n    70→    vi.advanceTimersByTime(100);\n    71→    await promise;\n    72→\n    73→    expect(callbackRan).toBe(true);\n    74→  });\n    75→\n    76→  it('should be idempotent - multiple calls return same result', async () => {\n    77→    const p1 = tq.shutdown();\n    78→    const p2 = tq.shutdown();\n    79→\n    80→    vi.advanceTimersByTime(100);\n    81→    const r1 = await p1;\n    82→    const r2 = await p2;\n    83→\n    84→    expect(r1).toBe(r2);\n    85→  });\n    86→\n    87→  it('should return a shutdown summary', async () => {\n    88→    const promise = tq.shutdown();\n    89→    vi.advanceTimersByTime(100);\n    90→    const result = await promise;\n    91→\n    92→    expect(result).toHaveProperty('completed');\n    93→    expect(result).toHaveProperty('forceCancelled');\n    94→    expect(result).toHaveProperty('durationMs');\n    95→  });\n    96→});\n    97→"}]},"parent_tool_use_id":"toolu_01EiN2LBzJgtEnc2nAR1jW9R","session_id":"39620430-694a-4989-ac58-ce8fd865b6a5","uuid":"4cd5c103-8093-4958-b22b-7e716b4a15a0"}
