eue independently', () => {\n    50→    tq.add('q1-low', { queue: 'q1', priority: 10 });\n    51→    tq.add('q1-high', { queue: 'q1', priority: 1 });\n    52→    tq.add('q2-low', { queue: 'q2', priority: 10 });\n    53→\n    54→    expect(tq.next('q1')?.payload).toBe('q1-high');\n    55→    expect(tq.next('q2')?.payload).toBe('q2-low');\n    56→  });\n    57→});\n    58→"}]},"parent_tool_use_id":"toolu_01EiN2LBzJgtEnc2nAR1jW9R","session_id":"39620430-694a-4989-ac58-ce8fd865b6a5","uuid":"e6ef6f57-8817-4f47-ac0a-fd0c97c96718"}
