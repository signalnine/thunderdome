-  - `timeout`: maximum milliseconds to wait for processing tasks (default: 30000)
-- **`onShutdown(callback)`** - Register a callback to be called during shutdown.
+Add the ability to shut down the task queue system in an orderly fashion.
 
 ## Requirements
 
-- After `shutdown()` is called, `enqueue()` should throw an error
-- `shutdown()` waits for all currently processing tasks to complete
-- If processing tasks don't complete within the timeout, they are force-cancelled
-- `onShutdown` callbacks are called during the shutdown process
-- The returned summary object includes:
-  - `completed`: number of tasks that completed during shutdown
-  - `cancelled`: number of tasks that were force-cancelled
-  - `elapsed`: time in milliseconds the shutdown took
-- Multiple calls to `shutdown()` should be idempotent (return the same promise/result)
-- If there are no processing tasks, shutdown resolves immediately
-- Force-cancelled tasks have their status set to `'cancelled'`
+- A shutdown operation should signal the system to stop accepting new tasks.
+- After shutdown is initiated, attempting to add new tasks should produce an error.
+- The shutdown should wait for all currently-processing tasks to finish, up to a configurable timeout.
+- If processing tasks do not complete within the timeout, they should be force-cancelled.
+- Callbacks can be registered to run during the shutdown process.
+- The shutdown should produce a summary indicating how many tasks completed, how many were force-cancelled, and how long the shutdown took.
+- Calling shutdown multiple times should be safe and return the same result.
+- If no tasks are processing, shutdown should complete immediately.
diff --git a/src/TaskQueue.ts b/src/TaskQueue.ts
new file mode 100644
index 0000000..82938c9
--- /dev/null
+++ b/src/TaskQueue.ts
@@ -0,0 +1,535 @@
+import { randomUUID } from 'node:crypto';
+import {
+  Task,
+  TaskOptions,
+  TaskStatus,
+  createTask,
+  ProgressInfo,
+  ProgressListener,
+  CronSchedule,
+  MiddlewareFn,
+  HandlerFn,
+  ShutdownResult,
+} from './types.js';
+import { parseCron } from './cron.js';
+
+interface QueueState {
+  tasks: Map<string, Task>;
+  deadLetterQueue: Task[];
+  concurrencyLimit: number;
+  activeCount: number;
+  middleware: MiddlewareFn[];
+  handler: HandlerFn | null;
+}
+
+export class TaskQueue {
+  private queues = new Map<string, QueueState>();
+  private allTasks = new Map<string, Task>();
+  private progressListeners = new Map<string, Set<ProgressListener>>();
+  private schedules = new Map<string, CronSchedule>();
+  private isShutdown = false;
+  private shutdownPromise: Promise<ShutdownResult> | null = null;
+  private shutdownCallbacks: Array<() => void | Promise<void>> = [];
+
+  // ---- Internal helpers ----
+
+  private getOrCreateQueue(name: string): QueueState {
+    let q = this.queues.get(name);
+    if (!q) {
+      q = {
+        tasks: new Map(),
+        deadLetterQueue: [],
+        concurrencyLimit: 0, // 0 means unlimited
+        activeCount: 0,
+        middleware: [],
+        handler: null,
+      };
+      this.queues.set(name, q);
+    }
+    return q;
+  }
+
+  private getQueue(name: string): QueueState | undefined {
+    return this.queues.get(name);
+  }
+
+  private areDependenciesMet(task: Task): boolean {
+    for (const depId of task.dependsOn) {
+      const dep = this.allTasks.get(depId);
+      if (!dep || dep.status !== 'completed') {
+        return false;
+      }
+    }
+    return true;
+  }
+
+  private detectCircularDeps(taskId: string, deps: string[], visited: Set<string> = new Set()): boolean {
+    for (const depId of deps) {
+      if (depId === taskId) return true;
+      if (visited.has(depId)) continue;
+      visited.add(depId);
+      const depTask = this.allTasks.get(depId);
+      if (depTask && depTask.dependsOn.length > 0) {
+        if (this.detectCircularDeps(taskId, depTask.dependsOn, visited)) {
+          return true;
+        }
+      }
+    }
+    return false;
+  }
+
+  // ---- Phase 1: Basic FIFO Queue ----
+
+  add<T = unknown>(payload: T, options?: TaskOptions): Task<T> {
+    if (this.isShutdown) {
+      throw new Error('Queue system is shut down: cannot add new tasks');
+    }
+
+    const task = createTask(payload, options);
+    const q = this.getOrCreateQueue(task.queue);
+
+    // Phase 7: validate dependencies
+    if (task.dependsOn.length > 0) {
+      for (const depId of task.dependsOn) {
+        if (!this.allTasks.has(depId)) {
+          throw new Error(`Dependency task "${depId}" does not exist`);
+        }
+      }
+      if (this.detectCircularDeps(task.id, task.dependsOn)) {
+        throw new Error('Circular dependency detected');
+      }
+    }
+
+    q.tasks.set(task.id, task);
+    this.allTasks.set(task.id, task);
+    return task;
+  }
+
+  next(queueName: string = 'default'): Task | null {
+    const q = this.getQueue(queueName);
+    if (!q) return null;
+
+    // Phase 8: check concurrency limit
+    if (q.concurrencyLimit > 0 && q.activeCount >= q.concurrencyLimit) {
+      return null;
+    }
+
+    const now = new Date();
+    const candidates: Task[] = [];
+
+    for (const task of q.tasks.values()) {
+      if (task.status !== 'pending') continue;
+      if (task.availableAt > now) continue;
+      if (task.dependsOn.length > 0 && !this.areDependenciesMet(task)) continue;
+      candidates.push(task);
+    }
+
+    if (candidates.length === 0) return null;
+
+    // Sort: priority asc (lower = higher priority), then availableAt asc, then createdAt asc
+    candidates.sort((a, b) => {
+      if (a.priority !== b.priority) return a.priority - b.priority;
+      const aTime = a.availableAt.getTime();
+      const bTime = b.availableAt.getTime();
+      if (aTime !== bTime) return aTime - bTime;
+      return a.createdAt.getTime() - b.createdAt.getTime();
+    });
+
+    const task = candidates[0];
+    task.status = 'processing';
+    task.attempt += 1;
+    q.activeCount += 1;
+    return task;
+  }
+
+  size(queueName: string = 'default'): number {
+    const q = this.getQueue(queueName);
+    if (!q) return 0;
+    let count = 0;
+    for (const task of q.tasks.values()) {
+      if (task.status === 'pending') count++;
+    }
+    return count;
+  }
+
+  getTask(taskId: string): Task | undefined {
+    return this.allTasks.get(taskId);
+  }
+
+  // ---- Phase 2: Named Queues ----
+
+  listQueues(): string[] {
+    return Array.from(this.queues.keys());
+  }
+
+  // ---- Phase 5: Complete / Fail ----
+
+  complete(taskId: string): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) throw new Error(`Task "${taskId}" not found`);
+    if (task.status !== 'processing') {
+      throw new Error(`Task "${taskId}" is not in processing state`);
+    }
+
+    task.status = 'completed';
+    task.progress = { percentage: 100 };
+
+    const q = this.getQueue(task.queue);
+    if (q) {
+      q.activeCount = Math.max(0, q.activeCount - 1);
+    }
+  }
+
+  fail(taskId: string, error?: Error): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) throw new Error(`Task "${taskId}" not found`);
+    if (task.status !== 'processing') {
+      throw new Error(`Task "${taskId}" is not in processing state`);
+    }
+
+    task.error = error;
+    task.failCount += 1;
+
+    const q = this.getQueue(task.queue);
+    if (q) {
+      q.activeCount = Math.max(0, q.activeCount - 1);
+    }
+
+    if (task.attempt < task.maxRetries) {
+      // Retry with backoff
+      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);
+      task.status = 'pending';
+      task.availableAt = new Date(Date.now() + delay);
+    } else {
+      // Exhausted retries
+      task.status = 'failed';
+      // Phase 6: move to DLQ
+      if (q) {
+        q.tasks.delete(task.id);
+        q.deadLetterQueue.push(task);
+      }
+    }
+  }
+
+  // ---- Phase 6: Dead Letter Queue ----
+
+  getDeadLetterQueue(queueName: string = 'default'): Task[] {
+    const q = this.getQueue(queueName);
+    if (!q) return [];
+    return [...q.deadLetterQueue];
+  }
+
+  retryDeadLetter(taskId: string): Task {
+    for (const q of this.queues.values()) {
+      const idx = q.deadLetterQueue.findIndex(t => t.id === taskId);
+      if (idx !== -1) {
+        const task = q.deadLetterQueue.splice(idx, 1)[0];
+        task.status = 'pending';
+        task.attempt = 0;
+        task.failCount = 0;
+        task.error = undefined;
+        task.availableAt = new Date();
+        q.tasks.set(task.id, task);
+        return task;
+      }
+    }
+    throw new Error(`Task "${taskId}" not found in any dead letter queue`);
+  }
+
+  clearDeadLetterQueue(queueName: string = 'default'): void {
+    const q = this.getQueue(queueName);
+    if (q) {
+      q.deadLetterQueue = [];
+    }
+  }
+
+  // ---- Phase 7: Task Dependencies ----
+
+  getDependencyStatus(taskId: string): { taskId: string; resolved: boolean; dependencies: Array<{ id: string; status: TaskStatus }> } {
+    const task = this.allTasks.get(taskId);
+    if (!task) throw new Error(`Task "${taskId}" not found`);
+
+    const dependencies = task.dependsOn.map(depId => {
+      const dep = this.allTasks.get(depId);
+      if (!dep) throw new Error(`Dependency task "${depId}" not found`);
+      return { id: depId, status: dep.status };
+    });
+
+    const resolved = this.areDependenciesMet(task);
+
+    return { taskId, resolved, dependencies };
+  }
+
+  // ---- Phase 8: Concurrency Control ----
+
+  setConcurrency(queueName: string, limit: number): void {
+    const q = this.getOrCreateQueue(queueName);
+    q.concurrencyLimit = limit;
+  }
+
+  getConcurrency(queueName: string): { limit: number; active: number } {
+    const q = this.getQueue(queueName);
+    if (!q) return { limit: 0, active: 0 };
+    return { limit: q.concurrencyLimit, active: q.activeCount };
+  }
+
+  // ---- Phase 9: Progress Tracking and Cancellation ----
+
+  reportProgress(taskId: string, percentage: number, message?: string): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) throw new Error(`Task "${taskId}" not found`);
+    if (task.status !== 'processing') {
+      throw new Error(`Task "${taskId}" is not in processing state`);
+    }
+    if (percentage < 0 || percentage > 100) {
+      throw new Error('Progress must be between 0 and 100');
+    }
+
+    task.progress = { percentage, message };
+
+    const listeners = this.progressListeners.get(taskId);
+    if (listeners) {
+      for (const listener of listeners) {
+        listener(task.progress);
+      }
+    }
+  }
+
+  getProgress(taskId: string): ProgressInfo {
+    const task = this.allTasks.get(taskId);
+    if (!task) throw new Error(`Task "${taskId}" not found`);
+    return { ...task.progress };
+  }
+
+  onProgress(taskId: string, listener: ProgressListener): () => void {
+    let listeners = this.progressListeners.get(taskId);
+    if (!listeners) {
+      listeners = new Set();
+      this.progressListeners.set(taskId, listeners);
+    }
+    listeners.add(listener);
+
+    // Return unsubscribe function
+    return () => {
+      listeners!.delete(listener);
+      if (listeners!.size === 0) {
+        this.progressListeners.delete(taskId);
+      }
+    };
+  }
+
+  cancel(taskId: string): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) throw new Error(`Task "${taskId}" not found`);
+
+    if (task.status !== 'pending' && task.status !== 'processing') {
+      throw new Error(`Task "${taskId}" cannot be cancelled (status: ${task.status})`);
+    }
+
+    const wasProcessing = task.status === 'processing';
+    task.status = 'cancelled';
+    // Ensure cancelled tasks are never retried
+    task.maxRetries = 0;
+
+    const q = this.getQueue(task.queue);
+    if (q) {
+      if (wasProcessing) {
+        q.activeCount = Math.max(0, q.activeCount - 1);
+      }
+      q.tasks.delete(task.id);
+    }
+  }
+
+  // ---- Phase 10: Recurring Tasks ----
+
+  addSchedule(expression: string, queueName: string, payload: unknown, priority?: number): CronSchedule {
+    // Validate the cron expression by parsing it
+    parseCron(expression);
+
+    const schedule: CronSchedule = {
+      id: randomUUID(),
+      expression,
+      queue: queueName,
+      payload,
+      priority,
+    };
+
+    this.schedules.set(schedule.id, schedule);
+    return schedule;
+  }
+
+  removeSchedule(scheduleId: string): void {
+    if (!this.schedules.has(scheduleId)) {
+      throw new Error(`Schedule "${scheduleId}" not found`);
+    }
+    this.schedules.delete(scheduleId);
+  }
+
+  listSchedules(): CronSchedule[] {
+    return Array.from(this.schedules.values());
+  }
+
+  tick(now?: Date): Task[] {
+    const currentTime = now ?? new Date();
+    // Truncate to minute boundary for cron matching
+    const matchTime = new Date(currentTime);
+    matchTime.setSeconds(0, 0);
+
+    const created: Task[] = [];
+
+    for (const schedule of this.schedules.values()) {
+      const cron = parseCron(schedule.expression);
+      if (!cron.matches(matchTime)) continue;
+
+      // Avoid double-firing in the same minute
+      if (schedule.lastRun) {
+        const lastMinute = new Date(schedule.lastRun);
+        lastMinute.setSeconds(0, 0);
+        if (lastMinute.getTime() === matchTime.getTime()) continue;
+      }
+
+      schedule.lastRun = currentTime;
+
+      const task = this.add(schedule.payload, {
+        queue: schedule.queue,
+        priority: schedule.priority,
+      });
+      created.push(task);
+    }
+
+    return created;
+  }
+
+  // ---- Phase 11: Middleware Pipeline ----
+
+  use(queueName: string, middleware: MiddlewareFn): void {
+    const q = this.getOrCreateQueue(queueName);
+    q.middleware.push(middleware);
+  }
+
+  setHandler(queueName: string, handler: HandlerFn): void {
+    const q = this.getOrCreateQueue(queueName);
+    q.handler = handler;
+  }
+
+  async process(queueName: string = 'default'): Promise<Task | null> {
+    const task = this.next(queueName);
+    if (!task) return null;
+
+    const q = this.getQueue(queueName)!;
+
+    const middlewareStack = [...q.middleware];
+    const handler = q.handler;
+
+    let index = 0;
+    const executeNext = async (): Promise<void> => {
+      if (index < middlewareStack.length) {
+        const mw = middlewareStack[index++];
+        await mw(task, executeNext);
+      } else if (handler) {
+        await handler(task);
+      }
+    };
+
+    try {
+      await executeNext();
+      if (task.status === 'processing') {
+        this.complete(task.id);
+      }
+    } catch (err) {
+      if (task.status === 'processing') {
+        this.fail(task.id, err instanceof Error ? err : new Error(String(err)));
+      }
+    }
+
+    return task;
+  }
+
+  // ---- Phase 12: Graceful Shutdown ----
+
+  onShutdown(callback: () => void | Promise<void>): void {
+    this.shutdownCallbacks.push(callback);
+  }
+
+  async shutdown(timeoutMs: number = 30000): Promise<ShutdownResult> {
+    if (this.shutdownPromise) {
+      return this.shutdownPromise;
+    }
+
+    this.isShutdown = true;
+
+    this.shutdownPromise = this.performShutdown(timeoutMs);
+    return this.shutdownPromise;
+  }
+
+  private async performShutdown(timeoutMs: number): Promise<ShutdownResult> {
+    const startTime = Date.now();
+
+    // Run shutdown callbacks (continue even if one fails)
+    for (const callback of this.shutdownCallbacks) {
+      try {
+        await callback();
+      } catch {
+        // Shutdown callbacks should not prevent shutdown from proceeding
+      }
+    }
+
+    // Find all currently processing tasks
+    const processingTasks: Task[] = [];
+    for (const task of this.allTasks.values()) {
+      if (task.status === 'processing') {
+        processingTasks.push(task);
+      }
+    }
+
+    if (processingTasks.length === 0) {
+      return {
+        completed: 0,
+        forceCancelled: 0,
+        durationMs: Date.now() - startTime,
+      };
+    }
+
+    // Wait for processing tasks to complete, up to timeout
+    let completed = 0;
+    let forceCancelled = 0;
+
+    await new Promise<void>((resolve) => {
+      const checkInterval = setInterval(() => {
+        const stillProcessing = processingTasks.filter(t => t.status === 'processing');
+        if (stillProcessing.length === 0 || Date.now() - startTime >= timeoutMs) {
+          clearInterval(checkInterval);
+          resolve();
+        }
+      }, 10);
+
+      // Also set an absolute timeout
+      setTimeout(() => {
+        clearInterval(checkInterval);
+        resolve();
+      }, timeoutMs);
+    });
+
+    // Count results and force-cancel remaining
+    for (const task of processingTasks) {
+      if (task.status === 'processing') {
+        task.status = 'cancelled';
+        task.maxRetries = 0;
+        const q = this.getQueue(task.queue);
+        if (q) {
+          q.activeCount = Math.max(0, q.activeCount - 1);
+          q.tasks.delete(task.id);
+        }
+        forceCancelled++;
+      } else {
+        completed++;
+      }
+    }
+
+    return {
+      completed,
+      forceCancelled,
+      durationMs: Date.now() - startTime,
+    };
+  }
+}
