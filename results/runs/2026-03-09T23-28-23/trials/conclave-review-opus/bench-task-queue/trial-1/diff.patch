+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011M5YYaXyrjULcrKsVcNPiV","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach } from 'vitest';\n     2→import { TaskQueue } from '../src/index.js';\n     3→\n     4→describe('Phase 7: Task Dependencies', () => {\n     5→  let tq: TaskQueue;\n     6→\n     7→  beforeEach(() => {\n     8→    tq = new TaskQueue();\n     9→  });\n    10→\n    11→  it('should block tasks with unresolved dependencies', () => {\n    12→    const t1 = tq.add('prerequisite');\n    13→    const t2 = tq.add('dependent', { dependsOn: [t1.id] });\n    14→\n    15→    // t2 is blocked, only t1 should be returned\n    16→    const next = tq.next();\n    17→    expect(next?.id).toBe(t1.id);\n    18→\n    19→    // t2 is still blocked (t1 not completed yet)\n    20→    expect(tq.next()).toBeNull();\n    21→  });\n    22→\n    23→  it('should unblock tasks when dependencies complete', () => {\n    24→    const t1 = tq.add('prerequisite');\n    25→    const t2 = tq.add('dependent', { dependsOn: [t1.id] });\n    26→\n    27→    tq.next(); // get t1\n    28→    tq.complete(t1.id);\n    29→\n    30→    const next = tq.next();\n    31→    expect(next?.id).toBe(t2.id);\n    32→  });\n    33→\n    34→  it('should support multiple dependencies', () => {\n    35→    const t1 = tq.add('dep1');\n    36→    const t2 = tq.add('dep2');\n    37→    const t3 = tq.add('dependent', { dependsOn: [t1.id, t2.id] });\n    38→\n    39→    tq.next(); // t1\n    40→    tq.complete(t1.id);\n    41→\n    42→    // t3 still blocked because t2 not done\n    43→    const afterT1 = tq.next();\n    44→    expect(afterT1?.id).toBe(t2.id);\n    45→    expect(tq.next()).toBeNull();\n    46→\n    47→    tq.complete(t2.id);\n    48→\n    49→    // Now t3 should be available\n    50→    const final = tq.next();\n    51→    expect(final?.id).toBe(t3.id);\n    52→  });\n    53→\n    54→  it('should detect direct circular dependencies', () => {\n    55→    const t1 = tq.add('a');\n    56→    expect(() => tq.add('b', { dependsOn: [t1.id] })).not.toThrow();\n    57→    // Can't create a task that depends on itself by ID (we'd need to know the ID first)\n    58→    // But indirect cycles should be caught\n    59→  });\n    60→\n    61→  it('should detect indirect circular dependencies', () => {\n    62→    const t1 = tq.add('a');\n    63→    const t2 = tq.add('b', { dependsOn: [t1.id] });\n    64→    // t3 depends on t2, t1 depends on nothing — no cycle\n    65→    const t3 = tq.add('c', { dependsOn: [t2.id] });\n    66→    expect(t3).toBeDefined();\n    67→  });\n    68→\n    69→  it('should reject dependency on non-existent task', () => {\n    70→    expect(() => tq.add('a', { dependsOn: ['nonexistent'] })).toThrow();\n    71→  });\n    72→\n    73→  it('should allow inspecting dependency status', () => {\n    74→    const t1 = tq.add('dep');\n    75→    const t2 = tq.add('dependent', { dependsOn: [t1.id] });\n    76→\n    77→    let status = tq.getDependencyStatus(t2.id);\n    78→    expect(status.resolved).toBe(false);\n    79→    expect(status.dependencies).toHaveLength(1);\n    80→    expect(status.dependencies[0].status).toBe('pending');\n    81→\n    82→    tq.next();\n    83→    tq.complete(t1.id);\n    84→\n    85→    status = tq.getDependencyStatus(t2.id);\n    86→    expect(status.resolved).toBe(true);\n    87→    expect(status.dependencies[0].status).toBe('completed');\n    88→  });\n    89→\n    90→  it('failed dependencies should NOT fail dependents (they remain blocked)', () => {\n    91→    const t1 = tq.add('dep', { maxRetries: 1 });\n    92→    const t2 = tq.add('dependent', { dependsOn: [t1.id] });\n    93→\n    94→    tq.next(); // t1\n    95→    tq.fail(t1.id, new Error('oops'));\n    96→\n    97→    // t2 is still blocked\n    98→    expect(tq.next()).toBeNull();\n    99→    expect(t2.status).toBe('pending');\n   100→  });\n   101→});\n   102→"}]},"parent_tool_use_id":"toolu_01EiN2LBzJgtEnc2nAR1jW9R","session_id":"39620430-694a-4989-ac58-ce8fd865b6a5","uuid":"c317c554-3113-495a-95d9-caab544ed261"}
