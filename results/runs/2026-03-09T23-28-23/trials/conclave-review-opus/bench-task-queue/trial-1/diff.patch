+
+  it('should reject new tasks after shutdown', async () => {
+    const promise = tq.shutdown();
+    vi.advanceTimersByTime(100);
+    await promise;
+
+    expect(() => tq.add('test')).toThrow(/shut down/);
+  });
+
+  it('should complete immediately if no tasks are processing', async () => {
+    const promise = tq.shutdown();
+    vi.advanceTimersByTime(100);
+    const result = await promise;
+
+    expect(result.completed).toBe(0);
+    expect(result.forceCancelled).toBe(0);
+    expect(result.durationMs).toBeGreaterThanOrEqual(0);
+  });
+
+  it('should wait for processing tasks and then force cancel on timeout', async () => {
+    tq.add('long-task');
+    tq.next(); // start processing
+
+    const shutdownPromise = tq.shutdown(100);
+
+    // Advance past the timeout
+    vi.advanceTimersByTime(200);
+
+    const result = await shutdownPromise;
+    expect(result.forceCancelled).toBe(1);
+  });
+
+  it('should count completed tasks during shutdown', async () => {
+    const task = tq.add('quick-task');
+    tq.next();
+
+    const shutdownPromise = tq.shutdown(5000);
+
+    // Complete the task before timeout
+    tq.complete(task.id);
+
+    vi.advanceTimersByTime(100);
+    const result = await shutdownPromise;
+
+    expect(result.completed).toBe(1);
+    expect(result.forceCancelled).toBe(0);
+  });
+
+  it('should run shutdown callbacks', async () => {
+    let callbackRan = false;
+    tq.onShutdown(() => {
+      callbackRan = true;
+    });
+
+    const promise = tq.shutdown();
+    vi.advanceTimersByTime(100);
+    await promise;
+
+    expect(callbackRan).toBe(true);
+  });
+
+  it('should be idempotent - multiple calls return same result', async () => {
+    const p1 = tq.shutdown();
+    const p2 = tq.shutdown();
+
+    vi.advanceTimersByTime(100);
+    const r1 = await p1;
+    const r2 = await p2;
+
+    expect(r1).toBe(r2);
+  });
+
+  it('should return a shutdown summary', async () => {
