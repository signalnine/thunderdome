+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VPZhZmkLotJK2qg6incmGW","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach } from 'vitest';\n     2→import { TaskQueue } from '../src/index.js';\n     3→\n     4→describe('Phase 1: Basic FIFO Queue', () => {\n     5→  let tq: TaskQueue;\n     6→\n     7→  beforeEach(() => {\n     8→    tq = new TaskQueue();\n     9→  });\n    10→\n    11→  it('should add a task and return a task object', () => {\n    12→    const task = tq.add({ message: 'hello' });\n    13→    expect(task.id).toBeDefined();\n    14→    expect(task.payload).toEqual({ message: 'hello' });\n    15→    expect(task.status).toBe('pending');\n    16→    expect(task.createdAt).toBeInstanceOf(Date);\n    17→  });\n    18→\n    19→  it('should assign unique IDs to each task', () => {\n    20→    const t1 = tq.add('task1');\n    21→    const t2 = tq.add('task2');\n    22→    expect(t1.id).not.toBe(t2.id);\n    23→  });\n    24→\n    25→  it('should retrieve tasks in FIFO order', () => {\n    26→    tq.add('first');\n    27→    tq.add('second');\n    28→    tq.add('third');\n    29→\n    30→    const r1 = tq.next();\n    31→    expect(r1?.payload).toBe('first');\n    32→    expect(r1?.status).toBe('processing');\n    33→\n    34→    const r2 = tq.next();\n    35→    expect(r2?.payload).toBe('second');\n    36→\n    37→    const r3 = tq.next();\n    38→    expect(r3?.payload).toBe('third');\n    39→  });\n    40→\n    41→  it('should return null when no tasks are available', () => {\n    42→    expect(tq.next()).toBeNull();\n    43→  });\n    44→\n    45→  it('should track the size of pending tasks', () => {\n    46→    expect(tq.size()).toBe(0);\n    47→    tq.add('a');\n    48→    tq.add('b');\n    49→    expect(tq.size()).toBe(2);\n    50→    tq.next();\n    51→    expect(tq.size()).toBe(1);\n    52→  });\n    53→\n    54→  it('should transition task to processing state on next()', () => {\n    55→    const task = tq.add('work');\n    56→    const retrieved = tq.next();\n    57→    expect(retrieved?.id).toBe(task.id);\n    58→    expect(retrieved?.status).toBe('processing');\n    59→  });\n    60→});\n    61→"}]},"parent_tool_use_id":"toolu_01EiN2LBzJgtEnc2nAR1jW9R","session_id":"39620430-694a-4989-ac58-ce8fd865b6a5","uuid":"c69e7293-82d9-436c-8fe7-abbfe5dfc7e7"}
