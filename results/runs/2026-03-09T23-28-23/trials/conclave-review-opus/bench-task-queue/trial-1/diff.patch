+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AnRgyQjETamvDTm46Hezr9","type":"tool_result","content":"     1→import { randomUUID } from 'node:crypto';\n     2→import {\n     3→  Task,\n     4→  TaskOptions,\n     5→  TaskStatus,\n     6→  createTask,\n     7→  ProgressInfo,\n     8→  ProgressListener,\n     9→  CronSchedule,\n    10→  MiddlewareFn,\n    11→  HandlerFn,\n    12→  ShutdownResult,\n    13→} from './types.js';\n    14→import { parseCron } from './cron.js';\n    15→\n    16→interface QueueState {\n    17→  tasks: Map<string, Task>;\n    18→  deadLetterQueue: Task[];\n    19→  concurrencyLimit: number;\n    20→  activeCount: number;\n    21→  middleware: MiddlewareFn[];\n    22→  handler: HandlerFn | null;\n    23→}\n    24→\n    25→export class TaskQueue {\n    26→  private queues = new Map<string, QueueState>();\n    27→  private allTasks = new Map<string, Task>();\n    28→  private progressListeners = new Map<string, Set<ProgressListener>>();\n    29→  private schedules = new Map<string, CronSchedule>();\n    30→  private isShutdown = false;\n    31→  private shutdownPromise: Promise<ShutdownResult> | null = null;\n    32→  private shutdownCallbacks: Array<() => void | Promise<void>> = [];\n    33→\n    34→  // ---- Internal helpers ----\n    35→\n    36→  private getOrCreateQueue(name: string): QueueState {\n    37→    let q = this.queues.get(name);\n    38→    if (!q) {\n    39→      q = {\n    40→        tasks: new Map(),\n    41→        deadLetterQueue: [],\n    42→        concurrencyLimit: 0, // 0 means unlimited\n    43→        activeCount: 0,\n    44→        middleware: [],\n    45→        handler: null,\n    46→      };\n    47→      this.queues.set(name, q);\n    48→    }\n    49→    return q;\n    50→  }\n    51→\n    52→  private getQueue(name: string): QueueState | undefined {\n    53→    return this.queues.get(name);\n    54→  }\n    55→\n    56→  private areDependenciesMet(task: Task): boolean {\n    57→    for (const depId of task.dependsOn) {\n    58→      const dep = this.allTasks.get(depId);\n    59→      if (!dep || dep.status !== 'completed') {\n    60→        return false;\n    61→      }\n    62→    }\n    63→    return true;\n    64→  }\n    65→\n    66→  private detectCircularDeps(taskId: string, deps: string[], visited: Set<string> = new Set()): boolean {\n    67→    for (const depId of deps) {\n    68→      if (depId === taskId) return true;\n    69→      if (visited.has(depId)) continue;\n    70→      visited.add(depId);\n    71→      const depTask = this.allTasks.get(depId);\n    72→      if (depTask && depTask.dependsOn.length > 0) {\n    73→        if (this.detectCircularDeps(taskId, depTask.dependsOn, visited)) {\n    74→          return true;\n    75→        }\n    76→      }\n    77→    }\n    78→    return false;\n    79→  }\n    80→\n    81→  // ---- Phase 1: Basic FIFO Queue ----\n    82→\n    83→  add<T = unknown>(payload: T, options?: TaskOptions): Task<T> {\n    84→    if (this.isShutdown) {\n    85→      throw new Error('Queue system is shut down: cannot add new tasks');\n    86→    }\n    87→\n    88→    const task = createTask(payload, options);\n    89→    const q = this.getOrCreateQueue(task.queue);\n    90→\n    91→    // Phase 7: validate dependencies\n    92→    if (task.dependsOn.length > 0) {\n    93→      for (const depId of task.dependsOn) {\n    94→        if (!this.allTasks.has(depId)) {\n    95→          throw new Error(`Dependency task \"${depId}\" does not exist`);\n    96→        }\n    97→      }\n    98→      if (this.detectCircularDeps(task.id, task.dependsOn)) {\n    99→        throw new Error('Circular dependency detected');\n   100→      }\n   101→    }\n   102→\n   103→    q.tasks.set(task.id, task);\n   104→    this.allTasks.set(task.id, task);\n   105→    return task;\n   106→  }\n   107→\n   108→  next(queueName: string = 'default'): Task | null {\n   109→    const q = this.getQueue(queueName);\n   110→    if (!q) return null;\n   111→\n   112→    // Phase 8: check concurrency limit\n   113→    if (q.concurrencyLimit > 0 && q.activeCount >= q.concurrencyLimit) {\n   114→      return null;\n   115→    }\n   116→\n   117→    const now = new Date();\n   118→    const candidates: Task[] = [];\n   119→\n   120→    for (const task of q.tasks.values()) {\n   121→      if (task.status !== 'pending') continue;\n   122→      if (task.availableAt > now) continue;\n   123→      if (task.dependsOn.length > 0 && !this.areDependenciesMet(task)) continue;\n   124→      candidates.push(task);\n   125→    }\n   126→\n   127→    if (candidates.length === 0) return null;\n   128→\n   129→    // Sort: priority asc (lower = higher priority), then availableAt asc, then createdAt asc\n   130→    candidates.sort((a, b) => {\n   131→      if (a.priority !== b.priority) return a.priority - b.priority;\n   132→      const aTime = a.availableAt.getTime();\n   133→      const bTime = b.availableAt.getTime();\n   134→      if (aTime !== bTime) return aTime - bTime;\n   135→      return a.createdAt.getTime() - b.createdAt.getTime();\n   136→    });\n   137→\n   138→    const task = candidates[0];\n   139→    task.status = 'processing';\n   140→    task.attempt += 1;\n   141→    q.activeCount += 1;\n   142→    return task;\n   143→  }\n   144→\n   145→  size(queueName: string = 'default'): number {\n   146→    const q = this.getQueue(queueName);\n   147→    if (!q) return 0;\n   148→    let count = 0;\n   149→    for (const task of q.tasks.values()) {\n   150→      if (task.status === 'pending') count++;\n   151→    }\n   152→    return count;\n   153→  }\n   154→\n   155→  getTask(taskId: string): Task | undefined {\n   156→    return this.allTasks.get(taskId);\n   157→  }\n   158→\n   159→  // ---- Phase 2: Named Queues ----\n   160→\n   161→  listQueues(): string[] {\n   162→    return Array.from(this.queues.keys());\n   163→  }\n   164→\n   165→  // ---- Phase 5: Complete / Fail ----\n   166→\n   167→  complete(taskId: string): void {\n   168→    const task = this.allTasks.get(taskId);\n   169→    if (!task) throw new Error(`Task \"${taskId}\" not found`);\n   170→    if (task.status !== 'processing') {\n   171→      throw new Error(`Task \"${taskId}\" is not in processing state`);\n   172→    }\n   173→\n   174→    task.status = 'completed';\n   175→    task.progress = { percentage: 100 };\n   176→\n   177→    const q = this.getQueue(task.queue);\n   178→    if (q) {\n   179→      q.activeCount = Math.max(0, q.activeCount - 1);\n   180→    }\n   181→  }\n   182→\n   183→  fail(taskId: string, error?: Error): void {\n   184→    const task = this.allTasks.get(taskId);\n   185→    if (!task) throw new Error(`Task \"${taskId}\" not found`);\n   186→    if (task.status !== 'processing') {\n   187→      throw new Error(`Task \"${taskId}\" is not in processing state`);\n   188→    }\n   189→\n   190→    task.error = error;\n   191→    task.failCount += 1;\n   192→\n   193→    const q = this.getQueue(task.queue);\n   194→    if (q) {\n   195→      q.activeCount = Math.max(0, q.activeCount - 1);\n   196→    }\n   197→\n   198→    if (task.attempt < task.maxRetries) {\n   199→      // Retry with backoff\n   200→      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);\n   201→      task.status = 'pending';\n   202→      task.availableAt = new Date(Date.now() + delay);\n   203→    } else {\n   204→      // Exhausted retries\n   205→      task.status = 'failed';\n   206→      // Phase 6: move to DLQ\n   207→      if (q) {\n   208→        q.tasks.delete(task.id);\n   209→        q.deadLetterQueue.push(task);\n   210→      }\n   211→    }\n   212→  }\n   213→\n   214→  // ---- Phase 6: Dead Letter Queue ----\n   215→\n   216→  getDeadLetterQueue(queueName: string = 'default'): Task[] {\n   217→    const q = this.getQueue(queueName);\n   218→    if (!q) return [];\n   219→    return [...q.deadLetterQueue];\n   220→  }\n   221→\n   222→  retryDeadLetter(taskId: string): Task {\n   223→    for (const q of this.queues.values()) {\n   224→      const idx = q.deadLetterQueue.findIndex(t => t.id === taskId);\n   225→      if (idx !== -1) {\n   226→        const task = q.deadLetterQueue.splice(idx, 1)[0];\n   227→        task.status = 'pending';\n   228→        task.attempt = 0;\n   229→        task.failCount = 0;\n   230→        task.error = undefined;\n   231→        task.availableAt = new Date();\n   232→        q.tasks.set(task.id, task);\n   233→        return task;\n   234→      }\n   235→    }\n   236→    throw new Error(`Task \"${taskId}\" not found in any dead letter queue`);\n   237→  }\n   238→\n   239→  clearDeadLetterQueue(queueName: string = 'default'): void {\n   240→    const q = this.getQueue(queueName);\n   241→    if (q) {\n   242→      q.deadLetterQueue = [];\n   243→    }\n   244→  }\n   245→\n   246→  // ---- Phase 7: Task Dependencies ----\n   247→\n   248→  getDependencyStatus(taskId: string): { taskId: string; resolved: boolean; dependencies: Array<{ id: string; status: TaskStatus }> } {\n   249→    const task = this.allTasks.get(taskId);\n   250→    if (!task) throw new Error(`Task \"${taskId}\" not found`);\n   251→\n   252→    const dependencies = task.dependsOn.map(depId => {\n   253→      const dep = this.allTasks.get(depId);\n   254→      return { id: depId, status: dep?.status ?? ('unknown' as TaskStatus) };\n   255→    });\n   256→\n   257→    const resolved = this.areDependenciesMet(task);\n   258→\n   259→    return { taskId, resolved, dependencies };\n   260→  }\n   261→\n   262→  // ---- Phase 8: Concurrency Control ----\n   263→\n   264→  setConcurrency(queueName: string, limit: number): void {\n   265→    const q = this.getOrCreateQueue(queueName);\n   266→    q.concurrencyLimit = limit;\n   267→  }\n   268→\n   269→  getConcurrency(queueName: string): { limit: number; active: number } {\n   270→    const q = this.getQueue(queueName);\n   271→    if (!q) return { limit: 0, active: 0 };\n   272→    return { limit: q.concurrencyLimit, active: q.activeCount };\n   273→  }\n   274→\n   275→  // ---- Phase 9: Progress Tracking and Cancellation ----\n   276→\n   277→  reportProgress(taskId: string, percentage: number, message?: string): void {\n   278→    const task = this.allTasks.get(taskId);\n   279→    if (!task) throw new Error(`Task \"${taskId}\" not found`);\n   280→    if (task.status !== 'processing') {\n   281→      throw new Error(`Task \"${taskId}\" is not in processing state`);\n   282→    }\n   283→    if (percentage < 0 || percentage > 100) {\n   284→      throw new Error('Progress must be between 0 and 100');\n   285→    }\n   286→\n   287→    task.progress = { percentage, message };\n   288→\n   289→    const listeners = this.progressListeners.get(taskId);\n   290→    if (listeners) {\n   291→      for (const listener of listeners) {\n   292→        listener(task.progress);\n   293→      }\n   294→    }\n   295→  }\n   296→\n   297→  getProgress(taskId: string): ProgressInfo {\n   298→    const task = this.allTasks.get(taskId);\n   299→    if (!task) throw new Error(`Task \"${taskId}\" not found`);\n   300→    return { ...task.progress };\n   301→  }\n   302→\n   303→  onProgress(taskId: string, listener: ProgressListener): () => void {\n   304→    let listeners = this.progressListeners.get(taskId);\n   305→    if (!listeners) {\n   306→      listeners = new Set();\n   307→      this.progressListeners.set(taskId, listeners);\n   308→    }\n   309→    listeners.add(listener);\n   310→\n   311→    // Return unsubscribe function\n   312→    return () => {\n   313→      listeners!.delete(listener);\n   314→      if (listeners!.size === 0) {\n   315→        this.progressListeners.delete(taskId);\n   316→      }\n   317→    };\n   318→  }\n   319→\n   320→  cancel(taskId: string): void {\n   321→    const task = this.allTasks.get(taskId);\n   322→    if (!task) throw new Error(`Task \"${taskId}\" not found`);\n   323→\n   324→    if (task.status !== 'pending' && task.status !== 'processing') {\n   325→      throw new Error(`Task \"${taskId}\" cannot be cancelled (status: ${task.status})`);\n   326→    }\n   327→\n   328→    const wasProcessing = task.status === 'processing';\n   329→    task.status = 'cancelled';\n   330→    // Ensure cancelled tasks are never retried\n   331→    task.maxRetries = 0;\n   332→\n   333→    const q = this.getQueue(task.queue);\n   334→    if (q) {\n   335→      if (wasProcessing) {\n   336→        q.activeCount = Math.max(0, q.activeCount - 1);\n   337→      }\n   338→      q.tasks.delete(task.id);\n   339→    }\n   340→  }\n   341→\n   342→  // ---- Phase 10: Recurring Tasks ----\n   343→\n   344→  addSchedule(expression: string, queueName: string, payload: unknown, priority?: number): CronSchedule {\n   345→    // Validate the cron expression by parsing it\n   346→    parseCron(expression);\n   347→\n   348→    const schedule: CronSchedule = {\n   349→      id: randomUUID(),\n   350→      expression,\n   351→      queue: queueName,\n   352→      payload,\n   353→      priority,\n   354→    };\n   355→\n   356→    this.schedules.set(schedule.id, schedule);\n   357→    return schedule;\n   358→  }\n   359→\n   360→  removeSchedule(scheduleId: string): void {\n   361→    if (!this.schedules.has(scheduleId)) {\n   362→      throw new Error(`Schedule \"${scheduleId}\" not found`);\n   363→    }\n   364→    this.schedules.delete(scheduleId);\n   365→  }\n   366→\n   367→  listSchedules(): CronSchedule[] {\n   368→    return Array.from(this.schedules.values());\n   369→  }\n   370→\n   371→  tick(now?: Date): Task[] {\n   372→    const currentTime = now ?? new Date();\n   373→    // Truncate to minute boundary for cron matching\n   374→    const matchTime = new Date(currentTime);\n   375→    matchTime.setSeconds(0, 0);\n   376→\n   377→    const created: Task[] = [];\n   378→\n   379→    for (const schedule of this.schedules.values()) {\n   380→      const cron = parseCron(schedule.expression);\n   381→      if (!cron.matches(matchTime)) continue;\n   382→\n   383→      // Avoid double-firing in the same minute\n   384→      if (schedule.lastRun) {\n   385→        const lastMinute = new Date(schedule.lastRun);\n   386→        lastMinute.setSeconds(0, 0);\n   387→        if (lastMinute.getTime() === matchTime.getTime()) continue;\n   388→      }\n   389→\n   390→      schedule.lastRun = currentTime;\n   391→\n   392→      const task = this.add(schedule.payload, {\n   393→        queue: schedule.queue,\n   394→        priority: schedule.priority,\n   395→      });\n   396→      created.push(task);\n   397→    }\n   398→\n   399→    return created;\n   400→  }\n   401→\n   402→  // ---- Phase 11: Middleware Pipeline ----\n   403→\n   404→  use(queueName: string, middleware: MiddlewareFn): void {\n   405→    const q = this.getOrCreateQueue(queueName);\n   406→    q.middleware.push(middleware);\n   407→  }\n   408→\n   409→  setHandler(queueName: string, handler: HandlerFn): void {\n   410→    const q = this.getOrCreateQueue(queueName);\n   411→    q.handler = handler;\n   412→  }\n   413→\n   414→  async process(queueName: string = 'default'): Promise<Task | null> {\n   415→    const task = this.next(queueName);\n   416→    if (!task) return null;\n   417→\n   418→    const q = this.getQueue(queueName);\n   419→    if (!q) return null;\n   420→\n   421→    const middlewareStack = [...q.middleware];\n   422→    const handler = q.handler;\n   423→\n   424→    let index = 0;\n   425→    const executeNext = async (): Promise<void> => {\n   426→      if (index < middlewareStack.length) {\n   427→        const mw = middlewareStack[index++];\n   428→        await mw(task, executeNext);\n   429→      } else if (handler) {\n   430→        await handler(task);\n   431→      }\n   432→    };\n   433→\n   434→    try {\n   435→      await executeNext();\n   436→      if (task.status === 'processing') {\n   437→        this.complete(task.id);\n   438→      }\n   439→    } catch (err) {\n   440→      if (task.status === 'processing') {\n   441→        this.fail(task.id, err instanceof Error ? err : new Error(String(err)));\n   442→      }\n   443→    }\n   444→\n   445→    return task;\n   446→  }\n   447→\n   448→  // ---- Phase 12: Graceful Shutdown ----\n   449→\n   450→  onShutdown(callback: () => void | Promise<void>): void {\n   451→    this.shutdownCallbacks.push(callback);\n   452→  }\n   453→\n   454→  async shutdown(timeoutMs: number = 30000): Promise<ShutdownResult> {\n   455→    if (this.shutdownPromise) {\n   456→      return this.shutdownPromise;\n   457→    }\n   458→\n   459→    this.isShutdown = true;\n   460→\n   461→    this.shutdownPromise = this.performShutdown(timeoutMs);\n   462→    return this.shutdownPromise;\n   463→  }\n   464→\n   465→  private async performShutdown(timeoutMs: number): Promise<ShutdownResult> {\n   466→    const startTime = Date.now();\n   467→\n   468→    // Run shutdown callbacks\n   469→    for (const callback of this.shutdownCallbacks) {\n   470→      await callback();\n   471→    }\n   472→\n   473→    // Find all currently processing tasks\n   474→    const processingTasks: Task[] = [];\n   475→    for (const task of this.allTasks.values()) {\n   476→      if (task.status === 'processing') {\n   477→        processingTasks.push(task);\n   478→      }\n   479→    }\n   480→\n   481→    if (processingTasks.length === 0) {\n   482→      return {\n   483→        completed: 0,\n   484→        forceCancelled: 0,\n   485→        durationMs: Date.now() - startTime,\n   486→      };\n   487→    }\n   488→\n   489→    // Wait for processing tasks to complete, up to timeout\n   490→    let completed = 0;\n   491→    let forceCancelled = 0;\n   492→\n   493→    await new Promise<void>((resolve) => {\n   494→      const checkInterval = setInterval(() => {\n   495→        const stillProcessing = processingTasks.filter(t => t.status === 'processing');\n   496→        if (stillProcessing.length === 0 || Date.now() - startTime >= timeoutMs) {\n   497→          clearInterval(checkInterval);\n   498→          resolve();\n   499→        }\n   500→      }, 10);\n   501→\n   502→      // Also set an absolute timeout\n   503→      setTimeout(() => {\n   504→        clearInterval(checkInterval);\n   505→        resolve();\n   506→      }, timeoutMs);\n   507→    });\n   508→\n   509→    // Count results and force-cancel remaining\n   510→    for (const task of processingTasks) {\n   511→      if (task.status === 'processing') {\n   512→        task.status = 'cancelled';\n   513→        task.maxRetries = 0;\n   514→        const q = this.getQueue(task.queue);\n   515→        if (q) {\n   516→          q.activeCount = Math.max(0, q.activeCount - 1);\n   517→          q.tasks.delete(task.id);\n   518→        }\n   519→        forceCancelled++;\n   520→      } else {\n   521→        completed++;\n   522→      }\n   523→    }\n   524→\n   525→    return {\n   526→      completed,\n   527→      forceCancelled,\n   528→      durationMs: Date.now() - startTime,\n   529→    };\n   530→  }\n   531→}\n   532→"}]},"parent_tool_use_id":"toolu_01EiN2LBzJgtEnc2nAR1jW9R","session_id":"39620430-694a-4989-ac58-ce8fd865b6a5","uuid":"88809045-df44-49d6-aef8-7748327fa5d4"}
