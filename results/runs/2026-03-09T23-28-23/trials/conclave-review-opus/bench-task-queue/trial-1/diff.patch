@@ -0,0 +1,60 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 1: Basic FIFO Queue', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  it('should add a task and return a task object', () => {
+    const task = tq.add({ message: 'hello' });
+    expect(task.id).toBeDefined();
+    expect(task.payload).toEqual({ message: 'hello' });
+    expect(task.status).toBe('pending');
+    expect(task.createdAt).toBeInstanceOf(Date);
+  });
+
+  it('should assign unique IDs to each task', () => {
+    const t1 = tq.add('task1');
+    const t2 = tq.add('task2');
+    expect(t1.id).not.toBe(t2.id);
+  });
+
+  it('should retrieve tasks in FIFO order', () => {
+    tq.add('first');
+    tq.add('second');
+    tq.add('third');
+
+    const r1 = tq.next();
+    expect(r1?.payload).toBe('first');
+    expect(r1?.status).toBe('processing');
+
+    const r2 = tq.next();
+    expect(r2?.payload).toBe('second');
+
+    const r3 = tq.next();
+    expect(r3?.payload).toBe('third');
+  });
+
+  it('should return null when no tasks are available', () => {
+    expect(tq.next()).toBeNull();
+  });
+
+  it('should track the size of pending tasks', () => {
+    expect(tq.size()).toBe(0);
+    tq.add('a');
+    tq.add('b');
+    expect(tq.size()).toBe(2);
+    tq.next();
+    expect(tq.size()).toBe(1);
+  });
+
+  it('should transition task to processing state on next()', () => {
+    const task = tq.add('work');
+    const retrieved = tq.next();
+    expect(retrieved?.id).toBe(task.id);
+    expect(retrieved?.status).toBe('processing');
+  });
+});
