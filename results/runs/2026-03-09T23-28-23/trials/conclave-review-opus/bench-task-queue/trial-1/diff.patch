+import { describe, it, expect, beforeEach, vi, afterEach } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 4: Delayed and Scheduled Tasks', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+    vi.useFakeTimers();
+  });
+
+  afterEach(() => {
+    vi.useRealTimers();
+  });
+
+  it('should delay a task by milliseconds', () => {
+    tq.add('delayed', { delay: 5000 });
+
+    // Not available yet
+    expect(tq.next()).toBeNull();
+
+    // Advance time
+    vi.advanceTimersByTime(5000);
+    const task = tq.next();
+    expect(task?.payload).toBe('delayed');
+  });
+
+  it('should accept a specific processAt time', () => {
+    const future = new Date(Date.now() + 10000);
+    tq.add('scheduled', { processAt: future });
+
+    expect(tq.next()).toBeNull();
+
+    vi.advanceTimersByTime(10000);
+    expect(tq.next()?.payload).toBe('scheduled');
+  });
+
+  it('should prefer non-delayed tasks over not-yet-available delayed tasks', () => {
+    tq.add('delayed', { delay: 5000 });
+    tq.add('immediate');
+
+    expect(tq.next()?.payload).toBe('immediate');
+    expect(tq.next()).toBeNull(); // delayed not yet ready
+  });
+
+  it('should order available delayed tasks by availability time, then priority, then FIFO', () => {
+    tq.add('delay-2s', { delay: 2000 });
+    tq.add('delay-1s', { delay: 1000 });
+
+    vi.advanceTimersByTime(2000);
+
+    expect(tq.next()?.payload).toBe('delay-1s');
+    expect(tq.next()?.payload).toBe('delay-2s');
+  });
+
+  it('should expose availableAt on the task', () => {
+    const task = tq.add('delayed', { delay: 3000 });
+    expect(task.availableAt.getTime()).toBeGreaterThan(task.createdAt.getTime());
+  });
+
+  it('should work with named queues', () => {
+    tq.add('delayed', { queue: 'special', delay: 1000 });
+
+    expect(tq.next('special')).toBeNull();
+    vi.advanceTimersByTime(1000);
+    expect(tq.next('special')?.payload).toBe('delayed');
+  });
+});
