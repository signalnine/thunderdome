return { limit: q.concurrencyLimit, active: q.activeCount };\n   273→  }\n   274→\n   275→  // ---- Phase 9: Progress Tracking and Cancellation ----\n   276→\n   277→  reportProgress(taskId: string, percentage: number, message?: string): void {\n   278→    const task = this.allTasks.get(taskId);\n   279→    if (!task) throw new Error(`Task \"${taskId}\" not found`);\n   280→    if (task.status !== 'processing') {\n   281→      throw new Error(`Task \"${taskId}\" is not in processing state`);\n   282→    }\n   283→    if (percentage < 0 || percentage > 100) {\n   284→      throw new Error('Progress must be between 0 and 100');\n   285→    }\n   286→\n   287→    task.progress = { percentage, message };\n   288→\n   289→    const listeners = this.progressListeners.get(taskId);\n   290→    if (listeners) {\n   291→      for (const listener of listeners) {\n   292→        listener(task.progress);\n   293→      }\n   294→    }\n   295→  }\n   296→\n   297→  getProgress(taskId: string): ProgressInfo {\n   298→    const task = this.allTasks.get(taskId);\n   299→    if (!task) throw new Error(`Task \"${taskId}\" not found`);\n   300→    return { ...task.progress };\n   301→  }\n   302→\n   303→  onProgress(taskId: string, listener: ProgressListener): () => void {\n   304→    let listeners = this.progressListeners.get(taskId);\n   305→    if (!listeners) {\n   306→      listeners = new Set();\n   307→      this.progressListeners.set(taskId, listeners);\n   308→    }\n   309→    listeners.add(listener);\n   310→\n   311→    // Return unsubscribe function\n   312→    return () => {\n   313→      listeners!.delete(listener);\n   314→      if (listeners!.size === 0) {\n   315→        this.progressListeners.delete(taskId);\n   316→      }\n   317→    };\n   318→  }\n   319→\n   320→  cancel(taskId: string): void {\n   321→    const task = this.allTasks.get(taskId);\n   322→    if (!task) throw new Error(`Task \"${taskId}\" not found`);\n   323→\n   324→    if (task.status !== 'pen