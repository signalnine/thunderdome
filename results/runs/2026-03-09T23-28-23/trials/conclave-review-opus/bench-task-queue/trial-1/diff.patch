+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015VGmhso6H2VGcpuQuSVuAt","type":"tool_result","content":"     1→import { randomUUID } from 'node:crypto';\n     2→\n     3→export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';\n     4→\n     5→export interface TaskOptions {\n     6→  queue?: string;\n     7→  priority?: number;\n     8→  delay?: number;\n     9→  processAt?: Date;\n    10→  maxRetries?: number;\n    11→  backoffDelay?: number;\n    12→  dependsOn?: string[];\n    13→}\n    14→\n    15→export interface ProgressInfo {\n    16→  percentage: number;\n    17→  message?: string;\n    18→}\n    19→\n    20→export type ProgressListener = (progress: ProgressInfo) => void;\n    21→\n    22→export interface Task<T = unknown> {\n    23→  id: string;\n    24→  payload: T;\n    25→  status: TaskStatus;\n    26→  queue: string;\n    27→  priority: number;\n    28→  createdAt: Date;\n    29→  availableAt: Date;\n    30→  attempt: number;\n    31→  maxRetries: number;\n    32→  backoffDelay: number;\n    33→  error?: Error;\n    34→  failCount: number;\n    35→  dependsOn: string[];\n    36→  progress: ProgressInfo;\n    37→  metadata: Record<string, unknown>;\n    38→}\n    39→\n    40→export function createTask<T>(payload: T, options: TaskOptions = {}): Task<T> {\n    41→  const now = new Date();\n    42→  let availableAt = now;\n    43→\n    44→  if (options.processAt) {\n    45→    availableAt = options.processAt;\n    46→  } else if (options.delay && options.delay > 0) {\n    47→    availableAt = new Date(now.getTime() + options.delay);\n    48→  }\n    49→\n    50→  const priority = options.priority ?? 5;\n    51→  if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n    52→    throw new Error(`Invalid priority ${priority}: must be an integer between 1 and 10`);\n    53→  }\n    54→\n    55→  return {\n    56→    id: randomUUID(),\n    57→    payload,\n    58→    status: 'pending',\n    59→    queue: options.queue ?? 'default',\n    60→    priority,\n    61→    createdAt: now,\n    62→    availableAt,\n    63→    attempt: 0,\n    64→    maxRetries: options.maxRetries ?? 3,\n    65→    backoffDelay: options.backoffDelay ?? 1000,\n    66→    failCount: 0,\n    67→    dependsOn: options.dependsOn ? [...options.dependsOn] : [],\n    68→    progress: { percentage: 0 },\n    69→    metadata: {},\n    70→  };\n    71→}\n    72→\n    73→export interface CronSchedule {\n    74→  id: string;\n    75→  expression: string;\n    76→  queue: string;\n    77→  payload: unknown;\n    78→  priority?: number;\n    79→  lastRun?: Date;\n    80→}\n    81→\n    82→export type MiddlewareFn = (task: Task, next: () => Promise<void>) => Promise<void>;\n    83→export type HandlerFn = (task: Task) => Promise<void> | void;\n    84→\n    85→export interface ShutdownResult {\n    86→  completed: number;\n    87→  forceCancelled: number;\n    88→  durationMs: number;\n    89→}\n    90→"}]},"parent_tool_use_id":"toolu_01EiN2LBzJgtEnc2nAR1jW9R","session_id":"39620430-694a-4989-ac58-ce8fd865b6a5","uuid":"468cc04d-c9e8-472d-a11d-3945c83f3abd"}
