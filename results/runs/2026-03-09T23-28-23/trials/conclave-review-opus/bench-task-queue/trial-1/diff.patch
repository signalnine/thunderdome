@@ -0,0 +1,112 @@
+import { describe, it, expect, beforeEach, vi } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 9: Progress Tracking and Cancellation', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  describe('Progress', () => {
+    it('should report progress on a processing task', () => {
+      const task = tq.add('work');
+      tq.next();
+
+      tq.reportProgress(task.id, 50, 'halfway');
+      const progress = tq.getProgress(task.id);
+      expect(progress.percentage).toBe(50);
+      expect(progress.message).toBe('halfway');
+    });
+
+    it('should reject progress outside 0-100', () => {
+      const task = tq.add('work');
+      tq.next();
+
+      expect(() => tq.reportProgress(task.id, -1)).toThrow();
+      expect(() => tq.reportProgress(task.id, 101)).toThrow();
+    });
+
+    it('should reject progress on non-processing task', () => {
+      const task = tq.add('work');
+      expect(() => tq.reportProgress(task.id, 50)).toThrow();
+    });
+
+    it('should notify progress listeners', () => {
+      const task = tq.add('work');
+      tq.next();
+
+      const updates: number[] = [];
+      tq.onProgress(task.id, (p) => updates.push(p.percentage));
+
+      tq.reportProgress(task.id, 25);
+      tq.reportProgress(task.id, 75);
+
+      expect(updates).toEqual([25, 75]);
+    });
+
+    it('should support unsubscribing from progress', () => {
+      const task = tq.add('work');
+      tq.next();
+
+      const updates: number[] = [];
+      const unsub = tq.onProgress(task.id, (p) => updates.push(p.percentage));
+
+      tq.reportProgress(task.id, 25);
+      unsub();
+      tq.reportProgress(task.id, 75);
+
+      expect(updates).toEqual([25]);
+    });
+  });
+
+  describe('Cancellation', () => {
+    it('should cancel a pending task', () => {
+      const task = tq.add('work');
+      tq.cancel(task.id);
+
+      expect(task.status).toBe('cancelled');
+      expect(tq.next()).toBeNull();
+      expect(tq.size()).toBe(0);
+    });
+
+    it('should cancel a processing task', () => {
+      const task = tq.add('work');
+      tq.next();
+
+      tq.cancel(task.id);
+      expect(task.status).toBe('cancelled');
+    });
+
+    it('should not allow cancelling completed tasks', () => {
+      const task = tq.add('work');
+      tq.next();
+      tq.complete(task.id);
+
+      expect(() => tq.cancel(task.id)).toThrow();
+    });
+
+    it('should not retry cancelled tasks', () => {
+      vi.useFakeTimers();
+      const task = tq.add('work', { maxRetries: 3 });
+      tq.next();
+      tq.cancel(task.id);
+
+      vi.advanceTimersByTime(10000);
+      expect(tq.next()).toBeNull();
+      vi.useRealTimers();
+    });
+
+    it('should free concurrency slot when cancelling processing task', () => {
+      tq.setConcurrency('default', 1);
+      tq.add('a');
+      tq.add('b');
+
+      const t1 = tq.next()!;
+      expect(tq.next()).toBeNull();
+
+      tq.cancel(t1.id);
+      expect(tq.getConcurrency('default').active).toBe(0);
+    });
+  });
+});
