+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue, Task } from '../src/index.js';
+
+describe('Phase 11: Middleware Pipeline', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  it('should register and run middleware before handler', async () => {
+    const order: string[] = [];
+
+    tq.use('default', async (_task, next) => {
+      order.push('mw1');
+      await next();
+    });
+
+    tq.setHandler('default', async () => {
+      order.push('handler');
+    });
+
+    tq.add('work');
+    await tq.process();
+
+    expect(order).toEqual(['mw1', 'handler']);
+  });
+
+  it('should run middleware in registration order', async () => {
+    const order: string[] = [];
+
+    tq.use('default', async (_task, next) => {
+      order.push('mw1-before');
+      await next();
+      order.push('mw1-after');
+    });
+
+    tq.use('default', async (_task, next) => {
+      order.push('mw2-before');
+      await next();
+      order.push('mw2-after');
+    });
+
+    tq.setHandler('default', async () => {
+      order.push('handler');
+    });
+
+    tq.add('work');
+    await tq.process();
+
+    expect(order).toEqual(['mw1-before', 'mw2-before', 'handler', 'mw2-after', 'mw1-after']);
+  });
+
+  it('should skip processing if middleware does not call next', async () => {
+    const handlerCalled = { value: false };
+
+    tq.use('default', async (_task, _next) => {
+      // Intentionally not calling next()
+    });
+
+    tq.setHandler('default', async () => {
+      handlerCalled.value = true;
+    });
+
+    tq.add('work');
+    await tq.process();
+
+    expect(handlerCalled.value).toBe(false);
+  });
+
+  it('should allow middleware to modify task metadata', async () => {
+    tq.use('default', async (task, next) => {
+      task.metadata['enriched'] = true;
+      await next();
+    });
+
+    let receivedTask: Task | null = null;
+    tq.setHandler('default', async (task) => {
+      receivedTask = task;
+    });
+
+    tq.add('work');
+    await tq.process();
+
+    expect(receivedTask?.metadata['enriched']).toBe(true);
+  });
+
+  it('should fail the task if middleware throws', async () => {
+    tq.use('default', async (_task, _next) => {
+      throw new Error('middleware error');
+    });
+
+    const task = tq.add('work', { maxRetries: 1 });
+    await tq.process();
+
+    expect(task.status).toBe('failed');
+    expect(task.error?.message).toBe('middleware error');
+  });
+
+  it('should complete the task after handler runs', async () => {
+    tq.setHandler('default', async () => {
+      // normal handler
+    });
+
+    const task = tq.add('work');
+    await tq.process();
+
+    expect(task.status).toBe('completed');
+  });
+
+  it('should return null when no tasks are available', async () => {
+    const result = await tq.process();
+    expect(result).toBeNull();
+  });
+
+  it('should have independent middleware per queue', async () => {
+    const calls: string[] = [];
+
+    tq.use('q1', async (_task, next) => {
+      calls.push('q1-mw');
+      await next();
+    });
+
+    tq.use('q2', async (_task, next) => {
+      calls.push('q2-mw');
+      await next();
+    });
+
+    tq.setHandler('q1', async () => { calls.push('q1-handler'); });
+    tq.setHandler('q2', async () => { calls.push('q2-handler'); });
+
+    tq.add('a', { queue: 'q1' });
+    tq.add('b', { queue: 'q2' });
+
+    await tq.process('q1');
+    await tq.process('q2');
+
+    expect(calls).toEqual(['q1-mw', 'q1-handler', 'q2-mw', 'q2-handler']);
+  });
+});
