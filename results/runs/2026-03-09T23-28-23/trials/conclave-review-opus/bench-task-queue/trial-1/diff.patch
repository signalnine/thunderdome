+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CBAkFVA3JvmkPtgxnmEBCS","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach, vi, afterEach } from 'vitest';\n     2→import { TaskQueue } from '../src/index.js';\n     3→\n     4→describe('Phase 4: Delayed and Scheduled Tasks', () => {\n     5→  let tq: TaskQueue;\n     6→\n     7→  beforeEach(() => {\n     8→    tq = new TaskQueue();\n     9→    vi.useFakeTimers();\n    10→  });\n    11→\n    12→  afterEach(() => {\n    13→    vi.useRealTimers();\n    14→  });\n    15→\n    16→  it('should delay a task by milliseconds', () => {\n    17→    tq.add('delayed', { delay: 5000 });\n    18→\n    19→    // Not available yet\n    20→    expect(tq.next()).toBeNull();\n    21→\n    22→    // Advance time\n    23→    vi.advanceTimersByTime(5000);\n    24→    const task = tq.next();\n    25→    expect(task?.payload).toBe('delayed');\n    26→  });\n    27→\n    28→  it('should accept a specific processAt time', () => {\n    29→    const future = new Date(Date.now() + 10000);\n    30→    tq.add('scheduled', { processAt: future });\n    31→\n    32→    expect(tq.next()).toBeNull();\n    33→\n    34→    vi.advanceTimersByTime(10000);\n    35→    expect(tq.next()?.payload).toBe('scheduled');\n    36→  });\n    37→\n    38→  it('should prefer non-delayed tasks over not-yet-available delayed tasks', () => {\n    39→    tq.add('delayed', { delay: 5000 });\n    40→    tq.add('immediate');\n    41→\n    42→    expect(tq.next()?.payload).toBe('immediate');\n    43→    expect(tq.next()).toBeNull(); // delayed not yet ready\n    44→  });\n    45→\n    46→  it('should order available delayed tasks by availability time, then priority, then FIFO', () => {\n    47→    tq.add('delay-2s', { delay: 2000 });\n    48→    tq.add('delay-1s', { delay: 1000 });\n    49→\n    50→    vi.advanceTimersByTime(2000);\n    51→\n    52→    expect(tq.next()?.payload).toBe('delay-1s');\n    53→    expect(tq.next()?.payload).toBe('delay-2s');\n    54→  });\n    55→\n    56→  it('should expose availableAt on the task', () => {\n    57→    const task = tq.add('delayed', { delay: 3000 });\n    58→    expect(task.availableAt.getTime()).toBeGreaterThan(task.createdAt.getTime());\n    59→  });\n    60→\n    61→  it('should work with named queues', () => {\n    62→    tq.add('delayed', { queue: 'special', delay: 1000 });\n    63→\n    64→    expect(tq.next('special')).toBeNull();\n    65→    vi.advanceTimersByTime(1000);\n    66→    expect(tq.next('special')?.payload).toBe('delayed');\n    67→  });\n    68→});\n    69→"}]},"parent_tool_use_id":"toolu_01EiN2LBzJgtEnc2nAR1jW9R","session_id":"39620430-694a-4989-ac58-ce8fd865b6a5","uuid":"2d56e27b-2863-4d34-9a14-6e5516a64162"}
