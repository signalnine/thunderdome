+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FsfaEM7BxvQCxapJU1wAAP","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach, vi, afterEach } from 'vitest';\n     2→import { TaskQueue } from '../src/index.js';\n     3→\n     4→describe('Phase 6: Dead Letter Queue', () => {\n     5→  let tq: TaskQueue;\n     6→\n     7→  beforeEach(() => {\n     8→    tq = new TaskQueue();\n     9→    vi.useFakeTimers();\n    10→  });\n    11→\n    12→  afterEach(() => {\n    13→    vi.useRealTimers();\n    14→  });\n    15→\n    16→  function exhaustRetries(taskId: string, maxRetries: number, backoffDelay: number) {\n    17→    for (let i = 0; i < maxRetries; i++) {\n    18→      tq.next();\n    19→      tq.fail(taskId, new Error(`fail-${i + 1}`));\n    20→      if (i < maxRetries - 1) {\n    21→        vi.advanceTimersByTime(backoffDelay * Math.pow(2, i));\n    22→      }\n    23→    }\n    24→  }\n    25→\n    26→  it('should move task to DLQ after exhausting retries', () => {\n    27→    const task = tq.add('work', { maxRetries: 1, backoffDelay: 100 });\n    28→    tq.next();\n    29→    tq.fail(task.id, new Error('oops'));\n    30→\n    31→    const dlq = tq.getDeadLetterQueue();\n    32→    expect(dlq).toHaveLength(1);\n    33→    expect(dlq[0].id).toBe(task.id);\n    34→    expect(dlq[0].status).toBe('failed');\n    35→  });\n    36→\n    37→  it('should retain error info in DLQ tasks', () => {\n    38→    const task = tq.add('work', { maxRetries: 1 });\n    39→    tq.next();\n    40→    tq.fail(task.id, new Error('boom'));\n    41→\n    42→    const dlq = tq.getDeadLetterQueue();\n    43→    expect(dlq[0].error?.message).toBe('boom');\n    44→    expect(dlq[0].failCount).toBe(1);\n    45→  });\n    46→\n    47→  it('should retry a dead-lettered task', () => {\n    48→    const task = tq.add('work', { maxRetries: 1, backoffDelay: 100 });\n    49→    tq.next();\n    50→    tq.fail(task.id, new Error('oops'));\n    51→\n    52→    expect(tq.getDeadLetterQueue()).toHaveLength(1);\n    53→\n    54→    const retried = tq.retryDeadLetter(task.id);\n    55→    expect(retried.status).toBe('pending');\n    56→    expect(retried.attempt).toBe(0);\n    57→    expect(retried.failCount).toBe(0);\n    58→\n    59→    expect(tq.getDeadLetterQueue()).toHaveLength(0);\n    60→    expect(tq.size()).toBe(1);\n    61→  });\n    62→\n    63→  it('should clear dead letter queue', () => {\n    64→    const t1 = tq.add('a', { maxRetries: 1 });\n    65→    const t2 = tq.add('b', { maxRetries: 1 });\n    66→\n    67→    tq.next();\n    68→    tq.fail(t1.id);\n    69→    tq.next();\n    70→    tq.fail(t2.id);\n    71→\n    72→    expect(tq.getDeadLetterQueue()).toHaveLength(2);\n    73→    tq.clearDeadLetterQueue();\n    74→    expect(tq.getDeadLetterQueue()).toHaveLength(0);\n    75→  });\n    76→\n    77→  it('should have independent DLQs per named queue', () => {\n    78→    const t1 = tq.add('a', { queue: 'q1', maxRetries: 1 });\n    79→    const t2 = tq.add('b', { queue: 'q2', maxRetries: 1 });\n    80→\n    81→    tq.next('q1');\n    82→    tq.fail(t1.id);\n    83→    tq.next('q2');\n    84→    tq.fail(t2.id);\n    85→\n    86→    expect(tq.getDeadLetterQueue('q1')).toHaveLength(1);\n    87→    expect(tq.getDeadLetterQueue('q2')).toHaveLength(1);\n    88→\n    89→    tq.clearDeadLetterQueue('q1');\n    90→    expect(tq.getDeadLetterQueue('q1')).toHaveLength(0);\n    91→    expect(tq.getDeadLetterQueue('q2')).toHaveLength(1);\n    92→  });\n    93→});\n    94→"}]},"parent_tool_use_id":"toolu_01EiN2LBzJgtEnc2nAR1jW9R","session_id":"39620430-694a-4989-ac58-ce8fd865b6a5","uuid":"8e2fe29c-fc56-4a54-bc54-7eec78d77852"}
