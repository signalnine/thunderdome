     const updates: number[] = [];\n    53→      const unsub = tq.onProgress(task.id, (p) => updates.push(p.percentage));\n    54→\n    55→      tq.reportProgress(task.id, 25);\n    56→      unsub();\n    57→      tq.reportProgress(task.id, 75);\n    58→\n    59→      expect(updates).toEqual([25]);\n    60→    });\n    61→  });\n    62→\n    63→  describe('Cancellation', () => {\n    64→    it('should cancel a pending task', () => {\n    65→      const task = tq.add('work');\n    66→      tq.cancel(task.id);\n    67→\n    68→      expect(task.status).toBe('cancelled');\n    69→      expect(tq.next()).toBeNull();\n    70→      expect(tq.size()).toBe(0);\n    71→    });\n    72→\n    73→    it('should cancel a processing task', () => {\n    74→      const task = tq.add('work');\n    75→      tq.next();\n    76→\n    77→      tq.cancel(task.id);\n    78→      expect(task.status).toBe('cancelled');\n    79→    });\n    80→\n    81→    it('should not allow cancelling completed tasks', () => {\n    82→      const task = tq.add('work');\n    83→      tq.next();\n    84→      tq.complete(task.id);\n    85→\n    86→      expect(() => tq.cancel(task.id)).toThrow();\n    87→    });\n    88→\n    89→    it('should not retry cancelled tasks', () => {\n    90→      vi.useFakeTimers();\n    91→      const task = tq.add('work', { maxRetries: 3 });\n    92→      tq.next();\n    93→      tq.cancel(task.id);\n    94→\n    95→      vi.advanceTimersByTime(10000);\n    96→      expect(tq.next()).toBeNull();\n    97→      vi.useRealTimers();\n    98→    });\n    99→\n   100→    it('should free concurrency slot when cancelling processing task', () => {\n   101→      tq.setConcurrency('default', 1);\n   102→      tq.add('a');\n   103→      tq.add('b');\n   104→\n   105→      const t1 = tq.next()!;\n   106→      expect(tq.next()).toBeNull();\n   107→\n   108→      tq.cancel(t1.id);\n   109→      expect(tq.getConcurrency('default').active).toBe(0);\n   110→    });\n   111→  });\n   112→});\n 