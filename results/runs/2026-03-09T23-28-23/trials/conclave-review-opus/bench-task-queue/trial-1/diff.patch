@@ -0,0 +1,76 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 8: Concurrency Control', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  it('should have unlimited concurrency by default', () => {
+    const c = tq.getConcurrency('default');
+    expect(c.limit).toBe(0);
+    expect(c.active).toBe(0);
+  });
+
+  it('should limit concurrent processing tasks', () => {
+    tq.setConcurrency('default', 2);
+    tq.add('a');
+    tq.add('b');
+    tq.add('c');
+
+    const t1 = tq.next();
+    const t2 = tq.next();
+    expect(t1).not.toBeNull();
+    expect(t2).not.toBeNull();
+
+    // Third should be null (limit reached)
+    expect(tq.next()).toBeNull();
+
+    const c = tq.getConcurrency('default');
+    expect(c.active).toBe(2);
+  });
+
+  it('should free concurrency slot on complete', () => {
+    tq.setConcurrency('default', 1);
+    tq.add('a');
+    tq.add('b');
+
+    const t1 = tq.next()!;
+    expect(tq.next()).toBeNull();
+
+    tq.complete(t1.id);
+    expect(tq.getConcurrency('default').active).toBe(0);
+
+    const t2 = tq.next();
+    expect(t2).not.toBeNull();
+  });
+
+  it('should free concurrency slot on fail', () => {
+    tq.setConcurrency('default', 1);
+    tq.add('a', { maxRetries: 1 });
+    tq.add('b');
+
+    const t1 = tq.next()!;
+    expect(tq.next()).toBeNull();
+
+    tq.fail(t1.id);
+    expect(tq.getConcurrency('default').active).toBe(0);
+  });
+
+  it('should still return highest priority task within concurrency limit', () => {
+    tq.setConcurrency('default', 1);
+    tq.add('low', { priority: 10 });
+    tq.add('high', { priority: 1 });
+
+    const task = tq.next();
+    expect(task?.payload).toBe('high');
+  });
+
+  it('should set and query concurrency for specific queues', () => {
+    tq.setConcurrency('q1', 5);
+    expect(tq.getConcurrency('q1').limit).toBe(5);
+    expect(tq.getConcurrency('q2').limit).toBe(0);
+  });
+});
