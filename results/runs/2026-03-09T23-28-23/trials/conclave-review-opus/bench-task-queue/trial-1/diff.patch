@@ -0,0 +1,99 @@
+import { randomUUID } from 'node:crypto';
+
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';
+
+export interface TaskOptions {
+  queue?: string;
+  priority?: number;
+  delay?: number;
+  processAt?: Date;
+  maxRetries?: number;
+  backoffDelay?: number;
+  dependsOn?: string[];
+}
+
+export interface ProgressInfo {
+  percentage: number;
+  message?: string;
+}
+
+export type ProgressListener = (progress: ProgressInfo) => void;
+
+export interface Task<T = unknown> {
+  id: string;
+  payload: T;
+  status: TaskStatus;
+  queue: string;
+  priority: number;
+  createdAt: Date;
+  availableAt: Date;
+  attempt: number;
+  maxRetries: number;
+  backoffDelay: number;
+  error?: Error;
+  failCount: number;
+  dependsOn: string[];
+  progress: ProgressInfo;
+  metadata: Record<string, unknown>;
+}
+
+export function createTask<T>(payload: T, options: TaskOptions = {}): Task<T> {
+  const now = new Date();
+  let availableAt = now;
+
+  if (options.processAt) {
+    availableAt = options.processAt;
+  } else if (options.delay && options.delay > 0) {
+    availableAt = new Date(now.getTime() + options.delay);
+  }
+
+  const priority = options.priority ?? 5;
+  if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {
+    throw new Error(`Invalid priority ${priority}: must be an integer between 1 and 10`);
+  }
+
+  const maxRetries = options.maxRetries ?? 3;
+  if (maxRetries < 0 || !Number.isInteger(maxRetries)) {
+    throw new Error(`Invalid maxRetries ${maxRetries}: must be a non-negative integer`);
+  }
+
+  const backoffDelay = options.backoffDelay ?? 1000;
+  if (backoffDelay < 0) {
+    throw new Error(`Invalid backoffDelay ${backoffDelay}: must be non-negative`);
+  }
+
+  return {
+    id: randomUUID(),
+    payload,
+    status: 'pending',
+    queue: options.queue ?? 'default',
+    priority,
+    createdAt: now,
+    availableAt,
+    attempt: 0,
+    maxRetries,
+    backoffDelay,
+    failCount: 0,
+    dependsOn: options.dependsOn ? [...options.dependsOn] : [],
+    progress: { percentage: 0 },
+    metadata: {},
+  };
+}
+
+export interface CronSchedule {
+  id: string;
+  expression: string;
+  queue: string;
+  payload: unknown;
+  priority?: number;
+  lastRun?: Date;
+}
+
+export type MiddlewareFn = (task: Task, next: () => Promise<void>) => Promise<void>;
+export type HandlerFn = (task: Task) => Promise<void> | void;
+
+export interface ShutdownResult {
+  completed: number;
+  forceCancelled: number;
+  durationMs: number;
+}
