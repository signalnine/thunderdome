new file mode 100644
index 0000000..eadfa2b
--- /dev/null
+++ b/src/cron.ts
@@ -0,0 +1,50 @@
+/**
+ * Simple cron expression parser supporting:
+ *   - `* /N * * * *` → every N minutes (written without space)
+ *   - `0 * * * *`   → every hour on the hour
+ *   - `0 0 * * *`   → every day at midnight
+ */
+export function parseCron(expression: string): { matches: (date: Date) => boolean } {
+  const parts = expression.trim().split(/\s+/);
+  if (parts.length !== 5) {
+    throw new Error(`Invalid cron expression: "${expression}"`);
+  }
+
+  const [minutePart, hourPart, dayOfMonth, month, dayOfWeek] = parts;
+
+  // Only wildcard is supported for day-of-month, month, and day-of-week
+  if (dayOfMonth !== '*' || month !== '*' || dayOfWeek !== '*') {
+    throw new Error(`Unsupported cron expression: only "*" is supported for day-of-month, month, and day-of-week fields`);
+  }
+
+  // Parse minute field
+  let minuteMatcher: (m: number) => boolean;
+  const everyNMatch = minutePart.match(/^\*\/(\d+)$/);
+  if (minutePart === '*') {
+    minuteMatcher = () => true;
+  } else if (everyNMatch) {
+    const n = parseInt(everyNMatch[1], 10);
+    if (n <= 0 || n > 59) throw new Error(`Invalid cron interval: ${n}`);
+    minuteMatcher = (m: number) => m % n === 0;
+  } else {
+    const val = parseInt(minutePart, 10);
+    if (isNaN(val) || val < 0 || val > 59) throw new Error(`Invalid cron minute: ${minutePart}`);
+    minuteMatcher = (m: number) => m === val;
+  }
+
+  // Parse hour field
+  let hourMatcher: (h: number) => boolean;
+  if (hourPart === '*') {
+    hourMatcher = () => true;
+  } else {
+    const val = parseInt(hourPart, 10);
+    if (isNaN(val) || val < 0 || val > 23) throw new Error(`Invalid cron hour: ${hourPart}`);
+    hourMatcher = (h: number) => h === val;
+  }
+
+  return {
+    matches(date: Date): boolean {
+      return minuteMatcher(date.getMinutes()) && hourMatcher(date.getHours());
+    },
+  };
+}
