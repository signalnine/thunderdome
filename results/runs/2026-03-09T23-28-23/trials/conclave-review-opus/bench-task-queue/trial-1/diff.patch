+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 10: Recurring Tasks', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  it('should create a schedule', () => {
+    const schedule = tq.addSchedule('*/5 * * * *', 'default', { job: 'cleanup' });
+    expect(schedule.id).toBeDefined();
+    expect(schedule.expression).toBe('*/5 * * * *');
+    expect(schedule.queue).toBe('default');
+  });
+
+  it('should list active schedules', () => {
+    tq.addSchedule('*/5 * * * *', 'default', 'a');
+    tq.addSchedule('0 * * * *', 'default', 'b');
+
+    expect(tq.listSchedules()).toHaveLength(2);
+  });
+
+  it('should remove a schedule', () => {
+    const s = tq.addSchedule('*/5 * * * *', 'default', 'a');
+    tq.removeSchedule(s.id);
+    expect(tq.listSchedules()).toHaveLength(0);
+  });
+
+  it('should throw when removing non-existent schedule', () => {
+    expect(() => tq.removeSchedule('nonexistent')).toThrow();
+  });
+
+  it('should enqueue tasks on tick when due (every N minutes)', () => {
+    tq.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });
+
+    // At minute 0 (divisible by 5) -> should fire
+    const t0 = new Date('2024-01-01T00:00:00Z');
+    const created = tq.tick(t0);
+    expect(created).toHaveLength(1);
+    expect(created[0].payload).toEqual({ type: 'cleanup' });
+  });
+
+  it('should not enqueue tasks when not due', () => {
+    tq.addSchedule('*/5 * * * *', 'default', 'cleanup');
+
+    // At minute 3 (not divisible by 5) -> should not fire
+    const t3 = new Date('2024-01-01T00:03:00Z');
+    expect(tq.tick(t3)).toHaveLength(0);
+  });
+
+  it('should not double-fire in the same minute', () => {
+    tq.addSchedule('*/5 * * * *', 'default', 'cleanup');
+
+    const t0 = new Date('2024-01-01T00:00:00Z');
+    tq.tick(t0);
+    const second = tq.tick(new Date('2024-01-01T00:00:30Z'));
+    expect(second).toHaveLength(0);
+  });
+
+  it('should support hourly schedule', () => {
+    tq.addSchedule('0 * * * *', 'default', 'hourly');
+
+    // On the hour -> should fire
+    expect(tq.tick(new Date('2024-01-01T01:00:00Z'))).toHaveLength(1);
+    // Not on the hour -> should not fire
+    expect(tq.tick(new Date('2024-01-01T01:30:00Z'))).toHaveLength(0);
+  });
+
+  it('should support daily schedule', () => {
+    tq.addSchedule('0 0 * * *', 'default', 'daily');
+
+    // Midnight -> should fire
+    expect(tq.tick(new Date('2024-01-01T00:00:00Z'))).toHaveLength(1);
+    // Not midnight -> should not fire
+    expect(tq.tick(new Date('2024-01-01T12:00:00Z'))).toHaveLength(0);
+  });
+
+  it('should stop scheduling after removal', () => {
+    const s = tq.addSchedule('*/5 * * * *', 'default', 'cleanup');
+
+    expect(tq.tick(new Date('2024-01-01T00:00:00Z'))).toHaveLength(1);
+    tq.removeSchedule(s.id);
+    expect(tq.tick(new Date('2024-01-01T00:05:00Z'))).toHaveLength(0);
+  });
+
+  it('should apply priority from schedule', () => {
+    tq.addSchedule('*/5 * * * *', 'default', 'urgent', 1);
+
+    const tasks = tq.tick(new Date('2024-01-01T00:00:00Z'));
+    expect(tasks[0].priority).toBe(1);
+  });
+});
