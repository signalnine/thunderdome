+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RrMbeXGvYubypDYkxn2qhs","type":"tool_result","content":"     1→import { randomUUID } from 'node:crypto';\n     2→import {\n     3→  Task,\n     4→  TaskOptions,\n     5→  TaskStatus,\n     6→  createTask,\n     7→  ProgressInfo,\n     8→  ProgressListener,\n     9→  CronSchedule,\n    10→  MiddlewareFn,\n    11→  HandlerFn,\n    12→  ShutdownResult,\n    13→} from './types.js';\n    14→import { parseCron } from './cron.js';\n    15→\n    16→interface QueueState {\n    17→  tasks: Map<string, Task>;\n    18→  deadLetterQueue: Task[];\n    19→  concurrencyLimit: number;\n    20→  activeCount: number;\n    21→  middleware: MiddlewareFn[];\n    22→  handler: HandlerFn | null;\n    23→}\n    24→\n    25→export class TaskQueue {\n    26→  private queues = new Map<string, QueueState>();\n    27→  private allTasks = new Map<string, Task>();\n    28→  private progressListeners = new Map<string, Set<ProgressListener>>();\n    29→  private schedules = new Map<string, CronSchedule>();\n    30→  private isShutdown = false;\n    31→  private shutdownPromise: Promise<ShutdownResult> | null = null;\n    32→  private shutdownCallbacks: Array<() => void | Promise<void>> = [];\n    33→\n    34→  // ---- Internal helpers ----\n    35→\n    36→  private getOrCreateQueue(name: string): QueueState {\n    37→    let q = this.queues.get(name);\n    38→    if (!q) {\n    39→      q = {\n    40→        tasks: new Map(),\n    41→        deadLetterQueue: [],\n    42→        concurrencyLimit: 0, // 0 means unlimited\n    43→        activeCount: 0,\n    44→        middleware: [],\n    45→        handler: null,\n    46→      };\n    47→      this.queues.set(name, q);\n    48→    }\n    49→    return q;\n    50→  }\n    51→\n    52→  private getQueue(name: string): QueueState | undefined {\n    53→    return this.queues.get(name);\n    54→  }\n    55→\n    56→  private areDependenciesMet(task: Task): boolean {\n    57→    for (const depId of task.dependsOn) {\n    58→      const dep = this.allTasks.get(depId);\n    59→      if (!dep || dep.status !== 'completed') {\n    60→        return false;\n    61→      }\n    62→    }\n    63→    return true;\n    64→  }\n    65→\n    66→  private detectCircularDeps(taskId: string, deps: string[], visited: Set<string> = new Set()): boolean {\n    67→    for (const depId of deps) {\n    68→      if (depId === taskId) return true;\n    69→      if (visited.has(depId)) continue;\n    70→      visited.add(depId);\n    71→      const depTask = this.allTasks.get(depId);\n    72→      if (depTask && depTask.dependsOn.length > 0) {\n    73→        if (this.detectCircularDeps(taskId, depTask.dependsOn, visited)) {\n    74→          return true;\n    75→        }\n    76→      }\n    77→    }\n    78→    return false;\n    79→  }\n    80→\n    81→  // ---- Phase 1: Basic FIFO Queue ----\n    82→\n    83→  add<T = unknown>(payload: T, options?: TaskOptions): Task<T> {\n    84→    if (this.isShutdown) {\n    85→      throw new Error('Queue system is shut down: cannot add new tasks');\n    86→    }\n    87→\n    88→    const task = createTask(payload, options);\n    89→    const q = this.getOrCreateQueue(task.queue);\n    90→\n    91→    // Phase 7: validate dependencies\n    92→    if (task.dependsOn.length > 0) {\n    93→      for (const depId of task.dependsOn) {\n    94→        if (!this.allTasks.has(depId)) {\n    95→          throw new Error(`Dependency task \"${depId}\" does not exist`);\n    96→        }\n    97→      }\n    98→      if (this.detectCircularDeps(task.id, task.dependsOn)) {\n    99→        throw new Error('Circular dependency detected');\n   100→      }\n   101→    }\n   102→\n   103→    q.tasks.set(task.id, task);\n   104→    this.allTasks.set(task.id, task);\n   105→    return task;\n   106→  }\n   107→\n   108→  next(queueName: string = 'default'): Task | null {\n   109→    const q = this.getQueue(queueName);\n   110→    if (!q) return null;\n   111→\n   112→    // Phase 8: check concurrency limit\n   113→    if (q.concurrencyLimit > 0 && q.activeCount >= q.concurrencyLimit) {\n   114→      return null;\n   115→    }\n   116→\n   117→    const now = new Date();\n   118→    const candidates: Task[] = [];\n   119→\n   120→    for (const task of q.tasks.values()) {\n   121→      if (task.status !== 'pending') continue;\n   122→      if (task.availableAt > now) continue;\n   123→      if (task.dependsOn.length > 0 && !this.areDependenciesMet(task)) continue;\n   124→      candidates.push(task);\n   125→    }\n   126→\n   127→    if (candidates.length === 0) return null;\n   128→\n   129→    // Sort: priority asc (lower = higher priority), then availableAt asc, then createdAt asc\n   130→    candidates.sort((a, b) => {\n   131→      if (a.priority !== b.priority) return a.priority - b.priority;\n   132→      const aTime = a.availableAt.getTime();\n   133→      const bTime = b.availableAt.getTime();\n   134→      if (aTime !== bTime) return aTime - bTime;\n   135→      return a.createdAt.getTime() - b.createdAt.getTime();\n   136→    });\n   137→\n   138→    const task = candidates[0];\n   139→    task.status = 'processing';\n   140→    task.attempt += 1;\n   141→    q.activeCount += 1;\n   142→    return task;\n   143→  }\n   144→\n   145→  size(queueName: string = 'default'): number {\n   146→    const q = this.getQueue(queueName);\n   147→    if (!q) return 0;\n   148→    let count = 0;\n   149→    for (const task of q.tasks.values()) {\n   150→      if (task.status === 'pending') count++;\n   151→    }\n   152→    return count;\n   153→  }\n   154→\n   155→  getTask(taskId: string): Task | undefined {\n   156→    return this.allTasks.get(taskId);\n   157→  }\n   158→\n   159→  // ---- Phase 2: Named Queues ----\n   160→\n   161→  listQueues(): string[] {\n   162→    return Array.from(this.queues.keys());\n   163→  }\n   164→\n   165→  // ---- Phase 5: Complete / Fail ----\n   166→\n   167→  complete(taskId: string): void {\n   168→    const task = this.allTasks.get(taskId);\n   169→    if (!task) throw new Error(`Task \"${taskId}\" not found`);\n   170→    if (task.status !== 'processing') {\n   171→      throw new Error(`Task \"${taskId}\" is not in processing state`);\n   172→    }\n   173→\n   174→    task.status = 'completed';\n   175→    task.progress = { percentage: 100 };\n   176→\n   177→    const q = this.getQueue(task.queue);\n   178→    if (q) {\n   179→      q.activeCount = Math.max(0, q.activeCount - 1);\n   180→    }\n   181→  }\n   182→\n   183→  fail(taskId: string, error?: Error): void {\n   184→    const task = this.allTasks.get(taskId);\n   185→    if (!task) throw new Error(`Task \"${taskId}\" not found`);\n   186→    if (task.status !== 'processing') {\n   187→      throw new Error(`Task \"${taskId}\" is not in processing state`);\n   188→    }\n   189→\n   190→    task.error = error;\n   191→    task.failCount += 1;\n   192→\n   193→    const q = this.getQueue(task.queue);\n   194→    if (q) {\n   195→      q.activeCount = Math.max(0, q.activeCount - 1);\n   196→    }\n   197→\n   198→    if (task.attempt < task.maxRetries) {\n   199→      // Retry with backoff\n   200→      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);\n   201→      task.status = 'pending';\n   202→      task.availableAt = new Date(Date.now() + delay);\n   203→    } else {\n   204→      // Exhausted retries\n   205→      task.status = 'failed';\n   206→      // Phase 6: move to DLQ\n   207→      if (q) {\n   208→        q.tasks.delete(task.id);\n   209→        q.deadLetterQueue.push(task);\n   210→      }\n   211→    }\n   212→  }\n   213→\n   214→  // ---- Phase 6: Dead Letter Queue ----\n   215→\n   216→  getDeadLetterQueue(queueName: string = 'default'): Task[] {\n   217→    const q = this.getQueue(queueName);\n   218→    if (!q) return [];\n   219→    return [...q.deadLetterQueue];\n   220→  }\n   221→\n   222→  retryDeadLetter(taskId: string):