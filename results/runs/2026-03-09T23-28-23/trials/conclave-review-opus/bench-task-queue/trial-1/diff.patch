+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01T8fWjNojtnryFqnG23LafR","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach } from 'vitest';\n     2→import { TaskQueue, Task } from '../src/index.js';\n     3→\n     4→describe('Phase 11: Middleware Pipeline', () => {\n     5→  let tq: TaskQueue;\n     6→\n     7→  beforeEach(() => {\n     8→    tq = new TaskQueue();\n     9→  });\n    10→\n    11→  it('should register and run middleware before handler', async () => {\n    12→    const order: string[] = [];\n    13→\n    14→    tq.use('default', async (_task, next) => {\n    15→      order.push('mw1');\n    16→      await next();\n    17→    });\n    18→\n    19→    tq.setHandler('default', async () => {\n    20→      order.push('handler');\n    21→    });\n    22→\n    23→    tq.add('work');\n    24→    await tq.process();\n    25→\n    26→    expect(order).toEqual(['mw1', 'handler']);\n    27→  });\n    28→\n    29→  it('should run middleware in registration order', async () => {\n    30→    const order: string[] = [];\n    31→\n    32→    tq.use('default', async (_task, next) => {\n    33→      order.push('mw1-before');\n    34→      await next();\n    35→      order.push('mw1-after');\n    36→    });\n    37→\n    38→    tq.use('default', async (_task, next) => {\n    39→      order.push('mw2-before');\n    40→      await next();\n    41→      order.push('mw2-after');\n    42→    });\n    43→\n    44→    tq.setHandler('default', async () => {\n    45→      order.push('handler');\n    46→    });\n    47→\n    48→    tq.add('work');\n    49→    await tq.process();\n    50→\n    51→    expect(order).toEqual(['mw1-before', 'mw2-before', 'handler', 'mw2-after', 'mw1-after']);\n    52→  });\n    53→\n    54→  it('should skip processing if middleware does not call next', async () => {\n    55→    const handlerCalled = { value: false };\n    56→\n    57→    tq.use('default', async (_task, _next) => {\n    58→      // Intentionally not calling next()\n    59→    });\n    60→\n    61→    tq.setHandler('default', async () => {\n    62→      handlerCalled.value = true;\n    63→    });\n    64→\n    65→    tq.add('work');\n    66→    await tq.process();\n    67→\n    68→    expect(handlerCalled.value).toBe(false);\n    69→  });\n    70→\n    71→  it('should allow middleware to modify task metadata', async () => {\n    72→    tq.use('default', async (task, next) => {\n    73→      task.metadata['enriched'] = true;\n    74→      await next();\n    75→    });\n    76→\n    77→    let receivedTask: Task | null = null;\n    78→    tq.setHandler('default', async (task) => {\n    79→      receivedTask = task;\n    80→    });\n    81→\n    82→    tq.add('work');\n    83→    await tq.process();\n    84→\n    85→    expect(receivedTask?.metadata['enriched']).toBe(true);\n    86→  });\n    87→\n    88→  it('should fail the task if middleware throws', async () => {\n    89→    tq.use('default', async (_task, _next) => {\n    90→      throw new Error('middleware error');\n    91→    });\n    92→\n    93→    const task = tq.add('work', { maxRetries: 1 });\n    94→    await tq.process();\n    95→\n    96→    expect(task.status).toBe('failed');\n    97→    expect(task.error?.message).toBe('middleware error');\n    98→  });\n    99→\n   100→  it('should complete the task after handler runs', async () => {\n   101→    tq.setHandler('default', async () => {\n   102→      // normal handler\n   103→    });\n   104→\n   105→    const task = tq.add('work');\n   106→    await tq.process();\n   107→\n   108→    expect(task.status).toBe('completed');\n   109→  });\n   110→\n   111→  it('should return null when no tasks are available', async () => {\n   112→    const result = await tq.process();\n   113→    expect(result).toBeNull();\n   114→  });\n   115→\n   116→  it('should have independent middleware per queue', async () => {\n   117→    const calls: string[] = [];\n   118→\n   119→    tq.use('q1', async (_task, next) => {\n   120→      calls.push('q1-mw');\n   121→      await next();\n   122→    });\n   123→\n   124→    tq.use('q2', async (_task, next) => {\n   125→      calls.push('q2-mw');\n   126→      await next();\n   127→    });\n   128→\n   129→    tq.setHandler('q1', async () => { calls.push('q1-handler'); });\n   130→    tq.setHandler('q2', async () => { calls.push('q2-handler'); });\n   131→\n   132→    tq.add('a', { queue: 'q1' });\n   133→    tq.add('b', { queue: 'q2' });\n   134→\n   135→    await tq.process('q1');\n   136→    await tq.process('q2');\n   137→\n   138→    expect(calls).toEqual(['q1-mw', 'q1-handler', 'q2-mw', 'q2-handler']);\n   139→  });\n   140→});\n   141→"}]},"parent_tool_use_id":"toolu_01EiN2LBzJgtEnc2nAR1jW9R","session_id":"39620430-694a-4989-ac58-ce8fd865b6a5","uuid":"db52090b-f765-4459-bf0c-679f4fccc91f"}
