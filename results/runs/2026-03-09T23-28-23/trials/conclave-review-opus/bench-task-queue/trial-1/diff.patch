+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LXDDmQcryMrGz9pG3mQZqJ","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach } from 'vitest';\n     2→import { TaskQueue } from '../src/index.js';\n     3→\n     4→describe('Phase 8: Concurrency Control', () => {\n     5→  let tq: TaskQueue;\n     6→\n     7→  beforeEach(() => {\n     8→    tq = new TaskQueue();\n     9→  });\n    10→\n    11→  it('should have unlimited concurrency by default', () => {\n    12→    const c = tq.getConcurrency('default');\n    13→    expect(c.limit).toBe(0);\n    14→    expect(c.active).toBe(0);\n    15→  });\n    16→\n    17→  it('should limit concurrent processing tasks', () => {\n    18→    tq.setConcurrency('default', 2);\n    19→    tq.add('a');\n    20→    tq.add('b');\n    21→    tq.add('c');\n    22→\n    23→    const t1 = tq.next();\n    24→    const t2 = tq.next();\n    25→    expect(t1).not.toBeNull();\n    26→    expect(t2).not.toBeNull();\n    27→\n    28→    // Third should be null (limit reached)\n    29→    expect(tq.next()).toBeNull();\n    30→\n    31→    const c = tq.getConcurrency('default');\n    32→    expect(c.active).toBe(2);\n    33→  });\n    34→\n    35→  it('should free concurrency slot on complete', () => {\n    36→    tq.setConcurrency('default', 1);\n    37→    tq.add('a');\n    38→    tq.add('b');\n    39→\n    40→    const t1 = tq.next()!;\n    41→    expect(tq.next()).toBeNull();\n    42→\n    43→    tq.complete(t1.id);\n    44→    expect(tq.getConcurrency('default').active).toBe(0);\n    45→\n    46→    const t2 = tq.next();\n    47→    expect(t2).not.toBeNull();\n    48→  });\n    49→\n    50→  it('should free concurrency slot on fail', () => {\n    51→    tq.setConcurrency('default', 1);\n    52→    tq.add('a', { maxRetries: 1 });\n    53→    tq.add('b');\n    54→\n    55→    const t1 = tq.next()!;\n    56→    expect(tq.next()).toBeNull();\n    57→\n    58→    tq.fail(t1.id);\n    59→    expect(tq.getConcurrency('default').active).toBe(0);\n    60→  });\n    61→\n    62→  it('should still return highest priority task within concurrency limit', () => {\n    63→    tq.setConcurrency('default', 1);\n    64→    tq.add('low', { priority: 10 });\n    65→    tq.add('high', { priority: 1 });\n    66→\n    67→    const task = tq.next();\n    68→    expect(task?.payload).toBe('high');\n    69→  });\n    70→\n    71→  it('should set and query concurrency for specific queues', () => {\n    72→    tq.setConcurrency('q1', 5);\n    73→    expect(tq.getConcurrency('q1').limit).toBe(5);\n    74→    expect(tq.getConcurrency('q2').limit).toBe(0);\n    75→  });\n    76→});\n    77→"}]},"parent_tool_use_id":"toolu_01EiN2LBzJgtEnc2nAR1jW9R","session_id":"39620430-694a-4989-ac58-ce8fd865b6a5","uuid":"fb6b63a0-85dc-45d0-95c0-89b2fc90fbd3"}
