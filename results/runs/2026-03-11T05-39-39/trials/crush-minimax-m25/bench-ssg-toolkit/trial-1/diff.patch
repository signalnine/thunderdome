+import { marked } from 'marked';
+import type { ContentFile, Plugin } from '../core/types.js';
+
+export function createMarkdownExtPlugin(): Plugin {
+  // Configure marked for GFM and footnotes
+  marked.use({
+    gfm: true,
+    breaks: false,
+  });
+
+  // Custom renderer for footnotes
+  const renderer = new marked.Renderer();
+
+  // Process footnote references like [^1]
+  renderer.text = function ({ text }: { text: string }) {
+    return text.replace(/\[\^(\d+)\]/g, '<sup><a href="#fn-$1">$1</a></sup>');
+  };
+
+  // Process admonition containers like :::note
+  renderer.paragraph = function ({ text }: { text: string }) {
+    // Check for admonition start
+    const admonitionMatch = text.match(/^:::(note|warning|tip)\s*$/i);
+    if (admonitionMatch) {
+      return ''; // Skip the marker paragraph
+    }
+    return `<p>${text}</p>`;
+  };
+
+  renderer.html = function ({ html }: { html: string }) {
+    let processed = html;
+
+    // Convert admonition blocks
+    const admonitionRegex = /:::(\w+)\n([\s\S]*?)\n:::/g;
+    processed = processed.replace(admonitionRegex, (_, type, content) => {
+      const typeLower = type.toLowerCase();
+      return `<div class="admonition admonition-${typeLower}">${content.trim()}</div>`;
+    });
+
+    return processed;
+  };
+
+  marked.use({ renderer });
+
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: (file: ContentFile) => {
+        if (!file.content.trim()) {
+          return file;
+        }
+
+        // Check if content already contains HTML (has HTML tags)
+        if (/<[a-z][\s\S]*>/i.test(file.content)) {
+          // Process for admonitions even in HTML content
+          let processed = file.content;
+          const admonitionRegex = /:::(\w+)\n([\s\S]*?)\n:::/g;
+          processed = processed.replace(admonitionRegex, (_, type, content) => {
+            const typeLower = type.toLowerCase();
+            return `<div class="admonition admonition-${typeLower}">${content.trim()}</div>`;
+          });
+          return { ...file, content: processed };
+        }
+
+        // Parse footnotes from content
+        const footnoteMap = new Map<string, string>();
+        const footnoteRefs: string[] = [];
+
+        // Extract footnotes from content
+        const footnoteDefRegex = /\[\^(\d+)\]:\s*(.+)/g;
+        let match;
+        while ((match = footnoteDefRegex.exec(file.content)) !== null) {
+          footnoteMap.set(match[1], match[2]);
+        }
+
+        // Replace footnote references
+        let contentWithRefs = file.content.replace(
+          /\[\^(\d+)\]/g,
+          '<sup><a href="#fn-$1">$1</a></sup>'
+        );
+
+        // Remove footnote definitions from main content
+        contentWithRefs = contentWithRefs.replace(footnoteDefRegex, '');
+
+        // Convert markdown to HTML
+        let html = marked.parse(contentWithRefs) as string;
+
+        // Process admonitions in the converted HTML
+        const admonitionRegex = /:::(\w+)\n([\s\S]*?)\n:::/g;
+        html = html.replace(admonitionRegex, (_, type, content) => {
+          const typeLower = type.toLowerCase();
+          return `<div class="admonition admonition-${typeLower}">${content.trim()}</div>`;
+        });
+
+        // Append footnote section if there are footnotes
+        if (footnoteMap.size > 0) {
+          let footnoteSection = '<section class="footnotes">\n';
+          footnoteMap.forEach((text, num) => {
+            footnoteSection += `<li id="fn-${num}">${text}</li>\n`;
+          });
+          footnoteSection += '</section>';
+          html += footnoteSection;
+        }
+
+        return { ...file, content: html };
+      },
+    },
+  };
+}
