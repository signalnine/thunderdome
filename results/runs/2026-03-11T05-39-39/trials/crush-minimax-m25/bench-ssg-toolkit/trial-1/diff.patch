+import type { ContentFile, Plugin } from '../core/types.js';
+
+export function createSyntaxHighlightPlugin(): Plugin {
+  return {
+    name: 'syntax-highlight',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: (file: ContentFile) => {
+        let content = file.content;
+
+        // Match <pre><code class="language-xxx">...</code></pre> pattern
+        // We need to add 'highlighted' class to code and data-language to pre
+        content = content.replace(
+          /<pre><code class="language-(\w+)">([\s\S]*?)<\/code><\/pre>/g,
+          (match, lang, code) => {
+            return `<pre data-language="${lang}"><code class="language-${lang} highlighted">${code}</code></pre>`;
+          }
+        );
+
+        return { ...file, content };
+      },
+    },
+  };
+}
