+import type { BuildContext, ContentFile, Plugin } from '../core/types.js';
+
+export function createAssetPipelinePlugin(): Plugin {
+  return {
+    name: 'asset-pipeline',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      beforeBuild: (ctx: BuildContext) => {
+        ctx.data.set('asset-manifest', { assets: [] as string[] });
+      },
+      transformContent: (file: ContentFile, ctx: BuildContext) => {
+        let content = file.content;
+        const manifest = ctx.data.get('asset-manifest') as { assets: string[] };
+        const assets = manifest?.assets || [];
+
+        // Match relative URLs like ./image.png or ./doc.pdf (starting with ./)
+        // Not matching URLs that already start with /assets/
+        const urlRegex = /(?:src|href)=["'](\.\/[^"']+)["']/g;
+
+        content = content.replace(urlRegex, (match, url) => {
+          // Extract the filename (remove ./ prefix)
+          const filename = url.replace(/^\.\//, '');
+          if (filename && !assets.includes(filename)) {
+            assets.push(filename);
+          }
+          return match.replace(url, `/assets/${filename}`);
+        });
+
+        // Update manifest
+        if (manifest) {
+          manifest.assets = [...new Set(assets)];
+        }
+
+        return { ...file, content };
+      },
+    },
+  };
+}
