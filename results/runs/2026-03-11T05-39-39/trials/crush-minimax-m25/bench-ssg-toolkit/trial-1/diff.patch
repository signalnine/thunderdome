+import type { BuildContext, ContentFile, Plugin } from '../core/types.js';
+
+function generateTagPageHtml(tag: string, files: ContentFile[], siteTitle: string): string {
+  const fileList = files
+    .map(f => `<li><a href="/${f.slug}.html">${f.title}</a></li>`)
+    .join('\n');
+
+  return `<!DOCTYPE html>
+<html lang="en">
+<head>
+  <meta charset="UTF-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1.0">
+  <title>${tag} - ${siteTitle}</title>
+</head>
+<body>
+  <h1>Tag: ${tag}</h1>
+  <ul>
+${fileList}
+  </ul>
+</body>
+</html>`;
+}
+
+export function createTaxonomyPlugin(): Plugin {
+  return {
+    name: 'taxonomy',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      beforeBuild: (ctx: BuildContext) => {
+        const tagMap = new Map<string, ContentFile[]>();
+
+        for (const file of ctx.files) {
+          if (file.tags && file.tags.length > 0) {
+            for (const tag of file.tags) {
+              const normalizedTag = tag.toLowerCase();
+              if (!tagMap.has(normalizedTag)) {
+                tagMap.set(normalizedTag, []);
+              }
+              tagMap.get(normalizedTag)!.push(file);
+            }
+          }
+        }
+
+        ctx.data.set('taxonomy-tags', tagMap);
+      },
+      afterBuild: (ctx: BuildContext) => {
+        const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]>;
+        if (!tagMap) return;
+
+        for (const [tag, files] of tagMap) {
+          const pageContent = generateTagPageHtml(tag, files, ctx.config.title);
+          ctx.output.set(`tags/${tag}.html`, pageContent);
+        }
+      },
+    },
+  };
+}
