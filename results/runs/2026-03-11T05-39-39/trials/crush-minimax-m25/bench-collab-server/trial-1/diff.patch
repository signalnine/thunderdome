+import Database from 'better-sqlite3';
+import { Document, Version, ActiveConnection } from './types.js';
+
+export interface Database {
+  getDocument(id: string): Document | undefined;
+  createDocument(id: string, title: string, content?: string): Document;
+  updateDocument(id: string, title?: string, content?: string): Document | undefined;
+  deleteDocument(id: string): boolean;
+  listDocuments(): Document[];
+  
+  addVersion(documentId: string, version: number, content: string, operation: unknown): Version;
+  getVersion(documentId: string, version: number): Version | undefined;
+  getVersions(documentId: string): Version[];
+  getLatestVersion(documentId: string): Version | undefined;
+  
+  addConnection(connectionId: string, documentId: string): void;
+  removeConnection(connectionId: string): void;
+  getConnections(documentId: string): ActiveConnection[];
+}
+
+export function createDatabase(dbPath: string = ':memory:'): Database {
+  const db = new Database(dbPath);
+  
+  // Enable foreign keys
+  db.pragma('foreign_keys = ON');
+  
+  // Initialize schema
+  db.exec(`
+    CREATE TABLE IF NOT EXISTS documents (
+      id TEXT PRIMARY KEY,
+      title TEXT NOT NULL,
+      content TEXT NOT NULL DEFAULT '',
+      created_at TEXT NOT NULL DEFAULT (datetime('now')),
+      updated_at TEXT NOT NULL DEFAULT (datetime('now'))
+    );
+    
+    CREATE TABLE IF NOT EXISTS versions (
+      id INTEGER PRIMARY KEY AUTOINCREMENT,
+      document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
+      version INTEGER NOT NULL,
+      content TEXT NOT NULL,
+      operation TEXT,
+      created_at TEXT NOT NULL DEFAULT (datetime('now')),
+      UNIQUE(document_id, version)
+    );
+    
+    CREATE TABLE IF NOT EXISTS active_connections (
+      id TEXT PRIMARY KEY,
+      document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
+      connected_at TEXT NOT NULL DEFAULT (datetime('now'))
+    );
+    
+    CREATE INDEX IF NOT EXISTS idx_versions_document ON versions(document_id);
+    CREATE INDEX IF NOT EXISTS idx_connections_document ON active_connections(document_id);
+  `);
+  
+  return {
+    getDocument(id: string): Document | undefined {
+      const stmt = db.prepare('SELECT * FROM documents WHERE id = ?');
+      return stmt.get(id) as Document | undefined;
+    },
+    
+    createDocument(id: string, title: string, content: string = ''): Document {
+      const stmt = db.prepare(`
+        INSERT INTO documents (id, title, content)
+        VALUES (?, ?, ?)
+      `);
+      stmt.run(id, title, content);
+      
+      const doc = db.prepare('SELECT * FROM documents WHERE id = ?').get(id) as Document;
+      
+      // Create initial version
+      if (content) {
+        this.addVersion(id, 1, content, null);
+      }
+      
+      return doc;
+    },
+    
+    updateDocument(id: string, title?: string, content?: string): Document | undefined {
+      const updates: string[] = [];
+      const values: (string | number)[] = [];
+      
+      if (title !== undefined) {
+        updates.push('title = ?');
+        values.push(title);
+      }
+      if (content !== undefined) {
+        updates.push('content = ?');
+        values.push(content);
+      }
+      updates.push("updated_at = datetime('now')");
+      
+      if (updates.length === 1) {
+        return this.getDocument(id);
+      }
+      
+      values.push(id);
+      const stmt = db.prepare(`UPDATE documents SET ${updates.join(', ')} WHERE id = ?`);
+      stmt.run(...values);
+      
+      return this.getDocument(id);
+    },
+    
+    deleteDocument(id: string): boolean {
+      const stmt = db.prepare('DELETE FROM documents WHERE id = ?');
+      const result = stmt.run(id);
+      return result.changes > 0;
+    },
+    
+    listDocuments(): Document[] {
+      const stmt = db.prepare('SELECT * FROM documents ORDER BY updated_at DESC');
+      return stmt.all() as Document[];
+    },
+    
+    addVersion(documentId: string, version: number, content: string, operation: unknown): Version {
+      const stmt = db.prepare(`
+        INSERT INTO versions (document_id, version, content, operation)
+        VALUES (?, ?, ?, ?)
+      `);
+      stmt.run(documentId, version, content, operation ? JSON.stringify(operation) : null);
+      return this.getVersion(documentId, version)!;
+    },
+    
+    getVersion(documentId: string, version: number): Version | undefined {
+      const stmt = db.prepare('SELECT * FROM versions WHERE document_id = ? AND version = ?');
+      const row = stmt.get(documentId, version) as (Version & { operation: string | null }) | undefined;
+      if (!row) return undefined;
+      return {
+        ...row,
+        operation: row.operation ? JSON.parse(row.operation) : null
+      };
+    },
+    
+    getVersions(documentId: string): Version[] {
+      const stmt = db.prepare('SELECT * FROM versions WHERE document_id = ? ORDER BY version');
+      const rows = stmt.all(documentId) as (Version & { operation: string | null })[];
+      return rows.map(row => ({
+        ...row,
+        operation: row.operation ? JSON.parse(row.operation) : null
+      }));
+    },
+    
+    getLatestVersion(documentId: string): Version | undefined {
+      const stmt = db.prepare('SELECT * FROM versions WHERE document_id = ? ORDER BY version DESC LIMIT 1');
+      const row = stmt.get(documentId) as (Version & { operation: string | null }) | undefined;
+      if (!row) return undefined;
+      return {
+        ...row,
+        operation: row.operation ? JSON.parse(row.operation) : null
+      };
+    },
+    
+    addConnection(connectionId: string, documentId: string): void {
+      const stmt = db.prepare(`
+        INSERT INTO active_connections (id, document_id)
+        VALUES (?, ?)
+      `);
+      stmt.run(connectionId, documentId);
+    },
+    
+    removeConnection(connectionId: string): void {
+      const stmt = db.prepare('DELETE FROM active_connections WHERE id = ?');
+      stmt.run(connectionId);
+    },
+    
+    getConnections(documentId: string): ActiveConnection[] {
+      const stmt = db.prepare('SELECT * FROM active_connections WHERE document_id = ?');
+      return stmt.all(documentId) as ActiveConnection[];
+    }
+  };
+}
