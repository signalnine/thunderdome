+import { TextOperation, Operation } from './types.js';
+
+/**
+ * Operational Transform implementation for text editing.
+ * Uses a simplified OT approach suitable for real-time collaboration.
+ * 
+ * Key concepts:
+ * - Operations are transformed against each other to maintain consistency
+ * - When two clients send operations at the same base version, we transform
+ *   the second operation so it can be applied after the first
+ */
+
+/**
+ * Apply an operation to a document string
+ */
+export function applyOperation(content: string, op: TextOperation): string {
+  switch (op.type) {
+    case 'insert':
+      return (
+        content.slice(0, op.position) +
+        (op.text || '') +
+        content.slice(op.position)
+      );
+    
+    case 'delete':
+      return (
+        content.slice(0, op.position) +
+        content.slice(op.position + (op.length || 0))
+      );
+    
+    case 'retain':
+      return content;
+    
+    default:
+      return content;
+  }
+}
+
+/**
+ * Transform operation A against operation B.
+ * Returns the transformed operation A' that can be applied after B.
+ * 
+ * This handles the case where two clients simultaneously make changes:
+ * - Client A inserts at position X
+ * - Client B inserts at position Y
+ * 
+ * We need to transform so both operations can be applied correctly.
+ */
+export function transformOperation(opA: TextOperation, opB: TextOperation): TextOperation {
+  // If operations are the same type and same position, adjust
+  const a = { ...opA };
+  const b = { ...opB };
+  
+  // Both insert at same position - offset second insert
+  if (a.type === 'insert' && b.type === 'insert' && a.position === b.position) {
+    // Shift the position of the second insert
+    return { ...a, position: a.position + (b.text?.length || 0) };
+  }
+  
+  // Insert vs Delete transformation
+  if (a.type === 'insert' && b.type === 'delete') {
+    if (a.position <= b.position) {
+      // Insert before delete - no change needed
+      return a;
+    } else if (a.position >= b.position + (b.length || 0)) {
+      // Insert after delete - adjust position
+      return { ...a, position: a.position - (b.length || 0) };
+    } else {
+      // Insert within deleted range - move to delete position
+      return { ...a, position: b.position };
+    }
+  }
+  
+  if (a.type === 'delete' && b.type === 'insert') {
+    if (a.position >= b.position) {
+      // Delete after insert - adjust position
+      return { ...a, position: a.position + (b.text?.length || 0) };
+    } else if (a.position + (a.length || 0) <= b.position) {
+      // Delete before insert - no change needed
+      return a;
+    } else {
+      // Delete spans insert position - split delete
+      // This is complex, so we just adjust to insert position
+      return { ...a, length: b.position - a.position };
+    }
+  }
+  
+  // Delete vs Delete transformation
+  if (a.type === 'delete' && b.type === 'delete') {
+    const aEnd = a.position + (a.length || 0);
+    const bEnd = b.position + (b.length || 0);
+    
+    if (a.position >= bEnd) {
+      // Delete A is entirely after Delete B
+      return { ...a, position: a.position - (b.length || 0) };
+    } else if (aEnd <= b.position) {
+      // Delete A is entirely before Delete B
+      return a;
+    } else if (a.position >= b.position && aEnd <= bEnd) {
+      // Delete A is entirely within Delete B - becomes no-op
+      return { ...a, length: 0 };
+    } else if (a.position < b.position && aEnd > bEnd) {
+      // Delete A completely spans Delete B
+      return { ...a, length: a.length! - (b.length || 0) };
+    } else if (a.position < b.position) {
+      // Overlap at end of A
+      return { ...a, length: b.position - a.position };
+    } else {
+      // Overlap at start of A
+      return { ...a, position: b.position, length: aEnd - bEnd };
+    }
+  }
+  
+  // Retain operations don't affect others
+  return a;
+}
+
+/**
+ * Compose two consecutive operations into one
+ */
+export function composeOperations(opA: TextOperation, opB: TextOperation): TextOperation | null {
+  // If either is retain, just return the other
+  if (opA.type === 'retain') return opB;
+  if (opB.type === 'retain') return opA;
+  
+  // Two inserts at same position can be merged
+  if (opA.type === 'insert' && opB.type === 'insert') {
+    if (opA.position + (opA.text?.length || 0) === opB.position) {
+      return {
+        type: 'insert',
+        position: opA.position,
+        text: (opA.text || '') + (opB.text || '')
+      };
+    }
+  }
+  
+  // Two deletes at same position can be merged
+  if (opA.type === 'delete' && opB.type === 'delete') {
+    if (opA.position === opB.position) {
+      return {
+        type: 'delete',
+        position: opA.position,
+        length: (opA.length || 0) + (opB.length || 0)
+      };
+    }
+  }
+  
+  // Cannot compose - return null
+  return null;
+}
+
+/**
+ * Create an insert operation
+ */
+export function createInsert(position: number, text: string): TextOperation {
+  return { type: 'insert', position, text };
+}
+
+/**
+ * Create a delete operation
+ */
+export function createDelete(position: number, length: number): TextOperation {
+  return { type: 'delete', position, length };
+}
+
+/**
+ * Validate an operation
+ */
+export function isValidOperation(op: unknown): op is TextOperation {
+  if (!op || typeof op !== 'object') return false;
+  const o = op as TextOperation;
+  if (o.type !== 'insert' && o.type !== 'delete' && o.type !== 'retain') return false;
+  if (typeof o.position !== 'number' || o.position < 0) return false;
+  if (o.type === 'insert' && typeof o.text !== 'string') return false;
+  if (o.type === 'delete' && typeof o.length !== 'number') return false;
+  return true;
+}
