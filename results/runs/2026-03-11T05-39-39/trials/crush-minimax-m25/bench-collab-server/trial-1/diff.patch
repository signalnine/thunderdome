+export interface Document {
+  id: string;
+  title: string;
+  content: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface Version {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operation: Operation | null;
+  created_at: string;
+}
+
+export interface ActiveConnection {
+  id: string;
+  document_id: string;
+  connected_at: string;
+}
+
+// OT Operations
+export type Operation = TextOperation;
+
+export interface TextOperation {
+  type: 'insert' | 'delete' | 'retain';
+  position: number;
+  text?: string;      // for insert
+  length?: number;    // for delete/retain
+}
+
+// WebSocket message types
+export type WSMessageType = 
+  | 'sync'
+  | 'operation'
+  | 'ack'
+  | 'error'
+  | 'client-join'
+  | 'client-leave'
+  | 'cursor';
+
+export interface WSMessage {
+  type: WSMessageType;
+  payload: unknown;
+  clientId?: string;
+}
+
+export interface SyncPayload {
+  documentId: string;
+  content: string;
+  version: number;
+}
+
+export interface OperationPayload {
+  operation: Operation;
+  version: number;
+  clientId: string;
+}
+
+export interface ErrorPayload {
+  message: string;
+  code?: string;
+}
+
+export interface CursorPayload {
+  clientId: string;
+  position: number;
+}
