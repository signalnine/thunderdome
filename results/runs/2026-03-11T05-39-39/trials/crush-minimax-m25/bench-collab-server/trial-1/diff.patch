+import express, { Express, Request, Response, NextFunction } from 'express';
+import { WebSocket, WebSocketServer } from 'ws';
+import http from 'http';
+import { createDatabase, Database } from './db.js';
+import {
+  Document,
+  Version,
+  WSMessage,
+  SyncPayload,
+  OperationPayload,
+  ErrorPayload,
+  TextOperation,
+  Operation
+} from './types.js';
+import { applyOperation, transformOperation, isValidOperation, createInsert, createDelete } from './ot.js';
+
+interface Client {
+  id: string;
+  ws: WebSocket;
+  documentId: string;
+}
+
+interface DocumentState {
+  content: string;
+  version: number;
+  clients: Map<string, Client>;
+  pendingOps: Map<string, { op: TextOperation; version: number }>;
+}
+
+export interface App {
+  app: Express;
+  start: (port?: number) => Promise<number>;
+  stop: () => Promise<void>;
+}
+
+export function createApp(dbPath: string = ':memory:'): App {
+  const db: Database = createDatabase(dbPath);
+  const expressApp = express();
+  const server = http.createServer(expressApp);
+  
+  // Body parsing
+  expressApp.use(express.json());
+  
+  // Document state management
+  const documentStates = new Map<string, DocumentState>();
+  
+  // Active WebSocket clients
+  const clients = new Map<string, Client>();
+  
+  // Get or create document state
+  function getDocumentState(documentId: string): DocumentState {
+    let state = documentStates.get(documentId);
+    if (!state) {
+      const doc = db.getDocument(documentId);
+      const latestVersion = db.getLatestVersion(documentId);
+      state = {
+        content: doc?.content || '',
+        version: latestVersion?.version || 0,
+        clients: new Map(),
+        pendingOps: new Map()
+      };
+      documentStates.set(documentId, state);
+    }
+    return state;
+  }
+  
+  // WebSocket server
+  const wss = new WebSocketServer({ server, path: '/ws' });
+  
+  wss.on('connection', (ws, req) => {
+    const url = new URL(req.url || '', `http://${req.headers.host}`);
+    const documentId = url.searchParams.get('documentId');
+    const clientId = url.searchParams.get('clientId') || crypto.randomUUID();
+    
+    if (!documentId) {
+      ws.send(JSON.stringify({ type: 'error', payload: { message: 'Document ID required' } }));
+      ws.close();
+      return;
+    }
+    
+    const doc = db.getDocument(documentId);
+    if (!doc) {
+      ws.send(JSON.stringify({ type: 'error', payload: { message: 'Document not found' } }));
+      ws.close();
+      return;
+    }
+    
+    const state = getDocumentState(documentId);
+    const client: Client = { id: clientId, ws, documentId };
+    state.clients.set(clientId, client);
+    clients.set(clientId, client);
+    db.addConnection(clientId, documentId);
+    
+    // Send sync message
+    const syncPayload: SyncPayload = {
+      documentId,
+      content: state.content,
+      version: state.version
+    };
+    ws.send(JSON.stringify({ type: 'sync', payload: syncPayload, clientId }));
+    
+    // Broadcast client join
+    broadcastToDocument(documentId, {
+      type: 'client-join',
+      payload: { clientId },
+      clientId
+    }, clientId);
+    
+    ws.on('message', (data) => {
+      try {
+        const message = JSON.parse(data.toString()) as WSMessage;
+        handleWSMessage(client, message);
+      } catch (e) {
+        ws.send(JSON.stringify({ type: 'error', payload: { message: 'Invalid message format' } }));
+      }
+    });
+    
+    ws.on('close', () => {
+      state.clients.delete(clientId);
+      clients.delete(clientId);
+      db.removeConnection(clientId);
+      
+      // Broadcast client leave
+      broadcastToDocument(documentId, {
+        type: 'client-leave',
+        payload: { clientId },
+        clientId
+      }, clientId);
+      
+      // Clean up document state if no clients
+      if (state.clients.size === 0) {
+        documentStates.delete(documentId);
+      }
+    });
+    
+    ws.on('error', (error) => {
+      console.error('WebSocket error:', error);
+    });
+  });
+  
+  function handleWSMessage(client: Client, message: WSMessage) {
+    const { type, payload } = message;
+    const state = getDocumentState(client.documentId);
+    
+    switch (type) {
+      case 'operation': {
+        const opPayload = payload as OperationPayload;
+        const operation = opPayload.operation as TextOperation;
+        const clientVersion = opPayload.version;
+        
+        // Validate operation
+        if (!isValidOperation(operation)) {
+          client.ws.send(JSON.stringify({
+            type: 'error',
+            payload: { message: 'Invalid operation' } as ErrorPayload,
+            clientId: client.id
+          }));
+          return;
+        }
+        
+        // Transform against any operations that happened since client's version
+        let transformedOp = operation;
+        let transformVersion = clientVersion;
+        
+        // Apply all operations from client's version to current version
+        const versions = db.getVersions(client.documentId);
+        for (const v of versions) {
+          if (v.version > clientVersion && v.operation) {
+            transformedOp = transformOperation(transformedOp, v.operation as TextOperation);
+            transformVersion = v.version;
+          }
+        }
+        
+        // Apply the transformed operation
+        const newContent = applyOperation(state.content, transformedOp);
+        state.content = newContent;
+        state.version++;
+        
+        // Save to database
+        db.updateDocument(client.documentId, undefined, newContent);
+        db.addVersion(client.documentId, state.version, newContent, transformedOp);
+        
+        // Acknowledge to sender
+        client.ws.send(JSON.stringify({
+          type: 'ack',
+          payload: { version: state.version },
+          clientId: client.id
+        }));
+        
+        // Broadcast to other clients
+        broadcastToDocument(client.documentId, {
+          type: 'operation',
+          payload: {
+            operation: transformedOp,
+            version: state.version,
+            clientId: client.id
+          } as OperationPayload,
+          clientId: client.id
+        }, client.id);
+        
+        break;
+      }
+      
+      case 'cursor': {
+        // Broadcast cursor position to other clients
+        broadcastToDocument(client.documentId, {
+          type: 'cursor',
+          payload: { clientId: client.id, position: (payload as { position: number }).position },
+          clientId: client.id
+        }, client.id);
+        break;
+      }
+      
+      default:
+        client.ws.send(JSON.stringify({
+          type: 'error',
+          payload: { message: `Unknown message type: ${type}` } as ErrorPayload,
+          clientId: client.id
+        }));
+    }
+  }
+  
+  function broadcastToDocument(documentId: string, message: WSMessage, excludeClientId?: string) {
+    const state = documentStates.get(documentId);
+    if (!state) return;
+    
+    const messageStr = JSON.stringify(message);
+    state.clients.forEach((client, id) => {
+      if (id !== excludeClientId && client.ws.readyState === WebSocket.OPEN) {
+        client.ws.send(messageStr);
+      }
+    });
+  }
+  
+  // REST API
+  
+  // Create document
+  expressApp.post('/documents', (req: Request, res: Response) => {
+    const { title, content = '' } = req.body;
+    if (!title) {
+      res.status(400).json({ error: 'Title is required' });
+      return;
+    }
+    
+    const id = uuidv4();
+    const doc = db.createDocument(id, title, content);
+    res.status(201).json(doc);
+  });
+  
+  // List documents
+  expressApp.get('/documents', (_req: Request, res: Response) => {
+    const docs = db.listDocuments();
+    res.json(docs);
+  });
+  
+  // Get document by ID
+  expressApp.get('/documents/:id', (req: Request, res: Response) => {
+    const doc = db.getDocument(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.json(doc);
+  });
+  
+  // Update document
+  expressApp.put('/documents/:id', (req: Request, res: Response) => {
+    const { title, content } = req.body;
+    const doc = db.updateDocument(req.params.id, title, content);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.json(doc);
+  });
+  
+  // Delete document
+  expressApp.delete('/documents/:id', (req: Request, res: Response) => {
+    const deleted = db.deleteDocument(req.params.id);
+    if (!deleted) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.status(204).send();
+  });
+  
+  // Get document versions
+  expressApp.get('/documents/:id/versions', (req: Request, res: Response) => {
+    const doc = db.getDocument(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    const versions = db.getVersions(req.params.id);
+    res.json(versions);
+  });
+  
+  // Get specific version
+  expressApp.get('/documents/:id/versions/:version', (req: Request, res: Response) => {
+    const version = db.getVersion(req.params.id, parseInt(req.params.version));
+    if (!version) {
+      res.status(404).json({ error: 'Version not found' });
+      return;
+    }
+    res.json(version);
+  });
+  
+  // Error handling middleware
+  expressApp.use((err: Error, _req: Request, res: Response, _next: NextFunction) => {
+    console.error('Server error:', err);
+    res.status(500).json({ error: 'Internal server error' });
+  });
+  
+  let serverInstance: http.Server | null = null;
+  
+  return {
+    app: expressApp,
+    
+    async start(port: number = 0): Promise<number> {
+      return new Promise((resolve) => {
+        serverInstance = server.listen(port, () => {
+          const addr = serverInstance!.address();
+          const actualPort = typeof addr === 'object' ? addr?.port || 0 : 0;
+          resolve(actualPort);
+        });
+      });
+    },
+    
+    async stop(): Promise<void> {
+      return new Promise((resolve) => {
+        // Close all WebSocket connections
+        clients.forEach((client) => {
+          if (client.ws.readyState === WebSocket.OPEN) {
+            client.ws.close();
+          }
+        });
+        
+        if (serverInstance) {
+          serverInstance.close(() => {
+            resolve();
+          });
+        } else {
+          resolve();
+        }
+      });
+    }
+  };
+}
