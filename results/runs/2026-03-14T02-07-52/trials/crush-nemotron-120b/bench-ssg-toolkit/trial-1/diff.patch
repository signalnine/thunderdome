+export function createRssFeedPlugin() {
+  return {
+    name: 'rss-feed',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'taxonomy'],
+    hooks: {
+      afterBuild: (ctx) => {
+        const tagMap = ctx.data.get('taxonomy-tags');
+        // Build reverse map: file slug -> tags
+        const fileTags = new Map();
+        if (tagMap) {
+          for (const [tag, files] of tagMap) {
+            for (const file of files) {
+              const existing = fileTags.get(file.slug) || [];
+              fileTags.set(file.slug, [...existing, tag]);
+            }
+          }
+        }
+
+        // Sort files by date (newest first), files without date go to the end
+        const sortedFiles = [...ctx.files].sort((a, b) => {
+          const dateA = a.date ? new Date(a.date) : 0;
+          const dateB = b.date ? new Date(b.date) : 0;
+          return dateB - dateA; // newest first
+        });
+
+        // Generate RSS 2.0 XML
+        let rss = `<?xml version="1.0" encoding="UTF-8"?>
+<rss version="2.0">
+  <channel>
+    <title>${ctx.config.title}</title>
+    <link>${ctx.config.baseUrl}</link>
+    <description>${ctx.config.title}</description>
+    <lastBuildDate>${new Date().toUTCString()}</lastBuildDate>`;
+
+        for (const file of sortedFiles) {
+          rss += `
+    <item>
+      <title>${file.title}</title>
+      <link>${ctx.config.baseUrl}/${file.slug}.html</link>
+      <description><![CDATA[${file.content}]]></description>`;
+
+          // Add pubDate if date exists
+          if (file.date) {
+            try {
+              const date = new Date(file.date);
+              if (!isNaN(date.getTime())) {
+                rss += `
+      <pubDate>${date.toUTCString()}</pubDate>`;
+              }
+            } catch (e) {
+              // Invalid date, skip pubDate
+            }
+          }
+
+          // Add categories from tags
+          const tags = fileTags.get(file.slug) || [];
+          for (const tag of tags) {
+            rss += `
+      <category>${tag}</category>`;
+          }
+
+          rss += `
+    </item>`;
+        }
+
+        rss += `
+  </channel>
+</rss>`;
+
+        ctx.output.set('feed.xml', rss);
+      }
+    }
+  };
+}
