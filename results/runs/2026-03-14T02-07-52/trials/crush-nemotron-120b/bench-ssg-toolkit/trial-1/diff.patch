+export function createSitemapPlugin() {
+  return {
+    name: 'sitemap',
+    version: '1.0.0',
+    dependencies: ['taxonomy', 'rss-feed'],
+    hooks: {
+      afterBuild: (ctx) => {
+        const tagMap = ctx.data.get('taxonomy-tags');
+        const baseUrl = ctx.config.baseUrl;
+
+        let xml = `<?xml version="1.0" encoding="UTF-8"?>
+<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">`;
+
+        // Add all content pages (from ctx.output)
+        for (const [path] of ctx.output) {
+          // Skip non-HTML/XML files like assets, but include HTML, XML, JSON files
+          if (path.endsWith('.html') || path.endsWith('.xml') || path.endsWith('.json')) {
+            xml += `
+  <url>
+    <loc>${baseUrl}/${path}</loc>
+  </url>`;
+          }
+        }
+
+        // Add tag pages from taxonomy (these should already be in ctx.output from taxonomy plugin)
+        // But we'll also check if they exist in case they weren't generated
+        if (tagMap) {
+          for (const [tag] of tagMap) {
+            const tagPath = `tags/${tag}.html`;
+            // Only add if not already in output (to avoid duplicates)
+            if (!ctx.output.has(tagPath)) {
+              xml += `
+  <url>
+    <loc>${baseUrl}/${tagPath}</loc>
+  </url>`;
+            }
+          }
+        }
+
+        xml += `
+</urlset>`;
+
+        ctx.output.set('sitemap.xml', xml);
+      }
+    }
+  };
+}
