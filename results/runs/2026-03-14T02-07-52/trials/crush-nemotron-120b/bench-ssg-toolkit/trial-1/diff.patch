+export function createTaxonomyPlugin() {
+  return {
+    name: 'taxonomy',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      beforeBuild: (ctx) => {
+        const tagMap = new Map();
+
+        for (const file of ctx.files) {
+          const tags = file.tags || [];
+          for (const tag of tags) {
+            const normalizedTag = tag.toLowerCase();
+            if (!tagMap.has(normalizedTag)) {
+              tagMap.set(normalizedTag, []);
+            }
+            tagMap.get(normalizedTag).push(file);
+          }
+        }
+
+        ctx.data.set('taxonomy-tags', tagMap);
+      },
+      afterBuild: (ctx) => {
+        const tagMap = ctx.data.get('taxonomy-tags');
+        if (!tagMap) return;
+
+        // We'll use a simple template for tag pages
+        // In a real implementation, we might use a template from ctx.templates
+        // But for this exercise, we'll generate a simple HTML listing
+        for (const [tag, files] of tagMap) {
+          let content = `<h1>Tag: ${tag}</h1><ul>`;
+          for (const file of files) {
+            content += `<li><a href="/${file.slug}.html">${file.title}</a></li>`;
+          }
+          content += '</ul>';
+
+          ctx.output.set(`tags/${tag}.html`, content);
+        }
+      }
+    }
+  };
+}
