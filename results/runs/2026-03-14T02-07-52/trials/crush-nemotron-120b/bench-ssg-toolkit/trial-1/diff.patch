+import { marked } from 'marked';
+import { BuildContext, ContentFile } from '../core/types.js';
+
+export function createMarkdownExtPlugin() {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: async (file: ContentFile, _ctx: BuildContext) => {
+        let processed = file.content;
+
+        // Process admonition containers: :::note, :::warning, :::tip
+        const admonitionRegex = /:::(note|warning|tip)\s*\n([\s\S]*?)\s*\n:::/g;
+        processed = processed.replace(admonitionRegex, (match, type, content) => {
+          return `<div class="admonition admonition-${type}">${content}</div>`;
+        });
+
+        // Extract footnote definitions and collect them
+        // Pattern: [^id]: multiline footnote content
+        // Starts at beginning of line, captures id and content
+        const footnoteDefRegex = /^\[\^(.+)\]:[ \t]*([\s\S]*?)(?=^\[\^|$)/gm;
+        const footnotes: { id: string; content: string }[] = [];
+        
+        // First, extract all footnote definitions
+        let match;
+        while ((match = footnoteDefRegex.exec(processed)) !== null) {
+          const [, id, content] = match;
+          footnotes.push({ id, content: content.trim() });
+        }
+        
+        // Remove all footnote definitions from the content
+        processed = processed.replace(footnoteDefRegex, '');
+
+        // Replace footnote references: [^id] -> superscript link
+        const footnoteRefRegex = /\[\^([^\]]+)\]/g;
+        processed = processed.replace(footnoteRefRegex, (match, id) => {
+          return `<sup><a href="#fn-${id}">${id}</a></sup>`;
+        });
+
+        // Convert markdown to HTML
+        let htmlContent = marked.parse(processed);
+
+        // Append footnotes section
+        if (footnotes.length > 0) {
+          let footnotesHTML = '<section class="footnotes"><ol>';
+          for (const note of footnotes) {
+            footnotesHTML += `<li id="fn-${note.id}">${note.content}</li>`;
+          }
+          footnotesHTML += '</ol></section>';
+          htmlContent += footnotesHTML;
+        }
+
+        return {
+          ...file,
+          content: htmlContent
+        };
+      }
+    }
+  };
+}
