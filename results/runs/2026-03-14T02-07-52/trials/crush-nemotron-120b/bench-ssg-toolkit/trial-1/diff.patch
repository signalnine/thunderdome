+export function createDevServerPlugin() {
+  return {
+    name: 'dev-server',
+    version: '1.0.0',
+    dependencies: ['asset-pipeline', 'search-index'],
+    hooks: {
+      afterBuild: (ctx) => {
+        const config = {
+          port: 3000,
+          routes: [],
+          assetPaths: [],
+          searchIndexPath: '/search-index.json'
+        };
+
+        // Add routes for content pages (.html files)
+        for (const [path] of ctx.output) {
+          if (path.endsWith('.html')) {
+            config.routes.push({
+              path: `/${path}`,
+              handler: 'static'
+            });
+          }
+          // Add route for search index if it exists
+          if (path === 'search-index.json') {
+            config.routes.push({
+              path: '/search-index.json',
+              handler: 'static'
+            });
+          }
+          // Add routes for XML feeds and sitemap
+          if (path.endsWith('.xml') || path.endsWith('.json')) {
+            config.routes.push({
+              path: `/${path}`,
+              handler: 'static'
+            });
+          }
+        }
+
+        // Add asset routes from asset-pipeline manifest
+        const manifest = ctx.data.get('asset-manifest');
+        if (manifest && manifest.assets) {
+          for (const asset of manifest.assets) {
+            config.assetPaths.push(asset);
+            config.routes.push({
+              path: `/assets/${asset}`,
+              handler: 'asset'
+            });
+          }
+        }
+
+        // Store the config in ctx.data
+        ctx.data.set('dev-server-config', config);
+      }
+    }
+  };
+}
