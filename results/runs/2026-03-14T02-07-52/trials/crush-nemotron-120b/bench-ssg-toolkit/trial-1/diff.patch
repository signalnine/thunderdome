+export function createSyntaxHighlightPlugin() {
+  return {
+    name: 'syntax-highlight',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: (file, _ctx) => {
+        let content = file.content;
+
+        // Regex to match <pre><code class="language-..."> blocks
+        // Captures:
+        //   Group 1: <pre [^>]*> (opening pre tag with attributes)
+        //   Group 2: \s* (whitespace between pre and code)
+        //   Group 3: <code [^>]*class="[^"]*language-([a-zA-Z0-9_-]+)[^"]*"[^>]*> (opening code tag with language class)
+        //   Group 4: the language value (from the class attribute)
+        //   Group 5: [\s\S]*? (inner content, non-greedy)
+        //   Group 6: </code>\s*</pre> (closing tags)
+        const regex = /(<pre[^>]*>)(\s*)(<code[^>]*class="[^"]*language-([a-zA-Z0-9_-]+)[^"]*"[^>]*>)([\s\S]*?)(<\/code>\s*<\/pre>)/g;
+
+        content = content.replace(regex, (match, preTag, whitespace, codeTag, language, innerContent, closingTags) => {
+          // Add data-language to pre tag if not present
+          let modifiedPreTag = preTag;
+          if (!preTag.includes('data-language')) {
+            modifiedPreTag = preTag.replace(/>(\s*)$/, ` data-language="${language}">$1`);
+          }
+
+          // Add highlighted class to code tag if not present
+          let modifiedCodeTag = codeTag;
+          if (!codeTag.includes('highlighted')) {
+            modifiedCodeTag = codeTag.replace(/(class=")([^"]*)(")/, '$1$2 highlighted$3');
+          }
+
+          return modifiedPreTag + whitespace + modifiedCodeTag + innerContent + closingTags;
+        });
+
+        return {
+          ...file,
+          content
+        };
+      }
+    }
+  };
+}
