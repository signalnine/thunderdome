+export function createSearchIndexPlugin() {
+  return {
+    name: 'search-index',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'syntax-highlight'],
+    hooks: {
+      afterBuild: (ctx) => {
+        const index = [];
+
+        for (const file of ctx.files) {
+          // Extract plain text content by stripping HTML tags
+          let plainText = file.content;
+          // Remove HTML tags but keep the content
+          plainText = plainText.replace(/<[^>]*>/g, ' ');
+          // Collapse multiple whitespace
+          plainText = plainText.replace(/\s+/g, ' ').trim();
+
+          const entry = {
+            slug: file.slug,
+            title: file.title,
+            content: plainText
+          };
+
+          // Include tags if present
+          if (file.tags && file.tags.length > 0) {
+            entry.tags = file.tags;
+          }
+
+          index.push(entry);
+        }
+
+        // Write search index to output
+        const indexJson = JSON.stringify(index, null, 2);
+        ctx.output.set('search-index.json', indexJson);
+      }
+    }
+  };
+}
