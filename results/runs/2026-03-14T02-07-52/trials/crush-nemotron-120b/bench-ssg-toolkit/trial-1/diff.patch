+
+
+export function createAssetPipelinePlugin() {
+  return {
+    name: 'asset-pipeline',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: (file, ctx) => {
+        // We'll process the content to rewrite asset URLs and collect assets
+        const content = file.content;
+
+        // Regular expression to match src and href attributes with relative URLs
+        // We'll match: src="relative/path" or href="relative/path"
+        // We want to avoid matching absolute URLs (starting with http, https, or /)
+        const assetRegex = /(src|href)=["']([^"']*?)["']/g;
+
+        // We'll collect assets in the context data
+        let assets = ctx.data.get('asset-manifest')?.assets || [];
+        const assetSet = new Set(assets);
+
+        // Function to rewrite a matched attribute
+        const rewriteAsset = (match, attr, url) => {
+          // If the URL is absolute (starts with http, https, or /) or already starts with /assets/, leave it
+          if (url.startsWith('http://') || url.startsWith('https://') || url.startsWith('/') || url.startsWith('/assets/')) {
+            return match;
+          }
+
+          // Normalize the URL by removing ./ prefix
+          let normalizedUrl = url;
+          if (normalizedUrl.startsWith('./')) {
+            normalizedUrl = normalizedUrl.substring(2);
+          }
+
+          // Rewrite the URL to /assets/ + normalizedUrl
+          const newUrl = `/assets/${normalizedUrl}`;
+          // Add to asset set if not already present (using normalized URL for deduplication)
+          if (!assetSet.has(normalizedUrl)) {
+            assetSet.add(normalizedUrl);
+            assets.push(normalizedUrl);
+          }
+          return `${attr}="${newUrl}"`;
+        };
+
+        // Replace all matches
+        const newContent = content.replace(assetRegex, rewriteAsset);
+
+        // Update the assets in context data
+        ctx.data.set('asset-manifest', { assets });
+
+        return {
+          ...file,
+          content: newContent
+        };
+      },
+      afterBuild: (ctx) => {
+        // Generate the asset manifest file
+        const manifest = ctx.data.get('asset-manifest');
+        if (manifest && manifest.assets.length > 0) {
+          // We'll create a JSON manifest file in the output directory
+          const manifestContent = JSON.stringify({
+            version: '1.0.0',
+            assets: manifest.assets.map(asset => ({
+              name: asset,
+              path: `/assets/${asset}`
+            }))
+          }, null, 2);
+
+          ctx.assets.set('asset-manifest.json', Buffer.from(manifestContent));
+        }
+      }
+    }
+  };
+}
