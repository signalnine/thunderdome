+**Step 2: Write tests**
+
+```typescript
+// src/registry/registry.test.ts
+import { describe, it, expect, beforeEach } from 'vitest';
+import { createRegistry } from './index.js';
+import type { PluginManifest } from '../types.js';
+
+const makeManifest = (overrides: Partial<PluginManifest> = {}): PluginManifest => ({
+  name: 'test-plugin',
+  version: '1.0.0',
+  description: 'A test plugin',
+  author: 'tester',
+  dependencies: {},
+  entryPoint: 'module.exports = 42;',
+  permissions: [],
+  ...overrides,
+});
+
+describe('RegistryService', () => {
+  let registry: ReturnType<typeof createRegistry>;
+
+  beforeEach(() => {
+    registry = createRegistry();
+  });
+
+  it('registers and retrieves a plugin', () => {
+    const manifest = makeManifest();
+    registry.register(manifest);
+    expect(registry.get('test-plugin')).toEqual(manifest);
+  });
+
+  it('returns null for unknown plugin', () => {
+    expect(registry.get('nope')).toBeNull();
+  });
+
+  it('gets a specific version', () => {
+    registry.register(makeManifest({ version: '1.0.0' }));
+    registry.register(makeManifest({ version: '2.0.0' }));
+    expect(registry.getVersion('test-plugin', '1.0.0')?.version).toBe('1.0.0');
+  });
+
+  it('lists all plugins', () => {
+    registry.register(makeManifest({ name: 'a', version: '1.0.0' }));
+    registry.register(makeManifest({ name: 'b', version: '1.0.0' }));
+    expect(registry.list()).toHaveLength(2);
+  });
+
+  it('searches by name and description', () => {
+    registry.register(makeManifest({ name: 'logger', description: 'Logging tool' }));
+    registry.register(makeManifest({ name: 'auth', description: 'Auth service' }));
+    expect(registry.search('log')).toHaveLength(1);
+    expect(registry.search('service')).toHaveLength(1);
+  });
+
+  it('removes a plugin version', () => {
+    registry.register(makeManifest());
+    expect(registry.remove('test-plugin', '1.0.0')).toBe(true);
+    expect(registry.get('test-plugin')).toBeNull();
+  });
+
+  it('returns false when removing nonexistent', () => {
+    expect(registry.remove('nope', '1.0.0')).toBe(false);
+  });
+
+  it('lists versions', () => {
+    registry.register(makeManifest({ version: '1.0.0' }));
+    registry.register(makeManifest({ version: '2.0.0' }));
+    expect(registry.listVersions('test-plugin')).toEqual(['1.0.0', '2.0.0']);
+  });
+
+  it('updates a plugin', () => {
+    registry.register(makeManifest());
+    registry.update('test-plugin', '1.0.0', { description: 'Updated' });
+    expect(registry.get('test-plugin')?.description).toBe('Updated');
+  });
+});
+```
