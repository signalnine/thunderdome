});\n\n  it('searches by name', () => {\n    registry.register(makeManifest({ name: 'logger', description: 'Logging tool' }));\n    registry.register(makeManifest({ name: 'auth', description: 'Auth service' }));\n    expect(registry.search('log')).toHaveLength(1);\n    expect(registry.search('log')[0].name).toBe('logger');\n  });\n\n  it('searches by description', () => {\n    registry.register(makeManifest({ name: 'auth', description: 'Auth service' }));\n    expect(registry.search('service')).toHaveLength(1);\n  });\n\n  it('search is case insensitive', () => {\n    registry.register(makeManifest({ name: 'Logger' }));\n    expect(registry.search('LOGGER')).toHaveLength(1);\n  });\n\n  it('removes a plugin version', () => {\n    registry.register(makeManifest());\n    expect(registry.remove('test-plugin', '1.0.0')).toBe(true);\n    expect(registry.get('test-plugin')).toBeNull();\n  });\n\n  it('returns false when removing nonexistent', () => {\n    expect(registry.remove('nope', '1.0.0')).toBe(false);\n  });\n\n  it('removes only the specified version', () => {\n    registry.register(makeManifest({ version: '1.0.0' }));\n    registry.register(makeManifest({ version: '2.0.0' }));\n    registry.remove('test-plugin', '1.0.0');\n    expect(registry.getVersion('test-plugin', '1.0.0')).toBeNull();\n    expect(registry.getVersion('test-plugin', '2.0.0')).not.toBeNull();\n  });\n\n  it('lists versions for a plugin', () => {\n    registry.register(makeManifest({ version: '1.0.0' }));\n    registry.register(makeManifest({ version: '2.0.0' }));\n    expect(registry.listVersions('test-plugin')).toEqual(['1.0.0', '2.0.0']);\n  });\n\n  it('returns empty array for unknown plugin versions', () => {\n    expect(registry.listVersions('nope')).toEqual([]);\n  });\n\n  it('updates a plugin manifest', () => {\n    registry.register(makeManifest());\n    registry.update('test-plugin', '1.0.0', { description: 'Updated desc' });\n    expect(registry.get('test-plugin')?.description).toBe(