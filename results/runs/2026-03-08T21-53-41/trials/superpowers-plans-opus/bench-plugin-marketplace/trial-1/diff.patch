+++ b/src/deps/deps.test.ts
@@ -0,0 +1,142 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { createDepsService } from './index.js';
+import { createRegistry } from '../registry/index.js';
+import type { RegistryService } from '../types.js';
+
+describe('DepsService', () => {
+  const deps = createDepsService();
+  let registry: RegistryService;
+
+  beforeEach(() => {
+    registry = createRegistry();
+  });
+
+  function registerPlugin(name: string, dependencies: Record<string, string> = {}) {
+    registry.register({
+      name,
+      version: '1.0.0',
+      description: `Plugin ${name}`,
+      author: 'test',
+      dependencies,
+      entryPoint: '1+1',
+      permissions: [],
+    });
+  }
+
+  describe('buildTree', () => {
+    it('builds a tree for a plugin with no deps', () => {
+      registerPlugin('root');
+      const tree = deps.buildTree('root', registry);
+      expect(tree.name).toBe('root');
+      expect(tree.version).toBe('1.0.0');
+      expect(tree.dependencies).toHaveLength(0);
+    });
+
+    it('builds a tree with nested deps', () => {
+      registerPlugin('leaf');
+      registerPlugin('mid', { leaf: '^1.0.0' });
+      registerPlugin('root', { mid: '^1.0.0' });
+
+      const tree = deps.buildTree('root', registry);
+      expect(tree.name).toBe('root');
+      expect(tree.dependencies).toHaveLength(1);
+      expect(tree.dependencies[0].name).toBe('mid');
+      expect(tree.dependencies[0].dependencies).toHaveLength(1);
+      expect(tree.dependencies[0].dependencies[0].name).toBe('leaf');
+    });
+
+    it('returns unknown version for unregistered plugin', () => {
+      const tree = deps.buildTree('missing', registry);
+      expect(tree.version).toBe('unknown');
+    });
+  });
+
+  describe('detectCycles', () => {
+    it('returns null when no cycles', () => {
+      registerPlugin('a');
+      registerPlugin('b', { a: '^1.0.0' });
+      expect(deps.detectCycles('b', registry)).toBeNull();
+    });
+
+    it('detects a direct cycle', () => {
+      registerPlugin('a', { b: '^1.0.0' });
+      registerPlugin('b', { a: '^1.0.0' });
+      const cycles = deps.detectCycles('a', registry);
+      expect(cycles).not.toBeNull();
+      expect(cycles!.length).toBeGreaterThan(0);
+    });
+
+    it('detects an indirect cycle', () => {
+      registerPlugin('a', { b: '^1.0.0' });
+      registerPlugin('b', { c: '^1.0.0' });
+      registerPlugin('c', { a: '^1.0.0' });
+      const cycles = deps.detectCycles('a', registry);
+      expect(cycles).not.toBeNull();
+    });
+  });
+
+  describe('hasCircularDependency', () => {
+    it('returns false for no cycle', () => {
+      registerPlugin('a');
+      expect(deps.hasCircularDependency('a', registry)).toBe(false);
+    });
+
+    it('returns true for a cycle', () => {
+      registerPlugin('a', { b: '^1.0.0' });
+      registerPlugin('b', { a: '^1.0.0' });
+      expect(deps.hasCircularDependency('a', registry)).toBe(true);
+    });
+  });
+
+  describe('topologicalSort', () => {
+    it('returns single plugin with no deps', () => {
+      registerPlugin('a');
+      expect(deps.topologicalSort('a', registry)).toEqual(['a']);
+    });
+
+    it('sorts dependencies before dependents', () => {
+      registerPlugin('leaf');
+      registerPlugin('mid', { leaf: '^1.0.0' });
+      registerPlugin('root', { mid: '^1.0.0' });
+
+      const sorted = deps.topologicalSort('root', registry);
+      expect(sorted.indexOf('leaf')).toBeLessThan(sorted.indexOf('mid'));
+      expect(sorted.indexOf('mid')).toBeLessThan(sorted.indexOf('root'));
+    });
+
+    it('throws on circular dependency', () => {
+      registerPlugin('a', { b: '^1.0.0' });
+      registerPlugin('b', { a: '^1.0.0' });
+      expect(() => deps.topologicalSort('a', registry)).toThrow('Circular dependency');
+    });
+  });
+
+  describe('flattenDependencies', () => {
+    it('returns empty for plugin with no deps', () => {
+      registerPlugin('a');
+      expect(deps.flattenDependencies('a', registry)).toEqual([]);
+    });
+
+    it('returns all transitive dependencies', () => {
+      registerPlugin('leaf');
+      registerPlugin('mid', { leaf: '^1.0.0' });
+      registerPlugin('root', { mid: '^1.0.0' });
+
+      const flat = deps.flattenDependencies('root', registry);
+      expect(flat).toContain('mid');
+      expect(flat).toContain('leaf');
+      expect(flat).not.toContain('root');
+    });
+
+    it('deduplicates shared dependencies', () => {
+      registerPlugin('shared');
+      registerPlugin('a', { shared: '^1.0.0' });
+      registerPlugin('b', { shared: '^1.0.0' });
+      registerPlugin('root', { a: '^1.0.0', b: '^1.0.0' });
+
+      const flat = deps.flattenDependencies('root', registry);
+      const sharedCount = flat.filter((d) => d === 'shared').length;
+      expect(sharedCount).toBe(1);
+    });
+  });
+});
