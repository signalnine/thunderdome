@@ -0,0 +1,108 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { createMarketplace } from './index.js';
+import type { PluginManifest } from './types.js';
+
+const makeManifest = (overrides: Partial<PluginManifest> = {}): PluginManifest => ({
+  name: 'test-plugin',
+  version: '1.0.0',
+  description: 'A test plugin',
+  author: 'tester',
+  dependencies: {},
+  entryPoint: '2 + 2',
+  permissions: [],
+  ...overrides,
+});
+
+describe('createMarketplace', () => {
+  let marketplace: ReturnType<typeof createMarketplace>;
+
+  beforeEach(() => {
+    marketplace = createMarketplace();
+  });
+
+  it('exposes all services', () => {
+    expect(marketplace.registry).toBeDefined();
+    expect(marketplace.resolver).toBeDefined();
+    expect(marketplace.runner).toBeDefined();
+    expect(marketplace.reviews).toBeDefined();
+    expect(marketplace.deps).toBeDefined();
+    expect(marketplace.installPlugin).toBeDefined();
+  });
+
+  describe('installPlugin', () => {
+    it('installs a simple plugin', async () => {
+      const result = await marketplace.installPlugin(makeManifest());
+      expect(result.executionResult.success).toBe(true);
+      expect(result.executionResult.output).toBe(4);
+      expect(result.resolvedDependencies).toEqual([]);
+    });
+
+    it('registers the plugin in the registry', async () => {
+      await marketplace.installPlugin(makeManifest());
+      expect(marketplace.registry.get('test-plugin')).not.toBeNull();
+    });
+
+    it('rejects manifest without name', async () => {
+      await expect(
+        marketplace.installPlugin(makeManifest({ name: '' })),
+      ).rejects.toThrow('name');
+    });
+
+    it('rejects manifest without version', async () => {
+      await expect(
+        marketplace.installPlugin(makeManifest({ version: '' })),
+      ).rejects.toThrow('version');
+    });
+
+    it('rejects manifest without entryPoint', async () => {
+      await expect(
+        marketplace.installPlugin(makeManifest({ entryPoint: '' })),
+      ).rejects.toThrow('entryPoint');
+    });
+
+    it('resolves dependencies when available', async () => {
+      // Register a dependency first
+      await marketplace.installPlugin(makeManifest({ name: 'dep-a', version: '1.0.0' }));
+
+      const result = await marketplace.installPlugin(
+        makeManifest({
+          name: 'main-plugin',
+          dependencies: { 'dep-a': '^1.0.0' },
+        }),
+      );
+
+      expect(result.resolvedDependencies).toHaveLength(1);
+      expect(result.resolvedDependencies[0].name).toBe('dep-a');
+      expect(result.resolvedDependencies[0].version).toBe('1.0.0');
+    });
+
+    it('rejects circular dependencies', async () => {
+      // Register plugin A that depends on B
+      marketplace.registry.register(
+        makeManifest({ name: 'plugin-a', dependencies: { 'plugin-b': '^1.0.0' } }),
+      );
+      // Register plugin B that depends on A
+      marketplace.registry.register(
+        makeManifest({ name: 'plugin-b', dependencies: { 'plugin-a': '^1.0.0' } }),
+      );
+
+      // Try to install C that depends on A (which creates a cycle through B)
+      await expect(
+        marketplace.installPlugin(
+          makeManifest({
+            name: 'plugin-c',
+            dependencies: { 'plugin-a': '^1.0.0' },
+          }),
+        ),
+      ).rejects.toThrow('Circular');
+    });
+
+    it('handles plugin with failing code', async () => {
+      const result = await marketplace.installPlugin(
+        makeManifest({ entryPoint: 'throw new Error("fail")' }),
+      );
+      expect(result.executionResult.success).toBe(false);
+      expect(result.executionResult.error).toBe('fail');
+    });
+  });
+});
