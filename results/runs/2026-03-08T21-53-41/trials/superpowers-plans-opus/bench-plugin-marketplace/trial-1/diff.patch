+
+describe('ReviewService', () => {
+  let reviews: ReviewService;
+
+  beforeEach(() => {
+    reviews = createReviewService(':memory:');
+  });
+
+  it('adds a review and returns it with id and createdAt', () => {
+    const review = reviews.addReview({
+      pluginName: 'test-plugin',
+      pluginVersion: '1.0.0',
+      userId: 'user1',
+      rating: 5,
+      comment: 'Great plugin!',
+    });
+
+    expect(review.id).toBeDefined();
+    expect(review.pluginName).toBe('test-plugin');
+    expect(review.rating).toBe(5);
+    expect(review.flagged).toBe(false);
+    expect(review.createdAt).toBeDefined();
+  });
+
+  it('gets reviews for a plugin', () => {
+    reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 4, comment: 'Good' });
+    reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: 'OK' });
+    reviews.addReview({ pluginName: 'p2', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'Best' });
+
+    const p1Reviews = reviews.getReviews('p1');
+    expect(p1Reviews).toHaveLength(2);
+  });
+
+  it('computes average rating excluding flagged reviews', () => {
+    reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'Great' });
+    reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: 'OK' });
+    const bad = reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u3', rating: 1, comment: 'Spam' });
+
+    reviews.flagReview(bad.id);
+
+    // Average of 5 and 3 = 4 (flagged review excluded)
+    expect(reviews.getAverageRating('p1')).toBe(4);
+  });
+
+  it('returns 0 for average when no reviews', () => {
+    expect(reviews.getAverageRating('nonexistent')).toBe(0);
+  });
+
+  it('flags a review', () => {
+    const review = reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 1, comment: 'Spam' });
+    reviews.flagReview(review.id);
+
+    const flagged = reviews.getFlaggedReviews();
+    expect(flagged).toHaveLength(1);
+    expect(flagged[0].flagged).toBe(true);
+  });
+
+  it('removes a review', () => {
+    const review = reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'Great' });
+    expect(reviews.removeReview(review.id)).toBe(true);
+    expect(reviews.getReviews('p1')).toHaveLength(0);
+  });
+
+  it('returns false when removing nonexistent review', () => {
+    expect(reviews.removeReview(999)).toBe(false);
+  });
+
+  it('gets reviews by user', () => {
+    reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'user1', rating: 4, comment: 'Good' });
+    reviews.addReview({ pluginName: 'p2', pluginVersion: '1.0.0', userId: 'user1', rating: 5, comment: 'Great' });
+    reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'user2', rating: 3, comment: 'OK' });
+
+    const userReviews = reviews.getReviewsByUser('user1');
+    expect(userReviews).toHaveLength(2);
+  });
+
+  it('counts reviews for a plugin', () => {
+    reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 4, comment: 'Good' });
+    reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: 'OK' });
+
+    expect(reviews.getReviewCount('p1')).toBe(2);
+    expect(reviews.getReviewCount('nonexistent')).toBe(0);
+  });
+});
