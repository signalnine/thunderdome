+import { describe, it, expect, beforeEach } from 'vitest';
+import { createRegistry } from './index.js';
+import type { PluginManifest } from '../types.js';
+
+const makeManifest = (overrides: Partial<PluginManifest> = {}): PluginManifest => ({
+  name: 'test-plugin',
+  version: '1.0.0',
+  description: 'A test plugin',
+  author: 'tester',
+  dependencies: {},
+  entryPoint: 'module.exports = 42;',
+  permissions: [],
+  ...overrides,
+});
+
+describe('RegistryService', () => {
+  let registry: ReturnType<typeof createRegistry>;
+
+  beforeEach(() => {
+    registry = createRegistry();
+  });
+
+  it('registers and retrieves a plugin', () => {
+    const manifest = makeManifest();
+    registry.register(manifest);
+    expect(registry.get('test-plugin')).toEqual(manifest);
+  });
+
+  it('returns null for unknown plugin', () => {
+    expect(registry.get('nope')).toBeNull();
+  });
+
+  it('gets a specific version', () => {
+    registry.register(makeManifest({ version: '1.0.0' }));
+    registry.register(makeManifest({ version: '2.0.0' }));
+    expect(registry.getVersion('test-plugin', '1.0.0')?.version).toBe('1.0.0');
+    expect(registry.getVersion('test-plugin', '2.0.0')?.version).toBe('2.0.0');
+  });
+
+  it('returns null for unknown version', () => {
+    registry.register(makeManifest());
+    expect(registry.getVersion('test-plugin', '9.9.9')).toBeNull();
+  });
+
+  it('lists all plugins across versions', () => {
+    registry.register(makeManifest({ name: 'a', version: '1.0.0' }));
+    registry.register(makeManifest({ name: 'b', version: '1.0.0' }));
+    registry.register(makeManifest({ name: 'a', version: '2.0.0' }));
+    expect(registry.list()).toHaveLength(3);
+  });
+
+  it('searches by name', () => {
+    registry.register(makeManifest({ name: 'logger', description: 'Logging tool' }));
+    registry.register(makeManifest({ name: 'auth', description: 'Auth service' }));
+    expect(registry.search('log')).toHaveLength(1);
+    expect(registry.search('log')[0].name).toBe('logger');
+  });
+
+  it('searches by description', () => {
+    registry.register(makeManifest({ name: 'auth', description: 'Auth service' }));
+    expect(registry.search('service')).toHaveLength(1);
+  });
+
+  it('search is case insensitive', () => {
+    registry.register(makeManifest({ name: 'Logger' }));
+    expect(registry.search('LOGGER')).toHaveLength(1);
+  });
+
+  it('removes a plugin version', () => {
+    registry.register(makeManifest());
+    expect(registry.remove('test-plugin', '1.0.0')).toBe(true);
+    expect(registry.get('test-plugin')).toBeNull();
+  });
+
+  it('returns false when removing nonexistent', () => {
+    expect(registry.remove('nope', '1.0.0')).toBe(false);
+  });
+
+  it('removes only the specified version', () => {
+    registry.register(makeManifest({ version: '1.0.0' }));
+    registry.register(makeManifest({ version: '2.0.0' }));
+    registry.remove('test-plugin', '1.0.0');
+    expect(registry.getVersion('test-plugin', '1.0.0')).toBeNull();
+    expect(registry.getVersion('test-plugin', '2.0.0')).not.toBeNull();
+  });
+
+  it('lists versions for a plugin', () => {
+    registry.register(makeManifest({ version: '1.0.0' }));
+    registry.register(makeManifest({ version: '2.0.0' }));
+    expect(registry.listVersions('test-plugin')).toEqual(['1.0.0', '2.0.0']);
+  });
+
+  it('returns empty array for unknown plugin versions', () => {
+    expect(registry.listVersions('nope')).toEqual([]);
+  });
+
+  it('updates a plugin manifest', () => {
+    registry.register(makeManifest());
+    registry.update('test-plugin', '1.0.0', { description: 'Updated desc' });
+    expect(registry.get('test-plugin')?.description).toBe('Updated desc');
+  });
+
+  it('update preserves name and version', () => {
+    registry.register(makeManifest());
+    registry.update('test-plugin', '1.0.0', { name: 'hacked', version: '9.9.9' } as Partial<PluginManifest>);
+    const result = registry.get('test-plugin');
+    expect(result?.name).toBe('test-plugin');
+    expect(result?.version).toBe('1.0.0');
+  });
+
+  it('throws on updating nonexistent plugin', () => {
+    expect(() => registry.update('nope', '1.0.0', {})).toThrow();
+  });
+
+  it('throws on updating nonexistent version', () => {
+    registry.register(makeManifest());
+    expect(() => registry.update('test-plugin', '9.9.9', {})).toThrow();
+  });
+});
