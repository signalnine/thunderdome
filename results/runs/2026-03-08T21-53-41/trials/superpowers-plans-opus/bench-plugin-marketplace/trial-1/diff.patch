},\n      );\n      expect(result[0].version).toBe('1.0.0');\n    });\n  });\n\n  describe('satisfies', () => {\n    it('returns true when version satisfies range', () => {\n      expect(resolver.satisfies('1.2.3', '^1.0.0')).toBe(true);\n    });\n\n    it('returns false when version does not satisfy range', () => {\n      expect(resolver.satisfies('2.0.0', '^1.0.0')).toBe(false);\n    });\n  });\n\n  describe('maxSatisfying', () => {\n    it('finds the maximum satisfying version', () => {\n      expect(resolver.maxSatisfying(['1.0.0', '1.5.0', '2.0.0'], '^1.0.0')).toBe('1.5.0');\n    });\n\n    it('returns null if nothing satisfies', () => {\n      expect(resolver.maxSatisfying(['1.0.0'], '^2.0.0')).toBeNull();\n    });\n  });\n\n  describe('validRange', () => {\n    it('returns true for valid semver ranges', () => {\n      expect(resolver.validRange('^1.0.0')).toBe(true);\n      expect(resolver.validRange('~1.2.3')).toBe(true);\n      expect(resolver.validRange('>=1.0.0 <2.0.0')).toBe(true);\n    });\n\n    it('returns false for invalid ranges', () => {\n      expect(resolver.validRange('not-a-range')).toBe(false);\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":386,"cache_read_input_tokens":30296,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":386},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"f152d743-e442-4a18-aa9c-0ed1b68f0b5d","uuid":"5de55785-3f13-4d79-8266-76d99b295960"}
