+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../task-queue.js';
+
+describe('Phase 4: Delayed and Scheduled Tasks', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  it('should support delay in milliseconds', () => {
+    const task = tq.addTask('delayed', { delay: 5000 });
+    expect(task.availableAt.getTime()).toBeGreaterThan(Date.now());
+  });
+
+  it('should not return delayed tasks before availability time', () => {
+    tq.addTask('delayed', { delay: 60000 }); // 1 minute delay
+    expect(tq.getNextTask()).toBeNull();
+  });
+
+  it('should return delayed tasks after availability time', () => {
+    // Create a task with an availability time in the past
+    const task = tq.addTask('delayed', {
+      availableAt: new Date(Date.now() - 1000),
+    });
+    const retrieved = tq.getNextTask();
+    expect(retrieved).not.toBeNull();
+    expect(retrieved!.id).toBe(task.id);
+  });
+
+  it('should support specific future availableAt time', () => {
+    const futureDate = new Date(Date.now() + 60000);
+    const task = tq.addTask('scheduled', { availableAt: futureDate });
+    expect(task.availableAt.getTime()).toBe(futureDate.getTime());
+  });
+
+  it('should prefer non-delayed tasks over unavailable delayed tasks', () => {
+    tq.addTask('delayed', { delay: 60000 });
+    tq.addTask('immediate');
+
+    const task = tq.getNextTask();
+    expect(task!.payload).toBe('immediate');
+  });
+
+  it('should order available tasks by availability time, then priority, then FIFO', () => {
+    const past1 = new Date(Date.now() - 3000);
+    const past2 = new Date(Date.now() - 1000);
+
+    tq.addTask('later-available', { availableAt: past2, priority: 1 });
+    tq.addTask('earlier-available', { availableAt: past1, priority: 1 });
+
+    // Both are available. Same priority, so FIFO by creation order should apply.
+    // But since they have different availability times, they should be ordered by
+    // priority first (both are 1), then creation time (FIFO).
+    const t1 = tq.getNextTask();
+    const t2 = tq.getNextTask();
+    expect(t1!.payload).toBe('later-available');
+    expect(t2!.payload).toBe('earlier-available');
+  });
+
+  it('should indicate availability time on task object', () => {
+    const futureDate = new Date(Date.now() + 10000);
+    const task = tq.addTask('data', { availableAt: futureDate });
+    expect(task.availableAt).toEqual(futureDate);
+  });
+
+  it('should work with named queues', () => {
+    tq.addTask('delayed', { queue: 'myqueue', delay: 60000 });
+    tq.addTask('immediate', { queue: 'myqueue' });
+
+    const task = tq.getNextTask('myqueue');
+    expect(task!.payload).toBe('immediate');
+  });
+
+  it('should handle immediate tasks (no delay) with availableAt <= now', () => {
+    const task = tq.addTask('no-delay');
+    expect(task.availableAt.getTime()).toBeLessThanOrEqual(Date.now());
+  });
+});
