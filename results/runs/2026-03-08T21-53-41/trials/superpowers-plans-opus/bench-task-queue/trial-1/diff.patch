Progress(task.id, 75, 'three quarters');\n\n      expect(updates).toHaveLength(2);\n      expect(updates[0]).toEqual({ progress: 25, message: 'quarter' });\n      expect(updates[1]).toEqual({ progress: 75, message: 'three quarters' });\n    });\n\n    it('should support unsubscribing from progress updates', () => {\n      tq.addTask('data');\n      const task = tq.getNextTask()!;\n\n      const updates: number[] = [];\n      const unsubscribe = tq.onProgress(task.id, (progress) => {\n        updates.push(progress);\n      });\n\n      tq.updateProgress(task.id, 25);\n      unsubscribe();\n      tq.updateProgress(task.id, 75);\n\n      expect(updates).toHaveLength(1);\n      expect(updates[0]).toBe(25);\n    });\n\n    it('should support offProgress to remove listener', () => {\n      tq.addTask('data');\n      const task = tq.getNextTask()!;\n\n      const updates: number[] = [];\n      const listener = (progress: number) => {\n        updates.push(progress);\n      };\n\n      tq.onProgress(task.id, listener);\n      tq.updateProgress(task.id, 25);\n      tq.offProgress(task.id, listener);\n      tq.updateProgress(task.id, 50);\n\n      expect(updates).toEqual([25]);\n    });\n\n    it('should set progress to 100 on completion', () => {\n      tq.addTask('data');\n      const task = tq.getNextTask()!;\n      tq.completeTask(task.id);\n      expect(tq.getProgress(task.id).progress).toBe(100);\n    });\n  });\n\n  describe('Cancellation', () => {\n    it('should cancel a pending task', () => {\n      const task = tq.addTask('data');\n      tq.cancelTask(task.id);\n      expect(tq.getTask(task.id)!.status).toBe('cancelled');\n    });\n\n    it('should cancel a processing task', () => {\n      tq.addTask('data');\n      const task = tq.getNextTask()!;\n      tq.cancelTask(task.id);\n      expect(tq.getTask(task.id)!.status).toBe('cancelled');\n    });\n\n    it('should remove cancelled pending task from queue', () => {\n      const task = tq.addTask('data');\n      tq.cancelTask(task.id);\n      expect(tq.getNextTask()).toBeNull();\n      expect(tq.getQueueLength()).toBe(0);\n    });\n\n    it('should not return cancelled tasks', () => {\n      tq.addTask('cancel-me');\n      tq.addTask('keep-me');\n\n      const first = tq.addTask('data');\n      // Cancel the first task that was added\n      const allTasks = [tq.getTask(first.id)];\n      tq.cancelTask(first.id);\n\n      // Should still be able to get the non-cancelled tasks\n      const next = tq.getNextTask();\n      expect(next).not.toBeNull();\n    });\n\n    it('should never retry cancelled tasks', () => {\n      const task = tq.addTask('data', { maxRetries: 5 });\n      const processing = tq.getNextTask()!;\n      tq.cancelTask(processing.id);\n\n      // Task should stay cancelled, not re-enqueued\n      expect(tq.getTask(task.id)!.status).toBe('cancelled');\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should not cancel completed tasks', () => {\n      tq.addTask('data');\n      const task = tq.getNextTask()!;\n      tq.completeTask(task.id);\n      expect(() => tq.cancelTask(task.id)).toThrow();\n    });\n\n    it('should not cancel failed tasks', () => {\n      const task = tq.addTask('data', { maxRetries: 1, backoffDelay: 1 });\n      tq.getNextTask();\n      tq.failTask(task.id, 'error');\n      expect(() => tq.cancelTask(task.id)).toThrow();\n    });\n\n    it('should free concurrency slot when cancelling processing task', () => {\n      tq.setConcurrency('default', 1);\n      tq.addTask('a');\n      tq.addTask('b');\n\n      const t1 = tq.getNextTask()!;\n      expect(tq.getNextTask()).toBeNull();\n\n      tq.cancelTask(t1.id);\n      const t2 = tq.getNextTask();\n      expect(t2).not.toBeNull();\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
