rs()).toHaveLength(1);\n\n    const requeued = tq.requeueDeadLetter(task.id);\n    expect(requeued.status).toBe('pending');\n    expect(requeued.attempts).toBe(0);\n\n    expect(tq.getDeadLetters()).toHaveLength(0);\n    expect(tq.getQueueLength()).toBe(1);\n\n    // Can be retrieved again\n    const retrieved = tq.getNextTask();\n    expect(retrieved).not.toBeNull();\n    expect(retrieved!.id).toBe(task.id);\n  });\n\n  it('should clear dead letters for a queue', () => {\n    const t1 = tq.addTask('a', { maxRetries: 1, backoffDelay: 1 });\n    const t2 = tq.addTask('b', { maxRetries: 1, backoffDelay: 1 });\n\n    tq.getNextTask();\n    tq.failTask(t1.id, 'fail');\n    tq.getNextTask();\n    tq.failTask(t2.id, 'fail');\n\n    expect(tq.getDeadLetters()).toHaveLength(2);\n    const cleared = tq.clearDeadLetters();\n    expect(cleared).toBe(2);\n    expect(tq.getDeadLetters()).toHaveLength(0);\n  });\n\n  it('should throw when requeuing non-existent dead letter', () => {\n    expect(() => tq.requeueDeadLetter('nonexistent')).toThrow();\n  });\n\n  it('should return empty array for queue with no dead letters', () => {\n    expect(tq.getDeadLetters('nonexistent')).toHaveLength(0);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1510,"cache_read_input_tokens":42463,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1510},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"eac75e22-58ce-4fc6-896c-8bd62c53d094","uuid":"f294372c-c7d5-4f9c-9f6c-6e0521568b1a"}
