reaterThan(Date.now());\n  });\n\n  it('should use exponential backoff', () => {\n    const task = tq.addTask('data', { maxRetries: 3, backoffDelay: 1000 });\n\n    // Attempt 1\n    tq.getNextTask();\n    const beforeFail1 = Date.now();\n    tq.failTask(task.id, 'fail 1');\n    // Backoff: 1000 * 2^0 = 1000ms\n    expect(tq.getTask(task.id)!.availableAt.getTime()).toBeGreaterThanOrEqual(beforeFail1 + 1000);\n\n    // Attempt 2 - hack: set availableAt to past to retrieve\n    tq.getTask(task.id)!.availableAt = new Date(Date.now() - 1);\n    tq.getNextTask();\n    const beforeFail2 = Date.now();\n    tq.failTask(task.id, 'fail 2');\n    // Backoff: 1000 * 2^1 = 2000ms\n    expect(tq.getTask(task.id)!.availableAt.getTime()).toBeGreaterThanOrEqual(beforeFail2 + 2000);\n  });\n\n  it('should default to 3 retries', () => {\n    const task = tq.addTask('data');\n    expect(task.maxRetries).toBe(3);\n  });\n\n  it('should default to 1000ms base backoff delay', () => {\n    const task = tq.addTask('data');\n    expect(task.backoffDelay).toBe(1000);\n  });\n\n  it('should allow configurable retries per task', () => {\n    const task = tq.addTask('data', { maxRetries: 5 });\n    expect(task.maxRetries).toBe(5);\n  });\n\n  it('should track attempt count', () => {\n    const task = tq.addTask('data', { maxRetries: 3, backoffDelay: 1 });\n\n    // First attempt\n    tq.getNextTask();\n    expect(tq.getTask(task.id)!.attempts).toBe(1);\n\n    tq.failTask(task.id, 'fail');\n    tq.getTask(task.id)!.availableAt = new Date(Date.now() - 1);\n\n    // Second attempt\n    tq.getNextTask();\n    expect(tq.getTask(task.id)!.attempts).toBe(2);\n  });\n\n  it('should keep original queue and priority on retry', () => {\n    const task = tq.addTask('data', { queue: 'myqueue', priority: 2, maxRetries: 3, backoffDelay: 1 });\n    tq.getNextTask('myqueue');\n    tq.failTask(task.id, 'fail');\n\n    const updated = tq.getTask(task.id)!;\n    expect(updated.queueName).toBe('myqueue');\n    expect(updated.priority).toBe(2);\n  });\n\n  it('should mark task as failed when retries exhausted', () => {\n    const task = tq.addTask('data', { maxRetries: 1, backoffDelay: 1 });\n\n    // Attempt 1 - only 1 retry allowed, so this is the last chance\n    tq.getNextTask();\n    tq.failTask(task.id, 'final fail');\n\n    expect(tq.getTask(task.id)!.status).toBe('failed');\n  });\n\n  it('should throw when failing a non-processing task', () => {\n    const task = tq.addTask('data');\n    expect(() => tq.failTask(task.id, 'fail')).toThrow();\n  });\n\n  it('should throw when completing a non-existent task', () => {\n    expect(() => tq.completeTask('nonexistent')).toThrow();\n  });\n});\n","structuredPatch":[{"oldStart":21,"oldLines":7,"newStart":21,"newLines":7,"lines":["   });"," ","   it('should fail a processing task and re-enqueue with backoff', () => {","-    const task = tq.addTask('data', { maxRetries: 3, backoffDelay: 100 });","+    tq.addTask('data', { maxRetries: 3, backoffDelay: 100 });","     const retrieved = tq.getNextTask()!;"," ","     tq.failTask(retrieved.id, 'something went wrong');"]}],"userModified":false,"replaceAll":false}}
