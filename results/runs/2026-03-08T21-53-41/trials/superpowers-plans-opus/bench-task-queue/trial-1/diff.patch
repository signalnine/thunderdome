+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../task-queue.js';
+
+describe('Phase 11: Middleware Pipeline', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  it('should register and execute middleware', async () => {
+    const log: string[] = [];
+
+    tq.use('default', async (_task, next) => {
+      log.push('middleware');
+      await next();
+    });
+
+    tq.setHandler('default', async () => {
+      log.push('handler');
+    });
+
+    tq.addTask('data');
+    await tq.processTask();
+
+    expect(log).toEqual(['middleware', 'handler']);
+  });
+
+  it('should execute middleware in registration order', async () => {
+    const log: string[] = [];
+
+    tq.use('default', async (_task, next) => {
+      log.push('first');
+      await next();
+    });
+    tq.use('default', async (_task, next) => {
+      log.push('second');
+      await next();
+    });
+
+    tq.setHandler('default', async () => {
+      log.push('handler');
+    });
+
+    tq.addTask('data');
+    await tq.processTask();
+
+    expect(log).toEqual(['first', 'second', 'handler']);
+  });
+
+  it('should skip handler if middleware does not call next', async () => {
+    const log: string[] = [];
+
+    tq.use('default', async (_task, _next) => {
+      log.push('blocker');
+      // Intentionally not calling next
+    });
+
+    tq.setHandler('default', async () => {
+      log.push('handler');
+    });
+
+    tq.addTask('data');
+    await tq.processTask();
+
+    expect(log).toEqual(['blocker']);
+  });
+
+  it('should allow middleware to modify the task', async () => {
+    tq.use('default', async (task, next) => {
+      (task.payload as Record<string, unknown>).enriched = true;
+      await next();
+    });
+
+    let receivedPayload: unknown;
+    tq.setHandler('default', async (task) => {
+      receivedPayload = task.payload;
+    });
+
+    tq.addTask({ original: true });
+    await tq.processTask();
+
+    expect(receivedPayload).toEqual({ original: true, enriched: true });
+  });
+
+  it('should mark task as failed if middleware throws', async () => {
+    tq.use('default', async (_task, _next) => {
+      throw new Error('middleware error');
+    });
+
+    const task = tq.addTask('data', { maxRetries: 1, backoffDelay: 1 });
+    await tq.processTask();
+
+    const result = tq.getTask(task.id)!;
+    // Task should have been failed
+    expect(result.lastError).toBe('middleware error');
+  });
+
+  it('should mark task as failed if handler throws', async () => {
+    tq.setHandler('default', async () => {
+      throw new Error('handler error');
+    });
+
+    const task = tq.addTask('data', { maxRetries: 1, backoffDelay: 1 });
+    await tq.processTask();
+
+    const result = tq.getTask(task.id)!;
+    expect(result.lastError).toBe('handler error');
+  });
+
+  it('should auto-complete task if not explicitly completed/failed', async () => {
+    tq.setHandler('default', async () => {
+      // Handler runs but doesn't explicitly complete
+    });
+
+    const task = tq.addTask('data');
+    await tq.processTask();
+
+    expect(tq.getTask(task.id)!.status).toBe('completed');
+  });
+
+  it('should return null when no task available to process', async () => {
+    const result = await tq.processTask();
+    expect(result).toBeNull();
+  });
+
+  it('should have independent middleware per queue', async () => {
+    const log: string[] = [];
+
+    tq.use('q1', async (_task, next) => {
+      log.push('q1-mw');
+      await next();
+    });
+    tq.use('q2', async (_task, next) => {
+      log.push('q2-mw');
+      await next();
+    });
+
+    tq.addTask('a', { queue: 'q1' });
+    tq.addTask('b', { queue: 'q2' });
+
+    await tq.processTask('q1');
+    await tq.processTask('q2');
+
+    expect(log).toEqual(['q1-mw', 'q2-mw']);
+  });
+
+  it('should process without middleware or handler', async () => {
+    const task = tq.addTask('data');
+    const result = await tq.processTask();
+    expect(result).not.toBeNull();
+    expect(tq.getTask(task.id)!.status).toBe('completed');
+  });
+});
