+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../task-queue.js';
+
+describe('Phase 8: Concurrency Control', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  it('should default to unlimited concurrency', () => {
+    const { limit } = tq.getConcurrency('default');
+    expect(limit).toBeUndefined();
+  });
+
+  it('should set concurrency limit', () => {
+    tq.setConcurrency('default', 2);
+    expect(tq.getConcurrency('default').limit).toBe(2);
+  });
+
+  it('should return null when concurrency limit reached', () => {
+    tq.setConcurrency('default', 1);
+    tq.addTask('a');
+    tq.addTask('b');
+
+    const t1 = tq.getNextTask();
+    expect(t1).not.toBeNull();
+
+    // Limit reached, should return null
+    const t2 = tq.getNextTask();
+    expect(t2).toBeNull();
+  });
+
+  it('should free slot on task completion', () => {
+    tq.setConcurrency('default', 1);
+    tq.addTask('a');
+    tq.addTask('b');
+
+    const t1 = tq.getNextTask()!;
+    expect(tq.getNextTask()).toBeNull();
+
+    tq.completeTask(t1.id);
+    const t2 = tq.getNextTask();
+    expect(t2).not.toBeNull();
+    expect(t2!.payload).toBe('b');
+  });
+
+  it('should free slot on task failure', () => {
+    tq.setConcurrency('default', 1);
+    tq.addTask('a', { maxRetries: 1, backoffDelay: 1 });
+    tq.addTask('b');
+
+    const t1 = tq.getNextTask()!;
+    expect(tq.getNextTask()).toBeNull();
+
+    tq.failTask(t1.id, 'error');
+
+    // Slot freed but t1 may be re-enqueued with delay
+    // t2 ('b') should be available
+    const next = tq.getNextTask();
+    expect(next).not.toBeNull();
+  });
+
+  it('should track active count', () => {
+    tq.setConcurrency('default', 3);
+    tq.addTask('a');
+    tq.addTask('b');
+    tq.addTask('c');
+
+    expect(tq.getConcurrency('default').active).toBe(0);
+    tq.getNextTask();
+    expect(tq.getConcurrency('default').active).toBe(1);
+    tq.getNextTask();
+    expect(tq.getConcurrency('default').active).toBe(2);
+  });
+
+  it('should still respect priority when concurrency limited', () => {
+    tq.setConcurrency('default', 1);
+    tq.addTask('low', { priority: 10 });
+    tq.addTask('high', { priority: 1 });
+
+    const task = tq.getNextTask();
+    expect(task!.payload).toBe('high');
+  });
+
+  it('should reject invalid concurrency limit', () => {
+    expect(() => tq.setConcurrency('default', 0)).toThrow();
+    expect(() => tq.setConcurrency('default', -1)).toThrow();
+    expect(() => tq.setConcurrency('default', 1.5)).toThrow();
+  });
+
+  it('should handle unlimited concurrency with many tasks', () => {
+    for (let i = 0; i < 10; i++) {
+      tq.addTask(`task-${i}`);
+    }
+    for (let i = 0; i < 10; i++) {
+      expect(tq.getNextTask()).not.toBeNull();
+    }
+    expect(tq.getNextTask()).toBeNull();
+  });
+});
