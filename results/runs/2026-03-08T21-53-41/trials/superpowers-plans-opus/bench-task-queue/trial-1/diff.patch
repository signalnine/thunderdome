@@ -0,0 +1,90 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../task-queue.js';
+
+describe('Phase 12: Graceful Shutdown', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  it('should stop accepting new tasks after shutdown', async () => {
+    await tq.shutdown();
+    expect(() => tq.addTask('data')).toThrow(/shutting down/);
+  });
+
+  it('should complete immediately if no tasks are processing', async () => {
+    const result = await tq.shutdown();
+    expect(result.completed).toBe(0);
+    expect(result.cancelled).toBe(0);
+    expect(result.duration).toBeGreaterThanOrEqual(0);
+  });
+
+  it('should wait for processing tasks to complete', async () => {
+    tq.addTask('data');
+    const task = tq.getNextTask()!;
+
+    // Start shutdown in background
+    const shutdownPromise = tq.shutdown({ timeout: 5000 });
+
+    // Complete the task
+    tq.completeTask(task.id);
+
+    const result = await shutdownPromise;
+    expect(result.completed).toBe(1);
+    expect(result.cancelled).toBe(0);
+  });
+
+  it('should force-cancel tasks after timeout', async () => {
+    tq.addTask('long-task');
+    tq.getNextTask(); // Start processing
+
+    const result = await tq.shutdown({ timeout: 50 });
+    expect(result.cancelled).toBe(1);
+  });
+
+  it('should run shutdown callbacks', async () => {
+    let callbackRan = false;
+    tq.onShutdown(() => {
+      callbackRan = true;
+    });
+
+    await tq.shutdown();
+    expect(callbackRan).toBe(true);
+  });
+
+  it('should produce a summary with duration', async () => {
+    const result = await tq.shutdown();
+    expect(typeof result.completed).toBe('number');
+    expect(typeof result.cancelled).toBe('number');
+    expect(typeof result.duration).toBe('number');
+  });
+
+  it('should return same result for multiple shutdown calls', async () => {
+    const r1 = tq.shutdown();
+    const r2 = tq.shutdown();
+    expect(await r1).toEqual(await r2);
+  });
+
+  it('should reject new schedules after shutdown', async () => {
+    await tq.shutdown();
+    expect(() => tq.addSchedule('*/5 * * * *', 'default', {})).toThrow(/shutting down/);
+  });
+
+  it('should report shuttingDown status', async () => {
+    expect(tq.shuttingDown).toBe(false);
+    const promise = tq.shutdown();
+    expect(tq.shuttingDown).toBe(true);
+    await promise;
+  });
+
+  it('should handle async shutdown callbacks', async () => {
+    const log: string[] = [];
+    tq.onShutdown(async () => {
+      log.push('async-callback');
+    });
+
+    await tq.shutdown();
+    expect(log).toContain('async-callback');
+  });
+});
