+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../task-queue.js';
+
+describe('Phase 10: Recurring Tasks', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  it('should create a schedule', () => {
+    const schedule = tq.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });
+    expect(schedule).toBeDefined();
+    expect(schedule.id).toBeDefined();
+    expect(schedule.cronExpression).toBe('*/5 * * * *');
+    expect(schedule.queueName).toBe('default');
+  });
+
+  it('should list active schedules', () => {
+    tq.addSchedule('*/5 * * * *', 'default', { type: 'a' });
+    tq.addSchedule('0 * * * *', 'default', { type: 'b' });
+    expect(tq.listSchedules()).toHaveLength(2);
+  });
+
+  it('should remove a schedule', () => {
+    const schedule = tq.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });
+    expect(tq.removeSchedule(schedule.id)).toBe(true);
+    expect(tq.listSchedules()).toHaveLength(0);
+  });
+
+  it('should return false when removing non-existent schedule', () => {
+    expect(tq.removeSchedule('nonexistent')).toBe(false);
+  });
+
+  it('should enqueue tasks on tick when schedule is due', () => {
+    tq.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });
+
+    // Tick at a time that matches */5 (minute divisible by 5)
+    const matchingTime = new Date('2024-01-01T00:00:00');
+    const tasks = tq.tick(matchingTime);
+
+    expect(tasks).toHaveLength(1);
+    expect(tasks[0].payload).toEqual({ type: 'cleanup' });
+    expect(tasks[0].status).toBe('pending');
+  });
+
+  it('should not enqueue when schedule is not due', () => {
+    tq.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });
+
+    // Tick at a time that doesn't match */5
+    const nonMatchingTime = new Date('2024-01-01T00:01:00');
+    const tasks = tq.tick(nonMatchingTime);
+    expect(tasks).toHaveLength(0);
+  });
+
+  it('should support hourly cron', () => {
+    tq.addSchedule('0 * * * *', 'default', { type: 'hourly' });
+
+    const onHour = new Date('2024-01-01T03:00:00');
+    const tasks = tq.tick(onHour);
+    expect(tasks).toHaveLength(1);
+
+    const offHour = new Date('2024-01-01T03:30:00');
+    const tasks2 = tq.tick(offHour);
+    expect(tasks2).toHaveLength(0);
+  });
+
+  it('should support daily midnight cron', () => {
+    tq.addSchedule('0 0 * * *', 'default', { type: 'daily' });
+
+    const midnight = new Date('2024-01-01T00:00:00');
+    const tasks = tq.tick(midnight);
+    expect(tasks).toHaveLength(1);
+
+    const noon = new Date('2024-01-01T12:00:00');
+    const tasks2 = tq.tick(noon);
+    expect(tasks2).toHaveLength(0);
+  });
+
+  it('should not enqueue duplicate for same minute', () => {
+    tq.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });
+
+    const time = new Date('2024-01-01T00:00:00');
+    tq.tick(time);
+    const tasks2 = tq.tick(time);
+    expect(tasks2).toHaveLength(0);
+  });
+
+  it('should enqueue to the specified queue', () => {
+    tq.addSchedule('*/1 * * * *', 'emails', { type: 'send' });
+
+    const time = new Date('2024-01-01T00:00:00');
+    tq.tick(time);
+
+    const task = tq.getNextTask('emails');
+    expect(task).not.toBeNull();
+    expect(task!.payload).toEqual({ type: 'send' });
+  });
+
+  it('should apply task options from schedule', () => {
+    tq.addSchedule('*/1 * * * *', 'default', { type: 'urgent' }, { priority: 1 });
+
+    const time = new Date('2024-01-01T00:00:00');
+    const tasks = tq.tick(time);
+    expect(tasks[0].priority).toBe(1);
+  });
+
+  it('should stop creating tasks after schedule removal', () => {
+    const schedule = tq.addSchedule('*/1 * * * *', 'default', { type: 'data' });
+
+    const time1 = new Date('2024-01-01T00:00:00');
+    tq.tick(time1);
+
+    tq.removeSchedule(schedule.id);
+
+    const time2 = new Date('2024-01-01T00:01:00');
+    const tasks = tq.tick(time2);
+    expect(tasks).toHaveLength(0);
+  });
+
+  it('should reject invalid cron expressions', () => {
+    expect(() => tq.addSchedule('invalid', 'default', {})).toThrow();
+    expect(() => tq.addSchedule('* * *', 'default', {})).toThrow();
+  });
+
+  it('should subject recurring tasks to all queue rules', () => {
+    tq.setConcurrency('default', 1);
+    tq.addSchedule('*/1 * * * *', 'default', { type: 'data' });
+
+    const time = new Date('2024-01-01T00:00:00');
+    tq.tick(time);
+
+    const t1 = tq.getNextTask();
+    expect(t1).not.toBeNull();
+
+    // tick again at a different minute
+    const time2 = new Date('2024-01-01T00:01:00');
+    tq.tick(time2);
+
+    // Concurrency limit reached
+    const t2 = tq.getNextTask();
+    expect(t2).toBeNull();
+  });
+});
