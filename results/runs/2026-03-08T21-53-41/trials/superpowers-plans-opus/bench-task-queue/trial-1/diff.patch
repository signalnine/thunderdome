+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01UbfBEbY6bzye3gT9hneh6D","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_018KvxRPngutVigdgLDbCzPh","name":"Write","input":{"file_path":"/workspace/src/task-queue.ts","content":"import {\n  type Task,\n  type TaskOptions,\n  type AddTaskOptions,\n  type MiddlewareFn,\n  type HandlerFn,\n  type ProgressListener,\n  type ShutdownOptions,\n  type ShutdownResult,\n  type ScheduleEntry,\n  DEFAULT_QUEUE,\n  DEFAULT_PRIORITY,\n  DEFAULT_MAX_RETRIES,\n  DEFAULT_BACKOFF_DELAY,\n} from './types.js';\nimport { generateId } from './utils.js';\nimport { Scheduler } from './scheduler.js';\n\nexport class TaskQueue {\n  /** All tasks by ID */\n  private tasks: Map<string, Task> = new Map();\n\n  /** Pending/blocked tasks per queue (tasks waiting to be picked up) */\n  private queues: Map<string, Task[]> = new Map();\n\n  /** Dead letter queues per queue name */\n  private deadLetters: Map<string, Task[]> = new Map();\n\n  /** Concurrency limits per queue (undefined = unlimited) */\n  private concurrencyLimits: Map<string, number> = new Map();\n\n  /** Currently processing count per queue */\n  private activeCounts: Map<string, number> = new Map();\n\n  /** Progress listeners per task ID */\n  private progressListeners: Map<string, Set<ProgressListener>> = new Map();\n\n  /** Middleware stacks per queue */\n  private middlewareStacks: Map<string, MiddlewareFn[]> = new Map();\n\n  /** Handlers per queue */\n  private handlers: Map<string, HandlerFn> = new Map();\n\n  /** Scheduler for recurring tasks */\n  private scheduler: Scheduler = new Scheduler();\n\n  /** Shutdown state */\n  private isShuttingDown = false;\n  private shutdownPromise: Promise<ShutdownResult> | null = null;\n  private shutdownCallbacks: Array<() => void | Promise<void>> = [];\n\n  // --- Phase 1 & 2: Basic FIFO + Named Queues ---\n\n  addTask<T = unknown>(payload: T, options?: AddTaskOptions): Task<T> {\n    if (this.isShuttingDown) {\n      throw new Error('Cannot add tasks: queue system is shutting down');\n    }\n\n    const queueName = options?.queue ?? DEFAULT_QUEUE;\n    const priority = options?.priority ?? DEFAULT_PRIORITY;\n\n    // Phase 3: Validate priority\n    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    }\n\n    // Phase 7: Validate dependencies\n    const dependencies = options?.dependencies ?? [];\n    for (const depId of dependencies) {\n      const depTask = this.tasks.get(depId);\n      if (!depTask) {\n        throw new Error(`Dependency task not found: ${depId}`);\n      }\n    }\n\n    // Phase 7: Check for circular dependencies\n    if (dependencies.length > 0) {\n      this.checkCircularDependencies(dependencies);\n    }\n\n    // Phase 4: Calculate availability time\n    let availableAt = new Date();\n    if (options?.availableAt) {\n      availableAt = new Date(options.availableAt);\n    } else if (options?.delay && options.delay > 0) {\n      availableAt = new Date(Date.now() + options.delay);\n    }\n\n    const now = new Date();\n\n    // Check which dependencies are already resolved\n    const resolvedDeps = new Set<string>();\n    for (const depId of dependencies) {\n      const depTask = this.tasks.get(depId);\n      if (depTask && depTask.status === 'completed') {\n        resolvedDeps.add(depId);\n      }\n    }\n\n    const hasUnresolvedDeps = dependencies.length > 0 &&\n      dependencies.some(depId => !resolvedDeps.has(depId));\n\n    const task: Task<T> = {\n      id: generateId(),\n      status: hasUnresolvedDeps ? 'blocked' : 'pending',\n      payload,\n      priority,\n      createdAt: now,\n      updatedAt: now,\n      availableAt,\n      queueName,\n      attempts: 0,\n      maxRetries: options?.maxRetries ?? DEFAULT_MAX_RETRIES,\n      backoffDelay: options?.backoffDelay ?? DEFAULT_BACKOFF_DELAY,\n      dependencies: [...dependencies],\n      resolvedDependencies: resolvedDeps,\n      progress: 0,\n    };\n\n    this.tasks.set(task.id, task as Task);\n\n    // Add to queue\n    if (!this.queues.has(queueName)) {\n      this.queues.set(queueName, []);\n    }\n    this.queues.get(queueName)!.push(task as Task);\n\n    return task;\n  }\n\n  getNextTask(queueName: string = DEFAULT_QUEUE): Task | null {\n    const queue = this.queues.get(queueName);\n    if (!queue || queue.length === 0) return null;\n\n    // Phase 8: Check concurrency limit\n    const limit = this.concurrencyLimits.get(queueName);\n    if (limit !== undefined) {\n      const active = this.activeCounts.get(queueName) ?? 0;\n      if (active >= limit) return null;\n    }\n\n    const now = new Date();\n\n    // Find the best available task:\n    // 1. Must be 'pending' status\n    // 2. Must have availableAt <= now (Phase 4)\n    // 3. Sort by: available first, then priority (asc), then creation time (asc)\n    let bestIndex = -1;\n    let bestTask: Task | null = null;\n\n    for (let i = 0; i < queue.length; i++) {\n      const task = queue[i];\n\n      // Skip non-pending tasks (blocked, etc.)\n      if (task.status !== 'pending') continue;\n\n      // Skip delayed tasks that aren't available yet\n      if (task.availableAt > now) continue;\n\n      if (bestTask === null || this.compareTasks(task, bestTask) < 0) {\n        bestTask = task;\n        bestIndex = i;\n      }\n    }\n\n    if (bestIndex === -1 || !bestTask) return null;\n\n    // Remove from queue and mark as processing\n    queue.splice(bestIndex, 1);\n    bestTask.status = 'processing';\n    bestTask.updatedAt = new Date();\n    bestTask.attempts += 1;\n\n    // Phase 8: Track active count\n    const active = this.activeCounts.get(queueName) ?? 0;\n    this.activeCounts.set(queueName, active + 1);\n\n    return bestTask;\n  }\n\n  /** Compare tasks for ordering: lower priority number first, then earlier creation */\n  private compareTasks(a: Task, b: Task): number {\n    if (a.priority !== b.priority) return a.priority - b.priority;\n    return a.createdAt.getTime() - b.createdAt.getTime();\n  }\n\n  getTask(taskId: string): Task | undefined {\n    return this.tasks.get(taskId);\n  }\n\n  getQueueLength(queueName: string = DEFAULT_QUEUE): number {\n    const queue = this.queues.get(queueName);\n    if (!queue) return 0;\n    return queue.filter(t => t.status === 'pending' || t.status === 'blocked').length;\n  }\n\n  getQueueNames(): string[] {\n    return Array.from(this.queues.keys());\n  }\n\n  // --- Phase 5: Retry with Backoff ---\n\n  completeTask(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot complete task in status: ${task.status}`);\n    }\n\n    task.status = 'completed';\n    task.updatedAt = new Date();\n    task.progress = 100;\n\n    // Phase 8: Free concurrency slot\n    this.decrementActive(task.queueName);\n\n    // Phase 7: Resolve dependents\n    this.resolveDependents(taskId);\n  }\n\n  failTask(taskId: string, error?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot fail task in status: ${task.status}`);\n    }\n\n    task.lastError = error;\n    task.updatedAt = new Date();\n\n    // Phase 8: Free concurrency slot\n    this.decrementActive(task.queueName);\n\n    // Check retries\n    if (task.attempts < task.maxRetries) {\n      // Re-enqueue with backoff delay\n      const delay = task.backoffDelay * Math.pow(2, task.attempts - 1);\n      task.status = 'pending';\n      task.availableAt = new Date(Date.now() + delay);\n      task.progress = 0;\n\n      // Add back to queue\n      const queue = this.queues.get(task.queueName);\n      if (queue) {\n        queue.push(task);\n      }\n    } else {\n      // Phase 6: Move to dead letter queue\n      task.status = 'failed';\n      this.addToDeadLetterQueue(task);\n    }\n  }\n\n  private decrementActive(queueName: string): void {\n    const active = this.activeCounts.get(queueName) ?? 0;\n    if (active > 0) {\n      this.activeCounts.set(queueName, active - 1);\n    }\n  }\n\n  // --- Phase 6: Dead Letter Queue ---\n\n  private addToDeadLetterQueue(task: Task): void {\n    if (!this.deadLetters.has(task.queueName)) {\n      this.deadLetters.set(task.queueName, []);\n    }\n    this.deadLetters.get(task.queueName)!.push(task);\n  }\n\n  getDeadLetters(queueName: string = DEFAULT_QUEUE): Task[] {\n    return [...(this.deadLetters.get(queueName) ?? [])];\n  }\n\n  requeueDeadLetter(taskId: string): Task {\n    // Find the task in dead letters\n    for (const [queueName, dlq] of this.deadLetters) {\n      const index = dlq.findIndex(t => t.id === taskId);\n      if (index !== -1) {\n        const task = dlq.splice(index, 1)[0];\n\n        // Reset for fresh retry round\n        task.status = 'pending';\n        task.attempts = 0;\n        task.availableAt = new Date();\n        task.updatedAt = new Date();\n        task.progress = 0;\n        delete task.lastError;\n\n        // Add back to the original queue\n        if (!this.queues.has(queueName)) {\n          this.queues.set(queueName, []);\n        }\n        this.queues.get(queueName)!.push(task);\n\n        return task;\n      }\n    }\n    throw new Error(`Dead letter task not found: ${taskId}`);\n  }\n\n  clearDeadLetters(queueName: string = DEFAULT_QUEUE): number {\n    const dlq = this.deadLetters.get(queueName);\n    if (!dlq) return 0;\n    const count = dlq.length;\n    this.deadLetters.set(queueName, []);\n    return count;\n  }\n\n  // --- Phase 7: Task Dependencies ---\n\n  private checkCircularDependencies(newDependencies: string[]): void {\n    // Build a dependency graph and check for cycles using DFS\n    // The \"new task\" depends on newDependencies\n    // We need to check if any of those dependencies (transitively) depend\n    // on tasks that would create a cycle. Since the new task doesn't exist yet,\n    // we just need to ensure the existing dependency graph has no cycles\n    // and the new deps don't create one.\n    // Actually for a new task, it can't create a cycle since nothing depends on it yet.\n    // The cycle check matters when a task depends on another task that depends on it.\n    // Since the new task doesn't have an ID yet, no existing task can depend on it,\n    // so there can be no cycle. This check is mainly for validation.\n    // But let's verify the dependency chain doesn't have existing cycles.\n    const visited = new Set<string>();\n    const inStack = new Set<string>();\n\n    const dfs = (taskId: string): boolean => {\n      if (inStack.has(taskId)) return true; // cycle found\n      if (visited.has(taskId)) return false;\n\n      visited.add(taskId);\n      inStack.add(taskId);\n\n      const task = this.tasks.get(taskId);\n      if (task) {\n        for (const depId of task.dependencies) {\n          if (dfs(depId)) return true;\n        }\n      }\n\n      inStack.delete(taskId);\n      return false;\n    };\n\n    for (const depId of newDependencies) {\n      if (dfs(depId)) {\n        throw new Error('Circular dependency detected');\n      }\n    }\n  }\n\n  private resolveDependents(completedTaskId: string): void {\n    for (const task of this.tasks.values()) {\n      if (task.status !== 'blocked') continue;\n      if (!task.dependencies.includes(completedTaskId)) continue;\n\n      task.resolvedDependencies.add(completedTaskId);\n\n      // Check if all dependencies are resolved\n      const allResolved = task.dependencies.every(depId =>\n        task.resolvedDependencies.has(depId)\n      );\n\n      if (allResolved) {\n        task.status = 'pending';\n        task.updatedAt = new Date();\n      }\n    }\n  }\n\n  getDependencyStatus(taskId: string): { dependencies: string[]; resolved: string[]; unresolved: string[] } {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    const resolved = [...task.resolvedDependencies];\n    const unresolved = task.dependencies.filter(d => !task.resolvedDependencies.has(d));\n\n    return {\n      dependencies: [...task.dependencies],\n      resolved,\n      unresolved,\n    };\n  }\n\n  // --- Phase 8: Concurrency Control ---\n\n  setConcurrency(queueName: string, limit: number): void {\n    if (limit < 1 || !Number.isInteger(limit)) {\n      throw new Error(`Invalid concurrency limit: ${limit}. Must be a positive integer.`);\n    }\n    this.concurrencyLimits.set(queueName, limit);\n  }\n\n  getConcurrency(queueName: string): { limit: number | undefined; active: number } {\n    return {\n      limit: this.concurrencyLimits.get(queueName),\n      active: this.activeCounts.get(queueName) ?? 0,\n    };\n  }\n\n  // --- Phase 9: Progress and Cancellation ---\n\n  updateProgress(taskId: string, percent: number, message?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot update progress for task in status: ${task.status}`);\n    }\n    if (percent < 0 || percent > 100) {\n      throw new Error(`Invalid progress: ${percent}. Must be between 0 and 100.`);\n    }\n\n    task.progress = percent;\n    task.progressMessage = message;\n    task.updatedAt = new Date();\n\n    // Notify listeners\n    const listeners = this.progressListeners.get(taskId);\n    if (listeners) {\n      for (const listener of listeners) {\n        listener(percent, message);\n      }\n    }\n  }\n\n  getProgress(taskId: string): { progress: number; message?: string } {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    return { progress: task.progress, message: task.progressMessage };\n  }\n\n  onProgress(taskId: string, listener: ProgressListener): () => void {\n    if (!this.progressListeners.has(taskId)) {\n      this.progressListeners.set(taskId, new Set());\n    }\n    this.progressListeners.get(taskId)!.add(listener);\n\n    // Return unsubscribe function\n    return () => {\n      this.offProgress(taskId, listener);\n    };\n  }\n\n  offProgress(taskId: string, listener: ProgressListener): void {\n    const listeners = this.progressListeners.get(taskId);\n    if (listeners) {\n      listeners.delete(listener);\n    }\n  }\n\n  cancelTask(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    if (task.status !== 'pending' && task.status !== 'processing' && task.status !== 'blocked') {\n      throw new Error(`Cannot cancel task in status: ${task.status}`);\n    }\n\n    const wasProcessing = task.status === 'processing';\n\n    task.status = 'cancelled';\n    task.updatedAt = new Date();\n\n    if (wasProcessing) {\n      // Free concurrency slot\n      this.decrementActive(task.queueName);\n    } else {\n      // Remove from queue\n      const queue = this.queues.get(task.queueName);\n      if (queue) {\n        const index = queue.indexOf(task);\n        if (index !== -1) {\n          queue.splice(index, 1);\n        }\n      }\n    }\n  }\n\n  // --- Phase 10: Recurring Tasks ---\n\n  addSchedule(\n    cronExpression: string,\n    queueName: string,\n    payload: unknown,\n    taskOptions?: TaskOptions\n  ): ScheduleEntry {\n    if (this.isShuttingDown) {\n      throw new Error('Cannot add schedules: queue system is shutting down');\n    }\n    return this.scheduler.addSchedule(cronExpression, queueName, payload, taskOptions);\n  }\n\n  removeSchedule(scheduleId: string): boolean {\n    return this.scheduler.removeSchedule(scheduleId);\n  }\n\n  listSchedules(): ScheduleEntry[] {\n    return this.scheduler.listSchedules();\n  }\n\n  tick