+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../task-queue.js';
+
+describe('Phase 6: Dead Letter Queue', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  it('should move task to DLQ when retries exhausted', () => {
+    const task = tq.addTask('data', { maxRetries: 1, backoffDelay: 1 });
+    tq.getNextTask();
+    tq.failTask(task.id, 'permanent error');
+
+    const dlq = tq.getDeadLetters();
+    expect(dlq).toHaveLength(1);
+    expect(dlq[0].id).toBe(task.id);
+  });
+
+  it('should retain error information on dead-lettered tasks', () => {
+    const task = tq.addTask('data', { maxRetries: 1, backoffDelay: 1 });
+    tq.getNextTask();
+    tq.failTask(task.id, 'permanent error');
+
+    const dlq = tq.getDeadLetters();
+    expect(dlq[0].lastError).toBe('permanent error');
+    expect(dlq[0].attempts).toBe(1);
+  });
+
+  it('should support per-queue dead letter queues', () => {
+    const t1 = tq.addTask('a', { queue: 'q1', maxRetries: 1, backoffDelay: 1 });
+    const t2 = tq.addTask('b', { queue: 'q2', maxRetries: 1, backoffDelay: 1 });
+
+    tq.getNextTask('q1');
+    tq.failTask(t1.id, 'fail');
+    tq.getNextTask('q2');
+    tq.failTask(t2.id, 'fail');
+
+    expect(tq.getDeadLetters('q1')).toHaveLength(1);
+    expect(tq.getDeadLetters('q2')).toHaveLength(1);
+    expect(tq.getDeadLetters('q1')[0].id).toBe(t1.id);
+    expect(tq.getDeadLetters('q2')[0].id).toBe(t2.id);
+  });
+
+  it('should requeue a dead-lettered task', () => {
+    const task = tq.addTask('data', { maxRetries: 1, backoffDelay: 1 });
+    tq.getNextTask();
+    tq.failTask(task.id, 'fail');
+
+    expect(tq.getDeadLetters()).toHaveLength(1);
+
+    const requeued = tq.requeueDeadLetter(task.id);
+    expect(requeued.status).toBe('pending');
+    expect(requeued.attempts).toBe(0);
+
+    expect(tq.getDeadLetters()).toHaveLength(0);
+    expect(tq.getQueueLength()).toBe(1);
+
+    // Can be retrieved again
+    const retrieved = tq.getNextTask();
+    expect(retrieved).not.toBeNull();
+    expect(retrieved!.id).toBe(task.id);
+  });
+
+  it('should clear dead letters for a queue', () => {
+    const t1 = tq.addTask('a', { maxRetries: 1, backoffDelay: 1 });
+    const t2 = tq.addTask('b', { maxRetries: 1, backoffDelay: 1 });
+
+    tq.getNextTask();
+    tq.failTask(t1.id, 'fail');
+    tq.getNextTask();
+    tq.failTask(t2.id, 'fail');
+
+    expect(tq.getDeadLetters()).toHaveLength(2);
+    const cleared = tq.clearDeadLetters();
+    expect(cleared).toBe(2);
+    expect(tq.getDeadLetters()).toHaveLength(0);
+  });
+
+  it('should throw when requeuing non-existent dead letter', () => {
+    expect(() => tq.requeueDeadLetter('nonexistent')).toThrow();
+  });
+
+  it('should return empty array for queue with no dead letters', () => {
+    expect(tq.getDeadLetters('nonexistent')).toHaveLength(0);
+  });
+});
