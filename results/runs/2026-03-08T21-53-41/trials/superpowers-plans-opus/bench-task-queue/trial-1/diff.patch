@@ -0,0 +1,117 @@
+import type { ScheduleEntry, TaskOptions } from './types.js';
+import { generateId } from './utils.js';
+
+export interface CronParts {
+  minute: string;
+  hour: string;
+  dayOfMonth: string;
+  month: string;
+  dayOfWeek: string;
+}
+
+export function parseCron(expression: string): CronParts {
+  const parts = expression.trim().split(/\s+/);
+  if (parts.length !== 5) {
+    throw new Error(`Invalid cron expression: "${expression}" - expected 5 fields`);
+  }
+  return {
+    minute: parts[0],
+    hour: parts[1],
+    dayOfMonth: parts[2],
+    month: parts[3],
+    dayOfWeek: parts[4],
+  };
+}
+
+function matchesField(field: string, value: number): boolean {
+  if (field === '*') return true;
+
+  // */N pattern
+  const stepMatch = field.match(/^\*\/(\d+)$/);
+  if (stepMatch) {
+    const step = parseInt(stepMatch[1], 10);
+    return value % step === 0;
+  }
+
+  // exact number
+  const exact = parseInt(field, 10);
+  if (!isNaN(exact)) {
+    return value === exact;
+  }
+
+  return false;
+}
+
+export function shouldRunAt(cron: CronParts, date: Date): boolean {
+  return (
+    matchesField(cron.minute, date.getMinutes()) &&
+    matchesField(cron.hour, date.getHours()) &&
+    matchesField(cron.dayOfMonth, date.getDate()) &&
+    matchesField(cron.month, date.getMonth() + 1) &&
+    matchesField(cron.dayOfWeek, date.getDay())
+  );
+}
+
+export class Scheduler {
+  private schedules: Map<string, ScheduleEntry> = new Map();
+
+  addSchedule(
+    cronExpression: string,
+    queueName: string,
+    payload: unknown,
+    taskOptions?: TaskOptions
+  ): ScheduleEntry {
+    // Validate the cron expression
+    parseCron(cronExpression);
+
+    const entry: ScheduleEntry = {
+      id: generateId(),
+      cronExpression,
+      queueName,
+      payload,
+      taskOptions,
+    };
+    this.schedules.set(entry.id, entry);
+    return entry;
+  }
+
+  removeSchedule(id: string): boolean {
+    return this.schedules.delete(id);
+  }
+
+  listSchedules(): ScheduleEntry[] {
+    return Array.from(this.schedules.values());
+  }
+
+  getSchedule(id: string): ScheduleEntry | undefined {
+    return this.schedules.get(id);
+  }
+
+  /**
+   * Check all schedules against the given time and return entries that should fire.
+   * Normalizes time to the start of the minute for comparison.
+   */
+  tick(now: Date = new Date()): Array<{ schedule: ScheduleEntry; shouldEnqueue: boolean }> {
+    const results: Array<{ schedule: ScheduleEntry; shouldEnqueue: boolean }> = [];
+    const normalizedNow = new Date(now);
+    normalizedNow.setSeconds(0, 0);
+
+    for (const schedule of this.schedules.values()) {
+      const cron = parseCron(schedule.cronExpression);
+      if (shouldRunAt(cron, normalizedNow)) {
+        // Check if we already ran at this exact minute
+        if (
+          schedule.lastRun &&
+          schedule.lastRun.getTime() === normalizedNow.getTime()
+        ) {
+          results.push({ schedule, shouldEnqueue: false });
+        } else {
+          schedule.lastRun = normalizedNow;
+          results.push({ schedule, shouldEnqueue: true });
+        }
+      }
+    }
+
+    return results;
+  }
+}
