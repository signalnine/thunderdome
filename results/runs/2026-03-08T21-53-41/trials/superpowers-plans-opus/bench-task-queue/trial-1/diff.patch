@@ -0,0 +1,143 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../task-queue.js';
+
+describe('Phase 1: Basic FIFO Queue', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  it('should add a task and return a task object', () => {
+    const task = tq.addTask({ message: 'hello' });
+    expect(task).toBeDefined();
+    expect(task.id).toBeDefined();
+    expect(task.status).toBe('pending');
+    expect(task.payload).toEqual({ message: 'hello' });
+    expect(task.createdAt).toBeInstanceOf(Date);
+  });
+
+  it('should assign unique IDs to tasks', () => {
+    const t1 = tq.addTask('a');
+    const t2 = tq.addTask('b');
+    expect(t1.id).not.toBe(t2.id);
+  });
+
+  it('should retrieve tasks in FIFO order', () => {
+    tq.addTask('first');
+    tq.addTask('second');
+    tq.addTask('third');
+
+    const t1 = tq.getNextTask();
+    const t2 = tq.getNextTask();
+    const t3 = tq.getNextTask();
+
+    expect(t1!.payload).toBe('first');
+    expect(t2!.payload).toBe('second');
+    expect(t3!.payload).toBe('third');
+  });
+
+  it('should transition task to processing state on retrieval', () => {
+    tq.addTask('data');
+    const task = tq.getNextTask();
+    expect(task!.status).toBe('processing');
+  });
+
+  it('should return null when no tasks are available', () => {
+    expect(tq.getNextTask()).toBeNull();
+  });
+
+  it('should track queue length', () => {
+    expect(tq.getQueueLength()).toBe(0);
+    tq.addTask('a');
+    tq.addTask('b');
+    expect(tq.getQueueLength()).toBe(2);
+    tq.getNextTask();
+    expect(tq.getQueueLength()).toBe(1);
+  });
+
+  it('should not return already-processing tasks', () => {
+    tq.addTask('a');
+    tq.getNextTask();
+    expect(tq.getNextTask()).toBeNull();
+  });
+
+  it('should get task by id', () => {
+    const added = tq.addTask('data');
+    const retrieved = tq.getTask(added.id);
+    expect(retrieved).toBeDefined();
+    expect(retrieved!.id).toBe(added.id);
+  });
+
+  it('should track attempts on retrieval', () => {
+    tq.addTask('data');
+    const task = tq.getNextTask();
+    expect(task!.attempts).toBe(1);
+  });
+});
+
+describe('Phase 2: Named Queues', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  it('should use default queue when no name specified', () => {
+    tq.addTask('data');
+    const task = tq.getNextTask();
+    expect(task!.queueName).toBe('default');
+  });
+
+  it('should support named queues', () => {
+    tq.addTask('email', { queue: 'emails' });
+    tq.addTask('sms', { queue: 'sms' });
+
+    const emailTask = tq.getNextTask('emails');
+    const smsTask = tq.getNextTask('sms');
+
+    expect(emailTask!.payload).toBe('email');
+    expect(smsTask!.payload).toBe('sms');
+  });
+
+  it('should keep named queues independent', () => {
+    tq.addTask('a', { queue: 'q1' });
+    tq.addTask('b', { queue: 'q2' });
+
+    expect(tq.getQueueLength('q1')).toBe(1);
+    expect(tq.getQueueLength('q2')).toBe(1);
+
+    tq.getNextTask('q1');
+    expect(tq.getQueueLength('q1')).toBe(0);
+    expect(tq.getQueueLength('q2')).toBe(1);
+  });
+
+  it('should return null for empty or non-existent queue', () => {
+    expect(tq.getNextTask('nonexistent')).toBeNull();
+  });
+
+  it('should list all queue names', () => {
+    tq.addTask('a', { queue: 'emails' });
+    tq.addTask('b', { queue: 'sms' });
+    tq.addTask('c'); // default
+
+    const names = tq.getQueueNames();
+    expect(names).toContain('emails');
+    expect(names).toContain('sms');
+    expect(names).toContain('default');
+  });
+
+  it('should create queue implicitly on first task', () => {
+    expect(tq.getQueueNames()).toHaveLength(0);
+    tq.addTask('data', { queue: 'new-queue' });
+    expect(tq.getQueueNames()).toContain('new-queue');
+  });
+
+  it('should remain backward compatible (no queue name = default)', () => {
+    tq.addTask('data');
+    expect(tq.getQueueLength()).toBe(1);
+    expect(tq.getQueueLength('default')).toBe(1);
+    const task = tq.getNextTask();
+    expect(task!.payload).toBe('data');
+  });
+});
diff --git a/src/tests/phase-03.test.ts b/src/tests/phase-03.test.ts
