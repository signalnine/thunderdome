+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../task-queue.js';
+
+describe('Phase 7: Task Dependencies', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  it('should accept dependencies as task IDs', () => {
+    const t1 = tq.addTask('first');
+    const t2 = tq.addTask('second', { dependencies: [t1.id] });
+    expect(t2.dependencies).toContain(t1.id);
+  });
+
+  it('should block tasks with unresolved dependencies', () => {
+    const t1 = tq.addTask('first');
+    const t2 = tq.addTask('second', { dependencies: [t1.id] });
+    expect(t2.status).toBe('blocked');
+  });
+
+  it('should not return blocked tasks', () => {
+    const t1 = tq.addTask('first');
+    tq.addTask('second', { dependencies: [t1.id] });
+
+    const next = tq.getNextTask();
+    expect(next!.payload).toBe('first');
+
+    // Second task is blocked so shouldn't be returned
+    expect(tq.getNextTask()).toBeNull();
+  });
+
+  it('should unblock task when dependency completes', () => {
+    const t1 = tq.addTask('first');
+    const t2 = tq.addTask('second', { dependencies: [t1.id] });
+
+    const processing = tq.getNextTask()!;
+    tq.completeTask(processing.id);
+
+    expect(tq.getTask(t2.id)!.status).toBe('pending');
+
+    const next = tq.getNextTask();
+    expect(next).not.toBeNull();
+    expect(next!.id).toBe(t2.id);
+  });
+
+  it('should support multiple dependencies', () => {
+    const t1 = tq.addTask('a');
+    const t2 = tq.addTask('b');
+    const t3 = tq.addTask('c', { dependencies: [t1.id, t2.id] });
+
+    expect(t3.status).toBe('blocked');
+
+    // Complete first dependency
+    const p1 = tq.getNextTask()!;
+    tq.completeTask(p1.id);
+    expect(tq.getTask(t3.id)!.status).toBe('blocked');
+
+    // Complete second dependency
+    const p2 = tq.getNextTask()!;
+    tq.completeTask(p2.id);
+    expect(tq.getTask(t3.id)!.status).toBe('pending');
+  });
+
+  it('should reject non-existent dependency', () => {
+    expect(() => tq.addTask('data', { dependencies: ['nonexistent'] })).toThrow();
+  });
+
+  it('should keep dependents blocked when dependency fails', () => {
+    const t1 = tq.addTask('first', { maxRetries: 1, backoffDelay: 1 });
+    const t2 = tq.addTask('second', { dependencies: [t1.id] });
+
+    tq.getNextTask();
+    tq.failTask(t1.id, 'error');
+
+    // t1 is now failed (exhausted retries), t2 should remain blocked
+    expect(tq.getTask(t2.id)!.status).toBe('blocked');
+  });
+
+  it('should inspect dependency status', () => {
+    const t1 = tq.addTask('a');
+    const t2 = tq.addTask('b');
+    const t3 = tq.addTask('c', { dependencies: [t1.id, t2.id] });
+
+    const status = tq.getDependencyStatus(t3.id);
+    expect(status.dependencies).toHaveLength(2);
+    expect(status.resolved).toHaveLength(0);
+    expect(status.unresolved).toHaveLength(2);
+
+    // Complete t1
+    tq.getNextTask();
+    tq.completeTask(t1.id);
+
+    const status2 = tq.getDependencyStatus(t3.id);
+    expect(status2.resolved).toContain(t1.id);
+    expect(status2.unresolved).toContain(t2.id);
+  });
+
+  it('should auto-resolve if dependency already completed', () => {
+    const t1 = tq.addTask('first');
+    const retrieved = tq.getNextTask()!;
+    tq.completeTask(retrieved.id);
+
+    // Now add a task depending on the already-completed task
+    const t2 = tq.addTask('second', { dependencies: [t1.id] });
+    expect(t2.status).toBe('pending'); // Should be immediately pending
+  });
+});
