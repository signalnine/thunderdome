+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+function compareLex(a: number[], b: number[]): number {
+  const len = Math.min(a.length, b.length);
+  for (let i = 0; i < len; i++) {
+    if (a[i] < b[i]) return -1;
+    if (a[i] > b[i]) return 1;
+  }
+  return a.length - b.length;
+}
+
+function compareLexArrays(a: number[], b: number[]): number {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] < b[i]) return -1;
+    if (a[i] > b[i]) return 1;
+  }
+  return 0;
+}
+
+/**
+ * Solve toggle puzzle using Gaussian elimination over GF(2).
+ *
+ * Builds augmented matrix A|b where A[i][j] = 1 if button j toggles light i,
+ * b[i] = target[i]. Performs row reduction, then enumerates free variable
+ * assignments to find minimum-weight, lexicographically smallest solution.
+ */
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const numLights = target.length;
+  const numButtons = buttons.length;
+
+  // Build augmented matrix [A | b] over GF(2)
+  // Rows = lights, Cols = buttons + 1 (augmented column)
+  const matrix: number[][] = [];
+  for (let i = 0; i < numLights; i++) {
+    const row = new Array(numButtons + 1).fill(0);
+    for (let j = 0; j < numButtons; j++) {
+      if (buttons[j].includes(i)) {
+        row[j] = 1;
+      }
+    }
+    row[numButtons] = target[i] ? 1 : 0;
+    matrix.push(row);
+  }
+
+  // Gaussian elimination over GF(2)
+  const pivotCol: number[] = [];
+  const pivotRow: number[] = new Array(numButtons).fill(-1);
+  let currentRow = 0;
+
+  for (let col = 0; col < numButtons && currentRow < numLights; col++) {
+    // Find pivot row
+    let pivotR = -1;
+    for (let r = currentRow; r < numLights; r++) {
+      if (matrix[r][col] === 1) {
+        pivotR = r;
+        break;
+      }
+    }
+    if (pivotR === -1) continue; // free variable
+
+    // Swap rows
+    [matrix[currentRow], matrix[pivotR]] = [matrix[pivotR], matrix[currentRow]];
+    pivotCol.push(col);
+    pivotRow[col] = currentRow;
+
+    // Eliminate column in all other rows
+    for (let r = 0; r < numLights; r++) {
+      if (r !== currentRow && matrix[r][col] === 1) {
+        for (let c = 0; c <= numButtons; c++) {
+          matrix[r][c] ^= matrix[currentRow][c];
+        }
+      }
+    }
+    currentRow++;
+  }
+
+  // Check for inconsistency: any row with all-zero coefficients but nonzero RHS
+  for (let r = currentRow; r < numLights; r++) {
+    if (matrix[r][numButtons] === 1) return null;
+  }
+
+  // Identify free variables (columns without pivots)
+  const pivotColSet = new Set(pivotCol);
+  const freeVars: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (!pivotColSet.has(col)) freeVars.push(col);
+  }
+
+  const numFree = freeVars.length;
+  let bestSolution: number[] | null = null;
+  let bestWeight = Infinity;
+
+  // Enumerate all 2^numFree assignments of free variables
+  const totalCombinations = 1 << numFree;
+  for (let mask = 0; mask < totalCombinations; mask++) {
+    const solution = new Array(numButtons).fill(0);
+
+    // Set free variables from bitmask
+    for (let f = 0; f < numFree; f++) {
+      solution[freeVars[f]] = (mask >> f) & 1;
+    }
+
+    // Back-substitute pivot variables
+    for (let p = pivotCol.length - 1; p >= 0; p--) {
+      const col = pivotCol[p];
+      const r = pivotRow[col];
+      let val = matrix[r][numButtons];
+      for (let c = 0; c < numButtons; c++) {
+        if (c !== col && matrix[r][c] === 1) {
+          val ^= solution[c];
+        }
+      }
+      solution[col] = val;
+    }
+
+    // Calculate Hamming weight (number of buttons pressed)
+    const weight = solution.reduce((a: number, b: number) => a + b, 0);
+
+    if (weight < bestWeight) {
+      bestWeight = weight;
+      bestSolution = [...solution];
+    } else if (weight === bestWeight && bestSolution) {
+      // Lexicographic comparison of pressed button indices
+      const currentIndices = [];
+      const bestIndices = [];
+      for (let i = 0; i < numButtons; i++) {
+        if (solution[i] === 1) currentIndices.push(i);
+        if (bestSolution[i] === 1) bestIndices.push(i);
+      }
+      if (compareLex(currentIndices, bestIndices) < 0) {
+        bestSolution = [...solution];
+      }
+    }
+  }
+
+  if (!bestSolution) {
+    // No free variables, unique solution (already found or empty)
+    return [];
+  }
+
+  const result: number[] = [];
+  for (let i = 0; i < numButtons; i++) {
+    if (bestSolution[i] === 1) result.push(i);
+  }
+  return result;
+}
+
+// ─── Counter Puzzle (GF(p)) ──────────────────────────────────────────────────
+
+function modPow(base: number, exp: number, mod: number): number {
+  let result = 1;
+  base = ((base % mod) + mod) % mod;
+  while (exp > 0) {
+    if (exp & 1) result = (result * base) % mod;
+    exp >>= 1;
+    base = (base * base) % mod;
+  }
+  return result;
+}
+
+function modInverse(a: number, mod: number): number {
+  return modPow(a, mod - 2, mod);
+}
+
+/**
+ * Solve counter puzzle using Gaussian elimination over GF(p).
+ *
+ * Each counter starts at 0 and wraps at modulus (prime). Buttons increment
+ * specific counters. Find the press counts (0..modulus-1 per button) that
+ * achieve the target, minimizing total presses, breaking ties lexicographically.
+ */
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number,
+): number[] | null {
+  const numLights = lights.length;
+  const numButtons = buttons.length;
+
+  // Build augmented matrix over GF(modulus)
+  const matrix: number[][] = [];
+  for (let i = 0; i < numLights; i++) {
+    const row = new Array(numButtons + 1).fill(0);
+    for (let j = 0; j < numButtons; j++) {
+      if (buttons[j].includes(i)) {
+        row[j] = 1;
+      }
+    }
+    row[numButtons] = ((lights[i] % modulus) + modulus) % modulus;
+    matrix.push(row);
+  }
+
+  // Gaussian elimination over GF(modulus)
+  const pivotCol: number[] = [];
+  const pivotRow: number[] = new Array(numButtons).fill(-1);
+  let currentRow = 0;
+
+  for (let col = 0; col < numButtons && currentRow < numLights; col++) {
+    // Find pivot row
+    let pivotR = -1;
+    for (let r = currentRow; r < numLights; r++) {
+      if (matrix[r][col] !== 0) {
+        pivotR = r;
+        break;
+      }
+    }
+    if (pivotR === -1) continue;
+
+    // Swap rows
+    [matrix[currentRow], matrix[pivotR]] = [matrix[pivotR], matrix[currentRow]];
+    pivotCol.push(col);
+    pivotRow[col] = currentRow;
+
+    // Scale pivot row so pivot element = 1
+    const inv = modInverse(matrix[currentRow][col], modulus);
+    for (let c = 0; c <= numButtons; c++) {
+      matrix[currentRow][c] = (matrix[currentRow][c] * inv) % modulus;
+    }
+
+    // Eliminate column in all other rows
+    for (let r = 0; r < numLights; r++) {
+      if (r !== currentRow && matrix[r][col] !== 0) {
+        const factor = matrix[r][col];
+        for (let c = 0; c <= numButtons; c++) {
+          matrix[r][c] =
+            ((matrix[r][c] - factor * matrix[currentRow][c]) % modulus + modulus) % modulus;
+        }
+      }
+    }
+    currentRow++;
+  }
+
+  // Check inconsistency
+  for (let r = currentRow; r < numLights; r++) {
+    if (matrix[r][numButtons] !== 0) return null;
+  }
+
+  // Find free variables
+  const pivotColSet = new Set(pivotCol);
+  const freeVars: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (!pivotColSet.has(col)) freeVars.push(col);
+  }
+
+  const numFree = freeVars.length;
+
+  // Helper to compute full solution from free variable values
+  function computeSolution(freeValues: number[]): number[] {
+    const solution = new Array(numButtons).fill(0);
+    for (let f = 0; f < numFree; f++) {
+      solution[freeVars[f]] = freeValues[f];
+    }
+    for (let p = pivotCol.length - 1; p >= 0; p--) {
+      const col = pivotCol[p];
+      const r = pivotRow[col];
+      let val = matrix[r][numButtons];
+      for (let c = 0; c < numButtons; c++) {
+        if (c !== col && matrix[r][c] !== 0) {
+          val = ((val - matrix[r][c] * solution[c]) % modulus + modulus) % modulus;
+        }
+      }
+      solution[col] = val;
+    }
+    return solution;
+  }
+
+  const totalCombinations = Math.pow(modulus, numFree);
+
+  let bestSolution: number[] | null = null;
+  let bestSum = Infinity;
+
+  if (totalCombinations <= 10_000_000) {
+    // Enumerate all combinations
+    for (let combo = 0; combo < totalCombinations; combo++) {
+      const freeValues: number[] = [];
+      let temp = combo;
+      for (let f = 0; f < numFree; f++) {
+        freeValues.push(temp % modulus);
+        temp = Math.floor(temp / modulus);
+      }
+
+      const solution = computeSolution(freeValues);
+      const sum = solution.reduce((a: number, b: number) => a + b, 0);
+
+      if (
+        sum < bestSum ||
+        (sum === bestSum && bestSolution && compareLexArrays(solution, bestSolution) < 0)
+      ) {
+        bestSum = sum;
+        bestSolution = solution;
+      }
+    }
+  } else {
+    // For very large search spaces, try each free variable independently
+    // Since pivot values are linear functions of free vars, we can optimize
+    // by trying all p values for each free var while others are 0, then combine
+    // Actually for correctness, just set free vars to 0 for the base case
+    bestSolution = computeSolution(new Array(numFree).fill(0));
+    bestSum = bestSolution.reduce((a: number, b: number) => a + b, 0);
+
+    // Try each free var individually to see if non-zero improves things
+    for (let f = 0; f < numFree; f++) {
+      for (let v = 1; v < modulus; v++) {
+        const freeValues = new Array(numFree).fill(0);
+        freeValues[f] = v;
+        const solution = computeSolution(freeValues);
+        const sum = solution.reduce((a: number, b: number) => a + b, 0);
+        if (
+          sum < bestSum ||
+          (sum === bestSum && compareLexArrays(solution, bestSolution!) < 0)
+        ) {
+          bestSum = sum;
+          bestSolution = solution;
+        }
+      }
+    }
+  }
+
+  return bestSolution ?? new Array(numButtons).fill(0);
+}
