+function modPow(base: number, exp: number, mod: number): number {
+  let result = 1;
+  base = ((base % mod) + mod) % mod;
+  while (exp > 0) {
+    if (exp & 1) result = (result * base) % mod;
+    exp >>= 1;
+    base = (base * base) % mod;
+  }
+  return result;
+}
+
+function modInverse(a: number, mod: number): number {
+  return modPow(a, mod - 2, mod);
+}
