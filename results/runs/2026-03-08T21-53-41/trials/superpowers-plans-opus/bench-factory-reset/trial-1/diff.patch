+      matrix[currentRow][c] = (matrix[currentRow][c] * inv) % modulus;
+    }
+
+    // Eliminate column
+    for (let r = 0; r < numLights; r++) {
+      if (r !== currentRow && matrix[r][col] !== 0) {
+        const factor = matrix[r][col];
+        for (let c = 0; c <= numButtons; c++) {
+          matrix[r][c] = ((matrix[r][c] - factor * matrix[currentRow][c]) % modulus + modulus) % modulus;
+        }
+      }
+    }
+    currentRow++;
+  }
+
+  // Check inconsistency
+  for (let r = currentRow; r < numLights; r++) {
+    if (matrix[r][numButtons] !== 0) return null;
+  }
+
+  // Find free variables
+  const pivotColSet = new Set(pivotCol);
+  const freeVars: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (!pivotColSet.has(col)) freeVars.push(col);
+  }
