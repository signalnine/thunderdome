number,\n  numButtons: number,\n  modulus: number,\n  density: number,\n  seed: number,\n): { lights: number[]; buttons: number[][]; modulus: number } {\n  const rng = seededRandom(seed);\n\n  const buttons: number[][] = [];\n  for (let j = 0; j < numButtons; j++) {\n    const affected: number[] = [];\n    for (let i = 0; i < numLights; i++) {\n      if (rng() < density) {\n        affected.push(i);\n      }\n    }\n    if (affected.length === 0) {\n      affected.push(Math.floor(rng() * numLights));\n    }\n    buttons.push(affected);\n  }\n\n  // Choose a random solution (press counts)\n  const solution: number[] = [];\n  for (let j = 0; j < numButtons; j++) {\n    solution.push(Math.floor(rng() * modulus));\n  }\n\n  // Compute target from solution\n  const lights = new Array(numLights).fill(0);\n  for (let j = 0; j < numButtons; j++) {\n    for (const i of buttons[j]) {\n      lights[i] = (lights[i] + solution[j]) % modulus;\n    }\n  }\n\n  return { lights, buttons, modulus };\n}\n\n// ─── Verification helpers ────────────────────────────────────────────────────\n\n/** Verify a toggle solution is correct */\nfunction verifyToggle(machine: Machine, solution: number[]): boolean {\n  const state = new Array(machine.target.length).fill(false);\n  for (const btnIdx of solution) {\n    for (const lightIdx of machine.buttons[btnIdx]) {\n      state[lightIdx] = !state[lightIdx];\n    }\n  }\n  return state.every((v: boolean, i: number) => v === machine.target[i]);\n}\n\n/** Verify a counter solution is correct */\nfunction verifyCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number,\n  solution: number[],\n): boolean {\n  const state = new Array(lights.length).fill(0);\n  for (let j = 0; j < buttons.length; j++) {\n    for (const i of buttons[j]) {\n      state[i] = (state[i] + solution[j]) % modulus;\n    }\n  }\n  return state.every((v: number, i: number) => v === lights[i]);\n}\n\n/** Count total presses in solution */\nfunction totalPresses(solut