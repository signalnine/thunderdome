@@ -0,0 +1,107 @@
+import { Router, Response } from 'express';
+import { folders, documents, permissions, users, activityLog, generateId } from '../store.js';
+import { AuthRequest, authMiddleware } from '../middleware.js';
+import { getEffectiveRole, canEdit } from '../permissions.js';
+import { Role } from '../types.js';
+
+const router = Router();
+
+router.use(authMiddleware);
+
+router.post('/', (req: AuthRequest, res: Response) => {
+  const { resourceType, resourceId, userId: targetUserId, role } = req.body;
+  const userId = req.userId!;
+
+  if (!resourceType || !resourceId || !targetUserId || !role) {
+    res.status(400).json({ error: 'resourceType, resourceId, userId, and role are required' });
+    return;
+  }
+
+  if (!['folder', 'document'].includes(resourceType)) {
+    res.status(400).json({ error: 'resourceType must be "folder" or "document"' });
+    return;
+  }
+
+  if (!['viewer', 'editor', 'owner'].includes(role)) {
+    res.status(400).json({ error: 'role must be "viewer", "editor", or "owner"' });
+    return;
+  }
+
+  // Target user must exist
+  if (!users.has(targetUserId)) {
+    res.status(404).json({ error: 'Target user not found' });
+    return;
+  }
+
+  // Resource must exist
+  if (resourceType === 'folder') {
+    const folder = folders.get(resourceId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+    // Check permissions: editors and owners can share
+    const effectiveRole = getEffectiveRole(userId, 'folder', resourceId);
+    if (!canEdit(effectiveRole) && folder.ownerId !== userId) {
+      res.status(403).json({ error: 'Insufficient permissions to share' });
+      return;
+    }
+  } else {
+    const doc = documents.get(resourceId);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    const effectiveRole = getEffectiveRole(userId, 'document', resourceId, doc.folderId);
+    if (!canEdit(effectiveRole) && doc.ownerId !== userId) {
+      res.status(403).json({ error: 'Insufficient permissions to share' });
+      return;
+    }
+  }
+
+  // Check if permission already exists - update it
+  const existing = permissions.find(
+    p => p.resourceType === resourceType && p.resourceId === resourceId && p.userId === targetUserId
+  );
+  if (existing) {
+    existing.role = role as Role;
+  } else {
+    permissions.push({
+      id: generateId(),
+      resourceType,
+      resourceId,
+      userId: targetUserId,
+      role: role as Role,
+    });
+  }
+
+  activityLog.push({
+    id: generateId(),
+    action: 'share',
+    userId,
+    resourceType,
+    resourceId,
+    timestamp: new Date().toISOString(),
+    details: `Shared with user ${targetUserId} as ${role}`,
+  });
+
+  res.status(200).json({ message: 'Permission granted', resourceType, resourceId, userId: targetUserId, role });
+});
+
+// Get permissions for a resource
+router.get('/:resourceType/:resourceId', authMiddleware, (req: AuthRequest, res: Response) => {
+  const { resourceType, resourceId } = req.params;
+
+  if (!['folder', 'document'].includes(resourceType)) {
+    res.status(400).json({ error: 'Invalid resource type' });
+    return;
+  }
+
+  const resourcePermissions = permissions.filter(
+    p => p.resourceType === resourceType && p.resourceId === resourceId
+  );
+
+  res.json(resourcePermissions);
+});
+
+export default router;
