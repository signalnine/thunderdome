d(role) && folder.ownerId !== userId) {\n    res.status(403).json({ error: 'Access denied' });\n    return;\n  }\n\n  // Get child folders and documents\n  const childFolders = Array.from(folders.values()).filter(f => f.parentId === folder.id);\n  const childDocuments = Array.from(documents.values()).filter(d => d.folderId === folder.id);\n\n  res.json({ ...folder, folders: childFolders, documents: childDocuments });\n});\n\nrouter.put('/:id', (req: AuthRequest, res: Response) => {\n  const folder = folders.get(req.params.id);\n  if (!folder) {\n    res.status(404).json({ error: 'Folder not found' });\n    return;\n  }\n\n  const userId = req.userId!;\n  const role = getEffectiveRole(userId, 'folder', folder.id);\n  if (!canEdit(role) && folder.ownerId !== userId) {\n    res.status(403).json({ error: 'Insufficient permissions' });\n    return;\n  }\n\n  const { name, parentId } = req.body;\n  if (name) folder.name = name;\n  if (parentId !== undefined) {\n    if (parentId !== null) {\n      const parent = folders.get(parentId);\n      if (!parent) {\n        res.status(404).json({ error: 'Parent folder not found' });\n        return;\n      }\n    }\n    folder.parentId = parentId;\n  }\n\n  res.json(folder);\n});\n\nrouter.delete('/:id', (req: AuthRequest, res: Response) => {\n  const folder = folders.get(req.params.id);\n  if (!folder) {\n    res.status(404).json({ error: 'Folder not found' });\n    return;\n  }\n\n  const userId = req.userId!;\n  const role = getEffectiveRole(userId, 'folder', folder.id);\n  if (!isOwner(role) && folder.ownerId !== userId) {\n    res.status(403).json({ error: 'Only owners can delete folders' });\n    return;\n  }\n\n  // Delete folder, its documents, and child folders recursively\n  deleteFolderRecursive(folder.id);\n\n  activityLog.push({\n    id: generateId(),\n    action: 'folder_deleted',\n    userId,\n    resourceType: 'folder',\n    resourceId: req.params.id,\n    timestamp: new Date().toISOString(),\n  });\n\n  res.status(204).send();\n});\n\nfunction deleteFolderRecursive(folderId: string): void {\n  // Delete child folders\n  for (const f of folders.values()) {\n    if (f.parentId === folderId) {\n      deleteFolderRecursive(f.id);\n    }\n  }\n  // Delete documents in this folder\n  for (const d of documents.values()) {\n    if (d.folderId === folderId) {\n      documents.delete(d.id);\n      // Remove document permissions\n      for (let i = permissions.length - 1; i >= 0; i--) {\n        if (permissions[i].resourceType === 'document' && permissions[i].resourceId === d.id) {\n          permissions.splice(i, 1);\n        }\n      }\n    }\n  }\n  // Remove folder permissions\n  for (let i = permissions.length - 1; i >= 0; i--) {\n    if (permissions[i].resourceType === 'folder' && permissions[i].resourceId === folderId) {\n      permissions.splice(i, 1);\n    }\n  }\n  folders.delete(folderId);\n}\n\nexport default router;\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":125,"cache_read_input_tokens":27908,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":125},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"4b8ae633-a94f-4860-90f9-a2ae61600497","uuid":"fe301d99-84e5-44a6-9554-2ec08b90d928"}
