Auth.token}`)\n        .send({ name: 'L2', parentId: l1.body.id });\n      const l3 = await request(app).post('/folders')\n        .set('Authorization', `Bearer ${aliceAuth.token}`)\n        .send({ name: 'L3', parentId: l2.body.id });\n\n      // Share L1 with Bob as editor\n      await request(app).post('/share')\n        .set('Authorization', `Bearer ${aliceAuth.token}`)\n        .send({ resourceType: 'folder', resourceId: l1.body.id, userId: bobAuth.userId, role: 'editor' });\n\n      // Bob should have editor access to L3 through inheritance\n      const doc = await request(app).post('/documents')\n        .set('Authorization', `Bearer ${aliceAuth.token}`)\n        .send({ title: 'Deep Doc', content: 'text', folderId: l3.body.id });\n\n      const res = await request(app)\n        .put(`/documents/${doc.body.id}`)\n        .set('Authorization', `Bearer ${bobAuth.token}`)\n        .send({ title: 'Updated by Bob' });\n      expect(res.status).toBe(200);\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
