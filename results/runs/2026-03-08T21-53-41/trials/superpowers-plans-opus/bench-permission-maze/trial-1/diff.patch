+import { Router, Response } from 'express';
+import { documents, folders, permissions, activityLog, generateId } from '../store.js';
+import { AuthRequest, authMiddleware } from '../middleware.js';
+import { getEffectiveRole, canRead, canEdit, isOwner } from '../permissions.js';
+
+const router = Router();
+
+router.use(authMiddleware);
+
+router.post('/', (req: AuthRequest, res: Response) => {
+  const { title, content, folderId } = req.body;
+  const userId = req.userId!;
+
+  if (!title || content === undefined || !folderId) {
+    res.status(400).json({ error: 'Title, content, and folderId are required' });
+    return;
+  }
+
+  const folder = folders.get(folderId);
+  if (!folder) {
+    res.status(404).json({ error: 'Folder not found' });
+    return;
+  }
+
+  // Must have at least editor access to folder to create document
+  const folderRole = getEffectiveRole(userId, 'folder', folderId);
+  if (!canEdit(folderRole) && folder.ownerId !== userId) {
+    res.status(403).json({ error: 'Insufficient permissions on folder' });
+    return;
+  }
+
+  const id = generateId();
+  const now = new Date().toISOString();
+  const doc = { id, title, content, folderId, ownerId: userId, createdAt: now, updatedAt: now };
+  documents.set(id, doc);
+
+  // Owner permission
+  permissions.push({ id: generateId(), resourceType: 'document', resourceId: id, userId, role: 'owner' });
+
+  activityLog.push({
+    id: generateId(),
+    action: 'document_created',
+    userId,
+    resourceType: 'document',
+    resourceId: id,
+    timestamp: now,
+  });
+
+  res.status(201).json(doc);
+});
+
+router.get('/:id', (req: AuthRequest, res: Response) => {
+  const doc = documents.get(req.params.id);
+  if (!doc) {
+    res.status(404).json({ error: 'Document not found' });
+    return;
+  }
+
+  const userId = req.userId!;
+  const role = getEffectiveRole(userId, 'document', doc.id, doc.folderId);
+  if (!canRead(role) && doc.ownerId !== userId) {
+    res.status(403).json({ error: 'Access denied' });
+    return;
+  }
+
+  res.json(doc);
+});
+
+router.put('/:id', (req: AuthRequest, res: Response) => {
+  const doc = documents.get(req.params.id);
+  if (!doc) {
+    res.status(404).json({ error: 'Document not found' });
+    return;
+  }
+
+  const userId = req.userId!;
+  const role = getEffectiveRole(userId, 'document', doc.id, doc.folderId);
+  if (!canEdit(role) && doc.ownerId !== userId) {
+    res.status(403).json({ error: 'Insufficient permissions' });
+    return;
+  }
+
+  const { title, content } = req.body;
+  if (title !== undefined) doc.title = title;
+  if (content !== undefined) doc.content = content;
+  doc.updatedAt = new Date().toISOString();
+
+  activityLog.push({
+    id: generateId(),
+    action: 'document_updated',
+    userId,
+    resourceType: 'document',
+    resourceId: doc.id,
+    timestamp: doc.updatedAt,
+  });
+
+  res.json(doc);
+});
+
+router.delete('/:id', (req: AuthRequest, res: Response) => {
+  const doc = documents.get(req.params.id);
+  if (!doc) {
+    res.status(404).json({ error: 'Document not found' });
+    return;
+  }
+
+  const userId = req.userId!;
+  const role = getEffectiveRole(userId, 'document', doc.id, doc.folderId);
+  if (!isOwner(role) && doc.ownerId !== userId) {
+    res.status(403).json({ error: 'Only owners can delete documents' });
+    return;
+  }
+
+  documents.delete(doc.id);
+
+  // Remove document permissions
+  for (let i = permissions.length - 1; i >= 0; i--) {
+    if (permissions[i].resourceType === 'document' && permissions[i].resourceId === doc.id) {
+      permissions.splice(i, 1);
+    }
+  }
+
+  activityLog.push({
+    id: generateId(),
+    action: 'document_deleted',
+    userId,
+    resourceType: 'document',
+    resourceId: req.params.id,
+    timestamp: new Date().toISOString(),
+  });
+
+  res.status(204).send();
+});
+
+export default router;
