+### Task 2: Implement findSwappedWires with structural analysis
+
+**Files:**
+- Modify: `src/index.ts`
+- Create: `src/__tests__/findSwappedWires.test.ts`
+
+**Algorithm:**
+
+A correct N-bit ripple-carry adder has a specific structure per bit:
+- **Bit 0 (half adder):**
+  - `xNN XOR yNN -> zNN` (sum)
+  - `xNN AND yNN -> carry` (carry out)
+- **Bits 1..N (full adder):**
+  - `xNN XOR yNN -> partial_sum` (XOR of inputs)
+  - `partial_sum XOR carry_in -> zNN` (final sum)
+  - `xNN AND yNN -> gen_carry` (generate)
+  - `partial_sum AND carry_in -> prop_carry` (propagate)
+  - `gen_carry OR prop_carry -> carry_out` (carry out)
+- **Final bit:** carry_out of last stage -> z(N+1)
+
+**Structural detection approach:**
+
+For each gate, check if it violates the expected pattern:
+1. A gate outputting `zNN` must be XOR (except the last z bit which is OR for the carry).
+2. XOR gates must have specific input patterns (either xNN/yNN inputs or one input from an xNN XOR yNN gate).
+3. AND gates with xNN/yNN inputs must NOT output to zNN.
+4. OR gates must NOT output to zNN (except the final carry bit).
+5. Check downstream connections of each gate type.
+
+The key rules to detect swapped wires:
+1. **z-outputs must be XOR** (except the highest z bit): If a non-XOR gate outputs to zNN, that output is swapped.
+2. **XOR of x/y should not output to z directly** (except bit 0): If xNN XOR yNN -> zNN for N>0, that's a swap.
+3. **XOR gates that aren't x/y XOR must output to z**: If a XOR gate has non-x/y inputs and doesn't output to z, it's swapped.
+4. **AND gates' outputs must be inputs to exactly one OR gate**: If an AND gate's output feeds into a non-OR gate (except for bit 0 carry), that's a swap.
+5. **OR gate outputs should be carry wires, not z wires** (except final): If an OR gate outputs to z, it's swapped.
+
+**Step 1: Write tests**
+
+```typescript
+// src/__tests__/findSwappedWires.test.ts
+import { describe, it, expect } from 'vitest';
+import { findSwappedWires, Gate } from '../index.js';
+
+function makeCorrectAdder(bits: number): Gate[] {
+  const gates: Gate[] = [];
+  // Bit 0: half adder
+  gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });
+  gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });
+
+  let carryIn = 'c00';
+  for (let i = 1; i < bits; i++) {
+    const nn = String(i).padStart(2, '0');
+    const t = `t${nn}`;
+    const a = `a${nn}`;
+    const b = `b${nn}`;
+    const c = `c${nn}`;
+    gates.push({ op: 'XOR', in1: `x${nn}`, in2: `y${nn}`, out: t });
+    gates.push({ op: 'XOR', in1: t, in2: carryIn, out: `z${nn}` });
+    gates.push({ op: 'AND', in1: `x${nn}`, in2: `y${nn}`, out: a });
+    gates.push({ op: 'AND', in1: t, in2: carryIn, out: b });
+    gates.push({ op: 'OR', in1: a, in2: b, out: c });
+    carryIn = c;
+  }
+  // Final carry -> last z bit
+  const lastZ = `z${String(bits).padStart(2, '0')}`;
+  // Rename last carry to be the final z
+  gates[gates.length - 1].out = lastZ;
+  return gates;
+}
+
+function swapOutputs(gates: Gate[], wire1: string, wire2: string): Gate[] {
+  return gates.map(g => {
+    if (g.out === wire1) return { ...g, out: wire2 };
+    if (g.out === wire2) return { ...g, out: wire1 };
+    return { ...g };
+  });
+}
+
+describe('findSwappedWires', () => {
+  it('finds swapped wires in a small adder', () => {
+    let gates = makeCorrectAdder(8);
+    // Swap 4 pairs
+    gates = swapOutputs(gates, 'z01', 'a01');
+    gates = swapOutputs(gates, 'z03', 'b03');
+    gates = swapOutputs(gates, 't05', 'z05');
+    gates = swapOutputs(gates, 'c06', 'z07');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(['a01', 'b03', 'c06', 't05', 'z01', 'z03', 'z05', 'z07'].sort());
+  });
+
+  it('returns sorted array of 8 wire names', () => {
+    let gates = makeCorrectAdder(10);
+    gates = swapOutputs(gates, 'z02', 't02');
+    gates = swapOutputs(gates, 'z04', 'a04');
+    gates = swapOutputs(gates, 'c05', 'z06');
+    gates = swapOutputs(gates, 'z08', 'b08');
+
+    const result = findSwappedWires(gates);
+    expect(result).toHaveLength(8);
+    expect(result).toEqual([...result].sort());
+  });
+
+  it('handles 45-bit adder within time limit', () => {
+    let gates = makeCorrectAdder(45);
+    gates = swapOutputs(gates, 'z10', 't10');
+    gates = swapOutputs(gates, 'z20', 'a20');
+    gates = swapOutputs(gates, 'c30', 'z31');
+    gates = swapOutputs(gates, 'z40', 'b40');
+
+    const start = Date.now();
+    const result = findSwappedWires(gates);
+    const elapsed = Date.now() - start;
+
+    expect(elapsed).toBeLessThan(5000);
+    expect(result).toHaveLength(8);
+    expect(result).toEqual(['a20', 'b40', 'c30', 't10', 'z10', 'z20', 'z31', 'z40'].sort());
+  });
+});
