.in2 === 'y00') || (gate.in1 === 'y00' && gate.in2 === 'x00'));\n\n      if (!isX00AndY00) {\n        const consumers = wireUsedBy.get(out) || [];\n        const feedsOR = consumers.some(g => g.op === 'OR');\n        if (!feedsOR && !out.startsWith('z')) {\n          // AND output doesn't feed OR and isn't z - it could be swapped\n          // But we should only flag it if it's not the expected pattern\n          swapped.add(out);\n        }\n        if (out.startsWith('z')) {\n          // AND output going to z is always wrong (except last z)\n          // Already caught by Rule 1\n        }\n      }\n    }\n\n    // Rule 5: OR gates should not output to z (except the last z bit)\n    if (gate.op === 'OR') {\n      if (out.startsWith('z') && out !== lastZ) {\n        swapped.add(out);\n      }\n    }\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[{"oldStart":45,"oldLines":12,"newStart":45,"newLines":6,"lines":["   const numBits = maxBit + 1;","   const lastZ = `z${String(numBits).padStart(2, '0')}`;"," ","-  // Build lookup structures","-  const gateByOutput = new Map<string, Gate>();","-  for (const gate of gates) {","-    gateByOutput.set(gate.out, gate);","-  }","-","   // Build a set of wires that are used as inputs to gates, keyed by wire name","   const wireUsedBy = new Map<string, Gate[]>();","   for (const gate of gates) {"]},{"oldStart":68,"oldLines":6,"newStart":62,"newLines":16,"lines":["            (gate.in1.startsWith('y') && gate.in2.startsWith('x'));","   }"," ","+  function isX00Y00(gate: Gate): boolean {","+    return (gate.in1 === 'x00' && gate.in2 === 'y00') ||","+           (gate.in1 === 'y00' && gate.in2 === 'x00');","+  }","+","+  function getConsumerOps(wire: string): Set<string> {","+    const consumers = wireUsedBy.get(wire) || [];","+    return new Set(consumers.map(g => g.op));","+  }","+","   for (const gate of gates) {","     const out = gate.out;"," "]},{"oldStart":78,"oldLines":38,"newStart":82,"newLines":35,"lines":["