index 0000000..d2f7947
--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,142 @@
+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+
+  while (remaining.length > 0) {
+    let progress = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        switch (gate.op) {
+          case 'AND': wires[gate.out] = a & b; break;
+          case 'OR':  wires[gate.out] = a | b; break;
+          case 'XOR': wires[gate.out] = a ^ b; break;
+        }
+        remaining.splice(i, 1);
+        progress = true;
+      }
+    }
+    if (!progress) break;
+  }
+
+  return wires;
+}
+
+export function findSwappedWires(gates: Gate[]): string[] {
+  // Determine the number of input bits by finding max x-index
+  let maxBit = 0;
+  for (const gate of gates) {
+    for (const wire of [gate.in1, gate.in2, gate.out]) {
+      const m = wire.match(/^x(\d+)$/);
+      if (m) {
+        maxBit = Math.max(maxBit, parseInt(m[1], 10));
+      }
+    }
+  }
+  const numBits = maxBit + 1;
+  const lastZ = `z${String(numBits).padStart(2, '0')}`;
+
+  // Build a set of wires that are used as inputs to gates, keyed by wire name
+  const wireUsedBy = new Map<string, Gate[]>();
+  for (const gate of gates) {
+    for (const input of [gate.in1, gate.in2]) {
+      if (!wireUsedBy.has(input)) wireUsedBy.set(input, []);
+      wireUsedBy.get(input)!.push(gate);
+    }
+  }
+
+  const swapped = new Set<string>();
+
+  // Helper: check if a gate has x/y inputs (in either order)
+  function hasXYInputs(gate: Gate): boolean {
+    return (gate.in1.startsWith('x') && gate.in2.startsWith('y')) ||
+           (gate.in1.startsWith('y') && gate.in2.startsWith('x'));
+  }
+
+  function isX00Y00(gate: Gate): boolean {
+    return (gate.in1 === 'x00' && gate.in2 === 'y00') ||
+           (gate.in1 === 'y00' && gate.in2 === 'x00');
+  }
+
+  function getConsumerOps(wire: string): Set<string> {
+    const consumers = wireUsedBy.get(wire) || [];
+    return new Set(consumers.map(g => g.op));
+  }
+
+  for (const gate of gates) {
+    const out = gate.out;
+
+    // Rule 1: z-outputs (except last z) must come from XOR gates
+    if (out.startsWith('z') && out !== lastZ) {
+      if (gate.op !== 'XOR') {
+        swapped.add(out);
+      }
+    }
+
+    if (gate.op === 'XOR') {
+      if (hasXYInputs(gate)) {
+        // Rule 2: XOR gates with x/y inputs should NOT output to z (except bit 0)
+        if (out.startsWith('z') && out !== 'z00') {
+          swapped.add(out);
+        }
+        // Rule 6: XOR(x,y) for non-bit-0 must feed into XOR and AND downstream
+        if (!isX00Y00(gate) && !out.startsWith('z')) {
+          const consumerOps = getConsumerOps(out);
+          if (!consumerOps.has('XOR') || !consumerOps.has('AND')) {
+            swapped.add(out);
+          }
+        }
+      } else {
+        // Rule 3: XOR gates without x/y inputs MUST output to z
+        if (!out.startsWith('z')) {
+          swapped.add(out);
+        }
+      }
+    }
+
+    // Rule 4: AND gates' outputs (except x00 AND y00) must feed into an OR gate
+    if (gate.op === 'AND') {
+      if (isX00Y00(gate)) {
+        // Rule 4b: AND(x00,y00) carry must feed into XOR and AND (like other carry wires)
+        // unless numBits == 1 (single-bit adder, then it goes to z01)
+        if (numBits > 1 && !out.startsWith('z')) {
+          const consumerOps = getConsumerOps(out);
+          if (!consumerOps.has('XOR') || !consumerOps.has('AND')) {
+            swapped.add(out);
+          }
+        }
+      } else {
+        const consumerOps = getConsumerOps(out);
+        if (!consumerOps.has('OR')) {
+          swapped.add(out);
+        }
+      }
+    }
+
+    // Rule 5: OR gates should not output to z (except the last z bit)
+    if (gate.op === 'OR') {
+      if (out.startsWith('z') && out !== lastZ) {
+        swapped.add(out);
+      }
+      // Rule 7: OR gate outputs (carry wires) must feed into XOR and AND downstream
+      // (except the last z bit which is a terminal output)
+      if (out !== lastZ) {
+        const consumerOps = getConsumerOps(out);
+        if (!consumerOps.has('XOR') || !consumerOps.has('AND')) {
+          swapped.add(out);
+        }
+      }
+    }
+  }
+
+  return [...swapped].sort();
+}
