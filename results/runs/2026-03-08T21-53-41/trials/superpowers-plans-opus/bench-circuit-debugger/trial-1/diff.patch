@@ -0,0 +1,129 @@
+import { describe, it, expect } from 'vitest';
+import { findSwappedWires, Gate } from '../index.js';
+
+function makeCorrectAdder(bits: number): Gate[] {
+  const gates: Gate[] = [];
+  // Bit 0: half adder
+  gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });
+  gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });
+
+  let carryIn = 'c00';
+  for (let i = 1; i < bits; i++) {
+    const nn = String(i).padStart(2, '0');
+    const t = `t${nn}`;
+    const a = `a${nn}`;
+    const b = `b${nn}`;
+    const c = `c${nn}`;
+    gates.push({ op: 'XOR', in1: `x${nn}`, in2: `y${nn}`, out: t });
+    gates.push({ op: 'XOR', in1: t, in2: carryIn, out: `z${nn}` });
+    gates.push({ op: 'AND', in1: `x${nn}`, in2: `y${nn}`, out: a });
+    gates.push({ op: 'AND', in1: t, in2: carryIn, out: b });
+    gates.push({ op: 'OR', in1: a, in2: b, out: c });
+    carryIn = c;
+  }
+  // Final carry -> last z bit
+  const lastZ = `z${String(bits).padStart(2, '0')}`;
+  gates[gates.length - 1].out = lastZ;
+  return gates;
+}
+
+function swapOutputs(gates: Gate[], wire1: string, wire2: string): Gate[] {
+  return gates.map(g => {
+    if (g.out === wire1) return { ...g, out: wire2 };
+    if (g.out === wire2) return { ...g, out: wire1 };
+    return { ...g };
+  });
+}
+
+describe('findSwappedWires', () => {
+  it('finds swapped wires in an 8-bit adder', () => {
+    let gates = makeCorrectAdder(8);
+    gates = swapOutputs(gates, 'z01', 'a01');
+    gates = swapOutputs(gates, 'z03', 'b03');
+    gates = swapOutputs(gates, 't05', 'z05');
+    gates = swapOutputs(gates, 'c06', 'z07');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(['a01', 'b03', 'c06', 't05', 'z01', 'z03', 'z05', 'z07'].sort());
+  });
+
+  it('returns sorted array of 8 wire names', () => {
+    let gates = makeCorrectAdder(10);
+    gates = swapOutputs(gates, 'z02', 't02');
+    gates = swapOutputs(gates, 'z04', 'a04');
+    gates = swapOutputs(gates, 'c05', 'z06');
+    gates = swapOutputs(gates, 'z08', 'b08');
+
+    const result = findSwappedWires(gates);
+    expect(result).toHaveLength(8);
+    expect(result).toEqual([...result].sort());
+    expect(result).toEqual(['a04', 'b08', 'c05', 't02', 'z02', 'z04', 'z06', 'z08'].sort());
+  });
+
+  it('handles 45-bit adder within time limit', () => {
+    let gates = makeCorrectAdder(45);
+    gates = swapOutputs(gates, 'z10', 't10');
+    gates = swapOutputs(gates, 'z20', 'a20');
+    gates = swapOutputs(gates, 'c30', 'z31');
+    gates = swapOutputs(gates, 'z40', 'b40');
+
+    const start = Date.now();
+    const result = findSwappedWires(gates);
+    const elapsed = Date.now() - start;
+
+    expect(elapsed).toBeLessThan(5000);
+    expect(result).toHaveLength(8);
+    expect(result).toEqual(['a20', 'b40', 'c30', 't10', 'z10', 'z20', 'z31', 'z40'].sort());
+  });
+
+  it('finds swaps when two non-z wires are swapped with each other', () => {
+    let gates = makeCorrectAdder(10);
+    // Swap two internal wires
+    gates = swapOutputs(gates, 't03', 'a03');
+    gates = swapOutputs(gates, 'c04', 'b05');
+    gates = swapOutputs(gates, 'z02', 'a07');
+    gates = swapOutputs(gates, 'z09', 't09');
+
+    const result = findSwappedWires(gates);
+    expect(result).toHaveLength(8);
+    expect(result).toEqual(['a03', 'a07', 'b05', 'c04', 't03', 't09', 'z02', 'z09'].sort());
+  });
+
+  it('finds swaps with randomized wire names', () => {
+    // Create an adder with randomized internal wire names (like real inputs)
+    const gates: Gate[] = [];
+    gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });
+    gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'abc' });
+
+    // bit 1
+    gates.push({ op: 'XOR', in1: 'x01', in2: 'y01', out: 'def' });
+    gates.push({ op: 'XOR', in1: 'def', in2: 'abc', out: 'z01' });
+    gates.push({ op: 'AND', in1: 'x01', in2: 'y01', out: 'ghi' });
+    gates.push({ op: 'AND', in1: 'def', in2: 'abc', out: 'jkl' });
+    gates.push({ op: 'OR', in1: 'ghi', in2: 'jkl', out: 'mno' });
+
+    // bit 2
+    gates.push({ op: 'XOR', in1: 'x02', in2: 'y02', out: 'pqr' });
+    gates.push({ op: 'XOR', in1: 'pqr', in2: 'mno', out: 'z02' });
+    gates.push({ op: 'AND', in1: 'x02', in2: 'y02', out: 'stu' });
+    gates.push({ op: 'AND', in1: 'pqr', in2: 'mno', out: 'vwx' });
+    gates.push({ op: 'OR', in1: 'stu', in2: 'vwx', out: 'yza' });
+
+    // bit 3
+    gates.push({ op: 'XOR', in1: 'x03', in2: 'y03', out: 'bzc' });
+    gates.push({ op: 'XOR', in1: 'bzc', in2: 'yza', out: 'z03' });
+    gates.push({ op: 'AND', in1: 'x03', in2: 'y03', out: 'dzf' });
+    gates.push({ op: 'AND', in1: 'bzc', in2: 'yza', out: 'gzh' });
+    gates.push({ op: 'OR', in1: 'dzf', in2: 'gzh', out: 'z04' });
+
+    // Now swap 4 pairs
+    let swapped = swapOutputs(gates, 'z01', 'ghi');
+    swapped = swapOutputs(swapped, 'z02', 'pqr');
+    swapped = swapOutputs(swapped, 'z03', 'vwx');
+    swapped = swapOutputs(swapped, 'z04', 'jkl');
+
+    const result = findSwappedWires(swapped);
+    expect(result).toHaveLength(8);
+    expect(result).toEqual(['ghi', 'jkl', 'pqr', 'vwx', 'z01', 'z02', 'z03', 'z04'].sort());
+  });
+});
