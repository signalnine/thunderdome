  for (const gate of gates) {\n    51→    for (const input of [gate.in1, gate.in2]) {\n    52→      if (!wireUsedBy.has(input)) wireUsedBy.set(input, []);\n    53→      wireUsedBy.get(input)!.push(gate);\n    54→    }\n    55→  }\n    56→\n    57→  const swapped = new Set<string>();\n    58→\n    59→  // Helper: check if a gate has x/y inputs (in either order)\n    60→  function hasXYInputs(gate: Gate): boolean {\n    61→    return (gate.in1.startsWith('x') && gate.in2.startsWith('y')) ||\n    62→           (gate.in1.startsWith('y') && gate.in2.startsWith('x'));\n    63→  }\n    64→\n    65→  function isX00Y00(gate: Gate): boolean {\n    66→    return (gate.in1 === 'x00' && gate.in2 === 'y00') ||\n    67→           (gate.in1 === 'y00' && gate.in2 === 'x00');\n    68→  }\n    69→\n    70→  function getConsumerOps(wire: string): Set<string> {\n    71→    const consumers = wireUsedBy.get(wire) || [];\n    72→    return new Set(consumers.map(g => g.op));\n    73→  }\n    74→\n    75→  for (const gate of gates) {\n    76→    const out = gate.out;\n    77→\n    78→    // Rule 1: z-outputs (except last z) must come from XOR gates\n    79→    if (out.startsWith('z') && out !== lastZ) {\n    80→      if (gate.op !== 'XOR') {\n    81→        swapped.add(out);\n    82→      }\n    83→    }\n    84→\n    85→    if (gate.op === 'XOR') {\n    86→      if (hasXYInputs(gate)) {\n    87→        // Rule 2: XOR gates with x/y inputs should NOT output to z (except bit 0)\n    88→        if (out.startsWith('z') && out !== 'z00') {\n    89→          swapped.add(out);\n    90→        }\n    91→        // Rule 6: XOR(x,y) for non-bit-0 must feed into XOR and AND downstream\n    92→        if (!isX00Y00(gate) && !out.startsWith('z')) {\n    93→          const consumerOps = getConsumerOps(out);\n    94→          if (!consumerOps.has('XOR') || !consumerOps.has('AND')) {\n    95→            swapped.add(out);\n    96→          }\n    97→        }\n    98→      } else {\n    99→        // Rule 3