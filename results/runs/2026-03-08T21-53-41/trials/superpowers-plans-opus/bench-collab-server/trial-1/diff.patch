+import { describe, it, expect, beforeEach, afterEach } from 'vitest';
+import request from 'supertest';
+import { createApp, AppInstance } from '../src/server.js';
+
+describe('REST API', () => {
+  let instance: AppInstance;
+
+  beforeEach(() => {
+    instance = createApp(); // in-memory DB
+  });
+
+  afterEach(async () => {
+    await instance.stop();
+  });
+
+  describe('POST /documents', () => {
+    it('creates a document with title and content', async () => {
+      const res = await request(instance.app)
+        .post('/documents')
+        .send({ title: 'Test Doc', content: 'Hello' })
+        .expect(201);
+
+      expect(res.body.id).toBeDefined();
+      expect(res.body.title).toBe('Test Doc');
+      expect(res.body.content).toBe('Hello');
+    });
+
+    it('creates a document with empty content by default', async () => {
+      const res = await request(instance.app)
+        .post('/documents')
+        .send({ title: 'Empty' })
+        .expect(201);
+
+      expect(res.body.content).toBe('');
+    });
+
+    it('returns 400 if title is missing', async () => {
+      await request(instance.app)
+        .post('/documents')
+        .send({ content: 'no title' })
+        .expect(400);
+    });
+  });
+
+  describe('GET /documents', () => {
+    it('lists all documents', async () => {
+      await request(instance.app)
+        .post('/documents')
+        .send({ title: 'Doc 1' });
+      await request(instance.app)
+        .post('/documents')
+        .send({ title: 'Doc 2' });
+
+      const res = await request(instance.app).get('/documents').expect(200);
+      expect(res.body).toHaveLength(2);
+    });
+
+    it('returns empty array when no documents', async () => {
+      const res = await request(instance.app).get('/documents').expect(200);
+      expect(res.body).toEqual([]);
+    });
+  });
+
+  describe('GET /documents/:id', () => {
+    it('returns a single document', async () => {
+      const created = await request(instance.app)
+        .post('/documents')
+        .send({ title: 'My Doc', content: 'content here' });
+
+      const res = await request(instance.app)
+        .get(`/documents/${created.body.id}`)
+        .expect(200);
+
+      expect(res.body.title).toBe('My Doc');
+      expect(res.body.content).toBe('content here');
+    });
+
+    it('returns 404 for unknown document', async () => {
+      await request(instance.app)
+        .get('/documents/nonexistent')
+        .expect(404);
+    });
+  });
+
+  describe('PUT /documents/:id', () => {
+    it('updates title and content', async () => {
+      const created = await request(instance.app)
+        .post('/documents')
+        .send({ title: 'Original', content: 'old' });
+
+      const res = await request(instance.app)
+        .put(`/documents/${created.body.id}`)
+        .send({ title: 'Updated', content: 'new' })
+        .expect(200);
+
+      expect(res.body.title).toBe('Updated');
+      expect(res.body.content).toBe('new');
+    });
+
+    it('returns 404 for unknown document', async () => {
+      await request(instance.app)
+        .put('/documents/nonexistent')
