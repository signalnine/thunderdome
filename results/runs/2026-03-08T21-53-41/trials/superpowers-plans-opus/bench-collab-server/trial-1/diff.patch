diff --git a/src/ot.ts b/src/ot.ts
new file mode 100644
index 0000000..d428386
--- /dev/null
+++ b/src/ot.ts
@@ -0,0 +1,124 @@
+export interface InsertOp {
+  type: 'insert';
+  position: number;
+  text: string;
+}
+
+export interface DeleteOp {
+  type: 'delete';
+  position: number;
+  count: number;
+}
+
+export type Operation = InsertOp | DeleteOp;
+
+/**
+ * Apply an operation to a document string, returning the new content.
+ */
+export function applyOp(doc: string, op: Operation): string {
+  if (op.type === 'insert') {
+    if (op.position < 0 || op.position > doc.length) {
+      throw new Error(
+        `Insert position ${op.position} out of bounds for document length ${doc.length}`
+      );
+    }
+    return doc.slice(0, op.position) + op.text + doc.slice(op.position);
+  } else {
+    if (op.position < 0 || op.position + op.count > doc.length) {
+      throw new Error(
+        `Delete range [${op.position}, ${op.position + op.count}) out of bounds for document length ${doc.length}`
+      );
+    }
+    return doc.slice(0, op.position) + doc.slice(op.position + op.count);
+  }
+}
+
+/**
+ * Transform op1 against op2 (both concurrent).
+ * Returns a transformed version of op1 that can be applied after op2 has been applied.
+ */
+export function transformOp(op1: Operation, op2: Operation): Operation {
+  // insert vs insert
+  if (op1.type === 'insert' && op2.type === 'insert') {
+    if (op1.position <= op2.position) {
+      return op1;
+    } else {
+      return { ...op1, position: op1.position + op2.text.length };
+    }
+  }
+
+  // insert vs delete
+  if (op1.type === 'insert' && op2.type === 'delete') {
+    if (op1.position <= op2.position) {
+      return op1;
+    } else if (op1.position >= op2.position + op2.count) {
+      return { ...op1, position: op1.position - op2.count };
+    } else {
+      // Insert position is within deleted range — move to delete start
+      return { ...op1, position: op2.position };
+    }
+  }
+
+  // delete vs insert
+  if (op1.type === 'delete' && op2.type === 'insert') {
+    if (op2.position <= op1.position) {
+      return { ...op1, position: op1.position + op2.text.length };
+    } else if (op2.position >= op1.position + op1.count) {
+      return op1;
+    } else {
+      // Insert is within our delete range — expand delete to include inserted text
+      return { ...op1, count: op1.count + op2.text.length };
+    }
+  }
+
+  // delete vs delete
+  if (op1.type === 'delete' && op2.type === 'delete') {
+    const s1 = op1.position;
+    const e1 = op1.position + op1.count;
+    const s2 = op2.position;
+    const e2 = op2.position + op2.count;
+
+    if (e1 <= s2) {
+      // op1 is entirely before op2
+      return op1;
+    } else if (e2 <= s1) {
+      // op1 is entirely after op2
+      return { ...op1, position: op1.position - op2.count };
+    } else {
+      // Overlapping deletes
+      const overlapStart = Math.max(s1, s2);
+      const overlapEnd = Math.min(e1, e2);
+      const overlap = overlapEnd - overlapStart;
+      const newCount = op1.count - overlap;
+      const newPosition = Math.min(s1, s2);
+
+      return { type: 'delete', position: newPosition, count: Math.max(0, newCount) };
+    }
+  }
+
+  return op1;
+}
+
+/**
+ * Validate that an unknown value is a well-formed Operation.
+ */
+export function validateOp(op: unknown): op is Operation {
+  if (!op || typeof op !== 'object') return false;
+  const o = op as Record<string, unknown>;
+  if (o.type === 'insert') {
+    return (
+      typeof o.position === 'number' &&
+      typeof o.text === 'string' &&
+      o.position >= 0
+    );
+  }
+  if (o.type === 'delete') {
+    return (
+      typeof o.position === 'number' &&
+      typeof o.count === 'number' &&
+      o.position >= 0 &&
+      o.count >= 0
+    );
+  }
+  return false;
+}
