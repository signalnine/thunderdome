@@ -0,0 +1,399 @@
+import { describe, it, expect, beforeEach, afterEach } from 'vitest';
+import WebSocket from 'ws';
+import { createApp, AppInstance } from '../src/server.js';
+
+interface WsClient {
+  ws: WebSocket;
+  messages: Record<string, unknown>[];
+  waiters: ((msg: Record<string, unknown>) => void)[];
+}
+
+function createWsClient(port: number, docId: string): Promise<WsClient> {
+  return new Promise((resolve, reject) => {
+    const ws = new WebSocket(`ws://localhost:${port}/documents/${docId}/ws`);
+    const client: WsClient = { ws, messages: [], waiters: [] };
+
+    ws.on('message', (data) => {
+      const msg = JSON.parse(data.toString());
+      if (client.waiters.length > 0) {
+        const waiter = client.waiters.shift()!;
+        waiter(msg);
+      } else {
+        client.messages.push(msg);
+      }
+    });
+
+    ws.on('open', () => resolve(client));
+    ws.on('error', reject);
+  });
+}
+
+function nextMessage(client: WsClient): Promise<Record<string, unknown>> {
+  if (client.messages.length > 0) {
+    return Promise.resolve(client.messages.shift()!);
+  }
+  return new Promise((resolve) => {
+    client.waiters.push(resolve);
+  });
+}
+
+describe('WebSocket Collaboration', () => {
+  let instance: AppInstance;
+  let port: number;
+  let baseUrl: string;
+
+  beforeEach(async () => {
+    instance = createApp();
+    port = await instance.start(0);
+    baseUrl = `http://localhost:${port}`;
+  });
+
+  afterEach(async () => {
+    await instance.stop();
+  });
+
+  async function createDocument(title: string, content = '') {
+    const res = await fetch(`${baseUrl}/documents`, {
+      method: 'POST',
+      headers: { 'Content-Type': 'application/json' },
+      body: JSON.stringify({ title, content }),
+    });
+    return res.json();
+  }
+
+  async function getDocument(id: string) {
+    const res = await fetch(`${baseUrl}/documents/${id}`);
+    return res.json();
+  }
+
+  async function getVersions(id: string) {
+    const res = await fetch(`${baseUrl}/documents/${id}/versions`);
+    return res.json();
+  }
+
+  describe('Connection lifecycle', () => {
+    it('sends sync message on connect', async () => {
+      const doc = await createDocument('Test', 'hello');
+      const client = await createWsClient(port, doc.id);
+      const msg = await nextMessage(client);
+
+      expect(msg.type).toBe('sync');
+      expect(msg.content).toBe('hello');
+      expect(msg.version).toBeDefined();
+      expect(msg.clientId).toBeDefined();
+
+      client.ws.close();
+    });
+
+    it('handles multiple clients connecting to same document', async () => {
+      const doc = await createDocument('Shared', 'content');
+
+      const c1 = await createWsClient(port, doc.id);
+      const msg1 = await nextMessage(c1);
+      expect(msg1.type).toBe('sync');
+
+      const c2 = await createWsClient(port, doc.id);
