+import { describe, it, expect, afterEach } from 'vitest';
+import request from 'supertest';
+import { createApp, AppInstance } from '../src/server.js';
+import { existsSync, unlinkSync } from 'fs';
+import { join } from 'path';
+import os from 'os';
+
+describe('Persistence', () => {
+  const dbPath = join(os.tmpdir(), `collab-test-${Date.now()}.db`);
+  const instances: AppInstance[] = [];
+
+  afterEach(async () => {
+    for (const inst of instances) {
+      await inst.stop();
+    }
+    instances.length = 0;
+    // cleanup
+    try {
+      if (existsSync(dbPath)) unlinkSync(dbPath);
+      if (existsSync(dbPath + '-wal')) unlinkSync(dbPath + '-wal');
+      if (existsSync(dbPath + '-shm')) unlinkSync(dbPath + '-shm');
+    } catch {
+      // ignore cleanup errors
+    }
+  });
+
+  it('documents persist across server restarts', async () => {
+    // First server instance
+    const instance1 = createApp(dbPath);
+    instances.push(instance1);
+    await instance1.start(0);
+
+    const created = await request(instance1.app)
+      .post('/documents')
+      .send({ title: 'Persistent', content: 'survive restart' });
+
+    const docId = created.body.id;
+    await instance1.stop();
+    instances.length = 0;
+
+    // Second server instance with same DB
+    const instance2 = createApp(dbPath);
+    instances.push(instance2);
+    await instance2.start(0);
+
+    const res = await request(instance2.app).get(`/documents/${docId}`);
+    expect(res.status).toBe(200);
+    expect(res.body.title).toBe('Persistent');
+    expect(res.body.content).toBe('survive restart');
+  });
+
+  it('version history persists across restarts', async () => {
+    const instance1 = createApp(dbPath);
+    instances.push(instance1);
+    await instance1.start(0);
+
+    const created = await request(instance1.app)
+      .post('/documents')
+      .send({ title: 'Versioned', content: 'v1' });
+
+    const docId = created.body.id;
+
+    // Update content to create more versions
+    await request(instance1.app)
+      .put(`/documents/${docId}`)
+      .send({ content: 'v2' });
+
+    await instance1.stop();
+    instances.length = 0;
+
+    // Restart
+    const instance2 = createApp(dbPath);
+    instances.push(instance2);
+    await instance2.start(0);
+
+    const versions = await request(instance2.app).get(`/documents/${docId}/versions`);
+    expect(versions.status).toBe(200);
+    expect(versions.body.length).toBeGreaterThanOrEqual(1);
+  });
+
+  it('multiple documents persist', async () => {
+    const instance1 = createApp(dbPath);
+    instances.push(instance1);
+    await instance1.start(0);
+
+    await request(instance1.app).post('/documents').send({ title: 'Doc A', content: 'aaa' });
+    await request(instance1.app).post('/documents').send({ title: 'Doc B', content: 'bbb' });
+
+    await instance1.stop();
+    instances.length = 0;
+
+    const instance2 = createApp(dbPath);
+    instances.push(instance2);
+    await instance2.start(0);
+
+    const docs = await request(instance2.app).get('/documents');
+    expect(docs.body.length).toBe(2);
+  });
+});
