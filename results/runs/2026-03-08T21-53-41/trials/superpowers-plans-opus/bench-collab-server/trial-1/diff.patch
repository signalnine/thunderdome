+++ b/src/server.ts
@@ -0,0 +1,60 @@
+import express from 'express';
+import { createServer, Server } from 'http';
+import { createDatabase } from './db.js';
+import { createRouter } from './routes.js';
+import { setupWebSocket } from './ws.js';
+import Database from 'better-sqlite3';
+import { WebSocketServer } from 'ws';
+
+export interface AppInstance {
+  app: express.Express;
+  start: (port?: number) => Promise<number>;
+  stop: () => Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db: Database.Database = createDatabase(dbPath);
+  const app = express();
+  app.use(express.json());
+
+  const router = createRouter(db);
+  app.use(router);
+
+  const server: Server = createServer(app);
+  const wss: WebSocketServer = setupWebSocket(server, db);
+
+  let started = false;
+
+  async function start(port?: number): Promise<number> {
+    return new Promise((resolve) => {
+      server.listen(port || 0, () => {
+        started = true;
+        const addr = server.address();
+        const actualPort = typeof addr === 'object' && addr ? addr.port : 0;
+        resolve(actualPort);
+      });
+    });
+  }
+
+  async function stop(): Promise<void> {
+    // Close all WebSocket connections
+    wss.clients.forEach((client) => {
+      client.close();
+    });
+
+    return new Promise<void>((resolve, reject) => {
+      if (!started) {
+        db.close();
+        resolve();
+        return;
+      }
+      server.close((err) => {
+        db.close();
+        if (err) reject(err);
+        else resolve();
+      });
+    });
+  }
+
+  return { app, start, stop };
+}
diff --git a/src/ws.ts b/src/ws.ts
new file mode 100644
index 0000000..9cf8b9f
--- /dev/null
+++ b/src/ws.ts
@@ -0,0 +1,218 @@
+import { WebSocketServer, WebSocket } from 'ws';
+import { IncomingMessage } from 'http';
+import { Server } from 'http';
+import Database from 'better-sqlite3';
+import { randomUUID } from 'crypto';
+import { Operation, applyOp, transformOp, validateOp } from './ot.js';
+
+interface Client {
+  ws: WebSocket;
+  id: string;
+  documentId: string;
+}
+
+interface DocumentState {
+  version: number;
+  clients: Set<Client>;
+}
+
+export function setupWebSocket(
+  server: Server,
+  db: Database.Database
+): WebSocketServer {
+  const wss = new WebSocketServer({ noServer: true });
+  const documents = new Map<string, DocumentState>();
+
+  function getOrCreateDocState(docId: string): DocumentState {
+    let state = documents.get(docId);
+    if (!state) {
+      const row = db
+        .prepare(
+          'SELECT MAX(version) as maxVersion FROM versions WHERE document_id = ?'
+        )
+        .get(docId) as { maxVersion: number | null } | undefined;
+      state = { version: row?.maxVersion || 1, clients: new Set() };
+      documents.set(docId, state);
+    }
+    return state;
+  }
+
+  server.on('upgrade', (request: IncomingMessage, socket, head) => {
+    const url = new URL(request.url || '', `http://${request.headers.host}`);
+    const match = url.pathname.match(/^\/documents\/([^/]+)\/ws$/);
+
+    if (!match) {
+      socket.destroy();
+      return;
+    }
+
+    const docId = match[1];
+
+    // Verify document exists
+    const doc = db.prepare('SELECT id FROM documents WHERE id = ?').get(docId);
+    if (!doc) {
+      socket.write('HTTP/1.1 404 Not Found\r\n\r\n');
+      socket.destroy();
+      return;
+    }
+
+    wss.handleUpgrade(request, socket, head, (ws) => {
+      wss.emit('connection', ws, request, docId);
+    });
+  });
+
+  wss.on(
+    'connection',
+    (ws: WebSocket, _request: IncomingMessage, docId: string) => {
+      const clientId = randomUUID();
+      const client: Client = { ws, id: clientId, documentId: docId };
+      const state = getOrCreateDocState(docId);
+      state.clients.add(client);
+
+      // Send current document state to new client
+      const doc = db
+        .prepare('SELECT content FROM documents WHERE id = ?')
+        .get(docId) as { content: string } | undefined;
+
+      if (doc) {
+        ws.send(
+          JSON.stringify({
+            type: 'sync',
+            content: doc.content,
+            version: state.version,
+            clientId,
+          })
+        );
+      }
+
+      ws.on('message', (data) => {
+        try {
+          const message = JSON.parse(data.toString());
+
+          if (message.type === 'operation') {
+            handleOperation(ws, client, state, message, docId, clientId);
+          }
+        } catch {
+          ws.send(
+            JSON.stringify({
+              type: 'error',
+              message: 'Invalid message format',
+            })
+          );
+        }
+      });
+
+      ws.on('close', () => {
+        state.clients.delete(client);
+        if (state.clients.size === 0) {
+          documents.delete(docId);
+        }
+      });
+    }
+  );
+
+  function handleOperation(
+    ws: WebSocket,
+    _client: Client,
+    state: DocumentState,
+    message: { operation: unknown; version?: number },
+    docId: string,
+    clientId: string
+  ) {
+    const op = message.operation;
+    if (!validateOp(op)) {
+      ws.send(JSON.stringify({ type: 'error', message: 'Invalid operation' }));
+      return;
+    }
+
+    const clientVersion =
+      typeof message.version === 'number' ? message.version : state.version;
+
+    // Get current doc content
+    const currentDoc = db
+      .prepare('SELECT content FROM documents WHERE id = ?')
+      .get(docId) as { content: string } | undefined;
+
+    if (!currentDoc) {
+      ws.send(
+        JSON.stringify({ type: 'error', message: 'Document not found' })
+      );
+      return;
+    }
+
+    // Transform against operations that happened since client's version
+    let transformedOp: Operation = op;
+    if (clientVersion < state.version) {
+      const missedOps = db
+        .prepare(
+          'SELECT operation FROM versions WHERE document_id = ? AND version > ? AND version <= ? ORDER BY version ASC'
+        )
+        .all(docId, clientVersion, state.version) as { operation: string }[];
+
+      for (const row of missedOps) {
+        if (row.operation) {
+          const serverOp = JSON.parse(row.operation) as Operation;
+          transformedOp = transformOp(transformedOp, serverOp);
+        }
+      }
+    }
+
+    // Handle no-op deletes (result of OT reducing a delete to nothing)
+    if (transformedOp.type === 'delete' && transformedOp.count === 0) {
+      ws.send(
+        JSON.stringify({
+          type: 'ack',
+          version: state.version,
+        })
+      );
+      return;
+    }
+
+    // Apply transformed operation to current content
+    let newContent: string;
+    try {
+      newContent = applyOp(currentDoc.content, transformedOp);
+    } catch (err) {
+      ws.send(
+        JSON.stringify({ type: 'error', message: (err as Error).message })
+      );
+      return;
+    }
+
+    state.version++;
+    const newVersion = state.version;
+
+    // Persist changes
+    db.prepare(
+      "UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?"
+    ).run(newContent, docId);
+
+    db.prepare(
+      'INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)'
+    ).run(docId, newVersion, newContent, JSON.stringify(transformedOp));
+
+    // Acknowledge to sender
+    ws.send(
+      JSON.stringify({
+        type: 'ack',
+        version: newVersion,
+      })
+    );
+
+    // Broadcast to other clients on same document
+    for (const c of state.clients) {
+      if (c.ws !== ws && c.ws.readyState === WebSocket.OPEN) {
+        c.ws.send(
+          JSON.stringify({
+            type: 'operation',
+            operation: transformedOp,
+            version: newVersion,
+            clientId,
+          })
+        );
+      }
+    }
+  }
+
+  return wss;
+}
