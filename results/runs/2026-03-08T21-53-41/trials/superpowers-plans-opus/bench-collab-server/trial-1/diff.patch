@@ -0,0 +1,102 @@
+import { describe, it, expect } from 'vitest';
+import { applyOp, transformOp, validateOp, Operation } from '../src/ot.js';
+
+describe('OT Engine', () => {
+  describe('applyOp', () => {
+    it('inserts text at position', () => {
+      expect(applyOp('hello', { type: 'insert', position: 5, text: ' world' })).toBe('hello world');
+    });
+
+    it('inserts at the beginning', () => {
+      expect(applyOp('world', { type: 'insert', position: 0, text: 'hello ' })).toBe('hello world');
+    });
+
+    it('inserts in the middle', () => {
+      expect(applyOp('hllo', { type: 'insert', position: 1, text: 'e' })).toBe('hello');
+    });
+
+    it('deletes text at position', () => {
+      expect(applyOp('hello world', { type: 'delete', position: 5, count: 6 })).toBe('hello');
+    });
+
+    it('throws for out-of-bounds insert', () => {
+      expect(() => applyOp('hi', { type: 'insert', position: 10, text: 'x' })).toThrow();
+    });
+
+    it('throws for out-of-bounds delete', () => {
+      expect(() => applyOp('hi', { type: 'delete', position: 0, count: 5 })).toThrow();
+    });
+  });
+
+  describe('transformOp', () => {
+    it('transforms insert-insert (op1 before op2)', () => {
+      const op1: Operation = { type: 'insert', position: 0, text: 'a' };
+      const op2: Operation = { type: 'insert', position: 3, text: 'b' };
+      const result = transformOp(op1, op2);
+      expect(result.position).toBe(0);
+    });
+
+    it('transforms insert-insert (op1 after op2)', () => {
+      const op1: Operation = { type: 'insert', position: 5, text: 'a' };
+      const op2: Operation = { type: 'insert', position: 2, text: 'bb' };
+      const result = transformOp(op1, op2);
+      expect(result.position).toBe(7); // 5 + 2
+    });
+
+    it('transforms insert-delete (insert before delete)', () => {
+      const op1: Operation = { type: 'insert', position: 1, text: 'x' };
+      const op2: Operation = { type: 'delete', position: 3, count: 2 };
+      const result = transformOp(op1, op2);
+      expect(result.position).toBe(1);
+    });
+
+    it('transforms insert-delete (insert after delete)', () => {
+      const op1: Operation = { type: 'insert', position: 5, text: 'x' };
+      const op2: Operation = { type: 'delete', position: 1, count: 2 };
+      const result = transformOp(op1, op2);
+      expect(result.position).toBe(3); // 5 - 2
+    });
+
+    it('transforms delete-delete (non-overlapping)', () => {
+      const op1: Operation = { type: 'delete', position: 0, count: 2 };
+      const op2: Operation = { type: 'delete', position: 5, count: 3 };
+      const result = transformOp(op1, op2);
+      expect(result).toEqual({ type: 'delete', position: 0, count: 2 });
+    });
+
+    it('preserves both insertions for convergence', () => {
+      const doc = 'hello';
+      const op1: Operation = { type: 'insert', position: 5, text: ' world' };
+      const op2: Operation = { type: 'insert', position: 5, text: '!' };
+
+      // Server-centric model: op1 arrives first, then op2 is transformed against op1
+      const doc1 = applyOp(doc, op1);
+      const op2t = transformOp(op2, op1);
+      const result = applyOp(doc1, op2t);
+
+      // Both inserts must be preserved
+      expect(result).toContain('hello');
+      expect(result).toContain(' world');
+      expect(result).toContain('!');
+      expect(result.length).toBe(12); // "hello" + " world" + "!"
+    });
+  });
+
+  describe('validateOp', () => {
+    it('validates insert operations', () => {
+      expect(validateOp({ type: 'insert', position: 0, text: 'hi' })).toBe(true);
+    });
+
+    it('validates delete operations', () => {
+      expect(validateOp({ type: 'delete', position: 0, count: 3 })).toBe(true);
+    });
+
+    it('rejects invalid operations', () => {
+      expect(validateOp(null)).toBe(false);
+      expect(validateOp({})).toBe(false);
+      expect(validateOp({ type: 'unknown' })).toBe(false);
+      expect(validateOp({ type: 'insert', position: -1, text: 'hi' })).toBe(false);
+      expect(validateOp({ type: 'delete', position: 0 })).toBe(false);
+    });
+  });
+});
