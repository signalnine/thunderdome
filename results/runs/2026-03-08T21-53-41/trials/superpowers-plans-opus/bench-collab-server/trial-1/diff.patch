+# Real-Time Collaborative Document Editor Implementation Plan
+
+> **For Claude:** REQUIRED SUB-SKILL: Use superpowers:executing-plans to implement this plan task-by-task.
+
+**Goal:** Build a collaborative real-time document editing server with REST API, WebSocket collaboration, OT-based conflict resolution, and SQLite persistence.
+
+**Architecture:** Express HTTP server with ws WebSocket server attached to the same HTTP server. OT (Operational Transform) for conflict resolution using position-based insert/delete operations with server-side transformation. SQLite via better-sqlite3 for persistence. Factory function `createApp` exports the server.
+
+**Tech Stack:** TypeScript, Express, ws, better-sqlite3, vitest + supertest for testing
+
+---
+
+### Task 1: Database Layer (`src/db.ts`)
+
+**Files:**
+- Create: `src/db.ts`
+
+**Implementation:**
+
+```typescript
+import Database from 'better-sqlite3';
+import { readFileSync } from 'fs';
+import { join, dirname } from 'path';
+import { fileURLToPath } from 'url';
+
+const __dirname = dirname(fileURLToPath(import.meta.url));
+
+export function createDatabase(dbPath?: string): Database.Database {
+  const db = new Database(dbPath || ':memory:');
+  db.pragma('journal_mode = WAL');
+  db.pragma('foreign_keys = ON');
+  const schema = readFileSync(join(__dirname, '..', 'schema.sql'), 'utf-8');
+  db.exec(schema);
+  return db;
+}
+```
+
+---
+
+### Task 2: OT Engine (`src/ot.ts`)
+
+**Files:**
+- Create: `src/ot.ts`
+
+**Implementation:**
+
+Define operation types and the transform function. Operations are either `insert` (position + text) or `delete` (position + count).
+
+```typescript
+export interface InsertOp {
+  type: 'insert';
+  position: number;
+  text: string;
+}
+
+export interface DeleteOp {
+  type: 'delete';
+  position: number;
+  count: number;
+}
+
+export type Operation = InsertOp | DeleteOp;
+
+// Apply an operation to a document string
+export function applyOp(doc: string, op: Operation): string {
+  if (op.type === 'insert') {
+    if (op.position < 0 || op.position > doc.length) {
+      throw new Error(`Insert position ${op.position} out of bounds for document length ${doc.length}`);
+    }
+    return doc.slice(0, op.position) + op.text + doc.slice(op.position);
+  } else {
+    if (op.position < 0 || op.position + op.count > doc.length) {
+      throw new Error(`Delete range [${op.position}, ${op.position + op.count}) out of bounds for document length ${doc.length}`);
+    }
+    return doc.slice(0, op.position) + doc.slice(op.position + op.count);
+  }
+}
+
+// Transform op1 against op2 (both concurrent).
+// Returns transformed op1 that can be applied after op2.
+export function transformOp(op1: Operation, op2: Operation): Operation {
+  if (op1.type === 'insert' && op2.type === 'insert') {
+    if (op1.position <= op2.position) {
+      return op1; // op1 inserts before or at same position, no change
+    } else {
+      return { ...op1, position: op1.position + op2.text.length };
+    }
+  }
+
+  if (op1.type === 'insert' && op2.type === 'delete') {
+    if (op1.position <= op2.position) {
+      return op1;
+    } else if (op1.position >= op2.position + op2.count) {
+      return { ...op1, position: op1.position - op2.count };
+    } else {
+      // Insert is within deleted range - move to delete position
+      return { ...op1, position: op2.position };
+    }
+  }
+
+  if (op1.type === 'delete' && op2.type === 'insert') {
+    if (op2.position <= op1.position) {
+      return { ...op1, position: op1.position + op2.text.length };
+    } else if (op2.position >= op1.position + op1.count) {
+      return op1;
+    } else {
+      // Insert is within our delete range - expand delete to account for inserted text
+      return { ...op1, count: op1.count + op2.text.length };
+    }
+  }
+
+  // Both deletes
+  if (op1.type === 'delete' && op2.type === 'delete') {
+    if (op1.position >= op2.position + op2.count) {
+      return { ...op1, position: op1.position - op2.count };
+    } else if (op2.position >= op1.position + op1.count) {
+      return op1;
+    } else {
+      // Overlapping deletes
+      const start1 = op1.position;
+      const end1 = op1.position + op1.count;
+      const start2 = op2.position;
+      const end2 = op2.position + op2.count;
+
+      const newStart = Math.min(start1, start2);
+      const overlapStart = Math.max(start1, start2);
+      const overlapEnd = Math.min(end1, end2);
+      const overlap = Math.max(0, overlapEnd - overlapStart);
+
+      const newPosition = start1 <= start2 ? start1 : start1 - (overlapStart - start2);
+      const newCount = op1.count - overlap;
+
+      if (newCount <= 0) {
+        return { type: 'delete', position: newPosition, count: 0 };
+      }
+
+      return { type: 'delete', position: newPosition, count: newCount };
+    }
+  }
+
+  return op1;
+}
+
+// Validate that an operation is well-formed
+export function validateOp(op: unknown): op is Operation {
+  if (!op || typeof op !== 'object') return false;
+  const o = op as Record<string, unknown>;
+  if (o.type === 'insert') {
+    return typeof o.position === 'number' && typeof o.text === 'string' && o.position >= 0;
+  }
+  if (o.type === 'delete') {
+    return typeof o.position === 'number' && typeof o.count === 'number' && o.position >= 0 && o.count >= 0;
+  }
+  return false;
+}
+```
