rror', reject);\n  });\n}\n\nfunction waitForMessage(ws: WebSocket): Promise<Record<string, unknown>> {\n  return new Promise((resolve) => {\n    ws.once('message', (data) => {\n      resolve(JSON.parse(data.toString()));\n    });\n  });\n}\n\ndescribe('WebSocket Collaboration', () => {\n  let instance: AppInstance;\n  let port: number;\n\n  beforeEach(async () => {\n    instance = createApp();\n    port = await instance.start(0);\n  });\n\n  afterEach(async () => {\n    await instance.stop();\n  });\n\n  async function createDocument(title: string, content = '') {\n    const res = await request(instance.app)\n      .post('/documents')\n      .send({ title, content });\n    return res.body;\n  }\n\n  describe('Connection lifecycle', () => {\n    it('sends sync message on connect', async () => {\n      const doc = await createDocument('Test', 'hello');\n      const ws = await connectWs(port, doc.id);\n      const msg = await waitForMessage(ws);\n\n      expect(msg.type).toBe('sync');\n      expect(msg.content).toBe('hello');\n      expect(msg.version).toBeDefined();\n      expect(msg.clientId).toBeDefined();\n\n      ws.close();\n    });\n\n    it('handles multiple clients connecting to same document', async () => {\n      const doc = await createDocument('Shared', 'content');\n\n      const ws1 = await connectWs(port, doc.id);\n      const msg1 = await waitForMessage(ws1);\n      expect(msg1.type).toBe('sync');\n\n      const ws2 = await connectWs(port, doc.id);\n      const msg2 = await waitForMessage(ws2);\n      expect(msg2.type).toBe('sync');\n      expect(msg2.content).toBe('content');\n\n      ws1.close();\n      ws2.close();\n    });\n\n    it('rejects connection to non-existent document', async () => {\n      return new Promise<void>((resolve) => {\n        const ws = new WebSocket(`ws://localhost:${port}/documents/fake-id/ws`);\n        ws.on('error', () => resolve());\n        ws.on('close', () => resolve());\n      });\n    });\n  });\n\n  describe('Single client editing', () => {\n    it('applies insert operation and acks', async () => {\n      const doc = await createDocument('Edit Test', 'hello');\n      const ws = await connectWs(port, doc.id);\n      const sync = await waitForMessage(ws);\n\n      const ackPromise = waitForMessage(ws);\n      ws.send(JSON.stringify({\n        type: 'operation',\n        operation: { type: 'insert', position: 5, text: ' world' },\n        version: sync.version,\n      }));\n\n      const ack = await ackPromise;\n      expect(ack.type).toBe('ack');\n      expect(ack.version).toBeDefined();\n\n      // Verify via REST\n      const res = await request(instance.app).get(`/documents/${doc.id}`);\n      expect(res.body.content).toBe('hello world');\n\n      ws.close();\n    });\n\n    it('applies delete operation', async () => {\n      const doc = await createDocument('Delete Test', 'hello world');\n      const ws = await connectWs(port, doc.id);\n      const sync = await waitForMessage(ws);\n\n      const ackPromise = waitForMessage(ws);\n      ws.send(JSON.stringify({\n        type: 'operation',\n        operation: { type: 'delete', position: 5, count: 6 },\n        version: sync.version,\n      }));\n\n      const ack = await ackPromise;\n      expect(ack.type).toBe('ack');\n\n      const res = await request(instance.app).get(`/documents/${doc.id}`);\n      expect(res.body.content).toBe('hello');\n\n      ws.close();\n    });\n\n    it('creates version history entries', async () => {\n      const doc = await createDocument('Version Test', '');\n      const ws = await connectWs(port, doc.id);\n      const sync = await waitForMessage(ws);\n\n      const ackPromise = waitForMessage(ws);\n      ws.send(JSON.stringify({\n        type: 'operation',\n        operation: { type: 'insert', position: 0, text: 'first' },\n        version: sync.version,\n      }));\n      const ack = await ackPromise;\n\n      const ack2Promise = waitForMessage(ws);\n      ws.send(JSON.stringify({\n        type: 'operation',\n        operation: { type: 'insert', position: 5, text: ' second' },\n        version: ack.version,\n      }));\n      await ack2Promise;\n\n      const versions = await request(instance.app).get(`/documents/${doc.id}/versions`);\n      expect(versions.body.length).toBeGreaterThanOrEqual(3); // initial + 2 ops\n\n      ws.close();\n    });\n  });\n\n  describe('Two-client convergence', () => {\n    it('broadcasts operations to other clients', async () => {\n      const doc = await createDocument('Broadcast', 'hi');\n\n      const ws1 = await connectWs(port, doc.id);\n      await waitForMessage(ws1); // sync\n\n      const ws2 = await connectWs(port, doc.id);\n      const sync2 = await waitForMessage(ws2); // sync\n\n      // ws2 receives op broadcast from ws1\n      const broadcastPromise = waitForMessage(ws2);\n\n      ws1.send(JSON.stringify({\n        type: 'operation',\n        operation: { type: 'insert', position: 2, text: '!' },\n        version: sync2.version,\n      }));\n\n      // ws1 gets ack\n      await waitForMessage(ws1);\n\n      // ws2 gets broadcast\n      const broadcast = await broadcastPromise;\n      expect(broadcast.type).toBe('operation');\n      expect(broadcast.operation).toEqual({ type: 'insert', position: 2, text: '!' });\n\n      ws1.close();\n      ws2.close();\n    });\n\n    it('concurrent inserts both preserved with convergence', async () => {\n      const doc = await createDocument('Concurrent', 'hello');\n\n      const ws1 = await connectWs(port, doc.id);\n      const sync1 = await waitForMessage(ws1);\n\n      const ws2 = await connectWs(port, doc.id);\n      const sync2 = await waitForMessage(ws2);\n\n      // Both clients insert at the same position simultaneously\n      // ws1 inserts 'A' at position 5\n      // ws2 inserts 'B' at position 5\n      const broadcast1Promise = waitForMessage(ws2);\n      ws1.send(JSON.stringify({\n        type: 'operation',\n        operation: { type: 'insert', position: 5, text: 'A' },\n        version: sync1.version,\n      }));\n      await waitForMessage(ws1); // ack for ws1\n\n      const broadcast2Promise = waitForMessage(ws1);\n      ws2.send(JSON.stringify({\n        type: 'operation',\n        operation: { type: 'insert', position: 5, text: 'B' },\n        version: sync2.version,\n      }));\n      await waitForMessage(ws2); // ack for ws2\n\n      await broadcast1Promise;\n      await broadcast2Promise;\n\n      // Check final document state - both A and B should be present\n      const res = await request(instance.app).get(`/documents/${doc.id}`);\n      const content = res.body.content;\n      expect(content).toContain('A');\n      expect(content).toContain('B');\n      expect(content).toContain('hello');\n      expect(content.length).toBe(7); // \"hello\" + \"A\" + \"B\"\n\n      ws1.close();\n      ws2.close();\n    });\n\n    it('concurrent insert and delete converge', async () => {\n      const doc = await createDocument('Mixed', 'abcdef');\n\n      const ws1 = await connectWs(port, doc.id);\n      const sync1 = await waitForMessage(ws1);\n\n      const ws2 = await connectWs(port, doc.id);\n      const sync2 = await waitForMessage(ws2);\n\n      // ws1 inserts 'X' at position 3\n      ws1.send(JSON.stringify({\n        type: 'operation',\n        operation: { type: 'insert', position: 3, text: 'X' },\n        version: sync1.version,\n      }));\n      await waitForMessage(ws1); // ack\n      await waitForMessage(ws2); // broadcast\n\n      // ws2 deletes first 2 chars, but based on old version\n      ws2.send(JSON.stringify({\n        type: 'operation',\n        operation: { type: 'delete', position: 0, count: 2 },\n        version: sync2.version,\n      }));\n      await waitForMessage(ws2); // ack\n      await waitForMessage(ws1); // broadcast\n\n      // Check result\n      const res = await request(instance.app).get(`/documents/${doc.id}`);\n      expect(res.body.content).toContain('X');\n      // Original was \"abcdef\", insert X at 3 => \"abcXdef\", delete 2 from start => \"cXdef\"\n      expect(res.body.content).toBe('cXdef');\n\n      ws1.close();\n      ws2.close();\n    });\n  });\n\n  describe('Stress test', () => {\n    it('handles 10 concurrent clients without corruption', async () => {\n      const doc = await createDocument('Stress', '');\n      const clients: WebSocket[] = [];\n      const syncs: Record<string, unknown>[] = [];\n\n      // Connect 10 clients\n      for (let i = 0; i < 10; i++) {\n        const ws = await connectWs(port, doc.id);\n        const sync = await waitForMessage(ws);\n        clients.push(ws);\n        syncs.push(sync);\n      }\n\n      // Each client inserts its number\n      const promises: Promise<Record<string, unknown>>[] = [];\n      for (let i = 0; i < 10; i++) {\n        promises.push(waitForMessage(clients[i])); // ack\n        clients[i].send(JSON.stringify({\n          type: 'operation',\n          operation: { type: 'insert', position: 0, text: `${i}` },\n          version: syncs[i].version,\n        }));\n      }\n\n      // Wait for all acks\n      await Promise.all(promises);\n\n      // Wait a moment for broadcasts to settle\n      await new Promise(r => setTimeout(r, 200));\n\n      // Verify document contains all 10 digits\n      const res = await request(instance.app).get(`/documents/${doc.id}`);\n      const content = res.body.content;\n      expect(content.length).toBe(10);\n      for (let i = 0; i < 10; i++) {\n        expect(content).toContain(`${i}`);\n      }\n\n      // Cleanup\n      clients.forEach(ws => ws.close());\n    });\n  });\n\n  describe('Error handling', () => {\n    it('rejects invalid operation type', async () => {\n      const doc = await createDocument('Error Test', 'hello');\n      const ws = await connectWs(port, doc.id);\n      await waitForMessage(ws); // sync\n\n      const errPromise = waitForMessage(ws);\n      ws.send(JSON.stringify({\n        type: 'operation',\n        operation: { type: 'unknown', position: 0 },\n        version: 1,\n      }));\n\n      const err = await errPromise;\n      expect(err.type).toBe('error');\n\n      ws.close();\n    });\n\n    it('rejects malformed JSON', async () => {\n      const doc = await createDocument('Bad JSON', 'hello');\n      const ws = await connectWs(port, doc.id);\n      await waitForMessage(ws); // sync\n\n      const errPromise = waitForMessage(ws);\n      ws.send('not valid json{{{');\n\n      const err = await errPromise;\n      expect(err.type).toBe('error');\n\n      ws.close();\n    });\n\n    it('rejects out-of-bounds operations', async () => {\n      const doc = await createDocument('Bounds Test', 'hi');\n      const ws = await connectWs(port, doc.id);\n      const sync = await waitForMessage(ws);\n\n      const errPromise = waitForMessage(ws);\n      ws.send(JSON.stringify({\n        type: 'operation',\n        operation: { type: 'delete', position: 0, count: 100 },\n        version: sync.version,\n      }));\n\n      const err = await errPromise;\n      expect(err.type).toBe('error');\n\n      ws.close();\n    });\n\n    it('does not crash on invalid operation', async () => {\n      const doc = await createDocument('Crash Test', 'hello');\n      const ws = await connectWs(port, doc.id);\n      await waitForMessage(ws); // sync\n\n      // Send invalid op\n      ws.send(JSON.stringify({\n        type: 'operation',\n        operation: { type: 'insert', position: -5, text: 'bad' },\n        version: 1,\n      }));\n\n      const err = await waitForMessage(ws);\n      expect(err.type).toBe('error');\n\n      // Server should still be alive - send a valid op\n      ws.send(JSON.stringify({\n        type: 'operation',\n        operation: { type: 'insert', position: 0, text: 'still alive' },\n        version: 1,\n      }));\n\n      const ack = await waitForMessage(ws);\n      expect(ack.type).toBe('ack');\n\n      ws.close();\n    });\n  });\n});\n"}}
