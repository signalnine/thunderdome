+export enum TokenType {
+  Number = 'Number',
+  String = 'String',
+  Boolean = 'Boolean',
+  CellRef = 'CellRef',
+  Operator = 'Operator',
+  LParen = 'LParen',
+  RParen = 'RParen',
+  Comma = 'Comma',
+  Colon = 'Colon',
+  Function = 'Function',
+}
+
+export interface Token {
+  type: TokenType;
+  value: string;
+}
+
+export function tokenize(input: string): Token[] {
+  const tokens: Token[] = [];
+  let i = 0;
+
+  while (i < input.length) {
+    // Skip whitespace
+    if (/\s/.test(input[i])) { i++; continue; }
+
+    // String literals
+    if (input[i] === '"') {
+      i++; // skip opening quote
+      let str = '';
+      while (i < input.length && input[i] !== '"') {
+        str += input[i++];
+      }
+      i++; // skip closing quote
+      tokens.push({ type: TokenType.String, value: str });
+      continue;
+    }
+
+    // Two-char comparison operators
+    if (i + 1 < input.length) {
+      const two = input[i] + input[i + 1];
+      if (two === '>=' || two === '<=' || two === '<>') {
+        tokens.push({ type: TokenType.Operator, value: two });
+        i += 2;
+        continue;
+      }
+    }
+
+    // Single-char operators and punctuation
+    if ('+-*/'.includes(input[i])) {
+      tokens.push({ type: TokenType.Operator, value: input[i] });
+      i++; continue;
+    }
+    if (input[i] === '>' || input[i] === '<' || input[i] === '=') {
+      tokens.push({ type: TokenType.Operator, value: input[i] });
+      i++; continue;
+    }
+    if (input[i] === '(') { tokens.push({ type: TokenType.LParen, value: '(' }); i++; continue; }
+    if (input[i] === ')') { tokens.push({ type: TokenType.RParen, value: ')' }); i++; continue; }
+    if (input[i] === ',') { tokens.push({ type: TokenType.Comma, value: ',' }); i++; continue; }
+    if (input[i] === ':') { tokens.push({ type: TokenType.Colon, value: ':' }); i++; continue; }
+
+    // Numbers
+    if (/\d/.test(input[i]) || (input[i] === '.' && i + 1 < input.length && /\d/.test(input[i + 1]))) {
+      let num = '';
+      while (i < input.length && (/\d/.test(input[i]) || input[i] === '.')) {
+        num += input[i++];
+      }
+      tokens.push({ type: TokenType.Number, value: num });
+      continue;
+    }
+
+    // Identifiers: cell refs, function names, booleans
+    if (/[A-Za-z]/.test(input[i])) {
+      let id = '';
+      while (i < input.length && /[A-Za-z0-9]/.test(input[i])) {
+        id += input[i++];
+      }
+      const upper = id.toUpperCase();
+      if (upper === 'TRUE' || upper === 'FALSE') {
+        tokens.push({ type: TokenType.Boolean, value: upper.toLowerCase() });
+      } else if (i < input.length && input[i] === '(') {
+        tokens.push({ type: TokenType.Function, value: upper });
+      } else if (/^[A-Z]+\d+$/i.test(id)) {
+        tokens.push({ type: TokenType.CellRef, value: id.toUpperCase() });
+      } else {
+        tokens.push({ type: TokenType.Function, value: upper });
+      }
+      continue;
+    }
+
+    throw new Error(`Unexpected character: ${input[i]}`);
+  }
+
+  return tokens;
+}
