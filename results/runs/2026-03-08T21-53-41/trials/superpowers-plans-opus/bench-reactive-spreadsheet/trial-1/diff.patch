--- /dev/null
+++ b/src/parser.ts
@@ -0,0 +1,131 @@
+import { tokenize, Token, TokenType } from './tokenizer.js';
+
+export enum NodeType {
+  Number = 'Number',
+  String = 'String',
+  Boolean = 'Boolean',
+  CellRef = 'CellRef',
+  BinaryOp = 'BinaryOp',
+  FunctionCall = 'FunctionCall',
+  Range = 'Range',
+}
+
+export type ASTNode =
+  | { type: NodeType.Number; value: number }
+  | { type: NodeType.String; value: string }
+  | { type: NodeType.Boolean; value: boolean }
+  | { type: NodeType.CellRef; ref: string }
+  | { type: NodeType.BinaryOp; op: string; left: ASTNode; right: ASTNode }
+  | { type: NodeType.FunctionCall; name: string; args: ASTNode[] }
+  | { type: NodeType.Range; start: string; end: string };
+
+export function parse(input: string): ASTNode {
+  const tokens = tokenize(input);
+  let pos = 0;
+
+  function peek(): Token | undefined { return tokens[pos]; }
+  function advance(): Token { return tokens[pos++]; }
+
+  function parseExpression(): ASTNode {
+    return parseComparison();
+  }
+
+  function parseComparison(): ASTNode {
+    let left = parseAddSub();
+    while (peek() && peek()!.type === TokenType.Operator &&
+           ['>', '<', '>=', '<=', '=', '<>'].includes(peek()!.value)) {
+      const op = advance().value;
+      const right = parseAddSub();
+      left = { type: NodeType.BinaryOp, op, left, right };
+    }
+    return left;
+  }
+
+  function parseAddSub(): ASTNode {
+    let left = parseMulDiv();
+    while (peek() && peek()!.type === TokenType.Operator &&
+           (peek()!.value === '+' || peek()!.value === '-')) {
+      const op = advance().value;
+      const right = parseMulDiv();
+      left = { type: NodeType.BinaryOp, op, left, right };
+    }
+    return left;
+  }
+
+  function parseMulDiv(): ASTNode {
+    let left = parseUnary();
+    while (peek() && peek()!.type === TokenType.Operator &&
+           (peek()!.value === '*' || peek()!.value === '/')) {
+      const op = advance().value;
+      const right = parseUnary();
+      left = { type: NodeType.BinaryOp, op, left, right };
+    }
+    return left;
+  }
+
+  function parseUnary(): ASTNode {
+    if (peek() && peek()!.type === TokenType.Operator && peek()!.value === '-') {
+      advance();
+      const operand = parseUnary();
+      return { type: NodeType.BinaryOp, op: '*', left: { type: NodeType.Number, value: -1 }, right: operand };
+    }
+    return parsePrimary();
+  }
+
+  function parsePrimary(): ASTNode {
+    const token = peek();
+    if (!token) throw new Error('Unexpected end of formula');
+
+    if (token.type === TokenType.Number) {
+      advance();
+      return { type: NodeType.Number, value: parseFloat(token.value) };
+    }
+
+    if (token.type === TokenType.String) {
+      advance();
+      return { type: NodeType.String, value: token.value };
+    }
+
+    if (token.type === TokenType.Boolean) {
+      advance();
+      return { type: NodeType.Boolean, value: token.value === 'true' };
+    }
+
+    if (token.type === TokenType.CellRef) {
+      advance();
+      // Check for range
+      if (peek() && peek()!.type === TokenType.Colon) {
+        advance(); // consume ':'
+        const endToken = advance();
+        return { type: NodeType.Range, start: token.value, end: endToken.value };
+      }
+      return { type: NodeType.CellRef, ref: token.value };
+    }
+
+    if (token.type === TokenType.Function) {
+      const name = advance().value;
+      advance(); // consume '('
+      const args: ASTNode[] = [];
+      if (peek() && peek()!.type !== TokenType.RParen) {
+        args.push(parseExpression());
+        while (peek() && peek()!.type === TokenType.Comma) {
+          advance(); // consume ','
+          args.push(parseExpression());
+        }
+      }
+      advance(); // consume ')'
+      return { type: NodeType.FunctionCall, name, args };
+    }
+
+    if (token.type === TokenType.LParen) {
+      advance(); // consume '('
+      const expr = parseExpression();
+      advance(); // consume ')'
+      return expr;
+    }
+
+    throw new Error(`Unexpected token: ${token.type} (${token.value})`);
+  }
+
+  return parseExpression();
+}
