@@ -0,0 +1,48 @@
+import { describe, it, expect } from 'vitest';
+import { parseCellRef, cellRefToString, columnToNumber, numberToColumn } from './cellRef.js';
+
+describe('cellRef', () => {
+  describe('columnToNumber', () => {
+    it('converts single letters', () => {
+      expect(columnToNumber('A')).toBe(0);
+      expect(columnToNumber('B')).toBe(1);
+      expect(columnToNumber('Z')).toBe(25);
+    });
+    it('converts double letters', () => {
+      expect(columnToNumber('AA')).toBe(26);
+      expect(columnToNumber('AZ')).toBe(51);
+      expect(columnToNumber('BA')).toBe(52);
+    });
+  });
+
+  describe('numberToColumn', () => {
+    it('converts numbers to column letters', () => {
+      expect(numberToColumn(0)).toBe('A');
+      expect(numberToColumn(25)).toBe('Z');
+      expect(numberToColumn(26)).toBe('AA');
+      expect(numberToColumn(51)).toBe('AZ');
+      expect(numberToColumn(52)).toBe('BA');
+    });
+  });
+
+  describe('parseCellRef', () => {
+    it('parses simple refs', () => {
+      expect(parseCellRef('A1')).toEqual({ col: 0, row: 0 });
+      expect(parseCellRef('B2')).toEqual({ col: 1, row: 1 });
+      expect(parseCellRef('Z100')).toEqual({ col: 25, row: 99 });
+    });
+    it('parses multi-letter columns', () => {
+      expect(parseCellRef('AA1')).toEqual({ col: 26, row: 0 });
+    });
+    it('is case-insensitive', () => {
+      expect(parseCellRef('a1')).toEqual({ col: 0, row: 0 });
+    });
+  });
+
+  describe('cellRefToString', () => {
+    it('converts back to string', () => {
+      expect(cellRefToString({ col: 0, row: 0 })).toBe('A1');
+      expect(cellRefToString({ col: 26, row: 0 })).toBe('AA1');
+    });
+  });
+});
diff --git a/src/cellRef.ts b/src/cellRef.ts
new file mode 100644
index 0000000..8a095ac
--- /dev/null
+++ b/src/cellRef.ts
@@ -0,0 +1,36 @@
+export interface CellRef {
+  col: number; // 0-based
+  row: number; // 0-based
+}
+
+export function columnToNumber(col: string): number {
+  let result = 0;
+  const upper = col.toUpperCase();
+  for (let i = 0; i < upper.length; i++) {
+    result = result * 26 + (upper.charCodeAt(i) - 64);
+  }
+  return result - 1;
+}
+
+export function numberToColumn(num: number): string {
+  let result = '';
+  let n = num;
+  do {
+    result = String.fromCharCode(65 + (n % 26)) + result;
+    n = Math.floor(n / 26) - 1;
+  } while (n >= 0);
+  return result;
+}
+
+export function parseCellRef(ref: string): CellRef {
+  const match = ref.toUpperCase().match(/^([A-Z]+)(\d+)$/);
+  if (!match) throw new Error(`Invalid cell reference: ${ref}`);
+  return {
+    col: columnToNumber(match[1]),
+    row: parseInt(match[2], 10) - 1,
+  };
+}
+
+export function cellRefToString(ref: CellRef): string {
+  return numberToColumn(ref.col) + (ref.row + 1);
+}
