+// src/evaluator.ts
+import { ASTNode, NodeType } from './parser';
+import { parseCellRef, cellRefToString } from './cellRef';
+
+export type CellGetter = (ref: string) => string | number | boolean | null;
+
+export function expandRange(start: string, end: string): string[] {
+  const s = parseCellRef(start);
+  const e = parseCellRef(end);
+  const refs: string[] = [];
+  const minCol = Math.min(s.col, e.col);
+  const maxCol = Math.max(s.col, e.col);
+  const minRow = Math.min(s.row, e.row);
+  const maxRow = Math.max(s.row, e.row);
+  for (let col = minCol; col <= maxCol; col++) {
+    for (let row = minRow; row <= maxRow; row++) {
+      refs.push(cellRefToString({ col, row }));
+    }
+  }
+  return refs;
+}
+
+export function evaluate(node: ASTNode, getCellValue: CellGetter): string | number | boolean | null {
+  switch (node.type) {
+    case NodeType.Number:
+      return node.value;
+    case NodeType.String:
+      return node.value;
+    case NodeType.Boolean:
+      return node.value;
+    case NodeType.CellRef: {
+      const val = getCellValue(node.ref);
+      return val ?? 0;
+    }
+    case NodeType.BinaryOp: {
+      const left = evaluate(node.left, getCellValue);
+      const right = evaluate(node.right, getCellValue);
+      const l = typeof left === 'number' ? left : 0;
+      const r = typeof right === 'number' ? right : 0;
+      switch (node.op) {
+        case '+': return l + r;
+        case '-': return l - r;
+        case '*': return l * r;
+        case '/': return l / r;
+        case '>': return l > r;
+        case '<': return l < r;
+        case '>=': return l >= r;
+        case '<=': return l <= r;
+        case '=': return left === right;
+        case '<>': return left !== right;
+        default: throw new Error(`Unknown operator: ${node.op}`);
+      }
+    }
+    case NodeType.FunctionCall: {
+      const { name, args } = node;
+      if (name === 'IF') {
+        const condition = evaluate(args[0], getCellValue);
+        return condition ? evaluate(args[1], getCellValue) : evaluate(args[2], getCellValue);
+      }
+      // For aggregate functions, expand ranges and collect values
+      const values: number[] = [];
+      for (const arg of args) {
+        if (arg.type === NodeType.Range) {
+          const refs = expandRange(arg.start, arg.end);
+          for (const ref of refs) {
+            const val = getCellValue(ref);
+            if (typeof val === 'number') values.push(val);
+          }
+        } else {
+          const val = evaluate(arg, getCellValue);
+          if (typeof val === 'number') values.push(val);
+        }
+      }
+      switch (name) {
+        case 'SUM': return values.reduce((a, b) => a + b, 0);
+        case 'AVERAGE': return values.length > 0 ? values.reduce((a, b) => a + b, 0) / values.length : 0;
+        case 'MIN': return Math.min(...values);
+        case 'MAX': return Math.max(...values);
+        case 'COUNT': return values.length;
+        default: throw new Error(`Unknown function: ${name}`);
+      }
+    }
+    case NodeType.Range:
+      throw new Error('Range cannot be evaluated outside of a function');
+    default:
+      throw new Error(`Unknown node type`);
+  }
+}
+```
