all = 'FunctionCall',\n  Range = 'Range',\n}\n\nexport type ASTNode =\n  | { type: NodeType.Number; value: number }\n  | { type: NodeType.String; value: string }\n  | { type: NodeType.Boolean; value: boolean }\n  | { type: NodeType.CellRef; ref: string }\n  | { type: NodeType.BinaryOp; op: string; left: ASTNode; right: ASTNode }\n  | { type: NodeType.FunctionCall; name: string; args: ASTNode[] }\n  | { type: NodeType.Range; start: string; end: string };\n\nexport function parse(input: string): ASTNode {\n  const tokens = tokenize(input);\n  let pos = 0;\n\n  function peek(): Token | undefined { return tokens[pos]; }\n  function advance(): Token { return tokens[pos++]; }\n\n  function parseExpression(): ASTNode {\n    return parseComparison();\n  }\n\n  function parseComparison(): ASTNode {\n    let left = parseAddSub();\n    while (peek() && peek()!.type === TokenType.Operator &&\n           ['>', '<', '>=', '<=', '=', '<>'].includes(peek()!.value)) {\n      const op = advance().value;\n      const right = parseAddSub();\n      left = { type: NodeType.BinaryOp, op, left, right };\n    }\n    return left;\n  }\n\n  function parseAddSub(): ASTNode {\n    let left = parseMulDiv();\n    while (peek() && peek()!.type === TokenType.Operator &&\n           (peek()!.value === '+' || peek()!.value === '-')) {\n      const op = advance().value;\n      const right = parseMulDiv();\n      left = { type: NodeType.BinaryOp, op, left, right };\n    }\n    return left;\n  }\n\n  function parseMulDiv(): ASTNode {\n    let left = parseUnary();\n    while (peek() && peek()!.type === TokenType.Operator &&\n           (peek()!.value === '*' || peek()!.value === '/')) {\n      const op = advance().value;\n      const right = parseUnary();\n      left = { type: NodeType.BinaryOp, op, left, right };\n    }\n    return left;\n  }\n\n  function parseUnary(): ASTNode {\n    if (peek() && peek()!.type === TokenType.Operator && peek()!.value === '-') {\n      advance();\n      const operand = p