@@ -0,0 +1,61 @@
+import { describe, it, expect } from 'vitest';
+import { DependencyGraph } from './depGraph.js';
+
+describe('DependencyGraph', () => {
+  it('tracks dependencies', () => {
+    const graph = new DependencyGraph();
+    graph.setDependencies('B1', ['A1']);
+    expect(graph.getDependents('A1')).toEqual(new Set(['B1']));
+  });
+
+  it('tracks transitive dependents', () => {
+    const graph = new DependencyGraph();
+    graph.setDependencies('B1', ['A1']);
+    graph.setDependencies('C1', ['B1']);
+    expect(graph.getDependents('A1')).toEqual(new Set(['B1']));
+    expect(graph.getDependents('B1')).toEqual(new Set(['C1']));
+  });
+
+  it('clears old dependencies when updated', () => {
+    const graph = new DependencyGraph();
+    graph.setDependencies('B1', ['A1']);
+    graph.setDependencies('B1', ['A2']);
+    expect(graph.getDependents('A1')).toEqual(new Set());
+    expect(graph.getDependents('A2')).toEqual(new Set(['B1']));
+  });
+
+  it('detects direct circular reference', () => {
+    const graph = new DependencyGraph();
+    graph.setDependencies('B1', ['A1']);
+    expect(() => graph.setDependencies('A1', ['B1'])).toThrow(/circular/i);
+  });
+
+  it('detects indirect circular reference', () => {
+    const graph = new DependencyGraph();
+    graph.setDependencies('B1', ['A1']);
+    graph.setDependencies('C1', ['B1']);
+    expect(() => graph.setDependencies('A1', ['C1'])).toThrow(/circular/i);
+  });
+
+  it('detects self-reference', () => {
+    const graph = new DependencyGraph();
+    expect(() => graph.setDependencies('A1', ['A1'])).toThrow(/circular/i);
+  });
+
+  it('returns topological order for evaluation', () => {
+    const graph = new DependencyGraph();
+    graph.setDependencies('B1', ['A1']);
+    graph.setDependencies('C1', ['B1']);
+    const order = graph.getEvaluationOrder('A1');
+    expect(order.indexOf('B1')).toBeLessThan(order.indexOf('C1'));
+    expect(order).toContain('B1');
+    expect(order).toContain('C1');
+  });
+
+  it('removes dependencies for a cell', () => {
+    const graph = new DependencyGraph();
+    graph.setDependencies('B1', ['A1']);
+    graph.removeDependencies('B1');
+    expect(graph.getDependents('A1')).toEqual(new Set());
+  });
+});
diff --git a/src/depGraph.ts b/src/depGraph.ts
new file mode 100644
index 0000000..7214ca0
--- /dev/null
+++ b/src/depGraph.ts
@@ -0,0 +1,85 @@
+export class DependencyGraph {
+  // cell -> set of cells it depends on
+  private dependencies: Map<string, Set<string>> = new Map();
+  // cell -> set of cells that depend on it
+  private dependents: Map<string, Set<string>> = new Map();
+
+  setDependencies(cell: string, deps: string[]): void {
+    // Check for circular references before committing
+    for (const dep of deps) {
+      if (dep === cell) throw new Error(`Circular reference detected: ${cell} depends on itself`);
+      if (this.wouldCreateCycle(cell, dep)) {
+        throw new Error(`Circular reference detected: ${cell} -> ${dep} creates a cycle`);
+      }
+    }
+
+    // Clear old dependencies
+    this.removeDependencies(cell);
+
+    // Set new dependencies
+    const depSet = new Set(deps);
+    this.dependencies.set(cell, depSet);
+    for (const dep of deps) {
+      if (!this.dependents.has(dep)) {
+        this.dependents.set(dep, new Set());
+      }
+      this.dependents.get(dep)!.add(cell);
+    }
+  }
+
+  removeDependencies(cell: string): void {
+    const oldDeps = this.dependencies.get(cell);
+    if (oldDeps) {
+      for (const dep of oldDeps) {
+        this.dependents.get(dep)?.delete(cell);
+      }
+    }
+    this.dependencies.delete(cell);
+  }
+
+  getDependents(cell: string): Set<string> {
+    return this.dependents.get(cell) ?? new Set();
+  }
+
+  getEvaluationOrder(changedCell: string): string[] {
+    // BFS to get dependents in topological order (closest first)
+    const order: string[] = [];
+    const visited = new Set<string>();
+    const queue: string[] = [changedCell];
+    visited.add(changedCell);
+
+    while (queue.length > 0) {
+      const cell = queue.shift()!;
+      const deps = this.dependents.get(cell);
+      if (!deps) continue;
+      for (const dep of deps) {
+        if (!visited.has(dep)) {
+          visited.add(dep);
+          order.push(dep);
+          queue.push(dep);
+        }
+      }
+    }
+
+    return order;
+  }
+
+  private wouldCreateCycle(cell: string, dep: string): boolean {
+    // Check if 'cell' is reachable from 'dep' following the dependencies graph
+    const visited = new Set<string>();
+    const stack = [dep];
+    while (stack.length > 0) {
+      const current = stack.pop()!;
+      if (current === cell) return true;
+      if (visited.has(current)) continue;
+      visited.add(current);
+      const currentDeps = this.dependencies.get(current);
+      if (currentDeps) {
+        for (const d of currentDeps) {
+          stack.push(d);
+        }
+      }
+    }
+    return false;
+  }
+}
