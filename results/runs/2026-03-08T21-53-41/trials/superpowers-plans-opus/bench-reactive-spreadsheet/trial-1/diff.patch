r (const ref of expandRange(n.start, n.end)) {\n          deps.push(ref);\n        }\n        break;\n      case NodeType.BinaryOp:\n        visit(n.left);\n        visit(n.right);\n        break;\n      case NodeType.FunctionCall:\n        for (const arg of n.args) {\n          visit(arg);\n        }\n        break;\n    }\n  };\n  visit(node);\n  return deps;\n}\n\nexport class Spreadsheet {\n  private cells: Map<string, CellData> = new Map();\n  private depGraph: DependencyGraph = new DependencyGraph();\n\n  set(cell: string, value: string | number | boolean): void {\n    const ref = normalizeRef(cell);\n\n    if (typeof value === 'string' && value.startsWith('=')) {\n      const formulaStr = value.slice(1);\n      const ast = parse(formulaStr);\n      const deps = extractDependencies(ast);\n\n      // Set dependencies (will throw on circular reference)\n      this.depGraph.setDependencies(ref, deps);\n\n      const computedValue = this.evaluateNode(ast);\n      this.cells.set(ref, { rawValue: value, formula: ast, computedValue });\n    } else {\n      // Raw value - remove any old dependencies\n      this.depGraph.removeDependencies(ref);\n      this.cells.set(ref, { rawValue: value, formula: null, computedValue: value });\n    }\n\n    // Reactively update all dependents\n    this.propagateUpdates(ref);\n  }\n\n  get(cell: string): string | number | boolean | null {\n    const ref = normalizeRef(cell);\n    const data = this.cells.get(ref);\n    if (!data) return null;\n    return data.computedValue;\n  }\n\n  getDisplay(cell: string): string {\n    const value = this.get(cell);\n    if (value === null) return '';\n    return String(value);\n  }\n\n  getCells(): Map<string, any> {\n    const result = new Map<string, any>();\n    for (const [ref, data] of this.cells) {\n      result.set(ref, data.computedValue);\n    }\n    return result;\n  }\n\n  private evaluateNode(ast: ASTNode): string | number | boolean | null {\n    const getter: CellGetter = (ref: string