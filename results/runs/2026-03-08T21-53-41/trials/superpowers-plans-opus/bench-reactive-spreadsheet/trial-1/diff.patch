+type FunctionCallNode = Extract<ASTNode, { type: NodeType.FunctionCall }>;
+
+describe('parser', () => {
+  it('parses a number', () => {
+    const ast = parse('42');
+    expect(ast).toEqual({ type: NodeType.Number, value: 42 });
+  });
+
+  it('parses a string', () => {
+    const ast = parse('"hello"');
+    expect(ast).toEqual({ type: NodeType.String, value: 'hello' });
+  });
+
+  it('parses a boolean', () => {
+    const ast = parse('true');
+    expect(ast).toEqual({ type: NodeType.Boolean, value: true });
+  });
+
+  it('parses a cell reference', () => {
+    const ast = parse('A1');
+    expect(ast).toEqual({ type: NodeType.CellRef, ref: 'A1' });
+  });
+
+  it('parses addition', () => {
+    const ast = parse('A1+B1') as BinaryOpNode;
+    expect(ast.type).toBe(NodeType.BinaryOp);
+    expect(ast.op).toBe('+');
+  });
+
+  it('respects operator precedence (* before +)', () => {
+    const ast = parse('A1+B1*C1') as BinaryOpNode;
+    expect(ast.type).toBe(NodeType.BinaryOp);
+    expect(ast.op).toBe('+');
+    expect((ast.right as BinaryOpNode).op).toBe('*');
+  });
+
+  it('parses parentheses', () => {
+    const ast = parse('(A1+B1)*2') as BinaryOpNode;
+    expect(ast.type).toBe(NodeType.BinaryOp);
+    expect(ast.op).toBe('*');
+    expect((ast.left as BinaryOpNode).op).toBe('+');
+  });
+
+  it('parses function calls with range', () => {
+    const ast = parse('SUM(A1:A5)') as FunctionCallNode;
+    expect(ast.type).toBe(NodeType.FunctionCall);
+    expect(ast.name).toBe('SUM');
+    expect(ast.args).toHaveLength(1);
+    expect(ast.args[0].type).toBe(NodeType.Range);
+  });
+
+  it('parses IF with three arguments', () => {
