+    expect(ast.type).toBe(NodeType.BinaryOp);
+    expect(ast.op).toBe('>=');
+  });
+
+  it('parses negative numbers (unary minus)', () => {
+    const ast = parse('-5') as BinaryOpNode;
+    expect(ast.type).toBe(NodeType.BinaryOp);
+    expect(ast.op).toBe('*');
+  });
+
+  it('parses block ranges', () => {
