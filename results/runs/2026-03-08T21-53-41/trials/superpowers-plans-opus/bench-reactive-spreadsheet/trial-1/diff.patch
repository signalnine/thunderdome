+// src/cellRef.ts
+export interface CellRef {
+  col: number; // 0-based
+  row: number; // 0-based
+}
+
+export function columnToNumber(col: string): number {
+  let result = 0;
+  const upper = col.toUpperCase();
+  for (let i = 0; i < upper.length; i++) {
+    result = result * 26 + (upper.charCodeAt(i) - 64);
+  }
+  return result - 1;
+}
+
+export function numberToColumn(num: number): string {
+  let result = '';
+  let n = num;
+  do {
+    result = String.fromCharCode(65 + (n % 26)) + result;
+    n = Math.floor(n / 26) - 1;
+  } while (n >= 0);
+  return result;
+}
+
+export function parseCellRef(ref: string): CellRef {
+  const match = ref.toUpperCase().match(/^([A-Z]+)(\d+)$/);
+  if (!match) throw new Error(`Invalid cell reference: ${ref}`);
+  return {
+    col: columnToNumber(match[1]),
+    row: parseInt(match[2], 10) - 1,
+  };
+}
+
+export function cellRefToString(ref: CellRef): string {
+  return numberToColumn(ref.col) + (ref.row + 1);
+}
+```
