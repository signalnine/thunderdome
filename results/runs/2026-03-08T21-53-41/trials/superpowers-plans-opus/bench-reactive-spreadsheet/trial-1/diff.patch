+import { describe, it, expect } from 'vitest';
+import { evaluate } from './evaluator.js';
+import { parse } from './parser.js';
+
+describe('evaluator', () => {
+  const emptyCellGetter = (_ref: string): string | number | boolean | null => null;
+
+  it('evaluates numbers', () => {
+    expect(evaluate(parse('42'), emptyCellGetter)).toBe(42);
+  });
+
+  it('evaluates strings', () => {
+    expect(evaluate(parse('"hello"'), emptyCellGetter)).toBe('hello');
+  });
+
+  it('evaluates booleans', () => {
+    expect(evaluate(parse('true'), emptyCellGetter)).toBe(true);
+  });
+
+  it('evaluates addition', () => {
+    expect(evaluate(parse('2+3'), emptyCellGetter)).toBe(5);
+  });
+
+  it('evaluates multiplication', () => {
+    expect(evaluate(parse('2*3'), emptyCellGetter)).toBe(6);
+  });
+
+  it('evaluates division', () => {
+    expect(evaluate(parse('10/4'), emptyCellGetter)).toBe(2.5);
+  });
+
+  it('evaluates subtraction', () => {
+    expect(evaluate(parse('10-3'), emptyCellGetter)).toBe(7);
+  });
+
+  it('evaluates cell references', () => {
+    const getter = (ref: string) => ref === 'A1' ? 10 : null;
+    expect(evaluate(parse('A1'), getter)).toBe(10);
+  });
+
+  it('evaluates comparison >', () => {
+    expect(evaluate(parse('5>3'), emptyCellGetter)).toBe(true);
+  });
+
+  it('evaluates comparison <>', () => {
+    expect(evaluate(parse('5<>3'), emptyCellGetter)).toBe(true);
+    expect(evaluate(parse('5<>5'), emptyCellGetter)).toBe(false);
+  });
+
+  it('evaluates comparison =', () => {
+    expect(evaluate(parse('5=5'), emptyCellGetter)).toBe(true);
+  });
+
+  describe('functions', () => {
+    const getter = (ref: string): number | null => {
+      const vals: Record<string, number> = { A1: 1, A2: 2, A3: 3, A4: 4, A5: 5 };
+      return vals[ref] ?? null;
+    };
+
+    it('evaluates SUM', () => {
+      expect(evaluate(parse('SUM(A1:A5)'), getter)).toBe(15);
+    });
+
+    it('evaluates AVERAGE', () => {
+      expect(evaluate(parse('AVERAGE(A1:A5)'), getter)).toBe(3);
+    });
+
+    it('evaluates MIN', () => {
+      expect(evaluate(parse('MIN(A1:A5)'), getter)).toBe(1);
+    });
+
+    it('evaluates MAX', () => {
+      expect(evaluate(parse('MAX(A1:A5)'), getter)).toBe(5);
+    });
+
+    it('evaluates COUNT', () => {
+      expect(evaluate(parse('COUNT(A1:A5)'), getter)).toBe(5);
+    });
+
+    it('evaluates IF true branch', () => {
+      expect(evaluate(parse('IF(5>3,1,2)'), emptyCellGetter)).toBe(1);
+    });
+
+    it('evaluates IF false branch', () => {
+      expect(evaluate(parse('IF(3>5,1,2)'), emptyCellGetter)).toBe(2);
+    });
+
+    it('evaluates IF with string results', () => {
