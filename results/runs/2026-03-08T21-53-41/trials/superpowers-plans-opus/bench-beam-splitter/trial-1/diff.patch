+type Direction = 'down' | 'down-left' | 'down-right';
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+function findSource(grid: string[][]): [number, number] {
+  for (let r = 0; r < grid.length; r++) {
+    for (let c = 0; c < grid[0].length; c++) {
+      if (grid[r][c] === 'S') return [r, c];
+    }
+  }
+  return [-1, -1];
+}
+
+/**
+ * Count the number of distinct cells visited by any beam.
+ * Uses BFS simulation tracking (row, col, direction) states.
+ */
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  if (rows === 0) return 0;
+  const cols = grid[0].length;
+
+  const [sourceRow, sourceCol] = findSource(grid);
+  if (sourceRow === -1) return 0;
+
+  const visited = new Set<string>();
+  const seen = new Set<string>();
+  const beams: Beam[] = [{ row: sourceRow, col: sourceCol, dir: 'down' }];
+
+  while (beams.length > 0) {
+    const beam = beams.pop()!;
+    const key = `${beam.row},${beam.col},${beam.dir}`;
+    if (seen.has(key)) continue;
+    seen.add(key);
+    visited.add(`${beam.row},${beam.col}`);
+
+    if (grid[beam.row][beam.col] === '^') {
+      if (inBounds(beam.row + 1, beam.col - 1, rows, cols))
+        beams.push({ row: beam.row + 1, col: beam.col - 1, dir: 'down-left' });
+      if (inBounds(beam.row + 1, beam.col + 1, rows, cols))
+        beams.push({ row: beam.row + 1, col: beam.col + 1, dir: 'down-right' });
+    } else {
+      let nc: number;
+      switch (beam.dir) {
+        case 'down': nc = beam.col; break;
+        case 'down-left': nc = beam.col - 1; break;
+        case 'down-right': nc = beam.col + 1; break;
+      }
+      if (inBounds(beam.row + 1, nc, rows, cols))
+        beams.push({ row: beam.row + 1, col: nc, dir: beam.dir });
+    }
+  }
+
+  return visited.size;
+}
+
+/**
+ * Count total distinct source-to-exit paths through the grid.
+ * Uses row-by-row counter propagation with bigint instead of
+ * enumerating individual paths.
+ */
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  if (rows === 0) return 0n;
+  const cols = grid[0].length;
+
+  const [sourceRow, sourceCol] = findSource(grid);
+  if (sourceRow === -1) return 0n;
+
+  const makeKey = (col: number, dir: Direction): string => `${col},${dir}`;
+
+  let current = new Map<string, bigint>();
+  current.set(makeKey(sourceCol, 'down'), 1n);
+  let totalExited = 0n;
+
+  for (let r = sourceRow; r < rows; r++) {
+    const next = new Map<string, bigint>();
+
+    for (const [key, count] of current) {
+      const [colStr, dir] = key.split(',') as [string, Direction];
+      const col = parseInt(colStr, 10);
+
+      if (grid[r][col] === '^') {
+        const lc = col - 1, rc = col + 1;
+        if (r + 1 < rows && lc >= 0 && lc < cols) {
+          const k = makeKey(lc, 'down-left');
+          next.set(k, (next.get(k) ?? 0n) + count);
+        } else {
+          totalExited += count;
+        }
+        if (r + 1 < rows && rc >= 0 && rc < cols) {
+          const k = makeKey(rc, 'down-right');
+          next.set(k, (next.get(k) ?? 0n) + count);
+        } else {
+          totalExited += count;
+        }
+      } else {
+        let nc: number;
+        switch (dir) {
+          case 'down': nc = col; break;
+          case 'down-left': nc = col - 1; break;
+          case 'down-right': nc = col + 1; break;
+        }
+        if (r + 1 < rows && nc >= 0 && nc < cols) {
+          const k = makeKey(nc, dir);
+          next.set(k, (next.get(k) ?? 0n) + count);
+        } else {
+          totalExited += count;
+        }
+      }
+    }
+
+    current = next;
+  }
+
+  for (const [_, count] of current) {
+    totalExited += count;
+  }
+
+  return totalExited;
+}
