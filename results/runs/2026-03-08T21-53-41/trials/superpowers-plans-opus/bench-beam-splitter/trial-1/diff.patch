+/**
+ * Discovery layer for the beam splitter implementation.
+ *
+ * Dynamically imports from ../src/ and tries to find countBeamCells and
+ * countBeamPaths functions regardless of how the implementor exported them.
+ */
+
+export interface BeamAPI {
+  countBeamCells: (grid: string[][]) => number;
+  countBeamPaths: (grid: string[][]) => bigint;
+}
+
+const COUNT_CELLS_ALIASES = [
+  'countBeamCells', 'countCells', 'beamCells', 'visitedCells',
+  'countVisited', 'simulate', 'traceBeam', 'countHits',
+];
+const COUNT_PATHS_ALIASES = [
+  'countBeamPaths', 'countPaths', 'beamPaths', 'totalPaths',
+  'pathCount', 'countDistinctPaths', 'numPaths',
+];
+
+function findFunction(obj: any, aliases: string[]): ((...args: any[]) => any) | null {
+  for (const name of aliases) {
+    if (typeof obj[name] === 'function') return obj[name].bind(obj);
+  }
+  return null;
+}
+
+async function tryImport(): Promise<any> {
+  const paths = [
+    '../src/index.js',
+    '../src/beam.js',
+    '../src/splitter.js',
+    '../src/solver.js',
+    '../src/index.ts',
+    '../src/beam.ts',
+    '../src/splitter.ts',
+    '../src/solver.ts',
+  ];
+  for (const p of paths) {
+    try {
+      return await import(p);
+    } catch {
+      // try next
+    }
+  }
+  throw new Error('Could not import beam splitter from any of: ' + paths.join(', '));
+}
+
+function extractFromObject(obj: any): { cells: Function | null; paths: Function | null } {
+  return {
+    cells: findFunction(obj, COUNT_CELLS_ALIASES),
+    paths: findFunction(obj, COUNT_PATHS_ALIASES),
+  };
+}
+
+export async function discover(): Promise<BeamAPI> {
+  const mod = await tryImport();
+
+  // 1. Direct named exports
+  let { cells, paths } = extractFromObject(mod);
+  if (cells && paths) return { countBeamCells: cells as any, countBeamPaths: paths as any };
+
+  // 2. Class exports
+  const classNames = [
+    'BeamSplitter', 'Beam', 'BeamSimulator', 'Simulator',
+    'Grid', 'Laboratory', 'Solver',
+  ];
+  for (const name of classNames) {
+    if (mod[name] && typeof mod[name] === 'function') {
+      try {
+        const instance = new mod[name]();
+        const result = extractFromObject(instance);
+        if (result.cells && result.paths) {
+          return { countBeamCells: result.cells as any, countBeamPaths: result.paths as any };
+        }
+      } catch {
+        // try next
+      }
+    }
+  }
+
+  // 3. Factory functions
+  const factoryNames = [
+    'createSolver', 'createSimulator', 'create', 'createBeam',
+    'makeSimulator', 'makeSolver',
+  ];
+  for (const name of factoryNames) {
+    if (typeof mod[name] === 'function') {
+      try {
+        const instance = mod[name]();
+        const result = extractFromObject(instance);
+        if (result.cells && result.paths) {
+          return { countBeamCells: result.cells as any, countBeamPaths: result.paths as any };
+        }
+      } catch {
+        // try next
+      }
+    }
+  }
+
+  // 4. Default export
+  const def = mod.default;
+  if (def) {
+    if (typeof def === 'function') {
+      try {
+        const instance = new def();
+        const result = extractFromObject(instance);
+        if (result.cells && result.paths) {
+          return { countBeamCells: result.cells as any, countBeamPaths: result.paths as any };
+        }
+      } catch {
+        try {
+          const instance = def();
+          const result = extractFromObject(instance);
+          if (result.cells && result.paths) {
+            return { countBeamCells: result.cells as any, countBeamPaths: result.paths as any };
+          }
+        } catch {
+          // skip
+        }
+      }
+    } else if (typeof def === 'object') {
+      const result = extractFromObject(def);
+      if (result.cells && result.paths) {
+        return { countBeamCells: result.cells as any, countBeamPaths: result.paths as any };
+      }
+    }
+  }
+
+  // 5. Partial fallback
+  if (!cells) cells = findFunction(mod, COUNT_CELLS_ALIASES);
+  if (!paths) paths = findFunction(mod, COUNT_PATHS_ALIASES);
+
+  for (const key of Object.keys(mod)) {
+    const val = mod[key];
+    if (val && typeof val === 'object') {
+      if (!cells) cells = findFunction(val, COUNT_CELLS_ALIASES);
+      if (!paths) paths = findFunction(val, COUNT_PATHS_ALIASES);
+    }
+  }
+
+  if (!cells) throw new Error('Could not find countBeamCells function. Tried: ' + COUNT_CELLS_ALIASES.join(', '));
+  if (!paths) throw new Error('Could not find countBeamPaths function. Tried: ' + COUNT_PATHS_ALIASES.join(', '));
+
+  return { countBeamCells: cells as any, countBeamPaths: paths as any };
+}
