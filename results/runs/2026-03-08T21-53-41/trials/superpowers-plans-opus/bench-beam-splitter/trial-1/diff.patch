+# Beam Splitter Implementation Plan
+
+> **For Claude:** REQUIRED SUB-SKILL: Use superpowers:executing-plans to implement this plan task-by-task.
+
+**Goal:** Implement a beam propagation simulator for a 2D grid that counts visited cells and distinct source-to-exit paths.
+
+**Architecture:** Two exported functions from `src/index.ts`. `countBeamCells` uses BFS simulation with a visited set, tracking (row, col, direction) states to avoid reprocessing. `countBeamPaths` uses row-by-row counter propagation with bigint to count paths without enumerating them, enabling it to handle exponential path counts efficiently.
+
+**Tech Stack:** TypeScript, Node16 modules, Vitest for testing, ESLint for linting.
+
+---
+
+### Task 1: Install dependencies
+
+**Step 1: Install npm dependencies**
+
+Run: `npm install`
+
+---
+
+### Task 2: Implement `src/index.ts`
+
+**Files:**
+- Create: `src/index.ts`
+
+**Step 1: Write the implementation**
+
+The file exports two functions:
+
+1. `countBeamCells(grid: string[][]): number` - BFS simulation tracking visited cells via a Set. Uses (row, col, direction) as seen-state to avoid reprocessing the same beam state. Beams start at 'S' going down, split at '^' into down-left and down-right, and continue in their current direction otherwise.
+
+2. `countBeamPaths(grid: string[][]): bigint` - Row-by-row counter propagation. Maintains a Map of `"col,direction"` -> bigint count. For each row, processes all beam states: splitters fork counts into two directions, normal cells propagate counts forward. Beams that exit the grid are accumulated into a total. This avoids enumerating individual paths and handles 2^K paths efficiently.
+
+Key implementation details:
+- Find source 'S' by scanning the grid
+- Return 0 / 0n if no source found
+- Directions: 'down' (col unchanged), 'down-left' (col-1), 'down-right' (col+1), all move row+1
+- Splitters always split regardless of incoming direction
+- Bounds checking: row in [0, rows), col in [0, cols)
+- For countBeamPaths, beams exiting any boundary (including sides) count as exited paths
+- For countBeamCells, the source cell 'S' counts as visited
+
+```typescript
+type Direction = 'down' | 'down-left' | 'down-right';
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  if (rows === 0) return 0;
+  const cols = grid[0].length;
+
+  let sourceRow = -1, sourceCol = -1;
+  for (let r = 0; r < rows; r++) {
+    for (let c = 0; c < cols; c++) {
+      if (grid[r][c] === 'S') { sourceRow = r; sourceCol = c; }
+    }
+  }
+  if (sourceRow === -1) return 0;
+
+  const visited = new Set<string>();
+  const seen = new Set<string>();
+  const beams: Beam[] = [{ row: sourceRow, col: sourceCol, dir: 'down' }];
+
+  while (beams.length > 0) {
+    const beam = beams.pop()!;
+    const key = `${beam.row},${beam.col},${beam.dir}`;
+    if (seen.has(key)) continue;
+    seen.add(key);
+    visited.add(`${beam.row},${beam.col}`);
+
+    if (grid[beam.row][beam.col] === '^') {
+      if (inBounds(beam.row + 1, beam.col - 1, rows, cols))
+        beams.push({ row: beam.row + 1, col: beam.col - 1, dir: 'down-left' });
+      if (inBounds(beam.row + 1, beam.col + 1, rows, cols))
+        beams.push({ row: beam.row + 1, col: beam.col + 1, dir: 'down-right' });
+    } else {
+      let nc: number;
+      switch (beam.dir) {
+        case 'down': nc = beam.col; break;
+        case 'down-left': nc = beam.col - 1; break;
+        case 'down-right': nc = beam.col + 1; break;
+      }
+      if (inBounds(beam.row + 1, nc, rows, cols))
+        beams.push({ row: beam.row + 1, col: nc, dir: beam.dir });
+    }
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  if (rows === 0) return 0n;
+  const cols = grid[0].length;
+
+  let sourceRow = -1, sourceCol = -1;
+  for (let r = 0; r < rows; r++) {
+    for (let c = 0; c < cols; c++) {
+      if (grid[r][c] === 'S') { sourceRow = r; sourceCol = c; }
+    }
+  }
+  if (sourceRow === -1) return 0n;
+
+  const makeKey = (col: number, dir: Direction): string => `${col},${dir}`;
+  let current = new Map<string, bigint>();
+  current.set(makeKey(sourceCol, 'down'), 1n);
+  let totalExited = 0n;
+
+  for (let r = sourceRow; r < rows; r++) {
+    const next = new Map<string, bigint>();
+    for (const [key, count] of current) {
+      const [colStr, dir] = key.split(',') as [string, Direction];
+      const col = parseInt(colStr, 10);
+
+      if (grid[r][col] === '^') {
+        const lc = col - 1, rc = col + 1;
+        if (r + 1 < rows && lc >= 0 && lc < cols) {
+          const k = makeKey(lc, 'down-left');
+          next.set(k, (next.get(k) ?? 0n) + count);
+        } else { totalExited += count; }
+        if (r + 1 < rows && rc >= 0 && rc < cols) {
+          const k = makeKey(rc, 'down-right');
+          next.set(k, (next.get(k) ?? 0n) + count);
+        } else { totalExited += count; }
+      } else {
+        let nc: number;
+        switch (dir) {
+          case 'down': nc = col; break;
+          case 'down-left': nc = col - 1; break;
+          case 'down-right': nc = col + 1; break;
+        }
+        if (r + 1 < rows && nc >= 0 && nc < cols) {
+          const k = makeKey(nc, dir);
+          next.set(k, (next.get(k) ?? 0n) + count);
+        } else { totalExited += count; }
+      }
+    }
+    current = next;
+  }
+
+  for (const [_, count] of current) {
+    totalExited += count;
+  }
+
+  return totalExited;
+}
+```
+
+**Step 2: Verify build**
+
+Run: `npm run build`
+Expected: No errors
+
+**Step 3: Verify lint**
+
+Run: `npm run lint`
+Expected: No errors
+
+---
+
+### Task 3: Run validation tests
+
+**Step 1: Run tests**
+
+Run: `npm test`
+Expected: All tests pass
+
+**Step 2: Run validation tests**
+
+Run: `npx vitest run --config validation-vitest.config.ts`
+Expected: All 20 tests pass in under 5 seconds
