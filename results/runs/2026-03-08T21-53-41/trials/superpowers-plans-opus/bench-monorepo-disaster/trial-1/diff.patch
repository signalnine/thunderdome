+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ltw5sYdSDCY8mxqybkdcyc","type":"tool_result","content":"     1→/**\n     2→ * Data sync job.\n     3→ * Syncs external user data into the local database.\n     4→ */\n     5→\n     6→import {\n     7→  createUser,\n     8→  getUserById,\n     9→  getAllUsers,\n    10→  type CreateUserInput,\n    11→} from '@monorepo/core';\n    12→\n    13→interface ExternalUser {\n    14→  name: string;\n    15→  email: string;\n    16→  role: 'admin' | 'user' | 'viewer';\n    17→}\n    18→\n    19→// Simulated external data source\n    20→function fetchExternalUsers(): ExternalUser[] {\n    21→  return [\n    22→    { name: 'External User 1', email: 'ext1@example.com', role: 'user' },\n    23→    { name: 'External User 2', email: 'ext2@example.com', role: 'viewer' },\n    24→  ];\n    25→}\n    26→\n    27→export async function syncJob(): Promise<void> {\n    28→  const externalUsers = fetchExternalUsers();\n    29→  const existingUsers = getAllUsers();\n    30→  const existingEmails = new Set(existingUsers.map((u) => u.email));\n    31→\n    32→  let synced = 0;\n    33→  let skipped = 0;\n    34→\n    35→  for (const extUser of externalUsers) {\n    36→    if (existingEmails.has(extUser.email)) {\n    37→      skipped++;\n    38→      continue;\n    39→    }\n    40→\n    41→    const input: CreateUserInput = {\n    42→      name: extUser.name,\n    43→      email: extUser.email,\n    44→      role: extUser.role,\n    45→    };\n    46→\n    47→    try {\n    48→      const newUser = createUser(input);\n    49→      if (newUser.id) {\n    50→        synced++;\n    51→      }\n    52→    } catch (err) {\n    53→      console.error(`Failed to sync user ${extUser.email}:`, err);\n    54→    }\n    55→  }\n    56→\n    57→  console.log(`Sync complete: ${synced} synced, ${skipped} skipped`);\n    58→}\n    59→\n    60→export async function syncSingleUser(userId: number): Promise<boolean> {\n    61→  const user = getUserById(userId);\n    62→  if (!user) {\n    63→    console.error(`User ${userId} not found for sync`);\n    64→    return false;\n    65→  }\n    66→\n    67→  // In a real app, we'd sync to an external service here\n    68→  console.log(`Synced user ${user.name} (${user.email})`);\n    69→  return true;\n    70→}\n    71→"}]},"parent_tool_use_id":null,"session_id":"081718fe-5855-4c85-87d3-3fbace946f07","uuid":"122ab2b4-ada9-4b8b-a8e7-e5becb17f26f","tool_use_result":{"type":"text","file":{"filePath":"/workspace/packages/worker/src/jobs/sync.ts","content":"/**\n * Data sync job.\n * Syncs external user data into the local database.\n */\n\nimport {\n  createUser,\n  getUserById,\n  getAllUsers,\n  type CreateUserInput,\n} from '@monorepo/core';\n\ninterface ExternalUser {\n  name: string;\n  email: string;\n  role: 'admin' | 'user' | 'viewer';\n}\n\n// Simulated external data source\nfunction fetchExternalUsers(): ExternalUser[] {\n  return [\n    { name: 'External User 1', email: 'ext1@example.com', role: 'user' },\n    { name: 'External User 2', email: 'ext2@example.com', role: 'viewer' },\n  ];\n}\n\nexport async function syncJob(): Promise<void> {\n  const externalUsers = fetchExternalUsers();\n  const existingUsers = getAllUsers();\n  const existingEmails = new Set(existingUsers.map((u) => u.email));\n\n  let synced = 0;\n  let skipped = 0;\n\n  for (const extUser of externalUsers) {\n    if (existingEmails.has(extUser.email)) {\n      skipped++;\n      continue;\n    }\n\n    const input: CreateUserInput = {\n      name: extUser.name,\n      email: extUser.email,\n      role: extUser.role,\n    };\n\n    try {\n      const newUser = createUser(input);\n      if (newUser.id) {\n        synced++;\n      }\n    } catch (err) {\n      console.error(`Failed to sync user ${extUser.email}:`, err);\n    }\n  }\n\n  console.log(`Sync complete: ${synced} synced, ${skipped} skipped`);\n}\n\nexport async function syncSingleUser(userId: number): Promise<boolean> {\n  const user = getUserById(userId);\n  if (!user) {\n    console.error(`User ${userId} not found for sync`);\n    return false;\n  }\n\n  // In a real app, we'd sync to an external service here\n  console.log(`Synced user ${user.name} (${user.email})`);\n  return true;\n}\n","numLines":71,"startLine":1,"totalLines":71}}}
