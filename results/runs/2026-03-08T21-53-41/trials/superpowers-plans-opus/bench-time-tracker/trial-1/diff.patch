+import { describe, it, expect, beforeEach, afterEach } from "vitest";
+import { TimeTracker } from "../tracker.js";
+import { mkdirSync, rmSync, existsSync, readFileSync } from "node:fs";
+import { join } from "node:path";
+import { tmpdir } from "node:os";
+
+let testDir: string;
+let testFile: string;
+
+beforeEach(() => {
+  testDir = join(tmpdir(), `time-tracker-test-${Date.now()}-${Math.random().toString(36).slice(2)}`);
+  mkdirSync(testDir, { recursive: true });
+  testFile = join(testDir, "data.json");
+});
+
+afterEach(() => {
+  if (existsSync(testDir)) {
+    rmSync(testDir, { recursive: true, force: true });
+  }
+});
+
+describe("TimeTracker", () => {
+  describe("start", () => {
+    it("should create an entry with end: null when starting a timer", () => {
+      const tracker = new TimeTracker(testFile);
+      tracker.start("coding");
+
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].task).toBe("coding");
+      expect(entries[0].start).toBeTruthy();
+      expect(entries[0].end).toBeNull();
+    });
+
+    it("should throw when starting with an empty name", () => {
+      const tracker = new TimeTracker(testFile);
+      expect(() => tracker.start("")).toThrow();
+    });
+
+    it("should throw when starting with a whitespace-only name", () => {
+      const tracker = new TimeTracker(testFile);
+      expect(() => tracker.start("   ")).toThrow();
+    });
+
+    it("should auto-stop the previous timer when starting a new one", () => {
+      const tracker = new TimeTracker(testFile);
+      tracker.start("task1");
+      tracker.start("task2");
+
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(2);
+      expect(entries[0].task).toBe("task1");
+      expect(entries[0].end).not.toBeNull();
+      expect(entries[1].task).toBe("task2");
+      expect(entries[1].end).toBeNull();
+    });
+  });
+
+  describe("stop", () => {
+    it("should set end time when stopping a running timer", () => {
+      const tracker = new TimeTracker(testFile);
+      tracker.start("coding");
+      tracker.stop();
+
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].end).not.toBeNull();
+    });
+
+    it("should throw when stopping with no timer running", () => {
+      const tracker = new TimeTracker(testFile);
+      expect(() => tracker.stop()).toThrow();
+    });
+
+    it("should throw when stopping after already stopped", () => {
+      const tracker = new TimeTracker(testFile);
+      tracker.start("coding");
+      tracker.stop();
+      expect(() => tracker.stop()).toThrow();
+    });
+  });
+
+  describe("persistence", () => {
+    it("should persist entries to disk and reload them", () => {
+      const tracker1 = new TimeTracker(testFile);
+      tracker1.start("coding");
+      tracker1.stop();
+
+      const tracker2 = new TimeTracker(testFile);
+      const entries = tracker2.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].task).toBe("coding");
+      expect(entries[0].end).not.toBeNull();
+    });
+
+    it("should create parent directories automatically", () => {
+      const deepPath = join(testDir, "a", "b", "c", "data.json");
+      const tracker = new TimeTracker(deepPath);
+      tracker.start("coding");
+      tracker.stop();
+
+      expect(existsSync(deepPath)).toBe(true);
+    });
+
+    it("should save valid JSON to disk", () => {
+      const tracker = new TimeTracker(testFile);
+      tracker.start("coding");
+      tracker.stop();
+
+      const raw = readFileSync(testFile, "utf-8");
+      const data = JSON.parse(raw);
+      expect(Array.isArray(data)).toBe(true);
+      expect(data).toHaveLength(1);
+    });
+
+    it("should work with an empty file path directory that does not exist", () => {
+      const nonExistentPath = join(testDir, "nonexistent", "tracker.json");
+      const tracker = new TimeTracker(nonExistentPath);
+      tracker.start("test");
+      tracker.stop();
+
+      expect(existsSync(nonExistentPath)).toBe(true);
+    });
+  });
+
+  describe("getEntries", () => {
+    it("should return all entries when no filters are provided", () => {
+      const tracker = new TimeTracker(testFile);
+      tracker.start("task1");
+      tracker.stop();
+      tracker.start("task2");
+      tracker.stop();
+
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(2);
+    });
+
+    it("should return an empty array when no entries exist", () => {
+      const tracker = new TimeTracker(testFile);
+      expect(tracker.getEntries()).toHaveLength(0);
+    });
+
+    it("should filter entries by start date", () => {
+      const tracker = new TimeTracker(testFile);
+      tracker.start("old-task");
+      tracker.stop();
+
+      const afterStart = new Date();
+      // Small delay to ensure different timestamps
+      tracker.start("new-task");
+      tracker.stop();
+
+      const entries = tracker.getEntries(afterStart);
+      expect(entries.length).toBeGreaterThanOrEqual(1);
+      expect(entries.some((e) => e.task === "new-task")).toBe(true);
+    });
+
+    it("should filter entries by end date", () => {
+      const tracker = new TimeTracker(testFile);
+      tracker.start("task1");
+      tracker.stop();
+
+      const beforeEnd = new Date();
+
+      // Create entries after the cutoff - use a future date
+      const futureFile = join(testDir, "future.json");
+      const tracker2 = new TimeTracker(futureFile);
+      tracker2.start("task2");
+      tracker2.stop();
+
+      const entries = tracker.getEntries(undefined, beforeEnd);
+      expect(entries.every((e) => new Date(e.start) <= beforeEnd)).toBe(true);
+    });
+
+    it("should filter entries by date range", () => {
+      const tracker = new TimeTracker(testFile);
+
+      tracker.start("task1");
+      tracker.stop();
+
+      const rangeStart = new Date();
+
+      tracker.start("task2");
+      tracker.stop();
+
+      const rangeEnd = new Date();
+
+      tracker.start("task3");
+      tracker.stop();
+
+      // task2 should be within the range, task1 before, task3 potentially after
+      const entries = tracker.getEntries(rangeStart, rangeEnd);
+      for (const entry of entries) {
+        const entryStart = new Date(entry.start);
+        expect(entryStart.getTime()).toBeGreaterThanOrEqual(rangeStart.getTime());
+        expect(entryStart.getTime()).toBeLessThanOrEqual(rangeEnd.getTime());
+      }
+    });
+
+    it("should return a copy, not the internal array", () => {
+      const tracker = new TimeTracker(testFile);
+      tracker.start("task1");
+      tracker.stop();
+
+      const entries = tracker.getEntries();
+      entries.push({ task: "fake", start: new Date().toISOString(), end: null });
+
+      expect(tracker.getEntries()).toHaveLength(1);
+    });
+  });
+
+  describe("getSummary", () => {
+    it("should return total time per task in milliseconds", () => {
+      const tracker = new TimeTracker(testFile);
+      tracker.start("coding");
+      tracker.stop();
+
+      const summary = tracker.getSummary();
+      expect(summary["coding"]).toBeDefined();
+      expect(typeof summary["coding"]).toBe("number");
+      expect(summary["coding"]).toBeGreaterThanOrEqual(0);
+    });
+
+    it("should sum multiple entries with the same task name", () => {
+      const tracker = new TimeTracker(testFile);
+      tracker.start("coding");
+      tracker.stop();
+      tracker.start("coding");
+      tracker.stop();
+
+      const summary = tracker.getSummary();
+      expect(summary["coding"]).toBeDefined();
+      expect(summary["coding"]).toBeGreaterThanOrEqual(0);
+    });
+
+    it("should include running tasks using current time", () => {
+      const tracker = new TimeTracker(testFile);
+      tracker.start("coding");
+      // Don't stop - it's still running
+
+      const summary = tracker.getSummary();
+      expect(summary["coding"]).toBeDefined();
+      expect(summary["coding"]).toBeGreaterThanOrEqual(0);
+    });
+
+    it("should return empty object when no entries exist", () => {
+      const tracker = new TimeTracker(testFile);
+      const summary = tracker.getSummary();
+      expect(Object.keys(summary)).toHaveLength(0);
+    });
+
+    it("should track multiple different tasks separately", () => {
+      const tracker = new TimeTracker(testFile);
+      tracker.start("coding");
+      tracker.stop();
+      tracker.start("review");
+      tracker.stop();
+
+      const summary = tracker.getSummary();
+      expect(Object.keys(summary)).toHaveLength(2);
+      expect(summary["coding"]).toBeDefined();
+      expect(summary["review"]).toBeDefined();
+    });
+  });
+
+  describe("unicode support", () => {
+    it("should handle emoji task names", () => {
+      const tracker = new TimeTracker(testFile);
+      tracker.start("🚀 deploy");
+      tracker.stop();
+
+      const entries = tracker.getEntries();
+      expect(entries[0].task).toBe("🚀 deploy");
+    });
+
+    it("should handle unicode characters in task names", () => {
+      const tracker = new TimeTracker(testFile);
+      tracker.start("日本語タスク");
+      tracker.stop();
+
+      const entries = tracker.getEntries();
+      expect(entries[0].task).toBe("日本語タスク");
+    });
+
+    it("should persist and reload unicode task names correctly", () => {
+      const tracker1 = new TimeTracker(testFile);
+      tracker1.start("café ☕ coding");
+      tracker1.stop();
+
+      const tracker2 = new TimeTracker(testFile);
+      const entries = tracker2.getEntries();
+      expect(entries[0].task).toBe("café ☕ coding");
+    });
+
+    it("should summarize unicode task names correctly", () => {
+      const tracker = new TimeTracker(testFile);
+      tracker.start("🎨 design");
+      tracker.stop();
+      tracker.start("🎨 design");
+      tracker.stop();
+
+      const summary = tracker.getSummary();
+      expect(summary["🎨 design"]).toBeDefined();
+    });
+  });
+});
