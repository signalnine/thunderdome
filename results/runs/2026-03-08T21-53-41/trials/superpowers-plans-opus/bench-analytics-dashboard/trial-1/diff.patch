amp DESC';\n\n  const rows = db.prepare(query).all(...params) as EventRow[];\n\n  if (format === 'csv') {\n    res.setHeader('Content-Type', 'text/csv');\n    res.setHeader('Content-Disposition', 'attachment; filename=\"events.csv\"');\n    res.send(eventsToCsv(rows));\n  } else {\n    const events = rows.map(r => ({\n      id: r.id,\n      tenantId: r.tenant_id,\n      name: r.name,\n      properties: JSON.parse(r.properties),\n      timestamp: r.timestamp,\n      userId: r.user_id,\n      sessionId: r.session_id,\n    }));\n    res.json({ events });\n  }\n});\n\n// GET /export/dashboards/:id\nrouter.get('/dashboards/:id', authenticate, (req: Request, res: Response): void => {\n  const db = getDb();\n  const tenantId = req.user!.tenantId;\n\n  const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(req.params.id, tenantId) as DashboardRow | undefined;\n\n  if (!dashboard) {\n    res.status(404).json({ error: 'Dashboard not found' });\n    return;\n  }\n\n  const widgets = db.prepare('SELECT * FROM widgets WHERE dashboard_id = ?').all(dashboard.id) as Array<{\n    id: string;\n    dashboard_id: string;\n    type: string;\n    config: string;\n    position_x: number;\n    position_y: number;\n    width: number;\n    height: number;\n  }>;\n\n  const format = (req.query.format as string) || 'json';\n\n  const result = {\n    dashboard: {\n      id: dashboard.id,\n      tenantId: dashboard.tenant_id,\n      name: dashboard.name,\n      ownerId: dashboard.owner_id,\n      config: JSON.parse(dashboard.config),\n      createdAt: dashboard.created_at,\n      updatedAt: dashboard.updated_at,\n    },\n    widgets: widgets.map(w => ({\n      id: w.id,\n      dashboardId: w.dashboard_id,\n      type: w.type,\n      config: JSON.parse(w.config),\n      positionX: w.position_x,\n      positionY: w.position_y,\n      width: w.width,\n      height: w.height,\n    })),\n  };\n\n  if (format === 'csv') {\n    res.setHeader('Content-Type', 'text/csv');\n    res.setHeader('Content-Disposition', `attachment; filename=\"dashboard-${dashboard.id}.csv\"`);\n    const header = 'id,name,owner_id,config,created_at,updated_at';\n    const configStr = dashboard.config.replace(/\"/g, '\"\"');\n    const row = `${dashboard.id},${dashboard.name},${dashboard.owner_id},\"${configStr}\",${dashboard.created_at},${dashboard.updated_at}`;\n    res.send([header, row].join('\\n'));\n  } else {\n    res.json(result);\n  }\n});\n\nexport default router;\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":417,"cache_read_input_tokens":32123,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":417},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"e53fbbbb-6cee-4b84-8626-546d5328e6b4","uuid":"185c6972-b5a1-49db-a8bc-0966868ab7a5"}
