'express';\nimport jwt from 'jsonwebtoken';\n\nconst JWT_SECRET = process.env.JWT_SECRET || 'analytics-dashboard-secret';\n\nexport interface AuthPayload {\n  userId: string;\n  tenantId: string;\n  role: string;\n  email: string;\n}\n\ndeclare global {\n  namespace Express {\n    interface Request {\n      user?: AuthPayload;\n    }\n  }\n}\n\nexport function authenticate(req: Request, res: Response, next: NextFunction): void {\n  const authHeader = req.headers.authorization;\n  if (!authHeader || !authHeader.startsWith('Bearer ')) {\n    res.status(401).json({ error: 'Authentication required' });\n    return;\n  }\n  const token = authHeader.split(' ')[1];\n  try {\n    const payload = jwt.verify(token, JWT_SECRET) as AuthPayload;\n    req.user = payload;\n    next();\n  } catch {\n    res.status(401).json({ error: 'Invalid token' });\n  }\n}\n\nexport function requireRole(...roles: string[]) {\n  return (req: Request, res: Response, next: NextFunction): void => {\n    if (!req.user || !roles.includes(req.user.role)) {\n      res.status(403).json({ error: 'Insufficient permissions' });\n      return;\n    }\n    next();\n  };\n}\n\nexport { JWT_SECRET };\n```\n\n---\n\n### Task 3: Auth Routes (`src/routes/auth.ts`)\n\n**Files:**\n- Create: `src/routes/auth.ts`\n\nImplements: POST /auth/register, POST /auth/login, GET /auth/profile, PUT /auth/users/:id/role\n\n- Register: creates user with hashed password (using crypto.createHash), returns JWT\n- Login: validates credentials, returns JWT\n- Profile: returns authenticated user info\n- Role update: admin-only, same tenant\n\n---\n\n### Task 4: Events Routes (`src/routes/events.ts`)\n\n**Files:**\n- Create: `src/routes/events.ts`\n\nImplements: POST /events (single), POST /events/batch (batch)\n\n- Both require auth\n- Auto-associate tenant_id from JWT\n- Validate required fields (name)\n- Support optional properties, timestamp, session_id\n\n---\n\n### Task 5: Query Routes (`src/routes/queries.ts`)\n\n**Files:**\n- Create: `src/routes/queries.ts`\n\nImplements: POST /queries/count, POST /queries/timeseries, POST /queries/breakdown\n\n- All require auth, enforce tenant isolation\n- Count: filter by event name, date range, properties\n- Timeseries: bucket by interval (hour/day/week/month), filter by event name, date range\n- Breakdown: group by property key, filter by event name, date range\n\n---\n\n### Task 6: Dashboard Routes (`src/routes/dashboards.ts`)\n\n**Files:**\n- Create: `src/routes/dashboards.ts`\n\nImplements: CRUD for dashboards (GET list, GET by id, POST, PUT, DELETE)\n\n- All require auth, scoped to tenant\n- Dashboards have name, config, owner_id\n\n---\n\n### Task 7: Export Routes (`src/routes/export.ts`)\n\n**Files:**\n- Create: `src/routes/export.ts`\n\nImplements: GET /export/events (CSV/JSON), GET /export/dashboards/:id (JSON)\n\n- Require auth, enforce tenant isolation\n- Support format query param (?format=csv or ?format=json)\n- CSV export with proper headers\n\n---\n\n### Task 8: App Entry Point (`src/app.ts`)\n\n**Files:**\n- Create: `src/app.ts`\n\nImplements: createApp() factory function that wires everything together.\n\n- Creates Express app, applies JSON body parser\n- Mounts all route groups\n- Exports createApp\n\n---\n\n### Task 9: Index Re-export (`src/index.ts`)\n\n**Files:**\n- Create: `src/index.ts`\n\nRe-exports createApp from app.ts.\n\n---\n\n### Task 10: Build, Lint, Test\n\n- Run `npm run build` and fix any TypeScript errors\n- Run `npm run lint` and fix any lint errors\n- Write integration tests and verify\n","structuredPatch":[],"originalFile":null}}
