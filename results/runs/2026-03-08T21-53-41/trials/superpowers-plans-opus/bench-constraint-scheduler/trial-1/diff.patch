event.preferredRoom === room.id) {\n          bestStart = start;\n          bestRoom = room;\n          break;\n        }\n        if (bestStart === null || start < bestStart) {\n          bestStart = start;\n          bestRoom = room;\n        }\n      }\n    }\n\n    if (bestStart !== null && bestRoom !== null) {\n      const assignment: Assignment = {\n        eventId: event.id,\n        roomId: bestRoom.id,\n        startTime: bestStart,\n        endTime: bestStart + event.duration,\n      };\n      assignments.set(event.id, assignment);\n      timelines.get(bestRoom.id)!.slots.push({ start: bestStart, end: bestStart + event.duration });\n    } else {\n      unscheduled.push(event.id);\n    }\n  }\n\n  return {\n    assignments: Array.from(assignments.values()),\n    unscheduled,\n  };\n}\n\nfunction getTopologicalDepth(eventId: string, eventMap: Map<string, Event>, cache: Map<string, number>): number {\n  if (cache.has(eventId)) return cache.get(eventId)!;\n  const event = eventMap.get(eventId);\n  if (!event || !event.prerequisites || event.prerequisites.length === 0) {\n    cache.set(eventId, 0);\n    return 0;\n  }\n  let maxDepth = 0;\n  for (const prereqId of event.prerequisites) {\n    if (eventMap.has(prereqId)) {\n      maxDepth = Math.max(maxDepth, getTopologicalDepth(prereqId, eventMap, cache) + 1);\n    }\n  }\n  cache.set(eventId, maxDepth);\n  return maxDepth;\n}\n\nfunction generateOrderings(sortedEvents: Event[], rooms: Room[], eventMap: Map<string, Event>): Event[][] {\n  const depthCache = new Map<string, number>();\n  for (const e of sortedEvents) getTopologicalDepth(e.id, eventMap, depthCache);\n\n  const orderings: Event[][] = [];\n\n  // Ordering 1: shortest duration first (within topo depth)\n  const byShort = [...sortedEvents].sort((a, b) => {\n    const da = depthCache.get(a.id)! - depthCache.get(b.id)!;\n    if (da !== 0) return da;\n    return a.duration - b.duration;\n  });\n  orderings.push(byShort);\n\n  // Ordering 2: most constrai