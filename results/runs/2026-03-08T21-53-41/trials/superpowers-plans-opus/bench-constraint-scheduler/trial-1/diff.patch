+import { Event, Room, ScheduleOptions, Assignment, ScheduleResult } from './types.js';
+import { topologicalSort } from './graph.js';
+
+interface RoomTimeline {
+  roomId: string;
+  capacity: number;
+  slots: { start: number; end: number }[];
+}
+
+function getEarliestStart(timeline: RoomTimeline, duration: number, gap: number, windowStart: number, windowEnd: number, minStart: number): number | null {
+  const effectiveStart = Math.max(windowStart, minStart);
+  if (effectiveStart + duration > windowEnd) return null;
+
+  const slots = timeline.slots.sort((a, b) => a.start - b.start);
+
+  if (slots.length === 0) {
+    return effectiveStart;
+  }
+
+  // Try before the first slot
+  if (effectiveStart + duration + gap <= slots[0].start || effectiveStart + duration <= slots[0].start) {
+    if (effectiveStart + duration <= windowEnd) {
+      // Check gap: our end + gap <= next slot start
+      if (effectiveStart + duration + gap <= slots[0].start) {
+        return effectiveStart;
+      }
+      // If no slots after, just check window
+      if (slots.length === 0) {
+        return effectiveStart;
+      }
+    }
+  }
+  // Actually, let's be more careful. We need: candidate + duration <= windowEnd
+  // and for each existing slot, no overlap considering gaps.
+
+  // Gather candidate start times
+  const candidates: number[] = [effectiveStart];
+  for (const slot of slots) {
+    candidates.push(slot.end + gap);
+  }
+
+  for (const candidate of candidates) {
+    if (candidate < effectiveStart) continue;
+    if (candidate + duration > windowEnd) continue;
+
+    let valid = true;
+    for (const slot of slots) {
+      // Our event: [candidate, candidate + duration)
+      // Existing slot: [slot.start, slot.end)
+      // Need: candidate + duration + gap <= slot.start OR slot.end + gap <= candidate
+      if (!(candidate + duration + gap <= slot.start || slot.end + gap <= candidate)) {
+        valid = false;
+        break;
+      }
+    }
+    if (valid) return candidate;
+  }
+
+  return null;
+}
+
+function computePrereqEndTimes(
+  eventId: string,
+  events: Map<string, Event>,
+  assignments: Map<string, Assignment>,
+  gap: number
+): number {
+  const event = events.get(eventId)!;
+  let minStart = 0;
+  if (event.prerequisites) {
+    for (const prereqId of event.prerequisites) {
+      const prereqAssignment = assignments.get(prereqId);
+      if (prereqAssignment) {
+        minStart = Math.max(minStart, prereqAssignment.endTime + gap);
+      } else if (events.has(prereqId)) {
+        // Prerequisite exists but wasn't scheduled - this event can't be scheduled
+        return Infinity;
+      }
+    }
+  }
+  return minStart;
+}
+
+export function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {
+  if (events.length === 0) {
+    return { assignments: [], unscheduled: [] };
+  }
+
+  const gap = options.gap ?? 15;
+  const sorted = topologicalSort(events);
+
+  const eventMap = new Map<string, Event>();
+  for (const event of events) {
+    eventMap.set(event.id, event);
+  }
+
+  // Try to maximize number of scheduled events using a greedy approach
+  // with retry: if greedy fails to maximize, try different orderings
+  const bestResult = greedySchedule(sorted, rooms, options, gap, eventMap);
+
+  return bestResult;
+}
+
+function greedySchedule(
+  sortedEvents: Event[],
+  rooms: Room[],
+  options: ScheduleOptions,
+  gap: number,
+  eventMap: Map<string, Event>
+): ScheduleResult {
+  // Try multiple orderings to maximize scheduled events:
+  // 1. Topological order (respecting prerequisites), then by shortest duration first
+  // 2. Topological order, then by most constrained first (fewest fitting rooms)
+
+  const orderings = generateOrderings(sortedEvents, rooms, eventMap);
+
+  let bestResult: ScheduleResult = { assignments: [], unscheduled: sortedEvents.map(e => e.id) };
+
+  for (const ordering of orderings) {
+    const result = trySchedule(ordering, rooms, options, gap, eventMap);
+    if (result.assignments.length > bestResult.assignments.length) {
+      bestResult = result;
+    }
+    if (bestResult.unscheduled.length === 0) break;
+  }
+
+  return bestResult;
+}
+
+function generateOrderings(sortedEvents: Event[], rooms: Room[], eventMap: Map<string, Event>): Event[][] {
+  const orderings: Event[][] = [];
+
+  // Compute topological depth for each event to maintain prerequisite order
+  const depthMap = new Map<string, number>();
+  function getDepth(id: string): number {
+    if (depthMap.has(id)) return depthMap.get(id)!;
+    const event = eventMap.get(id);
+    if (!event || !event.prerequisites || event.prerequisites.length === 0) {
+      depthMap.set(id, 0);
+      return 0;
+    }
+    let maxDepth = 0;
+    for (const prereqId of event.prerequisites) {
+      if (eventMap.has(prereqId)) {
+        maxDepth = Math.max(maxDepth, getDepth(prereqId) + 1);
+      }
+    }
+    depthMap.set(id, maxDepth);
+    return maxDepth;
+  }
+  for (const e of sortedEvents) getDepth(e.id);
+
+  // Ordering 1: shortest duration first (within topo order)
+  const byShort = [...sortedEvents].sort((a, b) => {
+    const da = depthMap.get(a.id)! - depthMap.get(b.id)!;
+    if (da !== 0) return da;
+    return a.duration - b.duration;
+  });
+  orderings.push(byShort);
+
+  // Ordering 2: most constrained first (fewest fitting rooms), within topo order
+  const fittingRooms = (e: Event) => rooms.filter(r => r.capacity >= (e.attendees ?? 1)).length;
+  const byConstrained = [...sortedEvents].sort((a, b) => {
+    const da = depthMap.get(a.id)! - depthMap.get(b.id)!;
+    if (da !== 0) return da;
+    return fittingRooms(a) - fittingRooms(b);
+  });
+  orderings.push(byConstrained);
+
+  // Ordering 3: longest duration first (within topo order)
+  const byLong = [...sortedEvents].sort((a, b) => {
+    const da = depthMap.get(a.id)! - depthMap.get(b.id)!;
+    if (da !== 0) return da;
+    return b.duration - a.duration;
+  });
+  orderings.push(byLong);
+
+  // Ordering 4: original topological order
+  orderings.push([...sortedEvents]);
+
+  return orderings;
+}
+
+function trySchedule(
+  orderedEvents: Event[],
+  rooms: Room[],
+  options: ScheduleOptions,
+  gap: number,
+  eventMap: Map<string, Event>
+): ScheduleResult {
+  const timelines = new Map<string, RoomTimeline>();
+  for (const room of rooms) {
+    timelines.set(room.id, { roomId: room.id, capacity: room.capacity, slots: [] });
+  }
+
+  const assignments = new Map<string, Assignment>();
+  const unscheduled: string[] = [];
+
+  for (const event of orderedEvents) {
+    const attendees = event.attendees ?? 1;
+    const minStart = computePrereqEndTimes(event.id, eventMap, assignments, gap);
+
+    if (minStart === Infinity) {
+      unscheduled.push(event.id);
+      continue;
+    }
+
+    // Try preferred room first, then others sorted by capacity (smallest fitting first)
+    const fittingRooms = rooms
+      .filter(r => r.capacity >= attendees)
+      .sort((a, b) => a.capacity - b.capacity);
+
+    if (fittingRooms.length === 0) {
+      unscheduled.push(event.id);
+      continue;
+    }
+
+    // Reorder to try preferred room first
+    const orderedRooms = [...fittingRooms];
+    if (event.preferredRoom) {
+      const prefIdx = orderedRooms.findIndex(r => r.id === event.preferredRoom);
+      if (prefIdx > 0) {
+        const [pref] = orderedRooms.splice(prefIdx, 1);
+        orderedRooms.unshift(pref);
+      }
+    }
+
+    let placed = false;
+    let bestStart: number | null = null;
+    let bestRoom: Room | null = null;
+
+    for (const room of orderedRooms) {
+      const timeline = timelines.get(room.id)!;
+      const start = getEarliestStart(timeline, event.duration, gap, options.startTime, options.endTime, minStart);
+      if (start !== null) {
+        if (bestStart === null || start < bestStart) {
+          bestStart = start;
+          bestRoom = room;
+          // If this is the preferred room and it works, use it immediately
+          if (event.preferredRoom === room.id) break;
+        }
+      }
+    }
+
+    if (bestStart !== null && bestRoom !== null) {
+      const assignment: Assignment = {
+        eventId: event.id,
+        roomId: bestRoom.id,
+        startTime: bestStart,
+        endTime: bestStart + event.duration,
+      };
+      assignments.set(event.id, assignment);
+      timelines.get(bestRoom.id)!.slots.push({ start: bestStart, end: bestStart + event.duration });
+      placed = true;
+    }
+
+    if (!placed) {
+      unscheduled.push(event.id);
+    }
+  }
+
+  return {
+    assignments: Array.from(assignments.values()),
+    unscheduled,
+  };
+}
