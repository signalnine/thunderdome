+import { EventBus } from '../bus.js';
+import { AnalyticsService, Events, PaymentProcessedEvent, PaymentStatus, OrderCreatedEvent, CartUpdatedEvent } from '../types.js';
+
+export function createAnalyticsService(bus: EventBus): AnalyticsService {
+  const eventCounts = new Map<string, number>();
+  let totalRevenue = 0;
+  const cartUsers = new Set<string>();
+  let orderCount = 0;
+  const productCounts = new Map<string, number>();
+
+  function trackEvent(eventType: string) {
+    eventCounts.set(eventType, (eventCounts.get(eventType) ?? 0) + 1);
+  }
+
+  bus.on(Events.PRODUCT_CREATED, () => { trackEvent(Events.PRODUCT_CREATED); });
+  bus.on(Events.INVENTORY_UPDATED, () => { trackEvent(Events.INVENTORY_UPDATED); });
+  bus.on(Events.LOW_STOCK_ALERT, () => { trackEvent(Events.LOW_STOCK_ALERT); });
+  bus.on(Events.CART_UPDATED, (payload: unknown) => {
+    trackEvent(Events.CART_UPDATED);
+    const event = payload as CartUpdatedEvent;
+    cartUsers.add(event.cartId);
+  });
+  bus.on(Events.PRICE_CALCULATED, () => { trackEvent(Events.PRICE_CALCULATED); });
+  bus.on(Events.ORDER_CREATED, (payload: unknown) => {
+    trackEvent(Events.ORDER_CREATED);
+    orderCount++;
+    const event = payload as OrderCreatedEvent;
+    // Track product quantities from the order -- we need to listen to cart data
+    // We use cartId tracking to map orders to cart items
+  });
+  bus.on(Events.ORDER_STATUS_CHANGED, () => { trackEvent(Events.ORDER_STATUS_CHANGED); });
+  bus.on(Events.PAYMENT_PROCESSED, (payload: unknown) => {
+    trackEvent(Events.PAYMENT_PROCESSED);
+    const event = payload as PaymentProcessedEvent;
+    if (event.status === PaymentStatus.SUCCESS) {
+      // Revenue is tracked from payment amount -- but PaymentProcessedEvent doesn't have amount
+      // We need to track from order creation
+    }
+  });
+  bus.on(Events.NOTIFICATION_SENT, () => { trackEvent(Events.NOTIFICATION_SENT); });
+  bus.on(Events.ANALYTICS_EVENT, () => { trackEvent(Events.ANALYTICS_EVENT); });
+
+  // Track revenue from orders + payments
+  const orderTotals = new Map<string, number>();
+  const orderCartMap = new Map<string, string>();
+  const cartItems = new Map<string, Array<{ productId: string; quantity: number }>>();
+
+  // Override order created to also track total
+  bus.on(Events.ORDER_CREATED, (payload: unknown) => {
+    const event = payload as OrderCreatedEvent;
+    orderTotals.set(event.orderId, event.total);
+    orderCartMap.set(event.orderId, event.cartId);
+    // Track product counts from associated cart
+    const items = cartItems.get(event.cartId);
+    if (items) {
+      for (const item of items) {
+        productCounts.set(item.productId, (productCounts.get(item.productId) ?? 0) + item.quantity);
+      }
+    }
+  });
+
+  bus.on(Events.CART_UPDATED, (payload: unknown) => {
+    const event = payload as CartUpdatedEvent;
+    cartItems.set(event.cartId, event.items);
+  });
+
+  bus.on(Events.PAYMENT_PROCESSED, (payload: unknown) => {
+    const event = payload as PaymentProcessedEvent;
+    if (event.status === PaymentStatus.SUCCESS) {
+      const total = orderTotals.get(event.orderId) ?? 0;
+      totalRevenue += total;
+    }
+  });
+
+  return {
+    getEventCount(eventType) {
+      return eventCounts.get(eventType) ?? 0;
+    },
+    getRevenue() {
+      return totalRevenue;
+    },
+    getConversionRate() {
+      if (cartUsers.size === 0) return 0;
+      return orderCount / cartUsers.size;
+    },
+    getTopProducts(limit) {
+      return [...productCounts.entries()]
+        .map(([productId, count]) => ({ productId, count }))
+        .sort((a, b) => b.count - a.count)
+        .slice(0, limit);
+    },
+  };
+}
