+    const totals = pricing.calculateTotal(items);
+    expect(totals.subtotal).toBe(1999.98);
+    expect(totals.tax).toBe(200);
+    expect(totals.total).toBe(2199.98);
+
+    // Reserve inventory
+    expect(inventory.reserve(productId, 2)).toBe(true);
+    expect(inventory.getStock(productId)).toBe(8);
+
+    // Create order
+    const orderId = orders.createOrder('user1', cartId, totals.total);
+    await new Promise(resolve => setTimeout(resolve, 10));
+
+    const order = orders.getOrder(orderId);
+    expect(order?.status).toBe(OrderStatus.PENDING);
+
+    // Process payment
+    const paymentResult = await payment.processPayment(orderId, totals.total);
+    expect(paymentResult.status).toBe(PaymentStatus.SUCCESS);
+
+    // Update order status
+    orders.updateStatus(orderId, OrderStatus.CONFIRMED);
+    await new Promise(resolve => setTimeout(resolve, 10));
+
+    expect(orders.getOrder(orderId)?.status).toBe(OrderStatus.CONFIRMED);
+
+    // Check notifications were sent
+    const userNotifications = notifications.getNotifications('user1');
+    expect(userNotifications.length).toBeGreaterThanOrEqual(2);
+
+    // Check analytics
+    expect(analytics.getRevenue()).toBe(2199.98);
+    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(1);
+    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBe(1);
+
+    // Top products
+    const topProducts = analytics.getTopProducts(1);
+    expect(topProducts).toHaveLength(1);
+    expect(topProducts[0].productId).toBe(productId);
+    expect(topProducts[0].count).toBe(2);
+  });
