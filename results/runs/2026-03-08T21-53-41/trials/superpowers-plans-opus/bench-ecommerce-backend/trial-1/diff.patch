diff --git a/tests/services.test.ts b/tests/services.test.ts
new file mode 100644
index 0000000..b251775
--- /dev/null
+++ b/tests/services.test.ts
@@ -0,0 +1,712 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { EventBus } from '../src/bus.js';
+import { Events, OrderStatus, PaymentStatus } from '../src/types.js';
+import { createCatalogService } from '../src/catalog/index.js';
+import { createInventoryService } from '../src/inventory/index.js';
+import { createCartService } from '../src/cart/index.js';
+import { createPricingService } from '../src/pricing/index.js';
+import { createOrderService } from '../src/orders/index.js';
+import { createPaymentService } from '../src/payment/index.js';
+import { createNotificationService } from '../src/notifications/index.js';
+import { createAnalyticsService } from '../src/analytics/index.js';
+
+describe('CatalogService', () => {
+  let bus: EventBus;
+
+  beforeEach(() => {
+    bus = new EventBus();
+  });
+
+  it('should create a product and return its id', () => {
+    const catalog = createCatalogService(bus);
+    const id = catalog.createProduct('Widget', 9.99, 'gadgets');
+    expect(id).toBeDefined();
+    expect(typeof id).toBe('string');
+  });
+
+  it('should retrieve a product by id', () => {
+    const catalog = createCatalogService(bus);
+    const id = catalog.createProduct('Widget', 9.99, 'gadgets');
+    const product = catalog.getProduct(id);
+    expect(product).toEqual({ id, name: 'Widget', price: 9.99, category: 'gadgets' });
+  });
+
+  it('should return null for non-existent product', () => {
+    const catalog = createCatalogService(bus);
+    expect(catalog.getProduct('nonexistent')).toBeNull();
+  });
+
+  it('should list all products', () => {
+    const catalog = createCatalogService(bus);
+    catalog.createProduct('Widget', 9.99, 'gadgets');
+    catalog.createProduct('Gizmo', 19.99, 'gadgets');
+    catalog.createProduct('Doohickey', 4.99, 'tools');
+    expect(catalog.listProducts()).toHaveLength(3);
+  });
+
+  it('should list products filtered by category', () => {
+    const catalog = createCatalogService(bus);
+    catalog.createProduct('Widget', 9.99, 'gadgets');
+    catalog.createProduct('Gizmo', 19.99, 'gadgets');
+    catalog.createProduct('Doohickey', 4.99, 'tools');
+    const gadgets = catalog.listProducts('gadgets');
+    expect(gadgets).toHaveLength(2);
+    expect(gadgets.every(p => p.category === 'gadgets')).toBe(true);
+  });
+
+  it('should search products by name', () => {
+    const catalog = createCatalogService(bus);
+    catalog.createProduct('Widget', 9.99, 'gadgets');
+    catalog.createProduct('Super Widget', 19.99, 'gadgets');
+    catalog.createProduct('Gizmo', 14.99, 'gadgets');
+    const results = catalog.searchProducts('widget');
+    expect(results).toHaveLength(2);
+  });
+
+  it('should update a product', () => {
+    const catalog = createCatalogService(bus);
+    const id = catalog.createProduct('Widget', 9.99, 'gadgets');
+    catalog.updateProduct(id, { name: 'Super Widget', price: 14.99 });
+    const product = catalog.getProduct(id);
+    expect(product?.name).toBe('Super Widget');
+    expect(product?.price).toBe(14.99);
+    expect(product?.category).toBe('gadgets');
+  });
+
+  it('should remove a product', () => {
+    const catalog = createCatalogService(bus);
+    const id = catalog.createProduct('Widget', 9.99, 'gadgets');
+    expect(catalog.removeProduct(id)).toBe(true);
+    expect(catalog.getProduct(id)).toBeNull();
+    expect(catalog.removeProduct(id)).toBe(false);
+  });
+
+  it('should emit product:created event', async () => {
+    const catalog = createCatalogService(bus);
+    catalog.createProduct('Widget', 9.99, 'gadgets');
+    // Allow bus.emit to complete (it's async but called without await from createProduct)
+    await new Promise(resolve => setTimeout(resolve, 10));
+    const log = bus.getLog();
+    const productCreatedEvents = log.filter(e => e.event === Events.PRODUCT_CREATED);
+    expect(productCreatedEvents).toHaveLength(1);
+    expect(productCreatedEvents[0].payload).toMatchObject({
+      name: 'Widget',
+      price: 9.99,
+      category: 'gadgets',
+    });
+  });
+});
+
+describe('InventoryService', () => {
+  let bus: EventBus;
+
+  beforeEach(() => {
+    bus = new EventBus();
+  });
+
+  it('should set and get stock', () => {
+    const inventory = createInventoryService(bus);
+    inventory.setStock('p1', 100);
+    expect(inventory.getStock('p1')).toBe(100);
+  });
+
+  it('should return 0 for unknown product stock', () => {
+    const inventory = createInventoryService(bus);
+    expect(inventory.getStock('nonexistent')).toBe(0);
+  });
+
+  it('should reserve stock successfully', () => {
+    const inventory = createInventoryService(bus);
+    inventory.setStock('p1', 10);
+    expect(inventory.reserve('p1', 5)).toBe(true);
+    expect(inventory.getStock('p1')).toBe(5);
+  });
+
+  it('should fail to reserve when insufficient stock', () => {
+    const inventory = createInventoryService(bus);
+    inventory.setStock('p1', 3);
+    expect(inventory.reserve('p1', 5)).toBe(false);
+    expect(inventory.getStock('p1')).toBe(3);
+  });
+
+  it('should release reserved stock', () => {
+    const inventory = createInventoryService(bus);
+    inventory.setStock('p1', 10);
+    inventory.reserve('p1', 5);
+    inventory.release('p1', 3);
+    expect(inventory.getStock('p1')).toBe(8);
+  });
+
+  it('should emit low stock alert when stock falls below threshold', async () => {
+    const inventory = createInventoryService(bus);
+    inventory.setStock('p1', 10);
+    inventory.setLowStockThreshold('p1', 5);
+    inventory.reserve('p1', 6);
+    await new Promise(resolve => setTimeout(resolve, 10));
+    const log = bus.getLog();
+    const alerts = log.filter(e => e.event === Events.LOW_STOCK_ALERT);
+    expect(alerts.length).toBeGreaterThan(0);
+  });
+
+  it('should emit inventory:updated on setStock', async () => {
+    const inventory = createInventoryService(bus);
+    inventory.setStock('p1', 50);
+    await new Promise(resolve => setTimeout(resolve, 10));
+    const log = bus.getLog();
+    const updates = log.filter(e => e.event === Events.INVENTORY_UPDATED);
+    expect(updates).toHaveLength(1);
+  });
+});
+
+describe('CartService', () => {
+  let bus: EventBus;
+
+  beforeEach(() => {
+    bus = new EventBus();
+  });
+
+  it('should create a cart and return id', () => {
+    const cart = createCartService(bus);
+    const id = cart.createCart('user1');
+    expect(id).toBeDefined();
+  });
+
+  it('should add items to cart', () => {
+    const cart = createCartService(bus);
+    const id = cart.createCart('user1');
+    cart.addItem(id, 'p1', 2);
+    const c = cart.getCart(id);
+    expect(c?.items).toHaveLength(1);
+    expect(c?.items[0]).toEqual({ productId: 'p1', quantity: 2 });
+  });
+
+  it('should consolidate same product when added multiple times', () => {
+    const cart = createCartService(bus);
+    const id = cart.createCart('user1');
+    cart.addItem(id, 'p1', 2);
+    cart.addItem(id, 'p1', 3);
+    const c = cart.getCart(id);
+    expect(c?.items).toHaveLength(1);
+    expect(c?.items[0]).toEqual({ productId: 'p1', quantity: 5 });
+  });
+
+  it('should remove items from cart', () => {
+    const cart = createCartService(bus);
+    const id = cart.createCart('user1');
+    cart.addItem(id, 'p1', 2);
+    cart.addItem(id, 'p2', 1);
+    cart.removeItem(id, 'p1');
+    const c = cart.getCart(id);
+    expect(c?.items).toHaveLength(1);
+    expect(c?.items[0].productId).toBe('p2');
+  });
+
+  it('should clear cart', () => {
+    const cart = createCartService(bus);
+    const id = cart.createCart('user1');
+    cart.addItem(id, 'p1', 2);
