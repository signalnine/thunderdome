+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01HcssuYdPr6LqudpbAnDwXB","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_0195YFfZqTfaQRMH15wAJtw8","name":"Write","input":{"file_path":"/workspace/tests/services.test.ts","content":"import { describe, it, expect, beforeEach } from 'vitest';\nimport { EventBus } from '../src/bus.js';\nimport { Events, OrderStatus, PaymentStatus } from '../src/types.js';\nimport { createCatalogService } from '../src/catalog/index.js';\nimport { createInventoryService } from '../src/inventory/index.js';\nimport { createCartService } from '../src/cart/index.js';\nimport { createPricingService } from '../src/pricing/index.js';\nimport { createOrderService } from '../src/orders/index.js';\nimport { createPaymentService } from '../src/payment/index.js';\nimport { createNotificationService } from '../src/notifications/index.js';\nimport { createAnalyticsService } from '../src/analytics/index.js';\n\ndescribe('CatalogService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should create a product and return its id', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    expect(id).toBeDefined();\n    expect(typeof id).toBe('string');\n  });\n\n  it('should retrieve a product by id', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    const product = catalog.getProduct(id);\n    expect(product).toEqual({ id, name: 'Widget', price: 9.99, category: 'gadgets' });\n  });\n\n  it('should return null for non-existent product', () => {\n    const catalog = createCatalogService(bus);\n    expect(catalog.getProduct('nonexistent')).toBeNull();\n  });\n\n  it('should list all products', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('Widget', 9.99, 'gadgets');\n    catalog.createProduct('Gizmo', 19.99, 'gadgets');\n    catalog.createProduct('Doohickey', 4.99, 'tools');\n    expect(catalog.listProducts()).toHaveLength(3);\n  });\n\n  it('should list products filtered by category', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('Widget', 9.99, 'gadgets');\n    catalog.createProduct('Gizmo', 19.99, 'gadgets');\n    catalog.createProduct('Doohickey', 4.99, 'tools');\n    const gadgets = catalog.listProducts('gadgets');\n    expect(gadgets).toHaveLength(2);\n    expect(gadgets.every(p => p.category === 'gadgets')).toBe(true);\n  });\n\n  it('should search products by name', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('Widget', 9.99, 'gadgets');\n    catalog.createProduct('Super Widget', 19.99, 'gadgets');\n    catalog.createProduct('Gizmo', 14.99, 'gadgets');\n    const results = catalog.searchProducts('widget');\n    expect(results).toHaveLength(2);\n  });\n\n  it('should update a product', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    catalog.updateProduct(id, { name: 'Super Widget', price: 14.99 });\n    const product = catalog.getProduct(id);\n    expect(product?.name).toBe('Super Widget');\n    expect(product?.price).toBe(14.99);\n    expect(product?.category).toBe('gadgets');\n  });\n\n  it('should remove a product', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    expect(catalog.removeProduct(id)).toBe(true);\n    expect(catalog.getProduct(id)).toBeNull();\n    expect(catalog.removeProduct(id)).toBe(false);\n  });\n\n  it('should emit product:created event', async () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('Widget', 9.99, 'gadgets');\n    // Allow bus.emit to complete (it's async but called without await from createProduct)\n    await new Promise(resolve => setTimeout(resolve, 10));\n    const log = bus.getLog();\n    const productCreatedEvents = log.filter(e => e.event === Events.PRODUCT_CREATED);\n    expect(productCreatedEvents).toHaveLength(1);\n    expect(productCreatedEvents[0].payload).toMatchObject({\n      name: 'Widget',\n      price: 9.99,\n      category: 'gadgets',\n    });\n  });\n});\n\ndescribe('InventoryService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should set and get stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 100);\n    expect(inventory.getStock('p1')).toBe(100);\n  });\n\n  it('should return 0 for unknown product stock', () => {\n    const inventory = createInventoryService(bus);\n    expect(inventory.getStock('nonexistent')).toBe(0);\n  });\n\n  it('should reserve stock successfully', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 10);\n    expect(inventory.reserve('p1', 5)).toBe(true);\n    expect(inventory.getStock('p1')).toBe(5);\n  });\n\n  it('should fail to reserve when insufficient stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 3);\n    expect(inventory.reserve('p1', 5)).toBe(false);\n    expect(inventory.getStock('p1')).toBe(3);\n  });\n\n  it('should release reserved stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 10);\n    inventory.reserve('p1', 5);\n    inventory.release('p1', 3);\n    expect(inventory.getStock('p1')).toBe(8);\n  });\n\n  it('should emit low stock alert when stock falls below threshold', async () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 10);\n    inventory.setLowStockThreshold('p1', 5);\n    inventory.reserve('p1', 6);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    const log = bus.getLog();\n    const alerts = log.filter(e => e.event === Events.LOW_STOCK_ALERT);\n    expect(alerts.length).toBeGreaterThan(0);\n  });\n\n  it('should emit inventory:updated on setStock', async () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 50);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    const log = bus.getLog();\n    const updates = log.filter(e => e.event === Events.INVENTORY_UPDATED);\n    expect(updates).toHaveLength(1);\n  });\n});\n\ndescribe('CartService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should create a cart and return id', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    expect(id).toBeDefined();\n  });\n\n  it('should add items to cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    const c = cart.getCart(id);\n    expect(c?.items).toHaveLength(1);\n    expect(c?.items[0]).toEqual({ productId: 'p1', quantity: 2 });\n  });\n\n  it('should consolidate same product when added multiple times', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p1', 3);\n    const c = cart.getCart(id);\n    expect(c?.items).toHaveLength(1);\n    expect(c?.items[0]).toEqual({ productId: 'p1', quantity: 5 });\n  });\n\n  it('should remove items from cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p2', 1);\n    cart.removeItem(id, 'p1');\n    const c = cart.getCart(id);\n    expect(c?.items).toHaveLength(1);\n    expect(c?.items[0].productId).toBe('p2');\n  });\n\n  it('should clear cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p2', 1);\n    cart.clearCart(id);\n    const c = cart.getCart(id);\n    expect(c?.items).toHaveLength(0);\n  });\n\n  it('should update quantity', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.updateQuantity(id, 'p1', 5);\n    const c = cart.getCart(id);\n    expect(c?.items[0].quantity).toBe(5);\n  });\n\n  it('should remove item when quantity set to 0', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.updateQuantity(id, 'p1', 0);\n    const c = cart.getCart(id);\n    expect(c?.items).toHaveLength(0);\n  });\n\n  it('should return null for non-existent cart', () => {\n    const cart = createCartService(bus);\n    expect(cart.getCart('nonexistent')).toBeNull();\n  });\n});\n\ndescribe('PricingService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should calculate total with tax', () => {\n    const pricing = createPricingService(bus);\n    const result = pricing.calculateTotal([\n      { productId: 'p1', quantity: 2, price: 10 },\n    ]);\n    expect(result.subtotal).toBe(20);\n    expect(result.discount).toBe(0);\n    expect(result.tax).toBe(2); // 10% of 20\n    expect(result.total).toBe(22);\n  });\n\n  it('should apply discount codes', () => {\n    const pricing = createPricingService(bus);\n    pricing.addDiscountCode('SAVE10', 10);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'SAVE10',\n    );\n    expect(result.subtotal).toBe(100);\n    expect(result.discount).toBe(10);\n    expect(result.tax).toBe(9); // 10% of 90\n    expect(result.total).toBe(99);\n  });\n\n  it('should ignore unknown discount codes', () => {\n    const pricing = createPricingService(bus);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'INVALID',\n    );\n    expect(result.discount).toBe(0);\n    expect(result.total).toBe(110);\n  });\n\n  it('should track product prices from events', async () => {\n    const pricing = createPricingService(bus);\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'Widget', price: 9.99, category: 'gadgets' });\n    expect(pricing.getPrice('p1')).toBe(9.99);\n  });\n\n  it('should return 0 for unknown product price', () => {\n    const pricing = createPricingService(bus);\n    expect(pricing.getPrice('nonexistent')).toBe(0);\n  });\n});\n\ndescribe('OrderService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should create an order in pending status', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    const order = orders.getOrder(id);\n    expect(order).toBeDefined();\n    expect(order?.status).toBe(OrderStatus.PENDING);\n    expect(order?.total).toBe(50);\n    expect(order?.userId).toBe('user1');\n  });\n\n  it('should return null for non-existent order', () => {\n    const orders = createOrderService(bus);\n    expect(orders.getOrder('nonexistent')).toBeNull();\n  });\n\n  it('should update order status', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    expect(orders.getOrder(id)?.status).toBe(OrderStatus.CONFIRMED);\n  });\n\n  it('should progress through status lifecycle', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    orders.updateStatus(id, OrderStatus.SHIPPED);\n    orders.updateStatus(id, OrderStatus.DELIVERED);\n    expect(orders.getOrder(id)?.status).toBe(OrderStatus.DELIVERED);\n  });\n\n  it('should cancel an order', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(id, OrderStatus.CANCELLED);\n    expect(orders.getOrder(id)?.status).toBe(OrderStatus.CANCELLED);\n  });\n\n  it('should list orders by user', () => {\n    const orders = createOrderService(bus);\n    orders.createOrder('user1', 'cart1', 50);\n    orders.createOrder('user1', 'cart2', 30);\n    orders.createOrder('user2', 'cart3', 20);\n    const user1Orders = orders.listOrders('user1');\n    expect(user1Orders).toHaveLength(2);\n    const user2Orders = orders.listOrders('user2');\n    expect(user2Orders).toHaveLength(1);\n  });\n\n  it('should emit order:created event', async () => {\n    const orders = createOrderService(bus);\n    orders.createOrder('user1', 'cart1', 50);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    const log = bus.getLog();\n    const created = log.filter(e => e.event === Events.ORDER_CREATED);\n    expect(created).toHaveLength(1);\n  });\n\n  it('should emit order:status_changed event with previousStatus', async () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    const log = bus.getLog();\n    const changed = log.filter(e => e.event === Events.ORDER_STATUS_CHANGED);\n    expect(changed).toHaveLength(1);\n    const payload = changed[0].payload as { orderId: string; status: string; previousStatus: string };\n    expect(payload.previousStatus).toBe(OrderStatus.PENDING);\n    expect(payload.status).toBe(OrderStatus.CONFIRMED);\n  });\n});\n\ndescribe('PaymentService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should process a successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 50);\n    expect(result.status).toBe(PaymentStatus.SUCCESS);\n    expect(result.transactionId).toBeDefined();\n    expect(result.error).toBeUndefined();\n  });\n\n  it('should simulate payment failure', async () => {\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const result = await payment.processPayment('order1', 50);\n    expect(result.status).toBe(PaymentStatus.FAILED);\n    expect(result.error).toBeDefined();\n  });\n\n  it('should simulate payment timeout', async () => {\n    const payment = createPaymentService(bus, { simulateTimeout: true });\n    const result = await payment.processPayment('order1', 50);\n    expect(result.status).toBe(PaymentStatus.TIMEOUT);\n    expect(result.error).toBeDefined();\n  });\n\n  it('should refund a successful transaction', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 50);\n    const refunded = await payment.refund(result.transactionId!);\n    expect(refunded).toBe(true);\n  });\n\n  it('should return false for refunding non-existent transaction', async () => {\n    const payment = createPaymentService(bus);\n    const refunded = await payment.refund('nonexistent');\n    expect(refunded).toBe(false);\n  });\n\n  it('should emit payment:processed event', async () => {\n    const payment = createPaymentService(bus);\n    await payment.processPayment('order1', 50);\n    const log = bus.getLog();\n    const events = log.filter(e => e.event === Events.PAYMENT_PROCESSED);\n    expect(events).toHaveLength(1);\n  });\n});\n\ndescribe('NotificationService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should subscribe a user and deliver notifications', async () => {\n    const notifications = createNotificationService(bus);\n    notifications.subscribe('user1');\n\n    // Simulate order creation event\n    await bus.emit(Events.ORDER_CREATED, {\n      orderId: 'order1',\n      userId: 'user1',\n      cartId: 'cart1',\n      total: 50,\n    });\n\n    const userNotifications = notifications.getNotifications('user1');\n    expect(userNotifications).toHaveLength(1);\n    expect(userNotifications[0].type).toBe('order_created');\n  });\n\n  it('should not deliver notifications to unsubscribed users', async () => {\n    const notifications = createNotificationService(bus);\n    // Don't subscribe\n\n    await bus.emit(Events.ORDER_CREATED, {\n      orderId: 'order1',\n      userId: 'user1',\n      cartId: 'cart1',\n      total: 50,\n    });\n\n    const userNotifications = notifications.getNotifications('user1');\n    expect(userNotifications).toHaveLength(0);\n  });\n\n  it('should track order status changes', async () => {\n    const notifications = createNotificationService(bus);\n    notifications.subscribe('user1');\n\n    // First create the order to map orderId -> userId\n    await bus.emit(Events.ORDER_CREATED, {\n      orderId: 'order1',\n      userId: 'user1',\n      cartId: 'cart1',\n      total: 50,\n    });\n\n    // Then change status\n    await bus.emit(Events.ORDER_STATUS_CHANGED, {\n      orderId: 'order1',\n      status: OrderStatus.CONFIRMED,\n      previousStatus: OrderStatus.PENDING,\n    });\n\n    const userNotifications = notifications.getNotifications('user1');\n    expect(userNotifications).toHaveLength(2);\n    expect(userNotifications[1].type).toBe('order_status');\n  });\n\n  it('should track payment events', async () => {\n    const notifications = createNotificationService(bus);\n    notifications.subscribe('user1');\n\n    await bus.emit(Events.ORDER_CREATED, {\n      orderId: 'order1',\n      userId: 'user1',\n      cartId: 'cart1',\n      total: 50,\n    });\n\n    await bus.emit(Events.PAYMENT_PROCESSED, {\n      orderId: 'order1',\n      status: PaymentStatus.SUCCESS,\n      transactionId: 'tx1',\n    });\n\n    const userNotifications = notifications.getNotifications('user1');\n    const paymentNotifications = userNotifications.filter(n => n.type === 'payment');\n    expect(paymentNotifications).toHaveLength(1);\n  });\n\n  it('should return empty array for user with no notifications', () => {\n    const notifications = createNotificationService(bus);\n    expect(notifications.getNotifications('user1')).toEqual([]);\n  });\n});\n\ndescribe('AnalyticsService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should count events by type', async () => {\n    const analytics = createAnalyticsService(bus);\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'W', price: 10, category: 'c' });\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p2', name: 'G', price: 20, category: 'c' });\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n  });\n\n  it('should return 0 for untracked event types', () => {\n    const analytics = createAnalyticsService(bus);\n    expect(analytics.getEventCount('unknown:event')).toBe(0);\n  });\n\n  it('should track revenue from successful payments', async () => {\n    const analytics = createAnalyticsService(bus);\n\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 'tx1' });\n\n    expect(analytics.getRevenue()).toBe(100);\n  });\n\n  it('should not track revenue from failed payments', async () => {\n    const analytics = createAnalyticsService(bus);\n\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.FAILED, error: 'failed' });\n\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  it('should calculate conversion rate', async () => {\n    const analytics = createAnalyticsService(bus);\n\n    // 2 unique carts\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [] });\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c2', userId: 'u2', items: [] });\n\n    // 1 order\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 50 });\n\n    expect(analytics.getConversionRate()).toBe(0.5);\n  });\n\n  it('should return 0 conversion rate when no carts', () => {\n    const analytics = createAnalyticsService(bus);\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n\n  it('should rank top products by order quantity', async () => {\n    const analytics = createAnalyticsService(bus);\n\n    // Cart with items\n    await bus.emit(Events.CART_UPDATED, {\n      cartId: 'c1',\n      userId: 'u1',\n      items: [\n        { productId: 'p1', quantity: 3 },\n        { productId: 'p2', quantity: 1 },\n      ],\n    });\n\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 50 });\n\n    const top = analytics.getTopProducts(2);\n    expect(top).toHaveLength(2);\n    expect(top[0].productId).toBe('p1');\n    expect(top[0].count).toBe(3);\n    expect(top[1].productId).toBe('p2');\n    expect(top[1].count).toBe(1);\n  });\n});\n\ndescribe('Integration: Full E-Commerce Flow', () => {\n  it('should handle a complete purchase flow', async () => {\n    const bus = new EventBus();\n\n    // Create all services -- order matters for event listeners\n    const analytics = createAnalyticsService(bus);\n    const notifications = createNotificationService(bus);\n    const pricing = createPricingService(bus);\n    const catalog = createCatalogService(bus);\n    const inventory = createInventoryService(bus);\n    const cart = createCartService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n\n    // Subscribe user for notifications\n    notifications.subscribe('user1');\n\n    // Create products\n    const productId = catalog.createProduct('Laptop', 999.99, 'electronics');\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    // Set inventory\n    inventory.setStock(productId, 10);\n    inventory.setLowStockThreshold(productId, 2);\n\n    // Pricing should have picked up the product price from event\n    expect(pricing.getPrice(productId)).toBe(999.99);\n\n    // Create cart and add items\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, productId, 2);\n\n    const cartData = cart.getCart(cartId);\n    expect(cartData?.items).toHaveLength(1);\n    expect(cartData?.items[0].quantity).toBe(2);\n\n    // Calculate pricing\n    const items = cartData!.items.map(item => ({\n      productId: item.productId,\n      quantity: item.quantity,\n      price: pricing.getPrice(item.productId),\n    }));\n    const totals = pricing.calculateTotal(items);\n    expect(totals.subtotal).toBe(1999.98);\n    expect(totals.tax).toBe(200);\n    expect(totals.total).toBe(2199.98);\n\n    // Reserve inventory\n    expect(inventory.reserve(productId, 2)).toBe(true);\n    expect(inventory.getStock(productId)).toBe(8);\n\n    // Create order\n    const orderId = orders.createOrder('user1', cartId, totals.total);\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    const order = orders.getOrder(orderId);\n    expect(order?.status).toBe(OrderStatus.PENDING);\n\n    // Process payment\n    const paymentResult = await payment.processPayment(orderId, totals.total);\n    expect(paymentResult.status).toBe(PaymentStatus.SUCCESS);\n\n    // Update order status\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    expect(orders.getOrder(orderId)?.status).toBe(OrderStatus.CONFIRMED);\n\n    // Check notifications were sent\n    const userNotifications = notifications.getNotifications('user1');\n    expect(userNotifications.length).toBeGreaterThanOrEqual(2);\n\n    // Check analytics\n    expect(analytics.getRevenue()).toBe(2199.98);\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(1);\n    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBe(1);\n\n    // Top products\n    const topProducts = analytics.getTopProducts(1);\n    expect(topProducts).toHaveLength(1);\n    expect(topProducts[0].productId).toBe(productId);\n    expect(topProducts[0].count).toBe(2);\n  });\n\n  it('should handle discount codes in pricing', () => {\n    const bus = new EventBus();\n    const pricing = createPricingService(bus);\n\n    pricing.addDiscountCode('SUMMER20', 20);\n\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 2, price: 50 }],\n      'SUMMER20',\n    );\n\n    expect(result.subtotal).toBe(100);\n    expect(result.discount).toBe(20);\n    expect(result.tax).toBe(8); // 10% of 80\n    expect(result.total).toBe(88);\n  });\n\n  it('should handle failed payment gracefully', async () => {\n    const bus = new EventBus();\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus, { simulateFailure: true });\n\n    notifications.subscribe('user1');\n\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    const result = await payment.processPayment(orderId, 100);\n    expect(result.status).toBe(PaymentStatus.FAILED);\n\n    // User should get payment notification\n    const userNotifications = notifications.getNotifications('user1');\n    const paymentNotif = userNotifications.filter(n => n.type === 'payment');\n    expect(paymentNotif).toHaveLength(1);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":126,"cache_read_input_tokens":35180,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":126},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"757812cf-19a5-4201-a986-aaddcc0c499a","uuid":"3c9edf95-cdf9-4302-88a6-0e8ff5161c6a"}
+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0195YFfZqTfaQRMH15wAJtw8","type":"tool_result","content":"File created successfully at: /workspace/tests/services.test.ts"}]},"parent_tool_use_id":null,"session_id":"757812cf-19a5-4201-a986-aaddcc0c499a","uuid":"359ce704-60b3-40d3-8c9a-364e61e0e82a","tool_use_result":{"type":"create","filePath":"/workspace/tests/services.test.ts","content":"import { describe, it, expect, beforeEach } from 'vitest';\nimport { EventBus } from '../src/bus.js';\nimport { Events, OrderStatus, PaymentStatus } from '../src/types.js';\nimport { createCatalogService } from '../src/catalog/index.js';\nimport { createInventoryService } from '../src/inventory/index.js';\nimport { createCartService } from '../src/cart/index.js';\nimport { createPricingService } from '../src/pricing/index.js';\nimport { createOrderService } from '../src/orders/index.js';\nimport { createPaymentService } from '../src/payment/index.js';\nimport { createNotificationService } from '../src/notifications/index.js';\nimport { createAnalyticsService } from '../src/analytics/index.js';\n\ndescribe('CatalogService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should create a product and return its id', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    expect(id).toBeDefined();\n    expect(typeof id).toBe('string');\n  });\n\n  it('should retrieve a product by id', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    const product = catalog.getProduct(id);\n    expect(product).toEqual({ id, name: 'Widget', price: 9.99, category: 'gadgets' });\n  });\n\n  it('should return null for non-existent product', () => {\n    const catalog = createCatalogService(bus);\n    expect(catalog.getProduct('nonexistent')).toBeNull();\n  });\n\n  it('should list all products', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('Widget', 9.99, 'gadgets');\n    catalog.createProduct('Gizmo', 19.99, 'gadgets');\n    catalog.createProduct('Doohickey', 4.99, 'tools');\n    expect(catalog.listProducts()).toHaveLength(3);\n  });\n\n  it('should list products filtered by category', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('Widget', 9.99, 'gadgets');\n    catalog.createProduct('Gizmo', 19.99, 'gadgets');\n    catalog.createProduct('Doohickey', 4.99, 'tools');\n    const gadgets = catalog.listProducts('gadgets');\n    expect(gadgets).toHaveLength(2);\n    expect(gadgets.every(p => p.category === 'gadgets')).toBe(true);\n  });\n\n  it('should search products by name', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('Widget', 9.99, 'gadgets');\n    catalog.createProduct('Super Widget', 19.99, 'gadgets');\n    catalog.createProduct('Gizmo', 14.99, 'gadgets');\n    const results = catalog.searchProducts('widget');\n    expect(results).toHaveLength(2);\n  });\n\n  it('should update a product', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    catalog.updateProduct(id, { name: 'Super Widget', price: 14.99 });\n    const product = catalog.getProduct(id);\n    expect(product?.name).toBe('Super Widget');\n    expect(product?.price).toBe(14.99);\n    expect(product?.category).toBe('gadgets');\n  });\n\n  it('should remove a product', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    expect(catalog.removeProduct(id)).toBe(true);\n    expect(catalog.getProduct(id)).toBeNull();\n    expect(catalog.removeProduct(id)).toBe(false);\n  });\n\n  it('should emit product:created event', async () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('Widget', 9.99, 'gadgets');\n    // Allow bus.emit to complete (it's async but called without await from createProduct)\n    await new Promise(resolve => setTimeout(resolve, 10));\n    const log = bus.getLog();\n    const productCreatedEvents = log.filter(e => e.event === Events.PRODUCT_CREATED);\n    expect(productCreatedEvents).toHaveLength(1);\n    expect(productCreatedEvents[0].payload).toMatchObject({\n      name: 'Widget',\n      price: 9.99,\n      category: 'gadgets',\n    });\n  });\n});\n\ndescribe('InventoryService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should set and get stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 100);\n    expect(inventory.getStock('p1')).toBe(100);\n  });\n\n  it('should return 0 for unknown product stock', () => {\n    const inventory = createInventoryService(bus);\n    expect(inventory.getStock('nonexistent')).toBe(0);\n  });\n\n  it('should reserve stock successfully', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 10);\n    expect(inventory.reserve('p1', 5)).toBe(true);\n    expect(inventory.getStock('p1')).toBe(5);\n  });\n\n  it('should fail to reserve when insufficient stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 3);\n    expect(inventory.reserve('p1', 5)).toBe(false);\n    expect(inventory.getStock('p1')).toBe(3);\n  });\n\n  it('should release reserved stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 10);\n    inventory.reserve('p1', 5);\n    inventory.release('p1', 3);\n    expect(inventory.getStock('p1')).toBe(8);\n  });\n\n  it('should emit low stock alert when stock falls below threshold', async () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 10);\n    inventory.setLowStockThreshold('p1', 5);\n    inventory.reserve('p1', 6);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    const log = bus.getLog();\n    const alerts = log.filter(e => e.event === Events.LOW_STOCK_ALERT);\n    expect(alerts.length).toBeGreaterThan(0);\n  });\n\n  it('should emit inventory:updated on setStock', async () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 50);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    const log = bus.getLog();\n    const updates = log.filter(e => e.event === Events.INVENTORY_UPDATED);\n    expect(updates).toHaveLength(1);\n  });\n});\n\ndescribe('CartService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should create a cart and return id', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    expect(id).toBeDefined();\n  });\n\n  it('should add items to cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    const c = cart.getCart(id);\n    expect(c?.items).toHaveLength(1);\n    expect(c?.items[0]).toEqual({ productId: 'p1', quantity: 2 });\n  });\n\n  it('should consolidate same product when added multiple times', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p1', 3);\n    const c = cart.getCart(id);\n    expect(c?.items).toHaveLength(1);\n    expect(c?.items[0]).toEqual({ productId: 'p1', quantity: 5 });\n  });\n\n  it('should remove items from cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p2', 1);\n    cart.removeItem(id, 'p1');\n    const c = cart.getCart(id);\n    expect(c?.items).toHaveLength(1);\n    expect(c?.items[0].productId).toBe('p2');\n  });\n\n  it('should clear cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p2', 1);\n    cart.clearCart(id);\n    const c = cart.getCart(id);\n    expect(c?.items).toHaveLength(0);\n  });\n\n  it('should update quantity', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.updateQuantity(id, 'p1', 5);\n    const c = cart.getCart(id);\n    expect(c?.items[0].quantity).toBe(5);\n  });\n\n  it('should remove item when quantity set to 0', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.updateQuantity(id, 'p1', 0);\n    const c = cart.getCart(id);\n    expect(c?.items).toHaveLength(0);\n  });\n\n  it('should return null for non-existent cart', () => {\n    const cart = createCartService(bus);\n    expect(cart.getCart('nonexistent')).toBeNull();\n  });\n});\n\ndescribe('PricingService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should calculate total with tax', () => {\n    const pricing = createPricingService(bus);\n    const result = pricing.calculateTotal([\n      { productId: 'p1', quantity: 2, price: 10 },\n    ]);\n    expect(result.subtotal).toBe(20);\n    expect(result.discount).toBe(0);\n    expect(result.tax).toBe(2); // 10% of 20\n    expect(result.total).toBe(22);\n  });\n\n  it('should apply discount codes', () => {\n    const pricing = createPricingService(bus);\n    pricing.addDiscountCode('SAVE10', 10);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'SAVE10',\n    );\n    expect(result.subtotal).toBe(100);\n    expect(result.discount).toBe(10);\n    expect(result.tax).toBe(9); // 10% of 90\n    expect(result.total).toBe(99);\n  });\n\n  it('should ignore unknown discount codes', () => {\n    const pricing = createPricingService(bus);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'INVALID',\n    );\n    expect(result.discount).toBe(0);\n    expect(result.total).toBe(110);\n  });\n\n  it('should track product prices from events', async () => {\n    const pricing = createPricingService(bus);\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'Widget', price: 9.99, category: 'gadgets' });\n    expect(pricing.getPrice('p1')).toBe(9.99);\n  });\n\n  it('should return 0 for unknown product price', () => {\n    const pricing = createPricingService(bus);\n    expect(pricing.getPrice('nonexistent')).toBe(0);\n  });\n});\n\ndescribe('OrderService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should create an order in pending status', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    const order = orders.getOrder(id);\n    expect(order).toBeDefined();\n    expect(order?.status).toBe(OrderStatus.PENDING);\n    expect(order?.total).toBe(50);\n    expect(order?.userId).toBe('user1');\n  });\n\n  it('should return null for non-existent order', () => {\n    const orders = createOrderService(bus);\n    expect(orders.getOrder('nonexistent')).toBeNull();\n  });\n\n  it('should update order status', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    expect(orders.getOrder(id)?.status).toBe(OrderStatus.CONFIRMED);\n  });\n\n  it('should progress through status lifecycle', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    orders.updateStatus(id, OrderStatus.SHIPPED);\n    orders.updateStatus(id, OrderStatus.DELIVERED);\n    expect(orders.getOrder(id)?.status).toBe(OrderStatus.DELIVERED);\n  });\n\n  it('should cancel an order', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(id, OrderStatus.CANCELLED);\n    expect(orders.getOrder(id)?.status).toBe(OrderStatus.CANCELLED);\n  });\n\n  it('should list orders by user', () => {\n    const orders = createOrderService(bus);\n    orders.createOrder('user1', 'cart1', 50);\n    orders.createOrder('user1', 'cart2', 30);\n    orders.createOrder('user2', 'cart3', 20);\n    const user1Orders = orders.listOrders('user1');\n    expect(user1Orders).toHaveLength(2);\n    const user2Orders = orders.listOrders('user2');\n    expect(user2Orders).toHaveLength(1);\n  });\n\n  it('should emit order:created event', async () => {\n    const orders = createOrderService(bus);\n    orders.createOrder('user1', 'cart1', 50);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    const log = bus.getLog();\n    const created = log.filter(e => e.event === Events.ORDER_CREATED);\n    expect(created).toHaveLength(1);\n  });\n\n  it('should emit order:status_changed event with previousStatus', async () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    const log = bus.getLog();\n    const changed = log.filter(e => e.event === Events.ORDER_STATUS_CHANGED);\n    expect(changed).toHaveLength(1);\n    const payload = changed[0].payload as { orderId: string; status: string; previousStatus: string };\n    expect(payload.previousStatus).toBe(OrderStatus.PENDING);\n    expect(payload.status).toBe(OrderStatus.CONFIRMED);\n  });\n});\n\ndescribe('PaymentService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should process a successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 50);\n    expect(result.status).toBe(PaymentStatus.SUCCESS);\n    expect(result.transactionId).toBeDefined();\n    expect(result.error).toBeUndefined();\n  });\n\n  it('should simulate payment failure', async () => {\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const result = await payment.processPayment('order1', 50);\n    expect(result.status).toBe(PaymentStatus.FAILED);\n    expect(result.error).toBeDefined();\n  });\n\n  it('should simulate payment timeout', async () => {\n    const payment = createPaymentService(bus, { simulateTimeout: true });\n    const result = await payment.processPayment('order1', 50);\n    expect(result.status).toBe(PaymentStatus.TIMEOUT);\n    expect(result.error).toBeDefined();\n  });\n\n  it('should refund a successful transaction', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 50);\n    const refunded = await payment.refund(result.transactionId!);\n    expect(refunded).toBe(true);\n  });\n\n  it('should return false for refunding non-existent transaction', async () => {\n    const payment = createPaymentService(bus);\n    const refunded = await payment.refund('nonexistent');\n    expect(refunded).toBe(false);\n  });\n\n  it('should emit payment:processed event', async () => {\n    const payment = createPaymentService(bus);\n    await payment.processPayment('order1', 50);\n    const log = bus.getLog();\n    const events = log.filter(e => e.event === Events.PAYMENT_PROCESSED);\n    expect(events).toHaveLength(1);\n  });\n});\n\ndescribe('NotificationService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should subscribe a user and deliver notifications', async () => {\n    const notifications = createNotificationService(bus);\n    notifications.subscribe('user1');\n\n    // Simulate order creation event\n    await bus.emit(Events.ORDER_CREATED, {\n      orderId: 'order1',\n      userId: 'user1',\n      cartId: 'cart1',\n      total: 50,\n    });\n\n    const userNotifications = notifications.getNotifications('user1');\n    expect(userNotifications).toHaveLength(1);\n    expect(userNotifications[0].type).toBe('order_created');\n  });\n\n  it('should not deliver notifications to unsubscribed users', async () => {\n    const notifications = createNotificationService(bus);\n    // Don't subscribe\n\n    await bus.emit(Events.ORDER_CREATED, {\n      orderId: 'order1',\n      userId: 'user1',\n      cartId: 'cart1',\n      total: 50,\n    });\n\n    const userNotifications = notifications.getNotifications('user1');\n    expect(userNotifications).toHaveLength(0);\n  });\n\n  it('should track order status changes', async () => {\n    const notifications = createNotificationService(bus);\n    notifications.subscribe('user1');\n\n    // First create the order to map orderId -> userId\n    await bus.emit(Events.ORDER_CREATED, {\n      orderId: 'order1',\n      userId: 'user1',\n      cartId: 'cart1',\n      total: 50,\n    });\n\n    // Then change status\n    await bus.emit(Events.ORDER_STATUS_CHANGED, {\n      orderId: 'order1',\n      status: OrderStatus.CONFIRMED,\n      previousStatus: OrderStatus.PENDING,\n    });\n\n    const userNotifications = notifications.getNotifications('user1');\n    expect(userNotifications).toHaveLength(2);\n    expect(userNotifications[1].type).toBe('order_status');\n  });\n\n  it('should track payment events', async () => {\n    const notifications = createNotificationService(bus);\n    notifications.subscribe('user1');\n\n    await bus.emit(Events.ORDER_CREATED, {\n      orderId: 'order1',\n      userId: 'user1',\n      cartId: 'cart1',\n      total: 50,\n    });\n\n    await bus.emit(Events.PAYMENT_PROCESSED, {\n      orderId: 'order1',\n      status: PaymentStatus.SUCCESS,\n      transactionId: 'tx1',\n    });\n\n    const userNotifications = notifications.getNotifications('user1');\n    const paymentNotifications = userNotifications.filter(n => n.type === 'payment');\n    expect(paymentNotifications).toHaveLength(1);\n  });\n\n  it('should return empty array for user with no notifications', () => {\n    const notifications = createNotificationService(bus);\n    expect(notifications.getNotifications('user1')).toEqual([]);\n  });\n});\n\ndescribe('AnalyticsService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should count events by type', async () => {\n    const analytics = createAnalyticsService(bus);\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'W', price: 10, category: 'c' });\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p2', name: 'G', price: 20, category: 'c' });\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n  });\n\n  it('should return 0 for untracked event types', () => {\n    const analytics = createAnalyticsService(bus);\n    expect(analytics.getEventCount('unknown:event')).toBe(0);\n  });\n\n  it('should track revenue from successful payments', async () => {\n    const analytics = createAnalyticsService(bus);\n\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 'tx1' });\n\n    expect(analytics.getRevenue()).toBe(100);\n  });\n\n  it('should not track revenue from failed payments', async () => {\n    const analytics = createAnalyticsService(bus);\n\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.FAILED, error: 'failed' });\n\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  it('should calculate conversion rate', async () => {\n    const analytics = createAnalyticsService(bus);\n\n    // 2 unique carts\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [] });\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c2', userId: 'u2', items: [] });\n\n    // 1 order\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 50 });\n\n    expect(analytics.getConversionRate()).toBe(0.5);\n  });\n\n  it('should return 0 conversion rate when no carts', () => {\n    const analytics = createAnalyticsService(bus);\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n\n  it('should rank top products by order quantity', async () => {\n    const analytics = createAnalyticsService(bus);\n\n    // Cart with items\n    await bus.emit(Events.CART_UPDATED, {\n      cartId: 'c1',\n      userId: 'u1',\n      items: [\n        { productId: 'p1', quantity: 3 },\n        { productId: 'p2', quantity: 1 },\n      ],\n    });\n\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 50 });\n\n    const top = analytics.getTopProducts(2);\n    expect(top).toHaveLength(2);\n    expect(top[0].productId).toBe('p1');\n    expect(top[0].count).toBe(3);\n    expect(top[1].productId).toBe('p2');\n    expect(top[1].count).toBe(1);\n  });\n});\n\ndescribe('Integration: Full E-Commerce Flow', () => {\n  it('should handle a complete purchase flow', async () => {\n    const bus = new EventBus();\n\n    // Create all services -- order matters for event listeners\n    const analytics = createAnalyticsService(bus);\n    const notifications = createNotificationService(bus);\n    const pricing = createPricingService(bus);\n    const catalog = createCatalogService(bus);\n    const inventory = createInventoryService(bus);\n    const cart = createCartService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n\n    // Subscribe user for notifications\n    notifications.subscribe('user1');\n\n    // Create products\n    const productId = catalog.createProduct('Laptop', 999.99, 