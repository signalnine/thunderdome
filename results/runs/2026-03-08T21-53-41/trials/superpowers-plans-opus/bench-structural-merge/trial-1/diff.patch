+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012ZydQcVmsWycJHnEMnoirS","type":"tool_result","content":"     1→import { Version, MergeResult, Conflict, DocumentData, BranchData } from './types.js';\n     2→import { deepClone, generateId, threeWayMerge } from './utils.js';\n     3→\n     4→function cloneDocumentData(doc: DocumentData): DocumentData {\n     5→  return {\n     6→    content: deepClone(doc.content),\n     7→    versions: doc.versions.map(v => ({\n     8→      id: v.id,\n     9→      timestamp: v.timestamp,\n    10→      content: deepClone(v.content),\n    11→    })),\n    12→    deleted: doc.deleted,\n    13→  };\n    14→}\n    15→\n    16→function cloneDocumentsMap(docs: Map<string, DocumentData>): Map<string, DocumentData> {\n    17→  const cloned = new Map<string, DocumentData>();\n    18→  for (const [id, doc] of docs) {\n    19→    cloned.set(id, cloneDocumentData(doc));\n    20→  }\n    21→  return cloned;\n    22→}\n    23→\n    24→export class DocumentStore {\n    25→  private branches: Map<string, BranchData> = new Map();\n    26→  private currentBranch: string = 'main';\n    27→\n    28→  constructor() {\n    29→    this.branches.set('main', {\n    30→      documents: new Map(),\n    31→      parentSnapshot: null,\n    32→      parentBranch: null,\n    33→    });\n    34→  }\n    35→\n    36→  private getBranchData(): BranchData {\n    37→    const branch = this.branches.get(this.currentBranch);\n    38→    if (!branch) {\n    39→      throw new Error(`Branch \"${this.currentBranch}\" does not exist`);\n    40→    }\n    41→    return branch;\n    42→  }\n    43→\n    44→  // --- Document CRUD ---\n    45→\n    46→  create(id: string, content: object): void {\n    47→    const branch = this.getBranchData();\n    48→    const existing = branch.documents.get(id);\n    49→    if (existing && !existing.deleted) {\n    50→      throw new Error(`Document \"${id}\" already exists`);\n    51→    }\n    52→    const clonedContent = deepClone(content);\n    53→    const version: Version = {\n    54→      id: generateId(),\n    55→      timestamp: Date.now(),\n    56→      content: deepClone(clonedContent),\n    57→    };\n    58→    branch.documents.set(id, {\n    59→      content: clonedContent,\n    60→      versions: [version],\n    61→      deleted: false,\n    62→    });\n    63→  }\n    64→\n    65→  get(id: string): object {\n    66→    const branch = this.getBranchData();\n    67→    const doc = branch.documents.get(id);\n    68→    if (!doc || doc.deleted) {\n    69→      throw new Error(`Document \"${id}\" does not exist`);\n    70→    }\n    71→    return deepClone(doc.content);\n    72→  }\n    73→\n    74→  update(id: string, content: object): void {\n    75→    const branch = this.getBranchData();\n    76→    const doc = branch.documents.get(id);\n    77→    if (!doc || doc.deleted) {\n    78→      throw new Error(`Document \"${id}\" does not exist`);\n    79→    }\n    80→    const clonedContent = deepClone(content);\n    81→    const version: Version = {\n    82→      id: generateId(),\n    83→      timestamp: Date.now(),\n    84→      content: deepClone(clonedContent),\n    85→    };\n    86→    doc.content = clonedContent;\n    87→    doc.versions.push(version);\n    88→  }\n    89→\n    90→  delete(id: string): void {\n    91→    const branch = this.getBranchData();\n    92→    const doc = branch.documents.get(id);\n    93→    if (!doc || doc.deleted) {\n    94→      throw new Error(`Document \"${id}\" does not exist`);\n    95→    }\n    96→    doc.deleted = true;\n    97→  }\n    98→\n    99→  // --- Version History ---\n   100→\n   101→  getHistory(id: string): Version[] {\n   102→    const branch = this.getBranchData();\n   103→    const doc = branch.documents.get(id);\n   104→    if (!doc) {\n   105→      throw new Error(`Document \"${id}\" does not exist`);\n   106→    }\n   107→    return doc.versions.map(v => ({\n   108→      id: v.id,\n   109→      timestamp: v.timestamp,\n   110→      content: deepClone(v.content),\n   111→    }));\n   112→  }\n   113→\n   114→  getVersion(id: string, versionId: string): object {\n   115→    const branch = this.getBranchData();\n   116→    const doc = branch.documents.get(id);\n   117→    if (!doc) {\n   118→      throw new Error(`Document \"${id}\" does not exist`);\n   119→    }\n   120→    const version = doc.versions.find(v => v.id === versionId);\n   121→    if (!version) {\n   122→      throw new Error(`Version \"${versionId}\" does not exist for document \"${id}\"`);\n   123→    }\n   124→    return deepClone(version.content);\n   125→  }\n   126→\n   127→  // --- Branching ---\n   128→\n   129→  createBranch(name: string, fromBranch?: string): void {\n   130→    if (this.branches.has(name)) {\n   131→      throw new Error(`Branch \"${name}\" already exists`);\n   132→    }\n   133→    const sourceName = fromBranch ?? this.currentBranch;\n   134→    const source = this.branches.get(sourceName);\n   135→    if (!source) {\n   136→      throw new Error(`Branch \"${sourceName}\" does not exist`);\n   137→    }\n   138→    this.branches.set(name, {\n   139→      documents: cloneDocumentsMap(source.documents),\n   140→      parentSnapshot: cloneDocumentsMap(source.documents),\n   141→      parentBranch: sourceName,\n   142→    });\n   143→  }\n   144→\n   145→  switchBranch(name: string): void {\n   146→    if (!this.branches.has(name)) {\n   147→      throw new Error(`Branch \"${name}\" does not exist`);\n   148→    }\n   149→    this.currentBranch = name;\n   150→  }\n   151→\n   152→  getBranch(): string {\n   153→    return this.currentBranch;\n   154→  }\n   155→\n   156→  listBranches(): string[] {\n   157→    return Array.from(this.branches.keys());\n   158→  }\n   159→\n   160→  // --- Merging ---\n   161→\n   162→  merge(sourceBranch: string): MergeResult {\n   163→    const sourceBranchData = this.branches.get(sourceBranch);\n   164→    if (!sourceBranchData) {\n   165→      throw new Error(`Branch \"${sourceBranch}\" does not exist`);\n   166→    }\n   167→    const targetBranchData = this.getBranchData();\n   168→\n   169→    // Find common ancestor: the snapshot taken when the source branch was created\n   170→    // This is the state of the parent at the time the source branch diverged\n   171→    const ancestorDocs = sourceBranchData.parentSnapshot;\n   172→\n   173→    const merged: Record<string, object> = {};\n   174→    const allConflicts: Conflict[] = [];\n   175→\n   176→    // Collect all document IDs across ancestor, target (ours), and source (theirs)\n   177→    const allDocIds = new Set<string>();\n   178→    if (ancestorDocs) {\n   179→      for (const id of ancestorDocs.keys()) allDocIds.add(id);\n   180→    }\n   181→    for (const id of targetBranchData.documents.keys()) allDocIds.add(id);\n   182→    for (const id of sourceBranchData.documents.keys()) allDocIds.add(id);\n   183→\n   184→    for (const docId of allDocIds) {\n   185→      const ancestorDoc = ancestorDocs?.get(docId) ?? null;\n   186→      const oursDoc = targetBranchData.documents.get(docId) ?? null;\n   187→      const theirsDoc = sourceBranchData.documents.get(docId) ?? null;\n   188→\n   189→      const ancestorExists = ancestorDoc !== null && !ancestorDoc.deleted;\n   190→      const oursExists = oursDoc !== null && !oursDoc.deleted;\n   191→      const theirsExists = theirsDoc !== null && !theirsDoc.deleted;\n   192→\n   193→      // Determine if each side changed relative to ancestor\n   194→      const oursContentStr = oursExists ? JSON.stringify(oursDoc!.content) : null;\n   195→      const theirsContentStr = theirsExists ? JSON.stringify(theirsDoc!.content) : null;\n   196→      const ancestorContentStr = ancestorExists ? JSON.stringify(ancestorDoc!.content) : null;\n   197→\n   198→      const oursChanged = oursContentStr !== ancestorContentStr || oursExists !== ancestorExists;\n   199→      const theirsChanged = theirsContentStr !== ancest