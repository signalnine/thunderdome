.toEqual({ name: 'Bob' });\n    });\n\n    it('should throw if document does not exist', () => {\n      expect(() => store.update('nonexistent', { name: 'Bob' })).toThrow();\n    });\n\n    it('should deep clone content on update', () => {\n      store.create('doc1', { name: 'Alice' });\n      const newContent = { name: 'Bob', nested: { x: 1 } };\n      store.update('doc1', newContent);\n      newContent.nested.x = 999;\n      expect(store.get('doc1')).toEqual({ name: 'Bob', nested: { x: 1 } });\n    });\n  });\n\n  describe('delete', () => {\n    it('should delete a document', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.delete('doc1');\n      expect(() => store.get('doc1')).toThrow();\n    });\n\n    it('should throw if document does not exist', () => {\n      expect(() => store.delete('nonexistent')).toThrow();\n    });\n\n    it('should throw if document already deleted', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.delete('doc1');\n      expect(() => store.delete('doc1')).toThrow();\n    });\n  });\n\n  // --- Version History ---\n\n  describe('getHistory', () => {\n    it('should return versions in chronological order', () => {\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n      store.update('doc1', { v: 3 });\n\n      const history = store.getHistory('doc1');\n      expect(history).toHaveLength(3);\n      expect(history[0].content).toEqual({ v: 1 });\n      expect(history[1].content).toEqual({ v: 2 });\n      expect(history[2].content).toEqual({ v: 3 });\n    });\n\n    it('should have unique version IDs', () => {\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n\n      const history = store.getHistory('doc1');\n      expect(history[0].id).not.toBe(history[1].id);\n    });\n\n    it('should include timestamps', () => {\n      store.create('doc1', { v: 1 });\n      const history = store.getHistory('doc1');\n      expect(typeof history[0].timestamp).toBe('number');\n      expect(history[0].timestamp).toBeGreaterThan(0);\n    });\n\n    it('should throw for nonexistent document', () => {\n      expect(() => store.getHistory('nonexistent')).toThrow();\n    });\n\n    it('should return deep cloned versions', () => {\n      store.create('doc1', { nested: { val: 1 } });\n      const history = store.getHistory('doc1');\n      (history[0].content as any).nested.val = 999;\n      expect(store.get('doc1')).toEqual({ nested: { val: 1 } });\n    });\n  });\n\n  describe('getVersion', () => {\n    it('should return content at a specific version', () => {\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n\n      const history = store.getHistory('doc1');\n      expect(store.getVersion('doc1', history[0].id)).toEqual({ v: 1 });\n      expect(store.getVersion('doc1', history[1].id)).toEqual({ v: 2 });\n    });\n\n    it('should throw for nonexistent version', () => {\n      store.create('doc1', { v: 1 });\n      expect(() => store.getVersion('doc1', 'bad_version')).toThrow();\n    });\n\n    it('should throw for nonexistent document', () => {\n      expect(() => store.getVersion('nonexistent', 'v1')).toThrow();\n    });\n  });\n\n  // --- Branching ---\n\n  describe('branching', () => {\n    it('should start on main branch', () => {\n      expect(store.getBranch()).toBe('main');\n    });\n\n    it('should list branches', () => {\n      expect(store.listBranches()).toEqual(['main']);\n    });\n\n    it('should create and switch to a new branch', () => {\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      expect(store.getBranch()).toBe('feature');\n    });\n\n    it('should list all branches', () => {\n      store.createBranch('feature');\n      store.createBranch('bugfix');\n      expect(store.listBranches()).toContain('main');\n      expect(store.listBranches()).toContain('feature');\n      expect(store.listBranches()).toContain('bugfix');\n    });\n\n    it('should isolate changes between branches', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'Bob' });\n\n      expect(store.get('doc1')).toEqual({ name: 'Bob' });\n      store.switchBranch('main');\n      expect(store.get('doc1')).toEqual({ name: 'Alice' });\n    });\n\n    it('should create branch from specific branch', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'Bob' });\n\n      store.createBranch('feature2', 'feature');\n      store.switchBranch('feature2');\n      expect(store.get('doc1')).toEqual({ name: 'Bob' });\n    });\n\n    it('should throw when creating duplicate branch', () => {\n      store.createBranch('feature');\n      expect(() => store.createBranch('feature')).toThrow();\n    });\n\n    it('should throw when switching to nonexistent branch', () => {\n      expect(() => store.switchBranch('nonexistent')).toThrow();\n    });\n\n    it('should not share new documents between branches', () => {\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.create('doc1', { name: 'feature-only' });\n\n      store.switchBranch('main');\n      expect(() => store.get('doc1')).toThrow();\n    });\n\n    it('should deep clone documents when creating branch', () => {\n      store.create('doc1', { nested: { val: 1 } });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { nested: { val: 2 } });\n\n      store.switchBranch('main');\n      expect(store.get('doc1')).toEqual({ nested: { val: 1 } });\n    });\n  });\n\n  // --- Merging ---\n\n  describe('merge', () => {\n    it('should merge when only source branch changed', () => {\n      store.create('doc1', { a: 1, b: 2 });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n    