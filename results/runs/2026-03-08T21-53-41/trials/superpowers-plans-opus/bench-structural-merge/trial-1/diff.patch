@@ -0,0 +1,342 @@
+import { Version, MergeResult, Conflict, DocumentData, BranchData } from './types.js';
+import { deepClone, generateId, threeWayMerge } from './utils.js';
+
+function cloneDocumentData(doc: DocumentData): DocumentData {
+  return {
+    content: deepClone(doc.content),
+    versions: doc.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    })),
+    deleted: doc.deleted,
+  };
+}
+
+function cloneDocumentsMap(docs: Map<string, DocumentData>): Map<string, DocumentData> {
+  const cloned = new Map<string, DocumentData>();
+  for (const [id, doc] of docs) {
+    cloned.set(id, cloneDocumentData(doc));
+  }
+  return cloned;
+}
+
+export class DocumentStore {
+  private branches: Map<string, BranchData> = new Map();
+  private currentBranch: string = 'main';
+
+  constructor() {
+    this.branches.set('main', {
+      documents: new Map(),
+      parentSnapshot: null,
+      parentBranch: null,
+    });
+  }
+
+  private getBranchData(): BranchData {
+    const branch = this.branches.get(this.currentBranch);
+    if (!branch) {
+      throw new Error(`Branch "${this.currentBranch}" does not exist`);
+    }
+    return branch;
+  }
+
+  // --- Document CRUD ---
+
+  create(id: string, content: object): void {
+    const branch = this.getBranchData();
+    const existing = branch.documents.get(id);
+    if (existing && !existing.deleted) {
+      throw new Error(`Document "${id}" already exists`);
+    }
+    const clonedContent = deepClone(content);
+    const version: Version = {
+      id: generateId(),
+      timestamp: Date.now(),
+      content: deepClone(clonedContent),
+    };
+    branch.documents.set(id, {
+      content: clonedContent,
+      versions: [version],
+      deleted: false,
+    });
+  }
+
+  get(id: string): object {
+    const branch = this.getBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    return deepClone(doc.content);
+  }
+
+  update(id: string, content: object): void {
+    const branch = this.getBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    const clonedContent = deepClone(content);
+    const version: Version = {
+      id: generateId(),
+      timestamp: Date.now(),
+      content: deepClone(clonedContent),
+    };
+    doc.content = clonedContent;
+    doc.versions.push(version);
+  }
+
+  delete(id: string): void {
+    const branch = this.getBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    doc.deleted = true;
+  }
+
+  // --- Version History ---
+
+  getHistory(id: string): Version[] {
+    const branch = this.getBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    return doc.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    }));
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const branch = this.getBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    const version = doc.versions.find(v => v.id === versionId);
+    if (!version) {
+      throw new Error(`Version "${versionId}" does not exist for document "${id}"`);
+    }
+    return deepClone(version.content);
+  }
+
+  // --- Branching ---
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch "${name}" already exists`);
+    }
+    const sourceName = fromBranch ?? this.currentBranch;
+    const source = this.branches.get(sourceName);
+    if (!source) {
+      throw new Error(`Branch "${sourceName}" does not exist`);
+    }
+    this.branches.set(name, {
+      documents: cloneDocumentsMap(source.documents),
+      parentSnapshot: cloneDocumentsMap(source.documents),
+      parentBranch: sourceName,
+    });
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch "${name}" does not exist`);
+    }
+    this.currentBranch = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranch;
+  }
+
+  listBranches(): string[] {
+    return Array.from(this.branches.keys());
+  }
+
+  // --- Merging ---
+
+  merge(sourceBranch: string): MergeResult {
+    const sourceBranchData = this.branches.get(sourceBranch);
+    if (!sourceBranchData) {
+      throw new Error(`Branch "${sourceBranch}" does not exist`);
+    }
+    const targetBranchData = this.getBranchData();
+
+    // Find common ancestor: the snapshot taken when the source branch was created
+    // This is the state of the parent at the time the source branch diverged
+    const ancestorDocs = sourceBranchData.parentSnapshot;
+
+    const merged: Record<string, object> = {};
+    const allConflicts: Conflict[] = [];
+
+    // Collect all document IDs across ancestor, target (ours), and source (theirs)
+    const allDocIds = new Set<string>();
+    if (ancestorDocs) {
+      for (const id of ancestorDocs.keys()) allDocIds.add(id);
+    }
+    for (const id of targetBranchData.documents.keys()) allDocIds.add(id);
+    for (const id of sourceBranchData.documents.keys()) allDocIds.add(id);
+
+    for (const docId of allDocIds) {
+      const ancestorDoc = ancestorDocs?.get(docId) ?? null;
+      const oursDoc = targetBranchData.documents.get(docId) ?? null;
+      const theirsDoc = sourceBranchData.documents.get(docId) ?? null;
+
+      const ancestorExists = ancestorDoc !== null && !ancestorDoc.deleted;
+      const oursExists = oursDoc !== null && !oursDoc.deleted;
+      const theirsExists = theirsDoc !== null && !theirsDoc.deleted;
+
+      // Determine if each side changed relative to ancestor
+      const oursContentStr = oursExists ? JSON.stringify(oursDoc!.content) : null;
+      const theirsContentStr = theirsExists ? JSON.stringify(theirsDoc!.content) : null;
+      const ancestorContentStr = ancestorExists ? JSON.stringify(ancestorDoc!.content) : null;
+
+      const oursChanged = oursContentStr !== ancestorContentStr || oursExists !== ancestorExists;
+      const theirsChanged = theirsContentStr !== ancestorContentStr || theirsExists !== ancestorExists;
+
+      if (!oursChanged && !theirsChanged) {
+        // No changes on either side - keep current state
+        if (oursExists) {
+          merged[docId] = deepClone(oursDoc!.content);
+        }
+        continue;
+      }
+
+      if (!theirsChanged) {
+        // Only ours changed - keep ours
+        if (oursExists) {
+          merged[docId] = deepClone(oursDoc!.content);
+        }
+        // else: ours deleted it, don't include
+        continue;
+      }
+
+      if (!oursChanged) {
+        // Only theirs changed - take theirs
+        if (theirsExists) {
+          merged[docId] = deepClone(theirsDoc!.content);
+        }
+        // else: theirs deleted it, don't include
+        continue;
+      }
+
+      // Both sides changed
+      // Handle deletion cases
+      if (!oursExists && !theirsExists) {
+        // Both deleted - no conflict, document stays deleted
+        continue;
+      }
+
+      if (!oursExists && theirsExists) {
+        // Ours deleted, theirs modified - conflict
+        merged[docId] = deepClone(theirsDoc!.content);
+        allConflicts.push({
+          documentId: docId,
+          path: '',
+          base: ancestorExists ? deepClone(ancestorDoc!.content) : undefined,
+          ours: undefined,
+          theirs: deepClone(theirsDoc!.content),
+        });
+        continue;
+      }
+
+      if (oursExists && !theirsExists) {
+        // Ours modified, theirs deleted - conflict
+        merged[docId] = deepClone(oursDoc!.content);
+        allConflicts.push({
+          documentId: docId,
+          path: '',
+          base: ancestorExists ? deepClone(ancestorDoc!.content) : undefined,
+          ours: deepClone(oursDoc!.content),
+          theirs: undefined,
+        });
+        continue;
+      }
+
+      // Both exist and both changed - do three-way field merge
+      if (!ancestorExists) {
+        // Both created the same document independently
+        // Treat base as empty object for merge purposes
+        const result = threeWayMerge(
+          {} as Record<string, unknown>,
+          oursDoc!.content as Record<string, unknown>,
+          theirsDoc!.content as Record<string, unknown>
+        );
+        merged[docId] = result.merged;
+        for (const c of result.conflicts) {
+          allConflicts.push({
+            documentId: docId,
+            path: c.path,
+            base: c.base,
+            ours: c.ours,
+            theirs: c.theirs,
+          });
+        }
+      } else {
+        const result = threeWayMerge(
+          ancestorDoc!.content as Record<string, unknown>,
+          oursDoc!.content as Record<string, unknown>,
+          theirsDoc!.content as Record<string, unknown>
+        );
+        merged[docId] = result.merged;
+        for (const c of result.conflicts) {
+          allConflicts.push({
+            documentId: docId,
+            path: c.path,
+            base: c.base,
+            ours: c.ours,
+            theirs: c.theirs,
+          });
+        }
+      }
+    }
+
+    const applied = allConflicts.length === 0;
+
+    if (applied) {
+      // Auto-apply: update the current branch's documents with merged results
+      // First handle deletions: docs that existed but aren't in merged
+      for (const docId of allDocIds) {
+        if (!(docId in merged)) {
+          // Document was deleted in the merge
+          const doc = targetBranchData.documents.get(docId);
+          if (doc && !doc.deleted) {
+            doc.deleted = true;
+          }
+        } else {
+          // Document exists in merged result
+          const existingDoc = targetBranchData.documents.get(docId);
+          const mergedContent = deepClone(merged[docId]);
+          if (existingDoc && !existingDoc.deleted) {
+            // Check if content actually changed
+            if (JSON.stringify(existingDoc.content) !== JSON.stringify(mergedContent)) {
+              existingDoc.content = mergedContent;
+              existingDoc.versions.push({
+                id: generateId(),
+                timestamp: Date.now(),
+                content: deepClone(mergedContent),
+              });
+            }
+          } else {
+            // Document is new to this branch (came from theirs)
+            targetBranchData.documents.set(docId, {
+              content: mergedContent,
+              versions: [{
+                id: generateId(),
+                timestamp: Date.now(),
+                content: deepClone(mergedContent),
+              }],
+              deleted: false,
+            });
+          }
+        }
+      }
+    }
+
+    return { merged, conflicts: allConflicts, applied };
+  }
+}
diff --git a/src/types.ts b/src/types.ts
new file mode 100644
index 0000000..25ba08f
--- /dev/null
+++ b/src/types.ts
@@ -0,0 +1,34 @@
+export interface Version {
+  id: string;
+  timestamp: number;
+  content: object;
+}
+
+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+export interface Conflict {
+  documentId: string;
+  path: string;
+  /* eslint-disable @typescript-eslint/no-explicit-any */
+  base: any;
+  ours: any;
+  theirs: any;
+  /* eslint-enable @typescript-eslint/no-explicit-any */
+}
+
+export interface DocumentData {
+  content: object;
+  versions: Version[];
+  deleted: boolean;
+}
+
+export interface BranchData {
+  documents: Map<string, DocumentData>;
+  /** Snapshot of documents at the time this branch was created (common ancestor for merges) */
+  parentSnapshot: Map<string, DocumentData> | null;
+  parentBranch: string | null;
+}
