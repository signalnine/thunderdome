me: 'Bob', age: 30 } });\n\n      store.switchBranch('main');\n      store.update('doc1', { user: { name: 'Charlie', age: 30 } });\n\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(false);\n      expect(result.conflicts).toHaveLength(1);\n      expect(result.conflicts[0].path).toBe('user.name');\n      expect(result.conflicts[0].base).toBe('Alice');\n      expect(result.conflicts[0].ours).toBe('Charlie');\n      expect(result.conflicts[0].theirs).toBe('Bob');\n    });\n\n    it('should handle no-op merge (no changes on either side)', () => {\n      store.create('doc1', { a: 1 });\n      store.createBranch('feature');\n\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(result.merged['doc1']).toEqual({ a: 1 });\n    });\n\n    it('should throw when merging nonexistent branch', () => {\n      expect(() => store.merge('nonexistent')).toThrow();\n    });\n\n    it('should create a new version when merge applies changes', () => {\n      store.create('doc1', { a: 1 });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { a: 2 });\n\n      store.switchBranch('main');\n      const historyBefore = store.getHistory('doc1');\n\n      store.merge('feature');\n\n      const historyAfter = store.getHistory('doc1');\n      expect(historyAfter.length).toBe(historyBefore.length + 1);\n      expect(historyAfter[historyAfter.length - 1].content).toEqual({ a: 2 });\n    });\n\n    it('should handle adding new fields on source branch', () => {\n      store.create('doc1', { a: 1 });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { a: 1, b: 2 });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.merged['doc1']).toEqual({ a: 1, b: 2 });\n    });\n  })