new file mode 100644
index 0000000..96e34bb
--- /dev/null
+++ b/src/utils.ts
@@ -0,0 +1,90 @@
+export function deepClone<T>(obj: T): T {
+  return JSON.parse(JSON.stringify(obj));
+}
+
+let counter = 0;
+export function generateId(): string {
+  return `v_${Date.now()}_${counter++}`;
+}
+
+interface MergeConflict {
+  path: string;
+  base: unknown;
+  ours: unknown;
+  theirs: unknown;
+}
+
+interface MergeOutput {
+  merged: Record<string, unknown>;
+  conflicts: MergeConflict[];
+}
+
+export function threeWayMerge(
+  base: Record<string, unknown>,
+  ours: Record<string, unknown>,
+  theirs: Record<string, unknown>,
+  path: string = ''
+): MergeOutput {
+  const allKeys = new Set([...Object.keys(base), ...Object.keys(ours), ...Object.keys(theirs)]);
+  const merged: Record<string, unknown> = {};
+  const conflicts: MergeConflict[] = [];
+
+  for (const key of allKeys) {
+    const currentPath = path ? `${path}.${key}` : key;
+    const baseVal = base[key];
+    const oursVal = ours[key];
+    const theirsVal = theirs[key];
+
+    const baseStr = JSON.stringify(baseVal);
+    const oursStr = JSON.stringify(oursVal);
+    const theirsStr = JSON.stringify(theirsVal);
+
+    const oursChanged = oursStr !== baseStr;
+    const theirsChanged = theirsStr !== baseStr;
+
+    if (!oursChanged && !theirsChanged) {
+      // No changes
+      if (key in base) merged[key] = deepClone(baseVal);
+      else if (key in ours) merged[key] = deepClone(oursVal);
+    } else if (oursChanged && !theirsChanged) {
+      // Only ours changed
+      if (key in ours) merged[key] = deepClone(oursVal);
+      // else: ours deleted the key, don't include it
+    } else if (!oursChanged && theirsChanged) {
+      // Only theirs changed
+      if (key in theirs) merged[key] = deepClone(theirsVal);
+      // else: theirs deleted the key, don't include it
+    } else {
+      // Both changed
+      if (oursStr === theirsStr) {
+        // Both changed to same value - no conflict
+        if (key in ours) merged[key] = deepClone(oursVal);
+      } else if (
+        typeof oursVal === 'object' && oursVal !== null && !Array.isArray(oursVal) &&
+        typeof theirsVal === 'object' && theirsVal !== null && !Array.isArray(theirsVal) &&
+        typeof baseVal === 'object' && baseVal !== null && !Array.isArray(baseVal)
+      ) {
+        // Both are plain objects - recurse for deeper merge
+        const sub = threeWayMerge(
+          baseVal as Record<string, unknown>,
+          oursVal as Record<string, unknown>,
+          theirsVal as Record<string, unknown>,
+          currentPath
+        );
+        merged[key] = sub.merged;
+        conflicts.push(...sub.conflicts);
+      } else {
+        // Conflict - use ours in merged result
+        merged[key] = deepClone(oursVal);
+        conflicts.push({
+          path: currentPath,
+          base: deepClone(baseVal),
+          ours: deepClone(oursVal),
+          theirs: deepClone(theirsVal),
+        });
+      }
+    }
+  }
+
+  return { merged, conflicts };
+}
