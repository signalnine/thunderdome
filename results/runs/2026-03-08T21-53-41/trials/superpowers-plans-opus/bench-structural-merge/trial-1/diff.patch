+import { describe, it, expect, beforeEach } from 'vitest';
+import { DocumentStore } from '../src/index.js';
+
+describe('DocumentStore', () => {
+  let store: DocumentStore;
+
+  beforeEach(() => {
+    store = new DocumentStore();
+  });
+
+  // --- CRUD Operations ---
+
+  describe('create', () => {
+    it('should create a new document', () => {
+      store.create('doc1', { name: 'Alice' });
+      expect(store.get('doc1')).toEqual({ name: 'Alice' });
+    });
+
+    it('should throw if document already exists', () => {
+      store.create('doc1', { name: 'Alice' });
+      expect(() => store.create('doc1', { name: 'Bob' })).toThrow();
+    });
+
+    it('should deep clone content on create', () => {
+      const content = { name: 'Alice', nested: { age: 30 } };
+      store.create('doc1', content);
+      content.nested.age = 99;
+      expect(store.get('doc1')).toEqual({ name: 'Alice', nested: { age: 30 } });
+    });
+  });
+
+  describe('get', () => {
+    it('should throw if document does not exist', () => {
+      expect(() => store.get('nonexistent')).toThrow();
+    });
+
+    it('should return a deep clone (mutations do not affect store)', () => {
+      store.create('doc1', { name: 'Alice' });
+      const result = store.get('doc1') as any;
+      result.name = 'Bob';
+      expect(store.get('doc1')).toEqual({ name: 'Alice' });
+    });
+  });
+
+  describe('update', () => {
+    it('should update document content', () => {
+      store.create('doc1', { name: 'Alice' });
+      store.update('doc1', { name: 'Bob' });
+      expect(store.get('doc1')).toEqual({ name: 'Bob' });
+    });
+
+    it('should throw if document does not exist', () => {
+      expect(() => store.update('nonexistent', { name: 'Bob' })).toThrow();
+    });
+
+    it('should deep clone content on update', () => {
+      store.create('doc1', { name: 'Alice' });
+      const newContent = { name: 'Bob', nested: { x: 1 } };
+      store.update('doc1', newContent);
+      newContent.nested.x = 999;
+      expect(store.get('doc1')).toEqual({ name: 'Bob', nested: { x: 1 } });
+    });
+  });
+
+  describe('delete', () => {
+    it('should delete a document', () => {
+      store.create('doc1', { name: 'Alice' });
+      store.delete('doc1');
+      expect(() => store.get('doc1')).toThrow();
+    });
+
+    it('should throw if document does not exist', () => {
+      expect(() => store.delete('nonexistent')).toThrow();
+    });
+
+    it('should throw if document already deleted', () => {
+      store.create('doc1', { name: 'Alice' });
+      store.delete('doc1');
+      expect(() => store.delete('doc1')).toThrow();
+    });
+  });
+
+  // --- Version History ---
+
+  describe('getHistory', () => {
+    it('should return versions in chronological order', () => {
+      store.create('doc1', { v: 1 });
+      store.update('doc1', { v: 2 });
+      store.update('doc1', { v: 3 });
+
+      const history = store.getHistory('doc1');
+      expect(history).toHaveLength(3);
+      expect(history[0].content).toEqual({ v: 1 });
+      expect(history[1].content).toEqual({ v: 2 });
+      expect(history[2].content).toEqual({ v: 3 });
+    });
+
+    it('should have unique version IDs', () => {
+      store.create('doc1', { v: 1 });
+      store.update('doc1', { v: 2 });
+
+      const history = store.getHistory('doc1');
+      expect(history[0].id).not.toBe(history[1].id);
+    });
+
+    it('should include timestamps', () => {
+      store.create('doc1', { v: 1 });
+      const history = store.getHistory('doc1');
+      expect(typeof history[0].timestamp).toBe('number');
+      expect(history[0].timestamp).toBeGreaterThan(0);
+    });
+
+    it('should throw for nonexistent document', () => {
+      expect(() => store.getHistory('nonexistent')).toThrow();
+    });
+
+    it('should return deep cloned versions', () => {
+      store.create('doc1', { nested: { val: 1 } });
+      const history = store.getHistory('doc1');
+      (history[0].content as any).nested.val = 999;
+      expect(store.get('doc1')).toEqual({ nested: { val: 1 } });
+    });
+  });
+
+  describe('getVersion', () => {
+    it('should return content at a specific version', () => {
