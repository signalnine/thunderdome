e(true);\n      expect(result.merged['doc1']).toEqual({ name: 'on main' });\n    });\n\n    it('should handle document deleted on source branch', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.delete('doc1');\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.merged).not.toHaveProperty('doc1');\n      expect(() => store.get('doc1')).toThrow();\n    });\n\n    it('should handle multiple documents independently', () => {\n      store.create('doc1', { a: 1 });\n      store.create('doc2', { x: 10 });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { a: 2 });\n\n      store.switchBranch('main');\n      store.update('doc2', { x: 20 });\n\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.merged['doc1']).toEqual({ a: 2 });\n      expect(result.merged['doc2']).toEqual({ x: 20 });\n      expect(store.get('doc1')).toEqual({ a: 2 });\n      expect(store.get('doc2')).toEqual({ x: 20 });\n    });\n\n    it('should handle nested object merge', () => {\n      store.create('doc1', { user: { name: 'Alice', age: 30 }, meta: { tag: 'a' } });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { user: { name: 'Alice', age: 31 }, meta: { tag: 'a' } });\n\n      store.switchBranch('main');\n      store.update('doc1', { user: { name: 'Alice', age: 30 }, meta: { tag: 'b' } });\n\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(result.merged['doc1']).toEqual({ user: { name: 'Alice', age: 31 }, meta: { tag: 'b' } });\n    });\n\n    it('should handle nested object conflicts', () => {\n      store.create('doc1', { user: { name: 'Alice