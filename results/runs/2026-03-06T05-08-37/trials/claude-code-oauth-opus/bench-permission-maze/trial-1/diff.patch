+  action: string,
+  userId: string,
+  resourceType: ResourceType,
+  resourceId: string,
+  details?: string
+): void {
+  store.activityLog.push({
+    id: generateId(store),
+    action,
+    userId,
+    resourceType,
+    resourceId,
+    details,
+    timestamp: new Date().toISOString(),
+  });
+}
+
+export function createActivityRoutes(store: Store): Router {
+  const router = Router();
+  const auth = authMiddleware(store);
+
+  // Get activity log
+  router.get('/activity', auth, (req: AuthenticatedRequest, res) => {
+    const { resourceType, resourceId } = req.query;
+
+    let log = store.activityLog;
+
+    if (resourceType && resourceId) {
+      log = log.filter(
+        entry =>
+          entry.resourceType === resourceType && entry.resourceId === resourceId
+      );
+    } else if (resourceType) {
+      log = log.filter(entry => entry.resourceType === resourceType);
+    }
+
+    res.status(200).json(log);
+  });
+
+  return router;
+}
