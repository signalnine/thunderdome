@@ -0,0 +1,195 @@
+import { Router } from 'express';
+import type { Store } from '../store.js';
+import { generateId } from '../store.js';
+import { authMiddleware, type AuthenticatedRequest } from '../auth.js';
+import { hasPermission } from '../permissions.js';
+import { addActivity } from './activity.js';
+
+export function createDocumentRoutes(store: Store): Router {
+  const router = Router();
+  const auth = authMiddleware(store);
+
+  // Create document
+  router.post('/documents', auth, (req: AuthenticatedRequest, res) => {
+    const { title, content, folderId } = req.body;
+    const userId = req.userId!;
+
+    if (!title || content === undefined || !folderId) {
+      res.status(400).json({ error: 'Title, content, and folderId are required' });
+      return;
+    }
+
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'folder', folderId, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions on folder' });
+      return;
+    }
+
+    const id = generateId(store);
+    const now = new Date().toISOString();
+    const doc = {
+      id,
+      title,
+      content,
+      folderId,
+      ownerId: userId,
+      createdAt: now,
+      updatedAt: now,
+    };
+    store.documents.set(id, doc);
+
+    // Set owner permission
+    store.permissions.push({
+      id: generateId(store),
+      resourceType: 'document',
+      resourceId: id,
+      userId,
+      role: 'owner',
+    });
+
+    addActivity(store, 'document_created', userId, 'document', id);
+
+    res.status(201).json(doc);
+  });
+
+  // Also support POST /folders/:folderId/documents
+  router.post('/folders/:folderId/documents', auth, (req: AuthenticatedRequest, res) => {
+    const { title, content } = req.body;
+    const folderId = req.params.folderId;
+    const userId = req.userId!;
+
+    if (!title || content === undefined) {
+      res.status(400).json({ error: 'Title and content are required' });
+      return;
+    }
+
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'folder', folderId, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions on folder' });
+      return;
+    }
+
+    const id = generateId(store);
+    const now = new Date().toISOString();
+    const doc = {
+      id,
+      title,
+      content,
+      folderId,
+      ownerId: userId,
+      createdAt: now,
+      updatedAt: now,
+    };
+    store.documents.set(id, doc);
+
+    store.permissions.push({
+      id: generateId(store),
+      resourceType: 'document',
+      resourceId: id,
+      userId,
+      role: 'owner',
+    });
+
+    addActivity(store, 'document_created', userId, 'document', id);
+
+    res.status(201).json(doc);
+  });
+
+  // Get document
+  router.get('/documents/:id', auth, (req: AuthenticatedRequest, res) => {
+    const doc = store.documents.get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    const userId = req.userId!;
+    if (!hasPermission(store, userId, 'document', doc.id, 'viewer')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    res.status(200).json(doc);
+  });
+
+  // Update document
+  router.put('/documents/:id', auth, (req: AuthenticatedRequest, res) => {
+    const doc = store.documents.get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    const userId = req.userId!;
+    if (!hasPermission(store, userId, 'document', doc.id, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const { title, content } = req.body;
+    if (title !== undefined) doc.title = title;
+    if (content !== undefined) doc.content = content;
+    doc.updatedAt = new Date().toISOString();
+
+    addActivity(store, 'document_updated', userId, 'document', doc.id);
+
+    res.status(200).json(doc);
+  });
+
+  // Delete document
+  router.delete('/documents/:id', auth, (req: AuthenticatedRequest, res) => {
+    const doc = store.documents.get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    const userId = req.userId!;
+    if (!hasPermission(store, userId, 'document', doc.id, 'owner')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    addActivity(store, 'document_deleted', userId, 'document', doc.id);
+
+    store.documents.delete(doc.id);
+    store.permissions = store.permissions.filter(
+      p => !(p.resourceType === 'document' && p.resourceId === doc.id)
+    );
+
+    res.status(204).send();
+  });
+
+  // Get document permissions/shares
+  router.get('/documents/:id/share', auth, (req: AuthenticatedRequest, res) => {
+    const doc = store.documents.get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    const userId = req.userId!;
+    if (!hasPermission(store, userId, 'document', doc.id, 'viewer')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const shares = store.permissions.filter(
+      p => p.resourceType === 'document' && p.resourceId === doc.id
+    );
+
+    res.status(200).json(shares);
+  });
+
+  return router;
+}
diff --git a/src/routes/folders.ts b/src/routes/folders.ts
new file mode 100644
index 0000000..1fe1914
--- /dev/null
+++ b/src/routes/folders.ts
@@ -0,0 +1,179 @@
+import { Router } from 'express';
+import type { Store } from '../store.js';
+import { generateId } from '../store.js';
+import { authMiddleware, type AuthenticatedRequest } from '../auth.js';
+import { hasPermission } from '../permissions.js';
+
+export function createFolderRoutes(store: Store): Router {
+  const router = Router();
+  const auth = authMiddleware(store);
+
+  // Create folder
+  router.post('/folders', auth, (req: AuthenticatedRequest, res) => {
+    const { name, parentId } = req.body;
+    const userId = req.userId!;
+
+    if (!name) {
+      res.status(400).json({ error: 'Folder name is required' });
+      return;
+    }
+
+    // If parentId specified, check it exists and user has at least editor permission
+    if (parentId) {
+      const parentFolder = store.folders.get(parentId);
+      if (!parentFolder) {
+        res.status(404).json({ error: 'Parent folder not found' });
+        return;
+      }
+      if (!hasPermission(store, userId, 'folder', parentId, 'editor')) {
+        res.status(403).json({ error: 'Insufficient permissions on parent folder' });
+        return;
+      }
+    }
+
+    const id = generateId(store);
+    const folder = {
+      id,
+      name,
+      parentId: parentId || null,
+      ownerId: userId,
+      createdAt: new Date().toISOString(),
+    };
+    store.folders.set(id, folder);
+
+    // Set owner permission
+    store.permissions.push({
+      id: generateId(store),
+      resourceType: 'folder',
+      resourceId: id,
+      userId,
+      role: 'owner',
+    });
+
+    res.status(201).json(folder);
+  });
+
+  // Get folder
+  router.get('/folders/:id', auth, (req: AuthenticatedRequest, res) => {
+    const folder = store.folders.get(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    const userId = req.userId!;
+    if (!hasPermission(store, userId, 'folder', folder.id, 'viewer')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    // Include subfolders and documents
+    const subfolders = Array.from(store.folders.values()).filter(f => f.parentId === folder.id);
+    const documents = Array.from(store.documents.values()).filter(d => d.folderId === folder.id);
+
+    res.status(200).json({ ...folder, subfolders, documents });
+  });
+
+  // Update folder
+  router.put('/folders/:id', auth, (req: AuthenticatedRequest, res) => {
+    const folder = store.folders.get(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    const userId = req.userId!;
+    if (!hasPermission(store, userId, 'folder', folder.id, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const { name, parentId } = req.body;
+    if (name !== undefined) folder.name = name;
+    if (parentId !== undefined) {
+      if (parentId !== null) {
+        const parentFolder = store.folders.get(parentId);
+        if (!parentFolder) {
+          res.status(404).json({ error: 'Parent folder not found' });
+          return;
+        }
+        // Prevent circular reference
+        if (parentId === folder.id) {
+          res.status(400).json({ error: 'Folder cannot be its own parent' });
+          return;
+        }
+      }
+      folder.parentId = parentId;
+    }
+
+    res.status(200).json(folder);
+  });
+
+  // Delete folder
+  router.delete('/folders/:id', auth, (req: AuthenticatedRequest, res) => {
+    const folder = store.folders.get(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    const userId = req.userId!;
+    if (!hasPermission(store, userId, 'folder', folder.id, 'owner')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    // Delete subfolders and their documents recursively
+    deleteFolderRecursive(store, folder.id);
+
+    res.status(204).send();
+  });
+
+  // Get folder permissions/shares
+  router.get('/folders/:id/share', auth, (req: AuthenticatedRequest, res) => {
+    const folder = store.folders.get(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    const userId = req.userId!;
+    if (!hasPermission(store, userId, 'folder', folder.id, 'viewer')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const shares = store.permissions.filter(
+      p => p.resourceType === 'folder' && p.resourceId === folder.id
+    );
+
+    res.status(200).json(shares);
+  });
+
+  return router;
+}
+
+function deleteFolderRecursive(store: Store, folderId: string): void {
+  // Delete documents in this folder
+  for (const [docId, doc] of store.documents) {
+    if (doc.folderId === folderId) {
+      store.documents.delete(docId);
+      store.permissions = store.permissions.filter(
+        p => !(p.resourceType === 'document' && p.resourceId === docId)
+      );
+    }
+  }
+
+  // Delete subfolders
+  for (const [subId, sub] of store.folders) {
+    if (sub.parentId === folderId) {
+      deleteFolderRecursive(store, subId);
+    }
+  }
+
+  // Delete the folder itself
+  store.folders.delete(folderId);
+  store.permissions = store.permissions.filter(
+    p => !(p.resourceType === 'folder' && p.resourceId === folderId)
+  );
+}
diff --git a/src/routes/sharing.ts b/src/routes/sharing.ts
new file mode 100644
index 0000000..84f378d
--- /dev/null
+++ b/src/routes/sharing.ts
@@ -0,0 +1,210 @@
+import { Router } from 'express';
+import type { Store } from '../store.js';
+import { generateId } from '../store.js';
+import { authMiddleware, type AuthenticatedRequest } from '../auth.js';
+import { getEffectiveRole } from '../permissions.js';
+import { addActivity } from './activity.js';
+import type { Role, ResourceType } from '../types.js';
+
+const VALID_ROLES: Role[] = ['viewer', 'editor', 'owner'];
+
+export function createSharingRoutes(store: Store): Router {
+  const router = Router();
+  const auth = authMiddleware(store);
+
+  // Share a resource (folder or document)
+  router.post('/share', auth, (req: AuthenticatedRequest, res) => {
+    const { resourceType, resourceId, userId: targetUserId, role } = req.body;
+    const currentUserId = req.userId!;
+
+    if (!resourceType || !resourceId || !targetUserId || !role) {
+      res.status(400).json({ error: 'resourceType, resourceId, userId, and role are required' });
+      return;
+    }
+
+    if (!VALID_ROLES.includes(role)) {
+      res.status(400).json({ error: 'Invalid role. Must be viewer, editor, or owner' });
+      return;
+    }
+
+    if (resourceType !== 'folder' && resourceType !== 'document') {
+      res.status(400).json({ error: 'Invalid resource type. Must be folder or document' });
+      return;
+    }
+
+    // Check resource exists
+    if (resourceType === 'folder' && !store.folders.has(resourceId)) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+    if (resourceType === 'document' && !store.documents.has(resourceId)) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    // Check target user exists
+    if (!store.users.has(targetUserId)) {
+      res.status(404).json({ error: 'Target user not found' });
+      return;
+    }
+
+    // Editors can share, but only viewer or editor roles; owners can assign any role
+    const currentRole = getEffectiveRole(store, currentUserId, resourceType, resourceId);
+    if (!currentRole) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    if (currentRole === 'viewer') {
+      res.status(403).json({ error: 'Viewers cannot share resources' });
+      return;
+    }
+
+    if (currentRole === 'editor' && role === 'owner') {
+      res.status(403).json({ error: 'Editors cannot grant owner role' });
+      return;
+    }
+
+    // Upsert permission: update if existing, else create
+    const existing = store.permissions.find(
+      p =>
+        p.resourceType === resourceType &&
+        p.resourceId === resourceId &&
+        p.userId === targetUserId
+    );
+
+    if (existing) {
+      existing.role = role;
+    } else {
+      store.permissions.push({
+        id: generateId(store),
+        resourceType,
+        resourceId,
+        userId: targetUserId,
+        role,
+      });
+    }
+
+    addActivity(
+      store,
+      'resource_shared',
+      currentUserId,
+      resourceType,
+      resourceId,
+      `Shared with user ${targetUserId} as ${role}`
+    );
+
+    res.status(200).json({ message: 'Resource shared successfully' });
+  });
+
+  // Also support POST /:resourceType/:id/share
+  router.post('/folders/:id/share', auth, (req: AuthenticatedRequest, res) => {
+    const resourceId = req.params.id;
+    const { userId: targetUserId, role } = req.body;
+    const currentUserId = req.userId!;
+
+    handleShare(store, res, 'folder', resourceId, targetUserId, role, currentUserId);
+  });
+
+  router.post('/documents/:id/share', auth, (req: AuthenticatedRequest, res) => {
+    const resourceId = req.params.id;
+    const { userId: targetUserId, role } = req.body;
+    const currentUserId = req.userId!;
+
+    handleShare(store, res, 'document', resourceId, targetUserId, role, currentUserId);
+  });
+
+  // Get effective permission for current user on a resource
+  router.get('/permissions/:resourceType/:resourceId', auth, (req: AuthenticatedRequest, res) => {
+    const { resourceType, resourceId } = req.params;
+    const userId = req.userId!;
+
+    if (resourceType !== 'folder' && resourceType !== 'document') {
+      res.status(400).json({ error: 'Invalid resource type' });
+      return;
+    }
+
+    const effectiveRole = getEffectiveRole(store, userId, resourceType as ResourceType, resourceId);
+
+    res.status(200).json({ resourceType, resourceId, userId, role: effectiveRole });
+  });
+
+  return router;
+}
+
+function handleShare(
+  store: Store,
+  res: import('express').Response,
+  resourceType: ResourceType,
+  resourceId: string,
+  targetUserId: string,
+  role: Role,
+  currentUserId: string
+): void {
+  if (!targetUserId || !role) {
+    res.status(400).json({ error: 'userId and role are required' });
+    return;
+  }
+
+  if (!VALID_ROLES.includes(role)) {
+    res.status(400).json({ error: 'Invalid role. Must be viewer, editor, or owner' });
+    return;
+  }
+
+  // Check resource exists
+  if (resourceType === 'folder' && !store.folders.has(resourceId)) {
+    res.status(404).json({ error: 'Folder not found' });
+    return;
+  }
+  if (resourceType === 'document' && !store.documents.has(resourceId)) {
+    res.status(404).json({ error: 'Document not found' });
+    return;
+  }
+
+  // Check target user exists
+  if (!store.users.has(targetUserId)) {
+    res.status(404).json({ error: 'Target user not found' });
+    return;
+  }
+
+  const currentRole = getEffectiveRole(store, currentUserId, resourceType, resourceId);
+  if (!currentRole || currentRole === 'viewer') {
+    res.status(403).json({ error: 'Insufficient permissions' });
+    return;
+  }
+
+  if (currentRole === 'editor' && role === 'owner') {
+    res.status(403).json({ error: 'Editors cannot grant owner role' });
+    return;
+  }
+
+  const existing = store.permissions.find(
+    p =>
+      p.resourceType === resourceType &&
+      p.resourceId === resourceId &&
+      p.userId === targetUserId
+  );
+
+  if (existing) {
+    existing.role = role;
+  } else {
+    store.permissions.push({
+      id: generateId(store),
+      resourceType,
+      resourceId,
+      userId: targetUserId,
+      role,
+    });
+  }
+
+  addActivity(
+    store,
+    'resource_shared',
+    currentUserId,
+    resourceType,
+    resourceId,
+    `Shared with user ${targetUserId} as ${role}`
+  );
+
+  res.status(200).json({ message: 'Resource shared successfully' });
+}
