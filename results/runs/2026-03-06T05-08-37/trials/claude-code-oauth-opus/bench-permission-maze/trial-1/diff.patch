olderId &&\n      perm.userId === userId\n    ) {\n      if (!maxRole || ROLE_LEVELS[perm.role] > ROLE_LEVELS[maxRole]) {\n        maxRole = perm.role;\n      }\n    }\n  }\n\n  // Ancestor folder permissions\n  const folder = store.folders.get(folderId);\n  if (folder && folder.parentId) {\n    const parentRole = getFolderRole(store, userId, folder.parentId);\n    if (parentRole && (!maxRole || ROLE_LEVELS[parentRole] > ROLE_LEVELS[maxRole])) {\n      maxRole = parentRole;\n    }\n  }\n\n  return maxRole;\n}\n\nfunction getAncestorFolderRole(store: Store, userId: string, folderId: string): Role | null {\n  const folder = store.folders.get(folderId);\n  if (!folder || !folder.parentId) {\n    return null;\n  }\n  return getFolderRole(store, userId, folder.parentId);\n}\n\nexport function hasPermission(\n  store: Store,\n  userId: string,\n  resourceType: ResourceType,\n  resourceId: string,\n  requiredRole: Role\n): boolean {\n  const effectiveRole = getEffectiveRole(store, userId, resourceType, resourceId);\n  if (!effectiveRole) return false;\n  return ROLE_LEVELS[effectiveRole] >= ROLE_LEVELS[requiredRole];\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":371,"cache_read_input_tokens":23033,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":371},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"f4e0381c-1d50-4f7c-8e0b-a246a01d0ede","uuid":"ab0b0a00-7877-4a90-b3e3-bffc90395411"}
