+import type { Store } from './store.js';
+import type { Role, ResourceType } from './types.js';
+
+const ROLE_LEVELS: Record<Role, number> = {
+  viewer: 1,
+  editor: 2,
+  owner: 3,
+};
+
+export function getEffectiveRole(
+  store: Store,
+  userId: string,
+  resourceType: ResourceType,
+  resourceId: string
+): Role | null {
+  let maxRole: Role | null = null;
+
+  // Check direct permissions on the resource
+  for (const perm of store.permissions) {
+    if (
+      perm.resourceType === resourceType &&
+      perm.resourceId === resourceId &&
+      perm.userId === userId
+    ) {
+      if (!maxRole || ROLE_LEVELS[perm.role] > ROLE_LEVELS[maxRole]) {
+        maxRole = perm.role;
+      }
+    }
+  }
+
+  // If resource is a document, also check folder permissions
+  if (resourceType === 'document') {
+    const doc = store.documents.get(resourceId);
+    if (doc) {
+      const folderRole = getFolderRole(store, userId, doc.folderId);
+      if (folderRole && (!maxRole || ROLE_LEVELS[folderRole] > ROLE_LEVELS[maxRole])) {
+        maxRole = folderRole;
+      }
+    }
+  }
+
+  // If resource is a folder, check ancestor folder permissions
+  if (resourceType === 'folder') {
+    const ancestorRole = getAncestorFolderRole(store, userId, resourceId);
+    if (ancestorRole && (!maxRole || ROLE_LEVELS[ancestorRole] > ROLE_LEVELS[maxRole])) {
+      maxRole = ancestorRole;
+    }
+  }
+
+  return maxRole;
+}
+
+function getFolderRole(store: Store, userId: string, folderId: string): Role | null {
+  let maxRole: Role | null = null;
+
+  // Direct permissions on the folder
+  for (const perm of store.permissions) {
+    if (
+      perm.resourceType === 'folder' &&
+      perm.resourceId === folderId &&
+      perm.userId === userId
+    ) {
+      if (!maxRole || ROLE_LEVELS[perm.role] > ROLE_LEVELS[maxRole]) {
+        maxRole = perm.role;
+      }
+    }
+  }
+
+  // Ancestor folder permissions
+  const folder = store.folders.get(folderId);
+  if (folder && folder.parentId) {
+    const parentRole = getFolderRole(store, userId, folder.parentId);
+    if (parentRole && (!maxRole || ROLE_LEVELS[parentRole] > ROLE_LEVELS[maxRole])) {
+      maxRole = parentRole;
+    }
+  }
+
+  return maxRole;
+}
+
+function getAncestorFolderRole(store: Store, userId: string, folderId: string): Role | null {
+  const folder = store.folders.get(folderId);
+  if (!folder || !folder.parentId) {
+    return null;
+  }
+  return getFolderRole(store, userId, folder.parentId);
+}
+
+export function hasPermission(
+  store: Store,
+  userId: string,
+  resourceType: ResourceType,
+  resourceId: string,
+  requiredRole: Role
+): boolean {
+  const effectiveRole = getEffectiveRole(store, userId, resourceType, resourceId);
+  if (!effectiveRole) return false;
+  return ROLE_LEVELS[effectiveRole] >= ROLE_LEVELS[requiredRole];
+}
