@@ -0,0 +1,46 @@
+export type Role = 'viewer' | 'editor' | 'owner';
+
+export interface User {
+  id: string;
+  username: string;
+  password: string;
+  token: string | null;
+}
+
+export interface Folder {
+  id: string;
+  name: string;
+  parentId: string | null;
+  ownerId: string;
+  createdAt: string;
