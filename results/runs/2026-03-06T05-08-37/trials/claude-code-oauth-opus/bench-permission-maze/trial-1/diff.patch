diff --git a/src/app.test.ts b/src/app.test.ts
new file mode 100644
index 0000000..5d5e531
--- /dev/null
+++ b/src/app.test.ts
@@ -0,0 +1,653 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import request from 'supertest';
+import type { Express } from 'express';
+import { createApp } from './app.js';
+
+let app: Express;
+
+beforeEach(() => {
+  app = createApp();
+});
+
+// Helper functions
+async function registerUser(username: string, password: string) {
+  const res = await request(app)
+    .post('/auth/register')
+    .send({ username, password });
+  return res;
+}
+
+async function loginUser(username: string, password: string) {
+  const res = await request(app)
+    .post('/auth/login')
+    .send({ username, password });
+  return res;
+}
+
+async function registerAndLogin(username: string, password: string) {
+  await registerUser(username, password);
+  const loginRes = await loginUser(username, password);
+  return loginRes.body as { token: string; userId: string };
+}
+
+async function createFolder(token: string, name: string, parentId?: string) {
+  const res = await request(app)
+    .post('/folders')
+    .set('Authorization', `Bearer ${token}`)
+    .send({ name, parentId });
+  return res;
+}
+
+async function createDocument(token: string, title: string, content: string, folderId: string) {
+  const res = await request(app)
+    .post('/documents')
+    .set('Authorization', `Bearer ${token}`)
+    .send({ title, content, folderId });
+  return res;
+}
+
+async function shareResource(
+  token: string,
+  resourceType: string,
+  resourceId: string,
+  userId: string,
+  role: string
+) {
+  const res = await request(app)
+    .post('/share')
+    .set('Authorization', `Bearer ${token}`)
+    .send({ resourceType, resourceId, userId, role });
+  return res;
+}
+
+describe('User Management', () => {
+  describe('POST /auth/register', () => {
+    it('should register a new user', async () => {
+      const res = await registerUser('alice', 'pass123');
+      expect(res.status).toBe(201);
+      expect(res.body).toHaveProperty('id');
+      expect(res.body.username).toBe('alice');
+    });
+
+    it('should reject duplicate username', async () => {
+      await registerUser('alice', 'pass123');
+      const res = await registerUser('alice', 'pass456');
+      expect(res.status).toBe(409);
+    });
+
+    it('should reject missing fields', async () => {
+      const res = await request(app).post('/auth/register').send({ username: 'alice' });
+      expect(res.status).toBe(400);
+    });
+  });
+
+  describe('POST /auth/login', () => {
+    it('should login with valid credentials', async () => {
+      await registerUser('alice', 'pass123');
+      const res = await loginUser('alice', 'pass123');
+      expect(res.status).toBe(200);
+      expect(res.body).toHaveProperty('token');
+      expect(res.body).toHaveProperty('userId');
+    });
+
+    it('should reject invalid credentials', async () => {
+      await registerUser('alice', 'pass123');
+      const res = await loginUser('alice', 'wrong');
+      expect(res.status).toBe(401);
+    });
+
+    it('should reject missing fields', async () => {
+      const res = await request(app).post('/auth/login').send({});
+      expect(res.status).toBe(400);
+    });
+  });
+});
+
+describe('Authentication', () => {
+  it('should reject requests without token', async () => {
+    const res = await request(app).get('/folders/1');
+    expect(res.status).toBe(401);
+  });
+
+  it('should reject requests with invalid token', async () => {
+    const res = await request(app)
+      .get('/folders/1')
+      .set('Authorization', 'Bearer invalidtoken');
+    expect(res.status).toBe(401);
+  });
+});
+
+describe('Folders', () => {
+  let alice: { token: string; userId: string };
+
+  beforeEach(async () => {
+    alice = await registerAndLogin('alice', 'pass123');
+  });
+
+  describe('POST /folders', () => {
+    it('should create a folder', async () => {
+      const res = await createFolder(alice.token, 'My Folder');
+      expect(res.status).toBe(201);
+      expect(res.body.name).toBe('My Folder');
+      expect(res.body.parentId).toBeNull();
+      expect(res.body).toHaveProperty('id');
+    });
+
+    it('should create a nested folder', async () => {
+      const parent = await createFolder(alice.token, 'Parent');
+      const child = await createFolder(alice.token, 'Child', parent.body.id);
+      expect(child.status).toBe(201);
+      expect(child.body.parentId).toBe(parent.body.id);
+    });
+
+    it('should reject missing name', async () => {
+      const res = await request(app)
+        .post('/folders')
+        .set('Authorization', `Bearer ${alice.token}`)
+        .send({});
+      expect(res.status).toBe(400);
+    });
+
+    it('should reject non-existent parent', async () => {
+      const res = await createFolder(alice.token, 'Child', '9999');
+      expect(res.status).toBe(404);
+    });
+  });
+
+  describe('GET /folders/:id', () => {
+    it('should return a folder with subfolders and documents', async () => {
+      const folder = await createFolder(alice.token, 'My Folder');
+      await createFolder(alice.token, 'Sub', folder.body.id);
+      await createDocument(alice.token, 'Doc', 'Content', folder.body.id);
+
+      const res = await request(app)
+        .get(`/folders/${folder.body.id}`)
+        .set('Authorization', `Bearer ${alice.token}`);
+      expect(res.status).toBe(200);
+      expect(res.body.name).toBe('My Folder');
+      expect(res.body.subfolders).toHaveLength(1);
+      expect(res.body.documents).toHaveLength(1);
+    });
+
+    it('should return 404 for non-existent folder', async () => {
+      const res = await request(app)
+        .get('/folders/9999')
+        .set('Authorization', `Bearer ${alice.token}`);
+      expect(res.status).toBe(404);
+    });
+  });
+
+  describe('PUT /folders/:id', () => {
+    it('should update folder name', async () => {
+      const folder = await createFolder(alice.token, 'Old Name');
+      const res = await request(app)
+        .put(`/folders/${folder.body.id}`)
+        .set('Authorization', `Bearer ${alice.token}`)
+        .send({ name: 'New Name' });
+      expect(res.status).toBe(200);
+      expect(res.body.name).toBe('New Name');
+    });
+  });
+
+  describe('DELETE /folders/:id', () => {
+    it('should delete a folder', async () => {
+      const folder = await createFolder(alice.token, 'To Delete');
+      const res = await request(app)
+        .delete(`/folders/${folder.body.id}`)
+        .set('Authorization', `Bearer ${alice.token}`);
+      expect(res.status).toBe(204);
+
+      const getRes = await request(app)
+        .get(`/folders/${folder.body.id}`)
+        .set('Authorization', `Bearer ${alice.token}`);
+      expect(getRes.status).toBe(404);
+    });
+
+    it('should recursively delete subfolders and documents', async () => {
+      const parent = await createFolder(alice.token, 'Parent');
+      const child = await createFolder(alice.token, 'Child', parent.body.id);
+      await createDocument(alice.token, 'Doc', 'Content', child.body.id);
+
+      const res = await request(app)
+        .delete(`/folders/${parent.body.id}`)
+        .set('Authorization', `Bearer ${alice.token}`);
+      expect(res.status).toBe(204);
+
+      const getChild = await request(app)
+        .get(`/folders/${child.body.id}`)
