@@ -0,0 +1,403 @@
+import { TimeEntry, TimeTracker } from './index.ts'; // Corrected import path
+import * as fs from 'fs';
+import * as path from 'path';
+import { describe, it, expect, beforeAll, afterAll, vi, beforeEach } from 'vitest'; // Added beforeEach and ensured vitest globals are used
+
+// Define a temporary directory for test files
+const TEMP_DIR = '/tmp/.gemini/tmp/workspace/test-data';
+const TEST_FILE_PATH = path.join(TEMP_DIR, 'time_tracker_test.json');
+
+// Helper to clean up the test directory and file before/after tests
+function setupTests() {
+    if (!fs.existsSync(TEMP_DIR)) {
+        fs.mkdirSync(TEMP_DIR, { recursive: true });
+    }
+    // Clear the test file if it exists
+    if (fs.existsSync(TEST_FILE_PATH)) {
+        fs.unlinkSync(TEST_FILE_PATH);
+    }
+}
+
+function cleanupTests() {
+    if (fs.existsSync(TEST_FILE_PATH)) {
+        fs.unlinkSync(TEST_FILE_PATH);
+    }
+    // Optionally, remove the directory if it's empty and was created for tests
+    // Be cautious with recursive removal to avoid unintended data loss.
+    // For now, we'll just clean the file.
+}
+
+describe('TimeTracker', () => {
+    // Setup and cleanup for all tests in this suite
+    beforeAll(() => {
+        setupTests();
+    });
+
+    afterAll(() => {
+        cleanupTests();
+    });
+
+    // --- Timer Start/Stop Tests ---
+    describe('Timer Start/Stop', () => {
+        it('should start a timer with a valid task name and persist it', () => {
+            const tracker = new TimeTracker(TEST_FILE_PATH);
+            const startTime = Date.now();
+            tracker.startTimer('Task A');
+            
+            // Verify persistence by reading the file
+            const data = JSON.parse(fs.readFileSync(TEST_FILE_PATH, 'utf-8'));
+            expect(data.length).toBe(1);
+            expect(data[0].taskName).toBe('Task A');
+            expect(data[0].endTime).toBeNull();
+            expect(data[0].startTime).toBeGreaterThanOrEqual(startTime);
+        });
+
+        it('should stop a running timer and record the entry', () => {
+            const tracker = new TimeTracker(TEST_FILE_PATH);
+            tracker.startTimer('Task B');
+            // Simulate a delay to ensure endTime is after startTime
+            setTimeout(() => {
+                const stoppedEntry = tracker.stopTimer();
+                expect(stoppedEntry.taskName).toBe('Task B');
+                expect(stoppedEntry.endTime).toBeGreaterThan(stoppedEntry.startTime);
+
+                const data = JSON.parse(fs.readFileSync(TEST_FILE_PATH, 'utf-8'));
+                expect(data.length).toBe(1);
+                expect(data[0].taskName).toBe('Task B');
+                expect(data[0].endTime).not.toBeNull();
+                expect(data[0].startTime).not.toBeNull();
+            }, 50); // 50ms delay
+        });
+
+        it('should automatically stop the previous timer when a new one starts', () => {
+            const tracker = new TimeTracker(TEST_FILE_PATH);
+            tracker.startTimer('Task C');
+            const firstStartTime = Date.now();
+
+            // Wait a bit, then start another timer
+            setTimeout(() => {
+                tracker.startTimer('Task D');
+                const secondStartTime = Date.now();
+
+                // Give a moment for file write operations to potentially complete (though sync ops are used)
+                // This setTimeout is mainly to ensure temporal ordering of events if not strictly sync
+                setTimeout(() => {
+                    const data = JSON.parse(fs.readFileSync(TEST_FILE_PATH, 'utf-8'));
+                    expect(data.length).toBe(2); // Both timers should be recorded
+
+                    // Check Task C (previous timer)
+                    const taskC = data.find((e: TimeEntry) => e.taskName === 'Task C'); // Explicit type for 'e'
+                    expect(taskC).toBeDefined();
+                    expect(taskC.endTime).not.toBeNull();
+                    expect(taskC.endTime).toBeGreaterThanOrEqual(firstStartTime);
+                    // The endTime of Task C should be before Task D's startTime
+                    expect(taskC.endTime).toBeLessThan(secondStartTime); 
+
+                    // Check Task D (current timer)
+                    const taskD = data.find((e: TimeEntry) => e.taskName === 'Task D'); // Explicit type for 'e'
+                    expect(taskD).toBeDefined();
+                    expect(taskD.endTime).toBeNull(); // Should be running
+                    expect(taskD.startTime).toBeGreaterThanOrEqual(secondStartTime);
+                }, 10); // Small delay to ensure data is written
+            }, 50);
+        });
+
+        it('should throw an error if starting timer with an empty name', () => {
+            const tracker = new TimeTracker(TEST_FILE_PATH);
+            expect(() => tracker.startTimer('')).toThrow('Task name cannot be empty.');
+            expect(() => tracker.startTimer('   ')).toThrow('Task name cannot be empty.');
+        });
+
+        it('should throw an error if stopping timer when none is running', () => {
+            const tracker = new TimeTracker(TEST_FILE_PATH);
+            expect(() => tracker.stopTimer()).toThrow('No timer is currently running.');
+        });
+    });
+
+    // --- Persistence Tests ---
+    describe('Persistence', () => {
+        it('should load existing entries from a JSON file on instantiation', () => {
+            const preExistingEntries: TimeEntry[] = [
+                { taskName: 'Load Task 1', startTime: Date.now() - 20000, endTime: Date.now() - 15000 }, // Finished
+                { taskName: 'Load Task 2', startTime: Date.now() - 10000, endTime: null } // Running
+            ];
+            fs.writeFileSync(TEST_FILE_PATH, JSON.stringify(preExistingEntries, null, 2), 'utf-8');
+
+            const tracker = new TimeTracker(TEST_FILE_PATH);
+            const loadedEntries = tracker.getEntries(); // Should return the loaded entries
+            expect(loadedEntries.length).toBe(2);
+            expect(loadedEntries.some((e: TimeEntry) => e.taskName === 'Load Task 1' && e.endTime !== null)).toBe(true); // Explicit type for 'e'
+            expect(loadedEntries.some((e: TimeEntry) => e.taskName === 'Load Task 2' && e.endTime === null)).toBe(true); // Explicit type for 'e'
+        });
+
+        it('should create the persistence file and directories if they do not exist', () => {
+            const nonExistentDirPath = path.join(TEMP_DIR, 'new_subdir');
+            const nonExistentFilePath = path.join(nonExistentDirPath, 'new_tracker.json');
+            // Ensure the path does not exist before test
+            if (fs.existsSync(nonExistentDirPath)) {
+                fs.rmSync(nonExistentDirPath, { recursive: true, force: true });
+            }
+
+            const tracker = new TimeTracker(nonExistentFilePath);
+            tracker.startTimer('New Task'); // This should trigger directory creation and file writing
+
+            expect(fs.existsSync(nonExistentDirPath)).toBe(true);
+            expect(fs.existsSync(nonExistentFilePath)).toBe(true);
+        });
+
+        it('should handle an empty persistence file gracefully', () => {
+            fs.writeFileSync(TEST_FILE_PATH, '', 'utf-8'); // Empty file
+            const tracker = new TimeTracker(TEST_FILE_PATH);
+            expect(tracker.getEntries()).toEqual([]);
+            expect(tracker.getTimeSummary()).toEqual([]);
+        });
+
+        it('should handle corrupted JSON in persistence file', () => {
+            fs.writeFileSync(TEST_FILE_PATH, '{ "invalid": "json" ', 'utf-8'); // Corrupted JSON
+            // Spy on console.error to check if the error message is logged without crashing
+            const consoleSpy = vi.spyOn(console, 'error').mockImplementation(() => {});
+            
+            expect(() => {
+                const tracker = new TimeTracker(TEST_FILE_PATH);
+                // Assertions to ensure it doesn't crash and starts with empty state
+                expect(tracker.getEntries()).toEqual([]);
+                expect(tracker.getTimeSummary()).toEqual([]);
+            }).not.toThrow();
+            
+            expect(consoleSpy).toHaveBeenCalled();
+            consoleSpy.mockRestore();
+        });
+
+        it('should save changes made by startTimer and stopTimer', () => {
+            const tracker = new TimeTracker(TEST_FILE_PATH);
+            tracker.startTimer('Save Task 1');
+            // Check file content after startTimer
+            let data = JSON.parse(fs.readFileSync(TEST_FILE_PATH, 'utf-8'));
+            expect(data.length).toBe(1);
+            expect(data[0].taskName).toBe('Save Task 1');
+
+            // Stop the timer
+            tracker.stopTimer();
+            // Check file content after stopTimer
+            data = JSON.parse(fs.readFileSync(TEST_FILE_PATH, 'utf-8'));
+            expect(data.length).toBe(1);
+            expect(data[0].taskName).toBe('Save Task 1');
+            expect(data[0].endTime).not.toBeNull();
+
+            // Start a new timer, which should overwrite/update the file
+            tracker.startTimer('Save Task 2');
+            data = JSON.parse(fs.readFileSync(TEST_FILE_PATH, 'utf-8')); // Corrected JSON.Parse to JSON.parse
+            expect(data.length).toBe(2); // Old task (finished) + new running task
+            const savedTask1 = data.find((e: TimeEntry) => e.taskName === 'Save Task 1'); // Explicit type for 'e'
+            expect(savedTask1.endTime).not.toBeNull();
+            const savedTask2 = data.find((e: TimeEntry) => e.taskName === 'Save Task 2'); // Explicit type for 'e'
+            expect(savedTask2.endTime).toBeNull();
+        });
+    });
+
+    // --- Querying Tests ---
+    describe('Querying Entries', () => {
+        const now = Date.now(); // Capture current time for consistent test data
+        const testEntries: TimeEntry[] = [
+            { taskName: 'Query Task A', startTime: now - 30000, endTime: now - 25000 }, // 5s duration, finished
+            { taskName: 'Query Task B', startTime: now - 20000, endTime: now - 10000 }, // 10s duration, finished
+            { taskName: 'Query Task C', startTime: now - 5000, endTime: null },       // Running task, started 5s ago
+            { taskName: 'Query Task D', startTime: now - 60000, endTime: now - 55000 }, // 5s duration, finished, outside recent range
+        ];
+
+        beforeEach(() => {
+            // Populate file with test data for querying
+            fs.writeFileSync(TEST_FILE_PATH, JSON.stringify(testEntries, null, 2), 'utf-8');
+            // Re-instantiate tracker to load from this specific file before each query test
+        });
+
+        it('should retrieve all entries', () => {
+            const tracker = new TimeTracker(TEST_FILE_PATH);
+            const entries = tracker.getEntries();
+            expect(entries.length).toBe(4);
+            expect(entries.some((e: TimeEntry) => e.taskName === 'Query Task A')).toBe(true); // Explicit type for 'e'
