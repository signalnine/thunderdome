@@ -0,0 +1,171 @@
+import * as fs from 'fs';
+import * as path from 'path';
+
+interface TimeEntry {
+    taskName: string;
+    startTime: number; // Unix timestamp in milliseconds
+    endTime: number | null; // Unix timestamp in milliseconds, null if running
+}
+
+class TimeTracker {
+    private entries: TimeEntry[] = [];
+    private activeTimer: TimeEntry | null = null;
+    private persistencePath: string;
+
+    constructor(persistencePath: string) {
+        this.persistencePath = path.resolve(persistencePath);
+        this.loadEntries();
+    }
+
+    private loadEntries() {
+        const dir = path.dirname(this.persistencePath);
+        if (!fs.existsSync(dir)) {
+            fs.mkdirSync(dir, { recursive: true });
+        }
+        if (fs.existsSync(this.persistencePath)) {
+            try {
+                const data = fs.readFileSync(this.persistencePath, 'utf-8');
+                // Handle empty file case
+                if (data.trim() === '') {
+                    this.entries = [];
+                    this.activeTimer = null;
+                    return;
+                }
+                const loadedEntries: TimeEntry[] = JSON.parse(data);
+
+                // Filter out entries that were marked as running (endTime === null)
+                // These should be restored as the `activeTimer`.
+                this.entries = loadedEntries.filter(entry => entry.endTime !== null);
+                const runningEntries = loadedEntries.filter(entry => entry.endTime === null);
+
+                if (runningEntries.length > 0) {
+                    // Sort by startTime to find the most recent running timer
+                    runningEntries.sort((a, b) => b.startTime - a.startTime);
+                    this.activeTimer = runningEntries[0];
+                    // Ensure no other entries in `this.entries` are marked as running if activeTimer is set
+                    this.entries = this.entries.filter(entry => entry.endTime !== null);
+                } else {
+                    this.activeTimer = null;
+                }
+            } catch (error) {
+                console.error(`Error loading time entries from ${this.persistencePath}:`, error);
+                // If file is corrupted or unreadable, start with empty state
+                this.entries = [];
+                this.activeTimer = null;
+            }
+        } else {
+            // File doesn't exist, start with empty state
+            this.entries = [];
+            this.activeTimer = null;
+        }
+    }
+
+    private saveEntries() {
+        const dir = path.dirname(this.persistencePath);
+        if (!fs.existsSync(dir)) {
+            fs.mkdirSync(dir, { recursive: true });
+        }
+        // Combine finished entries and the current active timer (if any)
+        const dataToSave: TimeEntry[] = [...this.entries];
+        if (this.activeTimer) {
+            dataToSave.push(this.activeTimer);
+        }
+        fs.writeFileSync(this.persistencePath, JSON.stringify(dataToSave, null, 2), 'utf-8');
+    }
+
+    startTimer(taskName: string): void {
+        if (!taskName || taskName.trim() === '') {
+            throw new Error('Task name cannot be empty.');
+        }
+
+        const now = Date.now();
+
+        // If a timer is already running, stop it first
+        if (this.activeTimer) {
+            this.stopTimer(); // This will save the previous timer
+        }
+
+        // Create a new active timer
+        this.activeTimer = {
+            taskName: taskName,
+            startTime: now,
+            endTime: null, // null indicates it's currently running
+        };
+        this.saveEntries(); // Save the new active timer state
+    }
+
+    stopTimer(): TimeEntry {
+        if (!this.activeTimer) {
+            throw new Error('No timer is currently running.');
+        }
+
+        const now = Date.now();
+        const stoppedEntry: TimeEntry = {
+            taskName: this.activeTimer.taskName,
+            startTime: this.activeTimer.startTime,
+            endTime: now,
+        };
+
+        this.entries.push(stoppedEntry); // Add to finished entries
+        this.activeTimer = null; // Reset active timer
+        this.saveEntries(); // Save the updated state (new entry added, active timer removed)
+        return stoppedEntry; // Return the entry that was just stopped
+    }
+
+    // Helper to get duration of a single entry, considering it might be running
+    private getEntryDuration(entry: TimeEntry): number {
+        const now = Date.now();
+        if (entry.endTime === null) {
+            return now - entry.startTime;
+        }
+        return entry.endTime - entry.startTime;
+    }
+
+    getEntries(options?: { startDate?: Date; endDate?: Date }): TimeEntry[] {
+        const startTimeFilter = options?.startDate ? options.startDate.getTime() : -Infinity;
+        const endTimeFilter = options?.endDate ? options.endDate.getTime() : Infinity;
+
+        const matchingEntries: TimeEntry[] = [];
+
+        // Helper to check if an entry overlaps with the date range
+        const overlapsRange = (entry: TimeEntry): boolean => {
+            const now = Date.now();
+            const effectiveEndTime = entry.endTime === null ? now : entry.endTime;
+            // Overlap occurs if (entry starts before range ends) AND (entry ends after range starts)
+            return entry.startTime <= endTimeFilter && effectiveEndTime >= startTimeFilter;
+        };
+
+        // Check finished entries
+        this.entries.forEach(entry => {
+            if (entry.endTime !== null && overlapsRange(entry)) {
+                matchingEntries.push(entry);
+            }
+        });
+
+        // Check active timer
+        if (this.activeTimer && overlapsRange(this.activeTimer)) {
+            matchingEntries.push(this.activeTimer);
+        }
+
+        return matchingEntries;
+    }
+
+    getTimeSummary(): { taskName: string; totalTime: number }[] {
+        const summaryMap = new Map<string, number>();
+
+        // Combine all entries (finished + active) for processing
+        const allEntriesToSum: TimeEntry[] = [...this.entries];
+        if (this.activeTimer) {
+            allEntriesToSum.push(this.activeTimer);
+        }
+
+        allEntriesToSum.forEach(entry => {
+            const duration = this.getEntryDuration(entry);
+            summaryMap.set(entry.taskName, (summaryMap.get(entry.taskName) || 0) + duration);
+        });
+
+        return Array.from(summaryMap, ([taskName, totalTime]) => ({ taskName, totalTime }));
+    }
+}
+
+export { TimeTracker };
