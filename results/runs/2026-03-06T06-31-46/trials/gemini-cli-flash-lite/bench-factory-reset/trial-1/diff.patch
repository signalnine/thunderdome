+        // Compare with best solution found so far
+        if (current_presses < min_presses) {
+            min_presses = current_presses;
+            best_solution = [...current_solution];
+        } else if (current_presses === min_presses) {
+            // Lexicographical comparison
+            if (best_solution === null) { // Should not happen if min_presses is not Infinity
+                 best_solution = [...current_solution];
+            } else {
+                let is_lex_smaller = false;
+                for(let k = 0; k < M; k++) {
+                    if (current_solution[k] < best_solution[k]) {
+                        is_lex_smaller = true;
+                        break;
+                    }
+                    if (current_solution[k] > best_solution[k]) {
+                        break; // current_solution is lexicographically larger
+                    }
+                }
+                if (is_lex_smaller) {
+                   best_solution = [...current_solution];
+                }
+            }
+        }
+    }
+
+    // Convert the best solution (binary array) to an array of button indices
+    if (best_solution === null) {
+        // This can happen if M > 0 but no solution was found due to logic error or
+        // if M=0 and target is not all zero (handled at start)
+        // If we reach here and M > 0, it implies an issue, but we've checked for inconsistency.
+        // If no free vars, num_combinations=1, best_solution should be set.
+        // If M=0, handled at start.
+        // If N=0, matrix is 0x(M+1), pivot_row=0, free_vars=all columns, num_comb=2^M.
+        // If N=0, target=[], solution is all 0s, min_presses=0, best_solution=[0...0]
+        if (N === 0 && M >= 0) return Array(M).fill(0);
+        return null; // Fallback, should ideally not be reached if logic is sound
+    }
+
+    const result_indices: number[] = [];
+    for (let i = 0; i < M; i++) {
+        if (best_solution[i] === 1) {
+            result_indices.push(i);
+        }
+    }
+    return result_indices; // Already sorted ascending because we build it from left to right.
