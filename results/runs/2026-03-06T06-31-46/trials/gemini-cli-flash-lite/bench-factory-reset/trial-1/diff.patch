+interface Machine {
+  target: boolean[];     // desired state for each light (all start off)
+  buttons: number[][];   // buttons[i] = array of light indices toggled by button i
+}
+
+interface CounterMachine {
+  target: number[];      // desired counter values (each 0..modulus-1)
+  buttons: number[][];   // buttons[i] = indices of counters affected by button i
+  modulus: number;       // counters wrap at this value (always prime)
+}
+
+// Helper for GF(2) operations
+function xor_arrays(arr1: number[], arr2: number[]): number[] {
+    const result: number[] = [];
+    for (let i = 0; i < arr1.length; i++) {
+        result.push(arr1[i] ^ arr2[i]);
+    }
+    return result;
+}
+
+// Part 1: Toggle Puzzle
+function solveToggle(machine: Machine): number[] | null {
+    const N = machine.target.length; // Number of lights
+    const M = machine.buttons.length; // Number of buttons
+
+    // Handle edge case: no buttons
+    if (M === 0) {
+        for (const target_light of machine.target) {
+            if (target_light) { // If any light needs to be ON but there are no buttons
+                return null;
+            }
+        }
+        return []; // All lights are OFF, and no buttons needed
+    }
+
+    // Build the augmented matrix: N rows, M+1 columns
+    // matrix[j][i] = 1 if button i toggles light j, 0 otherwise
+    // matrix[j][M] = machine.target[j] ? 1 : 0
+    const matrix: number[][] = Array(N).fill(0).map(() => Array(M + 1).fill(0));
+
+    for (let j = 0; j < N; j++) {
+        matrix[j][M] = machine.target[j] ? 1 : 0;
+        for (let i = 0; i < M; i++) {
+            if (machine.buttons[i].includes(j)) {
+                matrix[j][i] = 1;
+            }
+        }
+    }
+
+    // Gaussian Elimination over GF(2) to get Row Echelon Form
+    let pivot_row = 0;
+    const pivot_col_for_row: number[] = Array(N).fill(-1); // pivot_col_for_row[r] = col index of pivot in row r, or -1 if no pivot
+    const free_vars: number[] = []; // Stores indices of columns that are free variables
+
+    for (let col = 0; col < M && pivot_row < N; col++) {
+        // Find pivot in current column (from pivot_row downwards)
+        let pivot_candidate_row = pivot_row;
+        while (pivot_candidate_row < N && matrix[pivot_candidate_row][col] === 0) {
+            pivot_candidate_row++;
+        }
+
+        if (pivot_candidate_row === N) {
+            // No pivot in this column, it's a free variable
+            free_vars.push(col);
+            continue;
+        }
+
+        // Swap pivot row into place
+        [matrix[pivot_row], matrix[pivot_candidate_row]] = [matrix[pivot_candidate_row], matrix[pivot_row]];
+
+        // Record pivot column for this row
+        pivot_col_for_row[pivot_row] = col;
+
+        // Eliminate other 1s in this column (for Reduced Row Echelon Form)
+        for (let row = 0; row < N; row++) {
+            if (row !== pivot_row && matrix[row][col] === 1) {
+                matrix[row] = xor_arrays(matrix[row], matrix[pivot_row]);
+            }
+        }
+        pivot_row++;
+    }
+
+    // Check for inconsistencies (rows like [0, 0, ..., 0 | 1])
+    for (let r = pivot_row; r < N; r++) {
+        // If a row has all zeros in variable columns but a 1 in the target column, it's inconsistent
+        if (matrix[r][M] === 1) {
+            let all_vars_zero = true;
+            for(let c = 0; c < M; c++) {
+                if (matrix[r][c] !== 0) {
+                    all_vars_zero = false;
+                    break;
+                }
+            }
+            if (all_vars_zero) {
+                return null; // No solution
+            }
+        }
+    }
+
+    // Prepare for solving: get pivot columns sorted by row
+    const pivots: { row: number, col: number }[] = [];
+    for(let r = 0; r < pivot_row; r++) {
+        pivots.push({ row: r, col: pivot_col_for_row[r] });
+    }
+    // Sort pivots by column index for back-substitution from right to left
+    pivots.sort((a, b) => b.col - a.col);
+
+
+    // Solve for the variables, prioritizing minimum presses and lexicographical order
+    let best_solution: number[] | null = null;
+    let min_presses = Infinity;
+
+    const num_free_vars = free_vars.length;
+    const num_combinations = 1 << num_free_vars; // 2^num_free_vars
+
+    for (let i = 0; i < num_combinations; i++) {
+        const current_solution = Array(M).fill(0);
+        let current_presses = 0;
+
+        // Assign values to free variables based on bits in 'i'
+        for (let j = 0; j < num_free_vars; j++) {
+            if ((i >> j) & 1) { // If j-th bit is 1
+                const free_var_idx = free_vars[j];
+                current_solution[free_var_idx] = 1;
+                current_presses++;
+            }
+        }
+
+        // Back-substitute for pivot variables
+        for (const pivot_info of pivots) {
+            const r = pivot_info.row;
+            const pivot_col = pivot_info.col;
+
+            let sum_of_known_vars = 0;
+            // Sum contributions from variables to the right of the pivot_col
+            // In RREF, we only need to check variables with column index > pivot_col
+            for (let k = pivot_col + 1; k < M; k++) {
+                sum_of_known_vars ^= (current_solution[k] * matrix[r][k]);
+            }
