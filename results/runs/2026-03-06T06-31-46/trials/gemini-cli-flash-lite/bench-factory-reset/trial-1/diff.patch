+            // Solve for the pivot variable: x_pivot_col = target_val ^ sum_of_other_vars
+            current_solution[pivot_col] = matrix[r][M] ^ sum_of_known_vars;
+            if (current_solution[pivot_col] === 1) {
+                current_presses++;
+            }
+        }
