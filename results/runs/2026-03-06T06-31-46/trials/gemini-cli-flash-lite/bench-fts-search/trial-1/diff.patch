 import { Router, Request, Response, NextFunction } from 'express';
 import Database from 'better-sqlite3';
-import { Note, NoteInput } from './models.js';
+import { Note, NoteInput, SearchResult, SuggestResult } from './models.js';
 import { NotFoundError, ValidationError } from './errors.js';
 
+const PER_PAGE = 20;
+const MAX_SUGGESTIONS = 5;
+
 export function createRoutes(db: Database.Database): Router {
   const router = Router();
 
@@ -118,5 +121,77 @@ export function createRoutes(db: Database.Database): Router {
     }
   });
 
+  // GET /notes/search - Full-text search across notes
+  // Restoring original SQL query with snippet and rank.
+  router.get('/notes/search', (req: Request, res: Response, next: NextFunction) => {
+    try {
+      const query = req.query.q as string | undefined;
+      const page = parseInt(req.query.page as string) || 1;
+
+      if (!query || query.trim() === '') {
+        throw new ValidationError('Query parameter "q" is required and cannot be empty.');
+      }
+
+      const offset = (page - 1) * PER_PAGE;
+
+      const searchStmt = db.prepare(`
+        SELECT
+          n.id,
+          n.title,
+          n.created_at,
+          n.updated_at,
+          notes_fts.snippet(notes_fts.title, notes_fts.body) AS snippet,
+          notes_fts.rank AS rank
+        FROM notes AS n
+        JOIN notes_fts ON n.id = notes_fts.rowid
+        WHERE notes_fts MATCH ?
+        ORDER BY rank
+        LIMIT ? OFFSET ?
+      `);
+      const results = searchStmt.all(query, PER_PAGE, offset) as SearchResult[];
+
+      // Get total count for pagination
+      const countStmt = db.prepare('SELECT COUNT(*) AS total FROM notes_fts WHERE notes_fts MATCH ?');
+      const total = countStmt.get(query)?.total || 0;
+
+      res.json({
+        results,
+        total,
+        page,
+        perPage: PER_PAGE,
+      });
+    } catch (err) {
+      next(err);
+    }
+  });
+
+  // GET /notes/search/suggest - Autocomplete suggestions
+  router.get('/notes/search/suggest', (req: Request, res: Response, next: NextFunction) => {
+    try {
+      const prefix = req.query.q as string | undefined;
+
+      if (!prefix || prefix.trim() === '') {
+        throw new ValidationError('Query parameter "q" is required and cannot be empty.');
+      }
+
+      // FTS5 query for prefix matching in title and body
+      // Using notes_fts MATCH ? to search across indexed columns (title, body) for the prefix
+      const suggestStmt = db.prepare(`
+        SELECT
+          n.id,
+          n.title
+        FROM notes AS n
+        JOIN notes_fts ON n.id = notes_fts.rowid
+        WHERE notes_fts MATCH ?
+        LIMIT ?
+      `);
+      const results = suggestStmt.all(prefix + '*', MAX_SUGGESTIONS) as SuggestResult[]; // FTS5 prefix matching uses '*'
+
+      res.json({ results });
+    } catch (err) {
+      next(err);
+    }
+  });
+
   return router;
 }
