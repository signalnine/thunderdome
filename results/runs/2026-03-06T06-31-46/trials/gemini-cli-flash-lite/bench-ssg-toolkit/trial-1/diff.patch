+import type { Plugin, ContentFile, BuildContext, PluginHooks } from '../core/types';
+import path from 'path';
+
+const PLUGIN_NAME = 'dev-server';
+const PLUGIN_VERSION = '1.0.0';
+
+export function createDevServerPlugin(): Plugin {
+  const hooks: PluginHooks = {
+    // The dev-server configuration often influences how the server runs.
+    // This could be in `beforeBuild` or a dedicated hook if the engine supports it.
+    // For simplicity, we'll assume it might influence build-time configuration
+    // or add data to ctx that a separate dev server process would use.
+    // Since we are just generating configuration, we'll put it in `afterBuild`
+    // to ensure all other plugins have run and their outputs (like search-index.json) are available.
+
+    afterBuild: async (ctx: BuildContext): Promise<void> => {
+      const devServerConfig = {
+        static: {
+          // Serve files from the output directory.
+          // Assumes ctx.config.outputDir is set, otherwise defaults to '.'
+          directory: ctx.config.outputDir || '.',
+          // Ignore specific files if needed, e.g., temporary build artifacts.
+          ignore: ['**.tmp', '**/__tests__/**'],
+        },
+        // Potentially use search-index for client-side search integration
+        searchIndex: ctx.output.has('search-index.json') ? '/search-index.json' : null,
+        // Potentially use asset manifest for URL rewriting hints if the dev server needs it,
+        // though usually static file serving handles this automatically.
+        // assetManifest: ctx.output.has('assets-manifest.json') ? '/assets-manifest.json' : null,
+
+        // Example for proxying (if this SSG had a backend API)
+        // proxy: {
+        //   '/api': {
+        //     target: 'http://localhost:3001',
+        //     pathRewrite: { '^/api': '' },
+        //   },
+        // },
+
+        // Live reload might be a feature of the actual dev server tool,
+        // but we can configure aspects of it here if needed.
+        // For this example, we'll just generate a basic static server config.
+      };
+
+      // Store the configuration, perhaps in ctx.data or by writing a config file.
+      // For this task, we'll assume writing a config file is appropriate.
+      // A common pattern is a 'dev-server.config.js' or similar.
+      const configContent = `module.exports = ${JSON.stringify(devServerConfig, null, 2)};`;
+      ctx.output.set('dev-server.config.js', configContent);
+
+      console.log('Dev Server Plugin: Generated dev-server.config.js');
+    },
+  };
+
+  return {
+    name: PLUGIN_NAME,
+    version: PLUGIN_VERSION,
+    // Depends on asset-pipeline (for understanding assets) and search-index (for search config)
+    dependencies: ['asset-pipeline', 'search-index'],
+    hooks,
+  };
+}
