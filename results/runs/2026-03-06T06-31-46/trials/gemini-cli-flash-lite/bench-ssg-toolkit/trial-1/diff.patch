@@ -0,0 +1,92 @@
+import type { Plugin, ContentFile, BuildContext, PluginHooks } from '../core/types';
+
+const PLUGIN_NAME = 'sitemap';
+const PLUGIN_VERSION = '1.0.0';
+
+// Helper to escape XML characters
+const xmlEscape = (str: string): string => {
+  return str.replace(/[<>&'"]/g, (char) => {
+    switch (char) {
+      case '<': return '&lt;';
+      case '>': return '&gt;';
+      case '&': return '&amp;';
+      case "'": return '&apos;';
+      case '"': return '&quot;';
+      default: return char;
+    }
+  });
+};
+
+export function createSitemapPlugin(): Plugin {
+  const hooks: PluginHooks = {
+    // This plugin generates a sitemap XML file after all other content and feeds are generated.
+    // It needs to know about all generated pages, including those created by other plugins.
+    // The `afterBuild` hook is suitable for this.
+    afterBuild: async (ctx: BuildContext): Promise<void> => {
+      const sitemapEntries: string[] = [];
+      const siteUrl = ctx.config.baseUrl || 'http://localhost:3000'; // Fallback site URL
+
+      // Gather all URLs from the output map.
+      // This includes original content files and any generated pages (like tag/category/RSS).
+      for (const outputFileName of ctx.output.keys()) {
+        // We are interested in pages, typically ending in .html.
+        // Exclude non-page files like search-index.json, assets-manifest.json, feed.xml.
+        // However, we might want to include feed.xml if it's a page.
+        // For a sitemap, we usually list pages.
+        if (outputFileName.endsWith('.html') || outputFileName === 'feed.xml') {
+          const pageUrl = new URL(outputFileName, siteUrl).href;
+          // For simplicity, we'll set lastmod to current date and priority/changefreq to defaults.
+          // A more advanced plugin might try to infer lastmod from file metadata.
+          const lastmod = new Date().toISOString().split('T')[0]; // YYYY-MM-DD format
+
+          sitemapEntries.push(`
+    <url>
+      <loc>${xmlEscape(pageUrl)}</loc>
+      <lastmod>${lastmod}</lastmod>
+      <changefreq>weekly</changefreq>
+      <priority>0.8</priority>
+    </url>
+          `);
+        }
+      }
+
+      // Add root URL if it's not implicitly covered
+      if (!ctx.output.has('index.html') && !ctx.output.has('index.htm')) {
+         const rootUrl = siteUrl;
+         const lastmod = new Date().toISOString().split('T')[0];
+         sitemapEntries.push(`
+    <url>
+      <loc>${xmlEscape(rootUrl)}</loc>
+      <lastmod>${lastmod}</lastmod>
+      <changefreq>daily</changefreq>
+      <priority>1.0</priority>
+    </url>
+         `);
+      }
+
+
+      if (sitemapEntries.length === 0) {
+        console.warn('Sitemap Plugin: No URLs found to generate sitemap.');
+        return; // Do not generate an empty sitemap
+      }
+
+      const sitemapContent = `<?xml version="1.0" encoding="UTF-8"?>
+<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
+  ${sitemapEntries.join('
+')}
+</urlset>
+      `;
+
+      ctx.output.set('sitemap.xml', sitemapContent);
+      console.log('Sitemap Plugin: Generated sitemap.xml');
+    },
+  };
+
+  return {
+    name: PLUGIN_NAME,
+    version: PLUGIN_VERSION,
+    // Depends on taxonomy (for generated tag/category pages) and rss-feed (for feed.xml)
+    dependencies: ['taxonomy', 'rss-feed'],
+    hooks,
+  };
+}
