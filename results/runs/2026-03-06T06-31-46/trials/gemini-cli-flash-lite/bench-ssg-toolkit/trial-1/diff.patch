+import type { Plugin, ContentFile, BuildContext, PluginHooks } from '../core/types';
+import { marked } from 'marked'; // Potentially useful if we need to parse content for description
+
+const PLUGIN_NAME = 'rss-feed';
+const PLUGIN_VERSION = '1.0.0';
+
+// Helper to escape XML characters
+const xmlEscape = (str: string): string => {
+  return str.replace(/[<>&'"]/g, (char) => {
+    switch (char) {
+      case '<': return '&lt;';
+      case '>': return '&gt;';
+      case '&': return '&amp;';
+      case "'": return '&apos;';
+      case '"': return '&quot;';
+      default: return char;
+    }
+  });
+};
+
+// Helper to format date to RFC 822 format (required for RSS)
+// Example: 'Fri, 01 Mar 2024 12:00:00 GMT'
+const formatDateRss = (dateString: string | undefined): string | undefined => {
+  if (!dateString) return undefined;
+  try {
+    const date = new Date(dateString);
+    // toGMTString is deprecated, use toUTCString and adjust formatting
+    return date.toUTCString().replace('GMT', 'UTC'); // Example adjustment, may need more precision
+    // A more robust date formatting library might be needed for full RFC 822 compliance
+  } catch (e) {
+    console.error(`Error formatting date ${dateString}:`, e);
+    return undefined;
+  }
+};
+
+export function createRssFeedPlugin(): Plugin {
+  const hooks: PluginHooks = {
+    // This plugin primarily generates a file after all content has been processed.
+    // So, afterBuild is the most suitable hook.
+    afterBuild: async (ctx: BuildContext): Promise<void> => {
+      const rssItems: string[] = [];
+      const siteUrl = ctx.config.baseUrl || 'http://localhost:3000'; // Fallback site URL
+
+      // Filter files for inclusion in RSS feed (e.g., only published posts)
+      // For now, let's include all files that have a date and a title/slug.
+      const feedFiles = ctx.files.filter(file =>
+        file.date && (file.title || file.slug)
+      );
+
+      // Sort files by date, newest first
+      feedFiles.sort((a, b) => {
+        const dateA = new Date(a.date!).getTime();
+        const dateB = new Date(b.date!).getTime();
+        return dateB - dateA;
+      });
+
+      for (const file of feedFiles) {
+        const itemTitle = xmlEscape(file.title || file.slug);
+        // Ensure links are absolute, using baseUrl from config
+        const itemLink = new URL(file.slug, siteUrl).href;
+        const itemDate = formatDateRss(file.date);
+
+        // Use 'content:encoded' for full HTML content, or 'description' for summary.
+        // If markdown-ext has already converted to HTML, file.content will be HTML.
+        // Otherwise, it might still be markdown. For RSS, HTML is generally preferred for full items.
+        // Let's assume file.content is HTML due to markdown-ext.
+        const itemDescription = xmlEscape(file.content); // Assuming file.content is HTML after markdown-ext
+
+        // Get categories (from taxonomy plugin's output or directly from file.metadata if available)
+        // This plugin depends on taxonomy, so we might access taxonomy data from ctx.data
+        // or re-process metadata if taxonomy plugin didn't put it in a shared place.
+        // For now, let's use tags directly from file.metadata, assuming they are there.
+        const itemCategories = (file.metadata.tags || file.metadata.categories || [])
+          .filter((cat: any) => typeof cat === 'string')
+          .map((cat: string) => `<category>${xmlEscape(cat)}</category>`)
+          .join('
+');
+
+        // Ensure publication date is present and formatted
+        if (itemDate) {
+          rssItems.push(`
+      <item>
+        <title>${itemTitle}</title>
+        <link>${itemLink}</link>
+        <pubDate>${xmlEscape(itemDate)}</pubDate>
+        <guid isPermaLink="true">${itemLink}</guid>
+        ${itemCategories}
+        <description>${itemDescription}</description>
+      </item>
+          `);
+        }
+      }
+
+      if (rssItems.length === 0) {
+        console.warn('RSS Feed Plugin: No items found to generate RSS feed.');
+        return; // Do not generate an empty feed if there's no content
+      }
+
+      const rssContent = `<?xml version="1.0" encoding="UTF-8"?>
+<rss version="2.0" xmlns:content="http://purl.org/rss/1.0/modules/content/" xmlns:atom="http://www.w3.org/2005/Atom">
+  <channel>
+    <title>${xmlEscape(ctx.config.title)}</title>
+    <link>${siteUrl}</link>
+    <description>${xmlEscape(ctx.config.description || '')}</description>
+    <language>en-us</language>
+    <atom:link href="${siteUrl}/feed.xml" rel="self" type="application/rss+xml" />
+    ${rssItems.join('
+')}
+  </channel>
+</rss>
+      `;
+
+      ctx.output.set('feed.xml', rssContent);
+      console.log('RSS Feed Plugin: Generated feed.xml');
+    },
+  };
+
+  return {
+    name: PLUGIN_NAME,
+    version: PLUGIN_VERSION,
+    // This plugin depends on markdown-ext (for potentially processed content)
+    // and taxonomy (for categories/tags, if not directly on files)
+    dependencies: ['markdown-ext', 'taxonomy'],
+    hooks,
+  };
+}
