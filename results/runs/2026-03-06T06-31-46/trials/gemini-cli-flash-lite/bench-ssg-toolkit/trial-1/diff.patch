@@ -0,0 +1,135 @@
+import type { Plugin, ContentFile, BuildContext, PluginHooks } from '../core/types';
+
+// Assume a simple HTML template function for tag/category pages
+// In a real app, this would likely use a templating engine or more complex HTML generation
+const generateTagPageHtml = (tagName: string, tagFiles: ContentFile[], config: BuildContext['config']): string => {
+  const pageTitle = `Tag: ${tagName} - ${config.title}`;
+  const fileListItems = tagFiles.map(file =>
+    `<li><a href="/${file.slug}">${file.title || file.slug}</a></li>`
+  ).join('');
+
+  return `
+<!DOCTYPE html>
+<html lang="en">
+<head>
+    <meta charset="UTF-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1.0">
+    <title>${pageTitle}</title>
+    <!-- Link to CSS, assuming it's handled elsewhere or a basic style -->
+    <style>
+        body { font-family: sans-serif; }
+        nav a { margin-right: 1em; }
+    </style>
+</head>
+<body>
+    <nav>
+        <a href="/">Home</a>
+        <!-- Add other navigation links if available -->
+    </nav>
+    <h1>Posts tagged with "${tagName}"</h1>
+    <ul>
+        ${fileListItems}
+    </ul>
+</body>
+</html>
+  `;
+};
+
+const generateCategoryPageHtml = (categoryName: string, categoryFiles: ContentFile[], config: BuildContext['config']): string => {
+  const pageTitle = `Category: ${categoryName} - ${config.title}`;
+  const fileListItems = categoryFiles.map(file =>
+    `<li><a href="/${file.slug}">${file.title || file.slug}</a></li>`
+  ).join('');
+
+  return `
+<!DOCTYPE html>
+<html lang="en">
+<head>
+    <meta charset="UTF-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1.0">
+    <title>${pageTitle}</title>
+    <style>
+        body { font-family: sans-serif; }
+        nav a { margin-right: 1em; }
+    </style>
+</head>
+<body>
+    <nav>
+        <a href="/">Home</a>
+        <!-- Add other navigation links if available -->
+    </nav>
+    <h1>Posts in category "${categoryName}"</h1>
+    <ul>
+        ${fileListItems}
+    </ul>
+</body>
+</html>
+  `;
+};
+
+const PLUGIN_NAME = 'taxonomy';
+const PLUGIN_VERSION = '1.0.0';
+
+export function createTaxonomyPlugin(): Plugin {
+  const hooks: PluginHooks = {
+    afterBuild: async (ctx: BuildContext): Promise<void> => {
+      const tagsMap: Record<string, ContentFile[]> = {};
+      const categoriesMap: Record<string, ContentFile[]> = {};
+
+      // Aggregate files by tags and categories
+      for (const file of ctx.files) {
+        // Process tags
+        if (file.metadata.tags && Array.isArray(file.metadata.tags)) {
+          for (const tag of file.metadata.tags) {
+            if (typeof tag === 'string') {
+              if (!tagsMap[tag]) {
+                tagsMap[tag] = [];
+              }
+              tagsMap[tag].push(file);
+            }
+          }
+        }
+
+        // Process categories
+        if (file.metadata.categories && Array.isArray(file.metadata.categories)) {
+          for (const category of file.metadata.categories) {
+            if (typeof category === 'string') {
+              if (!categoriesMap[category]) {
+                categoriesMap[category] = [];
+              }
+              categoriesMap[category].push(file);
+            }
+          }
+        }
+      }
+
+      // Generate tag pages
+      for (const tagName in tagsMap) {
+        const tagFiles = tagsMap[tagName];
+        const pageContent = generateTagPageHtml(tagName, tagFiles, ctx.config);
+        const pageSlug = `tag/${tagName.toLowerCase().replace(/\s+/g, '-')}`; // slugify tag name
+        ctx.output.set(`${pageSlug}.html`, pageContent);
+        console.log(`Taxonomy Plugin: Generated tag page for "${tagName}"`);
+      }
+
+      // Generate category pages
+      for (const categoryName in categoriesMap) {
+        const categoryFiles = categoriesMap[categoryName];
+        const pageContent = generateCategoryPageHtml(categoryName, categoryFiles, ctx.config);
+        const pageSlug = `category/${categoryName.toLowerCase().replace(/\s+/g, '-')}`; // slugify category name
+        ctx.output.set(`${pageSlug}.html`, pageContent);
+        console.log(`Taxonomy Plugin: Generated category page for "${categoryName}"`);
+      }
+
+      // Optionally, generate an index page for all tags/categories
+      // For simplicity, we won't generate a main index page here, just individual pages.
+    },
+  };
+
+  return {
+    name: PLUGIN_NAME,
+    version: PLUGIN_VERSION,
+    dependencies: [], // No dependencies for Wave 1
+    hooks,
+  };
+}
