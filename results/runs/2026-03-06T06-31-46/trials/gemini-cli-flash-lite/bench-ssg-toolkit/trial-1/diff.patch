+import { marked } from 'marked';
+import hljs from 'highlight.js'; // Import highlight.js
+import type { Plugin, ContentFile, BuildContext, PluginHooks } from '../core/types';
+
+const PLUGIN_NAME = 'syntax-highlight';
+const PLUGIN_VERSION = '1.0.0';
+
+// Configure marked to use highlight.js for code blocks
+const renderer = new marked.Renderer();
+
+// Override the code method to use highlight.js
+renderer.code = (code: string, language: string | undefined): string => {
+  const validLanguage = language && hljs.getLanguage(language) ? language : 'plaintext';
+  const highlightedCode = hljs.highlight(code, { language: validLanguage, ignoreIllegals: true }).value;
+  return `<pre><code class="language-${validLanguage}">${highlightedCode}</code></pre>`;
+};
+
+// If you need to support admonitions and footnotes in conjunction with code highlighting,
+// you might need to merge renderers or ensure marked is configured correctly.
+// For example, if markdown-ext also overrides renderers, there might be conflicts.
+// For now, we'll assume this renderer setup is compatible with other marked configurations
+// or that markdown-ext's extensions are handled before this.
+
+export function createSyntaxHighlightPlugin(): Plugin {
+  const hooks: PluginHooks = {
+    // The transformContent hook is where we can apply syntax highlighting.
+    // However, if markdown-ext already transformed markdown to HTML,
+    // we would need to operate on HTML, which is more complex.
+    // A better approach might be to ensure the renderer is set globally
+    // or on the marked instance used by the engine BEFORE markdown is parsed.
+
+    // Given the current structure where plugins might run sequentially in transformContent,
+    // it's more robust to ensure this plugin's renderer is applied.
+    // If markdown-ext ran first, it would have already converted MD to HTML.
+    // So, this hook might need to be applied *before* markdown-ext's transformContent,
+    // or the engine must support setting renderers.
+
+    // Let's assume the engine allows for this renderer to be set up.
+    // A more reliable way might be to register renderers on the marked instance
+    // that the engine uses internally.
+    // If the engine doesn't handle this, we might need to re-parse markdown here
+    // or have markdown-ext accept a custom renderer.
+
+    // For this implementation, we'll assume the marked instance used by the engine
+    // can be configured or modified. If not, this approach will need adjustment.
+
+    // A simpler approach is to modify the markdown content *before* it's parsed by marked
+    // if marked doesn't support extensions easily in a plugin context.
+    // However, the current plugins are operating on `ContentFile.content` which is raw.
+
+    // Let's try setting marked's default renderer. This is generally not ideal
+    // as it's a global state, but might be the only way if the engine doesn't
+    // provide a more granular way to inject renderers.
+    //
+    // NOTE: This assumes that marked's global renderer state can be manipulated.
+    // If the engine uses a fresh marked instance per build or per plugin, this won't work.
+    // In that case, we'd need markdown-ext to be aware of this plugin's renderer.
+    beforeBuild: async (ctx: BuildContext): Promise<void> => {
+      // Apply the custom renderer before markdown processing potentially happens.
+      // This assumes markdown processing occurs via `marked` and its renderer.
+      marked.use({ renderer }); // Set our custom renderer
+      console.log('Syntax Highlight: Marked renderer configured.');
+    },
+
+    // We don't need to transform content here if the renderer is set globally before parsing.
+    // The markdown-ext plugin will handle the initial markdown parsing,
+    // and our custom renderer will be used automatically.
+    // If markdown-ext is *not* modifying the markdown parsing pipeline directly,
+    // then this hook might need to re-parse or apply transformations.
+    // For now, we rely on the global renderer setup.
+  };
+
+  return {
+    name: PLUGIN_NAME,
+    version: PLUGIN_VERSION,
+    dependencies: [], // No dependencies for Wave 1
+    hooks,
+  };
+}
