+import { marked } from 'marked';
+import { markedFootnote } from 'marked-footnote'; // Correct import for marked-footnote
+import { markedAdmonition } from 'marked-admonition'; // Correct import for marked-admonition
+import type { Plugin, ContentFile, BuildContext, PluginHooks } from '../core/types';
+
+const PLUGIN_NAME = 'markdown-ext';
+const PLUGIN_VERSION = '1.0.0';
+
+// Create a configured marked instance with extensions
+// It's generally better to configure extensions once if possible,
+// but if the engine doesn't pre-configure, we do it here.
+const markdownParser = marked.use(
+  markedFootnote(),
+  markedAdmonition()
+);
+
+export function createMarkdownExtPlugin(): Plugin {
+  const hooks: PluginHooks = {
+    transformContent: async (file: ContentFile, ctx: BuildContext): Promise<ContentFile> => {
+      // Only process files that are likely markdown
+      if (file.slug.endsWith('.md') || file.slug.endsWith('.markdown')) {
+        try {
+          // Use the configured markdownParser to convert markdown to HTML.
+          const htmlContent = await markdownParser.parse(file.content);
+
+          return {
+            ...file,
+            content: htmlContent, // Overwrite content with HTML
+          };
+        } catch (error) {
+          console.error(`Error transforming markdown file ${file.slug}:`, error);
+          // In a real scenario, you might want to throw an error to stop the build,
+          // or at least log more context. For now, returning original file.
+          return file;
+        }
+      }
+      return file; // Return original file if not a markdown file
+    },
+  };
+
+  return {
+    name: PLUGIN_NAME,
+    version: PLUGIN_VERSION,
+    dependencies: [], // This plugin has no dependencies
+    hooks,
+  };
+}
