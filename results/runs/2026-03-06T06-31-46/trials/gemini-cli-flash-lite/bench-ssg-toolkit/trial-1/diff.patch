+++ b/src/plugins/search-index.ts
@@ -0,0 +1,81 @@
+import type { Plugin, ContentFile, BuildContext, PluginHooks } from '../core/types';
+// Assuming markdown-ext has already converted markdown to HTML, file.content will be HTML.
+// If not, we might need to parse markdown here or ensure markdown-ext runs first.
+// We will extract text content for indexing.
+
+const PLUGIN_NAME = 'search-index';
+const PLUGIN_VERSION = '1.0.0';
+
+interface SearchIndexEntry {
+  slug: string;
+  title: string;
+  content: string; // Plain text content for searching
+  url: string;
+  tags?: string[];
+  categories?: string[];
+  date?: string;
+}
+
+// Simple function to extract plain text from HTML (very basic)
+// In a real app, a proper HTML parser would be better.
+const extractTextFromHtml = (html: string): string => {
+  // Remove HTML tags by matching them, very naive approach
+  return html.replace(/<[^>]*>/g, ' ');
+};
+
+export function createSearchIndexPlugin(): Plugin {
+  const hooks: PluginHooks = {
+    // This plugin generates a JSON file after all content processing is done.
+    afterBuild: async (ctx: BuildContext): Promise<void> => {
+      const searchIndex: SearchIndexEntry[] = [];
+      const siteUrl = ctx.config.baseUrl || 'http://localhost:3000'; // Fallback site URL
+
+      for (const file of ctx.files) {
+        // Only include files that are likely pages and have been processed.
+        // For example, filter out raw assets or non-page content.
+        // Assume files with a title or slug are candidates for indexing.
+        if (file.slug && (file.title || file.content)) {
+          let plainTextContent = '';
+          if (typeof file.content === 'string') {
+            // If markdown-ext ran, file.content should be HTML.
+            // Otherwise, it might be raw markdown. For search, plain text is better.
+            // A robust solution would detect content type or ensure HTML.
+            plainTextContent = extractTextFromHtml(file.content);
+          } else {
+            // Handle cases where content might not be a string (e.g., if it's binary or already processed)
+            plainTextContent = String(file.content); // Attempt to stringify, might need adjustment
+          }
+
+          // Basic slug for URL, assuming file.slug is already processed and clean
+          const fileUrl = new URL(file.slug, siteUrl).href;
+
+          searchIndex.push({
+            slug: file.slug,
+            title: file.title || '',
+            content: plainTextContent.replace(/\s+/g, ' ').trim(), // Normalize whitespace
+            url: fileUrl,
+            tags: (file.metadata.tags as string[]) || [],
+            categories: (file.metadata.categories as string[]) || [],
+            date: file.date,
+          });
+        }
+      }
+
+      // Generate the JSON index
+      const indexJson = JSON.stringify(searchIndex, null, 2);
+      const indexPath = 'search-index.json';
+
+      ctx.output.set(indexPath, indexJson);
+      console.log(`Search Index Plugin: Generated ${indexPath}`);
+    },
+  };
+
+  return {
+    name: PLUGIN_NAME,
+    version: PLUGIN_VERSION,
+    // Depends on markdown-ext (for HTML content) and syntax-highlight (for potential text extraction nuances)
+    // Though syntax-highlight doesn't modify text content, it's listed as a dependency.
+    dependencies: ['markdown-ext', 'syntax-highlight'],
+    hooks,
+  };
+}
