+
+    if (!events) {
+      return res.status(400).send('Events array is required.');
+    }
+
+    try {
+      const insertedEvents = [];
+      const eventList = Array.isArray(events) ? events : [events]; // Handle single event
+
+      for (const event of eventList) {
+        if (!event.name || !event.timestamp) {
+          return res.status(400).send('Each event must have a name and timestamp.');
+        }
+        // User ID and Session ID are optional
+        const newEvent = createEvent(
+          tenantId,
+          event.name,
+          event.properties || {},
+          event.timestamp,
+          event.userId,
+          event.sessionId
+        );
+        insertedEvents.push(newEvent);
+      }
+      res.status(201).json(insertedEvents);
+    } catch (error) {
+      console.error('Event ingestion error:', error);
+      res.status(500).send('Internal server error ingesting events.');
+    }
+  });
+
+  // Query Engine Routes
+  app.get('/query/events/count', authenticateToken, (req: Request, res: Response) => {
+    const tenantId = req.user.tenantId;
+    const { name, properties, start, end } = req.query;
+
+    if (!name) {
+      return res.status(400).send('Event name is required for counting.');
+    }
+
+    try {
+      // This is a very basic count. A real implementation would need to parse properties and time ranges more robustly.
+      // For now, we'll just count by name and use the provided time range.
+      const events = findEventsByTenant(tenantId as string, name as string, { start: start as string, end: end as string });
+      res.json({ count: events.length });
+    } catch (error) {
+      console.error('Event count query error:', error);
+      res.status(500).send('Internal server error running event count query.');
+    }
+  });
+
+  app.get('/query/events/timeseries', authenticateToken, (req: Request, res: Response) => {
+    const tenantId = req.user.tenantId;
+    const { name, interval, start, end } = req.query; // e.g., interval=daily, hourly
+
+    if (!name || !interval || !start || !end) {
+      return res.status(400).send('Event name, interval (daily, hourly), start, and end times are required.');
+    }
+
+    try {
+      // Complex query logic for timeseries. This is a placeholder.
+      // A real implementation would query events, group them by interval, and count.
+      // Example: SELECT strftime('%Y-%m-%d', timestamp) as day, COUNT(*) FROM events WHERE tenant_id = ? AND name = ? GROUP BY day;
+      const events = findEventsByTenant(tenantId as string, name as string, { start: start as string, end: end as string });
+
+      const results: Record<string, number> = {};
+      events.forEach(event => {
+        let bucket: string;
+        const date = new Date(event.timestamp);
+        if (interval === 'daily') {
+          bucket = date.toISOString().split('T')[0]; // YYYY-MM-DD
+        } else if (interval === 'hourly') {
+          bucket = date.toISOString().split('.')[0]; // YYYY-MM-DDTHH:MM:SS
+        } else {
+          return res.status(400).send('Unsupported interval. Use "daily" or "hourly".');
+        }
+        results[bucket] = (results[bucket] || 0) + 1;
+      });
+
+      res.json(results);
+    } catch (error) {
+      console.error('Timeseries query error:', error);
+      res.status(500).send('Internal server error running timeseries query.');
+    }
+  });
+
+  app.get('/query/events/breakdown', authenticateToken, (req: Request, res: Response) => {
+    const tenantId = req.user.tenantId;
+    const { name, groupBy, filter, start, end } = req.query; // groupBy is a property name
+
+    if (!name || !groupBy || !start || !end) {
+      return res.status(400).send('Event name, groupBy property, start, and end times are required.');
+    }
+
+    try {
+      // Complex query logic for breakdown. This is a placeholder.
+      const events = findEventsByTenant(tenantId as string, name as string, { start: start as string, end: end as string });
+
+      const results: Record<string, number> = {};
+      events.forEach(event => {
+        try {
+          const properties = JSON.parse(event.properties);
+          const groupValue = properties[groupBy as string];
+          if (groupValue !== undefined) {
+            results[groupValue] = (results[groupValue] || 0) + 1;
+          }
+        } catch (parseError) {
+          // Ignore events with invalid properties JSON
+          console.warn(`Could not parse properties for event ${event.id}: ${parseError}`);
+        }
+      });
+
+      res.json(results);
+    } catch (error) {
+      console.error('Breakdown query error:', error);
+      res.status(500).send('Internal server error running breakdown query.');
+    }
+  });
+
+  // Dashboard Configuration Routes
+  app.post('/dashboards', authenticateToken, (req: Request, res: Response) => {
+    const tenantId = req.user.tenantId;
+    const ownerId = req.user.userId;
+    const { name, config } = req.body;
