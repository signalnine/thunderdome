+    const { dashboardId } = req.params;
+    const { name, config } = req.body;
+
+    if (!name || !config) {
+      return res.status(400).send('Dashboard name and config are required.');
+    }
+
+    try {
+      // Check if dashboard exists and belongs to the tenant before updating
+      const existingDashboard = getDashboardById(dashboardId, tenantId);
