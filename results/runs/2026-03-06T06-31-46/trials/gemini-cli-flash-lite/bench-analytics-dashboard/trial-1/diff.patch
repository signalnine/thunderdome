--- /dev/null
+++ b/src/app.ts
@@ -0,0 +1,513 @@
+import express, { Express, Request, Response, NextFunction } from 'express';
+import sqlite3 from 'better-sqlite3';
+import jwt from 'jsonwebtoken';
+import { v4 as uuidv4 } from 'uuid';
+
+// --- Constants ---
+const JWT_SECRET = process.env.JWT_SECRET || 'your-super-secret-key-change-me'; // TODO: Get this from a secure source or env var
+const DB_PATH = './database.db'; // TODO: Consider a more robust path management
+
+// --- Database Setup ---
+const db = sqlite3(DB_PATH);
+
+// --- Helper Functions ---
+function authenticateToken(req: Request, res: Response, next: NextFunction) {
+  const authHeader = req.headers['authorization'];
+  const token = authHeader && authHeader.split(' ')[1];
+
+  if (token == null) {
+    return res.sendStatus(401); // No token provided
+  }
+
+  jwt.verify(token, JWT_SECRET, (err: any, user: any) => {
+    if (err) {
+      return res.sendStatus(403); // Token is invalid
+    }
+    // Attach user info to the request for downstream use
+    req.user = user; // Assuming user payload contains tenant_id and role
+    next();
+  });
+}
+
+// --- Data Access Layer (DAL) ---
+// This is a simplified example. A full implementation would involve classes or modules per entity.
+
+const createUser = (email: string, passwordHash: string, tenantId: string, role: string = 'viewer') => {
+  const stmt = db.prepare('INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)');
+  const userId = uuidv4();
+  stmt.run(userId, email, passwordHash, tenantId, role);
+  return { id: userId, email, tenant_id: tenantId, role };
+};
+
+const findUserByEmail = (email: string) => {
+  const stmt = db.prepare('SELECT * FROM users WHERE email = ?');
+  return stmt.get(email);
+};
+
+const findUserById = (id: string) => {
+  const stmt = db.prepare('SELECT * FROM users WHERE id = ?');
+  return stmt.get(id);
+};
+
+const updateUserRole = (userId: string, role: string) => {
+  const stmt = db.prepare('UPDATE users SET role = ? WHERE id = ?');
+  stmt.run(role, userId);
+};
+
+const createEvent = (tenantId: string, name: string, properties: object, timestamp: string, userId?: string, sessionId?: string) => {
+  const stmt = db.prepare('INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)');
+  const eventId = uuidv4();
+  stmt.run(eventId, tenantId, name, JSON.stringify(properties), timestamp, userId, sessionId);
+  return { id: eventId, tenant_id: tenantId, name, properties, timestamp, user_id: userId, session_id: sessionId };
+};
+
+const findEventsByTenant = (tenantId: string, filter?: string, timeRange?: { start: string, end: string }) => {
+  let query = 'SELECT * FROM events WHERE tenant_id = ?';
+  const params: any[] = [tenantId];
+
+  if (filter) {
+    query += ' AND name LIKE ?';
+    params.push(`%${filter}%`);
+  }
+  if (timeRange) {
+    query += ' AND timestamp BETWEEN ? AND ?';
+    params.push(timeRange.start, timeRange.end);
+  }
+
+  query += ' ORDER BY timestamp DESC'; // Default order
+  const stmt = db.prepare(query);
+  return stmt.all(...params);
+};
+
+const createDashboard = (tenantId: string, name: string, ownerId: string, config: object) => {
+  const stmt = db.prepare('INSERT INTO dashboards (id, tenant_id, name, owner_id, config) VALUES (?, ?, ?, ?, ?)');
+  const dashboardId = uuidv4();
+  stmt.run(dashboardId, tenantId, name, ownerId, JSON.stringify(config));
+  return { id: dashboardId, tenant_id: tenantId, name, owner_id: ownerId, config };
+};
+
+const getDashboardsByTenant = (tenantId: string) => {
+  const stmt = db.prepare('SELECT * FROM dashboards WHERE tenant_id = ?');
+  return stmt.all(tenantId);
+};
+
+const getDashboardById = (dashboardId: string, tenantId: string) => {
+  const stmt = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?');
+  return stmt.get(dashboardId, tenantId);
+};
+
+const updateDashboard = (dashboardId: string, tenantId: string, name: string, config: object) => {
+  const stmt = db.prepare('UPDATE dashboards SET name = ?, config = ?, updated_at = datetime('now') WHERE id = ? AND tenant_id = ?');
+  stmt.run(name, JSON.stringify(config), dashboardId, tenantId);
+};
+
+const deleteDashboard = (dashboardId: string, tenantId: string) => {
+  const stmt = db.prepare('DELETE FROM dashboards WHERE id = ? AND tenant_id = ?');
+  stmt.run(dashboardId, tenantId);
+};
+
+// --- Express Application Factory ---
+export function createApp(): Express {
+  const app = express();
+
+  // Middleware
+  app.use(express.json()); // For parsing application/json
+  app.use(express.urlencoded({ extended: true })); // For parsing application/x-www-form-urlencoded
+
+  // Simple health check
+  app.get('/health', (req: Request, res: Response) => {
+    res.status(200).send('OK');
+  });
+
+  // --- Routes ---
+
+  // User Authentication Routes
+  app.post('/auth/register', async (req: Request, res: Response) => {
+    const { email, password, tenantId, role } = req.body; // Assuming tenantId and role are provided during registration
+    if (!email || !password || !tenantId) {
+      return res.status(400).send('Email, password, and tenantId are required.');
+    }
+    try {
+      // In a real app, hash the password securely (e.g., bcrypt)
+      const passwordHash = `hashed_${password}`; // Placeholder
+      const existingUser = findUserByEmail(email);
+      if (existingUser) {
+        return res.status(409).send('Email already exists.');
+      }
+      const newUser = createUser(email, passwordHash, tenantId, role);
+      res.status(201).json({ id: newUser.id, email: newUser.email, tenant_id: newUser.tenant_id, role: newUser.role });
+    } catch (error) {
+      console.error('Registration error:', error);
+      res.status(500).send('Internal server error during registration.');
+    }
+  });
+
+  app.post('/auth/login', async (req: Request, res: Response) => {
+    const { email, password } = req.body;
+    if (!email || !password) {
+      return res.status(400).send('Email and password are required.');
+    }
+    try {
+      const user = findUserByEmail(email);
+      if (!user) {
+        return res.status(401).send('Invalid credentials.');
+      }
+      // In a real app, compare hashed passwords
+      const passwordMatch = `hashed_${password}` === user.password_hash; // Placeholder comparison
+      if (!passwordMatch) {
+        return res.status(401).send('Invalid credentials.');
+      }
+
+      // Generate JWT
+      const token = jwt.sign(
+        { userId: user.id, tenantId: user.tenant_id, role: user.role },
+        JWT_SECRET,
+        { expiresIn: '1h' }
+      );
+      res.json({ token });
+    } catch (error) {
+      console.error('Login error:', error);
+      res.status(500).send('Internal server error during login.');
+    }
+  });
+
+  // User Profile Route (requires authentication)
+  app.get('/profile', authenticateToken, (req: Request, res: Response) => {
+    // req.user is populated by the authenticateToken middleware
+    const userId = req.user.userId;
+    try {
+      const user = findUserById(userId);
+      if (!user) {
+        return res.status(404).send('User not found.');
+      }
+      // Return user details, excluding sensitive info like password_hash
+      res.json({ id: user.id, email: user.email, tenant_id: user.tenant_id, role: user.role });
+    } catch (error) {
+      console.error('Profile retrieval error:', error);
+      res.status(500).send('Internal server error fetching profile.');
+    }
+  });
+
+  // Admin Route: Update User Role (requires admin role)
+  app.put('/admin/users/:userId/role', authenticateToken, (req: Request, res: Response) => {
+    const { userId } = req.params;
+    const { role } = req.body;
+    const requestingUser = req.user;
+
+    if (requestingUser.role !== 'admin') {
+      return res.status(403).send('Admin role required.');
+    }
+    if (!['admin', 'editor', 'viewer'].includes(role)) {
+      return res.status(400).send('Invalid role specified.');
+    }
+
+    try {
+      const targetUser = findUserById(userId);
+      if (!targetUser) {
+        return res.status(404).send('User not found.');
+      }
+      if (targetUser.tenant_id !== requestingUser.tenantId) {
+        return res.status(403).send('Cannot modify users from other tenants.');
+      }
+
+      updateUserRole(userId, role);
+      res.status(200).send('User role updated successfully.');
+    } catch (error) {
