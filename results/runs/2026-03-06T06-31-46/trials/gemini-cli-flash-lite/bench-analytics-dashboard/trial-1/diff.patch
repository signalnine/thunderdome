--- /dev/null
+++ b/scripts/init-db.js
@@ -0,0 +1,32 @@
+import sqlite3 from 'better-sqlite3';
+import fs from 'fs';
+import path from 'path';
+
+const DB_PATH = path.resolve('./database.db');
+const SCHEMA_PATH = path.resolve('./schema.sql');
+
+// Ensure the database directory exists (though for a single file, this is usually just the root)
+const dbDir = path.dirname(DB_PATH);
+if (!fs.existsSync(dbDir)) {
+    fs.mkdirSync(dbDir, { recursive: true });
+}
+
+// Ensure the database file exists
+if (!fs.existsSync(DB_PATH)) {
+    fs.writeFileSync(DB_PATH, '');
+    console.log(`Created database file at: ${DB_PATH}`);
+}
+
+const db = sqlite3(DB_PATH);
+
+// Read and execute schema
+try {
+    const schemaSql = fs.readFileSync(SCHEMA_PATH, 'utf8');
+    db.exec(schemaSql);
+    console.log('Database schema applied successfully.');
+} catch (error) {
+    console.error('Error applying database schema:', error);
+    throw error; // Re-throw to halt execution if schema fails
+} finally {
+    db.close();
+}
diff --git a/src/app.ts b/src/app.ts
new file mode 100644
