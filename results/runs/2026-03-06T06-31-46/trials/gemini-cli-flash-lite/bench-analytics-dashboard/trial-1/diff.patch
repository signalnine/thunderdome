+    } catch (error) {
+      console.error('Update dashboard error:', error);
+      res.status(500).send('Internal server error updating dashboard.');
+    }
+  });
+
+  app.delete('/dashboards/:dashboardId', authenticateToken, (req: Request, res: Response) => {
+    const tenantId = req.user.tenantId;
+    const { dashboardId } = req.params;
+
+    try {
+      // Check if dashboard exists and belongs to the tenant before deleting
+      const existingDashboard = getDashboardById(dashboardId, tenantId);
+      if (!existingDashboard) {
+        return res.status(404).send('Dashboard not found or unauthorized.');
+      }
+
+      deleteDashboard(dashboardId, tenantId);
+      res.status(204).send(); // No content
+    } catch (error) {
+      console.error('Delete dashboard error:', error);
+      res.status(500).send('Internal server error deleting dashboard.');
+    }
+  });
+
+  // Data Export Routes (CSV and JSON)
+  // Placeholder for export functionality. This will require more complex logic to generate files.
+  app.get('/export/events/csv', authenticateToken, (req: Request, res: Response) => {
+    const tenantId = req.user.tenantId;
+    const { name, start, end } = req.query;
+
+    try {
+      // Fetch events first
+      const events = findEventsByTenant(tenantId as string, name as string, { start: start as string, end: end as string });
+
+      if (events.length === 0) {
+        return res.status(404).send('No events found for the given criteria.');
+      }
+
+      // Simple CSV generation (basic fields)
+      const csvRows = [];
+      // Header row
+      const headers = Object.keys(events[0]);
+      csvRows.push(headers.join(','));
+
+      // Data rows
+      for (const event of events) {
+        const values = headers.map(header => {
+          let value = event[header as keyof typeof event];
+          if (typeof value === 'object' && value !== null) {
+            value = JSON.stringify(value); // Stringify JSON properties
+          }
+          // Escape commas and quotes
+          value = String(value).replace(/"/g, '""');
+          return `"${value.replace(/,/g, '\,')}"`; // Basic CSV escaping
+        });
+        csvRows.push(values.join(','));
+      }
+
+      res.setHeader('Content-Type', 'text/csv');
+      res.setHeader('Content-Disposition', 'attachment; filename="events.csv"');
+      res.status(200).send(csvRows.join('
+'));
+
+    } catch (error) {
+      console.error('CSV export error:', error);
+      res.status(500).send('Internal server error during CSV export.');
+    }
+  });
+
+  app.get('/export/events/json', authenticateToken, (req: Request, res: Response) => {
+    const tenantId = req.user.tenantId;
+    const { name, start, end } = req.query;
+
+    try {
+      const events = findEventsByTenant(tenantId as string, name as string, { start: start as string, end: end as string });
+
+      if (events.length === 0) {
+        return res.status(404).send('No events found for the given criteria.');
+      }
+
+      res.setHeader('Content-Type', 'application/json');
+      res.setHeader('Content-Disposition', 'attachment; filename="events.json"');
+      res.status(200).json(events);
+    } catch (error) {
+      console.error('JSON export error:', error);
+      res.status(500).send('Internal server error during JSON export.');
+    }
+  });
+
+  // Dashboard export will need to be implemented similarly, likely fetching dashboard and widget configs.
+
+  // --- Error Handling Middleware ---
+  // Catch-all for routes not found
+  app.use((req: Request, res: Response) => {
+    res.status(404).send('Not Found');
+  });
+
+  // Generic error handler
+  app.use((err: any, req: Request, res: Response, next: NextFunction) => {
+    console.error('Unhandled error:', err.stack);
+    res.status(500).send('Something broke!');
+  });
+
+  return app;
+}
