+      if (!dashboard) {
+        return res.status(404).send('Dashboard not found or unauthorized.');
+      }
+      res.json(dashboard);
+    } catch (error) {
+      console.error('Get dashboard by ID error:', error);
+      res.status(500).send('Internal server error retrieving dashboard.');
+    }
+  });
+
+  app.put('/dashboards/:dashboardId', authenticateToken, (req: Request, res: Response) => {
