--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,189 @@
+/* eslint-disable @typescript-eslint/no-explicit-any */
+
+export interface Task<T = any> {
+  id: string;
+  payload: T;
+  status: TaskStatus;
+  createdAt: Date;
+  priority: number; // Phase 3: Added priority
+}
+
+export enum TaskStatus {
+  Pending = 'pending',
+  Processing = 'processing',
+  Completed = 'completed',
+  Failed = 'failed',
+  // Add other statuses as needed for future phases
+}
+
+const MIN_PRIORITY = 1;
+const MAX_PRIORITY = 10;
+const DEFAULT_PRIORITY = 5;
+
+// Internal class to manage tasks for a single named queue
+class SingleQueue {
+  private tasks: Task[] = [];
+  private nextId = 0; // ID counter specific to this queue
+
+  constructor() {}
+
+  /**
+   * Adds a new task to this queue with a given priority.
+   * @param payload The data payload for the task.
+   * @param priority Optional priority level (1-10, default 5).
+   * @returns The created task object.
+   * @throws Error if the priority value is invalid.
+   */
+  addTask<T>(payload: T, priority?: number): Task<T> {
+    let validatedPriority = DEFAULT_PRIORITY;
+    if (priority !== undefined) {
+      if (priority < MIN_PRIORITY || priority > MAX_PRIORITY) {
+        throw new Error(`Priority must be between ${MIN_PRIORITY} and ${MAX_PRIORITY}. Received: ${priority}`);
+      }
+      validatedPriority = priority;
+    }
+
+    const newTask: Task<T> = {
+      id: `task_${this.nextId++}`, // Simple unique ID generation for this queue
+      payload,
+      status: TaskStatus.Pending,
+      createdAt: new Date(),
+      priority: validatedPriority, // Assign validated priority
+    };
+    this.tasks.push(newTask);
+    return newTask;
+  }
+
+  /**
+   * Retrieves and removes the highest priority pending task from this queue.
+   * If multiple tasks have the same highest priority, the oldest one is returned (FIFO).
+   * Transitions the task's status to 'processing'.
+   * @returns The next task to process, or null if the queue is empty.
+   */
+  getNextTask(): Task | null {
+    const pendingTasks = this.tasks.filter(task => task.status === TaskStatus.Pending);
+
+    if (pendingTasks.length === 0) {
+      return null; // No pending tasks
+    }
+
+    // Find the highest priority (lowest number) among pending tasks
+    const minPriority = Math.min(...pendingTasks.map(task => task.priority));
+
+    // Get all tasks with the highest priority
+    const highestPriorityTasks = pendingTasks.filter(task => task.priority === minPriority);
+
+    // Sort these tasks by creation date (FIFO for same priority)
+    highestPriorityTasks.sort((a, b) => a.createdAt.getTime() - b.createdAt.getTime());
+
+    // The task to process is the first one in the sorted list
+    const taskToProcess = highestPriorityTasks[0];
+
+    // Find the task in the original 'this.tasks' array to update its status
+    // This is important because we are returning the task by reference,
+    // and its status needs to be updated in the main list.
+    const originalTaskIndex = this.tasks.findIndex(task => task.id === taskToProcess.id);
+    if (originalTaskIndex !== -1) {
+      this.tasks[originalTaskIndex].status = TaskStatus.Processing;
+    }
+
+    return taskToProcess;
+  }
+
+  /**
+   * Returns the number of tasks currently waiting to be processed in this queue.
+   * @returns The count of pending tasks.
+   */
+  getWaitingTasksCount(): number {
+    return this.tasks.filter(task => task.status === TaskStatus.Pending).length;
+  }
+
+  // This internal queue will not expose its tasks array directly anymore.
+  // All interactions are through the public methods.
+}
+
+export class TaskQueue {
+  private queues: Map<string, SingleQueue> = new Map();
+  private readonly defaultQueueName = 'default';
+
+  constructor() {
+    // Ensure the default queue exists when the TaskQueue is initialized.
+    this.ensureQueueExists(this.defaultQueueName);
+  }
+
+  /**
+   * Ensures a queue with the given name exists. Creates it if it doesn't.
+   * @param queueName The name of the queue.
+   * @returns The SingleQueue instance for the given name.
+   */
+  private ensureQueueExists(queueName: string): SingleQueue {
+    if (!this.queues.has(queueName)) {
+      this.queues.set(queueName, new SingleQueue());
+    }
+    return this.queues.get(queueName)!;
+  }
+
+  /**
+   * Adds a new task to a specific named queue with a given priority.
+   * If no queueName is provided, it defaults to the 'default' queue.
+   * @param payload The data payload for the task.
+   * @param queueName Optional name of the queue to add the task to. Defaults to 'default'.
+   * @param priority Optional priority level (1-10). Defaults to 5.
+   * @returns The created task object.
+   * @throws Error if the priority value is invalid.
+   */
+  addTask<T>(payload: T, queueName?: string, priority?: number): Task<T> {
+    const targetQueueName = queueName ?? this.defaultQueueName;
+    const queue = this.ensureQueueExists(targetQueueName);
+    // Pass priority down to SingleQueue's addTask
+    return queue.addTask(payload, priority);
+  }
+
+  /**
+   * Retrieves and removes the highest priority pending task from a specific named queue.
+   * If no queueName is provided, it defaults to the 'default' queue.
+   * Returns null if the specified queue does not exist or is empty.
+   * @param queueName Optional name of the queue to retrieve a task from. Defaults to 'default'.
+   * @returns The next task to process, or null if the queue is empty or non-existent.
+   */
+  getNextTask(queueName?: string): Task | null {
+    const targetQueueName = queueName ?? this.defaultQueueName;
+
+    // If the queue doesn't exist yet, we cannot get a task from it.
+    if (!this.queues.has(targetQueueName)) {
+      return null;
+    }
+
+    const queue = this.queues.get(targetQueueName)!;
+    return queue.getNextTask();
+  }
+
+  /**
+   * Returns the number of tasks currently waiting to be processed in a specific queue.
+   * If no queueName is provided, it defaults to the 'default' queue.
+   * Returns 0 if the specified queue does not exist.
+   * @param queueName Optional name of the queue to count tasks from. Defaults to 'default'.
+   * @returns The count of pending tasks.
+   */
+  getWaitingTasksCount(queueName?: string): number {
+    const targetQueueName = queueName ?? this.defaultQueueName;
+
+    // If the queue doesn't exist, it has 0 waiting tasks.
+    if (!this.queues.has(targetQueueName)) {
+      return 0;
+    }
+
+    const queue = this.queues.get(targetQueueName)!;
+    return queue.getWaitingTasksCount();
+  }
+
+  /**
+   * Lists the names of all queues that currently exist.
+   * @returns An array of queue names.
+   */
+  listQueues(): string[] {
+    return Array.from(this.queues.keys());
+  }
+
+  // Future phases will add more methods here.
+}
