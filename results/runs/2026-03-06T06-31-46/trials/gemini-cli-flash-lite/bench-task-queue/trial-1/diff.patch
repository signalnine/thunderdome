+      expect(queue.getWaitingTasksCount()).toBe(0); // Default queue should be empty
+    });
+
+    it('should retrieve tasks from a specific named queue', () => {
+      const payload1 = { task: 'process A' };
+      const payload2 = { task: 'process B' };
+      const task1 = queue.addTask(payload1, queueName1);
+      const task2 = queue.addTask(payload2, queueName1);
+
+      expect(queue.getWaitingTasksCount(queueName1)).toBe(2);
