+import { TaskQueue, TaskStatus } from './index.js';
+
+describe('TaskQueue', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  describe('Phase 1: Basic FIFO Queue (Default Queue)', () => {
+    it('should initialize with an empty default queue', () => {
+      expect(queue.getWaitingTasksCount()).toBe(0);
+      expect(queue.getNextTask()).toBeNull();
+      expect(queue.listQueues()).toEqual(['default']); // Default queue should exist
+    });
+
+    it('should add a task to the default queue', () => {
+      const payload = { data: 'test' };
+      const task = queue.addTask(payload); // No queueName provided, uses default
+
+      expect(task).toBeDefined();
+      expect(task.id).toBe('task_0');
+      expect(task.payload).toEqual(payload);
+      expect(task.status).toBe(TaskStatus.Pending);
+      expect(task.createdAt).toBeInstanceOf(Date);
+      expect(task.priority).toBe(5); // Default priority check
+      expect(queue.getWaitingTasksCount()).toBe(1); // Default queue count
+    });
+
+    it('should retrieve the next task in FIFO order from the default queue', () => {
+      const task1 = queue.addTask({ job: 1 });
+      const task2 = queue.addTask({ job: 2 });
+
+      expect(queue.getWaitingTasksCount()).toBe(2);
+
+      const retrievedTask1 = queue.getNextTask(); // From default queue
+      expect(retrievedTask1).toBeDefined();
+      expect(retrievedTask1?.id).toBe(task1.id);
+      expect(retrievedTask1?.status).toBe(TaskStatus.Processing);
+      expect(queue.getWaitingTasksCount()).toBe(1);
+
+      const retrievedTask2 = queue.getNextTask(); // From default queue
+      expect(retrievedTask2).toBeDefined();
+      expect(retrievedTask2?.id).toBe(task2.id);
+      expect(retrievedTask2?.status).toBe(TaskStatus.Processing);
+      expect(queue.getWaitingTasksCount()).toBe(0);
+    });
+
+    it('should return null when trying to get a task from an empty default queue', () => {
+      expect(queue.getNextTask()).toBeNull();
+
+      queue.addTask({ job: 1 });
+      const task = queue.getNextTask(); // Processes the only task
+      expect(task).not.toBeNull();
+      expect(queue.getNextTask()).toBeNull(); // Now empty
+    });
+
+    it('should correctly report the number of waiting tasks in the default queue', () => {
+      expect(queue.getWaitingTasksCount()).toBe(0);
+      queue.addTask({ job: 1 });
+      expect(queue.getWaitingTasksCount()).toBe(1);
+      queue.addTask({ job: 2 });
+      expect(queue.getWaitingTasksCount()).toBe(2);
+      queue.getNextTask(); // Processes task 0 from default
+      expect(queue.getWaitingTasksCount()).toBe(1);
+      queue.getNextTask(); // Processes task 1 from default
+      expect(queue.getWaitingTasksCount()).toBe(0);
+    });
+
+    it('should generate sequential unique IDs for tasks in the default queue', () => {
+      const task1 = queue.addTask({ job: 1 });
+      const task2 = queue.addTask({ job: 2 });
+      const task3 = queue.addTask({ job: 3 });
+
+      expect(task1.id).toBe('task_0');
+      expect(task2.id).toBe('task_1');
+      expect(task3.id).toBe('task_2');
+    });
+  });
+
+  describe('Phase 2: Named Queues', () => {
+    const queueName1 = 'highPriority';
+    const queueName2 = 'backgroundJobs';
+
+    it('should add tasks to a specific named queue', () => {
+      const payload1 = { task: 'process A' };
+      const task1 = queue.addTask(payload1, queueName1);
+
+      expect(task1).toBeDefined();
+      expect(task1.id).toBe('task_0'); // IDs are per-queue
