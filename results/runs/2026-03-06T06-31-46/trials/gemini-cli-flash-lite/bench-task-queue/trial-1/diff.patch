+      let retrieved = queue.getNextTask(); // Should be defaultTaskP1 (p1, created first)
+      expect(retrieved).toBeDefined();
+      expect(retrieved?.id).toBe(_defaultTaskP1.id); // Check ID
+      expect(retrieved?.priority).toBe(1);
+
+      retrieved = queue.getNextTask(queueName); // Should be q1TaskP1 (p1, created second)
+      expect(retrieved).toBeDefined();
+      expect(retrieved?.id).toBe(q1TaskP1.id);
+      expect(retrieved?.priority).toBe(1);
+
+      retrieved = queue.getNextTask('otherQueue'); // Should be q2TaskP1 (p1, created third)
+      expect(retrieved).toBeDefined();
+      expect(retrieved?.id).toBe(q2TaskP1.id);
+      expect(retrieved?.priority).toBe(1);
+
+      // Now process remaining tasks
+      retrieved = queue.getNextTask(queueName); // Should be q1TaskP3 (p3)
+      expect(retrieved).toBeDefined();
+      expect(retrieved?.id).toBe(q1TaskP3.id);
+      expect(retrieved?.priority).toBe(3);
+
+      retrieved = queue.getNextTask(); // Should be defaultTaskP5 (p5)
+      expect(retrieved).toBeDefined();
+      expect(retrieved?.id).toBe(_defaultTaskP5.id); // Check ID
+      expect(retrieved?.priority).toBe(5);
+    });
+
+    it('should expose priority on retrieved tasks', () => {
+      const task = queue.addTask({ data: 'task with priority' }, queueName, 3);
+      const retrievedTask = queue.getNextTask(queueName);
+      expect(retrievedTask).toBeDefined();
+      expect(retrievedTask?.priority).toBe(3);
+    });
+  });
+});
