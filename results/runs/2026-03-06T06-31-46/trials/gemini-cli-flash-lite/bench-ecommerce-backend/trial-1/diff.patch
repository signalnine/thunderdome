+import { EventBus } from '../bus.js';
+import { PaymentService, PaymentProcessedEvent, Events, PaymentStatus } from '../types.js';
+
+// Define default simulation options
+const DEFAULT_SIMULATION_OPTIONS = {
+  successRate: 0.8, // 80% success rate
+  timeoutRate: 0.1, // 10% timeout rate
+  // Failure rate is implicitly 1 - successRate - timeoutRate
+};
+
+export function createPaymentService(bus: EventBus): PaymentService {
+  // Map to store transaction details or status per orderId
+  // Using orderId as key for simplicity, though a transactionId would be more robust for refunds.
+  // The refund method expects transactionId. Let's store transactionId as well.
+  const orderTransactions = new Map<string, { transactionId: string; status: PaymentStatus; amount: number }>();
+  let transactionIdCounter = 1;
+
+  return {
+    async processPayment(orderId: string, amount: number): Promise<{ status: PaymentStatus; transactionId?: string; error?: string }> { // Added explicit types
+      const transactionId = `txn_${transactionIdCounter++}`;
+
+      // Simulate asynchronous processing
+      await new Promise(resolve => setTimeout(resolve, Math.random() * 1000)); // Simulate network latency
+
+      // The simulationOptions here would ideally come from options passed to createPaymentService factory.
+      // For now, using defaults.
+      const simulationOptions = { ...DEFAULT_SIMULATION_OPTIONS /*, ...options */ }; // Placeholder for options
+
+      const random = Math.random();
+      let status: PaymentStatus;
+      let error: string | undefined = undefined;
+
+      if (random < simulationOptions.successRate) {
+        status = PaymentStatus.SUCCESS;
+      } else if (random < simulationOptions.successRate + simulationOptions.timeoutRate) {
+        status = PaymentStatus.TIMEOUT;
+      } else {
+        status = PaymentStatus.FAILED;
+        error = 'Simulated payment failure';
+      }
+
+      // Store transaction info
+      orderTransactions.set(orderId, { transactionId, status, amount });
+
+      // Emit event
+      bus.emit(Events.PAYMENT_PROCESSED, { orderId, status, transactionId, error });
+
+      return { status, transactionId, error };
+    },
+
+    async refund(transactionId: string): Promise<boolean> { // Added explicit type
+      // Find transaction by transactionId. This requires a reverse lookup or a different storage.
+      // Let's assume we can find it. For simplicity, will iterate through values.
+      let orderIdToRefund: string | undefined;
+      let transactionDetails: { transactionId: string; status: PaymentStatus; amount: number } | undefined;
+
+      for (const [orderId, details] of orderTransactions.entries()) {
+        if (details.transactionId === transactionId) {
+          orderIdToRefund = orderId;
+          transactionDetails = details;
+          break;
+        }
+      }
+
+      if (!orderIdToRefund || !transactionDetails) {
+        console.error(`Refund failed: Transaction ${transactionId} not found.`);
+        return false;
+      }
+
+      if (transactionDetails.status !== PaymentStatus.SUCCESS) {
+        console.error(`Refund failed: Transaction ${transactionId} was not successful (status: ${transactionDetails.status}).`);
+        return false;
+      }
+
+      // Simulate refund processing
+      await new Promise(resolve => setTimeout(resolve, Math.random() * 500)); // Simulate network latency
+
+      // Update transaction status to REFUNDED
+      const updatedTransactionDetails = { ...transactionDetails, status: PaymentStatus.REFUNDED };
+      orderTransactions.set(orderIdToRefund, updatedTransactionDetails);
+
+      // Emit an event for refund processed if needed, but types.ts only defines PAYMENT_PROCESSED.
+      // For now, we just update internal state and return success.
+
+      console.log(`Transaction ${transactionId} for order ${orderIdToRefund} refunded successfully.`);
+      return true;
+    },
+  };
+}
