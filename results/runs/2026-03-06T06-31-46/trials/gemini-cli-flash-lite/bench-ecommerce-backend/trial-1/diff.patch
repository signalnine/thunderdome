@@ -0,0 +1,80 @@
+import { EventBus } from '../bus.js';
+import { CartService, CartUpdatedEvent, Events } from '../types.js';
+
+export function createCartService(bus: EventBus): CartService {
+  const carts = new Map<string, { id: string; userId: string; items: Array<{ productId: string; quantity: number }> }>();
+  let cartIdCounter = 1;
+
+  return {
+    createCart(userId: string) { // Added explicit type for userId
+      const cartId = `cart_${cartIdCounter++}`;
+      const newCart = { id: cartId, userId, items: [] };
+      carts.set(cartId, newCart);
+      // Cart is created but not yet updated with items, so we might not emit a cart:updated event here.
+      // If an event is required for cart creation, it would be defined in types.ts.
+      return cartId;
+    },
+    addItem(cartId: string, productId: string, quantity: number) { // Added explicit types
+      const cart = carts.get(cartId);
+      if (!cart) {
+        // Handle error: cart not found. Interface doesn't specify return for this.
+        return;
+      }
+
+      const existingItemIndex = cart.items.findIndex(item => item.productId === productId);
+      if (existingItemIndex > -1) {
+        // Item already exists, update quantity
+        cart.items[existingItemIndex].quantity += quantity;
+      } else {
+        // Add new item
+        cart.items.push({ productId, quantity });
+      }
+      // Emit cart update event
+      bus.emit(Events.CART_UPDATED, { cartId: cart.id, userId: cart.userId, items: cart.items });
+    },
+    removeItem(cartId: string, productId: string) { // Added explicit types
+      const cart = carts.get(cartId);
+      if (!cart) {
+        return;
+      }
+
+      const initialItemCount = cart.items.length;
+      cart.items = cart.items.filter(item => item.productId !== productId);
+
+      if (cart.items.length < initialItemCount) {
+        bus.emit(Events.CART_UPDATED, { cartId: cart.id, userId: cart.userId, items: cart.items });
+      }
+    },
+    getCart(cartId: string) { // Added explicit type
+      return carts.get(cartId) || null;
+    },
+    clearCart(cartId: string) { // Added explicit type
+      const cart = carts.get(cartId);
+      if (!cart) {
+        return;
+      }
+      if (cart.items.length > 0) {
+        cart.items = [];
+        bus.emit(Events.CART_UPDATED, { cartId: cart.id, userId: cart.userId, items: cart.items });
+      }
+    },
+    updateQuantity(cartId: string, productId: string, quantity: number) { // Added explicit types
+      const cart = carts.get(cartId);
+      if (!cart) {
+        return;
+      }
+
+      const itemIndex = cart.items.findIndex(item => item.productId === productId);
+      if (itemIndex > -1) {
+        if (quantity <= 0) {
+          // Remove item if quantity is zero or less
+          cart.items.splice(itemIndex, 1);
+        } else {
+          cart.items[itemIndex].quantity = quantity;
+        }
+        bus.emit(Events.CART_UPDATED, { cartId: cart.id, userId: cart.userId, items: cart.items });
+      }
+      // If item does not exist, this operation does nothing.
+    },
+  };
+}
