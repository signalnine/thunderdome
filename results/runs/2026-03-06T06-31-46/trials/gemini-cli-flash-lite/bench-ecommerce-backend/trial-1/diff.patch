+import { EventBus } from '../bus.js';
+import { OrderService, OrderCreatedEvent, OrderStatusChangedEvent, OrderStatus, Events } from '../types.js';
+
+export function createOrderService(bus: EventBus): OrderService {
+  const orders = new Map<string, { id: string; userId: string; status: OrderStatus; total: number }>();
+  let orderIdCounter = 1;
+
+  // Listen for price calculation event to create order
+  // NOTE: The original implementation had issues with userId and cartId availability.
+  // This listener is commented out as it relies on data not directly available or
+  // implies a different orchestration flow than independent service implementation.
+  // The primary way to create an order is via the public `createOrder` method.
+  /*
+  bus.on(Events.PRICE_CALCULATED, async (payload: unknown) => { // Changed to unknown, will cast
+    const p = payload as PriceCalculatedEvent; // Type assertion
+    const { cartId, total } = p;
+    if (!cartId || cartId === 'N/A' || total === undefined) {
+      console.error("PRICE_CALCULATED event missing required cartId or total.");
+      return; // Cannot create order without cartId and total
+    }
+    // Assuming userId is somehow available or derivable. This is a gap.
+    // For now, using a placeholder or assuming it's handled externally.
+    const userId = 'user_placeholder'; // Placeholder, as userId is not in PRICE_CALCULATEDEvent payload.
+    if (userId) { // Only proceed if userId is determined
+        // This would call the internal method, need to be careful with async operations and state updates.
+        // Calling this.createOrder here might require awaiting if it were async.
+        // For simplicity and adhering to synchronous method signatures where possible,
+        // direct calls to internal logic are often preferred if not complex async.
+        // If createOrder were to trigger other async operations, it would need to be handled.
+        // this.createOrder(userId, cartId, total); // Commented out due to potential issues.
+    }
+  });
+  */
+
+  return {
+    createOrder(userId: string, cartId: string, total: number): string { // Added explicit types
+      const orderId = `order_${orderIdCounter++}`;
+      const newOrder = {
+        id: orderId,
+        userId: userId,
+        status: OrderStatus.PENDING,
+        total: total,
+      };
+      orders.set(orderId, newOrder);
+      // Emit OrderCreatedEvent
+      bus.emit(Events.ORDER_CREATED, { orderId, userId, cartId, total });
+      return orderId;
+    },
+    getOrder(orderId: string) { // Added explicit type
+      return orders.get(orderId) || null;
+    },
+    updateStatus(orderId: string, status: OrderStatus): void { // Added explicit types
+      const order = orders.get(orderId);
+      if (!order) {
+        return; // Order not found
+      }
+
+      const previousStatus = order.status;
+      if (previousStatus === status) {
+        return; // No change
+      }
+
+      // Basic state transition validation (can be expanded)
+      const validTransitions: Record<OrderStatus, OrderStatus[]> = {
+        [OrderStatus.PENDING]: [OrderStatus.CONFIRMED, OrderStatus.CANCELLED],
+        [OrderStatus.CONFIRMED]: [OrderStatus.SHIPPED, OrderStatus.CANCELLED],
+        [OrderStatus.SHIPPED]: [OrderStatus.DELIVERED],
+        [OrderStatus.DELIVERED]: [], // No further transitions
+        [OrderStatus.CANCELLED]: [], // No further transitions
+      };
+
+      if (!validTransitions[previousStatus]?.includes(status)) {
+        console.warn(`Invalid status transition from ${previousStatus} to ${status} for order ${orderId}.`);
+        // Depending on requirements, could throw error or just ignore. Ignoring for now.
+        // return;
+      }
+
+      order.status = status;
+      orders.set(orderId, order); // Update in map
+
+      // Emit OrderStatusChangedEvent
+      bus.emit(Events.ORDER_STATUS_CHANGED, { orderId, status, previousStatus });
+    },
+    listOrders(userId: string): Array<{ id: string; status: OrderStatus; total: number }> { // Added explicit types
+      return Array.from(orders.values()).filter(order => order.userId === userId);
+    },
+  };
+}
