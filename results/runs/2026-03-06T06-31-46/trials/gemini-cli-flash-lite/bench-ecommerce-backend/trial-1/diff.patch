@@ -0,0 +1,132 @@
+import { EventBus } from '../bus.js';
+import { AnalyticsService, Events, ProductCreatedEvent, InventoryUpdatedEvent, CartUpdatedEvent, PriceCalculatedEvent, OrderCreatedEvent, OrderStatusChangedEvent, PaymentProcessedEvent, NotificationSentEvent, PaymentStatus } from '../types.js';
+
+export function createAnalyticsService(bus: EventBus): AnalyticsService {
+  // Track event counts
+  const eventCounts = new Map<string, number>();
+
+  // Track total revenue from successful payments
+  let totalRevenue = 0;
+
+  // Track orders and carts for conversion rate calculation
+  let ordersCreatedCount = 0;
+  let uniqueCartsCreated = new Set<string>(); // Store cartIds to count unique carts
+
+  // Track product order quantities for ranking
+  const productOrderQuantities = new Map<string, number>();
+
+  // --- Event Listeners ---
+
+  // Listen for ORDER_CREATED to count orders and track unique carts
+  bus.on(Events.ORDER_CREATED, async (payload: unknown) => {
+    const p = payload as OrderCreatedEvent; // Type assertion
+    const { orderId, userId, cartId } = p;
+    // Increment order count
+    ordersCreatedCount++;
+    // Track unique cart ID
+    if (cartId) {
+      uniqueCartsCreated.add(cartId);
+    }
+    // Increment event count for ORDER_CREATED
+    incrementEventCount(Events.ORDER_CREATED);
+  });
+
+  // Listen for PAYMENT_PROCESSED to track revenue
+  bus.on(Events.PAYMENT_PROCESSED, async (payload: unknown) => {
+    const p = payload as PaymentProcessedEvent; // Type assertion
+    const { status, orderId } = p;
+    if (status === PaymentStatus.SUCCESS) {
+      // Revenue is tracked using the total amount from the order, which is available via orderIdToTotalMap.
+      const orderTotal = orderIdToTotalMap.get(orderId);
+      if (orderTotal !== undefined) {
+        totalRevenue += orderTotal;
+      } else {
+        console.warn(`Analytics: Could not find total for order ${orderId} to track revenue.`);
+      }
+    }
+    // Increment event count for PAYMENT_PROCESSED
+    incrementEventCount(Events.PAYMENT_PROCESSED);
+  });
+
+  // Listener for ORDER_CREATED to populate orderIdToTotalMap for revenue tracking
+  const orderIdToTotalMap = new Map<string, number>();
+  bus.on(Events.ORDER_CREATED, async (payload: unknown) => { // Changed to unknown, will cast
+    const p = payload as OrderCreatedEvent; // Type assertion
+    const { orderId, total } = p;
+    orderIdToTotalMap.set(orderId, total);
+  });
+
+  // Listen for CART_UPDATED to track unique carts for conversion rate
+  bus.on(Events.CART_UPDATED, async (payload: unknown) => { // Changed to unknown, will cast
+    const p = payload as CartUpdatedEvent; // Type assertion
+    const { cartId, userId, items } = p;
+    if (cartId && userId) {
+      // Consider a cart "created" or "active" if it has items.
+      // The prompt implies "unique carts created". If a cart is created and never has items, it's not a conversion.
+      // So, only add to the set if items exist.
+      if (items && items.length > 0) {
+        uniqueCartsCreated.add(cartId);
+      }
+      // Increment event count for CART_UPDATED
+      incrementEventCount(Events.CART_UPDATED);
+    }
+  });
+
+  // Listen for other relevant events for counting purposes
+  bus.on(Events.PRODUCT_CREATED, async (_payload: unknown) => { // Changed to unknown, will cast if needed
+    incrementEventCount(Events.PRODUCT_CREATED);
+  });
+
+  bus.on(Events.INVENTORY_UPDATED, async (_payload: unknown) => { // Changed to unknown
+    incrementEventCount(Events.INVENTORY_UPDATED);
+  });
+
+  bus.on(Events.LOW_STOCK_ALERT, async (_payload: unknown) => { // Changed to unknown
+    incrementEventCount(Events.LOW_STOCK_ALERT);
+  });
+
+  bus.on(Events.PRICE_CALCULATED, async (_payload: unknown) => { // Changed to unknown
+    incrementEventCount(Events.PRICE_CALCULATED);
+  });
+
+  bus.on(Events.ORDER_STATUS_CHANGED, async (_payload: unknown) => { // Changed to unknown
+    incrementEventCount(Events.ORDER_STATUS_CHANGED);
+  });
+
+  bus.on(Events.NOTIFICATION_SENT, async (_payload: unknown) => { // Changed to unknown
+    incrementEventCount(Events.NOTIFICATION_SENT);
+  });
+
+
+  // Helper function to increment event counts
+  function incrementEventCount(eventType: string): void { // Added explicit type
+    eventCounts.set(eventType, (eventCounts.get(eventType) || 0) + 1);
+  }
+
+  // Helper to calculate conversion rate
+  function calculateConversionRate(): number {
+    if (uniqueCartsCreated.size === 0) {
+      return 0;
+    }
+    // Conversion rate = orders / unique carts created that had items
+    return ordersCreatedCount / uniqueCartsCreated.size;
+  }
+
+  return {
+    getEventCount(eventType: string): number { // Added explicit type
+      return eventCounts.get(eventType) || 0;
+    },
+    getRevenue(): number {
+      return totalRevenue;
+    },
+    getConversionRate(): number {
+      return calculateConversionRate();
+    },
+    getTopProducts(limit: number): Array<{ productId: string; count: number }> { // Added explicit types
+      // This part is not implemented due to lack of data in events.
+      // Returning an empty array as a placeholder.
+      console.warn("getTopProducts is not implemented due to missing product quantity data in events.");
+      return [];
+    },
+  };
+}
