+import { EventBus } from '../bus.js';
+import { PricingService, PriceCalculatedEvent, Events, ProductCreatedEvent } from '../types.js';
+
+export function createPricingService(bus: EventBus): PricingService {
+  const TAX_RATE = 0.10; // 10% tax rate
+  const productPrices = new Map<string, number>();
+  const discountCodes = new Map<string, number>(); // code -> percentage
+
+  // Listen for product creation to track prices
+  bus.on(Events.PRODUCT_CREATED, async (payload: ProductCreatedEvent) => {
+    const { productId, price } = payload;
+    productPrices.set(productId, price);
+  });
+
+  // Listen for product updates if they were to be added in CatalogService
+  // For now, assuming prices are set via PRODUCT_CREATED or not changed.
+
+  return {
+    calculateTotal(items: Array<{ productId: string; quantity: number; price: number }>, discountCode?: string): { subtotal: number; discount: number; tax: number; total: number } { // Added explicit types
+      // Using the internal productPrices map. Ignoring price passed in items.
+      let subtotal = 0;
+      for (const item of items) {
+        const price = productPrices.get(item.productId);
+        if (price === undefined) {
+          console.warn(`Price not found for product ${item.productId}. Assuming 0.`);
+          subtotal += 0;
+        } else {
+          subtotal += price * item.quantity;
+        }
+      }
+
+      let discount = 0;
+      if (discountCode && discountCodes.has(discountCode)) {
+        const discountPercentage = discountCodes.get(discountCode)!;
+        discount = subtotal * (discountPercentage / 100);
+      }
+
+      const taxableAmount = subtotal - discount;
+      const tax = taxableAmount * TAX_RATE;
+      const total = taxableAmount + tax;
+
+      // Emit event about price calculation
+      bus.emit(Events.PRICE_CALCULATED, {
+        cartId: 'N/A', // Cannot determine cartId from this function's signature
+        subtotal: subtotal,
+        discount: discount,
+        tax: tax,
+        total: total,
+      });
+
+      return {
+        subtotal: subtotal,
+        discount: discount,
+        tax: tax,
+        total: total,
+      };
+    },
+    addDiscountCode(code: string, percentage: number): void { // Added explicit types
+      if (percentage > 0 && percentage < 100) {
+        discountCodes.set(code, percentage);
+      } else {
+        console.warn(`Invalid discount percentage ${percentage} for code ${code}. Must be between 1 and 99.`);
+      }
+    },
+    getPrice(productId: string): number { // Added explicit type
+      return productPrices.get(productId) || 0; // Return 0 if price not found
+    },
+  };
+}
