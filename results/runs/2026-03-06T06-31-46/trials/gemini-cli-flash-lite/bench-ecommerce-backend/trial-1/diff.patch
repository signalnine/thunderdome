@@ -0,0 +1,60 @@
+import { EventBus } from '../bus.js';
+import { InventoryService, InventoryUpdatedEvent, LowStockAlertEvent, Events } from '../types.js';
+
+export function createInventoryService(bus: EventBus): InventoryService {
+  const stock = new Map<string, number>();
+  const lowStockThresholds = new Map<string, number>();
+
+  // Helper method to check and emit low stock alerts
+  const checkLowStock = (productId: string, currentQuantity: number): void => {
+    const threshold = lowStockThresholds.get(productId);
+    if (threshold !== undefined && currentQuantity < threshold) {
+      bus.emit(Events.LOW_STOCK_ALERT, { productId, currentQuantity, threshold });
+    }
+  };
+
+  // Subscribe to product creation event to initialize stock for new products
+  bus.on(Events.PRODUCT_CREATED, async (payload: unknown) => { // Changed handler payload to unknown and will assert
+    const p = payload as ProductCreatedEvent; // Type assertion
+    const { productId } = p;
+    // Default stock for new products is 0 unless otherwise specified by a separate command/event
+    if (!stock.has(productId)) {
+      stock.set(productId, 0);
+      // Default threshold can also be set here or via another mechanism. For now, assuming no default threshold.
+    }
+  });
+
+  return {
+    setStock(productId: string, quantity: number): void {
+      stock.set(productId, quantity);
+      bus.emit(Events.INVENTORY_UPDATED, { productId, quantity });
+      // Check for low stock after setting
+      checkLowStock(productId, quantity); // Call local helper directly
+    },
+    getStock(productId: string): number {
+      return stock.get(productId) || 0;
+    },
+    reserve(productId: string, quantity: number): boolean {
+      const currentStock = this.getStock(productId); // 'this.getStock' is fine as it's a method of the returned object
+      if (currentStock >= quantity) {
+        stock.set(productId, currentStock - quantity);
+        bus.emit(Events.INVENTORY_UPDATED, { productId, quantity: currentStock - quantity });
+        checkLowStock(productId, currentStock - quantity); // Call local helper directly
+        return true;
+      }
+      return false; // Insufficient stock
+    },
+    release(productId: string, quantity: number): void {
+      const currentStock = this.getStock(productId);
+      stock.set(productId, currentStock + quantity);
+      bus.emit(Events.INVENTORY_UPDATED, { productId, quantity: currentStock + quantity });
+      checkLowStock(productId, currentStock + quantity); // Call local helper directly
+    },
+    setLowStockThreshold(productId: string, threshold: number): void {
+      lowStockThresholds.set(productId, threshold);
+      // Check immediately if current stock is below the newly set threshold
+      const currentQuantity = this.getStock(productId);
+      checkLowStock(productId, currentQuantity); // Call local helper directly
+    },
+  };
+}
