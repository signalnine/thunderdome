@@ -0,0 +1,125 @@
+import { EventBus } from '../bus.js';
+import { NotificationService, NotificationSentEvent, OrderStatusChangedEvent, PaymentProcessedEvent, Events, PaymentStatus, OrderCreatedEvent } from '../types.js'; // Added OrderCreatedEvent import
+
+export function createNotificationService(bus: EventBus): NotificationService {
+  // Store user subscriptions and their associated orders/transactions
+  // Map: userId -> { orders: Set<orderId>, notifications: Array<{type: string, message: string, timestamp: number}> }
+  const userSubscriptions = new Map<string, { orders: Set<string>; notifications: Array<{ type: string; message: string; timestamp: number }> }>();
+  
+  // Map to link orderId to userId, populated when order is created.
+  const orderIdToUserIdMap = new Map<string, string>();
+
+  // Listen for Order Creation to map orderId to userId and ensure user subscription exists
+  bus.on(Events.ORDER_CREATED, async (payload: unknown) => { // Changed handler payload to unknown
+    const p = payload as OrderCreatedEvent; // Type assertion
+    const { orderId, userId, cartId } = p;
+    if (userId && orderId) {
+      orderIdToUserIdMap.set(orderId, userId);
+      // Ensure user subscription exists if not already
+      if (!userSubscriptions.has(userId)) {
+        userSubscriptions.set(userId, { orders: new Set(), notifications: [] });
+      }
+      userSubscriptions.get(userId)!.orders.add(orderId);
+    }
+  });
+
+  // Listener for Order Status Changes (now with userId lookup)
+  bus.on(Events.ORDER_STATUS_CHANGED, async (payload: unknown) => { // Changed handler payload to unknown
+    const p = payload as OrderStatusChangedEvent; // Type assertion
+    const { orderId, status, previousStatus } = p;
+    const userId = orderIdToUserIdMap.get(orderId);
+
+    if (!userId) {
+      console.warn(`Notification: Cannot determine user for order ${orderId}. Skipping status change notification.`);
+      return;
+    }
+
+    // Ensure user subscription exists
+    if (!userSubscriptions.has(userId)) {
+      userSubscriptions.set(userId, { orders: new Set([orderId]), notifications: [] }); // Add orderId if first time
+    } else {
+      userSubscriptions.get(userId)!.orders.add(orderId); // Add order to user's set
+    }
+
+    const userNotifications = userSubscriptions.get(userId)!.notifications;
+    const notificationMessage = `Order ${orderId} status changed from ${previousStatus} to ${status}.`;
+    const notification = {
+      type: 'order_status',
+      message: notificationMessage,
+      timestamp: Date.now(),
+    };
+    userNotifications.push(notification);
+    // Emit Notification Sent event
+    bus.emit(Events.NOTIFICATION_SENT, { userId, type: notification.type, message: notification.message });
+  });
+
+  // Subscribe to Payment Processed Events
+  bus.on(Events.PAYMENT_PROCESSED, async (payload: unknown) => { // Changed to unknown, will cast
+    const p = payload as PaymentProcessedEvent; // Type assertion
+    const { orderId, status, transactionId, error } = p;
+    const userId = orderIdToUserIdMap.get(orderId);
+
+    if (!userId) {
+      console.warn(`Notification: Cannot determine user for order ${orderId} during payment processing. Skipping notification.`);
+      return;
+    }
+
+    // Ensure user subscription exists
+    if (!userSubscriptions.has(userId)) {
+      userSubscriptions.set(userId, { orders: new Set([orderId]), notifications: [] });
+    } else {
+      userSubscriptions.get(userId)!.orders.add(orderId);
+    }
+
+    const userNotifications = userSubscriptions.get(userId)!.notifications;
+    let notificationMessage = '';
+    let notificationType = '';
+
+    switch (status) {
+      case PaymentStatus.SUCCESS:
+        notificationMessage = `Payment for order ${orderId} successful. Transaction ID: ${transactionId}.`;
+        notificationType = 'payment_success';
+        break;
+      case PaymentStatus.FAILED:
+        notificationMessage = `Payment for order ${orderId} failed. Reason: ${error}.`;
+        notificationType = 'payment_failed';
+        break;
+      case PaymentStatus.TIMEOUT:
+        notificationMessage = `Payment for order ${orderId} timed out. Please check your payment status.`;
+        notificationType = 'payment_timeout';
+        break;
+      case PaymentStatus.PENDING: // Though 'PENDING' usually isn't emitted from PaymentProcessedEvent, handle defensively
+        notificationMessage = `Payment for order ${orderId} is pending.`;
+        notificationType = 'payment_pending';
+        break;
+      case PaymentStatus.REFUNDED: // Refund event is not explicitly handled by PaymentProcessedEvent in types.ts
+        // If a refund event was emitted separately, this would be handled.
+        // For now, assuming only PAYMENT_PROCESSED events are listened to.
+        notificationMessage = `Refund processed for transaction ${transactionId} (Order ${orderId}).`;
+        notificationType = 'payment_refunded';
+        break;
+    }
+
+    if (notificationMessage) {
+      const notification = {
+        type: notificationType,
+        message: notificationMessage,
+        timestamp: Date.now(),
+      };
+      userNotifications.push(notification);
+      bus.emit(Events.NOTIFICATION_SENT, { userId, type: notification.type, message: notification.message });
+    }
+  });
+
+  return {
+    subscribe(userId: string): void { // Added explicit type
+      if (!userSubscriptions.has(userId)) {
+        userSubscriptions.set(userId, { orders: new Set(), notifications: [] });
+      }
+      // Subscribing just ensures the user is tracked; actual events trigger notifications.
+    },
+    getNotifications(userId: string): Array<{ type: string; message: string; timestamp: number }> { // Added explicit types
+      return userSubscriptions.get(userId)?.notifications || [];
+    },
+  };
+}
