+import { EventBus } from '../bus.js';
+import { CatalogService, ProductCreatedEvent, Events } from '../types.js';
+
+export function createCatalogService(bus: EventBus): CatalogService {
+  const products = new Map<string, { id: string; name: string; price: number; category: string }>();
+  let productIdCounter = 1;
+
+  // Initial setup or loading of existing products could go here if needed
+
+  return {
+    createProduct(name: string, price: number, category: string): string { // Added explicit types
+      const productId = `prod_${productIdCounter++}`;
+      const newProduct = { id: productId, name, price, category };
+      products.set(productId, newProduct);
+      // Emit event as per requirements
+      bus.emit(Events.PRODUCT_CREATED, { productId, name, price, category });
+      return productId;
+    },
+    getProduct(productId: string) { // Added explicit type
+      return products.get(productId) || null;
+    },
+    listProducts(category?: string) { // Added explicit type for category
+      let productList = Array.from(products.values());
+      if (category) {
+        productList = productList.filter(p => p.category === category);
+      }
+      return productList;
+    },
+    searchProducts(query: string) { // Added explicit type
+      const lowerQuery = query.toLowerCase();
+      return Array.from(products.values()).filter(p =>
+        p.name.toLowerCase().includes(lowerQuery) ||
+        p.category.toLowerCase().includes(lowerQuery)
+      );
+    },
+    updateProduct(productId: string, updates: Partial<{ name: string; price: number; category: string }>) { // Added explicit types
+      const existingProduct = products.get(productId);
+      if (!existingProduct) {
+        // Potentially throw an error or log a warning, but interface doesn't specify return for update
+        return;
+      }
+      const updatedProduct = { ...existingProduct, ...updates };
+      products.set(productId, updatedProduct);
+      // No explicit event for product updates in types.ts, so not emitting one.
+    },
+    removeProduct(productId: string): boolean { // Added explicit type
+      return products.delete(productId);
+    },
+  };
+}
