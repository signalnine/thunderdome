+import WebSocket from 'ws';
+import request from 'supertest';
+import { createApp, App } from '../server'; // Assuming server.ts is the entry point
+import sqlite3 from 'better-sqlite3';
+import fs from 'fs';
+import path from 'path';
+
+// Use an in-memory database for tests
+const TEST_DB_PATH = ':memory:';
+const SCHEMA_SQL_PATH = path.resolve(__dirname, '..', '..', 'schema.sql'); // Adjust path based on test file location
+
+// Helper function to create a WebSocket client connection
+const createWsClient = (port: number, docId: string): WebSocket => {
+  return new WebSocket(`ws://localhost:${port}/documents/${docId}/ws`);
+};
+
+describe('Real-Time Collaboration Integration Tests', () => {
+  let app: express.Express;
+  let server: App;
+  let db: sqlite3.Database;
+  let serverPort: number;
+
+  beforeAll(async () => {
+    if (!fs.existsSync(SCHEMA_SQL_PATH)) {
+      throw new Error(`schema.sql not found at ${SCHEMA_SQL_PATH}. Cannot run tests.`);
+    }
+    const schemaSql = fs.readFileSync(SCHEMA_SQL_PATH, 'utf-8');
+    db = new sqlite3(TEST_DB_PATH);
+    db.exec(schemaSql);
+  });
+
+  afterAll(() => {
+    db.close();
+  });
+
+  beforeEach(async () => {
+    // Re-initialize the database for each test
+    db.exec('DELETE FROM documents');
+    db.exec('DELETE FROM document_versions');
+    db.exec('DELETE FROM document_operations');
+    db.exec(fs.readFileSync(SCHEMA_SQL_PATH, 'utf-8'));
+
+    // Mock generateUniqueId for predictable document IDs
+    const mockGenerateUniqueId = jest.fn().mockReturnValue('collab-doc-1');
+    jest.mock('../server', () => ({
+      ...jest.requireActual('../server'),
+      generateUniqueId: mockGenerateUniqueId,
+    }));
+
+    server = createApp(TEST_DB_PATH);
+    app = server.app;
+    serverPort = await server.start(0); // Start server on a random port
+  });
+
+  afterEach(async () => {
+    await server.stop();
+  });
+
+  it('should synchronize document content and handle concurrent edits', async () => {
+    // 1. Create a document via REST API
+    const createResponse = await request(app)
+      .post('/documents')
+      .send({ title: 'Collaborative Doc', content: 'Initial content.' });
+    const docId = createResponse.body.id;
+
+    // 2. Connect two WebSocket clients to the document
+    const client1 = createWsClient(serverPort, docId);
+    const client2 = createWsClient(serverPort, docId);
+
+    // Wait for both clients to receive the initial sync message
+    await Promise.all([
+      new Promise<void>((resolve) => {
+        client1.on('message', (message) => {
+          const msg = JSON.parse(message.toString());
+          if (msg.type === 'sync' && msg.documentId === docId) {
+            expect(msg.content).toBe('Initial content.');
+            resolve();
+          }
+        });
+      }),
+      new Promise<void>((resolve) => {
+        client2.on('message', (message) => {
+          const msg = JSON.parse(message.toString());
+          if (msg.type === 'sync' && msg.documentId === docId) {
+            expect(msg.content).toBe('Initial content.');
+            resolve();
+          }
+        });
+      }),
+    ]);
+
+    // 3. Simulate concurrent edits
+    const edit1 = { type: 'operation', documentId: docId, operation: { type: 'insert', position: 7, text: ' great' }, clientId: 'client1', version: 0 }; // Insert ' great' at index 7
+    const edit2 = { type: 'operation', documentId: docId, operation: { type: 'insert', position: 7, text: ' amazing' }, clientId: 'client2', version: 0 }; // Insert ' amazing' at index 7
+
+    client1.send(JSON.stringify(edit1));
+    client2.send(JSON.stringify(edit2));
+
+    // 4. Wait for operations to be processed and broadcasted
+    // We need a way to detect when both clients have received the updates.
+    // This is tricky as it depends on the order of message arrival and processing.
+    // A robust test would track operations received by each client.
+    // For simplicity, we'll wait for a short period and then check the final state.
+    await new Promise(resolve => setTimeout(resolve, 500)); // Small delay to allow messages to propagate
+
+    // 5. Verify document convergence by checking the server's state (or by fetching via REST)
+    // Fetching via REST API to get the latest server-side content
+    const getResponse = await request(app).get(`/documents/${docId}`);
+    expect(getResponse.status).toBe(200);
+    
+    // The expected content depends on the OT implementation's transformation.
+    // With OT, concurrent inserts at the same position should be preserved.
+    // If client1 inserts ' great' at index 7, doc becomes 'Initial great content.' (version 1)
+    // If client2 inserts ' amazing' at index 7, doc becomes 'Initial amazing great content.' (version 2)
+    // OR: If client2 is processed first (conceptually), doc becomes 'Initial amazing content.' (version 1)
+    // Then client1 inserts ' great' at index 7, doc becomes 'Initial great amazing content.' (version 2)
+    // The exact order might depend on the server's message handling order.
+    // Let's assume the OT transforms them correctly. A common outcome is:
+    // "Initial amazing great content." or "Initial great amazing content."
+    // A simple sequential application without proper OT transformation would lead to corruption.
+    // With OT, both inserts should be visible.
+    // Let's test for one of the valid convergent states.
+    const finalContent = getResponse.body.content;
+    expect(finalContent).toBe('Initial amazing great content.'); // Based on typical OT behavior
+
+    // 6. Verify clients received the updates (more robust check)
+    let client1ReceivedOps = 0;
+    let client2ReceivedOps = 0;
+
+    client1.on('message', (message) => {
+        const msg = JSON.parse(message.toString());
+        if (msg.type === 'operation' && msg.documentId === docId) {
+            client1ReceivedOps++;
+        } else if (msg.type === 'sync') { // Re-sync message
+             expect(msg.content).toBe('Initial amazing great content.');
+        }
+    });
+    client2.on('message', (message) => {
+        const msg = JSON.parse(message.toString());
+        if (msg.type === 'operation' && msg.documentId === docId) {
+            client2ReceivedOps++;
+        } else if (msg.type === 'sync') { // Re-sync message
+             expect(msg.content).toBe('Initial amazing great content.');
+        }
+    });
+    
+    // After a bit more time to ensure messages are processed
+    await new Promise(resolve => setTimeout(resolve, 500)); 
+
+    // Expect each client to have received the operation from the other client.
+    // The server's operation is sent back, potentially transformed.
+    // We sent 2 operations from clients, server processed them and broadcasted.
+    // So each client should receive 2 broadcasts (one for client1's op, one for client2's op)
+    // The server's `version` increments for each applied operation.
+    // If edit1 is applied, version becomes 1. Then edit2 is applied, version becomes 2.
+    // So each client should receive operations that result in version 2.
+    // The number of operations received might depend on how the server broadcasts.
+    // The current server logic broadcasts one operation at a time.
+    // So, each client should receive 2 operations from the server broadcast.
+    expect(client1ReceivedOps).toBeGreaterThanOrEqual(1); // At least one operation received
+    expect(client2ReceivedOps).toBeGreaterThanOrEqual(1); // At least one operation received
+    
+    // Optional: Check if clients' local state also converged
+    // This would require clients to apply received operations, which is complex to test here.
+    // The REST API check is a good proxy for server-side convergence.
+
+    client1.close();
+    client2.close();
+  });
+
+  it('should handle out-of-sync clients and request resync', async () => {
+    // 1. Create a document
+    const createResponse = await request(app)
+      .post('/documents')
+      .send({ title: 'Sync Test Doc', content: 'Base Content' });
+    const docId = createResponse.body.id;
+
+    // 2. Connect one client and make an edit
+    const client1 = createWsClient(serverPort, docId);
+    
+    await new Promise<void>(resolve => {
+      client1.on('message', (message) => {
+        const msg = JSON.parse(message.toString());
+        if (msg.type === 'sync' && msg.documentId === docId) {
+          resolve();
+        }
+      });
+    });
+
+    // Simulate an edit from client1
+    const edit1 = { type: 'operation', documentId: docId, operation: { type: 'insert', position: 5, text: ' inserted' }, clientId: 'client1', version: 0 };
+    client1.send(JSON.stringify(edit1));
+
+    // Wait for the edit to be processed by the server (version becomes 1)
+    await new Promise(resolve => setTimeout(resolve, 500));
+
+    // 3. Connect a second client with an outdated version
+    const client2 = createWsClient(serverPort, docId);
+    const outdatedVersion = 0; // Client 2 thinks the document is at version 0
+
+    await new Promise<void>(resolve => {
+      client2.on('message', (message) => {
+        const msg = JSON.parse(message.toString());
+        if (msg.type === 'sync' && msg.documentId === docId) {
+          // Client 2 connects and gets sync message.
+          // Now simulate client2 sending an operation from an old version.
+          // The server should respond with 'resync'.
+          const outdatedEdit = { type: 'operation', documentId: docId, operation: { type: 'insert', position: 0, text: 'Outdated ' }, clientId: 'client2', version: outdatedVersion };
+          client2.send(JSON.stringify(outdatedEdit));
+        } else if (msg.type === 'resync' && msg.documentId === docId) {
+          // Client 2 receives the resync message
+          expect(msg.content).toBe('Base Content inserted'); // Content after client1's edit
+          expect(msg.version).toBe(1); // Server's current version
+          resolve();
+        }
+      });
+    });
+
+    client1.close();
+    client2.close();
+  });
+
+  it('should handle multiple concurrent clients editing different parts of the document', async () => {
+    const createResponse = await request(app)
+      .post('/documents')
+      .send({ title: 'Concurrent Edits Doc', content: 'abcdefghij' });
+    const docId = createResponse.body.id;
+
+    const client1 = createWsClient(serverPort, docId);
+    const client2 = createWsClient(serverPort, docId);
+    const client3 = createWsClient(serverPort, docId);
+
+    // Wait for all clients to sync
+    await Promise.all([
+        new Promise(resolve => client1.on('message', msg => JSON.parse(msg).type === 'sync' && resolve())),
+        new Promise(resolve => client2.on('message', msg => JSON.parse(msg).type === 'sync' && resolve())),
+        new Promise(resolve => client3.on('message', msg => JSON.parse(msg).type === 'sync' && resolve())),
+    ]);
+
+    // Client 1 inserts at beginning
+    const op1 = { type: 'operation', documentId: docId, operation: { type: 'insert', position: 0, text: 'START:' }, clientId: 'client1', version: 0 };
+    client1.send(JSON.stringify(op1));
+
+    // Client 2 inserts in middle
+    const op2 = { type: 'operation', documentId: docId, operation: { type: 'insert', position: 5, text: '[MIDDLE]' }, clientId: 'client2', version: 0 };
+    client2.send(JSON.stringify(op2));
+
+    // Client 3 deletes from end
+    const op3 = { type: 'operation', documentId: docId, operation: { type: 'delete', position: 9, length: 1 }, clientId: 'client3', version: 0 }; // delete 'j'
+    client3.send(JSON.stringify(op3));
+
+    // Wait for operations to propagate and server to process
+    await new Promise(resolve => setTimeout(resolve, 1000));
+
+    // Fetch final state via REST
+    const getResponse = await request(app).get(`/documents/${docId}`);
+    expect(getResponse.status).toBe(200);
+    
+    // Based on OT, the order of application might differ, but all edits should be preserved.
+    // Initial: 'abcdefghij'
+    // Op1: 'START:abcdefghij' (v1)
+    // Op2 (insert [MIDDLE] at 5): 'START:abc[MIDDLE]defghij' (v2)
+    // Op3 (delete at 9): 'START:abc[MIDDLE]defghi' (v3)
+    // OR if Op3 (delete at 9) was applied to 'abcdefghij' first: 'abcdefghi'
+    // Then Op1 at 0: 'START:abcdefghi'
+    // Then Op2 at 5: 'START:abc[MIDDLE]defghi'
+    // The expected final content should reflect all changes.
+    const finalContent = getResponse.body.content;
+    expect(finalContent.length).toBe('START:'.length + 'abcdefghij'.length - 1 + '[MIDDLE]'.length); // Check length
+    expect(finalContent).toContain('START:');
+    expect(finalContent).toContain('[MIDDLE]');
+    expect(finalContent).not.toContain('j'); // 'j' should be deleted
+
+    // Verify final content string
+    expect(finalContent).toBe('START:abc[MIDDLE]defghi');
+
+    client1.close();
+    client2.close();
+    client3.close();
+  });
+});
