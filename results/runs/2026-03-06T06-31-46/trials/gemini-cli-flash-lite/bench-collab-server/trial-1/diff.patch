+import { Request, Response } from 'express';
+import sqlite3 from 'better-sqlite3';
+import { Database } from 'better-sqlite3';
+import { generateUniqueId } from '../server'; // Assuming generateUniqueId is exported from server.ts
+
+// --- Interfaces (mirroring server.ts or defined here) ---
+interface Document {
+  id: string;
+  title: string;
+  content: string;
+  version: number;
+}
+
+interface DocumentListItem {
+  id: string;
+  title: string;
+}
+
+interface DocumentVersion {
+  version: number;
+  content: string;
+  timestamp: string;
+}
+
+// Initialize DB connection here for routes, or pass it from createApp
+// For simplicity, we'll assume a global DB instance or pass it in.
+// A better approach would be dependency injection via createApp.
+// For this example, we'll create a new connection, but this is not ideal for production.
+// In a real app, you would pass the db instance from createApp.
+
+// Placeholder: Replace with actual DB instance passed from createApp
+// const db = new sqlite3(':memory:'); // Or load from file path provided to createApp
+
+// Function to handle document listing
+export const listDocuments = (db: Database) => (req: Request, res: Response) => {
+  try {
+    const stmt = db.prepare('SELECT id, title FROM documents');
+    const docs: DocumentListItem[] = stmt.all();
+    res.json(docs);
+  } catch (error) {
+    console.error('Error listing documents:', error);
+    res.status(500).json({ error: 'Failed to list documents' });
+  }
+};
+
+// Function to handle document creation
+export const createDocument = (db: Database) => (req: Request, res: Response) => {
+  const { title, content = '' } = req.body;
+  if (!title) {
+    return res.status(400).json({ error: 'Title is required' });
+  }
+  const id = generateUniqueId(); // Needs to be accessible or passed
+  const initialVersion = 0;
+
+  try {
+    db.transaction(() => {
+      db.prepare('INSERT INTO documents (id, title, current_content, current_version) VALUES (?, ?, ?, ?)').run(id, title, content, initialVersion);
+      db.prepare('INSERT INTO document_versions (document_id, version, content) VALUES (?, ?, ?)').run(id, initialVersion, content);
+    })();
+    // In-memory state update should happen in server.ts's createApp
+    res.status(201).json({ id, title, content, version: initialVersion });
+  } catch (error) {
+    console.error(`Error creating document \${id}:`, error);
+    res.status(500).json({ error: 'Failed to create document' });
+  }
+};
+
+// Function to handle getting a specific document
+export const getDocument = (db: Database) => (req: Request, res: Response) => {
+  const { id } = req.params;
+  try {
+    const stmt = db.prepare('SELECT id, title, current_content AS content, current_version AS version FROM documents WHERE id = ?');
+    const doc: Document | undefined = stmt.get({ id });
+    if (!doc) {
+      return res.status(404).json({ error: 'Document not found' });
+    }
+    res.json(doc);
+  } catch (error) {
+    console.error(`Error fetching document \${id}:`, error);
+    res.status(500).json({ error: 'Failed to fetch document' });
+  }
+};
+
+// Function to handle updating a document
+export const updateDocument = (db: Database) => (req: Request, res: Response) => {
+  const { id } = req.params;
+  const { title, content } = req.body;
+
+  try {
+    const docStmt = db.prepare('SELECT * FROM documents WHERE id = ?');
+    const doc: any = docStmt.get({ id }); // Use 'any' or a more specific type for DB result
+
+    if (!doc) {
+      return res.status(404).json({ error: 'Document not found' });
+    }
+
+    const newTitle = title !== undefined ? title : doc.title;
+    const newContent = content !== undefined ? content : doc.current_content;
+
+    // Logic to save new version if content has changed
+    if (content !== undefined && content !== doc.current_content) {
+      const newVersion = doc.current_version + 1;
+      db.transaction(() => {
+        db.prepare('UPDATE documents SET title = ?, current_content = ?, current_version = ? WHERE id = ?').run(newTitle, newContent, newVersion, id);
+        db.prepare('INSERT INTO document_versions (document_id, version, content) VALUES (?, ?, ?)').run(id, newVersion, newContent);
+      })();
+      // In-memory state update should happen in server.ts's createApp
+      res.json({ id, title: newTitle, content: newContent, version: newVersion });
+    } else if (title !== undefined && title !== doc.title) {
+      // Only title changed
+      db.prepare('UPDATE documents SET title = ? WHERE id = ?').run(newTitle, id);
+      // In-memory state update should happen in server.ts's createApp
+      res.json({ id, title: newTitle, content: doc.current_content, version: doc.current_version });
+    } else {
+      // No changes
+      res.json({ id, title: doc.title, content: doc.current_content, version: doc.current_version });
+    }
+  } catch (error) {
+    console.error(`Error updating document \${id}:`, error);
+    res.status(500).json({ error: 'Failed to update document' });
+  }
+};
+
+// Function to handle document deletion
+export const deleteDocument = (db: Database) => (req: Request, res: Response) => {
+  const { id } = req.params;
+  try {
+    const result = db.prepare('DELETE FROM documents WHERE id = ?').run({ id });
+    if (result.changes === 0) {
+      return res.status(404).json({ error: 'Document not found' });
+    }
+    // In-memory state cleanup should happen in server.ts's createApp
+    // SQLite cascade will delete from document_versions and document_operations
+    res.sendStatus(204);
+  } catch (error) {
+    console.error(`Error deleting document \${id}:`, error);
+    res.status(500).json({ error: 'Failed to delete document' });
+  }
+};
+
+// Function to handle fetching document version history
+export const getDocumentHistory = (db: Database) => (req: Request, res: Response) => {
+  const { id } = req.params;
+  try {
+    // First, check if the document exists
+    const docExists = db.prepare('SELECT id FROM documents WHERE id = ?').get({ id });
+    if (!docExists) {
+      return res.status(404).json({ error: 'Document not found' });
+    }
+    const stmt = db.prepare('SELECT version, content, timestamp FROM document_versions WHERE document_id = ? ORDER BY version DESC');
+    const versions: DocumentVersion[] = stmt.all({ id });
+    res.json(versions);
+  } catch (error) {
+    console.error(`Error fetching history for document \${id}:`, error);
+    res.status(500).json({ error: 'Failed to fetch document history' });
+  }
+};
