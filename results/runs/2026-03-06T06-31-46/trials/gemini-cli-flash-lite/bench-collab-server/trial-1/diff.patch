@@ -0,0 +1,299 @@
+import express from 'express';
+import http from 'http';
+import WebSocket from 'ws';
+import sqlite3 from 'better-sqlite3';
+import { Database } from 'better-sqlite3';
+import fs from 'fs';
+import path from 'path';
+import ot from 'ot'; // Import the otjs library
+
+// Import route handlers
+import {
+  listDocuments,
+  createDocument,
+  getDocument,
+  updateDocument,
+  deleteDocument,
+  getDocumentHistory
+} from './routes/document';
+
+// Ensure schema.sql exists in the root directory
+const SCHEMA_SQL_PATH = path.resolve(__dirname, '..', 'schema.sql');
+
+// Interface for document state managed in memory
+interface DocumentState {
+  id: string;
+  title: string;
+  content: string;
+  version: number;
+  clients: Set<WebSocket>;
+  otDoc: ot.Doc; // Operational Transform document
+  clientOperations: Map<string, Map<number, ot.Operation>>; // Map: clientId -> Map: operationVersion -> Operation
+}
+
+// In-memory store for active documents and their states
+const activeDocuments = new Map<string, DocumentState>();
+
+export interface App {
+  app: express.Express;
+  start: (port?: number) => Promise<number>;
+  stop: () => Promise<void>;
+}
+
+export function createApp(dbPath: string = ':memory:'): App {
+  const app = express();
+  const server = http.createServer(app);
+  const wss = new WebSocket.Server({ noServer: true });
+
+  const db = new sqlite3(dbPath);
+
+  try {
+    if (fs.existsSync(SCHEMA_SQL_PATH)) {
+      const schemaSql = fs.readFileSync(SCHEMA_SQL_PATH, 'utf-8');
+      db.exec(schemaSql);
+      console.log(`Database schema initialized from ${SCHEMA_SQL_PATH}`);
+    } else {
+      console.error(`schema.sql not found at ${SCHEMA_SQL_PATH}. Database may not be initialized correctly.`);
+    }
+  } catch (error) {
+    console.error(`Error initializing database schema from ${SCHEMA_SQL_PATH}:`, error);
+  }
+
+  // --- REST API Routes ---
+  app.use(express.json());
+  app.get('/documents', listDocuments(db));
+  app.post('/documents', createDocument(db));
+  app.get('/documents/:id', getDocument(db));
+  app.put('/documents/:id', updateDocument(db));
+  app.delete('/documents/:id', deleteDocument(db));
+  app.get('/documents/:id/history', getDocumentHistory(db));
+
+  // --- WebSocket Handling ---
+  server.on('upgrade', (req, socket, head) => {
+    const url = req.url;
+    if (!url) {
+      socket.destroy();
+      return;
+    }
+
+    const match = url.match(/^\/documents\/([a-zA-Z0-9-]+)\/ws$/);
+    if (!match) {
+      socket.destroy();
+      return;
+    }
+
+    const documentId = match[1];
+    const docExists = db.prepare('SELECT id FROM documents WHERE id = ?').get({ id: documentId });
+    if (!docExists) {
+      console.log(`Connection attempt for non-existent document: ${documentId}`);
+      socket.destroy();
+      return;
+    }
+
+    wss.handleUpgrade(req, socket, head, (ws) => {
+      console.log(`WebSocket upgrade for document: ${documentId}`);
+
+      let docState = activeDocuments.get(documentId);
+      if (!docState) {
+        const dbDoc = db.prepare('SELECT title, current_content AS content, current_version AS version FROM documents WHERE id = ?').get({ id: documentId });
+        if (!dbDoc) {
+          console.error(`Document ${documentId} not found in DB during WebSocket init.`);
+          socket.destroy();
+          return;
+        }
+        // Initialize OT document
+        const otDoc = new ot.Doc([dbDoc.content]); // Initialize with current content
+        docState = { id: documentId, ...dbDoc, clients: new Set(), otDoc: otDoc, clientOperations: new Map() };
+        activeDocuments.set(documentId, docState);
+      }
+
+      docState.clients.add(ws);
+
+      // Send initial document state to the new client
+      const syncMessage = JSON.stringify({
+        type: 'sync',
+        documentId: documentId,
+        content: docState.otDoc.getText(), // Use OT doc's text
+        version: docState.version, // Current server version
+        title: docState.title,
+      });
+      ws.send(syncMessage);
+
+      ws.on('message', (message) => {
+        try {
+          const parsedMessage = JSON.parse(message.toString());
+          console.log(`Received message for doc ${documentId}:`, parsedMessage);
+
+          if (parsedMessage.type === 'operation') {
+            const { operation, clientId, version: clientVersion } = parsedMessage;
+            
+            // Basic validation
+            if (!operation || operation.type === undefined || operation.position === undefined || clientVersion === undefined) {
+              ws.send(JSON.stringify({ type: 'error', message: 'Malformed operation message' }));
+              return;
+            }
+
+            // Handle client operations
+            if (clientVersion > docState.version) {
+              // Client is ahead, request resync
+              ws.send(JSON.stringify({ type: 'resync', documentId: documentId, content: docState.otDoc.getText(), version: docState.version, title: docState.title }));
+              return;
+            }
+
+            if (clientVersion === docState.version) {
+              // Client is in sync, apply operation
+              try {
+                // Convert client's simple op to OT.Operation
+                let otOperation: ot.Operation;
+                if (operation.type === 'insert') {
+                  if (operation.text === undefined) {
+                    ws.send(JSON.stringify({ type: 'error', message: 'Insert operation missing text' }));
+                    return;
+                  }
+                  otOperation = new ot.InsertOperation(operation.position, operation.text);
+                } else if (operation.type === 'delete') {
+                  if (operation.length === undefined) {
+                    ws.send(JSON.stringify({ type: 'error', message: 'Delete operation missing length' }));
+                    return;
+                  }
+                  otOperation = new ot.DeleteOperation(operation.position, operation.length);
+                } else {
+                  ws.send(JSON.stringify({ type: 'error', message: 'Unknown operation type' }));
+                  return;
+                }
+                
+                // Store client's operation with its original version
+                if (!docState.clientOperations.has(clientId)) {
+                  docState.clientOperations.set(clientId, new Map());
+                }
+                docState.clientOperations.get(clientId)!.set(clientVersion, otOperation);
+
+                // Transform against existing pending operations on the server (if any)
+                // This is a simplified application; a full OT system requires managing operations queue and transforming.
+                // Here, we'll apply directly if version matches.
+                // A real OT implementation would transform the incoming operation against
+                // any operations received from other clients that were applied at `clientVersion`.
+                
+                // For this simplified version, we assume clientVersion === docState.version means it's safe to apply.
+                // The transformation logic is where OT library shines.
+                
+                // Apply the operation to the OT document
+                const transformedOp = docState.otDoc.apply(otOperation);
+
+                // Update server's version and content
+                docState.version++;
+                const newContent = docState.otDoc.getText();
+
+                // Persist the operation and document state
+                db.prepare(`
+                  INSERT INTO document_operations (document_id, client_id, operation_type, position, text, length, applied_version)
+                  VALUES (:document_id, :client_id, :operation_type, :position, :text, :length, :applied_version)
+                `).run({
+                  document_id: documentId,
+                  client_id: clientId,
+                  operation_type: operation.type,
+                  position: operation.position,
+                  text: operation.text,
+                  length: operation.length,
+                  applied_version: clientVersion, // The version this operation was based on
+                });
+                db.prepare('UPDATE documents SET current_content = ?, current_version = ? WHERE id = ?').run(newContent, docState.version, documentId);
+
+                // Broadcast the transformed operation to other clients
+                const broadcastMessage = JSON.stringify({
+                  type: 'operation',
+                  documentId: documentId,
+                  // Send the transformed operation details
+                  operation: {
+                    type: transformedOp.type,
+                    position: transformedOp.position,
+                    text: transformedOp.type === 'insert' ? (transformedOp as ot.InsertOperation).text : undefined,
+                    length: transformedOp.type === 'delete' ? (transformedOp as ot.DeleteOperation).length : undefined,
+                  },
+                  clientId: clientId, // Original client ID
+                  version: docState.version, // The new server version after applying this op
+                });
+
+                docState.clients.forEach((client) => {
+                  if (client !== ws && client.readyState === WebSocket.OPEN) {
+                    client.send(broadcastMessage);
+                  }
+                });
+
+              } catch (otError) {
+                console.error(`OT application error for doc ${documentId}:`, otError);
+                ws.send(JSON.stringify({ type: 'error', message: 'Failed to apply operation' }));
+              }
+
+            } else {
+              // Version mismatch - client is out of sync. Request resync.
+              console.log(`Client ${clientId} out of sync for doc ${documentId}. Client version: ${clientVersion}, Server version: ${docState.version}`);
+              ws.send(JSON.stringify({ type: 'resync', documentId: documentId, content: docState.otDoc.getText(), version: docState.version, title: docState.title }));
+            }
+          } else {
+            console.warn(`Received unhandled message type ${parsedMessage.type} for doc ${documentId}`);
+          }
+        } catch (error) {
+          console.error(`Error processing WebSocket message for doc ${documentId}:`, error);
+          ws.send(JSON.stringify({ type: 'error', message: 'Failed to process message' }));
+        }
+      });
+
+      ws.on('close', () => {
+        console.log(`Client disconnected from document ${documentId}`);
+        docState.clients.delete(ws);
+      });
+
+      ws.on('error', (error) => {
+        console.error(`WebSocket error for document ${documentId}:`, error);
+        docState.clients.delete(ws);
+      });
+    });
+  });
+
+  const start = async (port?: number): Promise<number> => {
+    return new Promise((resolve, reject) => {
+      server.listen(port, () => {
+        const actualPort = (server.address() as any).port;
+        console.log(`Server listening on port ${actualPort}`);
+        resolve(actualPort);
+      });
+      server.on('error', (err) => {
+        console.error('HTTP server error:', err);
+        reject(err);
+      });
+    });
+  };
+
+  const stop = async (): Promise<void> => {
+    console.log('Stopping server...');
+    return new Promise((resolve, reject) => {
+      wss.close((err) => {
+        if (err) {
+          console.error('WebSocket server close error:', err);
+        }
+        server.close((err) => {
+          if (err) {
+            console.error('HTTP server close error:', err);
+            return reject(err);
+          }
+          db.close((err) => {
+            if (err) {
+              console.error('Database close error:', err);
+              return reject(err);
+            }
+            console.log('Server stopped cleanly.');
+            resolve();
+          });
+        });
+      });
+    });
+  };
+
+  return { app, start, stop };
+}
+
+// Helper function for unique IDs (simplified for this example)
+function generateUniqueId(): string {
+  return Math.random().toString(36).substring(2, 15) + Math.random().toString(36).substring(2, 15);
+}
