ate(docId, content1);\n      expect(() => store.create(docId, content2)).toThrow('Document with ID \\'doc1\\' already exists');\n    });\n\n    test('should update and get the latest document content', () => {\n      const docId = 'doc1';\n      const content1 = { key1: 'value1' };\n      const content2 = { key1: 'updatedValue1', key2: 'newValue' };\n      store.create(docId, content1);\n      store.update(docId, content2);\n      expect(store.get(docId)).toEqual(content2);\n    });\n\n    test('should throw error if updating a non-existent document', () => {\n      const docId = 'nonExistentDoc';\n      const content = { key: 'value' };\n      expect(() => store.update(docId, content)).toThrow('Document with ID \\'nonExistentDoc\\' not found');\n    });\n\n    test('should delete a document', () => {\n      const docId = 'doc1';\n      const content = { key: 'value' };\n      store.create(docId, content);\n      store.delete(docId);\n      expect(() => store.get(docId)).toThrow('Document with ID \\'doc1\\' not found');\n    });\n\n    test('should throw error if deleting a non-existent document', () => {\n      const docId = 'nonExistentDoc';\n      expect(() => store.delete(docId)).toThrow('Document with ID \\'nonExistentDoc\\' not found');\n    });\n\n    test('should deep clone document content on get', () => {\n      const docId = 'doc1';\n      const content = { nested: { arr: [1, 2] } };\n      store.create(docId, content);\n      const retrievedContent = store.get(docId);\n      expect(retrievedContent).toEqual(content);\n      expect(retrievedContent).not.toBe(content); // Ensure it's a deep clone\n      expect(retrievedContent!.nested).not.toBe(content.nested);\n      expect(retrievedContent!.nested.arr).not.toBe(content.nested.arr);\n    });\n\n    test('should deep clone document content on create/update', () => {\n      const docId = 'doc1';\n      const content = { nested: { arr: [1, 2] } };\n      store.create(docId, content);\n      // Modify original content to ensure it doesn't affect stored version\n      content.nested.arr.push(3);\n      expect(store.get(docId)).toEqual({ nested: { arr: [1, 2] } }); // Original content should remain\n    });\n  });\n\n  // --- Version History Tests ---\n  describe('Version History', () => {\n    test('should create multiple versions for a document', () => {\n      const docId = 'doc1';\n      const content1 = { v: 1 };\n      const content2 = { v: 2, added: true };\n      const content3 = { v: 3, updated: true };\n\n      store.create(docId, content1);\n      store.update(docId, content2);\n      store.update(docId, content3);\n\n      const history = store.getHistory(docId);\n      expect(history).toHaveLength(3);\n      expect(history[0].content).toEqual(content1);\n      expect(history[1].content).toEqual(content2);\n      expect(history[2].content).toEqual(content3);\n    });\n\n    test('should return versions in chronological order', () => {\n      const docId = 'doc1';\n      const content1 = { v: 1 };\n      const content2 = { v: 2 };\n      store.create(docId, content1);\n      // Simulate a slight delay to ensure timestamps are different\n      // NOTE: In a real test environment, mocking Date.now() might be preferred for deterministic timestamps.\n      setTimeout(() => {\n        store.update(docId, content2);\n        const history = store.getHistory(docId);\n        expect(history[0].timestamp).toBeLessThan(history[1].timestamp);\n      }, 10); // Small delay\n    });\n\n    test('should get specific version content', () => {\n      const docId = 'doc1';\n      const content1 = { v: 1, base: true };\n      const content2 = { v: 2, modified: true };\n      const content3 = { v: 3, added: true };\n\n      store.create(docId, content1);\n      store.update(docId, content2);\n      store.update(docId, content3);\n\n      const history = store.getHistory(docId);\n      const version1Id = history[0].id;\n      const version2Id = history[1].id;\n      const version3Id = history[2].id;\n\n      expect(store.getVersion(docId, version1Id)).toEqual(content1);\n      expect(store.getVersion(docId, version2Id)).toEqual(content2);\n      expect(store.getVersion(docId, version3Id)).toEqual(content3);\n    });\n\n    test('should throw error if getting version for non-existent document', () => {\n      const docId = 'nonExistentDoc';\n      const versionId = 'v1';\n      expect(() => store.getVersion(docId, versionId)).toThrow('Document with ID \\'nonExistentDoc\\' not found or has no history');\n    });\n\n    test('should throw error if getting non-existent version', () => {\n      const docId = 'doc1';\n      const content = { v: 1 };\n      store.create(docId, content);\n      const versionId = 'nonExistentVersion';\n      expect(() => store.getVersion(docId, versionId)).toThrow('Version with ID \\'nonExistentVersion\\' not found');\n    });\n\n    test('should deep clone version content', () => {\n      const docId = 'doc1';\n      const content = { nested: { arr: [1, 2] } };\n      store.create(docId, content);\n      const history = store.getHistory(docId);\n      const retrievedContent = store.getVersion(docId, history[0].id);\n\n      expect(retrievedContent).toEqual(content);\n      expect(retrievedContent).not.toBe(content); // Ensure it's a deep clone\n      expect(retrievedContent!.nested).not.toBe(content.nested);\n      expect(retrievedContent!.nested.arr).not.toBe(content.nested.arr);\n    });\n  });\n\n  // --- Branching Tests ---\n  describe('Branching', () => {\n    test('should start with a \"main\" branch', () => {\n      expect(store.listBranches()).toEqual(['main']);\n      expect(store.getBranch()).toBe('main');\n    });\n\n    test('should create a new branch from the current branch', () => {\n      store.createBranch('feature-branch');\n      expect(store.listBranches()).toEqual(['main', 'feature-branch']);\n      expect(store.getBranch()).toBe('main'); // Current branch should remain main\n    });\n\n    test('should create a new branch from a specified branch', () => {\n      store.create('docOnMain', { data: 'main' });\n      store.createBranch('main-feature', 'main');\n      store.switchBranch('main-feature');\n      expect(store.getBranch()).toBe('main-feature');\n      expect(store.get('docOnMain')).toEqual({ data: 'main' });\n    });\n\n    test('should throw error if creating a branch with an existing name', () => {\n      store.createBranch('feature-branch');\n      expect(() => store.createBranch('feature-branch')).toThrow('Branch with name \\'feature-branch\\' already exists');\n    });\n\n    test('should switch to a different branch', () => {\n      store.createBranch('feature-branch');\n      store.switchBranch('feature-branch');\n      expect(store.getBranch()).toBe('feature-branch');\n    });\n\n    test('should throw error if switching to a non-existent branch', () => {\n      expect(() => store.switchBranch('nonExistentBranch')).toThrow('Branch \\'nonExistentBranch\\' not found');\n    });\n\n    test('should isolate document changes between branches', () => {\n      const mainDocId = 'doc1';\n      const mainContent1 = { state: 'initial' };\n      const featureDocId = 'doc2';\n      const featureContent1 = { feature: 'added' };\n\n      store.create(mainDocId, mainContent1);\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.create(featureDocId, featureContent1);\n      store.update(mainDocId, { state: 'modified in feature' }); // Update mainDocId on feature branch\n\n      // Switch back to main\n      store.switchBranch('main');\n      expect(store.get(mainDocId)).toEqual({ state: 'initial' }); // Should not see feature branch changes\n      expect(() => store.get(featureDocId)).toThrow('Document with ID \\'doc2\\' not found'); // Feature doc should not exist on main\n\n      // Switch back to feature\n      store.switchBranch('feature');\n      expect(store.get(mainDocId)).toEqual({ state: 'modified in feature' });\n      expect(store.get(featureDocId)).toEqual(featureContent1);\n    });\n\n    test('should deep clone branch state when creating a new branch', () => {\n      const docId = 'doc1';\n      const content1 = { data: 'initial' };\n      store.create(docId, content1);\n\n      store.createBranch('new-branch', 'main');\n      store.switchBranch('new-branch');\n\n      // Modify content on the new branch\n      store.update(docId, { data: 'modified in new-branch' });\n\n      // Switch back to main and check\n      store.switchBranch('main');\n      expect(store.get(docId)).toEqual(content1); // Main should not be affected\n    });\n\n    test('should preserve version history when branching', () => {\n      const docId = 'doc1';\n      const content1 = { v: 1 };\n      const content2 = { v: 2 };\n      store.create(docId, content1);\n      store.update(docId, content2);\n\n      store.createBranch('branch-with-history', 'main');\n      store.switchBranch('branch-with-history');\n\n      const historyOnBranch = store.getHistory(docId);\n      expect(historyOnBranch).toHaveLength(2);\n      expect(historyOnBranch[0].content).toEqual(content1);\n      expect(historyOnBranch[1].content).toEqual(content2);\n    });\n  });\n\n  // --- Merging Tests ---\n  describe('Merging', () => {\n    const createDocs = (store: DocumentStoreImpl, branchName: string, docs: Record<string, object>) => {\n      store.createBranch(branchName);\n      store.switchBranch(branchName);\n      for (const id in docs) {\n        store.create(id, docs[id]);\n      }\n    };\n\n    // --- No Conflicts ---\n    test('should merge when no documents have changed (fast-forward)', () => {\n      store.create('doc1', { a: 1 });\n      store.createBranch('branchA');\n      store.switchBranch('branchA');\n      store.create('doc2', { b: 2 });\n\n      store.switchBranch('main');\n      const mergeResult = store.merge('branchA');\n\n      expect(mergeResult.applied).toBe(true);\n      expect(mergeResult.conflicts).toHaveLength(0);\n      expect(mergeResult.merged).toEqual({ doc1: { a: 1 }, doc2: { b: 2 } });\n      expect(store.getBranch()).toBe('main');\n      expect(store.get('doc1')).toEqual({ a: 1 });\n      expect(store.get('doc2')).toEqual({ b: 2 });\n    });\n\n    test('should merge cleanly when only one branch has changes (additions)', () => {\n      store.create('doc1', { a: 1 });\n      createDocs(store, 'feature', { doc2: { b: 2 } }); // doc2 added on feature\n\n      store.switchBranch('main');\n      const mergeResult = store.merge('feature');\n\n      expect(mergeResult.applied).toBe(true);\n      expect(mergeResult.conflicts).toHaveLength(0);\n      expect(mergeResult.merged).toEqual({ doc1: { a: 1 }, doc2: { b: 2 } });\n      expect(store.get('doc2')).toEqual({ b: 2 });\n    });\n\n    test('should merge cleanly when only one branch has changes (updates)', () => {\n      store.create('doc1', { a: 1 });\n      store.update('doc1', { a: 1, updated: true }); // doc1 updated on main\n      createDocs(store, 'feature', {}); // feature branch has no new docs\n\n      store.switchBranch('feature');\n      const mergeResult = store.merge('main'); // Merge main into feature\n\n      expect(mergeResult.applied).toBe(true);\n      expect(mergeResult.conflicts).toHaveLength(0);\n      expect(mergeResult.merged).toEqual({ doc1: { a: 1, updated: true } });\n      expect(store.get('doc1')).toEqual({ a: 1, updated: true });\n    });\n\n    test('should merge cleanly when a document is deleted on one branch and unchanged on the other', () => {\n      store.create('doc1', { a: 1 });\n      store.create('doc2', { b: 2 });\n      store.delete('doc2'); // doc2 deleted on main\n\n      createDocs(store, 'feature', { doc1: { a: 1 }, doc2: { b: 2 } }); // doc2 exists on feature\n\n      store.switchBranch('main'); // back on main\n      const mergeResult = store.merge('feature'); // Merge feature into main\n\n      expect(mergeResult.applied).toBe(true);\n      expect(mergeResult.conflicts).toHaveLength(0);\n      expect(mergeResult.merged).toEqual({ doc1: { a: 1 } }); // doc2 should be gone\n      expect(() => store.get('doc2')).toThrow('Document with ID \\'doc2\\' not found');\n    });\n\n    test('should merge cleanly when a document is deleted on both branches', () => {\n      store.create('doc1', { a: 1 });\n      store.create('doc2', { b: 2 });\n      store.delete('doc2'); // doc2 deleted on main\n\n      createDocs(store, 'feature', { doc1: { a: 1 } }); // doc2 doesn't exist on feature\n      store.switchBranch('feature');\n      store.delete('doc2'); // simulate deletion if it somehow existed\n\n      store.switchBranch('main');\n      const mergeResult = store.merge('feature');\n\n      expect(mergeResult.applied).toBe(true); // applied true because no conflicts and changes occurred (deletion on both sides)\n      expect(mergeResult.conflicts).toHaveLength(0);\n      expect(mergeResult.merged).toEqual({ doc1: { a: 1 } }); // doc2 should remain gone\n      expect(() => store.get('doc2')).toThrow('Document with ID \\'doc2\\' not found');\n    });\n\n\n    test('should merge updates to different fields cleanly', () => {\n      store.create('doc1', { name: 'Alice', age: 30 });\n      createDocs(store, 'feature', { doc1: { name: 'Alice', city: 'New York' } });\n\n      store.switchBranch('main');\n      const mergeResult = store.merge('feature');\n\n      expect(mergeResult.applied).toBe(true);\n      expect(mergeResult.conflicts).toHaveLength(0);\n      expect(mergeResult.merged).toEqual({ doc1: { name: 'Alice', age: 30, city: 'New York' } });\n      expect(store.get('doc1')).toEqual({ name: 'Alice', age: 30, city: 'New York' });\n    });\n\n    test('should merge identical updates cleanly', () => {\n      store.create('doc1', { name: 'Alice', age: 30 });\n      createDocs(store, 'feature', { doc1: { name: 'Alice', age: 30 } });\n\n      store.switchBranch('main');\n      const mergeResult = store.merge('feature');\n\n      expect(mergeResult.applied).toBe(true);\n      expect(mergeResult.conflicts).toHaveLength(0);\n      expect(mergeResult.merged).toEqual({ doc1: { name: 'Alice', age: 30 } });\n      expect(store.get('doc1')).toEqual({ name: 'Alice', age: 30 });\n    });\n\n    // --- Conflicts ---\n    test('should detect conflict when different fields are updated on the same document', () => {\n      store.create('doc1', { name: 'Alice', age: 30 }); // Base\n      createDocs(store, 'feature', { doc1: { name: 'Alice', city: 'New York' } }); // Them: added city\n\n      store.switchBranch('main');\n      store.update('doc1', { name: 'Alice', age: 31 }); // Ours: updated age\n\n      const mergeResult = store.merge('feature');\n\n      expect(mergeResult.applied).toBe(false); // Not applied due to conflict\n      expect(mergeResult.conflicts).toHaveLength(1);\n      expect(mergeResult.conflicts[0]).toEqual({\n        documentId: 'doc1',\n        path: 'age', // Path within the document object\n        base: { name: 'Alice', age: 30 }, // Base content at the time of branch divergence for this doc\n        ours: { name: 'Alice', age: 31 }, // Our content\n        theirs: { name: 'Alice', city: 'New York' }, // Their content\n      });\n      // The 'merged' field should contain the result with 'ours' taken for conflicts\n      expect(mergeResult.merged).toEqual({ doc1: { name: 'Alice', age: 31, city: 'New York' } }); // city taken from theirs, age from ours\n      expect(store.get('doc1')).toEqual({ name: 'Alice', age: 30 }); // Current branch should NOT be updated\n    });\n\n    test('should detect conflict when the same field is updated differently', () => {\n      store.create('doc1', { status: 'pending' }); // Base\n      createDocs(store, 'feature', { doc1: { status: 'completed' } }); // Them: status = completed\n\n      store.switchBranch('main');\n      store.update('doc1', { status: 'in-progress' }); // Ours: status = in-progress\n\n      const mergeResult = store.merge('feature');\n\n      expect(mergeResult.applied).toBe(false);\n      expect(mergeResult.conflicts).toHaveLength(1);\n      expect(mergeResult.conflicts[0]).toEqual({\n        documentId: 'doc1',\n        path: 'status',\n        base: { status: 'pending' },\n        ours: { status: 'in-progress' },\n        theirs: { status: 'completed' },\n      });\n      expect(mergeResult.merged).toEqual({ doc1: { status: 'in-progress' } }); // 'ours' value taken for conflict resolution display\n      expect(store.get('doc1')).toEqual({ status: 'pending' }); // Current branch should not be updated\n    });\n\n    test('should detect conflicts within nested objects', () => {\n      store.create('doc1', { config: { timeout: 1000, retry: 3 } }); // Base\n      createDocs(store, 'feature', { doc1: { config: { timeout: 1000, retry: 5, log: true } } }); // Them: retry=5, log=true\n\n      store.switchBranch('main');\n      store.update('doc1', { config: { timeout: 2000, retry: 3, enabled: false } }); // Ours: timeout=2000, retry=3, enabled=false\n\n      const mergeResult = store.merge('feature');\n\n      expect(mergeResult.applied).toBe(false);\n      expect(mergeResult.conflicts).toHaveLength(1); // Conflict on 'retry'\n      expect(mergeResult.conflicts[0]).toEqual({\n        documentId: 'doc1',\n        path: 'config.retry',\n        base: { timeout: 1000, retry: 3 },\n        ours: { timeout: 2000, retry: 3, enabled: false },\n        theirs: { timeout: 1000, retry: 5, log: true },\n      });\n      expect(mergeResult.merged).toEqual({\n        doc1: {\n          config: {\n            timeout: 2000, // from ours\n            retry: 3, // from ours (conflict, but ours taken for display)\n            log: true, // from theirs (added)\n            enabled: false, // from ours (added)\n          }\n        }\n      });\n      expect(store.get('doc1')).toEqual({ config: { timeout: 1000, retry: 3 } }); // Current branch unchanged\n    });\n\n    test('should detect conflict when a primitive value is changed to an object and vice versa', () => {\n      store.create('doc1', { setting: 'enabled' }); // Base\n      createDocs(store, 'feature', { doc1: { setting: { value: 'enabled', level: 'high' } } }); // Them: changed to object\n\n      store.switchBranch('main');\n      store.update('doc1', { setting: 'disabled' }); // Ours: changed to primitive\n\n      const mergeResult = store.merge('feature');\n\n      expect(mergeResult.applied).toBe(false);\n      expect(mergeResult.conflicts).toHaveLength(1);\n      expect(mergeResult.conflicts[0]).toEqual({\n        documentId: 'doc1',\n        path: 'setting',\n        base: { setting: 'enabled' },\n        ours: { setting: 'disabled' },\n        theirs: { setting: { value: 'enabled', level: 'high' } },\n      });\n      expect(mergeResult.merged).toEqual({ doc1: { setting: 'disabled' } }); // 'ours' taken\n      expect(store.get('doc1')).toEqual({ setting: 'enabled' }); // Current branch unchanged\n    });\n\n    test('should handle deletion on one branch and modification on the other (conflict)', () => {\n      store.create('doc1', { name: 'Alice', age: 30 }); // Base\n      createDocs(store, 'feature', { doc1: { name: 'Alice', city: 'New York' } }); // Them: updated city\n\n      store.switchBranch('main');\n      store.delete('doc1'); // Ours: deleted doc1\n\n      const mergeResult = store.merge('feature');\n\n      expect(mergeResult.applied).toBe(false);\n      expect(mergeResult.conflicts).toHaveLength(1);\n      expect(mergeResult.conflicts[0]).toEqual({\n        documentId: 'doc1',\n        path: '', // Root level conflict for the entire document\n        base: { name: 'Alice', age: 30 },\n        ours: null, // Document is null on our branch (deleted)\n        theirs: { name: 'Alice', city: 'New York' }, // Document exists on their branch\n      });\n      // 'merged' will show 'ours' value for conflicts, so it should be null (representing deletion)\n      expect(mergeResult.merged).toEqual({ doc1: null });\n      expect(store.get('doc1')).toEqual({ name: 'Alice', age: 30 }); // Current branch unchanged\n    });\n\n    test('should handle deletion on both branches cleanly if they agree on deletion', () => {\n      store.create('doc1', { name: 'Alice', age: 30 });\n      store.delete('doc1'); // Delete on main\n\n      createDocs(store, 'feature', { doc1: { name: 'Alice', city: 'New York' } }); // Modify on feature\n      store.switchBranch('feature');\n      store.delete('doc1'); // Delete on feature\n\n      store.switchBranch('main');\n      const mergeResult = store.merge('feature');\n\n      expect(mergeResult.applied).toBe(true); // Applied because both deleted it, no conflicts, and it represents a change.\n      expect(mergeResult.conflicts).toHaveLength(0);\n      expect(mergeResult.merged).toEqual({}); // doc1 should be gone, so not in merged output if it's null.\n      expect(() => store.get('doc1')).toThrow('Document with ID \\'doc1\\' not found');\n    });\n\n    test('should merge nested arrays - conflict when differing elements/structure', () => {\n      // This test is tricky because array merge strategy isn't explicitly defined.\n      // The current implementation of performThreeWayMerge uses JSON.stringify for equality,\n      // which might lead to shallow array comparison if elements are complex objects.\n      // For now, testing with simple arrays and objects within arrays.\n      store.create('doc1', { list: [{ id: 1, val: 'a' }, { id: 2, val: 'b' }] }); // Base\n      createDocs(store, 'feature', { doc1: { list: [{ id: 1, val: 'a' }, { id: 2, val: 'B' }, { id: 3, val: 'c' }] } }); // Them: changed 'b' to 'B', added id:3\n\n      store.switchBranch('main');\n      store.update('doc1', { list: [{ id: 1, val: 'a' }, { id: 2, val: 'beta' }] }); // Ours: changed 'b' to 'beta'\n\n      const mergeResult = store.merge('feature');\n\n      expect(mergeResult.applied).toBe(false); // Conflict expected\n      expect(mergeResult.conflicts).toHaveLength(1);\n      expect(mergeResult.conflicts[0]).toEqual({\n        documentId: 'doc1',\n        path: 'list', // Conflict on the entire list array\n        base: { list: [{ id: 1, val: 'a' }, { id: 2, val: 'b' }] },\n        ours: { list: [{ id: 1, val: 'a' }, { id: 2, val: 'beta' }] },\n        theirs: { list: [{ id: 1, val: 'a' }, { id: 2, val: 'B' }, { id: 3, val: 'c' }] },\n      });\n      expect(mergeResult.merged).toEqual({ doc1: { list: [{ id: 1, val: 'a' }, { id: 2, val: 'beta' }] } }); // Ours taken for the conflict\n      expect(store.get('doc1')).toEqual({ list: [{ id: 1, val: 'a' }, { id: 2, val: 'b' }] }); // Unchanged on current branch\n    });\n  });\n\n  // --- Edge Cases & More Complex Scenarios ---\n  describe('Edge Cases and Complex Scenarios', () => {\n    test('should handle merging when branches diverge significantly', () => {\n      // Initial state on main: doc1={val:1}, doc2 added.\n      store.create('doc1', { val: 1 });\n      store.create('doc2', { initial: true });\n\n      // Create branch 'dev' from main\n      store.createBranch('dev');\n      store.switchBranch('dev');\n      // On 'dev': doc1 updated {val:2}, doc2 deleted, doc3 added {new:true}\n      store.update('doc1', { val: 2 });\n      store.delete('doc2');\n      store.create('doc3', { new: true });\n\n      // Create branch 'feature' from main\n      store.switchBranch('main'); // Back on main\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      // On 'feature': doc1 updated {val:10}, doc2 added {added:true}, doc3 added {added:true}\n      store.update('doc1', { val: 10 });\n      store.create('doc2', { added: true });\n      store.create('doc3', { added: true });\n\n\n      // Merge 'dev' into 'main'\n      store.switchBranch('main');\n      const mergeResultDevMain = store.merge('dev');\n\n      // Expected conflicts:\n      // doc1: Base={val:1}, Ours={val:2}, Theirs={val:10}. Conflict on 'val'.\n      // doc2: Base=undefined, Ours=deleted, Theirs={added:true}. Conflict (deleted vs added).\n      // doc3: Base=undefined, Ours=undefined, Theirs={new:true}. No conflict, added.\n\n      expect(mergeResultDevMain.applied).toBe(false);\n      expect(mergeResultDevMain.conflicts).toHaveLength(2); // Conflict on doc1.val and doc2\n\n      // Check doc1 conflict\n      const doc1Conflict = mergeResultDevMain.conflicts.find(c => c.documentId === 'doc1');\n      expect(doc1Conflict).toBeDefined();\n      expect(doc1Conflict).toEqual({\n        documentId: 'doc1',\n        path: 'val',\n        base: { val: 1 },\n        ours: { val: 2 },\n        theirs: { val: 10 },\n      });\n\n      // Check doc2 conflict (deleted vs added)\n      const doc2Conflict = mergeResultDevMain.conflicts.find(c => c.documentId === 'doc2');\n      expect(doc2Conflict).toBeDefined();\n      expect(doc2Conflict).toEqual({\n        documentId: 'doc2',\n        path: '',\n        base: null, // doc2 did not exist in base\n        ours: null, // Deleted on 'main'\n        theirs: { added: true }, // Added on 'dev'\n      });\n\n      // Check merged output (ours taken for conflicts, added docs included)\n      expect(mergeResultDevMain.merged).toEqual({\n        doc1: { val: 2 }, // 'ours' val:2 taken for conflict\n        doc2: null,       // 'ours' is null (deleted), so null for conflict display\n        doc3: { new: true }, // Added from 'dev'\n      });\n      // Assert state on 'main' is unchanged\n      expect(store.get('doc1')).toEqual({ val: 1 });\n      expect(store.get('doc2')).toEqual({ initial: true });\n      expect(() => store.get('doc3')).toThrow();\n    });\n\n    test('should handle merging with multiple documents and branches, respecting deletions', () => {\n      // Initial state on main\n      store.create('config', { api: 'v1' });\n      store.create('users', { admin: { id: 1, name: 'Admin' } });\n\n      // Create branch 'dev' from main\n      store.createBranch('dev');\n      store.switchBranch('dev');\n      store.update('config', { api: 'v2', env: 'dev' }); // Update config on dev\n      store.create('features', { experimental: true }); // Add features on dev\n\n      // Create branch 'release' from main\n      store.switchBranch('main');\n      store.createBranch('release');\n      store.switchBranch('release');\n      store.update('users', { admin: { id: 1, name: 'Administrator' } }); // Update users on release\n      store.delete('config'); // Delete config on release\n\n      // Merge 'release' into 'main'\n      store.switchBranch('main');\n      const mergeResultReleaseMain = store.merge('release');\n\n      // Expected state before merge on main:\n      // config: { api: 'v1' }\n      // users: { admin: { id: 1, name: 'Admin' } }\n      //\n      // Branch release state:\n      // config: deleted\n      // users: { admin: { id: 1, name: 'Administrator' } }\n      //\n      // Common ancestor is 'main' initial state.\n      //\n      // Merge 'release' into 'main':\n      // - config:\n      //   - Base: { api: 'v1' }\n      //   - Ours (main): { api: 'v1' }\n      //   - Theirs (release): null (deleted)\n      //   - Result: deleted. No conflict.\n      // - users:\n      //   - Base: { admin: { id: 1, name: 'Admin' } }\n      //   - Ours (main): { admin: { id: 1, name: 'Admin' } }\n      //   - Theirs (release): { admin: { id: 1, name: 'Administrator' } }\n      //   - Conflict on users.admin.name.\n      // - features:\n      //   - Base: undefined\n      //   - Ours (main): undefined\n      //   - Theirs (release): undefined\n      //   - Result: not present.\n\n      expect(mergeResultReleaseMain.applied).toBe(false); // Conflict on 'users'\n      expect(mergeResultReleaseMain.conflicts).toHaveLength(1);\n      expect(mergeResultReleaseMain.conflicts[0]).toEqual({\n        documentId: 'users',\n        path: 'admin.name',\n        base: { admin: { id: 1, name: 'Admin' } },\n        ours: { admin: { id: 1, name: 'Admin' } },\n        theirs: { admin: { id: 1, name: 'Administrator' } },\n      });\n      // merged shows 'ours' taken for conflicts and deletion\n      expect(mergeResultReleaseMain.merged).toEqual({\n        users: { admin: { id: 1, name: 'Admin' } }, // 'ours' taken for conflict\n        config: null // 'ours' was deleted on release, effectively\n      });\n      // Assert 'main' state unchanged\n      expect(store.get('users')).toEqual({ admin: { id: 1, name: 'Admin' } });\n      expect(() => store.get('config')).toThrow();\n      expect(() => store.get('features')).toThrow(); // 'features' was only on 'dev', not involved in this merge.\n    });\n  });\n});\n```\n\nThis marks the completion of the task.",
