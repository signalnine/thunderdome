d objects', () => {\n      store.create('doc1', { config: { timeout: 1000, retry: 3 } }); // Base\n      createDocs(store, 'feature', { doc1: { config: { timeout: 1000, retry: 5, log: true } } }); // Them: retry=5, log=true\n\n      store.switchBranch('main');\n      store.update('doc1', { config: { timeout: 2000, retry: 3, enabled: false } }); // Ours: timeout=2000, retry=3, enabled=false\n\n      const mergeResult = store.merge('feature');\n\n      expect(mergeResult.applied).toBe(false);\n      expect(mergeResult.conflicts).toHaveLength(1); // Conflict on 'retry'\n      expect(mergeResult.conflicts[0]).toEqual({\n        documentId: 'doc1',\n        path: 'config.retry',\n        base: { timeout: 1000, retry: 3 },\n        ours: { timeout: 2000, retry: 3, enabled: false },\n        theirs: { timeout: 1000, retry: 5, log: true },\n      });\n      expect(mergeResult.merged).toEqual({\n        doc1: {\n          config: {\n            timeout: 2000, // from ours\n            retry: 3, // from ours (conflict, but ours taken)\n            log: true, // from theirs (added)\n            enabled: false, // from ours (added)\n          }\n        }\n      });\n      expect(store.get('doc1')).toEqual({ config: { timeout: 1000, retry: 3 } }); // Current branch unchanged\n    });\n\n    test('should detect conflict when a primitive value is changed to an object and vice versa', () => {\n      store.create('doc1', { setting: 'enabled' }); // Base\n      createDocs(store, 'feature', { doc1: { setting: { value: 'enabled', level: 'high' } } }); // Them: changed to object\n\n      store.switchBranch('main');\n      store.update('doc1', { setting: 'disabled' }); // Ours: changed to primitive\n\n      const mergeResult = store.merge('feature');\n\n      expect(mergeResult.applied).toBe(false);\n      expect(mergeResult.conflicts).toHaveLength(1);\n      expect(mergeResult.conflicts[0]).toEqual({\n        documentId: 'doc1',\n        path: 'setting',\n        base: { setting: 'enabled' },\n        ours: { setting: 'disabled' },\n        theirs: { setting: { value: 'enabled', level: 'high' } },\n      });\n      expect(mergeResult.merged).toEqual({ doc1: { setting: 'disabled' } }); // 'ours' taken\n      expect(store.get('doc1')).toEqual({ setting: 'enabled' }); // Current branch unchanged\n    });\n\n    test('should handle deletion on one branch and modification on the other (conflict)', () => {\n      store.create('doc1', { name: 'Alice', age: 30 }); // Base\n      createDocs(store, 'feature', { doc1: { name: 'Alice', city: 'New York' } }); // Them: updated city\n\n      store.switchBranch('main');\n      store.delete('doc1'); // Ours: deleted doc1\n\n      const mergeResult = store.merge('feature');\n\n      expect(mergeResult.applied).toBe(false);\n      expect(mergeResult.conflicts).toHaveLength(1);\n      expect(mergeResult.conflicts[0]).toEqual({\n        documentId: 'doc1',\n        path: '', // Root level conflict for the entire document\n        base: { name: 'Alice', age: 30 },\n        ours: null, // Document is null on our branch (deleted)\n        theirs: { name: 'Alice', city: 'New York' }, // Document exists on their branch\n      });\n      // 'merged' will show 'ours' value for conflicts, so it should be null (representing deletion)\n      expect(mergeResult.merged).toEqual({ doc1: null });\n      expect(store.get('doc1')).toEqual({ name: 'Alice', age: 30 }); // Current branch unchanged\n    });\n\n    test('should handle deletion on both branches cleanly if they agree on deletion', () => {\n      store.create('doc1', { name: 'Alice', age: 30 });\n      store.delete('doc1'); // Delete on main\n\n      createDocs(store, 'feature', { doc1: { name: 'Alice', city: 'New York' } }); // Modify on feature\n      store.switchBranch('feature');\n      store.delete('doc1'); // Delete on feature\n\n      store.switchBranch('main');\n      const mergeResult = store.merge('feature');\n\n      expect(mergeResult.applied).toBe(true); // Applied because both deleted it, no conflict\n      expect(mergeResult.conflicts).toHaveLength(0);\n      expect(mergeResult.merged).toEqual({}); // doc1 should be gone\n      expect(() => store.get('doc1')).toThrow('Document with ID \\'doc1\\' not found');\n    });\n\n    test('should merge nested arrays - take ours if different, conflict if same but one has extra', () => {\n      // This test is tricky because array merge strategy isn't explicitly defined.\n      // Assuming deep comparison and conflict on differing elements/structures.\n      // The current implementation of performThreeWayMerge uses JSON.stringify for equality,\n      // which might lead to shallow array comparison if elements are complex objects.\n      // For now, testing with simple arrays.\n      store.create('doc1', { list: [1, 2] }); // Base\n      createDocs(store, 'feature', { doc1: { list: [1, 2, 3] } }); // Them: added 3\n\n      store.switchBranch('main');\n      store.update('doc1', { list: [1, 5] }); // Ours: changed 2 to 5\n\n      const mergeResult = store.merge('feature');\n\n      expect(mergeResult.applied).toBe(false); // Conflict expected\n      expect(mergeResult.conflicts).toHaveLength(1);\n      expect(mergeResult.conflicts[0]).toEqual({\n        documentId: 'doc1',\n        path: 'list',\n        base: { list: [1, 2] },\n        ours: { list: [1, 5] },\n        theirs: { list: [1, 2, 3] },\n      });\n      expect(mergeResult.merged).toEqual({ doc1: { list: [1, 5] } }); // Ours taken\n      expect(store.get('doc1')).toEqual({ list: [1, 2] }); // Unchanged on current branch\n    });\n  });\n\n  // --- Edge Cases & More Complex Scenarios ---\n  describe('Edge Cases and Complex Scenarios', () => {\n    test('should handle merging when branches diverge significantly', () => {\n      // Branch main: doc1 updated, doc2 deleted\n      store.create('doc1', { val: 1 });\n      store.update('doc1', { val: 2 });\n      store.delete('doc2');\n\n      // Branch feature: doc1 modified differently, doc3 added\n      createDocs(store, 'feature', { doc1: { val: 10 }, doc3: { new: true } });\n      store.switchBranch('feature');\n      store.update('doc1', { val: 11 }); // This is 'theirs' for merge\n      store.create('doc3', { new: true }); // This is 'theirs' for merge\n\n      store.switchBranch('main'); // back on main\n      // 'main' state: doc1={val:2}, doc2 deleted\n      // 'feature' state: doc1={val:11}, doc3={new:true}\n      // Common ancestor: doc1={val:1}, doc2 didn't exist, doc3 didn't exist\n\n      const mergeResult = store.merge('feature');\n\n      // Expect conflict on doc1, doc3 added, doc2 remains deleted\n      expect(mergeResult.applied).toBe(false);\n      expect(mergeResult.conflicts).toHaveLength(1);\n      expect(mergeResult.conflicts[0]).toEqual({\n        documentId: 'doc1',\n        path: 'val',\n        base: { val: 1 },\n        ours: { val: 2 }, // Deleted in base, updated on main\n        theirs: { val: 11 }, // Updated on feature\n      });\n      expect(mergeResult.merged).toEqual({\n        doc1: { val: 2 }, // 'ours' (2) taken for conflict\n        doc3: { new: true } // Added from feature\n      });\n      expect(store.get('doc3')).toEqual({ new: true }); // doc3 should exist on main after merge attempt\n      expect(() => store.get('doc2')).toThrow('Document with ID \\'doc2\\' not found'); // doc2 remains deleted\n      expect(store.get('doc1')).toEqual({ val: 2 }); // doc1 unchanged on current branch\n    });\n\n    test('should handle merging with multiple documents and branches', () => {\n      // Initial state on main\n      store.create('config', { api: 'v1' });\n      store.create('users', { admin: { id: 1, name: 'Admin' } });\n\n      // Create branch 'dev'\n      store.createBranch('dev');\n      store.switchBranch('dev');\n      store.update('config', { api: 'v2', env: 'dev' }); // Update config\n      store.create('features', { experimental: true }); // Add features\n\n      // Create branch 'release' from main\n      store.switchBranch('main');\n      store.createBranch('release');\n      store.switchBranch('release');\n      store.update('users', { admin: { id: 1, name: 'Administrator' } }); // Update users\n      store.delete('config'); // Delete config\n\n      // Merge 'dev' into 'main'\n      store.switchBranch('main');\n      const mergeResultDevMain = store.merge('dev');\n\n      expect(mergeResultDevMain.applied).toBe(false); // Conflict on config (updated on dev, deleted on main)\n      expect(mergeResultDevMain.conflicts).toHaveLength(1);\n      expect(mergeResultDevMain.conflicts[0]).toEqual({\n        documentId: 'config',\n        path: '',\n        base: { api: 'v1' },\n        ours: { api: 'v2', env: 'dev' }, // Updated on dev\n        theirs: null, // Deleted on main\n      });\n      expect(mergeResultDevMain.merged).toEqual({\n        config: null, // null taken because 'ours' was deleted\n        users: { admin: { id: 1, name: 'Admin' } }, // Unchanged\n        features: { experimental: true } // Added from dev\n      });\n      expect(store.get('users')).toEqual({ admin: { id: 1, name: 'Admin' } }); // users unchanged\n      expect(() => store.get('config')).toThrow(); // config deleted on main, should be gone after merge\n      expect(store.get('features')).toEqual({ experimental: true }); // features added from dev\n\n      // Merge 'release' into 'main' (after dev merge attempt)\n      // Current state of 'main' after dev merge attempt: config deleted, users updated, features added.\n      // Let's re-simulate the state of 'main' before 'release' merge for clarity\n      // (This means we should not actually apply the dev merge changes to 'main' if conflicts occur)\n      // Re-reading the spec: \"If there are conflicts, the merge is not applied (`applied: false`), and the conflicts are returned... The current branch remains unchanged.\"\n      // So, 'main' should still have config: {api: 'v1'}, users: {admin: {id:1, name:'Admin'}} before