onIdsB.has(versionA.id)) {\n          // This version ID exists in both branches' history\n          if (versionA.timestamp > latestCommonTimestamp) {\n            latestCommonTimestamp = versionA.timestamp;\n            latestCommonVersionId = versionA.id;\n          }\n        }\n      }\n    }\n\n    // If no common ID found, return null\n    return latestCommonVersionId;\n  }\n\n  // Helper to get all versions of a document from a specific branch state, sorted by timestamp\n  private getHistoryFromBranchState(branchState: BranchState, docId: string): Version[] | undefined {\n    const versionsMap = this.getDocumentVersions(branchState, docId);\n    if (!versionsMap) {\n      return undefined;\n    }\n    return Array.from(versionsMap.values()).sort((a, b) => a.timestamp - b.timestamp);\n  }\n\n  // Helper to get content of a specific version of a document from a branch state\n  private getVersionContent(branchState: BranchState, docId: string, versionId: string): object | null {\n    const versionsMap = this.getDocumentVersions(branchState, docId);\n    if (!versionsMap) {\n      return null;\n    }\n    const version = versionsMap.get(versionId);\n    return version ? deepClone(version.content) : null;\n  }\n\n\n  // Helper to perform a three-way merge on a single document's content\n  // Returns { mergedContent: object | null | undefined, conflicts: Conflict[] }\n  // `mergedContent` can be `undefined` if the operation was a no-op (e.g., no changes)\n  // `mergedContent` can be `null` if the result is deletion.\n  private performThreeWayMerge(\n    docId: string,\n    base: object | null,\n    ours: object | null,\n    theirs: object | null\n  ): { mergedContent: object | null | undefined, conflicts: Conflict[] } {\n    const conflicts: Conflict[] = [];\n    let mergedContent: object | null | undefined = undefined; // Use undefined to signal no operation needed\n\n    const baseObj = base as Record<string, any>;\n    const oursObj = ours as Record<string, any>;\n    const theirsObj = theirs as Record<string, any>;\n\n    const isBaseObject = base !== null && typeof base === 'object' && !Array.isArray(base);\n    const isOursObject = ours !== null && typeof ours === 'object' && !Array.isArray(ours);\n    const isTheirsObject = theirs !== null && typeof theirs === 'object' && !Array.isArray(theirs);\n\n    // --- Handle deletions and non-object types first ---\n\n    // Case 1: Document deleted on both sides\n    if (ours === null && theirs === null) {\n      // If base was also null, it means the document never existed or was deleted before branches diverged. No change.\n      // If base was not null, it means it was deleted on both branches. Result is deletion.\n      return { mergedContent: null, conflicts: [] };\n    }\n\n    // Case 2: Document deleted on one side, exists/modified on the other\n    if (ours === null && theirs !== null) { // Deleted on ours, exists/modified on theirs\n      // The spec states \"If there are conflicts... conflicts are returned... The current branch remains unchanged.\"\n      // If the document was deleted on ours, and exists/is modified on theirs, this is a conflict.\n      // The 'base' content is crucial here.\n      if (base !== null) { // If base had content, and we deleted it while they modified it.\n        conflicts.push({\n          documentId: docId,\n          path: '', // Conflict at the document root level\n          base: base,\n          ours: null, // Deleted on ours\n          theirs: theirs,\n        });\n        // For the `merged` field in case of conflict, use `ours` value, which is null (deletion)\n        return { mergedContent: null, conflicts };\n      } else { // If base was null (never existed), and they added it, it's just an addition on their side.\n        return { mergedContent: deepClone(theirs), conflicts: [] };\n      }\n    }\n    if (ours !== null && theirs === null) { // Deleted on theirs, exists/modified on ours\n      // Symmetric to the above.\n      if (base !== null) { // If base had content, and they deleted it while we modified it.\n        conflicts.push({\n          documentId: docId,\n          path: '',\n          base: base,\n          ours: ours,\n          theirs: null, // Deleted on theirs\n        });\n        // For the `merged` field, use `ours` value.\n        return { mergedContent: deepClone(ours), conflicts };\n      } else { // If base was null, and we added it.\n        return { mergedContent: deepClone(ours), conflicts: [] };\n      }\n    }\n\n    // Case 3: Document exists on both sides (ours and theirs are non-null)\n    // If they are not both objects, this is a conflict.\n    if (!isOursObject || !isTheirsObject) {\n      // One or both are primitives, arrays, or non-objects.\n      // If base was also different from both, it could be complex, but typically any change here is a conflict.\n      conflicts.push({\n        documentId: docId,\n        path: '',\n        base: base,\n        ours: ours,\n        theirs: theirs,\n      });\n      // For the `merged` field, use `ours` value.\n      return { mergedContent: deepClone(ours), conflicts };\n    }\n\n    // Case 4: Both ours and theirs are objects. Perform recursive merge.\n    const resultObj: Record<string, any> = {};\n    const allKeys = new Set([...Object.keys(oursObj), ...Object.keys(theirsObj), ...(isBaseObject ? Object.keys(baseObj) : [])]);\n\n    for (const key of allKeys) {\n      const baseValue = isBaseObject ? baseObj[key] : undefined;\n      const oursValue = oursObj[key]; // Will be undefined if key not in oursObj\n      const theirsValue = theirsObj[key]; // Will be undefined if key not in theirsObj\n\n      // Helper to compare values deeply, handling primitives, objects, and arrays\n      const areEqual = (v1: any, v2: any): boolean => {\n        try {\n          // For plain JSON objects, stringification is reliable.\n          // Handle undefined and null specifically for JSON.stringify.\n          const stringify = (val: any) => {\n            if (val === undefined) return 'undefined'; // Special handling for undefined\n            if (val === null) return 'null';\n            if (typeof val === 'object' && val !== null) return JSON.stringify(val);\n            return JSON.stringify(val);\n          };\n          return stringify(v1) === stringify(v2);\n        } catch (e) {\n          // Fallback for objects that cannot be stringified, though problem statement implies JSON\n          // For complex cases not stringifiable, this might indicate issues or require more robust diffing.\n          return v1 === v2; // Basic comparison\n        }\n      };\n\n      // Determine if a change occurred on ours or theirs relative to base\n      const changedOnOurs = !areEqual(baseValue, oursValue);\n      const changedOnTheirs = !areEqual(baseValue, theirsValue);\n\n      if (changedOnOurs && changedOnTheirs) {\n        // Both sides changed the same key. Check if they changed it to the same thing.\n        if (areEqual(oursValue, theirsValue)) {\n          // Both changed to the same value, no conflict. Take that value.\n          resultObj[key] = deepClone(oursValue); // or theirsValue, they are equal\n        } else {\n          // Both changed to different values. This is a conflict.\n          // Recursively merge if both values are objects.\n          if (typeof oursValue === 'object' && oursValue !== null && typeof theirsValue === 'object' && theirsValue !== null && !Array.isArray(oursValue) && !Array.isArray(theirsValue)) {\n            // If both are objects, attempt a recursive merge for this sub-path.\n            const subMergeResult = this.performThreeWayMerge(\n              `${docId}.${key}`,\n              baseValue as object | null, // Base value at this key's path\n              oursValue as object | null, // Our value at this key's path\n              theirsValue as object | null // Their value at this key's path\n            );\n            \n            if (subMergeResult.conflicts.length > 0) {\n              // Propagate conflicts from the recursive call\n              conflicts.push(...subMergeResult.conflicts);\n              // For the current result object's `merged` representation, take `ours` value for the conflict resolution.\n              resultObj[key] = deepClone(oursValue);\n            } else if (subMergeResult.mergedContent !== undefined) {\n              // If recursive merge succeeded without conflicts, take its result.\n              resultObj[key] = subMergeResult.mergedContent;\n            } else {\n              // Sub-merge resulted in null (deletion) or undefined (no-op).\n              resultObj[key] = subMergeResult.mergedContent;\n            }\n          } else {\n            // Primitive types, arrays, or mixed types changed differently. Conflict.\n            conflicts.push({\n              documentId: docId,\n              path: key, // This is the current level key. Path becomes dot-separated.\n              base: baseValue,\n              ours: oursValue,\n              theirs: theirsValue,\n            });\n            // As per spec: \"The `merged` field always contains the merge result (with conflicts resolved in favor of \"ours\" for the purpose of showing what it would look like).\"\n            resultObj[key] = deepClone(oursValue);\n          }\n        }\n      } else if (changedOnOurs) {\n        // Only ours changed. Take ours.\n        resultObj[key] = deepClone(oursValue);\n      } else if (changedOnTheirs) {\n        // Only theirs changed. Take theirs.\n        resultObj[key] = deepClone(theirsValue);\n      } else {\n        // No change on either side relative to base. Take base value.\n        if (baseValue !== undefined) { // If baseValue is undefined, it means it was never there and not changed.\n          resultObj[key] = deepClone(baseValue);\n        }\n        // If baseValue is undefined, and neither ours nor theirs changed it (implicitly), it means it was never