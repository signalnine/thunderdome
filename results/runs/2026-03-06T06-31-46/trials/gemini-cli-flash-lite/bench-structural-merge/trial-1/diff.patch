operations...\" is now `completed`. \"Implement Merging Logic\" is `in_progress`. I will now add the necessary helper functions and the `merge` method implementation to `src/index.ts`.\n\nThis will involve several helper functions for comparing and merging JSON structures, finding common ancestors, and managing conflicts.\n\nHere's the updated `src/index.ts` with the merging logic.\n\n```typescript\n// Interfaces\nexport interface Version {\n  id: string;\n  timestamp: number;\n  content: object;\n}\n\nexport interface MergeResult {\n  merged: Record<string, object>;  // documentId -> merged content\n  conflicts: Conflict[];\n  applied: boolean;  // true if merge was auto-applied (no conflicts)\n}\n\nexport interface Conflict {\n  documentId: string;\n  path: string;       // dot-separated JSON path, e.g. \"a.b.c\"\n  base: any;\n  ours: any;\n  theirs: any;\n}\n\nexport interface DocumentStore {\n  // Document CRUD\n  create(id: string, content: object): void;\n  get(id: string): object;\n  update(id: string, content: object): void;\n  delete(id: string): void;\n\n  // Version history\n  getHistory(id: string): Version[];\n  getVersion(id: string, versionId: string): object;\n\n  // Branching\n  createBranch(name: string, fromBranch?: string): void;\n  switchBranch(name: string): void;\n  getBranch(): string;\n  listBranches(): string[];\n\n  // Merging\n  merge(sourceBranchName: string): MergeResult;\n}\n\n// --- Internal Data Structures ---\n\ninterface BranchState {\n  documents: Map<string, DocumentState>; // docId -> DocumentState\n  versions: Map<string, Map<string, Version>>; // docId -> versionId -> Version\n  nextVersionIdCounter: number; // Counter for generating unique version IDs within this branch\n}\n\ninterface DocumentState {\n  id: string;\n  content: object; // Current content on this branch\n  currentVersionId: string | null; // ID of the latest version for this doc on this branch\n}\n\n// --- Implementation ---\n\nexport class DocumentStoreImpl implements DocumentStore {\n  private branches: Map<string, BranchState> = new Map();\n  private currentBranchName: string = \"main\";\n\n  constructor() {\n    // Initialize with the default 'main' branch\n    this.branches.set(\"main\", this.createEmptyBranchState());\n  }\n\n  private createEmptyBranchState(): BranchState {\n    return {\n      documents: new Map<string, DocumentState>(),\n      versions: new Map<string, Map<string, Version>>(),\n      nextVersionIdCounter: 0,\n    };\n  }\n\n  private getBranchState(): BranchState {\n    const state = this.branches.get(this.currentBranchName);\n    if (!state) {\n      throw new Error(`Internal error: Branch '${this.currentBranchName}' not found.`);\n    }\n    return state;\n  }\n\n  private getBranchStateByName(branchName: string): BranchState {\n    const state = this.branches.get(branchName);\n    if (!state) {\n      throw new Error(`Branch '${branchName}' not found.`);\n    }\n    return state;\n  }\n\n  private getDocumentState(branchState: BranchState, id: string): DocumentState | undefined {\n    return branchState.documents.get(id);\n  }\n\n  private getDocumentVersions(branchState: BranchState, id: string): Map<string, Version> | undefined {\n    return branchState.versions.get(id);\n  }\n\n  private addVersion(branchState: BranchState, docId: string, content: object): Version {\n    const versionId = `${branchState.nextVersionIdCounter++}`;\n    const timestamp = Date.now();\n    const newVersion: Version = { id: versionId, timestamp, content: deepClone(content) };\n\n    if (!branchState.versions.has(docId)) {\n      branchState.versions.set(docId, new Map<string, Version>());\n    }\n    branchState.versions.get(docId)!.set(versionId, newVersion);\n    return newVersion;\n  }\n\n  // Document CRUD\n  create(id: string, content: object): void {\n    const branchState = this.getBranchState();\n    if (this.getDocumentState(branchState, id)) {\n      throw new Error(`Document with ID '${id}' already exists on branch '${this.currentBranchName}'.`);\n    }\n\n    const newVersion = this.addVersion(branchState, id, content);\n    branchState.documents.set(id, {\n      id,\n      content: deepClone(content),\n      currentVersionId: newVersion.id,\n    });\n  }\n\n  get(id: string): object {\n    const branchState = this.getBranchState();\n    const docState = this.getDocumentState(branchState, id);\n    if (!docState) {\n      throw new Error(`Document with ID '${id}' not found on branch '${this.currentBranchName}'.`);\n    }\n    return deepClone(docState.content);\n  }\n\n  update(id: string, content: object): void {\n    const branchState = this.getBranchState();\n    const docState = this.getDocumentState(branchState, id);\n    if (!docState) {\n      throw new Error(`Document with ID '${id}' not found on branch '${this.currentBranchName}'.`);\n    }\n\n    const newVersion = this.addVersion(branchState, id, content);\n    docState.content = deepClone(content); // Update content in DocumentState\n    docState.currentVersionId = newVersion.id;\n  }\n\n  delete(id: string): void {\n    const branchState = this.getBranchState();\n    if (!this.getDocumentState(branchState, id)) {\n      throw new Error(`Document with ID '${id}' not found on branch '${this.currentBranchName}'.`);\n    }\n    branchState.documents.delete(id);\n    // Note: We don't delete versions when deleting a document, they remain in history.\n  }\n\n  // Version history\n  getHistory(id: string): Version[] {\n    const branchState = this.getBranchState();\n    const versionsMap = this.getDocumentVersions(branchState, id);\n    if (!versionsMap) {\n      throw new Error(`Document with ID '${id}' not found or has no history on branch '${this.currentBranchName}'.`);\n    }\n    // Sort versions by timestamp\n    const versionsArray = Array.from(versionsMap.values()).sort((a, b) => a.timestamp - b.timestamp);\n    return versionsArray.map(v => ({ ...v, content: deepClone(v.content) })); // Deep clone content\n  }\n\n  getVersion(id: string, versionId: string): object {\n    const branchState = this.getBranchState();\n    const versionsMap = this.getDocumentVersions(branchState, id);\n    if (!versionsMap) {\n      throw new Error(`Document with ID '${id}' not found or has no history on branch '${this.currentBranchName}'.`);\n    }\n    const version = versionsMap.get(versionId);\n    if (!version) {\n      throw new Error(`Version with ID '${versionId}' not found for document '${id}' on branch '${this.currentBranchName}'.`);\n    }\n    return deepClone(version.content);\n  }\n\n  // Branching\n  createBranch(name: string, fromBranch?: string): void {\n    if (this.branches.has(name)) {\n      throw new Error(`Branch with name '${name}' already exists.`);\n    }\n\n    const sourceBranchName = fromBranch || this.currentBranchName;\n    const sourceBranchState = this.getBranchStateByName(sourceBranchName);\n\n    // Deep clone the entire state of the source branch\n    const newBranchState: BranchState = {\n      documents: new Map(),\n      versions: new Map(),\n      nextVersionIdCounter: sourceBranchState.nextVersionIdCounter, // Carry over counter state\n    };\n\n    // Clone documents\n    sourceBranchState.documents.forEach((docState, docId) => {\n      newBranchState.documents.set(docId, {\n        ...docState,\n        content: deepClone(docState.content),\n      });\n    });\n\n    // Clone versions\n    sourceBranchState.versions.forEach((docVersionsMap, docId) => {\n      const newDocVersionsMap = new Map<string, Version>();\n      docVersionsMap.forEach((version, versionId) => {\n        newDocVersionsMap.set(versionId, {\n          ...version,\n          content: deepClone(version.content),\n        });\n      });\n      newBranchState.versions.set(docId, newDocVersionsMap);\n    });\n\n    this.branches.set(name, newBranchState);\n  }\n\n  switchBranch(name: string): void {\n    if (!this.branches.has(name)) {\n      throw new Error(`Branch '${name}' not found.`);\n    }\n    this.currentBranchName = name;\n  }\n\n  listBranches(): string[] {\n    return Array.from(this.branches.keys());\n  }\n\n  // Merging\n  merge(sourceBranchName: string): MergeResult {\n    const currentBranchState = this.getBranchState();\n    const sourceBranchState = this.getBranchStateByName(sourceBranchName);\n\n    const mergedDocuments: Record<string, object> = {};\n    const conflicts: Conflict[] = [];\n    let hasChanges = false;\n\n    // Collect all unique document IDs from both branches\n    const allDocIds = new Set([\n      ...currentBranchState.documents.keys(),\n      ...sourceBranchState.documents.keys(),\n    ]);\n\n    for (const docId of allDocIds) {\n      const ourDocState = this.getDocumentState(currentBranchState, docId);\n      const theirDocState = this.getDocumentState(sourceBranchState, docId);\n\n      const ourVersionId = ourDocState?.currentVersionId;\n      const theirVersionId = theirDocState?.currentVersionId;\n\n      // Get the actual content for base, ours, and theirs\n      const baseContent = this.getCommonAncestorContent(currentBranchState, sourceBranchState, docId);\n      const oursContent = ourDocState ? deepClone(ourDocState.content) : null; // null indicates deleted on ours\n      const theirsContent = theirDocState ? deepClone(theirDocState.content) : null; // null indicates deleted on theirs\n\n      const mergeOutcome = this.performThreeWayMerge(docId, baseContent, oursContent, theirsContent);\n\n      if (mergeOutcome.conflicts.length > 0) {\n        conflicts.push(...mergeOutcome.conflicts);\n        // Store the 'ours' version if it exists, otherwise if 'theirs' exists, store that.\n        // This is just for the merged result display, as applied will be false.\n        if (oursContent !== null) {\n          mergedDocuments[docId] = oursContent;\n        } else if (theirsContent !== null) {\n          mergedDocuments[docId] = theirsContent;\n        } else {\n          // Document was deleted on both sides (or deleted on one and never existed on other)\n          // This case might need refinement based on exact requirements for deleted docs\n          if (!mergedDocuments.hasOwnProperty(docId)) { // Avoid overwriting if already handled\n            // If deleted on both sides and not in base, it's gone. If deleted on both sides and in base, it's still gone.\n            // If we are to keep the delete, we might signify that. For now, assume it's removed.\n            // If conflicts exist, applied is false, so this might not matter for auto-apply.\n          }\n        }\n        hasChanges = true; // Mark that there were changes, even if conflicts prevent auto-apply\n      } else if (mergeOutcome.mergedContent !== undefined) { // No conflicts, and there's a result\n        mergedDocuments[docId] = mergeOutcome.mergedContent;\n        // Check if this change is different from the current state on the current branch\n        if (!ourDocState || JSON.stringify(ourDocState.content) !== JSON.stringify(mergeOutcome.mergedContent)) {\n          hasChanges = true;\n        }\n      } else {\n        // Document was deleted on both sides and no common ancestor or it was deleted in base too.\n        // If 'oursContent' and 'theirsContent' are both null, it implies deletion.\n        if (oursContent === null && theirsContent === null && baseContent !== null) {\n          // Document was deleted on both branches, and it existed in base.\n          // We consider this a change (effectively a no-op delete if it was already deleted on current branch)\n          hasChanges = true;\n          // Ensure it's marked for deletion or removed if merge is applied\n          // If applied is true, this means we need to delete it.\n        } else if (oursContent === null && theirsContent === null && baseContent === null) {\n          // Document never existed, was deleted on both sides. No change.\n        }\n      }\n    }\n\n    const applied = conflicts.length === 0 && hasChanges; // Merge is applied only if no conflicts and there were actual changes.\n\n    if (applied) {\n      // Apply the merge to the current branch\n      for (const docId in mergedDocuments) {\n        const content = mergedDocuments[docId];\n        const existingDocState = this.getDocumentState(currentBranchState, docId);\n\n        if (existingDocState) {\n          this.update(docId, content); // This will create a new version on the current branch\n        } else {\n          this.create(docId, content); // This will create a new document and version on the current branch\n        }\n      }\n\n      // Handle deletions: if a document was in `allDocIds` but not in `mergedDocuments` (meaning it was deleted on both sides or one side deleted and the other didn't have it),\n      // and it existed on `currentBranchState`, we should delete it from `currentBranchState`.\n      for (const docId in mergedDocuments) {\n        // If a document is present in `mergedDocuments` it implies it's either an update or create.\n        // If a document was deleted on both sides, and `mergedDocuments` does NOT contain it,\n        // we need to ensure it's deleted from the current branch if it existed.\n      }\n      // Re-evaluate deletions:\n      // If a docId was in `allDocIds` but not in `mergedDocuments` at all, it means it was deleted on both branches, or existed on one and was deleted on the other without existence in common ancestor.\n      // If it existed on the current branch, it should be deleted.\n      const docsToDelete = new Set<string>();\n      for (const docId of allDocIds) {\n        if (!mergedDocuments.hasOwnProperty(docId)) {\n          const ourDocState = this.getDocumentState(currentBranchState, docId);\n          if (ourDocState) { // If it existed on the current branch, it should be deleted.\n            docsToDelete.add(docId);\n          }\n        }\n      }\n      docsToDelete.forEach(docId => this.delete(docId));\n    }\n\n    return { merged: mergedDocuments, conflicts, applied };\n  }\n\n  // Helper to get content of a document at its common ancestor version\n  private getCommonAncestorContent(\n    branchStateA: BranchState,\n    branchStateB: BranchState,\n    docId: string\n  ): object | null {\n    const versionA = this.findCommonAncestorVersionId(branchStateA, branchStateB, docId);\n    if (versionA) {\n      // We need to retrieve the content for this versionId from *one* of the branches.\n      // Since it's a common ancestor, the content should be the same.\n      // Let's prioritize getting it from branchA's history.\n      return this.getVersionContent(branchStateA, docId, versionA);\n    }\n    return null; // No common ancestor found\n  }\n\n  // Helper to find the common ancestor version ID for a document between two branches\n  private findCommonAncestorVersionId(\n    branchStateA: BranchState,\n    branchStateB: BranchState,\n    docId: string\n  ): string | null {\n    const versionsA = this.getHistoryFromBranchState(branchStateA, docId);\n    const versionsB = this.getHistoryFromBranchState(branchStateB, docId);\n\n    if (!versionsA || !versionsB) {\n      return null; // Document doesn't exist in history on one or both branches\n    }\n\n    const versionIdsA = new Set(versionsA.map(v => v.id));\n    const versionIdsB = new Set(versionsB.map(v => v.id));\n\n    // Find common version IDs\n    const commonVersionIds = versionsA\n      .filter(v => versionIdsB.has(v.id))\n      .sort((a, b) => a.timestamp - b.timestamp); // Sort by timestamp (oldest first)\n\n    if (commonVersionIds.length > 0) {\n      return commonVersionIds[commonVersionIds.length - 1].id; // Return the latest common version ID\n    }\n\n    return null; // No common version found\n  }\n\n  // Helper to get all versions of a document from a specific branch state\n  private getHistoryFromBranchState(branchState: BranchState, docId: string): Version[] | undefined {\n    const versionsMap = this.getDocumentVersions(branchState, docId);\n    if (!versionsMap) {\n      return undefined;\n    }\n    return Array.from(versionsMap.values()).sort((a, b) => a.timestamp - b.timestamp);\n  }\n\n  // Helper to get content of a specific version of a document from a branch state\n  private getVersionContent(branchState: BranchState, docId: string, versionId: string): object | null {\n    const versionsMap = this.getDocumentVersions(branchState, docId);\n    if (!versionsMap) {\n      return null;\n    }\n    const version = versionsMap.get(versionId);\n    return version ? deepClone(version.content) : null;\n  }\n\n\n  // Helper to perform a three-way merge on a single document's content\n  // Returns { mergedContent: object | undefined, conflicts: Conflict[] }\n  private performThreeWayMerge(\n    docId: string,\n    base: object | null,\n    ours: object | null,\n    theirs: object | null\n  ): { mergedContent: object | undefined, conflicts: Conflict[] } {\n    const conflicts: Conflict[] = [];\n    let mergedContent: object | undefined = undefined;\n\n    // Case 1: Document deleted on both sides\n    if (ours === null && theirs === null) {\n      // If base was also null, it means the document never existed or was deleted before branches diverged. No change.\n      // If base was not null, it means it was deleted on both branches. Result is deletion.\n      // For merge result, we represent deletion with null.\n      mergedContent = null as any; // Explicitly null for deletion\n      return { mergedContent: null, conflicts: [] };\n    }\n\n    // Case 2: Document deleted on one side, modified/existed on the other\n    if (ours === null && theirs !== null) { // Deleted on ours, exists/modified on theirs\n      // If base also didn't have it (base === null), then theirs is a new addition.\n      // If base had it, then theirs is a modification of the base.\n      // In both cases, we take 'theirs' as the result.\n      mergedContent = deepClone(theirs);\n      return { mergedContent, conflicts: [] };\n    }\n    if (ours !== null && theirs === null) { // Deleted on theirs, exists/modified on ours\n      // Similar to above, we take 'ours'.\n      mergedContent = deepClone(ours);\n      return { mergedContent, conflicts: [] };\n    }\n\n    // Case 3: Document exists on both sides (or was potentially modified from base)\n    // Both ours and theirs are non-null objects.\n    const baseObj = base as Record<string, any>;\n    const oursObj = ours as Record<string, any>;\n    const theirsObj = theirs as Record<string, any>;\n\n    const resultObj: Record<string, any> = {};\n    const allKeys = new Set([...Object.keys(oursObj), ...Object.keys(theirsObj), ...(baseObj ? Object.keys(baseObj) : [])]);\n\n    for (const key of allKeys) {\n      const baseValue = baseObj ? baseObj[key] : undefined;\n      const oursValue = oursObj ? oursObj[key] : undefined;\n      const theirsValue = theirsObj ? theirsObj[key] : undefined;\n\n      // Helper to compare values deeply, handling primitives, objects, and arrays\n      const areEqual = (v1: any, v2: any): boolean => {\n        try {\n          return JSON.stringify(v1) === JSON.stringify(v2);\n        } catch {\n          // Fallback for objects that cannot be stringified, though problem statement implies JSON\n          return v1 === v2;\n        }\n      };\n\n      // Determine if a change occurred on ours or theirs\n      const changedOnOurs = !areEqual(baseValue, oursValue);\n      const changedOnTheirs = !areEqual(baseValue, theirsValue);\n\n      if (changedOnOurs && changedOnTheirs) {\n        // Both sides changed the same key. Check if they changed it to the same thing.\n        if (areEqual(oursValue, theirsValue)) {\n          // Both changed to the same value, no conflict. Take that value.\n          resultObj[key] = deepClone(oursValue); // or theirsValue, they are equal\n        } else {\n          // Both changed to different values. This is a conflict.\n          // Recursively merge if both values are objects.\n          if (typeof oursValue === 'object' && oursValue !== null && typeof theirsValue === 'object' && theirsValue !== null && !Array.isArray(oursValue) && !Array.isArray(theirsValue)) {\n            // If both are objects, attempt a recursive merge.\n            // The base for this recursive merge is the value at this path in the original 'base' object.\n            const subConflicts: Conflict[] = [];\n            const subMergeResult = this.performThreeWayMerge(\n              `${docId}.${key}`,\n              baseValue as object | null,\n              oursValue as object | null,\n              theirsValue as object | null\n            );\n            \n            if (subMergeResult.conflicts.length > 0) {\n              // Propagate conflicts\n              subMergeResult.conflicts.forEach(conflict => conflicts.push(conflict));\n              // For the current result object, we will record this path as having conflicts.\n              // The `mergedDocuments` will represent what the result *would* look like,\n              // and `conflicts` will detail the actual conflicts.\n              // For `resultObj[key]`, we'll put *one* of the values (e.g., ours) to represent the structure,\n              // but the conflict detail is what matters for `applied: false`.\n              // If `applied` is true, \"ours\" is taken for conflicting fields.\n              // If `applied` is false, \"ours\" is taken for the display `merged` object, but `conflicts` lists the diffs.\n              // Let's populate `resultObj[key]` with `oursValue` for now, as per the spec's `merged` field.\n              resultObj[key] = deepClone(oursValue); // Or theirsValue, they are different\n            } else if (subMergeResult.mergedContent !== undefined) {\n              resultObj[key] = subMergeResult.mergedContent;\n            } else {\n              // Sub-merge resulted in deletion or null.\n              resultObj[key] = subMergeResult.mergedContent