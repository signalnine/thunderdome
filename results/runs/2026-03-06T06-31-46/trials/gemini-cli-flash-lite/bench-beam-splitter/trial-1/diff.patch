 = r;\n                sourceCol = c;\n                break;\n            }\n        }\n        if (sourceRow !== -1) break;\n    }\n\n    if (sourceRow === -1) {\n        return 0; // No source found\n    }\n\n    // Start the simulation from the source\n    const startCellKey = `${sourceRow},${sourceCol}`;\n    visitedCells.add(startCellKey);\n    queue.push({ r: sourceRow, c: sourceCol, dir: DIR_DOWN });\n\n    let head = 0;\n    while (head < queue.length) {\n        const { r, c, dir } = queue[head++];\n\n        // Calculate the next position based on the current direction\n        const { next_r, next_c, next_dir } = getNextBeamState(r, c, dir);\n\n        // Check if the beam has moved outside the grid boundaries\n        if (next_r < 0 || next_r >= rows || next_c < 0 || next_c >= cols) {\n            continue; // Beam is absorbed\n        }\n\n        const nextCellKey = `${next_r},${next_c}`;\n        visitedCells.add(nextCellKey); // Mark the next cell as visited\n\n        const nextCellType = grid[next_r][next_c];\n\n        if (nextCellType === '^') {\n            // Splitter: The beam splits into two diagonal beams\n            // One beam goes down-left from the splitter cell\n            queue.push({ r: next_r, c: next_c, dir: DIR_DOWN_LEFT });\n            // One beam goes down-right from the splitter cell\n            queue.push({ r: next_r, c: next_c, dir: DIR_DOWN_RIGHT });\n        } else {\n            // Empty cell ('.') or source ('S'): Beam continues in the same direction\n            queue.push({ r: next_r, c: next_c, dir: next_dir });\n        }\n    }\n\n    return visitedCells.size;\n}\n\n/**\n * Counts the total number of distinct source-to-exit paths through the grid.\n * @param grid The 2D grid representing the laboratory.\n * @returns The total count of distinct paths as a bigint.\n */\nexport function countBeamPaths(grid: string[][]): bigint {\n    if (!grid || grid.length === 0 || grid[0].length === 0) {\n        return 0n;\n    }\n\n    const rows = grid.length;\n    const cols = grid[0].length;\n\n    // DP table: dp[r][c][dir] stores the number of beams arriving at (r, c) with direction `dir`.\n    // Directions: 0=DOWN, 1=DOWN_LEFT, 2=DOWN_RIGHT\n    const dp: bigint[][][] = Array(rows).fill(null).map(() =>\n        Array(cols).fill(null).map(() => Array(3).fill(0n))\n    );\n\n    let totalExits = 0n;\n\n    // Find the source 'S'\n    let sourceRow = -1;\n    let sourceCol = -1;\n    for (let r = 0; r < rows; r++) {\n        for (let c = 0; c < cols; c++) {\n            if (grid[r][c] === 'S') {\n                sourceRow = r;\n                sourceCol = c;\n                break;\n            }\n        }\n        if (sourceRow !== -1) break;\n    }\n\n    if (sourceRow === -1) {\n        return 0n; // No source found\n    }\n\n    // Initialize the DP table with the beam starting from 'S' moving DOWN\n    // This means 1 path *arrives* at (sourceRow, sourceCol) with direction DOWN.\n    dp[sourceRow][sourceCol][DIR_DOWN] = 1n;\n\n    // Iterate through the grid, processing beams row by row.\n    // This order ensures that when we process (r, c), all beams that could have\n    // arrived at (r, c) from previous rows have already been computed.\n    for (let r = 0; r < rows; r++) {\n        for (let c = 0; c < cols; c++) {\n            const cellType = grid[r][c];\n\n            // Process beams arriving at (r, c) from DIR_DOWN\n            if (dp[r][c][DIR_DOWN] > 0n) {\n                const currentPaths = dp[r][c][DIR_DOWN];\n                if (cellType === '^') {\n                    // Splitter: splits into DOWN_LEFT and DOWN_RIGHT FROM (r,c)\n                    // Path 1: Down-left from (r,c)\n                    const { next_r: next_r_left, next_c: next_c_left } = getNextBeamState(r, c, DIR_DOWN_LEFT);\n                    if (next_r_left < rows && next_c_left >= 0 && next_c_left < cols) {\n                        dp[next_r_left][next_c_left][DIR_DOWN_LEFT] += currentPaths;\n                    } else {\n                        totalExits += currentPaths; // Exits grid\n                    }\n\n                    // Path 2: Down-right from (r,c)\n                    const { next_r: next_r_right, next_c: next_c_right } = getNextBeamState(r, c, DIR_DOWN_RIGHT);\n                    if (next_r_right < rows && next_c_right >= 0 && next_c_right < cols) {\n                        dp[next_r_right][next_c_right][DIR_DOWN_RIGHT] += currentPaths;\n                    } else {\n                        totalExits += currentPaths; // Exits grid\n                    }\n                } else {\n                    // Pass through ('.') or start ('S' - although 'S' is only at row 0 and handled by initialization)\n                    // Continue in the same direction (DOWN) FROM (r,c)\n                    const { next_r, next_c } = getNextBeamState(r, c, DIR_DOWN);\n                    if (next_r < rows && next_c >= 0 && next_c < cols) {\n                        dp[next_r][next_c][DIR_DOWN] += currentPaths;\n                    } else {\n                        totalExits += currentPaths; // Exits grid\n                    }\n                }\n            }\n\n            // Process beams arriving at (r, c) from DIR_DOWN_LEFT\n            if (dp[r][c][DIR_DOWN_LEFT] > 0n) {\n                const currentPaths = dp[r][c][DIR_DOWN_LEFT];\n                if (cellType === '^') {\n                    // Splitter: splits into DOWN_LEFT and DOWN_RIGHT FROM (r,c)\n                    const { next_r: next_r_left, next_c: next_c_left } = getNextBeamState(r, c, DIR_DOWN_LEFT);\n                    if (next_r_left < rows && next_c_left >= 0 && next_c_left < cols) {\n                        dp[next_r_left][next_c_left][DIR_DOWN_LEFT] += currentPaths;\n                    } else {\n                        totalExits += currentPaths; // Exits grid\n                    }\n\n                    const { next_r: next_r_right, next_c: next_c_right } = getNextBeamState(r, c, DIR_DOWN_RIGHT);\n                    if (next_r_right < rows && next_c_right >= 0 && next_c_right < cols) {\n                        dp[next_r_right][next_c_right][DIR_DOWN_RIGHT] += currentPaths;\n                    } else {\n                        totalExits += currentPaths; // Exits grid\n                    }\n                } else {\n                    // Pass through ('.')\n                    // Continue in the same direction (DOWN_LEFT) FROM (r,c)\n                    const { next_r, next_c } = getNextBeamState(r, c, DIR_DOWN_LEFT);\n                    if (next_r < rows && next_c >= 0 && next_c < cols) {\n                        dp[next_r][next_c][DIR_DOWN_LEFT] += currentPaths;\n                    } else {\n                        totalExits += currentPaths; // Exits grid\n                    }\n                }\n            }\n\n            // Process beams arriving at (r, c) from DIR_DOWN_RIGHT\n            if (dp[r][c][DIR_DOWN_RIGHT] > 0n) {\n                const currentPaths = dp[r][c][DIR_DOWN_RIGHT];\n                if (cellType === '^') {\n                    // Splitter: splits into DOWN_LEFT and DOWN_RIGHT FROM (r,c)\n                    const { next_r: next_r_left, next_c: next_c_left } = getNextBeamState(r, c, DIR_DOWN_LEFT);\n                    if (next_r_left < rows && next_c_left >= 0 && next_c_left < cols) {\n                        dp[next_r_left][next_c_left][DIR_DOWN_LEFT] += currentPaths;\n                    } else {\n                        totalExits += currentPaths; // Exits grid\n                    }\n\n                    const { next_r: next_r_right, next_c: next_c_right } = getNextBeamState(r, c, DIR_DOWN_RIGHT);\n                    if (next_r_right < rows && next_c_right >= 0 && next_c_right < cols) {\n                        dp[next_r_right][next_c_right][DIR_DOWN_RIGHT] += currentPaths;\n                    } else {\n                        totalExits += currentPaths; // Exits grid\n                    }\n                } else {\n                    // Pass through ('.')\n                    // Continue in the same direction (DOWN_RIGHT) FROM (r,c)\n                    const { next_r, next_c } = getNextBeamState(r, c, DIR_DOWN_RIGHT);\n                    if (next_r < rows && next_c >= 0 && next_c < cols) {\n                        dp[next_r][next_c][DIR_DOWN_RIGHT] += currentPaths;\n                    } else {\n                        totalExits += currentPaths; // Exits grid\n                    }\n                }\n            }\n        }\n    }\n\n    return totalExits;\n}\n```\n\n```typescript\nimport { describe, it, expect } from 'vitest';\nimport { countBeamCells, countBeamPaths } from './index';\n\ndescribe('Beam Splitter', () => {\n\n    // Example 1 from problem description\n    const grid1 = [\n        ['.', 'S', '.', '.', '.'],\n        ['.', '.', '.', '.', '.'],\n        ['.', '^', '.', '.', '.'],\n        ['.', '.', '.', '.', '.'],\n    ];\n\n    it('should correctly count visited cells for grid 1', () => {\n        expect(countBeamCells(grid1)).toBe(5);\n    });\n\n    it('should correctly count paths for grid 1', () => {\n        expect(countBeamPaths(grid1)).toBe(2n);\n    });\n\n    // Example 2 from problem description\n    const grid2 = [\n        ['.', 'S', '.', '.', '.'],\n        ['.', '^', '.', '.', '.'],\n        ['^', '.', '^', '.', '.'],\n        ['.', '.', '.', '.', '.'],\n    ];\n\n    it('should correctly count visited cells for grid 2', () => {\n        expect(countBeamCells(grid2)).toBe(6);\n    });\n\n    it('should correctly count paths for grid 2', () => {\n        expect(countBeamPaths(grid2)).toBe(4n);\n    });\n\n    // Additional test case: no splitters\n    const grid3 = [\n        ['.', 'S', '.', '.'],\n        ['.', '.', '.', '.'],\n        ['.', '.', '.', '.'],\n    ];\n\n    it('should handle grids with no splitters', () => {\n        // S at (0,1) moves down to (1,1) and (2,1). Visited: (0,1), (1,1), (2,1). Count = 3.\n