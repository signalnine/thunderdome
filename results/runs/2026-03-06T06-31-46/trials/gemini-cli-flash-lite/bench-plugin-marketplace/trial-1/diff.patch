index 0000000..16d88f5
--- /dev/null
+++ b/src/sandboxedRunner/index.ts
@@ -0,0 +1,117 @@
+import vm from 'vm';
+import type { SandboxResult, SandboxContext } from '../types';
+
+const DEFAULT_TIMEOUT = 5000; // 5 seconds
+
+export class SandboxedRunner {
+    private readonly timeout: number;
+
+    constructor(timeout: number = DEFAULT_TIMEOUT) {
+        this.timeout = timeout;
+    }
+
+    /**
+     * Executes a string of JavaScript code in a sandboxed environment.
+     * @param code - The JavaScript code to execute.
+     * @param context - The context variables to make available in the sandbox.
+     * @returns A promise that resolves with the sandbox execution result.
+     */
+    async run(code: string, context: SandboxContext = {}): Promise<SandboxResult> {
+        const startTime = Date.now();
+        let endTime: number;
+        let memoryBefore = 0;
+        let memoryAfter = 0;
+        let exitCode = 0;
+        let output: any = null;
+        let error: Error | null = null;
+
+        const sandboxContext = vm.createContext(context);
+
+        // Prepare a promise for the script execution
+        const scriptExecution = new Promise<any>(async (resolve, reject) => {
+            try {
+                // Measure memory usage before execution if gc is available
+                if (global.gc) {
+                    global.gc();
+                    memoryBefore = process.memoryUsage().heapUsed;
+                }
+
+                // vm.Script does not have a timeout option. We use Promise.race for timeout.
+                const script = new vm.Script(code); // Removed timeout from here
+                const result = script.runInContext(sandboxContext);
+
+                // Handle promises returned by the script
+                const executionResult = await Promise.resolve(result);
+                resolve(executionResult);
+            } catch (err: any) {
+                reject(err);
+            }
+        });
+
+        // Prepare a promise for the timeout
+        const timeoutPromise = new Promise<never>((_, reject) => {
+            setTimeout(() => {
+                reject(new Error('Script execution timed out'));
+            }, this.timeout);
+        });
+
+        try {
+            // Race the script execution against the timeout
+            output = await Promise.race([scriptExecution, timeoutPromise]);
+            endTime = Date.now();
+
+            if (global.gc) {
+                global.gc();
+                memoryAfter = process.memoryUsage().heapUsed;
+            }
+
+            return {
+                success: true,
+                output: output,
+                error: null,
+                timing: {
+                    start: startTime,
+                    end: endTime,
+                    duration: endTime - startTime,
+                },
+                memory: {
+                    start_bytes: memoryBefore,
+                    end_bytes: memoryAfter,
+                    diff_bytes: memoryAfter - memoryBefore,
+                },
+                exitCode: 0,
+            };
+
+        } catch (err: any) {
+            endTime = Date.now();
+            error = err;
+            exitCode = err.code || 1; // Use err.code if available, otherwise default to 1
+
+            if (global.gc) {
+                global.gc();
+                memoryAfter = process.memoryUsage().heapUsed;
+            }
+
+            return {
+                success: false,
+                output: null,
+                error: {
+                    message: err.message,
+                    stack: err.stack,
+                    name: err.name,
+                },
+                timing: {
+                    start: startTime,
+                    end: endTime,
+                    duration: endTime - startTime,
+                },
+                memory: {
+                    start_bytes: memoryBefore,
+                    end_bytes: memoryAfter,
+                    diff_bytes: memoryAfter - memoryBefore,
+                },
+                exitCode: exitCode,
+            };
+        }
+    }
+}
