+import Database from 'better-sqlite3';
+import type { PluginManifest, PluginVersion, SearchOptions } from '../types';
+
+const DB_PATH = ':memory:'; // Use in-memory database for simplicity in this example
+
+export class PluginRegistry {
+    private db: Database.Database;
+
+    constructor() {
+        this.db = new Database(DB_PATH);
+        this.initializeDatabase();
+    }
+
+    private initializeDatabase() {
+        this.db.exec(`
+            CREATE TABLE IF NOT EXISTS plugins (
+                id INTEGER PRIMARY KEY AUTOINCREMENT,
+                name TEXT UNIQUE NOT NULL,
+                description TEXT,
+                author TEXT
+            );
+            CREATE TABLE IF NOT EXISTS plugin_versions (
+                id INTEGER PRIMARY KEY AUTOINCREMENT,
+                plugin_id INTEGER NOT NULL,
+                version TEXT NOT NULL,
+                entryPoint TEXT NOT NULL,
+                dependencies TEXT, -- JSON string of dependencies
+                FOREIGN KEY (plugin_id) REFERENCES plugins(id) ON DELETE CASCADE,
+                UNIQUE(plugin_id, version)
+            );
+            CREATE INDEX IF NOT EXISTS idx_plugin_versions_plugin_id ON plugin_versions(plugin_id);
+            CREATE UNIQUE INDEX IF NOT EXISTS idx_plugin_versions_unique ON plugin_versions(plugin_id, version);
+        `);
+    }
+
+    addPlugin(manifest: PluginManifest): void {
+        this.db.transaction(() => {
+            const pluginInfo = this.db.prepare('SELECT id FROM plugins WHERE name = ?').get(manifest.name) as { id: number } | undefined;
+            let pluginId: number;
+
+            if (pluginInfo) {
+                pluginId = pluginInfo.id;
+            } else {
+                const insertPlugin = this.db.prepare('INSERT INTO plugins (name, description, author) VALUES (?, ?, ?)');
+                const result = insertPlugin.run(manifest.name, manifest.description, manifest.author);
+                pluginId = result.lastInsertRowid as number;
+            }
+
+            const insertVersion = this.db.prepare(
+                'INSERT OR IGNORE INTO plugin_versions (plugin_id, version, entryPoint, dependencies) VALUES (?, ?, ?, ?)'
+            );
+            insertVersion.run(
+                pluginId,
+                manifest.version,
+                manifest.entryPoint,
+                JSON.stringify(manifest.dependencies || {})
+            );
+        })();
+    }
+
+    getPluginByName(name: string): PluginManifest | undefined {
+        const pluginInfo = this.db.prepare('SELECT * FROM plugins WHERE name = ?').get(name) as { id: number; name: string; description?: string; author?: string } | undefined;
+        if (!pluginInfo) {
+            return undefined;
+        }
+
+        const versions = this.db.prepare('SELECT version, entryPoint, dependencies FROM plugin_versions WHERE plugin_id = ? ORDER BY version DESC')
+            .all(pluginInfo.id) as PluginVersion[];
+
+        return {
+            name: pluginInfo.name,
+            description: pluginInfo.description,
+            author: pluginInfo.author,
+            version: versions.length > 0 ? versions[0].version : undefined, // Assuming latest version if not specified, or maybe should return all versions? Let's return latest for 'get' for now.
+            entryPoint: versions.length > 0 ? versions[0].entryPoint : undefined,
+            dependencies: versions.length > 0 ? JSON.parse(versions[0].dependencies) : {},
+            allVersions: versions.map(v => ({
+                version: v.version,
+                entryPoint: v.entryPoint,
+                dependencies: JSON.parse(v.dependencies)
+            }))
+        };
+    }
+    
+    getPluginVersion(name: string, version: string): PluginManifest | undefined {
+        const pluginInfo = this.db.prepare('SELECT * FROM plugins WHERE name = ?').get(name) as { id: number; name: string; description?: string; author?: string } | undefined;
+        if (!pluginInfo) {
+            return undefined;
+        }
+
+        const versionInfo = this.db.prepare('SELECT version, entryPoint, dependencies FROM plugin_versions WHERE plugin_id = ? AND version = ?')
+            .get(pluginInfo.id, version) as PluginVersion | undefined;
+
+        if (!versionInfo) {
+            return undefined;
+        }
+
+        return {
+            name: pluginInfo.name,
+            description: pluginInfo.description,
+            author: pluginInfo.author,
+            version: versionInfo.version,
+            entryPoint: versionInfo.entryPoint,
+            dependencies: JSON.parse(versionInfo.dependencies),
+        };
+    }
+
+    browsePlugins(): PluginManifest[] {
+        const plugins = this.db.prepare('SELECT id, name, description, author FROM plugins').all() as { id: number; name: string; description?: string; author?: string }[];
+
+        return plugins.map(p => {
+            const versions = this.db.prepare('SELECT version, entryPoint, dependencies FROM plugin_versions WHERE plugin_id = ? ORDER BY version DESC')
+                .all(p.id) as PluginVersion[];
+            return {
+                name: p.name,
+                description: p.description,
+                author: p.author,
+                version: versions.length > 0 ? versions[0].version : undefined, // Latest version
+                entryPoint: versions.length > 0 ? versions[0].entryPoint : undefined,
+                dependencies: versions.length > 0 ? JSON.parse(versions[0].dependencies) : {},
+                allVersions: versions.map(v => ({
+                    version: v.version,
+                    entryPoint: v.entryPoint,
+                    dependencies: JSON.parse(v.dependencies)
+                }))
+            };
+        });
+    }
+
+    searchPlugins(options: SearchOptions): PluginManifest[] {
+        let query = `
+            SELECT p.id, p.name, p.description, p.author
+            FROM plugins p
+            JOIN plugin_versions pv ON p.id = pv.plugin_id
+        `;
+        const params: (string | number)[] = [];
+        const conditions: string[] = [];
+
+        if (options.name) {
+            conditions.push('p.name LIKE ?');
+            params.push(`%${options.name}%`);
+        }
+        if (options.author) {
+            conditions.push('p.author LIKE ?');
+            params.push(`%${options.author}%`);
+        }
+        if (options.version) {
+            conditions.push('pv.version LIKE ?');
+            params.push(`%${options.version}%`);
+        }
+        if (options.entryPoint) {
+            conditions.push('pv.entryPoint LIKE ?');
+            params.push(`%${options.entryPoint}%`);
+        }
+
+        if (conditions.length > 0) {
+            query += ' WHERE ' + conditions.join(' AND ');
+        }
+
+        query += ' GROUP BY p.id, p.name, p.description, p.author ORDER BY p.name'; // Group by plugin, then find latest version within search results if needed
+
+        const plugins = this.db.prepare(query).all(params) as { id: number; name: string; description?: string; author?: string }[];
+
+        // For each found plugin, fetch its versions and determine the latest if not explicitly searched
+        return plugins.map(p => {
+            const versions = this.db.prepare('SELECT version, entryPoint, dependencies FROM plugin_versions WHERE plugin_id = ? ORDER BY version DESC')
+                .all(p.id) as PluginVersion[];
+            
+            // Filter versions based on search if version was specified, otherwise take latest
+            const filteredVersions = versions.filter(v => {
+                let match = true;
+                if (options.version) {
+                    // This is a bit tricky. The initial query might match a plugin if *any* of its versions match.
+                    // Here we need to ensure the *returned* version (or latest) matches if version was specified.
+                    // For simplicity, let's ensure *at least one* version matches the option.version pattern.
+                    // A more robust solution might involve more complex SQL or post-processing.
+                    // For now, we'll rely on the outer WHERE clause and just return the full manifest for the plugin.
+                    // If a specific version was requested, the getPluginVersion method should be used.
+                    // This search method should return plugins that *have* matching versions.
+                    return true; // Already filtered by main query
+                }
+                return true; // Return all versions if no version specified in search options
+            });
+
+            return {
+                name: p.name,
+                description: p.description,
+                author: p.author,
+                version: filteredVersions.length > 0 ? filteredVersions[0].version : undefined, // Latest version
+                entryPoint: filteredVersions.length > 0 ? filteredVersions[0].entryPoint : undefined,
+                dependencies: filteredVersions.length > 0 ? JSON.parse(filteredVersions[0].dependencies) : {},
+                allVersions: filteredVersions.map(v => ({
+                    version: v.version,
+                    entryPoint: v.entryPoint,
+                    dependencies: JSON.parse(v.dependencies)
+                }))
+            };
+        });
+    }
+
+    removePluginVersion(name: string, version: string): boolean {
+        const pluginInfo = this.db.prepare('SELECT id FROM plugins WHERE name = ?').get(name) as { id: number } | undefined;
+        if (!pluginInfo) {
+            return false;
+        }
+
+        const deleteResult = this.db.prepare('DELETE FROM plugin_versions WHERE plugin_id = ? AND version = ?')
+            .run(pluginInfo.id, version);
+
+        return deleteResult.changes > 0;
+    }
+
+    // Helper to get all registered versions for dependency resolution
+    getAllVersions(): { pluginName: string; version: string; dependencies: { [key: string]: string } }[] {
+        const results = this.db.prepare(`
+            SELECT p.name AS pluginName, pv.version, pv.dependencies
+            FROM plugins p
+            JOIN plugin_versions pv ON p.id = pv.plugin_id
+        `).all() as { pluginName: string; version: string; dependencies: string }[];
+
+        return results.map(r => ({
+            pluginName: r.pluginName,
+            version: r.version,
+            dependencies: JSON.parse(r.dependencies)
+        }));
+    }
+
+    close() {
+        this.db.close();
+    }
+}
