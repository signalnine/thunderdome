+import { PluginRegistry } from './pluginRegistry.js';
+import { VersionResolver } from './versionResolver.js';
+import { SandboxedRunner } from './sandboxedRunner.js';
+import { ReviewSystem } from './reviewSystem.js';
+import { DependencyGraph } from './dependencyGraph.js';
+import type {
+    Marketplace,
+    PluginManifest,
+    PluginVersion,
+    VersionConstraint,
+    SandboxContext,
+    SandboxResult,
+    Review,
+    ReviewQuery,
+    PluginReview,
+    UserReview,
+    SearchOptions,
+    InstallPluginResult
+} from './types.js';
+
+export function createMarketplace(): Marketplace {
+    const pluginRegistry = new PluginRegistry();
+    const versionResolver = new VersionResolver();
+    const sandboxedRunner = new SandboxedRunner(); // Default timeout
+    const reviewSystem = new ReviewSystem();
+    const dependencyGraph = new DependencyGraph();
+
+    const installPlugin = async (manifest: PluginManifest): Promise<InstallPluginResult> => {
+        // 1. Validate manifest
+        if (!manifest.name || !manifest.version || !manifest.entryPoint) {
+            throw new Error('Plugin manifest must contain name, version, and entryPoint.');
+        }
+
+        // 2. Register the plugin
+        pluginRegistry.addPlugin(manifest);
+
+        // Get all versions from the registry to build the graph and resolve dependencies
+        const allVersions = pluginRegistry.getAllVersions();
+        dependencyGraph.build(allVersions);
+
+        // Prepare constraints for the current plugin and its direct dependencies
+        const explicitConstraints: VersionConstraint[] = [{ pluginName: manifest.name, version: manifest.version }];
+        const pluginVersionsInRegistry = dependencyGraph.getAllVersions(); // Re-fetch or ensure graph has the latest
+
+        // 3. Resolve its dependency versions
+        // The version resolver will handle transitive dependencies as well.
+        const resolvedDependencies = versionResolver.resolve(explicitConstraints, allVersions);
+        
+        // Construct the actual versions to be installed based on resolved dependencies
+        const versionsToInstall: PluginVersion[] = [];
+        for (const [pluginName, resolvedVersion] of resolvedDependencies.entries()) {
+            const pluginManifest = pluginRegistry.getPluginVersion(pluginName, resolvedVersion);
+            if (!pluginManifest) {
+                // This should ideally not happen if versionResolver.resolve works correctly and allVersions are up-to-date
+                throw new Error(`Resolved version ${pluginName}@${resolvedVersion} not found in registry.`);
+            }
+            versionsToInstall.push({
+                version: pluginManifest.version!,
+                entryPoint: pluginManifest.entryPoint!,
+                dependencies: pluginManifest.dependencies!
+            });
+        }
+
+        // 4. Check for circular dependencies among all registered plugins
+        // This check could also be done when adding a plugin, but doing it before execution is also valid.
+        // For installPlugin, we ensure the overall graph is valid.
+        const circularDeps = dependencyGraph.detectCircularDependencies();
+        if (circularDeps.length > 0) {
+            throw new Error(`Circular dependencies detected in the plugin ecosystem: ${circularDeps.map(c => c.join(' -> ')).join(', ')}`);
+        }
+        
+        // 5. Execute the plugin's entry point in the sandbox
+        // The entry point is expected to be a string of code.
+        const entryPointCode = manifest.entryPoint; // Assuming entryPoint is the code string itself
+        const sandboxContext: SandboxContext = {
+            require: (pluginName: string) => {
+                // This 'require' function will provide access to other installed plugins/dependencies
+                // It needs to look up the resolved versions.
+                const resolvedVersion = resolvedDependencies.get(pluginName);
+                if (!resolvedVersion) {
+                    throw new Error(`Dependency "${pluginName}" not resolved.`);
+                }
+                // In a real scenario, this would return the actual module/function exported by the plugin.
+                // For this simplified example, we might return a placeholder or a mock.
+                // Here, we'll just return an identifier that it's available.
+                return { name: pluginName, version: resolvedVersion, isMock: true };
+            },
+            console: console, // Provide access to console
+            // Add other necessary global objects or utilities if needed
+        };
+
+        let sandboxResult: SandboxResult | null = null;
+        try {
+            sandboxResult = await sandboxedRunner.run(entryPointCode, sandboxContext);
+        } catch (e) {
+            // Rethrow to be caught by the final catch block
+            throw e;
+        }
+
+        // 6. Return the resolved dependency versions and sandbox execution result
+        return {
+            resolvedVersions: Object.fromEntries(resolvedDependencies),
+            executionResult: sandboxResult,
+        };
+    };
+
+    // Expose other methods from individual modules as needed
+    const getPlugin = pluginRegistry.getPluginByName.bind(pluginRegistry);
+    const browsePlugins = pluginRegistry.browsePlugins.bind(pluginRegistry);
+    const searchPlugins = pluginRegistry.searchPlugins.bind(pluginRegistry);
+    const removePluginVersion = pluginRegistry.removePluginVersion.bind(pluginRegistry);
+    
+    const addReview = reviewSystem.addReview.bind(reviewSystem);
+    const getReviews = reviewSystem.getReviews.bind(reviewSystem);
+    const flagReview = reviewSystem.flagReview.bind(reviewSystem);
+    const computeAverageRating = reviewSystem.computeAverageRating.bind(reviewSystem);
+
+    const buildDependencyTree = dependencyGraph.buildDependencyTree.bind(dependencyGraph);
+    const getTopologicalOrder = dependencyGraph.getTopologicalOrder.bind(dependencyGraph);
+    const flattenDependencies = dependencyGraph.flattenDependencies.bind(dependencyGraph);
+
+    const close = () => {
+        pluginRegistry.close();
+        reviewSystem.close();
+        // Note: No explicit close for VersionResolver or SandboxedRunner as they don't hold persistent state.
+        // DependencyGraph might need a clear() if it were stateful and reused across marketplaces,
+        // but here it's built per installPlugin.
+    };
+
+    return {
+        installPlugin,
+        getPlugin,
+        browsePlugins,
+        searchPlugins,
+        removePluginVersion,
+        addReview,
+        getReviews,
+        flagReview,
+        computeAverageRating,
+        buildDependencyTree,
+        getTopologicalOrder,
+        flattenDependencies,
+        close,
+    };
+}
