+import { PluginRegistry } from '../src/pluginRegistry';
+import type { PluginManifest } from '../src/types';
+
+describe('PluginRegistry', () => {
+    let registry: PluginRegistry;
+
+    beforeEach(() => {
+        registry = new PluginRegistry();
+    });
+
+    afterEach(() => {
+        registry.close();
+    });
+
+    it('should add and retrieve a plugin', () => {
+        const manifest: PluginManifest = {
+            name: 'my-plugin',
+            version: '1.0.0',
+            entryPoint: 'console.log("Hello")',
+            description: 'A test plugin',
+            author: 'Test User',
+            dependencies: { 'some-dep': '^1.0.0' },
+        };
+        registry.addPlugin(manifest);
+        const retrieved = registry.getPluginByName('my-plugin');
+
+        expect(retrieved).toBeDefined();
+        expect(retrieved?.name).toBe('my-plugin');
+        expect(retrieved?.version).toBe('1.0.0');
+        expect(retrieved?.entryPoint).toBe('console.log("Hello")');
+        expect(retrieved?.dependencies).toEqual({ 'some-dep': '^1.0.0' });
+        expect(retrieved?.allVersions).toHaveLength(1);
+        expect(retrieved?.allVersions?.[0].version).toBe('1.0.0');
+    });
+
+    it('should add multiple versions of the same plugin', () => {
+        const manifestV1: PluginManifest = {
+            name: 'my-plugin',
+            version: '1.0.0',
+            entryPoint: 'console.log("v1")',
+        };
+        const manifestV2: PluginManifest = {
+            name: 'my-plugin',
+            version: '2.0.0',
+            entryPoint: 'console.log("v2")',
+            dependencies: { 'another-dep': '*' },
+        };
+
+        registry.addPlugin(manifestV1);
+        registry.addPlugin(manifestV2);
+
+        const retrieved = registry.getPluginByName('my-plugin');
+        expect(retrieved).toBeDefined();
+        expect(retrieved?.name).toBe('my-plugin');
+        expect(retrieved?.version).toBe('2.0.0'); // Should return the latest version by default
+        expect(retrieved?.entryPoint).toBe('console.log("v2")');
+        expect(retrieved?.dependencies).toEqual({ 'another-dep': '*' });
+        expect(retrieved?.allVersions).toHaveLength(2);
+        expect(retrieved?.allVersions?.[0].version).toBe('2.0.0');
+        expect(retrieved?.allVersions?.[1].version).toBe('1.0.0');
+    });
+
+    it('should retrieve a specific version of a plugin', () => {
+        const manifestV1: PluginManifest = { name: 'my-plugin', version: '1.0.0', entryPoint: 'console.log("v1")' };
+        const manifestV2: PluginManifest = { name: 'my-plugin', version: '2.0.0', entryPoint: 'console.log("v2")' };
+        registry.addPlugin(manifestV1);
+        registry.addPlugin(manifestV2);
+
+        const retrievedV1 = registry.getPluginVersion('my-plugin', '1.0.0');
+        expect(retrievedV1).toBeDefined();
+        expect(retrievedV1?.version).toBe('1.0.0');
+
+        const retrievedV2 = registry.getPluginVersion('my-plugin', '2.0.0');
+        expect(retrievedV2).toBeDefined();
+        expect(retrievedV2?.version).toBe('2.0.0');
+
+        const nonExistent = registry.getPluginVersion('my-plugin', '3.0.0');
+        expect(nonExistent).toBeUndefined();
+    });
+
+    it('should browse all plugins', () => {
+        const manifest1: PluginManifest = { name: 'plugin-a', version: '1.0.0', entryPoint: 'a' };
+        const manifest2: PluginManifest = { name: 'plugin-b', version: '1.0.0', entryPoint: 'b', description: 'desc' };
+        registry.addPlugin(manifest1);
+        registry.addPlugin(manifest2);
+
+        const plugins = registry.browsePlugins();
+        expect(plugins).toHaveLength(2);
+        expect(plugins.find(p => p.name === 'plugin-a')).toBeDefined();
+        expect(plugins.find(p => p.name === 'plugin-b')?.description).toBe('desc');
+    });
+
+    it('should search plugins by name', () => {
+        const manifest1: PluginManifest = { name: 'alpha-plugin', version: '1.0.0', entryPoint: 'a' };
+        const manifest2: PluginManifest = { name: 'beta-plugin', version: '1.0.0', entryPoint: 'b' };
+        const manifest3: PluginManifest = { name: 'alpha-beta', version: '1.0.0', entryPoint: 'c' };
+        registry.addPlugin(manifest1);
+        registry.addPlugin(manifest2);
+        registry.addPlugin(manifest3);
+
+        const results = registry.searchPlugins({ name: 'alpha' });
+        expect(results).toHaveLength(2);
+        expect(results.map(p => p.name)).toEqual(['alpha-plugin', 'alpha-beta']);
+    });
+    
+    it('should search plugins by author', () => {
+        const manifest1: PluginManifest = { name: 'plugin-a', version: '1.0.0', entryPoint: 'a', author: 'Author One' };
+        const manifest2: PluginManifest = { name: 'plugin-b', version: '1.0.0', entryPoint: 'b', author: 'Author Two' };
+        registry.addPlugin(manifest1);
+        registry.addPlugin(manifest2);
+
+        const results = registry.searchPlugins({ author: 'Author One' });
+        expect(results).toHaveLength(1);
+        expect(results[0].name).toBe('plugin-a');
+    });
+
+    it('should remove a specific version of a plugin', () => {
+        const manifestV1: PluginManifest = { name: 'my-plugin', version: '1.0.0', entryPoint: 'v1' };
+        const manifestV2: PluginManifest = { name: 'my-plugin', version: '2.0.0', entryPoint: 'v2' };
+        registry.addPlugin(manifestV1);
+        registry.addPlugin(manifestV2);
+
+        let retrieved = registry.getPluginByName('my-plugin');
+        expect(retrieved?.allVersions).toHaveLength(2);
+
+        const removed = registry.removePluginVersion('my-plugin', '1.0.0');
+        expect(removed).toBe(true);
+
+        retrieved = registry.getPluginByName('my-plugin');
+        expect(retrieved?.allVersions).toHaveLength(1);
+        expect(retrieved?.version).toBe('2.0.0'); // Latest should remain
+
+        const removedNonExistent = registry.removePluginVersion('my-plugin', '3.0.0');
+        expect(removedNonExistent).toBe(false);
+
+        const removedFromNonExistentPlugin = registry.removePluginVersion('non-existent-plugin', '1.0.0');
+        expect(removedFromNonExistentPlugin).toBe(false);
+    });
+
+    it('should get all registered versions', () => {
+        const manifestV1: PluginManifest = {
+            name: 'plugin-x',
+            version: '1.0.0',
+            entryPoint: 'x1',
+            dependencies: { 'dep1': '1.x' }
+        };
+        const manifestV2: PluginManifest = {
+            name: 'plugin-x',
+            version: '1.1.0',
+            entryPoint: 'x1.1',
+            dependencies: { 'dep2': '2.x' }
+        };
+        registry.addPlugin(manifestV1);
+        registry.addPlugin(manifestV2);
+
+        const allVersions = registry.getAllVersions();
+        expect(allVersions).toHaveLength(2);
+        
+        // Check that the correct versions and dependencies are retrieved
+        const version1 = allVersions.find(v => v.pluginName === 'plugin-x' && v.version === '1.0.0');
+        expect(version1).toBeDefined();
+        expect(version1?.dependencies).toEqual({ 'dep1': '1.x' });
+
+        const version2 = allVersions.find(v => v.pluginName === 'plugin-x' && v.version === '1.1.0');
+        expect(version2).toBeDefined();
+        expect(version2?.dependencies).toEqual({ 'dep2': '2.x' });
+    });
+});
