@@ -0,0 +1,108 @@
+import semver from 'semver';
+import type { VersionConstraint, AvailableVersion } from '../types';
+
+export class VersionResolver {
+    /**
+     * Resolves a list of version constraints against available plugin versions.
+     * @param constraints - An array of version constraints.
+     * @param availableVersions - An array of available plugin versions with their dependencies.
+     * @returns A map where keys are plugin names and values are the resolved versions.
+     * @throws Error if a constraint cannot be satisfied or if circular dependencies are detected.
+     */
+    resolve(
+        constraints: VersionConstraint[],
+        availableVersions: { pluginName: string; version: string; dependencies: { [key: string]: string } }[]
+    ): Map<string, string> {
+        const resolvedVersions = new Map<string, string>();
+        const visited = new Set<string>(); // To detect circular dependencies during resolution
+
+        // Initialize resolvedVersions with explicit constraints if any
+        constraints.forEach(constraint => {
+            if (constraint.version) {
+                resolvedVersions.set(constraint.pluginName, constraint.version);
+            }
+        });
+
+        const resolveSingle = (pluginName: string, constraintVersion?: string): string => {
+            if (visited.has(pluginName)) {
+                // A very basic circular dependency check during resolution.
+                // A more robust check would be in the DependencyGraph module.
+                throw new Error(`Circular dependency detected while resolving ${pluginName}`);
+            }
+            visited.add(pluginName);
+
+            const availableForPlugin = availableVersions.filter(v => v.pluginName === pluginName);
+            if (availableForPlugin.length === 0) {
+                throw new Error(`Plugin "${pluginName}" not found in registry.`);
+            }
+
+            let bestMatch: string | null = null;
+
+            if (constraintVersion) {
+                // Try to satisfy the specific constraint version first
+                const satisfiesConstraint = availableForPlugin.some(v => semver.satisfies(v.version, constraintVersion));
+                if (!satisfiesConstraint) {
+                    throw new Error(`Could not satisfy version constraint "${constraintVersion}" for plugin "${pluginName}". Available: ${availableForPlugin.map(v => v.version).join(', ')}`);
+                }
+                
+                // Find the highest version that satisfies the constraint
+                bestMatch = semver.maxSatisfying(availableForPlugin.map(v => v.version), constraintVersion) || null;
+
+            } else {
+                // If no specific constraint, find the latest version
+                bestMatch = semver.maxSatisfying(availableForPlugin.map(v => v.version), '*') || null;
+            }
+
+            if (!bestMatch) {
+                 throw new Error(`No suitable version found for plugin "${pluginName}" with constraint "${constraintVersion || '*'}"`);
+            }
+            
+            // Once a version is chosen, resolve its dependencies
+            const chosenVersionData = availableForPlugin.find(v => v.version === bestMatch);
+            if (chosenVersionData && chosenVersionData.dependencies) {
+                for (const depName in chosenVersionData.dependencies) {
+                    if (!resolvedVersions.has(depName)) {
+                        const resolvedDepVersion = resolveSingle(depName, chosenVersionData.dependencies[depName]);
+                        resolvedVersions.set(depName, resolvedDepVersion);
+                    } else {
+                        // If already resolved, check for conflicts
+                        const existingVersion = resolvedVersions.get(depName)!;
+                        const requiredVersion = chosenVersionData.dependencies[depName];
+                        if (!semver.satisfies(existingVersion, requiredVersion)) {
+                             throw new Error(`Version conflict for plugin "${depName}". Required by "${pluginName}" as "${requiredVersion}", but already resolved to "${existingVersion}".`);
+                        }
+                        // If it satisfies, no action needed, already resolved.
+                    }
+                }
+            }
+
+            visited.delete(pluginName); // Backtrack for other branches
+            return bestMatch;
+        };
+
+        // Resolve all explicit constraints and their transitive dependencies
+        constraints.forEach(constraint => {
+            if (!resolvedVersions.has(constraint.pluginName)) { // Only resolve if not already set by another dependency
+                const resolved = resolveSingle(constraint.pluginName, constraint.version);
+                resolvedVersions.set(constraint.pluginName, resolved);
+            } else {
+                // If already resolved, ensure it matches the current constraint
+                const existingVersion = resolvedVersions.get(constraint.pluginName)!;
+                if (constraint.version && !semver.satisfies(existingVersion, constraint.version)) {
+                    throw new Error(`Version conflict for plugin "${constraint.pluginName}". Required by direct constraint as "${constraint.version}", but already resolved to "${existingVersion}".`);
+                }
+            }
+        });
+        
+        // Ensure all resolved versions are present in the availableVersions list (this should be guaranteed if resolveSingle works correctly)
+        for(const [name, version] of resolvedVersions.entries()) {
+            const versionExists = availableVersions.some(v => v.pluginName === name && v.version === version);
+            if (!versionExists) {
+                throw new Error(`Internal error: Resolved version ${name}@${version} does not exist in available versions.`);
+            }
+        }
+
+
+        return resolvedVersions;
+    }
+}
