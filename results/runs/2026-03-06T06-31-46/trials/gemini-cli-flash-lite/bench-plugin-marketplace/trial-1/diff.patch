+import { ReviewSystem } from '../src/reviewSystem';
+import type { Review } from '../src/types';
+
+describe('ReviewSystem', () => {
+    let reviewSystem: ReviewSystem;
+
+    beforeEach(() => {
+        reviewSystem = new ReviewSystem();
+    });
+
+    afterEach(() => {
+        reviewSystem.close();
+    });
+
+    it('should add a review', () => {
+        const review: Review = {
+            pluginName: 'test-plugin',
+            userId: 'user-1',
+            rating: 5,
+            comment: 'Great plugin!',
+        };
+        reviewSystem.addReview(review);
+
+        const reviews = reviewSystem.getReviews({ pluginName: 'test-plugin' });
+        expect(reviews).toHaveLength(1);
+        expect(reviews[0].pluginName).toBe('test-plugin');
+        expect(reviews[0].userId).toBe('user-1');
+        expect(reviews[0].rating).toBe(5);
+        expect(reviews[0].comment).toBe('Great plugin!');
+        expect(reviews[0].isFlagged).toBe(false);
+    });
+
+    it('should allow replacing an existing review from the same user', () => {
+        const review1: Review = { pluginName: 'test-plugin', userId: 'user-1', rating: 4, comment: 'Good' };
+        const review2: Review = { pluginName: 'test-plugin', userId: 'user-1', rating: 5, comment: 'Excellent!' };
+        
+        reviewSystem.addReview(review1);
+        reviewSystem.addReview(review2);
+
+        const reviews = reviewSystem.getReviews({ pluginName: 'test-plugin' });
+        expect(reviews).toHaveLength(1);
+        expect(reviews[0].rating).toBe(5);
+        expect(reviews[0].comment).toBe('Excellent!');
+    });
+
+    it('should get reviews for a specific plugin', () => {
+        const review1: Review = { pluginName: 'plugin-a', userId: 'user-1', rating: 4 };
+        const review2: Review = { pluginName: 'plugin-b', userId: 'user-2', rating: 5 };
+        const review3: Review = { pluginName: 'plugin-a', userId: 'user-3', rating: 3 };
+        
+        reviewSystem.addReview(review1);
+        reviewSystem.addReview(review2);
+        reviewSystem.addReview(review3);
+
+        const pluginAReviews = reviewSystem.getReviews({ pluginName: 'plugin-a' });
+        expect(pluginAReviews).toHaveLength(2);
+        expect(pluginAReviews.map(r => r.userId)).toEqual(['user-3', 'user-1']); // Sorted by creation date DESC
+
+        const pluginBReviews = reviewSystem.getReviews({ pluginName: 'plugin-b' });
+        expect(pluginBReviews).toHaveLength(1);
+    });
+
+    it('should get reviews for a specific user', () => {
+        const review1: Review = { pluginName: 'plugin-a', userId: 'user-1', rating: 4 };
+        const review2: Review = { pluginName: 'plugin-b', userId: 'user-2', rating: 5 };
+        const review3: Review = { pluginName: 'plugin-a', userId: 'user-1', rating: 5, comment: 'Updated rating' }; // Overwrites previous review by user-1 for plugin-a
+        
+        reviewSystem.addReview(review1);
+        reviewSystem.addReview(review2);
+        reviewSystem.addReview(review3);
+
+        const user1Reviews = reviewSystem.getReviews({ userId: 'user-1' });
+        expect(user1Reviews).toHaveLength(1);
+        expect(user1Reviews[0].pluginName).toBe('plugin-a');
+        expect(user1Reviews[0].rating).toBe(5);
+
+        const user2Reviews = reviewSystem.getReviews({ userId: 'user-2' });
+        expect(user2Reviews).toHaveLength(1);
+    });
+
+    it('should flag and unflag a review', () => {
+        const review: Review = { pluginName: 'test-plugin', userId: 'user-1', rating: 3 };
+        reviewSystem.addReview(review);
+        
+        const addedReview = reviewSystem.getReviews({ pluginName: 'test-plugin' })[0];
+        expect(addedReview.isFlagged).toBe(false);
+
+        const flagged = reviewSystem.flagReview(addedReview.id);
+        expect(flagged).toBe(true);
+
+        let updatedReview = reviewSystem.getReviews({ pluginName: 'test-plugin' })[0];
+        expect(updatedReview.isFlagged).toBe(true);
+
+        const unflagged = reviewSystem.unflagReview(addedReview.id);
+        expect(unflagged).toBe(true);
+
+        updatedReview = reviewSystem.getReviews({ pluginName: 'test-plugin' })[0];
+        expect(updatedReview.isFlagged).toBe(false);
+    });
+
+    it('should query flagged reviews', () => {
+        const review1: Review = { pluginName: 'plugin-a', userId: 'user-1', rating: 4, isFlagged: true };
+        const review2: Review = { pluginName: 'plugin-b', userId: 'user-2', rating: 5 };
+        const review3: Review = { pluginName: 'plugin-a', userId: 'user-3', rating: 3, isFlagged: false };
+        
+        reviewSystem.addReview(review1);
+        reviewSystem.addReview(review2);
+        reviewSystem.addReview(review3);
+
+        const flaggedReviews = reviewSystem.getReviews({ isFlagged: true });
+        expect(flaggedReviews).toHaveLength(1);
+        expect(flaggedReviews[0].userId).toBe('user-1');
+
+        const unflaggedReviews = reviewSystem.getReviews({ isFlagged: false });
+        expect(unflaggedReviews).toHaveLength(2);
+    });
+
+    it('should compute average rating excluding flagged reviews', () => {
+        const review1: Review = { pluginName: 'test-plugin', userId: 'user-1', rating: 5, isFlagged: false };
+        const review2: Review = { pluginName: 'test-plugin', userId: 'user-2', rating: 4, isFlagged: false };
+        const review3: Review = { pluginName: 'test-plugin', userId: 'user-3', rating: 3, isFlagged: true }; // Flagged
+        const review4: Review = { pluginName: 'test-plugin', userId: 'user-4', rating: 2, isFlagged: false };
+        
+        reviewSystem.addReview(review1);
+        reviewSystem.addReview(review2);
+        reviewSystem.addReview(review3);
+        reviewSystem.addReview(review4);
+
+        // Average of 5, 4, 2 is (5+4+2)/3 = 11/3 = 3.67
+        const avgRating = reviewSystem.computeAverageRating('test-plugin');
+        expect(avgRating).toBe(3.67);
+    });
+    
+    it('should return null for average rating if no non-flagged reviews exist', () => {
+        const review1: Review = { pluginName: 'test-plugin', userId: 'user-1', rating: 5, isFlagged: true };
+        reviewSystem.addReview(review1);
+
+        const avgRating = reviewSystem.computeAverageRating('test-plugin');
+        expect(avgRating).toBeNull();
+    });
+
+    it('should return null for average rating if plugin has no reviews', () => {
+        const avgRating = reviewSystem.computeAverageRating('non-existent-plugin');
+        expect(avgRating).toBeNull();
+    });
+});
