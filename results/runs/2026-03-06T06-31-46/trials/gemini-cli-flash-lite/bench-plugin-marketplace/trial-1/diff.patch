@@ -0,0 +1,107 @@
+import Database from 'better-sqlite3';
+import type { Review, PluginReview, UserReview, ReviewQuery } from '../types';
+
+const DB_PATH = ':memory:'; // Use in-memory database for simplicity
+
+export class ReviewSystem {
+    private db: Database.Database;
+
+    constructor() {
+        this.db = new Database(DB_PATH);
+        this.initializeDatabase();
+    }
+
+    private initializeDatabase() {
+        this.db.exec(`
+            CREATE TABLE IF NOT EXISTS reviews (
+                id INTEGER PRIMARY KEY AUTOINCREMENT,
+                plugin_name TEXT NOT NULL,
+                user_id TEXT NOT NULL,
+                rating INTEGER NOT NULL CHECK (rating >= 1 AND rating <= 5),
+                comment TEXT,
+                is_flagged BOOLEAN NOT NULL DEFAULT FALSE,
+                created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
+                UNIQUE(plugin_name, user_id) -- A user can only review a plugin once
+            );
+            CREATE INDEX IF NOT EXISTS idx_reviews_plugin_name ON reviews(plugin_name);
+            CREATE INDEX IF NOT EXISTS idx_reviews_user_id ON reviews(user_id);
+            CREATE INDEX IF NOT EXISTS idx_reviews_is_flagged ON reviews(is_flagged);
+        `);
+    }
+
+    addReview(review: Review): void {
+        const insert = this.db.prepare(
+            'INSERT OR REPLACE INTO reviews (plugin_name, user_id, rating, comment, is_flagged) VALUES (?, ?, ?, ?, ?)'
+        );
+        insert.run(review.pluginName, review.userId, review.rating, review.comment, review.isFlagged || false);
+    }
+
+    getReviews(query: ReviewQuery = {}): (PluginReview | UserReview)[] {
+        let sql = `
+            SELECT id, plugin_name, user_id, rating, comment, is_flagged, created_at
+            FROM reviews
+        `;
+        const params: (string | number | boolean)[] = [];
+        const conditions: string[] = [];
+
+        if (query.pluginName) {
+            conditions.push('plugin_name = ?');
+            params.push(query.pluginName);
+        }
+        if (query.userId) {
+            conditions.push('user_id = ?');
+            params.push(query.userId);
+        }
+        if (query.isFlagged !== undefined) {
+            conditions.push('is_flagged = ?');
+            params.push(query.isFlagged);
+        }
+        if (query.excludeFlagged) {
+            conditions.push('is_flagged = FALSE');
+        }
+
+        if (conditions.length > 0) {
+            sql += ' WHERE ' + conditions.join(' AND ');
+        }
+
+        sql += ' ORDER BY created_at DESC';
+
+        const rows = this.db.prepare(sql).all(params) as any[];
+
+        return rows.map(row => ({
+            id: row.id,
+            pluginName: row.plugin_name,
+            userId: row.user_id,
+            rating: row.rating,
+            comment: row.comment,
+            isFlagged: !!row.is_flagged,
+            createdAt: new Date(row.created_at),
+        }));
+    }
+
+    flagReview(reviewId: number): boolean {
+        const update = this.db.prepare('UPDATE reviews SET is_flagged = TRUE WHERE id = ?');
+        const result = update.run(reviewId);
+        return result.changes > 0;
+    }
+
+    unflagReview(reviewId: number): boolean {
+        const update = this.db.prepare('UPDATE reviews SET is_flagged = FALSE WHERE id = ?');
+        const result = update.run(reviewId);
+        return result.changes > 0;
+    }
+
+    computeAverageRating(pluginName: string): number | null {
+        const query = `
+            SELECT AVG(rating) as average_rating
+            FROM reviews
+            WHERE plugin_name = ? AND is_flagged = FALSE
+        `;
+        const row = this.db.prepare(query).get(pluginName) as { average_rating: number | null };
+        return row.average_rating !== null ? parseFloat(row.average_rating.toFixed(2)) : null;
+    }
+
+    close() {
+        this.db.close();
+    }
+}
