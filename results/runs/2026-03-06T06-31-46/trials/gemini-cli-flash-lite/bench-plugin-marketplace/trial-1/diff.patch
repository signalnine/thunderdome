+import { DependencyGraph } from '../src/dependencyGraph';
+import type { PluginVersion } from '../src/types';
+
+describe('DependencyGraph', () => {
+    let graph: DependencyGraph;
+
+    beforeEach(() => {
+        graph = new DependencyGraph();
+    });
+
+    it('should add a plugin and its dependencies', () => {
+        const pluginA: PluginVersion = { version: '1.0.0', entryPoint: '', dependencies: { 'B': '^1.0.0', 'C': '2.x' } };
+        graph.add('A', pluginA);
+
+        const pluginB: PluginVersion = { version: '1.0.0', entryPoint: '', dependencies: {} };
+        graph.add('B', pluginB);
+
+        const pluginC: PluginVersion = { version: '2.1.0', entryPoint: '', dependencies: {} };
+        graph.add('C', pluginC);
+
+        // Test to see if graph is built correctly
+        // Need to simulate build from allVersions for graph.build method to be used properly,
+        // but direct add is for internal logic testing here.
+
+        // The graph object itself is not directly inspectable in terms of its internal Map.
+        // We will test its public methods which rely on the internal structure.
+    });
+
+    it('should build the graph from all available versions', () => {
+        const allVersions = [
+            { pluginName: 'A', version: '1.0.0', dependencies: { 'B': '^1.0.0' } },
+            { pluginName: 'A', version: '1.1.0', dependencies: { 'C': '2.x' } },
+            { pluginName: 'B', version: '1.0.0', dependencies: {} },
+            { pluginName: 'C', version: '2.1.0', dependencies: {} },
+        ];
+        graph.build(allVersions);
+
+        // How to assert graph state after build?
+        // We can use other methods like detectCircularDependencies or getTopologicalOrder.
+        // For now, let's check if topological order works as expected.
+        const order = graph.getTopologicalOrder();
+        expect(order).toEqual(['B', 'C', 'A']); // B and C have no dependencies, A depends on B and C (implicitly via 1.1.0)
+    });
+
+    it('should detect circular dependencies', () => {
+        const allVersions = [
+            { pluginName: 'A', version: '1.0.0', dependencies: { 'B': '1.0.0' } },
+            { pluginName: 'B', version: '1.0.0', dependencies: { 'C': '1.0.0' } },
+            { pluginName: 'C', version: '1.0.0', dependencies: { 'A': '1.0.0' } }, // A -> B -> C -> A
+        ];
+        graph.build(allVersions);
+        const cycles = graph.detectCircularDependencies();
+        expect(cycles).toHaveLength(1);
+        expect(cycles[0]).toEqual(['A', 'B', 'C', 'A']);
+    });
+    
+    it('should detect multiple circular dependencies', () => {
+        const allVersions = [
+            { pluginName: 'A', version: '1.0.0', dependencies: { 'B': '1.0.0' } },
+            { pluginName: 'B', version: '1.0.0', dependencies: { 'A': '1.0.0' } }, // A <-> B
+            { pluginName: 'C', version: '1.0.0', dependencies: { 'D': '1.0.0' } },
+            { pluginName: 'D', version: '1.0.0', dependencies: { 'C': '1.0.0' } }, // C <-> D
+        ];
+        graph.build(allVersions);
+        const cycles = graph.detectCircularDependencies();
+        expect(cycles).toHaveLength(2);
+        // Order might vary, so check for presence of cycles
+        expect(cycles).toContainEqual(['A', 'B', 'A']);
+        expect(cycles).toContainEqual(['C', 'D', 'C']);
+    });
+
+    it('should produce a topological ordering', () => {
+        const allVersions = [
+            { pluginName: 'A', version: '1.0.0', dependencies: {} }, // Leaf
+            { pluginName: 'B', version: '1.0.0', dependencies: { 'A': '1.0.0' } },
+            { pluginName: 'C', version: '1.0.0', dependencies: { 'A': '1.0.0', 'B': '1.0.0' } },
+            { pluginName: 'D', version: '1.0.0', dependencies: { 'C': '1.0.0' } },
+        ];
+        graph.build(allVersions);
+        const order = graph.getTopologicalOrder();
+        // Expected: A, B, C, D (A must come first, B depends on A, C depends on A and B, D depends on C)
+        expect(order).toEqual(['A', 'B', 'C', 'D']);
+    });
+
+    it('should throw error on topological ordering if circular dependency exists', () => {
+        const allVersions = [
+            { pluginName: 'A', version: '1.0.0', dependencies: { 'B': '1.0.0' } },
+            { pluginName: 'B', version: '1.0.0', dependencies: { 'A': '1.0.0' } },
+        ];
+        graph.build(allVersions);
+        expect(() => graph.getTopologicalOrder()).toThrow(/Circular dependencies detected/);
+    });
+
+    it('should flatten dependencies for a given plugin', () => {
+        const allVersions = [
+            { pluginName: 'A', version: '1.0.0', dependencies: {} },
+            { pluginName: 'B', version: '1.0.0', dependencies: { 'A': '1.0.0' } },
+            { pluginName: 'C', version: '1.0.0', dependencies: { 'A': '1.0.0', 'B': '1.0.0' } },
+            { pluginName: 'D', version: '1.0.0', dependencies: { 'C': '1.0.0' } },
+            { pluginName: 'E', version: '1.0.0', dependencies: { 'C': '1.0.0', 'F': '1.0.0' } },
+            { pluginName: 'F', version: '1.0.0', dependencies: {} },
+        ];
+        graph.build(allVersions);
+
+        const flattenedD = graph.flattenDependencies('D');
+        expect(flattenedD).toEqual(expect.arrayContaining(['A', 'B', 'C'])); // Order doesn't matter for flatten
+        expect(flattenedD).toHaveLength(3);
+
+        const flattenedE = graph.flattenDependencies('E');
+        expect(flattenedE).toEqual(expect.arrayContaining(['A', 'B', 'C', 'F']));
+        expect(flattenedE).toHaveLength(4);
+        
+        const flattenedA = graph.flattenDependencies('A');
+        expect(flattenedA).toEqual([]);
+    });
+
+    it('should build a dependency tree', () => {
+        const allVersions = [
+            { pluginName: 'A', version: '1.0.0', dependencies: {} },
+            { pluginName: 'B', version: '1.0.0', dependencies: { 'A': '1.0.0' } },
+            { pluginName: 'C', version: '1.0.0', dependencies: { 'A': '1.0.0', 'B': '1.0.0' } },
+        ];
+        graph.build(allVersions);
+
+        const treeC = graph.buildDependencyTree('C');
+        expect(treeC).toEqual({
+            id: 'C',
+            children: [
+                { id: 'A', children: [] },
+                { id: 'B', children: [{ id: 'A', children: [] }] },
+            ],
+        });
+
+        const treeB = graph.buildDependencyTree('B');
+        expect(treeB).toEqual({
+            id: 'B',
+            children: [{ id: 'A', children: [] }],
+        });
+
+        const treeA = graph.buildDependencyTree('A');
+        expect(treeA).toEqual({ id: 'A', children: [] });
+    });
+    
+    it('should indicate cycle in dependency tree', () => {
+        const allVersions = [
+            { pluginName: 'A', version: '1.0.0', dependencies: { 'B': '1.0.0' } },
+            { pluginName: 'B', version: '1.0.0', dependencies: { 'A': '1.0.0' } },
+        ];
+        graph.build(allVersions);
+
+        const tree = graph.buildDependencyTree('A');
+        expect(tree).toEqual({
+            id: 'A',
+            children: [{ id: 'B', children: [{ id: 'A (cycle detected)', children: [] }] }],
+        });
+    });
+
+    it('should return null if building tree for non-existent plugin', () => {
+        const allVersions = [
+            { pluginName: 'A', version: '1.0.0', dependencies: {} },
+        ];
+        graph.build(allVersions);
+        const tree = graph.buildDependencyTree('non-existent');
+        expect(tree).toBeNull();
+    });
+});
