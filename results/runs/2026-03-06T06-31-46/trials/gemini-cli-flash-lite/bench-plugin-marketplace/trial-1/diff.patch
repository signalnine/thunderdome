+import type { PluginManifest, PluginVersion } from '../types';
+
+interface GraphNode {
+    id: string; // Plugin name
+    dependencies: string[];
+}
+
+export class DependencyGraph {
+    private graph: Map<string, GraphNode> = new Map();
+
+    /**
+     * Adds a plugin and its dependencies to the graph.
+     * @param pluginName - The name of the plugin.
+     * @param versionData - The version data including its dependencies.
+     */
+    add(pluginName: string, versionData: PluginVersion): void {
+        if (!this.graph.has(pluginName)) {
+            this.graph.set(pluginName, { id: pluginName, dependencies: [] });
+        }
+        const node = this.graph.get(pluginName)!;
+        // Ensure dependencies are unique and non-empty
+        const newDependencies = Object.keys(versionData.dependencies || {}).filter(dep => dep !== pluginName);
+        node.dependencies = [...new Set([...node.dependencies, ...newDependencies])];
+    }
+
+    /**
+     * Builds the dependency graph from a list of all available plugin versions.
+     * @param allVersions - All available plugin versions with their dependencies.
+     */
+    build(allVersions: { pluginName: string; version: string; dependencies: { [key: string]: string } }[]): void {
+        this.graph.clear();
+        allVersions.forEach(versionInfo => {
+            this.add(versionInfo.pluginName, {
+                version: versionInfo.version,
+                entryPoint: '', // Not needed for graph structure
+                dependencies: versionInfo.dependencies,
+            });
+        });
+    }
+
+    /**
+     * Detects circular dependencies using Depth First Search.
+     * @returns An array of cycles, where each cycle is an array of plugin names.
+     */
+    detectCircularDependencies(): string[][] {
+        const cycles: string[][] = [];
+        const visited: Set<string> = new Set();
+        const recursionStack: Set<string> = new Set();
+
+        const dfs = (nodeId: string, path: string[]): void => {
+            visited.add(nodeId);
+            recursionStack.add(nodeId);
+            path.push(nodeId);
+
+            const node = this.graph.get(nodeId);
+            if (node) {
+                for (const dependency of node.dependencies) {
+                    if (!visited.has(dependency)) {
+                        dfs(dependency, path);
+                    } else if (recursionStack.has(dependency)) {
+                        // Found a cycle
+                        const cycleStartIndex = path.indexOf(dependency);
+                        cycles.push([...path.slice(cycleStartIndex), dependency]);
+                    }
+                }
+            }
+
+            recursionStack.delete(nodeId);
+            path.pop();
+        };
+
+        for (const nodeId of this.graph.keys()) {
+            if (!visited.has(nodeId)) {
+                dfs(nodeId, []);
+            }
+        }
+
+        return cycles;
+    }
+
+    /**
+     * Produces a topological ordering of the plugins.
+     * @returns An array of plugin names in topological order, or throws an error if a cycle is detected.
+     */
+    getTopologicalOrder(): string[] {
+        const cycles = this.detectCircularDependencies();
+        if (cycles.length > 0) {
+            throw new Error(`Circular dependencies detected: ${cycles.map(c => c.join(' -> ')).join(', ')}`);
+        }
+
+        const sorted: string[] = [];
+        const visited: Set<string> = new Set();
+        const visiting: Set<string> = new Set(); // For detecting cycles (though already checked, good practice)
+
+        const visit = (nodeId: string): void => {
+            if (visiting.has(nodeId)) {
+                // This should ideally not happen due to prior cycle detection, but good as a safeguard.
+                throw new Error(`Cycle detected during topological sort: ${nodeId}`);
+            }
+            if (!visited.has(nodeId)) {
+                visiting.add(nodeId);
+                const node = this.graph.get(nodeId);
+                if (node) {
+                    for (const dependency of node.dependencies) {
+                        visit(dependency);
+                    }
+                }
+                visiting.delete(nodeId);
+                visited.add(nodeId);
+                sorted.push(nodeId);
+            }
+        };
+
+        for (const nodeId of this.graph.keys()) {
+            visit(nodeId);
+        }
+
+        // The sorted list is in reverse topological order (dependencies come before dependents)
+        // We want dependents to be executed AFTER dependencies, so we reverse it.
+        return sorted.reverse();
+    }
+
+    /**
+     * Flattens transitive dependencies for a given plugin.
+     * @param pluginName - The name of the plugin to flatten dependencies for.
+     * @returns An array of plugin names representing the flattened dependency list.
+     */
+    flattenDependencies(pluginName: string): string[] {
+        const flattened: Set<string> = new Set();
+        const visited: Set<string> = new Set();
+
+        const traverse = (currentPlugin: string): void => {
+            if (visited.has(currentPlugin)) {
+                return;
+            }
+            visited.add(currentPlugin);
+
+            const node = this.graph.get(currentPlugin);
+            if (node) {
+                for (const dependency of node.dependencies) {
+                    if (!flattened.has(dependency)) {
+                        flattened.add(dependency);
+                        traverse(dependency);
+                    }
+                }
+            }
+        };
+
+        traverse(pluginName);
+        return Array.from(flattened);
+    }
+
+    /**
+     * Builds a dependency tree for a given plugin.
+     * This is a simplified tree representation, not a full graph visualization.
+     * @param pluginName - The name of the root plugin.
+     * @returns A tree-like structure representing dependencies.
+     */
+    buildDependencyTree(pluginName: string): { id: string; children: any[] } | null {
+        const visited: Set<string> = new Set();
+
+        const buildNode = (currentPlugin: string): { id: string; children: any[] } | null => {
+            if (visited.has(currentPlugin)) {
+                // Cycle detected, return a placeholder or indicate cycle
+                return { id: `${currentPlugin} (cycle detected)`, children: [] };
+            }
+            visited.add(currentPlugin);
+
+            const node = this.graph.get(currentPlugin);
+            if (!node) {
+                return null; // Plugin not in graph
+            }
+
+            const children = (node.dependencies || [])
+                .map(dep => buildNode(dep))
+                .filter(child => child !== null); // Filter out nulls if a dependency wasn't found
+
+            visited.delete(currentPlugin); // Backtrack for other branches
+            return { id: currentPlugin, children: children as { id: string; children: any[] }[] };
+        };
+
+        return buildNode(pluginName);
+    }
+}
