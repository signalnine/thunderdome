+import { SandboxedRunner } from '../src/sandboxedRunner';
+import type { SandboxContext } from '../src/types';
+
+// Helper to expose gc if available
+// eslint-disable-next-line @typescript-eslint/no-explicit-any
+const exposeGc = (global as any).gc;
+
+describe('SandboxedRunner', () => {
+    let runner: SandboxedRunner;
+
+    beforeEach(() => {
+        // Temporarily provide a mock gc function if it's not available, to avoid errors in tests
+        // In a real Node.js environment with --expose-gc, this would be the actual function.
+        if (!exposeGc) {
+            // eslint-disable-next-line @typescript-eslint/no-explicit-any
+            (global as any).gc = jest.fn();
+        }
+        runner = new SandboxedRunner(5000); // Default timeout of 5 seconds
+    });
+
+    afterEach(() => {
+        // Restore original gc or remove mock
+        // eslint-disable-next-line @typescript-eslint/no-explicit-any
+        if (!exposeGc) {
+            // eslint-disable-next-line @typescript-eslint/no-explicit-any
+            delete (global as any).gc;
+        }
+    });
+
+    it('should execute simple code and return output', async () => {
+        const code = 'return 1 + 2;';
+        const result = await runner.run(code);
+
+        expect(result.success).toBe(true);
+        expect(result.output).toBe(3);
+        expect(result.error).toBeNull();
+        expect(result.exitCode).toBe(0);
+        expect(result.timing.duration).toBeGreaterThanOrEqual(0);
+        expect(result.memory.start_bytes).toBeDefined(); // Expect memory info
+    });
+
+    it('should execute code with context variables', async () => {
+        const code = 'return message.toUpperCase() + " " + count;';
+        const context: SandboxContext = { message: 'hello', count: 5 };
+        const result = await runner.run(code, context);
+
+        expect(result.success).toBe(true);
+        expect(result.output).toBe('HELLO 5');
+    });
+
+    it('should handle promises returned by the code', async () => {
+        const code = 'return Promise.resolve("resolved value");';
+        const result = await runner.run(code);
+
+        expect(result.success).toBe(true);
+        expect(result.output).toBe('resolved value');
+    });
+
+    it('should handle asynchronous operations within the sandbox', async () => {
+        const code = `
+            return new Promise(resolve => {
+                setTimeout(() => resolve("delayed result"), 100);
+            });
+        `;
+        const result = await runner.run(code);
+
+        expect(result.success).toBe(true);
+        expect(result.output).toBe('delayed result');
+        expect(result.timing.duration).toBeGreaterThanOrEqual(100);
+    });
+
+    it('should return an error result for code that throws an exception', async () => {
+        const code = 'throw new Error("Something went wrong");';
+        const result = await runner.run(code);
+
+        expect(result.success).toBe(false);
+        expect(result.output).toBeNull();
+        expect(result.error).toBeDefined();
+        expect(result.error?.message).toBe('Something went wrong');
+        expect(result.exitCode).toBe(1); // Default exit code for errors
+    });
+
+    it('should return an error result for syntax errors', async () => {
+        const code = 'return 1 + ;'; // Invalid syntax
+        const result = await runner.run(code);
+
+        expect(result.success).toBe(false);
+        expect(result.output).toBeNull();
+        expect(result.error).toBeDefined();
+        // The exact error message might vary slightly between Node versions,
+        // but it should indicate a syntax error.
+        expect(result.error?.message).toMatch(/Unexpected token/);
+        expect(result.exitCode).toBe(1);
+    });
+
+    it('should enforce execution timeout', async () => {
+        const code = `
+            // This code will intentionally run longer than the default timeout
+            let start = Date.now();
+            while (Date.now() - start < 2000) { // runs for 2 seconds
+                // busy loop
+            }
+            return "completed";
+        `;
+        // Use a short timeout for this test to ensure it fires
+        const shortTimeoutRunner = new SandboxedRunner(500); // 500ms timeout
+        const result = await shortTimeoutRunner.run(code);
+
+        expect(result.success).toBe(false);
+        expect(result.output).toBeNull();
+        expect(result.error).toBeDefined();
+        expect(result.error?.message).toMatch(/script timeout/i);
+        expect(result.exitCode).toBeDefined(); // Exit code for timeout might be specific or default
+    });
+
+    it('should provide accurate timing information', async () => {
+        const code = 'return Promise.resolve("done");';
+        const startTime = Date.now();
+        const result = await runner.run(code);
+        const endTime = Date.now();
+
+        expect(result.success).toBe(true);
+        expect(result.timing.start).toBe(startTime);
+        expect(result.timing.end).toBeGreaterThanOrEqual(startTime);
+        expect(result.timing.duration).toBe(result.timing.end - result.timing.start);
+        expect(result.timing.duration).toBeGreaterThanOrEqual(0);
+    });
+
+    it('should provide memory usage information if gc is exposed', async () => {
+        // This test relies on global.gc being available.
+        // If it's not, the memory fields will be 0.
+        const code = 'return "memory test";';
+        const result = await runner.run(code);
+
+        expect(result.memory.start_bytes).toBeDefined();
+        expect(result.memory.end_bytes).toBeDefined();
+        expect(result.memory.diff_bytes).toBeDefined();
+
+        // If gc was not exposed, start_bytes and end_bytes will be 0
+        if (!exposeGc) {
+            expect(result.memory.start_bytes).toBe(0);
+            expect(result.memory.end_bytes).toBe(0);
+        } else {
+            // Expect some memory usage, though exact values are hard to predict
+            expect(result.memory.start_bytes).toBeGreaterThanOrEqual(0);
+            expect(result.memory.end_bytes).toBeGreaterThanOrEqual(0);
+        }
+    });
+    
+    it('should handle code that modifies context', async () => {
+        const code = `
+            context.value = 'modified';
+            return context.value;
+        `;
+        const context = { value: 'initial' };
+        const result = await runner.run(code, context);
+
+        expect(result.success).toBe(true);
+        expect(result.output).toBe('modified');
+        expect(context.value).toBe('modified'); // Verify context modification
+    });
+});
diff --git a/__tests__/versionResolver.test.ts b/__tests__/versionResolver.test.ts
new file mode 100644
index 0000000..25a3c4b
--- /dev/null
+++ b/__tests__/versionResolver.test.ts
@@ -0,0 +1,139 @@
+import { VersionResolver } from '../src/versionResolver';
+import type { VersionConstraint } from '../src/types';
+
+describe('VersionResolver', () => {
+    let resolver: VersionResolver;
+    const availableVersions = [
+        { pluginName: 'A', version: '1.0.0', dependencies: {} },
+        { pluginName: 'A', version: '1.1.0', dependencies: { 'B': '^2.0.0' } },
+        { pluginName: 'A', version: '2.0.0', dependencies: { 'B': '3.x' } },
+        { pluginName: 'B', version: '2.0.0', dependencies: {} },
+        { pluginName: 'B', version: '2.1.0', dependencies: {} },
+        { pluginName: 'B', version: '3.0.0', dependencies: {} },
+        { pluginName: 'C', version: '1.0.0', dependencies: { 'A': '1.x' } },
+        { pluginName: 'D', version: '1.0.0', dependencies: { 'A': '1.0.0', 'B': '2.0.0' } },
+        { pluginName: 'E', version: '1.0.0', dependencies: { 'F': '1.0.0' } },
+        { pluginName: 'F', version: '1.0.0', dependencies: { 'E': '1.0.0' } }, // Circular dep E <-> F
+    ];
+
+    beforeEach(() => {
+        resolver = new VersionResolver();
+    });
+
+    it('should resolve a single plugin with no constraints', () => {
+        const constraints: VersionConstraint[] = [{ pluginName: 'A' }];
+        const resolved = resolver.resolve(constraints, availableVersions);
+        expect(resolved.size).toBe(1);
+        expect(resolved.get('A')).toBe('2.0.0'); // Latest version of A
+    });
+
+    it('should resolve a single plugin with a specific version constraint', () => {
+        const constraints: VersionConstraint[] = [{ pluginName: 'A', version: '^1.0.0' }];
+        const resolved = resolver.resolve(constraints, availableVersions);
+        expect(resolved.size).toBe(1);
+        expect(resolved.get('A')).toBe('1.1.0'); // Highest version satisfying '^1.0.0'
+    });
+
+    it('should resolve direct dependencies', () => {
+        const constraints: VersionConstraint[] = [{ pluginName: 'D' }]; // D depends on A and B
+        const resolved = resolver.resolve(constraints, availableVersions);
+        expect(resolved.size).toBe(3); // D, A, B
+        expect(resolved.get('D')).toBe('1.0.0');
+        expect(resolved.get('A')).toBe('2.0.0'); // D requires A@1.0.0, but latest that satisfies the overall graph might be higher. This logic needs refinement in actual resolve.
+        // The current resolveSingle logic picks the latest for the root, then resolves dependencies.
+        // Let's re-evaluate the expected behavior. If D requires A@1.0.0 and B@2.0.0, then those should be picked.
+        // The `resolveSingle` picks latest if constraintVersion is not provided for dependencies.
+        // Let's test with a constraint that forces a specific version.
+
+        // Test case: D requires A@1.0.0 and B@2.0.0.
+        // Based on current implementation, it finds latest for D, then resolves its deps.
+        // D@1.0.0 -> A@1.0.0, B@2.0.0
+        // The `resolveSingle` for 'A' and 'B' when called from 'D' will pick latest if no constraint.
+        // This is where the test might fail if the interpretation of 'resolve' is different.
+        // If D itself needs to be installed, and its dependencies are A@1.0.0 and B@2.0.0,
+        // then the `resolveSingle` for 'A' should use '1.0.0' and for 'B' should use '2.0.0'.
+        // The current `resolveSingle` uses `constraintVersion` if provided.
+        // If `constraintVersion` is missing (like for B when D calls resolveSingle('B')), it picks latest.
+
+        // Let's re-align expected values based on how `resolveSingle` works:
+        // 1. `resolveSingle('D', undefined)` -> finds latest D (only 1.0.0). returns '1.0.0'
+        // 2. `resolvedVersions` is {'D': '1.0.0'}
+        // 3. D's dependencies: A@1.0.0, B@2.0.0
+        // 4. `resolveSingle('A', '1.0.0')` -> finds '1.0.0' for A. returns '1.0.0'
+        // 5. `resolvedVersions` is {'D': '1.0.0', 'A': '1.0.0'}
+        // 6. `resolveSingle('B', '2.0.0')` -> finds '2.0.0' for B. returns '2.0.0'
+        // 7. `resolvedVersions` is {'D': '1.0.0', 'A': '1.0.0', 'B': '2.0.0'}
+        // This seems correct.
+
+        expect(resolved.get('D')).toBe('1.0.0');
+        expect(resolved.get('A')).toBe('1.0.0'); // Should resolve to the specific version required by D
+        expect(resolved.get('B')).toBe('2.0.0'); // Should resolve to the specific version required by D
+    });
+
+    it('should resolve transitive dependencies', () => {
+        const constraints: VersionConstraint[] = [{ pluginName: 'C' }]; // C depends on A, A depends on B
+        const resolved = resolver.resolve(constraints, availableVersions);
+        expect(resolved.size).toBe(3); // C, A, B
+        expect(resolved.get('C')).toBe('1.0.0');
+        expect(resolved.get('A')).toBe('1.0.0'); // C requires A@1.x. A@1.0.0 is chosen as it satisfies 1.x and has no higher 1.x version.
+        expect(resolved.get('B')).toBe('2.1.0'); // A@1.0.0 requires B@^2.0.0. The latest version of B that satisfies ^2.0.0 is 2.1.0.
+    });
+
+    it('should handle version conflicts', () => {
+        const conflictingVersions = [
+            { pluginName: 'A', version: '1.0.0', dependencies: { 'C': '1.0.0' } },
+            { pluginName: 'B', version: '1.0.0', dependencies: { 'C': '2.0.0' } },
+            { pluginName: 'C', version: '1.0.0', dependencies: {} },
+            { pluginName: 'C', version: '2.0.0', dependencies: {} },
+        ];
+        const constraints: VersionConstraint[] = [{ pluginName: 'A' }, { pluginName: 'B' }];
+        // A will resolve to 1.0.0, requiring C@1.0.0.
+        // B will resolve to 1.0.0, requiring C@2.0.0.
+        // This should cause a conflict for C.
+        expect(() => resolver.resolve(constraints, conflictingVersions)).toThrow(/Version conflict for plugin "C"/);
+    });
+
+    it('should detect circular dependencies', () => {
+        const constraints: VersionConstraint[] = [{ pluginName: 'E' }]; // E -> F, F -> E
+        expect(() => resolver.resolve(constraints, availableVersions)).toThrow(/Circular dependency detected/);
+    });
+
+    it('should throw an error if a plugin is not found', () => {
+        const constraints: VersionConstraint[] = [{ pluginName: 'non-existent-plugin' }];
+        expect(() => resolver.resolve(constraints, availableVersions)).toThrow(/Plugin "non-existent-plugin" not found/);
+    });
+
+    it('should throw an error if a version constraint cannot be satisfied', () => {
+        const constraints: VersionConstraint[] = [{ pluginName: 'A', version: '>=3.0.0' }];
+        expect(() => resolver.resolve(constraints, availableVersions)).toThrow(/Could not satisfy version constraint/);
+    });
+
+    it('should handle plugins with no dependencies', () => {
+        const constraints: VersionConstraint[] = [{ pluginName: 'A', version: '1.0.0' }];
+        const resolved = resolver.resolve(constraints, availableVersions);
+        expect(resolved.size).toBe(1);
+        expect(resolved.get('A')).toBe('1.0.0');
+    });
+    
+    it('should resolve direct dependencies correctly when specific versions are requested', () => {
+        const constraints: VersionConstraint[] = [{ pluginName: 'D', version: '1.0.0' }]; // D@1.0.0 depends on A@1.0.0 and B@2.0.0
+        const resolved = resolver.resolve(constraints, availableVersions);
+        expect(resolved.size).toBe(3);
+        expect(resolved.get('D')).toBe('1.0.0');
+        expect(resolved.get('A')).toBe('1.0.0');
+        expect(resolved.get('B')).toBe('2.0.0');
+    });
+
+    it('should resolve versions when multiple versions satisfy a range constraint', () => {
+        const versions = [
+            { pluginName: 'A', version: '1.0.0', dependencies: {} },
+            { pluginName: 'A', version: '1.1.0', dependencies: {} },
+            { pluginName: 'A', version: '1.2.0', dependencies: {} },
+            { pluginName: 'A', version: '2.0.0', dependencies: {} },
+        ];
+        const constraints: VersionConstraint[] = [{ pluginName: 'A', version: '1.x' }];
+        const resolved = resolver.resolve(constraints, versions);
+        expect(resolved.size).toBe(1);
+        expect(resolved.get('A')).toBe('1.2.0'); // Should pick the highest version in the 1.x range
+    });
+});
