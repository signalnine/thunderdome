+
+interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;   // input wire name
+  in2: string;   // input wire name
+  out: string;   // output wire name
+}
+
+/**
+ * Simulates a logic gate circuit.
+ *
+ * @param gates An array of gates describing the circuit.
+ * @param inputs An object mapping input wire names to their initial values (0 or 1).
+ * @returns An object mapping all wire names to their final values.
+ */
+export function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number> {
+    const wireValues: Record<string, number> = { ...inputs };
+    let remainingGates = [...gates];
+
+    // Keep track of which wires are defined to avoid infinite loops on missing inputs
+    const definedWires = new Set(Object.keys(inputs));
+
+    while (remainingGates.length > 0) {
+        const nextRemainingGates: Gate[] = [];
+        let gatesProcessedInThisPass = 0;
+
+        for (const gate of remainingGates) {
+            const input1Value = wireValues[gate.in1];
+            const input2Value = wireValues[gate.in2];
+
+            // Check if both inputs are defined and have values
+            if (input1Value !== undefined && input2Value !== undefined) {
+                let outputValue: number;
+                switch (gate.op) {
+                    case 'AND':
+                        outputValue = input1Value & input2Value;
+                        break;
+                    case 'OR':
+                        outputValue = input1Value | input2Value;
+                        break;
+                    case 'XOR':
+                        outputValue = input1Value ^ input2Value;
+                        break;
+                    default:
+                        // This case should ideally not be reached due to TypeScript typing
+                        throw new Error(`Unknown gate operation: ${gate.op}`);
+                }
+
+                // Assign the output value to the wire
+                if (wireValues[gate.out] === undefined) { // Only update if not already set (e.g. from inputs directly)
+                    wireValues[gate.out] = outputValue;
+                    definedWires.add(gate.out);
+                    gatesProcessedInThisPass++;
+                } else if (wireValues[gate.out] !== outputValue) {
+                    // This indicates a conflict if a wire is driven by multiple gates,
+                    // which shouldn't happen in a well-formed circuit definition.
+                    // However, if the problem implies some wires might be targets of swaps,
+                    // this could be a sign. For simulation, we assume unique outputs.
+                    // If wireValues[gate.out] was set by an input, it's an issue with input.
+                    // For now, let's assume simple acyclic graph, unique outputs.
+                }
+            } else {
+                // If inputs are not defined, keep the gate for the next pass
+                nextRemainingGates.push(gate);
+            }
+        }
+
+        if (gatesProcessedInThisPass === 0 && nextRemainingGates.length > 0) {
+            // If no gates were processed in a pass and there are still gates left,
+            // it implies a dependency cycle or missing input wires that are not provided.
+            // The problem statement guarantees acyclic circuits, so this indicates missing inputs.
+            // For robustness, we can log an error or throw.
+            // console.error("Simulation stuck: Cannot process remaining gates. Check for missing input wires.");
+            // For the purpose of this problem, we assume valid inputs are provided for simulation.
+            // If this error occurs, it might mean an input wire required by a gate was not in the initial 'inputs' object.
+            break; // Avoid infinite loop
+        }
+
+        remainingGates = nextRemainingGates;
+    }
+
+    return wireValues;
+}
