+/**
+ * Helper function to parse bit wire names like "x00", "y12", "z3"
+ * Returns null if the wire name does not follow the pattern.
+ */
+function parseBitWire(wireName: string): { type: 'x' | 'y' | 'z' | 'c', index: number } | null {
+    const match = wireName.match(/^([xy z c])(\d+)$/i); // Added 'c' to the character class
+    if (match) {
+        const type = match[1].toLowerCase() as 'x' | 'y' | 'z' | 'c'; // Broadened type assertion
+        const index = parseInt(match[2], 10);
+        if (type === 'z') {
+             return { type: 'z', index: index };
+        }
+        if (type === 'c') {
+             return { type: 'c', index: index };
+        }
+        // If type is 'x' or 'y', it falls through to here.
+        return { type: type as 'x' | 'y', index: index }; // This will now correctly assert type as 'x' or 'y'
+    }
+    return null;
+}
