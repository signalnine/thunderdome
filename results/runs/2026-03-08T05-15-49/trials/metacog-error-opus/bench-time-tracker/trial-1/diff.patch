+import { describe, it, expect, beforeEach, afterEach } from "vitest";
+import * as fs from "node:fs";
+import * as path from "node:path";
+import * as os from "node:os";
+import { TimeTracker } from "../src/index.js";
+
+function tmpFile(): string {
+  const dir = fs.mkdtempSync(path.join(os.tmpdir(), "timetracker-"));
+  return path.join(dir, "data.json");
+}
+
+function cleanup(filePath: string): void {
+  try {
+    fs.rmSync(path.dirname(filePath), { recursive: true, force: true });
+  } catch {
+    // ignore
+  }
+}
+
+describe("TimeTracker", () => {
+  let filePath: string;
+  let tracker: TimeTracker;
+
+  beforeEach(() => {
+    filePath = tmpFile();
+    tracker = new TimeTracker(filePath);
+  });
+
+  afterEach(() => {
+    cleanup(filePath);
+  });
+
+  describe("start", () => {
+    it("should start a timer and record entry", () => {
+      const entry = tracker.start("coding");
+      expect(entry.task).toBe("coding");
+      expect(entry.startTime).toBeTruthy();
+      expect(entry.endTime).toBeNull();
+    });
+
+    it("should throw on empty task name", () => {
+      expect(() => tracker.start("")).toThrow("Task name cannot be empty");
+    });
+
+    it("should throw on whitespace-only task name", () => {
+      expect(() => tracker.start("   ")).toThrow("Task name cannot be empty");
+    });
+
+    it("should auto-stop previous timer when starting new one", () => {
+      tracker.start("task1");
+      tracker.start("task2");
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(2);
+      expect(entries[0].endTime).not.toBeNull();
+      expect(entries[1].endTime).toBeNull();
+    });
+  });
+
+  describe("stop", () => {
+    it("should stop a running timer", () => {
+      tracker.start("coding");
+      const entry = tracker.stop();
+      expect(entry.task).toBe("coding");
+      expect(entry.endTime).not.toBeNull();
+    });
+
+    it("should throw when no timer is running", () => {
+      expect(() => tracker.stop()).toThrow("No timer is currently running");
+    });
+
+    it("should throw when stopping after already stopped", () => {
+      tracker.start("coding");
+      tracker.stop();
+      expect(() => tracker.stop()).toThrow("No timer is currently running");
+    });
+  });
+
+  describe("persistence", () => {
+    it("should persist entries across instances", () => {
+      tracker.start("task1");
+      tracker.stop();
+
+      const tracker2 = new TimeTracker(filePath);
+      const entries = tracker2.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].task).toBe("task1");
+    });
+
+    it("should create parent directories automatically", () => {
+      const deepPath = path.join(
+        os.tmpdir(),
+        "timetracker-deep",
+        "a",
+        "b",
+        "data.json"
+      );
+      const t = new TimeTracker(deepPath);
+      t.start("test");
+      t.stop();
+      expect(fs.existsSync(deepPath)).toBe(true);
+      fs.rmSync(path.join(os.tmpdir(), "timetracker-deep"), {
+        recursive: true,
+        force: true,
+      });
+    });
+
+    it("should handle non-existent file gracefully", () => {
+      const t = new TimeTracker("/tmp/nonexistent-tracker-test/data.json");
+      expect(t.getEntries()).toEqual([]);
+    });
+  });
+
+  describe("getEntries", () => {
+    it("should return all entries", () => {
+      tracker.start("task1");
+      tracker.stop();
+      tracker.start("task2");
+      tracker.stop();
+      expect(tracker.getEntries()).toHaveLength(2);
+    });
+
+    it("should filter entries by date range", () => {
+      tracker.start("old-task");
+      tracker.stop();
+
+      const now = new Date();
+      const before = new Date(now.getTime() - 1);
+      const after = new Date(now.getTime() + 100000);
+
+      const entries = tracker.getEntries({ start: before, end: after });
+      expect(entries.length).toBeGreaterThanOrEqual(1);
+    });
+
+    it("should exclude entries outside date range", () => {
+      tracker.start("task");
+      tracker.stop();
+
+      const future = new Date(Date.now() + 100000);
+      const farFuture = new Date(Date.now() + 200000);
+      const entries = tracker.getEntries({ start: future, end: farFuture });
+      expect(entries).toHaveLength(0);
+    });
+  });
+
+  describe("getSummary", () => {
+    it("should sum time per task name", () => {
+      tracker.start("coding");
+      tracker.stop();
+      tracker.start("coding");
+      tracker.stop();
+
+      const summary = tracker.getSummary();
+      expect(summary["coding"]).toBeGreaterThanOrEqual(0);
+      expect("coding" in summary).toBe(true);
+    });
+
+    it("should include running tasks using current time", () => {
+      tracker.start("running-task");
+      const summary = tracker.getSummary();
+      expect(summary["running-task"]).toBeGreaterThanOrEqual(0);
+    });
+
+    it("should separate different task names", () => {
+      tracker.start("task-a");
+      tracker.stop();
+      tracker.start("task-b");
+      tracker.stop();
+
+      const summary = tracker.getSummary();
+      expect("task-a" in summary).toBe(true);
+      expect("task-b" in summary).toBe(true);
+    });
+  });
+
+  describe("unicode support", () => {
+    it("should handle emoji task names", () => {
+      tracker.start("🚀 deploy");
+      tracker.stop();
+      const entries = tracker.getEntries();
+      expect(entries[0].task).toBe("🚀 deploy");
+    });
+
+    it("should handle unicode characters", () => {
+      tracker.start("コーディング");
+      tracker.stop();
+      const entries = tracker.getEntries();
+      expect(entries[0].task).toBe("コーディング");
+    });
+
+    it("should persist unicode correctly", () => {
+      tracker.start("日本語タスク 🎉");
+      tracker.stop();
+
+      const tracker2 = new TimeTracker(filePath);
+      const entries = tracker2.getEntries();
+      expect(entries[0].task).toBe("日本語タスク 🎉");
+    });
+
+    it("should summarize unicode tasks correctly", () => {
+      tracker.start("🔧 fix");
+      tracker.stop();
+      tracker.start("🔧 fix");
+      tracker.stop();
+
+      const summary = tracker.getSummary();
+      expect(summary["🔧 fix"]).toBeGreaterThanOrEqual(0);
+      expect("🔧 fix" in summary).toBe(true);
+    });
+  });
+
+  describe("getRunningEntry", () => {
+    it("should return null when nothing is running", () => {
+      expect(tracker.getRunningEntry()).toBeNull();
+    });
+
+    it("should return the running entry", () => {
+      tracker.start("active");
+      const running = tracker.getRunningEntry();
+      expect(running).not.toBeNull();
+      expect(running!.task).toBe("active");
+    });
   });
 });
