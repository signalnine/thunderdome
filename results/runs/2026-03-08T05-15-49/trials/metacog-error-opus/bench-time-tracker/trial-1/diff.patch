--- /dev/null
+++ b/src/tracker.ts
@@ -0,0 +1,123 @@
+import * as fs from "node:fs";
+import * as path from "node:path";
+import type { DateRange, TimeEntry, TimeSummary, TimeTrackerData } from "./types.js";
+
+export class TimeTracker {
+  private readonly filePath: string;
+  private data: TimeTrackerData;
+
+  constructor(filePath: string) {
+    this.filePath = path.resolve(filePath);
+    this.data = this.load();
+  }
+
+  /**
+   * Start a new timer. If another timer is running, it is stopped first.
+   */
+  start(task: string): TimeEntry {
+    // Error path first: empty name is the primary contract boundary
+    if (!task || task.trim().length === 0) {
+      throw new Error("Task name cannot be empty");
+    }
+
+    // Auto-stop any running timer
+    const running = this.getRunningEntry();
+    if (running) {
+      running.endTime = new Date().toISOString();
+    }
+
+    const entry: TimeEntry = {
+      task,
+      startTime: new Date().toISOString(),
+      endTime: null,
+    };
+
+    this.data.entries.push(entry);
+    this.save();
+    return entry;
+  }
+
+  /**
+   * Stop the currently running timer.
+   */
+  stop(): TimeEntry {
+    // Error path first: stopping when nothing runs defines the contract
+    const running = this.getRunningEntry();
+    if (!running) {
+      throw new Error("No timer is currently running");
+    }
+
+    running.endTime = new Date().toISOString();
+    this.save();
+    return running;
+  }
+
+  /**
+   * Get the currently running entry, or null if none.
+   */
+  getRunningEntry(): TimeEntry | null {
+    return this.data.entries.find((e) => e.endTime === null) ?? null;
+  }
+
+  /**
+   * Get all entries, optionally filtered by date range.
+   */
+  getEntries(range?: DateRange): TimeEntry[] {
+    if (!range) {
+      return [...this.data.entries];
+    }
+
+    return this.data.entries.filter((entry) => {
+      const entryStart = new Date(entry.startTime);
+      if (range.start && entryStart < range.start) {
+        return false;
+      }
+      if (range.end && entryStart > range.end) {
+        return false;
+      }
+      return true;
+    });
+  }
+
+  /**
+   * Get a summary of total time spent per task name in milliseconds.
+   * Running tasks use the current time for their duration.
+   */
+  getSummary(range?: DateRange): TimeSummary {
+    const entries = this.getEntries(range);
+    const summary: TimeSummary = {};
+
+    for (const entry of entries) {
+      const start = new Date(entry.startTime).getTime();
+      const end = entry.endTime
+        ? new Date(entry.endTime).getTime()
+        : Date.now();
+      const duration = end - start;
+
+      if (summary[entry.task] === undefined) {
+        summary[entry.task] = 0;
+      }
+      summary[entry.task] += duration;
+    }
+
+    return summary;
+  }
+
+  private load(): TimeTrackerData {
+    try {
+      const raw = fs.readFileSync(this.filePath, "utf-8");
+      return JSON.parse(raw) as TimeTrackerData;
+    } catch {
+      // File doesn't exist or is invalid — start fresh
+      return { entries: [] };
+    }
+  }
+
+  private save(): void {
+    // Create parent directories if they don't exist
+    const dir = path.dirname(this.filePath);
+    fs.mkdirSync(dir, { recursive: true });
+
+    fs.writeFileSync(this.filePath, JSON.stringify(this.data, null, 2), "utf-8");
+  }
+}
