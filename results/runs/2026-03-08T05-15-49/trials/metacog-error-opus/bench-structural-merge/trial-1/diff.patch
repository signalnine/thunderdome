 {\n      store.create('doc1', { user: { name: 'Alice', age: 30 } });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.update('doc1', { user: { name: 'Alice', age: 31 } });\n\n      store.switchBranch('main');\n      store.update('doc1', { user: { name: 'Bob', age: 30 } });\n\n      const result = store.merge('feature');\n      expect(result.applied).toBe(true);\n      expect(result.merged['doc1']).toEqual({ user: { name: 'Bob', age: 31 } });\n    });\n\n    it('should provide merged field with ours-favored resolution for conflicts', () => {\n      store.create('doc1', { a: 1, b: 2 });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: 10, b: 20 });\n\n      store.switchBranch('main');\n      store.update('doc1', { a: 100, b: 200 });\n\n      const result = store.merge('feature');\n      expect(result.applied).toBe(false);\n      // merged should favor ours\n      expect(result.merged['doc1']).toEqual({ a: 100, b: 200 });\n    });\n\n    it('should handle merge with no changes (fast-forward)', () => {\n      store.create('doc1', { a: 1 });\n      store.createBranch('feature');\n\n      // No changes on either branch\n      const result = store.merge('feature');\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n    });\n\n    it('should handle deep nested conflict paths', () => {\n      store.create('doc1', { a: { b: { c: 1 } } });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: { b: { c: 2 } } });\n\n      store.switchBranch('main');\n      store.update('doc1', { a: { b: { c: 3 } } });\n\n      const result = store.merge('feature');\n      expect(result.applied).toBe(false);\n      expect(result.conflicts[0].path).toBe('a.b.c');\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
