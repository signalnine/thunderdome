+import { randomUUID } from 'crypto';
+
+export interface Version {
+  id: string;
+  timestamp: number;
+  content: object;
+}
+
+export interface Conflict {
+  documentId: string;
+  path: string;
+  // eslint-disable-next-line @typescript-eslint/no-explicit-any
+  base: any;
+  // eslint-disable-next-line @typescript-eslint/no-explicit-any
+  ours: any;
+  // eslint-disable-next-line @typescript-eslint/no-explicit-any
+  theirs: any;
+}
+
+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+interface DocumentEntry {
+  content: object;
+  versions: Version[];
+  deleted: boolean;
+}
+
+interface BranchData {
+  documents: Map<string, DocumentEntry>;
+  // Snapshot of all documents at the point this branch was created (fork point).
+  // For 'main', this is empty (no ancestor). For derived branches, this captures
+  // the common ancestor state needed for three-way merge.
+  forkSnapshot: Map<string, object | null>; // null means document didn't exist at fork
+  parentBranch: string | null;
+}
+
+function deepClone<T>(obj: T): T {
+  if (obj === null || obj === undefined) return obj;
+  return JSON.parse(JSON.stringify(obj));
+}
+
+/**
+ * Take a snapshot of all documents on a branch at the current moment.
+ * Documents that are deleted or don't exist are stored as null.
+ */
+function snapshotBranch(branch: BranchData): Map<string, object | null> {
+  const snap = new Map<string, object | null>();
+  for (const [id, entry] of branch.documents) {
+    snap.set(id, entry.deleted ? null : deepClone(entry.content));
+  }
+  return snap;
+}
+
+/**
+ * Collect all leaf paths and their values from a plain object.
+ * Returns a map of dot-separated paths to values.
+ */
+// eslint-disable-next-line @typescript-eslint/no-explicit-any
+function collectPaths(obj: unknown, prefix: string = ''): Map<string, unknown> {
+  const result = new Map<string, unknown>();
+  if (obj === null || obj === undefined || typeof obj !== 'object' || Array.isArray(obj)) {
+    result.set(prefix, obj);
+    return result;
+  }
+  const record = obj as Record<string, unknown>;
+  const keys = Object.keys(record);
+  if (keys.length === 0) {
+    result.set(prefix, obj);
+    return result;
+  }
+  for (const key of keys) {
+    const newPrefix = prefix ? `${prefix}.${key}` : key;
+    const val = record[key];
+    if (val !== null && typeof val === 'object' && !Array.isArray(val) && Object.keys(val).length > 0) {
+      for (const [p, v] of collectPaths(val, newPrefix)) {
+        result.set(p, v);
+      }
+    } else {
+      result.set(newPrefix, val);
+    }
+  }
