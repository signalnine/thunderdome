+  // eslint-disable-next-line @typescript-eslint/no-explicit-any
+  const merged = deepClone(oursObj) as Record<string, any>; // start from ours
+
+  for (const path of allPaths) {
+    const baseVal = basePaths.has(path) ? basePaths.get(path) : NOT_FOUND;
+    const oursVal = oursPaths.has(path) ? oursPaths.get(path) : NOT_FOUND;
+    const theirsVal = theirsPaths.has(path) ? theirsPaths.get(path) : NOT_FOUND;
+
+    const oursChanged = !valuesEqual(baseVal, oursVal);
+    const theirsChanged = !valuesEqual(baseVal, theirsVal);
+
+    if (!oursChanged && !theirsChanged) {
+      // Neither changed — keep as-is (from ours, which == base)
+      continue;
+    }
+
+    if (oursChanged && !theirsChanged) {
+      // Only ours changed — already in merged (started from ours)
+      continue;
+    }
+
+    if (!oursChanged && theirsChanged) {
+      // Only theirs changed — apply theirs
+      if (theirsVal === NOT_FOUND) {
+        deleteAtPath(merged, path);
+      } else {
+        setAtPath(merged, path, deepClone(theirsVal));
+      }
+      continue;
+    }
+
+    // Both changed
+    if (valuesEqual(oursVal, theirsVal)) {
+      // Both changed to same value — no conflict
+      continue;
+    }
+
+    // Conflict — keep ours in merged, record conflict
+    conflicts.push({
+      documentId,
+      path,
+      base: baseVal === NOT_FOUND ? undefined : deepClone(baseVal),
+      ours: oursVal === NOT_FOUND ? undefined : deepClone(oursVal),
+      theirs: theirsVal === NOT_FOUND ? undefined : deepClone(theirsVal),
+    });
+  }
+
+  return { merged, conflicts };
