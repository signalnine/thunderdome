class DocumentStore {\n   215→  private branches: Map<string, BranchData> = new Map();\n   216→  private currentBranch: string = 'main';\n   217→\n   218→  constructor() {\n   219→    this.branches.set('main', {\n   220→      documents: new Map(),\n   221→      forkSnapshot: new Map(),\n   222→      parentBranch: null,\n   223→    });\n   224→  }\n   225→\n   226→  // --- CRUD ---\n   227→\n   228→  create(id: string, content: object): void {\n   229→    const branch = this.getCurrentBranchData();\n   230→    const existing = branch.documents.get(id);\n   231→    if (existing && !existing.deleted) {\n   232→      throw new Error(`Document \"${id}\" already exists`);\n   233→    }\n   234→    const cloned = deepClone(content);\n   235→    const version: Version = {\n   236→      id: randomUUID(),\n   237→      timestamp: Date.now(),\n   238→      content: deepClone(cloned),\n   239→    };\n   240→    branch.documents.set(id, {\n   241→      content: cloned,\n   242→      versions: existing && existing.deleted ? [...existing.versions, version] : [version],\n   243→      deleted: false,\n   244→    });\n   245→  }\n   246→\n   247→  get(id: string): object {\n   248→    const branch = this.getCurrentBranchData();\n   249→    const entry = branch.documents.get(id);\n   250→    if (!entry || entry.deleted) {\n   251→      throw new Error(`Document \"${id}\" not found`);\n   252→    }\n   253→    return deepClone(entry.content);\n   254→  }\n   255→\n   256→  update(id: string, content: object): void {\n   257→    const branch = this.getCurrentBranchData();\n   258→    const entry = branch.documents.get(id);\n   259→    if (!entry || entry.deleted) {\n   260→      throw new Error(`Document \"${id}\" not found`);\n   261→    }\n   262→    const cloned = deepClone(content);\n   263→    const version: Version = {\n   264→      id: randomUUID(),\n   265→      timestamp: Date.now(),\n   266→      content: deepClone(cloned),\n   267→    };\n   268→    entry.content = cloned;\n 