tore.create('doc1', { name: 'new-doc' });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n      expect(result.applied).toBe(true);\n      expect(result.merged['doc1']).toEqual({ name: 'new-doc' });\n      expect(store.get('doc1')).toEqual({ name: 'new-doc' });\n    });\n\n    it('should handle deletion on source branch (unchanged on target)', () => {\n      store.create('doc1', { name: 'test' });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.delete('doc1');\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n      expect(result.applied).toBe(true);\n      expect(() => store.get('doc1')).toThrow();\n    });\n\n    it('should handle multiple documents independently', () => {\n      store.create('doc1', { x: 1 });\n      store.create('doc2', { y: 1 });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.update('doc1', { x: 2 });\n\n      store.switchBranch('main');\n      store.update('doc2', { y: 2 });\n\n      const result = store.merge('feature');\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(store.get('doc1')).toEqual({ x: 2 });\n      expect(store.get('doc2')).toEqual({ y: 2 });\n    });\n\n    it('should not apply merge when there are conflicts', () => {\n      store.create('doc1', { a: 1 });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: 2 });\n\n      store.switchBranch('main');\n      store.update('doc1', { a: 3 });\n\n      const result = store.merge('feature');\n      expect(result.applied).toBe(false);\n      // Current branch should be unchanged\n      expect(store.get('doc1')).toEqual({ a: 3 });\n    });\n\n    it('should handle nested object merges', () => {\n      store.create('doc1', { user: { name: 'Alice', age: 30 } });\n      store.createBranch('feature');\n\n      store.switchBr