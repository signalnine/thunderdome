+  const basePaths = collectPaths(baseObj);
+  const oursPaths = collectPaths(oursObj);
+  const theirsPaths = collectPaths(theirsObj);
+
+  // Collect all unique paths
+  const allPaths = new Set<string>();
+  for (const p of basePaths.keys()) allPaths.add(p);
+  for (const p of oursPaths.keys()) allPaths.add(p);
+  for (const p of theirsPaths.keys()) allPaths.add(p);
