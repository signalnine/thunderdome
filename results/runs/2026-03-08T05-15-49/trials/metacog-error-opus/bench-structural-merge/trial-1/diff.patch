+      const sourceEntry = source.documents.get(docId);
+
+      const oursContent = targetEntry && !targetEntry.deleted ? targetEntry.content : null;
+      const theirsContent = sourceEntry && !sourceEntry.deleted ? sourceEntry.content : null;
+
+      const baseExists = baseSnapshot.has(docId) && baseSnapshot.get(docId) !== null;
+
+      // Check if document was deleted on either side
+      const oursExists = targetEntry != null && !targetEntry.deleted;
+      const theirsExists = sourceEntry != null && !sourceEntry.deleted;
+
+      // If nothing changed from base on either side, skip
+      if (valuesEqual(baseContent, oursContent) && valuesEqual(baseContent, theirsContent)
+          && (baseExists === oursExists || (!baseExists && !oursExists))
+          && (baseExists === theirsExists || (!baseExists && !theirsExists))) {
+        // Check deletion state too
+        if ((!baseExists && !oursExists && !theirsExists) || (baseExists && oursExists && theirsExists)) {
+          // No changes on either side — include in merged if exists
+          if (oursExists && oursContent) {
+            merged[docId] = deepClone(oursContent);
+          }
+          continue;
+        }
+      }
+
+      hasChanges = true;
+
+      // Handle document-level creation/deletion
+      if (!baseExists && oursExists && !theirsExists) {
+        // Created only on ours
+        merged[docId] = deepClone(oursContent!);
+        continue;
+      }
+      if (!baseExists && !oursExists && theirsExists) {
+        // Created only on theirs
+        merged[docId] = deepClone(theirsContent!);
+        continue;
+      }
+      if (!baseExists && oursExists && theirsExists) {
+        // Created on both sides — merge them
+        const result = threeWayMerge(null, oursContent, theirsContent, docId);
+        merged[docId] = result.merged;
+        allConflicts.push(...result.conflicts);
+        continue;
+      }
+      if (baseExists && !oursExists && !theirsExists) {
+        // Deleted on both sides — skip
+        continue;
+      }
+      if (baseExists && oursExists && !theirsExists) {
+        // Deleted on theirs only
+        // If ours is unchanged from base, accept deletion
+        if (valuesEqual(baseContent, oursContent)) {
+          // Accept deletion — don't include in merged
+          continue;
+        }
+        // Ours changed but theirs deleted — conflict at document level
+        // For merged, keep ours (favor ours in conflicts)
+        merged[docId] = deepClone(oursContent!);
+        continue;
+      }
+      if (baseExists && !oursExists && theirsExists) {
+        // Deleted on ours only
+        // If theirs is unchanged from base, accept our deletion
+        if (valuesEqual(baseContent, theirsContent)) {
+          // Accept our deletion
+          continue;
+        }
+        // Theirs changed but ours deleted — keep ours (deleted)
+        continue;
+      }
+
+      // Both sides exist — do a three-way field merge
+      const result = threeWayMerge(baseContent, oursContent!, theirsContent!, docId);
+      merged[docId] = result.merged;
+      allConflicts.push(...result.conflicts);
+    }
+
+    const applied = allConflicts.length === 0;
+
+    if (applied && hasChanges) {
+      // Apply the merge to the current branch
+      for (const [docId, content] of Object.entries(merged)) {
+        const entry = target.documents.get(docId);
+        if (entry && !entry.deleted) {
+          // Update existing document
+          const cloned = deepClone(content);
+          const version: Version = {
+            id: randomUUID(),
+            timestamp: Date.now(),
+            content: deepClone(cloned),
+          };
+          entry.content = cloned;
+          entry.versions.push(version);
+        } else {
+          // New document from source branch
+          const cloned = deepClone(content);
+          const version: Version = {
+            id: randomUUID(),
+            timestamp: Date.now(),
+            content: deepClone(cloned),
+          };
+          target.documents.set(docId, {
+            content: cloned,
+            versions: [version],
+            deleted: false,
+          });
+        }
+      }
+
+      // Handle documents deleted through merge
+      for (const docId of target.documents.keys()) {
+        if (!(docId in merged)) {
+          const entry = target.documents.get(docId)!;
+          // Check if this doc was intentionally removed by the merge
+          const baseContent = baseSnapshot.has(docId) ? baseSnapshot.get(docId) : null;
+          const sourceEntry = source.documents.get(docId);
+          const theirsDeleted = !sourceEntry || sourceEntry.deleted;
+          const baseExists = baseSnapshot.has(docId) && baseSnapshot.get(docId) !== null;
+
+          if (baseExists && theirsDeleted && !entry.deleted) {
+            // Check if ours is unchanged from base
+            if (valuesEqual(baseContent, entry.content)) {
+              entry.deleted = true;
+              entry.content = {};
+            }
+          }
+        }
+      }
+    }
+
+    // Build final merged output — only include non-deleted documents
+    const finalMerged: Record<string, object> = {};
+    for (const [docId, content] of Object.entries(merged)) {
+      finalMerged[docId] = deepClone(content);
+    }
+
+    return {
+      merged: finalMerged,
+      conflicts: allConflicts,
+      applied,
+    };
+  }
+
+  // --- Private ---
+
+  private getCurrentBranchData(): BranchData {
+    return this.branches.get(this.currentBranch)!;
+  }
+}
