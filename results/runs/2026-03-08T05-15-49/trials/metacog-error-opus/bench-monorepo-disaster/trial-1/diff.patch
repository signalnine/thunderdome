er input correctly', () => {\n    57→    const valid = validateUser({\n    58→      name: 'Test',\n    59→      email: 'test@test.com',\n    60→      role: 'user',\n    61→    });\n    62→    expect(valid.valid).toBe(true);\n    63→\n    64→    const invalid = validateUser({ name: '', email: 'not-an-email', role: 'hacker' });\n    65→    expect(invalid.valid).toBe(false);\n    66→    expect(invalid.errors).toBeDefined();\n    67→  });\n    68→});\n    69→"}]},"parent_tool_use_id":"toolu_01NiMaJDmP9CmvHy8TijWFGV","session_id":"0570351a-5ee5-4c63-9623-8155574cb1ef","uuid":"d5c74071-68f8-4878-8809-460eaf63c992"}
