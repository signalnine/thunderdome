expect(canDelete('user')).toBe(false);\n    48→  });\n    49→\n    50→  it('requirePermission throws when permission is missing', () => {\n    51→    expect(() => requirePermission('viewer', 'write')).toThrow(\n    52→      \"Role 'viewer' does not have permission 'write'\"\n    53→    );\n    54→  });\n    55→});\n    56→"}]},"parent_tool_use_id":"toolu_01NiMaJDmP9CmvHy8TijWFGV","session_id":"0570351a-5ee5-4c63-9623-8155574cb1ef","uuid":"58a8c8b3-5c4b-4f0e-9dc4-6b3879daae7f"}
