ue);\n    51→  });\n    52→\n    53→  it('rejects invalid token', async () => {\n    54→    const res = await request(app)\n    55→      .get('/auth/verify')\n    56→      .set('Authorization', 'Bearer bad-token');\n    57→    expect(res.status).toBe(401);\n    58→  });\n    59→\n    60→  it('rejects request without token', async () => {\n    61→    const res = await request(app).get('/auth/verify');\n    62→    expect(res.status).toBe(401);\n    63→  });\n    64→});\n    65→"}]},"parent_tool_use_id":"toolu_01NiMaJDmP9CmvHy8TijWFGV","session_id":"0570351a-5ee5-4c63-9623-8155574cb1ef","uuid":"55b1c6f4-7e48-4ac8-801a-ca713f5eac6c"}
