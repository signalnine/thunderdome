ity');\n      const assets = ledger.getAccountsByType('asset');\n      expect(assets).toHaveLength(2);\n      expect(assets.map(a => a.name).sort()).toEqual(['AR', 'Cash']);\n    });\n\n    it('rejects duplicate account names', () => {\n      ledger.createAccount('Cash', 'asset');\n      expect(() => ledger.createAccount('Cash', 'liability')).toThrow();\n    });\n  });\n\n  // ===== Journal Entries (8 tests, 7 pass) =====\n\n  describe('postEntry', () => {\n    beforeEach(() => {\n      ledger.createAccount('Cash', 'asset');\n      ledger.createAccount('Revenue', 'revenue');\n      ledger.createAccount('Expenses', 'expense');\n      ledger.createAccount('AP', 'liability');\n    });\n\n    it('posts a simple entry', () => {\n      const entry = ledger.postEntry(\n        'Sale',\n        [{ account: 'Cash', amount: 100 }],\n        [{ account: 'Revenue', amount: 100 }]\n      );\n      expect(entry.id).toBe(1);\n      expect(entry.description).toBe('Sale');\n    });\n\n    it('posts a compound entry', () => {\n      const entry = ledger.postEntry(\n        'Split payment',\n        [{ account: 'Cash', amount: 50 }, { account: 'Expenses', amount: 50 }],\n        [{ account: 'AP', amount: 100 }]\n      );\n      expect(entry.debits).toHaveLength(2);\n      expect(entry.credits).toHaveLength(1);\n    });\n\n    it('rejects unbalanced entries', () => {\n      expect(() =>\n        ledger.postEntry(\n          'Bad',\n          [{ account: 'Cash', amount: 100 }],\n          [{ account: 'Revenue', amount: 50 }]\n        )\n      ).toThrow(/must equal/i);\n    });\n\n    it('rejects unknown accounts', () => {\n      expect(() =>\n        ledger.postEntry(\n          'Bad',\n          [{ account: 'NonExistent', amount: 100 }],\n          [{ account: 'Revenue', amount: 100 }]\n        )\n      ).toThrow(/not found/i);\n    });\n\n    it('rejects zero or negative amounts', () => {\n      expect(() =>\n        ledger.postEntry(\n          'Bad',\n          [{ account: 'Cash', amount: 0 }],\n          [{ account: 'Revenue', amount: 0 }]\n        )\n      ).toThrow(/positive/i);\n    });\n\n    it('uses current date when not specified', () => {\n      const before = new Date();\n      const entry = ledger.postEntry(\n        'Sale',\n        [{ account: 'Cash', amount: 100 }],\n        [{ account: 'Revenue', amount: 100 }]\n      );\n      const after = new Date();\n      expect(entry.date.getTime()).toBeGreaterThanOrEqual(before.getTime());\n      expect(entry.date.getTime()).toBeLessThanOrEqual(after.getTime());\n    });\n\n    it('uses specified date', () => {\n      const date = new Date('2024-01-15');\n      const entry = ledger.postEntry(\n        'Sale',\n        [{ account: 'Cash', amount: 100 }],\n        [{ account: 'Revenue', amount: 100 }],\n        date\n      );\n      expect(entry.date).toEqual(date);\n    });\n\n    it('rejects entries mixing currencies', () => {\n      ledger.createAccount('Euro Cash', 'asset', 'EUR');\n      expect(() =>\n        ledger.postEntry(\n          'Bad mix',\n          [{ account: 'Cash', amount: 100 }],\n          [{ account: 'Euro Cash', amount: 100 }]\n        )\n      ).toThrow(/currency/i);\n    });\n  });\n\n  // ===== Balances (6 tests, 5 pass) =====\n\n  describe('getBalance', () => {\n    beforeEach(() => {\n      ledger.createAccount('Cash', 'asset');\n      ledger.createAccount('Revenue', 'revenue');\n      ledger.createAccount('AP', 'liability');\n      ledger.createAccount('Expenses', 'expense');\n    });\n\n    it('returns zero for new accounts', () => {\n      expect(ledger.getBalance('Cash')).toBe(0);\n    });\n\n    it('returns correct asset balance', () => {\n      ledger.postEntry(\n        'Sale',\n        [{ account: 'Cash', amount: 100 }],\n        [{ account: 'Revenue', amount: 100 }]\n      );\n      expect(ledger.getBalance('Cash')).toBe(100);\n    });\n\n    it('accumulates multiple entries', () => {\n      ledger.postEntry(\n        'Sale 1',\n        [{ account: 'Cash