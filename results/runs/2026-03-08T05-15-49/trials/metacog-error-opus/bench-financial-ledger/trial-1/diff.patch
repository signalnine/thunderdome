      ledger.postEntry(\n        'Sale',\n        [{ account: 'Cash', amount: 200 }],\n        [{ account: 'Revenue', amount: 200 }]\n      );\n      ledger.postEntry(\n        'Cost',\n        [{ account: 'Expenses', amount: 50 }],\n        [{ account: 'Cash', amount: 50 }]\n      );\n      const tb = ledger.getTrialBalance();\n      const totalDebits = tb.reduce((s, e) => s + e.debit, 0);\n      const totalCredits = tb.reduce((s, e) => s + e.credit, 0);\n      expect(totalDebits).toBe(totalCredits);\n    });\n  });\n\n  // ===== Statements (6 tests, 4 pass) =====\n\n  describe('getStatement', () => {\n    const jan1 = new Date('2024-01-01');\n    const jan15 = new Date('2024-01-15');\n    const jan31 = new Date('2024-01-31');\n    const feb15 = new Date('2024-02-15');\n\n    beforeEach(() => {\n      ledger.createAccount('Cash', 'asset');\n      ledger.createAccount('Revenue', 'revenue');\n      ledger.createAccount('Expenses', 'expense');\n    });\n\n    it('returns empty statement for no entries', () => {\n      const stmt = ledger.getStatement('Cash');\n      expect(stmt).toHaveLength(0);\n    });\n\n    it('returns entries in date order', () => {\n      ledger.postEntry('Late', [{ account: 'Cash', amount: 50 }], [{ account: 'Revenue', amount: 50 }], jan31);\n      ledger.postEntry('Early', [{ account: 'Cash', amount: 100 }], [{ account: 'Revenue', amount: 100 }], jan1);\n      const stmt = ledger.getStatement('Cash');\n      expect(stmt).toHaveLength(2);\n      expect(stmt[0].description).toBe('Early');\n      expect(stmt[1].description).toBe('Late');\n    });\n\n    it('only includes entries for the requested account', () => {\n      ledger.postEntry('Sale', [{ account: 'Cash', amount: 100 }], [{ account: 'Revenue', amount: 100 }], jan1);\n      ledger.postEntry('Cost', [{ account: 'Expenses', amount: 30 }], [{ account: 'Cash', amount: 30 }], jan15);\n      const stmt = ledger.getStatement('Cash');\n      expect(stmt).toHaveLength(2); // Cash appears in both\n      const revenueStmt = ledger.getStatement('Revenue');\n      expect(revenueStmt).toHaveLength(1);\n    });\n\n    it('throws for unknown account', () => {\n      expect(() => ledger.getStatement('Nonexistent')).toThrow(/not found/i);\n    });\n\n    it('shows correct running balance', () => {\n      ledger.postEntry('Sale', [{ account: 'Cash', amount: 100 }], [{ account: 'Revenue', amount: 100 }], jan1);\n      ledger.postEntry('Cost', [{ account: 'Expenses', amount: 30 }], [{ account: 'Cash', amount: 30 }], jan15);\n      const stmt = ledger.getStatement('Cash');\n      expect(stmt[0].balance).toBe(100);  // +100 debit\n      expect(stmt[1].balance).toBe(70);   // -30 credit\n    });\n\n    it('filters by date range inclusively', () => {\n      ledger.postEntry('Jan', [{ account: 'Cash', amount: 100 }], [{ account: 'Revenue', amount: 100 }], jan1);\n      ledger.postEntry('Mid', [{ account: 'Cash', amount: 50 }], [{ account: 'Revenue', amount: 50 }], jan15);\n      ledger.postEntry('Feb', [{ account: 'Cash', amount: 200 }], [{ account: 'Revenue', amount: 200 }], feb15);\n      const stmt = ledger.getStatement('Cash', jan1, jan31);\n      expect(stmt).toHaveLength(2); // Jan 1 and Jan 15, not Feb 15\n      expect(stmt[0].description).toBe('Jan');\n      expect(stmt[1].description).toBe('Mid');\n    });\n  });\n\n  // ===== Split Entries (4 tests, 2 pass) =====\n\n  describe('splitEntry', () => {\n    beforeEach(() => {\n      ledger.createAccount('Cash', 'asset');\n      ledger.createAccount('Rent', 'expense');\n      ledger.createAccount('Utilities', 'expense');\n      ledger.createAccount('Insurance', 'expense');\n    });\n\n    it('creates a basic split entry', () => {\n      // This passes because with one destination, totalAmount === ta.amount by coincidence\n      const entry = ledger.splitEntry(\n        'Office costs',\n        'Cash',\n        [{ account: 'Rent', amount: 1000 }],\n        1000\n      );\n      expect(entry.debits[0].amount).toBe(1000);