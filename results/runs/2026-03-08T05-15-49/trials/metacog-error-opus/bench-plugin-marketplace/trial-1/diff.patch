es exist', () => {\n    registry.register(makeManifest('a', '1.0.0', { b: '^1.0.0' }));\n    registry.register(makeManifest('b', '1.0.0'));\n\n    expect(depsService.detectCycles('a', registry)).toBeNull();\n  });\n\n  it('should perform topological sort', () => {\n    registry.register(makeManifest('a', '1.0.0', { b: '^1.0.0', c: '^1.0.0' }));\n    registry.register(makeManifest('b', '1.0.0', { c: '^1.0.0' }));\n    registry.register(makeManifest('c', '1.0.0'));\n\n    const sorted = depsService.topologicalSort('a', registry);\n    expect(sorted.indexOf('c')).toBeLessThan(sorted.indexOf('b'));\n    expect(sorted.indexOf('b')).toBeLessThan(sorted.indexOf('a'));\n    expect(sorted).toContain('a');\n    expect(sorted).toContain('b');\n    expect(sorted).toContain('c');\n  });\n\n  it('should flatten dependencies (excluding root)', () => {\n    registry.register(makeManifest('a', '1.0.0', { b: '^1.0.0' }));\n    registry.register(makeManifest('b', '1.0.0', { c: '^1.0.0' }));\n    registry.register(makeManifest('c', '1.0.0'));\n\n    const flat = depsService.flattenDependencies('a', registry);\n    expect(flat).toContain('b');\n    expect(flat).toContain('c');\n    expect(flat).not.toContain('a');\n  });\n\n  it('should check for circular dependency', () => {\n    registry.register(makeManifest('a', '1.0.0', { b: '^1.0.0' }));\n    registry.register(makeManifest('b', '1.0.0', { a: '^1.0.0' }));\n\n    expect(depsService.hasCircularDependency('a', registry)).toBe(true);\n  });\n\n  it('should handle plugin with no dependencies', () => {\n    registry.register(makeManifest('a', '1.0.0'));\n\n    const tree = depsService.buildTree('a', registry);\n    expect(tree.dependencies).toEqual([]);\n    expect(depsService.detectCycles('a', registry)).toBeNull();\n    expect(depsService.topologicalSort('a', registry)).toEqual(['a']);\n    expect(depsService.flattenDependencies('a', registry)).toEqual([]);\n    expect(depsService.hasCircularDependency('a', registry)).toBe(false);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1596,"cache_read_input_tokens":32742,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1596},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"e7aba37a-bc39-4e9b-8dfe-4e7e95141e3d","uuid":"fbaf0347-eca2-438f-8623-5aa5538230dd"}
