--- /dev/null
+++ b/src/deps/index.ts
@@ -0,0 +1,115 @@
+import type { DependencyNode, DepsService, RegistryService } from '../types.js';
+
+export function createDepsService(): DepsService {
+  function buildTreeInternal(
+    name: string,
+    registry: RegistryService,
+    visited: Set<string>
+  ): DependencyNode {
+    const manifest = registry.get(name);
+    const version = manifest?.version ?? 'unknown';
+
+    if (visited.has(name)) {
+      return { name, version, dependencies: [] };
+    }
+
+    visited.add(name);
+
+    const deps: DependencyNode[] = [];
+    if (manifest && manifest.dependencies) {
+      for (const depName of Object.keys(manifest.dependencies)) {
+        deps.push(buildTreeInternal(depName, registry, new Set(visited)));
+      }
+    }
+
+    return { name, version, dependencies: deps };
+  }
+
+  function detectCyclesInternal(
+    name: string,
+    registry: RegistryService
+  ): string[][] | null {
+    const cycles: string[][] = [];
+
+    function dfs(current: string, path: string[], visited: Set<string>): void {
+      if (path.includes(current)) {
+        const cycleStart = path.indexOf(current);
+        const cycle = [...path.slice(cycleStart), current];
+        cycles.push(cycle);
+        return;
+      }
+
+      if (visited.has(current)) return;
+
+      path.push(current);
+      const manifest = registry.get(current);
+      if (manifest && manifest.dependencies) {
+        for (const depName of Object.keys(manifest.dependencies)) {
+          dfs(depName, [...path], visited);
+        }
+      }
+      visited.add(current);
+      path.pop();
+    }
+
+    dfs(name, [], new Set());
+    return cycles.length > 0 ? cycles : null;
+  }
+
+  function getAllDeps(name: string, registry: RegistryService, visited: Set<string>): void {
+    if (visited.has(name)) return;
+    visited.add(name);
+    const manifest = registry.get(name);
+    if (manifest && manifest.dependencies) {
+      for (const depName of Object.keys(manifest.dependencies)) {
+        getAllDeps(depName, registry, visited);
+      }
+    }
+  }
+
+  return {
+    buildTree(name: string, registry: RegistryService): DependencyNode {
+      return buildTreeInternal(name, registry, new Set());
+    },
+
+    detectCycles(name: string, registry: RegistryService): string[][] | null {
+      return detectCyclesInternal(name, registry);
+    },
+
+    topologicalSort(name: string, registry: RegistryService): string[] {
+      const result: string[] = [];
+      const visited = new Set<string>();
+      const temp = new Set<string>();
+
+      function visit(current: string): void {
+        if (visited.has(current)) return;
+        if (temp.has(current)) return; // cycle - skip
+
+        temp.add(current);
+        const manifest = registry.get(current);
+        if (manifest && manifest.dependencies) {
+          for (const depName of Object.keys(manifest.dependencies)) {
+            visit(depName);
+          }
+        }
+        temp.delete(current);
+        visited.add(current);
+        result.push(current);
+      }
+
+      visit(name);
+      return result;
+    },
+
+    flattenDependencies(name: string, registry: RegistryService): string[] {
+      const visited = new Set<string>();
+      getAllDeps(name, registry, visited);
+      visited.delete(name); // exclude the root plugin itself
+      return Array.from(visited);
+    },
+
+    hasCircularDependency(name: string, registry: RegistryService): boolean {
+      return detectCyclesInternal(name, registry) !== null;
+    },
+  };
+}
