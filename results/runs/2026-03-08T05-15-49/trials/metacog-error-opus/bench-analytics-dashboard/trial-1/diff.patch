@@ -0,0 +1,230 @@
+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { AuthRequest, authenticate } from "../auth.js";
+
+interface EventRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string;
+  session_id: string | null;
+}
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+interface WidgetRow {
+  id: string;
+  dashboard_id: string;
+  type: string;
+  config: string;
+  position_x: number;
+  position_y: number;
+  width: number;
+  height: number;
+}
+
+function escapeCsvField(field: string): string {
+  if (
+    field.includes(",") ||
+    field.includes('"') ||
+    field.includes("\n") ||
+    field.includes("\r")
+  ) {
+    return `"${field.replace(/"/g, '""')}"`;
+  }
+  return field;
+}
+
+export function createExportRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Export events as JSON
+  router.get("/events/json", authenticate, (req: AuthRequest, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { eventName, startDate, endDate } = req.query;
+
+    let query =
+      "SELECT id, tenant_id, name, properties, timestamp, user_id, session_id FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [tenantId];
+
+    if (eventName) {
+      query += " AND name = ?";
+      params.push(eventName);
+    }
+    if (startDate) {
+      query += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+    if (endDate) {
+      query += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    query += " ORDER BY timestamp DESC";
+
+    const events = db.prepare(query).all(...params) as EventRow[];
+
+    const mapped = events.map((e) => ({
+      id: e.id,
+      tenantId: e.tenant_id,
+      name: e.name,
+      properties: JSON.parse(e.properties),
+      timestamp: e.timestamp,
+      userId: e.user_id,
+      sessionId: e.session_id,
+    }));
+
+    res.setHeader("Content-Type", "application/json");
+    res.setHeader(
+      "Content-Disposition",
+      'attachment; filename="events.json"'
+    );
+    res.json({ events: mapped });
+  });
+
+  // Export events as CSV
+  router.get("/events/csv", authenticate, (req: AuthRequest, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { eventName, startDate, endDate } = req.query;
+
+    let query =
+      "SELECT id, tenant_id, name, properties, timestamp, user_id, session_id FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [tenantId];
+
+    if (eventName) {
+      query += " AND name = ?";
+      params.push(eventName);
+    }
+    if (startDate) {
+      query += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+    if (endDate) {
+      query += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    query += " ORDER BY timestamp DESC";
+
+    const events = db.prepare(query).all(...params) as EventRow[];
+
+    const header = "id,tenant_id,name,properties,timestamp,user_id,session_id";
+    const rows = events.map(
+      (e) =>
+        `${escapeCsvField(e.id)},${escapeCsvField(e.tenant_id)},${escapeCsvField(e.name)},${escapeCsvField(e.properties)},${escapeCsvField(e.timestamp)},${escapeCsvField(e.user_id || "")},${escapeCsvField(e.session_id || "")}`
+    );
+
+    const csv = [header, ...rows].join("\n");
+
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader(
+      "Content-Disposition",
+      'attachment; filename="events.csv"'
+    );
+    res.send(csv);
+  });
+
+  // Export dashboard as JSON
+  router.get(
+    "/dashboards/:id/json",
+    authenticate,
+    (req: AuthRequest, res: Response): void => {
+      const tenantId = req.user!.tenantId;
+      const { id } = req.params;
+
+      const dashboard = db
+        .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+        .get(id, tenantId) as DashboardRow | undefined;
+
+      if (!dashboard) {
+        res.status(404).json({ error: "Dashboard not found" });
+        return;
+      }
+
+      const widgets = db
+        .prepare("SELECT * FROM widgets WHERE dashboard_id = ?")
+        .all(id) as WidgetRow[];
+
+      const exportData = {
+        dashboard: {
+          id: dashboard.id,
+          tenantId: dashboard.tenant_id,
+          name: dashboard.name,
+          ownerId: dashboard.owner_id,
+          config: JSON.parse(dashboard.config),
+          createdAt: dashboard.created_at,
+          updatedAt: dashboard.updated_at,
+        },
+        widgets: widgets.map((w) => ({
+          id: w.id,
+          dashboardId: w.dashboard_id,
+          type: w.type,
+          config: JSON.parse(w.config),
+          positionX: w.position_x,
+          positionY: w.position_y,
+          width: w.width,
+          height: w.height,
+        })),
+      };
+
+      res.setHeader("Content-Type", "application/json");
+      res.setHeader(
+        "Content-Disposition",
+        `attachment; filename="dashboard-${id}.json"`
+      );
+      res.json(exportData);
+    }
+  );
+
+  // Export dashboard as CSV
+  router.get(
+    "/dashboards/:id/csv",
+    authenticate,
+    (req: AuthRequest, res: Response): void => {
+      const tenantId = req.user!.tenantId;
+      const { id } = req.params;
+
+      const dashboard = db
+        .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+        .get(id, tenantId) as DashboardRow | undefined;
+
+      if (!dashboard) {
+        res.status(404).json({ error: "Dashboard not found" });
+        return;
+      }
+
+      const widgets = db
+        .prepare("SELECT * FROM widgets WHERE dashboard_id = ?")
+        .all(id) as WidgetRow[];
+
+      const header =
+        "widget_id,dashboard_id,type,config,position_x,position_y,width,height";
+      const rows = widgets.map(
+        (w) =>
+          `${escapeCsvField(w.id)},${escapeCsvField(w.dashboard_id)},${escapeCsvField(w.type)},${escapeCsvField(w.config)},${w.position_x},${w.position_y},${w.width},${w.height}`
+      );
+
+      let csv = `# Dashboard: ${dashboard.name}\n# ID: ${dashboard.id}\n`;
+      csv += [header, ...rows].join("\n");
+
+      res.setHeader("Content-Type", "text/csv");
+      res.setHeader(
+        "Content-Disposition",
+        `attachment; filename="dashboard-${id}.csv"`
+      );
+      res.send(csv);
+    }
+  );
+
+  return router;
+}
diff --git a/src/routes/queries.ts b/src/routes/queries.ts
new file mode 100644
index 0000000..589c3a1
--- /dev/null
+++ b/src/routes/queries.ts
@@ -0,0 +1,143 @@
+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { AuthRequest, authenticate } from "../auth.js";
+
+export function createQueryRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Count query
+  router.post("/count", authenticate, (req: AuthRequest, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { eventName, startDate, endDate, filters } = req.body;
+
+    let query = "SELECT COUNT(*) as count FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [tenantId];
+
+    if (eventName) {
+      query += " AND name = ?";
+      params.push(eventName);
+    }
+    if (startDate) {
+      query += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+    if (endDate) {
+      query += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        query += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value);
+      }
+    }
+
+    const result = db.prepare(query).get(...params) as { count: number };
+    res.json({ count: result.count });
+  });
+
+  // Timeseries query
+  router.post("/timeseries", authenticate, (req: AuthRequest, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { eventName, startDate, endDate, interval, filters } = req.body;
+
+    const granularity = interval || "day";
+    let dateFormat: string;
+    switch (granularity) {
+      case "hour":
+        dateFormat = "%Y-%m-%dT%H:00:00";
+        break;
+      case "week":
+        dateFormat = "%Y-W%W";
+        break;
+      case "month":
+        dateFormat = "%Y-%m";
+        break;
+      case "day":
+      default:
+        dateFormat = "%Y-%m-%d";
+        break;
+    }
+
+    let query = `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: unknown[] = [tenantId];
+
+    if (eventName) {
+      query += " AND name = ?";
+      params.push(eventName);
+    }
+    if (startDate) {
+      query += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+    if (endDate) {
+      query += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        query += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value);
+      }
+    }
+
+    query += " GROUP BY bucket ORDER BY bucket ASC";
+
+    const results = db.prepare(query).all(...params) as Array<{
+      bucket: string;
+      count: number;
+    }>;
+
+    res.json({ timeseries: results, interval: granularity });
+  });
+
+  // Breakdown query
+  router.post("/breakdown", authenticate, (req: AuthRequest, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { eventName, property, startDate, endDate, filters } = req.body;
+
+    if (!property) {
+      res.status(400).json({ error: "property is required for breakdown queries" });
+      return;
+    }
+
+    let query = `SELECT json_extract(properties, ?) as property_value, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: unknown[] = [`$.${property}`, tenantId];
+
+    if (eventName) {
+      query += " AND name = ?";
+      params.push(eventName);
+    }
+    if (startDate) {
+      query += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+    if (endDate) {
+      query += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        query += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value);
+      }
+    }
+
+    query += " GROUP BY property_value ORDER BY count DESC";
+
+    const results = db.prepare(query).all(...params) as Array<{
+      property_value: string | null;
+      count: number;
+    }>;
+
+    res.json({
+      breakdown: results.map((r) => ({
+        value: r.property_value,
+        count: r.count,
+      })),
+      property,
+    });
+  });
+
+  return router;
+}
diff --git a/src/routes/users.ts b/src/routes/users.ts
new file mode 100644
index 0000000..6523612
--- /dev/null
+++ b/src/routes/users.ts
@@ -0,0 +1,145 @@
+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { v4 as uuidv4 } from "uuid";
+import {
+  AuthRequest,
+  hashPassword,
+  verifyPassword,
+  generateToken,
+  authenticate,
+  requireRole,
+} from "../auth.js";
+
+export function createUserRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Register
+  router.post("/register", (req: AuthRequest, res: Response): void => {
+    const { email, password, tenantId, role } = req.body;
+
+    if (!email || !password || !tenantId) {
+      res.status(400).json({ error: "email, password, and tenantId are required" });
+      return;
+    }
+
+    const existing = db
+      .prepare("SELECT id FROM users WHERE email = ?")
+      .get(email);
+    if (existing) {
+      res.status(409).json({ error: "Email already registered" });
+      return;
+    }
+
+    const id = uuidv4();
+    const passwordHash = hashPassword(password);
+    const userRole = role && ["admin", "viewer", "editor"].includes(role) ? role : "viewer";
+
+    db.prepare(
+      "INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)"
+    ).run(id, email, passwordHash, tenantId, userRole);
+
+    const token = generateToken({
+      userId: id,
+      tenantId,
+      role: userRole,
+      email,
+    });
+
+    res.status(201).json({ id, email, tenantId, role: userRole, token });
+  });
+
+  // Login
+  router.post("/login", (req: AuthRequest, res: Response): void => {
+    const { email, password } = req.body;
+
+    if (!email || !password) {
+      res.status(400).json({ error: "email and password are required" });
+      return;
+    }
+
+    const user = db
+      .prepare("SELECT id, email, password_hash, tenant_id, role FROM users WHERE email = ?")
+      .get(email) as
+      | { id: string; email: string; password_hash: string; tenant_id: string; role: string }
+      | undefined;
+
+    if (!user || !verifyPassword(password, user.password_hash)) {
+      res.status(401).json({ error: "Invalid credentials" });
+      return;
+    }
+
+    const token = generateToken({
+      userId: user.id,
+      tenantId: user.tenant_id,
+      role: user.role,
+      email: user.email,
+    });
+
+    res.json({
+      id: user.id,
+      email: user.email,
+      tenantId: user.tenant_id,
+      role: user.role,
+      token,
+    });
+  });
+
+  // Get profile
+  router.get("/me", authenticate, (req: AuthRequest, res: Response): void => {
+    const user = db
+      .prepare("SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?")
+      .get(req.user!.userId) as
+      | { id: string; email: string; tenant_id: string; role: string; created_at: string }
+      | undefined;
+
+    if (!user) {
+      res.status(404).json({ error: "User not found" });
+      return;
+    }
+
+    res.json({
+      id: user.id,
+      email: user.email,
+      tenantId: user.tenant_id,
+      role: user.role,
+      createdAt: user.created_at,
+    });
+  });
+
+  // Update user role (admin only)
+  router.put(
+    "/:userId/role",
+    authenticate,
+    requireRole("admin"),
+    (req: AuthRequest, res: Response): void => {
+      const { userId } = req.params;
+      const { role } = req.body;
+
+      if (!role || !["admin", "viewer", "editor"].includes(role)) {
+        res.status(400).json({ error: "Valid role is required (admin, viewer, editor)" });
+        return;
+      }
+
+      // Only allow changing roles within same tenant
+      const targetUser = db
+        .prepare("SELECT id, tenant_id FROM users WHERE id = ?")
+        .get(userId) as { id: string; tenant_id: string } | undefined;
+
+      if (!targetUser) {
+        res.status(404).json({ error: "User not found" });
+        return;
+      }
+
+      if (targetUser.tenant_id !== req.user!.tenantId) {
+        res.status(403).json({ error: "Cannot modify users from other tenants" });
+        return;
+      }
+
+      db.prepare("UPDATE users SET role = ? WHERE id = ?").run(role, userId);
+
+      res.json({ id: userId, role });
+    }
+  );
+
+  return router;
+}
