rray<{\n          name: string;\n          properties?: Record<string, unknown>;\n          timestamp?: string;\n          sessionId?: string;\n        }>\n      ) => {\n        const results: Array<{ id: string; name: string }> = [];\n        for (const evt of evts) {\n          if (!evt.name) continue;\n          const id = uuidv4();\n          const eventTimestamp = evt.timestamp || new Date().toISOString();\n          const eventProperties = evt.properties\n            ? JSON.stringify(evt.properties)\n            : \"{}\";\n          insertStmt.run(\n            id,\n            tenantId,\n            evt.name,\n            eventProperties,\n            eventTimestamp,\n            req.user!.userId,\n            evt.sessionId || null\n          );\n          results.push({ id, name: evt.name });\n        }\n        return results;\n      }\n    );\n\n    const results = insertMany(events);\n    res.status(201).json({ inserted: results.length, events: results });\n  });\n\n  // List events (with optional filters)\n  router.get(\"/\", authenticate, (req: AuthRequest, res: Response): void => {\n    const tenantId = req.user!.tenantId;\n    const { name, startDate, endDate, limit: limitParam, offset: offsetParam } = req.query;\n\n    let query = \"SELECT id, tenant_id, name, properties, timestamp, user_id, session_id FROM events WHERE tenant_id = ?\";\n    const params: unknown[] = [tenantId];\n\n    if (name) {\n      query += \" AND name = ?\";\n      params.push(name);\n    }\n    if (startDate) {\n      query += \" AND timestamp >= ?\";\n      params.push(startDate);\n    }\n    if (endDate) {\n      query += \" AND timestamp <= ?\";\n      params.push(endDate);\n    }\n\n    query += \" ORDER BY timestamp DESC\";\n\n    const limit = limitParam ? parseInt(limitParam as string, 10) : 100;\n    const offset = offsetParam ? parseInt(offsetParam as string, 10) : 0;\n    query += \" LIMIT ? OFFSET ?\";\n    params.push(limit, offset);\n\n    const events = db.prepare(query).all(...params) as Array<{\n      id: string;\n      tenant_id: string;\n      name: string;\n      properties: string;\n      timestamp: string;\n      user_id: string;\n      session_id: string | null;\n    }>;\n\n    const mapped = events.map((e) => ({\n      id: e.id,\n      tenantId: e.tenant_id,\n      name: e.name,\n      properties: JSON.parse(e.properties),\n      timestamp: e.timestamp,\n      userId: e.user_id,\n      sessionId: e.session_id,\n    }));\n\n    res.json({ events: mapped, count: mapped.length });\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1326,"cache_read_input_tokens":24802,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1326},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"16297cc7-64b7-4200-8a9b-c208387fd56f","uuid":"662db658-adb9-4992-930a-0d4bafb2bf68"}
