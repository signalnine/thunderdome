     .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe(\"My Dashboard\");\n      expect(res.body.widgets).toBeDefined();\n    });\n\n    it(\"should update a dashboard\", async () => {\n      const res = await request(app)\n        .put(`/api/dashboards/${dashboardId}`)\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ name: \"Updated Dashboard\" });\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe(\"Updated Dashboard\");\n    });\n\n    it(\"should add a widget\", async () => {\n      const res = await request(app)\n        .post(`/api/dashboards/${dashboardId}/widgets`)\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({\n          type: \"counter\",\n          config: { eventName: \"page_view\" },\n          positionX: 0,\n          positionY: 0,\n          width: 2,\n          height: 1,\n        });\n      expect(res.status).toBe(201);\n      expect(res.body.type).toBe(\"counter\");\n    });\n\n    it(\"should delete a dashboard\", async () => {\n      const res = await request(app)\n        .delete(`/api/dashboards/${dashboardId}`)\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(res.status).toBe(204);\n    });\n\n    it(\"should return 404 for deleted dashboard\", async () => {\n      const res = await request(app)\n        .get(`/api/dashboards/${dashboardId}`)\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(res.status).toBe(404);\n    });\n  });\n\n  describe(\"Export\", () => {\n    let exportDashboardId: string;\n\n    it(\"should export events as JSON\", async () => {\n      const res = await request(app)\n        .get(\"/api/export/events/json\")\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(res.status).toBe(200);\n      expect(res.body.events).toBeDefined();\n      expect(res.body.events.length).toBeGreaterThanOrEqual(1);\n    });\n\n    it(\"should export events as CSV\", async () => {\n      const res = await request(app)\n        .get(\"/api/export/events/csv\")\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(res.status).toBe(200);\n      expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n      expect(res.text).toContain(\"id,tenant_id,name\");\n    });\n\n    it(\"should export dashboard as JSON\", async () => {\n      // Create a dashboard first\n      const createRes = await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ name: \"Export Test\" });\n      exportDashboardId = createRes.body.id;\n\n      const res = await request(app)\n        .get(`/api/export/dashboards/${exportDashboardId}/json`)\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(res.status).toBe(200);\n      expect(res.body.dashboard).toBeDefined();\n      expect(res.body.dashboard.name).toBe(\"Export Test\");\n    });\n\n    it(\"should export dashboard as CSV\", async () => {\n      const res = await request(app)\n        .get(`/api/export/dashboards/${exportDashboardId}/csv`)\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(res.status).toBe(200);\n      expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n    });\n\n    it(\"should reject unauthenticated export\", async () => {\n      const res = await request(app).get(\"/api/export/events/json\");\n      expect(res.status).toBe(401);\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
