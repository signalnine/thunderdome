@@ -0,0 +1,132 @@
+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { v4 as uuidv4 } from "uuid";
+import { AuthRequest, authenticate } from "../auth.js";
+
+export function createEventRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Ingest single event
+  router.post("/", authenticate, (req: AuthRequest, res: Response): void => {
+    const { name, properties, timestamp, sessionId } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: "Event name is required" });
+      return;
+    }
+
+    const id = uuidv4();
+    const tenantId = req.user!.tenantId;
+    const eventTimestamp = timestamp || new Date().toISOString();
+    const eventProperties = properties ? JSON.stringify(properties) : "{}";
+
+    db.prepare(
+      "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    ).run(id, tenantId, name, eventProperties, eventTimestamp, req.user!.userId, sessionId || null);
+
+    res.status(201).json({ id, name, tenantId, timestamp: eventTimestamp });
+  });
+
+  // Batch ingest events
+  router.post("/batch", authenticate, (req: AuthRequest, res: Response): void => {
+    const { events } = req.body;
+
+    if (!Array.isArray(events) || events.length === 0) {
+      res.status(400).json({ error: "events array is required and must not be empty" });
+      return;
+    }
+
+    const tenantId = req.user!.tenantId;
+    const insertStmt = db.prepare(
+      "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    );
+
+    const insertMany = db.transaction(
+      (
+        evts: Array<{
+          name: string;
+          properties?: Record<string, unknown>;
+          timestamp?: string;
+          sessionId?: string;
+        }>
+      ) => {
+        const results: Array<{ id: string; name: string }> = [];
+        for (const evt of evts) {
+          if (!evt.name) continue;
+          const id = uuidv4();
+          const eventTimestamp = evt.timestamp || new Date().toISOString();
+          const eventProperties = evt.properties
+            ? JSON.stringify(evt.properties)
+            : "{}";
+          insertStmt.run(
+            id,
+            tenantId,
+            evt.name,
+            eventProperties,
+            eventTimestamp,
+            req.user!.userId,
+            evt.sessionId || null
+          );
+          results.push({ id, name: evt.name });
+        }
+        return results;
+      }
+    );
+
+    const results = insertMany(events);
+    res.status(201).json({ inserted: results.length, events: results });
+  });
+
+  // List events (with optional filters)
+  router.get("/", authenticate, (req: AuthRequest, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { name, startDate, endDate, limit: limitParam, offset: offsetParam } = req.query;
+
+    let query = "SELECT id, tenant_id, name, properties, timestamp, user_id, session_id FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [tenantId];
+
+    if (name) {
+      query += " AND name = ?";
+      params.push(name);
+    }
+    if (startDate) {
+      query += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+    if (endDate) {
+      query += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    query += " ORDER BY timestamp DESC";
+
+    const limit = limitParam ? parseInt(limitParam as string, 10) : 100;
+    const offset = offsetParam ? parseInt(offsetParam as string, 10) : 0;
+    query += " LIMIT ? OFFSET ?";
+    params.push(limit, offset);
+
+    const events = db.prepare(query).all(...params) as Array<{
+      id: string;
+      tenant_id: string;
+      name: string;
+      properties: string;
+      timestamp: string;
+      user_id: string;
+      session_id: string | null;
+    }>;
+
+    const mapped = events.map((e) => ({
+      id: e.id,
+      tenantId: e.tenant_id,
+      name: e.name,
+      properties: JSON.parse(e.properties),
+      timestamp: e.timestamp,
+      userId: e.user_id,
+      sessionId: e.session_id,
+    }));
+
+    res.json({ events: mapped, count: mapped.length });
+  });
+
+  return router;
+}
