+type Direction = 'down' | 'down-left' | 'down-right';
+
+function findSource(grid: string[][]): [number, number] | null {
+  for (let c = 0; c < grid[0].length; c++) {
+    if (grid[0][c] === 'S') return [0, c];
+  }
+  return null;
+}
+
+function nextPos(col: number, dir: Direction): number {
+  switch (dir) {
+    case 'down': return col;
+    case 'down-left': return col - 1;
+    case 'down-right': return col + 1;
+  }
+}
+
+function makeKey(col: number, dir: Direction): string {
+  return `${col},${dir}`;
+}
+
+function parseKey(key: string): [number, Direction] {
+  const commaIdx = key.indexOf(',');
+  return [parseInt(key.substring(0, commaIdx)), key.substring(commaIdx + 1) as Direction];
+}
+
+export function countBeamCells(grid: string[][]): number {
+  if (grid.length === 0 || grid[0].length === 0) return 0;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const source = findSource(grid);
+  if (!source) return 0;
+
+  const visited = new Set<number>();
+  visited.add(source[0] * cols + source[1]);
+
+  // Track unique (col, direction) pairs per row — avoids exponential beam duplication
+  let beamSet = new Set<string>();
+  beamSet.add(makeKey(source[1], 'down'));
+
+  for (let fromRow = source[0]; fromRow < rows - 1; fromRow++) {
+    const nextBeamSet = new Set<string>();
+
+    for (const key of beamSet) {
+      const [col, dir] = parseKey(key);
+      const nc = nextPos(col, dir);
+      const nr = fromRow + 1;
+
+      if (nc < 0 || nc >= cols) continue;
+
+      visited.add(nr * cols + nc);
+
+      if (grid[nr][nc] === '^') {
+        nextBeamSet.add(makeKey(nc, 'down-left'));
+        nextBeamSet.add(makeKey(nc, 'down-right'));
+      } else {
+        nextBeamSet.add(makeKey(nc, dir));
+      }
+    }
+
+    beamSet = nextBeamSet;
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  if (grid.length === 0 || grid[0].length === 0) return 0n;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const source = findSource(grid);
+  if (!source) return 0n;
+
+  let totalPaths = 0n;
+
+  // Row-by-row simulation. Merge beams with the same (col, direction) and sum path counts.
+  let beamMap = new Map<string, bigint>();
+  beamMap.set(makeKey(source[1], 'down'), 1n);
+
+  for (let fromRow = source[0]; fromRow < rows - 1; fromRow++) {
+    const nextBeamMap = new Map<string, bigint>();
+
+    for (const [key, pathCount] of beamMap) {
+      const [col, dir] = parseKey(key);
+      const nc = nextPos(col, dir);
+      const nr = fromRow + 1;
+
+      if (nc < 0 || nc >= cols) {
+        totalPaths += pathCount;
+        continue;
+      }
+
+      if (grid[nr][nc] === '^') {
+        const leftKey = makeKey(nc, 'down-left');
+        const rightKey = makeKey(nc, 'down-right');
+        nextBeamMap.set(leftKey, (nextBeamMap.get(leftKey) ?? 0n) + pathCount);
+        nextBeamMap.set(rightKey, (nextBeamMap.get(rightKey) ?? 0n) + pathCount);
+      } else {
+        const contKey = makeKey(nc, dir);
+        nextBeamMap.set(contKey, (nextBeamMap.get(contKey) ?? 0n) + pathCount);
+      }
+    }
+
+    beamMap = nextBeamMap;
+  }
+
+  for (const [, pathCount] of beamMap) {
+    totalPaths += pathCount;
+  }
+
+  return totalPaths;
+}
