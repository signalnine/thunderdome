ction simulate(\n  gates: Gate[],\n  inputs: Record<string, number>,\n): Record<string, number> {\n  const wires: Record<string, number> = { ...inputs };\n  const remaining = new Set<number>(gates.map((_, i) => i));\n\n  let progress = true;\n  while (remaining.size > 0 && progress) {\n    progress = false;\n    for (const i of remaining) {\n      const gate = gates[i];\n      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {\n        const a = wires[gate.in1];\n        const b = wires[gate.in2];\n        switch (gate.op) {\n          case 'AND':\n            wires[gate.out] = a & b;\n            break;\n          case 'OR':\n            wires[gate.out] = a | b;\n            break;\n          case 'XOR':\n            wires[gate.out] = a ^ b;\n            break;\n        }\n        remaining.delete(i);\n        progress = true;\n      }\n    }\n  }\n\n  return wires;\n}\n\n/**\n * Check if a wire name is an input wire (x## or y##).\n */\nfunction isInputWire(name: string): boolean {\n  return /^[xy]\\d{2}$/.test(name);\n}\n\n/**\n * Check if a wire name is an output wire (z##).\n */\nfunction isOutputWire(name: string): boolean {\n  return /^z\\d{2}$/.test(name);\n}\n\n/**\n * Get the bit number from a wire name like x03 -> 3.\n */\nfunction getBitNum(name: string): number {\n  return parseInt(name.slice(1), 10);\n}\n\n/**\n * Check if a gate has the given input wires (in either order).\n */\nfunction hasInputs(gate: Gate, a: string, b: string): boolean {\n  return (\n    (gate.in1 === a && gate.in2 === b) || (gate.in1 === b && gate.in2 === a)\n  );\n}\n\n/**\n * Find all 8 wires involved in 4 swap pairs in a broken ripple-carry adder.\n *\n * Uses structural analysis of the adder topology:\n * - Bit 0: x00 XOR y00 -> z00, x00 AND y00 -> c00\n * - Bit n (n>0): xNN XOR yNN -> tNN (partial sum)\n *                tNN XOR c(N-1) -> zNN (final sum)\n *                xNN AND yNN -> aNN (generate)\n *                tNN AND c(N-1) -> bNN (propagate)\n 