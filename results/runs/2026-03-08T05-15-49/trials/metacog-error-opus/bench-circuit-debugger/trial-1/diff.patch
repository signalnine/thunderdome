+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+/**
+ * Simulate a circuit of logic gates given initial wire values.
+ * Process gates in dependency order until all gates have fired.
+ */
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>,
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = new Set<number>(gates.map((_, i) => i));
+
+  let progress = true;
+  while (remaining.size > 0 && progress) {
+    progress = false;
+    for (const i of remaining) {
+      const gate = gates[i];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        switch (gate.op) {
+          case 'AND':
+            wires[gate.out] = a & b;
+            break;
+          case 'OR':
+            wires[gate.out] = a | b;
+            break;
+          case 'XOR':
+            wires[gate.out] = a ^ b;
+            break;
+        }
+        remaining.delete(i);
+        progress = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+/**
+ * Check if a wire name is an input wire (x## or y##).
+ */
+function isInputWire(name: string): boolean {
+  return /^[xy]\d{2}$/.test(name);
+}
+
+/**
+ * Check if a wire name is an output wire (z##).
+ */
+function isOutputWire(name: string): boolean {
+  return /^z\d{2}$/.test(name);
+}
+
+/**
+ * Get the bit number from a wire name like x03 -> 3.
+ */
+function getBitNum(name: string): number {
+  return parseInt(name.slice(1), 10);
+}
+
+/**
+ * Check if a gate has the given input wires (in either order).
+ */
+function hasInputs(gate: Gate, a: string, b: string): boolean {
+  return (
+    (gate.in1 === a && gate.in2 === b) || (gate.in1 === b && gate.in2 === a)
+  );
+}
+
+/**
+ * Find all 8 wires involved in 4 swap pairs in a broken ripple-carry adder.
+ *
+ * Uses structural analysis of the adder topology:
+ * - Bit 0: x00 XOR y00 -> z00, x00 AND y00 -> c00
+ * - Bit n (n>0): xNN XOR yNN -> tNN (partial sum)
+ *                tNN XOR c(N-1) -> zNN (final sum)
+ *                xNN AND yNN -> aNN (generate)
+ *                tNN AND c(N-1) -> bNN (propagate)
+ *                aNN OR bNN -> cNN (carry out)
+ * - Last carry -> z(N+1)
+ *
+ * Rules for a correct adder:
+ * 1. XOR gates with two x/y inputs must NOT output to z (except z00)
+ * 2. XOR gates that output to z must have exactly one x/y-XOR gate as input
+ * 3. z outputs (except last) must come from XOR gates
+ * 4. AND gates must not output directly to z (except trivially)
+ * 5. OR gates must not output to z (except the last bit)
+ */
+export function findSwappedWires(gates: Gate[]): string[] {
+  const swapped = new Set<string>();
+
+  // Build lookup structures
+  const gateByOutput = new Map<string, Gate>();
+  for (const gate of gates) {
+    gateByOutput.set(gate.out, gate);
+  }
+
+  // Find the highest z bit
+  let maxZ = 0;
+  for (const gate of gates) {
+    if (isOutputWire(gate.out)) {
+      maxZ = Math.max(maxZ, getBitNum(gate.out));
+    }
+  }
+
+  // Find XOR gates that take x## and y## inputs of the same bit
+  const xyXorByBit = new Map<number, Gate>();
+  for (const gate of gates) {
+    const in1IsX = gate.in1.startsWith('x');
+    const in1IsY = gate.in1.startsWith('y');
+    const in2IsX = gate.in2.startsWith('x');
+    const in2IsY = gate.in2.startsWith('y');
+
+    if ((in1IsX && in2IsY) || (in1IsY && in2IsX)) {
+      const bit1 = getBitNum(gate.in1);
+      const bit2 = getBitNum(gate.in2);
+      if (bit1 === bit2 && gate.op === 'XOR') {
+        xyXorByBit.set(bit1, gate);
+      }
+    }
+  }
+
+  // Rule 1: XOR of x/y inputs (partial sum) should NOT go directly to z##
+  // EXCEPT for bit 0 where x00 XOR y00 -> z00 is correct
+  for (const [bit, gate] of xyXorByBit) {
+    if (bit !== 0 && isOutputWire(gate.out)) {
+      swapped.add(gate.out);
+    }
+  }
+
+  // Rule 2: z## outputs (except the last z bit) must come from XOR gates
+  for (const gate of gates) {
+    if (
+      isOutputWire(gate.out) &&
+      getBitNum(gate.out) !== 0 &&
+      getBitNum(gate.out) !== maxZ
+    ) {
+      if (gate.op !== 'XOR') {
+        swapped.add(gate.out);
+      }
+    }
+  }
+
+  // Rule 3: XOR gates that are NOT x/y XOR gates (i.e., the "sum" XOR gates)
+  // must output to z##. If they don't, their output is swapped.
+  for (const gate of gates) {
+    if (gate.op === 'XOR') {
+      const isXYGate = isInputWire(gate.in1) || isInputWire(gate.in2);
+      if (!isXYGate && !isOutputWire(gate.out)) {
+        swapped.add(gate.out);
+      }
+    }
+  }
+
+  // Rule 4: AND gate outputs should feed into OR gates (they represent
+  // carry-generate or carry-propagate). If an AND gate output feeds into
+  // something that's not an OR gate, it might be swapped.
+  // Exception: bit 0's AND gate (x00 AND y00) feeds directly as carry.
+  for (const gate of gates) {
+    if (gate.op === 'AND') {
+      // Skip bit 0's AND gate
+      if (hasInputs(gate, 'x00', 'y00')) continue;
+
+      // Check what gates consume this output
+      for (const consumer of gates) {
+        if (consumer.in1 === gate.out || consumer.in2 === gate.out) {
+          if (consumer.op !== 'OR') {
+            swapped.add(gate.out);
+          }
+        }
+      }
+    }
+  }
+
+  // Rule 5: OR gate inputs should come from AND gate outputs.
+  // If an OR gate has an input that comes from a non-AND gate, that input wire
+  // is swapped (e.g., an XOR x/y output feeding into an OR gate).
+  // Exception: the gate producing the highest z bit (final carry pass-through).
+  const lastZWire = `z${maxZ.toString().padStart(2, '0')}`;
+  for (const gate of gates) {
+    if (gate.op === 'OR' && gate.out !== lastZWire) {
+      const producer1 = gateByOutput.get(gate.in1);
+      const producer2 = gateByOutput.get(gate.in2);
+      if (producer1 && producer1.op !== 'AND') {
+        swapped.add(gate.in1);
+      }
+      if (producer2 && producer2.op !== 'AND') {
+        swapped.add(gate.in2);
+      }
+    }
+  }
+
+  return Array.from(swapped).sort();
+}
