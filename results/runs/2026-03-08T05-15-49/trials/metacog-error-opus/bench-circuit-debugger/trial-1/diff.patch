placeholder","-}","-","-function doSwaps(gates: Gate[], swaps: [string, string][]): string[] {","-  const swappedWires: string[] = [];","-  for (const [a, b] of swaps) {","-    swappedWires.push(a, b);","-    for (const gate of gates) {","-      if (gate.out === a) {","-        gate.out = b;","-      } else if (gate.out === b) {","-        gate.out = a;","-      }","-    }","-  }","-  return swappedWires;","-}"]}],"originalFile":"import { describe, it, expect } from 'vitest';\nimport { simulate, findSwappedWires, Gate } from './index.js';\n\ndescribe('simulate', () => {\n  it('should handle AND gate', () => {\n    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 0 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 0 });\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n  });\n\n  it('should handle OR gate', () => {\n    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n  });\n\n  it('should handle XOR gate', () => {\n    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 0 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n  });\n\n  it('should process gates in dependency order', () => {\n    const gates: Gate[] = [\n      { op: 'AND', in1: 'c', in2: 'd', out: 'e' }, // depends on c\n      { op: 'XOR', in1: 'a', in2: 'b', out: 'c' }, // produces c\n    ];\n    const result = simulate(gates, { a: 1, b: 0, d: 1 });\n    expect(result.c).toBe(1);\n    expect(result.e).toBe(1);\n  });\n\n  it('should handle a chain of gates', () => {\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'a', in2: 'b', out: 'c' },\n      { op: 'AND', in1: 'c', in2: 'd', out: 'e' },\n      { op: 'OR', in1: 'e', in2: 'f', out: 'g' },\n    ];\n    const result = simulate(gates, { a: 1, b: 0, d: 1, f: 0 });\n    expect(result.c).toBe(1);\n    expect(result.e).toBe(1);\n    expect(result.g).toBe(1);\n  });\n\n  it('should simulate a correct 4-bit adder (0 + 0)', () => {\n    const gates = build4BitAdder();\n    const inputs = makeInputs(4, 0, 0);\n    const result = simulate(gates, inputs);\n    expect(extractZ(result, 5)).toBe(0);\n  });\n\n  it('should simulate a correct 4-bit adder (3 + 5 = 8)', () => {\n    const gates = build4BitAdder();\n    const inputs = makeInputs(4, 3, 5);\n    const result = simulate(gates, inputs);\n    expect(extractZ(result, 5)).toBe(8);\n  });\n\n  it('should simulate a correct 4-bit adder (15 + 15 = 30)', () => {\n    const gates = build4BitAdder();\n    const inputs = makeInputs(4, 15, 15);\n    const result = simulate(gates, inputs);\n    expect(extractZ(result, 5)).toBe(30);\n  });\n\n  it('should simulate a correct 4-bit adder (7 + 1 = 8)', () => {\n    const gates = build4BitAdder();\n    const inputs = makeInputs(4, 7, 1);\n    const result = simulate(gates, inputs);\n    expect(extractZ(result, 5)).toBe(8);\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  it('should find swapped wires in a simple adder', () => {\n    // Build a correct 8-bit adder then swap 4 pairs\n    const gates = build8BitAdder();\n\n    // Swap 4 pairs of output wires\n    const swaps: [string, string][] = [\n      [findGateOut(gates, 'XOR', 'x01', 'y01'), 'z01'], // swap t01 and z01\n      [findGateOut(gates, 'AND', 'x03', 'y03'), findGateOut(gates, 'OR', findGateOut(gates, 'AND', 'x05', 'y05'), findGateOut(gates, 'AND', findGateOut(gates, 'XOR', 'x05', 'y05'), ''))],\n    ];\n\n    // Let me use a simpler approach - build and swap known wires\n    const gates2 = build8BitAdder();\n    const swappedWires = doSwaps(gates2, [\n      ['z01', findGateOutByOp(gates2, 'XOR', isXY(1))],\n      ['z03', findGateOutByOp(gates2, 'AND', isXY(3))],\n      ['z05', findGateOutByOp(gates2, 'AND', isXY(5))],\n      ['z07', findGateOutByOp(gates2, 'OR', hasBit(6))],\n    ]);\n\n    const result = findSwappedWires(gates2);\n    expect(result).toHaveLength(8);\n    expect(result).toEqual([...swappedWires].sort());\n  });\n\n  it('should find 8 swapped wires in a constructed broken adder', () => {\n    const gates = buildBrokenAdder();\n    const result = findSwappedWires(gates.gates);\n    expect(result).toHaveLength(8);\n    expect(result).toEqual(gates.swappedWires.sort());\n  });\n\n  it('should return sorted array', () => {\n    const gates = buildBrokenAdder();\n    const result = findSwappedWires(gates.gates);\n    const sorted = [...result].sort();\n    expect(result).toEqual(sorted);\n  });\n});\n\n// Helper functions\n\nfunction pad2(n: number): string {\n  return n.toString().padStart(2, '0');\n}\n\nfunction makeInputs(\n  bits: number,\n  x: number,\n  y: number,\n): Record<string, number> {\n  const inputs: Record<string, number> = {};\n  for (let i = 0; i < bits; i++) {\n    inputs[`x${pad2(i)}`] = (x >> i) & 1;\n    inputs[`y${pad2(i)}`] = (y >> i) & 1;\n  }\n  return inputs;\n}\n\nfunction extractZ(wires: Record<string, number>, bits: number): number {\n  let result = 0;\n  for (let i = 0; i < bits; i++) {\n    result |= (wires[`z${pad2(i)}`] ?? 0) << i;\n  }\n  return result;\n}\n\nfunction build4BitAdder(): Gate[] {\n  const gates: Gate[] = [];\n\n  // Bit 0: half adder\n  gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });\n  gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });\n\n  // Bits 1-3: full adder\n  for (let i = 1; i <= 3; i++) {\n    const xi = `x${pad2(i)}`;\n    const yi = `y${pad2(i)}`;\n    const ti = `t${pad2(i)}`;\n    const ai = `a${pad2(i)}`;\n    const bi = `b${pad2(i)}`;\n    const ci = `c${pad2(i)}`;\n    const zi = `z${pad2(i)}`;\n    const cPrev = `c${pad2(i - 1)}`;\n\n    gates.push({ op: 'XOR', in1: xi, in2: yi, out: ti });\n    gates.push({ op: 'XOR', in1: ti, in2: cPrev, out: zi });\n    gates.push({ op: 'AND', in1: xi, in2: yi, out: ai });\n    gates.push({ op: 'AND', in1: ti, in2: cPrev, out: bi });\n    gates.push({ op: 'OR', in1: ai, in2: bi, out: ci });\n  }\n\n  // Final carry\n  gates.push({ op: 'OR', in1: 'c03', in2: 'c03', out: 'z04' });\n\n  return gates;\n}\n\nfunction buildNBitAdder(n: number): Gate[] {\n  const gates: Gate[] = [];\n\n  // Bit 0: half adder\n  gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });\n  gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });\n\n  // Bits 1 to n-1: full adder\n  for (let i = 1; i < n; i++) {\n    const xi = `x${pad2(i)}`;\n    const yi = `y${pad2(i)}`;\n    const ti = `t${pad2(i)}`;\n    const ai = `a${pad2(i)}`;\n    const bi = `b${pad2(i)}`;\n    const ci = `c${pad2(i)}`;\n    const zi = `z${pad2(i)}`;\n    const cPrev = `c${pad2(i - 1)}`;\n\n    gates.push({ op: 'XOR', in1: xi, in2: yi, out: ti });\n    gates.push({ op: 'XOR', in1: ti, in2: cPrev, out: zi });\n    gates.push({ op: 'AND', in1: xi, in2: yi, out: ai });\n    gates.push({ op: 'AND', in1: ti, in2: cPrev, out: bi });\n    gates.push({ op: 'OR', in1: ai, in2: bi, out: ci });\n  }\n\n  // Final carry -> last z\n  const lastC = `c${pad2(n - 1)}`;\n  const lastZ = `z${pad2(n)}`;\n  // Use an OR gate with same input to pass through\n  gates.push({ op: 'OR', in1: lastC, in2: lastC, out: lastZ });\n\n  return gates;\n}\n\nfunction build8BitAdder(): Gate[] {\n  return buildNBitAdder(8);\n}\n\nfunction buildBrokenAdder(): { gates: Gate[]; swappedWires: string[] } {\n  const gates = buildNBitAdder(10);\n\n  // Swap 4 pairs:\n  // Pair 1: swap z01 with t01 (XOR output going to z, and actual z)\n  // Pair 2: swap z03 with a03 (AND generate output going to z)\n  // Pair 3: swap t05 with a05 (two internal wires)\n  // Pair 4: swap z07 with c06 (carry output going to z)\n\n  const swaps: [string, string][] = [\n    ['z01', 't01'],\n    ['z03', 'a03'],\n    ['t05', 'a05'],\n    ['z07', 'c06'],\n  ];\n\n  const swappedWires: string[] = [];\n  for (const [a, b] of swaps) {\n    swappedWires.push(a, b);\n    for (const gate of gates) {\n      if (gate.out === a) {\n        gate.out = b;\n      } else if (gate.out === b) {\n        gate.out = a;\n      }\n    }\n  }\n\n  return { gates, swappedWires };\n}\n\nfunction findGateOut(gates: Gate[], op: string, in1: string, in2: string): string {\n  for (const gate of gates) {\n    if (gate.op === op && ((gate.in1 === in1 && gate.in2 === in2) || (gate.in1 === in2 && gate.in2 === in1))) {\n      return gate.out;\n    }\n  }\n  return '';\n}\n\nfunction findGateOutByOp(gates: Gate[], op: string, pred: (g: Gate) => boolean): string {\n  for (const gate of gates) {\n    if (gate.op === op && pred(gate)) {\n      return gate.out;\n    }\n  }\n  return '';\n}\n\nfunction isXY(bit: number): (g: Gate) => boolean {\n  const x = `x${pad2(bit)}`;\n  const y = `y${pad2(bit)}`;\n  return (g: Gate) =>\n    (g.in1 === x && g.in2 === y) || (g.in1 === y && g.in2 === x);\n}\n\nfunction hasBit(_bit: number): (g: Gate) => boolean {\n  return (_g: Gate) => true; // placeholder\n}\n\nfunction doSwaps(gates: Gate[], swaps: [string, string][]): string[] {\n  const swappedWires: string[] = [];\n  for (const [a, b] of swaps) {\n    swappedWires.push(a, b);\n    for (const gate of gates) {\n      if (gate.out === a) {\n        gate.out = b;\n      } else if (gate.out === b) {\n        gate.out = a;\n      }\n    }\n  }\n  return swappedWires;\n}\n"}}
