+      if (this.peek().type === 'RANGE') {
+        const rangeToken = this.advance();
+        const rangeValues = this.resolveRange(rangeToken.value as string);
+        values.push(...rangeValues);
+      } else {
+        values.push(this.parseExpression());
+      }
+    };
+
+    addArg();
+    while (this.peek().type === 'COMMA') {
+      this.advance(); // consume ','
+      addArg();
+    }
+
+    return values;
+  }
+
+  private parseFunction(): CellValue {
+    const funcToken = this.advance();
+    const funcName = funcToken.value as string;
+    this.expect('LPAREN');
+
+    if (funcName === 'IF') {
+      const condition = this.parseExpression();
+      this.expect('COMMA');
+      const trueVal = this.parseExpression();
+      this.expect('COMMA');
+      const falseVal = this.parseExpression();
+      this.expect('RPAREN');
+      return condition ? trueVal : falseVal;
+    }
+
+    const args = this.collectArgs();
+    this.expect('RPAREN');
+
+    const numericValues = args.filter((v): v is number => typeof v === 'number');
+
+    switch (funcName) {
+      case 'SUM':
+        return numericValues.reduce((sum, v) => sum + v, 0);
+      case 'AVERAGE':
+        return numericValues.length === 0 ? 0 : numericValues.reduce((sum, v) => sum + v, 0) / numericValues.length;
+      case 'MIN':
+        return numericValues.length === 0 ? 0 : Math.min(...numericValues);
+      case 'MAX':
+        return numericValues.length === 0 ? 0 : Math.max(...numericValues);
+      case 'COUNT':
+        return numericValues.length;
+      default:
+        throw new Error(`Unknown function: ${funcName}`);
+    }
+  }
+}
+
+function evaluateFormula(
+  formula: string,
+  getCellValue: (ref: string) => CellValue
+): { value: CellValue; dependencies: Set<string> } {
+  // Strip the leading '='
+  const expr = formula.slice(1);
+  const tokens = tokenize(expr);
+  const parser = new Parser(tokens, getCellValue);
+  return parser.parse();
+}
+
+export class Spreadsheet {
+  private cells: Map<string, CellData> = new Map();
+  // Reverse dependency map: cell -> set of cells that depend on it
+  private dependents: Map<string, Set<string>> = new Map();
+
+  set(cell: string, value: string | number | boolean): void {
+    const ref = cell.toUpperCase();
+
+    // Remove old reverse dependencies
+    const oldData = this.cells.get(ref);
+    if (oldData) {
+      for (const dep of oldData.dependencies) {
+        const revDeps = this.dependents.get(dep);
+        if (revDeps) {
+          revDeps.delete(ref);
+        }
+      }
+    }
+
+    const isFormula = typeof value === 'string' && value.startsWith('=');
+
+    if (isFormula) {
+      // Evaluate the formula and extract dependencies
+      const { value: computed, dependencies } = evaluateFormula(
+        value,
+        (r) => this.getComputedValue(r)
+      );
+
+      // Check for circular dependencies before committing
+      this.checkCircular(ref, dependencies);
+
+      this.cells.set(ref, {
+        raw: value,
+        computed,
+        formula: true,
+        dependencies,
+      });
+
+      // Register reverse dependencies
+      for (const dep of dependencies) {
+        if (!this.dependents.has(dep)) {
+          this.dependents.set(dep, new Set());
+        }
+        this.dependents.get(dep)!.add(ref);
+      }
+    } else {
+      this.cells.set(ref, {
+        raw: value,
+        computed: value,
+        formula: false,
+        dependencies: new Set(),
+      });
+    }
+
+    // Propagate changes to all dependents
+    this.propagate(ref);
+  }
+
+  get(cell: string): CellValue {
+    return this.getComputedValue(cell.toUpperCase());
+  }
+
+  getDisplay(cell: string): string {
+    const val = this.get(cell);
+    if (val === null) return '';
+    return String(val);
+  }
+
+  getCells(): Map<string, CellValue> {
+    const result = new Map<string, CellValue>();
+    for (const [ref, data] of this.cells) {
+      result.set(ref, data.computed);
+    }
+    return result;
+  }
+
+  private getComputedValue(ref: string): CellValue {
+    const data = this.cells.get(ref);
+    if (!data) return null;
+    return data.computed;
+  }
+
+  private checkCircular(cell: string, dependencies: Set<string>): void {
+    // BFS/DFS from each dependency to see if any path leads back to cell
+    const visited = new Set<string>();
+    const stack = [...dependencies];
+
+    while (stack.length > 0) {
+      const current = stack.pop()!;
+      if (current === cell) {
+        throw new Error(`Circular reference detected: ${cell}`);
+      }
+      if (visited.has(current)) continue;
+      visited.add(current);
+
+      const currentData = this.cells.get(current);
+      if (currentData) {
+        for (const dep of currentData.dependencies) {
+          stack.push(dep);
+        }
+      }
+    }
+  }
+
+  private propagate(changedCell: string): void {
+    // Collect all cells that need re-evaluation using topological sort
+    const toReeval = this.getTransitiveDependents(changedCell);
+
+    // Re-evaluate each cell in topological order
+    for (const ref of toReeval) {
+      const data = this.cells.get(ref);
+      if (data && data.formula) {
+        // Remove old reverse deps
+        for (const dep of data.dependencies) {
+          const revDeps = this.dependents.get(dep);
+          if (revDeps) {
+            revDeps.delete(ref);
+          }
+        }
+
+        // Re-evaluate
+        const { value: computed, dependencies } = evaluateFormula(
+          data.raw as string,
+          (r) => this.getComputedValue(r)
+        );
+
+        data.computed = computed;
+        data.dependencies = dependencies;
+
+        // Re-register reverse deps
+        for (const dep of dependencies) {
+          if (!this.dependents.has(dep)) {
+            this.dependents.set(dep, new Set());
+          }
+          this.dependents.get(dep)!.add(ref);
+        }
+      }
+    }
+  }
+
+  private getTransitiveDependents(cell: string): string[] {
+    // BFS to find all transitive dependents, then topological sort
+    const visited = new Set<string>();
+    const queue = [cell];
+    const allDependents: string[] = [];
+
+    while (queue.length > 0) {
+      const current = queue.shift()!;
+      const deps = this.dependents.get(current);
+      if (deps) {
+        for (const dep of deps) {
+          if (!visited.has(dep)) {
+            visited.add(dep);
+            allDependents.push(dep);
+            queue.push(dep);
+          }
+        }
+      }
+    }
+
+    // Topological sort of the dependents
+    // Build subgraph of just these cells
+    if (allDependents.length <= 1) return allDependents;
+
+    const depSet = new Set(allDependents);
+    const inDegree = new Map<string, number>();
+    const graph = new Map<string, string[]>();
+
+    for (const ref of allDependents) {
+      inDegree.set(ref, 0);
+      graph.set(ref, []);
+    }
+
+    for (const ref of allDependents) {
+      const data = this.cells.get(ref);
+      if (data) {
+        for (const dep of data.dependencies) {
+          if (depSet.has(dep)) {
+            graph.get(dep)!.push(ref);
+            inDegree.set(ref, (inDegree.get(ref) || 0) + 1);
+          }
+        }
+      }
+    }
+
+    const sorted: string[] = [];
+    const zeroQueue: string[] = [];
+    for (const [ref, deg] of inDegree) {
+      if (deg === 0) zeroQueue.push(ref);
+    }
+
+    while (zeroQueue.length > 0) {
+      const ref = zeroQueue.shift()!;
+      sorted.push(ref);
+      for (const neighbor of graph.get(ref) || []) {
+        const newDeg = (inDegree.get(neighbor) || 0) - 1;
+        inDegree.set(neighbor, newDeg);
+        if (newDeg === 0) zeroQueue.push(neighbor);
+      }
+    }
+
+    return sorted;
+  }
+}
