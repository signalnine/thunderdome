+import { describe, it, expect } from 'vitest';
+import { Spreadsheet } from './index.js';
+
+describe('Spreadsheet', () => {
+  describe('basic values', () => {
+    it('should store and retrieve numbers', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 42);
+      expect(sheet.get('A1')).toBe(42);
+    });
+
+    it('should store and retrieve strings', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 'hello');
+      expect(sheet.get('A1')).toBe('hello');
+    });
+
+    it('should store and retrieve booleans', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', true);
+      expect(sheet.get('A1')).toBe(true);
+      sheet.set('A2', false);
+      expect(sheet.get('A2')).toBe(false);
+    });
+
+    it('should return null for empty cells', () => {
+      const sheet = new Spreadsheet();
+      expect(sheet.get('A1')).toBe(null);
+    });
+
+    it('should handle floating point numbers', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 3.14);
+      expect(sheet.get('A1')).toBe(3.14);
+    });
+
+    it('should overwrite existing values', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A1', 20);
+      expect(sheet.get('A1')).toBe(20);
+    });
+  });
+
+  describe('getDisplay', () => {
+    it('should display numbers as strings', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 42);
+      expect(sheet.getDisplay('A1')).toBe('42');
+    });
+
+    it('should display strings as-is', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 'hello');
+      expect(sheet.getDisplay('A1')).toBe('hello');
+    });
+
+    it('should display booleans as strings', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', true);
+      expect(sheet.getDisplay('A1')).toBe('true');
+    });
+
+    it('should display empty string for empty cells', () => {
+      const sheet = new Spreadsheet();
+      expect(sheet.getDisplay('A1')).toBe('');
+    });
+
+    it('should display computed formula results', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.getDisplay('A3')).toBe('30');
+    });
+  });
+
+  describe('getCells', () => {
+    it('should return all non-empty cells', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('B1', 20);
+      sheet.set('C1', '=A1+B1');
+      const cells = sheet.getCells();
+      expect(cells.size).toBe(3);
+      expect(cells.get('A1')).toBe(10);
+      expect(cells.get('B1')).toBe(20);
+      expect(cells.get('C1')).toBe(30);
+    });
+
+    it('should return empty map when no cells set', () => {
+      const sheet = new Spreadsheet();
+      const cells = sheet.getCells();
+      expect(cells.size).toBe(0);
+    });
+  });
+
+  describe('simple formulas', () => {
+    it('should evaluate addition', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should evaluate subtraction', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 30);
+      sheet.set('A2', 10);
+      sheet.set('A3', '=A1-A2');
+      expect(sheet.get('A3')).toBe(20);
+    });
+
+    it('should evaluate multiplication', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 5);
+      sheet.set('A2', 6);
+      sheet.set('A3', '=A1*A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should evaluate division', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 20);
+      sheet.set('A2', 4);
+      sheet.set('A3', '=A1/A2');
+      expect(sheet.get('A3')).toBe(5);
+    });
+
+    it('should respect operator precedence', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 2);
+      sheet.set('A2', 3);
+      sheet.set('A3', 4);
+      sheet.set('A4', '=A1+A2*A3');
+      expect(sheet.get('A4')).toBe(14); // 2 + 3*4 = 14
+    });
+
+    it('should handle parentheses', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 2);
+      sheet.set('A2', 3);
+      sheet.set('A3', 4);
+      sheet.set('A4', '=(A1+A2)*A3');
+      expect(sheet.get('A4')).toBe(20); // (2+3)*4 = 20
+    });
+
+    it('should handle number literals in formulas', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', '=A1+5');
+      expect(sheet.get('A2')).toBe(15);
+    });
+
+    it('should handle formulas with only literals', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', '=2+3*4');
+      expect(sheet.get('A1')).toBe(14);
+    });
+
+    it('should handle unary minus', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', '=-A1');
+      expect(sheet.get('A2')).toBe(-10);
+    });
+
+    it('should handle references to empty cells as 0', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', '=A1+B1');
+      expect(sheet.get('A2')).toBe(10); // B1 is null, treated as 0
+    });
+  });
+
+  describe('cell reference formats', () => {
+    it('should handle single letter columns', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 1);
+      sheet.set('Z1', 26);
+      expect(sheet.get('A1')).toBe(1);
+      expect(sheet.get('Z1')).toBe(26);
+    });
+
+    it('should handle multi-letter columns', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('AA1', 27);
+      sheet.set('AB1', 28);
+      sheet.set('AZ1', 52);
+      expect(sheet.get('AA1')).toBe(27);
+      expect(sheet.get('AB1')).toBe(28);
+      expect(sheet.get('AZ1')).toBe(52);
+    });
+
+    it('should handle large row numbers', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A100', 42);
+      expect(sheet.get('A100')).toBe(42);
+    });
+
+    it('should be case-insensitive for cell references', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('a1', 42);
+      expect(sheet.get('A1')).toBe(42);
+      expect(sheet.get('a1')).toBe(42);
+    });
+  });
+
+  describe('comparison operators', () => {
+    it('should evaluate greater than', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 5);
+      sheet.set('A3', '=A1>A2');
+      expect(sheet.get('A3')).toBe(true);
+    });
+
+    it('should evaluate less than', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 3);
+      sheet.set('A2', 5);
+      sheet.set('A3', '=A1<A2');
+      expect(sheet.get('A3')).toBe(true);
+    });
+
+    it('should evaluate equality', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 5);
+      sheet.set('A2', 5);
+      sheet.set('A3', '=A1=A2');
+      expect(sheet.get('A3')).toBe(true);
+    });
+
+    it('should evaluate not equal', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 5);
+      sheet.set('A2', 10);
+      sheet.set('A3', '=A1<>A2');
+      expect(sheet.get('A3')).toBe(true);
+    });
+
+    it('should evaluate greater than or equal', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 5);
+      sheet.set('A2', 5);
+      sheet.set('A3', '=A1>=A2');
+      expect(sheet.get('A3')).toBe(true);
+    });
+
+    it('should evaluate less than or equal', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 3);
+      sheet.set('A2', 5);
+      sheet.set('A3', '=A1<=A2');
+      expect(sheet.get('A3')).toBe(true);
+    });
+  });
+
+  describe('SUM function', () => {
+    it('should sum a column range', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', 30);
+      sheet.set('A4', '=SUM(A1:A3)');
+      expect(sheet.get('A4')).toBe(60);
+    });
+
+    it('should sum a row range', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
