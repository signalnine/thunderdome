+
+function columnToIndex(col: string): number {
+  let index = 0;
+  for (let i = 0; i < col.length; i++) {
+    index = index * 26 + (col.charCodeAt(i) - 64);
+  }
+  return index;
+}
+
+function indexToColumn(index: number): string {
+  let col = '';
+  while (index > 0) {
+    const remainder = (index - 1) % 26;
+    col = String.fromCharCode(65 + remainder) + col;
+    index = Math.floor((index - 1) / 26);
+  }
+  return col;
+}
+
+function parseCellRef(ref: string): { col: string; row: number } {
+  const match = ref.match(/^([A-Z]+)(\d+)$/);
+  if (!match) throw new Error(`Invalid cell reference: ${ref}`);
+  return { col: match[1], row: parseInt(match[2], 10) };
+}
+
+function expandRange(start: string, end: string): string[] {
+  const s = parseCellRef(start);
+  const e = parseCellRef(end);
+  const startCol = columnToIndex(s.col);
+  const endCol = columnToIndex(e.col);
+  const startRow = s.row;
+  const endRow = e.row;
+  const minCol = Math.min(startCol, endCol);
+  const maxCol = Math.max(startCol, endCol);
+  const minRow = Math.min(startRow, endRow);
+  const maxRow = Math.max(startRow, endRow);
+
+  const cells: string[] = [];
+  for (let c = minCol; c <= maxCol; c++) {
+    for (let r = minRow; r <= maxRow; r++) {
+      cells.push(indexToColumn(c) + r);
+    }
+  }
+  return cells;
+}
+
+// Token types for the formula parser
+type TokenType =
+  | 'NUMBER'
+  | 'STRING'
+  | 'BOOLEAN'
+  | 'CELL_REF'
+  | 'RANGE'
+  | 'FUNCTION'
+  | 'LPAREN'
+  | 'RPAREN'
+  | 'COMMA'
+  | 'PLUS'
+  | 'MINUS'
+  | 'STAR'
+  | 'SLASH'
+  | 'GT'
+  | 'LT'
+  | 'GTE'
+  | 'LTE'
+  | 'EQ'
+  | 'NEQ'
+  | 'EOF';
