],\n   156→  rank: number,\n   157→  pivotCol: number[],\n   158→  freeVars: number[],\n   159→  numButtons: number\n   160→): number[] | null {\n   161→  // Split free variables into two halves\n   162→  const numFree = freeVars.length;\n   163→  const half1 = Math.floor(numFree / 2);\n   164→  const half2 = numFree - half1;\n   165→\n   166→  // For each free variable, precompute its effect on pivot variables\n   167→  // When free var freeVars[i] = 1, it flips pivot variable pivotCol[r]\n   168→  // if matrix[r][freeVars[i]] = 1\n   169→  // We represent the effect as: which pivot variables get flipped, and the free var itself\n   170→\n   171→  // Precompute: for a given free variable assignment, what buttons are pressed?\n   172→  // Pivot buttons: determined by the free vars + the base solution (matrix[r][numButtons])\n   173→  // Free buttons: directly from the assignment\n   174→\n   175→  // Base solution (all free vars = 0):\n   176→  const baseSolution = new Array(numButtons).fill(0);\n   177→  for (let r = 0; r < rank; r++) {\n   178→    baseSolution[pivotCol[r]] = matrix[r][numButtons];\n   179→  }\n   180→\n   181→  // Effect of each free variable on the solution:\n   182→  // freeEffects[i] = array of button indices whose value flips when freeVars[i] is toggled\n   183→  // This includes freeVars[i] itself (goes from 0 to 1) and any pivot vars that flip\n   184→  const freeEffects: number[][] = [];\n   185→  for (let i = 0; i < numFree; i++) {\n   186→    const effects: number[] = [freeVars[i]];\n   187→    for (let r = 0; r < rank; r++) {\n   188→      if (matrix[r][freeVars[i]] === 1) {\n   189→        effects.push(pivotCol[r]);\n   190→      }\n   191→    }\n   192→    freeEffects.push(effects);\n   193→  }\n   194→\n   195→  // We represent each solution as a bitmask of numButtons bits\n   196→  // Base solution bitmask:\n   197→  let baseMask = 0n;\n   198→  for (let j = 0; j < numButtons; j++) {\n   199→    if (baseSolution[j]) baseMask |= 1n << BigInt(j);\n   200→  }\n   201→\n   202→  // Effect masks for each free variable:\n   203→  const effectMasks: bigint[] = [];\n   204→  for (let i = 0; i < numFree; i++) {\n   205→    let mask = 0n;\n   206→    for (const btn of freeEffects[i]) {\n   207→      mask ^= 1n << BigInt(btn);\n   208→    }\n   209→    effectMasks.push(mask);\n   210→  }\n   211→\n   212→  // First half: enumerate all 2^half1 combinations\n   213→  const half1Size = 1 << half1;\n   214→  // Store: map from effect XOR -> { count, mask, freeAssignment }\n   215→  // But we want minimum count, so we store the best for each XOR pattern\n   216→  // Actually for meet-in-middle, we compute the XOR effect of first half,\n   217→  // then for second half we find the complementary XOR that minimizes total count\n   218→\n   219→  // For first half, compute: xorEffect on baseMask, number of 1-bits in result\n   220→  interface HalfResult {\n   221→    xorMask: bigint; // XOR mask applied to baseMask\n   222→    count: number; // popcount of (baseMask ^ xorMask) considering only the effect\n   223→    assignment: number; // bitmask of free var assignment for first half\n   224→  }\n   225→\n   226→  // Group first half results by their xorMask\n   227→  const firstHalfMap = new Map<bigint, { bestCount: number; bestAssignment: number }>();\n   228→\n   229→  for (let mask = 0; mask < half1Size; mask++) {\n   230→    let xorMask = 0n;\n   231→    for (let i = 0; i < half1; i++) {\n   232→      if ((mask >> i) & 1) {\n   233→        xorMask ^= effectMasks[i];\n   234→      }\n   235→    }\n   236→\n   237→    // The full solution mask so far (with second half all 0) is baseMask ^ xorMask\n   238→    // But we need to combine with second half, so store the xorMask\n   239→    const existing = firstHalfMap.get(xorMask);\n   240→    if (!existing) {\n   241→      firstHalfMap.set(xorMask, { bestCount: popcount(xorMask), bestAssignment: mask });\n   242→    }\n   243→    // We can't directly compare counts