t = count;\n   291→        bestButtons = pressed;\n   292→      }\n   293→      return;\n   294→    }\n   295→\n   296→    // Try free var = 0\n   297→    search(idx + 1, currentMask);\n   298→    // Try free var = 1\n   299→    search(idx + 1, currentMask ^ effectMasks[idx]);\n   300→  }\n   301→\n   302→  search(0, baseMask);\n   303→  return bestButtons;\n   304→}\n   305→\n   306→function popcount(n: bigint): number {\n   307→  let count = 0;\n   308→  while (n > 0n) {\n   309→    n &= n - 1n;\n   310→    count++;\n   311→  }\n   312→  return count;\n   313→}\n   314→\n   315→/**\n   316→ * Compare two sorted arrays lexicographically.\n   317→ * Returns negative if a < b, positive if a > b, 0 if equal.\n   318→ */\n   319→function compareLex(a: number[], b: number[]): number {\n   320→  const len = Math.min(a.length, b.length);\n   321→  for (let i = 0; i < len; i++) {\n   322→    if (a[i] !== b[i]) return a[i] - b[i];\n   323→  }\n   324→  return a.length - b.length;\n   325→}\n   326→\n   327→/**\n   328→ * Modular arithmetic helpers for GF(p)\n   329→ */\n   330→function modInverse(a: number, p: number): number {\n   331→  // Extended Euclidean algorithm\n   332→  let [old_r, r] = [a, p];\n   333→  let [old_s, s] = [1, 0];\n   334→  while (r !== 0) {\n   335→    const q = Math.floor(old_r / r);\n   336→    [old_r, r] = [r, old_r - q * r];\n   337→    [old_s, s] = [s, old_s - q * s];\n   338→  }\n   339→  return ((old_s % p) + p) % p;\n   340→}\n   341→\n   342→function mod(a: number, p: number): number {\n   343→  return ((a % p) + p) % p;\n   344→}\n   345→\n   346→/**\n   347→ * Solve counter puzzle over GF(p) using Gaussian elimination.\n   348→ * Find button presses (0 to modulus-1 each) that produce target counter values,\n   349→ * minimizing total presses, then lexicographically smallest.\n   350→ */\n   351→export function solveCounter(\n   352→  lights: number[],\n   353→  buttons: number[][],\n   354→  modulus: number\n   355→): number[] | null {\n   356→  const numLights = lights.length;\n   357→  const numButtons = buttons.length;\n   358→\n   359→  if (numButtons === 0) {\n   360→    return lights.every((l) => l === 0) ? [] : null;\n   361→  }\n   362→\n   363→  // Build augmented matrix over GF(modulus): each row is a counter,\n   364→  // columns are buttons + 1 (target column).\n   365→  // matrix[counter][button] = 1 if button affects that counter (increments by 1)\n   366→  // matrix[counter][numButtons] = target value for that counter\n   367→  const matrix: number[][] = [];\n   368→  for (let i = 0; i < numLights; i++) {\n   369→    const row = new Array(numButtons + 1).fill(0);\n   370→    row[numButtons] = mod(lights[i], modulus);\n   371→    matrix.push(row);\n   372→  }\n   373→  for (let j = 0; j < numButtons; j++) {\n   374→    for (const counter of buttons[j]) {\n   375→      if (counter >= 0 && counter < numLights) {\n   376→        matrix[counter][j] = mod(matrix[counter][j] + 1, modulus);\n   377→      }\n   378→    }\n   379→  }\n   380→\n   381→  // Gaussian elimination over GF(modulus) with partial pivoting\n   382→  const pivotCol: number[] = new Array(numLights).fill(-1);\n   383→  let rank = 0;\n   384→\n   385→  for (let col = 0; col < numButtons && rank < numLights; col++) {\n   386→    // Find pivot row\n   387→    let pivotR = -1;\n   388→    for (let row = rank; row < numLights; row++) {\n   389→      if (matrix[row][col] !== 0) {\n   390→        pivotR = row;\n   391→        break;\n   392→      }\n   393→    }\n   394→    if (pivotR === -1) continue;\n   395→\n   396→    // Swap rows\n   397→    [matrix[rank], matrix[pivotR]] = [matrix[pivotR], matrix[rank]];\n   398→    pivotCol[rank] = col;\n   399→\n   400→    // Normalize pivot row so pivot element = 1\n   401→    const inv = modInverse(matrix[rank][col], modulus);\n   402→    for (let c = 0; c <= numButtons; c++) {\n   403→      matrix[rank][c] = mod(matrix[rank][c] * inv, modulus);\n   404→    }\n   405→\n   406→    // El