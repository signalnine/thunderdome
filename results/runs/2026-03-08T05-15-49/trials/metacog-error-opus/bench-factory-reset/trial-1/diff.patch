update","filePath":"/workspace/src/index.ts","content":"export interface Machine {\n  target: boolean[];\n  buttons: number[][];\n}\n\n/**\n * Solve toggle puzzle over GF(2) using Gaussian elimination.\n * Find minimum set of buttons (then lexicographically smallest) to press\n * so that toggling produces the target configuration.\n */\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const numLights = target.length;\n  const numButtons = buttons.length;\n\n  if (numButtons === 0) {\n    return target.every((t) => !t) ? [] : null;\n  }\n\n  // Build augmented matrix over GF(2): rows = lights, cols = buttons + augmented col\n  const matrix: number[][] = [];\n  for (let i = 0; i < numLights; i++) {\n    const row = new Array(numButtons + 1).fill(0);\n    row[numButtons] = target[i] ? 1 : 0;\n    matrix.push(row);\n  }\n  for (let j = 0; j < numButtons; j++) {\n    for (const light of buttons[j]) {\n      if (light >= 0 && light < numLights) {\n        matrix[light][j] ^= 1;\n      }\n    }\n  }\n\n  // Gaussian elimination over GF(2)\n  const pivotCol: number[] = [];\n  let rank = 0;\n\n  for (let col = 0; col < numButtons && rank < numLights; col++) {\n    let pivotR = -1;\n    for (let row = rank; row < numLights; row++) {\n      if (matrix[row][col] === 1) {\n        pivotR = row;\n        break;\n      }\n    }\n    if (pivotR === -1) continue;\n\n    [matrix[rank], matrix[pivotR]] = [matrix[pivotR], matrix[rank]];\n    pivotCol.push(col);\n\n    for (let row = 0; row < numLights; row++) {\n      if (row !== rank && matrix[row][col] === 1) {\n        for (let c = col; c <= numButtons; c++) {\n          matrix[row][c] ^= matrix[rank][c];\n        }\n      }\n    }\n    rank++;\n  }\n\n  // Check for inconsistency\n  for (let row = rank; row < numLights; row++) {\n    if (matrix[row][numButtons] === 1) {\n      return null;\n    }\n  }\n\n  // Identify free variables\n  const isPivot = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let col = 0; col < numButtons; col++) {\n    if (!isPivot.has(col)) {\n      freeVars.push(col);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  // Precompute: for each pivot row, which free variables affect it\n  // After RREF, solution[pivotCol[r]] = matrix[r][numButtons] XOR (XOR of matrix[r][freeVar] * freeVar)\n  // Since matrix is in RREF, matrix[r][c] for c > pivotCol[r] are the only nonzero non-augmented entries\n\n  // For the toggle problem, we need minimum Hamming weight solution, then lex smallest.\n  // We enumerate free variable assignments. Each assignment determines the full solution.\n\n  // Use BigInt bitmask representation for efficient popcount and comparison.\n  // Base solution (all free vars = 0):\n  let baseMask = 0n;\n  for (let r = 0; r < rank; r++) {\n    if (matrix[r][numButtons] === 1) {\n      baseMask |= 1n << BigInt(pivotCol[r]);\n    }\n  }\n\n  // Effect mask for each free variable: toggling freeVars[i] flips these bits\n  const effectMasks: bigint[] = [];\n  for (let i = 0; i < numFree; i++) {\n    let mask = 1n << BigInt(freeVars[i]); // The free variable itself\n    for (let r = 0; r < rank; r++) {\n      if (matrix[r][freeVars[i]] === 1) {\n        mask ^= 1n << BigInt(pivotCol[r]);\n      }\n    }\n    effectMasks.push(mask);\n  }\n\n  // Branch and bound over free variable assignments\n  let bestMask = -1n;\n  let bestCount = numButtons + 1;\n\n  function search(idx: number, currentMask: bigint): void {\n    if (idx === numFree) {\n      const count = popcount(currentMask);\n      if (count < bestCount || (count === bestCount && compareBigMask(currentMask, bestMask) < 0)) {\n        bestCount = count;\n        bestMask = currentMask;\n      }\n      return;\n    }\n\n    // Pruning: current popcount is already >= bestCount, no point continuing\n    // (toggling more free vars can only change count by +/- small amounts,\n    // but we can't guarantee improvement, so this is a weak bound)\n    // A tighter bound: current popcount provides a lower bound since\n    // remaining free vars can reduce it by at most numFree - idx\n    const currentCount = popcount(currentMask);\n    if (currentCount - (numFree - idx) >= bestCount) {\n      return; // Even if every remaining free var reduces count by 1, can't beat best\n    }\n\n    // Try free var = 0 first (prefer fewer presses for lex ordering of button indices)\n    search(idx + 1, currentMask);\n    // Try free var = 1\n    search(idx + 1, currentMask ^ effectMasks[idx]);\n  }\n\n  search(0, baseMask);\n\n  if (bestMask === -1n) return null;\n\n  // Extract pressed button indices\n  const result: number[] = [];\n  for (let j = 0; j < numButtons; j++) {\n    if ((bestMask >> BigInt(j)) & 1n) {\n      result.push(j);\n    }\n  }\n  return result;\n}\n\nfunction popcount(n: bigint): number {\n  let count = 0;\n  let v = n;\n  while (v > 0n) {\n    v &= v - 1n;\n    count++;\n  }\n  return count;\n}\n\n/**\n * Compare two bitmasks as sets of button indices for lexicographic ordering.\n * We want the lex smallest sorted list of set bit positions.\n * The lex smallest set is determined by: if they differ at some position,\n * the one that has a set bit at a smaller position is... well, it depends.\n *\n * For same-size sets, lex comparison of sorted indices:\n * {0,3} < {1,2} because first element 0 < 1.\n * In bitmask terms: 0b1001 vs 0b0110 — we need to compare the sorted positions.\n *\n * Actually, for same popcount, the lex smallest sorted set corresponds to\n * the numerically smallest bitmask. E.g., {0,3}=0b1001=9, {1,2}=0b0110=6.\n * Wait, {1,2} has bitmask 6 < 9 but {0,3} is lex smaller. So numeric comparison\n * of bitmask does NOT give lex order!\n *\n * We need to compare by the actual sorted positions.\n */\nfunction compareBigMask(a: bigint, b: bigint): number {\n  if (a === b) return 0;\n  // Find the first position where they differ\n  const diff = a ^ b;\n  // Lowest set bit position i