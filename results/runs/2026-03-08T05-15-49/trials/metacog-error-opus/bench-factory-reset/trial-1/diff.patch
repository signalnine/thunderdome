l: number[],\n   459→  freeVars: number[],\n   460→  numButtons: number,\n   461→  modulus: number\n   462→): number[] | null {\n   463→  const numFree = freeVars.length;\n   464→  let bestSolution: number[] | null = null;\n   465→  let bestTotal = Infinity;\n   466→\n   467→  // Enumerate all modulus^numFree combinations\n   468→  const freeAssignment = new Array(numFree).fill(0);\n   469→\n   470→  const enumerate = (): void => {\n   471→    while (true) {\n   472→      const solution = new Array(numButtons).fill(0);\n   473→\n   474→      // Set free variables\n   475→      for (let i = 0; i < numFree; i++) {\n   476→        solution[freeVars[i]] = freeAssignment[i];\n   477→      }\n   478→\n   479→      // Compute pivot variables\n   480→      for (let r = rank - 1; r >= 0; r--) {\n   481→        let val = matrix[r][numButtons];\n   482→        for (let c = pivotCol[r] + 1; c < numButtons; c++) {\n   483→          val = mod(val - matrix[r][c] * solution[c], modulus);\n   484→        }\n   485→        solution[pivotCol[r]] = val;\n   486→      }\n   487→\n   488→      // Compute total presses\n   489→      let total = 0;\n   490→      for (let j = 0; j < numButtons; j++) {\n   491→        total += solution[j];\n   492→      }\n   493→\n   494→      if (total < bestTotal || (total === bestTotal && compareLexArr(solution, bestSolution!) < 0)) {\n   495→        bestTotal = total;\n   496→        bestSolution = [...solution];\n   497→      }\n   498→\n   499→      // Increment free assignment (odometer style)\n   500→      let carry = true;\n   501→      for (let i = 0; i < numFree && carry; i++) {\n   502→        freeAssignment[i]++;\n   503→        if (freeAssignment[i] >= modulus) {\n   504→          freeAssignment[i] = 0;\n   505→        } else {\n   506→          carry = false;\n   507→        }\n   508→      }\n   509→      if (carry) break; // All combinations exhausted\n   510→    }\n   511→  };\n   512→\n   513→  enumerate();\n   514→  return bestSolution;\