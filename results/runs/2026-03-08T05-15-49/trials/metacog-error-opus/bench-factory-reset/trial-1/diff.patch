":{"type":"update","filePath":"/workspace/src/index.ts","content":"export interface Machine {\n  target: boolean[];\n  buttons: number[][];\n}\n\n// Count trailing zeros\nfunction ctz(n: number): number {\n  if (n === 0) return 32;\n  let count = 0;\n  while ((n & 1) === 0) {\n    n >>= 1;\n    count++;\n  }\n  return count;\n}\n\n// Popcount for 32-bit integer\nfunction popcnt32(n: number): number {\n  n = n - ((n >> 1) & 0x55555555);\n  n = (n & 0x33333333) + ((n >> 2) & 0x33333333);\n  n = (n + (n >> 4)) & 0x0f0f0f0f;\n  return (n * 0x01010101) >> 24;\n}\n\n// Popcount for 40-bit mask stored as (lo, hi)\nfunction popcount40(lo: number, hi: number): number {\n  return popcnt32(lo) + popcnt32(hi);\n}\n\n// Compare two 40-bit masks for lex ordering of set bit positions\nfunction compareMask(aLo: number, aHi: number, bLo: number, bHi: number): number {\n  const diffLo = (aLo ^ bLo) >>> 0;\n  if (diffLo !== 0) {\n    const lowestBit = (diffLo & (-diffLo)) >>> 0;\n    return (aLo & lowestBit) ? -1 : 1;\n  }\n  const diffHi = (aHi ^ bHi) >>> 0;\n  if (diffHi !== 0) {\n    const lowestBit = (diffHi & (-diffHi)) >>> 0;\n    return (aHi & lowestBit) ? -1 : 1;\n  }\n  return 0;\n}\n\n// Encode (lo, hi) pair as a single number for hash map key.\n// Since hi has at most 8 bits (positions 32-39), we can encode as:\n// key = hi * 2^32 + lo, but JS numbers only have 53 bits of precision.\n// With hi < 256 (8 bits) and lo < 2^32, the key = hi * 4294967296 + (lo >>> 0)\n// fits in 53 bits since hi < 256 means key < 2^40 < 2^53. Safe!\nfunction maskKey(lo: number, hi: number): number {\n  return (hi >>> 0) * 4294967296 + (lo >>> 0);\n}\n\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const numLights = target.length;\n  const numButtons = buttons.length;\n\n  if (numButtons === 0) {\n    return target.every((t) => !t) ? [] : null;\n  }\n\n  // Build augmented matrix over GF(2)\n  const matrix: number[][] = [];\n  for (let