515→      if (row !== rank && matrix[row][col] !== 0) {\n   516→        const factor = matrix[row][col];\n   517→        for (let c = col; c <= numButtons; c++) {\n   518→          matrix[row][c] = mod(matrix[row][c] - factor * matrix[rank][c], modulus);\n   519→        }\n   520→      }\n   521→    }\n   522→    rank++;\n   523→  }\n   524→\n   525→  // Check for inconsistency\n   526→  for (let row = rank; row < numLights; row++) {\n   527→    if (matrix[row][numButtons] !== 0) {\n   528→      return null;\n   529→    }\n   530→  }\n   531→\n   532→  // Identify free variables\n   533→  const isPivot = new Set(pivotCol);\n   534→  const freeVars: number[] = [];\n   535→  for (let col = 0; col < numButtons; col++) {\n   536→    if (!isPivot.has(col)) {\n   537→      freeVars.push(col);\n   538→    }\n   539→  }\n   540→\n   541→  const numFree = freeVars.length;\n   542→\n   543→  // Precompute coefficients\n   544→  const pivotCoeffs: number[][] = [];\n   545→  const pivotConst: number[] = [];\n   546→  for (let r = 0; r < rank; r++) {\n   547→    const coeffs: number[] = [];\n   548→    for (let i = 0; i < numFree; i++) {\n   549→      coeffs.push(matrix[r][freeVars[i]]);\n   550→    }\n   551→    pivotCoeffs.push(coeffs);\n   552→    pivotConst.push(matrix[r][numButtons]);\n   553→  }\n   554→\n   555→  const solution = new Array(numButtons).fill(0);\n   556→  let bestSolution: number[] | null = null;\n   557→  let bestTotal = Infinity;\n   558→\n   559→  const computeAndCheck = (): void => {\n   560→    for (let r = 0; r < rank; r++) {\n   561→      let val = pivotConst[r];\n   562→      for (let i = 0; i < numFree; i++) {\n   563→        val -= pivotCoeffs[r][i] * solution[freeVars[i]];\n   564→      }\n   565→      solution[pivotCol[r]] = mod(val, modulus);\n   566→    }\n   567→\n   568→    let total = 0;\n   569→    for (let j = 0; j < numButtons; j++) {\n   570→      total += solution[j];\n   571→    }\n   572→\n   573→    if (total < bestTotal || (total =