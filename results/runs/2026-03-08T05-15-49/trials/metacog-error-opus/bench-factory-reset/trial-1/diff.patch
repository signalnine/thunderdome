hat toggling produces the target configuration.\n */\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const numLights = target.length;\n  const numButtons = buttons.length;\n\n  if (numButtons === 0) {\n    return target.every((t) => !t) ? [] : null;\n  }\n\n  // Build augmented matrix over GF(2): each row is a light,\n  // columns are buttons + 1 (target column).\n  // matrix[light][button] = 1 if button toggles that light\n  // matrix[light][numButtons] = target value\n  const matrix: number[][] = [];\n  for (let i = 0; i < numLights; i++) {\n    const row = new Array(numButtons + 1).fill(0);\n    row[numButtons] = target[i] ? 1 : 0;\n    matrix.push(row);\n  }\n  for (let j = 0; j < numButtons; j++) {\n    for (const light of buttons[j]) {\n      if (light >= 0 && light < numLights) {\n        matrix[light][j] ^= 1;\n      }\n    }\n  }\n\n  // Gaussian elimination over GF(2) with partial pivoting\n  // Track which column is the pivot for each row\n  const pivotCol: number[] = new Array(numLights).fill(-1);\n  const pivotRow: number[] = new Array(numButtons).fill(-1); // pivotRow[col] = row where this col is pivot\n  let rank = 0;\n\n  for (let col = 0; col < numButtons && rank < numLights; col++) {\n    // Find pivot row\n    let pivotR = -1;\n    for (let row = rank; row < numLights; row++) {\n      if (matrix[row][col] === 1) {\n        pivotR = row;\n        break;\n      }\n    }\n    if (pivotR === -1) continue; // Free variable\n\n    // Swap rows\n    [matrix[rank], matrix[pivotR]] = [matrix[pivotR], matrix[rank]];\n    pivotCol[rank] = col;\n    pivotRow[col] = rank;\n\n    // Eliminate all other rows\n    for (let row = 0; row < numLights; row++) {\n      if (row !== rank && matrix[row][col] === 1) {\n        for (let c = 0; c <= numButtons; c++) {\n          matrix[row][c] ^= matrix[rank][c];\n        }\n      }\n    }\n    rank++;\n  }\n\n  // Check for inconsistency: any row with all zeros in button columns but 1 in target\n  for (let row = rank; row < numLights; row++) {\n    if (matrix[row][numButtons] === 1) {\n      return null; // No solution\n    }\n  }\n\n  // Identify free variables (columns that are not pivot columns)\n  const freeVars: number[] = [];\n  const isPivot = new Array(numButtons).fill(false);\n  for (let r = 0; r < rank; r++) {\n    isPivot[pivotCol[r]] = true;\n  }\n  for (let col = 0; col < numButtons; col++) {\n    if (!isPivot[col]) {\n      freeVars.push(col);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  // For each assignment of free variables, compute the full solution\n  // and track the one with minimum button presses, then lex smallest.\n  // If numFree <= 25, enumerate directly. Otherwise use meet-in-the-middle.\n\n  if (numFree <= 25) {\n    return solveToggleEnumerate(matrix, rank, pivotCol, freeVars, numButtons);\n  } else {\n    return solveToggleMeetInMiddle(matrix, rank, pivotCol, freeVars, numButtons);\n  }\n}\n\nfunction solveToggleEnumerate(\n  matrix: number[][],\n  rank: number,\n  pivotCol: number[],\n  freeVars: number[],\n  numButtons: number\n): number[] | null {\n  const numFree = freeVars.length;\n  let bestButtons: number[] | null = null;\n  let bestCount = numButtons + 1;\n\n  // For each free variable assignment (bitmask)\n  const totalCombinations = 1 << numFree;\n  for (let mask = 0; mask < totalCombinations; mask++) {\n    const solution = new Array(numButtons).fill(0);\n\n    // Set free variables\n    for (let i = 0; i < numFree; i++) {\n      solution[freeVars[i]] = (mask >> i) & 1;\n    }\n\n    // Compute pivot variables from the reduced matrix\n    // For pivot row r with pivot column pivotCol[r]:\n    // solution[pivotCol[r]] = matrix[r][numButtons] XOR sum(matrix[r][freeVar] * solution[freeVar])\n    let valid = true;\n    for (let r = rank - 1; r >= 0; r--) {\n      let val = matrix[r][numButtons];\n      for (let c = pivotCol[r] + 1; c < numButtons; c++) {\n        val ^= matrix[r][c] & solution[c];\n      }\n      solution[pivotCol[r]] = val;\n    }\n\n    if (!valid) continue;\n\n    // Count pressed buttons\n    const pressed: number[] = [];\n    for (let j = 0; j < numButtons; j++) {\n      if (solution[j] === 1) pressed.push(j);\n    }\n\n    const count = pressed.length;\n    if (count < bestCount || (count === bestCount && compareLex(pressed, bestButtons!) < 0)) {\n      bestCount = count;\n      bestButtons = pressed;\n    }\n  }\n\n  return bestButtons;\n}\n\nfunction solveToggleMeetInMiddle(\n  matrix: number[][],\n  rank: number,\n  pivotCol: number[],\n  freeVars: number[],\n  numButtons: number\n): number[] | null {\n  // Split free variables into two halves\n  const numFree = freeVars.length;\n  const half1 = Math.floor(numFree / 2);\n  const half2 = numFree - half1;\n\n  // For each free variable, precompute its effect on pivot variables\n  // When free var freeVars[i] = 1, it flips pivot variable pivotCol[r]\n  // if matrix[r][freeVars[i]] = 1\n  // We represent the effect as: which pivot variables get flipped, and the free var itself\n\n  // Precompute: for a given free variable assignment, what buttons are pressed?\n  // Pivot buttons: determined by the free vars + the base solution (matrix[r][numButtons])\n  // Free buttons: directly from the assignment\n\n  // Base solution (all free vars = 0):\n  const baseSolution = new Array(numButtons).fill(0);\n  for (let r = 0; r < rank; r++) {\n    baseSolution[pivotCol[r]] = matrix[r][numButtons];\n  }\n\n  // Effect of each free variable on the solution:\n  // freeEffects[i] = array of button indices whose value flips when freeVars[i] is toggled\n  // This includes freeVars[i] itself (goes from 0 to 1) and any pivot vars that flip\n  const freeEffects: number[][] = [];\n  for (let i = 0; i < numFree; i++) {\n    const effects: number[] = [freeVars[i]];\n    for (let r = 0; r < rank; r++) {\n      if (matrix[r][freeVars[i]] === 1) {\n        effects.push(pivotCol[r]);\n      }\n