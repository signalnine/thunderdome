+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter, Machine } from './index.js';
+
+// Helper: verify a toggle solution
+function verifyToggle(machine: Machine, buttons: number[] | null): boolean {
+  if (buttons === null) return false;
+  const lights = new Array(machine.target.length).fill(false);
+  for (const b of buttons) {
+    for (const l of machine.buttons[b]) {
+      lights[l] = !lights[l];
+    }
+  }
+  return lights.every((v, i) => v === machine.target[i]);
+}
+
+// Helper: verify a counter solution
+function verifyCounter(
+  target: number[], buttons: number[][], modulus: number, solution: number[] | null
+): boolean {
+  if (solution === null) return false;
+  const counters = new Array(target.length).fill(0);
+  for (let b = 0; b < buttons.length; b++) {
+    for (let press = 0; press < solution[b]; press++) {
+      for (const c of buttons[b]) {
+        counters[c] = (counters[c] + 1) % modulus;
+      }
+    }
+  }
+  return counters.every((v, i) => v === target[i]);
+}
+
+describe('solveToggle', () => {
+  it('should return empty array when target is all off', () => {
+    const machine: Machine = {
+      target: [false, false, false],
+      buttons: [[0, 1], [1, 2]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([]);
+  });
+
+  it('should return null for impossible configurations', () => {
+    // From the task example
+    const machine: Machine = {
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toBeNull();
+  });
+
+  it('should find single button press', () => {
+    const machine: Machine = {
+      target: [true, true, false],
+      buttons: [[0, 1], [1, 2]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0]);
+    expect(verifyToggle(machine, result)).toBe(true);
+  });
+
+  it('should find minimum button presses', () => {
+    const machine: Machine = {
+      target: [true, false, true],
+      buttons: [[0], [1], [2], [0, 2]],
+    };
+    // Button 3 toggles both 0 and 2: result [true, false, true] — 1 press
+    // Buttons 0 and 2: also correct — 2 presses
+    const result = solveToggle(machine);
+    expect(result).toEqual([3]);
+    expect(verifyToggle(machine, result)).toBe(true);
+  });
+
+  it('should return lex smallest among minimum solutions', () => {
+    // Two buttons that each toggle light 0
+    const machine: Machine = {
+      target: [true],
+      buttons: [[0], [0]],
+    };
+    // Both button 0 and button 1 alone work. Min presses = 1. Lex smallest = [0].
+    const result = solveToggle(machine);
+    expect(result).toEqual([0]);
+  });
+
+  it('should handle no buttons', () => {
+    const machine: Machine = {
+      target: [false, false],
+      buttons: [],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('should handle no buttons with non-trivial target', () => {
+    const machine: Machine = {
+      target: [true, false],
+      buttons: [],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('should handle all lights on target', () => {
+    const machine: Machine = {
+      target: [true, true, true],
+      buttons: [[0], [1], [2]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0, 1, 2]);
+    expect(verifyToggle(machine, result)).toBe(true);
+  });
+
+  it('should handle overlapping buttons', () => {
+    const machine: Machine = {
+      target: [true, false],
+      buttons: [[0, 1], [1]],
+    };
+    // Press both: light 0 toggled once (on), light 1 toggled twice (off)
+    const result = solveToggle(machine);
+    expect(result).toEqual([0, 1]);
+    expect(verifyToggle(machine, result)).toBe(true);
+  });
+
+  it('should handle larger puzzle', () => {
+    // 8 lights, 8 buttons
+    const machine: Machine = {
+      target: [true, false, true, false, true, false, true, false],
+      buttons: [
+        [0], [1], [2], [3], [4], [5], [6], [7],
+      ],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0, 2, 4, 6]);
+    expect(verifyToggle(machine, result)).toBe(true);
+  });
+});
+
+describe('solveCounter', () => {
+  it('should return all zeros when target is all zero', () => {
+    const result = solveCounter([0, 0, 0], [[0, 1], [1, 2]], 5);
+    expect(result).toEqual([0, 0]);
+  });
+
+  it('should return null for impossible configurations', () => {
+    // Single button affects counter 0 only, but need counter 1 to be nonzero
+    const result = solveCounter([0, 1], [[0]], 3);
+    expect(result).toBeNull();
+  });
+
+  it('should find single button solution', () => {
+    const result = solveCounter([2, 0], [[0]], 5);
+    expect(result).toEqual([2]);
+    expect(verifyCounter([2, 0], [[0]], 5, result)).toBe(true);
+  });
+
+  it('should handle modular arithmetic', () => {
+    // Button 0 affects counter 0. Need counter 0 = 3 mod 5.
+    // Press button 0 three times.
+    const result = solveCounter([3], [[0]], 5);
+    expect(result).toEqual([3]);
+    expect(verifyCounter([3], [[0]], 5, result)).toBe(true);
+  });
+
+  it('should find minimum total presses', () => {
+    // Two buttons both affect counter 0. Need counter 0 = 1 mod 5.
+    // Options: [1,0] (total=1), [0,1] (total=1). Lex: [0,1].
+    const result = solveCounter([1], [[0], [0]], 5);
+    expect(result).toEqual([0, 1]);
+    expect(verifyCounter([1], [[0], [0]], 5, result)).toBe(true);
+  });
+
+  it('should return lex smallest among minimum total solutions', () => {
+    // Two independent buttons affecting different counters
+    const result = solveCounter([2, 3], [[0], [1]], 5);
+    expect(result).toEqual([2, 3]);
+    expect(verifyCounter([2, 3], [[0], [1]], 5, result)).toBe(true);
+  });
+
+  it('should handle empty buttons', () => {
+    expect(solveCounter([0, 0], [], 3)).toEqual([]);
+    expect(solveCounter([1, 0], [], 3)).toBeNull();
+  });
+
+  it('should handle modulus 2 (binary)', () => {
+    const result = solveCounter([1, 1], [[0, 1]], 2);
+    expect(result).toEqual([1]);
+    expect(verifyCounter([1, 1], [[0, 1]], 2, result)).toBe(true);
+  });
+
+  it('should handle larger modulus', () => {
+    const result = solveCounter([50], [[0]], 97);
+    expect(result).toEqual([50]);
+    expect(verifyCounter([50], [[0]], 97, result)).toBe(true);
+  });
+
+  it('should handle multiple buttons with shared counters', () => {
+    // Button 0: counters [0,1], Button 1: counters [1,2]
+    // Need: counter 0=1, counter 1=0, counter 2=1, mod 3
+    // b0 affects 0,1; b1 affects 1,2
+    // c0 = b0 mod 3 = 1 => b0 = 1
+    // c1 = (b0 + b1) mod 3 = 0 => b1 = 2
+    // c2 = b1 mod 3 = 2 (but we want 1!)
+    // This is impossible!
+    const result = solveCounter([1, 0, 1], [[0, 1], [1, 2]], 3);
+    expect(result).toBeNull();
+  });
+
+  it('should find valid solution for counter puzzle', () => {
+    // Button 0: [0,1], Button 1: [1,2]
+    // Need: c0=1, c1=2, c2=1, mod 3
+    // c0 = b0 = 1, c1 = b0+b1 = 2, c2 = b1 = 1
+    // b0=1, b1=1
+    const result = solveCounter([1, 2, 1], [[0, 1], [1, 2]], 3);
+    expect(result).toEqual([1, 1]);
+    expect(verifyCounter([1, 2, 1], [[0, 1], [1, 2]], 3, result)).toBe(true);
+  });
+});
