+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+// Count trailing zeros
+function ctz(n: number): number {
+  if (n === 0) return 32;
+  let count = 0;
+  while ((n & 1) === 0) {
+    n >>= 1;
+    count++;
+  }
+  return count;
+}
+
+// Popcount for 32-bit integer
+function popcnt32(n: number): number {
+  n = n - ((n >> 1) & 0x55555555);
+  n = (n & 0x33333333) + ((n >> 2) & 0x33333333);
+  n = (n + (n >> 4)) & 0x0f0f0f0f;
+  return (n * 0x01010101) >> 24;
+}
+
+// Popcount for 40-bit mask stored as (lo, hi)
+function popcount40(lo: number, hi: number): number {
+  return popcnt32(lo) + popcnt32(hi);
+}
+
+// Compare two 40-bit masks for lex ordering of set bit positions
+function compareMask(aLo: number, aHi: number, bLo: number, bHi: number): number {
+  const diffLo = (aLo ^ bLo) >>> 0;
+  if (diffLo !== 0) {
+    const lowestBit = (diffLo & (-diffLo)) >>> 0;
+    return (aLo & lowestBit) ? -1 : 1;
+  }
+  const diffHi = (aHi ^ bHi) >>> 0;
+  if (diffHi !== 0) {
+    const lowestBit = (diffHi & (-diffHi)) >>> 0;
+    return (aHi & lowestBit) ? -1 : 1;
+  }
+  return 0;
+}
+
+// Encode (lo, hi) pair as a single number for hash map key.
+// Since hi has at most 8 bits (positions 32-39), we can encode as:
+// key = hi * 2^32 + lo, but JS numbers only have 53 bits of precision.
+// With hi < 256 (8 bits) and lo < 2^32, the key = hi * 4294967296 + (lo >>> 0)
+// fits in 53 bits since hi < 256 means key < 2^40 < 2^53. Safe!
+function maskKey(lo: number, hi: number): number {
+  return (hi >>> 0) * 4294967296 + (lo >>> 0);
+}
+
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const numLights = target.length;
+  const numButtons = buttons.length;
+
+  if (numButtons === 0) {
+    return target.every((t) => !t) ? [] : null;
+  }
+
+  // Build augmented matrix over GF(2)
+  const matrix: number[][] = [];
+  for (let i = 0; i < numLights; i++) {
+    const row = new Array(numButtons + 1).fill(0);
+    row[numButtons] = target[i] ? 1 : 0;
+    matrix.push(row);
+  }
+  for (let j = 0; j < numButtons; j++) {
+    for (const light of buttons[j]) {
+      if (light >= 0 && light < numLights) {
+        matrix[light][j] ^= 1;
+      }
+    }
+  }
+
+  // Gaussian elimination over GF(2)
+  const pivotCol: number[] = [];
+  let rank = 0;
+
+  for (let col = 0; col < numButtons && rank < numLights; col++) {
+    let pivotR = -1;
+    for (let row = rank; row < numLights; row++) {
+      if (matrix[row][col] === 1) {
+        pivotR = row;
+        break;
+      }
+    }
+    if (pivotR === -1) continue;
+
+    [matrix[rank], matrix[pivotR]] = [matrix[pivotR], matrix[rank]];
+    pivotCol.push(col);
+
+    for (let row = 0; row < numLights; row++) {
+      if (row !== rank && matrix[row][col] === 1) {
+        for (let c = col; c <= numButtons; c++) {
+          matrix[row][c] ^= matrix[rank][c];
+        }
+      }
+    }
+    rank++;
+  }
+
+  // Check for inconsistency
+  for (let row = rank; row < numLights; row++) {
+    if (matrix[row][numButtons] === 1) {
+      return null;
+    }
+  }
+
+  // Identify free variables
+  const isPivot = new Set(pivotCol);
+  const freeVars: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (!isPivot.has(col)) {
+      freeVars.push(col);
+    }
+  }
+
+  const numFree = freeVars.length;
+
+  // Build base mask and effect masks using (lo, hi) pairs
+  let baseLo = 0;
+  let baseHi = 0;
+  for (let r = 0; r < rank; r++) {
+    if (matrix[r][numButtons] === 1) {
+      const col = pivotCol[r];
+      if (col < 32) baseLo |= (1 << col);
+      else baseHi |= (1 << (col - 32));
+    }
+  }
+  baseLo = baseLo >>> 0;
+  baseHi = baseHi >>> 0;
+
+  const eLo: number[] = [];
+  const eHi: number[] = [];
+  for (let i = 0; i < numFree; i++) {
+    let lo = 0;
+    let hi = 0;
+    const fv = freeVars[i];
+    if (fv < 32) lo |= (1 << fv);
+    else hi |= (1 << (fv - 32));
+    for (let r = 0; r < rank; r++) {
+      if (matrix[r][freeVars[i]] === 1) {
+        const col = pivotCol[r];
+        if (col < 32) lo ^= (1 << col);
+        else hi ^= (1 << (col - 32));
+      }
+    }
+    eLo.push(lo >>> 0);
+    eHi.push(hi >>> 0);
+  }
+
+  // Group free variables by their effect on pivot columns only
+  // (the part excluding their own free variable bit).
+  // This helps reduce the search space when many free vars have identical pivot effects.
+  // After grouping, within each group we only toggle 0 or 1 variable.
+  // This reduces the effective number of binary choices.
+
+  // Compute pivot-only effect for each free variable
+  const pivotEffectLo: number[] = [];
+  const pivotEffectHi: number[] = [];
+  for (let i = 0; i < numFree; i++) {
+    let lo = 0;
+    let hi = 0;
+    for (let r = 0; r < rank; r++) {
+      if (matrix[r][freeVars[i]] === 1) {
+        const col = pivotCol[r];
+        if (col < 32) lo ^= (1 << col);
+        else hi ^= (1 << (col - 32));
+      }
+    }
+    pivotEffectLo.push(lo >>> 0);
+    pivotEffectHi.push(hi >>> 0);
+  }
+
+  // Group by pivot effect key
+  const groups = new Map<number, number[]>();
+  for (let i = 0; i < numFree; i++) {
+    const key = maskKey(pivotEffectLo[i], pivotEffectHi[i]);
+    const group = groups.get(key);
+    if (group) group.push(i);
+    else groups.set(key, [i]);
+  }
+
+  // Build reduced problem: for each group, we have a binary choice
+  // (toggle 0 or 1 variable). If we toggle 1, we choose the lowest-indexed
+  // variable for lex ordering.
+  // The effect of choosing to toggle the representative of each group:
+  const groupList: { effectLo: number; effectHi: number; representative: number }[] = [];
+  for (const [, members] of groups) {
+    // Representative is the one with the smallest button index (already sorted)
+    const rep = members[0]; // freeVars are in ascending order, so members[0] is smallest
+    groupList.push({ effectLo: eLo[rep], effectHi: eHi[rep], representative: rep });
+  }
+
+  const numGroups = groupList.length;
+
+  let bestLo = 0;
+  let bestHi = 0;
+  let bestCount = numButtons + 1;
+
+  if (numGroups <= 28) {
+    // Direct Gray code enumeration over groups
+    const total = 1 << numGroups;
+    const geLo = groupList.map((g) => g.effectLo);
+    const geHi = groupList.map((g) => g.effectHi);
+
+    let lo = baseLo;
+    let hi = baseHi;
+    let count = popcount40(lo, hi);
+    if (count < bestCount || (count === bestCount && compareMask(lo, hi, bestLo, bestHi) < 0)) {
+      bestCount = count;
+      bestLo = lo;
+      bestHi = hi;
+    }
+
+    for (let gray = 1; gray < total; gray++) {
+      const changedBit = ctz(gray);
+      lo = (lo ^ geLo[changedBit]) >>> 0;
+      hi = (hi ^ geHi[changedBit]) >>> 0;
+      count = popcount40(lo, hi);
+      if (count < bestCount || (count === bestCount && compareMask(lo, hi, bestLo, bestHi) < 0)) {
+        bestCount = count;
+        bestLo = lo;
+        bestHi = hi;
+      }
+    }
+  } else {
+    // Nearest codeword approach using iterative deepening.
+    // For each target Hamming weight d = 0, 1, 2, ...,
+    // check if any mask with popcount d is achievable.
+    // A mask M is achievable iff (M XOR baseMask) is in the span of group effect masks.
+
+    // First, do GE on the group effect masks to get RREF basis
+    const geLo = groupList.map((g) => g.effectLo);
+    const geHi = groupList.map((g) => g.effectHi);
+
+    // Combine into single representation for GE
+    // We'll use lo + hi*2^32 but stored as pair
+    // GE on numGroups vectors of 40 bits
+    const basisLo: number[] = [...geLo];
+    const basisHi: number[] = [...geHi];
+    const basisSize = numGroups;
+    // pivotBits[i] = which bit position is the pivot for basis vector i
+    const basisPivots: number[] = [];
+    const usedPivots = new Set<number>();
+
+    // Perform GE on basis
+    for (let i = 0; i < basisSize; i++) {
+      // Find the lowest set bit not already used as a pivot
+      let pivotBit = -1;
+      for (let b = 0; b < numButtons; b++) {
+        if (usedPivots.has(b)) continue;
+        const bit = b < 32 ? (basisLo[i] >> b) & 1 : (basisHi[i] >> (b - 32)) & 1;
+        if (bit) {
+          pivotBit = b;
+          break;
+        }
+      }
+      if (pivotBit === -1) {
+        // This vector is in the span of previous vectors (linearly dependent)
+        basisPivots.push(-1);
+        continue;
+      }
+      basisPivots.push(pivotBit);
+      usedPivots.add(pivotBit);
+
+      // Eliminate this bit from all other basis vectors
+      for (let j = 0; j < basisSize; j++) {
+        if (j === i) continue;
+        const bit = pivotBit < 32
+          ? (basisLo[j] >> pivotBit) & 1
+          : (basisHi[j] >> (pivotBit - 32)) & 1;
+        if (bit) {
+          basisLo[j] = (basisLo[j] ^ basisLo[i]) >>> 0;
+          basisHi[j] = (basisHi[j] ^ basisHi[i]) >>> 0;
+        }
+      }
+    }
+
+    // Collect the actual basis vectors (non-zero)
+    const finalBasisLo: number[] = [];
+    const finalBasisHi: number[] = [];
+    const finalPivots: number[] = [];
+    for (let i = 0; i < basisSize; i++) {
+      if (basisPivots[i] !== -1) {
+        finalBasisLo.push(basisLo[i]);
+        finalBasisHi.push(basisHi[i]);
+        finalPivots.push(basisPivots[i]);
+      }
+    }
+    const basisRank = finalBasisLo.length;
+
+    // Function to check if a vector is in the span and return the coefficients
+    const isInSpan = (lo: number, hi: number): boolean => {
+      let curLo = lo;
+      let curHi = hi;
+      for (let i = 0; i < basisRank; i++) {
+        const p = finalPivots[i];
+        const bit = p < 32 ? (curLo >> p) & 1 : (curHi >> (p - 32)) & 1;
+        if (bit) {
+          curLo = (curLo ^ finalBasisLo[i]) >>> 0;
+          curHi = (curHi ^ finalBasisHi[i]) >>> 0;
+        }
+      }
+      return curLo === 0 && curHi === 0;
+    };
+
+    // Iterative deepening: for each distance d, try all C(numButtons, d) masks
+    // Check if (candidate XOR baseMask) is in span
+    // Collect all valid candidates at the minimum distance, then find lex smallest
+
+    // Limit iterative deepening to avoid combinatorial explosion
+    // C(40,8) = 76M which takes ~2s. C(40,9) = 273M too slow.
+    const maxIterDeepD = Math.min(numButtons, 8);
+
+    for (let d = 0; d <= maxIterDeepD; d++) {
+      // Generate all d-bit masks and check
+      const validMasks: { lo: number; hi: number }[] = [];
+
+      // Generate combinations of d positions from numButtons positions
+      const combo = new Array(d).fill(0);
+      for (let i = 0; i < d; i++) combo[i] = i;
+
+      if (d === 0) {
+        // Check the zero mask (no buttons pressed)
+        const testLo = baseLo;
+        const testHi = baseHi;
+        if (isInSpan(testLo, testHi)) {
+          validMasks.push({ lo: 0, hi: 0 });
+        }
+      } else {
+        let done = false;
+        while (!done) {
+          // Build the candidate mask from combo
+          let candLo = 0;
+          let candHi = 0;
+          for (let i = 0; i < d; i++) {
+            const b = combo[i];
+            if (b < 32) candLo |= (1 << b);
+            else candHi |= (1 << (b - 32));
+          }
+          candLo = candLo >>> 0;
+          candHi = candHi >>> 0;
+
+          // Check if (candidate XOR baseMask) is in span
+          const testLo = (candLo ^ baseLo) >>> 0;
+          const testHi = (candHi ^ baseHi) >>> 0;
+          if (isInSpan(testLo, testHi)) {
+            validMasks.push({ lo: candLo, hi: candHi });
+          }
+
+          // Generate next combination
+          let i = d - 1;
+          while (i >= 0 && combo[i] === numButtons - d + i) i--;
+          if (i < 0) {
+            done = true;
+          } else {
+            combo[i]++;
+            for (let j = i + 1; j < d; j++) {
+              combo[j] = combo[j - 1] + 1;
+            }
+          }
+        }
+      }
+
+      if (validMasks.length > 0) {
+        // Find lex smallest among valid masks
+        let best = validMasks[0];
+        for (let i = 1; i < validMasks.length; i++) {
+          if (compareMask(validMasks[i].lo, validMasks[i].hi, best.lo, best.hi) < 0) {
+            best = validMasks[i];
+          }
+        }
+        bestCount = d;
+        bestLo = best.lo;
+        bestHi = best.hi;
+        break; // Found minimum distance
+      }
+    }
+
+    // If iterative deepening didn't find a solution, fall back to MITM
+    if (bestCount > numButtons) {
+      const halfA = Math.ceil(numGroups / 2);
+      const halfB = numGroups - halfA;
+      const halfASize = 1 << halfA;
+      const halfBSize = 1 << halfB;
+
+      const halfALoArr = new Int32Array(halfASize);
+      const halfAHiArr = new Int32Array(halfASize);
+      {
+        let lo = baseLo;
+        let hi = baseHi;
+        halfALoArr[0] = lo;
+        halfAHiArr[0] = hi;
+
+        for (let gray = 1; gray < halfASize; gray++) {
+          const changedBit = ctz(gray);
+          lo = (lo ^ geLo[changedBit]) >>> 0;
+          hi = (hi ^ geHi[changedBit]) >>> 0;
+          const binaryIdx = gray ^ (gray >> 1);
+          halfALoArr[binaryIdx] = lo;
+          halfAHiArr[binaryIdx] = hi;
+        }
+      }
+
+      let dLo = 0;
+      let dHi = 0;
+      for (let grayB = 0; grayB < halfBSize; grayB++) {
+        if (grayB > 0) {
+          const changedBit = ctz(grayB);
+          dLo = (dLo ^ geLo[halfA + changedBit]) >>> 0;
+          dHi = (dHi ^ geHi[halfA + changedBit]) >>> 0;
+        }
+
+        for (let aBits = 0; aBits < halfASize; aBits++) {
+          const lo = ((halfALoArr[aBits] ^ dLo) >>> 0);
+          const hi = ((halfAHiArr[aBits] ^ dHi) >>> 0);
+          const count = popcount40(lo, hi);
+          if (count < bestCount || (count === bestCount && compareMask(lo, hi, bestLo, bestHi) < 0)) {
+            bestCount = count;
+            bestLo = lo;
+            bestHi = hi;
+          }
+        }
+      }
+    }
+  }
+
+  if (bestCount > numButtons) return null;
+
+  // Extract pressed button indices
+  const result: number[] = [];
+  for (let j = 0; j < numButtons; j++) {
+    const bit = j < 32 ? (bestLo >> j) & 1 : (bestHi >> (j - 32)) & 1;
+    if (bit) result.push(j);
+  }
+  return result;
+}
+
+// ----- GF(p) helpers -----
+
+function mod(a: number, p: number): number {
+  return ((a % p) + p) % p;
+}
+
+function modInverse(a: number, p: number): number {
+  let [old_r, r] = [a, p];
+  let [old_s, s] = [1, 0];
+  while (r !== 0) {
+    const q = Math.floor(old_r / r);
+    [old_r, r] = [r, old_r - q * r];
+    [old_s, s] = [s, old_s - q * s];
+  }
+  return ((old_s % p) + p) % p;
+}
+
+// ----- Counter Puzzle (GF(p)) -----
+
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numLights = lights.length;
+  const numButtons = buttons.length;
+
+  if (numButtons === 0) {
+    return lights.every((l) => l % modulus === 0) ? [] : null;
+  }
+
+  // Build augmented matrix over GF(modulus)
+  const matrix: number[][] = [];
+  for (let i = 0; i < numLights; i++) {
+    const row = new Array(numButtons + 1).fill(0);
+    row[numButtons] = mod(lights[i], modulus);
+    matrix.push(row);
+  }
+  for (let j = 0; j < numButtons; j++) {
+    for (const counter of buttons[j]) {
+      if (counter >= 0 && counter < numLights) {
+        matrix[counter][j] = mod(matrix[counter][j] + 1, modulus);
+      }
+    }
+  }
+
+  // Gaussian elimination over GF(modulus)
+  const pivotCol: number[] = [];
+  let rank = 0;
+
+  for (let col = 0; col < numButtons && rank < numLights; col++) {
+    let pivotR = -1;
+    for (let row = rank; row < numLights; row++) {
+      if (matrix[row][col] !== 0) {
+        pivotR = row;
+        break;
+      }
+    }
+    if (pivotR === -1) continue;
+
+    [matrix[rank], matrix[pivotR]] = [matrix[pivotR], matrix[rank]];
+    pivotCol.push(col);
+
+    const inv = modInverse(matrix[rank][col], modulus);
+    for (let c = col; c <= numButtons; c++) {
+      matrix[rank][c] = mod(matrix[rank][c] * inv, modulus);
+    }
+
+    for (let row = 0; row < numLights; row++) {
+      if (row !== rank && matrix[row][col] !== 0) {
+        const factor = matrix[row][col];
+        for (let c = col; c <= numButtons; c++) {
+          matrix[row][c] = mod(matrix[row][c] - factor * matrix[rank][c], modulus);
+        }
+      }
+    }
+    rank++;
+  }
+
+  // Check for inconsistency
+  for (let row = rank; row < numLights; row++) {
+    if (matrix[row][numButtons] !== 0) {
+      return null;
+    }
+  }
+
+  // Identify free variables
+  const isPivot = new Set(pivotCol);
+  const freeVars: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (!isPivot.has(col)) {
+      freeVars.push(col);
+    }
+  }
+
+  const numFree = freeVars.length;
+
+  // Precompute coefficients
+  const pivotCoeffs: number[][] = [];
+  const pivotConst: number[] = [];
+  for (let r = 0; r < rank; r++) {
+    const coeffs: number[] = [];
+    for (let i = 0; i < numFree; i++) {
+      coeffs.push(matrix[r][freeVars[i]]);
+    }
+    pivotCoeffs.push(coeffs);
+    pivotConst.push(matrix[r][numButtons]);
+  }
+
+  const solution = new Array(numButtons).fill(0);
+  let bestSolution: number[] | null = null;
+  let bestTotal = Infinity;
+
+  const computeAndCheck = (): void => {
+    for (let r = 0; r < rank; r++) {
+      let val = pivotConst[r];
+      for (let i = 0; i < numFree; i++) {
+        val -= pivotCoeffs[r][i] * solution[freeVars[i]];
+      }
+      solution[pivotCol[r]] = mod(val, modulus);
+    }
+
+    let total = 0;
+    for (let j = 0; j < numButtons; j++) {
+      total += solution[j];
+    }
+
+    if (total < bestTotal || (total === bestTotal && compareLexArr(solution, bestSolution!) < 0)) {
+      bestTotal = total;
+      bestSolution = [...solution];
+    }
+  };
+
+  if (numFree === 0) {
+    computeAndCheck();
+    return bestSolution;
+  }
+
+  // Estimate search space
+  let searchSpace = 1;
+  let overflow = false;
+  for (let i = 0; i < numFree; i++) {
+    searchSpace *= modulus;
+    if (searchSpace > 10_000_000) {
+      overflow = true;
+      break;
+    }
+  }
+
+  if (!overflow) {
+    // Direct enumeration
+    const freeAssignment = new Array(numFree).fill(0);
+    let done = false;
+    while (!done) {
+      for (let i = 0; i < numFree; i++) {
+        solution[freeVars[i]] = freeAssignment[i];
+      }
+      computeAndCheck();
+
+      let carry = true;
+      for (let i = 0; i < numFree && carry; i++) {
+        freeAssignment[i]++;
+        if (freeAssignment[i] >= modulus) {
+          freeAssignment[i] = 0;
+        } else {
+          carry = false;
+        }
+      }
+      if (carry) done = true;
+    }
+  } else {
+    // Branch and bound with pruning
+    const searchBnB = (freeIdx: number, freeSum: number): void => {
+      if (freeSum >= bestTotal) return;
+
+      if (freeIdx === numFree) {
+        computeAndCheck();
+        return;
+      }
+
+      for (let v = 0; v < modulus; v++) {
+        solution[freeVars[freeIdx]] = v;
+        searchBnB(freeIdx + 1, freeSum + v);
+      }
+      solution[freeVars[freeIdx]] = 0;
+    };
+
+    searchBnB(0, 0);
+  }
+
+  return bestSolution;
+}
+
+function compareLexArr(a: number[], b: number[]): number {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] !== b[i]) return a[i] - b[i];
+  }
+  return 0;
+}
