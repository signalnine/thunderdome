       curLo = (curLo ^ finalBasisLo[i]) >>> 0;\n   305→          curHi = (curHi ^ finalBasisHi[i]) >>> 0;\n   306→        }\n   307→      }\n   308→      return curLo === 0 && curHi === 0;\n   309→    };\n   310→\n   311→    // Iterative deepening: for each distance d, try all C(numButtons, d) masks\n   312→    // Check if (candidate XOR baseMask) is in span\n   313→    // Collect all valid candidates at the minimum distance, then find lex smallest\n   314→\n   315→    const bitPositions: number[] = [];\n   316→    for (let b = 0; b < numButtons; b++) bitPositions.push(b);\n   317→\n   318→    // Limit iterative deepening to avoid combinatorial explosion\n   319→    // C(40,8) = 76M which takes ~2s. C(40,9) = 273M too slow.\n   320→    const maxIterDeepD = Math.min(numButtons, 8);\n   321→\n   322→    for (let d = 0; d <= maxIterDeepD; d++) {\n   323→      // Generate all d-bit masks and check\n   324→      const validMasks: { lo: number; hi: number }[] = [];\n   325→\n   326→      // Generate combinations of d positions from numButtons positions\n   327→      const combo = new Array(d).fill(0);\n   328→      for (let i = 0; i < d; i++) combo[i] = i;\n   329→\n   330→      if (d === 0) {\n   331→        // Check the zero mask (no buttons pressed)\n   332→        const testLo = baseLo;\n   333→        const testHi = baseHi;\n   334→        if (isInSpan(testLo, testHi)) {\n   335→          validMasks.push({ lo: 0, hi: 0 });\n   336→        }\n   337→      } else {\n   338→        let done = false;\n   339→        while (!done) {\n   340→          // Build the candidate mask from combo\n   341→          let candLo = 0;\n   342→          let candHi = 0;\n   343→          for (let i = 0; i < d; i++) {\n   344→            const b = combo[i];\n   345→            if (b < 32) candLo |= (1 << b);\n   346→            else candHi |= (1 << (b - 32));\n   347→          }\n   348→          candLo = candLo >>> 0;\n   349→          candHi = candHi >>> 0;\n   350→\n   351→          // Check if (candidate XOR baseMask) is in span\n   352→          const testLo = (candLo ^ baseLo) >>> 0;\n   353→          const testHi = (candHi ^ baseHi) >>> 0;\n   354→          if (isInSpan(testLo, testHi)) {\n   355→            validMasks.push({ lo: candLo, hi: candHi });\n   356→          }\n   357→\n   358→          // Generate next combination\n   359→          let i = d - 1;\n   360→          while (i >= 0 && combo[i] === numButtons - d + i) i--;\n   361→          if (i < 0) {\n   362→            done = true;\n   363→          } else {\n   364→            combo[i]++;\n   365→            for (let j = i + 1; j < d; j++) {\n   366→              combo[j] = combo[j - 1] + 1;\n   367→            }\n   368→          }\n   369→        }\n   370→      }\n   371→\n   372→      if (validMasks.length > 0) {\n   373→        // Find lex smallest among valid masks\n   374→        let best = validMasks[0];\n   375→        for (let i = 1; i < validMasks.length; i++) {\n   376→          if (compareMask(validMasks[i].lo, validMasks[i].hi, best.lo, best.hi) < 0) {\n   377→            best = validMasks[i];\n   378→          }\n   379→        }\n   380→        bestCount = d;\n   381→        bestLo = best.lo;\n   382→        bestHi = best.hi;\n   383→        break; // Found minimum distance\n   384→      }\n   385→    }\n   386→\n   387→    // If iterative deepening didn't find a solution, fall back to MITM\n   388→    if (bestCount > numButtons) {\n   389→      const halfA = Math.ceil(numGroups / 2);\n   390→      const halfB = numGroups - halfA;\n   391→      const halfASize = 1 << halfA;\n   392→      const halfBSize = 1 << halfB;\n   393→\n   394→      const halfALoArr = new Int32Array(halfASize);\n   395→      const halfAHiArr = new Int32Array(halfASize);\n   396→      {\n   397→        let lo = baseLo;\n   398→        let hi = baseHi;\n   399→        halfALoArr[0] = lo;\n   400→        halfAHiArr[0] = hi;\n   401→\n   402→        for (let gray = 1; gray < halfASize; gray++