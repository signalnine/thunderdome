 });\n    49→\n    50→  it('renders footnote section at bottom of content', async () => {\n    51→    const file = makeFile({ content: 'Text[^1] and more[^2].\\n\\n[^1]: First note.\\n[^2]: Second note.' });\n    52→    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    53→    expect(result.content).toContain('<section class=\"footnotes\">');\n    54→    expect(result.content).toContain('<li id=\"fn-1\">First note.</li>');\n    55→    expect(result.content).toContain('<li id=\"fn-2\">Second note.</li>');\n    56→  });\n    57→\n    58→  it('converts :::note container to admonition div', async () => {\n    59→    const file = makeFile({ content: ':::note\\nThis is a note.\\n:::' });\n    60→    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    61→    expect(result.content).toContain('<div class=\"admonition admonition-note\">');\n    62→    expect(result.content).toContain('This is a note.');\n    63→  });\n    64→\n    65→  it('converts :::warning container to admonition div', async () => {\n    66→    const file = makeFile({ content: ':::warning\\nBe careful!\\n:::' });\n    67→    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    68→    expect(result.content).toContain('<div class=\"admonition admonition-warning\">');\n    69→    expect(result.content).toContain('Be careful!');\n    70→  });\n    71→\n    72→  it('converts :::tip container to admonition div', async () => {\n    73→    const file = makeFile({ content: ':::tip\\nHelpful hint.\\n:::' });\n    74→    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    75→    expect(result.content).toContain('<div class=\"admonition admonition-tip\">');\n    76→    expect(result.content).toContain('Helpful hint.');\n    77→  });\n    78→\n    79→  it('preserves existing HTML in content', async () => {\n    80→    const file = makeFile({ content: '<div class=\"custom\">Already HTML</div>' });\n    81→    const result = await