+++ b/src/plugins/markdown-ext.ts
@@ -0,0 +1,101 @@
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+function processAdmonitions(content: string): string {
+  return content.replace(/:::(note|warning|tip)\n([\s\S]*?):::/g, (_match, type: string, body: string) => {
+    return `<div class="admonition admonition-${type}">\n${body.trim()}\n</div>`;
+  });
+}
+
+function processFootnotes(content: string): string {
+  // Collect footnote definitions
+  const footnotes: Map<string, string> = new Map();
+  const defRegex = /^\[\^(\d+)\]:\s*(.+)$/gm;
+  let match: RegExpExecArray | null;
+  while ((match = defRegex.exec(content)) !== null) {
+    footnotes.set(match[1], match[2]);
+  }
+
+  // Remove footnote definitions from content
+  let result = content.replace(/^\[\^(\d+)\]:\s*(.+)$/gm, '');
+
+  // Replace footnote references with sup links
+  result = result.replace(/\[\^(\d+)\]/g, (_match, num: string) => {
+    return `<sup><a href="#fn-${num}">${num}</a></sup>`;
+  });
+
+  // If we have footnotes, add the footnotes section
+  if (footnotes.size > 0) {
+    let section = '<section class="footnotes">\n<ol>\n';
+    for (const [num, text] of footnotes) {
+      section += `<li id="fn-${num}">${text}</li>\n`;
+    }
+    section += '</ol>\n</section>';
+    result = result.trim() + '\n' + section;
+  }
+
+  return result;
+}
+
+function processMarkdown(content: string): string {
+  // Process headings
+  let result = content.replace(/^### (.+)$/gm, '<h3>$1</h3>');
+  result = result.replace(/^## (.+)$/gm, '<h2>$1</h2>');
+  result = result.replace(/^# (.+)$/gm, '<h1>$1</h1>');
+
+  // Process bold
+  result = result.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
+
+  // Process italic
+  result = result.replace(/\*(.+?)\*/g, '<em>$1</em>');
+
+  // Process paragraphs: lines that aren't already HTML tags or empty
+  const lines = result.split('\n');
+  const processed: string[] = [];
+  for (const line of lines) {
+    const trimmed = line.trim();
+    if (trimmed === '') {
+      processed.push('');
+    } else if (trimmed.startsWith('<')) {
+      processed.push(line);
+    } else {
+      processed.push(`<p>${trimmed}</p>`);
+    }
+  }
+
+  return processed.join('\n');
+}
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file: ContentFile, _ctx: BuildContext): ContentFile {
+        let content = file.content;
+
+        if (!content) {
+          return { ...file, content: '' };
+        }
+
+        // Process admonitions first (before markdown)
+        content = processAdmonitions(content);
+
+        // Process footnotes
+        content = processFootnotes(content);
+
+        // Only process markdown on non-HTML content
+        // Check if content is already predominantly HTML
+        const hasHtmlTags = /<[a-z][\s\S]*>/i.test(content);
+        const hasMarkdownHeadings = /^#+ /m.test(content);
+        const hasMarkdownBold = /\*\*[^*]+\*\*/m.test(content);
+
+        if (!hasHtmlTags || hasMarkdownHeadings || hasMarkdownBold) {
+          content = processMarkdown(content);
+        }
+
+        return { ...file, content };
+      },
+    },
+  };
+}
