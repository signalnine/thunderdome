+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01M648TmeQ31uvPRMzh9qakJ","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach, afterEach } from \"vitest\";\n     2→import request from \"supertest\";\n     3→import WebSocket from \"ws\";\n     4→import { createApp, AppInstance } from \"./server.js\";\n     5→\n     6→// Helper to create a WS client connected to a document\n     7→// Returns the WS and the initial sync message together to avoid race conditions\n     8→function connectWs(\n     9→  port: number,\n    10→  docId: string\n    11→): Promise<{ ws: WebSocket; sync: Record<string, unknown> }> {\n    12→  return new Promise((resolve, reject) => {\n    13→    const ws = new WebSocket(`ws://localhost:${port}/ws/${docId}`);\n    14→    const timeout = setTimeout(() => reject(new Error(\"Connection timeout\")), 5000);\n    15→    ws.on(\"message\", function handler(data) {\n    16→      clearTimeout(timeout);\n    17→      ws.off(\"message\", handler);\n    18→      resolve({ ws, sync: JSON.parse(data.toString()) });\n    19→    });\n    20→    ws.on(\"error\", (err) => {\n    21→      clearTimeout(timeout);\n    22→      reject(err);\n    23→    });\n    24→  });\n    25→}\n    26→\n    27→// Helper for connecting when we expect an error (non-existent doc, bad URL)\n    28→function connectWsRaw(port: number, path: string): Promise<WebSocket> {\n    29→  return new Promise((resolve, reject) => {\n    30→    const ws = new WebSocket(`ws://localhost:${port}${path}`);\n    31→    ws.on(\"open\", () => resolve(ws));\n    32→    ws.on(\"error\", reject);\n    33→  });\n    34→}\n    35→\n    36→// Helper to wait for next WS message\n    37→function nextMessage(ws: WebSocket): Promise<Record<string, unknown>> {\n    38→  return new Promise((resolve, reject) => {\n    39→    const timeout = setTimeout(() => reject(new Error(\"Message timeout\")), 5000);\n    40→    ws.once(\"message\", (data) => {\n    41→      clearTimeout(timeout);\n    42→      resolve(JSON.parse(data.toString()));\n    43→    });\n    44→  });\n    45→}\n    46→\n    47→// Helper: send an operation and wait for ack\n    48→async function sendOp(\n    49→  ws: WebSocket,\n    50→  docId: string,\n    51→  version: number,\n    52→  operation: Record<string, unknown>\n    53→): Promise<Record<string, unknown>> {\n    54→  const promise = nextMessage(ws);\n    55→  ws.send(\n    56→    JSON.stringify({ type: \"operation\", docId, version, operation })\n    57→  );\n    58→  return promise;\n    59→}\n    60→\n    61→// Helper to drain a message from a websocket (for skipping sync messages etc.)\n    62→function drainMessages(ws: WebSocket, count: number): Promise<Record<string, unknown>[]> {\n    63→  return new Promise((resolve) => {\n    64→    const messages: Record<string, unknown>[] = [];\n    65→    const handler = (data: WebSocket.Data) => {\n    66→      messages.push(JSON.parse(data.toString()));\n    67→      if (messages.length >= count) {\n    68→        ws.off(\"message\", handler);\n    69→        resolve(messages);\n    70→      }\n    71→    };\n    72→    ws.on(\"message\", handler);\n    73→  });\n    74→}\n    75→\n    76→// ─── REST CRUD ────────────────────────────────────────────────────────────────\n    77→describe(\"REST CRUD\", () => {\n    78→  let app: AppInstance;\n    79→  let port: number;\n    80→\n    81→  beforeEach(async () => {\n    82→    app = createApp();\n    83→    port = await app.start(0);\n    84→  });\n    85→\n    86→  afterEach(async () => {\n    87→    await app.stop();\n    88→  });\n    89→\n    90→  it(\"should create a document\", async () => {\n    91→    const res = await request(app.app)\n    92→      .post(\"/documents\")\n    93→      .send({ title: \"Test Doc\", content: \"Hello\" })\n    94→      .expect(201);\n    95→\n    96→    expect(res.body.id).toBeDefined();\n    97→    expect(res.body.title).toBe(\"Test Doc\");\n    98→    expect(res.body.content).toBe(\"Hello\");\n    99→  });\n   100→\n   101→  it(\"should create a document with empty content by default\", async () => {\n   102→    const res = await request(app.app)\n   103→      .post(\"/documents\")\n   104→      .send({ title: \"Empty Doc\" })\n   105→      .expect(201);\n   106→\n   107→    expect(res.body.content).toBe(\"\");\n   108→  });\n   109→\n   110→  it(\"should reject creating a document without title\", async () => {\n   111→    await request(app.app)\n   112→      .post(\"/documents\")\n   113→      .send({ content: \"No title\" })\n   114→      .expect(400);\n   115→  });\n   116→\n   117→  it(\"should get a document by id\", async () => {\n   118→    const create = await request(app.app)\n   119→      .post(\"/documents\")\n   120→      .send({ title: \"Get Me\" });\n   121→\n   122→    const res = await request(app.app)\n   123→      .get(`/documents/${create.body.id}`)\n   124→      .expect(200);\n   125→\n   126→    expect(res.body.title).toBe(\"Get Me\");\n   127→  });\n   128→\n   129→  it(\"should return 404 for non-existent document\", async () => {\n   130→    await request(app.app)\n   131→      .get(\"/documents/nonexistent-id\")\n   132→      .expect(404);\n   133→  });\n   134→\n   135→  it(\"should list all documents\", async () => {\n   136→    await request(app.app).post(\"/documents\").send({ title: \"Doc 1\" });\n   137→    await request(app.app).post(\"/documents\").send({ title: \"Doc 2\" });\n   138→\n   139→    const res = await request(app.app).get(\"/documents\").expect(200);\n   140→    expect(res.body.length).toBeGreaterThanOrEqual(2);\n   141→  });\n   142→\n   143→  it(\"should update a document title\", async () => {\n   144→    const create = await request(app.app)\n   145→      .post(\"/documents\")\n   146→      .send({ title: \"Old Title\" });\n   147→\n   148→    const res = await request(app.app)\n   149→      .put(`/documents/${create.body.id}`)\n   150→      .send({ title: \"New Title\" })\n   151→      .expect(200);\n   152→\n   153→    expect(res.body.title).toBe(\"New Title\");\n   154→  });\n   155→\n   156→  it(\"should update a document content via PUT\", async () => {\n   157→    const create = await request(app.app)\n   158→      .post(\"/documents\")\n   159→      .send({ title: \"Doc\", content: \"old\" });\n   160→\n   161→    const res = await request(app.app)\n   162→      .put(`/documents/${create.body.id}`)\n   163→      .send({ content: \"new content\" })\n   164→      .expect(200);\n   165→\n   166→    expect(res.body.content).toBe(\"new content\");\n   167→  });\n   168→\n   169→  it(\"should delete a document\", async () => {\n   170→    const create = await request(app.app)\n   171→      .post(\"/documents\")\n   172→      .send({ title: \"Delete Me\" });\n   173→\n   174→    await request(app.app)\n   175→      .delete(`/documents/${create.body.id}`)\n   176→      .expect(204);\n   177→\n   178→    await request(app.app)\n   179→      .get(`/documents/${create.body.id}`)\n   180→      .expect(404);\n   181→  });\n   182→\n   183→  it(\"should return 404 when deleting non-existent document\", async () => {\n   184→    await request(app.app)\n   185→      .delete(\"/documents/nonexistent-id\")\n   186→      .expect(404);\n   187→  });\n   188→\n   189→  it(\"should get version history for a document\", async () => {\n   190→    const create = await request(app.app)\n   191→      .post(\"/documents\")\n   192→      .send({ title: \"Versioned\", content: \"initial\" });\n   193→\n   194→    const res = await request(app.app)\n   195→      .get(`/documents/${create.body.id}/versions`)\n   196→      .expect(200);\n   197→\n   198→    expect(res.body.length).toBeGreaterThanOrEqual(1);\n   199→    expect(res.body[0].version).toBe(0);\n   200→    expect(res.body[0].content).toBe(\"initial\");\n   201→  });\n   202→\n   203→  it(\"should get a specific version\", async () => {\n   204→    const create = await request(app.app)\n   205→      .post(\"/documents\")\n   206→      .send({ title: \"Versioned\", content: \"v0\" });\n   207→\n   208→    const res = await request(app.app)\n   209→      .get(`/documents/${create.body.id}/versions/0`)\n   210→      .expect(200);\n   211→\n   212→    expect(res.body.version).toBe(0);\n   213→    expect(res.body.content).toBe(\"v0\");\n   214→  });\n   215→});\n   216→\n   217→// ─── WebSocket Lifecycle ──────────────────────────────────────────────────────\n   218→describe(\"WebSocket Lifecycle\", () => {\n   219→  let app: AppInstance;\n   220→  let port: number;\n   221→\n   222→  beforeEach(async () => {\n   223→    app = createApp();\n   224→    port = await app.start(0);\n   225→  });\n   226→\n   227→  afterEach(async () => {\n   228→    await app.stop();\n   229→  });\n   230→\n   231→  it(\"should connect to a document via WebSocket\", async () => {\n   232→    const doc = await request(app.app)\n   233→      .post(\"/documents\")\n   234→      .send({ title: \"WS Doc\", content: \"hello\" });\n   235→\n   236→    const ws = await connectWs(port, doc.body.id);\n   237→    const msg = await nextMessage(ws);\n   238→\n   239→    expect(msg.type).toBe(\"sync\");\n   240→    expect(msg.content).toBe(\"hello\");\n   241→    expect(msg.version).toBe(0);\n   242→\n   243→    ws.close();\n   244→  });\n   245→\n   246→  it(\"should receive sync with current content and version\", async () => {\n   247→    const doc = await request(app.app)\n   248→      .post(\"/documents\")\n   249→      .send({ title: \"Sync Doc\", content: \"content here\" });\n   250→\n   251→    const ws = await connectWs(port, doc.body.id);\n   252→    const msg = await nextMessage(ws);\n   253→\n   254→    expect(msg.type).toBe(\"sync\");\n   255→    expect(msg.content).toBe(\"content here\");\n   256→    expect(typeof msg.version).toBe(\"number\");\n   257→\n   258→    ws.close();\n   259→  });\n   260→\n   261→  it(\"should reject connection to non-existent document\", async () => {\n   262→    const ws = new WebSocket(`ws://localhost:${port}/ws/nonexistent-doc`);\n   263→    const msg = await nextMessage(ws);\n   264→\n   265→    expect(msg.type).toBe(\"error\");\n   266→    ws.close();\n   267→  });\n   268→\n   269→  it(\"should reject connection with invalid URL\", async () => {\n   270→    const ws = new WebSocket(`ws://localhost:${port}/invalid-path`);\n   271→    const msg = await nextMessage(ws);\n   272→\n   273→    expect(msg.type).toBe(\"error\");\n   274→    ws.close();\n   275→  });\n   276→\n   277→  it(\"should handle multiple clients connecting to same document\", async () => {\n   278→    const doc = await request(app.app)\n   279→      .post(\"/documents\")\n   280→      .send({ title: \"Multi\", content: \"shared\" });\n   281→\n   282→    const ws1 = await connectWs(port, doc.body.id);\n   283→    const msg1 = await nextMessage(ws1);\n   284→\n   285→    const ws2 = await connectWs(port, doc.body.id);\n   286→    const msg2 = await nextMessage(ws2);\n   287→\n   288→    expect(msg1.type).toBe(\"sync\");\n   289→    expect(msg2.type).toBe(\"sync\");\n   290→    expect(msg1.content).toBe(\"shared\");\n   291→    expect(msg2.content).toBe(\"shared\");\n   292→\n   293→    ws1.close();\n   294→    ws2.close();\n   295→  });\n   296→\n   297→  it(\"should handle client disconnect gracefully\", async () => {\n   298→    const doc = await request(app.app)\n   299→      .post(\"/documents\")\n   300→      .send({ title: \"Disconnect\", content: \"\" });\n   301→\n   302→    const ws = await connectWs(port, doc.body.id);\n   303→    await nextMessage(ws); // sync\n   304→    ws.close();\n   305→\n   306→    // Server should still work after client disconnects\n   307→    const ws2 = await connectWs(port, doc.body.id);\n   308→    const msg = await nextMessage(ws2);\n   309→    expect(msg.type).toBe(\"sync\");\n   310→    ws2.close();\n   311→  });\n   312→\n   313→  it(\"should handle connecting to different documents\", async () => {\n   314→    const doc1 = await request(app.app)\n   315→      .post(\"/documents\")\n   316→      .send({ title: \"Doc A\", content: \"aaa\" });\n   317→    const doc2 = await request(app.app)\n   318→      .post(\"/documents\")\n   319→      .send({ title: \"Doc B\", content: \"bbb\" });\n   320→\n   321→    const ws1 = await connectWs(port, doc1.body.id);\n   322→    const msg1 = await nextMessage(ws1);\n   323→\n   324→    const ws2 = await connectWs(port, doc2.body.id);\n   325→    const msg2 = await nextMessage(ws2);\n   326→\n   327→    expect(msg1.content).toBe(\"aaa\");\n   328→    expect(msg2.content).toBe(\"bbb\");\n   329→\n   330→    ws1.close();\n   331→    ws2.close();\n   332→  });\n   333→\n   334→  it(\"should include docId in sync message\", async () => {\n   335→    const doc = await request(app.app)\n   336→      .post(\"/documents\")\n   337→      .send({ title: \"ID Check\", content: \"\" });\n   338→\n   339→    const ws = await connectWs(port, doc.body.id);\n   340→    const msg = await nextMessage(ws);\n   341→\n   342→    expect(msg.docId).toBe(doc.body.id);\n   343→    ws.close();\n   344→  });\n   345→});\n   346→\n   347→// ─── Single Client Editing ────────────────────────────────────────────────────\n   348→describe(\"Single Client Editing\", () => {\n   349→  let app: AppInstance;\n   350→  let port: number;\n   351→\n   352→  beforeEach(async () => {\n   353→    app = createApp();\n   354→    port = await app.start(0);\n   355→  });\n   356→\n   357→  afterEach(async () => {\n   358→    await app.stop();\n   359→  });\n   360→\n   361→  it(\"should apply an insert operation\", async () => {\n   362→    const doc = await request(app.app)\n   363→      .post(\"/documents\")\n   364→      .send({ title: \"Edit\", content: \"\" });\n   365→\n   366→    const ws = await connectWs(port, doc.body.id);\n   367→    await nextMessage(ws); // sync\n   368→\n   369→    const ack = await sendOp(ws, doc.body.id, 0, {\n   370→      type: \"insert\",\n   371→      position: 0,\n   372→      text: \"Hello\",\n   373→    });\n   374→\n   375→    expect(ack.type).toBe(\"ack\");\n   376→    expect(ack.version).toBe(1);\n   377→\n   378→    // Verify via REST\n   379→    const res = await request(app.app)\n   380→      .get(`/documents/${doc.body.id}`)\n   381→      .expect(200);\n   382→    expect(res.body.content).toBe(\"Hello\");\n   383→\n   384→    ws.close();\n   385→  });\n   386→\n   387→  it(\"should apply a delete operation\", async () => {\n   388→    const doc = await request(app.app)\n   389→      .post(\"/documents\")\n   390→      .send({ title: \"Delete\", content: \"Hello World\" });\n   391→\n   392→    const ws = await connectWs(port, doc.body.id);\n   393→    await nextMessage(ws); // sync\n   394→\n   395→    const ack = await sendOp(ws, doc.body.id, 0, {\n   396→      type: \"delete\",\n   397→      position: 5,\n   398→      length: 6,\n   399→    });\n   400→\n   401→    expect(ack.type).toBe(\"ack\");\n   402→\n   403→    const res = await request(app.app)\n   404→      .get(`/documents/${doc.body.id}`)\n   405→      .expect(200);\n   406→    expect(res.body.content).toBe(\"Hello\");\n   407→\n   408→    ws.close();\n   409→  });\n   410→\n   411→  it(\"should apply multiple sequential operations\", async () => {\n   412→    const doc = await request(app.app)\n   413→      .post(\"/documents\")\n   414→      .send({ title: \"Sequential\", content: \"\" });\n   415→\n   416→    const ws = await connectWs(port, doc.body.id);\n   417→    await nextMessage(ws); // sync\n   418→\n   419→    // Insert \"Hello\"\n   420→    await sendOp(ws, doc.body.id, 0, {\n   421→      type: \"insert\",\n   422→      position: 0,\n   423→      text: \"Hello\",\n   424→    });\n   425→\n   426→    // Insert \" World\"\n   427→    await sendOp(ws, doc.body.id, 1, {\n   428→      type: \"insert\",\n   429→      position: 5,\n   430→      text: \" World\",\n   431→    });\n   432→\n   433→    const res = await request(app.app)\n   434→      .get(`/documents/${doc.body.id}`)\n   435→      .expect(200);\n   436→    expect(res.body.content).toBe(\"Hello World\");\n   437→\n   438→    ws.close();\n   439→  });\n   440→\n   441→  it(\"should record versions for each operation\", async () => {\n   442→    const doc = await request(app.app)\n   443→      .post(\"/documents\")\n   444→      .send({ title: \"Versions\", content: \"\" });\n   445→\n   446→    const ws = await connectWs(port, doc.body.id);\n   447→    await nextMessage(ws); // sync\n   448→\n   449→    await sendOp(ws, doc.body.id, 0, {\n   450→      type: \"insert\",\n   451→      position: 0,\n   452→      text: \"A\",\n   453→    });\n   454→\n   455→    await sendOp(ws, doc.body.id, 1, {\n   456→      type: \"insert\",\n   457→      position: 1,\n   458→      text: \"B\",\n   459→    });\n   460→\n   461→    const versions = await request(app.app)\n   462→      .get(`/documents/${doc.body.id}/versions`)\n   463→      .expect(200);\n   464→\n   465→    // Should have initial version + 2 operation versions\n   466→    expect(versions.body.length).toBeGreaterThanOrEqual(3);\n   467→\n   468→    ws.close();\n   469→  });\n   470→\n   471→  it(\"should insert at specific positions\", async () => {\n   472→    const doc = await request(app.app)\n   473→      .post(\"/documents\")\n   474→      .send({ title: \"Position\", content: \"AC\" });\n   475→\n   476→    const ws = await connectWs(port, doc.body.id);\n   477→    await nextMessage(ws); // sync\n   478→\n   479→    await sendOp(ws, doc.body.id, 0, {\n   480→      type: \"insert\",\n   481→      position: 1,\n   482→      text: \"B\",\n   483→    });\n   484→\n   485→    const res = await request(app.app)\n   486→      .get(`/documents/${doc.body.id}`)\n   487→      .expect(200);\n   488→    expect(res.body.content).toBe(\"ABC\");\n   489→\n   490→    ws.close();\n   491→  });\n   492→\n   493→  it(\"should handle insert at end of document\", async () => {\n   494→    const doc = await request(app.app)\n   495→      .post(\"/documents\")\n   496→      .send({ title: \"End Insert\", content: \"Hello\" });\n   497→\n   498→    const ws = await connectWs(port, doc.body.id);\n   499→    await nextMessage(ws); // sync\n   500→\n   501→    await sendOp(ws, doc.body.id, 0, {\n   502→      type: \"insert\",\n   503→      position: 5,\n   504→      text: \"!\",\n   505→    });\n   506→\n   507→    const res = await request(app.app)\n   508→      .get(`/documents/${doc.body.id}`)\n   509→      .expect(200);\n   510→    expect(res.body.content).toBe(\"Hello!\");\n   511→\n   512→    ws.close();\n   513→  });\n   514→});\n   515→\n   516→// ─── Two-Client Convergence ──────────────────────────────────────────────────\n   517→describe(\"Two-Client Convergence\", () => {\n   518→  let app: AppInstance;\n   519→  let port: number;\n   520→\n   521→  beforeEach(async () => {\n   522→    app = createApp();\n   523→    port = await app.start(0);\n   524→  });\n   525→\n   526→  afterEach(async () => {\n   527→    await app.stop();\n   528→  });\n   529→\n   530→  it(\"should broadcast operations to other clients\", async () => {\n   531→    const doc = await request(app.app)\n   532→      .post(\"/documents\")\n   533→      .send({ title: \"Broadcast\", content: \"\" });\n   534→\n   535→    const ws1 = await connectWs(port, doc.body.id);\n   536→    await nextMessage(ws1); // sync\n   537→\n   538→    const ws2 = await connectWs(port, doc.body.id);\n   539→    await nextMessage(ws2); // sync\n   540→\n   541→    // Set up listener for ws2 before sending from ws1\n   542→    const ws2Promise = nextMessage(ws2);\n   543→\n   544→    // ws1 sends an insert\n   545→    await sendOp(ws1, doc.body.id, 0, {\n   546→      type: \"insert\",\n   547→      position: 0,\n   548→      text: \"Hello\",\n   549→    });\n   550→\n   551→    // ws2 should receive the broadcast\n   552→    const broadcast = await ws2Promise;\n   553→    expect(broadcast.type).toBe(\"operation\");\n   554→    expect(broadcast.version).toBe(1);\n   555→\n   556→    ws1.close();\n   557→    ws2.close();\n   558→  });\n   559→\n   560→  it(\"should converge with concurrent inserts at different positions\", async () => {\n   561→    const doc = await request(app.app)\n   562→      .post(\"/documents\")\n   563→      .send({ title: \"Converge\", content: \"Hello World\" });\n   564→\n   565→    const ws1 = await connectWs(port, doc.body.id);\n   566→    await nextMessage(ws1); // sync\n   567→\n   568→    const ws2 = await connectWs(port, doc.body.id);\n   569→    await nextMessage(ws2); // sync\n   570→\n   571→    // Both clients send concurrent operations based on version 0\n   572→    const ws2Broadcast = nextMessage(ws2);\n   573→    const ws1Broadcast = nextMessage(ws1);\n   574→\n   575→    // ws1 inserts at position 0\n   576→    await sendOp(ws1, doc.body.id, 0, {\n   577→      type: \"insert\",\n   578→      position: 0,\n   579→      text: \"A\",\n   580→    });\n   581→\n   582→    // Wait for ws2 to get the broadcast before ws2 sends\n   583→    await ws2Broadcast;\n   584→\n   585→    // ws2 inserts at position 11 (end), but based on version 0\n   586→    await sendOp(ws2, doc.body.id, 0, {\n   587→      type: \"insert\",\n   588→      position: 11,\n   589→      text: \"B\",\n   590→    });\n   591→\n   592→    await ws1Broadcast;\n   593→\n   594→    // Wait a beat for persistence\n   595→    await new Promise((r) => setTimeout(r, 100));\n   596→\n   597→    // Check final state\n   598→    const res = await request(app.app)\n   599→      .get(`/documents/${doc.body.id}`)\n   600→      .expect(200);\n   601→\n   602→    // Both A and B should be present\n   603→    expect(res.body.content).toContain(\"A\");\n   604→    expect(res.body.content).toContain(\"B\");\n   605→    expect(res.body.content).toContain(\"Hello World\");\n   606→\n   607→    ws1.close();\n   608→    ws2.close();\n   609→  });\n   610→\n   611→  it(\"should converge with concurrent inserts at the same position\", async () => {\n   612→    const doc = await request(app.app)\n   613→      .post(\"/documents\")\n   614→      .send({ title: \"Same Pos\", content: \"\" });\n   615→\n   616→    const ws1 = await connectWs(port, doc.body.id);\n   617→    await nextMessage(ws1); // sync\n   618→\n   619→    const ws2 = await connectWs(port, doc.body.id);\n   620→    await nextMessage(ws2); // sync\n   621→\n   622→    // Both insert at position 0, based on version 0\n   623→    const ws2Broadcast = nextMessage(ws2);\n   624→\n   625→    await sendOp(ws1, doc.body.id, 0, {\n   626→      type: \"insert\",\n   627→      position: 0,\n   628→      text: \"A\",\n   629→    });\n   630→\n   631→    await ws2Broadcast;\n   632→\n   633→    const ws1Broadcast = nextMessage(ws1);\n   634→    await sendOp(ws2, doc.body.id, 0, {\n   635→      type: \"insert\",\n   636→      position: 0,\n   637→      text: \"B\",\n   638→    });\n   639→\n   640→    await ws1Broadcast;\n   641→\n   642→    await new Promise((r) => setTimeout(r, 100));\n   643→\n   644→    const res = await request(app.app)\n   645→      .get(`/documents/${doc.body.id}`)\n   646→      .expect(200);\n   647→\n   648→    // Both characters should be present\n   649→    expect(res.body.content).toContain(\"A\");\n   650→    expect(res.body.content).toContain(\"B\");\n   651→    expect(res.body.content.length).toBe(2);\n   652→\n   653→    ws1.close();\n   654→    ws2.close();\n   655→  });\n   656→\n   657→  it(\"should converge with concurrent insert and delete\", async () => {\n   658→    const doc = await request(app.app)\n   659→      .post(\"/documents\")\n   660→      .send({ title: \"InsertDelete\", content: \"Hello\" });\n   661→\n   662→    const ws1 = await connectWs(port, doc.body.id);\n   663→    await nextMessage(ws1); // sync\n   664→\n   665→    const ws2 = await connectWs(port, doc.body.id);\n   666→    await nextMessage(ws2); // sync\n   667→\n   668→    const ws2Broadcast = nextMessage(ws2);\n   669→\n   670→    // ws1 inserts at beginning\n   671→    await sendOp(ws1, doc.body.id, 0, {\n   672→      type: \"insert\",\n   673→      position: 0,\n   674→      text: \"X\",\n   675→    });\n   676→\n   677→    await ws2Broadcast;\n   678→\n   679→    const ws1Broadcast = nextMessage(ws1);\n   680→\n   681→    // ws2 deletes last character, based on version 0\n   682→    await sendOp(ws2, doc.body.id, 0, {\n   683→      type: \"delete\",\n   684→      position: 4,\n   685→      length: 1,\n   686→    });\n   687→\n   688→    await ws1Broadcast;\n   689→\n   690→    await new Promise((r) => setTimeout(r, 100));\n   691→\n   692→    const res = await request(app.app)\n   693→      .get(`/documents/${doc.body.id}`)\n   694→      .expect(200);\n   695→\n   696→    // \"X\" should be inserted, last char \"o\" should be deleted\n   697→    expect(res.body.content).toContain(\"X\");\n   698→    expect(res.body.content).toContain(\"Hell\");\n   699→    expect(res.body.content).toBe(\"XHell\");\n   700→\n   701→    ws1.close();\n   702→    ws2.close();\n   703→  });\n   704→\n   705→  it(\"should handle rapid sequential edits from two clients\", async () => {\n   706→    const doc = await request(app.app)\n   707→      .post(\"/documents\")\n   708→      .send({ title: \"Rapid\", content: \"\" });\n   709→\n   710→    const ws1 = await connectWs(port, doc.body.id);\n   711→    await nextMessage(ws1); // sync\n   712→\n   713→    const ws2 = await connectWs(port, doc.body.id);\n   714→    await nextMessage(ws2); // sync\n   715→\n   716→    // ws1 types \"AB\"\n   717→    const b1 = nextMessage(ws2);\n   718→    await sendOp(ws1, doc.body.id, 0, {\n   719→      type: \"insert\", position: 0, text: \"A\",\n   720→    });\n   721→    await b1;\n   722→\n   723→    const b2 = nextMessage(ws2);\n   724→    await sendOp(ws1, doc.body.id, 1, {\n   725→      type: \"insert\", position: 1, text: \"B\",\n   726→    });\n   727→    await b2;\n   728→\n   729→    // ws2 types \"CD\" at end, based on latest version\n   730→    const b3 = nextMessage(ws1);\n   731→    await sendOp(ws2, doc.body.id, 2, {\n   732→      type: \"insert\", position: 2, text: \"C\",\n   733→    });\n   734→    await b3;\n   735→\n   736→    const b4 = nextMessage(ws1);\n   737→    await sendOp(ws2, doc.body.id, 3, {\n   738→      type: \"insert\", position: 3, text: \"D\",\n   739→    });\n   740→    await b4;\n   741→\n   742→    await new Promise((r) => setTimeout(r, 100));\n   743→\n   744→    const res = await request(app.app)\n   745→      .get(`/documents/${doc.body.id}`)\n   746→      .expect(200);\n   747→\n   748→    expect(res.body.content).toBe(\"ABCD\");\n   749→\n   750→    ws1.close();\n   751→    ws2.close();\n   752→  });\n   753→\n   754→  it(\"should not lose any edits from either client\", async () => {\n   755→    const doc = await request(app.app)\n   756→      .post(\"/documents\")\n   757→      .send({ title: \"NoLoss\", content: \"\" });\n   758→\n   759→    const ws1 = await connectWs(port, doc.body.id);\n   760→    await nextMessage(ws1); // sync\n   761→\n   762→    const ws2 = await connectWs(port, doc.body.id);\n   763→    await nextMessage(ws2); // sync\n   764→\n   765→    // Client 1 inserts \"Hello\"\n   766→    const b1 = nextMessage(ws2);\n   767→    await sendOp(ws1, doc.body.id, 0, {\n   768→      type: \"insert\", position: 0, text: \"Hello\",\n   769→    });\n   770→    await b1;\n   771→\n   772→    // Client 2 inserts \" World\" at end, based on version 1\n   773→    const b2 = nextMessage(ws1);\n   774→    await sendOp(ws2, doc.body.id, 1, {\n   775→      type: \"insert\", position: 5, text: \" World\",\n   776→    });\n   777→    await b2;\n   778→\n   779→    await new Promise((r) => setTimeout(r, 100));\n   780→\n   781→    const res = await request(app.app)\n   782→      .get(`/documents/${doc.body.id}`)\n   783→      .expect(200);\n   784→\n   785→    expect(res.body.content).toBe(\"Hello World\");\n   786→\n   787→    ws1.close();\n   788→    ws2.close();\n   789→  });\n   790→\n   791→  it(\"should maintain correct version numbering across clients\", async () => {\n   792→    const doc = await request(app.app)\n   793→      .post(\"/documents\")\n   794→      .send({ title: \"Version Track\", content: \"\" });\n   795→\n   796→    const ws1 = await connectWs(port, doc.body.id);\n   797→    await nextMessage(ws1); // sync\n   798→\n   799→    const ack1 = await sendOp(ws1, doc.body.id, 0, {\n   800→      type: \"insert\", position: 0, text: \"A\",\n   801→    });\n   802→    expect(ack1.version).toBe(1);\n   803→\n   804→    const ack2 = await sendOp(ws1, doc.body.id, 1, {\n   805→      type: \"insert\", position: 1, text: \"B\",\n   806→    });\n   807→    expect(ack2.version).toBe(2);\n   808→\n   809→    ws1.close();\n   810→  });\n   811→\n   812→  it(\"should transform operations correctly when versions diverge\", async () => {\n   813→    const doc = await request(app.app)\n   814→      .post(\"/documents\")\n   815→      .send({ title: \"Diverge\", content: \"XY\" });\n   816→\n   817→    const ws1 = await connectWs(port, doc.body.id);\n   818→    await nextMessage(ws1); // sync\n   819→\n   820→    const ws2 = await connectWs(port, doc.body.id);\n   821→    await nextMessage(ws2); // sync\n   822→\n   823→    // ws1 inserts \"A\" at position 0 — doc becomes \"AXY\"\n   824→    const b1 = nextMessage(ws2);\n   825→    await sendOp(ws1, doc.body.id, 0, {\n   826→      type: \"insert\", position: 0, text: \"A\",\n   827→    });\n   828→    await b1;\n   829→\n   830→    // ws2 sends based on version 0 (before seeing A), inserting \"B\" at end (position 2)\n   831→    // Server needs to transform: position 2 -> position 3 (because \"A\" was inserted before it)\n   832→    const b2 = nextMessage(ws1);\n   833→    await sendOp(ws2, doc.body.id, 0, {\n   834→      type: \"insert\", position: 2, text: \"B\",\n   835→    });\n   836→    await b2;\n   837→\n   838→    await new Promise((r) => setTimeout(r, 100));\n   839→\n   840→    const res = await request(app.app)\n   841→      .get(`/documents/${doc.body.id}`)\n   842→      .expect(200);\n   843→\n   844→    expect(res.body.content).toBe(\"AXYB\");\n   845→\n   846→    ws1.close();\n   847→    ws2.close();\n   848→  });\n   849→});\n   850→\n   851→// ─── Stress Test ─────────────────────────────────────────────────────────────\n   852→describe(\"Stress Test\", () => {\n   853→  let app: AppInstance;\n   854→  let port: number;\n   855→\n   856→  beforeEach(async () => {\n   857→    app = createApp();\n   858→    port = await app.start(0);\n   859→  });\n   860→\n   861→  afterEach(async () => {\n   862→    await app.stop();\n   863→  });\n   864→\n   865→  it(\"should handle 10 concurrent clients on the same document\", async () => {\n   866→    const doc = await request(app.app)\n   867→      .post(\"/documents\")\n   868→      .send({ title: \"Stress\", content: \"\" });\n   869→\n   870→    const clients: WebSocket[] = [];\n   871→    const syncPromises: Promise<Record<string, unknown>>[] = [];\n   872→\n   873→    // Connect 10 clients\n   874→    for (let i = 0; i < 10; i++) {\n   875→      const ws = await connectWs(port, doc.body.id);\n   876→      syncPromises.push(nextMessage(ws));\n   877→      clients.push(ws);\n   878→    }\n   879→\n   880→    // Wait for all syncs\n   881→    await Promise.all(syncPromises);\n   882→\n   883→    // Each client sends one insert sequentially to avoid race conditions\n   884→    for (let i = 0; i < clients.length; i++) {\n   885→      await sendOp(clients[i], doc.body.id, i, {\n   886→        type: \"insert\",\n   887→        position: i,\n   888→        text: String(i),\n   889→      });\n   890→      // Small delay to let broadcasts propagate\n   891→      await new Promise((r) => setTimeout(r, 50));\n   892→    }\n   893→\n   894→    await new Promise((r) => setTimeout(r, 200));\n   895→\n   896→    // Verify final state\n   897→    const res = await request(app.app)\n   898→      .get(`/documents/${doc.body.id}`)\n   899→      .expect(200);\n   900→\n   901→    // All 10 digits should be present\n   902→    for (let i = 0; i < 10; i++) {\n   903→      expect(res.body.content).toContain(String(i));\n   904→    }\n   905→    expect(res.body.content.length).toBe(10);\n   906→\n   907→    for (const ws of clients) ws.close();\n   908→  });\n   909→\n   910→  it(\"should not corrupt document with many rapid operations\", async () => {\n   911→    const doc = await request(app.app)\n   912→      .post(\"/documents\")\n   913→      .send({ title: \"Rapid Stress\", content: \"\" });\n   914→\n   915→    const ws = await connectWs(port, doc.body.id);\n   916→    await nextMessage(ws); // sync\n   917→\n   918→    // Send 20 rapid inserts\n   919→    for (let i = 0; i < 20; i++) {\n   920→      await sendOp(ws, doc.body.id, i, {\n   921→        type: \"insert\",\n   922→        position: i,\n   923→        text: String.fromCharCode(65 + (i % 26)),\n   924→      });\n   925→    }\n   926→\n   927→    await new Promise((r) => setTimeout(r, 200));\n   928→\n   929→    const res = await request(app.app)\n   930→      .get(`/documents/${doc.body.id}`)\n   931→      .expect(200);\n   932→\n   933→    expect(res.body.content.length).toBe(20);\n   934→\n   935→    ws.close();\n   936→  });\n   937→\n   938→  it(\"should handle multiple clients inserting simultaneously\", async () => {\n   939→    const doc = await request(app.app)\n   940→      .post(\"/documents\")\n   941→      .send({ title: \"Simultaneous\", content: \"\" });\n   942→\n   943→    const NUM_CLIENTS = 5;\n   944→    const clients: WebSocket[] = [];\n   945→\n   946→    for (let i = 0; i < NUM_CLIENTS; i++) {\n   947→      const ws = await connectWs(port, doc.body.id);\n   948→      await nextMessage(ws); // sync\n   949→      clients.push(ws);\n   950→    }\n   951→\n   952→    // All clients send concurrently, all based on version 0\n   953→    const ackPromises = clients.map((ws, i) =>\n   954→      sendOp(ws, doc.body.id, 0, {\n   955→        type: \"insert\",\n   956→        position: 0,\n   957→        text: String.fromCharCode(65 + i),\n   958→      })\n   959→    );\n   960→\n   961→    await Promise.all(ackPromises);\n   962→    await new Promise((r) => setTimeout(r, 300));\n   963→\n   964→    const res = await request(app.app)\n   965→      .get(`/documents/${doc.body.id}`)\n   966→      .expect(200);\n   967→\n   968→    // All letters should be present\n   969→    for (let i = 0; i < NUM_CLIENTS; i++) {\n   970→      expect(res.body.content).toContain(String.fromCharCode(65 + i));\n   971→    }\n   972→    expect(res.body.content.length).toBe(NUM_CLIENTS);\n   973→\n   974→    for (const ws of clients) ws.close();\n   975→  });\n   976→\n   977→  it(\"should maintain document integrity with interleaved inserts and deletes\", async () => {\n   978→    const doc = await request(app.app)\n   979→      .post(\"/documents\")\n   980→      .send({ title: \"Interleave\", content: \"ABCDE\" });\n   981→\n   982→    const ws1 = await connectWs(port, doc.body.id);\n   983→    await nextMessage(ws1); // sync\n   984→\n   985→    const ws2 = await connectWs(port, doc.body.id);\n   986→    await nextMessage(ws2); // sync\n   987→\n   988→    // ws1 deletes \"C\" (position 2, length 1)\n   989→    const b1 = nextMessage(ws2);\n   990→    await sendOp(ws1, doc.body.id, 0, {\n   991→      type: \"delete\", position: 2, length: 1,\n   992→    });\n   993→    await b1;\n   994→\n   995→    // ws2 inserts \"X\" at position 2 (based on version 1, after delete)\n   996→    const b2 = nextMessage(ws1);\n   997→    await sendOp(ws2, doc.body.id, 1, {\n   998→      type: \"insert\", position: 2, text: \"X\",\n   999→    });\n  1000→    await b2;\n  1001→\n  1002→    await new Promise((r) => setTimeout(r, 100));\n  1003→\n  1004→    const res = await request(app.app)\n  1005→      .get(`/documents/