+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01FgXjNXc3E9iUucbw4m4VEZ","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01MDzYHynTf3zNAFN5J5Y6MY","name":"Edit","input":{"replace_all":false,"file_path":"/workspace/src/server.test.ts","old_string":"// Helper to create a WS client connected to a document\nfunction connectWs(port: number, docId: string): Promise<WebSocket> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/${docId}`);\n    ws.on(\"open\", () => resolve(ws));\n    ws.on(\"error\", reject);\n  });\n}\n\n// Helper to wait for next WS message\nfunction nextMessage(ws: WebSocket): Promise<Record<string, unknown>> {\n  return new Promise((resolve, reject) => {\n    const timeout = setTimeout(() => reject(new Error(\"Message timeout\")), 5000);\n    ws.once(\"message\", (data) => {\n      clearTimeout(timeout);\n      resolve(JSON.parse(data.toString()));\n    });\n  });\n}","new_string":"// Helper to create a WS client connected to a document\n// Returns the WS and the initial sync message together to avoid race conditions\nfunction connectWs(\n  port: number,\n  docId: string\n): Promise<{ ws: WebSocket; sync: Record<string, unknown> }> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/${docId}`);\n    const timeout = setTimeout(() => reject(new Error(\"Connection timeout\")), 5000);\n    ws.on(\"message\", function handler(data) {\n      clearTimeout(timeout);\n      ws.off(\"message\", handler);\n      resolve({ ws, sync: JSON.parse(data.toString()) });\n    });\n    ws.on(\"error\", (err) => {\n      clearTimeout(timeout);\n      reject(err);\n    });\n  });\n}\n\n// Helper for connecting when we expect an error (non-existent doc, bad URL)\nfunction connectWsRaw(port: number, path: string): Promise<WebSocket> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}${path}`);\n    ws.on(\"open\", () => resolve(ws));\n    ws.on(\"error\", reject);\n  });\n}\n\n// Helper to wait for next WS message\nfunction nextMessage(ws: WebSocket): Promise<Record<string, unknown>> {\n  return new Promise((resolve, reject) => {\n    const timeout = setTimeout(() => reject(new Error(\"Message timeout\")), 5000);\n    ws.once(\"message\", (data) => {\n      clearTimeout(timeout);\n      resolve(JSON.parse(data.toString()));\n    });\n  });\n}"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1134,"cache_read_input_tokens":49202,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1134},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"2a8ce476-0495-481b-a577-fb7eedf6a3c7","uuid":"1d9ff320-cbd4-45a0-99ba-942a2f1a9f45"}
+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MDzYHynTf3zNAFN5J5Y6MY","type":"tool_result","content":"The file /workspace/src/server.test.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"2a8ce476-0495-481b-a577-fb7eedf6a3c7","uuid":"33626072-ed4e-4a1f-9236-8aa25a8b65f9","tool_use_result":{"filePath":"/workspace/src/server.test.ts","oldString":"// Helper to create a WS client connected to a document\nfunction connectWs(port: number, docId: string): Promise<WebSocket> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/${docId}`);\n    ws.on(\"open\", () => resolve(ws));\n    ws.on(\"error\", reject);\n  });\n}\n\n// Helper to wait for next WS message\nfunction nextMessage(ws: WebSocket): Promise<Record<string, unknown>> {\n  return new Promise((resolve, reject) => {\n    const timeout = setTimeout(() => reject(new Error(\"Message timeout\")), 5000);\n    ws.once(\"message\", (data) => {\n      clearTimeout(timeout);\n      resolve(JSON.parse(data.toString()));\n    });\n  });\n}","newString":"// Helper to create a WS client connected to a document\n// Returns the WS and the initial sync message together to avoid race conditions\nfunction connectWs(\n  port: number,\n  docId: string\n): Promise<{ ws: WebSocket; sync: Record<string, unknown> }> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/${docId}`);\n    const timeout = setTimeout(() => reject(new Error(\"Connection timeout\")), 5000);\n    ws.on(\"message\", function handler(data) {\n      clearTimeout(timeout);\n      ws.off(\"message\", handler);\n      resolve({ ws, sync: JSON.parse(data.toString()) });\n    });\n    ws.on(\"error\", (err) => {\n      clearTimeout(timeout);\n      reject(err);\n    });\n  });\n}\n\n// Helper for connecting when we expect an error (non-existent doc, bad URL)\nfunction connectWsRaw(port: number, path: string): Promise<WebSocket> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}${path}`);\n    ws.on(\"open\", () => resolve(ws));\n    ws.on(\"error\", reject);\n  });\n}\n\n// Helper to wait for next WS message\nfunction nextMessage(ws: WebSocket): Promise<Record<string, unknown>> {\n  return new Promise((resolve, reject) => {\n    const timeout = setTimeout(() => reject(new Error(\"Message timeout\")), 5000);\n    ws.once(\"message\", (data) => {\n      clearTimeout(timeout);\n      resolve(JSON.parse(data.toString()));\n    });\n  });\n}","originalFile":"import { describe, it, expect, beforeEach, afterEach } from \"vitest\";\nimport request from \"supertest\";\nimport WebSocket from \"ws\";\nimport { createApp, AppInstance } from \"./server.js\";\n\n// Helper to create a WS client connected to a document\nfunction connectWs(port: number, docId: string): Promise<WebSocket> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/${docId}`);\n    ws.on(\"open\", () => resolve(ws));\n    ws.on(\"error\", reject);\n  });\n}\n\n// Helper to wait for next WS message\nfunction nextMessage(ws: WebSocket): Promise<Record<string, unknown>> {\n  return new Promise((resolve, reject) => {\n    const timeout = setTimeout(() => reject(new Error(\"Message timeout\")), 5000);\n    ws.once(\"message\", (data) => {\n      clearTimeout(timeout);\n      resolve(JSON.parse(data.toString()));\n    });\n  });\n}\n\n// Helper: send an operation and wait for ack\nasync function sendOp(\n  ws: WebSocket,\n  docId: string,\n  version: number,\n  operation: Record<string, unknown>\n): Promise<Record<string, unknown>> {\n  const promise = nextMessage(ws);\n  ws.send(\n    JSON.stringify({ type: \"operation\", docId, version, operation })\n  );\n  return promise;\n}\n\n// Helper to drain a message from a websocket (for skipping sync messages etc.)\nfunction drainMessages(ws: WebSocket, count: number): Promise<Record<string, unknown>[]> {\n  return new Promise((resolve) => {\n    const messages: Record<string, unknown>[] = [];\n    const handler = (data: WebSocket.Data) => {\n      messages.push(JSON.parse(data.toString()));\n      if (messages.length >= count) {\n        ws.off(\"message\", handler);\n        resolve(messages);\n      }\n    };\n    ws.on(\"message\", handler);\n  });\n}\n\n// ─── REST CRUD ────────────────────────────────────────────────────────────────\ndescribe(\"REST CRUD\", () => {\n  let app: AppInstance;\n  let port: number;\n\n  beforeEach(async () => {\n    app = createApp();\n    port = await app.start(0);\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it(\"should create a document\", async () => {\n    const res = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Test Doc\", content: \"Hello\" })\n      .expect(201);\n\n    expect(res.body.id).toBeDefined();\n    expect(res.body.title).toBe(\"Test Doc\");\n    expect(res.body.content).toBe(\"Hello\");\n  });\n\n  it(\"should create a document with empty content by default\", async () => {\n    const res = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Empty Doc\" })\n      .expect(201);\n\n    expect(res.body.content).toBe(\"\");\n  });\n\n  it(\"should reject creating a document without title\", async () => {\n    await request(app.app)\n      .post(\"/documents\")\n      .send({ content: \"No title\" })\n      .expect(400);\n  });\n\n  it(\"should get a document by id\", async () => {\n    const create = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Get Me\" });\n\n    const res = await request(app.app)\n      .get(`/documents/${create.body.id}`)\n      .expect(200);\n\n    expect(res.body.title).toBe(\"Get Me\");\n  });\n\n  it(\"should return 404 for non-existent document\", async () => {\n    await request(app.app)\n      .get(\"/documents/nonexistent-id\")\n      .expect(404);\n  });\n\n  it(\"should list all documents\", async () => {\n    await request(app.app).post(\"/documents\").send({ title: \"Doc 1\" });\n    await request(app.app).post(\"/documents\").send({ title: \"Doc 2\" });\n\n    const res = await request(app.app).get(\"/documents\").expect(200);\n    expect(res.body.length).toBeGreaterThanOrEqual(2);\n  });\n\n  it(\"should update a document title\", async () => {\n    const create = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Old Title\" });\n\n    const res = await request(app.app)\n      .put(`/documents/${create.body.id}`)\n      .send({ title: \"New Title\" })\n      .expect(200);\n\n    expect(res.body.title).toBe(\"New Title\");\n  });\n\n  it(\"should update a document content via PUT\", async () => {\n    const create = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Doc\", content: \"old\" });\n\n    const res = await request(app.app)\n      .put(`/documents/${create.body.id}`)\n      .send({ content: \"new content\" })\n      .expect(200);\n\n    expect(res.body.content).toBe(\"new content\");\n  });\n\n  it(\"should delete a document\", async () => {\n    const create = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Delete Me\" });\n\n    await request(app.app)\n      .delete(`/documents/${create.body.id}`)\n      .expect(204);\n\n    await request(app.app)\n      .get(`/documents/${create.body.id}`)\n      .expect(404);\n  });\n\n  it(\"should return 404 when deleting non-existent document\", async () => {\n    await request(app.app)\n      .delete(\"/documents/nonexistent-id\")\n      .expect(404);\n  });\n\n  it(\"should get version history for a document\", async () => {\n    const create = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Versioned\", content: \"initial\" });\n\n    const res = await request(app.app)\n      .get(`/documents/${create.body.id}/versions`)\n      .expect(200);\n\n    expect(res.body.length).toBeGreaterThanOrEqual(1);\n    expect(res.body[0].version).toBe(0);\n    expect(res.body[0].content).toBe(\"initial\");\n  });\n\n  it(\"should get a specific version\", async () => {\n    const create = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Versioned\", content: \"v0\" });\n\n    const res = await request(app.app)\n      .get(`/documents/${create.body.id}/versions/0`)\n      .expect(200);\n\n    expect(res.body.version).toBe(0);\n    expect(res.body.content).toBe(\"v0\");\n  });\n});\n\n// ─── WebSocket Lifecycle ──────────────────────────────────────────────────────\ndescribe(\"WebSocket Lifecycle\", () => {\n  let app: AppInstance;\n  let port: number;\n\n  beforeEach(async () => {\n    app = createApp();\n    port = await app.start(0);\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it(\"should connect to a document via WebSocket\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"WS Doc\", content: \"hello\" });\n\n    const ws = await connectWs(port, doc.body.id);\n    const msg = await nextMessage(ws);\n\n    expect(msg.type).toBe(\"sync\");\n    expect(msg.content).toBe(\"hello\");\n    expect(msg.version).toBe(0);\n\n    ws.close();\n  });\n\n  it(\"should receive sync with current content and version\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Sync Doc\", content: \"content here\" });\n\n    const ws = await connectWs(port, doc.body.id);\n    const msg = await nextMessage(ws);\n\n    expect(msg.type).toBe(\"sync\");\n    expect(msg.content).toBe(\"content here\");\n    expect(typeof msg.version).toBe(\"number\");\n\n    ws.close();\n  });\n\n  it(\"should reject connection to non-existent document\", async () => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/nonexistent-doc`);\n    const msg = await nextMessage(ws);\n\n    expect(msg.type).toBe(\"error\");\n    ws.close();\n  });\n\n  it(\"should reject connection with invalid URL\", async () => {\n    const ws = new WebSocket(`ws://localhost:${port}/invalid-path`);\n    const msg = await nextMessage(ws);\n\n    expect(msg.type).toBe(\"error\");\n    ws.close();\n  });\n\n  it(\"should handle multiple clients connecting to same document\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Multi\", content: \"shared\" });\n\n    const ws1 = await connectWs(port, doc.body.id);\n    const msg1 = await nextMessage(ws1);\n\n    const ws2 = await connectWs(port, doc.body.id);\n    const msg2 = await nextMessage(ws2);\n\n    expect(msg1.type).toBe(\"sync\");\n    expect(msg2.type).toBe(\"sync\");\n    expect(msg1.content).toBe(\"shared\");\n    expect(msg2.content).toBe(\"shared\");\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should handle client disconnect gracefully\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Disconnect\", content: \"\" });\n\n    const ws = await connectWs(port, doc.body.id);\n    await nextMessage(ws); // sync\n    ws.close();\n\n    // Server should still work after client disconnects\n    const ws2 = await connectWs(port, doc.body.id);\n    const msg = await nextMessage(ws2);\n    expect(msg.type).toBe(\"sync\");\n    ws2.close();\n  });\n\n  it(\"should handle connecting to different documents\", async () => {\n    const doc1 = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Doc A\", content: \"aaa\" });\n    const doc2 = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Doc B\", content: \"bbb\" });\n\n    const ws1 = await connectWs(port, doc1.body.id);\n    const msg1 = await nextMessage(ws1);\n\n    const ws2 = await connectWs(port, doc2.body.id);\n    const msg2 = await nextMessage(ws2);\n\n    expect(msg1.content).toBe(\"aaa\");\n    expect(msg2.content).toBe(\"bbb\");\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should include docId in sync message\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"ID Check\", content: \"\" });\n\n    const ws = await connectWs(port, doc.body.id);\n    const msg = await nextMessage(ws);\n\n    expect(msg.docId).toBe(doc.body.id);\n    ws.close();\n  });\n});\n\n// ─── Single Client Editing ────────────────────────────────────────────────────\ndescribe(\"Single Client Editing\", () => {\n  let app: AppInstance;\n  let port: number;\n\n  beforeEach(async () => {\n    app = createApp();\n    port = await app.start(0);\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it(\"should apply an insert operation\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Edit\", content: \"\" });\n\n    const ws = await connectWs(port, doc.body.id);\n    await nextMessage(ws); // sync\n\n    const ack = await sendOp(ws, doc.body.id, 0, {\n      type: \"insert\",\n      position: 0,\n      text: \"Hello\",\n    });\n\n    expect(ack.type).toBe(\"ack\");\n    expect(ack.version).toBe(1);\n\n    // Verify via REST\n    const res = await request(app.app)\n      .get(`/documents/${doc.body.id}`)\n      .expect(200);\n    expect(res.body.content).toBe(\"Hello\");\n\n    ws.close();\n  });\n\n  it(\"should apply a delete operation\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Delete\", content: \"Hello World\" });\n\n    const ws = await connectWs(port, doc.body.id);\n    await nextMessage(ws); // sync\n\n    const ack = await sendOp(ws, doc.body.id, 0, {\n      type: \"delete\",\n      position: 5,\n      length: 6,\n    });\n\n    expect(ack.type).toBe(\"ack\");\n\n    const res = await request(app.app)\n      .get(`/documents/${doc.body.id}`)\n      .expect(200);\n    expect(res.body.content).toBe(\"Hello\");\n\n    ws.close();\n  });\n\n  it(\"should apply multiple sequential operations\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Sequential\", content: \"\" });\n\n    const ws = await connectWs(port, doc.body.id);\n    await nextMessage(ws); // sync\n\n    // Insert \"Hello\"\n    await sendOp(ws, doc.body.id, 0, {\n      type: \"insert\",\n      position: 0,\n      text: \"Hello\",\n    });\n\n    // Insert \" World\"\n    await sendOp(ws, doc.body.id, 1, {\n      type: \"insert\",\n      position: 5,\n      text: \" World\",\n    });\n\n    const res = await request(app.app)\n      .get(`/documents/${doc.body.id}`)\n      .expect(200);\n    expect(res.body.content).toBe(\"Hello World\");\n\n    ws.close();\n  });\n\n  it(\"should record versions for each operation\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Versions\", content: \"\" });\n\n    const ws = await connectWs(port, doc.body.id);\n    await nextMessage(ws); // sync\n\n    await sendOp(ws, doc.body.id, 0, {\n      type: \"insert\",\n      position: 0,\n      text: \"A\",\n    });\n\n    await sendOp(ws, doc.body.id, 1, {\n      type: \"insert\",\n      position: 1,\n      text: \"B\",\n    });\n\n    const versions = await request(app.app)\n      .get(`/documents/${doc.body.id}/versions`)\n      .expect(200);\n\n    // Should have initial version + 2 operation versions\n    expect(versions.body.length).toBeGreaterThanOrEqual(3);\n\n    ws.close();\n  });\n\n  it(\"should insert at specific positions\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Position\", content: \"AC\" });\n\n    const ws = await connectWs(port, doc.body.id);\n    await nextMessage(ws); // sync\n\n    await sendOp(ws, doc.body.id, 0, {\n      type: \"insert\",\n      position: 1,\n      text: \"B\",\n    });\n\n    const res = await request(app.app)\n      .get(`/documents/${doc.body.id}`)\n      .expect(200);\n    expect(res.body.content).toBe(\"ABC\");\n\n    ws.close();\n  });\n\n  it(\"should handle insert at end of document\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"End Insert\", content: \"Hello\" });\n\n    const ws = await connectWs(port, doc.body.id);\n    await nextMessage(ws); // sync\n\n    await sendOp(ws, doc.body.id, 0, {\n      type: \"insert\",\n      position: 5,\n      text: \"!\",\n    });\n\n    const res = await request(app.app)\n      .get(`/documents/${doc.body.id}`)\n      .expect(200);\n    expect(res.body.content).toBe(\"Hello!\");\n\n    ws.close();\n  });\n});\n\n// ─── Two-Client Convergence ──────────────────────────────────────────────────\ndescribe(\"Two-Client Convergence\", () => {\n  let app: AppInstance;\n  let port: number;\n\n  beforeEach(async () => {\n    app = createApp();\n    port = await app.start(0);\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it(\"should broadcast operations to other clients\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Broadcast\", content: \"\" });\n\n    const ws1 = await connectWs(port, doc.body.id);\n    await nextMessage(ws1); // sync\n\n    const ws2 = await connectWs(port, doc.body.id);\n    await nextMessage(ws2); // sync\n\n    // Set up listener for ws2 before sending from ws1\n    const ws2Promise = nextMessage(ws2);\n\n    // ws1 sends an insert\n    await sendOp(ws1, doc.body.id, 0, {\n      type: \"insert\",\n      position: 0,\n      text: \"Hello\",\n    });\n\n    // ws2 should receive the broadcast\n    const broadcast = await ws2Promise;\n    expect(broadcast.type).toBe(\"operation\");\n    expect(broadcast.version).toBe(1);\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should converge with concurrent inserts at different positions\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Converge\", content: \"Hello World\" });\n\n    const ws1 = await connectWs(port, doc.body.id);\n    await nextMessage(ws1); // sync\n\n    const ws2 = await connectWs(port, doc.body.id);\n    await nextMessage(ws2); // sync\n\n    // Both clients send concurrent operations based on version 0\n    const ws2Broadcast = nextMessage(ws2);\n    const ws1Broadcast = nextMessage(ws1);\n\n    // ws1 inserts at position 0\n    await sendOp(ws1, doc.body.id, 0, {\n      type: \"insert\",\n      position: 0,\n      text: \"A\",\n    });\n\n    // Wait for ws2 to get the broadcast before ws2 sends\n    await ws2Broadcast;\n\n    // ws2 inserts at position 11 (end), but based on version 0\n    await sendOp(ws2, doc.body.id, 0, {\n      type: \"insert\",\n      position: 11,\n      text: \"B\",\n    });\n\n    await ws1Broadcast;\n\n    // Wait a beat for persistence\n    await new Promise((r) => setTimeout(r, 100));\n\n    // Check final state\n    const res = await request(app.app)\n      .get(`/documents/${doc.body.id}`)\n      .expect(200);\n\n    // Both A and B should be present\n    expect(res.body.content).toContain(\"A\");\n    expect(res.body.content).toContain(\"B\");\n    expect(res.body.content).toContain(\"Hello World\");\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should converge with concurrent inserts at the same position\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Same Pos\", content: \"\" });\n\n    const ws1 = await connectWs(port, doc.body.id);\n    await nextMessage(ws1); // sync\n\n    const ws2 = await connectWs(port, doc.body.id);\n    await nextMessage(ws2); // sync\n\n    // Both insert at position 0, based on version 0\n    const ws2Broadcast = nextMessage(ws2);\n\n    await sendOp(ws1, doc.body.id, 0, {\n      type: \"insert\",\n      position: 0,\n      text: \"A\",\n    });\n\n    await ws2Broadcast;\n\n    const ws1Broadcast = nextMessage(ws1);\n    await sendOp(ws2, doc.body.id, 0, {\n      type: \"insert\",\n      position: 0,\n      text: \"B\",\n    });\n\n    await ws1Broadcast;\n\n    await new Promise((r) => setTimeout(r, 100));\n\n    const res = await request(app.app)\n      .get(`/documents/${doc.body.id}`)\n      .expect(200);\n\n    // Both characters should be present\n    expect(res.body.content).toContain(\"A\");\n    expect(res.body.content).toContain(\"B\");\n    expect(res.body.content.length).toBe(2);\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should converge with concurrent insert and delete\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"InsertDelete\", content: \"Hello\" });\n\n    const ws1 = await connectWs(port, doc.body.id);\n    await nextMessage(ws1); // sync\n\n    const ws2 = await connectWs(port, doc.body.id);\n    await nextMessage(ws2); // sync\n\n    const ws2Broadcast = nextMessage(ws2);\n\n    // ws1 inserts at beginning\n    await sendOp(ws1, doc.body.id, 0, {\n      type: \"insert\",\n      position: 0,\n      text: \"X\",\n    });\n\n    await ws2Broadcast;\n\n    const ws1Broadcast = nextMessage(ws1);\n\n    // ws2 deletes last character, based on version 0\n    await sendOp(ws2, doc.body.id, 0, {\n      type: \"delete\",\n      position: 4,\n      length: 1,\n    });\n\n    await ws1Broadcast;\n\n    await new Promise((r) => setTimeout(r, 100));\n\n    const res = await request(app.app)\n      .get(`/documents/${doc.body.id}`)\n      .expect(200);\n\n    // \"X\" should be inserted, last char \"o\" should be deleted\n    expect(res.body.content).toContain(\"X\");\n    expect(res.body.content).toContain(\"Hell\");\n    expect(res.body.content).toBe(\"XHell\");\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should handle rapid sequential edits from two clients\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Rapid\", content: \"\" });\n\n    const ws1 = await connectWs(port, doc.body.id);\n    await nextMessage(ws1); // sync\n\n    const ws2 = await connectWs(port, doc.body.id);\n    await nextMessage(ws2); // sync\n\n    // ws1 types \"AB\"\n    const b1 = nextMessage(ws2);\n    await sendOp(ws1, doc.body.id, 0, {\n      type: \"insert\", position: 0, text: \"A\",\n    });\n    await b1;\n\n    const b2 = nextMessage(ws2);\n    await sendOp(ws1, doc.body.id, 1, {\n      type: \"insert\", position: 1, text: \"B\",\n    });\n    await b2;\n\n    // ws2 types \"CD\" at end, based on latest version\n    const b3 = nextMessage(ws1);\n    await sendOp(ws2, doc.body.id, 2, {\n      type: \"insert\", position: 2, text: \"C\",\n    });\n    await b3;\n\n    const b4 = nextMessage(ws1);\n    await sendOp(ws2, doc.body.id, 3, {\n      type: \"insert\", position: 3, text: \"D\",\n    });\n    await b4;\n\n    await new Promise((r) => setTimeout(r, 100));\n\n    const res = await request(app.app)\n      .get(`/documents/${doc.body.id}`)\n      .expect(200);\n\n    expect(res.body.content).toBe(\"ABCD\");\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should not lose any edits from either client\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"NoLoss\", content: \"\" });\n\n    const ws1 = await connectWs(port, doc.body.id);\n    await nextMessage(ws1); // sync\n\n    const ws2 = await connectWs(port, doc.body.id);\n    await nextMessage(ws2); // sync\n\n    // Client 1 inserts \"Hello\"\n    const b1 = nextMessage(ws2);\n    await sendOp(ws1, doc.body.id, 0, {\n      type: \"insert\", position: 0, text: \"Hello\",\n    });\n    await b1;\n\n    // Client 2 inserts \" World\" at end, based on version 1\n    const b2 = nextMessage(ws1);\n    await sendOp(ws2, doc.body.id, 1, {\n      type: \"insert\", position: 5, text: \" World\",\n    });\n    await b2;\n\n    await new Promise((r) => setTimeout(r, 100));\n\n    const res = await request(app.app)\n      .get(`/documents/${doc.body.id}`)\n      .expect(200);\n\n    expect(res.body.content).toBe(\"Hello World\");\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should maintain correct version numbering across clients\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Version Track\", content: \"\" });\n\n    const ws1 = await connectWs(port, doc.body.id);\n    await nextMessage(ws1); // sync\n\n    const ack1 = await sendOp(ws1, doc.body.id, 0, {\n      type: \"insert\", position: 0, text: \"A\",\n    });\n    expect(ack1.version).toBe(1);\n\n    const ack2 = await sendOp(ws1, doc.body.id, 1, {\n      type: \"insert\", position: 1, text: \"B\",\n    });\n    expect(ack2.version).toBe(2);\n\n    ws1.close();\n  });\n\n  it(\"should transform operations correctly when versions diverge\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Diverge\", content: \"XY\" });\n\n    const ws1 = await connectWs(port, doc.body.id);\n    await nextMessage(ws1); // sync\n\n    const ws2 = await connectWs(port, doc.body.id);\n    await nextMessage(ws2); // sync\n\n    // ws1 inserts \"A\" at position 0 — doc becomes \"AXY\"\n    const b1 = nextMessage(ws2);\n    await sendOp(ws1, doc.body.id, 0, {\n      type: \"insert\", position: 0, text: \"A\",\n    });\n    await b1;\n\n    // ws2 sends based on version 0 (before seeing A), inserting \"B\" at end (position 2)\n    // Server needs to transform: position 2 -> position 3 (because \"A\" was inserted before it)\n    const b2 = nextMessage(ws1);\n    await sendOp(ws2, doc.body.id, 0, {\n      type: \"insert\", position: 2, text: \"B\",\n    });\n    await b2;\n\n    await new Promise((r) => setTimeout(r, 100));\n\n    const res = await request(app.app)\n      .get(`/documents/${doc.body.id}`)\n      .expect(200);\n\n    expect(res.body.content).toBe(\"AXYB\");\n\n    ws1.close();\n    ws2.close();\n  });\n});\n\n// ─── Stress Test ─────────────────────────────────────────────────────────────\ndescribe(\"Stress Test\", () => {\n  let app: AppInstance;\n  let port: number;\n\n  beforeEach(async () => {\n    app = createApp();\n    port = await app.start(0);\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it(\"should handle 10 concurrent clients on the same document\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Stress\", content: \"\" });\n\n    const clients: WebSocket[] = [];\n    const syncPromises: Promise<Record<string, unknown>>[] = [];\n\n    // Connect 10 clients\n    for (let i = 0; i < 10; i++) {\n      const ws = await connectWs(port, doc.body.id);\n      syncPromises.push(nextMessage(ws));\n      clients.push(ws);\n    }\n\n    // Wait for all syncs\n    await Promise.all(syncPromises);\n\n    // Each client sends one insert sequentially to avoid race conditions\n    for (let i = 0; i < clients.length; i++) {\n      await sendOp(clients[i], doc.body.id, i, {\n        type: \"insert\",\n        position: i,\n        text: String(i),\n      });\n      // Small delay to let broadcasts propagate\n      await new Promise((r) => setTimeout(r, 50));\n    }\n\n    await new Promise((r) => setTimeout(r, 200));\n\n    // Verify final state\n    const res = await request(app.app)\n      .get(`/documents/${doc.body.id}`)\n      .expect(200);\n\n    // All 10 digits should be present\n    for (let i = 0; i < 10; i++) {\n      expect(res.body.content).toContain(String(i));\n    }\n    expect(res.body.content.length).toBe(10);\n\n    for (const ws of clients) ws.close();\n  });\n\n  it(\"should not corrupt document with many rapid operations\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Rapid Stress\", content: \"\" });\n\n    const ws = await connectWs(port, doc.body.id);\n    await nextMessage(ws); // sync\n\n    // Send 20 rapid inserts\n    for (let i = 0; i < 20; i++) {\n      await sendOp(ws, doc.body.id, i, {\n        type: \"insert\",\n        position: i,\n        text: String.fromCharCode(65 + (i % 26)),\n      });\n    }\n\n    await new Promise((r) => setTimeout(r, 200));\n\n    const res = await request(app.app)\n      .get(`/documents/${doc.body.id}`)\n      .expect(200);\n\n    expect(res.body.content.length).toBe(20);\n\n    ws.close();\n  });\n\n  it(\"should handle multiple clients inserting simultaneously\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Simultaneous\", content: \"\" });\n\n    const NUM_CLIENTS = 5;\n    const clients: WebSocket[] = [];\n\n    for (let i = 0; i < NUM_CLIENTS; i++) {\n      const ws = await connectWs(port, doc.body.id);\n      await nextMessage(ws); // sync\n      clients.push(ws);\n    }\n\n    // All clients send concurrently, all based on version 0\n    const ackPromises = clients.map((ws, i) =>\n      sendOp(ws, doc.body.id, 0, {\n        type: \"insert\",\n        position: 0,\n        text: String.fromCharCode(65 + i),\n      })\n    );\n\n    await Promise.all(ackPromises);\n    await new Promise((r) => setTimeout(r, 300));\n\n    const res = await request(app.app)\n      .get(`/documents/${doc.body.id}`)\n      .expect(200);\n\n    // All letters should be present\n    for (let i = 0; i < NUM_CLIENTS; i++) {\n      expect(res.body.content).toContain(String.fromCharCode(65 + i));\n    }\n    expect(res.body.content.length).toBe(NUM_CLIENTS);\n\n    for (const ws of clients) ws.close();\n  });\n\n  it(\"should maintain document integrity with interleaved inserts and deletes\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Interleave\", content: \"ABCDE\" });\n\n    const ws1 = await connectWs(port, doc.body.id);\n    aw