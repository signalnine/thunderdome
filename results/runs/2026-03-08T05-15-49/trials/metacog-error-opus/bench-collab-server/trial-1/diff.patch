+import express from "express";
+import { createServer, Server } from "http";
+import { createDatabase, DocumentStore } from "./db.js";
+import { createRouter } from "./routes.js";
+import { CollaborationServer } from "./ws.js";
+
+export interface AppInstance {
+  app: express.Express;
+  start: (port?: number) => Promise<number>;
+  stop: () => Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db = createDatabase(dbPath || ":memory:");
+  const store = new DocumentStore(db);
+
+  const app = express();
+  app.use("/api", createRouter(store));
+
+  // Also mount at root level for convenience
+  app.use(createRouter(store));
+
+  let server: Server | null = null;
+  let collabServer: CollaborationServer | null = null;
+
+  return {
+    app,
+    async start(port?: number): Promise<number> {
+      return new Promise((resolve) => {
+        server = createServer(app);
+        collabServer = new CollaborationServer(server, store);
+
+        server.listen(port ?? 0, () => {
+          const addr = server!.address();
+          const actualPort =
+            typeof addr === "object" && addr !== null ? addr.port : 0;
+          resolve(actualPort);
+        });
+      });
+    },
+    async stop(): Promise<void> {
+      return new Promise((resolve, reject) => {
+        if (collabServer) {
+          collabServer.closeAll();
+          collabServer = null;
+        }
+
+        if (server) {
+          server.close((err) => {
+            db.close();
+            if (err) reject(err);
+            else resolve();
+          });
+          server = null;
+        } else {
+          db.close();
+          resolve();
+        }
+      });
+    },
+  };
+}
