sions`)\n      .expect(200);\n\n    expect(versions.body.length).toBeGreaterThanOrEqual(2);\n\n    await app2.stop();\n  });\n\n  it(\"should persist content changes made via WebSocket\", async () => {\n    const dbPath = \"/tmp/test-persist-ws-\" + Date.now() + \".db\";\n\n    const app1 = createApp(dbPath);\n    const port1 = await app1.start(0);\n\n    const doc = await request(app1.app)\n      .post(\"/documents\")\n      .send({ title: \"WSPersist\", content: \"\" });\n\n    const ws = await connectWs(port1, doc.body.id);\n    await nextMessage(ws); // sync\n\n    await sendOp(ws, doc.body.id, 0, {\n      type: \"insert\", position: 0, text: \"WebSocket content\",\n    });\n\n    await new Promise((r) => setTimeout(r, 100));\n    ws.close();\n    await app1.stop();\n\n    // Restart and verify\n    const app2 = createApp(dbPath);\n    await app2.start(0);\n\n    const res = await request(app2.app)\n      .get(`/documents/${doc.body.id}`)\n      .expect(200);\n\n    expect(res.body.content).toBe(\"WebSocket content\");\n\n    await app2.stop();\n  });\n});\n","numLines":1266,"startLine":1,"totalLines":1266}}}
