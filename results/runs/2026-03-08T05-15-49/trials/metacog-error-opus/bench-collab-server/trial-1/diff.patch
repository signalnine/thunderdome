document string and return the new string.\n */\nexport function applyOperation(content: string, op: Operation): string {\n  if (op.type === \"insert\") {\n    const pos = Math.min(Math.max(0, op.position), content.length);\n    return content.slice(0, pos) + op.text + content.slice(pos);\n  } else {\n    const pos = Math.min(Math.max(0, op.position), content.length);\n    const end = Math.min(pos + op.length, content.length);\n    return content.slice(0, pos) + content.slice(end);\n  }\n}\n\n/**\n * Transform operation `op` against a previously applied operation `applied`.\n * Returns the transformed version of `op` that should be applied after `applied`.\n *\n * This is server-side OT: the server applies operations in order and transforms\n * incoming operations against all operations that have been applied since the\n * client's known version.\n */\nexport function transformOperation(op: Operation, applied: Operation): Operation {\n  if (op.type === \"insert\" && applied.type === \"insert\") {\n    // Both insertions\n    if (op.position <= applied.position) {\n      // op inserts before or at the same position - no change needed\n      return op;\n    } else {\n      // op inserts after applied - shift right by inserted text length\n      return { ...op, position: op.position + applied.text.length };\n    }\n  }\n\n  if (op.type === \"insert\" && applied.type === \"delete\") {\n    if (op.position <= applied.position) {\n      return op;\n    } else if (op.position >= applied.position + applied.length) {\n      return { ...op, position: op.position - applied.length };\n    } else {\n      // Insert was inside the deleted range - move to deletion point\n      return { ...op, position: applied.position };\n    }\n  }\n\n  if (op.type === \"delete\" && applied.type === \"insert\") {\n    if (op.position >= applied.position) {\n      return { ...op, position: op.position + applied.text.length };\n    } else if (op.position + op.length <= applied.position) {\n      return op;\n    } else {\n      // Delete range spans the insertion point\n      // The delete needs to grow to account for inserted text\n      return { ...op, length: op.length + applied.text.length };\n    }\n  }\n\n  if (op.type === \"delete\" && applied.type === \"delete\") {\n    if (op.position >= applied.position + applied.length) {\n      // op is entirely after applied\n      return { ...op, position: op.position - applied.length };\n    } else if (op.position + op.length <= applied.position) {\n      // op is entirely before applied\n      return op;\n    } else {\n      // Overlapping deletes\n      const opEnd = op.position + op.length;\n      const appliedEnd = applied.position + applied.length;\n\n      const newStart = Math.min(op.position, applied.position);\n      const newEnd = Math.max(opEnd, appliedEnd);\n\n      // Calculate the remaining delete length (exclude already-deleted portion)\n      const overlapStart = Math.max(op.position, applied.position);\n      const overlapEnd = Math.min(opEnd, appliedEnd);\n      const overlapLen = Math.max(0, overlapEnd - overlapStart);\n\n      const newLength = op.length - overlapLen;\n      const newPosition = op.position <= applied.position\n        ? op.position\n        : op.position - Math.min(applied.length, op.position - applied.position);\n\n      if (newLength <= 0) {\n        // Entire delete was already handled by the applied operation\n        return { type: \"delete\", position: newPosition, length: 0 };\n      }\n\n      return { type: \"delete\", position: newPosition, length: newLength };\n    }\n  }\n\n  // Should never reach here\n  return op;\n}\n\n/**\n * Transform an operation against a sequence of previously applied operations.\n */\nexport function transformAgainstAll(op: Operation, appliedOps: Operation[]): Operation {\n  let transformed = op;\n  for (const applied of appliedOps) {\n    transformed = transformOperation(transformed, applied);\n  }\n  return transformed;\n}\n\n/**\n * Validate that an operation is well-formed.\n */\nexport function validateOperation(op: unknown): op is Operation {\n  if (!op || typeof op !== \"object\") return false;\n\n  const candidate = op as Record<string, unknown>;\n\n  if (candidate.type === \"insert\") {\n    return (\n      typeof candidate.position === \"number\" &&\n      candidate.position >= 0 &&\n      Number.isInteger(candidate.position) &&\n      typeof candidate.text === \"string\" &&\n      candidate.text.length > 0\n    );\n  }\n\n  if (candidate.type === \"delete\") {\n    return (\n      typeof candidate.position === \"number\" &&\n      candidate.position >= 0 &&\n      Number.isInteger(candidate.position) &&\n      typeof candidate.length === \"number\" &&\n      candidate.length > 0 &&\n      Number.isInteger(candidate.length)\n    );\n  }\n\n  return false;\n}\n","structuredPatch":[{"oldStart":97,"oldLines":9,"newStart":97,"newLines":6,"lines":["       const opEnd = op.position + op.length;","       const appliedEnd = applied.position + applied.length;"," ","-      const newStart = Math.min(op.position, applied.position);","-      const newEnd = Math.max(opEnd, appliedEnd);","-","       // Calculate the remaining delete length (exclude already-deleted portion)","       const overlapStart = Math.max(op.position, applied.position);","       const overlapEnd = Math.min(opEnd, appliedEnd);"]}],"userModified":false,"replaceAll":false}}
