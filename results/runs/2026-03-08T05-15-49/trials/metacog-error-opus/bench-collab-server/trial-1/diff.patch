id, 2, {\n   651→      type: \"insert\", position: 2, text: \"C\",\n   652→    });\n   653→    await b3;\n   654→\n   655→    const b4 = nextMessage(ws1);\n   656→    await sendOp(ws2, doc.body.id, 3, {\n   657→      type: \"insert\", position: 3, text: \"D\",\n   658→    });\n   659→    await b4;\n   660→\n   661→    await new Promise((r) => setTimeout(r, 100));\n   662→\n   663→    const res = await request(app.app)\n   664→      .get(`/documents/${doc.body.id}`)\n   665→      .expect(200);\n   666→\n   667→    expect(res.body.content).toBe(\"ABCD\");\n   668→\n   669→    ws1.close();\n   670→    ws2.close();\n   671→  });\n   672→\n   673→  it(\"should not lose any edits from either client\", async () => {\n   674→    const doc = await request(app.app)\n   675→      .post(\"/documents\")\n   676→      .send({ title: \"NoLoss\", content: \"\" });\n   677→\n   678→    const { ws: ws1 } = await connectWs(port, doc.body.id);\n   679→    const { ws: ws2 } = await connectWs(port, doc.body.id);\n   680→\n   681→    const b1 = nextMessage(ws2);\n   682→    await sendOp(ws1, doc.body.id, 0, {\n   683→      type: \"insert\", position: 0, text: \"Hello\",\n   684→    });\n   685→    await b1;\n   686→\n   687→    const b2 = nextMessage(ws1);\n   688→    await sendOp(ws2, doc.body.id, 1, {\n   689→      type: \"insert\", position: 5, text: \" World\",\n   690→    });\n   691→    await b2;\n   692→\n   693→    await new Promise((r) => setTimeout(r, 100));\n   694→\n   695→    const res = await request(app.app)\n   696→      .get(`/documents/${doc.body.id}`)\n   697→      .expect(200);\n   698→\n   699→    expect(res.body.content).toBe(\"Hello World\");\n   700→\n   701→    ws1.close();\n   702→    ws2.close();\n   703→  });\n   704→\n   705→  it(\"should maintain correct version numbering across clients\", async () => {\n   706→    const doc = await request(app.app)\n   707→      .post(\"/documents\")\n   708→      .send({ title: \"Version Track\", content: \"\" });\n   709→\n   710→    const { ws } = await connectWs(port, doc.body.id);\n   711→\n   712→    const ack1 = await sendOp(ws, doc.body.id, 0, {\n   713→      type: \"insert\", position: 0, text: \"A\",\n   714→    });\n   715→    expect(ack1.version).toBe(1);\n   716→\n   717→    const ack2 = await sendOp(ws, doc.body.id, 1, {\n   718→      type: \"insert\", position: 1, text: \"B\",\n   719→    });\n   720→    expect(ack2.version).toBe(2);\n   721→\n   722→    ws.close();\n   723→  });\n   724→\n   725→  it(\"should transform operations correctly when versions diverge\", async () => {\n   726→    const doc = await request(app.app)\n   727→      .post(\"/documents\")\n   728→      .send({ title: \"Diverge\", content: \"XY\" });\n   729→\n   730→    const { ws: ws1 } = await connectWs(port, doc.body.id);\n   731→    const { ws: ws2 } = await connectWs(port, doc.body.id);\n   732→\n   733→    // ws1 inserts \"A\" at position 0 — doc becomes \"AXY\"\n   734→    const b1 = nextMessage(ws2);\n   735→    await sendOp(ws1, doc.body.id, 0, {\n   736→      type: \"insert\", position: 0, text: \"A\",\n   737→    });\n   738→    await b1;\n   739→\n   740→    // ws2 sends based on version 0, inserting \"B\" at end (position 2)\n   741→    // Server transforms: position 2 -> position 3\n   742→    const b2 = nextMessage(ws1);\n   743→    await sendOp(ws2, doc.body.id, 0, {\n   744→      type: \"insert\", position: 2, text: \"B\",\n   745→    });\n   746→    await b2;\n   747→\n   748→    await new Promise((r) => setTimeout(r, 100));\n   749→\n   750→    const res = await request(app.app)\n   751→      .get(`/documents/${doc.body.id}`)\n   752→      .expect(200);\n   753→\n   754→    expect(res.body.content).toBe(\"AXYB\");\n   755→\n   756→    ws1.close();\n   757→    ws2.close();\n   758→  });\n   759→});\n   760→\n   761→// ─── Stress Test ─────────────────────────────────────────────────────────────\n   762→describe(\"Stress Test\", () => {\n   763→  let app: AppInstance;\n   764→  let port: number;\n   765→\n   766→  beforeEach(async () => {\n   767→    app = createApp();\n   768→    port = await app.start(0);\n   769→  });\n   770→\n   771→  afterEach(async () => {\n   772→    await app.stop();\n   773→  });\n   774→\n   775→  it(\"should handle 10 concurrent clients on the same document\", async () => {\n   776→    const doc = await request(app.app)\n   777→      .post(\"/documents\")\n   778→      .send({ title: \"Stress\", content: \"\" });\n   779→\n   780→    const clients: WebSocket[] = [];\n   781→\n   782→    // Connect 10 clients\n   783→    for (let i = 0; i < 10; i++) {\n   784→      const { ws } = await connectWs(port, doc.body.id);\n   785→      clients.push(ws);\n   786→    }\n   787→\n   788→    // Each client sends one insert sequentially\n   789→    for (let i = 0; i < clients.length; i++) {\n   790→      await sendOp(clients[i], doc.body.id, i, {\n   791→        type: \"insert\",\n   792→        position: i,\n   793→        text: String(i),\n   794→      });\n   795→      await new Promise((r) => setTimeout(r, 50));\n   796→    }\n   797→\n   798→    await new Promise((r) => setTimeout(r, 200));\n   799→\n   800→    const res = await request(app.app)\n   801→      .get(`/documents/${doc.body.id}`)\n   802→      .expect(200);\n   803→\n   804→    for (let i = 0; i < 10; i++) {\n   805→      expect(res.body.content).toContain(String(i));\n   806→    }\n   807→    expect(res.body.content.length).toBe(10);\n   808→\n   809→    for (const ws of clients) ws.close();\n   810→  });\n   811→\n   812→  it(\"should not corrupt document with many rapid operations\", async () => {\n   813→    const doc = await request(app.app)\n   814→      .post(\"/documents\")\n   815→      .send({ title: \"Rapid Stress\", content: \"\" });\n   816→\n   817→    const { ws } = await connectWs(port, doc.body.id);\n   818→\n   819→    for (let i = 0; i < 20; i++) {\n   820→      await sendOp(ws, doc.body.id, i, {\n   821→        type: \"insert\",\n   822→        position: i,\n   823→        text: String.fromCharCode(65 + (i % 26)),\n   824→      });\n   825→    }\n   826→\n   827→    await new Promise((r) => setTimeout(r, 200));\n   828→\n   829→    const res = await request(app.app)\n   830→      .get(`/documents/${doc.body.id}`)\n   831→      .expect(200);\n   832→\n   833→    expect(res.body.content.length).toBe(20);\n   834→\n   835→    ws.close();\n   836→  });\n   837→\n   838→  it(\"should handle multiple clients inserting simultaneously\", async () => {\n   839→    const doc = await request(app.app)\n   840→      .post(\"/documents\")\n   841→      .send({ title: \"Simultaneous\", content: \"\" });\n   842→\n   843→    const NUM_CLIENTS = 5;\n   844→    const clients: WebSocket[] = [];\n   845→\n   846→    for (let i = 0; i < NUM_CLIENTS; i++) {\n   847→      const { ws } = await connectWs(port, doc.body.id);\n   848→      clients.push(ws);\n   849→    }\n   850→\n   851→    // All clients send concurrently, all based on version 0\n   852→    const ackPromises = clients.map((ws, i) =>\n   853→      sendOp(ws, doc.body.id, 0, {\n   854→        type: \"insert\",\n   855→        position: 0,\n   856→        text: String.fromCharCode(65 + i),\n   857→      })\n   858→    );\n   859→\n   860→    await Promise.all(ackPromises);\n   861→    await new Promise((r) => setTimeout(r, 300));\n   862→\n   863→    const res = await request(app.app)\n   864→      .get(`/documents/${doc.body.id}`)\n   865→      .expect(200);\n   866→\n   867→    for (let i = 0; i < NUM_CLIENTS; i++) {\n   868→      expect(res.body.content).toContain(String.fromCharCode(65 + i));\n   869→    }\n   870→    expect(res.body.content.length).toBe(NUM_CLIENTS);\n   871→\n   872→    for (const ws of clients) ws.close();\n   873→  });\n   874→\n   875→  it(\"should maintain document integrity with interleaved inserts and deletes\", async () => {\n   876→    const doc = await request(app.app)\n   877→      .post(\"/documents\")\n   878→      .send({ title: \"Interleave\", content: \"ABCDE\" });\n   879→\n   880→    const { ws: ws1 } = await connectWs(port, doc.body.id);\n   881→    const { ws: ws2 } = await connectWs(port, doc.body.id);\n   882→\n   883→    // ws1 deletes \"C\" (position 2, length 1)\n   884→    const b1 = nextMessage(ws2);\n   885→    await sendOp(ws1, doc.body.id, 0, {\n   886→      type: \"delete\", position: 2, length: 1,\n   887→    });\n   888→    await b1;\n   889→\n   890→    // ws2 inserts \"X\" at position 2 (based on version 1, after delete)\n   891→    const b2 = nextMessage(ws1);\n   892→    await sendOp(ws2, doc.body.id, 1, {\n   893→      type: \"insert\", position: 2, text: \"X\",\n   894→    });\n   895→    await b2;\n   896→\n   897→    await new Promise((r) => setTimeout(r, 100));\n   898→\n   899→    const res = await request(app.app)\n   900→      .get(`/documents/${doc.body.id}`)\n   901→      .expect(200);\n   902→\n   903→    expect(res.body.content).toBe(\"ABXDE\");\n   904→\n   905→    ws1.close();\n   906→    ws2.close();\n   907→  });\n   908→\n   909→  it(\"should handle clients connecting and disconnecting during edits\", async () => {\n   910→    const doc = await request(app.app)\n   911→      .post(\"/documents\")\n   912→      .send({ title: \"ChurnTest\", content: \"\" });\n   913→\n   914→    const { ws: ws1 } = await connectWs(port, doc.body.id);\n   915→\n   916→    await sendOp(ws1, doc.body.id, 0, {\n   917→      type: \"insert\", position: 0, text: \"A\",\n   918→    });\n   919→\n   920→    // New client connects mid-edit\n   921→    const { ws: ws2, sync: sync2 } = await connectWs(port, doc.body.id);\n   922→    expect(sync2.content).toBe(\"A\");\n   923→\n   924→    ws1.close();\n   925→\n   926→    await sendOp(ws2, doc.body.id, 1, {\n   927→      type: \"insert\", position: 1, text: \"B\",\n   928→    });\n   929→\n   930→    await new Promise((r) => setTimeout(r, 100));\n   931→\n   932→    const res = await request(app.app)\n   933→      .get(`/documents/${doc.body.id}`)\n   934→      .expect(200);\n   935→\n   936→    expect(res.body.content).toBe(\"AB\");\n   937→\n   938→    ws2.close();\n   939→  });\n   940→});\n   941→\n   942→// ─── Error Handling ──────────────────────────────────────────────────────────\n   943→describe(\"Error Handling\", () => {\n   944→  let app: AppInstance;\n   945→  let port: number;\n   946→\n   947→  beforeEach(async () => {\n   948→    app = createApp();\n   949→    port = await app.start(0);\n   950→  });\n   951→\n   952→  afterEach(async () => {\n   953→    await app.stop();\n   954→  });\n   955→\n   956→  it(\"should reject invalid JSON messages\", async () => {\n   957→    const doc = await request(app.app)\n   958→      .post(\"/documents\")\n   959→      .send({ title: \"ErrJSON\", content: \"\" });\n   960→\n   961→    const { ws } = await connectWs(port, doc.body.id);\n   962→\n   963→    ws.send(\"not valid json{{{\");\n   964→    const err = await nextMessage(ws);\n   965→    expect(err.type).toBe(\"error\");\n   966→\n   967→    ws.close();\n   968→  });\n   969→\n   970→  it(\"should reject invalid operation format\", async () => {\n   971→    const doc = await request(app.app)\n   972→      .post(\"/documents\")\n   973→      .send({ title: \"ErrOp\", content: \"\" });\n   974→\n   975→    const { ws } = await connectWs(port, doc.body.id);\n   976→\n   977→    ws.send(JSON.stringify({\n   978→      type: \"operation\",\n   979→      version: 0,\n   980→      operation: { type: \"invalid\", position: 0 },\n   981→    }));\n   982→\n   983→    const err = await nextMessage(ws);\n   984→    expect(err.type).toBe(\"error\");\n   985→\n   986→    ws.close();\n   987→  });\n   988→\n   989→  it(\"should reject operation with missing fields\", async () => {\n   990→    const doc = await request(app.app)\n   991→      .post(\"/documents\")\n   992→      .send({ title: \"ErrFields\", content: \"\" });\n   993→\n   994→    const { ws } = await connectWs(port, doc.body.id);\n   995→\n   996→    ws.send(JSON.stringify({\n   997→      type: \"operation\",\n   998→      version: 0,\n   999→      operation: { type: \"insert\" },\n  1000→    }));\n  1001→\n  1002→    const err = await nextMessage(ws);\n  1003→    expect(err.type).toBe(\"error\");\n  1004→\n  1005→    ws.close();\n  1006→  });\n  1007→\n  1008→  it(\"should reject unknown message types\", async () => {\n  1009→    const doc = await request(app.app)\n  1010→      .post(\"/documents\")\n  1011→      .send({ title: \"ErrType\", content: \"\" });\n  1012→\n  1013→    const { ws } = await connectWs(port, doc.body.id);\n  1014→\n  1015→    ws.send(JSON.stringify({ type: \"unknown_type\" }));\n  1016→    const err = await nextMessage(ws);\n  1017→    expect(err.type).toBe(\"error\");\n  1018→\n  1019→    ws.close();\n  1020→  });\n  1021→\n  1022→  it(\"should not crash on malformed operation and continue serving\", async () => {\n  1023→    const doc = await request(app.app)\n  1024→      .post(\"/documents\")\n  1025→      .send({ title: \"NoCrash\", content: \"\" });\n  1026→\n  1027→    const { ws } = await connectWs(port, doc.body.id);\n  1028→\n  1029→    ws.send(JSON.stringify({\n  1030→      type: \"operation\",\n  1031→      version: 0,\n  1032→      operation: null,\n  1033→    }));\n  1034→\n  1035→    const err = await nextMessage(ws);\n  1036→    expect(err.type).toBe(\"error\");\n  1037→\n  1038→    // Should still accept valid operations after error\n  1039→    const ack = await sendOp(ws, doc.body.id, 0, {\n  1040→      type: \"insert\", position: 0, text: \"OK\",\n  1041→    });\n  1042→    expect(ack.type).toBe(\"ack\");\n  1043→\n  1044→    ws.close();\n  1045→  });\n  1046→});\n  1047→\n  1048→// ─── Persistence ─────────────────────────────────────────────────────────────\n  1049→describe(\"Persistence\", () => {\n  1050→  it(\"should persist documents across server restarts\", async () => {\n  1051→    const dbPath = \"/tmp/test-persist-\" + Date.now() + \".db\";\n  1052→\n  1053→    const app1 = createApp(dbPath);\n  1054→    await app1.start(0);\n  1055→\n  1056→    const doc = await request(app1.app)\n  1057→      .post(\"/documents\")\n  1058→      .send({ title: \"Persist\", content: \"saved data\" });\n  1059→\n  1060→    const docId = doc.body.id;\n  1061→    await app1.stop();\n  1062→\n  1063→    const app2 = createApp(dbPath);\n  1064→    await app2.start(0);\n  1065→\n  1066→    const res = await request(app2.app)\n  1067→      .get(`/documents/${docId}`)\n  1068→      .expect(200);\n  1069→\n  1070→    expect(res.body.title).toBe(\"Persist\");\n  1071→    expect(res.body.content).toBe(\"saved data\");\n  1072→\n  1073→    await app2.stop();\n  1074→  });\n  1075→\n  1076→  it(\"should persist version history across restarts\", async () => {\n  1077→    const dbPath = \"/tmp/test-persist-versions-\" + Date.now() + \".db\";\n  1078→\n  1079→    const app1 = createApp(dbPath);\n  1080→    const port1 = await app1.start(0);\n  1081→\n  1082→    const doc = await request(app1.app)\n  1083→      .post(\"/documents\")\n  1084→      .send({ title: \"PersistVersions\", content: \"v0\" });\n  1085→\n  1086→    const { ws } = await connectWs(port1, doc.body.id);\n  1087→\n  1088→    await sendOp(ws, doc.body.id, 0, {\n  1089→      type: \"insert\", position: 2, text: \" edit\",\n  1090→    });\n  1091→\n  1092→    await new Promise((r) => setTimeout(r, 100));\n  1093→    ws.close();\n  1094→    await app1.stop();\n  1095→\n  1096→    const app2 = createApp(dbPath);\n  1097→    await app2.start(0);\n  1098→\n  1099→    const versions = await request(app2.app)\n  1100→      .get(`/documents/${doc.body.id}/versions`)\n  1101→      .expect(200);\n  1102→\n  1103→    expect(versions.body.length).toBeGreaterThanOrEqual(2);\n  1104→\n  1105→    await app2.stop();\n  1106→  });\n  1107→\n  1108→  it(\"should persist content changes made via WebSocket\", async () => {\n  1109→    const dbPath = \"/tmp/test-persist-ws-\" + Date.now() + \".db\";\n  1110→\n  1111→    const app1 = createApp(dbPath);\n  1112→    const port1 = await app1.start(0);\n  1113→\n  1114→    const doc = await request(app1.app)\n  1115→      .post(\"/documents\")\n  1116→      .send({ title: \"WSPersist\", content: \"\" });\n  1117→\n  1118→    const { ws } = await connectWs(port1, doc.body.id);\n  1119→\n  1120→    await sendOp(ws, doc.body.id, 0, {\n  1121→      type: \"insert\", position: 0, text: \"WebSocket content\",\n  1122→    });\n  1123→\n  1124→    await new Promise((r) => setTimeout(r, 100));\n  1125→    ws.close();\n  1126→    await app1.stop();\n  1127→\n  1128→    const app2 = createApp(dbPath);\n  1129→    await app2.start(0);\n  1130→\n  1131→    const res = await request(app2.app)\n  1132→      .get(`/documents/${doc.body.id}`)\n  1133→      .expect(200);\n  1134→\n  1135→    expect(res.body.content).toBe(\"WebSocket content\");\n  1136→\n  1137→    await app2.stop();\n  1138→  });\n  1139→});\n  1140→"}]},"parent_tool_use_id":null,"session_id":"2a8ce476-0495-481b-a577-fb7eedf6a3c7","uuid":"9a94db74-d026-4e96-96ac-e7c119837943","tool_use_result":{"type":"update","filePath":"/workspace/src/server.test.ts","content":"import { describe, it, expect, beforeEach, afterEach } from \"vitest\";\nimport request from \"supertest\";\nimport WebSocket from \"ws\";\nimport { createApp, AppInstance } from \"./server.js\";\n\n// Helper to create a WS client connected to a document.\n// Returns the WS and the initial sync message together to avoid race conditions.\nfunction connectWs(\n  port: number,\n  docId: string\n): Promise<{ ws: WebSocket; sync: Record<string, unknown> }> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/${docId}`);\n    const timeout = setTimeout(() => reject(new Error(\"Connection timeout\")), 5000);\n    ws.on(\"message\", function handler(data) {\n      clearTimeout(timeout);\n      ws.off(\"message\", handler);\n      resolve({ ws, sync: JSON.parse(data.toString()) });\n    });\n    ws.on(\"error\", (err) => {\n      clearTimeout(timeout);\n      reject(err);\n    });\n  });\n}\n\n// Helper to wait for next WS message\nfunction nextMessage(ws: WebSocket): Promise<Record<string, unknown>> {\n  return new Promise((resolve, reject) => {\n    const timeout = setTimeout(() => reject(new Error(\"Message timeout\")), 5000);\n    ws.once(\"message\", (data) => {\n      clearTimeout(timeout);\n      resolve(JSON.parse(data.toString()));\n    });\n  });\n}\n\n// Helper: send an operation and wait for ack\nasync function sendOp(\n  ws: WebSocket,\n  docId: string,\n  version: number,\n  operation: Record<string, unknown>\n): Promise<Record<string, unknown>> {\n  const promise = nextMessage(ws);\n  ws.send(\n    JSON.stringify({ type: \"operation\", docId, version, operation })\n  );\n  return promise;\n}\n\n// Helper to wait for first message on a raw WS (for error/close scenarios)\nfunction connectRawAndWaitMessage(\n  port: number,\n  path: string\n): Promise<{ ws: WebSocket; msg: Record<string, unknown> }> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}${path}`);\n    const timeout = setTimeout(() => reject(new Error(\"Connection timeout\")), 5000);\n    ws.on(\"message\", function handler(data) {\n      clearTimeout(timeout);\n      ws.off(\"message\", handler);\n      resolve({ ws, msg: JSON.parse(data.toString()) });\n    });\n    ws.on(\"error\", (err) => {\n      clearTimeout(timeout);\n      reject(err);\n    });\n  });\n}\n\n// ─── REST CRUD ────────────────────────────────────────────────────────────────\ndescribe(\"REST CRUD\", () => {\n  let app: AppInstance;\n\n  beforeEach(async () => {\n    app = createApp();\n    await app.start(0);\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it(\"should create a document\", async () => {\n    const res = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Test Doc\", content: \"Hello\" })\n      .expect(201);\n\n    expect(res.body.id).toBeDefined();\n    expect(res.body.title).toBe(\"Test Doc\");\n    expect(res.body.content).toBe(\"Hello\");\n  });\n\n  it(\"should create a document with empty content by default\", async () => {\n    const res = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Empty Doc\" })\n      .expect(201);\n\n    expect(res.body.content).toBe(\"\");\n  });\n\n  it(\"should reject creating a document without title\", async () => {\n    await request(app.app)\n      .post(\"/documents\")\n      .send({ content: \"No title\" })\n      .expect(400);\n  });\n\n  it(\"should get a document by id\", async () => {\n    const create = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Get Me\" });\n\n    const res = await request(app.app)\n      .get(`/documents/${create.body.id}`)\n      .expect(200);\n\n    expect(res.body.title).toBe(\"Get Me\");\n  });\n\n  it(\"should return 404 for non-existent document\", async () => {\n    await request(app.app)\n      .get(\"/documents/nonexistent-id\")\n      .expect(404);\n  });\n\n  it(\"should list all documents\", async () => {\n    await request(app.app).post(\"/documents\").send({ title: \"Doc 1\" });\n    await request(app.app).post(\"/documents\").send({ title: \"Doc 2\" });\n\n    const res = await request(app.app).get(\"/documents\").expect(200);\n    expect(res.body.length).toBeGreaterThanOrEqual(2);\n  });\n\n  it(\"should update a document title\", async () => {\n    const create = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Old Title\" });\n\n    const res = await request(app.app)\n      .put(`/documents/${create.body.id}`)\n      .send({ title: \"New Title\" })\n      .expect(200);\n\n    expect(res.body.title).toBe(\"New Title\");\n  });\n\n  it(\"should update a document content via PUT\", async () => {\n    const create = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Doc\", content: \"old\" });\n\n    const res = await request(app.app)\n      .put(`/documents/${create.body.id}`)\n      .send({ content: \"new content\" })\n      .expect(200);\n\n    expect(res.body.content).toBe(\"new content\");\n  });\n\n  it(\"should delete a document\", async () => {\n    const create = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Delete Me\" });\n\n    await request(app.app)\n      .delete(`/documents/${create.body.id}`)\n      .expect(204);\n\n    await request(app.app)\n      .get(`/documents/${create.body.id}`)\n      .expect(404);\n  });\n\n  it(\"should return 404 when deleting non-existent document\", async () => {\n    await request(app.app)\n      .delete(\"/documents/nonexistent-id\")\n      .expect(404);\n  });\n\n  it(\"should get version history for a document\", async () => {\n    const create = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Versioned\", content: \"initial\" });\n\n    const res = await request(app.app)\n      .get(`/documents/${create.body.id}/versions`)\n      .expect(200);\n\n    expect(res.body.length).toBeGreaterThanOrEqual(1);\n    expect(res.body[0].version).toBe(0);\n    expect(res.body[0].content).toBe(\"initial\");\n  });\n\n  it(\"should get a specific version\", async () => {\n    const create = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Versioned\", content: \"v0\" });\n\n    const res = await request(app.app)\n      .get(`/documents/${create.body.id}/versions/0`)\n      .expect(200);\n\n    expect(res.body.version).toBe(0);\n    expect(res.body.content).toBe(\"v0\");\n  });\n});\n\n// ─── WebSocket Lifecycle ──────────────────────────────────────────────────────\ndescribe(\"WebSocket Lifecycle\", () => {\n  let app: AppInstance;\n  let port: number;\n\n  beforeEach(async () => {\n    app = createApp();\n    port = await app.start(0);\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it(\"should connect to a document via WebSocket\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"WS Doc\", content: \"hello\" });\n\n    const { ws, sync } = await connectWs(port, doc.body.id);\n\n    expect(sync.type).toBe(\"sync\");\n    expect(sync.content).toBe(\"hello\");\n    expect(sync.version).toBe(0);\n\n    ws.close();\n  });\n\n  it(\"should receive sync with current content and version\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Sync Doc\", content: \"content here\" });\n\n    const { ws, sync } = await connectWs(port, doc.body.id);\n\n    expect(sync.type).toBe(\"sync\");\n    expect(sync.content).toBe(\"content here\");\n    expect(typeof sync.version).toBe(\"number\");\n\n    ws.close();\n  });\n\n  it(\"should reject connection to non-existent document\", async () => {\n    const { ws, msg } = await connectRawAndWaitMessage(port, \"/ws/nonexistent-doc\");\n    expect(msg.type).toBe(\"error\");\n    ws.close();\n  });\n\n  it(\"should reject connection with invalid URL\", async () => {\n    const { ws, msg } = await connectRawAndWaitMessage(port, \"/invalid-path\");\n    expect(msg.type).toBe(\"error\");\n    ws.close();\n  });\n\n  it(\"should handle multiple clients connecting to same document\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Multi\", content: \"shared\" });\n\n    const { ws: ws1, sync: sync1 } = await connectWs(port, doc.body.id);\n    const { ws: ws2, sync: sync2 } = await connectWs(port, doc.body.id);\n\n    expect(sync1.type).toBe(\"sync\");\n    expect(sync2.type).toBe(\"sync\");\n    expect(sync1.content).toBe(\"shared\");\n    expect(sync2.content).toBe(\"shared\");\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should handle client disconnect gracefully\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Disconnect\", content: \"\" });\n\n    const { ws: ws1 } = await connectWs(port, doc.body.id);\n    ws1.close();\n\n    // Wait for close to propagate\n    await new Promise((r) => setTimeout(r, 50));\n\n    // Server should still work after client disconnects\n    const { ws: ws2, sync } = await connectWs(port, doc.body.id);\n    expect(sync.type).toBe(\"sync\");\n    ws2.close();\n  });\n\n  it(\"should handle connecting to different documents\", async () => {\n    const doc1 = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Doc A\", content: \"aaa\" });\n    const doc2 = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Doc B\", content: \"bbb\" });\n\n    const { ws: ws1, sync: sync1 } = await connectWs(port, doc1.body.id);\n    const { ws: ws2, sync: sync2 } = await connectWs(port, doc2.body.id);\n\n    expect(sync1.content).toBe(\"aaa\");\n    expect(sync2.content).toBe(\"bbb\");\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should include docId in sync message\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"ID Check\", content: \"\" });\n\n    const { ws, sync } = await connectWs(port, doc.body.id);\n\n    expect(sync.docId).toBe(doc.body.id);\n    ws.close();\n  });\n});\n\n// ─── Single Client Editing ────────────────────────────────────────────────────\ndescribe(\"Single Client Editing\", () => {\n  let app: AppInstance;\n  let port: number;\n\n  beforeEach(async () => {\n    app = createApp();\n    port = await app.start(0);\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it(\"should apply an insert operation\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Edit\", content: \"\" });\n\n    const { ws } = await connectWs(port, doc.body.id);\n\n    const ack = await sendOp(ws, doc.body.id, 0, {\n      type: \"insert\",\n      position: 0,\n      text: \"Hello\",\n    });\n\n    expect(ack.type).toBe(\"ack\");\n    expect(ack.version).toBe(1);\n\n    const res = await request(app.app)\n      .get(`/documents/${doc.body.id}`)\n      .expect(200);\n    expect(res.body.content).toBe(\"Hello\");\n\n    ws.close();\n  });\n\n  it(\"should apply a delete operation\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Delete\", content: \"Hello World\" });\n\n    const { ws } = await connectWs(port, doc.body.id);\n\n    const ack = await sendOp(ws, doc.body.id, 0, {\n      type: \"delete\",\n      position: 5,\n      length: 6,\n    });\n\n    expect(ack.type).toBe(\"ack\");\n\n    const res = await request(app.app)\n      .get(`/documents/${doc.body.id}`)\n      .expect(200);\n    expect(res.body.content).toBe(\"Hello\");\n\n    ws.close();\n  });\n\n  it(\"should apply multiple sequential operations\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Sequential\", content: \"\" });\n\n    const { ws } = await connectWs(port, doc.body.id);\n\n    await sendOp(ws, doc.body.id, 0, {\n      type: \"insert\", position: 0, text: \"Hello\",\n    });\n\n    await sendOp(ws, doc.body.id, 1, {\n      type: \"insert\", position: 5, text: \" World\",\n    });\n\n    const res = await request(app.app)\n      .get(`/documents/${doc.body.id}`)\n      .expect(200);\n    expect(res.body.content).toBe(\"Hello World\");\n\n    ws.close();\n  });\n\n  it(\"should record versions for each operation\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Versions\", content: \"\" });\n\n    const { ws } = await connectWs(port, doc.body.id);\n\n    await sendOp(ws, doc.body.id, 0, {\n      type: \"insert\", position: 0, text: \"A\",\n    });\n\n    await sendOp(ws, doc.body.id, 1, {\n      type: \"insert\", position: 1, text: \"B\",\n    });\n\n    const versions = await request(app.app)\n      .get(`/documents/${doc.body.id}/versions`)\n      .expect(200);\n\n    expect(versions.body.length).toBeGreaterThanOrEqual(3);\n\n    ws.close();\n  });\n\n  it(\"should insert at specific positions\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Position\", content: \"AC\" });\n\n    const { ws } = await connectWs(port, doc.body.id);\n\n    await sendOp(ws, doc.body.id, 0, {\n      type: \"insert\", position: 1, text: \"B\",\n    });\n\n    const res = await request(app.app)\n      .get(`/documents/${doc.body.id}`)\n      .expect(200);\n    expect(res.body.content).toBe(\"ABC\");\n\n    ws.close();\n  });\n\n  it(\"should handle insert at end of document\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"End Insert\", content: \"Hello\" });\n\n    const { ws } = await connectWs(port, doc.body.id);\n\n    await sendOp(ws, doc.body.id, 0, {\n      type: \"insert\", position: 5, text: \"!\",\n    });\n\n    const res = await request(app.app)\n      .get(`/documents/${doc.body.id}`)\n      .expect(200);\n    expect(res.body.content).toBe(\"Hello!\");\n\n    ws.close();\n  });\n});\n\n// ─── Two-Client Convergence ──────────────────────────────────────────────────\ndescribe(\"Two-Client Convergence\", () => {\n  let app: AppInstance;\n  let port: number;\n\n  beforeEach(async () => {\n    app = createApp();\n    port = await app.start(0);\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it(\"should broadcast operations to other clients\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Broadcast\", content: \"\" });\n\n    const { ws: ws1 } = await connectWs(port, doc.body.id);\n    const { ws: ws2 } = await connectWs(port, doc.body.id);\n\n    // Set up listener for ws2 before sending from ws1\n    const ws2Promise = nextMessage(ws2);\n\n    await sendOp(ws1, doc.body.id, 0, {\n      type: \"insert\", position: 0, text: \"Hello\",\n    });\n\n    const broadcast = await ws2Promise;\n    expect(broadcast.type).toBe(\"operation\");\n    expect(broadcast.version).toBe(1);\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should converge with concurrent inserts at different positions\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Converge\", content: \"Hello World\" });\n\n    const { ws: ws1 } = await connectWs(port, doc.body.id);\n    const { ws: ws2 } = await connectWs(port, doc.body.id);\n\n    const ws2Broadcast = nextMessage(ws2);\n    const ws1Broadcast = nextMessage(ws1);\n\n    // ws1 inserts at position 0\n    await sendOp(ws1, doc.body.id, 0, {\n      type: \"insert\", position: 0, text: \"A\",\n    });\n\n    await ws2Broadcast;\n\n    // ws2 inserts at position 11 (end), based on version 0\n    await sendOp(ws2, doc.body.id, 0, {\n      type: \"insert\", position: 11, text: \"B\",\n    });\n\n    await ws1Broadcast;\n    await new Promise((r) => setTimeout(r, 100));\n\n    const res = await request(app.app)\n      .get(`/documents/${doc.body.id}`)\n      .expect(200);\n\n    expect(res.body.content).toContain(\"A\");\n    expect(res.body.content).toContain(\"B\");\n    expect(res.body.content).toContain(\"Hello World\");\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should converge with concurrent inserts at the same position\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Same Pos\", content: \"\" });\n\n    const { ws: ws1 } = await connectWs(port, doc.body.id);\n    const { ws: ws2 } = await connectWs(port, doc.body.id);\n\n    const ws2Broadcast = nextMessage(ws2);\n\n    await sendOp(ws1, doc.body.id, 0, {\n      type: \"insert\", position: 0, text: \"A\",\n    });\n\n    await ws2Broadcast;\n\n    const ws1Broadcast = nextMessage(ws1);\n    await sendOp(ws2, doc.body.id, 0, {\n      type: \"insert\", position: 0, text: \"B\",\n    });\n\n    await ws1Broadcast;\n    await new Promise((r) => setTimeout(r, 100));\n\n    const res = await request(app.app)\n      .get(`/documents/${doc.body.id}`)\n      .expect(200);\n\n    expect(res.body.content).toContain(\"A\");\n    expect(res.body.content).toContain(\"B\");\n    expect(res.body.content.length).toBe(2);\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should converge with concurrent insert and delete\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"InsertDelete\", content: \"Hello\" });\n\n    const { ws: ws1 } = await connectWs(port, doc.body.id);\n    const { ws: ws2 } = await connectWs(port, doc.body.id);\n\n    const ws2Broadcast = nextMessage(ws2);\n\n    // ws1 inserts at beginning\n    await sendOp(ws1, doc.body.id, 0, {\n      type: \"insert\", position: 0, text: \"X\",\n    });\n\n    await ws2Broadcast;\n\n    const ws1Broadcast = nextMessage(ws1);\n\n    // ws2 deletes last character, based on version 0\n    await sendOp(ws2, doc.body.id, 0, {\n      type: \"delete\", position: 4, length: 1,\n    });\n\n    await ws1Broadcast;\n    await new Promise((r) => setTimeout(r, 100));\n\n    const res = await request(app.app)\n      .get(`/documents/${doc.body.id}`)\n      .expect(200);\n\n    expect(res.body.content).toContain(\"X\");\n    expect(res.body.content).toContain(\"Hell\");\n    expect(res.body.content).toBe(\"XHell\");\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should handle rapid sequential edits from two clients\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Rapid\", content: \"\" });\n\n    const { ws: ws1 } = await connectWs(port, doc.body.id);\n    const { ws: ws2 } = await connectWs(port, doc.body.id);\n\n    // ws1 types \"AB\"\n    const b1 = nextMessage(ws2);\n    await sendOp(ws1, doc.body.id, 0, {\n      type: \"insert\", position: 0, text: \"A\",\n    });\n    await b1;\n\n    const b2 = nextMessage(ws2);\n    await sendOp(ws1, doc.body.id, 1, {\n      type: \"insert\", position: 1, text: \"B\",\n    });\n    await b2;\n\n    // ws2 types \"CD\" at end\n    const b3 = nextMessage(ws1);\n    await sendOp(ws2, doc.body.id, 2, {\n      type: \"insert\", position: 2, text: \"C\",\n    });\n    await b3;\n\n    const b4 = nextMessage(ws1);\n    await sendOp(ws2, doc.body.id, 3, {\n      type: \"insert\", position: 3, text: \"D\",\n    });\n    await b4;\n\n    await new Promise((r) => setTimeout(r, 100));\n\n    const res = await request(app.app)\n      .get(`/documents/${doc.body.id}`)\n      .expect(200);\n\n    expect(res.body.content).toBe(\"ABCD\");\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should not lose any edits from either client\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"NoLoss\", content: \"\" });\n\n    const { ws: ws1 } = await connectWs(port, doc.body.id);\n    const { ws: ws2 } = await connectWs(port, doc.body.id);\n\n    const b1 = nextMessage(ws2);\n    await sendOp(ws1, doc.body.id, 0, {\n      type: \"insert\", position: 0, text: \"Hello\",\n    });\n    await b1;\n\n    const b2 = nextMessage(ws1);\n    await sendOp(ws2, doc.body.id, 1, {\n      type: \"insert\", position: 5, text: \" World\",\n    });\n    await b2;\n\n    await new Promise((r) => setTimeout(r, 100));\n\n    const res = await request(app.app)\n      .get(`/documents/${doc.body.id}`)\n      .expect(200);\n\n    expect(res.body.content).toBe(\"Hello World\");\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should maintain correct version numbering across clients\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Version Track\", content: \"\" });\n\n    const { ws } = await connectWs(port, doc.body.id);\n\n    const ack1 = await sendOp(ws, doc.body.id, 0, {\n      type: \"insert\", position: 0, text: \"A\",\n    });\n    expect(ack1.version).toBe(1);\n\n    const ack2 = await sendOp(ws, doc.body.id, 1, {\n      type: \"insert\", position: 1, text: \"B\",\n    });\n    expect(ack2.version).toBe(2);\n\n    ws.close();\n  });\n\n  it(\"should transform operations correctly when versions diverge\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Diverge\", content: \"XY\" });\n\n    const { ws: ws1 } = await connectWs(port, doc.body.id);\n    const { ws: ws2 } = await connectWs(port, doc.body.id);\n\n    // ws1 inserts \"A\" at position 0 — doc becomes \"AXY\"\n    const b1 = nextMessage(ws2);\n    await sendOp(ws1, doc.body.id, 0, {\n      type: \"insert\", position: 0, text: \"A\",\n    });\n    await b1;\n\n    // ws2 sends based on version 0, inserting \"B\" at end (position 2)\n    // Server transforms: position 2 -> position 3\n    const b2 = nextMessage(ws1);\n    await sendOp(ws2, doc.body.id, 0, {\n      type: \"insert\", position: 2, text: \"B\",\n    });\n    await b2;\n\n    await new Promise((r) => setTimeout(r, 100));\n\n    const res = await request(app.app)\n      .get(`/documents/${doc.body.id}`)\n      .expect(200);\n\n    expect(res.body.content).toBe(\"AXYB\");\n\n    ws1.close();\n    ws2.close();\n  });\n});\n\n// ─── Stress Test ─────────────────────────────────────────────────────────────\ndescribe(\"Stress Test\", () => {\n  let app: AppInstance;\n  let port: number;\n\n  beforeEach(async () => {\n    app = createApp();\n    port = await app.start(0);\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it(\"should handle 10 concurrent clients on the same document\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Stress\", content: \"\" });\n\n    const clients: WebSocket[] = [];\n\n    // Connect 10 clients\n    for (let i = 0; i < 10; i++) {\n      const { ws } = await connectWs(port, doc.body.id);\n      clients.push(ws);\n    }\n\n    // Each client sends one insert sequentially\n    for (let i = 0; i < clients.length; i++) {\n      await sendOp(clients[i], doc.body.id, i, {\n        type: \"insert\",\n        position: i,\n        text: String(i),\n      });\n      await new Promise((r) => setTimeout(r, 50));\n    }\n\n    await new Promise((r) => setTimeout(r, 200));\n\n    const res = await request(app.app)\n      .get(`/documents/${doc.body.id}`)\n      .expect(200);\n\n    for (let i = 0; i < 10; i++) {\n      expect(res.body.content).toContain(String(i));\n    }\n    expect(res.body.content.length).toBe(10);\n\n    for (const ws of clients) ws.close();\n  });\n\n  it(\"should not corrupt document with many rapid operations\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Rapid Stress\", content: \"\" });\n\n    const { ws } = await connectWs(port, doc.body.id);\n\n    for (let i = 0; i < 20; i++) {\n      await sendOp(ws, doc.body.id, i, {\n        type: \"insert\",\n        position: i,\n        text: String.fromCharCode(65 + (i % 26)),\n      });\n    }\n\n    await new Promise((r) => setTimeout(r, 200));\n\n    const res = await request(app.app)\n      .get(`/documents/${doc.body.id}`)\n      .expect(200);\n\n    expect(res.body.content.length).toBe(20);\n\n    ws.close();\n  });\n\n  it(\"should handle multiple clients inserting simultaneously\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Simultaneous\", content: \"\" });\n\n    const NUM_CLIENTS = 5;\n    const clients: WebSocket[] = [];\n\n    for (let i = 0; i < NUM_CLIENTS; i++) {\n      const { ws } = await connectWs(port, doc.body.id);\n      clients.push(ws);\n    }\n\n    // All clients send concurrently, all based on version 0\n    const ackPromises = clients.map((ws, i) =>\n      sendOp(ws, doc.body.id, 0, {\n        type: \"insert\",\n        position: 0,\n        text: String.fromCharCode(65 + i),\n      })\n    );\n\n    await Promise.all(ackPromises);\n    await new Promise((r) => setTimeout(r, 300));\n\n    const res = await request(app.app)\n      .get(`/documents/${doc.body.id}`)\n      .expect(200);\n\n    for (let i = 0; i < NUM_CLIENTS; i++) {\n      expect(res.body.content).toContain(String.fromCharCode(65 + i));\n    }\n    expect(res.body.content.length).toBe(NUM_CLIENTS);\n\n    for (const ws of clients) ws.close();\n  });\n\n  it(\"should maintain document integrity with interleaved inserts and deletes\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Interleave\", content: \"ABCDE\" });\n\n    const { ws: ws1 } = await connectWs(port, doc.body.id);\n    const { ws: ws2 } = await connectWs(port, doc.body.id);\n\n    // ws1 deletes \"C\" (position 2, length 1)\n    const b1 = nextMessage(ws2);\n    await sendOp(ws1, doc.body.id, 0, {\n      type: \"delete\", position: 2, length: 1,\n    });\n    await b1;\n\n    // ws2 inserts \"X\" at position 2 (based on version 1, after delete)\n    const b2 = nextMessage(ws1);\n    await sendOp(ws2, doc.body.id, 1, {\n      type: \"insert\", position: 2, text: \"X\",\n    });\n    await b2;\n\n    await new Promise((r) => setTimeout(r, 100));\n\n    const res = await request(app.app)\n      .get(`/documents/${doc.body.id}`)\n      .expect(200);\n\n    expect(res.body.content).toBe(\"ABXDE\");\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should handle clients connecting and disconnecting during edits\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"ChurnTest\", content: \"\" });\n\n    const { ws: ws1 } = await connectWs(port, doc.body.id);\n\n    await sendOp(ws1, doc.body.id, 0, {\n      type: \"insert\", position: 0, text: 