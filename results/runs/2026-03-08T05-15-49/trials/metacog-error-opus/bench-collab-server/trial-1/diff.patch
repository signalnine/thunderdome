y.id, 1, {\n   426→      type: \"insert\", position: 1, text: \"B\",\n   427→    });\n   428→\n   429→    const versions = await request(app.app)\n   430→      .get(`/documents/${doc.body.id}/versions`)\n   431→      .expect(200);\n   432→\n   433→    expect(versions.body.length).toBeGreaterThanOrEqual(3);\n   434→\n   435→    ws.close();\n   436→  });\n   437→\n   438→  it(\"should insert at specific positions\", async () => {\n   439→    const doc = await request(app.app)\n   440→      .post(\"/documents\")\n   441→      .send({ title: \"Position\", content: \"AC\" });\n   442→\n   443→    const { ws } = await connectWs(port, doc.body.id);\n   444→\n   445→    await sendOp(ws, doc.body.id, 0, {\n   446→      type: \"insert\", position: 1, text: \"B\",\n   447→    });\n   448→\n   449→    const res = await request(app.app)\n   450→      .get(`/documents/${doc.body.id}`)\n   451→      .expect(200);\n   452→    expect(res.body.content).toBe(\"ABC\");\n   453→\n   454→    ws.close();\n   455→  });\n   456→\n   457→  it(\"should handle insert at end of document\", async () => {\n   458→    const doc = await request(app.app)\n   459→      .post(\"/documents\")\n   460→      .send({ title: \"End Insert\", content: \"Hello\" });\n   461→\n   462→    const { ws } = await connectWs(port, doc.body.id);\n   463→\n   464→    await sendOp(ws, doc.body.id, 0, {\n   465→      type: \"insert\", position: 5, text: \"!\",\n   466→    });\n   467→\n   468→    const res = await request(app.app)\n   469→      .get(`/documents/${doc.body.id}`)\n   470→      .expect(200);\n   471→    expect(res.body.content).toBe(\"Hello!\");\n   472→\n   473→    ws.close();\n   474→  });\n   475→});\n   476→\n   477→// ─── Two-Client Convergence ──────────────────────────────────────────────────\n   478→describe(\"Two-Client Convergence\", () => {\n   479→  let app: AppInstance;\n   480→  let port: number;\n   481→\n   482→  beforeEach(async () => {\n   483→    app = createApp();\n   484→    port = await app.start(0);\n   485→  });\n   486→\n   487→  afterEach(async () => {\n   488→    await app.stop();\n   489→  });\n   490→\n   491→  it(\"should broadcast operations to other clients\", async () => {\n   492→    const doc = await request(app.app)\n   493→      .post(\"/documents\")\n   494→      .send({ title: \"Broadcast\", content: \"\" });\n   495→\n   496→    const { ws: ws1 } = await connectWs(port, doc.body.id);\n   497→    const { ws: ws2 } = await connectWs(port, doc.body.id);\n   498→\n   499→    // Set up listener for ws2 before sending from ws1\n   500→    const ws2Promise = nextMessage(ws2);\n   501→\n   502→    await sendOp(ws1, doc.body.id, 0, {\n   503→      type: \"insert\", position: 0, text: \"Hello\",\n   504→    });\n   505→\n   506→    const broadcast = await ws2Promise;\n   507→    expect(broadcast.type).toBe(\"operation\");\n   508→    expect(broadcast.version).toBe(1);\n   509→\n   510→    ws1.close();\n   511→    ws2.close();\n   512→  });\n   513→\n   514→  it(\"should converge with concurrent inserts at different positions\", async () => {\n   515→    const doc = await request(app.app)\n   516→      .post(\"/documents\")\n   517→      .send({ title: \"Converge\", content: \"Hello World\" });\n   518→\n   519→    const { ws: ws1 } = await connectWs(port, doc.body.id);\n   520→    const { ws: ws2 } = await connectWs(port, doc.body.id);\n   521→\n   522→    const ws2Broadcast = nextMessage(ws2);\n   523→    const ws1Broadcast = nextMessage(ws1);\n   524→\n   525→    // ws1 inserts at position 0\n   526→    await sendOp(ws1, doc.body.id, 0, {\n   527→      type: \"insert\", position: 0, text: \"A\",\n   528→    });\n   529→\n   530→    await ws2Broadcast;\n   531→\n   532→    // ws2 inserts at position 11 (end), based on version 0\n   533→    await sendOp(ws2, doc.body.id, 0, {\n   534→      type: \"insert\", position: 11, text: \"B\",\n   535→    });\n   536→\n   537→    await ws1Broadcast;\n   538→    await new Promise((r) => setTimeout(r, 100));\n   539→\n   540→    const res = await request(app.app)\n   541→      .get(`/documents/${doc.body.id}`)\n   542→      .expect(200);\n   543→\n   544→    expect(res.body.content).toContain(\"A\");\n   545→    expect(res.body.content).toContain(\"B\");\n   546→    expect(res.body.content).toContain(\"Hello World\");\n   547→\n   548→    ws1.close();\n   549→    ws2.close();\n   550→  });\n   551→\n   552→  it(\"should converge with concurrent inserts at the same position\", async () => {\n   553→    const doc = await request(app.app)\n   554→      .post(\"/documents\")\n   555→      .send({ title: \"Same Pos\", content: \"\" });\n   556→\n   557→    const { ws: ws1 } = await connectWs(port, doc.body.id);\n   558→    const { ws: ws2 } = await connectWs(port, doc.body.id);\n   559→\n   560→    const ws2Broadcast = nextMessage(ws2);\n   561→\n   562→    await sendOp(ws1, doc.body.id, 0, {\n   563→      type: \"insert\", position: 0, text: \"A\",\n   564→    });\n   565→\n   566→    await ws2Broadcast;\n   567→\n   568→    const ws1Broadcast = nextMessage(ws1);\n   569→    await sendOp(ws2, doc.body.id, 0, {\n   570→      type: \"insert\", position: 0, text: \"B\",\n   571→    });\n   572→\n   573→    await ws1Broadcast;\n   574→    await new Promise((r) => setTimeout(r, 100));\n   575→\n   576→    const res = await request(app.app)\n   577→      .get(`/documents/${doc.body.id}`)\n   578→      .expect(200);\n   579→\n   580→    expect(res.body.content).toContain(\"A\");\n   581→    expect(res.body.content).toContain(\"B\");\n   582→    expect(res.body.content.length).toBe(2);\n   583→\n   584→    ws1.close();\n   585→    ws2.close();\n   586→  });\n   587→\n   588→  it(\"should converge with concurrent insert and delete\", async () => {\n   589→    const doc = await request(app.app)\n   590→      .post(\"/documents\")\n   591→      .send({ title: \"InsertDelete\", content: \"Hello\" });\n   592→\n   593→    const { ws: ws1 } = await connectWs(port, doc.body.id);\