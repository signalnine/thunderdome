@@ -0,0 +1,224 @@
+import { WebSocket, WebSocketServer } from "ws";
+import { IncomingMessage } from "http";
+import { Server } from "http";
+import { randomUUID } from "crypto";
+import { DocumentStore } from "./db.js";
+import {
+  Operation,
+  applyOperation,
+  transformAgainstAll,
+  validateOperation,
+} from "./ot.js";
+
+interface ClientConnection {
+  id: string;
+  ws: WebSocket;
+  docId: string;
+}
+
+interface DocumentState {
+  version: number;
+  // Operations applied since the document was loaded, indexed by version
+  // operations[v] is the operation that transformed version v-1 to version v
+  operations: Operation[];
+}
+
+export class CollaborationServer {
+  private wss: WebSocketServer;
+  private store: DocumentStore;
+  private connections: Map<string, ClientConnection> = new Map();
+  private documentStates: Map<string, DocumentState> = new Map();
+
+  constructor(server: Server, store: DocumentStore) {
+    this.store = store;
+    this.wss = new WebSocketServer({ server });
+    this.wss.on("connection", (ws, req) => this.handleConnection(ws, req));
+  }
+
+  private getDocumentState(docId: string): DocumentState {
+    let state = this.documentStates.get(docId);
+    if (!state) {
+      const version = this.store.getLatestVersion(docId);
+      state = { version, operations: [] };
+      this.documentStates.set(docId, state);
+    }
+    return state;
+  }
+
+  private handleConnection(ws: WebSocket, req: IncomingMessage): void {
+    // Extract document ID from URL path: /ws/:docId
+    const url = req.url || "";
+    const match = url.match(/\/ws\/([^/?]+)/);
+
+    if (!match) {
+      ws.send(JSON.stringify({ type: "error", message: "Invalid WebSocket URL. Use /ws/:docId" }));
+      ws.close(1008, "Invalid URL");
+      return;
+    }
+
+    const docId = match[1];
+    const doc = this.store.getDocument(docId);
+
+    if (!doc) {
+      ws.send(JSON.stringify({ type: "error", message: "Document not found" }));
+      ws.close(1008, "Document not found");
+      return;
+    }
+
+    const connectionId = randomUUID();
+    const connection: ClientConnection = { id: connectionId, ws, docId };
+    this.connections.set(connectionId, connection);
+
+    const state = this.getDocumentState(docId);
+
+    // Send sync message with current document state
+    ws.send(
+      JSON.stringify({
+        type: "sync",
+        docId,
+        content: doc.content,
+        version: state.version,
+      })
+    );
+
+    ws.on("message", (data) => {
+      try {
+        const message = JSON.parse(data.toString());
+        this.handleMessage(connection, message);
+      } catch (err) {
+        ws.send(
+          JSON.stringify({
+            type: "error",
+            message: "Invalid JSON message",
+          })
+        );
+      }
+    });
+
+    ws.on("close", () => {
+      this.connections.delete(connectionId);
+    });
+
+    ws.on("error", () => {
+      this.connections.delete(connectionId);
+    });
+  }
+
+  private handleMessage(connection: ClientConnection, message: unknown): void {
+    if (!message || typeof message !== "object") {
+      connection.ws.send(
+        JSON.stringify({ type: "error", message: "Invalid message format" })
+      );
+      return;
+    }
+
+    const msg = message as Record<string, unknown>;
+
+    if (msg.type === "operation") {
+      this.handleOperation(connection, msg);
+    } else {
+      connection.ws.send(
+        JSON.stringify({ type: "error", message: `Unknown message type: ${msg.type}` })
+      );
+    }
+  }
+
+  private handleOperation(
+    connection: ClientConnection,
+    msg: Record<string, unknown>
+  ): void {
+    const docId = connection.docId;
+
+    if (!validateOperation(msg.operation)) {
+      connection.ws.send(
+        JSON.stringify({ type: "error", message: "Invalid operation" })
+      );
+      return;
+    }
+
+    const clientVersion = typeof msg.version === "number" ? msg.version : -1;
+
+    if (clientVersion < 0) {
+      connection.ws.send(
+        JSON.stringify({ type: "error", message: "Invalid version number" })
+      );
+      return;
+    }
+
+    const doc = this.store.getDocument(docId);
+    if (!doc) {
+      connection.ws.send(
+        JSON.stringify({ type: "error", message: "Document no longer exists" })
+      );
+      return;
+    }
+
+    const state = this.getDocumentState(docId);
+
+    // Get all operations that happened since the client's version
+    const opsToTransformAgainst = state.operations.slice(clientVersion);
+
+    // Transform the client's operation against all concurrent operations
+    const transformedOp = transformAgainstAll(
+      msg.operation as Operation,
+      opsToTransformAgainst
+    );
+
+    // Apply the transformed operation to the document
+    const newContent = applyOperation(doc.content, transformedOp);
+    const newVersion = state.version + 1;
+
+    // Update document content in database
+    this.store.updateContent(docId, newContent);
+
+    // Record version in database
+    this.store.addVersion(
+      docId,
+      newVersion,
+      newContent,
+      JSON.stringify(transformedOp)
+    );
+
+    // Update in-memory state
+    state.version = newVersion;
+    state.operations.push(transformedOp);
+
+    // Send acknowledgment to the sender
+    connection.ws.send(
+      JSON.stringify({
+        type: "ack",
+        version: newVersion,
+      })
+    );
+
+    // Broadcast to all other clients viewing this document
+    this.broadcast(docId, connection.id, {
+      type: "operation",
+      docId,
+      version: newVersion,
+      operation: transformedOp,
+    });
+  }
+
+  private broadcast(
+    docId: string,
+    excludeId: string,
+    message: unknown
+  ): void {
+    const data = JSON.stringify(message);
+    for (const [, conn] of this.connections) {
+      if (conn.docId === docId && conn.id !== excludeId && conn.ws.readyState === WebSocket.OPEN) {
+        conn.ws.send(data);
+      }
+    }
+  }
+
+  closeAll(): void {
+    for (const [, conn] of this.connections) {
+      conn.ws.close(1001, "Server shutting down");
+    }
+    this.connections.clear();
+    this.documentStates.clear();
+    this.wss.close();
+  }
+}
