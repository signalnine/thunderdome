")\n      .send({ title: \"ErrOp\", content: \"\" });\n\n    const ws = await connectWs(port, doc.body.id);\n    await nextMessage(ws); // sync\n\n    ws.send(JSON.stringify({\n      type: \"operation\",\n      version: 0,\n      operation: { type: \"invalid\", position: 0 },\n    }));\n\n    const err = await nextMessage(ws);\n    expect(err.type).toBe(\"error\");\n\n    ws.close();\n  });\n\n  it(\"should reject operation with missing fields\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"ErrFields\", content: \"\" });\n\n    const ws = await connectWs(port, doc.body.id);\n    await nextMessage(ws); // sync\n\n    ws.send(JSON.stringify({\n      type: \"operation\",\n      version: 0,\n      operation: { type: \"insert\" },  // missing position and text\n    }));\n\n    const err = await nextMessage(ws);\n    expect(err.type).toBe(\"error\");\n\n    ws.close();\n  });\n\n  it(\"should reject unknown message types\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"ErrType\", content: \"\" });\n\n    const ws = await connectWs(port, doc.body.id);\n    await nextMessage(ws); // sync\n\n    ws.send(JSON.stringify({ type: \"unknown_type\" }));\n    const err = await nextMessage(ws);\n    expect(err.type).toBe(\"error\");\n\n    ws.close();\n  });\n\n  it(\"should not crash on malformed operation and continue serving\", async () => {\n    const doc = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"NoCrash\", content: \"\" });\n\n    const ws = await connectWs(port, doc.body.id);\n    await nextMessage(ws); // sync\n\n    // Send malformed operation\n    ws.send(JSON.stringify({\n      type: \"operation\",\n      version: 0,\n      operation: null,\n    }));\n\n    const err = await nextMessage(ws);\n    expect(err.type).toBe(\"error\");\n\n    // Should still accept valid operations after error\n    const ack = await sendOp