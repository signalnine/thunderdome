mber,\n    43→  operation: Record<string, unknown>\n    44→): Promise<Record<string, unknown>> {\n    45→  const promise = nextMessage(ws);\n    46→  ws.send(\n    47→    JSON.stringify({ type: \"operation\", docId, version, operation })\n    48→  );\n    49→  return promise;\n    50→}\n    51→\n    52→// Helper to wait for first message on a raw WS (for error/close scenarios)\n    53→function connectRawAndWaitMessage(\n    54→  port: number,\n    55→  path: string\n    56→): Promise<{ ws: WebSocket; msg: Record<string, unknown> }> {\n    57→  return new Promise((resolve, reject) => {\n    58→    const ws = new WebSocket(`ws://localhost:${port}${path}`);\n    59→    const timeout = setTimeout(() => reject(new Error(\"Connection timeout\")), 5000);\n    60→    ws.on(\"message\", function handler(data) {\n    61→      clearTimeout(timeout);\n    62→      ws.off(\"message\", handler);\n    63→      resolve({ ws, msg: JSON.parse(data.toString()) });\n    64→    });\n    65→    ws.on(\"error\", (err) => {\n    66→      clearTimeout(timeout);\n    67→      reject(err);\n    68→    });\n    69→  });\n    70→}\n    71→\n    72→// ─── REST CRUD ────────────────────────────────────────────────────────────────\n    73→describe(\"REST CRUD\", () => {\n    74→  let app: AppInstance;\n    75→\n    76→  beforeEach(async () => {\n    77→    app = createApp();\n    78→    await app.start(0);\n    79→  });\n    80→\n    81→  afterEach(async () => {\n    82→    await app.stop();\n    83→  });\n    84→\n    85→  it(\"should create a document\", async () => {\n    86→    const res = await request(app.app)\n    87→      .post(\"/documents\")\n    88→      .send({ title: \"Test Doc\", content: \"Hello\" })\n    89→      .expect(201);\n    90→\n    91→    expect(res.body.id).toBeDefined();\n    92→    expect(res.body.title).toBe(\"Test Doc\");\n    93→    expect(res.body.content).toBe(\"Hello\");\n    94→  });\n    95→\n    96→  it(\"should create a document with empty content by default\"