@@ -0,0 +1,692 @@
+import { randomUUID } from 'node:crypto';
+import type {
+  Task,
+  TaskOptions,
+  Schedule,
+  MiddlewareFn,
+  HandlerFn,
+  ProgressCallback,
+  ShutdownSummary,
+} from './types.js';
+
+const DEFAULT_QUEUE = 'default';
+const DEFAULT_PRIORITY = 5;
+const DEFAULT_MAX_RETRIES = 3;
+const DEFAULT_BACKOFF_DELAY = 1000;
+
+interface QueueState {
+  tasks: Map<string, Task>;
+  deadLetterQueue: Task[];
+  concurrencyLimit: number;
+  middlewares: MiddlewareFn[];
+  handler?: HandlerFn;
+}
+
+export class TaskQueue {
+  private queues: Map<string, QueueState> = new Map();
+  private allTasks: Map<string, Task> = new Map();
+  private progressSubscribers: Map<string, Set<ProgressCallback>> = new Map();
+  private schedules: Map<string, Schedule> = new Map();
+  private shutdownState: {
+    initiated: boolean;
+    promise?: Promise<ShutdownSummary>;
+    callbacks: Array<() => void | Promise<void>>;
+  } = { initiated: false, callbacks: [] };
+
+  // ── Phase 1 & 2: Core queue operations ──
+
+  private getOrCreateQueue(name: string): QueueState {
+    let q = this.queues.get(name);
+    if (!q) {
+      q = {
+        tasks: new Map(),
+        deadLetterQueue: [],
+        concurrencyLimit: 0,
+        middlewares: [],
+      };
+      this.queues.set(name, q);
+    }
+    return q;
+  }
+
+  add<T = unknown>(payload: T, options?: TaskOptions & { queue?: string }): Task<T> {
+    if (this.shutdownState.initiated) {
+      throw new Error('Queue system is shutting down; cannot add new tasks');
+    }
+
+    const queueName = options?.queue ?? DEFAULT_QUEUE;
+    const priority = options?.priority ?? DEFAULT_PRIORITY;
+
+    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {
+      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);
+    }
+
+    // Validate dependencies
+    const dependencies = options?.dependencies ?? [];
+    for (const depId of dependencies) {
+      const depTask = this.allTasks.get(depId);
+      if (!depTask) {
+        throw new Error(`Dependency task ${depId} does not exist`);
+      }
+    }
+
+    // Detect circular dependencies
+    if (dependencies.length > 0) {
+      const taskId = randomUUID();
+      // We'll use this ID, but first check circularity
+      // Since the task doesn't exist yet, we check if any dependency transitively depends on... well, it can't since this task doesn't exist yet
+      // But we need to ensure existing dependency chains don't form a cycle with the new task
+      // Since the new task doesn't exist yet and no other task depends on it, there can't be a cycle at creation time
+      // unless we allow forward references. The requirement says "Depending on a non-existent task should cause an error"
+      // so we can't have forward refs, thus cycles are impossible at creation time... UNLESS
+      // task A depends on task B, and we try to add task C that depends on A, while A depends on C.
+      // But A can't depend on C because C doesn't exist when A was created.
+      // Actually, the only way to get a cycle is if we could create mutual dependencies, which requires forward refs.
+      // So circularity can only happen indirectly through chains.
+      // Wait - it's possible: A depends on B. Then we add C depending on A. Then we try to add D depending on C.
+      // That's fine, no cycle. The real question: can we have A depends on B, then try to make B depend on A?
+      // B already exists. When we add a NEW task that depends on [B], that's fine.
+      // But the spec says we specify deps at creation time. So B was created first without deps on A.
+      // Then A is created depending on B. No cycle.
+      // The only way: A depends on B, B depends on C, and we try to create a new task D that depends on A,
+      // while A depends on D - but D doesn't exist yet when A was created.
+      // Conclusion: with deps specified only at creation time and no forward refs, cycles are structurally impossible.
+      // BUT to be safe and follow the spec, let's still detect them:
+      this.detectCircularDependencies(taskId, dependencies);
+
+      return this.createTask(payload, queueName, priority, options, taskId);
+    }
+
+    return this.createTask(payload, queueName, priority, options);
+  }
+
+  private detectCircularDependencies(newTaskId: string, dependencies: string[]): void {
+    // Check if any dependency chain leads back to newTaskId
+    // Since newTaskId doesn't exist yet, we check if any dep's dep chain has a cycle
+    // We also need to make sure that the deps themselves don't form issues
+    const visited = new Set<string>();
+
+    const checkDep = (depId: string, path: Set<string>): void => {
+      if (path.has(depId)) {
+        throw new Error('Circular dependency detected');
+      }
+      if (visited.has(depId)) return;
+      visited.add(depId);
+      path.add(depId);
+
+      const task = this.allTasks.get(depId);
+      if (task) {
+        for (const subDep of task.dependencies) {
+          checkDep(subDep, new Set(path));
+        }
+      }
+      path.delete(depId);
+    };
+
+    for (const depId of dependencies) {
+      checkDep(depId, new Set([newTaskId]));
+    }
+  }
+
+  private createTask<T = unknown>(
+    payload: T,
+    queueName: string,
+    priority: number,
+    options?: TaskOptions,
+    existingId?: string
+  ): Task<T> {
+    const now = new Date();
+    let availableAt = now;
+
+    if (options?.availableAt) {
+      availableAt = options.availableAt;
+    } else if (options?.delay && options.delay > 0) {
+      availableAt = new Date(now.getTime() + options.delay);
+    }
+
+    const task: Task<T> = {
+      id: existingId ?? randomUUID(),
+      payload,
+      status: 'pending',
+      priority,
+      createdAt: now,
+      availableAt,
+      attempt: 0,
+      maxRetries: options?.maxRetries ?? DEFAULT_MAX_RETRIES,
+      backoffDelay: options?.backoffDelay ?? DEFAULT_BACKOFF_DELAY,
+      queue: queueName,
+      progress: 0,
+      failureCount: 0,
+      dependencies: options?.dependencies ?? [],
+      resolvedDependencies: new Set<string>(),
+    };
+
+    const q = this.getOrCreateQueue(queueName);
+    q.tasks.set(task.id, task);
+    this.allTasks.set(task.id, task as Task);
+    return task;
+  }
+
+  next(queueName?: string): Task | null {
+    const name = queueName ?? DEFAULT_QUEUE;
+    const q = this.queues.get(name);
+    if (!q) return null;
+
+    // Phase 8: Check concurrency limit
+    if (q.concurrencyLimit > 0) {
+      const activeCount = this.getActiveCount(name);
+      if (activeCount >= q.concurrencyLimit) {
+        return null;
+      }
+    }
+
+    const now = new Date();
+    const candidates: Task[] = [];
+
+    for (const task of q.tasks.values()) {
+      if (task.status !== 'pending') continue;
+
+      // Phase 7: Skip blocked tasks (unresolved dependencies)
+      if (task.dependencies.length > 0) {
+        const allResolved = task.dependencies.every(depId => task.resolvedDependencies.has(depId));
+        if (!allResolved) continue;
+      }
+
+      // Phase 4: Skip tasks that aren't available yet
+      if (task.availableAt > now) continue;
+
+      candidates.push(task);
+    }
+
+    if (candidates.length === 0) return null;
+
+    // Sort: priority ASC (lower = higher priority), then availableAt ASC, then createdAt ASC
+    candidates.sort((a, b) => {
+      if (a.priority !== b.priority) return a.priority - b.priority;
+      if (a.availableAt.getTime() !== b.availableAt.getTime()) {
+        return a.availableAt.getTime() - b.availableAt.getTime();
+      }
+      return a.createdAt.getTime() - b.createdAt.getTime();
+    });
+
+    const task = candidates[0];
+    task.status = 'processing';
+    task.attempt++;
+    return task;
+  }
+
+  size(queueName?: string): number {
+    const name = queueName ?? DEFAULT_QUEUE;
+    const q = this.queues.get(name);
+    if (!q) return 0;
+
+    let count = 0;
+    for (const task of q.tasks.values()) {
+      if (task.status === 'pending') count++;
+    }
+    return count;
+  }
+
+  getQueues(): string[] {
+    return Array.from(this.queues.keys());
+  }
+
+  getTask(taskId: string): Task | undefined {
+    return this.allTasks.get(taskId);
+  }
+
+  // ── Phase 5 & 6: Complete / Fail ──
+
+  complete(taskId: string): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) throw new Error(`Task ${taskId} not found`);
+    if (task.status !== 'processing') throw new Error(`Task ${taskId} is not in processing state`);
+
+    task.status = 'completed';
+
+    // Phase 7: Resolve dependents
+    this.resolveDependents(taskId);
+  }
+
+  fail(taskId: string, error?: Error): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) throw new Error(`Task ${taskId} not found`);
+    if (task.status !== 'processing') throw new Error(`Task ${taskId} is not in processing state`);
+
+    task.error = error;
+    task.failureCount++;
+
+    if (task.attempt < task.maxRetries) {
+      // Retry with exponential backoff
+      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);
+      task.status = 'pending';
+      task.availableAt = new Date(Date.now() + delay);
+      task.progress = 0;
+      task.progressMessage = undefined;
+    } else {
+      // Exhausted retries
+      task.status = 'failed';
+      this.moveToDLQ(task);
+    }
+  }
+
+  // ── Phase 6: Dead Letter Queue ──
+
+  private moveToDLQ(task: Task): void {
+    const q = this.queues.get(task.queue);
+    if (!q) return;
+
+    task.status = 'dead-lettered';
+    q.tasks.delete(task.id);
+    q.deadLetterQueue.push(task);
+  }
+
+  getDeadLetterQueue(queueName?: string): Task[] {
+    const name = queueName ?? DEFAULT_QUEUE;
+    const q = this.queues.get(name);
+    if (!q) return [];
+    return [...q.deadLetterQueue];
+  }
+
+  retryDeadLetter(taskId: string): Task {
+    for (const [, q] of this.queues) {
+      const idx = q.deadLetterQueue.findIndex(t => t.id === taskId);
+      if (idx !== -1) {
+        const task = q.deadLetterQueue.splice(idx, 1)[0];
+        task.status = 'pending';
+        task.attempt = 0;
+        task.progress = 0;
+        task.progressMessage = undefined;
+        task.error = undefined;
+        task.availableAt = new Date();
+        q.tasks.set(task.id, task);
+        return task;
+      }
+    }
+    throw new Error(`Task ${taskId} not found in any dead letter queue`);
+  }
+
+  clearDeadLetterQueue(queueName?: string): void {
+    const name = queueName ?? DEFAULT_QUEUE;
+    const q = this.queues.get(name);
+    if (!q) return;
+
+    for (const task of q.deadLetterQueue) {
+      this.allTasks.delete(task.id);
+    }
+    q.deadLetterQueue = [];
+  }
+
+  // ── Phase 7: Dependencies ──
+
+  private resolveDependents(completedTaskId: string): void {
+    for (const [, task] of this.allTasks) {
+      if (task.dependencies.includes(completedTaskId)) {
+        task.resolvedDependencies.add(completedTaskId);
+      }
+    }
+  }
+
+  getDependencyStatus(taskId: string): { dependencies: string[]; resolved: string[]; blocked: boolean } {
+    const task = this.allTasks.get(taskId);
+    if (!task) throw new Error(`Task ${taskId} not found`);
+
+    const resolved = Array.from(task.resolvedDependencies);
+    const blocked = task.dependencies.length > 0 && !task.dependencies.every(d => task.resolvedDependencies.has(d));
+
+    return {
+      dependencies: [...task.dependencies],
+      resolved,
+      blocked,
+    };
+  }
+
+  // ── Phase 8: Concurrency Control ──
+
+  setConcurrency(queueName: string, limit: number): void {
+    const q = this.getOrCreateQueue(queueName);
+    q.concurrencyLimit = limit;
+  }
+
+  getConcurrency(queueName?: string): { limit: number; active: number } {
+    const name = queueName ?? DEFAULT_QUEUE;
+    const q = this.queues.get(name);
+    if (!q) return { limit: 0, active: 0 };
+
+    return {
+      limit: q.concurrencyLimit,
+      active: this.getActiveCount(name),
+    };
+  }
+
+  private getActiveCount(queueName: string): number {
+    const q = this.queues.get(queueName);
+    if (!q) return 0;
+
+    let count = 0;
+    for (const task of q.tasks.values()) {
+      if (task.status === 'processing') count++;
+    }
+    return count;
+  }
+
+  // ── Phase 9: Progress Tracking and Cancellation ──
+
+  updateProgress(taskId: string, progress: number, message?: string): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) throw new Error(`Task ${taskId} not found`);
+    if (task.status !== 'processing') throw new Error(`Task ${taskId} is not in processing state`);
+    if (progress < 0 || progress > 100) throw new Error('Progress must be between 0 and 100');
+
+    task.progress = progress;
+    task.progressMessage = message;
+
+    const subs = this.progressSubscribers.get(taskId);
+    if (subs) {
+      for (const cb of subs) {
+        cb(progress, message);
+      }
+    }
+  }
+
+  getProgress(taskId: string): { progress: number; message?: string } {
+    const task = this.allTasks.get(taskId);
+    if (!task) throw new Error(`Task ${taskId} not found`);
+    return { progress: task.progress, message: task.progressMessage };
+  }
+
+  onProgress(taskId: string, callback: ProgressCallback): () => void {
+    let subs = this.progressSubscribers.get(taskId);
+    if (!subs) {
+      subs = new Set();
+      this.progressSubscribers.set(taskId, subs);
+    }
+    subs.add(callback);
+
+    return () => {
+      subs!.delete(callback);
+      if (subs!.size === 0) {
+        this.progressSubscribers.delete(taskId);
+      }
+    };
+  }
+
+  cancel(taskId: string): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) throw new Error(`Task ${taskId} not found`);
+    if (task.status !== 'pending' && task.status !== 'processing') {
+      throw new Error(`Task ${taskId} cannot be cancelled from ${task.status} state`);
+    }
+
+    const wasPending = task.status === 'pending';
+    task.status = 'cancelled';
+
+    if (wasPending) {
+      // Remove from queue
+      const q = this.queues.get(task.queue);
+      if (q) {
+        q.tasks.delete(task.id);
+      }
+    }
+  }
+
+  // ── Phase 10: Recurring Tasks ──
+
+  addSchedule(
+    id: string,
+    cron: string,
+    queueName: string,
+    payload: unknown,
+    taskOptions?: Omit<TaskOptions, 'delay' | 'availableAt' | 'dependencies'>
+  ): Schedule {
+    this.validateCron(cron);
+
+    const schedule: Schedule = {
+      id,
+      cron,
+      queue: queueName,
+      payload,
+      taskOptions,
+      active: true,
+    };
+
+    this.schedules.set(id, schedule);
+    return schedule;
+  }
+
+  removeSchedule(id: string): void {
+    const schedule = this.schedules.get(id);
+    if (schedule) {
+      schedule.active = false;
+      this.schedules.delete(id);
+    }
+  }
+
+  getSchedules(): Schedule[] {
+    return Array.from(this.schedules.values()).filter(s => s.active);
+  }
+
+  tick(now?: Date): Task[] {
+    const currentTime = now ?? new Date();
+    const enqueued: Task[] = [];
+
+    for (const schedule of this.schedules.values()) {
+      if (!schedule.active) continue;
+
+      if (this.isDue(schedule, currentTime)) {
+        const task = this.add(schedule.payload, {
+          queue: schedule.queue,
+          ...schedule.taskOptions,
+        });
+        enqueued.push(task as Task);
+        schedule.lastRun = currentTime;
+      }
+    }
+
+    return enqueued;
+  }
+
+  private validateCron(cron: string): void {
+    const parts = cron.split(' ');
+    if (parts.length !== 5) {
+      throw new Error(`Invalid cron expression: ${cron}`);
+    }
+
+    // Validate the simple subset we support
+    const [minute, hour, dayOfMonth, month, dayOfWeek] = parts;
+
+    // Check valid patterns
+    const isValidField = (field: string): boolean => {
+      if (field === '*') return true;
+      if (/^\d+$/.test(field)) return true;
+      if (/^\*\/\d+$/.test(field)) return true;
+      return false;
+    };
+
+    if (!isValidField(minute) || !isValidField(hour) || !isValidField(dayOfMonth) ||
+        !isValidField(month) || !isValidField(dayOfWeek)) {
+      throw new Error(`Invalid cron expression: ${cron}`);
+    }
+  }
+
+  private isDue(schedule: Schedule, now: Date): boolean {
+    const [minuteExpr, hourExpr] = schedule.cron.split(' ');
+
+    const currentMinute = now.getMinutes();
+    const currentHour = now.getHours();
+
+    // Check minute
+    if (!this.matchesCronField(minuteExpr, currentMinute)) return false;
+    // Check hour
+    if (!this.matchesCronField(hourExpr, currentHour)) return false;
+
+    // Prevent duplicate runs within the same minute
+    if (schedule.lastRun) {
+      const lastRunMinute = schedule.lastRun.getMinutes();
+      const lastRunHour = schedule.lastRun.getHours();
+      const lastRunDate = schedule.lastRun.toDateString();
+      const nowDate = now.toDateString();
+
+      if (lastRunMinute === currentMinute && lastRunHour === currentHour && lastRunDate === nowDate) {
+        return false;
+      }
+    }
+
+    return true;
+  }
+
+  private matchesCronField(expr: string, value: number): boolean {
+    if (expr === '*') return true;
+
+    if (expr.startsWith('*/')) {
+      const interval = parseInt(expr.substring(2), 10);
+      return value % interval === 0;
+    }
+
+    return parseInt(expr, 10) === value;
+  }
+
+  // ── Phase 11: Middleware Pipeline ──
+
+  use(queueName: string, middleware: MiddlewareFn): void {
+    const q = this.getOrCreateQueue(queueName);
+    q.middlewares.push(middleware);
+  }
+
+  setHandler(queueName: string, handler: HandlerFn): void {
+    const q = this.getOrCreateQueue(queueName);
+    q.handler = handler;
+  }
+
+  async process(queueName?: string): Promise<Task | null> {
+    const name = queueName ?? DEFAULT_QUEUE;
+    const task = this.next(name);
+    if (!task) return null;
+
+    const q = this.queues.get(name);
+    if (!q) return null;
+
+    const middlewares = [...q.middlewares];
+    const handler = q.handler;
+
+    try {
+      await this.runMiddlewarePipeline(task, middlewares, handler);
+      if (task.status === 'processing') {
+        this.complete(task.id);
+      }
+    } catch (err) {
+      if (task.status === 'processing') {
+        this.fail(task.id, err instanceof Error ? err : new Error(String(err)));
+      }
+    }
+
+    return task;
+  }
+
+  private async runMiddlewarePipeline(
+    task: Task,
+    middlewares: MiddlewareFn[],
+    handler?: HandlerFn
+  ): Promise<void> {
+    let index = 0;
+
+    const runNext = async (): Promise<void> => {
+      if (index < middlewares.length) {
+        const mw = middlewares[index++];
+        await mw(task, runNext);
+      } else if (handler) {
+        await handler(task);
+      }
+    };
+
+    await runNext();
+  }
+
+  // ── Phase 12: Graceful Shutdown ──
+
+  onShutdown(callback: () => void | Promise<void>): void {
+    this.shutdownState.callbacks.push(callback);
+  }
+
+  async shutdown(timeout: number = 5000): Promise<ShutdownSummary> {
+    if (this.shutdownState.promise) {
+      return this.shutdownState.promise;
+    }
+
+    this.shutdownState.initiated = true;
+
+    this.shutdownState.promise = this.performShutdown(timeout);
+    return this.shutdownState.promise;
+  }
+
+  private async performShutdown(timeout: number): Promise<ShutdownSummary> {
+    const startTime = Date.now();
+
+    // Run shutdown callbacks
+    for (const cb of this.shutdownState.callbacks) {
+      await cb();
+    }
+
+    // Find all processing tasks
+    const processingTasks: Task[] = [];
+    for (const [, task] of this.allTasks) {
+      if (task.status === 'processing') {
+        processingTasks.push(task);
+      }
+    }
+
+    let completed = 0;
+    let cancelled = 0;
+
+    if (processingTasks.length === 0) {
+      return {
+        completed: 0,
+        cancelled: 0,
+        duration: Date.now() - startTime,
+      };
+    }
+
+    // Wait for processing tasks with timeout
+    const waitResult = await Promise.race([
+      this.waitForProcessing(processingTasks),
+      this.timeoutPromise(timeout),
+    ]);
+
+    if (waitResult === 'timeout') {
+      // Force-cancel remaining processing tasks
+      for (const task of processingTasks) {
+        if (task.status === 'processing') {
+          task.status = 'cancelled';
+          cancelled++;
+        } else if (task.status === 'completed') {
+          completed++;
+        }
+      }
+    } else {
+      // All completed
+      completed = processingTasks.length;
+    }
+
+    return {
+      completed,
+      cancelled,
+      duration: Date.now() - startTime,
+    };
+  }
+
+  private async waitForProcessing(tasks: Task[]): Promise<'done'> {
+    // Poll until all tasks are no longer processing
+    while (tasks.some(t => t.status === 'processing')) {
+      await new Promise(resolve => setTimeout(resolve, 10));
+    }
+    return 'done';
+  }
+
+  private async timeoutPromise(ms: number): Promise<'timeout'> {
+    return new Promise(resolve => setTimeout(() => resolve('timeout'), ms));
+  }
+
+  get isShuttingDown(): boolean {
+    return this.shutdownState.initiated;
+  }
+}
diff --git a/src/types.ts b/src/types.ts
new file mode 100644
index 0000000..2fd281a
--- /dev/null
+++ b/src/types.ts
@@ -0,0 +1,49 @@
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled' | 'dead-lettered';
+
+export interface Task<T = unknown> {
+  id: string;
+  payload: T;
+  status: TaskStatus;
+  priority: number;
+  createdAt: Date;
+  availableAt: Date;
+  attempt: number;
+  maxRetries: number;
+  backoffDelay: number;
+  queue: string;
+  progress: number;
+  progressMessage?: string;
+  error?: Error;
+  failureCount: number;
+  dependencies: string[];
+  resolvedDependencies: Set<string>;
+}
+
+export interface TaskOptions {
+  priority?: number;
+  delay?: number;
+  availableAt?: Date;
+  maxRetries?: number;
+  backoffDelay?: number;
+  dependencies?: string[];
+}
+
+export interface Schedule {
+  id: string;
+  cron: string;
+  queue: string;
+  payload: unknown;
+  taskOptions?: Omit<TaskOptions, 'delay' | 'availableAt' | 'dependencies'>;
+  lastRun?: Date;
+  active: boolean;
+}
+
+export type MiddlewareFn = (task: Task, next: () => Promise<void>) => Promise<void>;
+export type HandlerFn = (task: Task) => Promise<void>;
+export type ProgressCallback = (progress: number, message?: string) => void;
+
+export interface ShutdownSummary {
+  completed: number;
+  cancelled: number;
+  duration: number;
+}
