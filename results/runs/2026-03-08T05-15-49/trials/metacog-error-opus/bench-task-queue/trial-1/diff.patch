+import { describe, it, expect, beforeEach, vi } from 'vitest';
+import { TaskQueue } from './task-queue.js';
+
+describe('TaskQueue', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  // ── Phase 1: Basic FIFO Queue ──
+
+  describe('Phase 1: Basic FIFO Queue', () => {
+    it('should add a task and return a task object with id, status, and createdAt', () => {
+      const task = queue.add({ message: 'hello' });
+      expect(task.id).toBeDefined();
+      expect(task.status).toBe('pending');
+      expect(task.createdAt).toBeInstanceOf(Date);
+      expect(task.payload).toEqual({ message: 'hello' });
+    });
+
+    it('should generate unique IDs for each task', () => {
+      const t1 = queue.add('task1');
+      const t2 = queue.add('task2');
+      expect(t1.id).not.toBe(t2.id);
+    });
+
+    it('should retrieve the oldest pending task first (FIFO)', () => {
+      queue.add('first');
+      queue.add('second');
+      queue.add('third');
+
+      const next = queue.next();
+      expect(next).not.toBeNull();
+      expect(next!.payload).toBe('first');
+      expect(next!.status).toBe('processing');
+    });
+
+    it('should return null when no tasks are available', () => {
+      expect(queue.next()).toBeNull();
+    });
+
+    it('should track pending task count', () => {
+      expect(queue.size()).toBe(0);
+      queue.add('task1');
+      expect(queue.size()).toBe(1);
+      queue.add('task2');
+      expect(queue.size()).toBe(2);
+      queue.next();
+      expect(queue.size()).toBe(1);
+    });
+
+    it('should not return already-processing tasks', () => {
+      queue.add('first');
+      queue.add('second');
+
+      const t1 = queue.next();
+      expect(t1!.payload).toBe('first');
+
+      const t2 = queue.next();
+      expect(t2!.payload).toBe('second');
+
+      expect(queue.next()).toBeNull();
+    });
+  });
+
+  // ── Phase 2: Named Queues ──
+
+  describe('Phase 2: Named Queues', () => {
+    it('should add tasks to named queues', () => {
+      queue.add('email-task', { queue: 'emails' });
+      queue.add('sms-task', { queue: 'sms' });
+
+      expect(queue.size('emails')).toBe(1);
+      expect(queue.size('sms')).toBe(1);
+    });
+
+    it('should use default queue when no name given', () => {
+      queue.add('default-task');
+      expect(queue.size()).toBe(1);
+      expect(queue.size('default')).toBe(1);
+    });
+
+    it('should retrieve from specified queue only', () => {
+      queue.add('email', { queue: 'emails' });
+      queue.add('sms', { queue: 'sms' });
+
+      const task = queue.next('emails');
+      expect(task!.payload).toBe('email');
+
+      expect(queue.next('emails')).toBeNull();
+      expect(queue.next('sms')).not.toBeNull();
+    });
+
+    it('should create queues implicitly', () => {
+      queue.add('task', { queue: 'new-queue' });
+      expect(queue.getQueues()).toContain('new-queue');
+    });
+
+    it('should list all queue names', () => {
+      queue.add('a', { queue: 'q1' });
+      queue.add('b', { queue: 'q2' });
+      const names = queue.getQueues();
+      expect(names).toContain('q1');
+      expect(names).toContain('q2');
+    });
+
+    it('should return null for non-existent queue', () => {
+      expect(queue.next('nonexistent')).toBeNull();
+    });
+
+    it('should maintain backward compatibility (no queue name)', () => {
+      queue.add('task');
+      const task = queue.next();
+      expect(task).not.toBeNull();
+      expect(task!.payload).toBe('task');
+    });
+  });
+
+  // ── Phase 3: Priority ──
+
+  describe('Phase 3: Priority', () => {
+    it('should default priority to 5', () => {
+      const task = queue.add('task');
+      expect(task.priority).toBe(5);
+    });
+
+    it('should return higher priority tasks first', () => {
+      queue.add('low', { priority: 10 });
+      queue.add('high', { priority: 1 });
+      queue.add('medium', { priority: 5 });
+
+      expect(queue.next()!.payload).toBe('high');
+      expect(queue.next()!.payload).toBe('medium');
+      expect(queue.next()!.payload).toBe('low');
+    });
+
+    it('should maintain FIFO within same priority', () => {
+      queue.add('first', { priority: 5 });
+      queue.add('second', { priority: 5 });
+      queue.add('third', { priority: 5 });
+
+      expect(queue.next()!.payload).toBe('first');
+      expect(queue.next()!.payload).toBe('second');
+      expect(queue.next()!.payload).toBe('third');
+    });
+
+    it('should reject invalid priorities', () => {
+      expect(() => queue.add('task', { priority: 0 })).toThrow();
+      expect(() => queue.add('task', { priority: 11 })).toThrow();
+      expect(() => queue.add('task', { priority: 1.5 })).toThrow();
+    });
+
+    it('should expose priority on task object', () => {
+      const task = queue.add('task', { priority: 3 });
+      expect(task.priority).toBe(3);
+    });
+
+    it('should maintain priority per queue', () => {
+      queue.add('low-email', { queue: 'email', priority: 10 });
+      queue.add('high-email', { queue: 'email', priority: 1 });
+      queue.add('low-sms', { queue: 'sms', priority: 10 });
+      queue.add('high-sms', { queue: 'sms', priority: 1 });
+
+      expect(queue.next('email')!.payload).toBe('high-email');
+      expect(queue.next('sms')!.payload).toBe('high-sms');
+    });
+  });
+
+  // ── Phase 4: Delayed Tasks ──
+
+  describe('Phase 4: Delayed and Scheduled Tasks', () => {
+    it('should delay tasks by milliseconds', () => {
+      queue.add('delayed', { delay: 10000 });
+      expect(queue.next()).toBeNull(); // Not available yet
+    });
+
+    it('should make delayed tasks available after time passes', () => {
+      const task = queue.add('delayed', { delay: 0 }); // 0ms delay = available now
+      expect(task.availableAt).toBeInstanceOf(Date);
+      const next = queue.next();
+      expect(next).not.toBeNull();
+    });
+
+    it('should accept specific future time', () => {
+      const futureTime = new Date(Date.now() + 10000);
+      queue.add('scheduled', { availableAt: futureTime });
+      expect(queue.next()).toBeNull();
+    });
+
+    it('should prefer non-delayed tasks over not-yet-available delayed tasks', () => {
+      queue.add('delayed', { delay: 10000, priority: 1 });
+      queue.add('immediate', { priority: 5 });
+
+      const next = queue.next();
+      expect(next!.payload).toBe('immediate');
+    });
+
+    it('should order delayed tasks by availability then priority then FIFO', () => {
+      const now = Date.now();
+      queue.add('later', { availableAt: new Date(now - 100), priority: 5 });
+      queue.add('earlier', { availableAt: new Date(now - 200), priority: 5 });
+
+      expect(queue.next()!.payload).toBe('earlier');
+      expect(queue.next()!.payload).toBe('later');
+    });
+
+    it('should indicate availability time on task', () => {
+      const futureTime = new Date(Date.now() + 5000);
+      const task = queue.add('task', { availableAt: futureTime });
+      expect(task.availableAt).toEqual(futureTime);
+    });
+
+    it('should work with named queues', () => {
+      queue.add('delayed', { queue: 'work', delay: 10000 });
+      expect(queue.next('work')).toBeNull();
+    });
+  });
+
+  // ── Phase 5: Retry with Backoff ──
+
+  describe('Phase 5: Retry with Backoff', () => {
+    it('should mark task as completed', () => {
+      queue.add('task');
+      const task = queue.next()!;
+      queue.complete(task.id);
+      expect(queue.getTask(task.id)!.status).toBe('completed');
+    });
+
+    it('should mark task as failed and retry with backoff', () => {
+      queue.add('task', { maxRetries: 3 });
+      const task = queue.next()!;
+
+      queue.fail(task.id, new Error('oops'));
+      const updatedTask = queue.getTask(task.id)!;
+
+      expect(updatedTask.status).toBe('pending');
+      expect(updatedTask.failureCount).toBe(1);
+      // Should have exponential backoff delay
+      expect(updatedTask.availableAt.getTime()).toBeGreaterThan(Date.now());
+    });
+
+    it('should use exponential backoff: baseDelay * 2^(attempt-1)', () => {
+      queue.add('task', { maxRetries: 3, backoffDelay: 1000 });
+      const task = queue.next()!;
+
+      const beforeFail = Date.now();
+      queue.fail(task.id, new Error('fail'));
+
+      const updated = queue.getTask(task.id)!;
+      // First retry: 1000 * 2^0 = 1000ms
+      const expectedDelay = 1000;
+      const actualDelay = updated.availableAt.getTime() - beforeFail;
+      expect(actualDelay).toBeGreaterThanOrEqual(expectedDelay - 50);
+      expect(actualDelay).toBeLessThanOrEqual(expectedDelay + 100);
+    });
+
+    it('should default to 3 retries and 1000ms backoff', () => {
+      const task = queue.add('task');
+      expect(task.maxRetries).toBe(3);
+      expect(task.backoffDelay).toBe(1000);
+    });
+
+    it('should configure retries per task', () => {
+      const task = queue.add('task', { maxRetries: 5, backoffDelay: 500 });
+      expect(task.maxRetries).toBe(5);
+      expect(task.backoffDelay).toBe(500);
+    });
+
+    it('should track attempt count', () => {
+      queue.add('task', { maxRetries: 3, backoffDelay: 0 });
+      const task = queue.next()!;
+      expect(task.attempt).toBe(1);
+    });
+
+    it('should keep original queue and priority on retry', () => {
+      queue.add('task', { queue: 'myqueue', priority: 2, maxRetries: 3 });
+      const task = queue.next('myqueue')!;
+      queue.fail(task.id);
+
+      const updated = queue.getTask(task.id)!;
+      expect(updated.queue).toBe('myqueue');
+      expect(updated.priority).toBe(2);
+    });
+
+    it('should move to failed state when retries exhausted', () => {
+      queue.add('task', { maxRetries: 1, backoffDelay: 0 });
+
+      // Attempt 1
+      const task = queue.next()!;
+      queue.fail(task.id, new Error('fail'));
+
+      // The task now has no more retries (1 attempt used, maxRetries = 1)
+      const updated = queue.getTask(task.id)!;
+      expect(updated.status).toBe('dead-lettered'); // moved to DLQ
+    });
+  });
+
+  // ── Phase 6: Dead Letter Queue ──
+
+  describe('Phase 6: Dead Letter Queue', () => {
+    it('should move task to DLQ when retries exhausted', () => {
+      queue.add('task', { maxRetries: 1, backoffDelay: 0 });
