+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01CW1Rfc99QeXSm6Lr2FaN5A","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_018K1JUQdBZtaoYdyK1rgoeq","name":"Write","input":{"file_path":"/workspace/src/task-queue.test.ts","content":"import { describe, it, expect, beforeEach, vi } from 'vitest';\nimport { TaskQueue } from './task-queue.js';\n\ndescribe('TaskQueue', () => {\n  let queue: TaskQueue;\n\n  beforeEach(() => {\n    queue = new TaskQueue();\n  });\n\n  // ── Phase 1: Basic FIFO Queue ──\n\n  describe('Phase 1: Basic FIFO Queue', () => {\n    it('should add a task and return a task object with id, status, and createdAt', () => {\n      const task = queue.add({ message: 'hello' });\n      expect(task.id).toBeDefined();\n      expect(task.status).toBe('pending');\n      expect(task.createdAt).toBeInstanceOf(Date);\n      expect(task.payload).toEqual({ message: 'hello' });\n    });\n\n    it('should generate unique IDs for each task', () => {\n      const t1 = queue.add('task1');\n      const t2 = queue.add('task2');\n      expect(t1.id).not.toBe(t2.id);\n    });\n\n    it('should retrieve the oldest pending task first (FIFO)', () => {\n      queue.add('first');\n      queue.add('second');\n      queue.add('third');\n\n      const next = queue.next();\n      expect(next).not.toBeNull();\n      expect(next!.payload).toBe('first');\n      expect(next!.status).toBe('processing');\n    });\n\n    it('should return null when no tasks are available', () => {\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should track pending task count', () => {\n      expect(queue.size()).toBe(0);\n      queue.add('task1');\n      expect(queue.size()).toBe(1);\n      queue.add('task2');\n      expect(queue.size()).toBe(2);\n      queue.next();\n      expect(queue.size()).toBe(1);\n    });\n\n    it('should not return already-processing tasks', () => {\n      queue.add('first');\n      queue.add('second');\n\n      const t1 = queue.next();\n      expect(t1!.payload).toBe('first');\n\n      const t2 = queue.next();\n      expect(t2!.payload).toBe('second');\n\n      expect(queue.next()).toBeNull();\n    });\n  });\n\n  // ── Phase 2: Named Queues ──\n\n  describe('Phase 2: Named Queues', () => {\n    it('should add tasks to named queues', () => {\n      queue.add('email-task', { queue: 'emails' });\n      queue.add('sms-task', { queue: 'sms' });\n\n      expect(queue.size('emails')).toBe(1);\n      expect(queue.size('sms')).toBe(1);\n    });\n\n    it('should use default queue when no name given', () => {\n      queue.add('default-task');\n      expect(queue.size()).toBe(1);\n      expect(queue.size('default')).toBe(1);\n    });\n\n    it('should retrieve from specified queue only', () => {\n      queue.add('email', { queue: 'emails' });\n      queue.add('sms', { queue: 'sms' });\n\n      const task = queue.next('emails');\n      expect(task!.payload).toBe('email');\n\n      expect(queue.next('emails')).toBeNull();\n      expect(queue.next('sms')).not.toBeNull();\n    });\n\n    it('should create queues implicitly', () => {\n      queue.add('task', { queue: 'new-queue' });\n      expect(queue.getQueues()).toContain('new-queue');\n    });\n\n    it('should list all queue names', () => {\n      queue.add('a', { queue: 'q1' });\n      queue.add('b', { queue: 'q2' });\n      const names = queue.getQueues();\n      expect(names).toContain('q1');\n      expect(names).toContain('q2');\n    });\n\n    it('should return null for non-existent queue', () => {\n      expect(queue.next('nonexistent')).toBeNull();\n    });\n\n    it('should maintain backward compatibility (no queue name)', () => {\n      queue.add('task');\n      const task = queue.next();\n      expect(task).not.toBeNull();\n      expect(task!.payload).toBe('task');\n    });\n  });\n\n  // ── Phase 3: Priority ──\n\n  describe('Phase 3: Priority', () => {\n    it('should default priority to 5', () => {\n      const task = queue.add('task');\n      expect(task.priority).toBe(5);\n    });\n\n    it('should return higher priority tasks first', () => {\n      queue.add('low', { priority: 10 });\n      queue.add('high', { priority: 1 });\n      queue.add('medium', { priority: 5 });\n\n      expect(queue.next()!.payload).toBe('high');\n      expect(queue.next()!.payload).toBe('medium');\n      expect(queue.next()!.payload).toBe('low');\n    });\n\n    it('should maintain FIFO within same priority', () => {\n      queue.add('first', { priority: 5 });\n      queue.add('second', { priority: 5 });\n      queue.add('third', { priority: 5 });\n\n      expect(queue.next()!.payload).toBe('first');\n      expect(queue.next()!.payload).toBe('second');\n      expect(queue.next()!.payload).toBe('third');\n    });\n\n    it('should reject invalid priorities', () => {\n      expect(() => queue.add('task', { priority: 0 })).toThrow();\n      expect(() => queue.add('task', { priority: 11 })).toThrow();\n      expect(() => queue.add('task', { priority: 1.5 })).toThrow();\n    });\n\n    it('should expose priority on task object', () => {\n      const task = queue.add('task', { priority: 3 });\n      expect(task.priority).toBe(3);\n    });\n\n    it('should maintain priority per queue', () => {\n      queue.add('low-email', { queue: 'email', priority: 10 });\n      queue.add('high-email', { queue: 'email', priority: 1 });\n      queue.add('low-sms', { queue: 'sms', priority: 10 });\n      queue.add('high-sms', { queue: 'sms', priority: 1 });\n\n      expect(queue.next('email')!.payload).toBe('high-email');\n      expect(queue.next('sms')!.payload).toBe('high-sms');\n    });\n  });\n\n  // ── Phase 4: Delayed Tasks ──\n\n  describe('Phase 4: Delayed and Scheduled Tasks', () => {\n    it('should delay tasks by milliseconds', () => {\n      queue.add('delayed', { delay: 10000 });\n      expect(queue.next()).toBeNull(); // Not available yet\n    });\n\n    it('should make delayed tasks available after time passes', () => {\n      const task = queue.add('delayed', { delay: 0 }); // 0ms delay = available now\n      expect(task.availableAt).toBeInstanceOf(Date);\n      const next = queue.next();\n      expect(next).not.toBeNull();\n    });\n\n    it('should accept specific future time', () => {\n      const futureTime = new Date(Date.now() + 10000);\n      queue.add('scheduled', { availableAt: futureTime });\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should prefer non-delayed tasks over not-yet-available delayed tasks', () => {\n      queue.add('delayed', { delay: 10000, priority: 1 });\n      queue.add('immediate', { priority: 5 });\n\n      const next = queue.next();\n      expect(next!.payload).toBe('immediate');\n    });\n\n    it('should order delayed tasks by availability then priority then FIFO', () => {\n      const now = Date.now();\n      queue.add('later', { availableAt: new Date(now - 100), priority: 5 });\n      queue.add('earlier', { availableAt: new Date(now - 200), priority: 5 });\n\n      expect(queue.next()!.payload).toBe('earlier');\n      expect(queue.next()!.payload).toBe('later');\n    });\n\n    it('should indicate availability time on task', () => {\n      const futureTime = new Date(Date.now() + 5000);\n      const task = queue.add('task', { availableAt: futureTime });\n      expect(task.availableAt).toEqual(futureTime);\n    });\n\n    it('should work with named queues', () => {\n      queue.add('delayed', { queue: 'work', delay: 10000 });\n      expect(queue.next('work')).toBeNull();\n    });\n  });\n\n  // ── Phase 5: Retry with Backoff ──\n\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should mark task as completed', () => {\n      queue.add('task');\n      const task = queue.next()!;\n      queue.complete(task.id);\n      expect(queue.getTask(task.id)!.status).toBe('completed');\n    });\n\n    it('should mark task as failed and retry with backoff', () => {\n      queue.add('task', { maxRetries: 3 });\n      const task = queue.next()!;\n\n      queue.fail(task.id, new Error('oops'));\n      const updatedTask = queue.getTask(task.id)!;\n\n      expect(updatedTask.status).toBe('pending');\n      expect(updatedTask.failureCount).toBe(1);\n      // Should have exponential backoff delay\n      expect(updatedTask.availableAt.getTime()).toBeGreaterThan(Date.now());\n    });\n\n    it('should use exponential backoff: baseDelay * 2^(attempt-1)', () => {\n      queue.add('task', { maxRetries: 3, backoffDelay: 1000 });\n      const task = queue.next()!;\n\n      const beforeFail = Date.now();\n      queue.fail(task.id, new Error('fail'));\n\n      const updated = queue.getTask(task.id)!;\n      // First retry: 1000 * 2^0 = 1000ms\n      const expectedDelay = 1000;\n      const actualDelay = updated.availableAt.getTime() - beforeFail;\n      expect(actualDelay).toBeGreaterThanOrEqual(expectedDelay - 50);\n      expect(actualDelay).toBeLessThanOrEqual(expectedDelay + 100);\n    });\n\n    it('should default to 3 retries and 1000ms backoff', () => {\n      const task = queue.add('task');\n      expect(task.maxRetries).toBe(3);\n      expect(task.backoffDelay).toBe(1000);\n    });\n\n    it('should configure retries per task', () => {\n      const task = queue.add('task', { maxRetries: 5, backoffDelay: 500 });\n      expect(task.maxRetries).toBe(5);\n      expect(task.backoffDelay).toBe(500);\n    });\n\n    it('should track attempt count', () => {\n      queue.add('task', { maxRetries: 3, backoffDelay: 0 });\n      const task = queue.next()!;\n      expect(task.attempt).toBe(1);\n    });\n\n    it('should keep original queue and priority on retry', () => {\n      queue.add('task', { queue: 'myqueue', priority: 2, maxRetries: 3 });\n      const task = queue.next('myqueue')!;\n      queue.fail(task.id);\n\n      const updated = queue.getTask(task.id)!;\n      expect(updated.queue).toBe('myqueue');\n      expect(updated.priority).toBe(2);\n    });\n\n    it('should move to failed state when retries exhausted', () => {\n      queue.add('task', { maxRetries: 1, backoffDelay: 0 });\n\n      // Attempt 1\n      const task = queue.next()!;\n      queue.fail(task.id, new Error('fail'));\n\n      // The task now has no more retries (1 attempt used, maxRetries = 1)\n      const updated = queue.getTask(task.id)!;\n      expect(updated.status).toBe('dead-lettered'); // moved to DLQ\n    });\n  });\n\n  // ── Phase 6: Dead Letter Queue ──\n\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move task to DLQ when retries exhausted', () => {\n      queue.add('task', { maxRetries: 1, backoffDelay: 0 });\n      const task = queue.next()!;\n      queue.fail(task.id, new Error('permanent failure'));\n\n      const dlq = queue.getDeadLetterQueue();\n      expect(dlq.length).toBe(1);\n      expect(dlq[0].id).toBe(task.id);\n      expect(dlq[0].status).toBe('dead-lettered');\n    });\n\n    it('should retain error information', () => {\n      queue.add('task', { maxRetries: 1 });\n      const task = queue.next()!;\n      queue.fail(task.id, new Error('some error'));\n\n      const dlq = queue.getDeadLetterQueue();\n      expect(dlq[0].error).toBeInstanceOf(Error);\n      expect(dlq[0].error!.message).toBe('some error');\n    });\n\n    it('should track failure count', () => {\n      queue.add('task', { maxRetries: 1 });\n      const task = queue.next()!;\n      queue.fail(task.id, new Error('fail'));\n\n      const dlq = queue.getDeadLetterQueue();\n      expect(dlq[0].failureCount).toBe(1);\n    });\n\n    it('should retry a dead-lettered task', () => {\n      queue.add('task', { maxRetries: 1 });\n      const task = queue.next()!;\n      queue.fail(task.id, new Error('fail'));\n\n      const retried = queue.retryDeadLetter(task.id);\n      expect(retried.status).toBe('pending');\n      expect(retried.attempt).toBe(0);\n      expect(queue.getDeadLetterQueue().length).toBe(0);\n    });\n\n    it('should clear dead letter queue', () => {\n      queue.add('task1', { maxRetries: 1 });\n      queue.add('task2', { maxRetries: 1 });\n\n      const t1 = queue.next()!;\n      queue.fail(t1.id);\n      const t2 = queue.next()!;\n      queue.fail(t2.id);\n\n      expect(queue.getDeadLetterQueue().length).toBe(2);\n      queue.clearDeadLetterQueue();\n      expect(queue.getDeadLetterQueue().length).toBe(0);\n    });\n\n    it('should have independent DLQs per queue', () => {\n      queue.add('email', { queue: 'emails', maxRetries: 1 });\n      queue.add('sms', { queue: 'sms', maxRetries: 1 });\n\n      const t1 = queue.next('emails')!;\n      queue.fail(t1.id);\n      const t2 = queue.next('sms')!;\n      queue.fail(t2.id);\n\n      expect(queue.getDeadLetterQueue('emails').length).toBe(1);\n      expect(queue.getDeadLetterQueue('sms').length).toBe(1);\n    });\n  });\n\n  // ── Phase 7: Task Dependencies ──\n\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block tasks with unresolved dependencies', () => {\n      const dep = queue.add('dependency');\n      queue.add('dependent', { dependencies: [dep.id] });\n\n      // Should only get the dependency, not the dependent\n      const next = queue.next();\n      expect(next!.payload).toBe('dependency');\n      expect(queue.next()).toBeNull(); // dependent is blocked\n    });\n\n    it('should unblock tasks when dependency completes', () => {\n      const dep = queue.add('dependency');\n      queue.add('dependent', { dependencies: [dep.id] });\n\n      const task = queue.next()!;\n      queue.complete(task.id);\n\n      const next = queue.next();\n      expect(next).not.toBeNull();\n      expect(next!.payload).toBe('dependent');\n    });\n\n    it('should error on non-existent dependency', () => {\n      expect(() =>\n        queue.add('task', { dependencies: ['nonexistent-id'] })\n      ).toThrow();\n    });\n\n    it('should keep dependents blocked when dependency fails', () => {\n      const dep = queue.add('dependency', { maxRetries: 1 });\n      queue.add('dependent', { dependencies: [dep.id] });\n\n      const task = queue.next()!;\n      queue.fail(task.id, new Error('fail')); // exhausts retries\n\n      // Dependent should remain blocked\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should inspect dependency status', () => {\n      const dep1 = queue.add('dep1');\n      const dep2 = queue.add('dep2');\n      const dependent = queue.add('dependent', { dependencies: [dep1.id, dep2.id] });\n\n      const status = queue.getDependencyStatus(dependent.id);\n      expect(status.dependencies).toHaveLength(2);\n      expect(status.resolved).toHaveLength(0);\n      expect(status.blocked).toBe(true);\n\n      // Complete dep1\n      const t1 = queue.next()!;\n      queue.complete(t1.id);\n\n      const status2 = queue.getDependencyStatus(dependent.id);\n      expect(status2.resolved).toHaveLength(1);\n      expect(status2.blocked).toBe(true);\n    });\n\n    it('should support multiple dependencies', () => {\n      const dep1 = queue.add('dep1');\n      const dep2 = queue.add('dep2');\n      queue.add('dependent', { dependencies: [dep1.id, dep2.id] });\n\n      // Process dep1\n      const t1 = queue.next()!;\n      queue.complete(t1.id);\n      // Dependent is still blocked (dep2 not done)\n      const t2 = queue.next()!;\n      expect(t2.payload).toBe('dep2');\n      queue.complete(t2.id);\n\n      // Now dependent should be available\n      const dep = queue.next()!;\n      expect(dep.payload).toBe('dependent');\n    });\n  });\n\n  // ── Phase 8: Concurrency Control ──\n\n  describe('Phase 8: Concurrency Control', () => {\n    it('should default to no concurrency limit', () => {\n      const info = queue.getConcurrency();\n      expect(info.limit).toBe(0); // 0 = unlimited\n    });\n\n    it('should enforce concurrency limit', () => {\n      queue.setConcurrency('default', 2);\n\n      queue.add('task1');\n      queue.add('task2');\n      queue.add('task3');\n\n      expect(queue.next()).not.toBeNull();\n      expect(queue.next()).not.toBeNull();\n      expect(queue.next()).toBeNull(); // Limit reached\n    });\n\n    it('should free slot when task completes', () => {\n      queue.setConcurrency('default', 1);\n\n      queue.add('task1');\n      queue.add('task2');\n\n      const t1 = queue.next()!;\n      expect(queue.next()).toBeNull(); // Limit reached\n\n      queue.complete(t1.id);\n      expect(queue.next()).not.toBeNull(); // Slot freed\n    });\n\n    it('should free slot when task fails', () => {\n      queue.setConcurrency('default', 1);\n\n      queue.add('task1', { maxRetries: 1 });\n      queue.add('task2');\n\n      const t1 = queue.next()!;\n      expect(queue.next()).toBeNull();\n\n      queue.fail(t1.id, new Error('fail')); // Exhausts retries, frees slot\n      expect(queue.next()).not.toBeNull();\n    });\n\n    it('should query concurrency state', () => {\n      queue.setConcurrency('default', 3);\n      queue.add('task1');\n      queue.add('task2');\n\n      queue.next();\n\n      const info = queue.getConcurrency();\n      expect(info.limit).toBe(3);\n      expect(info.active).toBe(1);\n    });\n\n    it('should interact correctly with priority', () => {\n      queue.setConcurrency('default', 1);\n\n      queue.add('low', { priority: 10 });\n      queue.add('high', { priority: 1 });\n\n      const task = queue.next()!;\n      expect(task.payload).toBe('high');\n    });\n  });\n\n  // ── Phase 9: Progress & Cancellation ──\n\n  describe('Phase 9: Progress Tracking and Cancellation', () => {\n    it('should update and query progress', () => {\n      queue.add('task');\n      const task = queue.next()!;\n\n      queue.updateProgress(task.id, 50, 'halfway');\n      const progress = queue.getProgress(task.id);\n      expect(progress.progress).toBe(50);\n      expect(progress.message).toBe('halfway');\n    });\n\n    it('should subscribe to progress updates', () => {\n      queue.add('task');\n      const task = queue.next()!;\n\n      const updates: number[] = [];\n      queue.onProgress(task.id, (progress) => {\n        updates.push(progress);\n      });\n\n      queue.updateProgress(task.id, 25);\n      queue.updateProgress(task.id, 50);\n      queue.updateProgress(task.id, 100);\n\n      expect(updates).toEqual([25, 50, 100]);\n    });\n\n    it('should unsubscribe from progress', () => {\n      queue.add('task');\n      const task = queue.next()!;\n\n      const updates: number[] = [];\n      const unsub = queue.onProgress(task.id, (progress) => {\n        updates.push(progress);\n      });\n\n      queue.updateProgress(task.id, 25);\n      unsub();\n      queue.updateProgress(task.id, 50);\n\n      expect(updates).toEqual([25]);\n    });\n\n    it('should cancel pending tasks', () => {\n      const task = queue.add('task');\n      queue.cancel(task.id);\n\n      expect(queue.getTask(task.id)!.status).toBe('cancelled');\n      expect(queue.next()).toBeNull(); // Removed from queue\n    });\n\n    it('should cancel processing tasks', () => {\n      queue.add('task');\n      const task = queue.next()!;\n      queue.cancel(task.id);\n\n      expect(queue.getTask(task.id)!.status).toBe('cancelled');\n    });\n\n    it('should not retry cancelled tasks', () => {\n      queue.add('task', { maxRetries: 3 });\n      const task = queue.next()!;\n      queue.cancel(task.id);\n\n      expect(queue.getTask(task.id)!.status).toBe('cancelled');\n      // Should not be back in queue\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should reject invalid progress values', () => {\n      queue.add('task');\n      const task = queue.next()!;\n\n      expect(() => queue.updateProgress(task.id, -1)).toThrow();\n      expect(() => queue.updateProgress(task.id, 101)).toThrow();\n    });\n  });\n\n  // ── Phase 10: Recurring Tasks ──\n\n  describe('Phase 10: Recurring Tasks', () => {\n    it('should add and list schedules', () => {\n      queue.addSchedule('every5', '*/5 * * * *', 'default', { type: 'check' });\n      const schedules = queue.getSchedules();\n      expect(schedules).toHaveLength(1);\n      expect(schedules[0].id).toBe('every5');\n    });\n\n    it('should remove schedules', () => {\n      queue.addSchedule('every5', '*/5 * * * *', 'default', { type: 'check' });\n      queue.removeSchedule('every5');\n      expect(queue.getSchedules()).toHaveLength(0);\n    });\n\n    it('should enqueue tasks on tick when due', () => {\n      queue.addSchedule('hourly', '0 * * * *', 'default', { type: 'hourly' });\n\n      // Tick at exactly on the hour\n      const onTheHour = new Date('2024-01-15T14:00:00');\n      const tasks = queue.tick(onTheHour);\n      expect(tasks).toHaveLength(1);\n      expect(tasks[0].payload).toEqual({ type: 'hourly' });\n    });\n\n    it('should not enqueue when not due', () => {\n      queue.addSchedule('hourly', '0 * * * *', 'default', { type: 'hourly' });\n\n      // Tick at 14:30 - not on the hour\n      const notOnHour = new Date('2024-01-15T14:30:00');\n      const tasks = queue.tick(notOnHour);\n      expect(tasks).toHaveLength(0);\n    });\n\n    it('should support every-N-minutes syntax', () => {\n      queue.addSchedule('every5', '*/5 * * * *', 'default', { type: 'check' });\n\n      // Tick at 14:05 - divisible by 5\n      const tasks = queue.tick(new Date('2024-01-15T14:05:00'));\n      expect(tasks).toHaveLength(1);\n\n      // Tick at 14:07 - not divisible by 5\n      const tasks2 = queue.tick(new Date('2024-01-15T14:07:00'));\n      expect(tasks2).toHaveLength(0);\n    });\n\n    it('should support daily midnight syntax', () => {\n      queue.addSchedule('daily', '0 0 * * *', 'default', { type: 'daily' });\n\n      const midnight = new Date('2024-01-15T00:00:00');\n      expect(queue.tick(midnight)).toHaveLength(1);\n\n      const noon = new Date('2024-01-15T12:00:00');\n      expect(queue.tick(noon)).toHaveLength(0);\n    });\n\n    it('should prevent duplicate runs in same minute', () => {\n      queue.addSchedule('hourly', '0 * * * *', 'default', { type: 'hourly' });\n\n      const t = new Date('2024-01-15T14:00:00');\n      queue.tick(t);\n      const tasks2 = queue.tick(t); // Same time\n      expect(tasks2).toHaveLength(0);\n    });\n\n    it('should stop creating tasks after schedule removal', () => {\n      queue.addSchedule('every5', '*/5 * * * *', 'default', { type: 'check' });\n      queue.removeSchedule('every5');\n\n      const tasks = queue.tick(new Date('2024-01-15T14:05:00'));\n      expect(tasks).toHaveLength(0);\n    });\n\n    it('enqueued recurring tasks follow all queue rules', () => {\n      queue.addSchedule('hourly', '0 * * * *', 'work', { type: 'hourly' }, { priority: 2 });\n      queue.tick(new Date('2024-01-15T14:00:00'));\n\n      const task = queue.next('work');\n      expect(task).not.toBeNull();\n      expect(task!.priority).toBe(2);\n    });\n  });\n\n  // ── Phase 11: Middleware Pipeline ──\n\n  describe('Phase 11: Middleware Pipeline', () => {\n    it('should run middleware in order before handler', async () => {\n      const order: string[] = [];\n\n      queue.use('default', async (_task, next) => {\n        order.push('mw1');\n        await next();\n      });\n      queue.use('default', async (_task, next) => {\n        order.push('mw2');\n        await next();\n      });\n      queue.setHandler('default', async () => {\n        order.push('handler');\n      });\n\n      queue.add('task');\n      await queue.process();\n\n      expect(order).toEqual(['mw1', 'mw2', 'handler']);\n    });\n\n    it('should skip processing when middleware does not call next', async () => {\n      const handlerCalled = vi.fn();\n\n      queue.use('default', async () => {\n        // Don't call next\n      });\n      queue.setHandler('default', async () => {\n        handlerCalled();\n      });\n\n      queue.add('task');\n      await queue.process();\n\n      expect(handlerCalled).not.toHaveBeenCalled();\n    });\n\n    it('should allow middleware to modify task', async () => {\n      queue.use('