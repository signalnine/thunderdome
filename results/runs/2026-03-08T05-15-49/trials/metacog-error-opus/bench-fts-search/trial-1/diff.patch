from 'supertest';\nimport { createSeededApp } from '../src/server.js';\nimport type { App } from '../src/server.js';\n\ndescribe('Search', () => {\n  let appCtx: App;\n\n  beforeEach(() => {\n    appCtx = createSeededApp();\n  });\n\n  afterEach(() => {\n    appCtx.db.close();\n  });\n\n  // 1. GET /notes/search?q=keyword returns matching notes\n  it('GET /notes/search?q=keyword returns matching notes', async () => {\n    const res = await request(appCtx.app).get('/notes/search?q=python');\n    expect(res.status).toBe(200);\n    expect(res.body.results.length).toBeGreaterThan(0);\n  });\n\n  // 2. GET /notes/search?q=keyword results have snippet field\n  it('GET /notes/search?q=keyword results have snippet field', async () => {\n    const res = await request(appCtx.app).get('/notes/search?q=python');\n    expect(res.status).toBe(200);\n    expect(res.body.results[0]).toHaveProperty('snippet');\n    expect(typeof res.body.results[0].snippet).toBe('string');\n  });\n\n  // 3. Snippets contain <mark> tags around matched terms\n  it('Snippets contain <mark> tags around matched terms', async () => {\n    const res = await request(appCtx.app).get('/notes/search?q=python');\n    expect(res.status).toBe(200);\n    const snippet = res.body.results[0].snippet;\n    expect(snippet).toContain('<mark>');\n    expect(snippet).toContain('</mark>');\n  });\n\n  // 4. Results are ranked by relevance (most relevant first)\n  it('Results are ranked by relevance (most relevant first)', async () => {\n    const res = await request(appCtx.app).get('/notes/search?q=programming');\n    expect(res.status).toBe(200);\n    expect(res.body.results.length).toBeGreaterThan(1);\n    // rank values should be in ascending order (lower rank = more relevant in FTS5)\n    for (let i = 1; i < res.body.results.length; i++) {\n      expect(res.body.results[i].rank).toBeGreaterThanOrEqual(res.body.results[i - 1].rank);\n    }\n  });\n\n  // 5. GET /notes/search?q=\"exact phrase\" matches exact phrases\n  it('GET /notes/search?q=\"exact phrase\" matches exact phrases', async () => {\n    const res = await request(appCtx.app).get('/notes/search?q=\"chocolate chip\"');\n    expect(res.status).toBe(200);\n    expect(res.body.results.length).toBeGreaterThan(0);\n    // The result should be the chocolate chip cookies note\n    const titles = res.body.results.map((r: { title: string }) => r.title);\n    expect(titles.some((t: string) => t.toLowerCase().includes('chocolate'))).toBe(true);\n  });\n\n  // 6. Search returns id, title, snippet, rank fields\n  it('Search returns id, title, snippet, rank fields', async () => {\n    const res = await request(appCtx.app).get('/notes/search?q=guitar');\n    expect(res.status).toBe(200);\n    expect(res.body.results.length).toBeGreaterThan(0);\n    const result = res.body.results[0];\n    expect(result).toHaveProperty('id');\n    expect(result).toHaveProperty('title');\n    expect(result).toHaveProperty('snippet');\n    expect(result).toHaveProperty('rank');\n    expect(typeof result.id).toBe('number');\n    expect(typeof result.title).toBe('string');\n    expect(typeof result.snippet).toBe('string');\n    expect(typeof result.rank).toBe('number');\n  });\n\n  // 7. GET /notes/search?q=nonexistent returns empty array\n  it('GET /notes/search?q=nonexistent returns empty array', async () => {\n    const res = await request(appCtx.app).get('/notes/search?q=xyznonexistentterm');\n    expect(res.status).toBe(200);\n    expect(res.body.results).toEqual([]);\n  });\n\n  // 8. GET /notes/search without q returns 400\n  it('GET /notes/search without q returns 400', async () => {\n    const res = await request(appCtx.app).get('/notes/search');\n    expect(res.status).toBe(400);\n  });\n\n  // 9. GET /notes/search?q= (empty) returns 400\n  it('GET /notes/search?q= (empty) returns 400', async () => {\n    const res = await request(appCtx.app).get('/notes/search?q=');\n    expect(res.status).toBe(400);\n  });\n\n  // 10. Pagination: page=1 return