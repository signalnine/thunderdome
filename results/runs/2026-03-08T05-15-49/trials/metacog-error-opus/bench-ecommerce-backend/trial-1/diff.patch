te quantity', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.updateQuantity(id, 'p1', 10);\n    expect(cart.getCart(id)!.items[0].quantity).toBe(10);\n  });\n\n  it('should clear cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.clearCart(id);\n    expect(cart.getCart(id)!.items).toHaveLength(0);\n  });\n\n  it('should return null for unknown cart', () => {\n    const cart = createCartService(bus);\n    expect(cart.getCart('nonexistent')).toBeNull();\n  });\n});\n\ndescribe('Pricing Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should calculate total with tax', () => {\n    const pricing = createPricingService(bus);\n    const result = pricing.calculateTotal([\n      { productId: 'p1', quantity: 2, price: 10 },\n    ]);\n    expect(result.subtotal).toBe(20);\n    expect(result.discount).toBe(0);\n    expect(result.tax).toBe(2); // 10% of 20\n    expect(result.total).toBe(22);\n  });\n\n  it('should apply discount code before tax', () => {\n    const pricing = createPricingService(bus);\n    pricing.addDiscountCode('SAVE10', 10);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'SAVE10'\n    );\n    expect(result.subtotal).toBe(100);\n    expect(result.discount).toBe(10); // 10% of 100\n    expect(result.tax).toBe(9); // 10% of (100-10)=90\n    expect(result.total).toBe(99); // 90 + 9\n  });\n\n  it('should track prices from product events', async () => {\n    const pricing = createPricingService(bus);\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'Widget', price: 25, category: 'gadgets' });\n    expect(pricing.getPrice('p1')).toBe(25);\n  });\n\n  it('should return 0 for unknown product price', () => {\n    const pricing = createPricingService(bus);\n    expect(pricing.getPrice('unknown')).toBe(0);\n  });\n\n  it('should ignore unknown discount code', () => {\n    const pricing = createPricingService(bus);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'INVALID'\n    );\n    expect(result.discount).toBe(0);\n    expect(result.total).toBe(110);\n  });\n});\n\ndescribe('Order Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should create an order in PENDING status', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 100);\n    const order = orders.getOrder(id);\n    expect(order).not.toBeNull();\n    expect(order!.status).toBe(OrderStatus.PENDING);\n    expect(order!.total).toBe(100);\n  });\n\n  it('should update order status', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 100);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.CONFIRMED);\n  });\n\n  it('should emit ORDER_CREATED and ORDER_STATUS_CHANGED events', async () => {\n    const orders = createOrderService(bus);\n    const created: unknown[] = [];\n    const statusChanged: unknown[] = [];\n    bus.on(Events.ORDER_CREATED, (p) => { created.push(p); });\n    bus.on(Events.ORDER_STATUS_CHANGED, (p) => { statusChanged.push(p); });\n    const id = orders.createOrder('user1', 'cart1', 100);\n    await new Promise(r => setTimeout(r, 10));\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    await new Promise(r => setTimeout(r, 10));\n    expect(created).toHaveLength(1);\n    expect(statusChanged).toHaveLength(1);\n    const sc = statusChanged[0] as { previousStatus: string };\n    expect(sc.previousStatus).toBe(OrderStatus.PENDING);\n  });\n\n  it('should list orders by user', () => {\n    const orders = createOrderService(bus);\n    orders.createOrder('user1', 'c1', 50);\n    orders.createOrder('user1', 'c2', 75);\n    orders.createOrder('user2', 'c3', 100);\n    expect(orders.listOrders('user1')).toHaveLength(2);\n    expect(orders.listOrders('user2')).toHaveLength(1);\n  });\n\n  it('should return null for unknown order', () => {\n    const orders = createOrderService(bus);\n    expect(orders.getOrder('nonexistent')).toBeNull();\n  });\n});\n\ndescribe('Payment Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should process a successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.SUCCESS);\n    expect(result.transactionId).toBeDefined();\n  });\n\n  it('should simulate failure', async () => {\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.FAILED);\n    expect(result.error).toBeDefined();\n  });\n\n  it('should simulate timeout', async () => {\n    const payment = createPaymentService(bus, { simulateTimeout: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.TIMEOUT);\n    expect(result.error).toBeDefined();\n  });\n\n  it('should refund a successful transaction', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    const refunded = await payment.refund(result.transactionId!);\n    expect(refunded).toBe(true);\n  });\n\n  it('should not refund a nonexistent transaction', async () => {\n    const payment = createPaymentService(bus);\n    const refunded = await payment.refund('nonexistent');\n    expect(refunded).toBe(false);\n  });\n\n  it('should emit payment:processed event', async () => {\n    const payment = createPaymentService(bus);\n    const events: unknown[] = [];\n    bus.on(Events.PAYMENT_PROCESSED, (p) => { events.push(p); });\n    await payment.processPayment('order1', 100);\n    expect(events).toHaveLength(1);\n  });\n});\n\ndescribe('Notification Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should deliver notifications to subscribed users', async () => {\n    const notifications = createNotificationService(bus);\n    notifications.subscribe('user1');\n\n    // Simulate order creation\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThanOrEqual(1);\n    expect(notifs[0].type).toBe('order_created');\n  });\n\n  it('should not deliver notifications to unsubscribed users', async () => {\n    const notifications = createNotificationService(bus);\n    // not subscribed\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n    expect(notifications.getNotifications('user1')).toHaveLength(0);\n  });\n\n  it('should track order-user mapping for status changes', async () => {\n    const notifications = createNotificationService(bus);\n    notifications.subscribe('user1');\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.ORDER_STATUS_CHANGED, { orderId: 'o1', status: 'confirmed', previousStatus: 'pending' });\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThanOrEqual(2);\n  });\n\n  it('should notify on payment events', async () => {\n    const notifications = createNotificationService(bus);\n    notifications.subscribe('user1');\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: 'success', transactionId: 'tx1' });\n    const notifs = notifications.getNotifications('user1');\n    const paymentNotifs = notifs.filter(n => n.type === 'payment');\n    expect(paymentNotifs).toHaveLength(1);\n  });\n});\n\ndescribe('Analytics Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should count events by type', async () => {\n    const analytics = createAnalyticsService(bus);\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'W', price: 10, category: 'c' });\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p2', name: 'X', price: 20, category: 'c' });\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n  });\n\n  it('should calculate conversion rate', async () => {\n    const analytics = createAnalyticsService(bus);\n    // 2 unique carts\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [] });\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c2', userId: 'u2', items: [] });\n    // 1 order\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 50 });\n    expect(analytics.getConversionRate()).toBe(0.5);\n  });\n\n  it('should return 0 conversion rate with no carts', () => {\n    const analytics = createAnalyticsService(bus);\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n\n  it('should return 0 revenue initially', () => {\n    const analytics = createAnalyticsService(bus);\n    expect(analytics.getRevenue()).toBe(0);\n  });\n});\n\ndescribe('Integration: Full Order Flow', () => {\n  it('should handle a complete order lifecycle', async () => {\n    const bus = new EventBus();\n\n    // Create all services\n    const catalog = createCatalogService(bus);\n    const inventory = createInventoryService(bus);\n    const cart = createCartService(bus);\n    const pricing = createPricingService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    const notifications = createNotificationService(bus);\n    const analytics = createAnalyticsService(bus);\n\n    // Subscribe user for notifications\n    notifications.subscribe('user1');\n\n    // Create product\n    const productId = catalog.createProduct('Laptop', 999.99, 'electronics');\n    await new Promise(r => setTimeout(r, 10));\n\n    // Set stock\n    inventory.setStock(productId, 50);\n\n    // Verify pricing picked up the product price\n    expect(pricing.getPrice(productId)).toBe(999.99);\n\n    // Create cart and add items\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, productId, 1);\n\n    // Reserve stock\n    expect(inventory.reserve(productId, 1)).toBe(true);\n\n    // Calculate total\n    const cartData = cart.getCart(cartId)!;\n    const items = cartData.items.map(i => ({\n      productId: i.productId,\n      quantity: i.quantity,\n      price: pricing.getPrice(i.productId),\n    }));\n    const totals = pricing.calculateTotal(items);\n    expect(totals.total).toBeCloseTo(1099.99, 2);\n\n    // Create order\n    const orderId = orders.createOrder('user1', cartId, totals.total);\n    await new Promise(r => setTimeout(r, 10));\n\n    // Process payment\n    const paymentResult = await payment.processPayment(orderId, totals.total);\n    expect(paymentResult.status).toBe(PaymentStatus.SUCCESS);\n\n    // Update order status\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    await new Promise(r => setTimeout(r, 10));\n\n    // Check notifications\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThanOrEqual(2); // at least order_created + status_changed\n\n    // Check analytics\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBeGreaterThanOrEqual(1);\n    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBeGreaterThanOrEqual(1);\n\n    // Verify order state\n    const order = orders.getOrder(orderId)!;\n    expect(order.status).toBe(OrderStat