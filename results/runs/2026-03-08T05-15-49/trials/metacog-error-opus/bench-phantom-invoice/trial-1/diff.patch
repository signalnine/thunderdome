ustomer_id,\n    48→    date: input.date,\n    49→    subtotal,\n    50→    discount_rate: input.discount_rate,\n    51→    tax_rate: input.tax_rate,\n    52→    total,\n    53→    status: input.status || 'draft',\n    54→    line_items: input.line_items,\n    55→  };\n    56→\n    57→  return createInvoice(db, invoice);\n    58→}\n    59→"}]},"parent_tool_use_id":null,"session_id":"478dec3c-8f52-41c4-9872-76927a136609","uuid":"6f1706b2-318e-4e76-83ae-6ec66df42ae5","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/services/billing.ts","content":"import type Database from 'better-sqlite3';\nimport type { InvoiceCreateInput, Invoice, LineItem } from '../models/invoice.js';\nimport { createInvoice } from '../db/queries.js';\n\n/**\n * Calculate the total for an invoice given subtotal, discount rate, and tax rate.\n *\n * Formula: subtotal * (1 - discountRate) * (1 + taxRate)\n *   - First apply the discount to get the discounted subtotal\n *   - Then apply tax on the discounted amount\n */\nexport function calculateInvoiceTotal(\n  subtotal: number,\n  discountRate: number,\n  taxRate: number,\n): number {\n  const discounted = subtotal * (1 - discountRate);\n  const total = discounted + subtotal * taxRate;\n  return Math.round(total * 100) / 100;\n}\n\n/**\n * Apply a discount to a subtotal.\n */\nexport function applyDiscount(subtotal: number, discountRate: number): number {\n  return Math.round(subtotal * (1 - discountRate) * 100) / 100;\n}\n\n/**\n * Calculate subtotal from line items.\n */\nexport function calculateSubtotal(lineItems: LineItem[]): number {\n  return lineItems.reduce((sum, item) => sum + item.quantity * item.unit_price, 0);\n}\n\n/**\n * Generate an invoice from input data, calculating subtotal and total.\n */\nexport function generateInvoice(\n  db: Database.Database,\n  input: InvoiceCreateInput,\n): number {\n  const subtotal = calculateSubtotal(input.line_items);\n  const total = calculateInvoiceTotal(subtotal, input.discount_rate, input.tax_rate);\n\n  const invoice: Invoice & { line_items: LineItem[] } = {\n    customer_id: input.customer_id,\n    date: input.date,\n    subtotal,\n    discount_rate: input.discount_rate,\n    tax_rate: input.tax_rate,\n    total,\n    status: input.status || 'draft',\n    line_items: input.line_items,\n  };\n\n  return createInvoice(db, invoice);\n}\n","numLines":59,"startLine":1,"totalLines":59}}}
