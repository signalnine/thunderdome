b)!;\n    return eventB.duration - eventA.duration;\n  });\n\n  // Use backtracking to maximize scheduled events\n  const bestResult = backtrackSchedule(\n    eventIds,\n    eventMap,\n    rooms,\n    options,\n    gap,\n    validRoomsCount\n  );\n\n  return bestResult;\n}\n\nfunction backtrackSchedule(\n  eventIds: string[],\n  eventMap: Map<string, Event>,\n  rooms: Room[],\n  options: ScheduleOptions,\n  gap: number,\n  validRoomsCount: Map<string, number>\n): ScheduleResult {\n  const roomAssignments = new Map<string, Assignment[]>();\n  for (const room of rooms) {\n    roomAssignments.set(room.id, []);\n  }\n  const eventAssignments = new Map<string, Assignment>();\n  const assignments: Assignment[] = [];\n  const unscheduled: string[] = [];\n\n  // Check if all prerequisites of an event are scheduled\n  function prereqsSatisfied(eventId: string): boolean {\n    const event = eventMap.get(eventId)!;\n    for (const prereqId of event.prerequisites ?? []) {\n      if (eventMap.has(prereqId) && !eventAssignments.has(prereqId)) {\n        return false;\n      }\n    }\n    return true;\n  }\n\n  // Order rooms for an event: preferred room first, then by capacity (smallest sufficient first)\n  function getRoomOrder(event: Event): Room[] {\n    const attendees = event.attendees ?? 1;\n    const validRooms = rooms\n      .filter((r) => r.capacity >= attendees)\n      .sort((a, b) => a.capacity - b.capacity);\n\n    if (event.preferredRoom) {\n      const prefIdx = validRooms.findIndex(\n        (r) => r.id === event.preferredRoom\n      );\n      if (prefIdx > 0) {\n        const [pref] = validRooms.splice(prefIdx, 1);\n        validRooms.unshift(pref);\n      }\n    }\n\n    return validRooms;\n  }\n\n  // Try to schedule each event greedily first\n  for (const eventId of eventIds) {\n    const event = eventMap.get(eventId)!;\n\n    if (!prereqsSatisfied(eventId)) {\n      unscheduled.push(eventId);\n      continue;\n    }\n\n    const roomOrder = getRoomOrder(event);\n    let placed = false;\n\n    for (const room of roomOrder) {\n      const startTime = findEarliestStart(\n        event,\n        room,\n        roomAssignments,\n        eventAssignments,\n        options,\n        gap\n      );\n\n      if (startTime !== null) {\n        const assignment: Assignment = {\n          eventId,\n          roomId: room.id,\n          startTime,\n          endTime: startTime + event.duration,\n        };\n        assignments.push(assignment);\n        roomAssignments.get(room.id)!.push(assignment);\n        eventAssignments.set(eventId, assignment);\n        placed = true;\n        break;\n      }\n    }\n\n    if (!placed) {\n      unscheduled.push(eventId);\n    }\n  }\n\n  // If everything was scheduled, return immediately\n  if (unscheduled.length === 0) {\n    return { assignments, unscheduled };\n  }\n\n  // Try to improve by attempting different placement strategies\n  // for unscheduled events via rescheduling\n  const improved = tryImproveSchedule(\n    eventIds,\n    eventMap,\n    rooms,\n    options,\n    gap,\n    assignments,\n    unscheduled,\n    validRoomsCount\n  );\n\n  return improved;\n}\n\nfunction tryImproveSchedule(\n  eventIds: string[],\n  eventMap: Map<string, Event>,\n  rooms: Room[],\n  options: ScheduleOptions,\n  gap: number,\n  currentAssignments: Assignment[],\n  currentUnscheduled: string[],\n  validRoomsCount: Map<string, number>\n): ScheduleResult {\n  // Try multiple orderings and pick the one that schedules the most events\n  let bestAssignments = currentAssignments;\n  let bestUnscheduled = currentUnscheduled;\n  let bestCount = currentAssignments.length;\n\n  // Generate alternative orderings\n  const orderings: string[][] = [];\n\n  // Ordering 1: Sort by duration descending (longest first)\n  const byDuration = [...eventIds].sort((a, b) => {\n    const eventA = eventMap.get(a)!;\n    const eventB = eventMap.get(b)!;\n    return eventB.duration - eventA.duration;\n  });\n  orderings.push(topo