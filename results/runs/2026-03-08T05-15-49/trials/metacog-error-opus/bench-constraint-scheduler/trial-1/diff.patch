@@ -0,0 +1,211 @@
+import { describe, it, expect } from "vitest";
+import { schedule } from "./scheduler.js";
+import type { Event, Room, ScheduleOptions } from "./scheduler.js";
+
+const defaultOptions: ScheduleOptions = {
+  startTime: 540, // 9:00 AM
+  endTime: 1020, // 5:00 PM
+  gap: 15,
+};
+
+const rooms: Room[] = [
+  { id: "room-a", name: "Room A", capacity: 10 },
+  { id: "room-b", name: "Room B", capacity: 20 },
+  { id: "room-c", name: "Room C", capacity: 50 },
+];
+
+describe("schedule", () => {
+  it("should schedule a single event", () => {
+    const events: Event[] = [
+      { id: "e1", name: "Event 1", duration: 60 },
+    ];
+    const result = schedule(events, rooms, defaultOptions);
+    expect(result.assignments).toHaveLength(1);
+    expect(result.unscheduled).toHaveLength(0);
+    expect(result.assignments[0].eventId).toBe("e1");
+    expect(result.assignments[0].startTime).toBeGreaterThanOrEqual(540);
+    expect(result.assignments[0].endTime).toBeLessThanOrEqual(1020);
+    expect(result.assignments[0].endTime - result.assignments[0].startTime).toBe(60);
+  });
+
+  it("should schedule multiple events in the same room with gaps", () => {
+    const events: Event[] = [
+      { id: "e1", name: "Event 1", duration: 60 },
+      { id: "e2", name: "Event 2", duration: 60 },
+    ];
+    const result = schedule(events, [rooms[0]], defaultOptions);
+    expect(result.assignments).toHaveLength(2);
+    expect(result.unscheduled).toHaveLength(0);
+
+    const sorted = [...result.assignments].sort((a, b) => a.startTime - b.startTime);
+    // Gap between events should be at least 15 minutes
+    expect(sorted[1].startTime).toBeGreaterThanOrEqual(sorted[0].endTime + 15);
+  });
+
+  it("should respect room capacity", () => {
+    const smallRoom: Room[] = [{ id: "small", name: "Small", capacity: 5 }];
+    const events: Event[] = [
+      { id: "e1", name: "Event 1", duration: 60, attendees: 10 },
+    ];
+    const result = schedule(events, smallRoom, defaultOptions);
+    expect(result.assignments).toHaveLength(0);
+    expect(result.unscheduled).toEqual(["e1"]);
+  });
+
+  it("should respect time window", () => {
+    const tightOptions: ScheduleOptions = {
+      startTime: 540,
+      endTime: 570, // only 30 minutes
+    };
+    const events: Event[] = [
+      { id: "e1", name: "Event 1", duration: 60 },
+    ];
+    const result = schedule(events, rooms, tightOptions);
+    expect(result.assignments).toHaveLength(0);
+    expect(result.unscheduled).toEqual(["e1"]);
+  });
+
+  it("should respect prerequisites", () => {
+    const events: Event[] = [
+      { id: "e1", name: "Event 1", duration: 60 },
+      { id: "e2", name: "Event 2", duration: 60, prerequisites: ["e1"] },
+    ];
+    const result = schedule(events, rooms, defaultOptions);
+    expect(result.assignments).toHaveLength(2);
+
+    const a1 = result.assignments.find((a) => a.eventId === "e1")!;
+    const a2 = result.assignments.find((a) => a.eventId === "e2")!;
+    expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + 15);
+  });
+
+  it("should throw on prerequisite cycle", () => {
+    const events: Event[] = [
+      { id: "e1", name: "Event 1", duration: 60, prerequisites: ["e2"] },
+      { id: "e2", name: "Event 2", duration: 60, prerequisites: ["e1"] },
+    ];
+    expect(() => schedule(events, rooms, defaultOptions)).toThrow(/[Cc]ycle/);
+  });
+
+  it("should throw on self-reference", () => {
+    const events: Event[] = [
+      { id: "e1", name: "Event 1", duration: 60, prerequisites: ["e1"] },
+    ];
+    expect(() => schedule(events, rooms, defaultOptions)).toThrow(/[Cc]ycle/);
+  });
+
+  it("should honor preferred room when possible", () => {
+    const events: Event[] = [
+      { id: "e1", name: "Event 1", duration: 60, preferredRoom: "room-b" },
+    ];
+    const result = schedule(events, rooms, defaultOptions);
+    expect(result.assignments).toHaveLength(1);
+    expect(result.assignments[0].roomId).toBe("room-b");
+  });
+
+  it("should use default gap of 15 minutes", () => {
+    const events: Event[] = [
+      { id: "e1", name: "Event 1", duration: 60 },
+      { id: "e2", name: "Event 2", duration: 60 },
+    ];
+    const opts: ScheduleOptions = { startTime: 540, endTime: 1020 };
+    const result = schedule(events, [rooms[0]], opts);
+    expect(result.assignments).toHaveLength(2);
+
+    const sorted = [...result.assignments].sort((a, b) => a.startTime - b.startTime);
+    expect(sorted[1].startTime).toBeGreaterThanOrEqual(sorted[0].endTime + 15);
+  });
+
+  it("should return empty arrays for empty input", () => {
+    const result = schedule([], rooms, defaultOptions);
+    expect(result.assignments).toHaveLength(0);
+    expect(result.unscheduled).toHaveLength(0);
+  });
+
+  it("should default attendees to 1", () => {
+    const tinyRoom: Room[] = [{ id: "tiny", name: "Tiny", capacity: 1 }];
+    const events: Event[] = [
+      { id: "e1", name: "Event 1", duration: 60 },
+    ];
+    const result = schedule(events, tinyRoom, defaultOptions);
+    expect(result.assignments).toHaveLength(1);
+  });
+
+  it("should maximize scheduled events", () => {
+    // One room, tight window: can fit 2 short events OR 1 long event
+    // The scheduler should pick 2 short events to maximize
+    const tightOptions: ScheduleOptions = {
+      startTime: 540,
+      endTime: 690, // 150 minutes
+      gap: 15,
+    };
+    const events: Event[] = [
+      { id: "long", name: "Long Event", duration: 120 },
+      { id: "short1", name: "Short 1", duration: 60 },
+      { id: "short2", name: "Short 2", duration: 60 },
+    ];
+    const result = schedule(events, [rooms[0]], tightOptions);
+    // Should schedule 2 events (the two short ones: 60 + 15 + 60 = 135 <= 150)
+    expect(result.assignments).toHaveLength(2);
+    expect(result.unscheduled).toHaveLength(1);
+  });
+
+  it("should handle custom gap", () => {
+    const events: Event[] = [
+      { id: "e1", name: "Event 1", duration: 60 },
+      { id: "e2", name: "Event 2", duration: 60 },
+    ];
+    const opts: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 30 };
+    const result = schedule(events, [rooms[0]], opts);
+    expect(result.assignments).toHaveLength(2);
+
+    const sorted = [...result.assignments].sort((a, b) => a.startTime - b.startTime);
+    expect(sorted[1].startTime).toBeGreaterThanOrEqual(sorted[0].endTime + 30);
+  });
+
+  it("should handle prerequisites with gap", () => {
+    const events: Event[] = [
+      { id: "e1", name: "Event 1", duration: 60 },
+      { id: "e2", name: "Event 2", duration: 60, prerequisites: ["e1"] },
+    ];
+    const opts: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 30 };
+    const result = schedule(events, rooms, opts);
+    expect(result.assignments).toHaveLength(2);
+
+    const a1 = result.assignments.find((a) => a.eventId === "e1")!;
+    const a2 = result.assignments.find((a) => a.eventId === "e2")!;
+    expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + 30);
+  });
+
+  it("should spread events across rooms", () => {
+    const events: Event[] = [
+      { id: "e1", name: "Event 1", duration: 60 },
+      { id: "e2", name: "Event 2", duration: 60 },
+      { id: "e3", name: "Event 3", duration: 60 },
+    ];
+    const result = schedule(events, rooms, defaultOptions);
+    expect(result.assignments).toHaveLength(3);
+    expect(result.unscheduled).toHaveLength(0);
+  });
+
+  it("should handle three-event cycle", () => {
+    const events: Event[] = [
+      { id: "a", name: "A", duration: 30, prerequisites: ["c"] },
+      { id: "b", name: "B", duration: 30, prerequisites: ["a"] },
+      { id: "c", name: "C", duration: 30, prerequisites: ["b"] },
+    ];
+    expect(() => schedule(events, rooms, defaultOptions)).toThrow(/[Cc]ycle/);
+  });
+
+  it("should handle zero gap", () => {
+    const events: Event[] = [
+      { id: "e1", name: "Event 1", duration: 60 },
+      { id: "e2", name: "Event 2", duration: 60 },
+    ];
+    const opts: ScheduleOptions = { startTime: 540, endTime: 660, gap: 0 };
+    const result = schedule(events, [rooms[0]], opts);
+    expect(result.assignments).toHaveLength(2);
+
+    const sorted = [...result.assignments].sort((a, b) => a.startTime - b.startTime);
+    expect(sorted[1].startTime).toBe(sorted[0].endTime);
+  });
+});
