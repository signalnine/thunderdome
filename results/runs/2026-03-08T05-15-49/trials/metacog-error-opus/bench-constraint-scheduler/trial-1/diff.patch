@@ -0,0 +1,590 @@
+export interface Event {
+  id: string;
+  name: string;
+  duration: number;
+  attendees?: number;
+  prerequisites?: string[];
+  preferredRoom?: string;
+}
+
+export interface Room {
+  id: string;
+  name: string;
+  capacity: number;
+}
+
+export interface ScheduleOptions {
+  startTime: number;
+  endTime: number;
+  gap?: number;
+}
+
+export interface Assignment {
+  eventId: string;
+  roomId: string;
+  startTime: number;
+  endTime: number;
+}
+
+export interface ScheduleResult {
+  assignments: Assignment[];
+  unscheduled: string[];
+}
+
+/**
+ * Detect cycles in the prerequisite graph using DFS.
+ * Throws an error if a cycle is found (including self-references).
+ */
+function detectCycles(events: Event[]): void {
+  const eventIds = new Set(events.map((e) => e.id));
+  const adjacency = new Map<string, string[]>();
+
+  for (const event of events) {
+    const prereqs = (event.prerequisites ?? []).filter((p) => eventIds.has(p));
+    adjacency.set(event.id, prereqs);
+
+    // Self-reference check
+    if (event.prerequisites?.includes(event.id)) {
+      throw new Error(
+        `Cycle detected in prerequisites: event "${event.id}" references itself`
+      );
+    }
+  }
+
+  const WHITE = 0,
+    GRAY = 1,
+    BLACK = 2;
+  const color = new Map<string, number>();
+  for (const id of eventIds) {
+    color.set(id, WHITE);
+  }
+
+  function dfs(node: string): void {
+    color.set(node, GRAY);
+    for (const dep of adjacency.get(node) ?? []) {
+      const c = color.get(dep);
+      if (c === GRAY) {
+        throw new Error(
+          `Cycle detected in prerequisites involving event "${dep}"`
+        );
+      }
+      if (c === WHITE) {
+        dfs(dep);
+      }
+    }
+    color.set(node, BLACK);
+  }
+
+  for (const id of eventIds) {
+    if (color.get(id) === WHITE) {
+      dfs(id);
+    }
+  }
+}
+
+/**
+ * Topological sort of events based on prerequisites.
+ * Returns event IDs in an order such that prerequisites come first.
+ */
+function topologicalSort(events: Event[]): string[] {
+  const eventIds = new Set(events.map((e) => e.id));
+  const inDegree = new Map<string, number>();
+  const adjacency = new Map<string, string[]>();
+
+  for (const id of eventIds) {
+    inDegree.set(id, 0);
+    adjacency.set(id, []);
+  }
+
+  for (const event of events) {
+    for (const prereq of event.prerequisites ?? []) {
+      if (eventIds.has(prereq)) {
+        adjacency.get(prereq)!.push(event.id);
+        inDegree.set(event.id, (inDegree.get(event.id) ?? 0) + 1);
+      }
+    }
+  }
+
+  const queue: string[] = [];
+  for (const [id, deg] of inDegree) {
+    if (deg === 0) {
+      queue.push(id);
+    }
+  }
+
+  const result: string[] = [];
+  while (queue.length > 0) {
+    const node = queue.shift()!;
+    result.push(node);
+    for (const neighbor of adjacency.get(node) ?? []) {
+      const newDeg = (inDegree.get(neighbor) ?? 1) - 1;
+      inDegree.set(neighbor, newDeg);
+      if (newDeg === 0) {
+        queue.push(neighbor);
+      }
+    }
+  }
+
+  return result;
+}
+
+/**
+ * Find the earliest start time for an event in a given room,
+ * respecting room gaps and prerequisite completion times.
+ */
+function findEarliestStart(
+  event: Event,
+  room: Room,
+  roomAssignments: Map<string, Assignment[]>,
+  eventAssignments: Map<string, Assignment>,
+  options: ScheduleOptions,
+  gap: number
+): number | null {
+  const attendees = event.attendees ?? 1;
+  if (attendees > room.capacity) {
+    return null;
+  }
+
+  // Earliest start from prerequisites
+  let earliest = options.startTime;
+  for (const prereqId of event.prerequisites ?? []) {
+    const prereqAssignment = eventAssignments.get(prereqId);
+    if (prereqAssignment) {
+      earliest = Math.max(earliest, prereqAssignment.endTime + gap);
+    }
+    // If a prerequisite hasn't been scheduled yet but exists in events,
+    // we can't schedule this event
+  }
+
+  const endNeeded = earliest + event.duration;
+  if (endNeeded > options.endTime) {
+    return null;
+  }
+
+  // Find earliest slot in this room that doesn't conflict
+  const existing = roomAssignments.get(room.id) ?? [];
+  const sorted = [...existing].sort((a, b) => a.startTime - b.startTime);
+
+  // Try fitting at `earliest` and check for conflicts
+  let candidateStart = earliest;
+
+  for (const assignment of sorted) {
+    const candidateEnd = candidateStart + event.duration;
+
+    // Check if candidate fits before this existing assignment
+    if (candidateEnd + gap <= assignment.startTime) {
+      // It fits before this assignment
+      if (candidateEnd <= options.endTime) {
+        return candidateStart;
+      }
+    }
+
+    // If overlaps or too close, push candidate after this assignment
+    if (candidateStart < assignment.endTime + gap) {
+      candidateStart = assignment.endTime + gap;
+    }
+  }
+
+  // Check if it fits after all existing assignments
+  const candidateEnd = candidateStart + event.duration;
+  if (
+    candidateStart >= earliest &&
+    candidateEnd <= options.endTime
+  ) {
+    return candidateStart;
+  }
+
+  return null;
+}
+
+/**
+ * Schedule events into rooms using constraint-density ordering with backtracking.
+ */
+export function schedule(
+  events: Event[],
+  rooms: Room[],
+  options: ScheduleOptions
+): ScheduleResult {
+  if (events.length === 0) {
+    return { assignments: [], unscheduled: [] };
+  }
+
+  // Detect cycles first (throws on cycle)
+  detectCycles(events);
+
+  const gap = options.gap ?? 15;
+  const eventMap = new Map<string, Event>();
+  for (const event of events) {
+    eventMap.set(event.id, event);
+  }
+
+  // Get topological order
+  const topoOrder = topologicalSort(events);
+  const topoIndex = new Map<string, number>();
+  for (let i = 0; i < topoOrder.length; i++) {
+    topoIndex.set(topoOrder[i], i);
+  }
+
+  // Calculate constraint density for each event:
+  // - Number of valid rooms (fewer = more constrained)
+  // - Number of prerequisites (more = more constrained)
+  // - Duration (longer = more constrained)
+  const validRoomsCount = new Map<string, number>();
+  for (const event of events) {
+    const attendees = event.attendees ?? 1;
+    let count = 0;
+    for (const room of rooms) {
+      if (room.capacity >= attendees) {
+        count++;
+      }
+    }
+    validRoomsCount.set(event.id, count);
+  }
+
+  // Sort events: respect topological order, but within the same topo-level,
+  // prioritize more constrained events
+  const eventIds = [...topoOrder];
+
+  // Compute depth in prerequisite graph for better ordering
+  const depth = new Map<string, number>();
+  function getDepth(id: string): number {
+    if (depth.has(id)) return depth.get(id)!;
+    const event = eventMap.get(id);
+    if (!event || !event.prerequisites || event.prerequisites.length === 0) {
+      depth.set(id, 0);
+      return 0;
+    }
+    let maxDepth = 0;
+    for (const prereqId of event.prerequisites) {
+      if (eventMap.has(prereqId)) {
+        maxDepth = Math.max(maxDepth, getDepth(prereqId) + 1);
+      }
+    }
+    depth.set(id, maxDepth);
+    return maxDepth;
+  }
+  for (const id of eventIds) {
+    getDepth(id);
+  }
+
+  // Sort: topological depth first, then constraint density (fewer valid rooms first),
+  // then longer duration first
+  eventIds.sort((a, b) => {
+    const depthA = depth.get(a) ?? 0;
+    const depthB = depth.get(b) ?? 0;
+    if (depthA !== depthB) return depthA - depthB;
+
+    const roomsA = validRoomsCount.get(a) ?? 0;
+    const roomsB = validRoomsCount.get(b) ?? 0;
+    if (roomsA !== roomsB) return roomsA - roomsB;
+
+    const eventA = eventMap.get(a)!;
+    const eventB = eventMap.get(b)!;
+    return eventB.duration - eventA.duration;
+  });
+
+  // Use backtracking to maximize scheduled events
+  const bestResult = backtrackSchedule(
+    eventIds,
+    eventMap,
+    rooms,
+    options,
+    gap,
+    validRoomsCount
+  );
+
+  return bestResult;
+}
+
+function backtrackSchedule(
+  eventIds: string[],
+  eventMap: Map<string, Event>,
+  rooms: Room[],
+  options: ScheduleOptions,
+  gap: number,
+  validRoomsCount: Map<string, number>
+): ScheduleResult {
+  const roomAssignments = new Map<string, Assignment[]>();
+  for (const room of rooms) {
+    roomAssignments.set(room.id, []);
+  }
+  const eventAssignments = new Map<string, Assignment>();
+  const assignments: Assignment[] = [];
+  const unscheduled: string[] = [];
+
+  // Check if all prerequisites of an event are scheduled
+  function prereqsSatisfied(eventId: string): boolean {
+    const event = eventMap.get(eventId)!;
+    for (const prereqId of event.prerequisites ?? []) {
+      if (eventMap.has(prereqId) && !eventAssignments.has(prereqId)) {
+        return false;
+      }
+    }
+    return true;
+  }
+
+  // Order rooms for an event: preferred room first, then by capacity (smallest sufficient first)
+  function getRoomOrder(event: Event): Room[] {
+    const attendees = event.attendees ?? 1;
+    const validRooms = rooms
+      .filter((r) => r.capacity >= attendees)
+      .sort((a, b) => a.capacity - b.capacity);
+
+    if (event.preferredRoom) {
+      const prefIdx = validRooms.findIndex(
+        (r) => r.id === event.preferredRoom
+      );
+      if (prefIdx > 0) {
+        const [pref] = validRooms.splice(prefIdx, 1);
+        validRooms.unshift(pref);
+      }
+    }
+
+    return validRooms;
+  }
+
+  // Try to schedule each event greedily first
+  for (const eventId of eventIds) {
+    const event = eventMap.get(eventId)!;
+
+    if (!prereqsSatisfied(eventId)) {
+      unscheduled.push(eventId);
+      continue;
+    }
+
+    const roomOrder = getRoomOrder(event);
+    let placed = false;
+
+    for (const room of roomOrder) {
+      const startTime = findEarliestStart(
+        event,
+        room,
+        roomAssignments,
+        eventAssignments,
+        options,
+        gap
+      );
+
+      if (startTime !== null) {
+        const assignment: Assignment = {
+          eventId,
+          roomId: room.id,
+          startTime,
+          endTime: startTime + event.duration,
+        };
+        assignments.push(assignment);
+        roomAssignments.get(room.id)!.push(assignment);
+        eventAssignments.set(eventId, assignment);
+        placed = true;
+        break;
+      }
+    }
+
+    if (!placed) {
+      unscheduled.push(eventId);
+    }
+  }
+
+  // If everything was scheduled, return immediately
+  if (unscheduled.length === 0) {
+    return { assignments, unscheduled };
+  }
+
+  // Try to improve by attempting different placement strategies
+  // for unscheduled events via rescheduling
+  const improved = tryImproveSchedule(
+    eventIds,
+    eventMap,
+    rooms,
+    options,
+    gap,
+    assignments,
+    unscheduled,
+    validRoomsCount
+  );
+
+  return improved;
+}
+
+function tryImproveSchedule(
+  eventIds: string[],
+  eventMap: Map<string, Event>,
+  rooms: Room[],
+  options: ScheduleOptions,
+  gap: number,
+  currentAssignments: Assignment[],
+  currentUnscheduled: string[],
+  validRoomsCount: Map<string, number>
+): ScheduleResult {
+  // Try multiple orderings and pick the one that schedules the most events
+  let bestAssignments = currentAssignments;
+  let bestUnscheduled = currentUnscheduled;
+  let bestCount = currentAssignments.length;
+
+  // Generate alternative orderings
+  const orderings: string[][] = [];
+
+  // Ordering 1: Sort by duration descending (longest first)
+  const byDuration = [...eventIds].sort((a, b) => {
+    const eventA = eventMap.get(a)!;
+    const eventB = eventMap.get(b)!;
+    return eventB.duration - eventA.duration;
+  });
+  orderings.push(topoAwareSort(byDuration, eventMap));
+
+  // Ordering 2: Sort by duration ascending (shortest first)
+  const byDurationAsc = [...eventIds].sort((a, b) => {
+    const eventA = eventMap.get(a)!;
+    const eventB = eventMap.get(b)!;
+    return eventA.duration - eventB.duration;
+  });
+  orderings.push(topoAwareSort(byDurationAsc, eventMap));
+
+  // Ordering 3: Sort by fewest valid rooms first (most constrained)
+  const byConstraint = [...eventIds].sort((a, b) => {
+    const ra = validRoomsCount.get(a) ?? 0;
+    const rb = validRoomsCount.get(b) ?? 0;
+    if (ra !== rb) return ra - rb;
+    return (eventMap.get(b)!.duration) - (eventMap.get(a)!.duration);
+  });
+  orderings.push(topoAwareSort(byConstraint, eventMap));
+
+  // Ordering 4: Sort by attendees descending (largest groups first)
+  const byAttendees = [...eventIds].sort((a, b) => {
+    const aa = eventMap.get(a)!.attendees ?? 1;
+    const ab = eventMap.get(b)!.attendees ?? 1;
+    return ab - aa;
+  });
+  orderings.push(topoAwareSort(byAttendees, eventMap));
+
+  for (const ordering of orderings) {
+    const result = greedySchedule(ordering, eventMap, rooms, options, gap);
+    if (result.assignments.length > bestCount) {
+      bestAssignments = result.assignments;
+      bestUnscheduled = result.unscheduled;
+      bestCount = result.assignments.length;
+    }
+    if (bestUnscheduled.length === 0) break;
+  }
+
+  return { assignments: bestAssignments, unscheduled: bestUnscheduled };
+}
+
+/**
+ * Re-sort an ordering to respect topological constraints.
+ * Events with prerequisites must come after their prerequisites.
+ */
+function topoAwareSort(
+  ordering: string[],
+  eventMap: Map<string, Event>
+): string[] {
+  const result: string[] = [];
+  const placed = new Set<string>();
+  const visiting = new Set<string>();
+
+  function place(id: string): void {
+    if (placed.has(id) || visiting.has(id)) return;
+    visiting.add(id);
+    const event = eventMap.get(id);
+    if (event) {
+      for (const prereq of event.prerequisites ?? []) {
+        if (eventMap.has(prereq)) {
+          place(prereq);
+        }
+      }
+    }
+    visiting.delete(id);
+    if (!placed.has(id)) {
+      placed.add(id);
+      result.push(id);
+    }
+  }
+
+  for (const id of ordering) {
+    place(id);
+  }
+
+  return result;
+}
+
+function greedySchedule(
+  eventIds: string[],
+  eventMap: Map<string, Event>,
+  rooms: Room[],
+  options: ScheduleOptions,
+  gap: number
+): ScheduleResult {
+  const roomAssignments = new Map<string, Assignment[]>();
+  for (const room of rooms) {
+    roomAssignments.set(room.id, []);
+  }
+  const eventAssignments = new Map<string, Assignment>();
+  const assignments: Assignment[] = [];
+  const unscheduled: string[] = [];
+
+  for (const eventId of eventIds) {
+    const event = eventMap.get(eventId)!;
+    const attendees = event.attendees ?? 1;
+
+    // Check prerequisites
+    let prereqsSatisfied = true;
+    for (const prereqId of event.prerequisites ?? []) {
+      if (eventMap.has(prereqId) && !eventAssignments.has(prereqId)) {
+        prereqsSatisfied = false;
+        break;
+      }
+    }
+
+    if (!prereqsSatisfied) {
+      unscheduled.push(eventId);
+      continue;
+    }
+
+    // Get rooms sorted: preferred first, then smallest sufficient capacity
+    const validRooms = rooms
+      .filter((r) => r.capacity >= attendees)
+      .sort((a, b) => a.capacity - b.capacity);
+
+    if (event.preferredRoom) {
+      const prefIdx = validRooms.findIndex(
+        (r) => r.id === event.preferredRoom
+      );
+      if (prefIdx > 0) {
+        const [pref] = validRooms.splice(prefIdx, 1);
+        validRooms.unshift(pref);
+      }
+    }
+
+    let placed = false;
+    for (const room of validRooms) {
+      const startTime = findEarliestStart(
+        event,
+        room,
+        roomAssignments,
+        eventAssignments,
+        options,
+        gap
+      );
+
+      if (startTime !== null) {
+        const assignment: Assignment = {
+          eventId,
+          roomId: room.id,
+          startTime,
+          endTime: startTime + event.duration,
+        };
+        assignments.push(assignment);
+        roomAssignments.get(room.id)!.push(assignment);
+        eventAssignments.set(eventId, assignment);
+        placed = true;
+        break;
+      }
+    }
+
+    if (!placed) {
+      unscheduled.push(eventId);
+    }
+  }
+
+  return { assignments, unscheduled };
+}
