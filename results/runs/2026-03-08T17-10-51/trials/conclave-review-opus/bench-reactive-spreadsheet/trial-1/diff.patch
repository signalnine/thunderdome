+  switch (op) {
+    case '+': return (l as number) + (r as number);
+    case '-': return (l as number) - (r as number);
+    case '*': return (l as number) * (r as number);
+    case '/': {
+      if ((r as number) === 0) throw new Error('Division by zero');
+      return (l as number) / (r as number);
+    }
+    case '>': return (l as number) > (r as number);
+    case '<': return (l as number) < (r as number);
+    case '>=': return (l as number) >= (r as number);
+    case '<=': return (l as number) <= (r as number);
+    case '=': return l === r;
+    case '<>': return l !== r;
+    default:
+      throw new Error(`Unknown operator: ${op}`);
+  }
+}
+
+function resolveRangeValues(node: ASTNode, getCell: (ref: string) => CellValue): CellValue[] {
+  if (node.kind === 'range') {
+    const cells = expandRange(node.start, node.end);
+    return cells.map(c => getCell(c));
+  }
+  // Single value
+  return [evaluate(node, getCell)];
+}
+
+function evalFunction(name: string, args: ASTNode[], getCell: (ref: string) => CellValue): CellValue {
+  switch (name) {
+    case 'SUM': {
+      let sum = 0;
+      for (const arg of args) {
+        for (const v of resolveRangeValues(arg, getCell)) {
+          if (typeof v === 'number') sum += v;
+        }
+      }
+      return sum;
+    }
+    case 'AVERAGE': {
+      let sum = 0;
+      let count = 0;
+      for (const arg of args) {
+        for (const v of resolveRangeValues(arg, getCell)) {
+          if (typeof v === 'number') { sum += v; count++; }
+        }
+      }
+      return count === 0 ? 0 : sum / count;
+    }
+    case 'MIN': {
+      let min = Infinity;
+      for (const arg of args) {
+        for (const v of resolveRangeValues(arg, getCell)) {
+          if (typeof v === 'number' && v < min) min = v;
+        }
+      }
+      return min === Infinity ? 0 : min;
+    }
+    case 'MAX': {
+      let max = -Infinity;
+      for (const arg of args) {
+        for (const v of resolveRangeValues(arg, getCell)) {
+          if (typeof v === 'number' && v > max) max = v;
+        }
+      }
+      return max === -Infinity ? 0 : max;
+    }
+    case 'COUNT': {
+      let count = 0;
+      for (const arg of args) {
+        for (const v of resolveRangeValues(arg, getCell)) {
+          if (typeof v === 'number') count++;
+        }
+      }
+      return count;
+    }
+    case 'IF': {
+      if (args.length !== 3) throw new Error('IF requires 3 arguments');
+      const condition = evaluate(args[0], getCell);
+      if (condition) {
+        return evaluate(args[1], getCell);
+      } else {
+        return evaluate(args[2], getCell);
+      }
+    }
+    default:
+      throw new Error(`Unknown function: ${name}`);
+  }
+}
+
+// --- Spreadsheet ---
+
+interface CellData {
+  raw: string | number | boolean;
+  formula: ASTNode | null;
+  value: CellValue;
+  deps: Set<string>; // cells this cell depends on
+}
+
+export class Spreadsheet {
+  private cells = new Map<string, CellData>();
+  // Reverse dependency map: cellRef -> set of cells that depend on it
+  private dependents = new Map<string, Set<string>>();
+
+  set(cell: string, value: string | number | boolean): void {
+    const ref = cell.toUpperCase();
+    // Validate ref format
+    parseRef(ref);
+
+    const oldData = this.cells.get(ref);
+    const oldDeps = oldData?.deps ?? new Set<string>();
+
+    let formula: ASTNode | null = null;
+    let deps = new Set<string>();
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      formula = parseFormula(value.substring(1));
+      deps = extractDependencies(formula);
+    }
+
+    // Check for circular references before committing
+    if (deps.size > 0) {
+      this.checkCircular(ref, deps);
+    }
+
+    // Remove old reverse dependencies
+    for (const dep of oldDeps) {
+      const revSet = this.dependents.get(dep);
+      if (revSet) {
+        revSet.delete(ref);
+        if (revSet.size === 0) this.dependents.delete(dep);
+      }
+    }
+
+    // Add new reverse dependencies
+    for (const dep of deps) {
+      let revSet = this.dependents.get(dep);
+      if (!revSet) {
+        revSet = new Set();
+        this.dependents.set(dep, revSet);
+      }
+      revSet.add(ref);
+    }
+
+    // Compute value
+    let computed: CellValue;
+    if (formula) {
+      computed = evaluate(formula, (r) => this.getCellValue(r));
+    } else if (typeof value === 'string') {
+      computed = value;
+    } else {
+      computed = value;
+    }
+
+    this.cells.set(ref, { raw: value, formula, value: computed, deps });
+
+    // Propagate updates to dependents
+    this.propagateUpdates(ref);
+  }
+
+  get(cell: string): string | number | boolean | null {
+    const ref = cell.toUpperCase();
+    return this.getCellValue(ref);
+  }
+
+  getDisplay(cell: string): string {
+    const val = this.get(cell);
+    if (val === null) return '';
+    return String(val);
+  }
+
+  getCells(): Map<string, CellValue> {
+    const result = new Map<string, CellValue>();
+    for (const [ref, data] of this.cells) {
+      result.set(ref, data.value);
+    }
+    return result;
+  }
+
+  private getCellValue(ref: string): CellValue {
+    const data = this.cells.get(ref);
+    if (!data) return null;
+    return data.value;
+  }
+
+  private checkCircular(startRef: string, deps: Set<string>): void {
+    // BFS/DFS from deps to see if we can reach startRef
+    const visited = new Set<string>();
+    const stack = [...deps];
+
+    while (stack.length > 0) {
+      const current = stack.pop()!;
+      if (current === startRef) {
+        throw new Error(`Circular reference detected: ${startRef}`);
+      }
+      if (visited.has(current)) continue;
+      visited.add(current);
+
+      // Follow the dependencies of current cell
+      const cellData = this.cells.get(current);
+      if (cellData) {
+        for (const dep of cellData.deps) {
+          if (!visited.has(dep)) {
+            stack.push(dep);
+          }
+        }
+      }
+    }
+  }
+
+  private propagateUpdates(changedRef: string): void {
+    // Topological sort of all transitive dependents, then recompute in order
+    const order = this.topologicalSort(changedRef);
+
+    for (const ref of order) {
+      const data = this.cells.get(ref);
+      if (data?.formula) {
+        data.value = evaluate(data.formula, (r) => this.getCellValue(r));
+      }
+    }
+  }
+
+  private topologicalSort(startRef: string): string[] {
+    // Get all transitive dependents of startRef, then topologically sort them
+    const allDependents = new Set<string>();
+    const queue = [startRef];
+
+    // BFS to collect all transitive dependents
+    while (queue.length > 0) {
+      const current = queue.shift()!;
+      const revDeps = this.dependents.get(current);
+      if (revDeps) {
+        for (const dep of revDeps) {
+          if (!allDependents.has(dep)) {
+            allDependents.add(dep);
+            queue.push(dep);
+          }
+        }
+      }
+    }
+
+    if (allDependents.size === 0) return [];
+
+    // Topological sort using Kahn's algorithm within the subgraph
+    // Build in-degree map (only counting edges within allDependents)
+    const inDegree = new Map<string, number>();
+    for (const ref of allDependents) {
+      inDegree.set(ref, 0);
+    }
+
+    for (const ref of allDependents) {
+      const data = this.cells.get(ref);
+      if (data) {
+        for (const dep of data.deps) {
+          // dep -> ref edge; if dep is in allDependents or is startRef
+          if (allDependents.has(dep)) {
+            inDegree.set(ref, (inDegree.get(ref) ?? 0) + 1);
+          }
+        }
+      }
+    }
+
+    const sorted: string[] = [];
+    const readyQueue: string[] = [];
+
+    for (const [ref, degree] of inDegree) {
+      if (degree === 0) {
+        readyQueue.push(ref);
+      }
+    }
+
+    while (readyQueue.length > 0) {
+      const current = readyQueue.shift()!;
+      sorted.push(current);
+
+      const revDeps = this.dependents.get(current);
+      if (revDeps) {
+        for (const dep of revDeps) {
+          if (allDependents.has(dep)) {
+            const newDegree = (inDegree.get(dep) ?? 0) - 1;
+            inDegree.set(dep, newDegree);
+            if (newDegree === 0) {
+              readyQueue.push(dep);
+            }
+          }
+        }
+      }
+    }
+
+    return sorted;
+  }
+}
