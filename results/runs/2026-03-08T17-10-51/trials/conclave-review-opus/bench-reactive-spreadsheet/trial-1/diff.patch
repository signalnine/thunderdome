+// --- Cell Reference Utilities ---
+
+function columnToIndex(col: string): number {
+  let index = 0;
+  for (let i = 0; i < col.length; i++) {
+    index = index * 26 + (col.charCodeAt(i) - 64); // A=1, B=2, ...
+  }
+  return index - 1; // 0-based
+}
+
+function indexToColumn(index: number): string {
+  let col = '';
+  let n = index + 1; // 1-based
+  while (n > 0) {
+    n--;
+    col = String.fromCharCode(65 + (n % 26)) + col;
+    n = Math.floor(n / 26);
+  }
+  return col;
+}
+
+function parseRef(ref: string): { col: number; row: number } {
+  const match = ref.match(/^([A-Z]+)(\d+)$/);
+  if (!match) throw new Error(`Invalid cell reference: ${ref}`);
+  return { col: columnToIndex(match[1]), row: parseInt(match[2], 10) - 1 };
+}
+
+function refToString(col: number, row: number): string {
+  return `${indexToColumn(col)}${row + 1}`;
+}
+
+function expandRange(start: string, end: string): string[] {
+  const s = parseRef(start);
+  const e = parseRef(end);
+  const minCol = Math.min(s.col, e.col);
+  const maxCol = Math.max(s.col, e.col);
+  const minRow = Math.min(s.row, e.row);
+  const maxRow = Math.max(s.row, e.row);
+  const cells: string[] = [];
+  for (let r = minRow; r <= maxRow; r++) {
+    for (let c = minCol; c <= maxCol; c++) {
+      cells.push(refToString(c, r));
+    }
+  }
+  return cells;
+}
+
+// --- Tokenizer ---
+
+enum TokenType {
+  Number,
+  String,
+  Boolean,
+  CellRef,
+  Function,
+  Operator,
+  LParen,
+  RParen,
+  Comma,
+  Colon,
+  EOF,
+}
+
+interface Token {
+  type: TokenType;
+  value: string;
+}
+
+function tokenize(formula: string): Token[] {
+  const tokens: Token[] = [];
+  let i = 0;
+
+  while (i < formula.length) {
+    const ch = formula[i];
+
+    if (ch === ' ' || ch === '\t') {
+      i++;
+      continue;
+    }
+
+    if (ch === '"') {
+      let str = '';
+      i++; // skip opening quote
+      while (i < formula.length && formula[i] !== '"') {
+        str += formula[i];
+        i++;
+      }
+      if (i >= formula.length) throw new Error('Unterminated string');
+      i++; // skip closing quote
+      tokens.push({ type: TokenType.String, value: str });
+      continue;
+    }
+
+    if (ch === '(') { tokens.push({ type: TokenType.LParen, value: '(' }); i++; continue; }
+    if (ch === ')') { tokens.push({ type: TokenType.RParen, value: ')' }); i++; continue; }
+    if (ch === ',') { tokens.push({ type: TokenType.Comma, value: ',' }); i++; continue; }
+    if (ch === ':') { tokens.push({ type: TokenType.Colon, value: ':' }); i++; continue; }
+
+    // Comparison operators: >=, <=, <>, =, >, <
+    if (ch === '>' || ch === '<') {
+      if (i + 1 < formula.length && (formula[i + 1] === '=' || (ch === '<' && formula[i + 1] === '>'))) {
+        tokens.push({ type: TokenType.Operator, value: formula[i] + formula[i + 1] });
+        i += 2;
+      } else {
+        tokens.push({ type: TokenType.Operator, value: ch });
+        i++;
+      }
+      continue;
+    }
+
+    if (ch === '=') {
+      tokens.push({ type: TokenType.Operator, value: '=' });
+      i++;
+      continue;
+    }
+
+    if (ch === '+' || ch === '-' || ch === '*' || ch === '/') {
+      tokens.push({ type: TokenType.Operator, value: ch });
+      i++;
+      continue;
+    }
+
+    // Numbers
+    if (/\d/.test(ch) || (ch === '.' && i + 1 < formula.length && /\d/.test(formula[i + 1]))) {
+      let num = '';
+      while (i < formula.length && (/\d/.test(formula[i]) || formula[i] === '.')) {
+        num += formula[i];
+        i++;
+      }
+      tokens.push({ type: TokenType.Number, value: num });
+      continue;
+    }
