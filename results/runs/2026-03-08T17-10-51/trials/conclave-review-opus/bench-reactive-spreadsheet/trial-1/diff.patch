+      return operand;
+    }
+    case 'binary': {
+      const left = evaluate(ast.left, getCell);
+      const right = evaluate(ast.right, getCell);
+      return evalBinaryOp(ast.op, left, right);
+    }
+    case 'call':
+      return evalFunction(ast.name, ast.args, getCell);
+  }
+}
+
+function evalBinaryOp(op: string, left: CellValue, right: CellValue): CellValue {
