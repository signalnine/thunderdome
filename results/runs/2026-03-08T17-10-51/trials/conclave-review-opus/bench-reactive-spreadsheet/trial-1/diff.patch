   this.advance();\n      return { kind: 'boolean', value: tok.value === 'TRUE' };\n    }\n\n    if (tok.type === TokenType.Function) {\n      const name = this.advance().value;\n      this.expect(TokenType.LParen);\n      const args: ASTNode[] = [];\n      if (this.peek().type !== TokenType.RParen) {\n        args.push(this.parseFunctionArg());\n        while (this.peek().type === TokenType.Comma) {\n          this.advance();\n          args.push(this.parseFunctionArg());\n        }\n      }\n      this.expect(TokenType.RParen);\n      return { kind: 'call', name, args };\n    }\n\n    if (tok.type === TokenType.CellRef) {\n      this.advance();\n      // Check for range (CellRef : CellRef)\n      if (this.peek().type === TokenType.Colon) {\n        this.advance();\n        const end = this.expect(TokenType.CellRef);\n        return { kind: 'range', start: tok.value, end: end.value };\n      }\n      return { kind: 'cellref', ref: tok.value };\n    }\n\n    if (tok.type === TokenType.LParen) {\n      this.advance();\n      const expr = this.parseExpression();\n      this.expect(TokenType.RParen);\n      return expr;\n    }\n\n    throw new Error(`Unexpected token: ${TokenType[tok.type]} (${tok.value})`);\n  }\n\n  private parseFunctionArg(): ASTNode {\n    // Inside function args, a cell ref followed by ':' is a range\n    return this.parseExpression();\n  }\n}\n\nfunction parseFormula(formula: string): ASTNode {\n  const tokens = tokenize(formula);\n  const parser = new Parser(tokens);\n  return parser.parse();\n}\n\n// --- Dependency extraction ---\n\nfunction extractDependencies(ast: ASTNode): Set<string> {\n  const deps = new Set<string>();\n\n  function walk(node: ASTNode): void {\n    switch (node.kind) {\n      case 'cellref':\n        deps.add(node.ref);\n        break;\n      case 'range':\n        for (const cell of expandRange(node.start, node.end)) {\n          deps.add(cell);\n        }\n        break;\n      case 'binary':\n        walk(node.left);\n        walk(node.right);\n        break;\n      case 'unary':\n        walk(node.operand);\n        break;\n      case 'call':\n        for (const arg of node.args) {\n          walk(arg);\n        }\n        break;\n      // number, string, boolean have no deps\n    }\n  }\n\n  walk(ast);\n  return deps;\n}\n\n// --- Evaluator ---\n\ntype CellValue = string | number | boolean | null;\n\nfunction evaluate(ast: ASTNode, getCell: (ref: string) => CellValue): CellValue {\n  switch (ast.kind) {\n    case 'number':\n      return ast.value;\n    case 'string':\n      return ast.value;\n    case 'boolean':\n      return ast.value;\n    case 'cellref': {\n      const val = getCell(ast.ref);\n      return val;\n    }\n    case 'range':\n      throw new Error('Range used outside of function');\n    case 'unary': {\n      const operand = evaluate(ast.operand, getCell);\n      if (ast.op === '-') {\n        return -(operand as number);\n      }\n      return operand;\n    }\n    case 'binary': {\n      const left = evaluate(ast.left, getCell);\n      const right = evaluate(ast.right, getCell);\n      return evalBinaryOp(ast.op, left, right);\n    }\n    case 'call':\n      return evalFunction(ast.name, ast.args, getCell);\n  }\n}\n\nfunction evalBinaryOp(op: string, left: CellValue, right: CellValue): CellValue {\n  const l = left === null ? 0 : left;\n  const r = right === null ? 0 : right;\n\n  switch (op) {\n    case '+': return (l as number) + (r as number);\n    case '-': return (l as number) - (r as number);\n    case '*': return (l as number) * (r as number);\n    case '/': {\n      if ((r as number) === 0) throw new Error('Division by zero');\n      return (l as number) / (r as number);\n    }\n    case '>': return (l as number) > (r as number);\n    case '<': return (l as number) < (r as number);\n    case '>=': return (l as number) >= (r as number);\n    case '<=': return (l as number) <= (r as number);\n    case '=': return l === r;\n    case '<>': return l !== r;\n    default:\n      throw new Error(`Unknown operator: ${op}`);\n  }\n}\n\nfunction resolveRangeValues(node: ASTNode, getCell: (ref: string) => CellValue): CellValue[] {\n  if (node.kind === 'range') {\n    const cells = expandRange(node.start, node.end);\n    return cells.map(c => getCell(c));\n  }\n  // Single value\n  return [evaluate(node, getCell)];\n}\n\nfunction evalFunction(name: string, args: ASTNode[], getCell: (ref: string) => CellValue): CellValue {\n  switch (name) {\n    case 'SUM': {\n      let sum = 0;\n      for (const arg of args) {\n        for (const v of resolveRangeValues(arg, getCell)) {\n          if (typeof v === 'number') sum += v;\n        }\n      }\n      return sum;\n    }\n    case 'AVERAGE': {\n      let sum = 0;\n      let count = 0;\n      for (const arg of args) {\n        for (const v of resolveRangeValues(arg, getCell)) {\n          if (typeof v === 'number') { sum += v; count++; }\n        }\n      }\n      return count === 0 ? 0 : sum / count;\n    }\n    case 'MIN': {\n      let min = Infinity;\n      for (const arg of args) {\n        for (const v of resolveRangeValues(arg, getCell)) {\n          if (typeof v === 'number' && v < min) min = v;\n        }\n      }\n      return min === Infinity ? 0 : min;\n    }\n    case 'MAX': {\n      let max = -Infinity;\n      for (const arg of args) {\n        for (const v of resolveRangeValues(arg, getCell)) {\n          if (typeof v === 'number' && v > max) max = v;\n        }\n      }\n      return max === -Infinity ? 0 : max;\n    }\n    case 'COUNT': {\n      let count = 0;\n      for (const arg of args) {\n        for (const v of resolveRangeValues(arg, getCell)) {\n          if (typeof v === 'number') count++;\n        }\n      }\n      return count;\n    }\n    case 'IF': {\n      if (args.length !== 3) throw new Error('IF requires 3 arguments');\n      const condition = evaluate(args[0], getCell);\n      if (condition) {\n        return evaluate(args[1], getCell);\n      } else {\