\n    const ref = cell.toUpperCase();\n    return this.getCellValue(ref);\n  }\n\n  getDisplay(cell: string): string {\n    const val = this.get(cell);\n    if (val === null) return '';\n    return String(val);\n  }\n\n  getCells(): Map<string, CellValue> {\n    const result = new Map<string, CellValue>();\n    for (const [ref, data] of this.cells) {\n      result.set(ref, data.value);\n    }\n    return result;\n  }\n\n  private getCellValue(ref: string): CellValue {\n    const data = this.cells.get(ref);\n    if (!data) return null;\n    return data.value;\n  }\n\n  private checkCircular(startRef: string, deps: Set<string>): void {\n    // BFS/DFS from deps to see if we can reach startRef\n    const visited = new Set<string>();\n    const stack = [...deps];\n\n    while (stack.length > 0) {\n      const current = stack.pop()!;\n      if (current === startRef) {\n        throw new Error(`Circular reference detected: ${startRef}`);\n      }\n      if (visited.has(current)) continue;\n      visited.add(current);\n\n      // Follow the dependencies of current cell\n      const cellData = this.cells.get(current);\n      if (cellData) {\n        for (const dep of cellData.deps) {\n          if (!visited.has(dep)) {\n            stack.push(dep);\n          }\n        }\n      }\n    }\n  }\n\n  private propagateUpdates(changedRef: string): void {\n    // Topological sort of all transitive dependents, then recompute in order\n    const order = this.topologicalSort(changedRef);\n\n    for (const ref of order) {\n      const data = this.cells.get(ref);\n      if (data?.formula) {\n        data.value = evaluate(data.formula, (r) => this.getCellValue(r));\n      }\n    }\n  }\n\n  private topologicalSort(startRef: string): string[] {\n    // Get all transitive dependents of startRef, then topologically sort them\n    const allDependents = new Set<string>();\n    const queue = [startRef];\n\n    // BFS to collect all transitive dependents\n    while (queue.length > 0) {\n     