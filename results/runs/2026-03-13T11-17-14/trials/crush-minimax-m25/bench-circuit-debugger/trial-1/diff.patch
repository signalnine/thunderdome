+import { describe, it, expect } from 'vitest';
+import { simulate, findSwappedWires, type Gate } from '../src/index';
+
+describe('simulate', () => {
+  it('should simulate a simple AND gate', () => {
+    const gates: Gate[] = [
+      { op: 'AND', in1: 'a', in2: 'b', out: 'c' }
+    ];
+    const result = simulate(gates, { a: 1, b: 1 });
+    expect(result.c).toBe(1);
+  });
+
+  it('should simulate a simple OR gate', () => {
+    const gates: Gate[] = [
+      { op: 'OR', in1: 'a', in2: 'b', out: 'c' }
+    ];
+    const result = simulate(gates, { a: 0, b: 1 });
+    expect(result.c).toBe(1);
+  });
+
+  it('should simulate a simple XOR gate', () => {
+    const gates: Gate[] = [
+      { op: 'XOR', in1: 'a', in2: 'b', out: 'c' }
+    ];
+    const result = simulate(gates, { a: 1, b: 0 });
+    expect(result.c).toBe(1);
+  });
+
+  it('should simulate a 4-bit adder correctly', () => {
+    const gates: Gate[] = [
+      // x00 XOR y00 -> z00
+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+      // x00 AND y00 -> c00
+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+
+      // x01 XOR y01 -> t01
+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },
+      // t01 XOR c00 -> z01
+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },
+      // x01 AND y01 -> a01
+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },
+      // t01 AND c00 -> b01
+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },
+      // a01 OR b01 -> c01
+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },
+
+      // x02 XOR y02 -> t02
+      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },
+      // t02 XOR c01 -> z02
+      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },
+      // x02 AND y02 -> a02
+      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },
+      // t02 AND c01 -> b02
+      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },
+      // a02 OR b02 -> c02
+      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },
+
+      // x03 XOR y03 -> t03
+      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },
+      // t03 XOR c02 -> z03
+      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },
+      // x03 AND y03 -> a03
+      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },
+      // t03 AND c02 -> b03
+      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },
+      // a03 OR b03 -> c03
+      { op: 'OR', in1: 'a03', in2: 'b03', out: 'c03' },
+
+      // c03 -> z04
+      { op: 'XOR', in1: 'c03', in2: 'c03', out: 'z04' },
+    ];
+
+    // Test 2 + 3 = 5
+    const result = simulate(gates, {
+      x00: 0, x01: 1, x02: 0, x03: 0,  // 2
+      y00: 1, y01: 1, y02: 0, y03: 0   // 3
+    });
+
+    expect(result.z00).toBe(1); // 5 = 0101
+    expect(result.z01).toBe(0);
+    expect(result.z02).toBe(1);
+    expect(result.z03).toBe(0);
+    expect(result.z04).toBe(0);
+  });
+
+  it('should find swapped wires in a 4-bit adder', () => {
+    // Create a 4-bit adder with swapped wires
+    // Let's swap z01 and a01
+    const gates: Gate[] = [
+      // x00 XOR y00 -> z00
+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+      // x00 AND y00 -> c00
+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+
+      // x01 XOR y01 -> t01
+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },
+      // t01 XOR c00 -> a01 (SWAPPED: should be z01)
+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'a01' },
+      // x01 AND y01 -> z01 (SWAPPED: should be a01)
+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'z01' },
+      // t01 AND c00 -> b01
+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },
+      // a01 OR b01 -> c01
+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },
+
+      // x02 XOR y02 -> t02
+      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },
+      // t02 XOR c01 -> z02
+      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },
+      // x02 AND y02 -> a02
+      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },
+      // t02 AND c01 -> b02
+      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },
+      // a02 OR b02 -> c02
+      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },
+
+      // x03 XOR y03 -> t03
+      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },
+      // t03 XOR c02 -> z03
+      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },
+      // x03 AND y03 -> a03
+      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },
+      // t03 AND c02 -> b03
+      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },
+      // a03 OR b03 -> c03
+      { op: 'OR', in1: 'a03', in2: 'b03', out: 'c03' },
+
+      // c03 -> z04
+      { op: 'XOR', in1: 'c03', in2: 'c03', out: 'z04' },
+    ];
+
+    const swapped = findSwappedWires(gates);
+    // Should find z01 and a01 as swapped
+    expect(swapped).toContain('z01');
+    expect(swapped).toContain('a01');
+    expect(swapped.length).toBe(2);
+  });
+});
