+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number> {
+  const gateByOutput = new Map<string, Gate>();
+  for (const gate of gates) {
+    gateByOutput.set(gate.out, gate);
+  }
+
+  const wireValues: Record<string, number> = { ...inputs };
+  const processed = new Set<string>();
+
+  function tryProcessGate(outWire: string): boolean {
+    const gate = gateByOutput.get(outWire);
+    if (!gate) return false;
+
+    const v1 = wireValues[gate.in1];
+    const v2 = wireValues[gate.in2];
+
+    if (v1 === undefined || v2 === undefined) return false;
+
+    let result: number;
+    switch (gate.op) {
+      case 'AND':
+        result = (v1 === 1 && v2 === 1) ? 1 : 0;
+        break;
+      case 'OR':
+        result = (v1 === 1 || v2 === 1) ? 1 : 0;
+        break;
+      case 'XOR':
+        result = (v1 !== v2) ? 1 : 0;
+        break;
+    }
+
+    wireValues[outWire] = result;
+    processed.add(outWire);
+    return true;
+  }
+
+  const outputWires = gates.map(g => g.out);
+
+  let changed = true;
+  while (changed) {
+    changed = false;
+    for (const outWire of outputWires) {
+      if (!processed.has(outWire)) {
+        if (tryProcessGate(outWire)) {
+          changed = true;
+        }
+      }
+    }
+  }
+
+  return wireValues;
+}
+
+function computeAdderExpected(n: number, x: number, y: number): number[] {
+  const result: number[] = [];
+  let carry = 0;
+
+  for (let i = 0; i <= n; i++) {
+    const xi = (x >> i) & 1;
+    const yi = (y >> i) & 1;
+
+    if (i === 0) {
+      result[i] = xi ^ yi;
+    } else {
+      const partialSum = xi ^ yi;
+      result[i] = partialSum ^ carry;
+    }
+
+    const generate = xi & yi;
+    const partialSum = i === 0 ? xi ^ yi : (xi ^ yi);
+    const propagate = partialSum & carry;
+    carry = generate | propagate;
+  }
+
+  return result;
+}
+
+export function findSwappedWires(gates: Gate[]): string[] {
+  const inputWires = new Set<string>();
+  const outputWires = new Set<string>();
+
+  for (const gate of gates) {
+    outputWires.add(gate.out);
+  }
+
+  for (const gate of gates) {
+    if (!outputWires.has(gate.in1)) inputWires.add(gate.in1);
+    if (!outputWires.has(gate.in2)) inputWires.add(gate.in2);
+  }
+
+  const xWires: string[] = [];
+  const yWires: string[] = [];
+  const zWires: string[] = [];
+
+  for (const w of inputWires) {
+    if (w.match(/^x\d+$/)) xWires.push(w);
+    if (w.match(/^y\d+$/)) yWires.push(w);
+  }
+  for (const w of outputWires) {
+    if (w.match(/^z\d+$/)) zWires.push(w);
+  }
+
+  xWires.sort((a, b) => parseInt(a.slice(1)) - parseInt(b.slice(1)));
+  yWires.sort((a, b) => parseInt(a.slice(1)) - parseInt(b.slice(1)));
+  zWires.sort((a, b) => parseInt(a.slice(1)) - parseInt(b.slice(1)));
+
+  const numBits = xWires.length;
+
+  const testCases = [
+    { x: 0, y: 0 },
+    { x: 1, y: 0 },
+    { x: 0, y: 1 },
+    { x: 1, y: 1 },
+    { x: 2, y: 3 },
+    { x: 5, y: 7 },
+    { x: 15, y: 1 },
+    { x: (1 << numBits) - 1, y: 1 },
+    { x: (1 << (numBits - 1)), y: (1 << (numBits - 1)) },
+  ];
+
+  // Build expected signatures for z outputs
+  const zExpectedSignatures = new Map<string, number[]>();
+
+  for (let i = 0; i < zWires.length; i++) {
+    const values: number[] = [];
+    for (const tc of testCases) {
+      const expected = computeAdderExpected(numBits - 1, tc.x, tc.y);
+      values.push(expected[i]);
+    }
+    zExpectedSignatures.set(zWires[i], values);
+  }
+
+  // Build actual signatures for all outputs
+  const actualSignatures = new Map<string, number[]>();
+
+  for (const wire of outputWires) {
+    const values: number[] = [];
+    for (const tc of testCases) {
+      const inputs: Record<string, number> = {};
+      for (let i = 0; i < numBits; i++) {
+        inputs[`x${i.toString().padStart(2, '0')}`] = (tc.x >> i) & 1;
+        inputs[`y${i.toString().padStart(2, '0')}`] = (tc.y >> i) & 1;
+      }
+      const result = simulate(gates, inputs);
+      values.push(result[wire] ?? 0);
+    }
+    actualSignatures.set(wire, values);
+  }
+
+  // For each output wire, check if it's in the right place
+  // z wires should have z signatures
+  // Other output wires should not have any z signature (they're internal)
+
+  const allSwapped = new Set<string>();
+  const assigned = new Set<string>();
+
+  // First handle z wires: each should have its expected signature
+  for (const zWire of zWires) {
+    const expected = zExpectedSignatures.get(zWire)!;
+    const actual = actualSignatures.get(zWire)!;
+
+    let isCorrect = true;
+    for (let i = 0; i < expected.length; i++) {
+      if (expected[i] !== actual[i]) {
+        isCorrect = false;
+        break;
+      }
+    }
+
+    if (isCorrect) {
+      assigned.add(zWire);
+      continue;
+    }
+
+    // zWire is swapped - find which other output has this expected signature
+    for (const [otherWire, otherActual] of actualSignatures) {
+      if (otherWire === zWire) continue;
+      if (assigned.has(otherWire)) continue;
+
+      let match = true;
+      for (let i = 0; i < expected.length; i++) {
+        if (expected[i] !== otherActual[i]) {
+          match = false;
+          break;
+        }
+      }
+
+      if (match) {
+        allSwapped.add(zWire);
+        allSwapped.add(otherWire);
+        assigned.add(otherWire);
+        break;
+      }
+    }
+  }
+
+  // Now handle non-z outputs that might be swapped with each other
+  // or swapped with z wires but not yet detected
+  // For each unassigned output, check if it has a z signature
+  for (const wire of outputWires) {
+    if (assigned.has(wire)) continue;
+
+    const actual = actualSignatures.get(wire)!;
+
+    // Check if this wire has any z expected signature
+    for (const [zWire, expected] of zExpectedSignatures) {
+      if (assigned.has(zWire)) continue;
+
+      let match = true;
+      for (let i = 0; i < expected.length; i++) {
+        if (expected[i] !== actual[i]) {
+          match = false;
+          break;
+        }
+      }
+
+      if (match) {
+        // This wire has zWire's expected signature - they're swapped
+        allSwapped.add(wire);
+        allSwapped.add(zWire);
+        assigned.add(wire);
+        assigned.add(zWire);
+        break;
+      }
+    }
+  }
+
+  return Array.from(allSwapped).sort();
+}
