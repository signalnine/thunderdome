+++ b/src/plugins/markdown-ext.ts
@@ -0,0 +1,106 @@
+import { marked } from 'marked';
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+interface Admonition {
+  placeholder: string;
+  type: string;
+  text: string;
+  original: string;
+}
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: async (file: ContentFile, _ctx: BuildContext): Promise<ContentFile> => {
+        const content = file.content;
+
+        // Handle footnotes
+        const footnoteRefs: Map<string, { id: number; text: string }> = new Map();
+        const footnoteDefs: Map<string, string> = new Map();
+
+        // Find footnote references [^1], [^2], etc.
+        const footnoteRefRegex = /\[\^(\w+)\]/g;
+        let footnoteId = 0;
+        const refMatches = [...content.matchAll(footnoteRefRegex)];
+        refMatches.forEach((refMatch) => {
+          const key = refMatch[1];
+          if (!footnoteRefs.has(key)) {
+            footnoteId++;
+            footnoteRefs.set(key, { id: footnoteId, text: '' });
+          }
+        });
+
+        // Find footnote definitions [^1]: ...
+        const footnoteDefRegex = /^\[\^(\w+)\]:\s*(.+)$/gm;
+        const defMatches = [...content.matchAll(footnoteDefRegex)];
+        defMatches.forEach((defMatch) => {
+          const key = defMatch[1];
+          const text = defMatch[2].trim();
+          footnoteDefs.set(key, text);
+        });
+
+        // Replace footnote references with links (but not definitions)
+        let processedContent = content.replace(/\[\^(\w+)\](?!:)/g, (match, key) => {
+          const ref = footnoteRefs.get(key);
+          if (ref) {
+            return `<sup><a href="#fn-${key}">${ref.id}</a></sup>`;
+          }
+          return match;
+        });
+
+        // Remove footnote definitions from content
+        processedContent = processedContent.replace(/^\[\^(\w+)\]:\s*(.+)$/gm, '');
+
+        // Process admonitions
+        const admonitions: Admonition[] = [];
+        const admonitionRegex = /:::(note|warning|tip)\s*\n([\s\S]*?)\n:::/g;
+        let match;
+        let admonitionIndex = 0;
+
+        while ((match = admonitionRegex.exec(content)) !== null) {
+          const type = match[1];
+          const text = match[2].trim();
+          const fullMatch = match[0];
+          const placeholder = `<!--ADMONITION-${admonitionIndex}-->`;
+          admonitions.push({ placeholder, type, text, original: fullMatch });
+          admonitionIndex++;
+        }
+
+        // Replace admonitions with placeholders
+        for (const admonition of admonitions) {
+          processedContent = processedContent.replace(admonition.original, admonition.placeholder);
+        }
+
+        // Parse markdown to HTML
+        let html = await marked.parse(processedContent);
+
+        // Restore admonitions with parsed content
+        for (const admonition of admonitions) {
+          const parsedText = await marked.parseInline(admonition.text);
+          html = html.replace(admonition.placeholder, `<div class="admonition admonition-${admonition.type}">${parsedText}</div>`);
+        }
+
+        // Add footnotes section if there are any
+        if (footnoteRefs.size > 0) {
+          const footnoteItems: string[] = [];
+          footnoteRefs.forEach((ref, key) => {
+            const text = footnoteDefs.get(key) || '';
+            footnoteItems.push(`<li id="fn-${key}">${text}</li>`);
+          });
+
+          if (footnoteItems.length > 0) {
+            html += `\n<section class="footnotes">\n<ol>\n${footnoteItems.join('\n')}\n</ol>\n</section>`;
+          }
+        }
+
+        return {
+          ...file,
+          content: html,
+        };
+      },
+    },
+  };
+}
