@@ -0,0 +1,58 @@
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createAssetPipelinePlugin(): Plugin {
+  return {
+    name: 'asset-pipeline',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: async (file: ContentFile, ctx: BuildContext): Promise<ContentFile> => {
+        let content = file.content;
+        const discoveredAssets: string[] = [];
+
+        // Regex to find relative URLs in src="./..." or href="./..."
+        // Match paths starting with ./ or just filename references without protocol
+        const assetRegex = /(src|href)="\.\/([^"]+)"/g;
+
+        // Find all asset references
+        let match;
+        while ((match = assetRegex.exec(content)) !== null) {
+          const assetName = match[2];
+          // Skip if already /assets/ path
+          if (!assetName.startsWith('/assets/') && !assetName.startsWith('http')) {
+            discoveredAssets.push(assetName);
+          }
+        }
+
+        // Rewrite URLs from ./filename to /assets/filename
+        content = content.replace(assetRegex, (match, attr, path) => {
+          // If it's already an absolute path or external URL, leave it
+          if (path.startsWith('/assets/') || path.startsWith('http://') || path.startsWith('https://')) {
+            return match;
+          }
+          return `${attr}="/assets/${path}"`;
+        });
+
+        // Update the asset manifest in ctx.data
+        if (discoveredAssets.length > 0) {
+          const existingManifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;
+          if (existingManifest) {
+            // Add new assets, avoiding duplicates
+            for (const asset of discoveredAssets) {
+              if (!existingManifest.assets.includes(asset)) {
+                existingManifest.assets.push(asset);
+              }
+            }
+          } else {
+            ctx.data.set('asset-manifest', { assets: discoveredAssets });
+          }
+        }
+
+        return {
+          ...file,
+          content,
+        };
+      },
+    },
+  };
+}
