@@ -0,0 +1,62 @@
+import { Plugin, BuildContext } from '../core/types.js';
+
+interface DevServerRoute {
+  path: string;
+  handler: 'static' | 'asset';
+}
+
+interface DevServerConfig {
+  port: number;
+  routes: DevServerRoute[];
+  assetPaths: string[];
+  searchIndexPath: string;
+}
+
+export function createDevServerPlugin(): Plugin {
+  return {
+    name: 'dev-server',
+    version: '1.0.0',
+    dependencies: ['asset-pipeline', 'search-index'],
+    hooks: {
+      afterBuild: async (ctx: BuildContext): Promise<void> => {
+        const routes: DevServerRoute[] = [];
+        const assetPaths: string[] = [];
+
+        // Get asset manifest from asset-pipeline
+        const assetManifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;
+        if (assetManifest && assetManifest.assets) {
+          for (const asset of assetManifest.assets) {
+            assetPaths.push(asset);
+            routes.push({
+              path: `/assets/${asset}`,
+              handler: 'asset',
+            });
+          }
+        }
+
+        // Add content routes from ctx.output
+        for (const [path, _] of ctx.output) {
+          if (path.endsWith('.html')) {
+            routes.push({
+              path: `/${path}`,
+              handler: 'static',
+            });
+          }
+        }
+
+        // Determine search index path
+        const searchIndexPath = ctx.output.has('search-index.json') ? '/search-index.json' : '';
+
+        // Create dev server config
+        const config: DevServerConfig = {
+          port: 3000,
+          routes,
+          assetPaths,
+          searchIndexPath,
+        };
+
+        ctx.data.set('dev-server-config', config);
+      },
+    },
+  };
+}
