@@ -0,0 +1,83 @@
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createRssFeedPlugin(): Plugin {
+  return {
+    name: 'rss-feed',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'taxonomy'],
+    hooks: {
+      afterBuild: async (ctx: BuildContext): Promise<void> => {
+        // Get taxonomy tags from ctx.data
+        const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]> | undefined;
+
+        // Sort files by date (newest first)
+        const sortedFiles = [...ctx.files].sort((a, b) => {
+          const dateA = a.date ? new Date(a.date).getTime() : 0;
+          const dateB = b.date ? new Date(b.date).getTime() : 0;
+          return dateB - dateA;
+        });
+
+        // Build RSS items
+        const items: string[] = [];
+        for (const file of sortedFiles) {
+          const title = file.title;
+          const link = `${ctx.config.baseUrl}/${file.slug}.html`;
+          const pubDate = file.date ? new Date(file.date).toUTCString() : '';
+          const content = `<![CDATA[${file.content}]]>`;
+
+          // Build categories from tags
+          let categories = '';
+          if (file.tags && file.tags.length > 0) {
+            categories = file.tags
+              .map((tag) => `<category>${tag.toLowerCase()}</category>`)
+              .join('\n      ');
+          } else if (tagMap) {
+            // Also check if file is in any taxonomy tags
+            const fileTags: string[] = [];
+            tagMap.forEach((files, tag) => {
+              if (files.some((f) => f.slug === file.slug)) {
+                fileTags.push(tag);
+              }
+            });
+            if (fileTags.length > 0) {
+              categories = fileTags.map((tag) => `<category>${tag}</category>`).join('\n      ');
+            }
+          }
+
+          const item = `    <item>
+      <title>${escapeXml(title)}</title>
+      <link>${link}</link>
+      <guid>${link}</guid>
+      ${pubDate ? `<pubDate>${pubDate}</pubDate>` : ''}
+      <description>${content}</description>
+      ${categories ? categories + '\n      ' : ''}</item>`;
+
+          items.push(item);
+        }
+
+        // Build RSS feed
+        const rss = `<?xml version="1.0" encoding="UTF-8"?>
+<rss version="2.0">
+  <channel>
+    <title>${escapeXml(ctx.config.title)}</title>
+    <link>${ctx.config.baseUrl}</link>
+    <description>RSS feed for ${escapeXml(ctx.config.title)}</description>
+    <language>en</language>
+${items.join('\n')}
+  </channel>
+</rss>`;
+
+        ctx.output.set('feed.xml', rss);
+      },
+    },
+  };
+}
+
+function escapeXml(text: string): string {
+  return text
+    .replace(/&/g, '&amp;')
+    .replace(/</g, '&lt;')
+    .replace(/>/g, '&gt;')
+    .replace(/"/g, '&quot;')
+    .replace(/'/g, '&apos;');
+}
diff --git a/src/plugins/search-index.ts b/src/plugins/search-index.ts
new file mode 100644
index 0000000..a6b1546
--- /dev/null
+++ b/src/plugins/search-index.ts
@@ -0,0 +1,66 @@
+import { Plugin, BuildContext } from '../core/types.js';
+
+interface SearchIndexEntry {
+  slug: string;
+  title: string;
+  content: string;
+  tags?: string[];
+}
+
+export function createSearchIndexPlugin(): Plugin {
+  return {
+    name: 'search-index',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'syntax-highlight'],
+    hooks: {
+      afterBuild: async (ctx: BuildContext): Promise<void> => {
+        const index: SearchIndexEntry[] = [];
+
+        for (const file of ctx.files) {
+          // Strip HTML tags from content to get plain text
+          const plainText = stripHtml(file.content);
+
+          const entry: SearchIndexEntry = {
+            slug: file.slug,
+            title: file.title,
+            content: plainText,
+          };
+
+          // Include tags if present
+          if (file.tags && file.tags.length > 0) {
+            entry.tags = file.tags;
+          }
+
+          index.push(entry);
+        }
+
+        // Store the search index as JSON in ctx.output
+        ctx.output.set('search-index.json', JSON.stringify(index, null, 2));
+      },
+    },
+  };
+}
+
+function stripHtml(html: string): string {
+  // Remove script and style elements
+  let text = html.replace(/<script[^>]*>[\s\S]*?<\/script>/gi, '');
+  text = text.replace(/<style[^>]*>[\s\S]*?<\/style>/gi, '');
+
+  // Remove HTML tags but preserve content
+  text = text.replace(/<[^>]+>/g, ' ');
+
+  // Normalize whitespace
+  text = text.replace(/\s+/g, ' ').trim();
+
+  // Decode common HTML entities
+  text = text
+    .replace(/&amp;/g, '&')
+    .replace(/&lt;/g, '<')
+    .replace(/&gt;/g, '>')
+    .replace(/&quot;/g, '"')
+    .replace(/&apos;/g, "'")
+    .replace(/&#(\d+);/g, (_match, dec) => String.fromCharCode(dec))
+    .replace(/&#x([0-9a-fA-F]+);/g, (_match, hex) => String.fromCharCode(parseInt(hex, 16)));
+
+  return text;
+}
