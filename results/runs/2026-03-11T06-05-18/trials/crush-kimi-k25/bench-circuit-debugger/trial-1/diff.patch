+import { describe, it, expect } from 'vitest';
+import { simulate, findSwappedWires, Gate } from './index';
+
+describe('simulate', () => {
+  it('should simulate a simple AND gate', () => {
+    const gates: Gate[] = [
+      { op: 'AND', in1: 'a', in2: 'b', out: 'c' }
+    ];
+    const inputs = { a: 1, b: 1 };
+    const result = simulate(gates, inputs);
+    expect(result.c).toBe(1);
+  });
+
+  it('should simulate a simple OR gate', () => {
+    const gates: Gate[] = [
+      { op: 'OR', in1: 'a', in2: 'b', out: 'c' }
+    ];
+    const inputs = { a: 1, b: 0 };
+    const result = simulate(gates, inputs);
+    expect(result.c).toBe(1);
+  });
+
+  it('should simulate a simple XOR gate', () => {
+    const gates: Gate[] = [
+      { op: 'XOR', in1: 'a', in2: 'b', out: 'c' }
+    ];
+    const inputs = { a: 1, b: 1 };
+    const result = simulate(gates, inputs);
+    expect(result.c).toBe(0);
+  });
+
+  it('should handle chained gates', () => {
+    const gates: Gate[] = [
+      { op: 'AND', in1: 'a', in2: 'b', out: 'temp' },
+      { op: 'XOR', in1: 'temp', in2: 'c', out: 'result' }
+    ];
+    const inputs = { a: 1, b: 1, c: 0 };
+    const result = simulate(gates, inputs);
+    expect(result.temp).toBe(1);
+    expect(result.result).toBe(1);
+  });
+
+  it('should simulate a 2-bit adder', () => {
+    // 1 + 1 = 2 (binary: 01 + 01 = 10)
+    const gates: Gate[] = [
+      // Bit 0: half adder
+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+      // Bit 1: full adder
+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },
+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },
+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },
+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },
+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' }
+    ];
+    const inputs = { x00: 1, y00: 1, x01: 0, y01: 0 };
+    const result = simulate(gates, inputs);
+    expect(result.z00).toBe(0); // 1+1=0 (with carry)
+    expect(result.z01).toBe(1); // carry from bit 0
+    expect(result.z02).toBe(0); // no overflow
+  });
+});
+
+describe('findSwappedWires', () => {
+  it('should return empty for a correct circuit', () => {
+    const gates: Gate[] = [
+      // Bit 0: half adder
+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+      // Bit 1: full adder
+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },
+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },
+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },
+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },
+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' }
+    ];
+    const result = findSwappedWires(gates);
+    expect(result).toEqual([]);
+  });
+
+  it('should detect a simple swap', () => {
+    // Swap z01 and a01
+    const gates: Gate[] = [
+      // Bit 0: half adder
+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+      // Bit 1: full adder with swapped outputs
+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },
+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'a01' },  // should be z01
+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'z01' },  // should be a01 (but z01 is wrong)
+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },
+      { op: 'OR', in1: 'z01', in2: 'b01', out: 'z02' }
+    ];
+    const result = findSwappedWires(gates);
+    expect(result).toContain('z01');
+    expect(result).toContain('a01');
+  });
+
+  it('should detect swap of partial sum and z output', () => {
+    // Swap t01 (partial sum) with z01
+    const gates: Gate[] = [
+      // Bit 0: half adder
+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+      // Bit 1: full adder with swapped outputs
+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 'z01' },  // should be t01
+      { op: 'XOR', in1: 'z01', in2: 'c00', out: 'z01b' }, // uses wrong input
+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },
+      { op: 'AND', in1: 'z01', in2: 'c00', out: 'b01' },
+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' }
+    ];
+    const result = findSwappedWires(gates);
+    expect(result).toContain('z01');
+  });
+
+  it('should handle a 4-bit adder with no swaps', () => {
+    // 4-bit adder: x03x02x01x00 + y03y02y01y00 = z04z03z02z01z00
+    const gates: Gate[] = [
+      // Bit 0: half adder
+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+      // Bit 1: full adder
+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },
+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },
+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },
+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },
+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },
+      // Bit 2: full adder
+      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },
+      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },
+      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },
+      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },
+      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },
+      // Bit 3: full adder
+      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },
+      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },
+      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },
+      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },
+      { op: 'OR', in1: 'a03', in2: 'b03', out: 'z04' }
+    ];
+    const result = findSwappedWires(gates);
+    expect(result).toEqual([]);
+  });
+
+  it('should detect when z output is swapped with intermediate wire', () => {
+    // Swap z02 with a02 in a 4-bit adder
+    const gates: Gate[] = [
+      // Bit 0: half adder
+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+      // Bit 1: full adder
+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },
+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },
+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },
+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },
+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },
+      // Bit 2: full adder with swap
+      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },
+      { op: 'XOR', in1: 't02', in2: 'c01', out: 'a02' },  // should be z02
+      { op: 'AND', in1: 'x02', in2: 'y02', out: 'z02' },  // should be a02
+      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },
+      { op: 'OR', in1: 'z02', in2: 'b02', out: 'c02' },
+      // Bit 3: full adder
+      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },
+      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },
+      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },
+      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },
+      { op: 'OR', in1: 'a03', in2: 'b03', out: 'z04' }
+    ];
+    const result = findSwappedWires(gates);
+    expect(result).toContain('z02');
+    expect(result).toContain('a02');
+  });
+
+  it('should handle larger adders efficiently', () => {
+    // Generate an 8-bit adder
+    const gates: Gate[] = [];
+
+    // Bit 0: half adder
+    gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });
+    gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });
+
+    let prevCarry = 'c00';
+
+    // Bits 1-7: full adders
+    for (let i = 1; i <= 7; i++) {
+      const xWire = `x${i.toString().padStart(2, '0')}`;
+      const yWire = `y${i.toString().padStart(2, '0')}`;
+      const zWire = `z${i.toString().padStart(2, '0')}`;
+      const tWire = `t${i.toString().padStart(2, '0')}`;
+      const aWire = `a${i.toString().padStart(2, '0')}`;
+      const bWire = `b${i.toString().padStart(2, '0')}`;
+      const cWire = i === 7 ? 'z08' : `c${i.toString().padStart(2, '0')}`;
+
+      gates.push({ op: 'XOR', in1: xWire, in2: yWire, out: tWire });
+      gates.push({ op: 'XOR', in1: tWire, in2: prevCarry, out: zWire });
+      gates.push({ op: 'AND', in1: xWire, in2: yWire, out: aWire });
+      gates.push({ op: 'AND', in1: tWire, in2: prevCarry, out: bWire });
+      gates.push({ op: 'OR', in1: aWire, in2: bWire, out: cWire });
+
+      prevCarry = cWire;
+    }
+
+    const start = Date.now();
+    const result = findSwappedWires(gates);
+    const duration = Date.now() - start;
+
+    expect(result).toEqual([]);
+    expect(duration).toBeLessThan(100); // Should be very fast
+  });
+});
