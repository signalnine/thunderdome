@@ -0,0 +1,245 @@
+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number> {
+  const values: Record<string, number> = { ...inputs };
+  const remaining = new Set<Gate>(gates);
+
+  while (remaining.size > 0) {
+    let progress = false;
+
+    for (const gate of remaining) {
+      if (gate.in1 in values && gate.in2 in values) {
+        const v1 = values[gate.in1];
+        const v2 = values[gate.in2];
+        let result: number;
+
+        switch (gate.op) {
+          case 'AND':
+            result = v1 & v2;
+            break;
+          case 'OR':
+            result = v1 | v2;
+            break;
+          case 'XOR':
+            result = v1 ^ v2;
+            break;
+        }
+
+        values[gate.out] = result;
+        remaining.delete(gate);
+        progress = true;
+      }
+    }
+
+    if (!progress && remaining.size > 0) {
+      throw new Error('Circular dependency detected or missing inputs');
+    }
+  }
+
+  return values;
+}
+
+export function findSwappedWires(gates: Gate[]): string[] {
+  // Build lookup maps
+  const gateByOutput = new Map<string, Gate>();
+  const gatesByInput = new Map<string, Gate[]>();
+
+  for (const gate of gates) {
+    gateByOutput.set(gate.out, gate);
+
+    // Index by each input
+    if (!gatesByInput.has(gate.in1)) gatesByInput.set(gate.in1, []);
+    if (!gatesByInput.has(gate.in2)) gatesByInput.set(gate.in2, []);
+    gatesByInput.get(gate.in1)!.push(gate);
+    gatesByInput.get(gate.in2)!.push(gate);
+  }
+
+  // Find max bit position
+  let maxBit = 0;
+  for (const gate of gates) {
+    for (const wire of [gate.in1, gate.in2, gate.out]) {
+      if (wire.startsWith('x') || wire.startsWith('y')) {
+        const num = parseInt(wire.slice(1), 10);
+        if (!isNaN(num)) maxBit = Math.max(maxBit, num);
+      }
+    }
+  }
+
+  const swapped = new Set<string>();
+
+  // Helper to find gate by inputs and operation
+  function findGate(in1: string, in2: string, op: string): Gate | undefined {
+    const candidates = gatesByInput.get(in1) || [];
+    return candidates.find(g =>
+      g.op === op && (g.in1 === in2 || g.in2 === in2)
+    );
+  }
+
+  // Trace through the adder structure
+  let carry: string | null = null;
+
+  for (let i = 0; i <= maxBit; i++) {
+    const xWire = `x${i.toString().padStart(2, '0')}`;
+    const yWire = `y${i.toString().padStart(2, '0')}`;
+    const zWire = `z${i.toString().padStart(2, '0')}`;
+
+    // Find the partial sum XOR gate (xi XOR yi)
+    const partialXor = findGate(xWire, yWire, 'XOR');
+    // Find the generate AND gate (xi AND yi)
+    const generateAnd = findGate(xWire, yWire, 'AND');
+
+    if (i === 0) {
+      // Bit 0: half adder
+      // z00 should be output of x00 XOR y00
+      // c00 should be output of x00 AND y00
+
+      if (partialXor && partialXor.out !== zWire) {
+        // The XOR output went somewhere else
+        if (partialXor.out.startsWith('z')) {
+          swapped.add(partialXor.out);
+        }
+      }
+
+      if (generateAnd) {
+        carry = generateAnd.out;
+      }
+    } else {
+      // Bit 1+: full adder
+      // Structure:
+      //   ti = xi XOR yi (partial sum)
+      //   zi = ti XOR ci-1 (final sum)
+      //   ai = xi AND yi (generate)
+      //   bi = ti AND ci-1 (propagate)
+      //   ci = ai OR bi (carry out)
+
+      if (!partialXor || !generateAnd || !carry) {
+        continue;
+      }
+
+      const partialSum = partialXor.out;
+
+      // Find the final sum XOR gate (partialSum XOR carry)
+      const sumXor = findGate(partialSum, carry, 'XOR');
+
+      if (sumXor) {
+        if (sumXor.out !== zWire) {
+          // The sum XOR output went to wrong wire
+          if (sumXor.out.startsWith('z')) {
+            swapped.add(sumXor.out);
+          }
+        }
+      }
+
+      // Check what drives z wire
+      const zDriver = gateByOutput.get(zWire);
+      if (zDriver) {
+        // z should be driven by XOR (for bits 1 to maxBit)
+        if (zDriver.op !== 'XOR') {
+          swapped.add(zWire);
+        }
+      }
+
+      // Check if partial XOR outputs to z (wrong for bit > 0)
+      if (partialXor.out.startsWith('z') && partialXor.out !== zWire) {
+        swapped.add(partialXor.out);
+      }
+
+      // Find propagate AND gate (partialSum AND carry)
+      const propagateAnd = findGate(partialSum, carry, 'AND');
+
+      if (propagateAnd && generateAnd) {
+        // Find carry OR gate (generate AND result OR propagate AND result)
+        const carryOr = findGate(generateAnd.out, propagateAnd.out, 'OR');
+        if (carryOr) {
+          carry = carryOr.out;
+        }
+      }
+    }
+  }
+
+  // Final carry should go to z(maxBit+1)
+  const highestZ = `z${(maxBit + 1).toString().padStart(2, '0')}`;
+  const finalZDriver = gateByOutput.get(highestZ);
+
+  if (finalZDriver && finalZDriver.op !== 'OR') {
+    swapped.add(highestZ);
+  }
+
+  if (carry && carry !== highestZ && carry.startsWith('z')) {
+    swapped.add(carry);
+  }
+
+  // Additional structural validation
+  // Check all XOR gates without x/y inputs - they should output to z
+  for (const gate of gates) {
+    if (gate.op === 'XOR') {
+      const hasXYInput = (gate.in1.startsWith('x') && gate.in2.startsWith('y')) ||
+                         (gate.in1.startsWith('y') && gate.in2.startsWith('x'));
+
+      if (!hasXYInput && !gate.out.startsWith('z')) {
+        // This XOR computes sum from intermediate values but doesn't output to z
+        // Check if it takes partial sum and carry as inputs
+        const in1Gate = gateByOutput.get(gate.in1);
+        const in2Gate = gateByOutput.get(gate.in2);
+
+        if (in1Gate && in2Gate) {
+          const in1HasXY = (in1Gate.in1.startsWith('x') && in1Gate.in2.startsWith('y')) ||
+                           (in1Gate.in1.startsWith('y') && in1Gate.in2.startsWith('x'));
+          const in2HasXY = (in2Gate.in1.startsWith('x') && in2Gate.in2.startsWith('y')) ||
+                           (in2Gate.in1.startsWith('y') && in2Gate.in2.startsWith('x'));
+
+          // One input should be partial sum (XOR with x/y), other should be carry (OR or AND for bit 0)
+          const in1IsPartial = in1Gate.op === 'XOR' && in1HasXY;
+          const in2IsPartial = in2Gate.op === 'XOR' && in2HasXY;
+          const in1IsCarry = in1Gate.op === 'OR' || (in1Gate.op === 'AND' && in1HasXY);
+          const in2IsCarry = in2Gate.op === 'OR' || (in2Gate.op === 'AND' && in2HasXY);
+
+          if ((in1IsPartial && in2IsCarry) || (in2IsPartial && in1IsCarry)) {
+            swapped.add(gate.out);
+          }
+        }
+      }
+    }
+  }
+
+  // Check all AND gates - they should NOT output to z (except maybe through swap)
+  for (const gate of gates) {
+    if (gate.op === 'AND' && gate.out.startsWith('z') && gate.out !== highestZ) {
+      swapped.add(gate.out);
+    }
+  }
+
+  // Check all OR gates - only the highest z should come from OR
+  for (const gate of gates) {
+    if (gate.op === 'OR' && gate.out.startsWith('z') && gate.out !== highestZ) {
+      swapped.add(gate.out);
+    }
+  }
+
+  // Check XOR gates with x/y inputs for bit > 0 - should NOT output to z
+  for (const gate of gates) {
+    if (gate.op === 'XOR') {
+      const xMatch = gate.in1.match(/^x(\d+)$/);
+      const yMatch = gate.in2.match(/^y(\d+)$/);
+      const yMatch2 = gate.in1.match(/^y(\d+)$/);
+      const xMatch2 = gate.in2.match(/^x(\d+)$/);
+
+      const bit1 = xMatch ? parseInt(xMatch[1], 10) : (yMatch2 ? parseInt(yMatch2[1], 10) : null);
+      const bit2 = yMatch ? parseInt(yMatch[1], 10) : (xMatch2 ? parseInt(xMatch2[1], 10) : null);
+
+      if (bit1 !== null && bit2 !== null && bit1 === bit2 && bit1 > 0) {
+        // This is a partial sum XOR for bit > 0, should NOT output to z
+        if (gate.out.startsWith('z')) {
+          swapped.add(gate.out);
+        }
+      }
+    }
+  }
+
+  return Array.from(swapped).sort();
+}
