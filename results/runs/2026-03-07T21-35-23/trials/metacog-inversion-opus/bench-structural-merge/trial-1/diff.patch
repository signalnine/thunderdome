+import { describe, it, expect, beforeEach } from 'vitest';
+import { DocumentStore } from './index.js';
+
+describe('DocumentStore', () => {
+  let store: DocumentStore;
+
+  beforeEach(() => {
+    store = new DocumentStore();
+  });
+
+  describe('Document CRUD', () => {
+    it('should create and get a document', () => {
+      store.create('doc1', { name: 'hello' });
+      expect(store.get('doc1')).toEqual({ name: 'hello' });
+    });
+
+    it('should throw when creating a document with existing id', () => {
+      store.create('doc1', { name: 'hello' });
+      expect(() => store.create('doc1', { name: 'world' })).toThrow();
+    });
+
+    it('should update a document', () => {
+      store.create('doc1', { name: 'hello' });
+      store.update('doc1', { name: 'world' });
+      expect(store.get('doc1')).toEqual({ name: 'world' });
+    });
+
+    it('should throw when updating a non-existent document', () => {
+      expect(() => store.update('doc1', { name: 'hello' })).toThrow();
+    });
+
+    it('should delete a document', () => {
+      store.create('doc1', { name: 'hello' });
+      store.delete('doc1');
+      expect(() => store.get('doc1')).toThrow();
+    });
+
+    it('should throw when deleting a non-existent document', () => {
+      expect(() => store.delete('doc1')).toThrow();
+    });
+
+    it('should throw when getting a deleted document', () => {
+      store.create('doc1', { name: 'hello' });
+      store.delete('doc1');
+      expect(() => store.get('doc1')).toThrow();
+    });
+
+    it('should deep clone on create to prevent mutation', () => {
+      const content = { name: 'hello', nested: { value: 1 } };
+      store.create('doc1', content);
+      content.nested.value = 999;
+      expect(store.get('doc1')).toEqual({ name: 'hello', nested: { value: 1 } });
+    });
+
+    it('should deep clone on get to prevent mutation', () => {
+      store.create('doc1', { name: 'hello', nested: { value: 1 } });
+      const retrieved = store.get('doc1') as { nested: { value: number } };
+      retrieved.nested.value = 999;
+      expect(store.get('doc1')).toEqual({ name: 'hello', nested: { value: 1 } });
+    });
+  });
+
+  describe('Version History', () => {
+    it('should track versions on create', () => {
+      store.create('doc1', { name: 'hello' });
+      const history = store.getHistory('doc1');
+      expect(history).toHaveLength(1);
+      expect(history[0].content).toEqual({ name: 'hello' });
+    });
+
+    it('should track versions on update', () => {
+      store.create('doc1', { name: 'v1' });
+      store.update('doc1', { name: 'v2' });
+      store.update('doc1', { name: 'v3' });
+      const history = store.getHistory('doc1');
+      expect(history).toHaveLength(3);
+      expect(history[0].content).toEqual({ name: 'v1' });
+      expect(history[1].content).toEqual({ name: 'v2' });
+      expect(history[2].content).toEqual({ name: 'v3' });
+    });
+
+    it('should get specific version by id', () => {
+      store.create('doc1', { name: 'v1' });
+      store.update('doc1', { name: 'v2' });
+      const history = store.getHistory('doc1');
+      const v1Content = store.getVersion('doc1', history[0].id);
+      expect(v1Content).toEqual({ name: 'v1' });
+    });
+
+    it('should throw for non-existent version', () => {
+      store.create('doc1', { name: 'v1' });
+      expect(() => store.getVersion('doc1', 'non-existent')).toThrow();
+    });
+
+    it('should return versions in chronological order', () => {
+      store.create('doc1', { name: 'v1' });
+      store.update('doc1', { name: 'v2' });
+      store.update('doc1', { name: 'v3' });
+      const history = store.getHistory('doc1');
+      for (let i = 1; i < history.length; i++) {
+        expect(history[i].timestamp).toBeGreaterThanOrEqual(history[i - 1].timestamp);
+      }
+    });
+
+    it('should have unique version ids', () => {
+      store.create('doc1', { name: 'v1' });
+      store.update('doc1', { name: 'v2' });
+      const history = store.getHistory('doc1');
+      expect(history[0].id).not.toEqual(history[1].id);
+    });
+  });
+
+  describe('Branching', () => {
+    it('should default to main branch', () => {
+      expect(store.getBranch()).toBe('main');
+    });
+
+    it('should create and switch branches', () => {
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      expect(store.getBranch()).toBe('feature');
+    });
+
+    it('should list branches', () => {
+      store.createBranch('feature');
+      store.createBranch('bugfix');
+      expect(store.listBranches()).toContain('main');
+      expect(store.listBranches()).toContain('feature');
+      expect(store.listBranches()).toContain('bugfix');
+    });
+
+    it('should isolate changes between branches', () => {
+      store.create('doc1', { name: 'original' });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { name: 'changed' });
+
+      store.switchBranch('main');
+      expect(store.get('doc1')).toEqual({ name: 'original' });
+
+      store.switchBranch('feature');
+      expect(store.get('doc1')).toEqual({ name: 'changed' });
+    });
+
+    it('should not see documents created on other branches', () => {
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.create('doc1', { name: 'feature-only' });
+
+      store.switchBranch('main');
+      expect(() => store.get('doc1')).toThrow();
+    });
+
+    it('should throw when creating a branch that already exists', () => {
+      store.createBranch('feature');
+      expect(() => store.createBranch('feature')).toThrow();
+    });
+
+    it('should throw when switching to a non-existent branch', () => {
+      expect(() => store.switchBranch('nonexistent')).toThrow();
+    });
+
+    it('should branch from a specified branch', () => {
+      store.create('doc1', { name: 'main-doc' });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.create('doc2', { name: 'feature-doc' });
+
+      store.switchBranch('main');
+      store.createBranch('from-feature', 'feature');
+      store.switchBranch('from-feature');
+
+      expect(store.get('doc1')).toEqual({ name: 'main-doc' });
+      expect(store.get('doc2')).toEqual({ name: 'feature-doc' });
+    });
+  });
+
+  describe('Merging', () => {
+    it('should merge non-conflicting changes from source branch', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 10, b: 2 });
+
+      store.switchBranch('main');
+      const result = store.merge('feature');
+
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(result.merged['doc1']).toEqual({ a: 10, b: 2 });
+      expect(store.get('doc1')).toEqual({ a: 10, b: 2 });
+    });
+
+    it('should handle both sides changing different fields', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 10, b: 2 });
+
+      store.switchBranch('main');
+      store.update('doc1', { a: 1, b: 20 });
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(result.merged['doc1']).toEqual({ a: 10, b: 20 });
+      expect(store.get('doc1')).toEqual({ a: 10, b: 20 });
+    });
+
+    it('should detect conflicts when both sides change the same field differently', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 100, b: 2 });
+
+      store.switchBranch('main');
+      store.update('doc1', { a: 200, b: 2 });
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(false);
+      expect(result.conflicts).toHaveLength(1);
+      expect(result.conflicts[0].documentId).toBe('doc1');
+      expect(result.conflicts[0].path).toBe('a');
+      expect(result.conflicts[0].base).toBe(1);
+      expect(result.conflicts[0].ours).toBe(200);
+      expect(result.conflicts[0].theirs).toBe(100);
+    });
+
+    it('should not apply merge when there are conflicts', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 100 });
+
+      store.switchBranch('main');
+      store.update('doc1', { a: 200 });
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(false);
+      // Current branch should remain unchanged
+      expect(store.get('doc1')).toEqual({ a: 200 });
+    });
+
+    it('should not conflict when both sides change a field to the same value', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 42 });
+
+      store.switchBranch('main');
+      store.update('doc1', { a: 42 });
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+    });
+
+    it('should merge new documents from source branch', () => {
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.create('doc1', { name: 'new-doc' });
+
+      store.switchBranch('main');
+      const result = store.merge('feature');
+
+      expect(result.applied).toBe(true);
+      expect(result.merged['doc1']).toEqual({ name: 'new-doc' });
+      expect(store.get('doc1')).toEqual({ name: 'new-doc' });
+    });
+
+    it('should handle independent documents merging cleanly', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.create('doc2', { b: 2 });
+
+      store.switchBranch('main');
+      store.create('doc3', { c: 3 });
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(store.get('doc2')).toEqual({ b: 2 });
+      expect(store.get('doc3')).toEqual({ c: 3 });
+    });
+
+    it('should handle nested object merging', () => {
+      store.create('doc1', { user: { name: 'Alice', age: 30, email: 'alice@test.com' } });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { user: { name: 'Alice', age: 31, email: 'alice@test.com' } });
+
+      store.switchBranch('main');
+      store.update('doc1', { user: { name: 'Alice', age: 30, email: 'alice@new.com' } });
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.merged['doc1']).toEqual({
+        user: { name: 'Alice', age: 31, email: 'alice@new.com' },
+      });
+    });
+
+    it('should handle nested object conflicts', () => {
+      store.create('doc1', { config: { theme: 'light', lang: 'en' } });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { config: { theme: 'dark', lang: 'en' } });
+
+      store.switchBranch('main');
+      store.update('doc1', { config: { theme: 'blue', lang: 'en' } });
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(false);
+      expect(result.conflicts).toHaveLength(1);
+      expect(result.conflicts[0].path).toBe('config.theme');
+    });
+
+    it('should show merged result with ours for conflicts', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 100, b: 200 });
+
+      store.switchBranch('main');
+      store.update('doc1', { a: 999, b: 888 });
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(false);
+      // merged should show ours for conflicting fields
+      expect(result.merged['doc1']).toEqual({ a: 999, b: 888 });
+    });
+
+    it('should handle merge with no changes (fast-forward)', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+
+      // No changes on either side
+      store.switchBranch('main');
+      const result = store.merge('feature');
+
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+    });
+
+    it('should add new fields from source branch', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 1, b: 2 });
+
+      store.switchBranch('main');
+      const result = store.merge('feature');
+
+      expect(result.applied).toBe(true);
+      expect(result.merged['doc1']).toEqual({ a: 1, b: 2 });
+      expect(store.get('doc1')).toEqual({ a: 1, b: 2 });
+    });
+  });
+});
