--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,411 @@
+import { deepClone } from './utils.js';
+import { threeWayMerge, Conflict } from './merge.js';
+
+export { Conflict };
+
+export interface Version {
+  id: string;
+  timestamp: number;
+  content: object;
+}
+
+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+interface DocumentEntry {
+  content: object;
+  versions: Version[];
+  deleted: boolean;
+}
+
+interface BranchState {
+  documents: Map<string, DocumentEntry>;
+  /** The branch this was forked from, and a snapshot of that branch's documents at fork time */
+  parent?: {
+    branchName: string;
+    snapshot: Map<string, DocumentEntry>;
+  };
+}
+
+let versionCounter = 0;
+
+function generateVersionId(): string {
+  return `v_${++versionCounter}_${Date.now()}`;
+}
+
+function cloneDocumentEntry(entry: DocumentEntry): DocumentEntry {
+  return {
+    content: deepClone(entry.content),
+    versions: entry.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    })),
+    deleted: entry.deleted,
+  };
+}
+
+function snapshotDocuments(docs: Map<string, DocumentEntry>): Map<string, DocumentEntry> {
+  const snapshot = new Map<string, DocumentEntry>();
+  for (const [id, entry] of docs) {
+    snapshot.set(id, cloneDocumentEntry(entry));
+  }
+  return snapshot;
+}
+
+export class DocumentStore {
+  private branches: Map<string, BranchState> = new Map();
+  private currentBranch: string = 'main';
+
+  constructor() {
+    this.branches.set('main', { documents: new Map() });
+  }
+
+  // --- Document CRUD ---
+
+  create(id: string, content: object): void {
+    const branch = this.getCurrentBranchState();
+    const existing = branch.documents.get(id);
+    if (existing && !existing.deleted) {
+      throw new Error(`Document "${id}" already exists`);
+    }
+    const version: Version = {
+      id: generateVersionId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+    branch.documents.set(id, {
+      content: deepClone(content),
+      versions: [version],
+      deleted: false,
+    });
+  }
+
+  get(id: string): object {
+    const branch = this.getCurrentBranchState();
+    const entry = branch.documents.get(id);
+    if (!entry || entry.deleted) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    return deepClone(entry.content);
+  }
+
+  update(id: string, content: object): void {
+    const branch = this.getCurrentBranchState();
+    const entry = branch.documents.get(id);
+    if (!entry || entry.deleted) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    const version: Version = {
+      id: generateVersionId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+    entry.content = deepClone(content);
+    entry.versions.push(version);
+  }
+
+  delete(id: string): void {
+    const branch = this.getCurrentBranchState();
+    const entry = branch.documents.get(id);
+    if (!entry || entry.deleted) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    entry.deleted = true;
+  }
+
+  // --- Version History ---
+
+  getHistory(id: string): Version[] {
+    const branch = this.getCurrentBranchState();
+    const entry = branch.documents.get(id);
+    if (!entry) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    return entry.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    }));
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const branch = this.getCurrentBranchState();
+    const entry = branch.documents.get(id);
+    if (!entry) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    const version = entry.versions.find(v => v.id === versionId);
+    if (!version) {
+      throw new Error(`Version "${versionId}" not found for document "${id}"`);
+    }
+    return deepClone(version.content);
+  }
+
+  // --- Branching ---
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch "${name}" already exists`);
+    }
+    const sourceBranchName = fromBranch ?? this.currentBranch;
+    const sourceBranch = this.branches.get(sourceBranchName);
+    if (!sourceBranch) {
+      throw new Error(`Branch "${sourceBranchName}" not found`);
+    }
+    // Snapshot the source branch's documents at this point in time
+    const snapshot = snapshotDocuments(sourceBranch.documents);
+    const newBranch: BranchState = {
+      documents: snapshotDocuments(sourceBranch.documents),
+      parent: {
+        branchName: sourceBranchName,
+        snapshot,
+      },
+    };
+    this.branches.set(name, newBranch);
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch "${name}" not found`);
+    }
+    this.currentBranch = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranch;
+  }
+
+  listBranches(): string[] {
+    return Array.from(this.branches.keys());
+  }
+
+  // --- Merging ---
+
+  merge(sourceBranch: string): MergeResult {
+    const sourceBranchState = this.branches.get(sourceBranch);
+    if (!sourceBranchState) {
+      throw new Error(`Branch "${sourceBranch}" not found`);
+    }
+    const targetBranchState = this.getCurrentBranchState();
+
+    // Find common ancestor: we use the snapshot stored at branch creation time
+    // The ancestor is the state of the parent branch when the child was created
+    const ancestor = this.findCommonAncestor(sourceBranch, this.currentBranch);
+
+    // Collect all document IDs across ancestor, source, and target
+    const allDocIds = new Set<string>();
+    if (ancestor) {
+      for (const id of ancestor.keys()) allDocIds.add(id);
+    }
+    for (const id of sourceBranchState.documents.keys()) allDocIds.add(id);
+    for (const id of targetBranchState.documents.keys()) allDocIds.add(id);
+
+    const merged: Record<string, object> = {};
+    const allConflicts: Conflict[] = [];
+
+    for (const docId of allDocIds) {
+      const baseEntry = ancestor?.get(docId);
+      const oursEntry = targetBranchState.documents.get(docId);
+      const theirsEntry = sourceBranchState.documents.get(docId);
+
+      // Get content, treating deleted docs as undefined
+      const baseContent = baseEntry && !baseEntry.deleted ? baseEntry.content : undefined;
+      const oursContent = oursEntry && !oursEntry.deleted ? oursEntry.content : undefined;
+      const theirsContent = theirsEntry && !theirsEntry.deleted ? theirsEntry.content : undefined;
+
+      // Skip if nothing exists on either side and no base
+      if (baseContent === undefined && oursContent === undefined && theirsContent === undefined) {
+        continue;
+      }
+
+      // Check if either side actually changed from base
+      const oursMatchesBase = deepEqualOptional(baseContent, oursContent);
+      const theirsMatchesBase = deepEqualOptional(baseContent, theirsContent);
+
+      if (oursMatchesBase && theirsMatchesBase) {
+        // No changes on either side — keep as-is
+        if (oursContent !== undefined) {
+          merged[docId] = deepClone(oursContent);
+        }
+        continue;
+      }
+
+      if (oursMatchesBase && !theirsMatchesBase) {
+        // Only source branch changed — fast-forward
+        if (theirsContent !== undefined) {
+          merged[docId] = deepClone(theirsContent);
+        }
+        // If theirs deleted it, don't include in merged
+        continue;
+      }
+
+      if (!oursMatchesBase && theirsMatchesBase) {
+        // Only target branch changed — keep ours
+        if (oursContent !== undefined) {
+          merged[docId] = deepClone(oursContent);
+        }
+        continue;
+      }
+
+      // Both sides changed — need three-way merge
+      if (oursContent === undefined && theirsContent === undefined) {
+        // Both deleted — no conflict
+        continue;
+      }
+
+      if (oursContent === undefined || theirsContent === undefined) {
+        // One deleted, one modified — conflict on the whole document
+        // We treat this as a conflict at the root level
+        if (oursContent === undefined && theirsContent !== undefined) {
+          // Ours deleted, theirs modified
+          allConflicts.push({
+            documentId: docId,
+            path: '',
+            base: baseContent !== undefined ? deepClone(baseContent) : undefined,
+            ours: undefined,
+            theirs: deepClone(theirsContent),
+          });
+          // For merged, use ours (deleted = not included)
+        } else {
+          // Ours modified, theirs deleted
+          allConflicts.push({
+            documentId: docId,
+            path: '',
+            base: baseContent !== undefined ? deepClone(baseContent) : undefined,
+            ours: deepClone(oursContent!),
+            theirs: undefined,
+          });
+          merged[docId] = deepClone(oursContent!);
+        }
+        continue;
+      }
+
+      // Both exist and both changed — structural three-way merge
+      const mergeResult = threeWayMerge(
+        docId,
+        baseContent ?? {},
+        oursContent,
+        theirsContent,
+      );
+      merged[docId] = mergeResult.merged;
+      allConflicts.push(...mergeResult.conflicts);
+    }
+
+    const applied = allConflicts.length === 0;
+
+    if (applied) {
+      // Apply the merge to the current branch
+      for (const docId of allDocIds) {
+        if (docId in merged) {
+          const existingEntry = targetBranchState.documents.get(docId);
+          if (existingEntry && !existingEntry.deleted) {
+            // Update existing document
+            const oldContent = existingEntry.content;
+            if (!deepEqualObjects(oldContent, merged[docId])) {
+              const version: Version = {
+                id: generateVersionId(),
+                timestamp: Date.now(),
+                content: deepClone(merged[docId]),
+              };
+              existingEntry.content = deepClone(merged[docId]);
+              existingEntry.versions.push(version);
+            }
+          } else {
+            // Create new document on this branch (was only on source)
+            const version: Version = {
+              id: generateVersionId(),
+              timestamp: Date.now(),
+              content: deepClone(merged[docId]),
+            };
+            targetBranchState.documents.set(docId, {
+              content: deepClone(merged[docId]),
+              versions: [version],
+              deleted: false,
+            });
+          }
+        } else {
+          // Document was deleted in the merge result
+          const existingEntry = targetBranchState.documents.get(docId);
+          if (existingEntry && !existingEntry.deleted) {
+            existingEntry.deleted = true;
+          }
+        }
+      }
+    }
+
+    return { merged, conflicts: allConflicts, applied };
+  }
+
+  // --- Private helpers ---
+
+  private getCurrentBranchState(): BranchState {
+    const state = this.branches.get(this.currentBranch);
+    if (!state) {
+      throw new Error(`Branch "${this.currentBranch}" not found`);
+    }
+    return state;
+  }
+
+  private findCommonAncestor(
+    branchA: string,
+    branchB: string,
+  ): Map<string, DocumentEntry> | undefined {
+    const stateA = this.branches.get(branchA);
+    const stateB = this.branches.get(branchB);
+    if (!stateA || !stateB) return undefined;
+
+    // If branchA was forked from branchB, the ancestor is branchA's parent snapshot
+    if (stateA.parent?.branchName === branchB) {
+      return stateA.parent.snapshot;
+    }
+
+    // If branchB was forked from branchA, the ancestor is branchB's parent snapshot
+    if (stateB.parent?.branchName === branchA) {
+      return stateB.parent.snapshot;
+    }
+
+    // If both branches share the same parent, find the common ancestor
+    // through their parent snapshots
+    if (stateA.parent && stateB.parent && stateA.parent.branchName === stateB.parent.branchName) {
+      // Both forked from the same branch — use the earlier snapshot
+      // For simplicity, use branchA's parent snapshot (they should be the same
+      // if forked at the same time)
+      return stateA.parent.snapshot;
+    }
+
+    // Default: empty ancestor (treat as if everything is new)
+    return new Map();
+  }
+}
+
+function deepEqualOptional(a: unknown, b: unknown): boolean {
+  if (a === undefined && b === undefined) return true;
+  if (a === undefined || b === undefined) return false;
+  return deepEqualObjects(a, b);
+}
+
+function deepEqualObjects(a: unknown, b: unknown): boolean {
+  if (a === b) return true;
+  if (a === null || b === null) return a === b;
+  if (typeof a !== typeof b) return false;
+
+  if (Array.isArray(a) && Array.isArray(b)) {
+    if (a.length !== b.length) return false;
+    return a.every((val, i) => deepEqualObjects(val, b[i]));
+  }
+
+  if (typeof a === 'object' && typeof b === 'object') {
+    const objA = a as Record<string, unknown>;
+    const objB = b as Record<string, unknown>;
+    const keysA = Object.keys(objA);
+    const keysB = Object.keys(objB);
+    if (keysA.length !== keysB.length) return false;
+    return keysA.every(key => key in objB && deepEqualObjects(objA[key], objB[key]));
+  }
+
+  return false;
+}
