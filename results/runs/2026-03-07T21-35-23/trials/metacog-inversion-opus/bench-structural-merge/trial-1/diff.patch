index 0000000..defa2fb
--- /dev/null
+++ b/src/merge.ts
@@ -0,0 +1,145 @@
+import { deepClone, isPlainObject } from './utils.js';
+
+export interface Conflict {
+  documentId: string;
+  path: string;
+  base: unknown;
+  ours: unknown;
+  theirs: unknown;
+}
+
+interface FieldMergeResult {
+  value: unknown;
+  conflicts: Conflict[];
+}
+
+/**
+ * Three-way structural merge for JSON objects.
+ * Compares `ours` and `theirs` against a common `base` ancestor.
+ */
+export function threeWayMerge(
+  documentId: string,
+  base: object | undefined,
+  ours: object | undefined,
+  theirs: object | undefined,
+): { merged: object; conflicts: Conflict[] } {
+  // Both deleted or both undefined
+  if (ours === undefined && theirs === undefined) {
+    return { merged: {}, conflicts: [] };
+  }
+
+  // Treat undefined base as empty object (document created on a branch)
+  const safeBase = base ?? {};
+  const safeOurs = ours ?? {};
+  const safeTheirs = theirs ?? {};
+
+  const result = mergeObjects(documentId, '', safeBase, safeOurs, safeTheirs);
+  return {
+    merged: result.value as object,
+    conflicts: result.conflicts,
+  };
+}
+
+function mergeObjects(
+  documentId: string,
+  pathPrefix: string,
+  base: unknown,
+  ours: unknown,
+  theirs: unknown,
+): FieldMergeResult {
+  const baseObj = isPlainObject(base) ? base : {};
+  const oursObj = isPlainObject(ours) ? ours : {};
+  const theirsObj = isPlainObject(theirs) ? theirs : {};
+
+  // Collect all keys from all three
+  const allKeys = new Set([
+    ...Object.keys(baseObj),
+    ...Object.keys(oursObj),
+    ...Object.keys(theirsObj),
+  ]);
+
+  const merged: Record<string, unknown> = {};
+  const conflicts: Conflict[] = [];
+
+  for (const key of allKeys) {
+    const fullPath = pathPrefix ? `${pathPrefix}.${key}` : key;
+    const baseVal = baseObj[key];
+    const oursVal = oursObj[key];
+    const theirsVal = theirsObj[key];
+
+    const oursChanged = !deepEqual(baseVal, oursVal);
+    const theirsChanged = !deepEqual(baseVal, theirsVal);
+
+    if (!oursChanged && !theirsChanged) {
+      // Neither side changed this field
+      if (key in baseObj) {
+        merged[key] = deepClone(baseVal);
+      }
+    } else if (oursChanged && !theirsChanged) {
+      // Only ours changed
+      if (key in oursObj) {
+        merged[key] = deepClone(oursVal);
+      }
+      // If key was deleted in ours (not in oursObj), omit it
+    } else if (!oursChanged && theirsChanged) {
+      // Only theirs changed
+      if (key in theirsObj) {
+        merged[key] = deepClone(theirsVal);
+      }
+      // If key was deleted in theirs, omit it
+    } else {
+      // Both sides changed
+      if (deepEqual(oursVal, theirsVal)) {
+        // Both changed to the same value
+        if (key in oursObj) {
+          merged[key] = deepClone(oursVal);
+        }
+      } else if (
+        isPlainObject(baseVal) &&
+        isPlainObject(oursVal) &&
+        isPlainObject(theirsVal)
+      ) {
+        // Both changed, but values are objects — recurse
+        const sub = mergeObjects(documentId, fullPath, baseVal, oursVal, theirsVal);
+        merged[key] = sub.value;
+        conflicts.push(...sub.conflicts);
+      } else {
+        // Genuine conflict — take ours for the merged result
+        conflicts.push({
+          documentId,
+          path: fullPath,
+          base: deepClone(baseVal),
+          ours: deepClone(oursVal),
+          theirs: deepClone(theirsVal),
+        });
+        // For merged output, use ours
+        if (key in oursObj) {
+          merged[key] = deepClone(oursVal);
+        }
+      }
+    }
+  }
+
+  return { value: merged, conflicts };
+}
+
+function deepEqual(a: unknown, b: unknown): boolean {
+  if (a === b) return true;
+  if (a === null || b === null) return false;
+  if (a === undefined || b === undefined) return false;
+  if (typeof a !== typeof b) return false;
+
+  if (Array.isArray(a) && Array.isArray(b)) {
+    if (a.length !== b.length) return false;
+    return a.every((val, i) => deepEqual(val, b[i]));
+  }
+
+  if (isPlainObject(a) && isPlainObject(b)) {
+    const keysA = Object.keys(a);
+    const keysB = Object.keys(b);
+    if (keysA.length !== keysB.length) return false;
+    return keysA.every(key => key in b && deepEqual(a[key], b[key]));
+  }
+
+  return false;
+}
diff --git a/src/utils.ts b/src/utils.ts
new file mode 100644
index 0000000..7c8db1d
--- /dev/null
+++ b/src/utils.ts
@@ -0,0 +1,17 @@
+export function deepClone<T>(value: T): T {
+  if (value === null || value === undefined || typeof value !== 'object') {
+    return value;
+  }
+  if (Array.isArray(value)) {
+    return value.map(item => deepClone(item)) as T;
+  }
+  const result: Record<string, unknown> = {};
+  for (const key of Object.keys(value as Record<string, unknown>)) {
+    result[key] = deepClone((value as Record<string, unknown>)[key]);
+  }
+  return result as T;
+}
+
+export function isPlainObject(value: unknown): value is Record<string, unknown> {
+  return typeof value === 'object' && value !== null && !Array.isArray(value);
+}
