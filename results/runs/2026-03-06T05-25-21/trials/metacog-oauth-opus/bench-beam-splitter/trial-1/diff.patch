+++ b/src/index.ts
@@ -0,0 +1,124 @@
+type Direction = 'down' | 'down-left' | 'down-right';
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+interface WeightedBeam {
+  row: number;
+  col: number;
+  dir: Direction;
+  count: bigint;
+}
+
+function findSource(grid: string[][]): [number, number] {
+  for (let c = 0; c < grid[0].length; c++) {
+    if (grid[0][c] === 'S') {
+      return [0, c];
+    }
+  }
+  throw new Error('No source found');
+}
+
+function advance(row: number, col: number, dir: Direction): [number, number] {
+  switch (dir) {
+    case 'down':
+      return [row + 1, col];
+    case 'down-left':
+      return [row + 1, col - 1];
+    case 'down-right':
+      return [row + 1, col + 1];
+  }
+}
+
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const [sr, sc] = findSource(grid);
+
+  const visited = new Set<string>();
+  visited.add(`${sr},${sc}`);
+
+  const beams: Beam[] = [{ row: sr, col: sc, dir: 'down' }];
+
+  while (beams.length > 0) {
+    const nextBeams: Beam[] = [];
+
+    for (const beam of beams) {
+      const [nr, nc] = advance(beam.row, beam.col, beam.dir);
+
+      if (!inBounds(nr, nc, rows, cols)) {
+        continue;
+      }
+
+      visited.add(`${nr},${nc}`);
+
+      if (grid[nr][nc] === '^') {
+        nextBeams.push({ row: nr, col: nc, dir: 'down-left' });
+        nextBeams.push({ row: nr, col: nc, dir: 'down-right' });
+      } else {
+        nextBeams.push({ row: nr, col: nc, dir: beam.dir });
+      }
+    }
+
+    beams.length = 0;
+    beams.push(...nextBeams);
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const [sr, sc] = findSource(grid);
+
+  // Use weighted beams: merge beams at the same position+direction
+  // to avoid exponential blowup
+  let beams: WeightedBeam[] = [{ row: sr, col: sc, dir: 'down', count: 1n }];
+  let totalPaths = 0n;
+
+  while (beams.length > 0) {
+    // Merge beams with same position and direction
+    const merged = new Map<string, bigint>();
+
+    for (const beam of beams) {
+      const [nr, nc] = advance(beam.row, beam.col, beam.dir);
+
+      if (!inBounds(nr, nc, rows, cols)) {
+        totalPaths += beam.count;
+        continue;
+      }
+
+      if (grid[nr][nc] === '^') {
+        // Splitter: create two beams
+        for (const newDir of ['down-left', 'down-right'] as Direction[]) {
+          const key = `${nr},${nc},${newDir}`;
+          merged.set(key, (merged.get(key) ?? 0n) + beam.count);
+        }
+      } else {
+        const key = `${nr},${nc},${beam.dir}`;
+        merged.set(key, (merged.get(key) ?? 0n) + beam.count);
+      }
+    }
+
+    beams = [];
+    for (const [key, count] of merged) {
+      const parts = key.split(',');
+      beams.push({
+        row: Number(parts[0]),
+        col: Number(parts[1]),
+        dir: parts[2] as Direction,
+        count,
+      });
+    }
+  }
+
+  return totalPaths;
+}
