index 0000000..09e1cf9
--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,129 @@
+type Direction = 0 | 1 | 2; // 0=down, 1=down-left, 2=down-right
+
+function findSource(grid: string[][]): number {
+  for (let col = 0; col < grid[0].length; col++) {
+    if (grid[0][col] === 'S') return col;
+  }
+  return -1;
+}
+
+function nextCol(col: number, dir: Direction): number {
+  if (dir === 0) return col;
+  if (dir === 1) return col - 1;
+  return col + 1;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  if (grid.length === 0 || grid[0].length === 0) return 0;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const sourceCol = findSource(grid);
+  if (sourceCol < 0) return 0;
+
+  const visited = new Set<number>(); // row * cols + col
+
+  // Track active beams as a map of (col, dir) -> present
+  // Use a key: col * 3 + dir
+  let current = new Map<number, boolean>();
+  current.set(sourceCol * 3 + 0, true); // start going down
+  visited.add(0 * cols + sourceCol); // source cell visited
+
+  for (let row = 0; row < rows; row++) {
+    const next = new Map<number, boolean>();
+
+    for (const [key] of current) {
+      const col = (key / 3) | 0;
+      const dir = (key % 3) as Direction;
+
+      if (grid[row][col] === '^') {
+        // Split into down-left and down-right
+        const nlc = col - 1;
+        const nrc = col + 1;
+        const nr = row + 1;
+
+        if (nr < rows && nlc >= 0 && nlc < cols) {
+          visited.add(nr * cols + nlc);
+          next.set(nlc * 3 + 1, true);
+        }
+        if (nr < rows && nrc >= 0 && nrc < cols) {
+          visited.add(nr * cols + nrc);
+          next.set(nrc * 3 + 2, true);
+        }
+      } else {
+        // Continue in current direction
+        const nc = nextCol(col, dir);
+        const nr = row + 1;
+        if (nr < rows && nc >= 0 && nc < cols) {
+          visited.add(nr * cols + nc);
+          next.set(nc * 3 + dir, true);
+        }
+      }
+    }
+
+    current = next;
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  if (grid.length === 0 || grid[0].length === 0) return 0n;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const sourceCol = findSource(grid);
+  if (sourceCol < 0) return 0n;
+
+  let totalPaths = 0n;
+
+  // Track active beams as a map of (col, dir) -> path count
+  let current = new Map<number, bigint>();
+  current.set(sourceCol * 3 + 0, 1n);
+
+  for (let row = 0; row < rows; row++) {
+    const next = new Map<number, bigint>();
+
+    for (const [key, paths] of current) {
+      const col = (key / 3) | 0;
+      const dir = (key % 3) as Direction;
+
+      if (grid[row][col] === '^') {
+        const nlc = col - 1;
+        const nrc = col + 1;
+        const nr = row + 1;
+
+        if (nr < rows && nlc >= 0 && nlc < cols) {
+          const nk = nlc * 3 + 1;
+          next.set(nk, (next.get(nk) ?? 0n) + paths);
+        } else {
+          totalPaths += paths;
+        }
+        if (nr < rows && nrc >= 0 && nrc < cols) {
+          const nk = nrc * 3 + 2;
+          next.set(nk, (next.get(nk) ?? 0n) + paths);
+        } else {
+          totalPaths += paths;
+        }
+      } else {
+        const nc = nextCol(col, dir);
+        const nr = row + 1;
+        if (nr < rows && nc >= 0 && nc < cols) {
+          const nk = nc * 3 + dir;
+          next.set(nk, (next.get(nk) ?? 0n) + paths);
+        } else {
+          totalPaths += paths;
+        }
+      }
+    }
+
+    current = next;
+  }
+
+  // Any beams still active after the last row exit the grid
+  for (const [, paths] of current) {
+    totalPaths += paths;
+  }
+
+  return totalPaths;
+}
