+++ b/src/app.ts
@@ -0,0 +1,565 @@
+import express, { Request, Response, NextFunction } from 'express';
+import crypto from 'crypto';
+import { Store, createStore } from './store.js';
+import { Role } from './types.js';
+
+function genId(): string {
+  return crypto.randomUUID();
+}
+
+export function createApp(): express.Application {
+  const app = express();
+  const store: Store = createStore();
+
+  app.use(express.json());
+
+  // Auth middleware - stores userId in res.locals
+  function authenticate(req: Request, res: Response, next: NextFunction): void {
+    const authHeader = req.headers.authorization;
+    if (!authHeader || !authHeader.startsWith('Bearer ')) {
+      res.status(401).json({ error: 'Authentication required' });
+      return;
+    }
+    const token = authHeader.slice(7);
+    const userId = store.tokens.get(token);
+    if (!userId) {
+      res.status(401).json({ error: 'Invalid token' });
+      return;
+    }
+    res.locals.userId = userId;
+    next();
+  }
+
+  // ─── Permission helpers ─────────────────────────────────────────────
+
+  const roleRank: Record<Role, number> = { viewer: 1, editor: 2, owner: 3 };
+
+  function getEffectiveRole(userId: string, resourceType: 'folder' | 'document', resourceId: string): Role | null {
+    let bestRole: Role | null = null;
+
+    // Check if user is owner of the resource
+    if (resourceType === 'folder') {
+      const folder = store.folders.get(resourceId);
+      if (folder && folder.ownerId === userId) return 'owner';
+    } else {
+      const doc = store.documents.get(resourceId);
+      if (doc && doc.ownerId === userId) return 'owner';
+    }
+
+    // Check direct shares on this resource
+    for (const share of store.shares) {
+      if (share.userId === userId && share.resourceType === resourceType && share.resourceId === resourceId) {
+        if (!bestRole || roleRank[share.role] > roleRank[bestRole]) {
+          bestRole = share.role;
+        }
+      }
+    }
+
+    // If resource is a document, also check folder-level shares
+    if (resourceType === 'document') {
+      const doc = store.documents.get(resourceId);
+      if (doc) {
+        const folderRole = getEffectiveFolderRole(userId, doc.folderId);
+        if (folderRole && (!bestRole || roleRank[folderRole] > roleRank[bestRole])) {
+          bestRole = folderRole;
+        }
+      }
+    }
+
+    // If resource is a folder, check parent folder shares (inheritance)
+    if (resourceType === 'folder') {
+      const folder = store.folders.get(resourceId);
+      if (folder && folder.parentId) {
+        const parentRole = getEffectiveFolderRole(userId, folder.parentId);
+        if (parentRole && (!bestRole || roleRank[parentRole] > roleRank[bestRole])) {
+          bestRole = parentRole;
+        }
+      }
+    }
+
+    return bestRole;
+  }
+
+  function getEffectiveFolderRole(userId: string, folderId: string): Role | null {
+    const folder = store.folders.get(folderId);
+    if (!folder) return null;
+
+    // Check ownership
+    if (folder.ownerId === userId) return 'owner';
+
+    let bestRole: Role | null = null;
+
+    // Direct shares on this folder
+    for (const share of store.shares) {
+      if (share.userId === userId && share.resourceType === 'folder' && share.resourceId === folderId) {
+        if (!bestRole || roleRank[share.role] > roleRank[bestRole]) {
+          bestRole = share.role;
+        }
+      }
+    }
+
+    // Check parent folder shares (inheritance up the chain)
+    if (folder.parentId) {
+      const parentRole = getEffectiveFolderRole(userId, folder.parentId);
+      if (parentRole && (!bestRole || roleRank[parentRole] > roleRank[bestRole])) {
+        bestRole = parentRole;
+      }
+    }
+
+    return bestRole;
+  }
+
+  function hasPermission(userId: string, resourceType: 'folder' | 'document', resourceId: string, requiredRole: Role): boolean {
+    const effective = getEffectiveRole(userId, resourceType, resourceId);
+    if (!effective) return false;
+    return roleRank[effective] >= roleRank[requiredRole];
+  }
+
+  function addActivity(action: string, userId: string, resourceType: 'folder' | 'document', resourceId: string, details?: string): void {
+    store.activityLog.push({
+      id: genId(),
+      action,
+      userId,
+      resourceType,
+      resourceId,
+      timestamp: new Date().toISOString(),
+      details,
+    });
+  }
+
+  // ─── Auth routes ────────────────────────────────────────────────────
+
+  app.post('/auth/register', (req: Request, res: Response) => {
+    const { username, password } = req.body;
+    if (!username || !password) {
+      res.status(400).json({ error: 'Username and password are required' });
+      return;
+    }
+
+    for (const user of store.users.values()) {
+      if (user.username === username) {
+        res.status(409).json({ error: 'Username already exists' });
+        return;
+      }
+    }
+
+    const id = genId();
+    const user = { id, username, password };
+    store.users.set(id, user);
+    res.status(201).json({ id, username });
+  });
+
+  app.post('/auth/login', (req: Request, res: Response) => {
+    const { username, password } = req.body;
+    if (!username || !password) {
+      res.status(400).json({ error: 'Username and password are required' });
+      return;
+    }
+
+    let foundUser = null;
+    for (const user of store.users.values()) {
+      if (user.username === username && user.password === password) {
+        foundUser = user;
+        break;
+      }
+    }
+
+    if (!foundUser) {
+      res.status(401).json({ error: 'Invalid credentials' });
+      return;
+    }
+
+    const token = genId();
+    store.tokens.set(token, foundUser.id);
+    foundUser.token = token;
+    res.status(200).json({ token, userId: foundUser.id });
+  });
+
+  // ─── Folder routes ──────────────────────────────────────────────────
+
+  app.post('/folders', authenticate, (_req: Request, res: Response) => {
+    const userId: string = res.locals.userId;
+    const { name, parentId } = _req.body;
+    if (!name) {
+      res.status(400).json({ error: 'Folder name is required' });
+      return;
+    }
+
+    if (parentId) {
+      const parentFolder = store.folders.get(parentId);
+      if (!parentFolder) {
+        res.status(404).json({ error: 'Parent folder not found' });
+        return;
+      }
+      if (!hasPermission(userId, 'folder', parentId, 'editor')) {
+        res.status(403).json({ error: 'Insufficient permissions on parent folder' });
+        return;
+      }
+    }
+
+    const id = genId();
+    const folder = {
+      id,
+      name,
+      parentId: parentId || null,
+      ownerId: userId,
+      createdAt: new Date().toISOString(),
+    };
+    store.folders.set(id, folder);
+    res.status(201).json(folder);
+  });
+
+  app.get('/folders/:id', authenticate, (_req: Request, res: Response) => {
+    const userId: string = res.locals.userId;
+    const folder = store.folders.get(_req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!hasPermission(userId, 'folder', folder.id, 'viewer')) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    const children: string[] = [];
+    for (const f of store.folders.values()) {
+      if (f.parentId === folder.id) children.push(f.id);
+    }
+    const documents: string[] = [];
+    for (const d of store.documents.values()) {
+      if (d.folderId === folder.id) documents.push(d.id);
+    }
+
+    res.json({ ...folder, children, documents });
+  });
+
+  app.put('/folders/:id', authenticate, (_req: Request, res: Response) => {
+    const userId: string = res.locals.userId;
+    const folder = store.folders.get(_req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!hasPermission(userId, 'folder', folder.id, 'editor')) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    const { name, parentId } = _req.body;
+    if (name !== undefined) folder.name = name;
+    if (parentId !== undefined) {
+      if (parentId !== null) {
+        const parentFolder = store.folders.get(parentId);
+        if (!parentFolder) {
+          res.status(404).json({ error: 'Parent folder not found' });
+          return;
+        }
+      }
+      folder.parentId = parentId;
+    }
+
+    res.json(folder);
+  });
+
+  app.delete('/folders/:id', authenticate, (_req: Request, res: Response) => {
+    const userId: string = res.locals.userId;
+    const folder = store.folders.get(_req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!hasPermission(userId, 'folder', folder.id, 'owner')) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    for (const [docId, doc] of store.documents) {
+      if (doc.folderId === folder.id) {
+        store.documents.delete(docId);
+      }
+    }
+
+    function deleteChildren(fId: string): void {
+      for (const [childId, child] of store.folders) {
+        if (child.parentId === fId) {
+          for (const [docId, doc] of store.documents) {
+            if (doc.folderId === childId) {
+              store.documents.delete(docId);
+            }
+          }
+          deleteChildren(childId);
+          store.folders.delete(childId);
+        }
+      }
+    }
+    deleteChildren(folder.id);
+
+    store.shares = store.shares.filter(s => !(s.resourceType === 'folder' && s.resourceId === folder.id));
+
+    store.folders.delete(folder.id);
+    res.status(204).send();
+  });
+
+  // ─── Document routes ────────────────────────────────────────────────
+
+  app.post('/documents', authenticate, (_req: Request, res: Response) => {
+    const userId: string = res.locals.userId;
+    const { title, content, folderId } = _req.body;
+    if (!title || content === undefined || !folderId) {
+      res.status(400).json({ error: 'Title, content, and folderId are required' });
+      return;
+    }
+
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!hasPermission(userId, 'folder', folderId, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions on folder' });
+      return;
+    }
+
+    const id = genId();
+    const now = new Date().toISOString();
+    const doc = {
+      id,
+      title,
+      content,
+      folderId,
+      ownerId: userId,
+      createdAt: now,
+      updatedAt: now,
+    };
+    store.documents.set(id, doc);
+
+    addActivity('document.create', userId, 'document', id);
+    res.status(201).json(doc);
+  });
+
+  app.post('/folders/:folderId/documents', authenticate, (_req: Request, res: Response) => {
+    const userId: string = res.locals.userId;
+    const folderId = _req.params.folderId;
+    const { title, content } = _req.body;
+    if (!title || content === undefined) {
+      res.status(400).json({ error: 'Title and content are required' });
+      return;
+    }
+
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!hasPermission(userId, 'folder', folderId, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions on folder' });
+      return;
+    }
+
+    const id = genId();
+    const now = new Date().toISOString();
+    const doc = {
+      id,
+      title,
+      content,
+      folderId,
+      ownerId: userId,
+      createdAt: now,
+      updatedAt: now,
+    };
+    store.documents.set(id, doc);
+
+    addActivity('document.create', userId, 'document', id);
+    res.status(201).json(doc);
+  });
+
+  app.get('/documents/:id', authenticate, (_req: Request, res: Response) => {
+    const userId: string = res.locals.userId;
+    const doc = store.documents.get(_req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!hasPermission(userId, 'document', doc.id, 'viewer')) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    res.json(doc);
+  });
+
+  app.put('/documents/:id', authenticate, (_req: Request, res: Response) => {
+    const userId: string = res.locals.userId;
+    const doc = store.documents.get(_req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!hasPermission(userId, 'document', doc.id, 'editor')) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    const { title, content } = _req.body;
+    if (title !== undefined) doc.title = title;
+    if (content !== undefined) doc.content = content;
+    doc.updatedAt = new Date().toISOString();
+
+    addActivity('document.update', userId, 'document', doc.id);
+    res.json(doc);
+  });
+
+  app.delete('/documents/:id', authenticate, (_req: Request, res: Response) => {
+    const userId: string = res.locals.userId;
+    const doc = store.documents.get(_req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!hasPermission(userId, 'document', doc.id, 'owner')) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    store.shares = store.shares.filter(s => !(s.resourceType === 'document' && s.resourceId === doc.id));
+
+    store.documents.delete(doc.id);
+    addActivity('document.delete', userId, 'document', doc.id);
+    res.status(204).send();
+  });
+
+  // ─── Sharing routes ─────────────────────────────────────────────────
+
+  function handleShare(
+    currentUserId: string,
+    resourceType: 'folder' | 'document',
+    resourceId: string,
+    targetUserId: string,
+    role: string,
+    res: Response
+  ): void {
+    if (!['viewer', 'editor', 'owner'].includes(role)) {
+      res.status(400).json({ error: 'role must be "viewer", "editor", or "owner"' });
+      return;
+    }
+
+    if (resourceType === 'folder') {
+      if (!store.folders.has(resourceId)) {
+        res.status(404).json({ error: 'Folder not found' });
+        return;
+      }
+    } else {
+      if (!store.documents.has(resourceId)) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+    }
+
+    if (!store.users.has(targetUserId)) {
+      res.status(404).json({ error: 'User not found' });
+      return;
+    }
+
+    if (!hasPermission(currentUserId, resourceType, resourceId, 'editor')) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    if (role === 'owner' && !hasPermission(currentUserId, resourceType, resourceId, 'owner')) {
+      res.status(403).json({ error: 'Only owners can grant owner role' });
+      return;
+    }
+
+    const existing = store.shares.find(
+      s => s.userId === targetUserId && s.resourceType === resourceType && s.resourceId === resourceId
+    );
+
+    if (existing) {
+      existing.role = role as Role;
+      addActivity('share', currentUserId, resourceType, resourceId, `Shared with user ${targetUserId} as ${role}`);
+      res.json(existing);
+      return;
+    }
+
+    const share = {
+      id: genId(),
+      resourceType,
+      resourceId,
+      userId: targetUserId,
+      role: role as Role,
+      sharedBy: currentUserId,
+      createdAt: new Date().toISOString(),
+    };
+    store.shares.push(share);
+
+    addActivity('share', currentUserId, resourceType, resourceId, `Shared with user ${targetUserId} as ${role}`);
+    res.status(201).json(share);
+  }
+
+  app.post('/share', authenticate, (_req: Request, res: Response) => {
+    const currentUserId: string = res.locals.userId;
+    const { resourceType, resourceId, userId, role } = _req.body;
+
+    if (!resourceType || !resourceId || !userId || !role) {
+      res.status(400).json({ error: 'resourceType, resourceId, userId, and role are required' });
+      return;
+    }
+
+    if (!['folder', 'document'].includes(resourceType)) {
+      res.status(400).json({ error: 'resourceType must be "folder" or "document"' });
+      return;
+    }
+
+    handleShare(currentUserId, resourceType, resourceId, userId, role, res);
+  });
+
+  app.post('/folders/:id/share', authenticate, (_req: Request, res: Response) => {
+    const currentUserId: string = res.locals.userId;
+    const { userId, role } = _req.body;
+
+    if (!userId || !role) {
+      res.status(400).json({ error: 'userId and role are required' });
+      return;
+    }
+
+    handleShare(currentUserId, 'folder', _req.params.id, userId, role, res);
+  });
+
+  app.post('/documents/:id/share', authenticate, (_req: Request, res: Response) => {
+    const currentUserId: string = res.locals.userId;
+    const { userId, role } = _req.body;
+
+    if (!userId || !role) {
+      res.status(400).json({ error: 'userId and role are required' });
+      return;
+    }
+
+    handleShare(currentUserId, 'document', _req.params.id, userId, role, res);
+  });
+
+  // ─── Activity log ───────────────────────────────────────────────────
+
+  app.get('/activity', authenticate, (_req: Request, res: Response) => {
+    let entries = store.activityLog;
+
+    const { resourceType, resourceId } = _req.query;
+    if (resourceType) {
+      entries = entries.filter(e => e.resourceType === resourceType);
+    }
+    if (resourceId) {
+      entries = entries.filter(e => e.resourceId === resourceId);
+    }
+
+    res.json(entries);
+  });
+
+  return app;
+}
