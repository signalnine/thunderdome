 } else {\n      const doc = store.documents.get(resourceId);\n      if (doc && doc.ownerId === userId) return 'owner';\n    }\n\n    // Check direct shares on this resource\n    for (const share of store.shares) {\n      if (share.userId === userId && share.resourceType === resourceType && share.resourceId === resourceId) {\n        if (!bestRole || roleRank[share.role] > roleRank[bestRole]) {\n          bestRole = share.role;\n        }\n      }\n    }\n\n    // If resource is a document, also check folder-level shares\n    if (resourceType === 'document') {\n      const doc = store.documents.get(resourceId);\n      if (doc) {\n        const folderRole = getEffectiveFolderRole(userId, doc.folderId);\n        if (folderRole && (!bestRole || roleRank[folderRole] > roleRank[bestRole])) {\n          bestRole = folderRole;\n        }\n      }\n    }\n\n    // If resource is a folder, check parent folder shares (inheritance)\n    if (resourceType === 'folder') {\n      const folder = store.folders.get(resourceId);\n      if (folder && folder.parentId) {\n        const parentRole = getEffectiveFolderRole(userId, folder.parentId);\n        if (parentRole && (!bestRole || roleRank[parentRole] > roleRank[bestRole])) {\n          bestRole = parentRole;\n        }\n      }\n    }\n\n    return bestRole;\n  }\n\n  function getEffectiveFolderRole(userId: string, folderId: string): Role | null {\n    const folder = store.folders.get(folderId);\n    if (!folder) return null;\n\n    // Check ownership\n    if (folder.ownerId === userId) return 'owner';\n\n    let bestRole: Role | null = null;\n\n    // Direct shares on this folder\n    for (const share of store.shares) {\n      if (share.userId === userId && share.resourceType === 'folder' && share.resourceId === folderId) {\n        if (!bestRole || roleRank[share.role] > roleRank[bestRole]) {\n          bestRole = share.role;\n        }\n      }\n    }\n\n    // Check parent folder shares (inheritance up the chain)\n    if (folder.parentId) {\n      const parentRole = getEffectiveFolderRole(userId, folder.parentId);\n      if (parentRole && (!bestRole || roleRank[parentRole] > roleRank[bestRole])) {\n        bestRole = parentRole;\n      }\n    }\n\n    return bestRole;\n  }\n\n  function hasPermission(userId: string, resourceType: 'folder' | 'document', resourceId: string, requiredRole: Role): boolean {\n    const effective = getEffectiveRole(userId, resourceType, resourceId);\n    if (!effective) return false;\n    return roleRank[effective] >= roleRank[requiredRole];\n  }\n\n  function addActivity(action: string, userId: string, resourceType: 'folder' | 'document', resourceId: string, details?: string): void {\n    store.activityLog.push({\n      id: genId(),\n      action,\n      userId,\n      resourceType,\n      resourceId,\n      timestamp: new Date().toISOString(),\n      details,\n    });\n  }\n\n  // ─── Auth routes ────────────────────────────────────────────────────\n\n  app.post('/auth/register', (req: Request, res: Response) => {\n    const { username, password } = req.body;\n    if (!username || !password) {\n      res.status(400).json({ error: 'Username and password are required' });\n      return;\n    }\n\n    // Check for duplicate username\n    for (const user of store.users.values()) {\n      if (user.username === username) {\n        res.status(409).json({ error: 'Username already exists' });\n        return;\n      }\n    }\n\n    const id = genId();\n    const user = { id, username, password };\n    store.users.set(id, user);\n    res.status(201).json({ id, username });\n  });\n\n  app.post('/auth/login', (req: Request, res: Response) => {\n    const { username, password } = req.body;\n    if (!username || !password) {\n      res.status(400).json({ error: 'Username and password are required' });\n      return;\n    }\n\n    let foundUser = null;\n    for (const user of store.users.values()) {\n      if (user.username === username && user.password === password) {\n        foundUser = user;\n        break;\n      }\n    }\n\n    if (!foundUser) {\n      res.status(401).json({ error: 'Invalid credentials' });\n      return;\n    }\n\n    const token = genId();\n    store.tokens.set(token, foundUser.id);\n    foundUser.token = token;\n    res.status(200).json({ token, userId: foundUser.id });\n  });\n\n  // ─── Folder routes ──────────────────────────────────────────────────\n\n  app.post('/folders', authenticate, (req: Request, res: Response) => {\n    const { name, parentId } = req.body;\n    if (!name) {\n      res.status(400).json({ error: 'Folder name is required' });\n      return;\n    }\n\n    if (parentId) {\n      const parentFolder = store.folders.get(parentId);\n      if (!parentFolder) {\n        res.status(404).json({ error: 'Parent folder not found' });\n        return;\n      }\n      // Must have at least editor permission on parent\n      if (!hasPermission(req.userId!, 'folder', parentId, 'editor')) {\n        res.status(403).json({ error: 'Insufficient permissions on parent folder' });\n        return;\n      }\n    }\n\n    const id = genId();\n    const folder = {\n      id,\n      name,\n      parentId: parentId || null,\n      ownerId: req.userId!,\n      createdAt: new Date().toISOString(),\n    };\n    store.folders.set(id, folder);\n    res.status(201).json(folder);\n  });\n\n  app.get('/folders/:id', authenticate, (req: Request, res: Response) => {\n    const folder = store.folders.get(req.params.id);\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n\n    if (!hasPermission(req.userId!, 'folder', folder.id, 'viewer')) {\n      res.status(403).json({ error: 'Access denied' });\n      return;\n    }\n\n    // Get children folders and documents\n    const children: string[] = [];\n    for (const f of store.folders.values()) {\n      if (f.parentId === folder.id) children.push(f.id);\n    }\n    const documents: string[] = [];\n    for (const d of store.documents.values()) {\n      if (d.folderId === folder.id) documents.push(d.id);\n    }\n\n    res.json({ ...folder, children, documents });\n  });\n\n  app.put('/folders/:id', authenticate, (req: Request, res: Response) => {\n    const folder = store.folders.get(req.params.id);\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n\n    if (!hasPermission(req.userId!, 'folder', folder.id, 'editor')) {\n      res.status(403).json({ error: 'Access denied' });\n      return;\n    }\n\n    const { name, parentId } = req.body;\n    if (name !== undefined) folder.name = name;\n    if (parentId !== undefined) {\n      if (parentId !== null) {\n        const parentFolder = store.folders.get(parentId);\n        if (!parentFolder) {\n          res.status(404).json({ error: 'Parent folder not found' });\n          return;\n        }\n      }\n      folder.parentId = parentId;\n    }\n\n    res.json(folder);\n  });\n\n  app.delete('/folders/:id', authenticate, (req: Request, res: Response) => {\n    const folder = store.folders.get(req.params.id);\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n\n    if (!hasPermission(req.userId!, 'folder', folder.id, 'owner')) {\n      res.status(403).json({ error: 'Access denied' });\n      return;\n    }\n\n    // Remove child documents\n    for (const [docId, doc] of store.documents) {\n      if (doc.folderId === folder.id) {\n        store.documents.delete(docId);\n      }\n    }\n\n    // Remove child folders recursively\n    function deleteChildren(fId: string): void {\n      for (const [childId, child] of store.folders) {\n        if (child.parentId === fId) {\n          // Remove docs in child folder\n          for (const [docId, doc] of store.documents) {\n            if (doc.folderId === childId) {\n              store.documents.delete(docId);\n            }\n          }\n          deleteChildren(childId);\n          store.folders.delete(childId);\n        }\n      }\n    }\n    deleteChildren(folder.id);\n\n    // Remove shares for this folder\n    store.shares = store.shares.filter(s => !(s.resourceType === 'folder' && s.resourceId === folder.id));\n\n    store.folders.delete(folder.id);\n    res.status(204).send();\n  });\n\n  // ─── Document routes ────────────────────────────────────────────────\n\n  app.post('/documents', authenticate, (req: Request, res: Response) => {\n    const { title, content, folderId } = req.body;\n    if (!title || content === undefined || !folderId) {\n      res.status(400).json({ error: 'Title, content, and folderId are required' });\n      return;\n    }\n\n    const folder = store.folders.get(folderId);\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n\n    if (!hasPermission(req.userId!, 'folder', folderId, 'editor')) {\n      res.status(403).json({ error: 'Insufficient permissions on folder' });\n      return;\n    }\n\n    const id = genId();\n    const now = new Date().toISOString();\n    const doc = {\n      id,\n      title,\n      content,\n      folderId,\n      ownerId: req.userId!,\n      createdAt: now,\n      updatedAt: now,\n    };\n    store.documents.set(id, doc);\n\n    addActivity('document.create', req.userId!, 'document', id);\n    res.status(201).json(doc);\n  });\n\n  // Also support POST /folders/:folderId/documents\n  app.post('/folders/:folderId/documents', authenticate, (req: Request, res: Response) => {\n    const folderId = req.params.folderId;\n    const { title, content } = req.body;\n    if (!title || content === undefined) {\n      res.status(400).json({ error: 'Title and content are required' });\n      return;\n    }\n\n    const folder = store.folders.get(folderId);\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n\n    if (!hasPermission(req.userId!, 'folder', folderId, 'editor')) {\n      res.status(403).json({ error: 'Insufficient permissions on folder' });\n      return;\n    }\n\n    const id = genId();\n    const now = new Date().toISOString();\n    const doc = {\n      id,\n      title,\n      content,\n      folderId,\n      ownerId: req.userId!,\n      createdAt: now,\n      updatedAt: now,\n    };\n    store.documents.set(id, doc);\n\n    addActivity('document.create', req.userId!, 'document', id);\n    res.status(201).json(doc);\n  });\n\n  app.get('/documents/:id', authenticate, (req: Request, res: Response) => {\n    const doc = store.documents.get(req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n\n    if (!hasPermission(req.userId!, 'document', doc.id, 'viewer')) {\n      res.status(403).json({ error: 'Access denied' });\n      return;\n    }\n\n    res.json(doc);\n  });\n\n  app.put('/documents/:id', authenticate, (req: Request, res: Response) => {\n    const doc = store.documents.get(req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n\n    if (!hasPermission(req.userId!, 'document', doc.id, 'editor')) {\n      res.status(403).json({ error: 'Access denied' });\n      return;\n    }\n\n    const { title, content } = req.body;\n    if (title !== undefined) doc.title = title;\n    if (content !== undefined) doc.content = content;\n    doc.updatedAt = new Date().toISOString();\n\n    addActivity('document.update', req.userId!, 'document', doc.id);\n    res.json(doc);\n  });\n\n  app.delete('/documents/:id', authenticate, (req: Request, res: Response) => {\n    const doc = store.documents.get(req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n\n    if (!hasPermission(req.userId!, 'document', doc.id, 'owner')) {\n      res.status(403).json({ error: 'Access denied' });\n      return;\n    }\n\n    // Remove shares for this document\n    store.shares = store.shares.filter(s => !(s.resourceType === 'document' && s.resourceId === doc.id));\n\n    store.documents.delete(doc.id);\n    addActivity('document.delete', req.userId!, 'document', doc.id);\n    res.status(204).send();\n  });\n\n  // ─── Sharing routes ─────────────────────────────────────────────────\n\n  app.post('/share', authenticate, (req: Request, res: Response) => {\n    const { resourceType, resourceId, userId, role } = req.body;\n\n    if (!resourceType || !resourceId || !userId || !role) {\n      res.status(400).json({ error: 'resourceType, resourceId, userId, and role are required' });\n      return;\n    }\n\n    if (!['folder', 'document'].includes(resourceType)) {\n      res.status(400).json({ error: 'resourceType must be \"folder\" or \"document\"' });\n      return;\n    }\n\n    if (!['viewer', 'editor', 'owner'].includes(role)) {\n      res.status(400).json({ error: 'role must be \"viewer\", \"editor\", or \"owner\"' });\n      return;\n    }\n\n    // Check resource exists\n    if (resourceType === 'folder') {\n      if (!store.folders.has(resourceId)) {\n        res.status(404).json({ error: 'Folder not found' });\n        return;\n      }\n    } else {\n      if (!store.documents.has(resourceId)) {\n        res.status(404).json({ error: 'Document not found' });\n        return;\n      }\n    }\n\n    // Check target user exists\n    if (!store.users.has(userId)) {\n      res.status(404).json({ error: 'User not found' });\n      return;\n    }\n\n    // Sharer must have at least editor role to share\n    if (!hasPermission(req.userId!, resourceType as 'folder' | 'document', resourceId, 'editor')) {\n      res.status(403).json({ error: 'Access denied' });\n      return;\n    }\n\n    // Only owners can grant owner role\n    if (role === 'owner' && !hasPermission(req.userId!, resourceType as 'folder' | 'document', resourceId, 'owner')) {\n      res.status(403).json({ error: 'Only owners can grant owner role' });\n      return;\n    }\n\n    // Check if share already exists for this user/resource - update it\n    const existing = store.shares.find(\n      s => s.userId === userId && s.resourceType === resourceType && s.resourceId === resourceId\n    );\n\n    if (existing) {\n      existing.role = role as Role;\n      addActivity('share', req.userId!, resourceType as 'folder' | 'document', resourceId, `Shared with user ${userId} as ${role}`);\n      res.json(existing);\n      return;\n    }\n\n    const share = {\n      id: genId(),\n      resourceType: resourceType as 'folder' | 'document',\n      resourceId,\n      userId,\n      role: role as Role,\n      sharedBy: req.userId!,\n      createdAt: new Date().toISOString(),\n    };\n    store.shares.push(share);\n\n    addActivity('share', req.userId!, resourceType as 'folder' | 'document', resourceId, `Shared with user ${userId} as ${role}`);\n    res.status(201).json(share);\n  });\n\n  // Also support POST /:resourceType/:id/share\n  app.post('/folders/:id/share', authenticate, (req: Request, res: Response) => {\n    const resourceId = req.params.id;\n    const { userId, role } = req.body;\n\n    if (!userId || !role) {\n      res.status(400).json({ error: 'userId and role are required' });\n      return;\n    }\n\n    if (!['viewer', 'editor', 'owner'].includes(role)) {\n      res.status(400).json({ error: 'role must be \"viewer\", \"editor\", or \"owner\"' });\n      return;\n    }\n\n    if (!store.folders.has(resourceId)) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n\n    if (!store.users.has(userId)) {\n      res.status(404).json({ error: 'User not found' });\n      return;\n    }\n\n    if (!hasPermission(req.userId!, 'folder', resourceId, 'editor')) {\n      res.status(403).json({ error: 'Access denied' });\n      return;\n    }\n\n    if (role === 'owner' && !hasPermission(req.userId!, 'folder', resourceId, 'owner')) {\n      res.status(403).json({ error: 'Only owners can grant owner role' });\n      return;\n    }\n\n    const existing = store.shares.find(\n      s => s.userId === userId && s.resourceType === 'folder' && s.resourceId === resourceId\n    );\n\n    if (existing) {\n      existing.role = role as Role;\n      addActivity('share', req.userId!, 'folder', resourceId, `Shared with user ${userId} as ${role}`);\n      res.json(existing);\n      return;\n    }\n\n    const share = {\n      id: genId(),\n      resourceType: 'folder' as const,\n      resourceId,\n      userId,\n      role: role as Role,\n      sharedBy: req.userId!,\n      createdAt: new Date().toISOString(),\n    };\n    store.shares.push(share);\n\n    addActivity('share', req.userId!, 'folder', resourceId, `Shared with user ${userId} as ${role}`);\n    res.status(201).json(share);\n  });\n\n  app.post('/documents/:id/share', authenticate, (req: Request, res: Response) => {\n    const resourceId = req.params.id;\n    const { userId, role } = req.body;\n\n    if (!userId || !role) {\n      res.status(400).json({ error: 'userId and role are required' });\n      return;\n    }\n\n    if (!['viewer', 'editor', 'owner'].includes(role)) {\n      res.status(400).json({ error: 'role must be \"viewer\", \"editor\", or \"owner\"' });\n      return;\n    }\n\n    if (!store.documents.has(resourceId)) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n\n    if (!store.users.has(userId)) {\n      res.status(404).json({ error: 'User not found' });\n      return;\n    }\n\n    if (!hasPermission(req.userId!, 'document', resourceId, 'editor')) {\n      res.status(403).json({ error: 'Access denied' });\n      return;\n    }\n\n    if (role === 'owner' && !hasPermission(req.userId!, 'document', resourceId, 'owner')) {\n      res.status(403).json({ error: 'Only owners can grant owner role' });\n      return;\n    }\n\n    const existing = store.shares.find(\n      s => s.userId === userId && s.resourceType === 'document' && s.resourceId === resourceId\n    );\n\n    if (existing) {\n      existing.role = role as Role;\n      addActivity('share', req.userId!, 'document', resourceId, `Shared with user ${userId} as ${role}`);\n      res.json(existing);\n      return;\n    }\n\n    const share = {\n      id: genId(),\n      resourceType: 'document' as const,\n      resourceId,\n      userId,\n      role: role as Role,\n      sharedBy: req.userId!,\n      createdAt: new Date().toISOString(),\n    };\n    store.shares.push(share);\n\n    addActivity('share', req.userId!, 'document', resourceId, `Shared with user ${userId} as ${role}`);\n    res.status(201).json(share);\n  });\n\n  // ─── Activity log ───────────────────────────────────────────────────\n\n  app.get('/activity', authenticate, (req: Request, res: Response) => {\n    // Return activity log entries. Optionally filter by resourceType and resourceId.\n    let entries = store.activityLog;\n\n    const { resourceType, resourceId } = req.query;\n    if (resourceType) {\n      entries = entries.filter(e => e.resourceType === resourceType);\n    }\n    if (resourceId) {\n      entries = entries.filter(e => e.resourceId === resourceId);\n    }\n\n    res.json(entries);\n  });\n\n  return app;\n}\n","structuredPatch":[],"originalFile":null}}
