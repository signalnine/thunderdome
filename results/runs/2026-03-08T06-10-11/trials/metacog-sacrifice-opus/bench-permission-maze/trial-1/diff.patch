ss123' });\n    expect(res.status).toBe(201);\n    expect(res.body).toHaveProperty('id');\n    expect(res.body.username).toBe('alice');\n  });\n\n  it('should reject duplicate username', async () => {\n    await request(app).post('/auth/register').send({ username: 'alice', password: 'pass123' });\n    const res = await request(app).post('/auth/register').send({ username: 'alice', password: 'pass456' });\n    expect(res.status).toBe(409);\n  });\n\n  it('should reject registration without username or password', async () => {\n    const res1 = await request(app).post('/auth/register').send({ username: 'alice' });\n    expect(res1.status).toBe(400);\n    const res2 = await request(app).post('/auth/register').send({ password: 'pass' });\n    expect(res2.status).toBe(400);\n  });\n\n  it('should login with valid credentials', async () => {\n    await request(app).post('/auth/register').send({ username: 'alice', password: 'pass123' });\n    const res = await request(app).post('/auth/login').send({ username: 'alice', password: 'pass123' });\n    expect(res.status).toBe(200);\n    expect(res.body).toHaveProperty('token');\n    expect(res.body).toHaveProperty('userId');\n  });\n\n  it('should reject invalid credentials', async () => {\n    await request(app).post('/auth/register').send({ username: 'alice', password: 'pass123' });\n    const res = await request(app).post('/auth/login').send({ username: 'alice', password: 'wrong' });\n    expect(res.status).toBe(401);\n  });\n\n  it('should reject requests without auth token', async () => {\n    const res = await request(app).get('/folders/some-id');\n    expect(res.status).toBe(401);\n  });\n\n  it('should reject requests with invalid auth token', async () => {\n    const res = await request(app)\n      .get('/folders/some-id')\n      .set('Authorization', 'Bearer invalid-token');\n    expect(res.status).toBe(401);\n  });\n});\n\ndescribe('Folders', () => {\n  beforeEach(() => {\n    app = createApp();\n  });\n\n  it('should create a folder', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const res = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'My Folder' });\n    expect(res.status).toBe(201);\n    expect(res.body.name).toBe('My Folder');\n    expect(res.body.parentId).toBeNull();\n  });\n\n  it('should reject folder creation without name', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const res = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({});\n    expect(res.status).toBe(400);\n  });\n\n  it('should create nested folders', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const parent = await createFolder(token, 'Parent');\n    const child = await createFolder(token, 'Child');\n    // Update child to have parent\n    const res = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Child2', parentId: parent.id });\n    expect(res.status).toBe(201);\n    expect(res.body.parentId).toBe(parent.id);\n    expect(child).toBeDefined();\n  });\n\n  it('should get a folder with children and documents', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'Parent');\n    await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Child', parentId: folder.id });\n    await createDocument(token, 'Doc', 'content', folder.id);\n\n    const res = await request(app)\n      .get(`/folders/${folder.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.children).toHaveLength(1);\n    expect(res.body.documents).toHaveLength(1);\n  });\n\n  it('should return 404 for non-existent folder', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const res = await request(app)\n      .get('/folders/nonexistent')\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.status).toBe(404);\n  });\n\n  it('should update a folder', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'Old Name');\n    const res = await request(app)\n      .put(`/folders/${folder.id}`)\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'New Name' });\n    expect(res.status).toBe(200);\n    expect(res.body.name).toBe('New Name');\n  });\n\n  it('should delete a folder and its children', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const parent = await createFolder(token, 'Parent');\n    await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Child', parentId: parent.id });\n    await createDocument(token, 'Doc', 'content', parent.id);\n\n    const res = await request(app)\n      .delete(`/folders/${parent.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.status).toBe(204);\n\n    const getRes = await request(app)\n      .get(`/folders/${parent.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(getRes.status).toBe(404);\n  });\n});\n\ndescribe('Documents', () => {\n  beforeEach(() => {\n    app = createApp();\n  });\n\n  it('should create a document', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'Folder');\n    const res = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ title: 'My Doc', content: 'Hello world', folderId: folder.id });\n    expect(res.status).toBe(201);\n    expect(res.body.title).toBe('My Doc');\n    expect(res.body.content).toBe('Hello world');\n    expect(res.body.folderId).toBe(folder.id);\n  });\n\n  it('should create a document via folder route', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'Folder');\n    const res = await request(app)\n      .post(`/folders/${folder.id}/documents`)\n      .set('Authorization', `Bearer ${token}`)\n      .send({ title: 'My Doc', content: 'Hello' });\n    expect(res.status).toBe(201);\n    expect(res.body.folderId).toBe(folder.id);\n  });\n\n  it('should reject document creation without required fields', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'Folder');\n    const res = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ title: 'Doc', folderId: folder.id });\n    expect(res.status).toBe(400);\n  });\n\n  it('should get a document', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'Folder');\n    const doc = await createDocument(token, 'Doc', 'Content', folder.id);\n    const res = await request(app)\n      .get(`/documents/${doc.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.title).toBe('Doc');\n  });\n\n  it('should update a document', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'Folder');\n    const doc = await createDocument(token, 'Doc', 'Content', folder.id);\n    const res = await request(app)\n      .put(`/documents/${doc.id}`)\n      .set('Authorization', `Bearer ${token}`)\n      .send({ title: 'Updated', content: 'New content' });\n    expect(res.status).toBe(200);\n    expect(res.body.title).toBe('Updated');\n    expect(res.body.content).toBe('New content');\n  });\n\n  it('should delete a document', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'Folder');\n    const doc = await createDocument(token, 'Doc', 'Content', folder.id);\n    const res = await request(app)\n      .delete(`/documents/${doc.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.status).toBe(204);\n\n    const getRes = await request(app)\n      .get(`/documents/${doc.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(getRes.status).toBe(404);\n  });\n\n  it('should return 404 for non-existent document', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const res = await request(app)\n      .get('/documents/nonexistent')\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.status).toBe(404);\n  });\n});\n\ndescribe('Sharing & Permissions', () => {\n  beforeEach(() => {\n    app = createApp();\n  });\n\n  it('should share a folder with another user', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Shared Folder');\n\n    const res = await shareResource(alice.token, 'folder', folder.id, bob.userId, 'viewer');\n    expect(res.status).toBe(201);\n    expect(res.body.role).toBe('viewer');\n  });\n\n  it('should allow viewer to read folder', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Shared Folder');\n    await shareResource(alice.token, 'folder', folder.id, bob.userId, 'viewer');\n\n    const res = await request(app)\n      .get(`/folders/${folder.id}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n    expect(res.status).toBe(200);\n  });\n\n  it('should deny viewer from modifying folder', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Shared Folder');\n    await shareResource(alice.token, 'folder', folder.id, bob.userId, 'viewer');\n\n    const res = await request(app)\n      .put(`/folders/${folder.id}`)\n      .set('Authorization', `Bearer ${bob.token}`)\n      .send({ name: 'Hacked' });\n    expect(res.status).toBe(403);\n  });\n\n  it('should allow editor to modify folder', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Shared Folder');\n    await shareResource(alice.token, 'folder', folder.id, bob.userId, 'editor');\n\n    const res = await request(app)\n      .put(`/folders/${folder.id}`)\n      .set('Authorization', `Bearer ${bob.token}`)\n      .send({ name: 'Renamed' });\n    expect(res.status).toBe(200);\n    expect(res.body.name).toBe('Renamed');\n  });\n\n  it('should deny editor from deleting folder', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Shared Folder');\n    await shareResource(alice.token, 'folder', folder.id, bob.userId, 'editor');\n\n    const res = await request(app)\n      .delete(`/folders/${folder.id}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n    expect(res.status).toBe(403);\n  });\n\n  it('should deny unshared user access to folder', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Private Folder');\n\n    const res = await request(app)\n      .get(`/folders/${folder.id}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n    expect(res.status).toBe(403);\n  });\n\n  it('should share a document with another user', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Folder');\n    const doc = await createDocument(alice.token, 'Doc', 'Content', folder.id);\n\n    const res = await shareResource(alice.token, 'document', doc.id, bob.userId, 'viewer');\n    expect(res.status).toBe(201);\n\n    const getRes = await request(app)\n      .get(`/documents/${doc.id}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n    expect(getRes.status).toBe(200);\n  });\n\n  it('should inherit folder permissions for documents', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Folder');\n    const doc = await createDocument(alice.token, 'Doc', 'Content', folder.id);\n    await shareResource(alice.token, 'folder', folder.id, bob.userId, 'viewer');\n\n    const res = await request(app)\n      .get(`/documents/${doc.id}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n    expect(res.status).toBe(200);\n  });\n\n  it('should inherit nested folder permissions', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const parent = await createFolder(alice.token, 'Parent');\n    const childRes = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Child', parentId: parent.id });\n    const child = childRes.body;\n\n    await shareResource(alice.token, 'folder', parent.id, bob.userId, 'viewer');\n\n    // Bob should be able to view the child folder through parent inheritance\n    const res = await request(app)\n      .get(`/folders/${child.id}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n    expect(res.status).toBe(200);\n  });\n\n  it('should use most permissive role when multiple paths exist', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Folder');\n    const doc = await createDocument(alice.token, 'Doc', 'Content', folder.id);\n\n    // Give bob viewer on folder, editor on document directly\n    await shareResource(alice.token, 'folder', folder.id, bob.userId, 'viewer');\n    await shareResource(alice.token, 'document', doc.id, bob.userId, 'editor');\n\n    // Bob should be able to edit (the more permissive of viewer via folder, editor directly)\n    const res = await request(app)\n      .put(`/documents/${doc.id}`)\n      .set('Authorization', `Bearer ${bob.token}`)\n      .send({ title: 'Updated' });\n    expect(res.status).toBe(200);\n  });\n\n  it('should use most permissive role: editor on folder, viewer on document', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Folder');\n    const doc = await createDocument(alice.token, 'Doc', 'Content', folder.id);\n\n    // Give bob editor on folder, viewer on document directly\n    await shareResource(alice.token, 'folder', folder.id, bob.userId, 'editor');\n    await shareResource(alice.token, 'document', doc.id, bob.userId, 'viewer');\n\n    // Bob should be able to edit (editor via folder is more permissive than viewer directly)\n    const res = await request(app)\n      .put(`/documents/${doc.id}`)\n      .set('Authorization', `Bearer ${bob.token}`)\n      .send({ title: 'Updated' });\n    expect(res.status).toBe(200);\n  });\n\n  it('should allow editor to share', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const carol = await createUser('carol', 'pass');\n    const folder = await createFolder(alice.token, 'Folder');\n\n    await shareResource(alice.token, 'folder', folder.id, bob.userId, 'editor');\n\n    // Bob (editor) can share with Carol\n    const res = await shareResource(bob.token, 'folder', folder.id, carol.userId, 'viewer');\n    expect(res.status).toBe(201);\n  });\n\n  it('should deny editor from granting owner role', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const carol = await createUser('carol', 'pass');\n    const folder = await createFolder(alice.token, 'Folder');\n\n    await shareResource(alice.token, 'folder', folder.id, bob.userId, 'editor');\n\n    const res = await shareResource(bob.token, 'folder', folder.id, carol.userId, 'owner');\n    expect(res.status).toBe(403);\n  });\n\n  it('should update existing share role', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Folder');\n\n    await shareResource(alice.token, 'folder', folder.id, bob.userId, 'viewer');\n    const res = await shareResource(alice.token, 'folder', folder.id, bob.userId, 'editor');\n    expect(res.status).toBe(200);\n    expect(res.body.role).toBe('editor');\n  });\n\n  it('should share via resource-specific endpoint', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Folder');\n\n    const res = await request(app)\n      .post(`/folders/${folder.id}/share`)\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ userId: bob.userId, role: 'viewer' });\n    expect(res.status).toBe(201);\n  });\n\n  it('should share document via resource-specific endpoint', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Folder');\n    const doc = await createDocument(alice.token, 'Doc', 'Content', folder.id);\n\n    const res = await request(app)\n      .post(`/documents/${doc.id}/share`)\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ userId: bob.userId, role: 'editor' });\n    expect(res.status).toBe(201);\n  });\n\n  it('should deny sharing non-existent resource', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n\n    const res = await shareResource(alice.token, 'folder', 'nonexistent', bob.userId, 'viewer');\n    expect(res.status).toBe(404);\n  });\n\n  it('should deny sharing to non-existent user', async () => {\n    const alice = await createUser('alice', 'pass');\n    const folder = await createFolder(alice.token, 'Folder');\n\n    const res = await shareResource(alice.token, 'folder', folder.id, 'nonexistent', 'viewer');\n    expect(res.status).toBe(404);\n  });\n});\n\ndescribe('Activity Log', () => {\n  beforeEach(() => {\n    app = createApp();\n  });\n\n  it('should log document creation', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'Folder');\n    await createDocument(token, 'Doc', 'Content', folder.id);\n\n    const res = await request(app)\n      .get('/activity')\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.length).toBeGreaterThanOrEqual(1);\n    const createEntry = res.body.find((e: { action: string }) => e.action === 'document.create');\n    expect(createEntry).toBeDefined();\n    expect(createEntry.resourceType).toBe('document');\n  });\n\n  it('should log document updates', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'Folder');\n    const doc = await createDocument(token, 'Doc', 'Content', folder.id);\n\n    await request(app)\n      .put(`/documents/${doc.id}`)\n      .set('Authorization', `Bearer ${token}`)\n      .send({ title: 'Updated' });\n\n    const res = await request(app)\n      .get('/activity')\n      .set('Authorization', `Bearer ${token}`);\n    const updateEntry = res.body.find((e: { action: string }) => e.action === 'document.update');\n    expect(updateEntry).toBeDefined();\n  });\n\n  it('should log document deletion', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'Folder');\n    const doc = await createDocument(token, 'Doc', 'Content', folder.id);\n\n    await request(app)\n      .delete(`/documents/${doc.id}`)\n      .set('Authorization', `Bearer ${token}`);\n\n    const res = await request(app)\n      .get('/activity')\n      .set('Authorization', `Bearer ${token}`);\n    const deleteEntry = res.body.find((e: { action: string }) => e.action === 'document.delete');\n    expect(deleteEntry).toBeDefined();\n  });\n\n  it('should log sharing events', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Folder');\n\n    await shareResource(alice.token, 'folder', folder.id, bob.userId, 'viewer');\n\n    const res = await request(app)\n      .get('/activity')\n      .set('Authorization', `Bearer ${alice.token}`);\n    const shareEntry = res.body.find((e: { action: string }) => e.action === 'share');\n    expect(shareEntry).toBeDefined();\n    expect(shareEntry.resourceType).toBe('folder');\n  });\n\n  it('should have timestamp on log entries', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'Folder');\n    await createDocument(token, 'Doc', 'Content', folder.id);\n\n    const res = await request(app)\n      .get('/activity')\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.body[0]).toHaveProperty('timestamp');\n    expect(res.body[0]).toHaveProperty('userId');\n    expect(res.body[0]).toHaveProperty('action');\n    expect(res.body[0]).toHaveProperty('resourceType');\n    expect(res.body[0]).toHaveProperty('resourceId');\n  });\n\n  it('should filter activity by resourceType', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'Folder');\n    await createDocument(token, 'Doc1', 'Content', folder.id);\n    await createDocument(token, 'Doc2', 'Content', folder.id);\n\n    const res = await request(app)\n      .get('/activity?resourceType=document')\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.every((e: { resourceType: string }) => e.resourceType === 'document')).toBe(true);\n  });\n\n  it('should filter activity by resourceId', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'Folder');\n    const doc1 = await createDocument(token, 'Doc1', 'Content', folder.id);\n    await createDocument(token, 'Doc2', 'Content', folder.id);\n\n    const res = await request(app)\n      .get(`/activity?resourceId=${doc1.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.every((e: { resourceId: string }) => e.resourceId === doc1.id)).toBe(true);\n  });\n});\n\ndescribe('Permission edge cases', () => {\n  beforeEach(() => {\n    app = createApp();\n  });\n\n  it('owner should have full control', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'Folder');\n    const doc = await createDocument(token, 'Doc', 'Content', folder.id);\n\n    // Owner can read\n    const readRes = await request(app)\n      .get(`/documents/${doc.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(readRes.status).toBe(200);\n\n    // Owner can edit\n    const editRes = await request(app)\n      .put(`/documents/${doc.id}`)\n      .set('Authorization', `Bearer ${token}`)\n      .send({ title: 'Updated' });\n    expect(editRes.status).toBe(200);\n\n    // Owner can delete\n    const delRes = await request(app)\n      .delete(`/documents/${doc.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(delRes.status).toBe(204);\n  });\n\n  it('document in shared folder inherits folder editor permissions', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Folder');\n    const doc = await createDocument(alice.token, 'Doc', 'Content', folder.id);\n\n    // Share folder as editor\n    await shareResource(alice.token, 'folder', folder.id, bob.userId, 'editor');\n\n    // Bob should be able to edit the document (inherited from folder)\n    const res = await request(app)\n      .put(`/documents/${doc.id}`)\n      .set('Authorization', `Bearer ${bob.token}`)\n      .send({ content: 'Modified by bob' });\n    expect(res.status).toBe(200);\n    expect(res.body.content).toBe('Modified by bob');\n  });\n\n  it('deeply nested folder inherits permissions from grandparent', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n\n    const root = await createFolder(alice.token, 'Root');\n    const midRes = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Mid', parentId: root.id });\n    const mid = midRes.body;\n\n    const leafRes = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Leaf', parentId: mid.id });\n    const leaf = leafRes.body;\n\n    // Share root with bob as viewer\n    await shareResource(alice.token, 'folder', root.id, bob.userId, 'viewer');\n\n    // Bob should be able to view the leaf folder\n    const res = await request(app)\n      .get(`/folders/${leaf.id}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n    expect(res.status).toBe(200);\n  });\n\n  it('document in deeply nested folder inherits permissions', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n\n    const root = await createFolder(alice.token, 'Root');\n    const childRes = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Child', parentId: root.id });\n    const child = childRes.body;\n\n    const doc = await createDocument(alice.token, 'Doc', 'Content', child.id);\n\n    // Share root with bob as editor\n    await shareResource(alice.token, 'folder', root.id, bob.userId, 'editor');\n\n    // Bob should be able to edit the document in the child folder\n    const res = await request(app)\n      .put(`/documents/${doc.id}`)\n      .set('Authorization', `Bearer ${bob.token}`)\n      .send({ content: 'Updated' });\n    expect(res.status).toBe(200);\n  });\n\n  it('viewer on folder cannot create documents', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Folder');\n    await shareResource(alice.token, 'folder', folder.id, bob.userId, 'viewer');\n\n    const res = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${bob.token}`)\n      .send({ title: 'Doc', content: 'test', folderId: folder.id });\n    expect(res.status).toBe(403);\n  });\n\n  it('editor on folder can create documents', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Folder');\n    await shareResource(alice.token, 'folder', folder.id, bob.userId, 'editor');\n\n    const res = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${bob.token}`)\n      .send({ title: 'Doc', content: 'test', folderId: folder.id });\n    expect(res.status).toBe(201);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":103,"cache_read_input_tokens":51094,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":103},"output_tokens":25,"service_tier":"stan