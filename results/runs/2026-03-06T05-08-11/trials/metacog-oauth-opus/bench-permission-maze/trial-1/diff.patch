+import { Router } from 'express';
+import crypto from 'crypto';
+import { Store } from '../store.js';
+import { AuthRequest, requireAuth } from '../auth.js';
+import { hasPermission } from '../permissions.js';
+
+export function createDocumentRoutes(store: Store): Router {
+  const router = Router();
+
+  // Create document
+  router.post('/documents', requireAuth, (req: AuthRequest, res) => {
+    const { title, content, folderId } = req.body;
+    const userId = req.userId!;
+
+    if (!title || typeof title !== 'string') {
+      res.status(400).json({ error: 'Document title is required' });
+      return;
+    }
+    if (content === undefined || content === null) {
+      res.status(400).json({ error: 'Document content is required' });
+      return;
+    }
+    if (!folderId) {
+      res.status(400).json({ error: 'Folder ID is required' });
+      return;
+    }
+
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    // Must have at least editor permission on the folder
+    if (!hasPermission(store, userId, 'folder', folderId, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions on folder' });
+      return;
+    }
+
+    const id = crypto.randomUUID();
+    const now = new Date().toISOString();
+    const doc = {
+      id,
+      title,
+      content: String(content),
+      folderId,
+      ownerId: userId,
+      createdAt: now,
+      updatedAt: now,
+    };
+    store.documents.set(id, doc);
+
+    // Give owner permission
+    store.permissions.push({
+      id: crypto.randomUUID(),
+      resourceType: 'document',
+      resourceId: id,
+      userId,
+      role: 'owner',
+    });
+
+    // Activity log
+    store.activityLog.push({
+      id: crypto.randomUUID(),
+      action: 'document_created',
+      userId,
+      resourceType: 'document',
+      resourceId: id,
+      timestamp: now,
+    });
+
+    res.status(201).json(doc);
+  });
+
+  // Also support POST /folders/:folderId/documents
+  router.post('/folders/:folderId/documents', requireAuth, (req: AuthRequest, res) => {
+    const { title, content } = req.body;
+    const folderId = req.params.folderId;
+    const userId = req.userId!;
+
+    if (!title || typeof title !== 'string') {
+      res.status(400).json({ error: 'Document title is required' });
+      return;
+    }
+    if (content === undefined || content === null) {
+      res.status(400).json({ error: 'Document content is required' });
+      return;
+    }
+
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'folder', folderId, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions on folder' });
+      return;
+    }
+
+    const id = crypto.randomUUID();
+    const now = new Date().toISOString();
+    const doc = {
+      id,
+      title,
+      content: String(content),
+      folderId,
+      ownerId: userId,
+      createdAt: now,
+      updatedAt: now,
+    };
+    store.documents.set(id, doc);
+
+    store.permissions.push({
+      id: crypto.randomUUID(),
+      resourceType: 'document',
+      resourceId: id,
+      userId,
+      role: 'owner',
+    });
+
+    store.activityLog.push({
+      id: crypto.randomUUID(),
+      action: 'document_created',
+      userId,
+      resourceType: 'document',
+      resourceId: id,
+      timestamp: now,
+    });
+
+    res.status(201).json(doc);
+  });
+
+  // Get document
+  router.get('/documents/:id', requireAuth, (req: AuthRequest, res) => {
+    const doc = store.documents.get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    const userId = req.userId!;
+    if (!hasPermission(store, userId, 'document', doc.id, 'viewer')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    res.json(doc);
+  });
+
+  // Update document
+  router.put('/documents/:id', requireAuth, (req: AuthRequest, res) => {
+    const doc = store.documents.get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    const userId = req.userId!;
+    if (!hasPermission(store, userId, 'document', doc.id, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const { title, content } = req.body;
+    if (title !== undefined) {
+      if (typeof title !== 'string' || !title) {
+        res.status(400).json({ error: 'Title must be a non-empty string' });
+        return;
+      }
+      doc.title = title;
+    }
+    if (content !== undefined) {
+      doc.content = String(content);
+    }
+    doc.updatedAt = new Date().toISOString();
+
+    // Activity log
+    store.activityLog.push({
+      id: crypto.randomUUID(),
+      action: 'document_updated',
+      userId,
+      resourceType: 'document',
+      resourceId: doc.id,
+      timestamp: doc.updatedAt,
+    });
+
+    res.json(doc);
+  });
+
+  // Delete document
+  router.delete('/documents/:id', requireAuth, (req: AuthRequest, res) => {
+    const doc = store.documents.get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    const userId = req.userId!;
+    if (!hasPermission(store, userId, 'document', doc.id, 'owner')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const now = new Date().toISOString();
+
+    // Activity log
+    store.activityLog.push({
+      id: crypto.randomUUID(),
+      action: 'document_deleted',
+      userId,
+      resourceType: 'document',
+      resourceId: doc.id,
+      timestamp: now,
+    });
+
+    store.documents.delete(doc.id);
+    store.permissions = store.permissions.filter(
+      p => !(p.resourceType === 'document' && p.resourceId === doc.id)
+    );
+
+    res.status(204).send();
+  });
+
+  return router;
+}
diff --git a/src/routes/folders.ts b/src/routes/folders.ts
new file mode 100644
index 0000000..d763f3d
--- /dev/null
+++ b/src/routes/folders.ts
@@ -0,0 +1,183 @@
+import { Router } from 'express';
+import crypto from 'crypto';
+import { Store } from '../store.js';
+import { AuthRequest, requireAuth } from '../auth.js';
+import { hasPermission } from '../permissions.js';
+
+export function createFolderRoutes(store: Store): Router {
+  const router = Router();
+
+  // Create folder
+  router.post('/folders', requireAuth, (req: AuthRequest, res) => {
+    const { name, parentId } = req.body;
+    const userId = req.userId!;
+
+    if (!name || typeof name !== 'string') {
+      res.status(400).json({ error: 'Folder name is required' });
+      return;
+    }
+
+    if (parentId !== undefined && parentId !== null) {
+      const parentFolder = store.folders.get(parentId);
+      if (!parentFolder) {
+        res.status(404).json({ error: 'Parent folder not found' });
+        return;
+      }
+      // Must have at least editor permission on parent to create subfolder
+      if (!hasPermission(store, userId, 'folder', parentId, 'editor')) {
+        res.status(403).json({ error: 'Insufficient permissions on parent folder' });
+        return;
+      }
+    }
+
+    const id = crypto.randomUUID();
+    const folder = {
+      id,
+      name,
+      parentId: parentId || null,
+      ownerId: userId,
+      createdAt: new Date().toISOString(),
+    };
+    store.folders.set(id, folder);
+
+    // Give owner permission
+    store.permissions.push({
+      id: crypto.randomUUID(),
+      resourceType: 'folder',
+      resourceId: id,
+      userId,
+      role: 'owner',
+    });
+
+    res.status(201).json(folder);
+  });
+
+  // Get folder
+  router.get('/folders/:id', requireAuth, (req: AuthRequest, res) => {
+    const folder = store.folders.get(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    const userId = req.userId!;
+    if (!hasPermission(store, userId, 'folder', folder.id, 'viewer')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    // Get child folders and documents
+    const children: string[] = [];
+    for (const f of store.folders.values()) {
+      if (f.parentId === folder.id) {
+        children.push(f.id);
+      }
+    }
+    const documents: string[] = [];
+    for (const doc of store.documents.values()) {
+      if (doc.folderId === folder.id) {
+        documents.push(doc.id);
+      }
+    }
+
+    res.json({ ...folder, children, documents });
+  });
+
+  // Update folder
+  router.put('/folders/:id', requireAuth, (req: AuthRequest, res) => {
+    const folder = store.folders.get(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    const userId = req.userId!;
+    if (!hasPermission(store, userId, 'folder', folder.id, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const { name, parentId } = req.body;
+    if (name !== undefined) {
+      if (typeof name !== 'string' || !name) {
+        res.status(400).json({ error: 'Folder name must be a non-empty string' });
+        return;
+      }
+      folder.name = name;
+    }
+    if (parentId !== undefined) {
+      if (parentId !== null) {
+        const parentFolder = store.folders.get(parentId);
+        if (!parentFolder) {
+          res.status(404).json({ error: 'Parent folder not found' });
+          return;
+        }
+        // Prevent circular references
+        if (parentId === folder.id) {
+          res.status(400).json({ error: 'A folder cannot be its own parent' });
+          return;
+        }
+      }
+      folder.parentId = parentId;
+    }
+
+    res.json(folder);
+  });
+
+  // Delete folder
+  router.delete('/folders/:id', requireAuth, (req: AuthRequest, res) => {
+    const folder = store.folders.get(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    const userId = req.userId!;
+    if (!hasPermission(store, userId, 'folder', folder.id, 'owner')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    // Delete child documents
+    for (const [docId, doc] of store.documents.entries()) {
+      if (doc.folderId === folder.id) {
+        store.documents.delete(docId);
+        store.permissions = store.permissions.filter(
+          p => !(p.resourceType === 'document' && p.resourceId === docId)
+        );
+      }
+    }
+
+    // Delete child folders recursively
+    const deleteSubfolders = (folderId: string) => {
+      for (const [fId, f] of store.folders.entries()) {
+        if (f.parentId === folderId) {
+          // Delete docs in this subfolder
+          for (const [docId, doc] of store.documents.entries()) {
+            if (doc.folderId === fId) {
+              store.documents.delete(docId);
+              store.permissions = store.permissions.filter(
+                p => !(p.resourceType === 'document' && p.resourceId === docId)
+              );
+            }
+          }
+          deleteSubfolders(fId);
+          store.folders.delete(fId);
+          store.permissions = store.permissions.filter(
+            p => !(p.resourceType === 'folder' && p.resourceId === fId)
+          );
+        }
+      }
+    };
+    deleteSubfolders(folder.id);
+
+    store.folders.delete(folder.id);
+    store.permissions = store.permissions.filter(
+      p => !(p.resourceType === 'folder' && p.resourceId === folder.id)
+    );
+
+    res.status(204).send();
+  });
+
+  return router;
+}
