+import { Router } from 'express';
+import crypto from 'crypto';
+import { Role } from '../types.js';
+import { Store } from '../store.js';
+import { AuthRequest, requireAuth } from '../auth.js';
+import { hasPermission, getEffectiveRole } from '../permissions.js';
+
+const VALID_ROLES: Role[] = ['viewer', 'editor', 'owner'];
+
+export function createSharingRoutes(store: Store): Router {
+  const router = Router();
+
+  // Share a resource (folder or document)
+  router.post('/share', requireAuth, (req: AuthRequest, res) => {
+    const { resourceType, resourceId, userId: targetUserId, role } = req.body;
+    const userId = req.userId!;
+
+    if (!resourceType || !['folder', 'document'].includes(resourceType)) {
+      res.status(400).json({ error: 'Invalid resource type. Must be "folder" or "document"' });
+      return;
+    }
+    if (!resourceId) {
+      res.status(400).json({ error: 'Resource ID is required' });
+      return;
+    }
+    if (!targetUserId) {
+      res.status(400).json({ error: 'Target user ID is required' });
+      return;
+    }
+    if (!role || !VALID_ROLES.includes(role)) {
+      res.status(400).json({ error: 'Invalid role. Must be "viewer", "editor", or "owner"' });
+      return;
+    }
+
+    // Check resource exists
+    if (resourceType === 'folder') {
+      if (!store.folders.has(resourceId)) {
+        res.status(404).json({ error: 'Folder not found' });
+        return;
+      }
+    } else {
+      if (!store.documents.has(resourceId)) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+    }
+
+    // Check target user exists
+    if (!store.users.has(targetUserId)) {
+      res.status(404).json({ error: 'Target user not found' });
+      return;
+    }
+
+    // To share, user must be editor or owner
+    if (!hasPermission(store, userId, resourceType, resourceId, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions to share this resource' });
+      return;
+    }
+
+    // Only owners can assign the owner role
+    if (role === 'owner') {
+      if (!hasPermission(store, userId, resourceType, resourceId, 'owner')) {
+        res.status(403).json({ error: 'Only owners can assign the owner role' });
+        return;
+      }
+    }
+
+    // Check if permission already exists and update it, or create new
+    const existingPerm = store.permissions.find(
+      p => p.resourceType === resourceType && p.resourceId === resourceId && p.userId === targetUserId
+    );
+
+    if (existingPerm) {
+      existingPerm.role = role;
+    } else {
+      store.permissions.push({
+        id: crypto.randomUUID(),
+        resourceType,
+        resourceId,
+        userId: targetUserId,
+        role,
+      });
+    }
+
+    const now = new Date().toISOString();
+    // Activity log
+    store.activityLog.push({
+      id: crypto.randomUUID(),
+      action: 'resource_shared',
+      userId,
+      resourceType,
+      resourceId,
+      timestamp: now,
+      details: `Shared with user ${targetUserId} as ${role}`,
+    });
+
+    res.json({ message: 'Resource shared successfully', resourceType, resourceId, userId: targetUserId, role });
+  });
+
+  // Also support POST /:resourceType/:id/share
+  router.post('/folders/:id/share', requireAuth, (req: AuthRequest, res) => {
+    const resourceId = req.params.id;
+    const { userId: targetUserId, role } = req.body;
+    const userId = req.userId!;
+
+    if (!targetUserId) {
+      res.status(400).json({ error: 'Target user ID is required' });
+      return;
+    }
+    if (!role || !VALID_ROLES.includes(role)) {
+      res.status(400).json({ error: 'Invalid role. Must be "viewer", "editor", or "owner"' });
+      return;
+    }
+
+    if (!store.folders.has(resourceId)) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+    if (!store.users.has(targetUserId)) {
+      res.status(404).json({ error: 'Target user not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'folder', resourceId, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions to share this resource' });
+      return;
+    }
+    if (role === 'owner' && !hasPermission(store, userId, 'folder', resourceId, 'owner')) {
+      res.status(403).json({ error: 'Only owners can assign the owner role' });
+      return;
+    }
+
+    const existingPerm = store.permissions.find(
+      p => p.resourceType === 'folder' && p.resourceId === resourceId && p.userId === targetUserId
+    );
+    if (existingPerm) {
+      existingPerm.role = role;
+    } else {
+      store.permissions.push({
+        id: crypto.randomUUID(),
+        resourceType: 'folder',
+        resourceId,
+        userId: targetUserId,
+        role,
+      });
+    }
+
+    const now = new Date().toISOString();
+    store.activityLog.push({
+      id: crypto.randomUUID(),
+      action: 'resource_shared',
+      userId,
+      resourceType: 'folder',
+      resourceId,
+      timestamp: now,
+      details: `Shared with user ${targetUserId} as ${role}`,
+    });
+
+    res.json({ message: 'Folder shared successfully', resourceType: 'folder', resourceId, userId: targetUserId, role });
+  });
+
+  router.post('/documents/:id/share', requireAuth, (req: AuthRequest, res) => {
+    const resourceId = req.params.id;
+    const { userId: targetUserId, role } = req.body;
+    const userId = req.userId!;
+
+    if (!targetUserId) {
+      res.status(400).json({ error: 'Target user ID is required' });
+      return;
+    }
+    if (!role || !VALID_ROLES.includes(role)) {
+      res.status(400).json({ error: 'Invalid role. Must be "viewer", "editor", or "owner"' });
+      return;
+    }
+
+    if (!store.documents.has(resourceId)) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    if (!store.users.has(targetUserId)) {
+      res.status(404).json({ error: 'Target user not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'document', resourceId, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions to share this resource' });
+      return;
+    }
+    if (role === 'owner' && !hasPermission(store, userId, 'document', resourceId, 'owner')) {
+      res.status(403).json({ error: 'Only owners can assign the owner role' });
+      return;
+    }
+
+    const existingPerm = store.permissions.find(
+      p => p.resourceType === 'document' && p.resourceId === resourceId && p.userId === targetUserId
+    );
+    if (existingPerm) {
+      existingPerm.role = role;
+    } else {
+      store.permissions.push({
+        id: crypto.randomUUID(),
+        resourceType: 'document',
+        resourceId,
+        userId: targetUserId,
+        role,
+      });
+    }
+
+    const now = new Date().toISOString();
+    store.activityLog.push({
+      id: crypto.randomUUID(),
+      action: 'resource_shared',
+      userId,
+      resourceType: 'document',
+      resourceId,
+      timestamp: now,
+      details: `Shared with user ${targetUserId} as ${role}`,
+    });
+
+    res.json({ message: 'Document shared successfully', resourceType: 'document', resourceId, userId: targetUserId, role });
+  });
+
+  // Get permissions for a resource
+  router.get('/folders/:id/permissions', requireAuth, (req: AuthRequest, res) => {
+    const resourceId = req.params.id;
+    const userId = req.userId!;
+
+    if (!store.folders.has(resourceId)) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'folder', resourceId, 'viewer')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const perms = store.permissions.filter(
+      p => p.resourceType === 'folder' && p.resourceId === resourceId
+    );
+    res.json(perms);
+  });
+
+  router.get('/documents/:id/permissions', requireAuth, (req: AuthRequest, res) => {
+    const resourceId = req.params.id;
+    const userId = req.userId!;
+
+    if (!store.documents.has(resourceId)) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'document', resourceId, 'viewer')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const perms = store.permissions.filter(
+      p => p.resourceType === 'document' && p.resourceId === resourceId
+    );
+    res.json(perms);
+  });
+
+  // Get effective role for current user on a resource
+  router.get('/folders/:id/role', requireAuth, (req: AuthRequest, res) => {
+    const resourceId = req.params.id;
+    const userId = req.userId!;
+
+    if (!store.folders.has(resourceId)) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, userId, 'folder', resourceId);
+    res.json({ role });
+  });
+
+  router.get('/documents/:id/role', requireAuth, (req: AuthRequest, res) => {
+    const resourceId = req.params.id;
+    const userId = req.userId!;
+
+    if (!store.documents.has(resourceId)) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, userId, 'document', resourceId);
+    res.json({ role });
+  });
+
+  return router;
+}
