);\n    expect(res.body.username).toBe('alice');\n    expect(res.body.id).toBeDefined();\n    expect(res.body.password).toBeUndefined();\n  });\n\n  it('should reject duplicate username', async () => {\n    await request(app).post('/auth/register').send({ username: 'alice', password: 'pass123' });\n    const res = await request(app).post('/auth/register').send({ username: 'alice', password: 'pass456' });\n    expect(res.status).toBe(409);\n  });\n\n  it('should reject registration without username or password', async () => {\n    const res1 = await request(app).post('/auth/register').send({ username: 'alice' });\n    expect(res1.status).toBe(400);\n    const res2 = await request(app).post('/auth/register').send({ password: 'pass' });\n    expect(res2.status).toBe(400);\n  });\n\n  it('should login and return token', async () => {\n    await request(app).post('/auth/register').send({ username: 'alice', password: 'pass123' });\n    const res = await request(app).post('/auth/login').send({ username: 'alice', password: 'pass123' });\n    expect(res.status).toBe(200);\n    expect(res.body.token).toBeDefined();\n    expect(res.body.userId).toBeDefined();\n  });\n\n  it('should reject invalid login', async () => {\n    await request(app).post('/auth/register').send({ username: 'alice', password: 'pass123' });\n    const res = await request(app).post('/auth/login').send({ username: 'alice', password: 'wrong' });\n    expect(res.status).toBe(401);\n  });\n});\n\ndescribe('Folders', () => {\n  let token: string;\n\n  beforeEach(async () => {\n    app = createApp();\n    const user = await createUser('alice', 'pass');\n    token = user.token;\n  });\n\n  it('should require auth', async () => {\n    const res = await request(app).post('/folders').send({ name: 'test' });\n    expect(res.status).toBe(401);\n  });\n\n  it('should create a root folder', async () => {\n    const res = await createFolder(token, 'My Folder');\n    expect(res.status).toBe(201);\n    expect(res.body.name).toBe('My Folder');\n    expect(res.body.parentId).toBeNull();\n    expect(res.body.id).toBeDefined();\n  });\n\n  it('should create a nested folder', async () => {\n    const parent = await createFolder(token, 'Parent');\n    const child = await createFolder(token, 'Child', parent.body.id);\n    expect(child.status).toBe(201);\n    expect(child.body.parentId).toBe(parent.body.id);\n  });\n\n  it('should get a folder with children and documents', async () => {\n    const parent = await createFolder(token, 'Parent');\n    await createFolder(token, 'Child', parent.body.id);\n    await createDocument(token, 'Doc 1', 'Content', parent.body.id);\n\n    const res = await request(app)\n      .get(`/folders/${parent.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.name).toBe('Parent');\n    expect(res.body.children).toHaveLength(1);\n    expect(res.body.documents).toHaveLength(1);\n  });\n\n  it('should update a folder', async () => {\n    const folder = await createFolder(token, 'Original');\n    const res = await request(app)\n      .put(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Renamed' });\n    expect(res.status).toBe(200);\n    expect(res.body.name).toBe('Renamed');\n  });\n\n  it('should delete a folder and its contents', async () => {\n    const parent = await createFolder(token, 'Parent');\n    const child = await createFolder(token, 'Child', parent.body.id);\n    await createDocument(token, 'Doc', 'Content', child.body.id);\n\n    const del = await request(app)\n      .delete(`/folders/${parent.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(del.status).toBe(204);\n\n    const getParent = await request(app)\n      .get(`/folders/${parent.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(getParent.status).toBe(404);\n\n    const getChild = await request(app)\n      .get(`/folders/${child.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(getChild.status).toBe(404);\n  });\n\n  it('should return 404 for non-existent folder', async () => {\n    const res = await request(app)\n      .get('/folders/nonexistent')\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.status).toBe(404);\n  });\n\n  it('should reject creating folder with non-existent parent', async () => {\n    const res = await createFolder(token, 'Orphan', 'nonexistent');\n    expect(res.status).toBe(404);\n  });\n});\n\ndescribe('Documents', () => {\n  let token: string;\n  let folderId: string;\n\n  beforeEach(async () => {\n    app = createApp();\n    const user = await createUser('alice', 'pass');\n    token = user.token;\n    const folder = await createFolder(token, 'Docs');\n    folderId = folder.body.id;\n  });\n\n  it('should create a document', async () => {\n    const res = await createDocument(token, 'Test Doc', 'Hello World', folderId);\n    expect(res.status).toBe(201);\n    expect(res.body.title).toBe('Test Doc');\n    expect(res.body.content).toBe('Hello World');\n    expect(res.body.folderId).toBe(folderId);\n  });\n\n  it('should create a document via folder route', async () => {\n    const res = await request(app)\n      .post(`/folders/${folderId}/documents`)\n      .set('Authorization', `Bearer ${token}`)\n      .send({ title: 'Doc via folder', content: 'content' });\n    expect(res.status).toBe(201);\n    expect(res.body.folderId).toBe(folderId);\n  });\n\n  it('should get a document', async () => {\n    const doc = await createDocument(token, 'Test', 'Content', folderId);\n    const res = await request(app)\n      .get(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.title).toBe('Test');\n  });\n\n  it('should update a document', async () => {\n    const doc = await createDocument(token, 'Test', 'Old Content', folderId);\n    const res = await request(app)\n      .put(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${token}`)\n      .send({ title: 'Updated', content: 'New Content' });\n    expect(res.status).toBe(200);\n    expect(res.body.title).toBe('Updated');\n    expect(res.body.content).toBe('New Content');\n  });\n\n  it('should delete a document', async () => {\n    const doc = await createDocument(token, 'Test', 'Content', folderId);\n    const del = await request(app)\n      .delete(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(del.status).toBe(204);\n\n    const get = await request(app)\n      .get(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(get.status).toBe(404);\n  });\n\n  it('should require folder ID to create a document', async () => {\n    const res = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ title: 'Test', content: 'Content' });\n    expect(res.status).toBe(400);\n  });\n\n  it('should reject creating document in non-existent folder', async () => {\n    const res = await createDocument(token, 'Test', 'Content', 'nonexistent');\n    expect(res.status).toBe(404);\n  });\n});\n\ndescribe('Sharing & Permissions', () => {\n  let aliceToken: string;\n  let bobToken: string;\n  let bobId: string;\n  let folderId: string;\n\n  beforeEach(async () => {\n    app = createApp();\n    const alice = await createUser('alice', 'pass');\n    aliceToken = alice.token;\n    _aliceId = alice.userId;\n    const bob = await createUser('bob', 'pass');\n    bobToken = bob.token;\n    bobId = bob.userId;\n    const folder = await createFolder(aliceToken, 'Shared Folder');\n    folderId = folder.body.id;\n  });\n\n  it('should share a folder with another user as viewer', async () => {\n    const res = await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({ resourceType: 'folder', resourceId: folderId, userId: bobId, role: 'viewer' });\n    expect(res.status).toBe(200);\n\n    // Bob should be able to read the folder\n    const get = await request(app)\n      .get(`/folders/${folderId}`)\n      .set('Authorization', `Bearer ${bobToken}`);\n    expect(get.status).toBe(200);\n  });\n\n  it('should prevent viewer from editing', async () => {\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({ resourceType: 'folder', resourceId: folderId, userId: bobId, role: 'viewer' });\n\n    const res = await request(app)\n      .put(`/folders/${folderId}`)\n      .set('Authorization', `Bearer ${bobToken}`)\n      .send({ name: 'Hacked' });\n    expect(res.status).toBe(403);\n  });\n\n  it('should allow editor to modify', async () => {\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({ resourceType: 'folder', resourceId: folderId, userId: bobId, role: 'editor' });\n\n    const res = await request(app)\n      .put(`/folders/${folderId}`)\n      .set('Authorization', `Bearer ${bobToken}`)\n      .send({ name: 'Edited by Bob' });\n    expect(res.status).toBe(200);\n    expect(res.body.name).toBe('Edited by Bob');\n  });\n\n  it('should prevent editor from deleting (requires owner)', async () => {\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({ resourceType: 'folder', resourceId: folderId, userId: bobId, role: 'editor' });\n\n    const res = await request(app)\n      .delete(`/folders/${folderId}`)\n      .set('Authorization', `Bearer ${bobToken}`);\n    expect(res.status).toBe(403);\n  });\n\n  it('should share a document', async () => {\n    const doc = await createDocument(aliceToken, 'Secret', 'Top secret', folderId);\n\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({ resourceType: 'document', resourceId: doc.body.id, userId: bobId, role: 'viewer' });\n\n    const get = await request(app)\n      .get(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${bobToken}`);\n    expect(get.status).toBe(200);\n    expect(get.body.content).toBe('Top secret');\n  });\n\n  it('should deny access to unshared resources', async () => {\n    const get = await request(app)\n      .get(`/folders/${folderId}`)\n      .set('Authorization', `Bearer ${bobToken}`);\n    expect(get.status).toBe(403);\n  });\n\n  it('should share via resource-specific route', async () => {\n    const res = await request(app)\n      .post(`/folders/${folderId}/share`)\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({ userId: bobId, role: 'viewer' });\n    expect(res.status).toBe(200);\n\n    const get = await request(app)\n      .get(`/folders/${folderId}`)\n      .set('Authorization', `Bearer ${bobToken}`);\n    expect(get.status).toBe(200);\n  });\n\n  it('should prevent non-owner from assigning owner role', async () => {\n    // Share folder with bob as editor\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({ resourceType: 'folder', resourceId: folderId, userId: bobId, role: 'editor' });\n\n    // Create a third user\n    const charlie = await createUser('charlie', 'pass');\n\n    // Bob (editor) tries to share as owner - should fail\n    const res = await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${bobToken}`)\n      .send({ resourceType: 'folder', resourceId: folderId, userId: charlie.userId, role: 'owner' });\n    expect(res.status).toBe(403);\n  });\n\n  it('should allow editor to share with others', async () => {\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({ resourceType: 'folder', resourceId: folderId, userId: bobId, role: 'editor' });\n\n    const charlie = await createUser('charlie', 'pass');\n\n    // Bob (editor) shares as viewer - should succeed\n    const res = await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${bobToken}`)\n      .send({ resourceType: 'folder', resourceId: folderId, userId: charlie.userId, role: 'viewer' });\n    expect(res.status).toBe(200);\n  });\n\n  it('should inherit folder permissions for documents', async () => {\n    // Share folder with bob as editor\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({ resourceType: 'folder', resourceId: folderId, userId: bobId, role: 'editor' });\n\n    // Alice creates a doc in the shared folder\n    const doc = await createDocument(aliceToken, 'Inherited', 'Content', folderId);\n\n    // Bob should be able to read and edit the doc through folder permission\n    const get = await request(app)\n      .get(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${bobToken}`);\n    expect(get.status).toBe(200);\n\n    const update = await request(app)\n      .put(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${bobToken}`)\n      .send({ content: 'Updated by Bob' });\n    expect(update.status).toBe(200);\n  });\n\n  it('should use most permissive role when multiple paths exist', async () => {\n    // Share folder with bob as viewer\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({ resourceType: 'folder', resourceId: folderId, userId: bobId, role: 'viewer' });\n\n    const doc = await createDocument(aliceToken, 'Multi-path', 'Content', folderId);\n\n    // Share document directly with bob as editor\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({ resourceType: 'document', resourceId: doc.body.id, userId: bobId, role: 'editor' });\n\n    // Bob should have editor access (most permissive)\n    const update = await request(app)\n      .put(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${bobToken}`)\n      .send({ content: 'Edited' });\n    expect(update.status).toBe(200);\n  });\n\n  it('should inherit permissions through nested folders', async () => {\n    // Share root folder with bob as editor\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({ resourceType: 'folder', resourceId: folderId, userId: bobId, role: 'editor' });\n\n    // Create nested folder\n    const child = await createFolder(aliceToken, 'Nested', folderId);\n\n    // Bob should be able to access the nested folder\n    const get = await request(app)\n      .get(`/folders/${child.body.id}`)\n      .set('Authorization', `Bearer ${bobToken}`);\n    expect(get.status).toBe(200);\n  });\n\n  it('should reject invalid role', async () => {\n    const res = await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({ resourceType: 'folder', resourceId: folderId, userId: bobId, role: 'admin' });\n    expect(res.status).toBe(400);\n  });\n\n  it('should reject sharing non-existent resource', async () => {\n    const res = await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({ resourceType: 'folder', resourceId: 'nonexistent', userId: bobId, role: 'viewer' });\n    expect(res.status).toBe(404);\n  });\n\n  it('should update existing permission when sharing again', async () => {\n    // Share as viewer first\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({ resourceType: 'folder', resourceId: folderId, userId: bobId, role: 'viewer' });\n\n    // Bob can read but not edit\n    const editBefore = await request(app)\n      .put(`/folders/${folderId}`)\n      .set('Authorization', `Bearer ${bobToken}`)\n      .send({ name: 'Try Edit' });\n    expect(editBefore.status).toBe(403);\n\n    // Now share as editor\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({ resourceType: 'folder', resourceId: folderId, userId: bobId, role: 'editor' });\n\n    // Bob can now edit\n    const editAfter = await request(app)\n      .put(`/folders/${folderId}`)\n      .set('Authorization', `Bearer ${bobToken}`)\n      .send({ name: 'Edited' });\n    expect(editAfter.status).toBe(200);\n  });\n});\n\ndescribe('Activity Log', () => {\n  let token: string;\n  let folderId: string;\n\n  beforeEach(async () => {\n    app = createApp();\n    const user = await createUser('alice', 'pass');\n    token = user.token;\n    const folder = await createFolder(token, 'Folder');\n    folderId = folder.body.id;\n  });\n\n  it('should log document creation', async () => {\n    await createDocument(token, 'Test', 'Content', folderId);\n    const res = await request(app)\n      .get('/activity')\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.length).toBeGreaterThanOrEqual(1);\n    const createEntry = res.body.find((e: { action: string }) => e.action === 'document_created');\n    expect(createEntry).toBeDefined();\n    expect(createEntry.resourceType).toBe('document');\n    expect(createEntry.timestamp).toBeDefined();\n  });\n\n  it('should log document update', async () => {\n    const doc = await createDocument(token, 'Test', 'Content', folderId);\n    await request(app)\n      .put(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${token}`)\n      .send({ content: 'Updated' });\n\n    const res = await request(app)\n      .get('/activity')\n      .set('Authorization', `Bearer ${token}`);\n    const updateEntry = res.body.find((e: { action: string }) => e.action === 'document_updated');\n    expect(updateEntry).toBeDefined();\n  });\n\n  it('should log document deletion', async () => {\n    const doc = await createDocument(token, 'Test', 'Content', folderId);\n    await request(app)\n      .delete(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n\n    const res = await request(app)\n      .get('/activity')\n      .set('Authorization', `Bearer ${token}`);\n    const deleteEntry = res.body.find((e: { action: string }) => e.action === 'document_deleted');\n    expect(deleteEntry).toBeDefined();\n  });\n\n  it('should log sharing events', async () => {\n    const bob = await createUser('bob', 'pass');\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ resourceType: 'folder', resourceId: folderId, userId: bob.userId, role: 'viewer' });\n\n    const res = await request(app)\n      .get('/activity')\n      .set('Authorization', `Bearer ${token}`);\n    const shareEntry = res.body.find((e: { action: string }) => e.action === 'resource_shared');\n    expect(shareEntry).toBeDefined();\n    expect(shareEntry.resourceType).toBe('folder');\n  });\n\n  it('should require authentication', async () => {\n    const res = await request(app).get('/activity');\n    expect(res.status).toBe(401);\n  });\n\n  it('should include user ID and resource info in log entries', async () => {\n    const doc = await createDocument(token, 'Tracked Doc', 'Content', folderId);\n    const res = await request(app)\n      .get('/activity')\n      .set('Authorization', `Bearer ${token}`);\n    const entry = res.body[0];\n    expect(entry.userId).toBeDefined();\n    expect(entry.resourceId).toBe(doc.body.id);\n    expect(entry.resourceType).toBe('document');\n    expect(entry.action).toBeDefined();\n    expect(entry.timestamp).toBeDefined();\n  });\n});\n\ndescribe('Edge Cases', () => {\n  beforeEach(() => {\n    app = createApp();\n  });\n\n  it('should reject requests without auth token for protected routes', async () => {\n    const endpoints = [\n      { method: 'get' as const, path: '/folders/123' },\n      { method: 'post' as const, path: '/folders' },\n      { method: 'get' as const, path: '/documents/123' },\n    