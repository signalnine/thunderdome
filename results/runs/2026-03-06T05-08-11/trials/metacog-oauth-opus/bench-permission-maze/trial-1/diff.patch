+import { Router } from 'express';
+import { Store } from '../store.js';
+import { AuthRequest, requireAuth } from '../auth.js';
+
+export function createActivityRoutes(store: Store): Router {
+  const router = Router();
+
+  // Get activity log
+  router.get('/activity', requireAuth, (_req: AuthRequest, res) => {
+    res.json(store.activityLog);
+  });
+
+  return router;
+}
