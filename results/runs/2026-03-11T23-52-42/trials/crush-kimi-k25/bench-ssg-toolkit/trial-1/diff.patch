+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createAssetPipelinePlugin(): Plugin {
+  return {
+    name: 'asset-pipeline',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      beforeBuild: (ctx: BuildContext): void => {
+        // Initialize asset manifest in ctx.data
+        ctx.data.set('asset-manifest', { assets: [] as string[] });
+      },
+      transformContent: (file: ContentFile, ctx: BuildContext): ContentFile => {
+        let content = file.content;
+        const manifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;
+        const assets: string[] = manifest?.assets || [];
+
+        // Regex to match relative asset URLs in src and href attributes
+        // Matches ./path or path (but not /path, http://, https://, or /assets/)
+        const assetRegex = /(src|href)="(\.\/[^"]+)"/g;
+
+        content = content.replace(assetRegex, (match, attr, path) => {
+          // Extract the filename from the path
+          const filename = path.replace(/^\.\//, '');
+
+          // Skip if already pointing to /assets/
+          if (path.startsWith('/assets/')) {
+            return match;
+          }
+
+          // Add to manifest if not already there
+          if (!assets.includes(filename)) {
+            assets.push(filename);
+          }
+
+          // Rewrite the URL
+          return `${attr}="/assets/${filename}"`;
+        });
+
+        // Update manifest
+        ctx.data.set('asset-manifest', { assets });
+
+        return {
+          ...file,
+          content,
+        };
+      },
+    },
+  };
+}
