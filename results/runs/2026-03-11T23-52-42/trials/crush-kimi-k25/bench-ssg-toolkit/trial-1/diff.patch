+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: (file: ContentFile, _ctx: BuildContext): ContentFile => {
+        let content = file.content;
+
+        // Process admonitions first (before other markdown processing)
+        content = processAdmonitions(content);
+
+        // Process footnotes
+        content = processFootnotes(content);
+
+        // Basic markdown to HTML conversion
+        content = convertBasicMarkdown(content);
+
+        return {
+          ...file,
+          content,
+        };
+      },
+    },
+  };
+}
+
+function processAdmonitions(content: string): string {
+  // Match :::note, :::warning, :::tip blocks
+  const admonitionRegex = /:::(note|warning|tip)\n([\s\S]*?):::/g;
+
+  return content.replace(admonitionRegex, (_match, type, innerContent) => {
+    const trimmedContent = innerContent.trim();
+    return `<div class="admonition admonition-${type}">${trimmedContent}</div>`;
+  });
+}
+
+function processFootnotes(content: string): string {
+  // Match footnote references [^1], [^2], etc.
+  const footnoteRefRegex = /\[\^(\d+)]/g;
+
+  // Match footnote definitions [^1]: content
+  const footnoteDefRegex = /^\[\^(\d+)]:\s*(.+)$/gm;
+
+  const footnotes: Map<string, string> = new Map();
+
+  // Extract footnote definitions
+  let defMatch;
+  while ((defMatch = footnoteDefRegex.exec(content)) !== null) {
+    const num = defMatch[1];
+    const text = defMatch[2];
+    footnotes.set(num, text);
+  }
+
+  // Remove footnote definitions from content
+  content = content.replace(footnoteDefRegex, '');
+
+  // Replace footnote references with superscript links
+  content = content.replace(footnoteRefRegex, (_match, num) => {
+    return `<sup><a href="#fn-${num}">${num}</a></sup>`;
+  });
+
+  // Add footnotes section if there are footnotes
+  if (footnotes.size > 0) {
+    let footnoteSection = '<section class="footnotes"><ol>';
+    for (const [num, text] of footnotes) {
+      footnoteSection += `<li id="fn-${num}">${text}</li>`;
+    }
+    footnoteSection += '</ol></section>';
+    content += footnoteSection;
+  }
+
+  return content.trim();
+}
+
+function convertBasicMarkdown(content: string): string {
+  // Convert headers
+  content = content.replace(/^#### (.*$)/gim, '<h4>$1</h4>');
+  content = content.replace(/^### (.*$)/gim, '<h3>$1</h3>');
+  content = content.replace(/^## (.*$)/gim, '<h2>$1</h2>');
+  content = content.replace(/^# (.*$)/gim, '<h1>$1</h1>');
+
+  // Convert bold
+  content = content.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
+
+  // Convert italic
+  content = content.replace(/\*(.*?)\*/g, '<em>$1</em>');
+
+  // Convert paragraphs (lines separated by blank lines)
+  const lines = content.split('\n');
+  let inParagraph = false;
+  let result: string[] = [];
+
+  for (const line of lines) {
+    const trimmed = line.trim();
+
+    // Skip empty lines and lines that are already HTML tags
+    if (trimmed === '') {
+      if (inParagraph) {
+        result.push('</p>');
+        inParagraph = false;
+      }
+      continue;
+    }
+
+    // Skip if line is already an HTML tag
+    if (trimmed.startsWith('<') && (trimmed.endsWith('>') || trimmed.includes('</'))) {
+      if (inParagraph) {
+        result.push('</p>');
+        inParagraph = false;
+      }
+      result.push(line);
+      continue;
+    }
+
+    if (!inParagraph) {
+      result.push('<p>');
+      inParagraph = true;
+    }
+    result.push(line);
+  }
+
+  if (inParagraph) {
+    result.push('</p>');
+  }
+
+  return result.join('\n');
+}
