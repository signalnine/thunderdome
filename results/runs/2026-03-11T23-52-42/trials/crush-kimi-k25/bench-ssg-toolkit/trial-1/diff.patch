+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createRssFeedPlugin(): Plugin {
+  return {
+    name: 'rss-feed',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'taxonomy'],
+    hooks: {
+      afterBuild: (ctx: BuildContext): void => {
+        // Sort files by date (newest first)
+        const sortedFiles = [...ctx.files].sort((a, b) => {
+          const dateA = a.date ? new Date(a.date).getTime() : 0;
+          const dateB = b.date ? new Date(b.date).getTime() : 0;
+          return dateB - dateA;
+        });
+
+        // Get tag map from taxonomy plugin
+        const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]> | undefined;
+
+        // Build RSS 2.0 feed
+        let rss = `<?xml version="1.0" encoding="UTF-8"?>
+<rss version="2.0">
+  <channel>
+    <title>${escapeXml(ctx.config.title)}</title>
+    <link>${ctx.config.baseUrl}</link>
+    <description>RSS feed for ${escapeXml(ctx.config.title)}</description>`;
+
+        for (const file of sortedFiles) {
+          const itemUrl = `${ctx.config.baseUrl}/${file.slug}.html`;
+          const pubDate = file.date ? new Date(file.date).toUTCString() : '';
+
+          rss += `
+    <item>
+      <title>${escapeXml(file.title)}</title>
+      <link>${itemUrl}</link>`;
+
+          // Add content as CDATA
+          if (file.content) {
+            rss += `
+      <description><![CDATA[${file.content}]]></description>`;
+          }
+
+          // Add pubDate if available
+          if (pubDate && pubDate !== 'Invalid Date') {
+            rss += `
+      <pubDate>${pubDate}</pubDate>`;
+          }
+
+          // Add categories from tags
+          if (file.tags && file.tags.length > 0) {
+            for (const tag of file.tags) {
+              rss += `
+      <category>${escapeXml(tag)}</category>`;
+            }
+          } else if (tagMap) {
+            // Find tags that include this file
+            for (const [tag, files] of tagMap) {
+              if (files.some(f => f.slug === file.slug)) {
+                rss += `
+      <category>${escapeXml(tag)}</category>`;
+              }
+            }
+          }
+
+          rss += `
+    </item>`;
+        }
+
+        rss += `
+  </channel>
+</rss>`;
+
+        ctx.output.set('feed.xml', rss);
+      },
+    },
+  };
+}
+
+function escapeXml(str: string): string {
+  return str
+    .replace(/&/g, '&amp;')
+    .replace(/</g, '&lt;')
+    .replace(/>/g, '&gt;')
+    .replace(/"/g, '&quot;')
+    .replace(/'/g, '&apos;');
+}
diff --git a/src/plugins/search-index.ts b/src/plugins/search-index.ts
