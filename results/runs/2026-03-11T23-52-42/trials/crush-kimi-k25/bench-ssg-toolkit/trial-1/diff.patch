+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createSitemapPlugin(): Plugin {
+  return {
+    name: 'sitemap',
+    version: '1.0.0',
+    dependencies: ['taxonomy', 'rss-feed'],
+    hooks: {
+      afterBuild: (ctx: BuildContext): void => {
+        const urls: string[] = [];
+
+        // Add all content pages from ctx.output
+        for (const [path] of ctx.output) {
+          // Skip the sitemap itself and non-HTML files
+          if (path === 'sitemap.xml') {
+            continue;
+          }
+
+          // Include HTML pages, feed.xml, and tag pages
+          if (path.endsWith('.html') || path === 'feed.xml') {
+            urls.push(`${ctx.config.baseUrl}/${path}`);
+          }
+        }
+
+        // Also add tag pages from taxonomy data
+        const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]> | undefined;
+        if (tagMap) {
+          for (const tag of tagMap.keys()) {
+            const tagUrl = `${ctx.config.baseUrl}/tags/${tag}.html`;
+            if (!urls.includes(tagUrl)) {
+              urls.push(tagUrl);
+            }
+          }
+        }
+
+        // Build sitemap XML
+        let sitemap = `<?xml version="1.0" encoding="UTF-8"?>
+<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">`;
+
+        for (const url of urls) {
+          sitemap += `
+  <url>
+    <loc>${escapeXml(url)}</loc>
+  </url>`;
+        }
+
+        sitemap += `
+</urlset>`;
+
+        ctx.output.set('sitemap.xml', sitemap);
+      },
+    },
+  };
+}
+
+function escapeXml(str: string): string {
+  return str
+    .replace(/&/g, '&amp;')
+    .replace(/</g, '&lt;')
+    .replace(/>/g, '&gt;')
+    .replace(/"/g, '&quot;')
+    .replace(/'/g, '&apos;');
+}
