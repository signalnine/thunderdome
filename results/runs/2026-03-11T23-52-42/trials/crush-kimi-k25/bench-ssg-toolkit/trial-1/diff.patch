@@ -0,0 +1,29 @@
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createSyntaxHighlightPlugin(): Plugin {
+  return {
+    name: 'syntax-highlight',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: (file: ContentFile, _ctx: BuildContext): ContentFile => {
+        let content = file.content;
+
+        // Regex to match <pre><code class="language-xxx"> blocks
+        // We need to handle the pre and code tags together
+        const codeBlockRegex = /<pre><code class="language-([^"]+)">([\s\S]*?)<\/code><\/pre>/g;
+
+        content = content.replace(codeBlockRegex, (_match, language, innerContent) => {
+          // Add 'highlighted' class to the existing class
+          // Add data-language attribute to pre tag
+          return `<pre data-language="${language}"><code class="language-${language} highlighted">${innerContent}</code></pre>`;
+        });
+
+        return {
+          ...file,
+          content,
+        };
+      },
+    },
+  };
+}
