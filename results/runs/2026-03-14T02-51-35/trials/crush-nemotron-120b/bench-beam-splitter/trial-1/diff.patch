@@ -0,0 +1,117 @@
+/**
+ * Beam propagation simulator for a 2D grid laboratory.
+ */
+
+/**
+ * Helper function to simulate beam propagation and compute both metrics.
+ * @param grid - 2D grid of characters
+ * @returns object with beamCells (number) and totalPaths (bigint)
+ */
+function simulate(grid: string[][]): { beamCells: number; totalPaths: bigint } {
+    const R = grid.length;
+    const C = grid[0].length;
+
+    // dp[r][c][d] where d: 0=down, 1=down-left, 2=down-right
+    const dp: bigint[][][] = Array.from({ length: R }, () =>
+        Array.from({ length: C }, () => [0n, 0n, 0n])
+    );
+
+    const visited: boolean[][] = Array.from({ length: R }, () =>
+        Array.from({ length: C }, () => false)
+    );
+
+    // Find the source (exactly one source on the top row)
+    let sourceR = -1, sourceC = -1;
+    for (let r = 0; r < R; r++) {
+        for (let c = 0; c < C; c++) {
+            if (grid[r][c] === 'S') {
+                sourceR = r;
+                sourceC = c;
+                break;
+            }
+        }
+        if (sourceR !== -1) break;
+    }
+
+    // Initialize: source emits downward (direction 0)
+    dp[sourceR][sourceC][0] = 1n;
+
+    let totalPaths = 0n;
+
+    // Directions:
+    //   0: down    -> (1, 0)
+    //   1: down-left -> (1, -1)
+    //   2: down-right -> (1, 1)
+
+    for (let r = 0; r < R; r++) {
+        for (let c = 0; c < C; c++) {
+            for (let d = 0; d < 3; d++) {
+                const count = dp[r][c][d];
+                if (count === 0n) continue;
+
+                // Mark cell as visited for beamCells count
+                visited[r][c] = true;
+
+                if (grid[r][c] === '^') {
+                    // Splitter: splits into down-left (dir=1) and down-right (dir=2)
+                    // Down-left beam
+                    let nr = r + 1;
+                    let nc = c - 1;
+                    if (nr < 0 || nr >= R || nc < 0 || nc >= C) {
+                        totalPaths += count;
+                    } else {
+                        dp[nr][nc][1] += count;
+                    }
+
+                    // Down-right beam
+                    nr = r + 1;
+                    nc = c + 1;
+                    if (nr < 0 || nr >= R || nc < 0 || nc >= C) {
+                        totalPaths += count;
+                    } else {
+                        dp[nr][nc][2] += count;
+                    }
+                } else {
+                    // Not a splitter: continue in the same direction
+                    let nr, nc;
+                    if (d === 0) { // down
+                        nr = r + 1;
+                        nc = c;
+                    } else if (d === 1) { // down-left
+                        nr = r + 1;
+                        nc = c - 1;
+                    } else { // d === 2: down-right
+                        nr = r + 1;
+                        nc = c + 1;
+                    }
+
+                    if (nr < 0 || nr >= R || nc < 0 || nc >= C) {
+                        totalPaths += count;
+                    } else {
+                        dp[nr][nc][d] += count;
+                    }
+                }
+            }
+        }
+    }
+
+    // Count distinct visited cells
+    let beamCells = 0;
+    for (let r = 0; r < R; r++) {
+        for (let c = 0; c < C; c++) {
+            if (visited[r][c]) {
+                beamCells++;
+            }
+        }
+    }
+
+    return { beamCells, totalPaths };
+}
+
+export function countBeamCells(grid: string[][]): number {
+    return simulate(grid).beamCells;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+    return simulate(grid).totalPaths;
+}
