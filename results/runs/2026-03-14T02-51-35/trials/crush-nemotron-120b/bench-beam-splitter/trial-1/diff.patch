@@ -0,0 +1,100 @@
+import { countBeamCells, countBeamPaths } from './index.js';
+
+describe('countBeamCells', () => {
+  test('example 1', () => {
+    const grid: string[][] = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(5);
+  });
+
+  test('example 2', () => {
+    const grid: string[][] = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(6);
+  });
+
+  test('single source no splitters', () => {
+    const grid: string[][] = [
+      ['S', '.', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    // Beam goes down through (0,0), (1,0), (2,0) then exits at bottom.
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  test('source at edge', () => {
+    const grid: string[][] = [
+      ['S', '.', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  test('beam exits left', () => {
+    const grid: string[][] = [
+      ['.', 'S', '.'],
+      ['.', '^', '.'],
+      ['.', '.', '.'],
+    ];
+    // Beam: (0,1) -> (1,1) splitter -> splits to (2,0) and (2,2)
+    // (2,0) exits left? Actually (2,0) is inside, then next step would be (3,-1) which is out.
+    // But we only count visited cells: (0,1), (1,1), (2,0), (2,2) -> 4 cells.
+    expect(countBeamCells(grid)).toBe(4);
+  });
+});
+
+describe('countBeamPaths', () => {
+  test('example 1', () => {
+    const grid: string[][] = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  test('example 2', () => {
+    const grid: string[][] = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    // According to the example, there are 4 paths total (all exit).
+    expect(countBeamPaths(grid)).toBe(4n);
+  });
+
+  test('single source no splitters', () => {
+    const grid: string[][] = [
+      ['S', '.', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    // One path going straight down and exiting at bottom.
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  test('beam splits and one branch exits immediately', () => {
+    const grid: string[][] = [
+      ['S', '.', '.'],
+      ['^', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    // Beam: (0,0) -> (1,0) splitter -> splits to (2,-1) [absorbed] and (2,1)
+    // (2,1) then goes to (3,1) [out of grid] -> exits.
+    // So two paths: one absorbed at (2,-1) and one exiting at bottom from (2,1).
+    // Both are considered exiting the grid (absorbed = exits). So 2 paths.
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+});
