@@ -0,0 +1,233 @@
+// eslint-disable-next-line @typescript-eslint/no-explicit-any
+export type JsonValue = any;
+
+export interface Conflict {
+  documentId: string;
+  path: string;
+  base: JsonValue;
+  ours: JsonValue;
+  theirs: JsonValue;
+}
+
+/**
+ * Three-way structural merge of two objects against a common base.
+ * Returns the merged result and any conflicts found.
+ */
+export function threeWayMerge(
+  base: object | undefined,
+  ours: object | undefined,
+  theirs: object | undefined,
+  documentId: string
+): { merged: object; conflicts: Conflict[] } {
+  const conflicts: Conflict[] = [];
+  const merged = mergeRecursive(
+    base ?? {},
+    ours ?? {},
+    theirs ?? {},
+    documentId,
+    '',
+    conflicts
+  );
+  return { merged, conflicts };
+}
+
+function mergeRecursive(
+  base: JsonValue,
+  ours: JsonValue,
+  theirs: JsonValue,
+  documentId: string,
+  currentPath: string,
+  conflicts: Conflict[]
+): JsonValue {
+  // Collect all keys from all three sides
+  const allKeys = new Set<string>();
+  if (isPlainObject(base)) for (const k of Object.keys(base)) allKeys.add(k);
+  if (isPlainObject(ours)) for (const k of Object.keys(ours)) allKeys.add(k);
+  if (isPlainObject(theirs)) for (const k of Object.keys(theirs)) allKeys.add(k);
+
+  // If none are plain objects, handle as leaf values
+  if (!isPlainObject(base) && !isPlainObject(ours) && !isPlainObject(theirs)) {
+    return mergeLeaf(base, ours, theirs, documentId, currentPath, conflicts);
+  }
+
+  // If some are objects and some aren't, we need to handle type changes
+  if (!isPlainObject(ours) || !isPlainObject(theirs)) {
+    return mergeLeaf(base, ours, theirs, documentId, currentPath, conflicts);
+  }
+
+  const result: Record<string, JsonValue> = {};
+  const baseObj: Record<string, JsonValue> = isPlainObject(base) ? base : {};
+
+  for (const key of allKeys) {
+    const fieldPath = currentPath ? `${currentPath}.${key}` : key;
+    const baseVal: JsonValue = baseObj[key];
+    const oursVal: JsonValue = ours[key];
+    const theirsVal: JsonValue = theirs[key];
+
+    const baseHas = key in baseObj;
+    const oursHas = key in ours;
+    const theirsHas = key in theirs;
+
+    // Both sides deleted the key (or it never existed on either)
+    if (!oursHas && !theirsHas) {
+      continue;
+    }
+
+    // Key exists in base; check who deleted/modified
+    if (baseHas) {
+      if (!oursHas && !theirsHas) {
+        // Both deleted
+        continue;
+      }
+      if (!oursHas) {
+        // We deleted, they didn't
+        if (deepEqual(baseVal, theirsVal)) {
+          // They didn't change it, our delete wins
+          continue;
+        } else {
+          // They changed it and we deleted - conflict
+          conflicts.push({
+            documentId,
+            path: fieldPath,
+            base: deepClone(baseVal),
+            ours: undefined,
+            theirs: deepClone(theirsVal),
+          });
+          // "ours" wins for merged preview -> key deleted
+          continue;
+        }
+      }
+      if (!theirsHas) {
+        // They deleted, we didn't
+        if (deepEqual(baseVal, oursVal)) {
+          // We didn't change it, their delete wins
+          continue;
+        } else {
+          // We changed it and they deleted - conflict
+          conflicts.push({
+            documentId,
+            path: fieldPath,
+            base: deepClone(baseVal),
+            ours: deepClone(oursVal),
+            theirs: undefined,
+          });
+          // "ours" wins for merged preview
+          result[key] = deepClone(oursVal);
+          continue;
+        }
+      }
+    } else {
+      // Key not in base
+      if (oursHas && !theirsHas) {
+        result[key] = deepClone(oursVal);
+        continue;
+      }
+      if (!oursHas && theirsHas) {
+        result[key] = deepClone(theirsVal);
+        continue;
+      }
+      // Both added - fall through to merge logic below
+    }
+
+    // Both sides have the key - recurse or compare
+    if (isPlainObject(oursVal) && isPlainObject(theirsVal)) {
+      result[key] = mergeRecursive(
+        baseHas ? baseVal : {},
+        oursVal,
+        theirsVal,
+        documentId,
+        fieldPath,
+        conflicts
+      );
+    } else {
+      result[key] = mergeLeaf(
+        baseHas ? baseVal : undefined,
+        oursVal,
+        theirsVal,
+        documentId,
+        fieldPath,
+        conflicts
+      );
+    }
+  }
+
+  return result;
+}
+
+function mergeLeaf(
+  base: JsonValue,
+  ours: JsonValue,
+  theirs: JsonValue,
+  documentId: string,
+  path: string,
+  conflicts: Conflict[]
+): JsonValue {
+  const baseToOurs = !deepEqual(base, ours);
+  const baseToTheirs = !deepEqual(base, theirs);
+
+  if (!baseToOurs && !baseToTheirs) {
+    // No changes
+    return deepClone(base);
+  }
+  if (baseToOurs && !baseToTheirs) {
+    // Only we changed
+    return deepClone(ours);
+  }
+  if (!baseToOurs && baseToTheirs) {
+    // Only they changed
+    return deepClone(theirs);
+  }
+  // Both changed
+  if (deepEqual(ours, theirs)) {
+    // Changed to same value
+    return deepClone(ours);
+  }
+  // Conflict
+  conflicts.push({
+    documentId,
+    path,
+    base: deepClone(base),
+    ours: deepClone(ours),
+    theirs: deepClone(theirs),
+  });
+  // "ours" wins for preview
+  return deepClone(ours);
+}
+
+export function isPlainObject(val: JsonValue): val is Record<string, JsonValue> {
+  return val !== null && typeof val === 'object' && !Array.isArray(val);
+}
+
+export function deepClone<T>(val: T): T {
+  if (val === null || val === undefined || typeof val !== 'object') {
+    return val;
+  }
+  return JSON.parse(JSON.stringify(val));
+}
+
+export function deepEqual(a: JsonValue, b: JsonValue): boolean {
+  if (a === b) return true;
+  if (a === null || b === null) return false;
+  if (a === undefined || b === undefined) return false;
+  if (typeof a !== typeof b) return false;
+  if (typeof a !== 'object') return false;
+
+  if (Array.isArray(a) !== Array.isArray(b)) return false;
+
+  if (Array.isArray(a)) {
+    if (a.length !== b.length) return false;
+    for (let i = 0; i < a.length; i++) {
+      if (!deepEqual(a[i], b[i])) return false;
+    }
+    return true;
+  }
+
+  const keysA = Object.keys(a);
+  const keysB = Object.keys(b);
+  if (keysA.length !== keysB.length) return false;
+  for (const key of keysA) {
+    if (!Object.prototype.hasOwnProperty.call(b, key)) return false;
+    if (!deepEqual(a[key], b[key])) return false;
+  }
+  return true;
+}
