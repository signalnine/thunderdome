diff --git a/src/index.ts b/src/index.ts
new file mode 100644
index 0000000..80b693d
--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,477 @@
+import { threeWayMerge, deepClone, deepEqual, Conflict } from './merge.js';
+
+export type { Conflict };
+
+export interface Version {
+  id: string;
+  timestamp: number;
+  content: object;
+}
+
+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+interface DocumentEntry {
+  content: object;
+  deleted: boolean;
+  versions: Version[];
+}
+
+interface BranchState {
+  documents: Map<string, DocumentEntry>;
+  forkPoint: Map<string, object | null> | null;
+  parent: string | null;
+}
+
+let versionCounter = 0;
+
+function generateVersionId(): string {
+  return `v_${++versionCounter}_${Date.now()}`;
+}
+
+function cloneDocumentMap(docs: Map<string, DocumentEntry>): Map<string, DocumentEntry> {
+  const cloned = new Map<string, DocumentEntry>();
+  for (const [id, entry] of docs) {
+    cloned.set(id, {
+      content: deepClone(entry.content),
+      deleted: entry.deleted,
+      versions: entry.versions.map(v => ({
+        id: v.id,
+        timestamp: v.timestamp,
+        content: deepClone(v.content),
+      })),
+    });
+  }
+  return cloned;
+}
+
+function snapshotDocuments(docs: Map<string, DocumentEntry>): Map<string, object | null> {
+  const snapshot = new Map<string, object | null>();
+  for (const [id, entry] of docs) {
+    if (entry.deleted) {
+      snapshot.set(id, null);
+    } else {
+      snapshot.set(id, deepClone(entry.content));
+    }
+  }
+  return snapshot;
+}
+
+export class DocumentStore {
+  private branches: Map<string, BranchState> = new Map();
+  private currentBranch: string = 'main';
+
+  constructor() {
+    this.branches.set('main', {
+      documents: new Map(),
+      forkPoint: null,
+      parent: null,
+    });
+  }
+
+  create(id: string, content: object): void {
+    const branch = this.getCurrentBranchState();
+    const existing = branch.documents.get(id);
+    if (existing && !existing.deleted) {
+      throw new Error(`Document "${id}" already exists`);
+    }
+
+    const version: Version = {
+      id: generateVersionId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+
+    branch.documents.set(id, {
+      content: deepClone(content),
+      deleted: false,
+      versions: existing ? [...existing.versions, version] : [version],
+    });
+  }
+
+  get(id: string): object {
+    const branch = this.getCurrentBranchState();
+    const entry = branch.documents.get(id);
+    if (!entry || entry.deleted) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    return deepClone(entry.content);
+  }
+
+  update(id: string, content: object): void {
+    const branch = this.getCurrentBranchState();
+    const entry = branch.documents.get(id);
+    if (!entry || entry.deleted) {
+      throw new Error(`Document "${id}" not found`);
+    }
+
+    const version: Version = {
+      id: generateVersionId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+
+    entry.content = deepClone(content);
+    entry.versions.push(version);
+  }
+
+  delete(id: string): void {
+    const branch = this.getCurrentBranchState();
+    const entry = branch.documents.get(id);
+    if (!entry || entry.deleted) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    entry.deleted = true;
+  }
+
+  getHistory(id: string): Version[] {
+    const branch = this.getCurrentBranchState();
+    const entry = branch.documents.get(id);
+    if (!entry) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    return entry.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    }));
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const branch = this.getCurrentBranchState();
+    const entry = branch.documents.get(id);
+    if (!entry) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    const version = entry.versions.find(v => v.id === versionId);
+    if (!version) {
+      throw new Error(`Version "${versionId}" not found for document "${id}"`);
+    }
+    return deepClone(version.content);
+  }
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch "${name}" already exists`);
+    }
+    const sourceName = fromBranch ?? this.currentBranch;
+    const source = this.branches.get(sourceName);
+    if (!source) {
+      throw new Error(`Branch "${sourceName}" not found`);
+    }
+
+    const newBranch: BranchState = {
+      documents: cloneDocumentMap(source.documents),
+      forkPoint: snapshotDocuments(source.documents),
+      parent: sourceName,
+    };
+    this.branches.set(name, newBranch);
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch "${name}" not found`);
+    }
+    this.currentBranch = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranch;
+  }
+
+  listBranches(): string[] {
+    return Array.from(this.branches.keys());
+  }
+
+  merge(sourceBranch: string): MergeResult {
+    const sourceBranchState = this.branches.get(sourceBranch);
+    if (!sourceBranchState) {
+      throw new Error(`Branch "${sourceBranch}" not found`);
+    }
+
+    const targetBranchState = this.getCurrentBranchState();
+    const base = this.findCommonAncestor(sourceBranch, this.currentBranch);
+
+    // Gather all document IDs across base, source, and target
+    const allDocIds = new Set<string>();
+    if (base) {
+      for (const id of base.keys()) {
+        // Only include if the base content was non-null (i.e., doc existed)
+        if (base.get(id) !== null) {
+          allDocIds.add(id);
+        }
+      }
+    }
+    for (const [id, entry] of sourceBranchState.documents) {
+      if (!entry.deleted) allDocIds.add(id);
+      else if (base?.has(id)) allDocIds.add(id); // was in base but deleted on source
+    }
+    for (const [id, entry] of targetBranchState.documents) {
+      if (!entry.deleted) allDocIds.add(id);
+      else if (base?.has(id)) allDocIds.add(id); // was in base but deleted on target
+    }
+
+    const merged: Record<string, object> = {};
+    const allConflicts: Conflict[] = [];
+    let hasChanges = false;
+
+    for (const docId of allDocIds) {
+      const baseSnapshot = base ? base.get(docId) : undefined;
+      // baseContent is undefined if doc didn't exist at fork, or if base is null
+      const baseContent: object | undefined = (baseSnapshot === null || baseSnapshot === undefined) ? undefined : baseSnapshot;
+
+      const sourceEntry = sourceBranchState.documents.get(docId);
+      const targetEntry = targetBranchState.documents.get(docId);
+
+      // Get current content (undefined if doesn't exist or deleted)
+      const sourceContent: object | undefined = (sourceEntry && !sourceEntry.deleted) ? sourceEntry.content : undefined;
+      const targetContent: object | undefined = (targetEntry && !targetEntry.deleted) ? targetEntry.content : undefined;
+
+      const baseExists = baseContent !== undefined;
+      const sourceExists = sourceContent !== undefined;
+      const targetExists = targetContent !== undefined;
+
+      // Check if source or target explicitly deleted a doc that existed in base
+      const sourceDeletedFromBase = baseExists && !sourceExists;
+      const targetDeletedFromBase = baseExists && !targetExists;
+
+      // Case 1: Document doesn't exist anywhere relevant
+      if (!baseExists && !sourceExists && !targetExists) {
+        continue;
+      }
+
+      // Case 2: No base - document is new
+      if (!baseExists) {
+        if (sourceExists && !targetExists) {
+          // New on source only
+          merged[docId] = deepClone(sourceContent!);
+          hasChanges = true;
+          continue;
+        }
+        if (!sourceExists && targetExists) {
+          // New on target only - already there
+          merged[docId] = deepClone(targetContent!);
+          continue;
+        }
+        if (sourceExists && targetExists) {
+          // Both added independently
+          const result = threeWayMerge({}, targetContent!, sourceContent!, docId);
+          merged[docId] = result.merged;
+          allConflicts.push(...result.conflicts);
+          if (!deepEqual(targetContent, result.merged)) hasChanges = true;
+          continue;
+        }
+        continue;
+      }
+
+      // Case 3: Base exists - check for deletions
+      if (sourceDeletedFromBase && targetDeletedFromBase) {
+        // Both deleted - no conflict, stays deleted
+        continue;
+      }
+
+      if (sourceDeletedFromBase) {
+        // Source deleted
+        if (!targetExists) {
+          // Target also doesn't have it (shouldn't really happen if targetDeletedFromBase was false, but just in case)
+          continue;
+        }
+        if (deepEqual(baseContent, targetContent)) {
+          // Target unchanged, accept source deletion
+          hasChanges = true;
+          continue;
+        }
+        // Target modified, source deleted - conflict
+        allConflicts.push({
+          documentId: docId,
+          path: '',
+          base: deepClone(baseContent),
+          ours: deepClone(targetContent),
+          theirs: undefined,
+        });
+        merged[docId] = deepClone(targetContent!);
+        continue;
+      }
+
+      if (targetDeletedFromBase) {
+        // Target deleted
+        if (!sourceExists) {
+          continue;
+        }
+        if (deepEqual(baseContent, sourceContent)) {
+          // Source unchanged, accept target deletion
+          continue;
+        }
+        // Source modified, target deleted - conflict
+        allConflicts.push({
+          documentId: docId,
+          path: '',
+          base: deepClone(baseContent),
+          ours: undefined,
+          theirs: deepClone(sourceContent),
+        });
+        // ours wins -> stays deleted
+        continue;
+      }
+
+      // Case 4: Both still exist - three-way merge contents
+      const sourceChanged = !deepEqual(baseContent, sourceContent);
+      const targetChanged = !deepEqual(baseContent, targetContent);
+
+      if (!sourceChanged && !targetChanged) {
+        // Neither changed - include as-is
+        merged[docId] = deepClone(targetContent!);
+        continue;
+      }
+
+      if (!sourceChanged && targetChanged) {
+        // Only target changed - already reflected in target
+        merged[docId] = deepClone(targetContent!);
+        continue;
+      }
+
+      if (sourceChanged && !targetChanged) {
+        // Only source changed - take source changes
+        merged[docId] = deepClone(sourceContent!);
+        hasChanges = true;
+        continue;
+      }
+
+      // Both changed - do structural merge
+      const result = threeWayMerge(
+        baseContent!,
+        targetContent!,
+        sourceContent!,
+        docId
+      );
+      merged[docId] = result.merged;
+      allConflicts.push(...result.conflicts);
+      if (!deepEqual(targetContent, result.merged)) hasChanges = true;
+    }
+
+    if (allConflicts.length === 0 && hasChanges) {
+      // Auto-apply: update the current branch with the merge results
+      this.applyMergeResults(targetBranchState, merged, base);
+
+      // Update fork point so subsequent merges see the new state
+      if (sourceBranchState.parent === this.currentBranch) {
+        sourceBranchState.forkPoint = snapshotDocuments(targetBranchState.documents);
+      }
+
+      return { merged, conflicts: [], applied: true };
+    }
+
+    if (allConflicts.length === 0 && !hasChanges) {
+      // No-op / fast-forward
+      return { merged, conflicts: [], applied: true };
+    }
+
+    // Has conflicts - don't apply
+    return { merged, conflicts: allConflicts, applied: false };
+  }
+
+  private applyMergeResults(
+    targetBranch: BranchState,
+    merged: Record<string, object>,
+    base: Map<string, object | null> | null
+  ): void {
+    // Apply merged document contents
+    for (const [docId, content] of Object.entries(merged)) {
+      const existingEntry = targetBranch.documents.get(docId);
+      if (existingEntry) {
+        if (!deepEqual(existingEntry.content, content) || existingEntry.deleted) {
+          existingEntry.content = deepClone(content);
+          existingEntry.deleted = false;
+          const version: Version = {
+            id: generateVersionId(),
+            timestamp: Date.now(),
+            content: deepClone(content),
+          };
+          existingEntry.versions.push(version);
+        }
+      } else {
+        const version: Version = {
+          id: generateVersionId(),
+          timestamp: Date.now(),
+          content: deepClone(content),
+        };
+        targetBranch.documents.set(docId, {
+          content: deepClone(content),
+          deleted: false,
+          versions: [version],
+        });
+      }
+    }
+
+    // Apply deletions: docs that were in base but not in merged (accepted deletions)
+    if (base) {
+      for (const [docId, baseContent] of base) {
+        if (baseContent === null) continue; // Was already deleted at base time
+        if (docId in merged) continue; // Doc is in merged result, not deleted
+        const targetEntry = targetBranch.documents.get(docId);
+        if (targetEntry && !targetEntry.deleted) {
+          targetEntry.deleted = true;
+        }
+      }
+    }
+  }
+
+  private getCurrentBranchState(): BranchState {
+    const state = this.branches.get(this.currentBranch);
+    if (!state) {
+      throw new Error(`Current branch "${this.currentBranch}" not found`);
+    }
+    return state;
+  }
+
+  private findCommonAncestor(
+    branchA: string,
+    branchB: string
+  ): Map<string, object | null> | null {
+    const stateA = this.branches.get(branchA)!;
+    const stateB = this.branches.get(branchB)!;
+
+    // If A was forked from B, use A's fork point
+    if (stateA.parent === branchB) {
+      return stateA.forkPoint;
+    }
+    // If B was forked from A, use B's fork point
+    if (stateB.parent === branchA) {
+      return stateB.forkPoint;
+    }
+
+    // Walk parent chains to find common ancestor
+    const ancestorsA = this.getAncestorChain(branchA);
+    const ancestorsB = this.getAncestorChain(branchB);
+
+    for (const ancestor of ancestorsA) {
+      if (ancestorsB.includes(ancestor)) {
+        if (stateA.parent === ancestor) {
+          return stateA.forkPoint;
+        }
+        if (stateB.parent === ancestor) {
+          return stateB.forkPoint;
+        }
+        break;
+      }
+    }
+
+    // Fallback: empty base
+    return new Map();
+  }
+
+  private getAncestorChain(branchName: string): string[] {
+    const chain: string[] = [];
+    let current = branchName;
+    while (current) {
+      chain.push(current);
+      const state = this.branches.get(current);
+      if (!state || !state.parent) break;
+      current = state.parent;
+    }
+    return chain;
+  }
+}
