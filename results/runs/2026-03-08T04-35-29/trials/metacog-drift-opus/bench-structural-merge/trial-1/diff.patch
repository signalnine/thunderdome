ch \"${this.currentBranch}\" not found`);\n   400→    }\n   401→    return state;\n   402→  }\n   403→\n   404→  private findCommonAncestor(\n   405→    branchA: string,\n   406→    branchB: string\n   407→  ): Map<string, object | null> | null {\n   408→    const stateA = this.branches.get(branchA)!;\n   409→    const stateB = this.branches.get(branchB)!;\n   410→\n   411→    // If A was forked from B, use A's fork point\n   412→    if (stateA.parent === branchB) {\n   413→      return stateA.forkPoint;\n   414→    }\n   415→    // If B was forked from A, use B's fork point\n   416→    if (stateB.parent === branchA) {\n   417→      return stateB.forkPoint;\n   418→    }\n   419→    // If both share a common parent, we need to walk up\n   420→    // For simplicity, try to find a common ancestor by walking parent chains\n   421→    const ancestorsA = this.getAncestorChain(branchA);\n   422→    const ancestorsB = this.getAncestorChain(branchB);\n   423→\n   424→    for (const ancestor of ancestorsA) {\n   425→      if (ancestorsB.includes(ancestor)) {\n   426→        // Found common ancestor, but we need the fork point\n   427→        // Use the fork point of whichever branch is closer\n   428→        if (stateA.parent === ancestor) {\n   429→          return stateA.forkPoint;\n   430→        }\n   431→        if (stateB.parent === ancestor) {\n   432→          return stateB.forkPoint;\n   433→        }\n   434→        break;\n   435→      }\n   436→    }\n   437→\n   438→    // Fallback: empty base (treat as independent)\n   439→    return new Map();\n   440→  }\n   441→\n   442→  private getAncestorChain(branchName: string): string[] {\n   443→    const chain: string[] = [];\n   444→    let current = branchName;\n   445→    while (current) {\n   446→      chain.push(current);\n   447→      const state = this.branches.get(current);\n   448→      if (!state || !state.parent) break;\n   449→      current = state.parent;\n   450→    }\n   451→    return chain;\n   452→  }\n   453→}\n   454→"}]},"parent_tool_use_id":null,"session_id":"190d319b-6a31-462e-9043-953eb9617a7b","uuid":"31b81c7c-db80-49b1-8662-50654589243a","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/index.ts","content":"import { threeWayMerge, deepClone, deepEqual, Conflict } from './merge.js';\n\nexport type { Conflict };\n\nexport interface Version {\n  id: string;\n  timestamp: number;\n  content: object;\n}\n\nexport interface MergeResult {\n  merged: Record<string, object>;\n  conflicts: Conflict[];\n  applied: boolean;\n}\n\ninterface DocumentEntry {\n  content: object;\n  deleted: boolean;\n  versions: Version[];\n}\n\ninterface BranchState {\n  documents: Map<string, DocumentEntry>;\n  /** Snapshot of the parent branch's documents at the time this branch was created */\n  forkPoint: Map<string, object | null> | null;\n  /** The branch this was forked from */\n  parent: string | null;\n}\n\nlet versionCounter = 0;\n\nfunction generateVersionId(): string {\n  return `v_${++versionCounter}_${Date.now()}`;\n}\n\nfunction cloneDocumentMap(docs: Map<string, DocumentEntry>): Map<string, DocumentEntry> {\n  const cloned = new Map<string, DocumentEntry>();\n  for (const [id, entry] of docs) {\n    cloned.set(id, {\n      content: deepClone(entry.content),\n      deleted: entry.deleted,\n      versions: entry.versions.map(v => ({\n        id: v.id,\n        timestamp: v.timestamp,\n        content: deepClone(v.content),\n      })),\n    });\n  }\n  return cloned;\n}\n\nfunction snapshotDocuments(docs: Map<string, DocumentEntry>): Map<string, object | null> {\n  const snapshot = new Map<string, object | null>();\n  for (const [id, entry] of docs) {\n    if (entry.deleted) {\n      snapshot.set(id, null);\n    } else {\n      snapshot.set(id, deepClone(entry.content));\n    }\n  }\n  return snapshot;\n}\n\nexport class DocumentStore {\n  private branches: Map<string, BranchState> = new Map();\n  private currentBranch: string = 'main';\n\n  constructor() {\n    this.branches.set('main', {\n      documents: new Map(),\n      forkPoint: null,\n      parent: null,\n    });\n  }\n\n  // --- Document CRUD ---\n\n  create(id: string, content: object): void {\n    const branch = this.getCurrentBranchState();\n    const existing = branch.documents.get(id);\n    if (existing && !existing.deleted) {\n      throw new Error(`Document \"${id}\" already exists`);\n    }\n\n    const version: Version = {\n      id: generateVersionId(),\n      timestamp: Date.now(),\n      content: deepClone(content),\n    };\n\n    branch.documents.set(id, {\n      content: deepClone(content),\n      deleted: false,\n      versions: existing ? [...existing.versions, version] : [version],\n    });\n  }\n\n  get(id: string): object {\n    const branch = this.getCurrentBranchState();\n    const entry = branch.documents.get(id);\n    if (!entry || entry.deleted) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    return deepClone(entry.content);\n  }\n\n  update(id: string, content: object): void {\n    const branch = this.getCurrentBranchState();\n    const entry = branch.documents.get(id);\n    if (!entry || entry.deleted) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n\n    const version: Version = {\n      id: generateVersionId(),\n      timestamp: Date.now(),\n      content: deepClone(content),\n    };\n\n    entry.content = deepClone(content);\n    entry.versions.push(version);\n  }\n\n  delete(id: string): void {\n    const branch = this.getCurrentBranchState();\n    const entry = branch.documents.get(id);\n    if (!entry || entry.deleted) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    entry.deleted = true;\n  }\n\n  // --- Version History ---\n\n  getHistory(id: string): Version[] {\n    const branch = this.getCurrentBranchState();\n    const entry = branch.documents.get(id);\n    if (!entry) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    return entry.version