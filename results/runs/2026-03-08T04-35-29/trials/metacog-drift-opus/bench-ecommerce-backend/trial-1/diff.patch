();\n    const statusEvent = log.find(e => e.event === Events.ORDER_STATUS_CHANGED);\n    expect(statusEvent).toBeTruthy();\n    const payload = statusEvent!.payload as { orderId: string; status: string; previousStatus: string };\n    expect(payload.previousStatus).toBe(OrderStatus.PENDING);\n    expect(payload.status).toBe(OrderStatus.CONFIRMED);\n  });\n\n  it('should list orders for a user', () => {\n    orders.createOrder('user1', 'cart1', 50);\n    orders.createOrder('user1', 'cart2', 75);\n    orders.createOrder('user2', 'cart3', 100);\n    expect(orders.listOrders('user1')).toHaveLength(2);\n    expect(orders.listOrders('user2')).toHaveLength(1);\n  });\n\n  it('should return null for non-existent order', () => {\n    expect(orders.getOrder('fake')).toBeNull();\n  });\n});\n\ndescribe('Payment Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should process a successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 99.99);\n    expect(result.status).toBe(PaymentStatus.SUCCESS);\n    expect(result.transactionId).toBeTruthy();\n  });\n\n  it('should simulate failure', async () => {\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const result = await payment.processPayment('order1', 99.99);\n    expect(result.status).toBe(PaymentStatus.FAILED);\n    expect(result.error).toBeTruthy();\n  });\n\n  it('should simulate timeout', async () => {\n    const payment = createPaymentService(bus, { simulateTimeout: true });\n    const result = await payment.processPayment('order1', 99.99);\n    expect(result.status).toBe(PaymentStatus.TIMEOUT);\n  });\n\n  it('should refund a successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 99.99);\n    const refunded = await payment.refund(result.transactionId!);\n    expect(refunded).toBe(true);\n  });\n\n  it('should fail to refund a non-existent transaction', async () => {\n    const payment = createPaymentService(bus);\n    const refunded = await payment.refund('fake');\n    expect(refunded).toBe(false);\n  });\n\n  it('should emit PAYMENT_PROCESSED event', async () => {\n    const payment = createPaymentService(bus);\n    await payment.processPayment('order1', 99.99);\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.PAYMENT_PROCESSED)).toBe(true);\n  });\n});\n\ndescribe('Notification Service', () => {\n  let bus: EventBus;\n  let notifications: ReturnType<typeof createNotificationService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    notifications = createNotificationService(bus);\n  });\n\n  it('should send notifications to subscribed users on order creation', async () => {\n    notifications.subscribe('user1');\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThan(0);\n    expect(notifs[0].type).toBe('order_created');\n  });\n\n  it('should not send notifications to unsubscribed users', async () => {\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user2', cartId: 'c1', total: 100 });\n    expect(notifications.getNotifications('user2')).toHaveLength(0);\n  });\n\n  it('should send notifications on order status change', async () => {\n    notifications.subscribe('user1');\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.ORDER_STATUS_CHANGED, { orderId: 'o1', status: 'confirmed', previousStatus: 'pending' });\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.some(n => n.type === 'order_status')).toBe(true);\n  });\n\n  it('should send notifications on payment', async () => {\n    notifications.subscribe('user1');\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: 'success', transactionId: 'tx1' });\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.some(n => n.type === 'payment')).toBe(true);\n  });\n});\n\ndescribe('Analytics Service', () => {\n  let bus: EventBus;\n  let analytics: ReturnType<typeof createAnalyticsService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    analytics = createAnalyticsService(bus);\n  });\n\n  it('should count events by type', async () => {\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'Widget', price: 10, category: 'test' });\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p2', name: 'Gadget', price: 20, category: 'test' });\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n  });\n\n  it('should track revenue from successful payments', async () => {\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 'tx1' });\n    expect(analytics.getRevenue()).toBe(100);\n  });\n\n  it('should not count revenue from failed payments', async () => {\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.FAILED, error: 'failed' });\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  it('should calculate conversion rate', async () => {\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [] });\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c2', userId: 'u2', items: [] });\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 50 });\n    expect(analytics.getConversionRate()).toBe(0.5);\n  });\n\n  it('should return 0 conversion rate with no carts', () => {\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n\n  it('should track top products', async () => {\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [{ productId: 'p1', quantity: 5 }, { productId: 'p2', quantity: 2 }] });\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    const top = analytics.getTopProducts(10);\n    expect(top[0].productId).toBe('p1');\n    expect(top[0].count).toBe(5);\n    expect(top[1].productId).toBe('p2');\n    expect(top[1].count).toBe(2);\n  });\n});\n\ndescribe('Integration: Full order flow', () => {\n  it('should handle a full order lifecycle', async () => {\n    const bus = new EventBus();\n\n    const catalog = createCatalogService(bus);\n    const inventory = createInventoryService(bus);\n    const cartService = createCartService(bus);\n    const pricing = createPricingService(bus);\n    const orderService = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    const notificationService = createNotificationService(bus);\n    const analytics = createAnalyticsService(bus);\n\n    // Subscribe user for notifications\n    notificationService.subscribe('user1');\n\n    // Create products\n    const p1 = catalog.createProduct('Laptop', 999.99, 'electronics');\n    const p2 = catalog.createProduct('Mouse', 29.99, 'electronics');\n\n    // Set inventory\n    inventory.setStock(p1, 10);\n    inventory.setStock(p2, 50);\n\n    // Create cart and add items\n    const cartId = cartService.createCart('user1');\n    cartService.addItem(cartId, p1, 1);\n    cartService.addItem(cartId, p2, 2);\n\n    // Calculate price\n    const cart = cartService.getCart(cartId)!;\n    const items = cart.items.map(i => ({\n      productId: i.productId,\n      quantity: i.quantity,\n      price: pricing.getPrice(i.productId),\n    }));\n    const total = pricing.calculateTotal(items);\n\n    expect(total.subtotal).toBeCloseTo(1059.97, 2);\n    expect(total.tax).toBeCloseTo(105.997, 1);\n\n    // Create order\n    const orderId = orderService.createOrder('user1', cartId, total.total);\n\n    // Reserve inventory\n    expect(inventory.reserve(p1, 1)).toBe(true);\n    expect(inventory.reserve(p2, 2)).toBe(true);\n\n    // Process payment\n    const payResult = await payment.processPayment(orderId, total.total);\n    expect(payResult.status).toBe(PaymentStatus.SUCCESS);\n\n    // Update order status\n    orderService.updateStatus(orderId, OrderStatus.CONFIRMED);\n    orderService.updateStatus(orderId, OrderStatus.SHIPPED);\n    orderService.updateStatus(orderId, OrderStatus.DELIVERED);\n\n    // Verify final state\n    const order = orderService.getOrder(orderId);\n    expect(order!.status).toBe(OrderStatus.DELIVERED);\n\n    // Check notifications\n    const notifs = notificationService.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThan(0);\n\n    // Check analytics\n    expect(analytics.getRevenue()).toBeCloseTo(total.total, 2);\n    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBe(1);\n    expect(analytics.getConversionRate()).toBeGreaterThan(0);\n  });\n});\n","structuredPatch":[],"originalFile":null}}
