nc () => {\n    const res = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Test Doc', content: 'Hello' }),\n    });\n    expect(res.status).toBe(201);\n    const body = await res.json();\n    expect(body).toHaveProperty('id');\n    expect(body.title).toBe('Test Doc');\n    expect(body.content).toBe('Hello');\n  });\n\n  it('should reject creating a document without title', async () => {\n    const res = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ content: 'No title' }),\n    });\n    expect(res.status).toBe(400);\n  });\n\n  it('should list documents', async () => {\n    const res = await fetch(`${baseUrl}/api/documents`);\n    expect(res.status).toBe(200);\n    const body = await res.json();\n    expect(Array.isArray(body)).toBe(true);\n    expect(body.length).toBeGreaterThan(0);\n  });\n\n  it('should get a specific document', async () => {\n    const doc = await createDoc('Get Test');\n    const res = await fetch(`${baseUrl}/api/documents/${doc.id}`);\n    expect(res.status).toBe(200);\n    const body = await res.json();\n    expect(body.title).toBe('Get Test');\n  });\n\n  it('should return 404 for missing document', async () => {\n    const res = await fetch(`${baseUrl}/api/documents/nonexistent-id`);\n    expect(res.status).toBe(404);\n  });\n\n  it('should update a document', async () => {\n    const doc = await createDoc('Update Test', 'original');\n    const res = await fetch(`${baseUrl}/api/documents/${doc.id}`, {\n      method: 'PUT',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Updated Title', content: 'updated content' }),\n    });\n    expect(res.status).toBe(200);\n    const body = await res.json();\n    expect(body.title).toBe('Updated Title');\n    expect(body.content).toBe('updated content');\n  });\n\n  it('should delete a document', async () => {\n    const doc = await createDoc('Delete Test');\n    const delRes = await fetch(`${baseUrl}/api/documents/${doc.id}`, { method: 'DELETE' });\n    expect(delRes.status).toBe(204);\n    const getRes = await fetch(`${baseUrl}/api/documents/${doc.id}`);\n    expect(getRes.status).toBe(404);\n  });\n\n  it('should get version history', async () => {\n    const doc = await createDoc('Version Test', 'v1');\n    const res = await fetch(`${baseUrl}/api/documents/${doc.id}/versions`);\n    expect(res.status).toBe(200);\n    const body = await res.json();\n    expect(Array.isArray(body)).toBe(true);\n    expect(body.length).toBe(1);\n    expect(body[0].version).toBe(1);\n    expect(body[0].content).toBe('v1');\n  });\n});\n\ndescribe('WebSocket Collaboration', () => {\n  beforeAll(setup);\n  afterAll(teardown);\n\n  afterEach(() => {\n    // Close all opened sockets after each test\n    for (const ws of openSockets) {\n      if (ws.readyState === WebSocket.OPEN || ws.readyState === WebSocket.CONNECTING) {\n        ws.close();\n      }\n    }\n    openSockets.length = 0;\n  });\n\n  it('should receive sync message on connect', async () => {\n    const doc = await createDoc('WS Test', 'hello');\n    const ws = await connectWs(doc.id);\n    const msg = await waitForMessage<{ type: string; content: string; version: number }>(ws);\n    expect(msg.type).toBe('sync');\n    expect(msg.content).toBe('hello');\n    expect(msg.version).toBe(1);\n    ws.close();\n  });\n\n  it('should apply an operation and receive ack', async () => {\n    const doc = await createDoc('WS Test', 'hello');\n    const ws = await connectWs(doc.id);\n    await waitForMessage(ws); // sync\n\n    const ackPromise = waitForMessage<{ type: string; version: number }>(ws);\n    sendOp(ws, 1, [5, ' world']);\n    const ack = await ackPromise;\n    expect(ack.type).toBe('ack');\n    expect(ack.version).toBe(2);\n\n    // Verify via REST\n    const updatedDoc = await getDoc(doc.id);\n    expect(updatedDoc.content).toBe('hello world');\n\n    ws.close();\n  });\n\n  it('should broadcast operations to other clients', async () => {\n    const doc = await createDoc('WS Test', 'hello');\n    const ws1 = await connectWs(doc.id);\n    const ws2 = await connectWs(doc.id);\n\n    await waitForMessage(ws1); // sync\n    await waitForMessage(ws2); // sync\n\n    const broadcastPromise = waitForMessage<{\n      type: string;\n      operation: unknown[];\n      version: number;\n    }>(ws2);\n    sendOp(ws1, 1, [5, ' world']);\n    const broadcast = await broadcastPromise;\n\n    expect(broadcast.type).toBe('operation');\n    expect(broadcast.version).toBe(2);\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should handle concurrent operations with OT', async () => {\n    const doc = await createDoc('WS Test', 'hello');\n    const ws1 = await connectWs(doc.id);\n    const ws2 = await connectWs(doc.id);\n\n    await waitForMessage(ws1); // sync\n    await waitForMessage(ws2); // sync\n\n    // Client 1: insert \" world\" at end based on version 1\n    const ack1Promise = waitForMessage<{ type: string; version: number }>(ws1);\n    sendOp(ws1, 1, [5, ' world']);\n    await ack1Promise;\n\n    // Client 2 receives the broadcast from client 1\n    const msg2 = await waitForMessage<{ type: string }>(ws2);\n    expect(msg2.type).toBe('operation');\n\n    // Client 2 sends op based on version 1 (before seeing server version 2)\n    // Server should transform it\n    const ack2Promise = waitForMessage<{ type: string; version: number }>(ws2);\n    sendOp(ws2, 1, ['Hi ', 5]);\n    const ack2 = await ack2Promise;\n    expect(ack2.type).toBe('ack');\n\n    // Verify final state via REST\n    const updatedDoc = await getDoc(doc.id);\n    expect(updatedDoc.content).toContain('Hi ');\n    expect(updatedDoc.content).toContain(' world');\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should handle error for invalid operation', async () => {\n    const doc = await createDoc('WS Test', 'hello');\n    const ws = await connectWs(doc.id);\n    await waitForMessage(ws); // sync\n\n    const errorPromise = waitForMessage<{ type: string; message: string }>(ws);\n    sendOp(ws, 1, [100]); // retain 100 chars on a 5-char doc\n    const error = await errorPromise;\n    expect(error.type).toBe('error');\n\n    ws.close();\n  });\n\n  it('should handle error for invalid message format', async () => {\n    const doc = await createDoc('WS Test', 'hello');\n    const ws = await connectWs(doc.id);\n    await waitForMessage(ws); // sync\n\n    const errorPromise = waitForMessage<{ type: string; message: string }>(ws);\n    ws.send('not json!!!');\n    const error = await errorPromise;\n    expect(error.type).toBe('error');\n\n    ws.close();\n  });\n\n  it('should handle error for invalid version', async () => {\n    const doc = await createDoc('WS Test', 'hello');\n    const ws = await connectWs(doc.id);\n    await waitForMessage(ws); // sync\n\n    const errorPromise = waitForMessage<{ type: string; message: string }>(ws);\n    sendOp(ws, 999, [5]); // version way too high\n    const error = await errorPromise;\n    expect(error.type).toBe('error');\n\n    ws.close();\n  });\n});\n\ndescribe('Concurrent clients stress test', () => {\n  beforeAll(setup);\n  afterAll(teardown);\n\n  afterEach(() => {\n    for (const ws of openSockets) {\n      if (ws.readyState === WebSocket.OPEN || ws.readyState === WebSocket.CONNECTING) {\n        ws.close();\n      }\n    }\n    openSockets.length = 0;\n  });\n\n  it('should handle 10 concurrent clients without corruption', async () => {\n    const doc = await createDoc('Stress Test', '');\n    const docId = doc.id;\n\n    const clientCount = 10;\n    const clients: WebSocket[] = [];\n\n    // Connect all clients\n    for (let i = 0; i < clientCount; i++) {\n      const ws = await connectWs(docId);\n      await waitForMessage(ws); // sync\n      clients.push(ws);\n    }\n\n    // Each client inserts a unique character, one at a time sequentially\n    for (let i = 0; i < clientCount; i++) {\n      const ws = clients[i];\n      const char = String.fromCharCode(65 + i); // A, B, C, ...\n\n      const updatedDoc = await getDoc(docId);\n      const currentContent = updatedDoc.content;\n\n      const versionsRes = await fetch(`${baseUrl}/api/documents/${docId}/versions`);\n      const versions = await versionsRes.json() as Array<{ version: number }>;\n      const currentVersion = versions[versions.length - 1].version;\n\n      const op = currentContent.length > 0\n        ? [currentContent.length, char]\n        : [char];\n\n      // Drain any pending messages\n      await drainMessages(ws, 50);\n\n      const ackPromise = waitForMessage<{ type: string; version: number }>(ws);\n      sendOp(ws, currentVersion, op);\n      const ack = await ackPromise;\n      expect(ack.type).toBe('ack');\n    }\n\n    // Verify final document contains all characters\n    const finalDoc = await getDoc(docId);\n    for (let i = 0; i < clientCount; i++) {\n      const char = String.fromCharCode(65 + i);\n      expect(finalDoc.content).toContain(char);\n    }\n    expect(finalDoc.content.length).toBe(clientCount);\n\n    for (const ws of clients) {\n      ws.close();\n    }\n  }, 30000);\n});\n\ndescribe('Persistence', () => {\n  it('should persist documents across server restarts', async () => {\n    const tmpPath = `/tmp/test-collab-${Date.now()}.db`;\n\n    const app1 = createApp(tmpPath);\n    const port1 = await app1.start(0);\n\n    const res = await fetch(`http://localhost:${port1}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Persist Test', content: 'persistent data' }),\n    });\n    const doc = await res.json();\n\n    await app1.stop();\n\n    const app2 = createApp(tmpPath);\n    const port2 = await app2.start(0);\n\n    const res2 = await fetch(`http://localhost:${port2}/api/documents/${doc.id}`);\n    expect(res2.status).toBe(200);\n    const body2 = await res2.json();\n    expect(body2.title).toBe('Persist Test');\n    expect(body2.content).toBe('persistent data');\n\n    await app2.stop();\n  });\n});\n\nfunction drainMessages(ws: WebSocket, timeout: number): Promise<void> {\n  return new Promise((resolve) => {\n    const timer = setTimeout(resolve, timeout);\n    const handler = () => {\n      clearTimeout(timer);\n      setTimeout(resolve, timeout);\n    };\n    ws.on('message', handler);\n    setTimeout(() => {\n      ws.removeListener('message', handler);\n      resolve();\n    }, timeout);\n  });\n}\n","structuredPatch":[{"oldStart":1,"oldLines":25,"newStart":1,"newLines":35,"lines":["-import { describe, it, expect, beforeAll, afterAll, beforeEach } from 'vitest';","-import request from 'supertest';","+import { describe, it, expect, afterAll, afterEach } from 'vitest';"," import WebSocket from 'ws';"," import { createApp, type AppInstance } from './server.js';"," "," let appInstance: AppInstance;"," let port: number;"," let baseUrl: string;","+const openSockets: WebSocket[] = [];"," ","-beforeAll(async () => {","-  appInstance = createApp(); // in-memory database","+async function setup() {","+  appInstance = createApp();","   port = await appInstance.start(0);","   baseUrl = `http://localhost:${port}`;","-});","+}"," ","-afterAll(async () => {","+async function teardown() {","+  // Close all tracked sockets first","+  for (const ws of openSockets) {","+    if (ws.readyState === WebSocket.OPEN || ws.readyState === WebSocket.CONNECTING) {","+      ws.close();","+    }","+  }","+  openSockets.length = 0;","+  // Wait for close events to propagate","+  await new Promise((r) => setTimeout(r, 100));","   await appInstance.stop();","-});","+}"," "," function connectWs(docId: string): Promise<WebSocket> {","   return new Promise((resolve, reject) => {","     const ws = new WebSocket(`ws://localhost:${port}/documents/${doc