+++ b/src/ot.ts
@@ -0,0 +1,400 @@
+/**
+ * Operational Transform (OT) engine for collaborative text editing.
+ *
+ * Operations are arrays of components:
+ * - number > 0: retain N characters
+ * - string: insert text
+ * - number < 0: delete |N| characters
+ *
+ * The sum of retained + deleted characters in an op must equal the document length
+ * it is applied to (the "input length"). After applying, the document length changes
+ * by the sum of inserted characters minus deleted characters.
+ */
+
+export type OpComponent = number | string;
+export type Operation = OpComponent[];
+
+export interface OperationMessage {
+  type: 'operation';
+  docId: string;
+  clientId: string;
+  version: number; // the version the client's op was based on
+  operation: Operation;
+}
+
+export interface SyncMessage {
+  type: 'sync';
+  docId: string;
+  content: string;
+  version: number;
+}
+
+export interface AckMessage {
+  type: 'ack';
+  version: number;
+}
+
+export interface ErrorMessage {
+  type: 'error';
+  message: string;
+}
+
+export interface BroadcastMessage {
+  type: 'operation';
+  clientId: string;
+  version: number;
+  operation: Operation;
+}
+
+export type ServerMessage = SyncMessage | AckMessage | ErrorMessage | BroadcastMessage;
+
+/** Calculate the input length an operation expects */
+export function inputLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) len += c;
+      else len += Math.abs(c);
+    }
+    // strings (inserts) don't consume input characters
+  }
+  return len;
+}
+
+/** Calculate the output length after applying an operation */
+export function outputLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) len += c; // retain
+      // negative (delete) produces no output
+    } else {
+      len += c.length; // insert
+    }
+  }
+  return len;
+}
+
+/** Normalize an operation by merging adjacent same-type components and removing no-ops */
+function normalize(op: Operation): Operation {
+  const result: Operation = [];
+  for (const c of op) {
+    if (typeof c === 'number' && c === 0) continue;
+    if (typeof c === 'string' && c === '') continue;
+
+    if (result.length === 0) {
+      result.push(c);
+      continue;
+    }
+
+    const last = result[result.length - 1];
+    if (typeof c === 'number' && typeof last === 'number') {
+      // Both are numbers: merge if same sign
+      if ((c > 0 && last > 0) || (c < 0 && last < 0)) {
+        result[result.length - 1] = last + c;
+      } else {
+        result.push(c);
+      }
+    } else if (typeof c === 'string' && typeof last === 'string') {
+      result[result.length - 1] = last + c;
+    } else {
+      result.push(c);
+    }
+  }
+  return result;
+}
+
+/** Apply an operation to a document string */
+export function apply(doc: string, op: Operation): string {
+  const expectedLen = inputLength(op);
+  if (expectedLen !== doc.length) {
+    throw new Error(
+      `Operation input length (${expectedLen}) does not match document length (${doc.length})`
+    );
+  }
+
+  let result = '';
+  let pos = 0;
+
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) {
+        // retain
+        result += doc.slice(pos, pos + c);
+        pos += c;
+      } else {
+        // delete
+        pos += Math.abs(c);
+      }
+    } else {
+      // insert
+      result += c;
+    }
+  }
+
+  return result;
+}
+
+/**
+ * Transform two concurrent operations so they can be applied in sequence.
+ *
+ * Given operations A and B that were both based on the same document state,
+ * produce A' and B' such that:
+ *   apply(apply(doc, A), B') === apply(apply(doc, B), A')
+ *
+ * Returns [aPrime, bPrime].
+ */
+export function transform(opA: Operation, opB: Operation): [Operation, Operation] {
+  const aPrime: Operation = [];
+  const bPrime: Operation = [];
+
+  // We iterate through both operations simultaneously using iterators
+  const iterA = new OpIterator(opA);
+  const iterB = new OpIterator(opB);
+
+  while (iterA.hasNext() || iterB.hasNext()) {
+    // Insert in A goes first (convention: left insert wins priority)
+    if (iterA.peekType() === 'insert') {
+      const ins = iterA.next() as string;
+      aPrime.push(ins);
+      bPrime.push(ins.length); // B' must retain A's insert
+      continue;
+    }
+
+    // Insert in B
+    if (iterB.peekType() === 'insert') {
+      const ins = iterB.next() as string;
+      bPrime.push(ins);
+      aPrime.push(ins.length); // A' must retain B's insert
+      continue;
+    }
+
+    // Both retain
+    if (iterA.peekType() === 'retain' && iterB.peekType() === 'retain') {
+      const lenA = iterA.peekLength();
+      const lenB = iterB.peekLength();
+      const minLen = Math.min(lenA, lenB);
+      iterA.next(minLen);
+      iterB.next(minLen);
+      aPrime.push(minLen);
+      bPrime.push(minLen);
+      continue;
+    }
+
+    // A deletes, B retains
+    if (iterA.peekType() === 'delete' && iterB.peekType() === 'retain') {
+      const lenA = Math.abs(iterA.peekLength());
+      const lenB = iterB.peekLength();
+      const minLen = Math.min(lenA, lenB);
+      iterA.next(minLen);
+      iterB.next(minLen);
+      aPrime.push(-minLen);
+      // B' doesn't need to do anything for deleted characters
+      continue;
+    }
+
+    // A retains, B deletes
+    if (iterA.peekType() === 'retain' && iterB.peekType() === 'delete') {
+      const lenA = iterA.peekLength();
+      const lenB = Math.abs(iterB.peekLength());
+      const minLen = Math.min(lenA, lenB);
+      iterA.next(minLen);
+      iterB.next(minLen);
+      bPrime.push(-minLen);
+      // A' doesn't need to do anything for deleted characters
+      continue;
+    }
+
+    // Both delete the same characters
+    if (iterA.peekType() === 'delete' && iterB.peekType() === 'delete') {
+      const lenA = Math.abs(iterA.peekLength());
+      const lenB = Math.abs(iterB.peekLength());
+      const minLen = Math.min(lenA, lenB);
+      iterA.next(minLen);
+      iterB.next(minLen);
+      // Both delete the same text, so neither A' nor B' needs to do anything
+      continue;
+    }
+
+    // If we reach here, both iterators are done
+    if (!iterA.hasNext() && !iterB.hasNext()) break;
+
+    throw new Error('Transform failed: mismatched operation lengths');
+  }
+
+  return [normalize(aPrime), normalize(bPrime)];
+}
+
+/** Compose two sequential operations into one */
+export function compose(opA: Operation, opB: Operation): Operation {
+  if (outputLength(opA) !== inputLength(opB)) {
+    throw new Error(
+      `Compose: outputLength(A)=${outputLength(opA)} !== inputLength(B)=${inputLength(opB)}`
+    );
+  }
+
+  const result: Operation = [];
+  const iterA = new OpIterator(opA);
+  const iterB = new OpIterator(opB);
+
+  while (iterA.hasNext() || iterB.hasNext()) {
+    // Delete in A
+    if (iterA.peekType() === 'delete') {
+      const comp = iterA.next();
+      result.push(comp);
+      continue;
+    }
+
+    // Insert in B
+    if (iterB.peekType() === 'insert') {
+      const comp = iterB.next();
+      result.push(comp);
+      continue;
+    }
+
+    // Retain in A, retain in B
+    if (iterA.peekType() === 'retain' && iterB.peekType() === 'retain') {
+      const lenA = iterA.peekLength();
+      const lenB = iterB.peekLength();
+      const minLen = Math.min(lenA, lenB);
+      iterA.next(minLen);
+      iterB.next(minLen);
+      result.push(minLen);
+      continue;
+    }
+
+    // Insert in A, retain in B
+    if (iterA.peekType() === 'insert' && iterB.peekType() === 'retain') {
+      const lenA = (iterA.peek() as string).length;
+      const lenB = iterB.peekLength();
+      const minLen = Math.min(lenA, lenB);
+      const str = (iterA.next(minLen) as string);
+      iterB.next(minLen);
+      result.push(str);
+      continue;
+    }
+
+    // Insert in A, delete in B
+    if (iterA.peekType() === 'insert' && iterB.peekType() === 'delete') {
+      const lenA = (iterA.peek() as string).length;
+      const lenB = Math.abs(iterB.peekLength());
+      const minLen = Math.min(lenA, lenB);
+      iterA.next(minLen);
+      iterB.next(minLen);
+      // Cancel out: insert then delete = nothing
+      continue;
+    }
+
+    // Retain in A, delete in B
+    if (iterA.peekType() === 'retain' && iterB.peekType() === 'delete') {
+      const lenA = iterA.peekLength();
+      const lenB = Math.abs(iterB.peekLength());
+      const minLen = Math.min(lenA, lenB);
+      iterA.next(minLen);
+      iterB.next(minLen);
+      result.push(-minLen);
+      continue;
+    }
+
+    if (!iterA.hasNext() && !iterB.hasNext()) break;
+    throw new Error('Compose failed: mismatched operations');
+  }
+
+  return normalize(result);
+}
+
+/** Validate that an operation is well-formed for a given document length */
+export function validate(op: Operation, docLength: number): string | null {
+  if (!Array.isArray(op)) return 'Operation must be an array';
+
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (!Number.isInteger(c)) return 'Numeric components must be integers';
+      if (c === 0) return 'Zero-length components are not allowed';
+    } else if (typeof c === 'string') {
+      if (c.length === 0) return 'Empty string inserts are not allowed';
+    } else {
+      return `Invalid component type: ${typeof c}`;
+    }
+  }
+
+  const inLen = inputLength(op);
+  if (inLen !== docLength) {
+    return `Operation input length (${inLen}) does not match document length (${docLength})`;
+  }
+
+  return null;
+}
+
+type ComponentType = 'retain' | 'insert' | 'delete' | 'none';
+
+class OpIterator {
+  private ops: Operation;
+  private index: number;
+  private offset: number;
+
+  constructor(ops: Operation) {
+    this.ops = ops;
+    this.index = 0;
+    this.offset = 0;
+  }
+
+  hasNext(): boolean {
+    return this.index < this.ops.length;
+  }
+
+  peek(): OpComponent | null {
+    if (!this.hasNext()) return null;
+    const c = this.ops[this.index];
+    if (typeof c === 'string') {
+      return this.offset > 0 ? c.slice(this.offset) : c;
+    }
+    if (c > 0) return c - this.offset;
+    return -(Math.abs(c) - this.offset);
+  }
+
+  peekType(): ComponentType {
+    if (!this.hasNext()) return 'none';
+    const c = this.ops[this.index];
+    if (typeof c === 'string') return 'insert';
+    if (c > 0) return 'retain';
+    return 'delete';
+  }
+
+  peekLength(): number {
+    if (!this.hasNext()) return Infinity;
+    const c = this.ops[this.index];
+    if (typeof c === 'string') return c.length - this.offset;
+    return Math.abs(c) - this.offset;
+  }
+
+  /** Consume up to `length` from the current component */
+  next(length?: number): OpComponent {
+    if (!this.hasNext()) throw new Error('Iterator exhausted');
+
+    const c = this.ops[this.index];
+
+    if (typeof c === 'string') {
+      const remaining = c.length - this.offset;
+      const take = length !== undefined ? Math.min(length, remaining) : remaining;
+      const result = c.slice(this.offset, this.offset + take);
+      this.offset += take;
+      if (this.offset >= c.length) {
+        this.index++;
+        this.offset = 0;
+      }
+      return result;
+    }
+
+    // Numeric component (retain or delete)
+    const absVal = Math.abs(c);
+    const remaining = absVal - this.offset;
+    const take = length !== undefined ? Math.min(length, remaining) : remaining;
+    this.offset += take;
+    if (this.offset >= absVal) {
+      this.index++;
+      this.offset = 0;
+    }
+    return c > 0 ? take : -take;
+  }
+}
