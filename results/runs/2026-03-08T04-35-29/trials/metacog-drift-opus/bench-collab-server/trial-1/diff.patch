   socket.destroy();\n        return;\n      }\n\n      this.wss.handleUpgrade(request, socket, head, (ws) => {\n        this.handleConnection(ws, docId);\n      });\n    });\n  }\n\n  private getDocumentState(docId: string): DocumentState {\n    let state = this.documents.get(docId);\n    if (!state) {\n      const doc = this.db.getDocument(docId);\n      if (!doc) throw new Error(`Document ${docId} not found`);\n\n      const version = this.db.getLatestVersion(docId);\n      // Load operation history from DB\n      const versions = this.db.getVersions(docId);\n      const operations: (Operation | null)[] = [null]; // index 0 unused (1-indexed)\n      for (const v of versions) {\n        operations[v.version] = v.operation ? JSON.parse(v.operation) : null;\n      }\n\n      state = {\n        content: doc.content,\n        version,\n        operations,\n      };\n      this.documents.set(docId, state);\n    }\n    return state;\n  }\n\n  private handleConnection(ws: WebSocket, docId: string): void {\n    const clientId = randomUUID();\n    const client: ClientConnection = { id: clientId, ws, docId };\n    this.clients.set(clientId, client);\n    this.db.addConnection(clientId, docId);\n\n    const state = this.getDocumentState(docId);\n\n    // Send sync message with current state\n    const syncMsg: ServerMessage = {\n      type: 'sync',\n      docId,\n      content: state.content,\n      version: state.version,\n    };\n    this.send(ws, syncMsg);\n\n    ws.on('message', (data) => {\n      try {\n        const msg = JSON.parse(data.toString());\n        this.handleMessage(clientId, msg);\n      } catch (err) {\n        const errorMsg: ServerMessage = {\n          type: 'error',\n          message: err instanceof Error ? err.message : 'Invalid message',\n        };\n        this.send(ws, errorMsg);\n      }\n    });\n\n    ws.on('close', () => {\n      this.clients.delete(clientId);\n      this.db.removeConnection(clientId);\n    });\n\n    ws.on('error', () => {\n      this.clients.delete(clientId);\n      this.db.removeConnection(clientId);\n    });\n  }\n\n  private handleMessage(clientId: string, msg: unknown): void {\n    const client = this.clients.get(clientId);\n    if (!client) return;\n\n    if (!msg || typeof msg !== 'object' || !('type' in msg)) {\n      this.send(client.ws, { type: 'error', message: 'Invalid message format' });\n      return;\n    }\n\n    const message = msg as Record<string, unknown>;\n\n    if (message.type === 'operation') {\n      this.handleOperation(client, message);\n    } else {\n      this.send(client.ws, { type: 'error', message: `Unknown message type: ${message.type}` });\n    }\n  }\n\n  private handleOperation(client: ClientConnection, msg: Record<string, unknown>): void {\n    const { docId } = client;\n    const state = this.getDocumentState(docId);\n\n    const clientVersion = msg.version;\n    if (typeof clientVersion !== 'number' || !Number.isInteger(clientVersion)) {\n      this.send(client.ws, { type: 'error', message: 'Version must be an integer' });\n      return;\n    }\n\n    if (clientVersion < 0 || clientVersion > state.version) {\n      this.send(client.ws, {\n        type: 'error',\n        message: `Invalid version ${clientVersion}. Current version is ${state.version}`,\n      });\n      return;\n    }\n\n    let operation = msg.operation;\n    if (!Array.isArray(operation)) {\n      this.send(client.ws, { type: 'error', message: 'Operation must be an array' });\n      return;\n    }\n\n    // We need to figure out what the document looked like at clientVersion\n    // and validate the op against that length, then transform against\n    // all operations that happened since clientVersion.\n    let op = operation as Operation;\n\n    // Compute document length at clientVersion by replaying from initial state\n    // Actually, we can validate after transform since that's more reliable.\n    // First, transform the operation against all concurrent operations.\n    try {\n      for (let v = clientVersion + 1; v <= state.version; v++) {\n        const serverOp = state.operations[v];\n        if (serverOp) {\n          const [, transformedClient] = transform(serverOp, op);\n          op = transformedClient;\n        }\n      }\n\n      // Validate the transformed operation against current document\n      const validationError = validate(op, state.content.length);\n      if (validationError) {\n        this.send(client.ws, { type: 'error', message: validationError });\n        return;\n      }\n\n      // Apply the operation\n      const newContent = apply(state.content, op);\n      state.version++;\n      state.content = newContent;\n      state.operations[state.version] = op;\n\n      // Persist\n      this.db.addVersion(docId, newContent, JSON.stringify(op));\n\n      // Acknowledge to the sender\n      this.send(client.ws, { type: 'ack', version: state.version });\n\n      // Broadcast to other clients on the same document\n      const broadcastMsg: ServerMessage = {\n        type: 'operation',\n        clientId: client.id,\n        version: state.version,\n        operation: op,\n      };\n\n      for (const [id, otherClient] of this.clients) {\n        if (id !== client.id && otherClient.docId === docId) {\n          this.send(otherClient.ws, broadcastMsg);\n        }\n      }\n    } catch (err) {\n      this.send(client.ws, {\n        type: 'error',\n        message: err instanceof Error ? err.message : 'Failed to process operation',\n      });\n    }\n  }\n\n  private send(ws: WebSocket, msg: ServerMessage): void {\n    if (ws.readyState === WebSocket.OPEN) {\n      ws.send(JSON.stringify(msg));\n    }\n  }\n\n  closeAll(): void {\n    for (const [, client] of this.clients) {\n      client.ws.close();\n    }\n    this.clients.clear();\n    this.documents.clear();\n    this.db.clearAllConnections();\n    this.wss.close();\n  }\n}\n","structuredPatch":[{"oldStart":160,"oldLines":7,"newStart":160,"newLines":7,"lines":["       re