n,\n  apply,\n  transform,\n  validate,\n  type ServerMessage,\n} from './ot.js';\n\ninterface ClientConnection {\n  id: string;\n  ws: WebSocket;\n  docId: string;\n}\n\ninterface DocumentState {\n  content: string;\n  version: number;\n  /** History of operations indexed by version they produced (1-indexed) */\n  operations: (Operation | null)[];\n}\n\nexport class CollaborationServer {\n  private wss: WebSocketServer;\n  private db: DocumentDatabase;\n  private clients: Map<string, ClientConnection> = new Map();\n  /** In-memory document states for active documents */\n  private documents: Map<string, DocumentState> = new Map();\n\n  constructor(server: HttpServer, db: DocumentDatabase) {\n    this.db = db;\n    this.wss = new WebSocketServer({ server, path: undefined });\n\n    // Handle upgrade manually to support path-based routing\n    server.on('upgrade', (request: IncomingMessage, socket, head) => {\n      const url = new URL(request.url || '', `http://${request.headers.host}`);\n      const match = url.pathname.match(/^\\/documents\\/([^/]+)\\/ws$/);\n\n      if (!match) {\n        socket.destroy();\n        return;\n      }\n\n      const docId = match[1];\n\n      // Verify document exists\n      const doc = this.db.getDocument(docId);\n      if (!doc) {\n        socket.write('HTTP/1.1 404 Not Found\\r\\n\\r\\n');\n        socket.destroy();\n        return;\n      }\n\n      this.wss.handleUpgrade(request, socket, head, (ws) => {\n        this.wss.emit('connection', ws, request, docId);\n      });\n    });\n\n    this.wss.on('connection', (ws: WebSocket, _request: IncomingMessage, docId: string) => {\n      this.handleConnection(ws, docId);\n    });\n  }\n\n  private getDocumentState(docId: string): DocumentState {\n    let state = this.documents.get(docId);\n    if (!state) {\n      const doc = this.db.getDocument(docId);\n      if (!doc) throw new Error(`Document ${docId} not found`);\n\n      const version = this.db.getLatestVersion(docId);\n      // 