+// ── Cell Reference Utilities ──
+
+const CELL_REF_RE = /^([A-Z]+)(\d+)$/;
+
+function parseColLetters(letters: string): number {
+  let col = 0;
+  for (let i = 0; i < letters.length; i++) {
+    col = col * 26 + (letters.charCodeAt(i) - 64); // A=1
+  }
+  return col; // 1-based
+}
+
+function colToLetters(col: number): string {
+  let s = '';
+  while (col > 0) {
+    col--;
+    s = String.fromCharCode(65 + (col % 26)) + s;
+    col = Math.floor(col / 26);
+  }
+  return s;
+}
+
+function parseCellRef(ref: string): { col: number; row: number } {
+  const m = ref.toUpperCase().match(CELL_REF_RE);
+  if (!m) throw new Error(`Invalid cell reference: ${ref}`);
+  return { col: parseColLetters(m[1]), row: parseInt(m[2], 10) };
+}
+
+function normalizeCellRef(ref: string): string {
+  return ref.toUpperCase();
+}
+
+function expandRange(start: string, end: string): string[] {
+  const s = parseCellRef(start);
+  const e = parseCellRef(end);
+  const minCol = Math.min(s.col, e.col);
+  const maxCol = Math.max(s.col, e.col);
+  const minRow = Math.min(s.row, e.row);
+  const maxRow = Math.max(s.row, e.row);
+  const cells: string[] = [];
+  for (let c = minCol; c <= maxCol; c++) {
+    for (let r = minRow; r <= maxRow; r++) {
+      cells.push(colToLetters(c) + r);
+    }
+  }
+  return cells;
+}
+
+// ── Tokenizer ──
+
+enum TokenType {
+  Number = 'Number',
+  String = 'String',
+  Boolean = 'Boolean',
+  CellRef = 'CellRef',
+  Range = 'Range',
+  Function = 'Function',
+  Operator = 'Operator',
+  LParen = 'LParen',
+  RParen = 'RParen',
+  Comma = 'Comma',
+}
+
+interface Token {
+  type: TokenType;
+  value: string;
+}
+
+function tokenize(formula: string): Token[] {
+  const tokens: Token[] = [];
+  let i = 0;
+  const src = formula;
+
+  while (i < src.length) {
+    // skip whitespace
+    if (src[i] === ' ' || src[i] === '\t') {
+      i++;
+      continue;
+    }
+
+    // string literal
+    if (src[i] === '"') {
+      let s = '';
+      i++; // skip opening quote
+      while (i < src.length && src[i] !== '"') {
+        s += src[i];
+        i++;
+      }
+      if (i < src.length) i++; // skip closing quote
+      tokens.push({ type: TokenType.String, value: s });
+      continue;
+    }
+
+    // number (including decimals)
+    if (/\d/.test(src[i]) || (src[i] === '.' && i + 1 < src.length && /\d/.test(src[i + 1]))) {
+      let num = '';
+      while (i < src.length && (/\d/.test(src[i]) || src[i] === '.')) {
+        num += src[i];
+        i++;
+      }
+      tokens.push({ type: TokenType.Number, value: num });
+      continue;
+    }
+
+    // identifiers: cell refs, functions, booleans, ranges
+    if (/[A-Za-z]/.test(src[i])) {
+      let ident = '';
+      while (i < src.length && /[A-Za-z0-9]/.test(src[i])) {
+        ident += src[i];
+        i++;
+      }
+      const upper = ident.toUpperCase();
+
+      // check for range (e.g. A1:B3)
+      if (src[i] === ':' && CELL_REF_RE.test(upper)) {
+        i++; // skip colon
+        let ident2 = '';
+        while (i < src.length && /[A-Za-z0-9]/.test(src[i])) {
+          ident2 += src[i];
+          i++;
+        }
+        tokens.push({ type: TokenType.Range, value: upper + ':' + ident2.toUpperCase() });
+        continue;
+      }
+
+      if (upper === 'TRUE' || upper === 'FALSE') {
+        tokens.push({ type: TokenType.Boolean, value: upper });
+        continue;
+      }
+
+      // function if next non-space is '('
+      let peek = i;
+      while (peek < src.length && src[peek] === ' ') peek++;
+      if (peek < src.length && src[peek] === '(') {
+        tokens.push({ type: TokenType.Function, value: upper });
+        continue;
+      }
+
+      // cell reference
+      if (CELL_REF_RE.test(upper)) {
+        tokens.push({ type: TokenType.CellRef, value: upper });
+        continue;
+      }
+
+      throw new Error(`Unknown identifier: ${ident}`);
+    }
+
+    // two-char operators
+    if (i + 1 < src.length) {
+      const two = src[i] + src[i + 1];
+      if (two === '>=' || two === '<=' || two === '<>') {
+        tokens.push({ type: TokenType.Operator, value: two });
+        i += 2;
+        continue;
+      }
+    }
+
+    // single-char operators and punctuation
+    if ('+-*/>=<'.includes(src[i])) {
+      tokens.push({ type: TokenType.Operator, value: src[i] });
+      i++;
+      continue;
+    }
+
+    if (src[i] === '(') {
+      tokens.push({ type: TokenType.LParen, value: '(' });
+      i++;
+      continue;
+    }
+    if (src[i] === ')') {
+      tokens.push({ type: TokenType.RParen, value: ')' });
+      i++;
+      continue;
+    }
+    if (src[i] === ',') {
+      tokens.push({ type: TokenType.Comma, value: ',' });
+      i++;
+      continue;
+    }
+
+    throw new Error(`Unexpected character: ${src[i]}`);
+  }
+
+  return tokens;
+}
+
+// ── AST ──
+
+type ASTNode =
+  | { kind: 'number'; value: number }
+  | { kind: 'string'; value: string }
+  | { kind: 'boolean'; value: boolean }
+  | { kind: 'cellRef'; ref: string }
+  | { kind: 'range'; start: string; end: string }
+  | { kind: 'binary'; op: string; left: ASTNode; right: ASTNode }
+  | { kind: 'unary'; op: string; operand: ASTNode }
+  | { kind: 'call'; name: string; args: ASTNode[] };
+
+// ── Parser (precedence climbing) ──
+
+class Parser {
+  private tokens: Token[];
+  private pos: number;
+
+  constructor(tokens: Token[]) {
+    this.tokens = tokens;
+    this.pos = 0;
+  }
+
+  parse(): ASTNode {
+    const node = this.parseExpression(0);
+    if (this.pos < this.tokens.length) {
+      throw new Error(`Unexpected token: ${this.tokens[this.pos].value}`);
+    }
+    return node;
+  }
+
+  private peek(): Token | null {
+    return this.pos < this.tokens.length ? this.tokens[this.pos] : null;
+  }
+
+  private advance(): Token {
+    return this.tokens[this.pos++];
+  }
+
+  private precedence(op: string): number {
+    switch (op) {
+      case '=':
+      case '<>':
+      case '<':
+      case '>':
+      case '<=':
+      case '>=':
+        return 1;
+      case '+':
+      case '-':
+        return 2;
+      case '*':
+      case '/':
+        return 3;
+      default:
+        return 0;
+    }
+  }
+
+  private parseExpression(minPrec: number): ASTNode {
+    let left = this.parsePrimary();
+
+    for (let t = this.peek(); t && t.type === TokenType.Operator; t = this.peek()) {
+      const prec = this.precedence(t.value);
+      if (prec < minPrec) break;
+      this.advance();
+      const right = this.parseExpression(prec + 1);
+      left = { kind: 'binary', op: t.value, left, right };
+    }
+
+    return left;
+  }
+
+  private parsePrimary(): ASTNode {
+    const t = this.peek();
+    if (!t) throw new Error('Unexpected end of formula');
+
+    // unary minus/plus
+    if (t.type === TokenType.Operator && (t.value === '-' || t.value === '+')) {
+      this.advance();
+      const operand = this.parsePrimary();
+      if (t.value === '+') return operand;
+      return { kind: 'unary', op: '-', operand };
+    }
+
+    if (t.type === TokenType.Number) {
+      this.advance();
+      return { kind: 'number', value: parseFloat(t.value) };
+    }
+
+    if (t.type === TokenType.String) {
+      this.advance();
+      return { kind: 'string', value: t.value };
+    }
+
+    if (t.type === TokenType.Boolean) {
+      this.advance();
+      return { kind: 'boolean', value: t.value === 'TRUE' };
+    }
+
+    if (t.type === TokenType.Range) {
+      this.advance();
+      const [start, end] = t.value.split(':');
+      return { kind: 'range', start, end };
+    }
+
+    if (t.type === TokenType.CellRef) {
+      this.advance();
+      return { kind: 'cellRef', ref: t.value };
+    }
+
+    if (t.type === TokenType.Function) {
+      const name = t.value;
+      this.advance();
+      // consume '('
+      if (!this.peek() || this.peek()!.type !== TokenType.LParen) {
+        throw new Error(`Expected ( after function ${name}`);
+      }
+      this.advance();
+      const args: ASTNode[] = [];
+      if (this.peek() && this.peek()!.type !== TokenType.RParen) {
+        args.push(this.parseExpression(0));
+        while (this.peek() && this.peek()!.type === TokenType.Comma) {
+          this.advance(); // skip comma
+          args.push(this.parseExpression(0));
+        }
+      }
+      if (!this.peek() || this.peek()!.type !== TokenType.RParen) {
+        throw new Error(`Expected ) after function arguments`);
+      }
+      this.advance();
+      return { kind: 'call', name, args };
+    }
+
+    if (t.type === TokenType.LParen) {
+      this.advance();
+      const node = this.parseExpression(0);
+      if (!this.peek() || this.peek()!.type !== TokenType.RParen) {
+        throw new Error('Expected )');
+      }
+      this.advance();
+      return node;
+    }
+
+    throw new Error(`Unexpected token: ${t.value}`);
+  }
+}
+
+function parseFormula(formula: string): ASTNode {
+  const tokens = tokenize(formula);
+  return new Parser(tokens).parse();
+}
+
+// ── Dependency Extraction ──
+
+function extractDependencies(node: ASTNode): Set<string> {
+  const deps = new Set<string>();
+  function walk(n: ASTNode): void {
+    switch (n.kind) {
+      case 'cellRef':
+        deps.add(n.ref);
+        break;
+      case 'range':
+        for (const cell of expandRange(n.start, n.end)) {
+          deps.add(cell);
+        }
+        break;
+      case 'binary':
+        walk(n.left);
+        walk(n.right);
+        break;
+      case 'unary':
+        walk(n.operand);
+        break;
+      case 'call':
+        for (const arg of n.args) walk(arg);
+        break;
+    }
+  }
+  walk(node);
+  return deps;
+}
+
+// ── Cell Types ──
+
+type CellValue = string | number | boolean | null;
+
+interface CellData {
+  raw: string | number | boolean;
+  formula: ASTNode | null;
+  computed: CellValue;
+  deps: Set<string>; // cells this cell depends on
+}
+
+// ── Spreadsheet ──
+
+export class Spreadsheet {
+  private cells: Map<string, CellData> = new Map();
+  private dependents: Map<string, Set<string>> = new Map(); // cell -> cells that depend on it
+
+  set(cell: string, value: string | number | boolean): void {
+    const key = normalizeCellRef(cell);
+
+    // Remove old dependency edges
+    const existing = this.cells.get(key);
+    if (existing) {
+      for (const dep of existing.deps) {
+        this.dependents.get(dep)?.delete(key);
+      }
+    }
+
+    let formula: ASTNode | null = null;
+    let deps = new Set<string>();
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      formula = parseFormula(value.slice(1));
+      deps = extractDependencies(formula);
+    }
+
+    // Check for circular references before committing
+    if (deps.size > 0) {
+      this.checkCircular(key, deps);
+    }
+
+    // Register new dependency edges
+    for (const dep of deps) {
+      if (!this.dependents.has(dep)) {
+        this.dependents.set(dep, new Set());
+      }
+      this.dependents.get(dep)!.add(key);
+    }
+
+    const cellData: CellData = {
+      raw: value,
+      formula,
+      computed: null,
+      deps,
+    };
+    this.cells.set(key, cellData);
+
+    // Evaluate this cell
+    cellData.computed = this.evaluate(cellData);
+
+    // Propagate to dependents
+    this.propagate(key);
+  }
+
+  get(cell: string): CellValue {
+    const key = normalizeCellRef(cell);
+    const data = this.cells.get(key);
+    if (!data) return null;
+    return data.computed;
+  }
+
+  getDisplay(cell: string): string {
+    const val = this.get(cell);
+    if (val === null) return '';
+    return String(val);
+  }
+
+  getCells(): Map<string, CellValue> {
+    const result = new Map<string, CellValue>();
+    for (const [key, data] of this.cells) {
+      result.set(key, data.computed);
+    }
+    return result;
+  }
+
+  private checkCircular(startKey: string, directDeps: Set<string>): void {
+    // BFS/DFS from each direct dependency — if we can reach startKey, it's circular
+    const visited = new Set<string>();
+    const stack = [...directDeps];
+    while (stack.length > 0) {
+      const current = stack.pop()!;
+      if (current === startKey) {
+        throw new Error(`Circular reference detected involving ${startKey}`);
+      }
+      if (visited.has(current)) continue;
+      visited.add(current);
+      const cellData = this.cells.get(current);
+      if (cellData) {
+        for (const dep of cellData.deps) {
+          stack.push(dep);
+        }
+      }
+    }
+  }
+
+  private propagate(changedKey: string): void {
+    // Topological order of all transitive dependents
+    const order = this.topologicalDependents(changedKey);
+    for (const key of order) {
+      const data = this.cells.get(key);
+      if (data) {
+        data.computed = this.evaluate(data);
+      }
+    }
+  }
+
+  private topologicalDependents(startKey: string): string[] {
+    // Collect all transitive dependents
+    const allDeps = new Set<string>();
+    const queue = [startKey];
+    while (queue.length > 0) {
+      const current = queue.shift()!;
+      const deps = this.dependents.get(current);
+      if (deps) {
+        for (const d of deps) {
+          if (!allDeps.has(d)) {
+            allDeps.add(d);
+            queue.push(d);
+          }
+        }
+      }
+    }
+
+    // Kahn's algorithm for topological sort within these cells
+    // Build in-degree map considering only edges within allDeps
+    const inDegree = new Map<string, number>();
+    for (const key of allDeps) {
+      inDegree.set(key, 0);
+    }
+    for (const key of allDeps) {
+      const data = this.cells.get(key);
+      if (data) {
+        for (const dep of data.deps) {
+          // If dep is in allDeps or is startKey, it contributes to in-degree
+          if (allDeps.has(dep) || dep === startKey) {
+            inDegree.set(key, (inDegree.get(key) || 0) + 1);
+          }
+        }
+      }
+    }
+
+    // Start with cells whose only changed dependency is startKey itself (in-degree after removing startKey edges)
+    // Actually simpler: subtract edges from startKey
+    const result: string[] = [];
+    const ready: string[] = [];
+
+    // Cells directly depending on startKey have their in-degree decremented by 1
+    // because startKey is already computed
+    for (const key of allDeps) {
+      const data = this.cells.get(key);
+      if (data && data.deps.has(startKey)) {
+        inDegree.set(key, inDegree.get(key)! - 1);
+      }
+    }
+
+    for (const [key, deg] of inDegree) {
+      if (deg === 0) ready.push(key);
+    }
+
+    while (ready.length > 0) {
+      const key = ready.shift()!;
+      result.push(key);
+      const deps = this.dependents.get(key);
+      if (deps) {
+        for (const d of deps) {
+          if (allDeps.has(d)) {
+            const newDeg = inDegree.get(d)! - 1;
+            inDegree.set(d, newDeg);
+            if (newDeg === 0) ready.push(d);
+          }
+        }
+      }
+    }
+
+    return result;
+  }
+
+  private evaluate(cellData: CellData): CellValue {
+    if (!cellData.formula) {
+      // Raw value
+      return cellData.raw as CellValue;
+    }
+    return this.evalNode(cellData.formula);
+  }
+
+  private evalNode(node: ASTNode): CellValue {
+    switch (node.kind) {
+      case 'number':
+        return node.value;
+      case 'string':
+        return node.value;
+      case 'boolean':
+        return node.value;
+      case 'cellRef': {
+        const data = this.cells.get(node.ref);
+        return data ? data.computed : null;
+      }
+      case 'range':
+        throw new Error('Range can only be used inside functions');
+      case 'unary': {
+        const val = this.evalNode(node.operand);
+        if (typeof val === 'number') return -val;
+        return null;
+      }
+      case 'binary':
+        return this.evalBinary(node.op, node.left, node.right);
+      case 'call':
+        return this.evalCall(node.name, node.args);
+    }
+  }
+
+  private evalBinary(op: string, left: ASTNode, right: ASTNode): CellValue {
+    const l = this.evalNode(left);
+    const r = this.evalNode(right);
+
+    if (op === '+' || op === '-' || op === '*' || op === '/') {
+      const ln = typeof l === 'number' ? l : 0;
+      const rn = typeof r === 'number' ? r : 0;
+      switch (op) {
+        case '+': return ln + rn;
+        case '-': return ln - rn;
+        case '*': return ln * rn;
+        case '/': return rn === 0 ? null : ln / rn;
+      }
+    }
+
+    // Comparisons
+    switch (op) {
+      case '=': return l === r;
+      case '<>': return l !== r;
+      case '<': return (l as number) < (r as number);
+      case '>': return (l as number) > (r as number);
+      case '<=': return (l as number) <= (r as number);
+      case '>=': return (l as number) >= (r as number);
+    }
+
+    return null;
+  }
+
+  private resolveRangeValues(node: ASTNode): CellValue[] {
+    if (node.kind === 'range') {
+      const cells = expandRange(node.start, node.end);
+      return cells.map(ref => {
+        const data = this.cells.get(ref);
+        return data ? data.computed : null;
+      });
+    }
+    // Single value
+    return [this.evalNode(node)];
+  }
+
+  private evalCall(name: string, args: ASTNode[]): CellValue {
+    switch (name) {
+      case 'SUM': {
+        let sum = 0;
+        for (const arg of args) {
+          for (const v of this.resolveRangeValues(arg)) {
+            if (typeof v === 'number') sum += v;
+          }
+        }
+        return sum;
+      }
+      case 'AVERAGE': {
+        let sum = 0;
+        let count = 0;
+        for (const arg of args) {
+          for (const v of this.resolveRangeValues(arg)) {
+            if (typeof v === 'number') {
+              sum += v;
+              count++;
+            }
+          }
+        }
+        return count === 0 ? null : sum / count;
+      }
+      case 'MIN': {
+        let min = Infinity;
+        for (const arg of args) {
+          for (const v of this.resolveRangeValues(arg)) {
+            if (typeof v === 'number' && v < min) min = v;
+          }
+        }
+        return min === Infinity ? null : min;
+      }
+      case 'MAX': {
+        let max = -Infinity;
+        for (const arg of args) {
+          for (const v of this.resolveRangeValues(arg)) {
+            if (typeof v === 'number' && v > max) max = v;
+          }
+        }
+        return max === -Infinity ? null : max;
+      }
+      case 'COUNT': {
+        let count = 0;
+        for (const arg of args) {
+          for (const v of this.resolveRangeValues(arg)) {
+            if (typeof v === 'number') count++;
+          }
+        }
+        return count;
+      }
+      case 'IF': {
+        if (args.length < 3) throw new Error('IF requires 3 arguments');
+        const condition = this.evalNode(args[0]);
+        const truthy = condition === true || (typeof condition === 'number' && condition !== 0) || (typeof condition === 'string' && condition !== '');
+        return truthy ? this.evalNode(args[1]) : this.evalNode(args[2]);
+      }
+      default:
+        throw new Error(`Unknown function: ${name}`);
+    }
+  }
+}
