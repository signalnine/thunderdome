t the beam\n    if (grid[row][col] === '^') {\n      const dirs: Direction[] = ['down-left', 'down-right'];\n      for (const newDir of dirs) {\n        const [nr, nc] = nextPos(row, col, newDir);\n        if (inBounds(nr, nc, rows, cols)) {\n          const key = `${nr},${nc},${newDir}`;\n          if (!seen.has(key)) {\n            seen.add(key);\n            visited.add(`${nr},${nc}`);\n            queue.push({ row: nr, col: nc, dir: newDir });\n          }\n        }\n      }\n    } else {\n      // Continue in current direction\n      const [nr, nc] = nextPos(row, col, dir);\n      if (inBounds(nr, nc, rows, cols)) {\n        const key = `${nr},${nc},${dir}`;\n        if (!seen.has(key)) {\n          seen.add(key);\n          visited.add(`${nr},${nc}`);\n          queue.push({ row: nr, col: nc, dir: newDir });\n        }\n      }\n    }\n  }\n\n  return visited.size;\n}\n\nexport function countBeamPaths(grid: string[][]): bigint {\n  if (grid.length === 0 || grid[0].length === 0) return 0n;\n\n  const rows = grid.length;\n  const cols = grid[0].length;\n  const source = findSource(grid);\n  if (!source) return 0n;\n\n  // Use memoization: from a given (row, col, dir), how many paths exit the grid?\n  const memo = new Map<string, bigint>();\n\n  function countFrom(row: number, col: number, dir: Direction): bigint {\n    const key = `${row},${col},${dir}`;\n    if (memo.has(key)) return memo.get(key)!;\n\n    // If current cell is a splitter, split\n    if (grid[row][col] === '^') {\n      let total = 0n;\n      const dirs: Direction[] = ['down-left', 'down-right'];\n      for (const newDir of dirs) {\n        const [nr, nc] = nextPos(row, col, newDir);\n        if (inBounds(nr, nc, rows, cols)) {\n          total += countFrom(nr, nc, newDir);\n        } else {\n          total += 1n; // beam exits grid = one path\n        }\n      }\n      memo.set(key, total);\n      return total;\n    }\n\n    // Continue in current direction\n    const [nr, nc] = nextPos(row, col, dir);\n    if (inBounds(nr, nc, rows, cols)) {\n      const result = countFrom(nr, nc, dir);\n      memo.set(key, result);\n      return result;\n    } else {\n      // Beam exits grid\n      memo.set(key, 1n);\n      return 1n;\n    }\n  }\n\n  return countFrom(source[0], source[1], 'down');\n}\n","structuredPatch":[{"oldStart":66,"oldLines":7,"newStart":66,"newLines":7,"lines":["         if (!seen.has(key)) {","           seen.add(key);","           visited.add(`${nr},${nc}`);","-          queue.push({ row: nr, col: nc, dir: newDir });","+          queue.push({ row: nr, col: nc, dir: dir });","         }","       }","     }"]}],"userModified":false,"replaceAll":false}}
