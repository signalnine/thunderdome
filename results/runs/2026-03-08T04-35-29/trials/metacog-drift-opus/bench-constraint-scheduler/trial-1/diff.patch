+import { describe, it, expect } from 'vitest';
+import { schedule, Event, Room, ScheduleOptions } from './index.js';
+
+describe('schedule', () => {
+  const rooms: Room[] = [
+    { id: 'r1', name: 'Room A', capacity: 10 },
+    { id: 'r2', name: 'Room B', capacity: 20 },
+  ];
+
+  const options: ScheduleOptions = {
+    startTime: 540,  // 9:00 AM
+    endTime: 1020,   // 5:00 PM
+    gap: 15,
+  };
+
+  it('schedules a single event', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60, attendees: 5 },
+    ];
+    const result = schedule(events, rooms, options);
+    expect(result.assignments).toHaveLength(1);
+    expect(result.unscheduled).toHaveLength(0);
+    expect(result.assignments[0].eventId).toBe('e1');
+    expect(result.assignments[0].startTime).toBe(540);
+    expect(result.assignments[0].endTime).toBe(600);
+  });
+
+  it('respects room capacity', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Big Event', duration: 60, attendees: 15 },
+    ];
+    const result = schedule(events, rooms, options);
+    expect(result.assignments).toHaveLength(1);
+    expect(result.assignments[0].roomId).toBe('r2'); // Only r2 has capacity >= 15
+  });
+
+  it('marks events as unscheduled when no room fits', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Huge Event', duration: 60, attendees: 50 },
+    ];
+    const result = schedule(events, rooms, options);
+    expect(result.assignments).toHaveLength(0);
+    expect(result.unscheduled).toEqual(['e1']);
+  });
+
+  it('respects prerequisites', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'First', duration: 60, attendees: 5 },
+      { id: 'e2', name: 'Second', duration: 60, attendees: 5, prerequisites: ['e1'] },
+    ];
+    const result = schedule(events, rooms, options);
+    expect(result.assignments).toHaveLength(2);
+
+    const a1 = result.assignments.find(a => a.eventId === 'e1')!;
+    const a2 = result.assignments.find(a => a.eventId === 'e2')!;
+    expect(a1.endTime + 15).toBeLessThanOrEqual(a2.startTime);
+  });
+
+  it('throws on self-referencing prerequisite', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Self', duration: 60, prerequisites: ['e1'] },
+    ];
+    expect(() => schedule(events, rooms, options)).toThrow();
+  });
+
+  it('throws on prerequisite cycle', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'A', duration: 60, prerequisites: ['e2'] },
+      { id: 'e2', name: 'B', duration: 60, prerequisites: ['e1'] },
+    ];
+    expect(() => schedule(events, rooms, options)).toThrow();
+  });
+
+  it('respects room gaps', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60, attendees: 5 },
+      { id: 'e2', name: 'Event 2', duration: 60, attendees: 5 },
+    ];
+    const smallRooms: Room[] = [{ id: 'r1', name: 'Room A', capacity: 10 }];
+    const result = schedule(events, smallRooms, options);
+    expect(result.assignments).toHaveLength(2);
+
+    const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);
+    expect(sorted[1].startTime).toBeGreaterThanOrEqual(sorted[0].endTime + 15);
+  });
+
+  it('respects preferred room when possible', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60, attendees: 5, preferredRoom: 'r2' },
+    ];
+    const result = schedule(events, rooms, options);
+    expect(result.assignments[0].roomId).toBe('r2');
+  });
+
+  it('handles empty events', () => {
+    const result = schedule([], rooms, options);
+    expect(result.assignments).toHaveLength(0);
+    expect(result.unscheduled).toHaveLength(0);
+  });
+
+  it('handles no rooms', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event', duration: 60 },
+    ];
+    const result = schedule(events, [], options);
+    expect(result.assignments).toHaveLength(0);
+    expect(result.unscheduled).toEqual(['e1']);
+  });
+
+  it('uses default gap of 15 when not specified', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60, attendees: 5 },
+      { id: 'e2', name: 'Event 2', duration: 60, attendees: 5 },
+    ];
+    const smallRooms: Room[] = [{ id: 'r1', name: 'Room A', capacity: 10 }];
+    const noGapOpts: ScheduleOptions = { startTime: 540, endTime: 1020 };
+    const result = schedule(events, smallRooms, noGapOpts);
+    expect(result.assignments).toHaveLength(2);
+
+    const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);
+    expect(sorted[1].startTime).toBeGreaterThanOrEqual(sorted[0].endTime + 15);
+  });
+
+  it('respects time window boundaries', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event', duration: 60, attendees: 5 },
+    ];
+    const tightOpts: ScheduleOptions = { startTime: 540, endTime: 570, gap: 0 };
+    const result = schedule(events, rooms, tightOpts);
+    // 60 min event can't fit in 30 min window
+    expect(result.assignments).toHaveLength(0);
+    expect(result.unscheduled).toEqual(['e1']);
+  });
+
+  it('schedules multiple events across rooms', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60, attendees: 5 },
+      { id: 'e2', name: 'Event 2', duration: 60, attendees: 5 },
+      { id: 'e3', name: 'Event 3', duration: 60, attendees: 5 },
+    ];
+    const result = schedule(events, rooms, options);
+    expect(result.assignments).toHaveLength(3);
+    expect(result.unscheduled).toHaveLength(0);
+  });
+
+  it('throws on longer cycle', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'A', duration: 60, prerequisites: ['e3'] },
+      { id: 'e2', name: 'B', duration: 60, prerequisites: ['e1'] },
+      { id: 'e3', name: 'C', duration: 60, prerequisites: ['e2'] },
+    ];
+    expect(() => schedule(events, rooms, options)).toThrow();
+  });
+
+  it('defaults attendees to 1', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Solo Event', duration: 60 },
+    ];
+    const tinyRoom: Room[] = [{ id: 'r1', name: 'Tiny', capacity: 1 }];
+    const result = schedule(events, tinyRoom, options);
+    expect(result.assignments).toHaveLength(1);
+  });
+
+  it('maximizes scheduled events', () => {
+    // 1 room, 8-hour window (480 min), gap=0
+    // 8 events of 60 min each should all fit
+    const events: Event[] = Array.from({ length: 8 }, (_, i) => ({
+      id: `e${i}`,
+      name: `Event ${i}`,
+      duration: 60,
+      attendees: 5,
+    }));
+    const singleRoom: Room[] = [{ id: 'r1', name: 'Room', capacity: 10 }];
+    const noGap: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 0 };
+    const result = schedule(events, singleRoom, noGap);
+    expect(result.assignments).toHaveLength(8);
+    expect(result.unscheduled).toHaveLength(0);
+  });
+});
