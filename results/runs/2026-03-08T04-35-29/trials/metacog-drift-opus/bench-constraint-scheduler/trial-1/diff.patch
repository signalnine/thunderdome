+export interface Event {
+  id: string;
+  name: string;
+  duration: number;
+  attendees?: number;
+  prerequisites?: string[];
+  preferredRoom?: string;
+}
+
+export interface Room {
+  id: string;
+  name: string;
+  capacity: number;
+}
+
+export interface ScheduleOptions {
+  startTime: number;
+  endTime: number;
+  gap?: number;
+}
+
+export interface Assignment {
+  eventId: string;
+  roomId: string;
+  startTime: number;
+  endTime: number;
+}
+
+export interface ScheduleResult {
+  assignments: Assignment[];
+  unscheduled: string[];
+}
+
+/**
+ * Detect cycles in the prerequisite graph using DFS.
+ * Throws if a cycle is found (including self-references).
+ */
+function detectCycles(events: Event[]): void {
+  const eventIds = new Set(events.map(e => e.id));
+  const adjList = new Map<string, string[]>();
+
+  for (const event of events) {
+    if (event.prerequisites) {
+      for (const prereq of event.prerequisites) {
+        if (prereq === event.id) {
+          throw new Error(`Cycle detected: event "${event.id}" references itself`);
+        }
+      }
+      // Store edges: prereq -> event (prereq must come before event)
+      adjList.set(event.id, event.prerequisites.filter(p => eventIds.has(p)));
+    }
+  }
+
+  // DFS cycle detection
+  const WHITE = 0, GRAY = 1, BLACK = 2;
+  const color = new Map<string, number>();
+  for (const e of events) color.set(e.id, WHITE);
+
+  function dfs(nodeId: string): void {
+    color.set(nodeId, GRAY);
+    const deps = adjList.get(nodeId) || [];
+    for (const dep of deps) {
+      const c = color.get(dep);
+      if (c === GRAY) {
+        throw new Error(`Cycle detected in prerequisites involving "${dep}"`);
+      }
+      if (c === WHITE) {
+        dfs(dep);
+      }
+    }
+    color.set(nodeId, BLACK);
+  }
+
+  for (const e of events) {
+    if (color.get(e.id) === WHITE) {
+      dfs(e.id);
+    }
+  }
+}
+
+/**
+ * Topological sort using Kahn's algorithm.
+ * Returns event IDs in an order that respects prerequisites.
+ */
+function topologicalSort(events: Event[]): string[] {
+  const eventIds = new Set(events.map(e => e.id));
+  const inDegree = new Map<string, number>();
+  const adjList = new Map<string, string[]>(); // prereq -> [dependents]
+
+  for (const e of events) {
+    inDegree.set(e.id, 0);
+    if (!adjList.has(e.id)) adjList.set(e.id, []);
+  }
+
+  for (const event of events) {
+    if (event.prerequisites) {
+      for (const prereq of event.prerequisites) {
+        if (eventIds.has(prereq)) {
+          inDegree.set(event.id, (inDegree.get(event.id) || 0) + 1);
+          const list = adjList.get(prereq) || [];
+          list.push(event.id);
+          adjList.set(prereq, list);
+        }
+      }
+    }
+  }
+
+  const queue: string[] = [];
+  for (const [id, deg] of inDegree) {
+    if (deg === 0) queue.push(id);
+  }
+
+  const sorted: string[] = [];
+  while (queue.length > 0) {
+    queue.sort(); // deterministic ordering within same level
+    const id = queue.shift()!;
+    sorted.push(id);
+    for (const dep of adjList.get(id) || []) {
+      const newDeg = (inDegree.get(dep) || 1) - 1;
+      inDegree.set(dep, newDeg);
+      if (newDeg === 0) queue.push(dep);
+    }
+  }
+
+  return sorted;
+}
+
+/**
+ * Get the earliest start time for an event based on its prerequisites.
+ */
+function getEarliestStart(
+  event: Event,
+  assignments: Map<string, Assignment>,
+  gap: number,
+  defaultStart: number
+): number {
+  let earliest = defaultStart;
+  if (event.prerequisites) {
+    for (const prereq of event.prerequisites) {
+      const prereqAssignment = assignments.get(prereq);
+      if (prereqAssignment) {
+        earliest = Math.max(earliest, prereqAssignment.endTime + gap);
+      }
+    }
+  }
+  return earliest;
+}
+
+/**
+ * Find the earliest available slot in a room for an event.
+ */
+function findEarliestSlot(
+  roomId: string,
+  duration: number,
+  earliestStart: number,
+  endTime: number,
+  gap: number,
+  roomAssignments: Assignment[]
+): number | null {
+  // Sort existing assignments by start time
+  const sorted = [...roomAssignments].sort((a, b) => a.startTime - b.startTime);
+
+  // Try to fit before the first assignment or between assignments
+  let candidateStart = earliestStart;
+
+  for (const existing of sorted) {
+    const candidateEnd = candidateStart + duration;
+
+    // Check if event fits before this existing assignment
+    if (candidateEnd + gap <= existing.startTime || candidateEnd <= existing.startTime) {
+      // Must respect gap: our end + gap <= existing start
+      if (candidateEnd + gap <= existing.startTime) {
+        if (candidateEnd <= endTime) {
+          return candidateStart;
+        }
+      }
+    }
+
+    // Move candidate past this existing assignment + gap
+    const afterExisting = existing.endTime + gap;
+    if (afterExisting > candidateStart) {
+      candidateStart = afterExisting;
+    }
+  }
+
+  // Try fitting after all existing assignments
+  if (candidateStart + duration <= endTime) {
+    return candidateStart;
+  }
+
+  return null;
+}
+
+/**
+ * Main scheduling function.
+ * Uses topological ordering + most-constrained-first heuristic
+ * with backtracking for optimization.
+ */
+export function schedule(
+  events: Event[],
+  rooms: Room[],
+  options: ScheduleOptions
+): ScheduleResult {
+  const gap = options.gap ?? 15;
+  const { startTime, endTime } = options;
+
+  // Validate and detect cycles
+  detectCycles(events);
+
+  if (events.length === 0 || rooms.length === 0) {
+    return {
+      assignments: [],
+      unscheduled: rooms.length === 0 ? events.map(e => e.id) : [],
+    };
+  }
+
+  const eventMap = new Map<string, Event>();
+  for (const e of events) eventMap.set(e.id, e);
+
+  // Topological sort
+  const topoOrder = topologicalSort(events);
+  const topoRank = new Map<string, number>();
+  topoOrder.forEach((id, i) => topoRank.set(id, i));
+
+  // For events not in topo (shouldn't happen, but safety)
+  for (const e of events) {
+    if (!topoRank.has(e.id)) {
+      topoRank.set(e.id, topoOrder.length);
+    }
+  }
+
+  // Count compatible rooms for each event (constraint tightness)
+  const compatibleRooms = new Map<string, Room[]>();
+  for (const event of events) {
+    const attendees = event.attendees ?? 1;
+    const compat = rooms.filter(r => r.capacity >= attendees);
+    compatibleRooms.set(event.id, compat);
+  }
+
+  // Sort events: first by topo rank, then by constraint tightness
+  // (fewer compatible rooms = more constrained = schedule first)
+  // Also consider: more dependents = schedule first
+  const dependentCount = new Map<string, number>();
+  for (const e of events) dependentCount.set(e.id, 0);
+  for (const e of events) {
+    if (e.prerequisites) {
+      for (const p of e.prerequisites) {
+        if (dependentCount.has(p)) {
+          dependentCount.set(p, (dependentCount.get(p) || 0) + 1);
+        }
+      }
+    }
+  }
+
+  const sortedEvents = [...events].sort((a, b) => {
+    const rankA = topoRank.get(a.id) ?? 0;
+    const rankB = topoRank.get(b.id) ?? 0;
+    if (rankA !== rankB) return rankA - rankB;
+
+    // More constrained (fewer rooms) first
+    const roomsA = (compatibleRooms.get(a.id) || []).length;
+    const roomsB = (compatibleRooms.get(b.id) || []).length;
+    if (roomsA !== roomsB) return roomsA - roomsB;
+
+    // Longer events first (harder to place)
+    if (a.duration !== b.duration) return b.duration - a.duration;
+
+    // More attendees first
+    return (b.attendees ?? 1) - (a.attendees ?? 1);
+  });
+
+  // Greedy scheduling with room preference
+  const assignments = new Map<string, Assignment>();
+  const roomSchedules = new Map<string, Assignment[]>();
+  for (const room of rooms) roomSchedules.set(room.id, []);
+
+  function tryPlaceEvent(event: Event): boolean {
+    const attendees = event.attendees ?? 1;
+    const compat = compatibleRooms.get(event.id) || [];
+
+    if (compat.length === 0) return false;
+
+    // Check if all prerequisites are assigned
+    if (event.prerequisites) {
+      for (const prereq of event.prerequisites) {
+        if (eventMap.has(prereq) && !assignments.has(prereq)) {
+          return false;
+        }
+      }
+    }
+
+    const earliestStart = getEarliestStart(event, assignments, gap, startTime);
+    if (earliestStart + event.duration > endTime) return false;
+
+    // Sort rooms: preferred room first, then by earliest available slot
+    const roomCandidates = [...compat].sort((a, b) => {
+      // Preferred room gets priority
+      if (event.preferredRoom === a.id && event.preferredRoom !== b.id) return -1;
+      if (event.preferredRoom === b.id && event.preferredRoom !== a.id) return 1;
+
+      // Smaller capacity first (leave large rooms for large events)
+      if (a.capacity !== b.capacity) return a.capacity - b.capacity;
+
+      return 0;
+    });
+
+    let bestSlot: { roomId: string; start: number } | null = null;
+
+    for (const room of roomCandidates) {
+      if (room.capacity < attendees) continue;
+
+      const roomAssigns = roomSchedules.get(room.id) || [];
+      const slotStart = findEarliestSlot(
+        room.id,
+        event.duration,
+        earliestStart,
+        endTime,
+        gap,
+        roomAssigns
+      );
+
+      if (slotStart !== null) {
+        // If this is the preferred room, use it immediately
+        if (event.preferredRoom === room.id) {
+          bestSlot = { roomId: room.id, start: slotStart };
+          break;
+        }
+
+        // Otherwise, pick the earliest available slot
+        if (!bestSlot || slotStart < bestSlot.start) {
+          bestSlot = { roomId: room.id, start: slotStart };
+        }
+      }
+    }
+
+    if (!bestSlot) return false;
+
+    const assignment: Assignment = {
+      eventId: event.id,
+      roomId: bestSlot.roomId,
+      startTime: bestSlot.start,
+      endTime: bestSlot.start + event.duration,
+    };
+
+    assignments.set(event.id, assignment);
+    roomSchedules.get(bestSlot.roomId)!.push(assignment);
+    return true;
+  }
+
+  function removeEvent(eventId: string): void {
+    const assignment = assignments.get(eventId);
+    if (assignment) {
+      const roomAssigns = roomSchedules.get(assignment.roomId)!;
+      const idx = roomAssigns.findIndex(a => a.eventId === eventId);
+      if (idx !== -1) roomAssigns.splice(idx, 1);
+      assignments.delete(eventId);
+    }
+  }
+
+  // First pass: greedy placement
+  for (const event of sortedEvents) {
+    tryPlaceEvent(event);
+  }
+
+  // Second pass: try to place unscheduled events with backtracking
+  // For each unscheduled event, try removing a less critical scheduled event
+  // and see if we can fit both
+  const unscheduledAfterGreedy = sortedEvents.filter(e => !assignments.has(e.id));
+
+  for (const event of unscheduledAfterGreedy) {
+    if (assignments.has(event.id)) continue;
+
+    // Try each room and time slot, checking if displacing an event helps
+    const attendees = event.attendees ?? 1;
+    const compat = compatibleRooms.get(event.id) || [];
+
+    let placed = false;
+
+    for (const room of compat) {
+      if (room.capacity < attendees) continue;
+
+      const roomAssigns = roomSchedules.get(room.id) || [];
+
+      // Try displacing each event in this room
+      for (const existing of [...roomAssigns]) {
+        const existingEvent = eventMap.get(existing.eventId)!;
+
+        // Don't displace if the existing event is a prerequisite of ours
+        if (event.prerequisites?.includes(existing.eventId)) continue;
+
+        // Don't displace if we are a prerequisite of the existing event
+        if (existingEvent.prerequisites?.includes(event.id)) continue;
+
+        // Remove existing, try to place our event, then try to re-place existing
+        removeEvent(existing.eventId);
+
+        if (tryPlaceEvent(event)) {
+          if (tryPlaceEvent(existingEvent)) {
+            // Both placed - success!
+            placed = true;
+            break;
+          } else {
+            // Can't re-place existing, revert
+            removeEvent(event.id);
+            // Restore existing
+            assignments.set(existing.eventId, existing);
+            roomSchedules.get(existing.roomId)!.push(existing);
+          }
+        } else {
+          // Can't place our event either, restore
+          assignments.set(existing.eventId, existing);
+          roomSchedules.get(existing.roomId)!.push(existing);
+        }
+      }
+
+      if (placed) break;
+    }
+  }
+
+  // Third pass: retry any remaining unscheduled events (they might fit now
+  // after backtracking shifted things around)
+  const stillUnscheduled = sortedEvents.filter(e => !assignments.has(e.id));
+  for (const event of stillUnscheduled) {
+    tryPlaceEvent(event);
+  }
+
+  // Build result
+  const assignmentList = [...assignments.values()].sort((a, b) => {
+    if (a.startTime !== b.startTime) return a.startTime - b.startTime;
+    return a.roomId.localeCompare(b.roomId);
+  });
+
+  const unscheduled = events
+    .filter(e => !assignments.has(e.id))
+    .map(e => e.id);
+
+  return {
+    assignments: assignmentList,
+    unscheduled,
+  };
+}
