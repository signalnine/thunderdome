@@ -0,0 +1,69 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { QueueManager } from '../queue-manager.js';
+
+describe('Phase 1: Basic FIFO Queue', () => {
+  let qm: QueueManager;
+
+  beforeEach(() => {
+    qm = new QueueManager();
+  });
+
+  it('should add a task and return a task object with required fields', () => {
+    const task = qm.add({ action: 'test' });
+    expect(task.id).toBeDefined();
+    expect(typeof task.id).toBe('string');
+    expect(task.status).toBe('pending');
+    expect(task.createdAt).toBeInstanceOf(Date);
+    expect(task.payload).toEqual({ action: 'test' });
+  });
+
+  it('should generate unique IDs for each task', () => {
+    const t1 = qm.add('task1');
+    const t2 = qm.add('task2');
+    expect(t1.id).not.toBe(t2.id);
+  });
+
+  it('should retrieve tasks in FIFO order', () => {
+    const t1 = qm.add('first');
+    const t2 = qm.add('second');
+    const t3 = qm.add('third');
+
+    const next1 = qm.next();
+    expect(next1?.id).toBe(t1.id);
+    expect(next1?.status).toBe('processing');
+
+    const next2 = qm.next();
+    expect(next2?.id).toBe(t2.id);
+
+    const next3 = qm.next();
+    expect(next3?.id).toBe(t3.id);
+  });
+
+  it('should return null when no tasks are available', () => {
+    expect(qm.next()).toBeNull();
+  });
+
+  it('should return null after all tasks are consumed', () => {
+    qm.add('only');
+    qm.next();
+    expect(qm.next()).toBeNull();
+  });
+
+  it('should track pending task count', () => {
+    expect(qm.size()).toBe(0);
+    qm.add('one');
+    expect(qm.size()).toBe(1);
+    qm.add('two');
+    expect(qm.size()).toBe(2);
+    qm.next();
+    expect(qm.size()).toBe(1);
+  });
+
+  it('should transition task from pending to processing when retrieved', () => {
+    const task = qm.add('data');
+    expect(task.status).toBe('pending');
+    const retrieved = qm.next();
+    expect(retrieved?.status).toBe('processing');
+    expect(retrieved?.id).toBe(task.id);
+  });
+});
