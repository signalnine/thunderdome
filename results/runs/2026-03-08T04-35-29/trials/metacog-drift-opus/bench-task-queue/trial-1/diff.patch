+import { describe, it, expect, beforeEach } from 'vitest';
+import { QueueManager } from '../queue-manager.js';
+
+describe('Phase 4: Delayed and Scheduled Tasks', () => {
+  let qm: QueueManager;
+
+  beforeEach(() => {
+    qm = new QueueManager();
+  });
+
+  it('should delay task by milliseconds', () => {
+    const task = qm.add('delayed', { delay: 5000 });
+    expect(task.availableAt.getTime()).toBeGreaterThan(task.createdAt.getTime());
+    expect(task.availableAt.getTime() - task.createdAt.getTime()).toBeCloseTo(5000, -2);
+  });
+
+  it('should not return delayed task before availability', () => {
+    qm.add('delayed', { delay: 60000 });
+    const now = new Date();
+    expect(qm.next('default', now)).toBeNull();
+  });
+
+  it('should return delayed task after availability', () => {
+    const task = qm.add('delayed', { delay: 1000 });
+    const future = new Date(Date.now() + 2000);
+    const retrieved = qm.next('default', future);
+    expect(retrieved?.id).toBe(task.id);
+  });
+
+  it('should schedule task for a specific time', () => {
+    const scheduledTime = new Date(Date.now() + 10000);
+    const task = qm.add('scheduled', { scheduledFor: scheduledTime });
+    expect(task.availableAt.getTime()).toBe(scheduledTime.getTime());
+  });
+
+  it('should prefer non-delayed tasks over unavailable delayed tasks', () => {
+    qm.add('delayed', { delay: 60000 });
+    qm.add('immediate');
+
+    const retrieved = qm.next();
+    expect(retrieved?.payload).toBe('immediate');
+  });
+
+  it('should order available delayed tasks by availability, priority, then FIFO', () => {
+    const baseTime = Date.now();
+    qm.add('later', { delay: 2000 });
+    qm.add('sooner', { delay: 1000 });
+    qm.add('immediate');
+
+    const future = new Date(baseTime + 3000);
+    expect(qm.next('default', future)?.payload).toBe('immediate');
+    expect(qm.next('default', future)?.payload).toBe('sooner');
+    expect(qm.next('default', future)?.payload).toBe('later');
+  });
+
+  it('should work with named queues', () => {
+    qm.add('delayed-email', { queue: 'emails', delay: 1000 });
+    qm.add('immediate-email', { queue: 'emails' });
+
+    expect(qm.next('emails')?.payload).toBe('immediate-email');
+    expect(qm.next('emails')).toBeNull(); // delayed not yet available
+  });
+
+  it('should count delayed tasks as pending', () => {
+    qm.add('delayed', { delay: 60000 });
+    expect(qm.size()).toBe(1);
+  });
+});
