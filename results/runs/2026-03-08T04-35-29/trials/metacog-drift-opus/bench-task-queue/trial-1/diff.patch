+import { describe, it, expect, beforeEach } from 'vitest';
+import { QueueManager } from '../queue-manager.js';
+
+describe('Phase 10: Recurring Tasks', () => {
+  let qm: QueueManager;
+
+  beforeEach(() => {
+    qm = new QueueManager();
+  });
+
+  it('should create a schedule', () => {
+    const id = qm.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });
+    expect(typeof id).toBe('string');
+
+    const schedules = qm.getSchedules();
+    expect(schedules).toHaveLength(1);
+    expect(schedules[0].cronExpression).toBe('*/5 * * * *');
+  });
+
+  it('should remove a schedule', () => {
+    const id = qm.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });
+    expect(qm.removeSchedule(id)).toBe(true);
+    expect(qm.getSchedules()).toHaveLength(0);
+  });
+
+  it('should fire every-N-minutes schedule', () => {
+    qm.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });
+
+    // Fire at minute 0 (divisible by 5)
+    const time = new Date(2024, 0, 1, 12, 0, 0);
+    const tasks = qm.tick(time);
+    expect(tasks).toHaveLength(1);
+    expect(tasks[0].payload).toEqual({ type: 'cleanup' });
+  });
+
+  it('should not fire if minute does not match', () => {
+    qm.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });
+
+    const time = new Date(2024, 0, 1, 12, 3, 0); // minute 3, not divisible by 5
+    const tasks = qm.tick(time);
+    expect(tasks).toHaveLength(0);
+  });
+
+  it('should not fire twice in the same minute', () => {
+    qm.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });
+
+    const time = new Date(2024, 0, 1, 12, 0, 0);
+    qm.tick(time);
+
+    const time2 = new Date(2024, 0, 1, 12, 0, 30);
+    const tasks = qm.tick(time2);
+    expect(tasks).toHaveLength(0);
+  });
+
+  it('should fire hourly schedule', () => {
+    qm.addSchedule('0 * * * *', 'default', { type: 'hourly' });
+
+    const onTheHour = new Date(2024, 0, 1, 13, 0, 0);
+    expect(qm.tick(onTheHour)).toHaveLength(1);
+
+    const notOnHour = new Date(2024, 0, 1, 13, 15, 0);
+    expect(qm.tick(notOnHour)).toHaveLength(0);
+  });
+
+  it('should fire daily schedule', () => {
+    qm.addSchedule('0 0 * * *', 'default', { type: 'daily' });
+
+    const midnight = new Date(2024, 0, 1, 0, 0, 0);
+    expect(qm.tick(midnight)).toHaveLength(1);
+
+    const afternoon = new Date(2024, 0, 1, 14, 30, 0);
+    expect(qm.tick(afternoon)).toHaveLength(0);
+  });
+
+  it('should enqueue to specified queue', () => {
+    qm.addSchedule('*/1 * * * *', 'emails', { type: 'sendDigest' });
+
+    const time = new Date(2024, 0, 1, 12, 0, 0);
+    const tasks = qm.tick(time);
+    expect(tasks[0].queueName).toBe('emails');
+    expect(qm.size('emails')).toBe(1);
+  });
+
+  it('should list all schedules', () => {
+    qm.addSchedule('*/5 * * * *', 'default', 'sched1');
+    qm.addSchedule('0 * * * *', 'emails', 'sched2');
+    qm.addSchedule('0 0 * * *', 'reports', 'sched3');
+
+    const schedules = qm.getSchedules();
+    expect(schedules).toHaveLength(3);
+  });
+
+  it('removing schedule should stop future occurrences', () => {
+    const id = qm.addSchedule('*/1 * * * *', 'default', 'data');
+    qm.removeSchedule(id);
+
+    const time = new Date(2024, 0, 1, 12, 0, 0);
+    expect(qm.tick(time)).toHaveLength(0);
+  });
+});
