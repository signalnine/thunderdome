@@ -0,0 +1,81 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { QueueManager } from '../queue-manager.js';
+
+describe('Phase 8: Concurrency Control', () => {
+  let qm: QueueManager;
+
+  beforeEach(() => {
+    qm = new QueueManager();
+  });
+
+  it('should limit concurrent processing', () => {
+    qm.setConcurrency('default', 2);
+    qm.add('task1');
+    qm.add('task2');
+    qm.add('task3');
+
+    const t1 = qm.next();
+    const t2 = qm.next();
+    expect(t1).not.toBeNull();
+    expect(t2).not.toBeNull();
+
+    // Third should be blocked by concurrency
+    expect(qm.next()).toBeNull();
+  });
+
+  it('should free slot when task completes', () => {
+    qm.setConcurrency('default', 1);
+    const t1 = qm.add('task1');
+    qm.add('task2');
+
+    qm.next();
+    expect(qm.next()).toBeNull();
+
+    qm.complete(t1.id);
+    const t2 = qm.next();
+    expect(t2).not.toBeNull();
+    expect(t2?.payload).toBe('task2');
+  });
+
+  it('should free slot when task fails', () => {
+    qm.setConcurrency('default', 1);
+    const t1 = qm.add('task1', { maxRetries: 1 });
+    qm.add('task2');
+
+    qm.next();
+    expect(qm.next()).toBeNull();
+
+    qm.fail(t1.id, new Error('fail'));
+
+    // t1 is now failed (exhausted retries), slot should be free
+    const t2 = qm.next();
+    expect(t2).not.toBeNull();
+    expect(t2?.payload).toBe('task2');
+  });
+
+  it('should default to unlimited concurrency', () => {
+    expect(qm.getConcurrency('default')).toBe(Infinity);
+  });
+
+  it('should query active count', () => {
+    qm.add('task1');
+    qm.add('task2');
+
+    expect(qm.getActiveCount('default')).toBe(0);
+
+    qm.next();
+    expect(qm.getActiveCount('default')).toBe(1);
+
+    qm.next();
+    expect(qm.getActiveCount('default')).toBe(2);
+  });
+
+  it('should still respect priority when concurrency limited', () => {
+    qm.setConcurrency('default', 1);
+    qm.add('low', { priority: 10 });
+    qm.add('high', { priority: 1 });
+
+    const t = qm.next();
+    expect(t?.payload).toBe('high');
+  });
+});
