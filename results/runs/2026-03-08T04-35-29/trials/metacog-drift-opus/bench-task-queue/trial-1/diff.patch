ons);\n\n    // Check circular dependencies after creating (using the task's id)\n    if (task.dependencies.length > 0) {\n      const hasCircular = detectCircularDependencies(\n        task.id,\n        task.dependencies,\n        (id: string) => {\n          const t = this._findTask(id);\n          return t ? t.dependencies : [];\n        }\n      );\n      if (hasCircular) {\n        // Remove the task we just added\n        queue.cancel(task.id);\n        throw new Error('Circular dependency detected');\n      }\n    }\n\n    return task;\n  }\n\n  next(queueName = 'default', now?: Date): Task | null {\n    const queue = this._queues.get(queueName);\n    if (!queue) return null;\n    return queue.next(now);\n  }\n\n  size(queueName = 'default'): number {\n    const queue = this._queues.get(queueName);\n    if (!queue) return 0;\n    return queue.size();\n  }\n\n  getQueues(): string[] {\n    return Array.from(this._queues.keys());\n  }\n\n  getQueue(name: string): Queue | undefined {\n    return this._queues.get(name);\n  }\n\n  // ─── Phase 5: Complete / Fail ──────────────────────────────────────\n\n  complete(taskId: string): void {\n    const queue = this._findQueueForTask(taskId);\n    if (!queue) throw new Error(`Task ${taskId} not found`);\n    queue.complete(taskId);\n  }\n\n  fail(taskId: string, error?: Error): void {\n    const queue = this._findQueueForTask(taskId);\n    if (!queue) throw new Error(`Task ${taskId} not found`);\n    queue.fail(taskId, error);\n  }\n\n  // ─── Phase 6: Dead Letter Queue ───────────────────────────────────\n\n  getDeadLetterTasks(queueName = 'default'): TaskData[] {\n    const queue = this._queues.get(queueName);\n    if (!queue) return [];\n    return queue.getDeadLetterTasks();\n  }\n\n  requeue(taskId: string, queueName = 'default'): Task | null {\n    const queue = this._queues.get(queueName);\n    if (!queue) return null;\n    const task = queue.requeue(taskId);\n    if (task) {\n      queue.addExisting(task);\n    }\n    return task;\n  }\n\n  clearDeadLetterQueue(queueName = 'default'): number {\n    const queue = this._queues.get(queueName);\n    if (!queue) return 0;\n    return queue.clearDeadLetterQueue();\n  }\n\n  // ─── Phase 7: Task Dependencies ───────────────────────────────────\n\n  getTask(taskId: string): Task | undefined {\n    return this._findTask(taskId);\n  }\n\n  getDependencyStatus(taskId: string): { dependency: string; status: string }[] {\n    const task = this._findTask(taskId);\n    if (!task) throw new Error(`Task ${taskId} not found`);\n\n    return task.dependencies.map(depId => {\n      const dep = this._findTask(depId);\n      return {\n        dependency: depId,\n        status: dep ? dep.status : 'not_found',\n      };\n    });\n  }\n\n  // ─── Phase 8: Concurrency Control ─────────────────────────────────\n\n  setConcurrency(queueName: string, max: number): void {\n    const queue = this._getOrCreateQueue(queueName);\n    queue.maxConcurrency = max;\n  }\n\n  getConcurrency(queueName: string): number {\n    const queue = this._queues.get(queueName);\n    if (!queue) return Infinity;\n    return queue.maxConcurrency;\n  }\n\n  getActiveCount(queueName: string): number {\n    const queue = this._queues.get(queueName);\n    if (!queue) return 0;\n    return queue.activeCount;\n  }\n\n  // ─── Phase 9: Progress & Cancellation ──────────────────────────────\n\n  reportProgress(taskId: string, percent: number, message?: string): void {\n    const task = this._findTask(taskId);\n    if (!task) throw new Error(`Task ${taskId} not found`);\n    task.reportProgress(percent, message);\n  }\n\n  getProgress(taskId: string): { progress: number; message?: string } {\n    const task = this._findTask(taskId);\n    if (!task) throw new Error(`Task ${taskId} not found`);\n    return { progress: task.progress, message: task.progressMessage };\n  }\n\n  onProgress(taskId: string, callback: ProgressCallback): string {\n    const task = this._findTask(taskId);\n    if (!task) throw new Error(`Task ${taskId} not found`);\n    return task.onProgress(callback);\n  }\n\n  offProgress(taskId: string, subscriptionId: string): boolean {\n    const task = this._findTask(taskId);\n    if (!task) return false;\n    return task.offProgress(subscriptionId);\n  }\n\n  cancel(taskId: string): boolean {\n    const queue = this._findQueueForTask(taskId);\n    if (!queue) return false;\n    return queue.cancel(taskId);\n  }\n\n  // ─── Phase 10: Recurring Tasks ────────────────────────────────────\n\n  addSchedule(\n    cronExpression: string,\n    queueName: string,\n    payload: unknown,\n    taskOptions?: Omit<TaskOptions, 'queue' | 'dependencies' | 'delay' | 'scheduledFor'>\n  ): string {\n    if (this._isShuttingDown) {\n      throw new Error('Queue manager is shutting down.');\n    }\n    const id = generateId();\n    this._schedules.set(id, {\n      id,\n      cronExpression,\n      queueName,\n      payload,\n      taskOptions,\n    });\n    return id;\n  }\n\n  removeSchedule(scheduleId: string): boolean {\n    return this._schedules.delete(scheduleId);\n  }\n\n  getSchedules(): ScheduleEntry[] {\n    return Array.from(this._schedules.values());\n  }\n\n  tick(now: Date = new Date()): Task[] {\n    if (this._isShuttingDown) return [];\n\n    const created: Task[] = [];\n    for (const schedule of this._schedules.values()) {\n      if (cronShouldFire(schedule.cronExpression, now, schedule.lastRun)) {\n        const task = this.add(schedule.payload, {\n          ...schedule.taskOptions,\n          queue: schedule.queueName,\n        });\n        schedule.lastRun = now;\n        created.push(task);\n      }\n    }\n    return created;\n  }\n\n  // ─── Phase 11: Middleware ──────────────────────────────────────────\n\n  use(queueName: string, middleware: MiddlewareFn): void {\n    const queue = this._getOrCreateQueue(queueName);\n    queue.use(middleware);\n  }\n\n  setProcessor(queueName: string, fn: ProcessorFn): void {\n    const queue = this._getOrCreateQueue(queueName);\n    queue.process(fn);\n  }\n\n  async processNext(queueName = 'default', now?: Date): Promise<Task | null> {\n    const queue = this._queues.get(queueName);\n    if (!queue) return null;\n\n    const task = queue.next(now);\n    if (!task) return null;\n\n    const middlewares = queue.middlewares;\n    const processor = queue.processor;\n\n    try {\n      await this._executeMiddlewareChain(task, middlewares, processor);\n      if (task.status === 'processing') {\n        queue.complete(task.id);\n      }\n    } catch (err) {\n      if (task.status === 'processing') {\n        queue.fail(task.id, err instanceof Error ? err : new Error(String(err)));\n      }\n    }\n\n    return task;\n  }\n\n  private async _executeMiddlewareChain(\n    task: Task,\n    middlewares: MiddlewareFn[],\n    processor: ProcessorFn | null\n  ): Promise<void> {\n    let index = 0;\n\n    const executeNext = async (): Promise<void> => {\n      if (index < middlewares.length) {\n        const mw = middlewares[index++];\n        await mw(task.toData(), executeNext);\n      } else if (processor) {\n        await processor(task.toData());\n      }\n    };\n\n    await executeNext();\n  }\n\n  // ─── Phase 12: Graceful Shutdown ───────────────────────────────────\n\n  async shutdown(timeout = 30000): Promise<ShutdownResult> {\n    if (this._shutdownPromise) {\n      return this._shutdownPromise;\n    }\n\n    this._isShuttingDown = true;\n    this._shutdownPromise = this._performShutdown(timeout);\n    return this._shutdownPromise;\n  }\n\n  onShutdown(callback: (result: ShutdownResult) => void): void {\n    this._shutdownCallbacks.push(callback);\n  }\n\n  get isShuttingDown(): boolean {\n    return this._isShuttingDown;\n  }\n\n  private async _performShutdown(timeout: number): Promise<ShutdownResult> {\n    const startTime = Date.now();\n    let completed = 0;\n    let forceCancelled = 0;\n\n    // Collect all processing tasks\n    const processingTasks: { task: Task; queue: Queue }[] = [];\n    for (const queue of this._queues.values()) {\n      for (const task of queue.getProcessingTasks()) {\n        processingTasks.push({ task, queue });\n      }\n    }\n\n    if (processingTasks.length === 0) {\n      const result: ShutdownResult = { completed: 0, forceCancelled: 0, duration: Date.now() - startTime };\n      this._notifyShutdownCallbacks(result);\n      return result;\n    }\n\n    // Wait for processing tasks to complete, with timeout\n    const waitPromise = new Promise<void>((resolve) => {\n      const check = () => {\n        const stillProcessing = processingTasks.filter(\n          ({ task }) => task.status === 'processing'\n        );\n        if (stillProcessing.length === 0) {\n          resolve();\n          return;\n        }\n        setTimeout(check, 10);\n      };\n      check();\n    });\n\n    const timeoutPromise = new Promise<'timeout'>((resolve) => {\n      setTimeout(() => resolve('timeout'), timeout);\n    });\n\n    const raceResult = await Promise.race([waitPromise, timeoutPromise]);\n\n    // Count completed\n    for (const { task } of processingTasks) {\n      if (task.status === 'completed') {\n        completed++;\n      }\n    }\n\n    // Force-cancel remaining processing tasks\n    if (raceResult === 'timeout') {\n      for (const { task, queue } of processingTasks) {\n        if (task.status === 'processing') {\n          task.status = 'cancelled';\n          queue.decrementActive();\n          forceCancelled++;\n        }\n      }\n    }\n\n    const result: ShutdownResult = {\n      completed,\n      forceCancelled,\n      duration: Date.now() - startTime,\n    };\n\n    this._notifyShutdownCallbacks(result);\n    return result;\n  }\n\n  private _notifyShutdownCallbacks(result: ShutdownResult): void {\n    for (const cb of this._shutdownCallbacks) {\n      try { cb(result); } catch { /* ignore */ }\n    }\n  }\n\n  // ─── Internal helpers ──────────────────────────────────────────────\n\n  private _findTask(taskId: string): Task | undefined {\n    for (const queue of this._queues.values()) {\n      const task = queue.getTask(taskId);\n      if (task) return task;\n    }\n    return undefined;\n  }\n\n  private _findQueueForTask(taskId: string): Queue | undefined {\n    for (const queue of this._queues.values()) {\n      if (queue.getTask(taskId)) return queue;\n    }\n    return undefined;\n  }\n}\n","structuredPatch":[],"originalFile":null}}
