@@ -0,0 +1,71 @@
+import { randomUUID } from 'node:crypto';
+
+export function generateId(): string {
+  return randomUUID();
+}
+
+/**
+ * Parse a simple cron subset and determine if it should fire given the current time.
+ * Supported patterns:
+ *   - `* /N * * * *` (every N minutes) -- written without the space
+ *   - `0 * * * *` (hourly at :00)
+ *   - `0 0 * * *` (daily at midnight)
+ *   - `M H * * *` (specific minute and hour)
+ *   - `* /N H * * *` variations
+ */
+export function cronShouldFire(expression: string, now: Date, lastRun?: Date): boolean {
+  const parts = expression.trim().split(/\s+/);
+  if (parts.length !== 5) return false;
+
+  const [minutePart, hourPart] = parts;
+
+  const minuteMatch = matchCronField(minutePart, now.getMinutes());
+  const hourMatch = matchCronField(hourPart, now.getHours());
+
+  if (!minuteMatch || !hourMatch) return false;
+
+  // Don't fire if we already fired during this same minute
+  if (lastRun) {
+    const lastMinute = Math.floor(lastRun.getTime() / 60000);
+    const nowMinute = Math.floor(now.getTime() / 60000);
+    if (lastMinute === nowMinute) return false;
+  }
+
+  return true;
+}
+
+function matchCronField(field: string, value: number): boolean {
+  if (field === '*') return true;
+
+  // */N pattern
+  if (field.startsWith('*/')) {
+    const interval = parseInt(field.slice(2), 10);
+    if (isNaN(interval) || interval <= 0) return false;
+    return value % interval === 0;
+  }
+
+  // Exact value
+  const exact = parseInt(field, 10);
+  if (isNaN(exact)) return false;
+  return value === exact;
+}
+
+export function detectCircularDependencies(
+  taskId: string,
+  dependencies: string[],
+  getDependencies: (id: string) => string[]
+): boolean {
+  const visited = new Set<string>();
+  const stack = [...dependencies];
+
+  while (stack.length > 0) {
+    const current = stack.pop()!;
+    if (current === taskId) return true;
+    if (visited.has(current)) continue;
+    visited.add(current);
+    const deps = getDependencies(current);
+    stack.push(...deps);
+  }
+
+  return false;
+}
