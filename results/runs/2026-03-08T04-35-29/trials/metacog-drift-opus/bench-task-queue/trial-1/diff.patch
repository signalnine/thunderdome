@@ -0,0 +1,104 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { QueueManager } from '../queue-manager.js';
+
+describe('Phase 5: Retry with Backoff', () => {
+  let qm: QueueManager;
+
+  beforeEach(() => {
+    qm = new QueueManager();
+  });
+
+  it('should complete a processing task', () => {
+    const task = qm.add('data');
+    qm.next();
+    qm.complete(task.id);
+    expect(task.status).toBe('completed');
+  });
+
+  it('should fail a processing task and retry if retries remain', () => {
+    const task = qm.add('data', { maxRetries: 3 });
+    qm.next();
+    qm.fail(task.id, new Error('oops'));
+
+    expect(task.status).toBe('pending');
+    expect(task.attempt).toBe(1);
+    expect(task.failureCount).toBe(1);
+  });
+
+  it('should apply exponential backoff on retries', () => {
+    const task = qm.add('data', { maxRetries: 3, backoffDelay: 1000 });
+
+    // Attempt 1
+    qm.next();
+    const beforeFail = Date.now();
+    qm.fail(task.id, new Error('fail1'));
+    // After first failure, delay = 1000 * 2^0 = 1000ms
+    expect(task.availableAt.getTime()).toBeGreaterThanOrEqual(beforeFail + 900);
+    expect(task.availableAt.getTime()).toBeLessThanOrEqual(beforeFail + 1200);
+
+    // Attempt 2
+    const future1 = new Date(Date.now() + 2000);
+    qm.next('default', future1);
+    const beforeFail2 = Date.now();
+    qm.fail(task.id, new Error('fail2'));
+    // After second failure, delay = 1000 * 2^1 = 2000ms
+    expect(task.availableAt.getTime()).toBeGreaterThanOrEqual(beforeFail2 + 1800);
+  });
+
+  it('should exhaust retries and mark as failed', () => {
+    const task = qm.add('data', { maxRetries: 2 });
+
+    // Attempt 1
+    qm.next();
+    qm.fail(task.id, new Error('fail1'));
+
+    // Attempt 2 (last retry)
+    const future = new Date(Date.now() + 10000);
+    qm.next('default', future);
+    qm.fail(task.id, new Error('fail2'));
+
+    expect(task.status).toBe('failed');
+    expect(task.attempt).toBe(2);
+  });
+
+  it('should default to 3 max retries', () => {
+    const task = qm.add('data');
+    expect(task.maxRetries).toBe(3);
+  });
+
+  it('should default to 1000ms base delay', () => {
+    const task = qm.add('data');
+    expect(task.backoffDelay).toBe(1000);
+  });
+
+  it('should track attempt count', () => {
+    const task = qm.add('data', { maxRetries: 5 });
+
+    qm.next();
+    expect(task.attempt).toBe(1);
+    qm.fail(task.id, new Error('fail'));
+
+    const future = new Date(Date.now() + 10000);
+    qm.next('default', future);
+    expect(task.attempt).toBe(2);
+  });
+
+  it('should keep original queue and priority on retry', () => {
+    const task = qm.add('data', { queue: 'myqueue', priority: 2, maxRetries: 3 });
+    qm.next('myqueue');
+    qm.fail(task.id, new Error('fail'));
+
+    expect(task.queueName).toBe('myqueue');
+    expect(task.priority).toBe(2);
+  });
+
+  it('should throw when completing non-processing task', () => {
+    const task = qm.add('data');
+    expect(() => qm.complete(task.id)).toThrow();
+  });
+
+  it('should throw when failing non-processing task', () => {
+    const task = qm.add('data');
+    expect(() => qm.fail(task.id)).toThrow();
+  });
+});
