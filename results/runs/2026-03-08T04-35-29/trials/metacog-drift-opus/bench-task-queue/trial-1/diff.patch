+import { describe, it, expect, beforeEach } from 'vitest';
+import { QueueManager } from '../queue-manager.js';
+
+describe('Phase 12: Graceful Shutdown', () => {
+  let qm: QueueManager;
+
+  beforeEach(() => {
+    qm = new QueueManager();
+  });
+
+  it('should reject new tasks after shutdown', async () => {
+    await qm.shutdown();
+    expect(() => qm.add('data')).toThrow(/shutting down/i);
+  });
+
+  it('should complete immediately with no processing tasks', async () => {
+    const result = await qm.shutdown();
+    expect(result.completed).toBe(0);
+    expect(result.forceCancelled).toBe(0);
+    expect(typeof result.duration).toBe('number');
+  });
+
+  it('should wait for processing tasks to complete', async () => {
+    const task = qm.add('data');
+    qm.next();
+
+    // Complete the task after a short delay
+    setTimeout(() => {
+      qm.complete(task.id);
+    }, 50);
+
+    const result = await qm.shutdown(5000);
+    expect(result.completed).toBe(1);
+    expect(result.forceCancelled).toBe(0);
+  });
+
+  it('should force-cancel tasks exceeding timeout', async () => {
+    qm.add('slow-task');
+    qm.next(); // now processing, will never complete
+
+    const result = await qm.shutdown(50); // very short timeout
+    expect(result.forceCancelled).toBe(1);
+  });
+
+  it('should register shutdown callbacks', async () => {
+    let callbackResult: { completed: number; forceCancelled: number } | null = null;
+
+    qm.onShutdown((result) => {
+      callbackResult = { completed: result.completed, forceCancelled: result.forceCancelled };
+    });
+
+    await qm.shutdown();
+
+    expect(callbackResult).not.toBeNull();
+    expect(callbackResult!.completed).toBe(0);
+  });
+
+  it('should return same result for multiple shutdown calls', async () => {
+    const result1Promise = qm.shutdown();
+    const result2Promise = qm.shutdown();
+
+    const [result1, result2] = await Promise.all([result1Promise, result2Promise]);
+    expect(result1).toBe(result2); // same object reference
+  });
+
+  it('should report isShuttingDown status', async () => {
+    expect(qm.isShuttingDown).toBe(false);
+    const promise = qm.shutdown();
+    expect(qm.isShuttingDown).toBe(true);
+    await promise;
+    expect(qm.isShuttingDown).toBe(true);
+  });
+
+  it('should include duration in shutdown result', async () => {
+    const result = await qm.shutdown();
+    expect(result.duration).toBeGreaterThanOrEqual(0);
+  });
+});
