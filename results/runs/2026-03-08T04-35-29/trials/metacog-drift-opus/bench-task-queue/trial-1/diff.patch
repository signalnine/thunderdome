fault')).toBe(1);\n\n    qm.next();\n    expect(qm.getActiveCount('default')).toBe(2);\n  });\n\n  it('should still respect priority when concurrency limited', () => {\n    qm.setConcurrency('default', 1);\n    qm.add('low', { priority: 10 });\n    qm.add('high', { priority: 1 });\n\n    const t = qm.next();\n    expect(t?.payload).toBe('high');\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1188,"cache_read_input_tokens":38375,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1188},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"506dd83c-382a-45ba-8c08-6cb3db03e95b","uuid":"9100ee26-e24c-4a4e-b295-ed52e67ad76b"}
