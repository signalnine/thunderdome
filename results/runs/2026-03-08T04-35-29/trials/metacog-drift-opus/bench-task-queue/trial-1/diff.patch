+import { describe, it, expect, beforeEach } from 'vitest';
+import { QueueManager } from '../queue-manager.js';
+
+describe('Phase 3: Priority', () => {
+  let qm: QueueManager;
+
+  beforeEach(() => {
+    qm = new QueueManager();
+  });
+
+  it('should default priority to 5', () => {
+    const task = qm.add('data');
+    expect(task.priority).toBe(5);
+  });
+
+  it('should set custom priority', () => {
+    const task = qm.add('urgent', { priority: 1 });
+    expect(task.priority).toBe(1);
+  });
+
+  it('should return higher-priority tasks first', () => {
+    qm.add('low', { priority: 10 });
+    qm.add('high', { priority: 1 });
+    qm.add('medium', { priority: 5 });
+
+    const t1 = qm.next();
+    expect(t1?.payload).toBe('high');
+    expect(t1?.priority).toBe(1);
+
+    const t2 = qm.next();
+    expect(t2?.payload).toBe('medium');
+
+    const t3 = qm.next();
+    expect(t3?.payload).toBe('low');
+  });
+
+  it('should use FIFO for same priority', () => {
+    qm.add('first', { priority: 3 });
+    qm.add('second', { priority: 3 });
+    qm.add('third', { priority: 3 });
+
+    expect(qm.next()?.payload).toBe('first');
+    expect(qm.next()?.payload).toBe('second');
+    expect(qm.next()?.payload).toBe('third');
+  });
+
+  it('should throw for invalid priority', () => {
+    expect(() => qm.add('data', { priority: 0 })).toThrow();
+    expect(() => qm.add('data', { priority: 11 })).toThrow();
+    expect(() => qm.add('data', { priority: -1 })).toThrow();
+    expect(() => qm.add('data', { priority: 1.5 })).toThrow();
+  });
+
+  it('should have per-queue priority ordering', () => {
+    qm.add('q1-low', { queue: 'q1', priority: 10 });
+    qm.add('q1-high', { queue: 'q1', priority: 1 });
+    qm.add('q2-low', { queue: 'q2', priority: 10 });
+    qm.add('q2-high', { queue: 'q2', priority: 1 });
+
+    expect(qm.next('q1')?.payload).toBe('q1-high');
+    expect(qm.next('q2')?.payload).toBe('q2-high');
+  });
+});
