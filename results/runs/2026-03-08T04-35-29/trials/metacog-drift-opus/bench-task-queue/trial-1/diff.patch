new file mode 100644
index 0000000..ae6e82a
--- /dev/null
+++ b/src/queue.ts
@@ -0,0 +1,216 @@
+import { Task } from './task.js';
+import type { TaskData, TaskOptions, MiddlewareFn, ProcessorFn } from './types.js';
+
+export class Queue {
+  readonly name: string;
+  private _tasks: Map<string, Task> = new Map();
+  private _deadLetterQueue: Task[] = [];
+  private _maxConcurrency: number = Infinity;
+  private _activeCount: number = 0;
+  private _middlewares: MiddlewareFn[] = [];
+  private _processor: ProcessorFn | null = null;
+
+  constructor(name: string) {
+    this.name = name;
+  }
+
+  add(payload: unknown, options: TaskOptions = {}): Task {
+    const task = new Task(payload, options, this.name);
+    this._tasks.set(task.id, task);
+    return task;
+  }
+
+  /** Used internally to re-add a retry task */
+  addExisting(task: Task): void {
+    this._tasks.set(task.id, task);
+  }
+
+  getTask(id: string): Task | undefined {
+    return this._tasks.get(id);
+  }
+
+  next(now: Date = new Date()): Task | null {
+    // Check concurrency limit
+    if (this._activeCount >= this._maxConcurrency) {
+      return null;
+    }
+
+    const candidates = this._getPendingAvailableUnblocked(now);
+    if (candidates.length === 0) return null;
+
+    // Sort: priority ascending (1 is highest), then availability time, then sequence (FIFO)
+    candidates.sort((a, b) => {
+      if (a.priority !== b.priority) return a.priority - b.priority;
+      const aTime = a.availableAt.getTime();
+      const bTime = b.availableAt.getTime();
+      if (aTime !== bTime) return aTime - bTime;
+      return a.sequence - b.sequence;
+    });
+
+    const task = candidates[0];
+    task.status = 'processing';
+    task.attempt++;
+    this._activeCount++;
+    return task;
+  }
+
+  private _getPendingAvailableUnblocked(now: Date): Task[] {
+    const result: Task[] = [];
+    for (const task of this._tasks.values()) {
+      if (task.status !== 'pending') continue;
+      if (!task.isAvailable(now)) continue;
+      if (!this._areDependenciesMet(task)) continue;
+      result.push(task);
+    }
+    return result;
+  }
+
+  private _areDependenciesMet(task: Task): boolean {
+    if (task.dependencies.length === 0) return true;
+    for (const depId of task.dependencies) {
+      const dep = this._tasks.get(depId);
+      if (!dep || dep.status !== 'completed') return false;
+    }
+    return true;
+  }
+
+  complete(taskId: string): void {
+    const task = this._tasks.get(taskId);
+    if (!task) throw new Error(`Task ${taskId} not found`);
+    if (task.status !== 'processing') throw new Error(`Task ${taskId} is not processing (status: ${task.status})`);
+    task.status = 'completed';
+    task.progress = 100;
+    this._activeCount = Math.max(0, this._activeCount - 1);
+  }
+
+  fail(taskId: string, error?: Error): void {
+    const task = this._tasks.get(taskId);
+    if (!task) throw new Error(`Task ${taskId} not found`);
+    if (task.status !== 'processing') throw new Error(`Task ${taskId} is not processing (status: ${task.status})`);
+
+    task.error = error;
+    task.failureCount++;
+    this._activeCount = Math.max(0, this._activeCount - 1);
+
+    if (task.attempt < task.maxRetries) {
+      // Retry with exponential backoff
+      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);
+      task.availableAt = new Date(Date.now() + delay);
+      task.status = 'pending';
+      task.progress = 0;
+      task.progressMessage = undefined;
+    } else {
+      // Move to dead letter queue
+      task.status = 'failed';
+      this._deadLetterQueue.push(task);
+    }
+  }
+
+  cancel(taskId: string): boolean {
+    const task = this._tasks.get(taskId);
+    if (!task) return false;
+    if (task.status !== 'pending' && task.status !== 'processing') return false;
+
+    if (task.status === 'processing') {
+      this._activeCount = Math.max(0, this._activeCount - 1);
+    }
+    task.status = 'cancelled';
+    return true;
+  }
+
+  size(): number {
+    let count = 0;
+    for (const task of this._tasks.values()) {
+      if (task.status === 'pending') count++;
+    }
+    return count;
+  }
+
+  // Dead Letter Queue methods
+  getDeadLetterTasks(): TaskData[] {
+    return this._deadLetterQueue.map(t => t.toData());
+  }
+
+  requeue(taskId: string): Task | null {
+    const index = this._deadLetterQueue.findIndex(t => t.id === taskId);
+    if (index === -1) return null;
+
+    const task = this._deadLetterQueue[index];
+    this._deadLetterQueue.splice(index, 1);
+
+    task.status = 'pending';
+    task.attempt = 0;
+    task.progress = 0;
+    task.progressMessage = undefined;
+    task.error = undefined;
+    task.availableAt = new Date();
+
+    return task;
+  }
+
+  clearDeadLetterQueue(): number {
+    const count = this._deadLetterQueue.length;
+    this._deadLetterQueue = [];
+    return count;
+  }
+
+  // Concurrency control
+  get maxConcurrency(): number {
+    return this._maxConcurrency;
+  }
+
+  set maxConcurrency(value: number) {
+    if (value < 1) throw new Error('Max concurrency must be at least 1');
+    this._maxConcurrency = value;
+  }
+
+  setUnlimitedConcurrency(): void {
+    this._maxConcurrency = Infinity;
+  }
+
+  get activeCount(): number {
+    return this._activeCount;
+  }
+
+  // Middleware
+  use(middleware: MiddlewareFn): void {
+    this._middlewares.push(middleware);
+  }
+
+  get middlewares(): MiddlewareFn[] {
+    return this._middlewares;
+  }
+
+  // Processor
+  process(fn: ProcessorFn): void {
+    this._processor = fn;
+  }
+
+  get processor(): ProcessorFn | null {
+    return this._processor;
+  }
+
+  /** Get all processing tasks */
+  getProcessingTasks(): Task[] {
+    const result: Task[] = [];
+    for (const task of this._tasks.values()) {
+      if (task.status === 'processing') result.push(task);
+    }
+    return result;
+  }
+
+  /** Check if a task dependency exists (for cross-queue dependency checking) */
+  hasTask(taskId: string): boolean {
+    return this._tasks.has(taskId);
+  }
+
+  /** Decrement active count externally (for force-cancel during shutdown) */
+  decrementActive(): void {
+    this._activeCount = Math.max(0, this._activeCount - 1);
+  }
+
+  /** Get all tasks for inspection */
+  getAllTasks(): Task[] {
+    return Array.from(this._tasks.values());
+  }
+}
