@@ -0,0 +1,117 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { QueueManager } from '../queue-manager.js';
+
+describe('Phase 9: Progress Tracking and Cancellation', () => {
+  let qm: QueueManager;
+
+  beforeEach(() => {
+    qm = new QueueManager();
+  });
+
+  describe('Progress', () => {
+    it('should report progress on processing task', () => {
+      const task = qm.add('data');
+      qm.next();
+
+      qm.reportProgress(task.id, 50, 'halfway done');
+      const progress = qm.getProgress(task.id);
+      expect(progress.progress).toBe(50);
+      expect(progress.message).toBe('halfway done');
+    });
+
+    it('should clamp progress to 0-100', () => {
+      const task = qm.add('data');
+      qm.next();
+
+      qm.reportProgress(task.id, 150);
+      expect(qm.getProgress(task.id).progress).toBe(100);
+
+      qm.reportProgress(task.id, -10);
+      expect(qm.getProgress(task.id).progress).toBe(0);
+    });
+
+    it('should subscribe to progress updates', () => {
+      const task = qm.add('data');
+      qm.next();
+
+      const updates: Array<{ progress: number; message?: string }> = [];
+      qm.onProgress(task.id, (progress, message) => {
+        updates.push({ progress, message });
+      });
+
+      qm.reportProgress(task.id, 25, 'quarter');
+      qm.reportProgress(task.id, 50, 'half');
+      qm.reportProgress(task.id, 75, 'three quarters');
+
+      expect(updates).toHaveLength(3);
+      expect(updates[0]).toEqual({ progress: 25, message: 'quarter' });
+      expect(updates[1]).toEqual({ progress: 50, message: 'half' });
+    });
+
+    it('should cancel progress subscription', () => {
+      const task = qm.add('data');
+      qm.next();
+
+      const updates: number[] = [];
+      const subId = qm.onProgress(task.id, (progress) => {
+        updates.push(progress);
+      });
+
+      qm.reportProgress(task.id, 25);
+      expect(updates).toHaveLength(1);
+
+      qm.offProgress(task.id, subId);
+      qm.reportProgress(task.id, 50);
+      expect(updates).toHaveLength(1); // no new update
+    });
+  });
+
+  describe('Cancellation', () => {
+    it('should cancel a pending task', () => {
+      const task = qm.add('data');
+      expect(qm.cancel(task.id)).toBe(true);
+      expect(task.status).toBe('cancelled');
+      expect(qm.size()).toBe(0);
+    });
+
+    it('should cancel a processing task', () => {
+      const task = qm.add('data');
+      qm.next();
+      expect(qm.cancel(task.id)).toBe(true);
+      expect(task.status).toBe('cancelled');
+    });
+
+    it('should not cancel a completed task', () => {
+      const task = qm.add('data');
+      qm.next();
+      qm.complete(task.id);
+      expect(qm.cancel(task.id)).toBe(false);
+    });
+
+    it('should not cancel a failed task', () => {
+      const task = qm.add('data', { maxRetries: 1 });
+      qm.next();
+      qm.fail(task.id, new Error('fail'));
+      expect(qm.cancel(task.id)).toBe(false);
+    });
+
+    it('cancelled pending task should not be returned by next', () => {
+      const t1 = qm.add('task1');
+      qm.add('task2');
+
+      qm.cancel(t1.id);
+      const next = qm.next();
+      expect(next?.payload).toBe('task2');
+    });
+
+    it('cancelled task should not be retried', () => {
+      const task = qm.add('data', { maxRetries: 3 });
+      qm.next();
+      qm.cancel(task.id);
+
+      // Should not be retrievable
+      expect(qm.next()).toBeNull();
+      expect(task.status).toBe('cancelled');
+    });
+  });
+});
