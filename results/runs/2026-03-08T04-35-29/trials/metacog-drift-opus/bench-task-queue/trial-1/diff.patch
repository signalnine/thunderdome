+import { describe, it, expect, beforeEach } from 'vitest';
+import { QueueManager } from '../queue-manager.js';
+
+describe('Phase 11: Middleware Pipeline', () => {
+  let qm: QueueManager;
+
+  beforeEach(() => {
+    qm = new QueueManager();
+  });
+
+  it('should register and execute middleware before processor', async () => {
+    const order: string[] = [];
+
+    qm.use('default', async (_task, next) => {
+      order.push('middleware1');
+      await next();
+    });
+
+    qm.setProcessor('default', async () => {
+      order.push('processor');
+    });
+
+    qm.add('data');
+    await qm.processNext('default');
+
+    expect(order).toEqual(['middleware1', 'processor']);
+  });
+
+  it('should execute middleware in order', async () => {
+    const order: string[] = [];
+
+    qm.use('default', async (_task, next) => {
+      order.push('first');
+      await next();
+    });
+
+    qm.use('default', async (_task, next) => {
+      order.push('second');
+      await next();
+    });
+
+    qm.use('default', async (_task, next) => {
+      order.push('third');
+      await next();
+    });
+
+    qm.setProcessor('default', async () => {
+      order.push('processor');
+    });
+
+    qm.add('data');
+    await qm.processNext('default');
+
+    expect(order).toEqual(['first', 'second', 'third', 'processor']);
+  });
+
+  it('should skip processing if middleware does not call next', async () => {
+    const order: string[] = [];
+
+    qm.use('default', async (_task, _next) => {
+      order.push('gatekeeper');
+      // Not calling next - skipping
+    });
+
+    qm.setProcessor('default', async () => {
+      order.push('processor');
+    });
+
+    qm.add('data');
+    await qm.processNext('default');
+
+    expect(order).toEqual(['gatekeeper']);
+  });
+
+  it('should mark task as failed if middleware throws', async () => {
+    qm.use('default', async () => {
+      throw new Error('middleware error');
+    });
+
+    qm.setProcessor('default', async () => {
+      // should not reach
+    });
+
+    const task = qm.add('data', { maxRetries: 1 });
+    await qm.processNext('default');
+
+    expect(task.status).toBe('failed');
+    expect(task.error?.message).toBe('middleware error');
+  });
+
+  it('should mark task as failed if processor throws', async () => {
+    qm.setProcessor('default', async () => {
+      throw new Error('processor error');
+    });
+
+    const task = qm.add('data', { maxRetries: 1 });
+    await qm.processNext('default');
+
+    expect(task.status).toBe('failed');
+  });
+
+  it('should complete task after successful middleware + processor', async () => {
+    qm.use('default', async (_task, next) => {
+      await next();
+    });
+
+    qm.setProcessor('default', async () => {
+      // success
+    });
+
+    const task = qm.add('data');
+    await qm.processNext('default');
+
+    expect(task.status).toBe('completed');
+  });
+
+  it('should have independent middleware stacks per queue', async () => {
+    const order: string[] = [];
+
+    qm.use('q1', async (_task, next) => {
+      order.push('q1-middleware');
+      await next();
+    });
+
+    qm.use('q2', async (_task, next) => {
+      order.push('q2-middleware');
+      await next();
+    });
+
+    qm.setProcessor('q1', async () => { order.push('q1-processor'); });
+    qm.setProcessor('q2', async () => { order.push('q2-processor'); });
+
+    qm.add('data1', { queue: 'q1' });
+    qm.add('data2', { queue: 'q2' });
+
+    await qm.processNext('q1');
+    await qm.processNext('q2');
+
+    expect(order).toEqual(['q1-middleware', 'q1-processor', 'q2-middleware', 'q2-processor']);
+  });
+
+  it('should return null from processNext when no tasks available', async () => {
