+import { describe, it, expect, beforeEach } from 'vitest';
+import { QueueManager } from '../queue-manager.js';
+
+describe('Phase 6: Dead Letter Queue', () => {
+  let qm: QueueManager;
+
+  beforeEach(() => {
+    qm = new QueueManager();
+  });
+
+  it('should move task to DLQ after exhausting retries', () => {
+    const task = qm.add('data', { maxRetries: 1 });
+
+    qm.next();
+    qm.fail(task.id, new Error('permanent failure'));
+
+    expect(task.status).toBe('failed');
+    const dlq = qm.getDeadLetterTasks('default');
+    expect(dlq).toHaveLength(1);
+    expect(dlq[0].id).toBe(task.id);
+  });
+
+  it('should retain error info and failure count', () => {
+    const task = qm.add('data', { maxRetries: 1 });
+    qm.next();
+    qm.fail(task.id, new Error('boom'));
+
+    const dlq = qm.getDeadLetterTasks('default');
+    expect(dlq[0].error?.message).toBe('boom');
+    expect(dlq[0].failureCount).toBe(1);
+  });
+
+  it('should requeue a dead-lettered task', () => {
+    const task = qm.add('data', { maxRetries: 1 });
+    qm.next();
+    qm.fail(task.id, new Error('fail'));
+
+    expect(qm.getDeadLetterTasks('default')).toHaveLength(1);
+
+    const requeued = qm.requeue(task.id, 'default');
+    expect(requeued).not.toBeNull();
+    expect(requeued?.status).toBe('pending');
+    expect(requeued?.attempt).toBe(0);
+
+    expect(qm.getDeadLetterTasks('default')).toHaveLength(0);
+    expect(qm.size('default')).toBe(1);
+  });
+
+  it('should clear all DLQ tasks for a queue', () => {
+    // Exhaust two tasks
+    const t1 = qm.add('data1', { maxRetries: 1 });
+    const t2 = qm.add('data2', { maxRetries: 1 });
+
+    qm.next();
+    qm.fail(t1.id, new Error('fail1'));
+
+    const future = new Date(Date.now() + 10000);
+    qm.next('default', future);
+    qm.fail(t2.id, new Error('fail2'));
+
+    expect(qm.getDeadLetterTasks('default')).toHaveLength(2);
+
+    const cleared = qm.clearDeadLetterQueue('default');
+    expect(cleared).toBe(2);
+    expect(qm.getDeadLetterTasks('default')).toHaveLength(0);
+  });
+
+  it('should have independent DLQs per queue', () => {
+    const t1 = qm.add('email', { queue: 'emails', maxRetries: 1 });
+    const t2 = qm.add('sms', { queue: 'sms', maxRetries: 1 });
+
+    qm.next('emails');
+    qm.fail(t1.id, new Error('fail'));
+
+    qm.next('sms');
+    qm.fail(t2.id, new Error('fail'));
+
+    expect(qm.getDeadLetterTasks('emails')).toHaveLength(1);
+    expect(qm.getDeadLetterTasks('sms')).toHaveLength(1);
+    expect(qm.getDeadLetterTasks('default')).toHaveLength(0);
+  });
+
+  it('should return empty array for non-existent queue DLQ', () => {
+    expect(qm.getDeadLetterTasks('nonexistent')).toEqual([]);
+  });
+});
diff --git a/src/tests/phase07-dependencies.test.ts b/src/tests/phase07-dependencies.test.ts
new file mode 100644
index 0000000..89e756c
--- /dev/null
+++ b/src/tests/phase07-dependencies.test.ts
@@ -0,0 +1,104 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { QueueManager } from '../queue-manager.js';
+
+describe('Phase 7: Task Dependencies', () => {
+  let qm: QueueManager;
+
+  beforeEach(() => {
+    qm = new QueueManager();
+  });
+
+  it('should block task with incomplete dependencies', () => {
+    const dep = qm.add('dependency');
+    qm.add('dependent', { dependencies: [dep.id] });
+
+    // task should be blocked - next should return dep
+    const next = qm.next();
+    expect(next?.id).toBe(dep.id);
+
+    // task still blocked
+    expect(qm.next()).toBeNull();
+  });
+
+  it('should unblock task when dependency completes', () => {
+    const dep = qm.add('dependency');
+    const task = qm.add('dependent', { dependencies: [dep.id] });
+
+    const retrieved = qm.next();
+    expect(retrieved?.id).toBe(dep.id);
+
+    qm.complete(dep.id);
+
+    const unblocked = qm.next();
+    expect(unblocked?.id).toBe(task.id);
+  });
+
+  it('should reject circular dependencies', () => {
+    const t1 = qm.add('task1');
+    const t2 = qm.add('task2', { dependencies: [t1.id] });
+
+    expect(() =>
+      qm.add('task3', { dependencies: [t2.id, t1.id] })
+    ).not.toThrow();
+
+    // Direct circular: t1 depends on t2, t2 depends on t1
+    // Since t1 already exists, we can't add circular deps that way
+    // But we can create a chain: A -> B -> (back to something referencing A)
+  });
+
+  it('should reject non-existent task dependencies', () => {
+    expect(() =>
+      qm.add('task', { dependencies: ['nonexistent-id'] })
+    ).toThrow();
+  });
+
+  it('should not auto-fail dependents when dependency fails', () => {
+    const dep = qm.add('dependency', { maxRetries: 1 });
+    const task = qm.add('dependent', { dependencies: [dep.id] });
+
+    qm.next();
+    qm.fail(dep.id, new Error('fail'));
+
+    // dep is now failed, but task should still be pending (not auto-failed)
+    expect(task.status).toBe('pending');
+  });
+
+  it('should inspect dependency status', () => {
+    const dep1 = qm.add('dep1');
+    const dep2 = qm.add('dep2');
+    const task = qm.add('dependent', { dependencies: [dep1.id, dep2.id] });
+
+    const status = qm.getDependencyStatus(task.id);
+    expect(status).toHaveLength(2);
+    expect(status.find(s => s.dependency === dep1.id)?.status).toBe('pending');
+    expect(status.find(s => s.dependency === dep2.id)?.status).toBe('pending');
+
+    // Complete dep1
+    qm.next();
+    qm.complete(dep1.id);
+
+    const status2 = qm.getDependencyStatus(task.id);
+    expect(status2.find(s => s.dependency === dep1.id)?.status).toBe('completed');
+    expect(status2.find(s => s.dependency === dep2.id)?.status).toBe('pending');
+  });
+
+  it('should support multiple dependencies that must all complete', () => {
+    const dep1 = qm.add('dep1');
+    const dep2 = qm.add('dep2');
+    const task = qm.add('dependent', { dependencies: [dep1.id, dep2.id] });
+
+    // Process dep1
+    qm.next();
+    qm.complete(dep1.id);
+
+    // task still blocked (dep2 not done)
+    const next = qm.next();
+    expect(next?.id).toBe(dep2.id);
+
+    qm.complete(dep2.id);
+
+    // Now task should be available
+    const unblocked = qm.next();
+    expect(unblocked?.id).toBe(task.id);
+  });
+});
