+++ b/src/task.ts
@@ -0,0 +1,103 @@
+import { generateId } from './utils.js';
+import type { TaskData, TaskOptions, TaskStatus, ProgressCallback } from './types.js';
+
+export class Task implements TaskData {
+  readonly id: string;
+  payload: unknown;
+  status: TaskStatus;
+  priority: number;
+  readonly createdAt: Date;
+  availableAt: Date;
+  attempt: number;
+  maxRetries: number;
+  backoffDelay: number;
+  queueName: string;
+  dependencies: string[];
+  progress: number;
+  progressMessage?: string;
+  error?: Error;
+  failureCount: number;
+
+  private _progressListeners: Map<string, ProgressCallback> = new Map();
+  private _sequence: number;
+
+  private static _globalSequence = 0;
+
+  constructor(payload: unknown, options: TaskOptions = {}, queueName = 'default') {
+    const priority = options.priority ?? 5;
+    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {
+      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);
+    }
+
+    this.id = generateId();
+    this.payload = payload;
+    this.status = 'pending';
+    this.priority = priority;
+    this.createdAt = new Date();
+    this.attempt = 0;
+    this.maxRetries = options.maxRetries ?? 3;
+    this.backoffDelay = options.backoffDelay ?? 1000;
+    this.queueName = queueName;
+    this.dependencies = options.dependencies ? [...options.dependencies] : [];
+    this.progress = 0;
+    this.failureCount = 0;
+
+    this._sequence = Task._globalSequence++;
+
+    // Calculate availability time
+    if (options.scheduledFor) {
+      this.availableAt = new Date(options.scheduledFor.getTime());
+    } else if (options.delay && options.delay > 0) {
+      this.availableAt = new Date(this.createdAt.getTime() + options.delay);
+    } else {
+      this.availableAt = new Date(this.createdAt.getTime());
+    }
+  }
+
+  get sequence(): number {
+    return this._sequence;
+  }
+
+  isAvailable(now: Date = new Date()): boolean {
+    return now.getTime() >= this.availableAt.getTime();
+  }
+
+  reportProgress(percent: number, message?: string): void {
+    if (this.status !== 'processing') return;
+    this.progress = Math.max(0, Math.min(100, percent));
+    this.progressMessage = message;
+    for (const cb of this._progressListeners.values()) {
+      try { cb(this.progress, this.progressMessage); } catch { /* ignore */ }
+    }
+  }
+
+  onProgress(callback: ProgressCallback): string {
+    const subId = generateId();
+    this._progressListeners.set(subId, callback);
+    return subId;
+  }
+
+  offProgress(subscriptionId: string): boolean {
+    return this._progressListeners.delete(subscriptionId);
+  }
+
+  toData(): TaskData {
+    return {
+      id: this.id,
+      payload: this.payload,
+      status: this.status,
+      priority: this.priority,
+      createdAt: this.createdAt,
+      availableAt: this.availableAt,
+      attempt: this.attempt,
+      maxRetries: this.maxRetries,
+      backoffDelay: this.backoffDelay,
+      queueName: this.queueName,
+      dependencies: [...this.dependencies],
+      progress: this.progress,
+      progressMessage: this.progressMessage,
+      error: this.error,
+      failureCount: this.failureCount,
+    };
+  }
+}
