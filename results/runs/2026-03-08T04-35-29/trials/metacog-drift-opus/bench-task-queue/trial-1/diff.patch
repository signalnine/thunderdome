+import { describe, it, expect, beforeEach } from 'vitest';
+import { QueueManager } from '../queue-manager.js';
+
+describe('Phase 2: Named Queues', () => {
+  let qm: QueueManager;
+
+  beforeEach(() => {
+    qm = new QueueManager();
+  });
+
+  it('should add tasks to a specific named queue', () => {
+    const t1 = qm.add('email-task', { queue: 'emails' });
+    const t2 = qm.add('sms-task', { queue: 'sms' });
+
+    expect(t1.queueName).toBe('emails');
+    expect(t2.queueName).toBe('sms');
+  });
+
+  it('should use default queue when no name specified', () => {
+    const task = qm.add('default-task');
+    expect(task.queueName).toBe('default');
+  });
+
+  it('should keep named queues independent', () => {
+    qm.add('email1', { queue: 'emails' });
+    qm.add('sms1', { queue: 'sms' });
+
+    expect(qm.size('emails')).toBe(1);
+    expect(qm.size('sms')).toBe(1);
+
+    const emailTask = qm.next('emails');
+    expect(emailTask?.payload).toBe('email1');
+    expect(qm.size('emails')).toBe(0);
+    expect(qm.size('sms')).toBe(1);
+  });
+
+  it('should implicitly create queue on first task', () => {
+    qm.add('data', { queue: 'new-queue' });
+    expect(qm.getQueues()).toContain('new-queue');
+  });
+
+  it('should list all queue names', () => {
+    qm.add('a', { queue: 'alpha' });
+    qm.add('b', { queue: 'beta' });
+    qm.add('c', { queue: 'gamma' });
+
+    const names = qm.getQueues();
+    expect(names).toContain('alpha');
+    expect(names).toContain('beta');
+    expect(names).toContain('gamma');
+  });
+
+  it('should return null from non-existent queue', () => {
+    expect(qm.next('nonexistent')).toBeNull();
+  });
+
+  it('should return 0 size for non-existent queue', () => {
+    expect(qm.size('nonexistent')).toBe(0);
+  });
+
+  it('should be backward-compatible with Phase 1 (default queue)', () => {
+    qm.add('task1');
+    qm.add('task2');
+
+    expect(qm.size()).toBe(2);
+    const t = qm.next();
+    expect(t?.payload).toBe('task1');
+    expect(qm.size()).toBe(1);
+  });
+});
