ning.length > 0) {\n    let progress = false;\n    for (let i = remaining.length - 1; i >= 0; i--) {\n      const gate = remaining[i];\n      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {\n        const a = wires[gate.in1];\n        const b = wires[gate.in2];\n        switch (gate.op) {\n          case 'AND':\n            wires[gate.out] = a & b;\n            break;\n          case 'OR':\n            wires[gate.out] = a | b;\n            break;\n          case 'XOR':\n            wires[gate.out] = a ^ b;\n            break;\n        }\n        remaining.splice(i, 1);\n        progress = true;\n      }\n    }\n    if (!progress) {\n      throw new Error('Circuit has unresolvable dependencies');\n    }\n  }\n\n  return wires;\n}\n\n/**\n * Find the 8 wires (4 pairs) that have been swapped in a binary adder circuit.\n *\n * Trace the expected ripple-carry adder structure bit by bit, fixing swaps\n * as they're discovered. The key approach for each bit:\n *\n * 1. Find the partial sum (xi XOR yi) and the sum gate (partialSum XOR carry -> zi)\n * 2. Find the generate carry (xi AND yi) and propagate carry (partialSum AND carry)\n * 3. Find the OR gate combining both carries\n *\n * At each step, if the expected gate/wire isn't found, we identify the swap.\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  const gateByOutput = new Map<string, Gate>();\n  for (const g of gates) {\n    gateByOutput.set(g.out, g);\n  }\n\n  function findGate(\n    op: Gate['op'],\n    in1: string,\n    in2: string,\n  ): Gate | undefined {\n    return gates.find(\n      (g) =>\n        g.op === op &&\n        ((g.in1 === in1 && g.in2 === in2) ||\n          (g.in1 === in2 && g.in2 === in1)),\n    );\n  }\n\n  function isInputWire(w: string): boolean {\n    return w.startsWith('x') || w.startsWith('y');\n  }\n\n  function findSecondXorWithInput(wire: string): Gate | undefined {\n    return gates.find(\n      (g) =>\n        g.op === 'XOR' &&\n        (g