      const zi = `z${i.toString().padStart(2, '0')}`;\n\n      const ti = newWire();\n      const ai = newWire();\n      const bi = newWire();\n      const ci = newWire();\n\n      gates.push({ op: 'XOR', in1: xi, in2: yi, out: ti });\n      gates.push({ op: 'XOR', in1: ti, in2: carry, out: zi });\n      gates.push({ op: 'AND', in1: xi, in2: yi, out: ai });\n      gates.push({ op: 'AND', in1: ti, in2: carry, out: bi });\n      gates.push({ op: 'OR', in1: ai, in2: bi, out: ci });\n\n      carry = ci;\n    }\n\n    // Final carry -> z_N\n    const zFinal = `z${numBits.toString().padStart(2, '0')}`;\n    // We need a gate that passes carry through to zFinal.\n    // Actually in the problem description, c_{N-1} IS z_N (the wire is just renamed).\n    // But since we have gates outputting carry, we need to handle this.\n    // In the example, \"c03 -> z04\" means c03 is directly z04.\n    // So the last OR gate should output z_N directly.\n    // Let's fix: the last carry output IS z_N.\n    const lastGate = gates[gates.length - 1];\n    lastGate.out = zFinal;\n\n    // Now perform 4 swaps, avoiding cycles.\n    // A swap between g1 and g2 is invalid if:\n    // - g2.out appears as g1.in1 or g1.in2 (g1 would depend on its own output)\n    // - g1.out appears as g2.in1 or g2.in2 (g2 would depend on its own output)\n    // - Also check transitive: g2.out is a transitive input of g1 or vice versa\n    const allInputs = new Map<string, Set<string>>();\n    function getTransitiveInputs(wire: string, visited = new Set<string>()): Set<string> {\n      if (visited.has(wire)) return new Set();\n      visited.add(wire);\n      if (allInputs.has(wire)) return allInputs.get(wire)!;\n      const gate = gates.find(g => g.out === wire);\n      if (!gate) return new Set();\n      const inputs = new Set<string>([gate.in1, gate.in2]);\n      for (const w of [gate.in1, gate.in2]) {\n        for (const ti of getTransitiveInputs(w, visited)) {\n          inputs.add(ti);\n        }\n      }\n