inputs: Record<string, number>,\n): Record<string, number> {\n  const wires: Record<string, number> = { ...inputs };\n  const remaining = [...gates];\n\n  while (remaining.length > 0) {\n    let progress = false;\n    for (let i = remaining.length - 1; i >= 0; i--) {\n      const gate = remaining[i];\n      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {\n        const a = wires[gate.in1];\n        const b = wires[gate.in2];\n        switch (gate.op) {\n          case 'AND':\n            wires[gate.out] = a & b;\n            break;\n          case 'OR':\n            wires[gate.out] = a | b;\n            break;\n          case 'XOR':\n            wires[gate.out] = a ^ b;\n            break;\n        }\n        remaining.splice(i, 1);\n        progress = true;\n      }\n    }\n    if (!progress) {\n      throw new Error('Circuit has unresolvable dependencies');\n    }\n  }\n\n  return wires;\n}\n\n/**\n * Find the 8 wires (4 pairs) that have been swapped in a binary adder circuit.\n *\n * A correct ripple-carry adder for bit i (i > 0) has this structure:\n *   x_i XOR y_i -> t_i          (partial sum)\n *   t_i XOR c_{i-1} -> z_i      (final sum = partial XOR carry-in)\n *   x_i AND y_i -> a_i          (generate carry)\n *   t_i AND c_{i-1} -> b_i      (propagate carry)\n *   a_i OR b_i -> c_i           (carry out)\n *\n * Bit 0:\n *   x00 XOR y00 -> z00\n *   x00 AND y00 -> c00\n *\n * The final carry c_N -> z_{N+1}\n *\n * We detect swaps by checking structural invariants of this adder pattern.\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Build lookup structures\n  const gateByOutput = new Map<string, Gate>();\n  for (const g of gates) {\n    gateByOutput.set(g.out, g);\n  }\n\n  // Find the number of input bits by looking at x-wires\n  const xWires = gates\n    .flatMap((g) => [g.in1, g.in2])\n    .filter((w) => w.startsWith('x'));\n  const maxBit = Math.max(...xWires.map((w) => parseInt(w.slice(1))));\n  const numBits = maxBit + 1;\n\n  // Helper: find a gate by its operation and input set\n  function findGate(\n    op: Gate['op'],\n    in1: string,\n    in2: string,\n  ): Gate | undefined {\n    return gates.find(\n      (g) =>\n        g.op === op &&\n        ((g.in1 === in1 && g.in2 === in2) ||\n          (g.in1 === in2 && g.in2 === in1)),\n    );\n  }\n\n  const swapped = new Set<string>();\n\n  // We'll trace through the adder structure bit by bit,\n  // identifying where wires don't match the expected pattern.\n\n  // For bit 0: x00 XOR y00 -> z00, x00 AND y00 -> carry\n  let carry: string;\n\n  // Process bit 0\n  const xor0 = findGate('XOR', 'x00', 'y00');\n  const and0 = findGate('AND', 'x00', 'y00');\n\n  if (!xor0 || !and0) {\n    throw new Error('Could not find bit 0 gates');\n  }\n\n  // z00 should be the output of xor0\n  if (xor0.out !== 'z00') {\n    // xor0.out is swapped with z00\n    swapped.add(xor0.out);\n    swapped.add('z00');\n    // Perform the swap in our lookup for subsequent analysis\n    swapOutputs(xor0.out, 'z00');\n  }\n\n  carry = and0.out;\n\n  // Check if carry is a z-wire (it shouldn't be, unless it's the final z)\n  // For bit 0, carry should NOT be a z-wire\n  if (carry.startsWith('z')) {\n    // carry has been swapped with some other wire; we'll detect this when\n    // we try to use it in bit 1\n  }\n\n  // Process bits 1 through numBits-1\n  for (let i = 1; i < numBits; i++) {\n    const xi = `x${i.toString().padStart(2, '0')}`;\n    const yi = `y${i.toString().padStart(2, '0')}`;\n    const zi = `z${i.toString().padStart(2, '0')}`;\n\n    // Step 1: find xi XOR yi -> t_i\n    const xorXY = findGate('XOR', xi, yi);\n    if (!xorXY) throw new Error(`Missing XOR gate for ${xi}, ${yi}`);\n\n    let partialSum = xorXY.out;\n\n    // Step 2: find partialSum XOR carry -> should be zi\n    let xorSumCarry = findGate('XOR', partialSum, carry);\n\n    if (!xorSumCarry) {\n      // One of partialSum or carry is wrong.\n      // Since carry comes from the previous stage (and we've been fixing as we go),\n      // partialSum is more likely swapped. But let's check both.\n\n      // Try: maybe partialSum is the problem. Look for any XOR gate with carry as input.\n      const xorWithCarry = gates.find(\n        (g) =>\n          g.op === 'XOR' &&\n          (g.in1 === carry || g.in2 === carry) &&\n          g.in1 !== xi &&\n          g.in2 !== xi &&\n          g.in1 !== yi &&\n          g.in2 !== yi,\n      );\n\n      if (xorWithCarry) {\n        // The other input to this gate is what partialSum should be\n        const correctPartialSum =\n          xorWithCarry.in1 === carry ? xorWithCarry.in2 : xorWithCarry.in1;\n        // partialSum (xorXY.out) was swapped with correctPartialSum\n        swapped.add(partialSum);\n        swapped.add(correctPartialSum);\n        swapOutputs(partialSum, correctPartialSum);\n        partialSum = correctPartialSum;\n        xorSumCarry = xorWithCarry;\n      } else {\n        // Try: maybe carry is the problem. Look for any XOR with partialSum as input.\n        const xorWithPartial = gates.find(\n          (g) =>\n            g.op === 'XOR' &&\n            (g.in1 === partialSum || g.in2 === partialSum) &&\n            g.in1 !== xi &&\n            g.in2 !== xi &&\n            g.in1 !== yi &&\n            g.in2 !== yi,\n        );\n        if (xorWithPartial) {\n          const correctCarry =\n            xorWithPartial.in1 === partialSum\n              ? xorWithPartial.in2\n              : xorWithPartial.in1;\n          swapped.add(carry);\n          swapped.add(correctCarry);\n          swapOutputs(carry, correctCarry);\n          carry = correctCarry;\n          xorSumCarry = xorWithPartial;\n        } else {\n          throw new Error(\n            `Cannot find sum XOR gate for bit ${i}`,\n          );\n        }\n      }\n    }\n\n    // The output of xorSumCarry should be zi\n    if (xorSumCarry.out !== zi) {\n      swapped.add(xorSumCarry.out);\n      swapped.add(zi);\