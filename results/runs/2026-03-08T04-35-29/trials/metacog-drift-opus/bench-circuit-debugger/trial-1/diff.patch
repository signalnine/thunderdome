orWithCarry && !xorWithPartial) {\n        // partialSum is the problem\n        const correctPartialSum =\n          xorWithCarry.in1 === carry ? xorWithCarry.in2 : xorWithCarry.in1;\n        markSwap(partialSum, correctPartialSum);\n        partialSum = correctPartialSum;\n        xorSumCarry = xorWithCarry;\n      } else if (xorWithPartial && xorWithCarry) {\n        // Both found second-level XORs. One is the correct gate for this bit,\n        // and the other is for a different bit. The correct one for this bit\n        // should output zi (or have zi as its expected output).\n        // Try partialSum's XOR first: if its other input should be the carry\n        if (xorWithPartial.out === zi || xorWithCarry.out !== zi) {\n          // partialSum found the right gate, so carry is wrong\n          const correctCarry =\n            xorWithPartial.in1 === partialSum\n              ? xorWithPartial.in2\n              : xorWithPartial.in1;\n          markSwap(carry, correctCarry);\n          carry = correctCarry;\n          xorSumCarry = xorWithPartial;\n        } else {\n          // carry found the right gate, so partialSum is wrong\n          const correctPartialSum =\n            xorWithCarry.in1 === carry ? xorWithCarry.in2 : xorWithCarry.in1;\n          markSwap(partialSum, correctPartialSum);\n          partialSum = correctPartialSum;\n          xorSumCarry = xorWithCarry;\n        }\n      } else {\n        throw new Error(`Cannot find second XOR for bit ${i}`);\n      }\n    }\n\n    // xorSumCarry should output zi\n    if (xorSumCarry.out !== zi) {\n      markSwap(xorSumCarry.out, zi);\n    }\n\n    // Step 3: xi AND yi -> generateCarry\n    const andXY = findGate('AND', xi, yi);\n    if (!andXY) throw new Error(`Missing AND for ${xi}, ${yi}`);\n    const generateCarry = andXY.out;\n\n    // Step 4: partialSum AND carry -> propagateCarry\n    const andPC = findGate('AND', partialSum, carry);\n    if (!andPC) {\n      throw new Error(\n        `Missing propagate AND for bit ${i}: ${partialSum} AND ${carry}`,\n      );\n    }\n    const propagateCarry = andPC.out;\n\n    // Step 5: generateCarry OR propagateCarry -> carryOut\n    let orCarry = findGate('OR', generateCarry, propagateCarry);\n    if (!orCarry) {\n      // One of generateCarry or propagateCarry is swapped.\n      // Find the OR gate that has one of them as input.\n      const orWithGen = gates.find(\n        (g) =>\n          g.op === 'OR' &&\n          (g.in1 === generateCarry || g.in2 === generateCarry),\n      );\n      const orWithProp = gates.find(\n        (g) =>\n          g.op === 'OR' &&\n          (g.in1 === propagateCarry || g.in2 === propagateCarry),\n      );\n\n      if (orWithGen && !orWithProp) {\n        const otherInput =\n          orWithGen.in1 === generateCarry ? orWithGen.in2 : orWithGen.in1;\n        markSwap(propagateCarry, otherInput);\n        orCarry = orWithGen;\n      } else if (orWithProp && !orWithGen) {\n        const otherInput =\n          orWithProp.in1 === propagateCarry ? orWithProp.in2 : orWithProp.in1;\n        markSwap(generateCarry, otherInput);\n        orCarry = orWithProp;\n      } else if (orWithGen && orWithProp) {\n        // Both have OR gates. Need to determine which is this bit's gate.\n        // The correct gate for this bit originally had both generateCarry\n        // and propagateCarry as inputs. One of those wire names was changed\n        // by the swap. We identify the correct gate by checking which\n        // candidate has an input that is the output of an AND gate\n        // matching this bit's expected structure.\n        const otherGen =\n          orWithGen.in1 === generateCarry ? orWithGen.in2 : orWithGen.in1;\n        const otherProp =\n          orWithProp.in1 === propagateCarry ? orWithProp.in2 : orWithProp.in1;\n\n        // Check: is orWithGen the right gate?\n        // Its other input (otherGen) should be the correct propagateCarry\n        // wire name. We verify by checking if the xi AND yi gate's ORIGINAL\n        // output was one of orWithGen's inputs — which it is (generateCarry).\n        // Then check if orWithGen's other input was originally the propagateCarry.\n        // We can't directly verify \"originally\", but we can look at the gate\n        // that currently produces otherGen and see if the AND gate for\n        // partialSum AND carry has its output set to otherGen (after swaps).\n        //\n        // Actually, the simplest reliable approach: check if the gate\n        // producing generateCarry (the AND(xi,yi) gate) has xi/yi as inputs.\n        // It always does (we found it by findGate). So generateCarry is\n        // definitely from this bit. The question is whether generateCarry's\n        // output name is the original or swapped.\n        //\n        // If generateCarry appears as input in an OR gate (orWithGen), and\n        // that OR gate's inputs are both originally from this bit, then\n        // orWithGen is the correct gate. We check if the gate structure\n        // around orWithGen is consistent with this bit.\n        //\n        // Key insight: the OR gate for this bit should feed into the next\n        // bit's XOR and AND. If we can verify that orWithGen's output or\n        // orWithProp's output is used in a way consistent with being the\n        // carry for bit i+1, we can determine which is correct.\n\n        // Try: use the next bit's structure to validate\n        const nextBit = i + 1;\n        let resolved = false;\n        if (nextBit < numBits) {\n          const xNext = `x${nextBit.toString().padStart(2, '0')}`;\n          const yNext = `y${nextBit.toString().padStart(2, '0')}`;\n          const xorNext = findGate('XOR', xNext, yNext);\n          if (xorNext) {\n            // The next bit's second XOR uses carry as input.\n            // Check if there's an XOR using xorNext.out and orWithGen.out\n            const nextXorWithGenCarry = findGate(\n              'XOR',\n              xorNext.out,\n              orWithGen.out,\n            );\n            const nextXorWithPropCarry = findGate(\n              'XOR',\n              xorNext.out,\n              orWithProp.out,\n            );\n            if (nextXorWithGenCarry && !nextXorWithPropCarry) {\n              // orWithGen's output works as carry for next bit\n              markSwap(propagateCarry, otherGen);\n              orCarry = orWithGen;\n              resolved = true;\n            } else if (nextXorWithPropCarry && !nextXorWithGenCarry) {\n              // orWithProp's output works as carry for next bit\n              markSwap(generateCarry, otherProp);\n              orCarry = orWithProp;\n              resolved = true;\n            }\n          }\n        }\n\n        if (!resolved) {\n          // Fallback: check if the generate carry wire name appears in\n          // the OR gate's input list (meaning it wasn't swapped), which\n          // means propagateCarry is the swapped one.\n          // The AND(xi,yi) gate found generateCarry. If generateCarry\n          // is NOT a z-wire and the OR gate with it (orWithGen) also\n          // has a second input that is an AND output, prefer orWithGen.\n          const gateForOtherGen = gateByOutput.get(otherGen);\n          if (gateForOtherGen && gateForOtherGen.op === 'AND') {\n            markSwap(propagateCarry, otherGen);\n            orCarry = orWithGen;\n          } else {\n            markSwap(generateCarry, otherProp);\n            orCarry = orWithProp;\n          }\n        }\n      } else {\n        throw new Error(`Cannot find carry OR gate for bit ${i}`);\n      }\n    }\n\n    carry = orCarry.out;\n\n    // Sanity check: carry should not be a z-wire (unless it's the final z)\n    const finalZ = `z${numBits.toString().padStart(2, '0')}`;\n    if (carry.startsWith('z') && carry !== finalZ) {\n      // The carry wire is a z-wire, which means it was swapped with the real carry.\n      // Find what the real carry should be: it's the 