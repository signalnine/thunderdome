   expect(result.mid).toBe(1);\n    expect(result.out).toBe(1);\n  });\n\n  it('should resolve gates regardless of order in array', () => {\n    // Put dependent gate first\n    const gates: Gate[] = [\n      { op: 'OR', in1: 'mid', in2: 'c', out: 'out' },\n      { op: 'AND', in1: 'a', in2: 'b', out: 'mid' },\n    ];\n    const result = simulate(gates, { a: 1, b: 0, c: 1 });\n    expect(result.mid).toBe(0);\n    expect(result.out).toBe(1);\n  });\n\n  it('should simulate a correct 2-bit adder: 3+3=6', () => {\n    // 2-bit adder: x=11 (3), y=11 (3), expected z=110 (6)\n    const gates: Gate[] = [\n      // Bit 0\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      // Bit 1\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },\n    ];\n    const inputs: Record<string, number> = {\n      x00: 1, x01: 1,\n      y00: 1, y01: 1,\n    };\n    const result = simulate(gates, inputs);\n    expect(result.z00).toBe(0); // 1 XOR 1 = 0\n    expect(result.z01).toBe(1); // (1 XOR 1) XOR 1 = 0 XOR 1 = 1\n    expect(result.z02).toBe(1); // carry out = 1\n  });\n\n  it('should simulate a 4-bit adder: 15+15=30', () => {\n    const gates: Gate[] = [\n      // Bit 0\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      // Bit 1\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n      // Bit 2\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n      // Bit 3\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n      { op: 'OR', in1: 'a03', in2: 'b03', out: 'z04' },\n    ];\n    // 15 + 15 = 30 -> 11110\n    const inputs: Record<string, number> = {\n      x00: 1, x01: 1, x02: 1, x03: 1,\n      y00: 1, y01: 1, y02: 1, y03: 1,\n    };\n    const result = simulate(gates, inputs);\n    // 30 = 11110\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(1);\n    expect(result.z02).toBe(1);\n    expect(result.z03).toBe(1);\n    expect(result.z04).toBe(1);\n  });\n\n  it('should simulate a 4-bit adder: 5+3=8', () => {\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n      { op: 'OR', in1: 'a03', in2: 'b03', out: 'z04' },\n    ];\n    // 5=0101, 3=0011 -> 8=01000\n    const inputs: Record<string, number> = {\n      x00: 1, x01: 0, x02: 1, x03: 0,\n      y00: 1, y01: 1, y02: 0, y03: 0,\n    };\n    const result = simulate(gates, inputs);\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(0);\n    expect(result.z02).toBe(0);\n    expect(result.z03).toBe(1);\n    expect(result.z04).toBe(0);\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  /**\n   * Helper: build a correct N-bit adder circuit with random wire names,\n   * then swap 4 pairs of output wires.\n   */\n  function buildAdder(numBits: number): {\n    gates: Gate[];\n    swappedWires: string[];\n  } {\n    const gates: Gate[] = [];\n    let wireCounter = 0;\n    function newWire(): string {\n      return `w${(wireCounter++).toString().padStart(3, '0')}`;\n    }\n\n    let carry: string;\n\n    // Bit 0\n    const z00 = 'z00';\n    const c00 = newWire();\n    gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: z00 });\n    gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: c00 });\n    carry = c00;\n\n    // Bits 1 to numBits-1\n    for (let i = 1; i < numBits; i++) {\n      const xi = `x${i.toString().padStart(2, '0')}`;\n      const yi = `y${i.toString().padStart(2, '0')}`;\n      const zi = `z${i.toString().padStart(2, '0')}`;\n\n      const ti = newWire();\n      const ai = newWire();\n      const bi = newWire();\n      const ci = newWire();\n\n      gates.push({ op: 'XOR', in1: xi, in2: yi, out: ti });\n      gates.push({ op: 'XOR', in1: ti, in2: carry, out: zi });\n      gates.push({ op: 'AND', in1: xi, in2: yi, out: ai });\n      gates.push({ op: 'AND', in1: ti, in2: carry, out: bi });\n      gates.push({ op: 'OR', in1: ai, in2: bi, out: ci });\n\n      carry = ci;\n    }\n\n    // Final carry -> z_N\n    const zFinal = `z${numBits.toString().padStart(2, '0')}`;\n    // We need a gate that passes carry through to zFinal.\n    // Actually in the problem description, c_{N-1} IS z_N (the wire is just renamed).\n    // But since we have gates outputting carry, we need to handle this.\n    // In the example, \"c03 -> z04\" means c03 is directly z04.\n    // So the last OR gate should output z_N directly.\n    // Let's fix: the last carry output IS z_N.\n    const lastGate = gates[gates.length - 1];\n    lastGate.out = zFinal;\n\n    // Now perform 4 swaps\n    // Pick 8 distinct gate indices and swap outputs pairwise\n    const indices = shuffleAndPick(gates.length, 8);\n    const swappedWires: string[] = [];\n    for (let p = 0; p < 4; p++) {\n      const g1 = gates[indices[p * 2]];\n      const g2 = gates[indices[p * 2 + 1]];\n      swappedWires.push(g1.out, g2.out);\n      const tmp = g1.out;\n      g1.out = g2.out;\n      g2.out = tmp;\n    }\n\n    // Shuffle gates array to remove any ordering hints\n    for (let i = gates.length - 1; i > 0; i--) {\n      const j = Math.floor(seededRandom() * (i + 1));\n      [gates[i], gates[j]] = [gates[j], gates[i]];\n    }\n\n    return { gates, swappedWires: swappedWires.sort() };\n  }\n\n  // Simple seeded random for reproducibility\n  let seed = 42;\n  function seededRandom(): number {\n    seed = (seed * 16807 + 0) % 2147483647;\n    return seed / 2147483647;\n  }\n\n  function shuffleAndPick(n: number, count: number): number[] {\n    const arr = Array.from({ length: n }, (_, i) => i);\n    for (let i = arr.length - 1; i > 0; i--) {\n      const j = Math.floor(seededRandom() * (i + 1));\n      [arr[i], arr[j]] = [arr[j], arr[i]];\n    }\n    return arr.slice(0, count);\n  }\n\n  it('should find swapped wires in a small 8-bit adder', () => {\n    seed = 42;\n    const { gates, swappedWires } = buildAdder(8);\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(swappedWires);\n  });\n\n  it('should find swapped wires in a 16-bit adder', () => {\n    seed = 123;\n    const { gates, swappedWires } = buildAdder(16);\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(swappedWires);\n  });\n\n  it('should find swapped wires in a 45-bit adder', () => {\n    seed = 999;\n    const { gates, swappedWires } = buildAdder(45);\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(swappedWires);\n  });\n\n  it('should find swapped wires with different seed', () => {\n    seed = 7777;\n    const { gates, swappedWires } = buildAdder(20);\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(swappedWires);\n  });\n\n  it('should return exactly 8 wire names sorted alphabetically', () => {\n    seed = 5555;\n    const { gates } = buildAdder(10);\n    const result = findSwappedWires(gates);\n    expect(result.length).toBe(8);\n    // Check sorted\n    for (let i = 1; i < result.length; i++) {\n      expect(result[i] >= result[i - 1]).toBe(true);\n    }\n  });\n\n  it('should handle swaps involving z-wires', () => {\n    // Build a 4-bit adder manually and swap z01 with a01\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      // Bit 1 - swap z01 <-> a01\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'a01' },  // should be z01\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'z01' },  // should be a01\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n      // Bit 2 - swap z02 <-> a02\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n      { op: 'XOR', in1: 't02', in2: 'c01', out: 'a02' },  // should be z02\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'z02' },  // should be a02\n      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n      // Bit 3 - swap t03 <-> b03\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 'b03' },  // should be t03\n      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 't03' },  // should be b03\n      { op: 'OR', in1: 'a03', in2: 'b03', out: 'c03' },\n      // Bit 4 - swap c03 <-> z04 ... wait, these can't swap with each other cleanly\n      // Let's do: swap c02 <-> c03 instead? No, let me reconsider.\n      // We need exactly 4 pairs. Let's swap c03 <-> z04.\n      // Actually c03 should become z04 in a correct circuit. Let me build differently.\n    ];\n    // This manual approach is getting complex. Let me just use the 3 swaps we have\n    // and add a 4th: swap c03 <-> some other wire.\n    // Actually the problem says we need EXACTLY 4 pairs. Let me restructure.\n    // The last OR gate outputs to z04 in a correct 4-bit adder.\n\n    // Let me clear and rebuild more carefully.\n    const gates2: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      // Bit 1\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n      // Bit 2\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n      // Bit 3\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n      { op: 'OR', in1: 'a03', in2: 'b03', out: 'z04' },\n    ];\n\n    // Now swap 4 pairs:\n    // Pair 1: z01 <-> a01\n    swap(gates2, 'z01', 'a01');\n    // Pair 2: z02 <-> b02\n    swap(gates2, 'z02', 'b02');\n    // Pair 3: t03 <-> a03\n    swap(gates2, 't03', 'a03');\n    // Pair 4: c01 <-> b01\n    swap(gates2, 'c01', 'b01');\n\n    const result = findSwappedWires(gates2);\n    expect(result).toEqual(\n      ['a01', 'a03', 'b01', 'b02', 'c01', 't03', 'z01', 'z02'].sort(),\n    );\n  });\n});\n\nfunction swap(gates: Gate[], wire1: string, wire2: string): void {\n  const g1 = gates.find((g) => g.out === wire1)!;\n  const g2 = gates.find((g) => g.out === wire2)!;\n  g1.out = wire2;\n  g2.out = wire1;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":224,"cache_read_input_tokens":24711,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":224},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"18e2aba9-e94f-4723-a1cf-3dd6b22e7b05","uuid":"44001dc9-d896-4e74-924c-c1f573db93f8"}
