   374→            ? orWithProp.in2\n   375→            : orWithProp.in1;\n   376→\n   377→        const genVerified = verifyCarryViaNextBit(i, orWithGen.out);\n   378→        const propVerified = verifyCarryViaNextBit(i, orWithProp.out);\n   379→\n   380→        if (genVerified && !propVerified) {\n   381→          markSwap(propagateCarry, otherGen);\n   382→          orCarry = orWithGen;\n   383→        } else if (propVerified && !genVerified) {\n   384→          markSwap(generateCarry, otherProp);\n   385→          orCarry = orWithProp;\n   386→        } else {\n   387→          // Both or neither verified. Use structural check as tiebreaker.\n   388→          const gateForOtherGen = gateByOutput.get(otherGen);\n   389→          const otherGenIsCorrectPropCarry =\n   390→            gateForOtherGen &&\n   391→            gateForOtherGen.op === 'AND' &&\n   392→            ((gateForOtherGen.in1 === partialSum &&\n   393→              gateForOtherGen.in2 === carry) ||\n   394→              (gateForOtherGen.in1 === carry &&\n   395→                gateForOtherGen.in2 === partialSum));\n   396→\n   397→          if (otherGenIsCorrectPropCarry) {\n   398→            markSwap(propagateCarry, otherGen);\n   399→            orCarry = orWithGen;\n   400→          } else {\n   401→            markSwap(generateCarry, otherProp);\n   402→            orCarry = orWithProp;\n   403→          }\n   404→        }\n   405→      } else {\n   406→        // Neither appears in an OR gate. Both must be swapped.\n   407→        // Find the correct OR gate via next-bit lookahead.\n   408→        orCarry = findOrGateViaNextBit(i, generateCarry, propagateCarry);\n   409→      }\n   410→\n   411→      if (!orCarry) {\n   412→        throw new Error(`Cannot find carry OR gate for bit ${i}`);\n   413→      }\n   414→    }\n   415→\n   416→    carry = orCarry.out;\n   417→\n   418→    // Sanity check: carry should not be a z-wire (unless it's the final z)\n   419→    const finalZ = `z${numBit