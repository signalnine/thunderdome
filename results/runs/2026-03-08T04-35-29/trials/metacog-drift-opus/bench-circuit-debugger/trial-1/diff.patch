n\n    // we try to use it in bit 1\n  }\n\n  // Process bits 1 through numBits-1\n  for (let i = 1; i < numBits; i++) {\n    const xi = `x${i.toString().padStart(2, '0')}`;\n    const yi = `y${i.toString().padStart(2, '0')}`;\n    const zi = `z${i.toString().padStart(2, '0')}`;\n\n    // Step 1: find xi XOR yi -> t_i\n    const xorXY = findGate('XOR', xi, yi);\n    if (!xorXY) throw new Error(`Missing XOR gate for ${xi}, ${yi}`);\n\n    let partialSum = xorXY.out;\n\n    // Step 2: find partialSum XOR carry -> should be zi\n    let xorSumCarry = findGate('XOR', partialSum, carry);\n\n    if (!xorSumCarry) {\n      // One of partialSum or carry is wrong.\n      // Since carry comes from the previous stage (and we've been fixing as we go),\n      // partialSum is more likely swapped. But let's check both.\n\n      // Try: maybe partialSum is the problem. Look for any XOR gate with carry as input.\n      const xorWithCarry = gates.find(\n        (g) =>\n          g.op === 'XOR' &&\n          (g.in1 === carry || g.in2 === carry) &&\n          g.in1 !== xi &&\n          g.in2 !== xi &&\n          g.in1 !== yi &&\n          g.in2 !== yi,\n      );\n\n      if (xorWithCarry) {\n        // The other input to this gate is what partialSum should be\n        const correctPartialSum =\n          xorWithCarry.in1 === carry ? xorWithCarry.in2 : xorWithCarry.in1;\n        // partialSum (xorXY.out) was swapped with correctPartialSum\n        swapped.add(partialSum);\n        swapped.add(correctPartialSum);\n        swapOutputs(partialSum, correctPartialSum);\n        partialSum = correctPartialSum;\n        xorSumCarry = xorWithCarry;\n      } else {\n        // Try: maybe carry is the problem. Look for any XOR with partialSum as input.\n        const xorWithPartial = gates.find(\n          (g) =>\n            g.op === 'XOR' &&\n            (g.in1 === partialSum || g.in2 === partialSum) &&\n            g.in1 !== xi &&\n            g.in2 !== xi &&\n            g.in1 !== yi &&\n            g.in2 !== yi,\n        );\n        if (xorWithPartial) {\n          const correctCarry =\n            xorWithPartial.in1 === partialSum\n              ? xorWithPartial.in2\n              : xorWithPartial.in1;\n          swapped.add(carry);\n          swapped.add(correctCarry);\n          swapOutputs(carry, correctCarry);\n          carry = correctCarry;\n          xorSumCarry = xorWithPartial;\n        } else {\n          throw new Error(\n            `Cannot find sum XOR gate for bit ${i}`,\n          );\n        }\n      }\n    }\n\n    // The output of xorSumCarry should be zi\n    if (xorSumCarry.out !== zi) {\n      swapped.add(xorSumCarry.out);\n      swapped.add(zi);\n      swapOutputs(xorSumCarry.out, zi);\n    }\n\n    // Step 3: find xi AND yi -> generate carry\n    const andXY = findGate('AND', xi, yi);\n    if (!andXY) throw new Error(`Missing AND gate for ${xi}, ${yi}`);\n\n    const generateCarry = andXY.out;\n\n    // Step 4: find partialSum AND carry -> propagate carry\n    const andPC = findGate('AND', partialSum, carry);\n    if (!andPC)\n      throw new Error(\n        `Missing propagate AND gate for bit ${i}: ${partialSum} AND ${carry}`,\n      );\n\n    const propagateCarry = andPC.out;\n\n    // Step 5: find generateCarry OR propagateCarry -> carry out\n    const orCarry = findGate('OR', generateCarry, propagateCarry);\n    if (!orCarry) {\n      // One of generateCarry or propagateCarry might be swapped.\n      // Look for OR gates with either input.\n      const orWithGen = gates.find(\n        (g) =>\n          g.op === 'OR' &&\n          (g.in1 === generateCarry || g.in2 === generateCarry),\n      );\n      if (orWithGen) {\n        const otherInput =\n          orWithGen.in1 === generateCarry ? orWithGen.in2 : orWithGen.in1;\n        swapped.add(propagateCarry);\n        swapped.add(otherInput);\n        swapOutputs(propagateCarry, otherInput);\n        carry = orWithGen.out;\n      } else {\n        const orWithProp = gates.find(\n          (g) =>\n            g.op === 'OR' &&\n            (g.in1 === propagateCarry || g.in2 === propagateCarry),\n        );\n        if (orWithProp) {\n          const otherInput =\n            orWithProp.in1 === propagateCarry\n              ? orWithProp.in2\n              : orWithProp.in1;\n          swapped.add(generateCarry);\n          swapped.add(otherInput);\n          swapOutputs(generateCarry, otherInput);\n          carry = orWithProp.out;\n        } else {\n          throw new Error(`Cannot find carry OR gate for bit ${i}`);\n        }\n      }\n    } else {\n      carry = orCarry.out;\n    }\n\n    // carry should not be a z-wire (unless it's the final output z_{numBits})\n    const finalZ = `z${numBits.toString().padStart(2, '0')}`;\n    if (carry.startsWith('z') && carry !== finalZ) {\n      // carry got swapped with some z-wire. We need to find what should be here.\n      // The real carry wire is whatever the z-wire's gate actually outputs.\n      // We already added it to swapped above if the OR output was wrong.\n      // But if the OR gate itself outputs a z-wire, we catch it here.\n      // Find the gate that should output this z-wire (the XOR for that bit)\n      // and see what it actually outputs - that's our real carry.\n      const zBit = parseInt(carry.slice(1));\n      const xz = `x${zBit.toString().padStart(2, '0')}`;\n      const yz = `y${zBit.toString().padStart(2, '0')}`;\n      // Look for the XOR chain that should produce this z-wire\n      const xorForZ = findGate('XOR', xz, yz);\n      if (xorForZ) {\n        // Find the second XOR that uses this partial sum\n        const secondXor = gates.find(\n          (g) =>\n            g.op === 'XOR' &&\n            (g.in1 === xorForZ.out || g.in2 === xorForZ.out) &&\n            g !== xorForZ,\n        );\n        if (secondXor && secondXor.out !== carry) {\n          swapped.add(carry);\n          swapped.add(secondXor.out);\n          swapOutputs(carry, secondXor.out);\n          carry = secondXor.out;\n        }\n      }\n    }\n  }\n\n  function swapOutputs(wire1: string, wire2: string): void {\n    const gate1 = gateByOutput.get(wire1);\n    const gate2 = gateByOutput.get(wire2);\n    if (gate1 && gate2) {\n      gate1.out = wire2;\n      gate2.out = wire1;\n      gateByOutput.set(wire1, gate2);\n      gateByOutput.set(wire2, gate1);\n    }\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[],"originalFile":null}}
