n): Record<string, number> {\n  const wires: Record<string, number> = { ...inputs };\n  const remaining = [...gates];\n\n  while (remaining.length > 0) {\n    let progress = false;\n    for (let i = remaining.length - 1; i >= 0; i--) {\n      const gate = remaining[i];\n      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {\n        const a = wires[gate.in1];\n        const b = wires[gate.in2];\n        switch (gate.op) {\n          case 'AND':\n            wires[gate.out] = a & b;\n            break;\n          case 'OR':\n            wires[gate.out] = a | b;\n            break;\n          case 'XOR':\n            wires[gate.out] = a ^ b;\n            break;\n        }\n        remaining.splice(i, 1);\n        progress = true;\n      }\n    }\n    if (!progress) {\n      throw new Error('Circuit has unresolvable dependencies');\n    }\n  }\n\n  return wires;\n}\n\n/**\n * Find the 8 wires (4 pairs) that have been swapped in a binary adder circuit.\n *\n * Strategy: trace the expected ripple-carry adder structure bit by bit.\n * At each bit, we know what gates should exist and what their inputs should be.\n * When we can't find an expected gate, it means one of the input wires was\n * swapped (its producing gate has the wrong output name). We identify the\n * swap and fix it before continuing.\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Build lookup: output wire -> gate\n  const gateByOutput = new Map<string, Gate>();\n  for (const g of gates) {\n    gateByOutput.set(g.out, g);\n  }\n\n  // Build lookup: (op, inputSet) -> gate\n  // We need this to find gates by their operation and inputs\n  function findGate(\n    op: Gate['op'],\n    in1: string,\n    in2: string,\n  ): Gate | undefined {\n    return gates.find(\n      (g) =>\n        g.op === op &&\n        ((g.in1 === in1 && g.in2 === in2) ||\n          (g.in1 === in2 && g.in2 === in1)),\n    );\n  }\n\n  // Find all XOR gates that are NOT the first-level xi XOR yi gates\n  // These are the \"second-level\" XOR gates: partialSum XOR carry -> zi\n  function isInputWire(w: string): boolean {\n    return w.startsWith('x') || w.startsWith('y');\n  }\n\n  function findSecondXorWithInput(wire: string): Gate | undefined {\n    return gates.find(\n      (g) =>\n        g.op === 'XOR' &&\n        (g.in1 === wire || g.in2 === wire) &&\n        !isInputWire(g.in1) &&\n        !isInputWire(g.in2),\n    );\n  }\n\n  const numBits =\n    Math.max(\n      ...gates\n        .flatMap((g) => [g.in1, g.in2])\n        .filter((w) => w.startsWith('x'))\n        .map((w) => parseInt(w.slice(1))),\n    ) + 1;\n\n  const swapped = new Set<string>();\n\n  function swapOutputs(wire1: string, wire2: string): void {\n    const gate1 = gateByOutput.get(wire1);\n    const gate2 = gateByOutput.get(wire2);\n    if (gate1 && gate2) {\n      gate1.out = wire2;\n      gate2.out = wire1;\n      gateByOutput.set(wire1, gate2);\n      gateByOutput.set(wire2, gate1);\n    }\n  }\n\n  function markSwap(wire1: string, wire2: string): void {\n    swapped.add(wire1);\n    swapped.add(wire2);\n    swapOutputs(wire1, wire2);\n  }\n\n  // Process bit 0\n  const xor0 = findGate('XOR', 'x00', 'y00');\n  const and0 = findGate('AND', 'x00', 'y00');\n  if (!xor0 || !and0) throw new Error('Missing bit 0 gates');\n\n  if (xor0.out !== 'z00') {\n    markSwap(xor0.out, 'z00');\n  }\n\n  let carry = and0.out;\n\n  // Process bits 1..numBits-1\n  for (let i = 1; i < numBits; i++) {\n    const xi = `x${i.toString().padStart(2, '0')}`;\n    const yi = `y${i.toString().padStart(2, '0')}`;\n    const zi = `z${i.toString().padStart(2, '0')}`;\n\n    // Step 1: xi XOR yi -> partialSum\n    const xorXY = findGate('XOR', xi, yi);\n    if (!xorXY) throw new Error(`Missing XOR for ${xi}, ${yi}`);\n    let partialSum = xorXY.out;\n\n    // Step 2: partialSum XOR carry -> zi\n    let xorSumCarry = findGate('XOR', partialSum, carry);\n\n    if (!xorSumCarry) {\n      // Either partialSum or carry is wrong (one was swapped to a different name).\n      // Look for a second-level XOR that uses partialSum.\n      const xorWithPartial = findSecondXorWithInput(partialSum);\n      // Look for a second-level XOR that uses carry.\n      const xorWithCarry = findSecondXorWithInput(carry);\n\n      if (xorWithPartial && !xorWithCarry) {\n        // carry is the problem\n        const correctCarry =\n          xorWithPartial.in1 === partialSum\n            ? xorWithPartial.in2\n            : xorWithPartial.in1;\n        markSwap(carry, correctCarry);\n        carry = correctCarry;\n        xorSumCarry = xorWithPartial;\n      } else if (xorWithCarry && !xorWithPartial) {\n        // partialSum is the problem\n        const correctPartialSum =\n          xorWithCarry.in1 === carry ? xorWithCarry.in2 : xorWithCarry.in1;\n        markSwap(partialSum, correctPartialSum);\n        partialSum = correctPartialSum;\n        xorSumCarry = xorWithCarry;\n      } else if (xorWithPartial && xorWithCarry) {\n        // Both found second-level XORs. One is the correct gate for this bit,\n        // and the other is for a different bit. The correct one for this bit\n        // should output zi (or have zi as its expected output).\n        // Try partialSum's XOR first: if its other input should be the carry\n        if (xorWithPartial.out === zi || xorWithCarry.out !== zi) {\n          // partialSum found the right gate, so carry is wrong\n          const correctCarry =\n            xorWithPartial.in1 === partialSum\n              ? xorWithPartial.in2\n              : xorWithPartial.in1;\n          markSwap(carry, correctCarry);\n          carry = correctCarry;\n          xorSumCarry = xorWithPartial;\n        } else {\n          // carry found the right gate, so partialSum is wrong\n          const correctPartialSum =\n            xorWithCarry.in1 === carry ? xorWithCarry.in2 : xorWithCarry.in1;\n          markSwap(partialSum, correctPartialSum);\n          partialSum = correctPartialSum;\n          xorSumCarry = xorWithCarry;\n        }\n      } else {\n        throw new Error(`Cannot find second XOR for bit ${i}`);\n      }\n    }\n\n    // xorSumCarry should output zi\n    if (xorSumCarry.out !== zi) {\n      markSwap(xorSumCarry.out, zi);\n    }\n\n    // Step 3: xi AND yi -> generateCarry\n    const andXY = findGate('AND', xi, yi);\n    if (!andXY) throw new Error(`Missing AND for ${xi}, ${yi}`);\n    const generateCarry = andXY.out;\n\n    // Step 4: partialSum AND carry -> propagateCarry\n    const andPC = findGate('AND', partialSum, carry);\n    if (!andPC) {\n      throw new Error(\n        `Missing propagate AND for bit ${i}: ${partialSum} AND ${carry}`,\n      );\n    }\n    const propagateCarry = andPC.out;\n\n    // Step 5: generateCarry OR propagateCarry -> carryOut\n    let orCarry = findGate('OR', generateCarry, propagateCarry);\n    if (!orCarry) {\n      // One of generateCarry or propagateCarry is swapped.\n      // Find the OR gate that has one of them as input.\n      const orWithGen = gates.find(\n        (g) =>\n          g.op === 'OR' &&\n          (g.in1 === generateCarry || g.in2 === generateCarry),\n      );\n      const orWithProp = gates.find(\n        (g) =>\n          g.op === 'OR' &&\n          (g.in1 === propagateCarry || g.in2 === propagateCarry),\n      );\n\n      if (orWithGen && !orWithProp) {\n        const otherInput =\n          orWithGen.in1 === generateCarry ? orWithGen.in2 : orWithGen.in1;\n        markSwap(propagateCarry, otherInput);\n        orCarry = orWithGen;\n      } else if (orWithProp && !orWithGen) {\n        const otherInput =\n          orWithProp.in1 === propagateCarry ? orWithProp.in2 : orWithProp.in1;\n        markSwap(generateCarry, otherInput);\n        orCarry = orWithProp;\n      } else if (orWithGen && orWithProp) {\n        // Both have OR gates. Need to figure out which is the right one for this bit.\n        // The OR gate for this bit should have both generateCarry and propagateCarry.\n        // One of the OR gates is for this bit (with a wrong input), the other is for\n        // a different bit. We look at which OR gate's \"other\" input is more likely correct.\n        // If orWithGen's other input looks like a propagate carry (output of an AND gate\n        // that involves carry), prefer it.\n        const otherGen =\n          orWithGen.in1 === generateCarry ? orWithGen.in2 : orWithGen.in1;\n        const otherProp =\n          orWithProp.in1 === propagateCarry ? orWithProp.in2 : orWithProp.in1;\n\n        // Check if otherGen is the propagateCarry (swapped) or otherProp is generateCarry (swapped)\n        const gateForOtherGen = gateByOutput.get(otherGen);\n        const gateForOtherProp = gateByOutput.get(otherProp);\n\n        // The real propagateCarry should be output of an AND with partialSum and carry\n        if (\n          gateForOtherGen &&\n          gateForOtherGen.op === 'AND' &&\n          ((gateForOtherGen.in1 === partialSum &&\n            gateForOtherGen.in2 === carry) ||\n            (gateForOtherGen.in1 === carry &&\n              gateForOtherGen.in2 === partialSum))\n        ) {\n          markSwap(propagateCarry, otherGen);\n          orCarry = orWithGen;\n        } else if (\n          gateForOtherProp &&\n          gateForOtherProp.op === 'AND'\n        ) {\n          markSwap(generateCarry, otherProp);\n          orCarry = orWithProp;\n        } else {\n          // Default: try gen first\n          markSwap(propagateCarry, otherGen);\n          orCarry = orWithGen;\n        }\n      } else {\n        throw new Error(`Cannot find carry OR gate for bit ${i}`);\n      }\n    }\n\n    carry = orCarry.out;\n\n    // Sanity check: carry should not be a z-wire (unless it's the final z)\n    const finalZ = `z${numBits.toString().padStart(2, '0')}`;\n    if (carry.startsWith('z') && carry !== finalZ) {\n      // The carry wire is a z-wire, which means it was swapped with the real carry.\n      // Find what the real carry should be: it's the wire that the z-gate should output.\n      // The z-wire for bit j should be output by the XOR chain for bit j.\n      const zBit = parseInt(carry.slice(1));\n      if (zBit <= numBits) {\n        const xz = `x${zBit.toString().padStart(2, '0')}`;\n        const yz = `y${zBit.toString().padStart(2, '0')}`;\n        const xorForZ = findGate('XOR', xz, yz);\n        if (xorForZ) {\n          const secondXor = findSecondXorWithInput(xorForZ.out);\n          if (secondXor && secondXor.out !== carry) {\n            markSwap(carry, secondXor.out);\n            carry = secondXor.out;\n          }\n        }\n      }\n    }\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[{"oldStart":49,"oldLines":36,"newStart":49,"newLines":21,"lines":[" /**","  * Find the 8 wires (4 pairs) that have been swapped in a binary adder circuit.","  *","- * A correct ripple-carry adder for bit i (i > 0) has this structure:","- *   x_i XOR y_i -> t_i          (partial sum)","- *   t_i XOR c_{i-1} -> z_i      (final sum = partial XOR carry-in)","- *   x_i AND y_i -> a_i          (generate carry)","- *   t_i AND c_{i-1} -> b_i      (propagate carry)","- *   a_i OR b_i -> c_i           (carry out)","- *","- * Bit 0:","- *   x00 XOR y00 -> z00","- *   x00 AND y00 -> c00","- *","- * The final carry c_N -> z_{N+1}","- *","- * We detect swaps by checking structural invariants of this adder pattern.","+ * Strategy: trace the expected ripple-carry adder structure bit by bit.","+ * At each bit, we know what gates should exist and what their inputs should be.","+ * When we can't find an expected gate, it means one of the input wires was","+ * swapped (its producing gate has the wrong output name). We identify the","+ * swap and fix it before continuing.","  */"," export function findSwappedWires(gates: Gate[]): string[] {","-  // Build lookup structures","+  // Build lookup: output wire -> gate","   const gateByOutput = new Map<string, Gate>();","   for (const g 