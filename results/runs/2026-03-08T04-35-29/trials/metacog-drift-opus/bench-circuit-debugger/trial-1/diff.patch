+    const xi = `x${i.toString().padStart(2, '0')}`;
+    const yi = `y${i.toString().padStart(2, '0')}`;
+    const zi = `z${i.toString().padStart(2, '0')}`;
+
+    // --- PARTIAL SUM: xi XOR yi ---
+    const xorXY = findGate('XOR', xi, yi);
+    if (!xorXY) throw new Error(`Missing XOR for ${xi}, ${yi}`);
+    let partialSum = xorXY.out;
+
+    // --- SUM GATE: partialSum XOR carry -> zi ---
+    let xorSumCarry = findGate('XOR', partialSum, carry);
+
+    if (!xorSumCarry) {
+      // partialSum or carry wire name is wrong. Find the right gate.
+      const xorWithPartial = findSecondXorWithInput(partialSum);
+      const xorWithCarry = findSecondXorWithInput(carry);
+
+      if (xorWithPartial && !xorWithCarry) {
+        const correctCarry =
+          xorWithPartial.in1 === partialSum
+            ? xorWithPartial.in2
+            : xorWithPartial.in1;
+        markSwap(carry, correctCarry);
+        carry = correctCarry;
+        xorSumCarry = xorWithPartial;
+      } else if (xorWithCarry && !xorWithPartial) {
+        const correctPS =
+          xorWithCarry.in1 === carry ? xorWithCarry.in2 : xorWithCarry.in1;
+        markSwap(partialSum, correctPS);
+        partialSum = correctPS;
+        xorSumCarry = xorWithCarry;
+      } else if (xorWithPartial && xorWithCarry) {
+        // Both found. The one outputting zi (or closer to zi) is for this bit.
+        if (xorWithPartial.out === zi || xorWithCarry.out !== zi) {
+          const correctCarry =
+            xorWithPartial.in1 === partialSum
+              ? xorWithPartial.in2
+              : xorWithPartial.in1;
+          markSwap(carry, correctCarry);
+          carry = correctCarry;
+          xorSumCarry = xorWithPartial;
+        } else {
+          const correctPS =
+            xorWithCarry.in1 === carry
+              ? xorWithCarry.in2
+              : xorWithCarry.in1;
+          markSwap(partialSum, correctPS);
+          partialSum = correctPS;
+          xorSumCarry = xorWithCarry;
+        }
+      } else {
+        throw new Error(`Cannot find second XOR for bit ${i}`);
+      }
+    }
+
+    if (xorSumCarry.out !== zi) {
+      markSwap(xorSumCarry.out, zi);
+    }
+
+    // --- GENERATE CARRY: xi AND yi ---
+    const andXY = findGate('AND', xi, yi);
+    if (!andXY) throw new Error(`Missing AND for ${xi}, ${yi}`);
+    const generateCarry = andXY.out;
+
+    // --- PROPAGATE CARRY: partialSum AND carry ---
+    const andPC = findGate('AND', partialSum, carry);
+    if (!andPC) {
+      throw new Error(
+        `Missing propagate AND for bit ${i}: ${partialSum} AND ${carry}`,
+      );
+    }
+    const propagateCarry = andPC.out;
+
+    // --- CARRY OUT: generateCarry OR propagateCarry ---
+    // In a correct adder, both feed into the same OR gate.
+    // Strategy: find OR gates referencing each wire.
+    const orForGen = findOrGateWithInput(generateCarry);
+    const orForProp = findOrGateWithInput(propagateCarry);
+
+    if (orForGen && orForProp && orForGen === orForProp) {
+      // Perfect match — same OR gate
+      carry = orForGen.out;
+    } else if (orForGen && !orForProp) {
+      // propagateCarry has no OR gate → it was swapped.
+      // orForGen's other input is the original propagateCarry wire name.
+      const otherInput =
+        orForGen.in1 === generateCarry ? orForGen.in2 : orForGen.in1;
+      markSwap(propagateCarry, otherInput);
+      carry = orForGen.out;
+    } else if (orForProp && !orForGen) {
+      // generateCarry has no OR gate → it was swapped.
+      const otherInput =
+        orForProp.in1 === propagateCarry
+          ? orForProp.in2
+          : orForProp.in1;
+      markSwap(generateCarry, otherInput);
+      carry = orForProp.out;
+    } else if (orForGen && orForProp && orForGen !== orForProp) {
+      // Both have OR gates, but different ones. One is this bit's gate,
+      // the other is from a different bit.
+      // Disambiguation: check which OR gate's output feeds into next bit.
+      const otherGen =
+        orForGen.in1 === generateCarry ? orForGen.in2 : orForGen.in1;
+      const otherProp =
+        orForProp.in1 === propagateCarry
+          ? orForProp.in2
+          : orForProp.in1;
+
+      let resolved = false;
+      if (i + 1 < numBits) {
+        const xNext = `x${(i + 1).toString().padStart(2, '0')}`;
+        const yNext = `y${(i + 1).toString().padStart(2, '0')}`;
+        const xorNext = findGate('XOR', xNext, yNext);
+        if (xorNext) {
+          const genNext = findGate('XOR', xorNext.out, orForGen.out);
+          const propNext = findGate('XOR', xorNext.out, orForProp.out);
+          if (genNext && !propNext) {
+            markSwap(propagateCarry, otherGen);
+            carry = orForGen.out;
+            resolved = true;
+          } else if (propNext && !genNext) {
+            markSwap(generateCarry, otherProp);
+            carry = orForProp.out;
+            resolved = true;
+          }
+        }
+      } else {
+        if (orForGen.out === finalZ) {
+          markSwap(propagateCarry, otherGen);
+          carry = orForGen.out;
+          resolved = true;
+        } else if (orForProp.out === finalZ) {
+          markSwap(generateCarry, otherProp);
+          carry = orForProp.out;
+          resolved = true;
+        }
+      }
+
+      if (!resolved) {
+        // Structural check: which gate's other input matches expected structure
+        const gateForOtherGen = gateByOutput.get(otherGen);
+        const otherGenMatch =
+          gateForOtherGen &&
+          gateForOtherGen.op === 'AND' &&
+          ((gateForOtherGen.in1 === partialSum &&
+            gateForOtherGen.in2 === carry) ||
+            (gateForOtherGen.in1 === carry &&
+              gateForOtherGen.in2 === partialSum));
+        if (otherGenMatch) {
+          markSwap(propagateCarry, otherGen);
+          carry = orForGen.out;
+        } else {
+          markSwap(generateCarry, otherProp);
+          carry = orForProp.out;
+        }
+      }
+    } else {
+      // Neither has an OR gate. Both generateCarry AND propagateCarry
+      // have been swapped away from this bit's OR gate.
+      // Find the OR gate by looking ahead to the next bit.
+      let found = false;
+
+      if (i + 1 < numBits) {
+        const xNext = `x${(i + 1).toString().padStart(2, '0')}`;
+        const yNext = `y${(i + 1).toString().padStart(2, '0')}`;
+        const xorNext = findGate('XOR', xNext, yNext);
+        if (xorNext) {
+          const secondXorNext = findSecondXorWithInput(xorNext.out);
+          if (secondXorNext) {
+            const nextCarry =
+              secondXorNext.in1 === xorNext.out
+                ? secondXorNext.in2
+                : secondXorNext.in1;
+            const orGate = gateByOutput.get(nextCarry);
+            if (orGate && orGate.op === 'OR') {
+              // Fix both swapped wires
+              if (orGate.in1 !== generateCarry && orGate.in1 !== propagateCarry) {
+                markSwap(generateCarry, orGate.in1);
+              }
+              // Re-check after first swap
+              if (orGate.in2 !== propagateCarry && orGate.in1 !== propagateCarry) {
+                markSwap(propagateCarry, orGate.in2);
+              }
+              carry = orGate.out;
+              found = true;
+            }
+          }
+        }
+      } else {
+        // Last bit: OR gate output should be z_N
+        const orGate = gateByOutput.get(finalZ);
+        if (orGate && orGate.op === 'OR') {
+          if (orGate.in1 !== generateCarry && orGate.in1 !== propagateCarry) {
+            markSwap(generateCarry, orGate.in1);
+          }
+          if (orGate.in2 !== propagateCarry && orGate.in1 !== propagateCarry) {
+            markSwap(propagateCarry, orGate.in2);
+          }
+          carry = finalZ;
+          found = true;
+        }
+      }
+
+      if (!found) {
+        throw new Error(`Cannot find carry OR gate for bit ${i}`);
+      }
+    }
+
+    // Sanity: carry should not be z-wire (unless final)
+    if (carry.startsWith('z') && carry !== finalZ) {
+      const zBit = parseInt(carry.slice(1));
+      if (zBit <= numBits) {
+        const xz = `x${zBit.toString().padStart(2, '0')}`;
+        const yz = `y${zBit.toString().padStart(2, '0')}`;
+        const xorForZ = findGate('XOR', xz, yz);
+        if (xorForZ) {
+          const secondXor = findSecondXorWithInput(xorForZ.out);
+          if (secondXor && secondXor.out !== carry) {
+            markSwap(carry, secondXor.out);
+            carry = secondXor.out;
+          }
+        }
+      }
+    }
+  }
+
+  return [...swapped].sort();
+}
