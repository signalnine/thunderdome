gate for this bit should have BOTH our carry wires as inputs.\n      // Since they're in different gates, we need to find which OR gate is ours.\n      //\n      // Check orForGen: does it have generateCarry as one input?\n      // What's the other input? If that other input should be propagateCarry\n      // (i.e., the other input is the original wire name for propCarry), then\n      // orForGen is the right gate and propCarry was swapped.\n      //\n      // Strategy: one OR gate has the right structure for this bit, the other\n      // is from another bit. Find which by checking if the OR gate's output\n      // feeds into the next bit's carry chain (lookahead) or by checking\n      // structural properties.\n\n      // The OR gate for this bit should have both inputs produced by AND gates\n      // where one AND is (xi, yi) and the other is (partialSum, carry).\n      // Since we can't check that directly after swaps, use alternative:\n\n      // Approach: try both options and see which gives a consistent carry chain.\n      // For the last bit, the carry should be z_N.\n      // For other bits, the carry should feed into the next bit's second XOR.\n\n      const otherGen =\n        orForGen.in1 === generateCarry ? orForGen.in2 : orForGen.in1;\n      const otherProp =\n        orForProp.in1 === propagateCarry ? orForProp.in2 : orForProp.in1;\n\n      // Quick check: if orForGen's other input matches propagateCarry's\n      // original position (i.e., should be this bit's propagateCarry)\n      // We check if otherGen is the output of an AND gate with partialSum\n      // and carry as inputs (which is what propagateCarry should be).\n      // But wait — after the swap, the gate producing otherGen might not\n      // be the right one. Let me use a different check.\n\n      // Use next-bit verification when possible:\n      let resolved = false;\n      if (i + 1 < numBits) {\n        const xNext = `x${(i + 1).toString().padStart(2, '0')}`;\n        const yNext = `y${(i + 1).toString().padStart(2, '0')}`;\n        const xorNext = findGate('XOR', xNext, yNext);\n        if (xorNext) {\n          const genCarryUsedNext = findGate(\n            'XOR',\n            xorNext.out,\n            orForGen.out,\n          );\n          const propCarryUsedNext = findGate(\n            'XOR',\n            xorNext.out,\n            orForProp.out,\n          );\n          if (genCarryUsedNext && !propCarryUsedNext) {\n            markSwap(propagateCarry, otherGen);\n            carry = orForGen.out;\n            resolved = true;\n          } else if (propCarryUsedNext && !genCarryUsedNext) {\n            markSwap(generateCarry, otherProp);\n            carry = orForProp.out;\n            resolved = true;\n          }\n        }\n      } else {\n        // Last bit: carry should be z_N\n        if (orForGen.out === finalZ) {\n          markSwap(propagateCarry, otherGen);\n          carry = orForGen.out;\n          resolved = true;\n        } else if (orForProp.out === finalZ) {\n          markSwap(generateCarry, otherProp);\n          carry = orForProp.out;\n          resolved = true;\n        }\n      }\n\n      if (!resolved) {\n        // Structural fallback: check which other input is an AND output\n        // with this bit's inputs\n        const gateForOtherGen = gateByOutput.get(otherGen);\n        const otherGenMatch =\n          gateForOtherGen &&\n          gateForOtherGen.op === 'AND' &&\n          ((gateForOtherGen.in1 === partialSum &&\n            gateForOtherGen.in2 === carry) ||\n            (gateForOtherGen.in1 === carry &&\n              gateForOtherGen.in2 === partialSum));\n\n        if (otherGenMatch) {\n          markSwap(propagateCarry, otherGen);\n          carry = orForGen.out;\n        } else {\n          markSwap(generateCarry, otherProp);\n          carry = orForProp.out;\n        }\n      }\n    } else if (orForGen && !orForProp) {\n      // propagateCarry doesn't feed into any OR gate.\n      // Check if this is actually the right OR gate for this bit.\n      // If generateCarry is ALSO swapped (to a wire from another bit),\n      // the OR gate found might be from that other bit.\n      // Verify by checking if the OR gate's output feeds into next bit.\n      const otherInput =\n        orForGen.in1 === generateCarry ? orForGen.in2 : orForGen.in1;\n\n      let useGen = true;\n      if (i + 1 < numBits) {\n        const xNext = `x${(i + 1).toString().padStart(2, '0')}`;\n        const yNext = `y${(i + 1).toString().padStart(2, '0')}`;\n        const xorNext = findGate('XOR', xNext, yNext);\n        if (xorNext) {\n          const nextXor = findGate('XOR', xorNext.out, orForGen.out);\n          if (!nextXor) {\n            // OR gate's output doesn't feed into next bit — wrong gate.\n            // Both generateCarry and propagateCarry are swapped.\n            useGen = false;\n          }\n        }\n      } else {\n        // Last bit: check if OR output is z_N\n        if (orForGen.out !== finalZ) {\n          useGen = false;\n        }\n      }\n\n      if (useGen) {\n        markSwap(propagateCarry, otherInput);\n        carry = orForGen.out;\n      } else {\n        // Fall through to \"both swapped\" handling below\n        orForGen; // both are swapped, handled in the else block\n        // Find correct OR gate via next bit\n        let found = false;\n        if (i + 1 < numBits) {\n          const xNext = `x${(i + 1).toString().padStart(2, '0')}`;\n          const yNext = `y${(i + 1).toString().padStart(2, '0')}`;\n          const xorNext = findGate('XOR', xNext, yNext);\n          if (xorNext) {\n            const secondXorNext = findSecondXorWithInput(xorNext.out);\n            if (secondXorNext) {\n              const nextCarry =\n                secondXorNext.in1 === xorNext.out\n                  ? secondXorNext.in2\n                  : secondXorNext.in1;\n              const orGate = gateByOutput.get(nextCarry);\n              if (orGate && orGate.op === 'OR'