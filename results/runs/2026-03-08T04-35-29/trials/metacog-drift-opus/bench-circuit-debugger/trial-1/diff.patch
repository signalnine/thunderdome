r structure bit by bit.\n * At each bit, we know what gates should exist and what their inputs should be.\n * When we can't find an expected gate, it means one of the input wires was\n * swapped (its producing gate has the wrong output name). We identify the\n * swap and fix it before continuing.\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Build lookup: output wire -> gate\n  const gateByOutput = new Map<string, Gate>();\n  for (const g of gates) {\n    gateByOutput.set(g.out, g);\n  }\n\n  // Build lookup: (op, inputSet) -> gate\n  // We need this to find gates by their operation and inputs\n  function findGate(\n    op: Gate['op'],\n    in1: string,\n    in2: string,\n  ): Gate | undefined {\n    return gates.find(\n      (g) =>\n        g.op === op &&\n        ((g.in1 === in1 && g.in2 === in2) ||\n          (g.in1 === in2 && g.in2 === in1)),\n    );\n  }\n\n  // Find all XOR gates that are NOT the first-level xi XOR yi gates\n  // These are the \"second-level\" XOR gates: partialSum XOR carry -> zi\n  function isInputWire(w: string): boolean {\n    return w.startsWith('x') || w.startsWith('y');\n  }\n\n  function findSecondXorWithInput(wire: string): Gate | undefined {\n    return gates.find(\n      (g) =>\n        g.op === 'XOR' &&\n        (g.in1 === wire || g.in2 === wire) &&\n        !isInputWire(g.in1) &&\n        !isInputWire(g.in2),\n    );\n  }\n\n  const numBits =\n    Math.max(\n      ...gates\n        .flatMap((g) => [g.in1, g.in2])\n        .filter((w) => w.startsWith('x'))\n        .map((w) => parseInt(w.slice(1))),\n    ) + 1;\n\n  const swapped = new Set<string>();\n\n  function swapOutputs(wire1: string, wire2: string): void {\n    const gate1 = gateByOutput.get(wire1);\n    const gate2 = gateByOutput.get(wire2);\n    if (gate1 && gate2) {\n      gate1.out = wire2;\n      gate2.out = wire1;\n      gateByOutput.set(wire1, gate2);\n      gateByOutput.set(wire2, gate1);\n    }\n  }\n\n  function markSwap(wire1: string, wire2: string): void {\n    swapped.add(wire1);\n    swapped.add(wire2);\n    swapOutputs(wire1, wire2);\n  }\n\n  // Process bit 0\n  const xor0 = findGate('XOR', 'x00', 'y00');\n  const and0 = findGate('AND', 'x00', 'y00');\n  if (!xor0 || !and0) throw new Error('Missing bit 0 gates');\n\n  if (xor0.out !== 'z00') {\n    markSwap(xor0.out, 'z00');\n  }\n\n  let carry = and0.out;\n\n  // Process bits 1..numBits-1\n  for (let i = 1; i < numBits; i++) {\n    const xi = `x${i.toString().padStart(2, '0')}`;\n    const yi = `y${i.toString().padStart(2, '0')}`;\n    const zi = `z${i.toString().padStart(2, '0')}`;\n\n    // Step 1: xi XOR yi -> partialSum\n    const xorXY = findGate('XOR', xi, yi);\n    if (!xorXY) throw new Error(`Missing XOR for ${xi}, ${yi}`);\n    let partialSum = xorXY.out;\n\n    // Step 2: partialSum XOR carry -> zi\n    let xorSumCarry = findGate('XOR', partialSum, carry);\n\n    if (!xorSumCarry) {\n      // Either partialSum or carry is wrong (one was swapped to a different name).\n      // Look for a second-level XOR that uses partialSum.\n      const xorWithPartial = findSecondXorWithInput(partialSum);\n      // Look for a second-level XOR that uses carry.\n      const xorWithCarry = findSecondXorWithInput(carry);\n\n      if (xorWithPartial && !xorWithCarry) {\n        // carry is the problem\n        const correctCarry =\n          xorWithPartial.in1 === partialSum\n            ? xorWithPartial.in2\n            : xorWithPartial.in1;\n        markSwap(carry, correctCarry);\n        carry = correctCarry;\n        xorSumCarry = xorWithPartial;\n      } else if (xorWithCarry && !xorWithPartial) {\n        // partialSum is the problem\n        const correctPartialSum =\n          xorWithCarry.in1 === carry ? xorWithCarry.in2 : xorWithCarry.in1;\n        markSwap(partialSum, correctPartialSum);\n        partialSum = correctPartialSum;\n        xorSumCarry = xorWithCarry;\n      } else if (xorWithPartial && xorWithCarry) {\n        // Both found second-level XORs. One is the correct gate for this bit,\n        // and the other is for a different bit. The correct one for this bit\n        // should output zi (or have zi as its expected output).\n        // Try partialSum's XOR first: if its other input should be the carry\n        if (xorWithPartial.out === zi || xorWithCarry.out !== zi) {\n          // partialSum found the right gate, so carry is wrong\n          const correctCarry =\n            xorWithPartial.in1 === partialSum\n              ? xorWithPartial.in2\n              : xorWithPartial.in1;\n          markSwap(carry, correctCarry);\n          carry = correctCarry;\n          xorSumCarry = xorWithPartial;\n        } else {\n          // carry found the right gate, so partialSum is wrong\n          const correctPartialSum =\n            xorWithCarry.in1 === carry ? xorWithCarry.in2 : xorWithCarry.in1;\n          markSwap(partialSum, correctPartialSum);\n          partialSum = correctPartialSum;\n          xorSumCarry = xorWithCarry;\n        }\n      } else {\n        throw new Error(`Cannot find second XOR for bit ${i}`);\n      }\n    }\n\n    // xorSumCarry should output zi\n    if (xorSumCarry.out !== zi) {\n      markSwap(xorSumCarry.out, zi);\n    }\n\n    // Step 3: xi AND yi -> generateCarry\n    const andXY = findGate('AND', xi, yi);\n    if (!andXY) throw new Error(`Missing AND for ${xi}, ${yi}`);\n    const generateCarry = andXY.out;\n\n    // Step 4: partialSum AND carry -> propagateCarry\n    const andPC = findGate('AND', partialSum, carry);\n    if (!andPC) {\n      throw new Error(\n        `Missing propagate AND for bit ${i}: ${partialSum} AND ${carry}`,\n      );\n    }\n    const propagateCarry = andPC.out;\n\n    // Step 5: generateCarry OR propagateCarry -> carryOut\n    let orCarry = findGate('OR', generateCarry, propagateCarry);\n    if (!orCarry) {\n      // One of generateCarry or propagateCarry is swapped.\n      // Find the OR gate that has one of them as input.\n      const or