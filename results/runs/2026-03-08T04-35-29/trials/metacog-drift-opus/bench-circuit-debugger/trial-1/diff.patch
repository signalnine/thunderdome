             const orGate = gateByOutput.get(nextCarry);\n              if (orGate && orGate.op === 'OR') {\n                fixBothSwaps(orGate, generateCarry, propagateCarry);\n                carry = orGate.out;\n                found = true;\n              }\n            }\n          }\n        } else {\n          const orGate = gateByOutput.get(finalZ);\n          if (orGate && orGate.op === 'OR') {\n            fixBothSwaps(orGate, generateCarry, propagateCarry);\n            carry = finalZ;\n            found = true;\n          }\n        }\n        if (!found) {\n          throw new Error(`Cannot find carry OR gate for bit ${i}`);\n        }\n      }\n    } else {\n      // Neither feeds into an OR gate. Both are swapped.\n      // Find the correct OR gate by looking at what feeds into next bit.\n      let found = false;\n\n      if (i + 1 < numBits) {\n        const xNext = `x${(i + 1).toString().padStart(2, '0')}`;\n        const yNext = `y${(i + 1).toString().padStart(2, '0')}`;\n        const xorNext = findGate('XOR', xNext, yNext);\n        if (xorNext) {\n          const secondXorNext = findSecondXorWithInput(xorNext.out);\n          if (secondXorNext) {\n            const nextCarry =\n              secondXorNext.in1 === xorNext.out\n                ? secondXorNext.in2\n                : secondXorNext.in1;\n            const orGate = gateByOutput.get(nextCarry);\n            if (orGate && orGate.op === 'OR') {\n              // Fix both swaps\n              const orIn1 = orGate.in1;\n              const orIn2 = orGate.in2;\n              // One of orIn1/orIn2 should be the original generateCarry,\n              // the other the original propagateCarry. Map them.\n              // generateCarry was output by AND(xi,yi) but swapped.\n              // propagateCarry was output by AND(partialSum,carry) but swapped.\n              // We need to swap each with the correct OR gate input.\n              if (orIn1 !== generateCarry && orIn1 !== propagateCarry) 