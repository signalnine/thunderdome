arkSwap(genCarry, orIn1);\n    }\n    if (orIn2 !== genCarry && orIn2 !== propCarry) {\n      markSwap(propCarry, orIn2);\n    }\n  }","originalFile":"export interface Gate {\n  op: 'AND' | 'OR' | 'XOR';\n  in1: string;\n  in2: string;\n  out: string;\n}\n\n/**\n * Simulate a circuit: given gates and initial wire values,\n * compute all wire values by processing gates in dependency order.\n */\nexport function simulate(\n  gates: Gate[],\n  inputs: Record<string, number>,\n): Record<string, number> {\n  const wires: Record<string, number> = { ...inputs };\n  const remaining = [...gates];\n\n  while (remaining.length > 0) {\n    let progress = false;\n    for (let i = remaining.length - 1; i >= 0; i--) {\n      const gate = remaining[i];\n      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {\n        const a = wires[gate.in1];\n        const b = wires[gate.in2];\n        switch (gate.op) {\n          case 'AND':\n            wires[gate.out] = a & b;\n            break;\n          case 'OR':\n            wires[gate.out] = a | b;\n            break;\n          case 'XOR':\n            wires[gate.out] = a ^ b;\n            break;\n        }\n        remaining.splice(i, 1);\n        progress = true;\n      }\n    }\n    if (!progress) {\n      throw new Error('Circuit has unresolvable dependencies');\n    }\n  }\n\n  return wires;\n}\n\n/**\n * Find the 8 wires (4 pairs) that have been swapped in a binary adder circuit.\n *\n * Uses structural rules of a ripple-carry adder to detect anomalies.\n * A correct adder follows these patterns:\n * - z-wires (except z00 and zN) are outputs of second-level XOR gates\n * - Second-level XOR gates (non-input XORs) should output z-wires\n * - AND gate outputs feed into OR gates\n * - OR gate outputs are internal (not z-wires, except the final carry zN)\n *\n * We trace the carry chain bit by bit, fixing swaps as we find them.\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  const gateByOutput = new Map<string, Gate>();\n  for (const g of gates) {\n    gateByOutput.set(g.out, g);\n  }\n\n  function findGate(\n    op: Gate['op'],\n    in1: string,\n    in2: string,\n  ): Gate | undefined {\n    return gates.find(\n      (g) =>\n        g.op === op &&\n        ((g.in1 === in1 && g.in2 === in2) ||\n          (g.in1 === in2 && g.in2 === in1)),\n    );\n  }\n\n  function isInputWire(w: string): boolean {\n    return w.startsWith('x') || w.startsWith('y');\n  }\n\n  function findSecondXorWithInput(wire: string): Gate | undefined {\n    return gates.find(\n      (g) =>\n        g.op === 'XOR' &&\n        (g.in1 === wire || g.in2 === wire) &&\n        !isInputWire(g.in1) &&\n        !isInputWire(g.in2),\n    );\n  }\n\n  // Build a map: wire -> list of gates that use it as input\n  function findOrGateWithInput(wire: string): Gate | undefined {\n    return gates.find(\n      (g) =>\n        g.op === 'OR' && (g.in1 === wire || g.in2 === wire),\n    );\n  }\n\n  const numBits =\n    Math.max(\n      ...gates\n        .flatMap((g) => [g.in1, g.in2])\n        .filter((w) => w.startsWith('x'))\n        .map((w) => parseInt(w.slice(1))),\n    ) + 1;\n\n  const finalZ = `z${numBits.toString().padStart(2, '0')}`;\n  const swapped = new Set<string>();\n\n  function swapOutputs(wire1: string, wire2: string): void {\n    const gate1 = gateByOutput.get(wire1);\n    const gate2 = gateByOutput.get(wire2);\n    if (gate1 && gate2) {\n      gate1.out = wire2;\n      gate2.out = wire1;\n      gateByOutput.set(wire1, gate2);\n      gateByOutput.set(wire2, gate1);\n    }\n  }\n\n  function markSwap(wire1: string, wire2: string): void {\n    swapped.add(wire1);\n    swapped.add(wire2);\n    swapOutputs(wire1, wire2);\n  }\n\n  // Process bit 0\n  const xor0 = findGate('XOR', 'x00', 'y00');\n  const and0 = findGate('AND', 'x00', 'y00');\n  if (!xor0 || !and0) throw new Error('Missing bit 0 gates');\n\n  if (xor0.out !== 'z00') {\n    markSwap(xor0.out, 'z00');\n  }\n\n  let carry = and0.out;\n\n  // Bit 0 carry should not be a z-wire\n  if (carry.startsWith('z')) {\n    // Find the wire it was swapped with by looking for a gate that\n    // should use the carry. Specifically, the next bit's XOR.\n    const xor1 = findGate('XOR', 'x01', 'y01');\n    if (xor1) {\n      const secondXor = findSecondXorWithInput(xor1.out);\n      if (secondXor) {\n        const otherInput =\n          secondXor.in1 === xor1.out ? secondXor.in2 : secondXor.in1;\n        markSwap(carry, otherInput);\n        carry = otherInput;\n      }\n    }\n  }\n\n  // Process bits 1..numBits-1\n  for (let i = 1; i < numBits; i++) {\n    const xi = `x${i.toString().padStart(2, '0')}`;\n    const yi = `y${i.toString().padStart(2, '0')}`;\n    const zi = `z${i.toString().padStart(2, '0')}`;\n\n    // Step 1: xi XOR yi -> partialSum\n    const xorXY = findGate('XOR', xi, yi);\n    if (!xorXY) throw new Error(`Missing XOR for ${xi}, ${yi}`);\n    let partialSum = xorXY.out;\n\n    // Step 2: partialSum XOR carry -> zi\n    let xorSumCarry = findGate('XOR', partialSum, carry);\n\n    if (!xorSumCarry) {\n      // Either partialSum or carry is wrong.\n      const xorWithPartial = findSecondXorWithInput(partialSum);\n      const xorWithCarry = findSecondXorWithInput(carry);\n\n      if (xorWithPartial && !xorWithCarry) {\n        const correctCarry =\n          xorWithPartial.in1 === partialSum\n            ? xorWithPartial.in2\n            : xorWithPartial.in1;\n        markSwap(carry, correctCarry);\n        carry = correctCarry;\n        xorSumCarry = xorWithPartial;\n      } else if (xorWithCarry && !xorWithPartial) {\n        const correctPartialSum =\n          xorWithCarry.in1 === carry ? xorWithCarry.in2 : xorWithCarry.in1;\n        markSwap(partialSum, correctPartialSum);\n        partialSum = correctPartialSum;\n        xorSumCarry = xorWithCarry;\n      } else if (xorWithPartial && xorWithCarry) {\n        if (xorWithPartial.out === zi || xorWithCarry.out !== zi) {\n          