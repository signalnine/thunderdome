determine which OR input corresponds to generateCarry\n    // and which to propagateCarry.\n    // generateCarry is the output of AND(xi, yi).\n    // propagateCarry is the output of AND(partialSum, carry).\n    // After swaps, genCarry and propCarry have wrong names, but the OR gate\n    // still references the correct (original) wire names.\n    // The gate producing orIn1 (in the original circuit) was one of the AND gates.\n    // After swaps, the gate NOW producing orIn1 might be different.\n    // But we know that genCarry and propCarry need to be swapped to match\n    // orIn1 and orIn2 (in some order).\n    if (orIn1 !== genCarry && orIn1 !== propCarry) {\n      // orIn1 is an original name that genCarry or propCarry should match\n      // Try to figure out which: genCarry should pair with the AND(xi,yi) output\n      // For simplicity: swap genCarry with orIn1 first\n      markSwap(genCarry, orIn1);\n    }\n    if (orIn2 !== genCarry && orIn2 !== propCarry) {\n      markSwap(propCarry, orIn2);\n    }\n  }\n\n  // Process bit 0\n  const xor0 = findGate('XOR', 'x00', 'y00');\n  const and0 = findGate('AND', 'x00', 'y00');\n  if (!xor0 || !and0) throw new Error('Missing bit 0 gates');\n\n  if (xor0.out !== 'z00') {\n    markSwap(xor0.out, 'z00');\n  }\n\n  let carry = and0.out;\n\n  // Bit 0 carry should not be a z-wire\n  if (carry.startsWith('z')) {\n    // Find the wire it was swapped with by looking for a gate that\n    // should use the carry. Specifically, the next bit's XOR.\n    const xor1 = findGate('XOR', 'x01', 'y01');\n    if (xor1) {\n      const secondXor = findSecondXorWithInput(xor1.out);\n      if (secondXor) {\n        const otherInput =\n          secondXor.in1 === xor1.out ? secondXor.in2 : secondXor.in1;\n        markSwap(carry, otherInput);\n        carry = otherInput;\n      }\n    }\n  }\n\n  // Process bits 1..numBits-1\n  for (let i = 1; i < numBits; i++) {\n    const xi = `x${i.toString().padStart(2, '0')}`;\n    const yi = `y${i.toStr