arry = orWithProp;\n        } else {\n          // Neither other input directly matches expected structure.\n          // Fall back: prefer the gate whose \"other\" input is produced\n          // by an AND gate (more likely to be carry-related).\n          if (gateForOtherGen && gateForOtherGen.op === 'AND') {\n            markSwap(propagateCarry, otherGen);\n            orCarry = orWithGen;\n          } else if (gateForOtherProp && gateForOtherProp.op === 'AND') {\n            markSwap(generateCarry, otherProp);\n            orCarry = orWithProp;\n          } else {\n            markSwap(propagateCarry, otherGen);\n            orCarry = orWithGen;\n          }\n        }\n      }","originalFile":"export interface Gate {\n  op: 'AND' | 'OR' | 'XOR';\n  in1: string;\n  in2: string;\n  out: string;\n}\n\n/**\n * Simulate a circuit: given gates and initial wire values,\n * compute all wire values by processing gates in dependency order.\n */\nexport function simulate(\n  gates: Gate[],\n  inputs: Record<string, number>,\n): Record<string, number> {\n  const wires: Record<string, number> = { ...inputs };\n  const remaining = [...gates];\n\n  while (remaining.length > 0) {\n    let progress = false;\n    for (let i = remaining.length - 1; i >= 0; i--) {\n      const gate = remaining[i];\n      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {\n        const a = wires[gate.in1];\n        const b = wires[gate.in2];\n        switch (gate.op) {\n          case 'AND':\n            wires[gate.out] = a & b;\n            break;\n          case 'OR':\n            wires[gate.out] = a | b;\n            break;\n          case 'XOR':\n            wires[gate.out] = a ^ b;\n            break;\n        }\n        remaining.splice(i, 1);\n        progress = true;\n      }\n    }\n    if (!progress) {\n      throw new Error('Circuit has unresolvable dependencies');\n    }\n  }\n\n  return wires;\n}\n\n/**\n * Find the 8 wires (4 pairs) that have been swapped in a binary adder circuit.\n *\n * Strategy: trace the expected ripple-carry adder structure bit by bit.\n * At each bit, we know what gates should exist and what their inputs should be.\n * When we can't find an expected gate, it means one of the input wires was\n * swapped (its producing gate has the wrong output name). We identify the\n * swap and fix it before continuing.\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Build lookup: output wire -> gate\n  const gateByOutput = new Map<string, Gate>();\n  for (const g of gates) {\n    gateByOutput.set(g.out, g);\n  }\n\n  // Build lookup: (op, inputSet) -> gate\n  // We need this to find gates by their operation and inputs\n  function findGate(\n    op: Gate['op'],\n    in1: string,\n    in2: string,\n  ): Gate | undefined {\n    return gates.find(\n      (g) =>\n        g.op === op &&\n        ((g.in1 === in1 && g.in2 === in2) ||\n          (g.in1 === in2 && g.in2 === in1)),\n    );\n  }\n\n  // Find all XOR gates that are NOT the first-level xi XOR yi gates\n  // These are the \"second-level\" XOR gates: partialSum XOR carry -> zi\n  function isInputWire(w: string): boolean {\n    return w.startsWith('x') || w.startsWith('y');\n  }\n\n  function findSecondXorWithInput(wire: string): Gate | undefined {\n    return gates.find(\n      (g) =>\n        g.op === 'XOR' &&\n        (g.in1 === wire || g.in2 === wire) &&\n        !isInputWire(g.in1) &&\n        !isInputWire(g.in2),\n    );\n  }\n\n  const numBits =\n    Math.max(\n      ...gates\n        .flatMap((g) => [g.in1, g.in2])\n        .filter((w) => w.startsWith('x'))\n        .map((w) => parseInt(w.slice(1))),\n    ) + 1;\n\n  const swapped = new Set<string>();\n\n  function swapOutputs(wire1: string, wire2: string): void {\n    const gate1 = gateByOutput.get(wire1);\n    const gate2 = gateByOutput.get(wire2);\n    if (gate1 && gate2) {\n      gate1.out = wire2;\n      gate2.out = wire1;\n      gateByOutput.set(wire1, gate2);\n      gateByOutput.