 wires[gate.in2];\n        switch (gate.op) {\n          case 'AND':\n            wires[gate.out] = a & b;\n            break;\n          case 'OR':\n            wires[gate.out] = a | b;\n            break;\n          case 'XOR':\n            wires[gate.out] = a ^ b;\n            break;\n        }\n        remaining.splice(i, 1);\n        progress = true;\n      }\n    }\n    if (!progress) {\n      throw new Error('Circuit has unresolvable dependencies');\n    }\n  }\n\n  return wires;\n}\n\n/**\n * Find the 8 wires (4 pairs) that have been swapped in a binary adder circuit.\n *\n * Strategy: trace the expected ripple-carry adder structure bit by bit.\n * At each bit, we know what gates should exist and what their inputs should be.\n * When we can't find an expected gate, it means one of the input wires was\n * swapped (its producing gate has the wrong output name). We identify the\n * swap and fix it before continuing.\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Build lookup: output wire -> gate\n  const gateByOutput = new Map<string, Gate>();\n  for (const g of gates) {\n    gateByOutput.set(g.out, g);\n  }\n\n  // Build lookup: (op, inputSet) -> gate\n  // We need this to find gates by their operation and inputs\n  function findGate(\n    op: Gate['op'],\n    in1: string,\n    in2: string,\n  ): Gate | undefined {\n    return gates.find(\n      (g) =>\n        g.op === op &&\n        ((g.in1 === in1 && g.in2 === in2) ||\n          (g.in1 === in2 && g.in2 === in1)),\n    );\n  }\n\n  // Find all XOR gates that are NOT the first-level xi XOR yi gates\n  // These are the \"second-level\" XOR gates: partialSum XOR carry -> zi\n  function isInputWire(w: string): boolean {\n    return w.startsWith('x') || w.startsWith('y');\n  }\n\n  function findSecondXorWithInput(wire: string): Gate | undefined {\n    return gates.find(\n      (g) =>\n        g.op === 'XOR' &&\n        (g.in1 === wire || g.in2 === wire) &&\n        !isInputWire(g.in1) &&\n        !isInputWire(g.in2),\n    );\n  }\n\n  const numBits =\n    Math.max(\n      ...gates\n        .flatMap((g) => [g.in1, g.in2])\n        .filter((w) => w.startsWith('x'))\n        .map((w) => parseInt(w.slice(1))),\n    ) + 1;\n\n  const swapped = new Set<string>();\n\n  function swapOutputs(wire1: string, wire2: string): void {\n    const gate1 = gateByOutput.get(wire1);\n    const gate2 = gateByOutput.get(wire2);\n    if (gate1 && gate2) {\n      gate1.out = wire2;\n      gate2.out = wire1;\n      gateByOutput.set(wire1, gate2);\n      gateByOutput.set(wire2, gate1);\n    }\n  }\n\n  function markSwap(wire1: string, wire2: string): void {\n    swapped.add(wire1);\n    swapped.add(wire2);\n    swapOutputs(wire1, wire2);\n  }\n\n  // Verify that a candidate carry wire is used as carry in the next bit.\n  // Returns true if verified, false if not.\n  function verifyCarryViaNextBit(\n    currentBit: number,\n    candidateCarry: string,\n  ): boolean {\n    const nextBit = currentBit + 1;\n    if (nextBit >= numBits) {\n      // Last bit; carry should be z_{numBits}\n      const finalZ = `z${numBits.toString().padStart(2, '0')}`;\n      return candidateCarry === finalZ;\n    }\n    const xNext = `x${nextBit.toString().padStart(2, '0')}`;\n    const yNext = `y${nextBit.toString().padStart(2, '0')}`;\n    const xorNext = findGate('XOR', xNext, yNext);\n    if (!xorNext) return false;\n    // Check if there's a second-level XOR using xorNext.out and candidateCarry\n    const secondXor = findGate('XOR', xorNext.out, candidateCarry);\n    return !!secondXor;\n  }\n\n  // Find the OR gate for this bit by looking at which OR gate's output\n  // is used as carry in the next bit's XOR gate.\n  function findOrGateViaNextBit(\n    currentBit: number,\n    genCarry: string,\n    propCarry: string,\n  ): Gate | null {\n    const nextBit = currentBit + 1;\n    if (nextBit >= numBits) {\n      // Last bit; the OR gate output should be z_{numBits}\n      const finalZ = `z${numBits.toString().padStart(2, '0')}`;\n      const orGate = gateByOutput.get(finalZ);\n      if (orGate && orGate.op === 'OR') {\n        // Fix swaps: the OR gate's inputs should be genCarry and propCarry\n        const in1 = orGate.in1;\n        const in2 = orGate.in2;\n        if (in1 !== genCarry && in1 !== propCarry) {\n          // in1 is the original gen/prop carry name. Determine which.\n          if (in2 !== genCarry && in2 !== propCarry) {\n            // Both inputs are original names; both gen and prop are swapped\n            markSwap(genCarry, in1);\n            markSwap(propCarry, in2);\n          }\n        }\n        return orGate;\n      }\n      return null;\n    }\n\n    const xNext = `x${nextBit.toString().padStart(2, '0')}`;\n    const yNext = `y${nextBit.toString().padStart(2, '0')}`;\n    const xorNext = findGate('XOR', xNext, yNext);\n    if (!xorNext) return null;\n\n    // Find the second-level XOR for next bit that uses xorNext.out\n    const secondXor = findSecondXorWithInput(xorNext.out);\n    if (!secondXor) return null;\n\n    // The other input to secondXor is the carry from bit i\n    const nextCarry =\n      secondXor.in1 === xorNext.out ? secondXor.in2 : secondXor.in1;\n\n    // nextCarry should be the output of the OR gate for bit i\n    const orGate = gateByOutput.get(nextCarry);\n    if (!orGate || orGate.op !== 'OR') return null;\n\n    // Now fix the swapped inputs. The OR gate's inputs should be genCarry\n    // and propCarry, but they have the original (pre-swap) wire names.\n    const orIn1 = orGate.in1;\n    const orIn2 = orGate.in2;\n\n    // Determine which OR input corresponds to which carry\n    if (orIn1 !== genCarry && orIn2 !== genCarry) {\n      // genCarry is not an input — it was swapped with one of the inputs\n      if (orIn1 !== propCarry) {\n        // orIn1 is the original generateCarry name\n        markSwap(genCarry, orIn1);\n      } else {\n        // orIn2 is the original generateCarry name\n        markSw