k>', '...', 32) as snippet,","+          rank","+        FROM notes_fts","+        JOIN notes ON notes.id = notes_fts.rowid","+        WHERE notes_fts MATCH ?","+        ORDER BY rank","+        LIMIT ? OFFSET ?","+      `);","+      const results = searchStmt.all(sanitized, perPage, offset) as SearchResult[];","+","+      res.json({ results, total, page, perPage });","+    } catch (err) {","+      next(err);","+    }","+  });","+","+  // GET /notes/search/suggest?q=<prefix> - Autocomplete suggestions","+  router.get('/notes/search/suggest', (req: Request, res: Response, next: NextFunction) => {","+    try {","+      const q = req.query.q as string | undefined;","+      if (!q || q.trim() === '') {","+        throw new ValidationError('Search query parameter \"q\" is required');","+      }","+","+      const sanitized = sanitizeFtsQuery(q);","+      if (!sanitized || sanitized.trim() === '') {","+        res.json({ results: [] });","+        return;","+      }","+","+      // Use prefix matching with *","+      const prefixQuery = sanitized.split(/\\s+/).map(term => term + '*').join(' ');","+","+      const suggestStmt = db.prepare(`","+        SELECT notes.id, notes.title","+        FROM notes_fts","+        JOIN notes ON notes.id = notes_fts.rowid","+        WHERE notes_fts MATCH ?","+        ORDER BY rank","+        LIMIT 5","+      `);","+      const results = suggestStmt.all(prefixQuery) as SuggestResult[];","+","+      res.json({ results });","+    } catch (err) {","+      next(err);","+    }","+  });","+","   // GET /notes - List all notes (with optional tag filter)","   router.get('/notes', (req: Request, res: Response, next: NextFunction) => {","     try {"]}],"userModified":false,"replaceAll":false}}
