@@ -0,0 +1,39 @@
+import Database from "better-sqlite3";
+import { readFileSync } from "fs";
+import { join } from "path";
+
+let db: Database.Database | null = null;
+
+export function getDb(): Database.Database {
+  if (!db) {
+    db = initDb();
+  }
+  return db;
+}
+
+export function initDb(filePath?: string): Database.Database {
+  const instance = new Database(filePath ?? ":memory:");
+  instance.pragma("journal_mode = WAL");
+  instance.pragma("foreign_keys = ON");
+
+  const schemaPath = join(__dirname, "..", "schema.sql");
+  try {
+    const schema = readFileSync(schemaPath, "utf-8");
+    instance.exec(schema);
+  } catch {
+    // If schema.sql not found relative to dist, try from cwd
+    const fallbackPath = join(process.cwd(), "schema.sql");
+    const schema = readFileSync(fallbackPath, "utf-8");
+    instance.exec(schema);
+  }
+
+  db = instance;
+  return instance;
+}
+
+export function closeDb(): void {
+  if (db) {
+    db.close();
+    db = null;
+  }
+}
