+import { Router, Response } from "express";
+import { getDb } from "../db.js";
+import { AuthenticatedRequest, authMiddleware } from "../auth.js";
+
+const router = Router();
+
+interface EventRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string;
+  session_id: string | null;
+}
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+interface WidgetRow {
+  id: string;
+  dashboard_id: string;
+  type: string;
+  config: string;
+  position_x: number;
+  position_y: number;
+  width: number;
+  height: number;
+}
+
+function escapeCsvField(value: string): string {
+  if (value.includes(",") || value.includes('"') || value.includes("\n")) {
+    return `"${value.replace(/"/g, '""')}"`;
+  }
+  return value;
+}
+
+function eventsToCsv(events: EventRow[]): string {
+  const header = "id,name,properties,timestamp,user_id,session_id";
+  const rows = events.map((e) =>
+    [
+      escapeCsvField(e.id),
+      escapeCsvField(e.name),
+      escapeCsvField(e.properties),
+      escapeCsvField(e.timestamp),
+      escapeCsvField(e.user_id || ""),
+      escapeCsvField(e.session_id || ""),
+    ].join(",")
+  );
+  return [header, ...rows].join("\n");
+}
+
+// GET /export/events?format=json|csv
+router.get(
+  "/events",
+  authMiddleware,
+  (req: AuthenticatedRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: "Authentication required" });
+      return;
+    }
+
+    const format = (req.query.format as string) || "json";
+    const eventName = req.query.eventName as string | undefined;
+    const startDate = req.query.startDate as string | undefined;
+    const endDate = req.query.endDate as string | undefined;
+
+    const db = getDb();
+
+    let query = "SELECT id, tenant_id, name, properties, timestamp, user_id, session_id FROM events WHERE tenant_id = ?";
+    const params: string[] = [req.user.tenantId];
+
+    if (eventName) {
+      query += " AND name = ?";
+      params.push(eventName);
+    }
+    if (startDate) {
+      query += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+    if (endDate) {
+      query += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    query += " ORDER BY timestamp DESC";
+
+    const events = db.prepare(query).all(...params) as EventRow[];
+
+    if (format === "csv") {
+      const csv = eventsToCsv(events);
+      res.setHeader("Content-Type", "text/csv");
+      res.setHeader("Content-Disposition", "attachment; filename=events.csv");
+      res.send(csv);
+    } else {
+      const jsonEvents = events.map((e) => ({
+        id: e.id,
+        name: e.name,
+        properties: JSON.parse(e.properties),
+        timestamp: e.timestamp,
+        userId: e.user_id,
+        sessionId: e.session_id,
+      }));
+      res.json({ events: jsonEvents });
+    }
+  }
+);
+
+// GET /export/dashboards/:id?format=json|csv
+router.get(
+  "/dashboards/:id",
+  authMiddleware,
+  (req: AuthenticatedRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: "Authentication required" });
+      return;
+    }
+
+    const format = (req.query.format as string) || "json";
+
+    const db = getDb();
+    const dashboard = db
+      .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(req.params.id, req.user.tenantId) as DashboardRow | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const widgets = db
+      .prepare("SELECT * FROM widgets WHERE dashboard_id = ?")
+      .all(dashboard.id) as WidgetRow[];
+
+    if (format === "csv") {
+      const header = "dashboard_id,dashboard_name,widget_id,widget_type,widget_config,position_x,position_y,width,height";
+      const rows = widgets.map((w) =>
+        [
+          escapeCsvField(dashboard.id),
+          escapeCsvField(dashboard.name),
+          escapeCsvField(w.id),
+          escapeCsvField(w.type),
+          escapeCsvField(w.config),
+          String(w.position_x),
+          String(w.position_y),
+          String(w.width),
+          String(w.height),
+        ].join(",")
+      );
+
+      // If no widgets, still show the dashboard info
+      if (rows.length === 0) {
+        rows.push(
+          [
+            escapeCsvField(dashboard.id),
+            escapeCsvField(dashboard.name),
+            "",
+            "",
+            "",
+            "",
+            "",
+            "",
+            "",
+          ].join(",")
+        );
+      }
+
+      const csv = [header, ...rows].join("\n");
+      res.setHeader("Content-Type", "text/csv");
+      res.setHeader(
+        "Content-Disposition",
+        `attachment; filename=dashboard-${dashboard.id}.csv`
+      );
+      res.send(csv);
+    } else {
+      res.json({
+        dashboard: {
+          id: dashboard.id,
+          name: dashboard.name,
+          tenantId: dashboard.tenant_id,
+          ownerId: dashboard.owner_id,
+          config: JSON.parse(dashboard.config),
+          createdAt: dashboard.created_at,
+          updatedAt: dashboard.updated_at,
+        },
+        widgets: widgets.map((w) => ({
+          id: w.id,
+          type: w.type,
+          config: JSON.parse(w.config),
+          positionX: w.position_x,
+          positionY: w.position_y,
+          width: w.width,
+          height: w.height,
+        })),
+      });
+    }
+  }
+);
+
+export default router;
diff --git a/src/routes/queries.ts b/src/routes/queries.ts
new file mode 100644
index 0000000..41a93f1
--- /dev/null
+++ b/src/routes/queries.ts
@@ -0,0 +1,142 @@
+import { Router, Response } from "express";
+import { getDb } from "../db.js";
+import { AuthenticatedRequest, authMiddleware } from "../auth.js";
+
+const router = Router();
+
+interface QueryFilter {
+  eventName?: string;
+  startDate?: string;
+  endDate?: string;
+  properties?: Record<string, string>;
+}
+
+function buildWhereClause(
+  tenantId: string,
+  filter: QueryFilter
+): { where: string; params: (string | number)[] } {
+  let where = "WHERE tenant_id = ?";
+  const params: (string | number)[] = [tenantId];
+
+  if (filter.eventName) {
+    where += " AND name = ?";
+    params.push(filter.eventName);
+  }
+
+  if (filter.startDate) {
+    where += " AND timestamp >= ?";
+    params.push(filter.startDate);
+  }
+
+  if (filter.endDate) {
+    where += " AND timestamp <= ?";
+    params.push(filter.endDate);
+  }
+
+  return { where, params };
+}
+
+// POST /queries/count
+router.post(
+  "/count",
+  authMiddleware,
+  (req: AuthenticatedRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: "Authentication required" });
+      return;
+    }
+
+    const filter: QueryFilter = req.body;
+    const { where, params } = buildWhereClause(req.user.tenantId, filter);
+
+    const db = getDb();
+    const result = db
+      .prepare(`SELECT COUNT(*) as count FROM events ${where}`)
+      .get(...params) as { count: number };
+
+    res.json({ count: result.count });
+  }
+);
+
+// POST /queries/timeseries
+router.post(
+  "/timeseries",
+  authMiddleware,
+  (req: AuthenticatedRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: "Authentication required" });
+      return;
+    }
+
+    const { interval, ...filter } = req.body as QueryFilter & {
+      interval?: string;
+    };
+
+    const { where, params } = buildWhereClause(req.user.tenantId, filter);
+
+    let dateFormat: string;
+    switch (interval) {
+      case "hour":
+        dateFormat = "%Y-%m-%dT%H:00:00";
+        break;
+      case "month":
+        dateFormat = "%Y-%m-01";
+        break;
+      case "day":
+      default:
+        dateFormat = "%Y-%m-%d";
+        break;
+    }
+
+    const db = getDb();
+    const rows = db
+      .prepare(
+        `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count FROM events ${where} GROUP BY bucket ORDER BY bucket ASC`
+      )
+      .all(...params) as Array<{ bucket: string; count: number }>;
+
+    res.json({ timeseries: rows });
+  }
+);
+
+// POST /queries/breakdown
+router.post(
+  "/breakdown",
+  authMiddleware,
+  (req: AuthenticatedRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: "Authentication required" });
+      return;
+    }
+
+    const { property, ...filter } = req.body as QueryFilter & {
+      property?: string;
+    };
+
+    if (!property) {
+      res.status(400).json({ error: "property field is required for breakdown queries" });
+      return;
+    }
+
+    const { where, params } = buildWhereClause(req.user.tenantId, filter);
+
+    const db = getDb();
+    const rows = db
+      .prepare(
+        `SELECT json_extract(properties, '$.' || ?) as prop_value, COUNT(*) as count FROM events ${where} AND json_extract(properties, '$.' || ?) IS NOT NULL GROUP BY prop_value ORDER BY count DESC`
+      )
+      .all(property, ...params, property) as Array<{
+      prop_value: string;
+      count: number;
+    }>;
+
+    const breakdown = rows.map((row) => ({
+      value: row.prop_value,
+      count: row.count,
+    }));
+
+    res.json({ breakdown, property });
+  }
+);
+
+export default router;
