+
+    const widget = db
+      .prepare("SELECT * FROM widgets WHERE id = ? AND dashboard_id = ?")
+      .get(req.params.widgetId, req.params.dashboardId) as WidgetRow | undefined;
+
+    if (!widget) {
+      res.status(404).json({ error: "Widget not found" });
+      return;
+    }
+
+    db.prepare("DELETE FROM widgets WHERE id = ?").run(req.params.widgetId);
+
+    res.json({ message: "Widget deleted", id: req.params.widgetId });
+  }
+);
+
+export default router;
