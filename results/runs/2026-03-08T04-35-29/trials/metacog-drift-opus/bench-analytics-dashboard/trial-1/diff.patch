+
+    const updated = db
+      .prepare("SELECT * FROM dashboards WHERE id = ?")
+      .get(req.params.id) as DashboardRow;
+
+    res.json(formatDashboard(updated));
+  }
+);
+
+// DELETE /dashboards/:id - delete dashboard
