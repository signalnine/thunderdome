@@ -0,0 +1,160 @@
+import { Router, Response } from "express";
+import { v4 as uuidv4 } from "uuid";
+import { getDb } from "../db.js";
+import { AuthenticatedRequest, authMiddleware } from "../auth.js";
+
+const router = Router();
+
+// POST /events - ingest a single event
+router.post(
+  "/",
+  authMiddleware,
+  (req: AuthenticatedRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: "Authentication required" });
+      return;
+    }
+
+    const { name, properties, timestamp, sessionId } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: "Event name is required" });
+      return;
+    }
+
+    const db = getDb();
+    const id = uuidv4();
+    const eventTimestamp = timestamp || new Date().toISOString();
+    const eventProperties = properties ? JSON.stringify(properties) : "{}";
+
+    db.prepare(
+      "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    ).run(
+      id,
+      req.user.tenantId,
+      name,
+      eventProperties,
+      eventTimestamp,
+      req.user.userId,
+      sessionId || null
+    );
+
+    res.status(201).json({
+      id,
+      tenantId: req.user.tenantId,
+      name,
+      properties: properties || {},
+      timestamp: eventTimestamp,
+    });
+  }
+);
+
+// POST /events/batch - ingest multiple events
+router.post(
+  "/batch",
+  authMiddleware,
+  (req: AuthenticatedRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: "Authentication required" });
+      return;
+    }
+
+    const { events } = req.body;
+
+    if (!Array.isArray(events) || events.length === 0) {
+      res.status(400).json({ error: "events array is required and must not be empty" });
+      return;
+    }
+
+    const db = getDb();
+    const stmt = db.prepare(
+      "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    );
+
+    const insertMany = db.transaction(
+      (
+        evts: Array<{
+          name: string;
+          properties?: Record<string, unknown>;
+          timestamp?: string;
+          sessionId?: string;
+        }>
+      ) => {
+        const results: Array<{ id: string; name: string; timestamp: string }> = [];
+        for (const evt of evts) {
+          if (!evt.name) continue;
+          const id = uuidv4();
+          const ts = evt.timestamp || new Date().toISOString();
+          const props = evt.properties ? JSON.stringify(evt.properties) : "{}";
+          stmt.run(
+            id,
+            req.user!.tenantId,
+            evt.name,
+            props,
+            ts,
+            req.user!.userId,
+            evt.sessionId || null
+          );
+          results.push({ id, name: evt.name, timestamp: ts });
+        }
+        return results;
+      }
+    );
+
+    const results = insertMany(events);
+
+    res.status(201).json({ inserted: results.length, events: results });
+  }
+);
+
+// GET /events - list events for tenant
+router.get(
+  "/",
+  authMiddleware,
+  (req: AuthenticatedRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: "Authentication required" });
+      return;
+    }
+
+    const db = getDb();
+    const limit = Math.min(parseInt(req.query.limit as string) || 100, 1000);
+    const offset = parseInt(req.query.offset as string) || 0;
+    const name = req.query.name as string | undefined;
+
+    let query = "SELECT id, tenant_id, name, properties, timestamp, user_id, session_id FROM events WHERE tenant_id = ?";
+    const params: (string | number)[] = [req.user.tenantId];
+
+    if (name) {
+      query += " AND name = ?";
+      params.push(name);
+    }
+
+    query += " ORDER BY timestamp DESC LIMIT ? OFFSET ?";
+    params.push(limit, offset);
+
+    const rows = db.prepare(query).all(...params) as Array<{
+      id: string;
+      tenant_id: string;
+      name: string;
+      properties: string;
+      timestamp: string;
+      user_id: string;
+      session_id: string | null;
+    }>;
+
+    const events = rows.map((row) => ({
+      id: row.id,
+      tenantId: row.tenant_id,
+      name: row.name,
+      properties: JSON.parse(row.properties),
+      timestamp: row.timestamp,
+      userId: row.user_id,
+      sessionId: row.session_id,
+    }));
+
+    res.json({ events, limit, offset });
+  }
+);
+
+export default router;
