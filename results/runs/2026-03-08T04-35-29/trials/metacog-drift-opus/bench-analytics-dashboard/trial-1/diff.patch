toBe(\"ok\");\n  });\n});\n\ndescribe(\"Auth\", () => {\n  let token: string;\n  let userId: string;\n\n  it(\"should register a user\", async () => {\n    const res = await request(app).post(\"/auth/register\").send({\n      email: \"admin@tenant1.com\",\n      password: \"password123\",\n      tenantId: \"tenant1\",\n      role: \"admin\",\n    });\n    expect(res.status).toBe(201);\n    expect(res.body.user.email).toBe(\"admin@tenant1.com\");\n    expect(res.body.user.role).toBe(\"admin\");\n    expect(res.body.token).toBeDefined();\n    token = res.body.token;\n    userId = res.body.user.id;\n  });\n\n  it(\"should not register duplicate email\", async () => {\n    const res = await request(app).post(\"/auth/register\").send({\n      email: \"admin@tenant1.com\",\n      password: \"password123\",\n      tenantId: \"tenant1\",\n    });\n    expect(res.status).toBe(409);\n  });\n\n  it(\"should login\", async () => {\n    const res = await request(app).post(\"/auth/login\").send({\n      email: \"admin@tenant1.com\",\n      password: \"password123\",\n    });\n    expect(res.status).toBe(200);\n    expect(res.body.token).toBeDefined();\n    token = res.body.token;\n  });\n\n  it(\"should reject bad password\", async () => {\n    const res = await request(app).post(\"/auth/login\").send({\n      email: \"admin@tenant1.com\",\n      password: \"wrong\",\n    });\n    expect(res.status).toBe(401);\n  });\n\n  it(\"should get profile\", async () => {\n    const res = await request(app)\n      .get(\"/auth/profile\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.email).toBe(\"admin@tenant1.com\");\n    expect(res.body.tenantId).toBe(\"tenant1\");\n  });\n\n  it(\"should reject unauthenticated profile\", async () => {\n    const res = await request(app).get(\"/auth/profile\");\n    expect(res.status).toBe(401);\n  });\n\n  it(\"should change user role\", async () => {\n    // Register a second user\n    const reg = await request(app).post(\"/auth/register\").send({\n      email: \"viewer@tenant1.com\",\n      password: \"password123\",\n      tenantId: \"tenant1\",\n    });\n    const viewerId = reg.body.user.id;\n\n    const res = await request(app)\n      .put(`/auth/users/${viewerId}/role`)\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ role: \"editor\" });\n    expect(res.status).toBe(200);\n    expect(res.body.role).toBe(\"editor\");\n  });\n\n  it(\"should not change role of user in another tenant\", async () => {\n    const reg = await request(app).post(\"/auth/register\").send({\n      email: \"other@tenant2.com\",\n      password: \"password123\",\n      tenantId: \"tenant2\",\n    });\n    const otherId = reg.body.user.id;\n\n    const res = await request(app)\n      .put(`/auth/users/${otherId}/role`)\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ role: \"editor\" });\n    expect(res.status).toBe(403);\n  });\n});\n\ndescribe(\"Events\", () => {\n  let token: string;\n\n  beforeAll(async () => {\n    const res = await request(app).post(\"/auth/login\").send({\n      email: \"admin@tenant1.com\",\n      password: \"password123\",\n    });\n    token = res.body.token;\n  });\n\n  it(\"should ingest single event\", async () => {\n    const res = await request(app)\n      .post(\"/events\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({\n        name: \"page_view\",\n        properties: { url: \"/home\", browser: \"chrome\" },\n      });\n    expect(res.status).toBe(201);\n    expect(res.body.name).toBe(\"page_view\");\n  });\n\n  it(\"should reject unauthenticated event\", async () => {\n    const res = await request(app).post(\"/events\").send({ name: \"test\" });\n    expect(res.status).toBe(401);\n  });\n\n  it(\"should ingest batch events\", async () => {\n    const res = await request(app)\n      .post(\"/events/batch\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({\n        events: [\n