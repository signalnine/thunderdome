+  type: string;
+  config: string;
+  position_x: number;
+  position_y: number;
+  width: number;
+  height: number;
+}
+
+function formatDashboard(row: DashboardRow, widgets?: WidgetRow[]) {
+  return {
+    id: row.id,
+    tenantId: row.tenant_id,
+    name: row.name,
+    ownerId: row.owner_id,
+    config: JSON.parse(row.config),
+    createdAt: row.created_at,
+    updatedAt: row.updated_at,
+    widgets: widgets?.map((w) => ({
+      id: w.id,
+      dashboardId: w.dashboard_id,
+      type: w.type,
+      config: JSON.parse(w.config),
+      positionX: w.position_x,
+      positionY: w.position_y,
+      width: w.width,
+      height: w.height,
+    })),
+  };
+}
+
+// GET /dashboards - list dashboards for tenant
+router.get(
+  "/",
+  authMiddleware,
+  (req: AuthenticatedRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: "Authentication required" });
+      return;
+    }
+
+    const db = getDb();
+    const rows = db
+      .prepare(
+        "SELECT id, tenant_id, name, owner_id, config, created_at, updated_at FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC"
+      )
+      .all(req.user.tenantId) as DashboardRow[];
+
+    res.json({ dashboards: rows.map((r) => formatDashboard(r)) });
+  }
+);
+
+// POST /dashboards - create dashboard
+router.post(
+  "/",
+  authMiddleware,
+  (req: AuthenticatedRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: "Authentication required" });
+      return;
+    }
+
+    const { name, config } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: "Dashboard name is required" });
+      return;
+    }
+
+    const db = getDb();
+    const id = uuidv4();
+    const now = new Date().toISOString();
+    const configStr = config ? JSON.stringify(config) : "{}";
+
+    db.prepare(
+      "INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    ).run(id, req.user.tenantId, name, req.user.userId, configStr, now, now);
+
+    const row = db
+      .prepare("SELECT * FROM dashboards WHERE id = ?")
+      .get(id) as DashboardRow;
+
+    res.status(201).json(formatDashboard(row));
+  }
+);
+
+// GET /dashboards/:id - get dashboard with widgets
+router.get(
+  "/:id",
+  authMiddleware,
+  (req: AuthenticatedRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: "Authentication required" });
+      return;
+    }
+
+    const db = getDb();
+    const row = db
+      .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(req.params.id, req.user.tenantId) as DashboardRow | undefined;
+
+    if (!row) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const widgets = db
+      .prepare("SELECT * FROM widgets WHERE dashboard_id = ?")
