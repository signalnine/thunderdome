+interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+/**
+ * Solve the toggle puzzle using Gaussian elimination over GF(2).
+ * Find the minimum set of buttons (then lexicographically smallest) to press
+ * so that toggling produces the target configuration.
+ */
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const numLights = target.length;
+  const numButtons = buttons.length;
+
+  // Build augmented matrix over GF(2): each row is a light equation.
+  // Columns are buttons + 1 augmented column for the target.
+  // matrix[light][button] = 1 if button toggles that light
+  // matrix[light][numButtons] = target value
+  const cols = numButtons + 1;
+  const matrix: number[][] = [];
+
+  for (let i = 0; i < numLights; i++) {
+    const row = new Array(cols).fill(0);
+    row[numButtons] = target[i] ? 1 : 0;
+    matrix.push(row);
+  }
+
+  for (let b = 0; b < numButtons; b++) {
+    for (const light of buttons[b]) {
+      if (light < numLights) {
+        matrix[light][b] = 1;
+      }
+    }
+  }
+
+  // Gaussian elimination over GF(2)
+  // Track which column is the pivot for each row
+  const pivotCol: number[] = new Array(numLights).fill(-1);
+  const pivotRow: number[] = new Array(numButtons).fill(-1); // which row has pivot in this column
+  let rank = 0;
+
+  for (let col = 0; col < numButtons && rank < numLights; col++) {
+    // Find pivot row
+    let found = -1;
+    for (let row = rank; row < numLights; row++) {
+      if (matrix[row][col] === 1) {
+        found = row;
+        break;
+      }
+    }
+    if (found === -1) continue;
+
+    // Swap rows
+    [matrix[rank], matrix[found]] = [matrix[found], matrix[rank]];
+    pivotCol[rank] = col;
+    pivotRow[col] = rank;
+
+    // Eliminate other rows
+    for (let row = 0; row < numLights; row++) {
+      if (row !== rank && matrix[row][col] === 1) {
+        for (let c = 0; c < cols; c++) {
+          matrix[row][c] ^= matrix[rank][c];
+        }
+      }
+    }
+    rank++;
+  }
+
+  // Check for inconsistency: any row with all-zero coefficients but non-zero target
+  for (let row = rank; row < numLights; row++) {
+    if (matrix[row][numButtons] === 1) {
+      return null;
+    }
+  }
+
+  // Identify free variables (columns not used as pivots)
+  const freeVars: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (pivotRow[col] === -1) {
+      freeVars.push(col);
+    }
+  }
+
+  // If no free variables, there's exactly one solution
+  if (freeVars.length === 0) {
+    const result: number[] = [];
+    for (let row = 0; row < rank; row++) {
+      if (matrix[row][numButtons] === 1) {
+        result.push(pivotCol[row]);
+      }
+    }
+    result.sort((a, b) => a - b);
+    return result;
+  }
+
+  // Enumerate all 2^freeVars combinations to find minimum presses, then lex smallest
+  // freeVars.length can be up to 40 in theory, but with 40 lights and 40 buttons,
+  // the number of free variables is numButtons - rank, which should be manageable
+  // for reasonable inputs. For worst case we need a smarter approach.
+  // But with up to 40 lights, rank <= 40, so free vars = numButtons - rank.
+  // If numButtons=40 and rank=0, we'd have 2^40 which is too many.
+  // However, if rank=0, all targets must be 0, so the answer is just [].
+  // In practice, free vars should be manageable. Let's handle up to ~25 free vars
+  // with brute force, and for more use a greedy/smart approach.
+
+  const numFree = freeVars.length;
+
+  // For each pivot variable, express it in terms of free variables and the constant
+  // pivotVal[i] = matrix[i][numButtons] XOR (sum of matrix[i][freeVar[j]] * freeVar[j])
+  // So for a given assignment of free variables, the pivot variable values are determined.
+
+  let bestResult: number[] | null = null;
+  let bestCount = numButtons + 1;
+
+  if (numFree <= 25) {
+    // Brute force over free variable assignments
+    const totalCombos = 1 << numFree;
+    for (let mask = 0; mask < totalCombos; mask++) {
+      const solution = new Array(numButtons).fill(0);
+
+      // Set free variables
+      for (let f = 0; f < numFree; f++) {
+        if (mask & (1 << f)) {
+          solution[freeVars[f]] = 1;
+        }
+      }
+
+      // Compute pivot variables
+      for (let row = 0; row < rank; row++) {
+        let val = matrix[row][numButtons];
+        for (let f = 0; f < numFree; f++) {
+          if (solution[freeVars[f]] === 1) {
+            val ^= matrix[row][freeVars[f]];
+          }
+        }
+        solution[pivotCol[row]] = val;
+      }
+
+      // Count presses
+      const pressed: number[] = [];
+      for (let i = 0; i < numButtons; i++) {
+        if (solution[i] === 1) pressed.push(i);
+      }
+
+      const count = pressed.length;
+      if (count < bestCount || (count === bestCount && lexSmaller(pressed, bestResult!))) {
+        bestCount = count;
+        bestResult = pressed;
+      }
+    }
+  } else {
+    // For very many free variables, we want minimum weight solution.
+    // Since we want to minimize total presses, and free variables add presses
+    // while also potentially canceling pivot variable presses, we need to be smart.
+    // Use a greedy approach: try setting each free variable to minimize total presses.
+    // This is a heuristic but should work for most cases.
+
+    // Start with all free vars = 0
+    const solution = new Array(numButtons).fill(0);
+    for (let row = 0; row < rank; row++) {
+      solution[pivotCol[row]] = matrix[row][numButtons];
+    }
+
+    // For each free variable, try flipping it and see if total count decreases
+    let improved = true;
+    while (improved) {
+      improved = false;
+      for (let f = 0; f < numFree; f++) {
+        const fv = freeVars[f];
+        // Try flipping this free variable
+        const oldVal = solution[fv];
+        const newVal = 1 - oldVal;
+
+        let oldCount = oldVal; // contribution of free var itself
+        let newCount = newVal;
+
+        // Effect on pivot variables
+        for (let row = 0; row < rank; row++) {
+          if (matrix[row][fv] === 1) {
+            // This pivot variable would flip
+            oldCount += solution[pivotCol[row]];
+            newCount += 1 - solution[pivotCol[row]];
+          } else {
+            oldCount += solution[pivotCol[row]];
+            newCount += solution[pivotCol[row]];
+          }
+        }
+
+        if (newCount < oldCount) {
+          // Flip
+          solution[fv] = newVal;
+          for (let row = 0; row < rank; row++) {
+            if (matrix[row][fv] === 1) {
+              solution[pivotCol[row]] = 1 - solution[pivotCol[row]];
+            }
+          }
+          improved = true;
+        }
+      }
+    }
+
+    const pressed: number[] = [];
+    for (let i = 0; i < numButtons; i++) {
+      if (solution[i] === 1) pressed.push(i);
+    }
+    bestResult = pressed;
+    bestCount = pressed.length;
+
+    // Also try starting with all free vars = 1 and optimize from there
+    const solution2 = new Array(numButtons).fill(0);
+    for (let f = 0; f < numFree; f++) {
+      solution2[freeVars[f]] = 1;
+    }
+    for (let row = 0; row < rank; row++) {
+      let val = matrix[row][numButtons];
+      for (let f = 0; f < numFree; f++) {
+        val ^= matrix[row][freeVars[f]];
+      }
+      solution2[pivotCol[row]] = val;
+    }
+
+    improved = true;
+    while (improved) {
+      improved = false;
+      for (let f = 0; f < numFree; f++) {
+        const fv = freeVars[f];
+        const oldVal = solution2[fv];
+        const newVal = 1 - oldVal;
+
+        let oldCount = oldVal;
+        let newCount = newVal;
+
+        for (let row = 0; row < rank; row++) {
+          if (matrix[row][fv] === 1) {
+            oldCount += solution2[pivotCol[row]];
+            newCount += 1 - solution2[pivotCol[row]];
+          } else {
+            oldCount += solution2[pivotCol[row]];
+            newCount += solution2[pivotCol[row]];
+          }
+        }
+
+        if (newCount < oldCount) {
+          solution2[fv] = newVal;
+          for (let row = 0; row < rank; row++) {
+            if (matrix[row][fv] === 1) {
+              solution2[pivotCol[row]] = 1 - solution2[pivotCol[row]];
+            }
+          }
+          improved = true;
+        }
+      }
+    }
+
+    const pressed2: number[] = [];
+    for (let i = 0; i < numButtons; i++) {
+      if (solution2[i] === 1) pressed2.push(i);
+    }
+
+    if (pressed2.length < bestCount || (pressed2.length === bestCount && lexSmaller(pressed2, bestResult!))) {
+      bestResult = pressed2;
+    }
+  }
+
+  return bestResult;
+}
+
+function lexSmaller(a: number[], b: number[]): boolean {
+  // Compare two sorted arrays of button indices lexicographically
+  // as "sets": first by size, then element by element
+  // Actually, the problem says: fewest presses first, then lex smallest set of indices
+  // "Lexicographically smallest set of indices" - comparing the sorted arrays
+  const len = Math.min(a.length, b.length);
+  for (let i = 0; i < len; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return a.length < b.length;
+}
+
+/**
+ * Solve the counter puzzle using Gaussian elimination over GF(p).
+ * Find button press counts that produce target counter values modulo p.
+ */
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numCounters = lights.length;
+  const numButtons = buttons.length;
+  const cols = numButtons + 1;
+
+  // Build augmented matrix over GF(modulus)
+  // matrix[counter][button] = 1 if button affects that counter, 0 otherwise
+  // matrix[counter][numButtons] = target value
+  const matrix: number[][] = [];
+
+  for (let i = 0; i < numCounters; i++) {
+    const row = new Array(cols).fill(0);
+    row[numButtons] = lights[i] % modulus;
+    matrix.push(row);
+  }
+
+  for (let b = 0; b < numButtons; b++) {
+    for (const counter of buttons[b]) {
+      if (counter < numCounters) {
+        matrix[counter][b] = (matrix[counter][b] + 1) % modulus;
+      }
+    }
+  }
+
+  // Precompute modular inverse using Fermat's little theorem: a^(p-2) mod p
+  const modInverse = (a: number, p: number): number => {
+    a = ((a % p) + p) % p;
+    if (a === 0) return 0; // shouldn't happen for non-zero
+    let result = 1;
+    let base = a;
+    let exp = p - 2;
+    while (exp > 0) {
+      if (exp & 1) result = (result * base) % p;
+      base = (base * base) % p;
+      exp >>= 1;
+    }
+    return result;
+  };
+
+  // Gaussian elimination over GF(modulus)
+  const pivotCol: number[] = new Array(numCounters).fill(-1);
+  const pivotRow: number[] = new Array(numButtons).fill(-1);
+  let rank = 0;
+
+  for (let col = 0; col < numButtons && rank < numCounters; col++) {
+    // Find pivot row
+    let found = -1;
+    for (let row = rank; row < numCounters; row++) {
+      if (matrix[row][col] !== 0) {
+        found = row;
+        break;
+      }
+    }
+    if (found === -1) continue;
+
+    // Swap rows
+    [matrix[rank], matrix[found]] = [matrix[found], matrix[rank]];
+
+    // Scale pivot row so pivot = 1
+    const inv = modInverse(matrix[rank][col], modulus);
+    for (let c = 0; c < cols; c++) {
+      matrix[rank][c] = (matrix[rank][c] * inv) % modulus;
+    }
+
+    pivotCol[rank] = col;
+    pivotRow[col] = rank;
+
+    // Eliminate other rows
+    for (let row = 0; row < numCounters; row++) {
+      if (row !== rank && matrix[row][col] !== 0) {
+        const factor = matrix[row][col];
+        for (let c = 0; c < cols; c++) {
+          matrix[row][c] = ((matrix[row][c] - factor * matrix[rank][c]) % modulus + modulus) % modulus;
+        }
+      }
+    }
+    rank++;
+  }
+
+  // Check for inconsistency
+  for (let row = rank; row < numCounters; row++) {
+    if (matrix[row][numButtons] !== 0) {
+      return null;
+    }
+  }
+
+  // Identify free variables
+  const freeVars: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (pivotRow[col] === -1) {
+      freeVars.push(col);
+    }
+  }
+
+  const numFree = freeVars.length;
+
+  // For each assignment of free variables, compute the full solution
+  // and find the one with minimum total presses, then lex smallest.
+  // With modulus up to 97 and potentially many free variables,
+  // brute force is modulus^numFree which can be huge.
+
+  // Strategy: for small number of free vars, enumerate all.
+  // For larger, use optimization.
+
+  const computeSolution = (freeAssignment: number[]): number[] => {
+    const solution = new Array(numButtons).fill(0);
+
+    // Set free variables
+    for (let f = 0; f < numFree; f++) {
+      solution[freeVars[f]] = freeAssignment[f];
+    }
+
+    // Compute pivot variables
+    for (let row = 0; row < rank; row++) {
+      let val = matrix[row][numButtons];
+      for (let f = 0; f < numFree; f++) {
+        val = ((val - matrix[row][freeVars[f]] * freeAssignment[f]) % modulus + modulus) % modulus;
+      }
+      solution[pivotCol[row]] = val;
+    }
+
+    return solution;
+  };
+
+  const totalPresses = (sol: number[]): number => {
+    let sum = 0;
+    for (let i = 0; i < numButtons; i++) sum += sol[i];
+    return sum;
+  };
+
+  const lexSmallerArr = (a: number[], b: number[]): boolean => {
+    for (let i = 0; i < a.length; i++) {
+      if (a[i] < b[i]) return true;
+      if (a[i] > b[i]) return false;
+    }
+    return false;
+  };
+
+  if (numFree === 0) {
+    // Unique solution
+    const solution = computeSolution([]);
+    return solution;
+  }
+
+  // For small search spaces, enumerate
+  const searchSpace = Math.pow(modulus, numFree);
+
+  if (searchSpace <= 5000000) {
+    // Enumerate all
+    let bestSolution: number[] | null = null;
+    let bestTotal = Infinity;
+    const freeAssignment = new Array(numFree).fill(0);
+
+    const enumerate = (): void => {
+      for (let iter = 0; iter < searchSpace; iter++) {
+        const sol = computeSolution(freeAssignment);
+        const total = totalPresses(sol);
+        if (total < bestTotal || (total === bestTotal && lexSmallerArr(sol, bestSolution!))) {
+          bestTotal = total;
+          bestSolution = [...sol];
+        }
+
+        // Increment freeAssignment
+        let carry = 1;
+        for (let f = 0; f < numFree; f++) {
+          freeAssignment[f] += carry;
+          if (freeAssignment[f] >= modulus) {
+            freeAssignment[f] = 0;
+            carry = 1;
+          } else {
+            carry = 0;
+            break;
+          }
+        }
+      }
+    };
+
+    enumerate();
+    return bestSolution;
+  }
+
+  // For larger search spaces, we need a smarter approach.
+  // The total presses = sum of solution[i] for all i.
+  // For pivot variables: solution[pivotCol[row]] = matrix[row][numButtons] - sum(matrix[row][freeVars[f]] * x_f)  (mod p)
+  // For free variables: solution[freeVars[f]] = x_f
+  // Total = sum of pivot values + sum of free values
+  // We want to minimize this sum.
+  //
+  // Each variable's value is in [0, modulus-1].
+  // The "cost" of a value v mod p is v itself (since 0 <= v < p).
+  //
+  // This is an optimization problem over GF(p) which is hard in general.
+  // Use a greedy/local search approach.
+
+  // Start with all free vars = 0 and try each value
+  const greedySearch = (startAssignment: number[]): number[] => {
+    const assignment = [...startAssignment];
+    let sol = computeSolution(assignment);
+    let bestT = totalPresses(sol);
+    let bestSol = [...sol];
+
+    let improved = true;
+    while (improved) {
+      improved = false;
+      for (let f = 0; f < numFree; f++) {
+        const origVal = assignment[f];
+        let bestVal = origVal;
+        let bestLocalTotal = bestT;
+        let bestLocalSol = bestSol;
+
+        for (let v = 0; v < modulus; v++) {
+          if (v === origVal) continue;
+          assignment[f] = v;
+          const s = computeSolution(assignment);
+          const t = totalPresses(s);
+          if (t < bestLocalTotal || (t === bestLocalTotal && lexSmallerArr(s, bestLocalSol))) {
+            bestLocalTotal = t;
+            bestVal = v;
+            bestLocalSol = [...s];
+          }
+        }
+
+        if (bestVal !== origVal) {
+          assignment[f] = bestVal;
+          sol = bestLocalSol;
+          bestT = bestLocalTotal;
+          bestSol = bestLocalSol;
+          improved = true;
+        } else {
+          assignment[f] = origVal;
+        }
+      }
+    }
+
+    return bestSol;
+  };
+
+  // Try multiple starting points
+  let bestSolution: number[] | null = null;
+  let bestTotal = Infinity;
+
+  // Start with all zeros
+  const sol0 = greedySearch(new Array(numFree).fill(0));
+  const total0 = totalPresses(sol0);
+  if (total0 < bestTotal || (total0 === bestTotal && (bestSolution === null || lexSmallerArr(sol0, bestSolution)))) {
+    bestTotal = total0;
+    bestSolution = sol0;
+  }
+
+  // Try random starts (deterministic based on index)
+  for (let trial = 0; trial < Math.min(50, modulus); trial++) {
+    const start = new Array(numFree).fill(0);
+    for (let f = 0; f < numFree; f++) {
+      start[f] = (trial * (f + 1) + f * 7) % modulus;
+    }
+    const sol = greedySearch(start);
+    const total = totalPresses(sol);
+    if (total < bestTotal || (total === bestTotal && lexSmallerArr(sol, bestSolution!))) {
+      bestTotal = total;
+      bestSolution = sol;
+    }
+  }
+
+  return bestSolution;
+}
