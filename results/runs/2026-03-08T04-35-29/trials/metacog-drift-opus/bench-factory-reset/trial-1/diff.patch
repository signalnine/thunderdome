+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter } from './index.js';
+
+describe('solveToggle', () => {
+  it('returns empty array when target is all off', () => {
+    const result = solveToggle({
+      target: [false, false, false],
+      buttons: [[0, 1], [1, 2]],
+    });
+    expect(result).toEqual([]);
+  });
+
+  it('returns null when no solution exists', () => {
+    // From the task example
+    const result = solveToggle({
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]],
+    });
+    expect(result).toBeNull();
+  });
+
+  it('solves a simple single-button case', () => {
+    const result = solveToggle({
+      target: [true, true],
+      buttons: [[0, 1]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('solves a two-button case', () => {
+    const result = solveToggle({
+      target: [true, false, true],
+      buttons: [[0], [2]],
+    });
+    expect(result).toEqual([0, 1]);
+  });
+
+  it('finds minimum presses when multiple solutions exist', () => {
+    // Buttons: 0 toggles [0,1], 1 toggles [0,1], 2 toggles [0]
+    // Target: [false, false]
+    // Solutions: press none, press {0,1}
+    // Minimum: press none
+    const result = solveToggle({
+      target: [false, false],
+      buttons: [[0, 1], [0, 1], [0]],
+    });
+    expect(result).toEqual([]);
+  });
+
+  it('returns lex smallest when tied on count', () => {
+    // Two buttons that do the same thing
+    // Target: [true]
+    // Button 0 toggles [0], Button 1 toggles [0]
+    // Both are single-press solutions, lex smallest is [0]
+    const result = solveToggle({
+      target: [true],
+      buttons: [[0], [0]],
+    });
+    expect(result).toEqual([0]);
+  });
+});
+
+describe('solveCounter', () => {
+  it('returns all zeros when target is all zero', () => {
+    const result = solveCounter([0, 0, 0], [[0, 1], [1, 2]], 5);
+    expect(result).toEqual([0, 0]);
+  });
+
+  it('solves a simple single-button case', () => {
+    const result = solveCounter([3], [[0]], 5);
+    expect(result).toEqual([3]);
+  });
+
+  it('returns null when no solution exists', () => {
+    // Button 0 affects counter 0, button 1 affects counter 0
+    // Target: counter 0 = 1, counter 1 = 1
+    // No button affects counter 1
+    const result = solveCounter([1, 1], [[0], [0]], 5);
+    expect(result).toBeNull();
+  });
+
+  it('solves a two-button case with modulus', () => {
+    // Button 0 affects counter 0, button 1 affects counter 1
+    // Target: [3, 4], modulus 5
+    const result = solveCounter([3, 4], [[0], [1]], 5);
+    expect(result).toEqual([3, 4]);
+  });
+
+  it('finds minimum total presses', () => {
+    // Button 0 affects counter 0
+    // Target: [4], modulus 5
+    // Press 4 times total = 4, or equivalently -1 mod 5 = 4
+    // The only solution is 4
+    const result = solveCounter([4], [[0]], 5);
+    expect(result).toEqual([4]);
+  });
+
+  it('handles overlapping buttons', () => {
+    // Button 0 affects [0, 1], Button 1 affects [1, 2]
+    // Target: [1, 2, 1], modulus 3
+    // b0 affects c0, c1; b1 affects c1, c2
+    // c0 = b0 = 1 => b0=1
+    // c1 = b0 + b1 = 2 => b1 = 2-1 = 1
+    // c2 = b1 = 1 => OK
+    const result = solveCounter([1, 2, 1], [[0, 1], [1, 2]], 3);
+    expect(result).toEqual([1, 1]);
+  });
+});
