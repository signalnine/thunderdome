+import { describe, it, expect, beforeEach } from 'vitest';
+import { createReviewService } from './index.js';
+import type { ReviewService } from '../types.js';
+
+describe('ReviewService', () => {
+  let reviews: ReviewService;
+
+  beforeEach(() => {
+    reviews = createReviewService();
+  });
+
+  it('should add and retrieve reviews', () => {
+    const review = reviews.addReview({
+      pluginName: 'test-plugin',
+      pluginVersion: '1.0.0',
+      userId: 'user1',
+      rating: 5,
+      comment: 'Great plugin!',
+    });
+    expect(review.id).toBeDefined();
+    expect(review.flagged).toBe(false);
+    expect(review.createdAt).toBeDefined();
+
+    const pluginReviews = reviews.getReviews('test-plugin');
+    expect(pluginReviews.length).toBe(1);
+    expect(pluginReviews[0].comment).toBe('Great plugin!');
+  });
+
+  it('should calculate average rating excluding flagged', () => {
+    reviews.addReview({
+      pluginName: 'p',
+      pluginVersion: '1.0.0',
+      userId: 'u1',
+      rating: 5,
+      comment: 'great',
+    });
+    reviews.addReview({
+      pluginName: 'p',
+      pluginVersion: '1.0.0',
+      userId: 'u2',
+      rating: 3,
+      comment: 'ok',
+    });
+    const flagged = reviews.addReview({
+      pluginName: 'p',
+      pluginVersion: '1.0.0',
+      userId: 'u3',
+      rating: 1,
+      comment: 'spam',
+    });
+    reviews.flagReview(flagged.id);
+
+    // Average of 5 and 3 = 4 (flagged review excluded)
+    expect(reviews.getAverageRating('p')).toBe(4);
+  });
+
+  it('should return 0 average for no reviews', () => {
+    expect(reviews.getAverageRating('nonexistent')).toBe(0);
+  });
+
+  it('should flag and retrieve flagged reviews', () => {
+    const r = reviews.addReview({
+      pluginName: 'p',
+      pluginVersion: '1.0.0',
+      userId: 'u1',
+      rating: 1,
+      comment: 'spam',
+    });
+    reviews.flagReview(r.id);
+
+    const flagged = reviews.getFlaggedReviews();
+    expect(flagged.length).toBe(1);
+    expect(flagged[0].flagged).toBe(true);
+  });
+
+  it('should remove a review', () => {
+    const r = reviews.addReview({
+      pluginName: 'p',
+      pluginVersion: '1.0.0',
+      userId: 'u1',
+      rating: 5,
+      comment: 'great',
+    });
+    expect(reviews.removeReview(r.id)).toBe(true);
+    expect(reviews.getReviews('p').length).toBe(0);
+  });
+
+  it('should return false for removing nonexistent review', () => {
+    expect(reviews.removeReview(999)).toBe(false);
+  });
+
+  it('should get reviews by user', () => {
+    reviews.addReview({
+      pluginName: 'p1',
+      pluginVersion: '1.0.0',
+      userId: 'user1',
+      rating: 5,
+      comment: 'great',
+    });
+    reviews.addReview({
+      pluginName: 'p2',
+      pluginVersion: '1.0.0',
+      userId: 'user1',
+      rating: 4,
+      comment: 'good',
+    });
+    reviews.addReview({
+      pluginName: 'p1',
+      pluginVersion: '1.0.0',
+      userId: 'user2',
+      rating: 3,
+      comment: 'ok',
+    });
+
+    const userReviews = reviews.getReviewsByUser('user1');
+    expect(userReviews.length).toBe(2);
+  });
+
+  it('should count reviews', () => {
+    reviews.addReview({
+      pluginName: 'p',
+      pluginVersion: '1.0.0',
+      userId: 'u1',
+      rating: 5,
+      comment: 'a',
+    });
+    reviews.addReview({
+      pluginName: 'p',
+      pluginVersion: '1.0.0',
+      userId: 'u2',
+      rating: 4,
+      comment: 'b',
+    });
+    expect(reviews.getReviewCount('p')).toBe(2);
+  });
+});
