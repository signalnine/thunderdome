e}</pubDate>\\n` : '';\n\n          return `    <item>\n      <title>${escapeXml(file.title)}</title>\n      <link>${config.baseUrl}/${file.slug}.html</link>\n${pubDate}      <description><![CDATA[${file.content}]]></description>\n${categoryTags}\n    </item>`;\n        }).join('\\n');\n\n        const rss = `<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<rss version=\"2.0\">\n  <channel>\n    <title>${escapeXml(config.title)}</title>\n    <link>${config.baseUrl}</link>\n    <description>${escapeXml(config.title)}</description>\n${items}\n  </channel>\n</rss>`;\n\n        ctx.output.set('feed.xml', rss);\n      },\n    },\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":432,"cache_read_input_tokens":46488,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":432},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"0891c8ff-9ed5-4cb2-a972-01364c631155","uuid":"3ce6c013-e268-424f-b885-4dbaa7459646"}
