@@ -0,0 +1,68 @@
+import { marked } from 'marked';
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+function processFootnotes(content: string): string {
+  const footnoteDefRegex = /^\[\^(\d+)\]:\s*(.+)$/gm;
+  const footnotes: Array<{ id: string; text: string }> = [];
+  let processed = content;
+
+  // Extract footnote definitions
+  let match;
+  while ((match = footnoteDefRegex.exec(content)) !== null) {
+    footnotes.push({ id: match[1], text: match[2] });
+  }
+
+  if (footnotes.length === 0) {
+    return content;
+  }
+
+  // Remove footnote definitions from content
+  processed = processed.replace(/^\[\^(\d+)\]:\s*(.+)$/gm, '').trim();
+
+  // Replace footnote references with sup links
+  for (const fn of footnotes) {
+    const refRegex = new RegExp(`\\[\\^${fn.id}\\]`, 'g');
+    processed = processed.replace(refRegex, `<sup><a href="#fn-${fn.id}">${fn.id}</a></sup>`);
+  }
+
+  // Add footnotes section
+  const footnotesHtml = footnotes
+    .map(fn => `<li id="fn-${fn.id}">${fn.text}</li>`)
+    .join('\n');
+  processed += `\n<section class="footnotes">\n<ol>\n${footnotesHtml}\n</ol>\n</section>`;
+
+  return processed;
+}
+
+function processAdmonitions(content: string): string {
+  return content.replace(
+    /^:::(note|warning|tip)\n([\s\S]*?)^:::/gm,
+    (_match, type: string, body: string) => {
+      return `<div class="admonition admonition-${type}">${body.trim()}</div>`;
+    }
+  );
+}
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file: ContentFile, _ctx: BuildContext): ContentFile {
+        let content = file.content;
+
+        // Process admonitions before markdown parsing
+        content = processAdmonitions(content);
+
+        // Process footnotes before markdown parsing
+        content = processFootnotes(content);
+
+        // Convert markdown to HTML using marked
+        content = marked(content) as string;
+
+        return { ...file, content };
+      },
+    },
+  };
+}
