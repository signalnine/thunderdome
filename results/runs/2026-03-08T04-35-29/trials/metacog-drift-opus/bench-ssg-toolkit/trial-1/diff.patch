+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+function escapeXml(str: string): string {
+  return str
+    .replace(/&/g, '&amp;')
+    .replace(/</g, '&lt;')
+    .replace(/>/g, '&gt;')
+    .replace(/"/g, '&quot;')
+    .replace(/'/g, '&apos;');
+}
+
+export function createRssFeedPlugin(): Plugin {
+  return {
+    name: 'rss-feed',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'taxonomy'],
+    hooks: {
+      afterBuild(ctx: BuildContext): void {
+        const { config, files } = ctx;
+        const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]> | undefined;
+
+        // Sort files by date, newest first. Files without dates go to the end.
+        const sortedFiles = [...files].sort((a, b) => {
+          if (!a.date && !b.date) return 0;
+          if (!a.date) return 1;
+          if (!b.date) return -1;
+          return new Date(b.date).getTime() - new Date(a.date).getTime();
+        });
+
+        // Build tag lookup: slug -> tags[]
+        const fileTagsMap = new Map<string, string[]>();
+        if (tagMap) {
+          for (const [tag, tagFiles] of tagMap) {
+            for (const f of tagFiles) {
+              const existing = fileTagsMap.get(f.slug) || [];
+              existing.push(tag);
+              fileTagsMap.set(f.slug, existing);
+            }
+          }
+        }
+
+        const items = sortedFiles.map(file => {
+          const tags = file.tags || fileTagsMap.get(file.slug) || [];
+          const categoryTags = tags
+            .map(t => `      <category>${escapeXml(t.toLowerCase())}</category>`)
+            .join('\n');
+
+          const pubDate = file.date ? `      <pubDate>${file.date}</pubDate>\n` : '';
+
+          return `    <item>
+      <title>${escapeXml(file.title)}</title>
+      <link>${config.baseUrl}/${file.slug}.html</link>
+${pubDate}      <description><![CDATA[${file.content}]]></description>
+${categoryTags}
+    </item>`;
+        }).join('\n');
+
+        const rss = `<?xml version="1.0" encoding="UTF-8"?>
+<rss version="2.0">
+  <channel>
+    <title>${escapeXml(config.title)}</title>
+    <link>${config.baseUrl}</link>
+    <description>${escapeXml(config.title)}</description>
+${items}
+  </channel>
+</rss>`;
+
+        ctx.output.set('feed.xml', rss);
+      },
+    },
+  };
+}
