+import express from "express";
+import type Database from "better-sqlite3";
+import { initDb } from "./db.js";
+import { authMiddleware, createAuthRouter } from "./auth.js";
+import { createEventsRouter } from "./events.js";
+import { createQueriesRouter } from "./queries.js";
+import { createDashboardsRouter } from "./dashboards.js";
+import { createExportRouter } from "./export.js";
+
+export function createApp(db?: Database.Database): express.Application {
+  const database = db || initDb();
+
+  const app = express();
+  app.use(express.json());
+  app.use(authMiddleware(database));
+
+  // Health check
+  app.get("/health", (_req, res) => {
+    res.json({ status: "ok" });
+  });
+
+  // Auth routes
+  app.use("/auth", createAuthRouter(database));
+
+  // Events routes
+  app.use("/events", createEventsRouter(database));
+
+  // Query routes
+  app.use("/query", createQueriesRouter(database));
+
+  // Dashboard routes
+  app.use("/dashboards", createDashboardsRouter(database));
+
+  // Export routes
+  app.use("/export", createExportRouter(database));
+
+  return app;
+}
