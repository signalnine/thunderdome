@@ -0,0 +1,201 @@
+import { Response, Router } from "express";
+import { v4 as uuidv4 } from "uuid";
+import type Database from "better-sqlite3";
+import { AuthRequest, requireAuth } from "./auth.js";
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+interface WidgetRow {
+  id: string;
+  dashboard_id: string;
+  type: string;
+  config: string;
+  position_x: number;
+  position_y: number;
+  width: number;
+  height: number;
+}
+
+export function createDashboardsRouter(db: Database.Database): Router {
+  const router = Router();
+
+  // List dashboards for tenant
+  router.get("/", requireAuth, (req: AuthRequest, res: Response) => {
+    const user = req.user!;
+    const dashboards = db
+      .prepare("SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC")
+      .all(user.tenant_id) as DashboardRow[];
+
+    res.json({
+      dashboards: dashboards.map((d) => ({
+        ...d,
+        config: JSON.parse(d.config),
+      })),
+    });
+  });
+
+  // Create dashboard
+  router.post("/", requireAuth, (req: AuthRequest, res: Response) => {
+    const user = req.user!;
+    const { name, config } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: "Dashboard name is required" });
+      return;
+    }
+
+    const id = uuidv4();
+    const dashConfig = config ? JSON.stringify(config) : "{}";
+    const now = new Date().toISOString();
+
+    db.prepare(
+      "INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    ).run(id, user.tenant_id, name, user.id, dashConfig, now, now);
+
+    res.status(201).json({
+      id,
+      tenant_id: user.tenant_id,
+      name,
+      owner_id: user.id,
+      config: config || {},
+      created_at: now,
+      updated_at: now,
+    });
+  });
+
+  // Get dashboard by ID
+  router.get("/:id", requireAuth, (req: AuthRequest, res: Response) => {
+    const user = req.user!;
+    const dashboard = db
+      .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(req.params.id, user.tenant_id) as DashboardRow | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const widgets = db
+      .prepare("SELECT * FROM widgets WHERE dashboard_id = ?")
+      .all(dashboard.id) as WidgetRow[];
+
+    res.json({
+      ...dashboard,
+      config: JSON.parse(dashboard.config),
+      widgets: widgets.map((w) => ({ ...w, config: JSON.parse(w.config) })),
+    });
+  });
+
+  // Update dashboard
+  router.put("/:id", requireAuth, (req: AuthRequest, res: Response) => {
+    const user = req.user!;
+    const dashboard = db
+      .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(req.params.id, user.tenant_id) as DashboardRow | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const { name, config } = req.body;
+    const updatedName = name || dashboard.name;
+    const updatedConfig = config ? JSON.stringify(config) : dashboard.config;
+    const now = new Date().toISOString();
+
+    db.prepare(
+      "UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?"
+    ).run(updatedName, updatedConfig, now, dashboard.id);
+
+    res.json({
+      id: dashboard.id,
+      tenant_id: dashboard.tenant_id,
+      name: updatedName,
+      owner_id: dashboard.owner_id,
+      config: JSON.parse(updatedConfig),
+      created_at: dashboard.created_at,
+      updated_at: now,
+    });
+  });
+
+  // Delete dashboard
+  router.delete("/:id", requireAuth, (req: AuthRequest, res: Response) => {
+    const user = req.user!;
+    const dashboard = db
+      .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(req.params.id, user.tenant_id) as DashboardRow | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    db.prepare("DELETE FROM widgets WHERE dashboard_id = ?").run(dashboard.id);
+    db.prepare("DELETE FROM dashboards WHERE id = ?").run(dashboard.id);
+
+    res.status(204).send();
+  });
+
+  // Add widget to dashboard
+  router.post(
+    "/:id/widgets",
+    requireAuth,
+    (req: AuthRequest, res: Response) => {
+      const user = req.user!;
+      const dashboard = db
+        .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+        .get(req.params.id, user.tenant_id) as DashboardRow | undefined;
+
+      if (!dashboard) {
+        res.status(404).json({ error: "Dashboard not found" });
+        return;
+      }
+
+      const { type, config, position_x, position_y, width, height } = req.body;
+
+      if (!type || !["counter", "timeseries", "breakdown", "funnel"].includes(type)) {
+        res.status(400).json({
+          error: "Valid widget type is required (counter, timeseries, breakdown, funnel)",
+        });
+        return;
+      }
+
+      const id = uuidv4();
+      const widgetConfig = config ? JSON.stringify(config) : "{}";
+
+      db.prepare(
+        "INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)"
+      ).run(
+        id,
+        dashboard.id,
+        type,
+        widgetConfig,
+        position_x ?? 0,
+        position_y ?? 0,
+        width ?? 1,
+        height ?? 1
+      );
+
+      res.status(201).json({
+        id,
+        dashboard_id: dashboard.id,
+        type,
+        config: config || {},
+        position_x: position_x ?? 0,
+        position_y: position_y ?? 0,
+        width: width ?? 1,
+        height: height ?? 1,
+      });
+    }
+  );
+
+  return router;
+}
