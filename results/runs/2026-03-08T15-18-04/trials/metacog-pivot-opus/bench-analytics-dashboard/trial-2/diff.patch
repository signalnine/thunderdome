--- /dev/null
+++ b/src/app.test.ts
@@ -0,0 +1,337 @@
+import { describe, it, expect, beforeEach } from "vitest";
+import request from "supertest";
+import { createApp } from "./app.js";
+import { initDb } from "./db.js";
+import type { Application } from "express";
+import type Database from "better-sqlite3";
+
+describe("Analytics Dashboard API", () => {
+  let app: Application;
+  let db: Database.Database;
+
+  beforeEach(() => {
+    db = initDb();
+    app = createApp(db);
+  });
+
+  describe("Auth", () => {
+    it("should register a new user", async () => {
+      const res = await request(app)
+        .post("/auth/register")
+        .send({ email: "test@example.com", password: "pass123", tenant_id: "t1" });
+      expect(res.status).toBe(201);
+      expect(res.body.token).toBeDefined();
+      expect(res.body.email).toBe("test@example.com");
+      expect(res.body.tenant_id).toBe("t1");
+    });
+
+    it("should login an existing user", async () => {
+      await request(app)
+        .post("/auth/register")
+        .send({ email: "test@example.com", password: "pass123", tenant_id: "t1" });
+
+      const res = await request(app)
+        .post("/auth/login")
+        .send({ email: "test@example.com", password: "pass123" });
+      expect(res.status).toBe(200);
+      expect(res.body.token).toBeDefined();
+    });
+
+    it("should reject invalid credentials", async () => {
+      await request(app)
+        .post("/auth/register")
+        .send({ email: "test@example.com", password: "pass123", tenant_id: "t1" });
+
+      const res = await request(app)
+        .post("/auth/login")
+        .send({ email: "test@example.com", password: "wrong" });
+      expect(res.status).toBe(401);
+    });
+
+    it("should return 401 for unauthenticated profile access", async () => {
+      const res = await request(app).get("/auth/profile");
+      expect(res.status).toBe(401);
+    });
+
+    it("should return profile for authenticated user", async () => {
+      const reg = await request(app)
+        .post("/auth/register")
+        .send({ email: "test@example.com", password: "pass123", tenant_id: "t1" });
+
+      const res = await request(app)
+        .get("/auth/profile")
+        .set("Authorization", `Bearer ${reg.body.token}`);
+      expect(res.status).toBe(200);
+      expect(res.body.email).toBe("test@example.com");
+    });
+
+    it("should allow admin to change user role", async () => {
+      const admin = await request(app)
+        .post("/auth/register")
+        .send({ email: "admin@example.com", password: "pass123", tenant_id: "t1", role: "admin" });
+
+      const viewer = await request(app)
+        .post("/auth/register")
+        .send({ email: "viewer@example.com", password: "pass123", tenant_id: "t1" });
+
+      const res = await request(app)
+        .put(`/auth/users/${viewer.body.id}/role`)
+        .set("Authorization", `Bearer ${admin.body.token}`)
+        .send({ role: "editor" });
+      expect(res.status).toBe(200);
+      expect(res.body.role).toBe("editor");
+    });
+  });
+
+  describe("Events", () => {
+    let token: string;
+
+    beforeEach(async () => {
+      const reg = await request(app)
+        .post("/auth/register")
+        .send({ email: "test@example.com", password: "pass123", tenant_id: "t1" });
+      token = reg.body.token;
+    });
+
+    it("should ingest a single event", async () => {
+      const res = await request(app)
+        .post("/events")
+        .set("Authorization", `Bearer ${token}`)
+        .send({ name: "page_view", properties: { url: "/home" } });
+      expect(res.status).toBe(201);
+      expect(res.body.name).toBe("page_view");
+    });
+
+    it("should ingest a batch of events", async () => {
+      const res = await request(app)
+        .post("/events/batch")
+        .set("Authorization", `Bearer ${token}`)
+        .send({
+          events: [
+            { name: "page_view", properties: { url: "/home" } },
+            { name: "click", properties: { button: "signup" } },
+          ],
+        });
+      expect(res.status).toBe(201);
+      expect(res.body.inserted).toBe(2);
+    });
+
+    it("should reject unauthenticated event ingestion", async () => {
+      const res = await request(app)
+        .post("/events")
+        .send({ name: "page_view" });
+      expect(res.status).toBe(401);
+    });
+  });
+
+  describe("Queries", () => {
+    let token: string;
+
+    beforeEach(async () => {
+      const reg = await request(app)
+        .post("/auth/register")
+        .send({ email: "test@example.com", password: "pass123", tenant_id: "t1" });
+      token = reg.body.token;
+
+      // Ingest some events
+      await request(app)
+        .post("/events/batch")
+        .set("Authorization", `Bearer ${token}`)
+        .send({
+          events: [
