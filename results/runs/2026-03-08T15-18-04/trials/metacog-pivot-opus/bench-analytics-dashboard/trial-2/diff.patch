ansaction(\n      (\n        evts: Array<{\n          name: string;\n          properties?: Record<string, unknown>;\n          timestamp?: string;\n          session_id?: string;\n        }>\n      ) => {\n        for (const evt of evts) {\n          if (!evt.name) continue;\n          const id = uuidv4();\n          const eventTimestamp = evt.timestamp || new Date().toISOString();\n          const eventProperties = evt.properties\n            ? JSON.stringify(evt.properties)\n            : \"{}\";\n          insert.run(\n            id,\n            user.tenant_id,\n            evt.name,\n            eventProperties,\n            eventTimestamp,\n            user.id,\n            evt.session_id || null\n          );\n          results.push({ id, name: evt.name });\n        }\n      }\n    );\n\n    insertMany(events);\n\n    res.status(201).json({ inserted: results.length, events: results });\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":345,"cache_read_input_tokens":23408,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":345},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"5fb6dc79-c0fa-4971-a6d2-3c76b8d1c049","uuid":"295a3b36-6385-4df0-ba05-2818734fe382"}
