@@ -0,0 +1,223 @@
+import { Response, Router } from "express";
+import type Database from "better-sqlite3";
+import { AuthRequest, requireAuth } from "./auth.js";
+
+interface EventRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string | null;
+  session_id: string | null;
+}
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+interface WidgetRow {
+  id: string;
+  dashboard_id: string;
+  type: string;
+  config: string;
+  position_x: number;
+  position_y: number;
+  width: number;
+  height: number;
+}
+
+function escapeCsvField(value: string): string {
+  if (
+    value.includes(",") ||
+    value.includes('"') ||
+    value.includes("\n")
+  ) {
+    return `"${value.replace(/"/g, '""')}"`;
+  }
+  return value;
+}
+
+function eventsToCsv(events: EventRow[]): string {
+  const header = "id,name,properties,timestamp,user_id,session_id";
+  const rows = events.map((e) =>
+    [
+      escapeCsvField(e.id),
+      escapeCsvField(e.name),
+      escapeCsvField(e.properties),
+      escapeCsvField(e.timestamp),
+      escapeCsvField(e.user_id || ""),
+      escapeCsvField(e.session_id || ""),
+    ].join(",")
+  );
+  return [header, ...rows].join("\n");
+}
+
+export function createExportRouter(db: Database.Database): Router {
+  const router = Router();
+
+  // Export events as JSON
+  router.get(
+    "/events/json",
+    requireAuth,
+    (req: AuthRequest, res: Response) => {
+      const user = req.user!;
+      const { event_name, start_date, end_date } = req.query;
+
+      let query = "SELECT * FROM events WHERE tenant_id = ?";
+      const params: unknown[] = [user.tenant_id];
+
+      if (event_name) {
+        query += " AND name = ?";
+        params.push(event_name);
+      }
+      if (start_date) {
+        query += " AND timestamp >= ?";
+        params.push(start_date);
+      }
+      if (end_date) {
+        query += " AND timestamp <= ?";
+        params.push(end_date);
+      }
+
+      query += " ORDER BY timestamp DESC";
+
+      const events = db.prepare(query).all(...params) as EventRow[];
+
+      const parsed = events.map((e) => ({
+        ...e,
+        properties: JSON.parse(e.properties),
+      }));
+
+      res.setHeader("Content-Type", "application/json");
+      res.setHeader(
+        "Content-Disposition",
+        'attachment; filename="events.json"'
+      );
+      res.json({ events: parsed });
+    }
+  );
+
+  // Export events as CSV
+  router.get(
+    "/events/csv",
+    requireAuth,
+    (req: AuthRequest, res: Response) => {
+      const user = req.user!;
+      const { event_name, start_date, end_date } = req.query;
+
+      let query = "SELECT * FROM events WHERE tenant_id = ?";
+      const params: unknown[] = [user.tenant_id];
+
+      if (event_name) {
+        query += " AND name = ?";
+        params.push(event_name);
+      }
+      if (start_date) {
+        query += " AND timestamp >= ?";
+        params.push(start_date);
+      }
+      if (end_date) {
+        query += " AND timestamp <= ?";
+        params.push(end_date);
+      }
+
+      query += " ORDER BY timestamp DESC";
+
+      const events = db.prepare(query).all(...params) as EventRow[];
+
+      res.setHeader("Content-Type", "text/csv");
+      res.setHeader(
+        "Content-Disposition",
+        'attachment; filename="events.csv"'
+      );
+      res.send(eventsToCsv(events));
+    }
+  );
+
+  // Export dashboard as JSON
+  router.get(
+    "/dashboards/:id/json",
+    requireAuth,
+    (req: AuthRequest, res: Response) => {
+      const user = req.user!;
+      const dashboard = db
+        .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+        .get(req.params.id, user.tenant_id) as DashboardRow | undefined;
+
+      if (!dashboard) {
+        res.status(404).json({ error: "Dashboard not found" });
+        return;
+      }
+
+      const widgets = db
+        .prepare("SELECT * FROM widgets WHERE dashboard_id = ?")
+        .all(dashboard.id) as WidgetRow[];
+
+      res.setHeader("Content-Type", "application/json");
+      res.setHeader(
+        "Content-Disposition",
+        `attachment; filename="dashboard-${dashboard.id}.json"`
+      );
+      res.json({
+        ...dashboard,
+        config: JSON.parse(dashboard.config),
+        widgets: widgets.map((w) => ({ ...w, config: JSON.parse(w.config) })),
+      });
+    }
+  );
+
+  // Export dashboard as CSV
+  router.get(
+    "/dashboards/:id/csv",
+    requireAuth,
+    (req: AuthRequest, res: Response) => {
+      const user = req.user!;
+      const dashboard = db
+        .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+        .get(req.params.id, user.tenant_id) as DashboardRow | undefined;
+
+      if (!dashboard) {
+        res.status(404).json({ error: "Dashboard not found" });
+        return;
+      }
+
+      const widgets = db
+        .prepare("SELECT * FROM widgets WHERE dashboard_id = ?")
+        .all(dashboard.id) as WidgetRow[];
+
+      const header =
+        "dashboard_id,dashboard_name,widget_id,widget_type,config,position_x,position_y,width,height";
+      const rows = widgets.map((w) =>
+        [
+          escapeCsvField(dashboard.id),
+          escapeCsvField(dashboard.name),
+          escapeCsvField(w.id),
+          escapeCsvField(w.type),
+          escapeCsvField(w.config),
+          String(w.position_x),
+          String(w.position_y),
+          String(w.width),
+          String(w.height),
+        ].join(",")
+      );
+
+      const csv = [header, ...rows].join("\n");
+
+      res.setHeader("Content-Type", "text/csv");
+      res.setHeader(
+        "Content-Disposition",
+        `attachment; filename="dashboard-${dashboard.id}.csv"`
+      );
+      res.send(csv);
+    }
+  );
+
+  return router;
+}
