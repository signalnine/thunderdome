@@ -0,0 +1,167 @@
+import { Response, Router } from "express";
+import type Database from "better-sqlite3";
+import { AuthRequest, requireAuth } from "./auth.js";
+
+interface CountQuery {
+  event_name?: string;
+  start_date?: string;
+  end_date?: string;
+  filters?: Record<string, string>;
+}
+
+interface TimeseriesQuery {
+  event_name?: string;
+  start_date?: string;
+  end_date?: string;
+  interval?: "hour" | "day" | "week" | "month";
+  filters?: Record<string, string>;
+}
+
+interface BreakdownQuery {
+  event_name?: string;
+  property: string;
+  start_date?: string;
+  end_date?: string;
+  filters?: Record<string, string>;
+}
+
+function buildWhereClause(
+  tenantId: string,
+  eventName?: string,
+  startDate?: string,
+  endDate?: string,
+  filters?: Record<string, string>
+): { where: string; params: unknown[] } {
+  const conditions: string[] = ["tenant_id = ?"];
+  const params: unknown[] = [tenantId];
+
+  if (eventName) {
+    conditions.push("name = ?");
+    params.push(eventName);
+  }
+
+  if (startDate) {
+    conditions.push("timestamp >= ?");
+    params.push(startDate);
+  }
+
+  if (endDate) {
+    conditions.push("timestamp <= ?");
+    params.push(endDate);
+  }
+
+  if (filters) {
+    for (const [key, value] of Object.entries(filters)) {
+      conditions.push(`json_extract(properties, '$.' || ?) = ?`);
+      params.push(key, value);
+    }
+  }
+
+  return { where: conditions.join(" AND "), params };
+}
+
+export function createQueriesRouter(db: Database.Database): Router {
+  const router = Router();
+
+  // Count query
+  router.post("/count", requireAuth, (req: AuthRequest, res: Response) => {
+    const user = req.user!;
+    const { event_name, start_date, end_date, filters } =
+      req.body as CountQuery;
+
+    const { where, params } = buildWhereClause(
+      user.tenant_id,
+      event_name,
+      start_date,
+      end_date,
+      filters
+    );
+
+    const result = db
+      .prepare(`SELECT COUNT(*) as count FROM events WHERE ${where}`)
+      .get(...params) as { count: number };
+
+    res.json({ count: result.count });
+  });
+
+  // Timeseries query
+  router.post(
+    "/timeseries",
+    requireAuth,
+    (req: AuthRequest, res: Response) => {
+      const user = req.user!;
+      const { event_name, start_date, end_date, interval, filters } =
+        req.body as TimeseriesQuery;
+
+      const { where, params } = buildWhereClause(
+        user.tenant_id,
+        event_name,
+        start_date,
+        end_date,
+        filters
+      );
+
+      let dateFormat: string;
+      switch (interval) {
+        case "hour":
+          dateFormat = "%Y-%m-%dT%H:00:00";
+          break;
+        case "week":
+          dateFormat = "%Y-W%W";
+          break;
+        case "month":
+          dateFormat = "%Y-%m";
+          break;
+        case "day":
+        default:
+          dateFormat = "%Y-%m-%d";
+          break;
+      }
+
+      const rows = db
+        .prepare(
+          `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count FROM events WHERE ${where} GROUP BY bucket ORDER BY bucket`
+        )
+        .all(...params) as Array<{ bucket: string; count: number }>;
+
+      res.json({ data: rows });
+    }
+  );
+
+  // Breakdown query
+  router.post(
+    "/breakdown",
+    requireAuth,
+    (req: AuthRequest, res: Response) => {
+      const user = req.user!;
+      const { event_name, property, start_date, end_date, filters } =
+        req.body as BreakdownQuery;
+
+      if (!property) {
+        res.status(400).json({ error: "property is required" });
+        return;
+      }
+
+      const { where, params } = buildWhereClause(
+        user.tenant_id,
+        event_name,
+        start_date,
+        end_date,
+        filters
+      );
+
+      const rows = db
+        .prepare(
+          `SELECT json_extract(properties, '$.' || ?) as value, COUNT(*) as count FROM events WHERE ${where} GROUP BY value ORDER BY count DESC`
+        )
+        .all(property, ...params) as Array<{
+        value: string | null;
+        count: number;
+      }>;
+
+      res.json({ data: rows });
+    }
+  );
+
+  return router;
+}
