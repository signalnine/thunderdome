 now);\n\n    res.status(201).json({\n      id,\n      tenant_id: user.tenant_id,\n      name,\n      owner_id: user.id,\n      config: config || {},\n      created_at: now,\n      updated_at: now,\n    });\n  });\n\n  // Get dashboard by ID\n  router.get(\"/:id\", requireAuth, (req: AuthRequest, res: Response) => {\n    const user = req.user!;\n    const dashboard = db\n      .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n      .get(req.params.id, user.tenant_id) as DashboardRow | undefined;\n\n    if (!dashboard) {\n      res.status(404).json({ error: \"Dashboard not found\" });\n      return;\n    }\n\n    const widgets = db\n      .prepare(\"SELECT * FROM widgets WHERE dashboard_id = ?\")\n      .all(dashboard.id) as WidgetRow[];\n\n    res.json({\n      ...dashboard,\n      config: JSON.parse(dashboard.config),\n      widgets: widgets.map((w) => ({ ...w, config: JSON.parse(w.config) })),\n    });\n  });\n\n  // Update dashboard\n  router.put(\"/:id\", requireAuth, (req: AuthRequest, res: Response) => {\n    const user = req.user!;\n    const dashboard = db\n      .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n      .get(req.params.id, user.tenant_id) as DashboardRow | undefined;\n\n    if (!dashboard) {\n      res.status(404).json({ error: \"Dashboard not found\" });\n      return;\n    }\n\n    const { name, config } = req.body;\n    const updatedName = name || dashboard.name;\n    const updatedConfig = config ? JSON.stringify(config) : dashboard.config;\n    const now = new Date().toISOString();\n\n    db.prepare(\n      \"UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?\"\n    ).run(updatedName, updatedConfig, now, dashboard.id);\n\n    res.json({\n      id: dashboard.id,\n      tenant_id: dashboard.tenant_id,\n      name: updatedName,\n      owner_id: dashboard.owner_id,\n      config: JSON.parse(updatedConfig),\n      created_at: dashboard.created_at,\n      updated_at: now,\n    });\n  });\n\n  // Delete dashboard\n  router.delete(\"/:id\", requireAuth, (req: AuthRequest, res: Response) => {\n    const user = req.user!;\n    const dashboard = db\n      .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n      .get(req.params.id, user.tenant_id) as DashboardRow | undefined;\n\n    if (!dashboard) {\n      res.status(404).json({ error: \"Dashboard not found\" });\n      return;\n    }\n\n    db.prepare(\"DELETE FROM widgets WHERE dashboard_id = ?\").run(dashboard.id);\n    db.prepare(\"DELETE FROM dashboards WHERE id = ?\").run(dashboard.id);\n\n    res.status(204).send();\n  });\n\n  // Add widget to dashboard\n  router.post(\n    \"/:id/widgets\",\n    requireAuth,\n    (req: AuthRequest, res: Response) => {\n      const user = req.user!;\n      const dashboard = db\n        .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n        .get(req.params.id, user.tenant_id) as DashboardRow | undefined;\n\n      if (!dashboard) {\n        res.status(404).json({ error: \"Dashboard not found\" });\n        return;\n      }\n\n      const { type, config, position_x, position_y, width, height } = req.body;\n\n      if (!type || ![\"counter\", \"timeseries\", \"breakdown\", \"funnel\"].includes(type)) {\n        res.status(400).json({\n          error: \"Valid widget type is required (counter, timeseries, breakdown, funnel)\",\n        });\n        return;\n      }\n\n      const id = uuidv4();\n      const widgetConfig = config ? JSON.stringify(config) : \"{}\";\n\n      db.prepare(\n        \"INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)\"\n      ).run(\n        id,\n        dashboard.id,\n        type,\n        widgetConfig,\n        position_x ?? 0,\n        position_y ?? 0,\n        width ?? 1,\n        height ?? 1\n      );\n\n      res.status(201).json({\n        id,\n        dashboard_id: dashboard.id,\n        type,\n        config: c