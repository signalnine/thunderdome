ster\")\n        .send({ email: \"test@example.com\", password: \"pass123\", tenantId: \"t1\" });\n      token = reg.body.token;\n    });\n\n    it(\"should ingest a single event\", async () => {\n      const res = await request(app)\n        .post(\"/api/events\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"page_view\", properties: { url: \"/home\" } });\n\n      expect(res.status).toBe(201);\n      expect(res.body.name).toBe(\"page_view\");\n      expect(res.body.properties.url).toBe(\"/home\");\n    });\n\n    it(\"should return 401 without auth\", async () => {\n      const res = await request(app)\n        .post(\"/api/events\")\n        .send({ name: \"page_view\" });\n\n      expect(res.status).toBe(401);\n    });\n\n    it(\"should ingest batch events\", async () => {\n      const res = await request(app)\n        .post(\"/api/events/batch\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({\n          events: [\n            { name: \"page_view\", properties: { url: \"/home\" } },\n            { name: \"click\", properties: { button: \"signup\" } },\n            { name: \"page_view\", properties: { url: \"/about\" } },\n          ],\n        });\n\n      expect(res.status).toBe(201);\n      expect(res.body.inserted).toBe(3);\n    });\n  });\n\n  describe(\"Query Engine\", () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const reg = await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"test@example.com\", password: \"pass123\", tenantId: \"t1\" });\n      token = reg.body.token;\n\n      // Insert some events\n      await request(app)\n        .post(\"/api/events/batch\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({\n          events: [\n            { name: \"page_view\", properties: { url: \"/home\" }, timestamp: \"2024-01-01T10:00:00\" },\n            { name: \"page_view\", properties: { url: \"/about\" }, timestamp: \"2024-01-01T14:00:00\" },\n            { name: \"page_view\", properties: { url: \"/home\" }, timestamp: \"2024-01-02T10:00:00\" },\n            { name: \"click\", properties: { button: \"signup\" }, timestamp: \"2024-01-02T11:00:00\" },\n          ],\n        });\n    });\n\n    it(\"should count all events\", async () => {\n      const res = await request(app)\n        .post(\"/api/queries/count\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({});\n\n      expect(res.status).toBe(200);\n      expect(res.body.count).toBe(4);\n    });\n\n    it(\"should count filtered events\", async () => {\n      const res = await request(app)\n        .post(\"/api/queries/count\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ eventName: \"page_view\" });\n\n      expect(res.status).toBe(200);\n      expect(res.body.count).toBe(3);\n    });\n\n    it(\"should do timeseries query\", async () => {\n      const res = await request(app)\n        .post(\"/api/queries/timeseries\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ eventName: \"page_view\", interval: \"day\" });\n\n      expect(res.status).toBe(200);\n      expect(res.body.timeseries).toHaveLength(2);\n      expect(res.body.timeseries[0].count).toBe(2);\n      expect(res.body.timeseries[1].count).toBe(1);\n    });\n\n    it(\"should do breakdown query\", async () => {\n      const res = await request(app)\n        .post(\"/api/queries/breakdown\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ eventName: \"page_view\", property: \"url\" });\n\n      expect(res.status).toBe(200);\n      expect(res.body.breakdown).toHaveLength(2);\n    });\n\n    it(\"should isolate tenant data in queries\", async () => {\n      // Register user in different tenant\n      const reg2 = await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"other@example.com\", password: \"pass123\", tenantId: \"t2\" });\n\n      const res = await request(app)\n        .post(\"/api/queries/count\")\n        .set(\"Authorization\", `Bearer ${reg2.body.token}`)\n        .send({});\n\n      expect(res.status).toBe(200);\n      expect(res.body.count).toBe(0);\n    });\n  });\n\n  describe(\"Dashboard CRUD\", () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const reg = await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"test@example.com\", password: \"pass123\", tenantId: \"t1\" });\n      token = reg.body.token;\n    });\n\n    it(\"should create a dashboard\", async () => {\n      const res = await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"Main Dashboard\", config: { theme: \"dark\" } });\n\n      expect(res.status).toBe(201);\n      expect(res.body.name).toBe(\"Main Dashboard\");\n    });\n\n    it(\"should list dashboards\", async () => {\n      await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"Dashboard 1\" });\n\n      await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"Dashboard 2\" });\n\n      const res = await request(app)\n        .get(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body.dashboards).toHaveLength(2);\n    });\n\n    it(\"should get single dashboard\", async () => {\n      const created = await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"Test Dashboard\" });\n\n      const res = await request(app)\n        .get(`/api/dashboards/${created.body.id}`)\n        .set(\"Authorization\", `Bearer ${token}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe(\"Test Dashboard\");\n      expect(res.body.widgets).toBeDefined();\n    });\n\n    it(\"should update a dashboard\", async () => {\n      const created = await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"Old Name\" });\n\n      const res = await request(app)\n        .put(`/api/dashboards/${created.body.id}`)\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"New Name\" });\n\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe(\"New Name\");\n    });\n\n    it(\"should delete a dashboard\", async () => {\n      const created = await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"To Delete\" });\n\n      const res = await request(app)\n        .delete(`/api/dashboards/${created.body.id}`)\n        .set(\"Authorization\", `Bearer ${token}`);\n\n      expect(res.status).toBe(204);\n    });\n\n    it(\"should not see other tenant dashboards\", async () => {\n      await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"Tenant 1 Dashboard\" });\n\n      const reg2 = await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"other@example.com\", password: \"pass123\", tenantId: \"t2\" });\n\n      const res = await request(app)\n        .get(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${reg2.body.token}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body.dashboards).toHaveLength(0);\n    });\n  });\n\n  describe(\"Export\", () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const reg = await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"test@example.com\", password: \"pass123\", tenantId: \"t1\" });\n      token = reg.body.token;\n\n      await request(app)\n        .post(\"/api/events/batch\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({\n          events: [\n            { name: \"page_view\", properties: { url: \"/home\" } },\n            { name: \"click\", properties: { button: \"signup\" } },\n          ],\n        });\n    });\n\n    it(\"should export events as JSON\", async () => {\n      const res = await request(app)\n        .get(\"/api/export/events/json\")\n        .set(\"Authorization\", `Bearer ${token}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body.events).toHaveLength(2);\n    });\n\n    it(\"should export events as CSV\", async () => {\n      const res = await request(app)\n        .get(\"/api/export/events/csv\")\n        .set(\"Authorization\", `Bearer ${token}`);\n\n      expect(res.status).toBe(200);\n      expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n      expect(res.text).toContain(\"id,tenant_id,name\");\n    });\n\n    it(\"should export dashboards as JSON\", async () => {\n      await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"Export Dashboard\" });\n\n      const res = await request(app)\n        .get(\"/api/export/dashboards/json\")\n        .set(\"Authorization\", `Bearer ${token}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body.dashboards).toHaveLength(1);\n    });\n\n    it(\"should export dashboards as CSV\", async () => {\n      await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"Export Dashboard\" });\n\n      const res = await request(app)\n        .get(\"/api/export/dashboards/csv\")\n        .set(\"Authorization\", `Bearer ${token}`);\n\n      expect(res.status).toBe(200);\n      expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n    });\n\n    it(\"should not export other tenant data\", async () => {\n      const reg2 = await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"other@example.com\", password: \"pass123\", tenantId: \"t2\" });\n\n      const res = await request(app)\n        .get(\"/api/export/events/json\")\n        .set(\"Authorization\", `Bearer ${reg2.body.token}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body.events).toHaveLength(0);\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
