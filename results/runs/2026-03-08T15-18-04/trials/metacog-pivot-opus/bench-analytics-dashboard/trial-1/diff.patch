new file mode 100644
index 0000000..8c0ea0b
--- /dev/null
+++ b/src/routes/queries.ts
@@ -0,0 +1,152 @@
+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { AuthRequest, authMiddleware } from "../auth.js";
+
+export function createQueryRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // All query routes require auth
+  router.use(authMiddleware);
+
+  // Count events matching filter
+  router.post("/count", (req: AuthRequest, res: Response) => {
+    const { eventName, startDate, endDate, filters } = req.body;
+    const tenantId = req.user!.tenantId;
+
+    let sql = "SELECT COUNT(*) as count FROM events WHERE tenant_id = ?";
+    const params: (string | number)[] = [tenantId];
+
+    if (eventName) {
+      sql += " AND name = ?";
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, String(value));
+      }
+    }
+
+    const result = db.prepare(sql).get(...params) as { count: number };
+
+    res.json({ count: result.count });
+  });
+
+  // Timeseries query - bucket event counts over time
+  router.post("/timeseries", (req: AuthRequest, res: Response) => {
+    const { eventName, startDate, endDate, interval, filters } = req.body;
+    const tenantId = req.user!.tenantId;
+
+    // Default interval is "day"
+    const granularity = interval || "day";
+    let dateFormat: string;
+
+    switch (granularity) {
+      case "hour":
+        dateFormat = "%Y-%m-%dT%H:00:00";
+        break;
+      case "day":
+        dateFormat = "%Y-%m-%d";
+        break;
+      case "week":
+        dateFormat = "%Y-W%W";
+        break;
+      case "month":
+        dateFormat = "%Y-%m";
+        break;
+      default:
+        dateFormat = "%Y-%m-%d";
+    }
+
+    let sql = `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: (string | number)[] = [tenantId];
+
+    if (eventName) {
+      sql += " AND name = ?";
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, String(value));
+      }
+    }
+
+    sql += " GROUP BY bucket ORDER BY bucket ASC";
+
+    const results = db.prepare(sql).all(...params) as Array<{ bucket: string; count: number }>;
+
+    res.json({ timeseries: results });
+  });
+
+  // Breakdown query - group event counts by a property value
+  router.post("/breakdown", (req: AuthRequest, res: Response) => {
+    const { eventName, property, startDate, endDate, filters } = req.body;
+    const tenantId = req.user!.tenantId;
+
+    if (!property) {
+      res.status(400).json({ error: "property is required for breakdown queries" });
+      return;
+    }
+
+    let sql = `SELECT json_extract(properties, ?) as property_value, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: (string | number)[] = [`$.${property}`, tenantId];
+
+    if (eventName) {
+      sql += " AND name = ?";
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, String(value));
+      }
+    }
+
+    sql += " GROUP BY property_value ORDER BY count DESC";
+
+    const results = db.prepare(sql).all(...params) as Array<{ property_value: string; count: number }>;
+
+    res.json({
+      breakdown: results.map((r) => ({
+        value: r.property_value,
+        count: r.count,
+      })),
+    });
+  });
+
+  return router;
+}
