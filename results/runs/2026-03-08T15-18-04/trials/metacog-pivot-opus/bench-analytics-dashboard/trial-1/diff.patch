@@ -0,0 +1,86 @@
+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { v4 as uuidv4 } from "uuid";
+import { AuthRequest, authMiddleware } from "../auth.js";
+
+export function createEventRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // All event routes require auth
+  router.use(authMiddleware);
+
+  // Ingest single event
+  router.post("/", (req: AuthRequest, res: Response) => {
+    const { name, properties, timestamp, sessionId } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: "Event name is required" });
+      return;
+    }
+
+    const id = uuidv4();
+    const tenantId = req.user!.tenantId;
+    const userId = req.user!.userId;
+    const eventTimestamp = timestamp || new Date().toISOString();
+    const eventProperties = properties ? JSON.stringify(properties) : "{}";
+
+    db.prepare(
+      "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    ).run(id, tenantId, name, eventProperties, eventTimestamp, userId, sessionId || null);
+
+    res.status(201).json({
+      id,
+      tenantId,
+      name,
+      properties: properties || {},
+      timestamp: eventTimestamp,
+      userId,
+      sessionId: sessionId || null,
+    });
+  });
+
+  // Batch ingest
+  router.post("/batch", (req: AuthRequest, res: Response) => {
+    const { events } = req.body;
+
+    if (!Array.isArray(events) || events.length === 0) {
+      res.status(400).json({ error: "events array is required and must not be empty" });
+      return;
+    }
+
+    const tenantId = req.user!.tenantId;
+    const userId = req.user!.userId;
+
+    const insertStmt = db.prepare(
+      "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    );
+
+    const inserted: Array<{ id: string; name: string }> = [];
+
+    const insertAll = db.transaction(() => {
+      for (const event of events) {
+        if (!event.name) continue;
+        const id = uuidv4();
+        const eventTimestamp = event.timestamp || new Date().toISOString();
+        const eventProperties = event.properties ? JSON.stringify(event.properties) : "{}";
+
+        insertStmt.run(
+          id,
+          tenantId,
+          event.name,
+          eventProperties,
+          eventTimestamp,
+          userId,
+          event.sessionId || null
+        );
+        inserted.push({ id, name: event.name });
+      }
+    });
+
+    insertAll();
+
+    res.status(201).json({ inserted: inserted.length, events: inserted });
+  });
+
+  return router;
+}
diff --git a/src/routes/exports.ts b/src/routes/exports.ts
new file mode 100644
index 0000000..c3ed65d
--- /dev/null
+++ b/src/routes/exports.ts
@@ -0,0 +1,150 @@
+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { AuthRequest, authMiddleware } from "../auth.js";
+
+interface EventRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string | null;
+  session_id: string | null;
+}
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+function eventsToCsv(events: EventRow[]): string {
+  const header = "id,tenant_id,name,properties,timestamp,user_id,session_id";
+  const rows = events.map((e) => {
+    const props = e.properties.replace(/"/g, '""');
+    return `${e.id},${e.tenant_id},${e.name},"${props}",${e.timestamp},${e.user_id || ""},${e.session_id || ""}`;
+  });
+  return [header, ...rows].join("\n");
+}
+
+function dashboardsToCsv(dashboards: DashboardRow[]): string {
+  const header = "id,tenant_id,name,owner_id,config,created_at,updated_at";
+  const rows = dashboards.map((d) => {
+    const config = d.config.replace(/"/g, '""');
+    return `${d.id},${d.tenant_id},${d.name},${d.owner_id},"${config}",${d.created_at},${d.updated_at}`;
+  });
+  return [header, ...rows].join("\n");
+}
+
+export function createExportRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // All export routes require auth
+  router.use(authMiddleware);
+
+  // Export events as JSON
+  router.get("/events/json", (req: AuthRequest, res: Response) => {
+    const tenantId = req.user!.tenantId;
+    const { eventName, startDate, endDate } = req.query;
+
+    let sql = "SELECT * FROM events WHERE tenant_id = ?";
+    const params: string[] = [tenantId];
+
+    if (eventName) {
+      sql += " AND name = ?";
+      params.push(String(eventName));
+    }
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(String(startDate));
+    }
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(String(endDate));
+    }
+
+    sql += " ORDER BY timestamp DESC";
+
+    const events = db.prepare(sql).all(...params) as EventRow[];
+
+    const formatted = events.map((e) => ({
+      id: e.id,
+      tenantId: e.tenant_id,
+      name: e.name,
+      properties: JSON.parse(e.properties),
+      timestamp: e.timestamp,
+      userId: e.user_id,
+      sessionId: e.session_id,
+    }));
+
+    res.json({ events: formatted });
+  });
+
+  // Export events as CSV
+  router.get("/events/csv", (req: AuthRequest, res: Response) => {
+    const tenantId = req.user!.tenantId;
+    const { eventName, startDate, endDate } = req.query;
+
+    let sql = "SELECT * FROM events WHERE tenant_id = ?";
+    const params: string[] = [tenantId];
+
+    if (eventName) {
+      sql += " AND name = ?";
+      params.push(String(eventName));
+    }
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(String(startDate));
+    }
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(String(endDate));
+    }
+
+    sql += " ORDER BY timestamp DESC";
+
+    const events = db.prepare(sql).all(...params) as EventRow[];
+
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader("Content-Disposition", "attachment; filename=events.csv");
+    res.send(eventsToCsv(events));
+  });
+
+  // Export dashboards as JSON
+  router.get("/dashboards/json", (req: AuthRequest, res: Response) => {
+    const tenantId = req.user!.tenantId;
