ail: \"viewer@example.com\", password: \"pass123\", tenantId: \"t1\" });\n\n      const res = await request(app)\n        .put(`/api/users/${viewer.body.id}/role`)\n        .set(\"Authorization\", `Bearer ${admin.body.token}`)\n        .send({ role: \"editor\" });\n\n      expect(res.status).toBe(200);\n      expect(res.body.role).toBe(\"editor\");\n    });\n\n    it(\"should prevent non-admin from changing roles\", async () => {\n      const viewer = await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"viewer@example.com\", password: \"pass123\", tenantId: \"t1\" });\n\n      const other = await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"other@example.com\", password: \"pass123\", tenantId: \"t1\" });\n\n      const res = await request(app)\n        .put(`/api/users/${other.body.id}/role`)\n        .set(\"Authorization\", `Bearer ${viewer.body.token}`)\n        .send({ role: \"editor\" });\n\n      expect(res.status).toBe(403);\n    });\n\n    it(\"should prevent cross-tenant role changes\", async () => {\n      const admin1 = await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"admin1@example.com\", password: \"pass123\", tenantId: \"t1\", role: \"admin\" });\n\n      const user2 = await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"user2@example.com\", password: \"pass123\", tenantId: \"t2\" });\n\n      const res = await request(app)\n        .put(`/api/users/${user2.body.id}/role`)\n        .set(\"Authorization\", `Bearer ${admin1.body.token}`)\n        .send({ role: \"editor\" });\n\n      expect(res.status).toBe(403);\n    });\n  });\n\n  describe(\"Event Ingestion\", () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const reg = await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"test@example.com\", password: \"pass123\", tenantId: \"t1\" });\n      token = reg.body.token;\n 