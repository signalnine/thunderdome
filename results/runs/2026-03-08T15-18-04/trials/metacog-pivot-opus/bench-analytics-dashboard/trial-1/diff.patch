enant_id = ?\";\n    const params: string[] = [tenantId];\n\n    if (eventName) {\n      sql += \" AND name = ?\";\n      params.push(String(eventName));\n    }\n    if (startDate) {\n      sql += \" AND timestamp >= ?\";\n      params.push(String(startDate));\n    }\n    if (endDate) {\n      sql += \" AND timestamp <= ?\";\n      params.push(String(endDate));\n    }\n\n    sql += \" ORDER BY timestamp DESC\";\n\n    const events = db.prepare(sql).all(...params) as EventRow[];\n\n    const formatted = events.map((e) => ({\n      id: e.id,\n      tenantId: e.tenant_id,\n      name: e.name,\n      properties: JSON.parse(e.properties),\n      timestamp: e.timestamp,\n      userId: e.user_id,\n      sessionId: e.session_id,\n    }));\n\n    res.json({ events: formatted });\n  });\n\n  // Export events as CSV\n  router.get(\"/events/csv\", (req: AuthRequest, res: Response) => {\n    const tenantId = req.user!.tenantId;\n    const { eventName, startDate, endDate } = req.query;\n\n    let sql = \"SELECT * FROM events WHERE tenant_id = ?\";\n    const params: string[] = [tenantId];\n\n    if (eventName) {\n      sql += \" AND name = ?\";\n      params.push(String(eventName));\n    }\n    if (startDate) {\n      sql += \" AND timestamp >= ?\";\n      params.push(String(startDate));\n    }\n    if (endDate) {\n      sql += \" AND timestamp <= ?\";\n      params.push(String(endDate));\n    }\n\n    sql += \" ORDER BY timestamp DESC\";\n\n    const events = db.prepare(sql).all(...params) as EventRow[];\n\n    res.setHeader(\"Content-Type\", \"text/csv\");\n    res.setHeader(\"Content-Disposition\", \"attachment; filename=events.csv\");\n    res.send(eventsToCsv(events));\n  });\n\n  // Export dashboards as JSON\n  router.get(\"/dashboards/json\", (req: AuthRequest, res: Response) => {\n    const tenantId = req.user!.tenantId;\n    const dashboards = db\n      .prepare(\"SELECT * FROM dashboards WHERE tenant_id = ?\")\n      .all(tenantId) as DashboardRow[];\n\n    const formatted = dashboards.map((d) => ({\n      id: d.id,\n      tenantId: d.tenant_id,\n      name: d.name,\n      ownerId: d.owner_id,\n      config: JSON.parse(d.config),\n      createdAt: d.created_at,\n      updatedAt: d.updated_at,\n    }));\n\n    res.json({ dashboards: formatted });\n  });\n\n  // Export dashboards as CSV\n  router.get(\"/dashboards/csv\", (req: AuthRequest, res: Response) => {\n    const tenantId = req.user!.tenantId;\n    const dashboards = db\n      .prepare(\"SELECT * FROM dashboards WHERE tenant_id = ?\")\n      .all(tenantId) as DashboardRow[];\n\n    res.setHeader(\"Content-Type\", \"text/csv\");\n    res.setHeader(\"Content-Disposition\", \"attachment; filename=dashboards.csv\");\n    res.send(dashboardsToCsv(dashboards));\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3463,"cache_read_input_tokens":28600,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3463},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"e01881cc-0ee5-483c-aeae-6daa1136bc4d","uuid":"ff6123c6-ac9d-4e95-83fa-9f2b4c5c06cf"}
