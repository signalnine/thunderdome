+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_013F6jUYEtdDdRUDNsALBMpx","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_012d6MZxGbJAdXakN65MeTqs","name":"Write","input":{"file_path":"/workspace/src/routes/dashboards.ts","content":"import { Router, Response } from \"express\";\nimport Database from \"better-sqlite3\";\nimport { v4 as uuidv4 } from \"uuid\";\nimport { AuthRequest, authMiddleware } from \"../auth.js\";\n\ninterface DashboardRow {\n  id: string;\n  tenant_id: string;\n  name: string;\n  owner_id: string;\n  config: string;\n  created_at: string;\n  updated_at: string;\n}\n\ninterface WidgetRow {\n  id: string;\n  dashboard_id: string;\n  type: string;\n  config: string;\n  position_x: number;\n  position_y: number;\n  width: number;\n  height: number;\n}\n\nexport function createDashboardRoutes(db: Database.Database): Router {\n  const router = Router();\n\n  // All dashboard routes require auth\n  router.use(authMiddleware);\n\n  // List dashboards for tenant\n  router.get(\"/\", (req: AuthRequest, res: Response) => {\n    const tenantId = req.user!.tenantId;\n    const dashboards = db\n      .prepare(\"SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC\")\n      .all(tenantId) as DashboardRow[];\n\n    res.json({\n      dashboards: dashboards.map((d) => ({\n        id: d.id,\n        tenantId: d.tenant_id,\n        name: d.name,\n        ownerId: d.owner_id,\n        config: JSON.parse(d.config),\n        createdAt: d.created_at,\n        updatedAt: d.updated_at,\n      })),\n    });\n  });\n\n  // Create dashboard\n  router.post(\"/\", (req: AuthRequest, res: Response) => {\n    const { name, config } = req.body;\n    const tenantId = req.user!.tenantId;\n\n    if (!name) {\n      res.status(400).json({ error: \"name is required\" });\n      return;\n    }\n\n    const id = uuidv4();\n    const ownerId = req.user!.userId;\n    const dashConfig = config ? JSON.stringify(config) : \"{}\";\n\n    db.prepare(\n      \"INSERT INTO dashboards (id, tenant_id, name, owner_id, config) VALUES (?, ?, ?, ?, ?)\"\n    ).run(id, tenantId, name, ownerId, dashConfig);\n\n    res.status(201).json({\n      id,\n      tenantId,\n      name,\n      ownerId,\n      config: config || {},\n    });\n  });\n\n  // Get single dashboard with widgets\n  router.get(\"/:dashboardId\", (req: AuthRequest, res: Response) => {\n    const tenantId = req.user!.tenantId;\n    const { dashboardId } = req.params;\n\n    const dashboard = db\n      .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n      .get(dashboardId, tenantId) as DashboardRow | undefined;\n\n    if (!dashboard) {\n      res.status(404).json({ error: \"Dashboard not found\" });\n      return;\n    }\n\n    const widgets = db\n      .prepare(\"SELECT * FROM widgets WHERE dashboard_id = ?\")\n      .all(dashboardId) as WidgetRow[];\n\n    res.json({\n      id: dashboard.id,\n      tenantId: dashboard.tenant_id,\n      name: dashboard.name,\n      ownerId: dashboard.owner_id,\n      config: JSON.parse(dashboard.config),\n      createdAt: dashboard.created_at,\n      updatedAt: dashboard.updated_at,\n      widgets: widgets.map((w) => ({\n        id: w.id,\n        dashboardId: w.dashboard_id,\n        type: w.type,\n        config: JSON.parse(w.config),\n        positionX: w.position_x,\n        positionY: w.position_y,\n        width: w.width,\n        height: w.height,\n      })),\n    });\n  });\n\n  // Update dashboard\n  router.put(\"/:dashboardId\", (req: AuthRequest, res: Response) => {\n    const tenantId = req.user!.tenantId;\n    const { dashboardId } = req.params;\n    const { name, config } = req.body;\n\n    const existing = db\n      .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n      .get(dashboardId, tenantId) as DashboardRow | undefined;\n\n    if (!existing) {\n      res.status(404).json({ error: \"Dashboard not found\" });\n      return;\n    }\n\n    const updatedName = name || existing.name;\n    const updatedConfig = config ? JSON.stringify(config) : existing.config;\n\n    db.prepare(\n      \"UPDATE dashboards SET name = ?, config = ?, updated_at = datetime('now') WHERE id = ?\"\n    ).run(updatedName, updatedConfig, dashboardId);\n\n    res.json({\n      id: dashboardId,\n      tenantId,\n      name: updatedName,\n      ownerId: existing.owner_id,\n      config: config || JSON.parse(existing.config),\n    });\n  });\n\n  // Delete dashboard\n  router.delete(\"/:dashboardId\", (req: AuthRequest, res: Response) => {\n    const tenantId = req.user!.tenantId;\n    const { dashboardId } = req.params;\n\n    const existing = db\n      .prepare(\"SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?\")\n      .get(dashboardId, tenantId) as { id: string } | undefined;\n\n    if (!existing) {\n      res.status(404).json({ error: \"Dashboard not found\" });\n      return;\n    }\n\n    // Delete widgets first (cascade should handle this, but be explicit)\n    db.prepare(\"DELETE FROM widgets WHERE dashboard_id = ?\").run(dashboardId);\n    db.prepare(\"DELETE FROM dashboards WHERE id = ?\").run(dashboardId);\n\n    res.status(204).send();\n  });\n\n  // Add widget to dashboard\n  router.post(\"/:dashboardId/widgets\", (req: AuthRequest, res: Response) => {\n    const tenantId = req.user!.tenantId;\n    const { dashboardId } = req.params;\n    const { type, config, positionX, positionY, width, height } = req.body;\n\n    const dashboard = db\n      .prepare(\"SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?\")\n      .get(dashboardId, tenantId) as { id: string } | undefined;\n\n    if (!dashboard) {\n      res.status(404).json({ error: \"Dashboard not found\" });\n      return;\n    }\n\n    if (!type || ![\"counter\", \"timeseries\", \"breakdown\", \"funnel\"].includes(type)) {\n      res.status(400).json({ error: \"Valid type is required (counter, timeseries, breakdown, funnel)\" });\n      return;\n    }\n\n    const id = uuidv4();\n    const widgetConfig = config ? JSON.stringify(config) : \"{}\";\n\n    db.prepare(\n      \"INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)\"\n    ).run(id, dashboardId, type, widgetConfig, positionX || 0, positionY || 0, width || 1, height || 1);\n\n    res.status(201).json({\n      id,\n      dashboardId,\n      type,\n      config: config || {},\n      positionX: positionX || 0,\n      positionY: positionY || 0,\n      width: width || 1,\n      height: height || 1,\n    });\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":426,"cache_read_input_tokens":28174,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":426},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"e01881cc-0ee5-483c-aeae-6daa1136bc4d","uuid":"68915713-7b36-411a-a2af-defa04004b72"}
