er.stop();\n      tracker.start(\"coding\");\n      tracker.stop();\n      tracker.start(\"review\");\n      tracker.stop();\n\n      const summary = tracker.getSummary();\n      expect(summary[\"coding\"]).toBeGreaterThan(0);\n      expect(summary[\"review\"]).toBeGreaterThan(0);\n      // coding ran twice, so should be at least as much as review\n      expect(Object.keys(summary)).toHaveLength(2);\n    });\n\n    it(\"should include running tasks using current time\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"running-task\");\n\n      const summary = tracker.getSummary();\n      expect(summary[\"running-task\"]).toBeGreaterThanOrEqual(0);\n    });\n  });\n\n  describe(\"unicode support\", () => {\n    it(\"should handle emoji task names\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"🚀 Launch prep\");\n      tracker.stop();\n\n      const entries = tracker.getEntries();\n      expect(entries[0].task).toBe(\"🚀 Launch prep\");\n    });\n\n    it(\"should handle CJK characters\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"日本語のタスク\");\n      tracker.stop();\n\n      const entries = tracker.getEntries();\n      expect(entries[0].task).toBe(\"日本語のタスク\");\n    });\n\n    it(\"should persist unicode correctly\", () => {\n      const tracker1 = new TimeTracker(filePath);\n      tracker1.start(\"Ünïcödé Täsk 🎉\");\n      tracker1.stop();\n\n      const tracker2 = new TimeTracker(filePath);\n      const entries = tracker2.getEntries();\n      expect(entries[0].task).toBe(\"Ünïcödé Täsk 🎉\");\n    });\n  });\n\n  describe(\"isRunning and currentTask\", () => {\n    it(\"should report running state correctly\", () => {\n      const tracker = new TimeTracker(filePath);\n      expect(tracker.isRunning()).toBe(false);\n      expect(tracker.currentTask()).toBeNull();\n\n      tracker.start(\"task\");\n      expect(tracker.isRunning()).toBe(true);\n      expect(tracker.currentTask()).toBe(\"task\");\n\n      tracker.stop();\n      expect(tracker.isRunning()).toBe(false);\n      expect(tracker.currentTask()).toBeNull();\n    });\n  });\n});\n","structuredPatch":[{"oldStart":97,"oldLines":13,"newStart":97,"newLines":8,"lines":["     });"," ","     it(\"should create parent directories if they don't exist\", () => {","-      const nested = join(","-        tmpdir(),","-        `tt-test-${Date.now()}`,","-        \"deep\",","-        \"nested\",","-        \"data.json\"","-      );","+      const topDir = join(tmpdir(), `tt-test-${Date.now()}`);","+      const nested = join(topDir, \"deep\", \"nested\", \"data.json\");","       const tracker = new TimeTracker(nested);","       tracker.start(\"task\");","       tracker.stop();"]},{"oldStart":111,"oldLines":7,"newStart":106,"newLines":6,"lines":["       expect(existsSync(nested)).toBe(true);"," ","       // Clean up","-      const topDir = join(tmpdir(), nested.split(\"/\").find((p) => p.startsWith(\"tt-test-\"))!);","       rmSync(topDir, { recursive: true, force: true });","     });"," "]}],"userModified":false,"replaceAll":false}}
