oin(tmpdir(), `tt-test-${Date.now()}`);\n      const nested = join(topDir, \"deep\", \"nested\", \"data.json\");\n      const tracker = new TimeTracker(nested);\n      tracker.start(\"task\");\n      tracker.stop();\n\n      expect(existsSync(nested)).toBe(true);\n\n      // Clean up\n      rmSync(topDir, { recursive: true, force: true });\n    });\n\n    it(\"should save valid JSON\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"coding\");\n      tracker.stop();\n\n      const raw = readFileSync(filePath, \"utf-8\");\n      const data = JSON.parse(raw);\n      expect(data.entries).toHaveLength(1);\n      expect(data.entries[0].task).toBe(\"coding\");\n    });\n\n    it(\"should handle corrupt file gracefully\", () => {\n      // Create a corrupt file\n      const dir = join(tmpdir(), `tt-corrupt-${Date.now()}`);\n      mkdirSync(dir, { recursive: true });\n      const corruptFile = join(dir, \"data.json\");\n      writeFileSync(corruptFile, \"not valid json{{{\", \"utf-8\");\n\n      const tracker = new TimeTracker(corruptFile);\n      expect(tracker.getEntries()).toHaveLength(0);\n\n      // Should still be able to use it\n      tracker.start(\"recovery\");\n      tracker.stop();\n      expect(tracker.getEntries()).toHaveLength(1);\n\n      rmSync(dir, { recursive: true, force: true });\n    });\n  });\n\n  describe(\"querying entries\", () => {\n    it(\"should return all entries when no filters\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"task1\");\n      tracker.stop();\n      tracker.start(\"task2\");\n      tracker.stop();\n\n      expect(tracker.getEntries()).toHaveLength(2);\n    });\n\n    it(\"should filter entries by date range\", () => {\n      const tracker = new TimeTracker(filePath);\n\n      tracker.start(\"task1\");\n      tracker.stop();\n\n      const afterFirst = new Date();\n\n      // Small delay to ensure distinct timestamps\n      const beforeSecond = new Date(Date.now() + 1);\n      tracker.start(\"task2\");\n      tracker.stop();\n\n      const entries = tracker.getEntries(afterFirst);\n      // task2 started after afterFirst\n      expect(entries.length).toBeGreaterThanOrEqual(0); // timing dependent\n\n      const allEntries = tracker.getEntries();\n      expect(allEntries).toHaveLength(2);\n    });\n\n    it(\"should filter with both from and to\", () => {\n      const tracker = new TimeTracker(filePath);\n\n      const before = new Date(Date.now() - 1000);\n      tracker.start(\"in-range\");\n      tracker.stop();\n      const after = new Date(Date.now() + 1000);\n\n      tracker.start(\"out-of-range\");\n      tracker.stop();\n\n      // The first entry should be in range\n      const entries = tracker.getEntries(before, after);\n      // Both might be in range since they're very close in time\n      expect(entries.length).toBeGreaterThanOrEqual(1);\n    });\n  });\n\n  describe(\"summarizing time\", () => {\n    it(\"should sum durations by task name\", () => {\n      const tracker = new TimeTracker(filePath);\n\n      tracker.start(\"coding\");\n      tracker.stop();\n      tracker.start(\"coding\");\n      tracker.stop();\n      tracker.start(\"review\");\n      tracker.stop();\n\n      const summary = tracker.getSummary();\n      expect(summary[\"coding\"]).toBeGreaterThan(0);\n      expect(summary[\"review\"]).toBeGreaterThan(0);\n      // coding ran twice, so should be at least as much as review\n      expect(Object.keys(summary)).toHaveLength(2);\n    });\n\n    it(\"should include running tasks using current time\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"running-task\");\n\n      const summary = tracker.getSummary();\n      expect(summary[\"running-task\"]).toBeGreaterThanOrEqual(0);\n    });\n  });\n\n  describe(\"unicode support\", () => {\n    it(\"should handle emoji task names\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"🚀 Launch