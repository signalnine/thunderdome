y running timer\n    const running = this.getRunningEntry();\n    if (running) {\n      running.stop = new Date().toISOString();\n    }\n\n    const entry: TimeEntry = {\n      task,\n      start: new Date().toISOString(),\n      stop: null,\n    };\n\n    this.data.entries.push(entry);\n    this.save();\n    return entry;\n  }\n\n  stop(): TimeEntry {\n    const running = this.getRunningEntry();\n    if (!running) {\n      throw new Error(\"No timer is currently running\");\n    }\n\n    running.stop = new Date().toISOString();\n    this.save();\n    return running;\n  }\n\n  getEntries(from?: Date, to?: Date): TimeEntry[] {\n    return this.data.entries.filter((entry) => {\n      const start = new Date(entry.start);\n      if (from && start < from) return false;\n      if (to && start > to) return false;\n      return true;\n    });\n  }\n\n  getSummary(from?: Date, to?: Date): Record<string, number> {\n    const entries = this.getEntries(from, to);\n    const summary: Record<string, number> = {};\n\n    for (const entry of entries) {\n      const startMs = new Date(entry.start).getTime();\n      const stopMs = entry.stop\n        ? new Date(entry.stop).getTime()\n        : Date.now();\n      const duration = stopMs - startMs;\n\n      if (summary[entry.task] === undefined) {\n        summary[entry.task] = 0;\n      }\n      summary[entry.task] += duration;\n    }\n\n    return summary;\n  }\n\n  isRunning(): boolean {\n    return this.getRunningEntry() !== undefined;\n  }\n\n  currentTask(): string | null {\n    const running = this.getRunningEntry();\n    return running ? running.task : null;\n  }\n}\n","structuredPatch":[],"originalFile":null}}
