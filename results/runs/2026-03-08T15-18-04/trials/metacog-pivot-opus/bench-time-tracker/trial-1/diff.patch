+++ b/src/tracker.test.ts
@@ -0,0 +1,263 @@
+import { describe, it, expect, beforeEach, afterEach } from "vitest";
+import { TimeTracker } from "./tracker.js";
+import { existsSync, rmSync, readFileSync, mkdirSync, writeFileSync } from "node:fs";
+import { join } from "node:path";
+import { tmpdir } from "node:os";
+
+function tmpFile(): string {
+  return join(
+    tmpdir(),
+    `time-tracker-test-${Date.now()}-${Math.random().toString(36).slice(2)}.json`
+  );
+}
+
+describe("TimeTracker", () => {
+  let filePath: string;
+
+  beforeEach(() => {
+    filePath = tmpFile();
+  });
+
+  afterEach(() => {
+    try {
+      if (existsSync(filePath)) rmSync(filePath);
+    } catch {
+      // ignore cleanup errors
+    }
+  });
+
+  describe("starting timers", () => {
+    it("should start a timer and create the data file", () => {
+      const tracker = new TimeTracker(filePath);
+      const entry = tracker.start("coding");
+
+      expect(entry.task).toBe("coding");
+      expect(entry.start).toBeTruthy();
+      expect(entry.stop).toBeNull();
