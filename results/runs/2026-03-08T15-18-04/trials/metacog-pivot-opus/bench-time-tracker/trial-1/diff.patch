@@ -0,0 +1,125 @@
+import { readFileSync, writeFileSync, mkdirSync, existsSync } from "node:fs";
+import { dirname } from "node:path";
+
+export interface TimeEntry {
+  task: string;
+  start: string; // ISO 8601
+  stop: string | null; // ISO 8601 or null if still running
+}
+
+interface TrackerData {
+  entries: TimeEntry[];
+}
+
+export class TimeTracker {
+  private filePath: string;
+  private data: TrackerData;
+
+  constructor(filePath: string) {
+    this.filePath = filePath;
+    this.data = this.load();
+  }
+
+  private load(): TrackerData {
+    try {
+      if (existsSync(this.filePath)) {
+        const raw = readFileSync(this.filePath, "utf-8");
+        const parsed: unknown = JSON.parse(raw);
+        if (
+          typeof parsed === "object" &&
+          parsed !== null &&
+          "entries" in parsed &&
+          Array.isArray((parsed as TrackerData).entries)
+        ) {
+          return parsed as TrackerData;
+        }
+      }
+    } catch {
+      // If file is corrupt or unreadable, start fresh
+    }
+    return { entries: [] };
+  }
+
+  private save(): void {
+    const dir = dirname(this.filePath);
+    if (!existsSync(dir)) {
+      mkdirSync(dir, { recursive: true });
+    }
+    writeFileSync(this.filePath, JSON.stringify(this.data, null, 2), "utf-8");
+  }
+
+  private getRunningEntry(): TimeEntry | undefined {
+    return this.data.entries.find((e) => e.stop === null);
+  }
+
+  start(task: string): TimeEntry {
+    if (!task || task.trim().length === 0) {
+      throw new Error("Task name cannot be empty");
+    }
+
+    // Auto-stop any running timer
+    const running = this.getRunningEntry();
+    if (running) {
+      running.stop = new Date().toISOString();
+    }
+
+    const entry: TimeEntry = {
+      task,
+      start: new Date().toISOString(),
+      stop: null,
+    };
+
+    this.data.entries.push(entry);
+    this.save();
+    return entry;
+  }
+
+  stop(): TimeEntry {
+    const running = this.getRunningEntry();
+    if (!running) {
+      throw new Error("No timer is currently running");
+    }
+
+    running.stop = new Date().toISOString();
+    this.save();
+    return running;
+  }
+
+  getEntries(from?: Date, to?: Date): TimeEntry[] {
+    return this.data.entries.filter((entry) => {
+      const start = new Date(entry.start);
+      if (from && start < from) return false;
+      if (to && start > to) return false;
+      return true;
+    });
+  }
+
+  getSummary(from?: Date, to?: Date): Record<string, number> {
+    const entries = this.getEntries(from, to);
+    const summary: Record<string, number> = {};
+
+    for (const entry of entries) {
+      const startMs = new Date(entry.start).getTime();
+      const stopMs = entry.stop
+        ? new Date(entry.stop).getTime()
+        : Date.now();
+      const duration = stopMs - startMs;
+
+      if (summary[entry.task] === undefined) {
+        summary[entry.task] = 0;
+      }
+      summary[entry.task] += duration;
+    }
+
+    return summary;
+  }
+
+  isRunning(): boolean {
+    return this.getRunningEntry() !== undefined;
+  }
+
+  currentTask(): string | null {
+    const running = this.getRunningEntry();
+    return running ? running.task : null;
+  }
+}
