@@ -0,0 +1,136 @@
+import { readFileSync, writeFileSync, mkdirSync } from "node:fs";
+import { dirname } from "node:path";
+
+export interface TimeEntry {
+  task: string;
+  start: string; // ISO 8601
+  stop: string | null; // ISO 8601, null if still running
+}
+
+export interface TimeTrackerOptions {
+  filePath: string;
+}
+
+export class TimeTracker {
+  private readonly filePath: string;
+  private entries: TimeEntry[];
+
+  constructor(options: TimeTrackerOptions) {
+    this.filePath = options.filePath;
+    this.entries = this.load();
+  }
+
+  /**
+   * Start a new timer. If one is already running, stop it first.
+   */
+  start(task: string): void {
+    if (!task || task.trim().length === 0) {
+      throw new Error("Task name must not be empty");
+    }
+
+    // Auto-stop any running timer
+    const running = this.getRunningEntry();
+    if (running) {
+      running.stop = new Date().toISOString();
+    }
+
+    this.entries.push({
+      task,
+      start: new Date().toISOString(),
+      stop: null,
+    });
+
+    this.save();
+  }
+
+  /**
+   * Stop the currently running timer.
+   */
+  stop(): TimeEntry {
+    const running = this.getRunningEntry();
+    if (!running) {
+      throw new Error("No timer is currently running");
+    }
+
+    running.stop = new Date().toISOString();
+    this.save();
+    return { ...running };
+  }
+
+  /**
+   * Get the currently running entry, or null if none.
+   */
+  getRunning(): TimeEntry | null {
+    const running = this.getRunningEntry();
+    return running ? { ...running } : null;
+  }
+
+  /**
+   * Get all entries, optionally filtered by a date range.
+   * Both `from` and `to` are inclusive boundaries compared against the entry start time.
+   */
+  getEntries(filter?: { from?: Date; to?: Date }): TimeEntry[] {
+    let result = this.entries;
+
+    if (filter) {
+      result = result.filter((entry) => {
+        const entryStart = new Date(entry.start).getTime();
+        if (filter.from && entryStart < filter.from.getTime()) {
+          return false;
+        }
+        if (filter.to && entryStart > filter.to.getTime()) {
+          return false;
+        }
+        return true;
+      });
+    }
+
+    return result.map((e) => ({ ...e }));
+  }
+
+  /**
+   * Get a summary of total time (in ms) per task name.
+   * Running tasks use the current time for their duration.
+   */
+  getSummary(): Record<string, number> {
+    const summary: Record<string, number> = {};
+
+    for (const entry of this.entries) {
+      const startMs = new Date(entry.start).getTime();
+      const stopMs = entry.stop
+        ? new Date(entry.stop).getTime()
+        : Date.now();
+      const duration = stopMs - startMs;
+
+      if (summary[entry.task] === undefined) {
+        summary[entry.task] = 0;
+      }
+      summary[entry.task] += duration;
+    }
+
+    return summary;
+  }
+
+  private getRunningEntry(): TimeEntry | undefined {
+    return this.entries.find((e) => e.stop === null);
+  }
+
+  private load(): TimeEntry[] {
+    try {
+      const data = readFileSync(this.filePath, "utf-8");
+      const parsed: unknown = JSON.parse(data);
+      if (!Array.isArray(parsed)) {
+        return [];
+      }
+      return parsed as TimeEntry[];
+    } catch {
+      return [];
+    }
+  }
+
+  private save(): void {
+    const dir = dirname(this.filePath);
+    mkdirSync(dir, { recursive: true });
+    writeFileSync(this.filePath, JSON.stringify(this.entries, null, 2), "utf-8");
+  }
+}
