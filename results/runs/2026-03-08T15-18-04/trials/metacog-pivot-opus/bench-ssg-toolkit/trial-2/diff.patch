@@ -0,0 +1,136 @@
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+function processAdmonitions(content: string): string {
+  return content.replace(/^:::(note|warning|tip)\n([\s\S]*?)^:::/gm, (_match, type: string, body: string) => {
+    const trimmed = body.trim();
+    return `<div class="admonition admonition-${type}">\n<p>${trimmed}</p>\n</div>`;
+  });
+}
+
+function processFootnotes(content: string): { content: string; footnotes: Map<string, string> } {
+  const footnotes = new Map<string, string>();
+
+  // Extract footnote definitions
+  const withoutDefs = content.replace(/^\[\^(\d+)\]:\s*(.+)$/gm, (_match, id: string, text: string) => {
+    footnotes.set(id, text);
+    return '';
+  });
+
+  // Replace footnote references with links
+  const withRefs = withoutDefs.replace(/\[\^(\d+)\]/g, (_match, id: string) => {
+    return `<sup><a href="#fn-${id}">${id}</a></sup>`;
+  });
+
+  return { content: withRefs, footnotes };
+}
+
+function renderFootnoteSection(footnotes: Map<string, string>): string {
+  if (footnotes.size === 0) return '';
+  const items = Array.from(footnotes.entries())
+    .map(([id, text]) => `<li id="fn-${id}">${text}</li>`)
+    .join('\n');
+  return `\n<section class="footnotes">\n<ol>\n${items}\n</ol>\n</section>`;
+}
+
+function markdownToHtml(text: string): string {
+  let html = text;
+
+  // Process headings (must be done before other inline processing)
+  html = html.replace(/^######\s+(.+)$/gm, '<h6>$1</h6>');
+  html = html.replace(/^#####\s+(.+)$/gm, '<h5>$1</h5>');
+  html = html.replace(/^####\s+(.+)$/gm, '<h4>$1</h4>');
+  html = html.replace(/^###\s+(.+)$/gm, '<h3>$1</h3>');
+  html = html.replace(/^##\s+(.+)$/gm, '<h2>$1</h2>');
+  html = html.replace(/^#\s+(.+)$/gm, '<h1>$1</h1>');
+
+  // Process code blocks (fenced)
+  html = html.replace(/```(\w*)\n([\s\S]*?)```/gm, (_match, lang: string, code: string) => {
+    const trimmedCode = code.trimEnd();
+    if (lang) {
+      return `<pre><code class="language-${lang}">${trimmedCode}</code></pre>`;
+    }
+    return `<pre><code>${trimmedCode}</code></pre>`;
+  });
+
+  // Process inline code
+  html = html.replace(/`([^`]+)`/g, '<code>$1</code>');
+
+  // Process bold and italic
+  html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
+  html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');
+
+  // Process links
+  html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>');
+
+  // Process images
+  html = html.replace(/!\[([^\]]*)\]\(([^)]+)\)/g, '<img src="$2" alt="$1">');
+
+  // Process paragraphs: wrap non-block lines in <p> tags
+  const lines = html.split('\n');
+  const result: string[] = [];
+  let i = 0;
+  while (i < lines.length) {
+    const line = lines[i];
+    const trimmed = line.trim();
+
+    if (trimmed === '') {
+      i++;
+      continue;
+    }
+
+    // Skip lines that already start with block-level HTML
+    if (/^<(?:h[1-6]|p|div|pre|ul|ol|li|blockquote|section|table|hr|br|img)/i.test(trimmed) ||
+        /^<\//.test(trimmed)) {
+      result.push(line);
+      i++;
+      continue;
+    }
+
+    // Wrap plain text lines in paragraphs
+    if (!/^</.test(trimmed)) {
+      result.push(`<p>${trimmed}</p>`);
+    } else {
+      result.push(line);
+    }
+    i++;
+  }
+
+  return result.join('\n');
+}
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file: ContentFile, _ctx: BuildContext): ContentFile {
+        let content = file.content;
+
+        // If content is already HTML (starts with <), return as-is
+        if (content.trim().startsWith('<')) {
+          return { ...file, content };
+        }
+
+        if (content.trim() === '') {
+          return { ...file, content: '' };
+        }
+
+        // Process admonitions before markdown
+        content = processAdmonitions(content);
+
+        // Process footnotes
+        const { content: withFootnoteRefs, footnotes } = processFootnotes(content);
+        content = withFootnoteRefs;
+
+        // Convert markdown to HTML
+        content = markdownToHtml(content);
+
+        // Append footnote section
+        content += renderFootnoteSection(footnotes);
+
+        return { ...file, content };
+      },
+    },
+  };
+}
