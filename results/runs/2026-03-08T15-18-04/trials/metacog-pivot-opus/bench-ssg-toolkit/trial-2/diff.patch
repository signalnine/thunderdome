gine(testConfig);\n   189→    engine.registerTemplate(createDefaultTemplate());\n   190→    const ctx = await engine.build([]);\n   191→    expect(ctx.output.size).toBe(0);\n   192→    expect(ctx.files).toHaveLength(0);\n   193→  });\n   194→});\n   195→"}]},"parent_tool_use_id":"toolu_01V957F7EjAyb9YqxBJEthCz","session_id":"f1e856c9-9281-4990-8836-3f0927847925","uuid":"ed4601ce-6126-4462-a128-fb551685678b"}
