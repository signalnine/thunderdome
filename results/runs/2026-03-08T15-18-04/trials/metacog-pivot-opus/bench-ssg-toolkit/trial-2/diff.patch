keFile({ content: 'start' })]);\n    expect(ctx.files[0].content).toBe('start [first] [second]');\n  });\n\n  it('provides shared data store in build context', async () => {\n    const engine = new BuildEngine(testConfig);\n    engine.registerPlugin(makePlugin({\n      hooks: {\n        beforeBuild: (ctx) => { ctx.data.set('key', 'value'); },\n      },\n    }));\n    const ctx = await engine.build([]);\n    expect(ctx.data.get('key')).toBe('value');\n  });\n\n  it('retains file metadata through build', async () => {\n    const engine = new BuildEngine(testConfig);\n    const file = makeFile({\n      metadata: { author: 'Alice', category: 'tech' },\n      date: '2024-01-01',\n      tags: ['js', 'node'],\n    });\n    const ctx = await engine.build([file]);\n    expect(ctx.files[0].metadata).toEqual({ author: 'Alice', category: 'tech' });\n    expect(ctx.files[0].date).toBe('2024-01-01');\n    expect(ctx.files[0].tags).toEqual(['js', 'node']);\n  });\n\n  it('produces empty output for empty file list', async () => {\n    const engine = new BuildEngine(testConfig);\n    engine.registerTemplate(createDefaultTemplate());\n    const ctx = await engine.build([]);\n    expect(ctx.output.size).toBe(0);\n    expect(ctx.files).toHaveLength(0);\n  });\n});\n```\n\n---\n\n## 8. PLUGIN TEST FILES\n\n### /workspace/tests/plugins/taxonomy.test.ts\n\n```typescript\nimport { describe, it, expect } from 'vitest';\nimport { createTaxonomyPlugin } from '../../src/plugins/taxonomy.js';\nimport { BuildContext, ContentFile, SiteConfig } from '../../src/core/types.js';\n\nconst testConfig: SiteConfig = {\n  title: 'Test Site',\n  baseUrl: 'https://example.com',\n  outputDir: './dist',\n  contentDir: './content',\n  templateDir: './templates',\n};\n\nfunction makeCtx(files: ContentFile[] = []): BuildContext {\n  return {\n    config: testConfig,\n    files,\n    output: new Map(),\n    assets: new Map(),\n    data: new Map(),\n  };\n}\n\nfunction makeFile(overrides: Partial<ContentFile> = {}): ContentFile {\n  return {\n    slug: 'test',\n    title: 'Test',\n    content: '<p>content</p>',\n    metadata: {},\n    ...overrides,\n  };\n}\n\ndescribe('taxonomy plugin', () => {\n  const plugin = createTaxonomyPlugin();\n\n  it('builds tag index from file tags', async () => {\n    const files = [\n      makeFile({ slug: 'post-1', title: 'Post 1', tags: ['javascript', 'node'] }),\n      makeFile({ slug: 'post-2', title: 'Post 2', tags: ['javascript'] }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.beforeBuild!(ctx);\n    const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]>;\n    expect(tagMap).toBeDefined();\n    expect(tagMap.get('javascript')).toHaveLength(2);\n    expect(tagMap.get('node')).toHaveLength(1);\n  });\n\n  it('generates tag listing pages in ctx.output', async () => {\n    const files = [\n      makeFile({ slug: 'post-1', title: 'Post 1', tags: ['javascript'] }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.beforeBuild!(ctx);\n    await plugin.hooks.afterBuild!(ctx);\n    expect(ctx.output.has('tags/javascript.html')).toBe(true);\n    expect(ctx.output.get('tags/javascript.html')).toContain('Post 1');\n  });\n\n  it('handles files with no tags', async () => {\n    const files = [\n      makeFile({ slug: 'post-1', title: 'Post 1' }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.beforeBuild!(ctx);\n    const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]>;\n    expect(tagMap.size).toBe(0);\n  });\n\n  it('handles files with multiple tags', async () => {\n    const files = [\n      makeFile({ slug: 'post-1', title: 'Post 1', tags: ['js', 'node', 'web'] }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.beforeBuild!(ctx);\n    const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]>;\n    expect(tagMap.size).toBe(3);\n    expect(tagMap.has('js')).toBe(true);\n    expect(tagMap.has('node')).toBe(true);\n    expect(tagMap.has('web')).toBe(true);\n  });\n\n  it('tag pages list all files with that tag', async () => {\n    const files = [\n      makeFile({ slug: 'post-1', title: 'First Post', tags: ['tech'] }),\n      makeFile({ slug: 'post-2', title: 'Second Post', tags: ['tech'] }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.beforeBuild!(ctx);\n    await plugin.hooks.afterBuild!(ctx);\n    const tagPage = ctx.output.get('tags/tech.html')!;\n    expect(tagPage).toContain('First Post');\n    expect(tagPage).toContain('Second Post');\n  });\n\n  it('stores tag map in ctx.data', async () => {\n    const files = [\n      makeFile({ slug: 'post-1', title: 'Post 1', tags: ['alpha'] }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.beforeBuild!(ctx);\n    expect(ctx.data.has('taxonomy-tags')).toBe(true);\n  });\n\n  it('handles empty file list', async () => {\n    const ctx = makeCtx([]);\n    await plugin.hooks.beforeBuild!(ctx);\n    await plugin.hooks.afterBuild!(ctx);\n    const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]>;\n    expect(tagMap.size).toBe(0);\n  });\n\n  it('tags are case-normalized to lowercase', async () => {\n    const files = [\n      makeFile({ slug: 'post-1', title: 'Post 1', tags: ['JavaScript'] }),\n      makeFile({ slug: 'post-2', title: 'Post 2', tags: ['JAVASCRIPT'] }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.beforeBuild!(ctx);\n    const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]>;\n    expect(tagMap.has('javascript')).toBe(true);\n    expect(tagMap.get('javascript')).toHaveLength(2);\n    expect(tagMap.has('JavaScript')).toBe(false);\n    expect(tagMap.has('JAVASCRIPT')).toBe(false);\n  });\n});\n```\n\n### /workspace/tests/plugins/markdown-ext.test.ts\n\n```typescript\nimport { describe, it, expect } from 'vitest';\nimport { createMarkdownExtPlugin } from '../../src/plugins/markdown-ext.js';\nimport { BuildContext, ContentFile, SiteConfig } from '../../src/core/types.js';\n\nconst testConfig: SiteConfig = {\n  title: 'Test Site',\n  baseUrl: 'https://example.com',\n  outputDir: './dist',\n  contentDir: './content',\n  templateDir: './templates',\n};\n\nfunction makeCtx(): BuildContext {\n  return {\n    config: testConfig,\n    files: [],\n    output: new Map(),\n    assets: new Map(),\n    data: new Map(),\n  };\n}\n\nfunction makeFile(overrides: Partial<ContentFile> = {}): ContentFile {\n  return {\n    slug: 'test',\n    title: 'Test',\n    content: '',\n    metadata: {},\n    ...overrides,\n  };\n}\n\ndescribe('markdown-ext plugin', () => {\n  const plugin = createMarkdownExtPlugin();\n\n  it('converts basic markdown to HTML', async () => {\n    const file = makeFile({ content: '# Hello\\n\\nThis is a **bold** paragraph.' });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('<h1>');\n    expect(result.content).toContain('Hello');\n    expect(result.content).toContain('<strong>bold</strong>');\n  });\n\n  it('handles footnotes with [^1] syntax', async () => {\n    const file = makeFile({ content: 'Some text[^1] here.\\n\\n[^1]: This is the footnote.' });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('<sup><a href=\"#fn-1\">1</a></sup>');\n  });\n\n  it('renders footnote section at bottom of content', async () => {\n    const file = makeFile({ content: 'Text[^1] and more[^2].\\n\\n[^1]: First note.\\n[^2]: Second note.' });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('<section class=\"footnotes\">');\n    expect(result.content).toContain('<li id=\"fn-1\">First note.</li>');\n    expect(result.content).toContain('<li id=\"fn-2\">Second note.</li>');\n  });\n\n  it('converts :::note container to admonition div', async () => {\n    const file = makeFile({ content: ':::note\\nThis is a note.\\n:::' });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('<div class=\"admonition admonition-note\">');\n    expect(result.content).toContain('This is a note.');\n  });\n\n  it('converts :::warning container to admonition div', async () => {\n    const file = makeFile({ content: ':::warning\\nBe careful!\\n:::' });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('<div class=\"admonition admonition-warning\">');\n    expect(result.content).toContain('Be careful!');\n  });\n\n  it('converts :::tip container to admonition div', async () => {\n    const file = makeFile({ content: ':::tip\\nHelpful hint.\\n:::' });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('<div class=\"admonition admonition-tip\">');\n    expect(result.content).toContain('Helpful hint.');\n  });\n\n  it('preserves existing HTML in content', async () => {\n    const file = makeFile({ content: '<div class=\"custom\">Already HTML</div>' });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('Already HTML');\n  });\n\n  it('handles empty content', async () => {\n    const file = makeFile({ content: '' });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toBeDefined();\n  });\n});\n```\n\n### /workspace/tests/plugins/sitemap.test.ts\n\n```typescript\nimport { describe, it, expect } from 'vitest';\nimport { createSitemapPlugin } from '../../src/plugins/sitemap.js';\nimport { BuildContext, ContentFile, SiteConfig } from '../../src/core/types.js';\n\nconst testConfig: SiteConfig = {\n  title: 'Test Site',\n  baseUrl: 'https://example.com',\n  outputDir: './dist',\n  contentDir: './content',\n  templateDir: './templates',\n};\n\nfunction makeCtx(\n  output?: Map<string, string>,\n  data?: Map<string, unknown>\n): BuildContext {\n  return {\n    config: testConfig,\n    files: [],\n    output: output || new Map(),\n    assets: new Map(),\n    data: data || new Map(),\n  };\n}\n\ndescribe('sitemap plugin', () => {\n  const plugin = createSitemapPlugin();\n\n  it('generates sitemap.xml in ctx.output', async () => {\n    const output = new Map<string, string>();\n    output.set('post-1.html', '<html></html>');\n    const ctx = makeCtx(output);\n    await plugin.hooks.afterBuild!(ctx);\n    expect(ctx.output.has('sitemap.xml')).toBe(true);\n  });\n\n  it('includes all content page URLs', async () => {\n    const output = new Map<string, string>();\n    output.set('post-1.html', '<html></html>');\n    output.set('post-2.html', '<html></html>');\n    const ctx = makeCtx(output);\n    await plugin.hooks.afterBuild!(ctx);\n    const sitemap = ctx.output.get('sitemap.xml')!;\n    expect(sitemap).toContain('https://example.com/post-1.html');\n    expect(sitemap).toContain('https://example.com/post-2.html');\n  });\n\n  it('includes taxonomy tag page URLs', async () => {\n    const output = new Map<string, string>();\n    output.set('tags/javascript.html', '<html>js tag page</html>');\n    const tagMap = new Map<string, ContentFile[]>();\n    tagMap.set('javascript', []);\n    const data = new Map<string, unknown>();\n    data.set('taxonomy-tags', tagMap);\n    const ctx = makeCtx(output, data);\n    await plugin.hooks.afterBuild!(ctx);\n    const sitemap = ctx.output.get('sitemap.xml')!;\n    expect(sitemap).toContain('https://example.com/tags/javascript.html');\n  });\n\n  it('includes feed.xml URL', async () => {\n    const output = new Map<string, string>();\n    output.set('feed.xml', '<rss></rss>');\n    const ctx = makeCtx(output);\n    await plugin.hooks.afterBuild!(ctx);\n    const sitemap = ctx.output.get('sitemap.xml')!;\n    expect(sitemap).toContain('https://example.com/feed.xml');\n  });\n\n  it('URLs use baseUrl from config', async () => {\n    const output = new Map<string, string>();\n    output.set('about.html', '<html></html>');\n    const ctx = makeCtx(output);\n    await plugin.hooks.afterBuild!(ctx);\n    const sitemap = ctx.output.get('sitemap.xml')!;\n    expect(sitemap).toContain('https://example.com/about.html');\n  });\n\n  it('sitemap is valid XML structure', async () => {\n    const output = new Map<string, string>();\n    output.set('post.html', '<html></html>');\n    const ctx = makeCtx(output);\n    await plugin.hooks.afterBuild!(ctx);\n    const sitemap = ctx.output.get('sitemap.xml')!;\n    expect(sitemap).toContain('<?xml version=\"1.0\"');\n    expect(sitemap).toContain('<urlset');\n    expect(sitemap).toContain('</urlset>');\n    expect(sitemap).toContain('<url>');\n    expect(sitemap).toContain('<loc>');\n  });\n\n  it('handles site with no tag pages', async () => {\n    const output = new Map<string, string>();\n    output.set('post.html', '<html></html>');\n    const ctx = makeCtx(output);\n    await plugin.hooks.afterBuild!(ctx);\n    const sitemap = ctx.output.get('sitemap.xml')!;\n    expect(sitemap).toContain('https://example.com/post.html');\n    expect(sitemap).not.toContain('/tags/');\n  });\n});\n```\n\n### /workspace/tests/plugins/rss-feed.test.ts\n\n```typescript\nimport { describe, it, expect } from 'vitest';\nimport { createRssFeedPlugin } from '../../src/plugins/rss-feed.js';\nimport { BuildContext, ContentFile, SiteConfig } from '../../src/core/types.js';\n\nconst testConfig: SiteConfig = {\n  title: 'Test Site',\n  baseUrl: 'https://example.com',\n  outputDir: './dist',\n  contentDir: './content',\n  templateDir: './templates',\n};\n\nfunction makeCtx(files: ContentFile[] = [], data?: Map<string, unknown>): BuildContext {\n  return {\n    config: testConfig,\n    files,\n    output: new Map(),\n    assets: new Map(),\n    data: data || new Map(),\n  };\n}\n\nfunction makeFile(overrides: Partial<ContentFile> = {}): ContentFile {\n  return {\n    slug: 'test',\n    title: 'Test',\n    content: '<p>HTML content</p>',\n    metadata: {},\n    ...overrides,\n  };\n}\n\ndescribe('rss-feed plugin', () => {\n  const plugin = createRssFeedPlugin();\n\n  it('generates valid RSS 2.0 XML', async () => {\n    const files = [makeFile({ slug: 'post-1', title: 'Post 1', date: '2024-01-01' })];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const feed = ctx.output.get('feed.xml')!;\n    expect(feed).toContain('<?xml version=\"1.0\"');\n    expect(feed).toContain('<rss version=\"2.0\">');\n    expect(feed).toContain('<channel>');\n    expect(feed).toContain('<item>');\n    expect(feed).toContain('</rss>');\n  });\n\n  it('feed items contain HTML content not raw markdown', async () => {\n    const files = [\n      makeFile({\n        slug: 'post-1',\n        title: 'Post 1',\n        content: '<p>This is <strong>HTML</strong> content</p>',\n        date: '2024-01-01',\n      }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const feed = ctx.output.get('feed.xml')!;\n    expect(feed).toContain('<![CDATA[<p>This is <strong>HTML</strong> content</p>]]>');\n  });\n\n  it('feed items include category tags from taxonomy', async () => {\n    const files = [\n      makeFile({ slug: 'post-1', title: 'Post 1', tags: ['javascript'], date: '2024-01-01' }),\n    ];\n    const tagMap = new Map<string, ContentFile[]>();\n    tagMap.set('javascript', [files[0]]);\n    const data = new Map<string, unknown>();\n    data.set('taxonomy-tags', tagMap);\n    const ctx = makeCtx(files, data);\n    await plugin.hooks.afterBuild!(ctx);\n    const feed = ctx.output.get('feed.xml')!;\n    expect(feed).toContain('<category>javascript</category>');\n  });\n\n  it('feed includes channel title from config', async () => {\n    const files = [makeFile({ slug: 'post-1', title: 'Post 1' })];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const feed = ctx.output.get('feed.xml')!;\n    expect(feed).toContain('<title>Test Site</title>');\n  });\n\n  it('feed items sorted by date newest first', async () => {\n    const files = [\n      makeFile({ slug: 'old', title: 'Old Post', date: '2023-01-01' }),\n      makeFile({ slug: 'new', title: 'New Post', date: '2024-06-15' }),\n      makeFile({ slug: 'mid', title: 'Mid Post', date: '2024-01-01' }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const feed = ctx.output.get('feed.xml')!;\n    const newIdx = feed.indexOf('New Post');\n    const midIdx = feed.indexOf('Mid Post');\n    const oldIdx = feed.indexOf('Old Post');\n    expect(newIdx).toBeLessThan(midIdx);\n    expect(midIdx).toBeLessThan(oldIdx);\n  });\n\n  it('handles files without dates', async () => {\n    const files = [\n      makeFile({ slug: 'no-date', title: 'No Date Post', content: '<p>No date</p>' }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const feed = ctx.output.get('feed.xml')!;\n    expect(feed).toContain('No Date Post');\n    expect(feed).not.toContain('<pubDate>undefined</pubDate>');\n  });\n\n  it('feed link uses baseUrl from config', async () => {\n    const files = [makeFile({ slug: 'post-1', title: 'Post 1' })];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const feed = ctx.output.get('feed.xml')!;\n    expect(feed).toContain('<link>https://example.com</link>');\n    expect(feed).toContain('<link>https://example.com/post-1.html</link>');\n  });\n});\n```\n\n### /workspace/tests/plugins/asset-pipeline.test.ts\n\n```typescript\nimport { describe, it, expect } from 'vitest';\nimport { createAssetPipelinePlugin } from '../../src/plugins/asset-pipeline.js';\nimport { BuildContext, ContentFile, SiteConfig } from '../../src/core/types.js';\n\nconst testConfig: SiteConfig = {\n  title: 'Test Site',\n  baseUrl: 'https://example.com',\n  outputDir: './dist',\n  contentDir: './content',\n  templateDir: './templates',\n};\n\nfunction makeCtx(): BuildContext {\n  return {\n    config: testConfig,\n    files: [],\n    output: new Map(),\n    assets: new Map(),\n    data: new Map(),\n  };\n}\n\nfunction makeFile(overrides: Partial<ContentFile> = {}): ContentFile {\n  return {\n    slug: 'test',\n    title: 'Test',\n    content: '',\n    metadata: {},\n    ...overrides,\n  };\n}\n\ndescribe('asset-pipeline plugin', () => {\n  const plugin = createAssetPipelinePlugin();\n\n  it('rewrites relative image URLs to /assets/ path', async () => {\n    const file = makeFile({ content: '<img src=\"./image.png\" alt=\"test\">' });\n    const ctx = makeCtx();\n    const result = await plugin.hooks.transformContent!(file, ctx);\n    expect(result.content).toContain('src=\"/assets/image.png\"');\n    expect(result.content).not.toContain('src=\"./image.png\"');\n  });\n\n  it('rewrites relative link URLs to /assets/ path', async () => {\n    const file = makeFile({ content: '<a href=\"./doc.pdf\">Download</a>' });\n    const ctx = makeCtx();\n    const result = await plugin.hooks.transformContent!(file, ctx);\n    expect(result.content).toContain('href=\"/assets/doc.pdf\"');\n    expect(result.content).not.toContain('href=\"./doc.pdf\"');\n  });\n\n  it('leaves absolute URLs unchanged', async () => {\n    const file = makeFile({ content: '<img src=\"https://cdn.example.com/image.png\">' });\n    const ctx = makeCtx();\n    const result = await plugin.hooks.transformContent!(file, ctx);\n    expect(result.content).toContain('src=\"https://cdn.example.com/image.png\"');\n  });\n\n  it('generates asset manifest in ctx.data', async () => {\n    const file = makeFile({ content: '<img src=\"./photo.jpg\">' });\n    const ctx = makeCtx();\n    await plugin.hooks.transformContent!(file, ctx);\n    const manifest = ctx.data.get('asset-manifest') as { assets: string[] };\n    expect(manifest).toBeDefined();\n    expect(manifest.assets).toContain('photo.jpg');\n  });\n\n  it('handles files with no asset references', async () => {\n    const file = makeFile({ content: '<p>No assets here</p>' });\n    const ctx = makeCtx();\n    const result = await plugin.hooks.transformContent!(file, ctx);\n    expect(result.content).toBe('<p>No assets here</p>');\n  });\n\n  it('handles multiple assets in one file', async () => {\n    const file = makeFile({\n      content: '<img src=\"./a.png\"><img src=\"./b.jpg\"><a href=\"./c.pdf\">link</a>',\n    });\n    const ctx = makeCtx();\n    await plugin.hooks.transformContent!(file, ctx);\n    const manifest = ctx.data.get('asset-manifest') as { assets: string[] };\n    expect(manifest.assets).toContain('a.png');\n    expect(manifest.assets).toContain('b.jpg');\n    expect(manifest.assets).toContain('c.pdf');\n  });\n\n  it('asset manifest includes all discovered assets', async () => {\n    const ctx = makeCtx();\n    const file1 = makeFile({ content: '<img src=\"./one.png\">' });\n    const file2 = makeFile({ content: '<img src=\"./two.png\">' });\n    await plugin.hooks.transformContent!(file1, ctx);\n    await plugin.hooks.transformContent!(file2, ctx);\n    const manifest = ctx.data.get('asset-manifest') as { assets: string[] };\n    expect(manifest.assets).toHaveLength(2);\n    expect(manifest.assets).toContain('one.png');\n    expect(manifest.assets).toContain('two.png');\n  });\n\n  it('does not double-process already-rewritten URLs', async () => {\n    const file = makeFile({ content: '<img src=\"/assets/image.png\">' });\n    const ctx = makeCtx();\n    const result = await plugin.hooks.transformContent!(file, ctx);\n    expect(result.content).toBe('<img src=\"/assets/image.png\">');\n    const manifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;\n    expect(!manifest || manifest.assets.length === 0).toBe(true);\n  });\n});\n```\n\n### /workspace/tests/plugins/syntax-highlight.test.ts\n\n```typescript\nimport { describe, it, expect } from 'vitest';\nimport { createSyntaxHighlightPlugin } from '../../src/plugins/syntax-highlight.js';\nimport { BuildContext, ContentFile, SiteConfig } from '../../src/core/types.js';\n\nconst testConfig: SiteConfig = {\n  title: 'Test Site',\n  baseUrl: 'https://example.com',\n  outputDir: './dist',\n  contentDir: './content',\n  templateDir: './templates',\n};\n\nfunction makeCtx(): BuildContext {\n  return {\n    config: testConfig,\n    files: [],\n    output: new Map(),\n    assets: new Map(),\n    data: new Map(),\n  };\n}\n\nfunction makeFile(overrides: Partial<ContentFile> = {}): ContentFile {\n  return {\n    slug: 'test',\n    title: 'Test',\n    content: '',\n    metadata: {},\n    ...overrides,\n  };\n}\n\ndescribe('syntax-highlight plugin', () => {\n  const plugin = createSyntaxHighlightPlugin();\n\n  it('adds language class to code blocks', async () => {\n    const file = makeFile({\n      content: '<pre><code class=\"language-javascript\">const x = 1;</code></pre>',\n    });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('class=\"language-javascript highlighted\"');\n  });\n\n  it('adds data-language attribute to pre tags', async () => {\n    const file = makeFile({\n      content: '<pre><code class=\"language-python\">print(\"hi\")</code></pre>',\n    });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('data-language=\"python\"');\n  });\n\n  it('handles multiple code blocks in one file', async () => {\n    const file = makeFile({\n      content:\n        '<pre><code class=\"language-js\">let a = 1;</code></pre>' +\n        '<p>Some text</p>' +\n        '<pre><code class=\"language-py\">x = 2</code></pre>',\n    });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('data-language=\"js\"');\n    expect(result.content).toContain('data-language=\"py\"');\n  });\n\n  it('handles code block with no language specified', async () => {\n    const file = makeFile({\n      content: '<pre><code>plain code</code></pre>',\n    });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    // Should not add highlighted class or data-language to blocks without language\n    expect(result.content).toBe('<pre><code>plain code</code></pre>');\n    expect(result.content).not.toContain('highlighted');\n  });\n\n  it('adds highlighted class to processed blocks', async () => {\n    const file = makeFile({\n      content: '<pre><code class=\"language-rust\">fn main() {}</code></pre>',\n    });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('highlighted');\n  });\n\n  it('preserves code block content', async () => {\n    const file = makeFile({\n      content: '<pre><code class=\"language-ts\">const x: number = 42;</code></pre>',\n    });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('const x: number = 42;');\n  });\n\n  it('handles empty code blocks', async () => {\n    const file = makeFile({\n      content: '<pre><code class=\"language-js\"></code></pre>',\n    });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('data-language=\"js\"');\n    expect(result.content).toContain('highlighted');\n  });\n\n  it('does not modify inline code', async () => {\n    const file = makeFile({\n      content: '<p>Use <code>console.log()</code> for debugging.</p>',\n    });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toBe('<p>Use <code>console.log()</code> for debugging.</p>');\n    expect(result.content).not.toContain('highlighted');\n  });\n});\n```\n\n### /workspace/tests/plugins/search-index.test.ts\n\n```typescript\nimport { describe, it, expect } from 'vitest';\nimport { createSearchIndexPlugin } from '../../src/plugins/search-index.js';\nimport { BuildContext, ContentFile, SiteConfig } from '../../src/core/types.js';\n\nconst testConfig: SiteConfig = {\n  title: 'Test Site',\n  baseUrl: 'https://example.com',\n  outputDir: './dist',\n  contentDir: './content',\n  templateDir: './templates',\n};\n\nfunction makeCtx(files: ContentFile[] = []): BuildContext {\n  return {\n    config: testConfig,\n    files,\n    output: new Map(),\n    assets: new Map(),\n    data: new Map(),\n  };\n}\n\nfunction makeFile(overrides: Partial<ContentFile> = {}): ContentFile {\n  return {\n    slug: 'test',\n    title: 'Test',\n    content: '',\n    metadata: {},\n    ...overrides,\n  };\n}\n\ndescribe('search-index plugin', () => {\n  const plugin = createSearchIndexPlugin();\n\n  it('generates search-index.json in ctx.output', async () => {\n    const files = [makeFile({ slug: 'post-1', title: 'Post 1', content: '<p>Hello</p>' })];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    expect(ctx.output.has('search-index.json')).toBe(true);\n  });\n\n  it('index entries have title, slug, and plain text content', async () => {\n    const files = [makeFile({ slug: 'my-post', title: 'My Post', content: '<p>Some text here</p>' })];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const index = JSON.parse(ctx.output.get('search-index.json')!);\n    expect(index[0].slug).toBe('my-post');\n    expect(index[0].title).toBe('My Post');\n    expect(index[0].content).toBe('Some text here');\n  });\n\n  it('HTML tags stripped from indexed content', async () => {\n    const files = [\n      makeFile({\n        slug: 'post',\n        title: 'Post',\n        content: '<h1>Title</h1><p>This is <strong>bold</strong> text.</p>',\n      }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const index = JSON.parse(ctx.output.get('search-index.json')!);\n    expect(index[0].content).not.toContain('<');\n    expect(index[0].content).not.toContain('>');\n    expect(index[0].content).toContain('bold');\n    expect(index[0].content).toContain('text');\n  });\n\n  it('code blocks included in searchable text', async () => {\n    const files = [\n      makeFile({\n        slug: 'post',\n        title: 'Code Post',\n        content: '<p>Example:</p><pre><code class=\"language-js\">const x = 1;</code></pre>',\n      }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const index = JSON.parse(ctx.output.get('search-index.json')!);\n    expect(index[0].content).toContain('const x = 1;');\n  });\n\n  it('handles empty file list', async () => {\n    const ctx = makeCtx([]);\n    await plugin.hooks.afterBuild!(ctx);\n    const index = JSON.parse(ctx.output.get('search-index.json')!);\n    expect(index).toEqual([]);\n  });\n\n  it('search index is valid JSON', async () => {\n    const files = [\n      makeFile({ slug: 'post-1', title: 'Post 1', content: '<p>Content</p>' }),\n      makeFile({ slug: 'post-2', title: 'Post 2', content: '<p>More</p>' }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const raw = ctx.output.get('search-index.json')!;\n    expect(() => JSON.parse(raw)).not.toThrow();\n    const index = JSON.parse(raw);\n    expect(Array.isArray(index)).toBe(true);\n    expect(index).toHaveLength(2);\n  });\n\n  it('index entries include tags if present', async () => {\n    const files = [\n      makeFile({ slug: 'post', title: 'Tagged Post', content: '<p>Text</p>', tags: ['js', 'web'] }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const index = JSON.parse(ctx.output.get('search-index.json')!);\n    expect(index[0].tags).toEqual(['js', 'web']);\n  });\n});\n```\n\n### /workspace/tests/plugins/dev-server.test.ts\n\n```typescript\nimport { describe, it, expect } from 'vitest';\nimport { createDevServerPlugin } from '../../src/plugins/dev-server.js';\nimport { BuildContext, SiteConfig } from '../../src/core/types.js';\n\nconst testConfig: SiteConfig = {\n  title: 'Test Site',\n  baseUrl: 'https://example.com',\n  outputDir: './dist',\n  contentDir: './content',\n  templateDir: './templates',\n};\n\ninterface DevServerConfig {\n  port: number;\n  routes: Array<{ path: string; handler: string }>;\n  assetPaths: string[];\n  searchIndexPath: string;\n}\n\nfunction makeCtx(\n  output?: Map<string, string>,\n  data?: Map<string, unknown>\n): BuildContext {\n  return {\n    config: testConfig,\n    files: [],\n    output: output || new Map(),\n    assets: new Map(),\n    data: data || new Map(),\n  };\n}\n\ndescribe('dev-server plugin', () => {\n  const plugin = createDevServerPlugin();\n\n  it('stores dev-server-config in ctx.data', async () => {\n    const ctx = makeCtx();\n    await plugin.hooks.afterBuild!(ctx);\n    expect(ctx.data.has('dev-server-config')).toBe(true);\n  });\n\n  it('config includes port setting', async () => {\n    const ctx = makeCtx();\n    await plugin.hooks.afterBuild!(ctx);\n    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    expect(config.port).toBeDefined();\n    expect(typeof config.port).toBe('number');\n  });\n\n  it('config includes asset routes from asset-pipeline', async () => {\n    const data = new Map<string, unknown>();\n    data.set('asset-manifest', { assets: ['image.png', 'style.css'] });\n    const ctx = makeCtx(new Map(), data);\n    await plugin.hooks.afterBuild!(ctx);\n    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    expect(config.assetPaths).toContain('image.png');\n    expect(config.assetPaths).toContain('style.css');\n    const assetRoutes = config.routes.filter(r => r.handler === 'asset');\n    expect(assetRoutes.length).toBeGreaterThanOrEqual(2);\n  });\n\n  it('config includes search index path', async () => {\n    const output = new Map<string, string>();\n    output.set('search-index.json', '[]');\n    const ctx = makeCtx(output);\n    await plugin.hooks.afterBuild!(ctx);\n    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    expect(config.searchIndexPath).toBe('/search-index.json');\n  });\n\n  it('config includes content routes', async () => {\n    const output = new Map<string, string>();\n    output.set('post-1.html', '<html></html>');\n    output.set('post-2.html', '<html></html>');\n    const ctx = makeCtx(output);\n    await plugin.hooks.afterBuild!(ctx);\n    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    const contentRoutes = config.routes.filter(r => r.handler === 'static');\n    expect(contentRoutes.length).toBe(2);\n  });\n\n  it('default port is 3000', async () => {\n    const ctx = makeCtx();\n    await plugin.hooks.afterBuild!(ctx);\n    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    expect(config.port).toBe(3000);\n  });\n\n  it('handles missing asset-pipeline data gracefully', async () => {\n    const ctx = makeCtx();\n    await plugin.hooks.afterBuild!(ctx);\n    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    expect(config.assetPaths).toEqual([]);\n  });\n});\n```\n\n---\n\n## TASK REQUIREMENTS - /workspace/TASK.md\n\n```markdown\n# T9: SSG Toolkit\n\nAdd 8 plugins to an existing Static Site Generator toolkit.\n\n## Starting State\n- `src/core/` contains the build engine, types, and templates (~600 lines)\n- 15 existing tests in `tests/core.test.ts` — these must continue to pass\n- Plugin test files in `tests/plugins/` define the expected behavior\n\n## Requirements\n\nBuild 8 plugins in `src/plugins/`, each implementing the `Plugin` interface from `src/core/types.ts`.\n\n### Wave 1 (no dependencies)\n1. **markdown-ext** — Markdown → HTML with footnotes and admonition containers\n2. **asset-pipeline** — Rewrite asset URLs and generate manifest\n3. **syntax-highlight** — Add language classes to code blocks\n4. **taxonomy** — Build tag/category indices and generate tag pages\n\n### Wave 2 (depend on Wave 1)\n5. **rss-feed** — Generate RSS 2.0 feed (depends: markdown-ext, taxonomy)\n6. **search-index** — Generate search index JSON (depends: markdown-ext, syntax-highlight)\n\n### Wave 3 (depend on Wave 2)\n7. **sitemap** — Generate sitemap XML (depends: taxonomy, rss-feed)\n8. **dev-server** — Generate dev server config (depends: asset-pipeline, search-index)\n\n### Plugin Interface\nEach plugin must export a `createXxxPlugin()` factory function that returns a `Plugin` object.\n\n## Validation\n- `npm test` — all tests must pass (15 existing + 60 new)\n- `npm run build` — must compile\n- `npm run lint` — must be clean\n```\n\n---\n\n## SUMMARY\n\nYou have a Static Site Generator (SSG) toolkit with:\n\n1. **Core Engine** (`/workspace/src/core/engine.ts`): A BuildEngine class that:\n   - Registers plugins and templates\n   - Resolves plugin execution order using topological sort (handles DAG dependencies)\n   - Executes plugins in phases: beforeBuild → transformContent → afterBuild\n   - Renders content through templates\n   - Maintains a shared BuildContext with config, files, output, assets, and data store\n\n2. **Type System** (`/workspace/src/core/types.ts`): Complete interfaces for:\n   - SiteConfig: site metadata and paths\n   - ContentFile: blog posts/pages with slug, title, content, metadata, date, tags\n   - BuildContext: shared state between all plugins\n   - Plugin interface with hooks (beforeBuild, transformContent, afterBuild)\n   - Template interface for rendering\n\n3. **Templates** (`/workspace/src/core/templates.ts`): Two default templates (default article and list)\n\n4. **Tests**: 15 core engine tests + 60 plugin tests (8 test files × 7-8 tests each) all expecting specific plugin behavior\n\n5. **Plugin Requirements**: Build 8 plugins with dependencies:\n   - **Wave 1** (no deps): markdown-ext, asset-pipeline, syntax-highlight, taxonomy\n   - **Wave 2** (deps on Wave 1): rss-feed, search-index\n   - **Wave 3** (deps on Wave 2): sitemap, dev-server\n\nAll plugins must be created in `/workspace/src/plugins/` and export factory functions like `createTaxonomyPlugin()`, `createMarkdownExtPlugin()`, etc."}],"totalDurationMs":97628,"totalTokens":49886,"totalToolUseCount":25,"usage":{"input_tokens":0,"cache_creation_input_tokens":692,"cache_read_input_tokens":33794,"output_tokens":15400,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":692,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[]}}}
