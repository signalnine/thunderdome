= [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 0, b: 0 }).c).toBe(0);\n    expect(simulate(gates, { a: 1, b: 0 }).c).toBe(1);\n    expect(simulate(gates, { a: 0, b: 1 }).c).toBe(1);\n    expect(simulate(gates, { a: 1, b: 1 }).c).toBe(1);\n  });\n\n  it('should evaluate a single XOR gate', () => {\n    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 0, b: 0 }).c).toBe(0);\n    expect(simulate(gates, { a: 1, b: 0 }).c).toBe(1);\n    expect(simulate(gates, { a: 0, b: 1 }).c).toBe(1);\n    expect(simulate(gates, { a: 1, b: 1 }).c).toBe(0);\n  });\n\n  it('should handle dependency chains', () => {\n    const gates: Gate[] = [\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },\n    ];\n    const result = simulate(gates, { a: 1, b: 1, d: 0 });\n    expect(result.c).toBe(1);\n    expect(result.e).toBe(1);\n  });\n\n  it('should simulate a 2-bit adder correctly', () => {\n    // 2-bit adder: x + y = z\n    const gates: Gate[] = [\n      // Bit 0: half adder\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      // Bit 1: full adder\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },\n    ];\n\n    // 1 + 1 = 2 (01 + 01 = 10)\n    let result = simulate(gates, { x00: 1, x01: 0, y00: 1, y01: 0 });\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(1);\n    expect(result.z02).toBe(0);\n\n    // 3 + 3 = 6 (11 + 11 = 110)\n    result = simulate(gates, { x00: 1, x01: 1, y00: 1, y01: 1 });\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(1);\n    expect(result.z02).toBe(1);\n\n    // 2 + 1 = 3 (10 + 01 = 011)\n    result = simulate(gates, { x00: 0, x01: 1, y00: 1, y01: 0 });\n    expect(result.z00).toBe(1);\n    expect(result.z01).toBe(1);\n    expect(result.z02).toBe(0);\n  });\n\n  it('should return all wire values including inputs', () => {\n    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n    const result = simulate(gates, { a: 1, b: 0 });\n    expect(result.a).toBe(1);\n    expect(result.b).toBe(0);\n    expect(result.c).toBe(0);\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  function makeAdder(numBits: number): Gate[] {\n    const gates: Gate[] = [];\n    const pad = (n: number) => n.toString().padStart(2, '0');\n    const lastZ = `z${pad(numBits)}`;\n\n    // Bit 0: half adder\n    gates.push({ op: 'XOR', in1: `x00`, in2: `y00`, out: `z00` });\n    gates.push({ op: 'AND', in1: `x00`, in2: `y00`, out: `c00` });\n\n    for (let i = 1; i < numBits; i++) {\n      const x = `x${pad(i)}`;\n      const y = `y${pad(i)}`;\n      const z = `z${pad(i)}`;\n      const t = `t${pad(i)}`;\n      const a = `a${pad(i)}`;\n      const b = `b${pad(i)}`;\n      // Last bit's carry output is the final z bit directly\n      const c = i === numBits - 1 ? lastZ : `c${pad(i)}`;\n      const cPrev = `c${pad(i - 1)}`;\n\n      gates.push({ op: 'XOR', in1: x, in2: y, out: t });\n      gates.push({ op: 'XOR', in1: t, in2: cPrev, out: z });\n      gates.push({ op: 'AND', in1: x, in2: y, out: a });\n      gates.push({ op: 'AND', in1: t, in2: cPrev, out: b });\n      gates.push({ op: 'OR', in1: a, in2: b, out: c });\n    }\n\n    return gates;\n  }\n\n  function swapOutputs(gates: Gate[], wire1: string, wire2: string): Gate[] {\n    return gates.map((g) => {\n      if (g.out === wire1) return { ...g, out: wire2 };\n      if (g.out === wire2) return { ...g, out: wire1 };\n      return { ...g };\n    });\n  }\n\n  function verifyAdder(gates: Gate[], numBits: number): boolean {\n    const pad = (n: number) => n.toString().padStart(2, '0');\n    const maxVal = (1 << numBits) - 1;\n\n    // Test a few representative values\n    const testCases = [\n      [0, 0],\n      [0, 1],\n      [1, 0],\n      [maxVal, maxVal],\n      [maxVal, 0],\n      [maxVal, 1],\n      [1, maxVal],\n    ];\n\n    for (const [xVal, yVal] of testCases) {\n      const inputs: Record<string, number> = {};\n      for (let i = 0; i < numBits; i++) {\n        inputs[`x${pad(i)}`] = (xVal >> i) & 1;\n        inputs[`y${pad(i)}`] = (yVal >> i) & 1;\n      }\n\n      const result = simulate(gates, inputs);\n      const expected = xVal + yVal;\n\n      for (let i = 0; i <= numBits; i++) {\n        const bit = (expected >> i) & 1;\n        if (result[`z${pad(i)}`] !== bit) return false;\n      }\n    }\n    return true;\n  }\n\n  it('should find swapped wires in a simple 4-bit adder', () => {\n    let gates = makeAdder(4);\n\n    // Verify the unswapped adder works\n    expect(verifyAdder(gates, 4)).toBe(true);\n\n    // Swap z01 and a01 (sum output swapped with generate)\n    gates = swapOutputs(gates, 'z01', 'a01');\n    // Swap b03 and c02 (propagate carry of bit 3 swapped with carry out of bit 2)\n    gates = swapOutputs(gates, 'b03', 'c02');\n    // Swap t02 and z02 (partial sum of bit 2 swapped with final sum of bit 2)\n    gates = swapOutputs(gates, 't02', 'z02');\n    // Swap a03 and z04 (generate of bit 3 swapped with final carry output)\n    gates = swapOutputs(gates, 'a03', 'z04');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['a01', 'a03', 'b03', 'c02', 't02', 'z01', 'z02', 'z04'].sort()\n    );\n  });\n\n  it('should find swapped wires in an 8-bit adder', () => {\n    let gates = makeAdder(8);\n    expect(verifyAdder(gates, 8)).toBe(true);\n\n    // 4 swaps\n    gates = swapOutputs(gates, 'z03', 't03');\n    gates = swapOutputs(gates, 'a05', 'b05');\n    gates = swapOutputs(gates, 'z07', 'c06');\n    gates = swapOutputs(gates, 'c07', 'z08');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['a