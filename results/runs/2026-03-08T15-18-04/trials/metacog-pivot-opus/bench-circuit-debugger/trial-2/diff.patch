i, c_{i-1}) -> zi   (final sum)\n *   - AND(xi, yi) -> ai        (generate)\n *   - AND(ti, c_{i-1}) -> bi   (propagate)\n *   - OR(ai, bi) -> ci         (carry out)\n *\n * We walk through the adder bit by bit, tracking the carry chain, and\n * identify any wire that doesn't match the expected pattern.\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  const swapped = new Set<string>();\n\n  // Build lookup structures\n  const gateByOutput = new Map<string, Gate>();\n  for (const g of gates) {\n    gateByOutput.set(g.out, g);\n  }\n\n  // Helper: find a gate with given op and inputs (order-independent)\n  function findGate(\n    op: Gate['op'],\n    in1: string,\n    in2: string\n  ): Gate | undefined {\n    for (const g of gates) {\n      if (\n        g.op === op &&\n        ((g.in1 === in1 && g.in2 === in2) ||\n          (g.in1 === in2 && g.in2 === in1))\n      ) {\n        return g;\n      }\n    }\n    return undefined;\n  }\n\n  // Determine the number of input bits\n  const xBits = new Set<number>();\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2]) {\n      const m = w.match(/^x(\\d+)$/);\n      if (m) xBits.add(parseInt(m[1], 10));\n    }\n  }\n  const numBits = Math.max(...xBits) + 1;\n\n  const pad = (n: number) => n.toString().padStart(2, '0');\n\n  // We'll check structural rules and collect violations.\n  // Rule-based approach: each gate's output must satisfy certain properties\n  // based on the adder structure.\n\n  // Key observations for a correct adder:\n  // 1. z outputs (except the last) must come from XOR gates\n  // 2. The last z output (z{numBits}) comes from OR (the final carry) or directly\n  // 3. XOR gates that don't output z must have x/y inputs (they're partial sums)\n  // 4. AND gates with x/y inputs must feed into OR gates (not directly to z or other AND)\n  // 5. OR gates represent carries and must not output to z (except the final carry bit)\n\n  // Actually, let me use a more direct structural walk approach.\n\n  // Swap tracking: when we detect a problem, we record the two wires that\n  // need swapping. After fixing conceptually, we continue.\n\n  // Build a mutable copy of the output mapping so we can \"fix\" swaps as we find them\n  const outputOf = new Map<Gate, string>();\n  const gateProducingWire = new Map<string, Gate>();\n  for (const g of gates) {\n    outputOf.set(g, g.out);\n    gateProducingWire.set(g.out, g);\n  }\n\n  function swapOutputs(wire1: string, wire2: string) {\n    swapped.add(wire1);\n    swapped.add(wire2);\n    const g1 = gateProducingWire.get(wire1)!;\n    const g2 = gateProducingWire.get(wire2)!;\n    outputOf.set(g1, wire2);\n    outputOf.set(g2, wire1);\n    gateProducingWire.set(wire1, g2);\n    gateProducingWire.set(wire2, g1);\n  }\n\n  function getOutput(g: Gate): string {\n    return outputOf.get(g)!;\n  }\n\n  function getGateForWire(w: string): Gate | undefined {\n    return gateProducingWire.get(w);\n  }\n\n  // Walk the adder structure bit by bit\n  let carry = '';\n\n  for (let bit = 0; bit < numBits; bit++) {\n    const x = `x${pad(bit)}`;\n    const y = `y${pad(bit)}`;\n    const z = `z${pad(bit)}`;\n\n    if (bit === 0) {\n      // Half adder: XOR(x00, y00) -> z00, AND(x00, y00) -> carry\n      const xorGate = findGate('XOR', x, y);\n      const andGate = findGate('AND', x, y);\n\n      if (!xorGate || !andGate) continue;\n\n      const xorOut = getOutput(xorGate);\n      if (xorOut !== z) {\n        // The XOR gate's output should be z00\n        // Find what's producing z00 and swap\n        const andOut = getOutput(andGate);\n        if (andOut === z) {\n          swapOutputs(xorOut, andOut);\n          carry = xorOut; // after swap, andGate now produces xorOut\n        } else {\n          // Something else is wrong - xorOut should be z\n          swapOutputs(xorOut, z);\n        }\n      }\n      carry = getOutput(andGate);\n    } else {\n      // Full adder for bit i:\n      // XOR(xi, yi) -> ti\n      // XOR(ti, carry_in) -> zi\n      // AND(xi, yi) -> ai\n      // AND(ti, carry_in) -> bi\n      // OR(ai, bi) -> ci\n\n      const xyXor = findGate('XOR', x, y);\n      const xyAnd = findGate('AND', x, y);\n\n      if (!xyXor || !xyAnd) continue;\n\n      let ti = getOutput(xyXor);\n\n      // Check: ti XOR carry -> zi\n      let sumGate = findGate('XOR', ti, carry);\n\n      if (!sumGate) {\n        // ti might be swapped. The XOR(xi,yi) output should participate in\n        // another XOR with carry. Let's find what does.\n        // Look for any XOR gate that uses carry as one input\n        let carryXor: Gate | undefined;\n        for (const g of gates) {\n          if (\n            g.op === 'XOR' &&\n            (g.in1 === carry || g.in2 === carry)\n          ) {\n            carryXor = g;\n            break;\n          }\n        }\n\n        if (carryXor) {\n          // The other input of carryXor should be ti but isn't\n          const otherInput =\n            carryXor.in1 === carry ? carryXor.in2 : carryXor.in1;\n          // otherInput is where ti's value ended up - that means ti and otherInput are swapped\n          swapOutputs(ti, otherInput);\n          ti = otherInput;\n          sumGate = carryXor;\n        }\n      }\n\n      if (sumGate) {\n        let sumOut = getOutput(sumGate);\n        if (sumOut !== z) {\n          // The sum gate should output zi but doesn't\n          swapOutputs(sumOut, z);\n          sumOut = z;\n        }\n      }\n\n      // Now find propagate: AND(ti, carry) -> bi\n      const propGate = findGate('AND', ti, carry);\n      const ai = getOutput(xyAnd);\n\n      // Find carry out: OR(ai, bi) -> ci\n      let bi = propGate ? getOutput(propGate) : '';\n      let carryGate: Gate | undefined;\n\n      if (propGate) {\n        carryGate = findGate('OR', ai, bi);\n\n        if (!carryGate) {\n          // ai or bi might be swapped\n          // Look for an OR gate with ai as input\n          let orWithAi: Gate | undefined;\n          let orWithBi: Gate | undefined;\n          for (const g of gates) {\n            if (g.op === 'OR') {\n              if (g.in1 === ai || g.in2 === ai) orWithAi = g;\n              if (g.in1 === bi || g.in2 === bi) orWithBi = g;\n            }\n          }\n\n          if (orWithAi) {\n            // Found OR with ai; the other input should be bi\n            const otherInput =\n              orWithAi.in1 === ai ? orWithAi.in2 : orWithAi.in1;\n            if (otherInput !== bi) {\n              swapOutputs(bi, otherInput);\n              bi = otherInput;\n            }\n            carryGate = orWithAi;\n          } else if (orWithBi) {\n            // Found OR with bi; the other input should be ai\n            const otherInput =\n              orWithBi.in1 === bi ? orWithBi.in2 : orWithBi.in1;\n            if (otherInput !== ai) {\n              swapOutputs(ai, otherInput);\n            }\n            carryGate = orWithBi;\n          }\n        }\n      }\n\n      if (carryGate) {\n        carry = getOutput(carryGate);\n        // Check: if this is the last bit and carry should be z{numBits}\n        const lastZ = `z${pad(numBits)}`;\n        if (bit === numBits - 1 && carry !== lastZ) {\n          swapOutputs(carry, lastZ);\n          carry = lastZ;\n        }\n      }\n    }\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[{"oldStart":135,"oldLines":10,"newStart":135,"newLines":6,"lines":["     return outputOf.get(g)!;","   }"," ","-  function getGateForWire(w: string): Gate | undefined {","-    return gateProducingWire.get(w);","-  }","-","   // Walk the adder structure bit by bit","   let carry = '';"," "]}],"userModified":false,"replaceAll":false}}
