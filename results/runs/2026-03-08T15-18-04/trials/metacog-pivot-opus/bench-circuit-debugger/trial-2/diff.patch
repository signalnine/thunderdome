+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+
+  let changed = true;
+  while (remaining.length > 0 && changed) {
+    changed = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        let result: number;
+        switch (gate.op) {
+          case 'AND':
+            result = a & b;
+            break;
+          case 'OR':
+            result = a | b;
+            break;
+          case 'XOR':
+            result = a ^ b;
+            break;
+        }
+        wires[gate.out] = result;
+        remaining.splice(i, 1);
+        changed = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+export function findSwappedWires(gates: Gate[]): string[] {
+  const swapped = new Set<string>();
+
+  // Find gate by op and inputs (using the actual wire names in the circuit)
+  function findGate(
+    op: Gate['op'],
+    in1: string,
+    in2: string
+  ): Gate | undefined {
+    for (const g of gates) {
+      if (
+        g.op === op &&
+        ((g.in1 === in1 && g.in2 === in2) ||
+          (g.in1 === in2 && g.in2 === in1))
+      ) {
+        return g;
+      }
+    }
+    return undefined;
+  }
+
+  // Find a gate that uses the given op and has wireA as one of its inputs
+  function findGateWithInput(op: Gate['op'], wireA: string): Gate | undefined {
+    for (const g of gates) {
+      if (g.op === op && (g.in1 === wireA || g.in2 === wireA)) {
+        return g;
+      }
+    }
+    return undefined;
+  }
+
+  function recordSwap(wire1: string, wire2: string) {
+    swapped.add(wire1);
+    swapped.add(wire2);
+  }
+
+  // Determine the number of input bits
+  let maxBit = 0;
+  for (const g of gates) {
+    for (const w of [g.in1, g.in2]) {
+      const m = w.match(/^x(\d+)$/);
+      if (m) {
+        const n = parseInt(m[1], 10);
+        if (n > maxBit) maxBit = n;
+      }
+    }
+  }
+  const numBits = maxBit + 1;
+  const pad = (n: number) => n.toString().padStart(2, '0');
+
+  // Walk the adder bit by bit, tracking carry wire names
+  // Important: all wire references here are the ACTUAL wire names in the circuit
+  // (i.e., the potentially-swapped names), because that's what gate inputs use.
+  let carry = '';
+
+  for (let bit = 0; bit < numBits; bit++) {
+    const x = `x${pad(bit)}`;
+    const y = `y${pad(bit)}`;
+    const z = `z${pad(bit)}`;
+
+    if (bit === 0) {
+      // Half adder: XOR(x00, y00) -> z00, AND(x00, y00) -> c00
+      const xorGate = findGate('XOR', x, y)!;
+      const andGate = findGate('AND', x, y)!;
+
+      if (xorGate.out !== z) {
+        // XOR should produce z00. Whatever it produces now is swapped with z00.
+        recordSwap(xorGate.out, z);
+        // After swap: xorGate effectively produces z, andGate keeps its output.
+        // But we also need to check if andGate's out is z00 (the other half of swap).
+        if (andGate.out === z) {
+          // AND produces z00, XOR produces something else => they're swapped with each other
+          carry = xorGate.out; // after swap, AND now produces what XOR had
+        } else {
+          // XOR's output was swapped with some other gate's output that produces z
+          carry = andGate.out;
+        }
+      } else {
+        carry = andGate.out;
+      }
+    } else {
+      // Full adder for bit i:
+      // Step 1: XOR(xi, yi) -> ti (partial sum)
+      const xyXor = findGate('XOR', x, y)!;
+      const xyAnd = findGate('AND', x, y)!;
+      let ti = xyXor.out;
+
+      // Step 2: XOR(ti, carry) -> zi (final sum)
+      let sumGate = findGate('XOR', ti, carry);
+
+      if (!sumGate) {
+        // ti might be swapped with something. Find the XOR gate that uses carry.
+        const carryXor = findGateWithInput('XOR', carry);
+        if (carryXor && carryXor !== xyXor) {
+          // The other input should be ti but is something else
+          const actualTi =
+            carryXor.in1 === carry ? carryXor.in2 : carryXor.in1;
+          // ti (xyXor.out) and actualTi are swapped
+          recordSwap(ti, actualTi);
+          ti = actualTi;
+          sumGate = carryXor;
+        } else {
+          // carry might be the swapped one. Find the XOR gate that uses ti (other than xyXor).
+          let tiXor: Gate | undefined;
+          for (const g of gates) {
+            if (
+              g.op === 'XOR' &&
+              g !== xyXor &&
+              (g.in1 === ti || g.in2 === ti)
+            ) {
+              tiXor = g;
+              break;
+            }
+          }
+          if (tiXor) {
+            const actualCarry =
+              tiXor.in1 === ti ? tiXor.in2 : tiXor.in1;
+            recordSwap(carry, actualCarry);
+            carry = actualCarry;
+            sumGate = tiXor;
+          }
+        }
+      }
+
+      if (sumGate) {
+        if (sumGate.out !== z) {
+          // Sum gate should output z but doesn't => swap
+          recordSwap(sumGate.out, z);
+        }
+      }
+
+      // Step 3: AND(xi, yi) -> ai (generate)
+      let ai = xyAnd.out;
+
+      // Step 4: AND(ti, carry) -> bi (propagate)
+      const propGate = findGate('AND', ti, carry);
+      let bi = propGate ? propGate.out : '';
+
+      // Step 5: OR(ai, bi) -> ci (carry out)
+      let carryGate: Gate | undefined;
+
+      if (propGate) {
+        carryGate = findGate('OR', ai, bi);
+
+        if (!carryGate) {
+          // ai or bi is swapped. Find OR gates that use either.
+          const orWithAi = findGateWithInput('OR', ai);
+          const orWithBi = findGateWithInput('OR', bi);
+
+          if (orWithAi && !orWithBi) {
+            const expectedBi =
+              orWithAi.in1 === ai ? orWithAi.in2 : orWithAi.in1;
+            recordSwap(bi, expectedBi);
+            bi = expectedBi;
+            carryGate = orWithAi;
+          } else if (orWithBi && !orWithAi) {
+            const expectedAi =
+              orWithBi.in1 === bi ? orWithBi.in2 : orWithBi.in1;
+            recordSwap(ai, expectedAi);
+            ai = expectedAi;
+            carryGate = orWithBi;
+          } else if (orWithAi) {
