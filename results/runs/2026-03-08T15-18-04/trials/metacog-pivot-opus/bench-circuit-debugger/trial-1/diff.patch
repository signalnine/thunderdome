n    if (bit === 0) {\n      // Half adder\n      const xorGate = findGate('XOR', xWire, yWire)!;\n      const andGate = findGate('AND', xWire, yWire)!;\n\n      if (xorGate.out !== zWire) {\n        doSwap(xorGate.out, zWire);\n      }\n\n      carry = andGate.out;\n      // If carry is a z-wire (and not the final z), it's been swapped.\n      // We resolve this by finding the XOR gate for that z-bit.\n      if (carry.startsWith('z') && carry !== finalZWire) {\n        const zBitNum = parseInt(carry.slice(1), 10);\n        const firstXor = findGate('XOR', `x${pad(zBitNum)}`, `y${pad(zBitNum)}`);\n        if (firstXor) {\n          const secondXor = findXorUsing(firstXor.out, firstXor);\n          if (secondXor) {\n            doSwap(carry, secondXor.out);\n            carry = andGate.out;\n          }\n        }\n      }\n    } else {\n      // Full adder\n      // Step 1: xi XOR yi -> ti\n      const xorGate = findGate('XOR', xWire, yWire)!;\n      let ti = xorGate.out;\n\n      // Step 2: ti XOR carry -> zi\n      let sumGate = findGate('XOR', ti, carry);\n\n      if (!sumGate) {\n        // Either ti or carry is wrong. Find which XOR gate uses one of them.\n        const foundWithTi = findXorUsing(ti, xorGate);\n        const foundWithCarry = findXorUsing(carry);\n\n        if (foundWithCarry && !foundWithTi) {\n          // ti is wrong — xorGate.out was swapped\n          const correctTi = otherInput(foundWithCarry, carry);\n          doSwap(ti, correctTi);\n          ti = correctTi;\n          sumGate = foundWithCarry;\n        } else if (foundWithTi && !foundWithCarry) {\n          // carry is wrong\n          const correctCarry = otherInput(foundWithTi, ti);\n          doSwap(carry, correctCarry);\n          carry = correctCarry;\n          sumGate = foundWithTi;\n        } else {\n          throw new Error(`Cannot resolve sum gate for bit ${bit}`);\n        }\n      }\n\n      // Sum gate should output zi\n      if (sumGate.out !== zWire) {\n        doSwap(sumGate.out, zWire);\n      }\n\n      // Step 3: xi AND yi -> ai\n      const genGate = findGate('AND', xWire, yWire)!;\n      const ai = genGate.out;\n\n      // Step 4: ti AND carry -> bi\n      const propGate = findGate('AND', ti, carry)!;\n      const bi = propGate.out;\n\n      // Step 5: ai OR bi -> ci\n      let orGate = findGate('OR', ai, bi);\n      if (!orGate) {\n        const foundWithAi = findOrUsing(ai);\n        const foundWithBi = findOrUsing(bi);\n        if (foundWithAi && !foundWithBi) {\n          const correctBi = otherInput(foundWithAi, ai);\n          doSwap(bi, correctBi);\n          orGate = foundWithAi;\n        } else if (foundWithBi && !foundWithAi) {\n          const correctAi = otherInput(foundWithBi, bi);\n          doSwap(ai, correctAi);\n          orGate = foundWithBi;\n        } else {\n          throw new Error(`Cannot resolve OR gate for bit ${bit}`);\n        }\n      }\n\n      carry = orGate.out;\n\n      // Carry should not be a z wire (unless it's the final output)\n      if (carry.startsWith('z') && carry !== finalZWire) {\n        const zBitNum = parseInt(carry.slice(1), 10);\n        if (zBitNum === 0) {\n          // z00 case - find the XOR gate for bit 0\n          const bit0Xor = findGate('XOR', 'x00', 'y00');\n          if (bit0Xor) {\n            doSwap(carry, bit0Xor.out);\n            carry = orGate.out;\n          }\n        } else {\n          const firstXor = findGate('XOR', `x${pad(zBitNum)}`, `y${pad(zBitNum)}`);\n          if (firstXor) {\n            const secondXor = findXorUsing(firstXor.out, firstXor);\n            if (secondXor) {\n              doSwap(carry, secondXor.out);\n              carry = orGate.out;\n            }\n          }\n        }\n      }\n    }\n  }\n\n  return swapped.sort();\n}\n","structuredPatch":[{"oldStart":40,"oldLines":7,"newStart":40,"newLines":9,"lines":["   return wires;"," }"," ","-export function findSwappedWires(gates: Gate[]): string[] {","+export function findSwappedWir