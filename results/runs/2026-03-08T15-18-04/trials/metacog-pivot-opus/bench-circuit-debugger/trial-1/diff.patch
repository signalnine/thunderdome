s correctly', () => {\n    const { gates, swappedWires } = makeSwappedAdder(8, [\n      ['z01', 't01'],\n      ['z03', 'a03'],\n      ['z05', 'c04'],\n      ['c06', 'z07'],\n    ]);\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(swappedWires.sort());\n\n    // After findSwappedWires mutates the gates, the circuit should be correct\n    // Test a few additions\n    for (let x = 0; x < 16; x++) {\n      for (let y = 0; y < 16; y++) {\n        const inputs: Record<string, number> = {};\n        for (let i = 0; i < 8; i++) {\n          inputs[`x${String(i).padStart(2, '0')}`] = (x >> i) & 1;\n          inputs[`y${String(i).padStart(2, '0')}`] = (y >> i) & 1;\n        }\n        const wires = simulate(gates, inputs);\n        expect(extractZ(wires, 9)).toBe(x + y);\n      }\n    }\n  });\n});\n\nfunction extractZ(wires: Record<string, number>, numBits: number): number {\n  let val = 0;\n  for (let i = 0; i < numBits; i++) {\n    const bit = wires[`z${String(i).padStart(2, '0')}`];\n    if (bit) val += (1 << i);\n  }\n  return val;\n}\n\nfunction makeCorrectAdder(numBits: number): Gate[] {\n  const gates: Gate[] = [];\n  const pad = (n: number) => String(n).padStart(2, '0');\n\n  // Bit 0: half adder\n  gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });\n  gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });\n\n  // Bits 1..numBits-1: full adders\n  for (let i = 1; i < numBits; i++) {\n    const p = pad(i);\n    const pp = pad(i - 1);\n    gates.push({ op: 'XOR', in1: `x${p}`, in2: `y${p}`, out: `t${p}` });\n    gates.push({ op: 'XOR', in1: `t${p}`, in2: `c${pp}`, out: `z${p}` });\n    gates.push({ op: 'AND', in1: `x${p}`, in2: `y${p}`, out: `a${p}` });\n    gates.push({ op: 'AND', in1: `t${p}`, in2: `c${pp}`, out: `b${p}` });\n    gates.push({ op: 'OR', in1: `a${p}`, in2: `b${p}`, out: `c${p}` });\n  }\n\n  // Last carry -> final z bit\n  const lastGate = gates.find(g => g.out === `c${pad(numBits - 1)}`);\n  if (lastGate) lastGate.out = `z${pad(numBits)}`;\n\n  return gates;\n}\n\nfunction makeSwappedAdder(\n  numBits: number,\n  swapPairs: [string, string][],\n): { gates: Gate[]; swappedWires: string[] } {\n  const gates = makeCorrectAdder(numBits);\n  const swappedWires: string[] = [];\n\n  for (const [wire1, wire2] of swapPairs) {\n    const g1 = gates.find(g => g.out === wire1);\n    const g2 = gates.find(g => g.out === wire2);\n    if (!g1 || !g2) {\n      throw new Error(`Cannot find gates for swap: ${wire1} <-> ${wire2}`);\n    }\n    g1.out = wire2;\n    g2.out = wire1;\n    swappedWires.push(wire1, wire2);\n  }\n\n  return { gates, swappedWires };\n}\n","structuredPatch":[{"oldStart":4,"oldLines":20,"newStart":4,"newLines":20,"lines":[" describe('simulate', () => {","   it('should simulate a simple AND gate', () => {","     const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];","-    const result = simulate(gates, { a: 1, b: 1 });","-    expect(result.c).toBe(1);","+    expect(simulate(gates, { a: 1, b: 1 }).c).toBe(1);","+    expect(simulate(gates, { a: 1, b: 0 }).c).toBe(0);","   });"," ","   it('should simulate a simple OR gate', () => {","     const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];","-    const result = simulate(gates, { a: 0, b: 1 });","-    expect(result.c).toBe(1);","+    expect(simulate(gates, { a: 0, b: 1 }).c).toBe(1);","+    expect(simulate(gates, { a: 0, b: 0 }).c).toBe(0);","   });"," ","   it('should simulate a simple XOR gate', () => {","     const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];","-    const result = simulate(gates, { a: 1, b: 1 });","-    expect(result.c).toBe(0);","+    expect(simulate(gates, { a: 1, b: 1 }).c).toBe(0);","+    expect(simulate(gates, { a: 1, b: 0 }).c).toBe(1);","   });"," ","   it('should handle dependency ordering', () => {"]},{"oldStart":30,"oldLines":56,"newStart":30,"newLines":83,"lines":["     expect(result.e).toBe(1);","   });"," ","-  it('should simulate a 4-bi