'op'],\n    in1: string,\n    in2: string,\n  ): Gate | undefined {\n    for (const g of gates) {\n      if (\n        g.op === op &&\n        ((g.in1 === in1 && g.in2 === in2) ||\n          (g.in1 === in2 && g.in2 === in1))\n      ) {\n        return g;\n      }\n    }\n    return undefined;\n  }\n\n  // Determine how many input bits there are\n  let maxBit = 0;\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2]) {\n      const m = w.match(/^[xy](\\d+)$/);\n      if (m) {\n        maxBit = Math.max(maxBit, parseInt(m[1], 10));\n      }\n    }\n  }\n\n  const swapped: string[] = [];\n\n  function swap(a: string, b: string): void {\n    // Swap the output wires of two gates\n    const gateA = gateByOutput.get(a)!;\n    const gateB = gateByOutput.get(b)!;\n    gateA.out = b;\n    gateB.out = a;\n    gateByOutput.set(a, gateB);\n    gateByOutput.set(b, gateA);\n    swapped.push(a, b);\n  }\n\n  // For each bit position, verify the adder structure and fix swaps.\n  // We trace the expected structure and when something doesn't match,\n  // we figure out which outputs were swapped.\n\n  let carry = '';\n\n  for (let bit = 0; bit <= maxBit; bit++) {\n    const xWire = `x${String(bit).padStart(2, '0')}`;\n    const yWire = `y${String(bit).padStart(2, '0')}`;\n    const zWire = `z${String(bit).padStart(2, '0')}`;\n\n    if (bit === 0) {\n      // Half adder: x00 XOR y00 -> z00, x00 AND y00 -> carry\n      const xorGate = findGate('XOR', xWire, yWire);\n      const andGate = findGate('AND', xWire, yWire);\n\n      if (!xorGate || !andGate) {\n        throw new Error(`Missing half adder gates for bit 0`);\n      }\n\n      // The XOR gate should output z00\n      if (xorGate.out !== zWire) {\n        // z00 is swapped with whatever xorGate currently outputs\n        swap(xorGate.out, zWire);\n      }\n\n      carry = andGate.out;\n      // Check if carry is a z-wire (that would be wrong for a carry)\n      if (carry.startsWith('z')) {\n        // The AND gate's output was swapped with something\n        // We need to find what z-wire it points to and swap\n        // Actually the carry shouldn't be a z wire, find the correct output\n        // The gate that currently has the right output for the and gate:\n        // We know and gate should NOT output a z wire, so its output was swapped\n        // We need to figure out what it was swapped WITH.\n        // For now, let's check in the next bit.\n      }\n    } else {\n      // Full adder for bit i:\n      // 1. xi XOR yi -> ti (partial sum)\n      // 2. ti XOR carry_{i-1} -> zi (final sum)\n      // 3. xi AND yi -> ai (generate)\n      // 4. ti AND carry_{i-1} -> bi (propagate)\n      // 5. ai OR bi -> ci (carry out)\n\n      // Step 1: Find the XOR of xi, yi\n      const xorGate = findGate('XOR', xWire, yWire);\n      if (!xorGate) {\n        throw new Error(`Missing XOR gate for ${xWire}, ${yWire}`);\n      }\n      let ti = xorGate.out;\n\n      // Step 2: Find the XOR of ti and carry -> should produce zi\n      let sumGate = findGate('XOR', ti, carry);\n\n      if (!sumGate) {\n        // ti or carry might be swapped.\n        // If ti was swapped, then the xorGate.out is wrong.\n        // If carry was swapped, the previous bit's OR output is wrong.\n        //\n        // Strategy: check if there's an XOR gate with carry as one input\n        // that isn't accounted for, or an XOR gate with ti as one input.\n\n        // Check if carry is the problem: look for any XOR gate with ti as input\n        // (other than the xi XOR yi gate itself)\n        let foundWithTi: Gate | undefined;\n        let foundWithCarry: Gate | undefined;\n        for (const g of gates) {\n          if (g.op === 'XOR' && g !== xorGate) {\n            if (g.in1 === ti || g.in2 === ti) foundWithTi = g;\n            if (g.in1 === carry || g.in2 === carry) foundWithCarry = g;\n          }\n        }\n\n        if (foundWithCarry && !foundWithTi) {\n          // ti is the problem - the xorGate output