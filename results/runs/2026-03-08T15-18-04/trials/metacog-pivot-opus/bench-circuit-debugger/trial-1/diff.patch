+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>,
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+
+  let progress = true;
+  while (remaining.length > 0 && progress) {
+    progress = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        switch (gate.op) {
+          case 'AND':
+            wires[gate.out] = a & b;
+            break;
+          case 'OR':
+            wires[gate.out] = a | b;
+            break;
+          case 'XOR':
+            wires[gate.out] = a ^ b;
+            break;
+        }
+        remaining.splice(i, 1);
+        progress = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+export function findSwappedWires(inputGates: Gate[]): string[] {
+  // Work on a deep copy to avoid mutating the input
+  const gates: Gate[] = inputGates.map(g => ({ ...g }));
+  const gateByOutput = new Map<string, Gate>();
+  for (const g of gates) {
+    gateByOutput.set(g.out, g);
+  }
+
+  function findGate(
+    op: Gate['op'],
+    in1: string,
+    in2: string,
+  ): Gate | undefined {
+    for (const g of gates) {
+      if (
+        g.op === op &&
+        ((g.in1 === in1 && g.in2 === in2) ||
+          (g.in1 === in2 && g.in2 === in1))
+      ) {
+        return g;
+      }
+    }
+    return undefined;
+  }
+
+  let maxBit = 0;
+  for (const g of gates) {
+    for (const w of [g.in1, g.in2]) {
+      const m = w.match(/^[xy](\d+)$/);
+      if (m) {
+        maxBit = Math.max(maxBit, parseInt(m[1], 10));
+      }
+    }
+  }
+
+  const swapped: string[] = [];
+
+  function doSwap(a: string, b: string): void {
+    const gateA = gateByOutput.get(a)!;
+    const gateB = gateByOutput.get(b)!;
+    gateA.out = b;
+    gateB.out = a;
+    gateByOutput.set(a, gateB);
+    gateByOutput.set(b, gateA);
+    swapped.push(a, b);
+  }
+
+  function pad(n: number): string {
+    return String(n).padStart(2, '0');
+  }
+
+  // Find an XOR gate that uses the given wire as one input (excluding a specific gate)
+  function findXorUsing(wire: string, exclude?: Gate): Gate | undefined {
+    for (const g of gates) {
+      if (g.op === 'XOR' && g !== exclude && (g.in1 === wire || g.in2 === wire)) {
+        return g;
+      }
+    }
+    return undefined;
+  }
+
+  // Find an OR gate that uses the given wire as one input
+  function findOrUsing(wire: string): Gate | undefined {
+    for (const g of gates) {
+      if (g.op === 'OR' && (g.in1 === wire || g.in2 === wire)) {
+        return g;
+      }
+    }
+    return undefined;
+  }
+
+  function otherInput(gate: Gate, known: string): string {
+    return gate.in1 === known ? gate.in2 : gate.in1;
+  }
+
+  let carry = '';
+  const finalZWire = `z${pad(maxBit + 1)}`;
+
+  for (let bit = 0; bit <= maxBit; bit++) {
+    const xWire = `x${pad(bit)}`;
+    const yWire = `y${pad(bit)}`;
+    const zWire = `z${pad(bit)}`;
+
+    if (bit === 0) {
+      // Half adder
+      const xorGate = findGate('XOR', xWire, yWire)!;
+      const andGate = findGate('AND', xWire, yWire)!;
+
+      if (xorGate.out !== zWire) {
+        doSwap(xorGate.out, zWire);
+      }
+
+      carry = andGate.out;
+      // If carry is a z-wire (and not the final z), it's been swapped.
+      // We resolve this by finding the XOR gate for that z-bit.
+      if (carry.startsWith('z') && carry !== finalZWire) {
+        const zBitNum = parseInt(carry.slice(1), 10);
+        const firstXor = findGate('XOR', `x${pad(zBitNum)}`, `y${pad(zBitNum)}`);
+        if (firstXor) {
+          const secondXor = findXorUsing(firstXor.out, firstXor);
+          if (secondXor) {
+            doSwap(carry, secondXor.out);
+            carry = andGate.out;
+          }
+        }
+      }
+    } else {
+      // Full adder
+      // Step 1: xi XOR yi -> ti
+      const xorGate = findGate('XOR', xWire, yWire)!;
+      let ti = xorGate.out;
+
+      // Step 2: ti XOR carry -> zi
+      let sumGate = findGate('XOR', ti, carry);
+
+      if (!sumGate) {
+        // Either ti or carry is wrong. Find which XOR gate uses one of them.
+        const foundWithTi = findXorUsing(ti, xorGate);
+        const foundWithCarry = findXorUsing(carry);
+
+        if (foundWithCarry && !foundWithTi) {
+          // ti is wrong — xorGate.out was swapped
+          const correctTi = otherInput(foundWithCarry, carry);
+          doSwap(ti, correctTi);
+          ti = correctTi;
+          sumGate = foundWithCarry;
+        } else if (foundWithTi && !foundWithCarry) {
+          // carry is wrong
+          const correctCarry = otherInput(foundWithTi, ti);
+          doSwap(carry, correctCarry);
+          carry = correctCarry;
+          sumGate = foundWithTi;
+        } else {
+          throw new Error(`Cannot resolve sum gate for bit ${bit}`);
+        }
+      }
+
+      // Sum gate should output zi
+      if (sumGate.out !== zWire) {
+        doSwap(sumGate.out, zWire);
+      }
+
+      // Step 3: xi AND yi -> ai
+      const genGate = findGate('AND', xWire, yWire)!;
+      const ai = genGate.out;
+
+      // Step 4: ti AND carry -> bi
+      const propGate = findGate('AND', ti, carry)!;
+      const bi = propGate.out;
+
+      // Step 5: ai OR bi -> ci
+      let orGate = findGate('OR', ai, bi);
+      if (!orGate) {
+        const foundWithAi = findOrUsing(ai);
+        const foundWithBi = findOrUsing(bi);
+        if (foundWithAi && !foundWithBi) {
+          const correctBi = otherInput(foundWithAi, ai);
+          doSwap(bi, correctBi);
+          orGate = foundWithAi;
+        } else if (foundWithBi && !foundWithAi) {
+          const correctAi = otherInput(foundWithBi, bi);
+          doSwap(ai, correctAi);
+          orGate = foundWithBi;
+        } else {
+          throw new Error(`Cannot resolve OR gate for bit ${bit}`);
+        }
+      }
+
+      carry = orGate.out;
+
+      // Carry should not be a z wire (unless it's the final output)
+      if (carry.startsWith('z') && carry !== finalZWire) {
+        const zBitNum = parseInt(carry.slice(1), 10);
+        if (zBitNum === 0) {
+          // z00 case - find the XOR gate for bit 0
+          const bit0Xor = findGate('XOR', 'x00', 'y00');
+          if (bit0Xor) {
+            doSwap(carry, bit0Xor.out);
+            carry = orGate.out;
+          }
+        } else {
+          const firstXor = findGate('XOR', `x${pad(zBitNum)}`, `y${pad(zBitNum)}`);
+          if (firstXor) {
+            const secondXor = findXorUsing(firstXor.out, firstXor);
+            if (secondXor) {
+              doSwap(carry, secondXor.out);
+              carry = orGate.out;
+            }
+          }
+        }
+      }
+    }
+  }
+
+  return swapped.sort();
+}
