   }\n    }\n\n    // Test a few additions on the fixed circuit\n    for (let x = 0; x < 16; x++) {\n      for (let y = 0; y < 16; y++) {\n        const inputs: Record<string, number> = {};\n        for (let i = 0; i < 8; i++) {\n          inputs[`x${String(i).padStart(2, '0')}`] = (x >> i) & 1;\n          inputs[`y${String(i).padStart(2, '0')}`] = (y >> i) & 1;\n        }\n        const wires = simulate(fixedGates, inputs);\n        expect(extractZ(wires, 9)).toBe(x + y);\n      }\n    }\n  });","originalFile":"import { describe, it, expect } from 'vitest';\nimport { simulate, findSwappedWires, Gate } from './index.js';\n\ndescribe('simulate', () => {\n  it('should simulate a simple AND gate', () => {\n    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 }).c).toBe(1);\n    expect(simulate(gates, { a: 1, b: 0 }).c).toBe(0);\n  });\n\n  it('should simulate a simple OR gate', () => {\n    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 0, b: 1 }).c).toBe(1);\n    expect(simulate(gates, { a: 0, b: 0 }).c).toBe(0);\n  });\n\n  it('should simulate a simple XOR gate', () => {\n    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 }).c).toBe(0);\n    expect(simulate(gates, { a: 1, b: 0 }).c).toBe(1);\n  });\n\n  it('should handle dependency ordering', () => {\n    const gates: Gate[] = [\n      { op: 'AND', in1: 'c', in2: 'd', out: 'e' },\n      { op: 'XOR', in1: 'a', in2: 'b', out: 'c' },\n    ];\n    const result = simulate(gates, { a: 1, b: 0, d: 1 });\n    expect(result.c).toBe(1);\n    expect(result.e).toBe(1);\n  });\n\n  it('should return all wire values including inputs', () => {\n    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n    const result = simulate(gates, { a: 1, b: 0 });\n    expect(result.a).toBe(1);\n    expect(result.b).toBe(0);\n    expect(result.c).toBe(0