+import { describe, it, expect } from 'vitest';
+import { simulate, findSwappedWires, Gate } from './index.js';
+
+describe('simulate', () => {
+  it('should simulate a simple AND gate', () => {
+    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 1, b: 1 }).c).toBe(1);
+    expect(simulate(gates, { a: 1, b: 0 }).c).toBe(0);
+  });
+
+  it('should simulate a simple OR gate', () => {
+    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 0, b: 1 }).c).toBe(1);
+    expect(simulate(gates, { a: 0, b: 0 }).c).toBe(0);
+  });
+
+  it('should simulate a simple XOR gate', () => {
+    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 1, b: 1 }).c).toBe(0);
+    expect(simulate(gates, { a: 1, b: 0 }).c).toBe(1);
+  });
+
+  it('should handle dependency ordering', () => {
+    const gates: Gate[] = [
+      { op: 'AND', in1: 'c', in2: 'd', out: 'e' },
+      { op: 'XOR', in1: 'a', in2: 'b', out: 'c' },
+    ];
+    const result = simulate(gates, { a: 1, b: 0, d: 1 });
+    expect(result.c).toBe(1);
+    expect(result.e).toBe(1);
+  });
+
+  it('should return all wire values including inputs', () => {
+    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];
+    const result = simulate(gates, { a: 1, b: 0 });
+    expect(result.a).toBe(1);
+    expect(result.b).toBe(0);
+    expect(result.c).toBe(0);
+  });
+
+  it('should simulate a correct 4-bit adder', () => {
+    const gates = makeCorrectAdder(4);
+    // 3 + 5 = 8
+    const inputs: Record<string, number> = {
+      x00: 1, x01: 1, x02: 0, x03: 0,
+      y00: 1, y01: 0, y02: 1, y03: 0,
+    };
+    const result = simulate(gates, inputs);
+    expect(extractZ(result, 5)).toBe(8);
+
+    // 15 + 15 = 30
+    const inputs2: Record<string, number> = {
+      x00: 1, x01: 1, x02: 1, x03: 1,
+      y00: 1, y01: 1, y02: 1, y03: 1,
+    };
+    expect(extractZ(simulate(gates, inputs2), 5)).toBe(30);
+  });
+});
+
+describe('findSwappedWires', () => {
+  it('should find swapped z and t wires', () => {
+    // Swap z01 <-> t01, z02 <-> t02, z03 <-> t03, and c00 <-> a01
+    const { gates, swappedWires } = makeSwappedAdder(8, [
+      ['z01', 't01'],
+      ['z02', 'a02'],
+      ['z03', 'c02'],
+      ['c05', 'z06'],
+    ]);
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(swappedWires.sort());
+  });
+
+  it('should find swapped wires across different bit positions', () => {
+    const { gates, swappedWires } = makeSwappedAdder(12, [
+      ['z01', 't01'],
+      ['z04', 't04'],
+      ['z07', 'c06'],
+      ['z10', 'a10'],
+    ]);
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(swappedWires.sort());
+  });
+
+  it('should verify result contains exactly 8 wire names', () => {
+    const { gates, swappedWires } = makeSwappedAdder(8, [
+      ['z01', 't01'],
+      ['z03', 'a03'],
+      ['z05', 'c04'],
+      ['c06', 'z07'],
+    ]);
+    const result = findSwappedWires(gates);
+    expect(result).toHaveLength(8);
+    expect(result).toEqual(swappedWires.sort());
+  });
+
+  it('should not mutate the input gates', () => {
+    const { gates } = makeSwappedAdder(8, [
+      ['z01', 't01'],
+      ['z03', 'a03'],
+      ['z05', 'c04'],
+      ['c06', 'z07'],
+    ]);
+    const originalOuts = gates.map(g => g.out);
+    findSwappedWires(gates);
+    const afterOuts = gates.map(g => g.out);
+    expect(afterOuts).toEqual(originalOuts);
+  });
+});
+
+function extractZ(wires: Record<string, number>, numBits: number): number {
+  let val = 0;
+  for (let i = 0; i < numBits; i++) {
+    const bit = wires[`z${String(i).padStart(2, '0')}`];
+    if (bit) val += (1 << i);
+  }
+  return val;
+}
+
+function makeCorrectAdder(numBits: number): Gate[] {
+  const gates: Gate[] = [];
+  const pad = (n: number) => String(n).padStart(2, '0');
+
+  // Bit 0: half adder
+  gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });
+  gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });
+
+  // Bits 1..numBits-1: full adders
+  for (let i = 1; i < numBits; i++) {
+    const p = pad(i);
+    const pp = pad(i - 1);
+    gates.push({ op: 'XOR', in1: `x${p}`, in2: `y${p}`, out: `t${p}` });
+    gates.push({ op: 'XOR', in1: `t${p}`, in2: `c${pp}`, out: `z${p}` });
+    gates.push({ op: 'AND', in1: `x${p}`, in2: `y${p}`, out: `a${p}` });
+    gates.push({ op: 'AND', in1: `t${p}`, in2: `c${pp}`, out: `b${p}` });
+    gates.push({ op: 'OR', in1: `a${p}`, in2: `b${p}`, out: `c${p}` });
+  }
+
+  // Last carry -> final z bit
+  const lastGate = gates.find(g => g.out === `c${pad(numBits - 1)}`);
+  if (lastGate) lastGate.out = `z${pad(numBits)}`;
+
+  return gates;
+}
+
+function makeSwappedAdder(
+  numBits: number,
+  swapPairs: [string, string][],
+): { gates: Gate[]; swappedWires: string[] } {
+  const gates = makeCorrectAdder(numBits);
+  const swappedWires: string[] = [];
+
+  for (const [wire1, wire2] of swapPairs) {
+    const g1 = gates.find(g => g.out === wire1);
+    const g2 = gates.find(g => g.out === wire2);
+    if (!g1 || !g2) {
+      throw new Error(`Cannot find gates for swap: ${wire1} <-> ${wire2}`);
+    }
+    g1.out = wire2;
+    g2.out = wire1;
+    swappedWires.push(wire1, wire2);
+  }
+
+  return { gates, swappedWires };
+}
