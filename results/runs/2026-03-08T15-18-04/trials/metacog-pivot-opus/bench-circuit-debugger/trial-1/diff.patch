1: 0, y02: 1, y03: 0,\n    };\n    const result = simulate(gates, inputs);\n    // 8 = 01000\n    expect(extractZ(result, 5)).toBe(8);\n  });\n\n  it('should simulate a 4-bit adder (15 + 15 = 30)', () => {\n    const gates = make4BitAdder();\n    const inputs: Record<string, number> = {\n      x00: 1, x01: 1, x02: 1, x03: 1,\n      y00: 1, y01: 1, y02: 1, y03: 1,\n    };\n    const result = simulate(gates, inputs);\n    // 30 = 11110\n    expect(extractZ(result, 5)).toBe(30);\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  it('should find swapped wires in a simple case', () => {\n    const gates = make4BitAdderWithSwaps();\n    const result = findSwappedWires(gates.gates);\n    expect(result).toEqual(gates.expectedSwapped.sort());\n  });\n\n  it('should find swapped wires in a larger circuit', () => {\n    const { gates, expectedSwapped } = make8BitAdderWithSwaps();\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(expectedSwapped.sort());\n  });\n});\n\n// Helper to extract the Z value from wire results\nfunction extractZ(wires: Record<string, number>, numBits: number): number {\n  let val = 0;\n  for (let i = 0; i < numBits; i++) {\n    const bit = wires[`z${String(i).padStart(2, '0')}`];\n    if (bit) val += (1 << i);\n  }\n  return val;\n}\n\n// Build a correct 4-bit adder\nfunction make4BitAdder(): Gate[] {\n  return [\n    { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n    { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n    { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n    { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n    { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n    { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n    { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n    { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n    { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n    { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n    { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n    { op