3\n    [5, 'a', 'b'],  // swap a05 and b05\n    [6, 'z', 'c'],  // swap z06 and c05 (carry from bit 5 to bit 6)\n  ]);\n}\n\nfunction make8BitAdderWithSwaps() {\n  return makeNBitAdderWithSwaps(10, [\n    [2, 'z', 'a'],  // swap z02 and a02\n    [4, 'z', 't'],  // swap z04 and t04\n    [6, 'a', 'b'],  // swap a06 and b06\n    [8, 'z', 'c'],  // swap z08 and c07 (carry from bit 7)\n  ]);\n}\n\ntype SwapSpec = [number, string, string]; // [bit, wireType1, wireType2]\n\nfunction makeNBitAdderWithSwaps(numBits: number, swaps: SwapSpec[]) {\n  // First build a correct adder\n  const wireNames: Record<string, string> = {};\n\n  function wireName(type: string, bit: number): string {\n    const key = `${type}${String(bit).padStart(2, '0')}`;\n    return wireNames[key] || key;\n  }\n\n  // Generate correct wire names\n  for (let i = 0; i <= numBits; i++) {\n    wireNames[`t${String(i).padStart(2, '0')}`] = `t${String(i).padStart(2, '0')}`;\n    wireNames[`a${String(i).padStart(2, '0')}`] = `a${String(i).padStart(2, '0')}`;\n    wireNames[`b${String(i).padStart(2, '0')}`] = `b${String(i).padStart(2, '0')}`;\n    wireNames[`c${String(i).padStart(2, '0')}`] = `c${String(i).padStart(2, '0')}`;\n    wireNames[`z${String(i).padStart(2, '0')}`] = `z${String(i).padStart(2, '0')}`;\n  }\n\n  const gates: Gate[] = [];\n\n  // Bit 0: half adder\n  gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });\n  gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });\n\n  // Bits 1..numBits-1: full adders\n  for (let i = 1; i < numBits; i++) {\n    const p = String(i).padStart(2, '0');\n    const pp = String(i - 1).padStart(2, '0');\n    gates.push({ op: 'XOR', in1: `x${p}`, in2: `y${p}`, out: `t${p}` });\n    gates.push({ op: 'XOR', in1: `t${p}`, in2: `c${pp}`, out: `z${p}` });\n    gates.push({ op: 'AND', in1: `x${p}`, in2: `y${p}`, out: `a${p}` });\n    gates.push({ op: 'AND', in1: `t${p}`, in2: `c${pp}`, out: `b${p}` });\n    gates.push({ op: 'OR', in1: `a${p}`, in2: `b${p}`