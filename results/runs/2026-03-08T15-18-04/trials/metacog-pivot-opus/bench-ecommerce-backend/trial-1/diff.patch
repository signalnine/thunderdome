_STOCK_ALERT when below threshold', async () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 10);\n    inventory.setLowStockThreshold('p1', 5);\n    inventory.setStock('p1', 3);\n    await new Promise(r => setTimeout(r, 10));\n    const log = bus.getLog();\n    const alerts = log.filter(e => e.event === Events.LOW_STOCK_ALERT);\n    expect(alerts.length).toBeGreaterThan(0);\n  });\n});\n\ndescribe('Cart Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should create a cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    expect(id).toBeDefined();\n  });\n\n  it('should add items to cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    const c = cart.getCart(id);\n    expect(c!.items).toHaveLength(1);\n    expect(c!.items[0]).toEqual({ productId: 'p1', quantity: 2 });\n  });\n\n  it('should consolidate same product items', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p1', 3);\n    const c = cart.getCart(id);\n    expect(c!.items).toHaveLength(1);\n    expect(c!.items[0].quantity).toBe(5);\n  });\n\n  it('should remove items from cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p2', 1);\n    cart.removeItem(id, 'p1');\n    const c = cart.getCart(id);\n    expect(c!.items).toHaveLength(1);\n    expect(c!.items[0].productId).toBe('p2');\n  });\n\n  it('should clear cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.clearCart(id);\n    const c = cart.getCart(id);\n    expect(c!.items).toHaveLength(0);\n  });\n\n  it('should update quantity', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.updateQuantity(id, 'p1', 10);\n    const c = cart.getCart(id);\n    expect(c!.items[0].quantity).toBe(10);\n  });\n\n  it('should return null for non-existent cart', () => {\n    const cart = createCartService(bus);\n    expect(cart.getCart('nonexistent')).toBeNull();\n  });\n});\n\ndescribe('Pricing Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should calculate total with tax', () => {\n    const pricing = createPricingService(bus);\n    const result = pricing.calculateTotal([\n      { productId: 'p1', quantity: 2, price: 10 },\n    ]);\n    expect(result.subtotal).toBe(20);\n    expect(result.discount).toBe(0);\n    expect(result.tax).toBe(2); // 10% of 20\n    expect(result.total).toBe(22);\n  });\n\n  it('should apply discount code before tax', () => {\n    const pricing = createPricingService(bus);\n    pricing.addDiscountCode('SAVE10', 10);\n    const result = pricing.calculateTotal([\n      { productId: 'p1', quantity: 1, price: 100 },\n    ], 'SAVE10');\n    expect(result.subtotal).toBe(100);\n    expect(result.discount).toBe(10); // 10% of 100\n    expect(result.tax).toBe(9); // 10% of (100-10)\n    expect(result.total).toBe(99); // 90 + 9\n  });\n\n  it('should ignore invalid discount code', () => {\n    const pricing = createPricingService(bus);\n    const result = pricing.calculateTotal([\n      { productId: 'p1', quantity: 1, price: 100 },\n    ], 'INVALID');\n    expect(result.discount).toBe(0);\n    expect(result.total).toBe(110);\n  });\n\n  it('should track product prices from events', async () => {\n    const pricing = createPricingService(bus);\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'Widget', price: 9.99, category: 'gadgets' });\n    expect(pricing.getPrice('p1')).toBe(9.99);\n  });\n\n  it('should return 0 for unknown product price', () => {\n    const pricing = createPricingService(bus);\n    expect(pricing.getPrice('unknown')).toBe(0);\n  });\n});\n\ndescribe('Order Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should create an order in PENDING status', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 99.99);\n    const order = orders.getOrder(id);\n    expect(order).not.toBeNull();\n    expect(order!.status).toBe(OrderStatus.PENDING);\n    expect(order!.total).toBe(99.99);\n  });\n\n  it('should update order status', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 99.99);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.CONFIRMED);\n  });\n\n  it('should track status lifecycle', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 99.99);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    orders.updateStatus(id, OrderStatus.SHIPPED);\n    orders.updateStatus(id, OrderStatus.DELIVERED);\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.DELIVERED);\n  });\n\n  it('should support cancellation', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 99.99);\n    orders.updateStatus(id, OrderStatus.CANCELLED);\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.CANCELLED);\n  });\n\n  it('should list orders for a user', () => {\n    const orders = createOrderService(bus);\n    orders.createOrder('user1', 'cart1', 10);\n    orders.createOrder('user1', 'cart2', 20);\n    orders.createOrder('user2', 'cart3', 30);\n    expect(orders.listOrders('user1')).toHaveLength(2);\n    expect(orders.listOrders('user2')).toHaveLength(1);\n  });\n\n  it('should emit ORDER_CREATED and ORDER_STATUS_CHANGED events', async () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 99.99);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    await new Promise(r => setTimeout(r, 10));\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.ORDER_CREATED)).toBe(true);\n    const statusEvents = log.filter(e => e.event === Events.ORDER_STATUS_CHANGED);\n    expect(statusEvents).toHaveLength(1);\n    expect(statusEvents[0].payload).toMatchObject({\n      orderId: id,\n      status: OrderStatus.CONFIRMED,\n      previousStatus: OrderStatus.PENDING,\n    });\n  });\n});\n\ndescribe('Payment Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should process payment successfully by default', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 99.99);\n    expect(result.status).toBe(PaymentStatus.SUCCESS);\n    expect(result.transactionId).toBeDefined();\n  });\n\n  it('should simulate failure', async () => {\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const result = await payment.processPayment('order1', 99.99);\n    expect(result.status).toBe(PaymentStatus.FAILED);\n    expect(result.error).toBeDefined();\n  });\n\n  it('should simulate timeout', async () => {\n    const payment = createPaymentService(bus, { simulateTimeout: true });\n    const result = await payment.processPayment('order1', 99.99);\n    expect(result.status).toBe(PaymentStatus.TIMEOUT);\n    expect(result.error).toBeDefined();\n  });\n\n  it('should refund a successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 99.99);\n    const refunded = await payment.refund(result.transactionId!);\n    expect(refunded).toBe(true);\n  });\n\n  it('should fail to refund non-existent transaction', async () => {\n    const payment = createPaymentService(bus);\n    const refunded = await payment.refund('nonexistent');\n    expect(refunded).toBe(false);\n  });\n\n  it('should emit PAYMENT_PROCESSED event', async () => {\n    const payment = createPaymentService(bus);\n    await payment.processPayment('order1', 99.99);\n    const log = bus.getLog();\n    const payEvents = log.filter(e => e.event === Events.PAYMENT_PROCESSED);\n    expect(payEvents).toHaveLength(1);\n  });\n});\n\ndescribe('Notification Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should only deliver notifications to subscribed users', async () => {\n    const notifications = createNotificationService(bus);\n    // Don't subscribe user1\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n    expect(notifications.getNotifications('user1')).toHaveLength(0);\n\n    // Now subscribe and emit\n    notifications.subscribe('user1');\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o2', userId: 'user1', cartId: 'c2', total: 200 });\n    expect(notifications.getNotifications('user1').length).toBeGreaterThan(0);\n  });\n\n  it('should track order-user mapping for status changes', async () => {\n    const notifications = createNotificationService(bus);\n    notifications.subscribe('user1');\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.ORDER_STATUS_CHANGED, { orderId: 'o1', status: OrderStatus.CONFIRMED, previousStatus: OrderStatus.PENDING });\n    const notes = notifications.getNotifications('user1');\n    expect(notes.length).toBe(2); // one for creation, one for status change\n  });\n\n  it('should send payment notifications', async () => {\n    const notifications = createNotificationService(bus);\n    notifications.subscribe('user1');\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 'tx1' });\n    const notes = notifications.getNotifications('user1');\n    expect(notes.some(n => n.type === 'payment')).toBe(true);\n  });\n});\n\ndescribe('Analytics Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should count events by type', async () => {\n    const analytics = createAnalyticsService(bus);\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'Widget', price: 10, category: 'gadgets' });\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p2', name: 'Gizmo', price: 20, category: 'gadgets' });\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n  });\n\n  it('should track revenue from successful payments', async () => {\n    const analytics = createAnalyticsService(bus);\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 'tx1' });\n    expect(analytics.getRevenue()).toBe(100);\n  });\n\n  it('should not count failed payments as revenue', async () => {\n    const analytics = createAnalyticsService(bus);\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.FAILED, error: 'declined' });\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  it('should calculate conversion rate', async () => {\n    const analytics = createAnalyticsService(bus);\n    // Create 2 carts\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [] });\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c2', userId: 'u2', items: [] });\n    // Create 1 order\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    expect(analytics.getConversionRate()).toBe(0.5); // 1 order / 2 carts\n  });\n\n  it('should return 0 conversion rate with no carts', () => {\n    const analytics = createAnalyticsService(bus);\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n\n  it('should rank top products by order quantity', async () => {\n    const analytics = createAnalyticsService(bus);\n    // Cart with items\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [\n      { productId: 'p1', quantity: 3 },\n      { productId: 'p2', quantity: 1 },\n    ]});\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c2', userId: 'u2', items: [\n      { productId: 'p1', quantity: 2 },\n      { productId: 'p3', quantity: 5 },\n    ]});\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o2', userId: 'u2', cartId: 'c2', total: 200 });\n\n    const top = analytics.getTopProducts(2);\n    expect(top).toHaveLength(2);\n    // p1: 3+2=5, p3: 5, p2: 1\n    expect(top[0].productId).toBe('p1');\n    expect(top[0].count).toBe(5);\n    expect(top[1].productId).toBe('p3');\n    expect(top[1].count).toBe(5);\n  });\n});\n\ndescribe('Integration: Full Purchase Flow', () => {\n  it('should complete end-to-end purchase', async () => {\n    const bus = new EventBus();\n\n    // Create services (order matters for event listeners)\n    const analytics = createAnalyticsService(bus);\n    const notifications = createNotificationService(bus);\n    const pricing = createPricingService(bus);\n    const catalog = createCatalogService(bus);\n    const inventory = createInventoryService(bus);\n    const cart = createCartService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n\n    // Subscribe user\n    notifications.subscribe('user1');\n\n    // Create products\n    const p1 = catalog.createProduct('Widget', 10, 'gadgets');\n    const p2 = catalog.createProduct('Gizmo', 20, 'gadgets');\n\n    // Wait for events to propagate\n    await new Promise(r => setTimeout(r, 10));\n\n    // Set inventory\n    inventory.setStock(p1, 100);\n    inventory.setStock(p2, 50);\n\n    // Verify pricing tracks products\n    expect(pricing.getPrice(p1)).toBe(10);\n    expect(pricing.getPrice(p2)).toBe(20);\n\n    // Create cart and add items\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, p1, 2);\n    cart.addItem(cartId, p2, 1);\n\n    // Calculate total\n    const cartData = cart.getCart(cartId)!;\n    const items = cartData.items.map(i => ({\n      productId: i.productId,\n      quantity: i.quantity,\n      price: pricing.getPrice(i.productId),\n    }));\n    const total = pricing.calculateTotal(items);\n    expect(total.subtotal).toBe(40); // 2*10 + 1*20\n    expect(total.tax).toBe(4); // 10% of 40\n    expect(total.total).toBe(44);\n\n    // Reserve inventory\n    expect(inventory.reserve(p1, 2)).toBe(true);\n    expect(inventory.reserve(p2, 1)).toBe(true);\n\n    // Create order\n    const orderId = orders.createOrder('user1', cartId, total.total);\n\n    // Wait for events\n    await new Promise(r => setTimeout(r, 10));\n\n    // Process payment\n    const payResult = await payment.processPayment(orderId, total.total);\n    expect(payResult.status).toBe(PaymentStatus.SUCCESS);\n\n    // Update order status\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    orders.updateStatus(orderId, OrderStatus.SHIPPED);\n    orders.updateStatus(orderId, OrderStatus.DELIVERED);\n\n    // Wait for events\n    await new Promise(r => setTimeout(r, 10));\n\n    // Verify analytics\n    expect(analytics.getRevenue()).toBe(44);\n    expect(analytics.getConversionRate()).toBeGreaterThan(0);\n\n    // Verify notifications\n    const notes = notifications.getNotifications('user1');\n    expect(notes.length).toBeGreaterThan(0);\n\n    // Verify order\n    const order = orders.getOrder(orderId);\n    expect(order!.status).toBe(OrderStatus.DELIVERED);\n  });\n});\n","structuredPatch":[],"originalFile":null}}
