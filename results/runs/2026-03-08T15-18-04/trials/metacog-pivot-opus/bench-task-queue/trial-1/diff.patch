+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XrZvan7eENdJffmjZh6HA4","type":"tool_result","content":"The file /workspace/src/task-queue.test.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"8f27f16f-0c55-4db4-b21c-91af69c44b8f","uuid":"9f39d157-bda6-47f7-9229-7011c9104525","tool_use_result":{"filePath":"/workspace/src/task-queue.test.ts","oldString":"import { describe, it, expect, vi, beforeEach } from 'vitest';","newString":"import { describe, it, expect, beforeEach } from 'vitest';","originalFile":"import { describe, it, expect, vi, beforeEach } from 'vitest';\nimport { TaskQueue, Task } from './index.js';\n\ndescribe('Phase 1: Basic FIFO Queue', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  it('should add a task and return a task object', () => {\n    const task = tq.addTask({ message: 'hello' });\n    expect(task).toBeInstanceOf(Task);\n    expect(task.id).toBeDefined();\n    expect(task.status).toBe('pending');\n    expect(task.createdAt).toBeInstanceOf(Date);\n    expect(task.payload).toEqual({ message: 'hello' });\n  });\n\n  it('should generate unique IDs for each task', () => {\n    const t1 = tq.addTask('a');\n    const t2 = tq.addTask('b');\n    expect(t1.id).not.toBe(t2.id);\n  });\n\n  it('should retrieve tasks in FIFO order', () => {\n    const t1 = tq.addTask('first');\n    const t2 = tq.addTask('second');\n    const t3 = tq.addTask('third');\n\n    const r1 = tq.getNextTask();\n    expect(r1?.id).toBe(t1.id);\n    expect(r1?.status).toBe('processing');\n\n    const r2 = tq.getNextTask();\n    expect(r2?.id).toBe(t2.id);\n\n    const r3 = tq.getNextTask();\n    expect(r3?.id).toBe(t3.id);\n  });\n\n  it('should return null when no tasks available', () => {\n    expect(tq.getNextTask()).toBeNull();\n  });\n\n  it('should report pending count', () => {\n    expect(tq.pendingCount()).toBe(0);\n    tq.addTask('a');\n    tq.addTask('b');\n    expect(tq.pendingCount()).toBe(2);\n    tq.getNextTask();\n    expect(tq.pendingCount()).toBe(1);\n  });\n});\n\ndescribe('Phase 2: Named Queues', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  it('should add tasks to a named queue', () => {\n    const t1 = tq.addTask('a', 'emails');\n    expect(t1.queue).toBe('emails');\n  });\n\n  it('should use default queue when no name given', () => {\n    const t = tq.addTask('a');\n    expect(t.queue).toBe('default');\n  });\n\n  it('should keep named queues independent', () => {\n    tq.addTask('email1', 'emails');\n    tq.addTask('sms1', 'sms');\n\n    expect(tq.pendingCount('emails')).toBe(1);\n    expect(tq.pendingCount('sms')).toBe(1);\n\n    const e = tq.getNextTask('emails');\n    expect(e?.payload).toBe('email1');\n    expect(tq.pendingCount('emails')).toBe(0);\n    expect(tq.pendingCount('sms')).toBe(1);\n  });\n\n  it('should list queue names', () => {\n    tq.addTask('a', 'q1');\n    tq.addTask('b', 'q2');\n    const names = tq.getQueueNames();\n    expect(names).toContain('q1');\n    expect(names).toContain('q2');\n  });\n\n  it('should return null for non-existent queue', () => {\n    expect(tq.getNextTask('nonexistent')).toBeNull();\n  });\n\n  it('should be backward-compatible with Phase 1 API', () => {\n    tq.addTask('x');\n    const t = tq.getNextTask();\n    expect(t?.payload).toBe('x');\n  });\n});\n\ndescribe('Phase 3: Priority', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  it('should default to priority 5', () => {\n    const t = tq.addTask('a');\n    expect(t.priority).toBe(5);\n  });\n\n  it('should accept custom priority', () => {\n    const t = tq.addTask('a', { priority: 1 });\n    expect(t.priority).toBe(1);\n  });\n\n  it('should reject invalid priority', () => {\n    expect(() => tq.addTask('a', { priority: 0 })).toThrow();\n    expect(() => tq.addTask('a', { priority: 11 })).toThrow();\n    expect(() => tq.addTask('a', { priority: 1.5 })).toThrow();\n  });\n\n  it('should return higher-priority tasks first', () => {\n    tq.addTask('low', { priority: 10 });\n    tq.addTask('high', { priority: 1 });\n    tq.addTask('medium', { priority: 5 });\n\n    expect(tq.getNextTask()?.payload).toBe('high');\n    expect(tq.getNextTask()?.payload).toBe('medium');\n    expect(tq.getNextTask()?.payload).toBe('low');\n  });\n\n  it('should use FIFO order for same priority', () => {\n    tq.addTask('first', { priority: 3 });\n    tq.addTask('second', { priority: 3 });\n\n    expect(tq.getNextTask()?.payload).toBe('first');\n    expect(tq.getNextTask()?.payload).toBe('second');\n  });\n\n  it('should handle priority per queue', () => {\n    tq.addTask('low', 'q1', { priority: 10 });\n    tq.addTask('high', 'q1', { priority: 1 });\n    tq.addTask('other', 'q2', { priority: 5 });\n\n    expect(tq.getNextTask('q1')?.payload).toBe('high');\n    expect(tq.getNextTask('q2')?.payload).toBe('other');\n  });\n});\n\ndescribe('Phase 4: Delayed and Scheduled Tasks', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  it('should delay a task by milliseconds', () => {\n    const t = tq.addTask('delayed', { delay: 100000 });\n    expect(t.availableAt.getTime()).toBeGreaterThan(Date.now());\n    expect(tq.getNextTask()).toBeNull();\n  });\n\n  it('should make delayed task available after time passes', () => {\n    const t = tq.addTask('delayed', { delay: 1 });\n    // Manually set availableAt to past\n    t.availableAt = new Date(Date.now() - 1);\n    const next = tq.getNextTask();\n    expect(next?.id).toBe(t.id);\n  });\n\n  it('should accept a processAt date', () => {\n    const future = new Date(Date.now() + 100000);\n    const t = tq.addTask('scheduled', { processAt: future });\n    expect(t.availableAt.getTime()).toBe(future.getTime());\n  });\n\n  it('should prefer non-delayed tasks over not-yet-available delayed tasks', () => {\n    tq.addTask('delayed', { delay: 100000, priority: 1 });\n    tq.addTask('immediate', { priority: 5 });\n\n    const next = tq.getNextTask();\n    expect(next?.payload).toBe('immediate');\n  });\n\n  it('should order delayed tasks by availability time, then priority, then FIFO', () => {\n    const t1 = tq.addTask('later', { priority: 1 });\n    const t2 = tq.addTask('earlier', { priority: 1 });\n\n    // Make both available but t2 available earlier\n    t1.availableAt = new Date(Date.now() - 100);\n    t2.availableAt = new Date(Date.now() - 200);\n\n    expect(tq.getNextTask()?.payload).toBe('earlier');\n    expect(tq.getNextTask()?.payload).toBe('later');\n  });\n});\n\ndescribe('Phase 5: Retry with Backoff', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  it('should complete a task successfully', () => {\n    const t = tq.addTask('x');\n    tq.getNextTask();\n    tq.completeTask(t.id);\n    expect(t.status).toBe('completed');\n  });\n\n  it('should retry a failed task with backoff', () => {\n    const t = tq.addTask('x', { maxRetries: 3, backoffDelay: 100 });\n    tq.getNextTask(); // attempt 1\n    tq.failTask(t.id, new Error('oops'));\n\n    // Task should be back to pending with a delay\n    expect(t.status).toBe('pending');\n    expect(t.attempt).toBe(1);\n    expect(t.failCount).toBe(1);\n    expect(t.availableAt.getTime()).toBeGreaterThan(Date.now() - 1);\n  });\n\n  it('should increase backoff delay exponentially', () => {\n    const t = tq.addTask('x', { maxRetries: 5, backoffDelay: 1000 });\n\n    // Attempt 1\n    tq.getNextTask();\n    const before1 = Date.now();\n    tq.failTask(t.id, new Error('fail'));\n    const delay1 = t.availableAt.getTime() - before1;\n    expect(delay1).toBeGreaterThanOrEqual(900); // ~1000ms\n\n    // Make available again\n    t.availableAt = new Date(Date.now() - 1);\n\n    // Attempt 2\n    tq.getNextTask();\n    const before2 = Date.now();\n    tq.failTask(t.id, new Error('fail'));\n    const delay2 = t.availableAt.getTime() - before2;\n    expect(delay2).toBeGreaterThanOrEqual(1900); // ~2000ms\n  });\n\n  it('should track attempt count', () => {\n    const t = tq.addTask('x', { maxRetries: 3 });\n\n    tq.getNextTask();\n    expect(t.attempt).toBe(1);\n    tq.failTask(t.id, new Error('fail'));\n\n    t.availableAt = new Date(Date.now() - 1);\n    tq.getNextTask();\n    expect(t.attempt).toBe(2);\n  });\n\n  it('should default maxRetries to 3', () => {\n    const t = tq.addTask('x');\n    expect(t.maxRetries).toBe(3);\n  });\n\n  it('should default backoffDelay to 1000', () => {\n    const t = tq.addTask('x');\n    expect(t.backoffDelay).toBe(1000);\n  });\n});\n\ndescribe('Phase 6: Dead Letter Queue', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  it('should move task to DLQ after exhausting retries', () => {\n    const t = tq.addTask('x', { maxRetries: 1 });\n\n    tq.getNextTask();\n    tq.failTask(t.id, new Error('fail'));\n\n    const dlq = tq.getDeadLetterTasks();\n    expect(dlq).toHaveLength(1);\n    expect(dlq[0].id).toBe(t.id);\n    expect(dlq[0].status).toBe('failed');\n    expect(dlq[0].error?.message).toBe('fail');\n    expect(dlq[0].failCount).toBe(1);\n  });\n\n  it('should support per-queue dead letter queues', () => {\n    const t1 = tq.addTask('a', 'q1', { maxRetries: 1 });\n    const t2 = tq.addTask('b', 'q2', { maxRetries: 1 });\n\n    tq.getNextTask('q1');\n    tq.failTask(t1.id, new Error('fail'));\n\n    tq.getNextTask('q2');\n    tq.failTask(t2.id, new Error('fail'));\n\n    expect(tq.getDeadLetterTasks('q1')).toHaveLength(1);\n    expect(tq.getDeadLetterTasks('q2')).toHaveLength(1);\n  });\n\n  it('should retry a dead-lettered task', () => {\n    const t = tq.addTask('x', { maxRetries: 1 });\n    tq.getNextTask();\n    tq.failTask(t.id, new Error('fail'));\n\n    const retried = tq.retryDeadLetterTask(t.id);\n    expect(retried).not.toBeNull();\n    expect(retried?.status).toBe('pending');\n    expect(retried?.attempt).toBe(0);\n\n    const next = tq.getNextTask();\n    expect(next?.id).toBe(t.id);\n  });\n\n  it('should clear dead letter queue', () => {\n    const t = tq.addTask('x', { maxRetries: 1 });\n    tq.getNextTask();\n    tq.failTask(t.id, new Error('fail'));\n\n    const cleared = tq.clearDeadLetterQueue();\n    expect(cleared).toBe(1);\n    expect(tq.getDeadLetterTasks()).toHaveLength(0);\n  });\n});\n\ndescribe('Phase 7: Task Dependencies', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  it('should block tasks with unresolved dependencies', () => {\n    const t1 = tq.addTask('dep');\n    const t2 = tq.addTask('dependent', { dependsOn: [t1.id] });\n\n    // t2 should not be available yet\n    const next = tq.getNextTask();\n    expect(next?.id).toBe(t1.id);\n\n    // t2 still blocked\n    expect(tq.getNextTask()).toBeNull();\n  });\n\n  it('should unblock tasks when dependencies complete', () => {\n    const t1 = tq.addTask('dep');\n    const t2 = tq.addTask('dependent', { dependsOn: [t1.id] });\n\n    tq.getNextTask(); // get t1\n    tq.completeTask(t1.id);\n\n    const next = tq.getNextTask();\n    expect(next?.id).toBe(t2.id);\n  });\n\n  it('should reject non-existent dependencies', () => {\n    expect(() => tq.addTask('x', { dependsOn: ['nonexistent'] })).toThrow(\n      'Dependency task nonexistent does not exist'\n    );\n  });\n\n  it('should detect circular dependencies', () => {\n    const t1 = tq.addTask('a');\n    const t2 = tq.addTask('b', { dependsOn: [t1.id] });\n\n    expect(() => tq.addTask('c', { dependsOn: [t2.id, t1.id] })).not.toThrow();\n\n    // But creating a cycle should throw\n    // t1 depends on nothing, t2 depends on t1\n    // Adding t3 that depends on t2 is fine\n    const t3 = tq.addTask('c', { dependsOn: [t2.id] });\n    expect(t3).toBeDefined();\n  });\n\n  it('should expose dependency status', () => {\n    const t1 = tq.addTask('a');\n    const t2 = tq.addTask('b');\n    const t3 = tq.addTask('c', { dependsOn: [t1.id, t2.id] });\n\n    const status = tq.getDependencyStatus(t3.id);\n    expect(status?.total).toBe(2);\n    expect(status?.resolved).toBe(0);\n    expect(status?.pending).toContain(t1.id);\n    expect(status?.pending).toContain(t2.id);\n\n    tq.getNextTask();\n    tq.completeTask(t1.id);\n\n    const status2 = tq.getDependencyStatus(t3.id);\n    expect(status2?.resolved).toBe(1);\n    expect(status2?.pending).toHaveLength(1);\n  });\n\n  it('should not auto-fail dependents when dependency fails', () => {\n    const t1 = tq.addTask('a', { maxRetries: 1 });\n    const _t2 = tq.addTask('b', { dependsOn: [t1.id] });\n\n    tq.getNextTask();\n    tq.failTask(t1.id, new Error('fail'));\n\n    // t2 should remain pending (blocked), not failed\n    expect(_t2.status).toBe('pending');\n  });\n});\n\ndescribe('Phase 8: Concurrency Control', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  it('should limit concurrent processing', () => {\n    tq.setConcurrency('default', 2);\n    tq.addTask('a');\n    tq.addTask('b');\n    tq.addTask('c');\n\n    expect(tq.getNextTask()).not.toBeNull();\n    expect(tq.getNextTask()).not.toBeNull();\n    expect(tq.getNextTask()).toBeNull(); // limited by concurrency\n  });\n\n  it('should free slots when tasks complete', () => {\n    tq.setConcurrency('default', 1);\n    const t1 = tq.addTask('a');\n    tq.addTask('b');\n\n    tq.getNextTask(); // t1\n    expect(tq.getNextTask()).toBeNull();\n\n    tq.completeTask(t1.id);\n    expect(tq.getNextTask()).not.toBeNull();\n  });\n\n  it('should default to unlimited concurrency', () => {\n    const info = tq.getConcurrency();\n    expect(info.limit).toBeNull();\n  });\n\n  it('should report concurrency info', () => {\n    tq.setConcurrency('default', 5);\n    tq.addTask('a');\n    tq.getNextTask();\n\n    const info = tq.getConcurrency();\n    expect(info.limit).toBe(5);\n    expect(info.active).toBe(1);\n  });\n\n  it('should still respect priority with concurrency', () => {\n    tq.setConcurrency('default', 1);\n    tq.addTask('low', { priority: 10 });\n    tq.addTask('high', { priority: 1 });\n\n    const next = tq.getNextTask();\n    expect(next?.payload).toBe('high');\n  });\n});\n\ndescribe('Phase 9: Progress Tracking and Cancellation', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  it('should report progress on processing tasks', () => {\n    const t = tq.addTask('x');\n    tq.getNextTask();\n    tq.reportProgress(t.id, 50, 'halfway');\n\n    expect(t.progress).toBe(50);\n    expect(t.progressMessage).toBe('halfway');\n  });\n\n  it('should clamp progress to 0-100', () => {\n    const t = tq.addTask('x');\n    tq.getNextTask();\n    tq.reportProgress(t.id, 150);\n    expect(t.progress).toBe(100);\n\n    tq.reportProgress(t.id, -10);\n    expect(t.progress).toBe(0);\n  });\n\n  it('should notify progress listeners', () => {\n    const t = tq.addTask('x');\n    tq.getNextTask();\n\n    const updates: Array<{ progress: number; message?: string }> = [];\n    tq.onProgress(t.id, (p, m) => updates.push({ progress: p, message: m }));\n\n    tq.reportProgress(t.id, 25, 'quarter');\n    tq.reportProgress(t.id, 75, 'three-quarters');\n\n    expect(updates).toHaveLength(2);\n    expect(updates[0]).toEqual({ progress: 25, message: 'quarter' });\n    expect(updates[1]).toEqual({ progress: 75, message: 'three-quarters' });\n  });\n\n  it('should support unsubscribing from progress', () => {\n    const t = tq.addTask('x');\n    tq.getNextTask();\n\n    let callCount = 0;\n    const unsub = tq.onProgress(t.id, () => callCount++);\n\n    tq.reportProgress(t.id, 50);\n    unsub();\n    tq.reportProgress(t.id, 100);\n\n    expect(callCount).toBe(1);\n  });\n\n  it('should cancel pending tasks', () => {\n    const t = tq.addTask('x');\n    const cancelled = tq.cancelTask(t.id);\n\n    expect(cancelled).toBe(true);\n    expect(t.status).toBe('cancelled');\n    expect(tq.getNextTask()).toBeNull();\n  });\n\n  it('should cancel processing tasks', () => {\n    const t = tq.addTask('x');\n    tq.getNextTask();\n    const cancelled = tq.cancelTask(t.id);\n\n    expect(cancelled).toBe(true);\n    expect(t.status).toBe('cancelled');\n  });\n\n  it('should not cancel completed tasks', () => {\n    const t = tq.addTask('x');\n    tq.getNextTask();\n    tq.completeTask(t.id);\n\n    expect(tq.cancelTask(t.id)).toBe(false);\n  });\n\n  it('should not retry cancelled tasks', () => {\n    const t = tq.addTask('x', { maxRetries: 3 });\n    tq.getNextTask();\n    tq.cancelTask(t.id);\n\n    expect(t.status).toBe('cancelled');\n    // Should not be retriable\n    expect(tq.getNextTask()).toBeNull();\n  });\n});\n\ndescribe('Phase 10: Recurring Tasks', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  it('should create a schedule', () => {\n    const id = tq.addSchedule('*/5 * * * *', { type: 'cleanup' });\n    expect(id).toBeDefined();\n    expect(tq.getSchedules()).toHaveLength(1);\n  });\n\n  it('should enqueue tasks on tick when schedule is due', () => {\n    tq.addSchedule('0 * * * *', { type: 'hourly' });\n\n    // Tick at the top of the hour\n    const topOfHour = new Date();\n    topOfHour.setMinutes(0, 0, 0);\n\n    const created = tq.tick(topOfHour);\n    expect(created).toHaveLength(1);\n    expect(created[0].payload).toEqual({ type: 'hourly' });\n  });\n\n  it('should not enqueue when not due', () => {\n    tq.addSchedule('0 * * * *', { type: 'hourly' });\n\n    const notTopOfHour = new Date();\n    notTopOfHour.setMinutes(30, 0, 0);\n\n    const created = tq.tick(notTopOfHour);\n    expect(created).toHaveLength(0);\n  });\n\n  it('should not run same schedule twice in same minute', () => {\n    tq.addSchedule('*/5 * * * *', { type: 'periodic' });\n\n    const time = new Date();\n    time.setMinutes(10, 0, 0);\n\n    tq.tick(time);\n    const second = tq.tick(time);\n    expect(second).toHaveLength(0);\n  });\n\n  it('should remove a schedule', () => {\n    const id = tq.addSchedule('*/1 * * * *', { type: 'every-min' });\n    expect(tq.removeSchedule(id)).toBe(true);\n    expect(tq.getSchedules()).toHaveLength(0);\n  });\n\n  it('should list active schedules', () => {\n    tq.addSchedule('*/5 * * * *', { type: 'a' });\n    tq.addSchedule('0 0 * * *', { type: 'b' });\n    expect(tq.getSchedules()).toHaveLength(2);\n  });\n});\n\ndescribe('Phase 11: Middleware Pipeline', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  it('should run middleware in order', async () => {\n    const order: string[] = [];\n\n    tq.use('default', async (_task, next) => {\n      order.push('mw1-before');\n      await next();\n      order.push('mw1-after');\n    });\n\n    tq.use('default', async (_task, next) => {\n      order.push('mw2-before');\n      await next();\n      order.push('mw2-after');\n    });\n\n    tq.setHandler('default', async () => {\n      order.push('handler');\n    });\n\n    const t = tq.addTask('x');\n    tq.getNextTask();\n    await tq.processTask(t.id);\n\n    expect(order).toEqual(['mw1-before', 'mw2-before', 'handler', 'mw2-after', 'mw1-after']);\n  });\n\n  it('should skip handler if middleware does not call next', async () => {\n    let handlerCalled = false;\n\n    tq.use('default', async () => {\n      // Not calling next\n    });\n\n    tq.setHandler('default', async () => {\n      handlerCalled = true;\n    });\n\n    const t = tq.addTask('x');\n    tq.getNextTask();\n    await tq.processTask(t.id);\n\n    expect(handlerCalled).toBe(false);\n  });\n\n  it('should allow middleware to modify task', async () => {\n    tq.use('default', async (task, next) => {\n      (task as Record<string, unknown>).metadata = { processed: true };\n      await next();\n    });\n\n    let receivedTask: Record<string, unknown> | null = null;\n    tq.setHandler('default', async (task) => {\n      receivedTask = task as Record<string, unknown>;\n    });\n\n    const t = tq.addTask('x');\n    tq.getNextTask();\n    await tq.processTask(t.id);\n\n    expect(receivedTask?.metadata).toEqual({ processed: true });\n  });\n\n  it('should fail task if middleware throws', async () => {\n    tq.use('default', async () => {\n      throw new Error('middleware error');\n    });\n\n    const t = tq.addTask('x', { maxRetries: 1 });\n    tq.getNextTask();\n\n    await expect(tq.processTask(t.id)).rejects.toThrow('middleware error');\n  });\n\n  it('should have independent middleware per queue', async () => {\n    const q1Calls: string[] = [];\n    const q2Calls: string[] = [];\n\n    tq.use('q1', async (_task, next) => {\n      q1Calls.push('q1-mw');\n      await next();\n    });\n\n    tq.use('q2', async (_task, next) => {\n      q2Calls.push('q2-mw');\n      await next();\n    });\n\n    tq.setHandler('q1', async () => { q1Calls.push('q1-handler'); });\n    tq.setHandler('q2', async () => { q2Calls.push('q2-handler'); });\n\n    const t1 = tq.addTask('a', 'q1');\n    const t2 = tq.addTask('b', 'q2');\n\n    tq.getNextTask('q1');\n    tq.getNextTask('q2');\n\n    await tq.processTask(t1.id);\n    await tq.processTask(t2.id);\n\n    expect(q1Calls).toEqual(['q1-mw', 'q1-handler']);\n    expect(q2Calls).toEqual(['q2-mw', 'q2-handler']);\n  });\n});\n\ndescribe('Phase 12: Graceful Shutdown', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  it('should reject new tasks after shutdown', async () => {\n    await tq.shutdown();\n    expect(() => tq.addTask('x')).toThrow('shut down');\n  });\n\n  it('should complete immediately with no processing tasks', async () => {\n    const summary = await tq.shutdown();\n    expect(summary.completed).toBe(0);\n    expect(summary.forceCancelled).toBe(0);\n    expect(summary.durationMs).toBeGreaterThanOrEqual(0);\n  });\n\n  it('should wait for processing tasks to complete', async () => {\n    const t = tq.addTask('x');\n    tq.getNextTask();\n\n    // Complete the task after a short delay\n    setTimeout(() => tq.completeTask(t.id), 50);\n\n    const summary = await tq.shutdown({ timeout: 5000 });\n    expect(summary.completed).toBe(1);\n    expect(summary.forceCancelled).toBe(0);\n  });\n\n  it('should force-cancel tasks after timeout', async () => {\n    const t = tq.addTask('x');\n    tq.getNextTask();\n    // Don't complete it\n\n    const summary = await tq.shutdown({ timeout: 50 });\n    expect(summary.forceCancelled).toBe(1);\n    expect(t.status).toBe('cancelled');\n  });\n\n  it('should return same result for multiple shutdown calls', async () => {\n    const s1 = tq.shutdown();\n    const s2 = tq.shutdown();\n    expect(await s1).toBe(await s2);\n  });\n\n  it('should run shutdown callbacks', async () => {\n    let called = false;\n    tq.onShutdown(() => {\n      called = true;\n    });\n\n    await tq.shutdown();\n    expect(called).toBe(true);\n  });\n\n  it('should report shutdown duration', async () => {\n    const summary = await tq.shutdown();\n    expect(typeof summary.durationMs).toBe('number');\n  });\n});\n","structuredPatch":[{"oldStart":1,"oldLines":4,"newStart":1,"newLines":4,"lines":["-import { describe, it, expect, vi, beforeEach } from 'vitest';","+import { describe, it, expect, beforeEach } from 'vitest';"," import { TaskQueue, Task } from './index.js';"," "," describe('Phase 1: Basic FIFO Queue', () => {"]}],"userModified":false,"replaceAll":false}}
