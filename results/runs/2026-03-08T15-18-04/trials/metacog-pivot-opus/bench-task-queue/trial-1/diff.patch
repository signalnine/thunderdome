+import { Task } from './task.js';
+import type { TaskOptions, MiddlewareFn, TaskHandler } from './types.js';
+
+export class Queue {
+  readonly name: string;
+  private tasks: Map<string, Task> = new Map();
+  private deadLetterTasks: Map<string, Task> = new Map();
+  private concurrencyLimit: number | null = null;
+  private middlewares: MiddlewareFn[] = [];
+  private handler: TaskHandler | null = null;
+
+  constructor(name: string) {
+    this.name = name;
+  }
+
+  addTask(payload: unknown, options: TaskOptions = {}): Task {
+    const task = new Task(payload, this.name, options);
+    this.tasks.set(task.id, task);
+    return task;
+  }
+
+  addExistingTask(task: Task): void {
+    this.tasks.set(task.id, task);
+  }
+
+  getTask(id: string): Task | undefined {
+    return this.tasks.get(id);
+  }
+
+  getNextTask(): Task | null {
+    // Check concurrency limit
+    if (this.concurrencyLimit !== null) {
+      const activeCount = this.getActiveCount();
+      if (activeCount >= this.concurrencyLimit) {
+        return null;
+      }
+    }
+
+    // Find the best ready task: highest priority (lowest number), then earliest createdAt
+    let best: Task | null = null;
+
+    for (const task of this.tasks.values()) {
+      if (!task.isReady()) continue;
+
+      if (
+        best === null ||
+        task.priority < best.priority ||
+        (task.priority === best.priority &&
+          task.availableAt.getTime() < best.availableAt.getTime()) ||
+        (task.priority === best.priority &&
+          task.availableAt.getTime() === best.availableAt.getTime() &&
+          task.createdAt.getTime() < best.createdAt.getTime())
+      ) {
+        best = task;
+      }
+    }
+
+    if (best) {
+      best.transitionTo('processing');
+      best.attempt++;
+    }
+
+    return best;
+  }
+
+  pendingCount(): number {
+    let count = 0;
+    for (const task of this.tasks.values()) {
+      if (task.status === 'pending') {
+        count++;
+      }
+    }
+    return count;
+  }
+
+  completeTask(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task ${taskId} not found`);
+    }
+    if (task.status !== 'processing') {
+      throw new Error(`Task ${taskId} is not in processing state`);
+    }
+    task.transitionTo('completed');
+  }
+
+  failTask(taskId: string, error?: Error): void {
+    const task = this.tasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task ${taskId} not found`);
+    }
+    if (task.status !== 'processing') {
+      throw new Error(`Task ${taskId} is not in processing state`);
+    }
+
+    task.failCount++;
+    task.error = error;
+
+    if (task.attempt < task.maxRetries) {
+      // Retry with backoff
+      task.scheduleRetry();
+    } else {
+      // Exhausted retries -> fail permanently
+      task.transitionTo('failed');
+      // Move to dead letter queue
+      this.tasks.delete(taskId);
+      this.deadLetterTasks.set(taskId, task);
+    }
+  }
+
+  cancelTask(taskId: string): boolean {
+    const task = this.tasks.get(taskId);
+    if (!task) return false;
+    if (task.status !== 'pending' && task.status !== 'processing') return false;
+
+    task.transitionTo('cancelled');
+    return true;
+  }
+
+  getDeadLetterTasks(): Task[] {
+    return Array.from(this.deadLetterTasks.values());
+  }
+
+  getDeadLetterTask(taskId: string): Task | undefined {
+    return this.deadLetterTasks.get(taskId);
+  }
+
+  retryDeadLetterTask(taskId: string): Task | null {
+    const task = this.deadLetterTasks.get(taskId);
+    if (!task) return null;
+
+    this.deadLetterTasks.delete(taskId);
+    task.status = 'pending';
+    task.attempt = 0;
+    task.failCount = 0;
+    task.progress = 0;
+    task.progressMessage = undefined;
+    task.error = undefined;
+    task.availableAt = new Date();
+    this.tasks.set(taskId, task);
+    return task;
+  }
+
+  clearDeadLetterQueue(): number {
+    const count = this.deadLetterTasks.size;
+    this.deadLetterTasks.clear();
+    return count;
+  }
+
+  // Concurrency
+  setConcurrency(limit: number | null): void {
+    this.concurrencyLimit = limit;
+  }
+
+  getConcurrency(): number | null {
+    return this.concurrencyLimit;
+  }
+
+  getActiveCount(): number {
+    let count = 0;
+    for (const task of this.tasks.values()) {
+      if (task.status === 'processing') {
+        count++;
+      }
+    }
+    return count;
+  }
+
+  // Middleware
+  use(middleware: MiddlewareFn): void {
+    this.middlewares.push(middleware);
+  }
+
+  getMiddlewares(): MiddlewareFn[] {
+    return this.middlewares;
+  }
+
+  // Handler
+  setHandler(handler: TaskHandler): void {
+    this.handler = handler;
+  }
+
+  getHandler(): TaskHandler | null {
+    return this.handler;
+  }
+
+  // Process task through middleware pipeline then handler
+  async processTask(task: Task): Promise<void> {
+    const middlewares = this.middlewares;
+    const handler = this.handler;
+
+    let index = 0;
+
+    const next = async (): Promise<void> => {
+      if (index < middlewares.length) {
+        const mw = middlewares[index++];
+        await mw(task, next);
+      } else if (handler) {
+        await handler(task);
+      }
+    };
+
+    await next();
+  }
+
+  // Get all tasks (for dependency resolution, shutdown, etc.)
+  getAllTasks(): Map<string, Task> {
+    return this.tasks;
+  }
+
+  getProcessingTasks(): Task[] {
+    const result: Task[] = [];
+    for (const task of this.tasks.values()) {
+      if (task.status === 'processing') {
+        result.push(task);
+      }
+    }
+    return result;
+  }
+}
