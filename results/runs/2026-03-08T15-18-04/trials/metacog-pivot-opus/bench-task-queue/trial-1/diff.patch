@@ -0,0 +1,65 @@
+/**
+ * Simple cron expression parser supporting:
+ * - `* /N * * * *` -> every N minutes (written without space, slash-N)
+ * - `0 * * * *`   -> every hour on the hour
+ * - `0 0 * * *`   -> every day at midnight
+ */
+export function parseCron(expression: string): { matches: (date: Date) => boolean } {
+  const parts = expression.trim().split(/\s+/);
+  if (parts.length !== 5) {
+    throw new Error(`Invalid cron expression: "${expression}" (expected 5 fields)`);
+  }
+
+  const [minuteField, hourField] = parts;
+
+  const minuteMatcher = parseField(minuteField, 0, 59);
+  const hourMatcher = parseField(hourField, 0, 23);
+
+  return {
+    matches(date: Date): boolean {
+      const minute = date.getMinutes();
+      const hour = date.getHours();
+      return minuteMatcher(minute) && hourMatcher(hour);
+    },
+  };
+}
+
+function parseField(field: string, _min: number, _max: number): (value: number) => boolean {
+  if (field === '*') {
+    return () => true;
+  }
+
+  // */N pattern
+  const stepMatch = field.match(/^\*\/(\d+)$/);
+  if (stepMatch) {
+    const step = parseInt(stepMatch[1], 10);
+    if (step <= 0) {
+      throw new Error(`Invalid step value: ${step}`);
+    }
+    return (value: number) => value % step === 0;
+  }
+
+  // Exact number
+  const num = parseInt(field, 10);
+  if (!isNaN(num)) {
+    return (value: number) => value === num;
+  }
+
+  throw new Error(`Unsupported cron field: "${field}"`);
+}
+
+export function shouldRunAt(expression: string, date: Date, lastRun?: Date): boolean {
+  const cron = parseCron(expression);
+  if (!cron.matches(date)) {
+    return false;
+  }
+  if (!lastRun) {
+    return true;
+  }
+  // Prevent running more than once per minute match
+  const lastMinute = new Date(lastRun);
+  lastMinute.setSeconds(0, 0);
+  const currentMinute = new Date(date);
+  currentMinute.setSeconds(0, 0);
+  return currentMinute.getTime() > lastMinute.getTime();
+}
