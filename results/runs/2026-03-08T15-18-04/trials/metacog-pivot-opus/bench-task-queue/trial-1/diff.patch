ue;\n        visited.add(current);\n        const task = this.allTasks.get(current);\n        if (!task) continue;\n        for (const transitiveDep of task.dependencies) {\n          // A cycle among existing tasks: this shouldn't happen\n          // because we validate at each insertion, but check anyway\n          if (transitiveDep === depId && depSet.has(depId)) {\n            // Only a real cycle if transitiveDep leads back to itself\n            // through a chain, not just being in our dependency list\n          }\n          stack.push(transitiveDep);\n        }\n      }\n    }\n  }","originalFile":"import crypto from 'node:crypto';\nimport { Queue } from './queue.js';\nimport { Task } from './task.js';\nimport { parseCron as parseCronExpr, shouldRunAt } from './cron.js';\nimport type {\n  TaskOptions,\n  ScheduleEntry,\n  ShutdownOptions,\n  ShutdownSummary,\n  MiddlewareFn,\n  TaskHandler,\n} from './types.js';\n\nconst DEFAULT_QUEUE = 'default';\n\nexport class TaskQueue {\n  private queues: Map<string, Queue> = new Map();\n  private allTasks: Map<string, Task> = new Map();\n  private schedules: Map<string, ScheduleEntry> = new Map();\n  private shutdownCallbacks: (() => void | Promise<void>)[] = [];\n  private isShutdown = false;\n  private shutdownPromise: Promise<ShutdownSummary> | null = null;\n\n  // Phase 1 & 2: Add task to a named queue\n  addTask(payload: unknown, queueName?: string, options?: TaskOptions): Task;\n  addTask(payload: unknown, options?: TaskOptions): Task;\n  addTask(\n    payload: unknown,\n    queueNameOrOptions?: string | TaskOptions,\n    maybeOptions?: TaskOptions\n  ): Task {\n    if (this.isShutdown) {\n      throw new Error('Task queue is shut down; cannot add new tasks');\n    }\n\n    let queueName: string;\n    let options: TaskOptions;\n\n    if (typeof queueNameOrOptions === 'string') {\n      queueName = queueNameOrOptions;\n      options = maybeOptions ?? {};\n    } else {\n      queueName = DEFAULT_QUEUE;\n      opti