@@ -0,0 +1,119 @@
+import crypto from 'node:crypto';
+import type { TaskStatus, TaskOptions, TaskData, ProgressListener } from './types.js';
+
+export class Task implements TaskData {
+  id: string;
+  payload: unknown;
+  status: TaskStatus;
+  priority: number;
+  createdAt: Date;
+  availableAt: Date;
+  attempt: number;
+  maxRetries: number;
+  backoffDelay: number;
+  queue: string;
+  progress: number;
+  progressMessage?: string;
+  error?: Error;
+  failCount: number;
+  dependencies: string[];
+  resolvedDependencies: Set<string>;
+
+  private progressListeners: Map<symbol, ProgressListener> = new Map();
+
+  constructor(payload: unknown, queue: string, options: TaskOptions = {}) {
+    if (options.priority !== undefined) {
+      if (!Number.isInteger(options.priority) || options.priority < 1 || options.priority > 10) {
+        throw new Error('Priority must be an integer between 1 and 10');
+      }
+    }
+
+    this.id = crypto.randomUUID();
+    this.payload = payload;
+    this.status = 'pending';
+    this.priority = options.priority ?? 5;
+    this.createdAt = new Date();
+    this.queue = queue;
+    this.attempt = 0;
+    this.maxRetries = options.maxRetries ?? 3;
+    this.backoffDelay = options.backoffDelay ?? 1000;
+    this.progress = 0;
+    this.failCount = 0;
+    this.dependencies = options.dependsOn ? [...options.dependsOn] : [];
+    this.resolvedDependencies = new Set();
+
+    if (options.processAt) {
+      this.availableAt = new Date(options.processAt);
+    } else if (options.delay !== undefined && options.delay > 0) {
+      this.availableAt = new Date(Date.now() + options.delay);
+    } else {
+      this.availableAt = this.createdAt;
+    }
+  }
+
+  isAvailable(): boolean {
+    return Date.now() >= this.availableAt.getTime();
+  }
+
+  hasUnresolvedDependencies(): boolean {
+    for (const dep of this.dependencies) {
+      if (!this.resolvedDependencies.has(dep)) {
+        return true;
+      }
+    }
+    return false;
+  }
+
+  isReady(): boolean {
+    return this.status === 'pending' && this.isAvailable() && !this.hasUnresolvedDependencies();
+  }
+
+  transitionTo(status: TaskStatus): void {
+    this.status = status;
+  }
+
+  reportProgress(percent: number, message?: string): void {
+    if (this.status !== 'processing') {
+      throw new Error('Can only report progress on processing tasks');
+    }
+    this.progress = Math.max(0, Math.min(100, percent));
+    this.progressMessage = message;
+    for (const listener of this.progressListeners.values()) {
+      listener(this.progress, this.progressMessage);
+    }
+  }
+
+  onProgress(listener: ProgressListener): () => void {
+    const key = Symbol();
+    this.progressListeners.set(key, listener);
+    return () => {
+      this.progressListeners.delete(key);
+    };
+  }
+
+  resolveDependency(taskId: string): void {
+    this.resolvedDependencies.add(taskId);
+  }
+
+  getDependencyStatus(): { total: number; resolved: number; pending: string[] } {
+    const pending: string[] = [];
+    for (const dep of this.dependencies) {
+      if (!this.resolvedDependencies.has(dep)) {
+        pending.push(dep);
+      }
+    }
+    return {
+      total: this.dependencies.length,
+      resolved: this.resolvedDependencies.size,
+      pending,
+    };
+  }
+
+  scheduleRetry(): void {
+    const delay = this.backoffDelay * Math.pow(2, this.attempt - 1);
+    this.availableAt = new Date(Date.now() + delay);
+    this.status = 'pending';
+    this.progress = 0;
+    this.progressMessage = undefined;
+  }
+}
diff --git a/src/types.ts b/src/types.ts
