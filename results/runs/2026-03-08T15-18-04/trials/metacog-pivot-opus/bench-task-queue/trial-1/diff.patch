@@ -0,0 +1,54 @@
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';
+
+export interface TaskOptions {
+  priority?: number;
+  delay?: number;
+  processAt?: Date;
+  maxRetries?: number;
+  backoffDelay?: number;
+  dependsOn?: string[];
+}
+
+export interface TaskData {
+  id: string;
+  payload: unknown;
+  status: TaskStatus;
+  priority: number;
+  createdAt: Date;
+  availableAt: Date;
+  attempt: number;
+  maxRetries: number;
+  backoffDelay: number;
+  queue: string;
+  progress: number;
+  progressMessage?: string;
+  error?: Error;
+  failCount: number;
+  dependencies: string[];
+  resolvedDependencies: Set<string>;
+}
+
+export type ProgressListener = (progress: number, message?: string) => void;
+
+export type MiddlewareFn = (task: TaskData, next: () => Promise<void>) => Promise<void>;
+
+export type TaskHandler = (task: TaskData) => Promise<void> | void;
+
+export interface ScheduleEntry {
+  id: string;
+  cron: string;
+  queue: string;
+  payload: unknown;
+  taskOptions?: Omit<TaskOptions, 'dependsOn' | 'delay' | 'processAt'>;
+  lastRun?: Date;
+}
+
+export interface ShutdownOptions {
+  timeout?: number;
+}
+
+export interface ShutdownSummary {
+  completed: number;
+  forceCancelled: number;
+  durationMs: number;
+}
