Retries) {\n      // Retry with exponential backoff\n      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);\n      task.availableAt = new Date(Date.now() + delay);\n      task.status = 'delayed';\n      task.progress = 0;\n    } else {\n      // No retries left: move to dead letter queue\n      task.status = 'dead-lettered';\n      this.ensureDeadLetterQueue(task.queue);\n      this.deadLetterQueues.get(task.queue)!.add(taskId);\n      // Remove from main queue\n      const queue = this.queues.get(task.queue);\n      if (queue) queue.delete(taskId);\n    }\n  }\n\n  // ─── Phase 6: Dead Letter Queue ───\n\n  getDeadLetterTasks<T = unknown>(queueName: string = DEFAULT_QUEUE): Task<T>[] {","numLines":30,"startLine":215,"totalLines":745}}}
