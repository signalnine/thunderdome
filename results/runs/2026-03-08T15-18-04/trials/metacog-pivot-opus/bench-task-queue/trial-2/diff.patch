 nextCalled = true;\n      await this.executeMiddleware(stack, task, index + 1, onComplete, setSkipped);\n    });\n\n    if (!nextCalled) {\n      setSkipped(true);\n    }\n  }","newString":"  async processNext(queueName: string = DEFAULT_QUEUE): Promise<Task | null> {\n    const task = this.getNextTask(queueName);\n    if (!task) return null;\n\n    const middlewareStack = this.middlewares.get(queueName) ?? [];\n    const processor = this.processors.get(queueName);\n\n    try {\n      let handlerReached = false;\n\n      const runPipeline = (index: number): Promise<void> => {\n        if (index >= middlewareStack.length) {\n          // End of middleware chain - run the processor\n          handlerReached = true;\n          if (processor && task.status === 'processing') {\n            return processor(task);\n          }\n          return Promise.resolve();\n        }\n\n        return middlewareStack[index](task, () => runPipeline(index + 1));\n      };\n\n      await runPipeline(0);\n\n      if (!handlerReached) {\n        // Middleware didn't call next - task processing was skipped\n        if (task.status === 'processing') {\n          task.status = 'pending';\n          task.attempt -= 1;\n        }\n        return task;\n      }\n\n      if (task.status === 'processing') {\n        this.completeTask(task.id);\n      }\n    } catch (err) {\n      if (task.status === 'processing') {\n        this.failTask(task.id, err instanceof Error ? err : new Error(String(err)));\n      }\n    }\n\n    return task;\n  }","originalFile":"import { randomUUID } from 'node:crypto';\nimport type {\n  Task,\n  TaskOptions,\n  TaskStatus,\n  MiddlewareFn,\n  ProcessorFn,\n  ProgressCallback,\n  Schedule,\n  ScheduleOptions,\n  ShutdownResult,\n} from './types.js';\n\nconst DEFAULT_QUEUE = 'default';\nconst DEFAULT_PRIORITY = 5;\nconst DEFAULT_MAX_RETRIES = 3;\nconst DEFAULT_BACKOFF_DELAY = 1000;\n\nexport class TaskQueue {\n  private tasks: Map<string, Task> = new Map();\n  private queues: Map<string, Set<string>> = new Map();\n  private deadLetterQueues: Map<string, Set<string>> = new Map();\n  private concurrencyLimits: Map<string, number> = new Map();\n  private middlewares: Map<string, MiddlewareFn[]> = new Map();\n  private processors: Map<string, ProcessorFn> = new Map();\n  private progressSubscriptions: Map<string, Set<ProgressCallback>> = new Map();\n  private schedules: Map<string, Schedule> = new Map();\n  private shutdownCallbacks: Array<() => void | Promise<void>> = [];\n  private isShuttingDown = false;\n  private shutdownPromise: Promise<ShutdownResult> | null = null;\n  private sequenceCounter = 0;\n  private taskSequence: Map<string, number> = new Map();\n\n  // ─── Phase 1: Basic Queue ───\n\n  addTask<T = unknown>(payload: T, options: TaskOptions = {}): Task<T> {\n    if (this.isShuttingDown) {\n      throw new Error('Cannot add tasks: system is shutting down');\n    }\n\n    const queueName = options.queue ?? DEFAULT_QUEUE;\n    const priority = options.priority ?? DEFAULT_PRIORITY;\n\n    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    }\n\n    const now = new Date();\n    let availableAt = now;\n\n    if (options.availableAt) {\n      availableAt = options.availableAt;\n    } else if (options.delay != null && options.delay > 0) {\n      availableAt = new Date(now.getTime() + options.delay);\n    }\n\n    // Validate dependencies\n    const dependencies = options.dependencies ?? [];\n    for (const depId of dependencies) {\n      if (!this.tasks.has(depId)) {\n        throw new Error(`Dependency task not found: ${depId}`);\n      }\n    }\n\n    const taskId = randomUUID();\n\n    // Circular dependency detection\n    if (dependencies.length > 0) {\n      this.detectCircularDependencies(taskId, dependencies);\n    }\n\n    const hasUnresolvedDeps = dependencies.some(depId => {\n      const dep = this.tasks.get(depId)!;\n      return dep.status !== 'completed';\n    });\n\n    let status: TaskStatus = 'pending';\n    if (hasUnresolvedDeps) {\n      status = 'blocked';\n    } else if (availableAt > now) {\n      status = 'delayed';\n    }\n\n    const task: Task<T> = {\n      id: taskId,\n      payload,\n      status,\n      priority,\n      queue: queueName,\n      createdAt: now,\n      availableAt,\n      attempt: 0,\n      maxRetries: options.maxRetries ?? DEFAULT_MAX_RETRIES,\n      backoffDelay: options.backoffDelay ?? DEFAULT_BACKOFF_DELAY,\n      progress: 0,\n      failureCount: 0,\n      dependencies: [...dependencies],\n      resolvedDependencies: new Set(\n        dependencies.filter(depId => {\n          const dep = this.tasks.get(depId)!;\n          return dep.status === 'completed';\n        })\n      ),\n    };\n\n    this.tasks.set(taskId, task as Task);\n    this.ensureQueue(queueName);\n    this.queues.get(queueName)!.add(taskId);\n    this.taskSequence.set(taskId, this.sequenceCounter++);\n\n    return task;\n  }\n\n  getTask<T = unknown>(taskId: string): Task<T> | null {\n    return (this.tasks.get(taskId) as Task<T>) ?? null;\n  }\n\n  // ─── Phase 2: Named Queues / Phase 1: Basic retrieval ───\n\n  getNextTask<T = unknown>(queueName: string = DEFAULT_QUEUE): Task<T> | null {\n    const queue = this.queues.get(queueName);\n    if (!queue) return null;\n\n    // Check concurrency limit\n    const limit = this.concurrencyLimits.get(queueName);\n    if (limit != null) {\n      const activeCount = this.getActiveCount(queueName);\n      if (activeCount >= limit) return null;\n    }\n\n    const now = new Date();\n\n    // Collect eligible tasks: pending or delayed-but-now-available\n    const eligible: Task[] = [];\n    for (const taskId of queue) {\n      const task = this.tasks.get(taskId)!;\n      if (task.status === 'pending') {\n        eligible.push(task);\n      } else if (task.status === 'delayed' && task.availableAt <= now) {\n        eligible.push(task);\n      }\n    }\n\n    if (eligible.length === 0) return null;\n\n    // Sort: priority (ascending, lower number = higher priority), then availability time, then FIFO (sequence)\n    eligible.sort((a, b) => {\n      if (a.priority !== b.priority) return a.priority - b.priority;\n      const aTime = a.availableAt.getTime();\n      const bTime = b.availableAt.getTime();\n      if (aTime !== bTime) return aTime - bTime;\n      return this.taskSequence.get(a.id)! - this.taskSequence.get(b.id)!;\n    });\n\n    const task = eligible[0];\n    task.status = 'processing';\n    task.attempt += 1;\n\n    return task as Task<T>;\n  }\n\n  getPendingCount(queueName: string = DEFAULT_QUEUE): number {\n    const queue = this.queues.get(queueName);\n    if (!queue) return 0;\n\n    let count = 0;\n    const now = new Date();\n    for (const taskId of queue) {\n      const task = this.tasks.get(taskId)!;\n      if (task.status === 'pending') {\n        count++;\n      } else if (task.status === 'delayed' && task.availableAt <= now) {\n        count++;\n      }\n    }\n    return count;\n  }\n\n  getWaitingCount(queueName: string = DEFAULT_QUEUE): number {\n    const queue = this.queues.get(queueName);\n    if (!queue) return 0;\n\n    let count = 0;\n    for (const taskId of queue) {\n      const task = this.tasks.get(taskId)!;\n      if (task.status === 'pending' || task.status === 'delayed' || task.status === 'blocked') {\n        count++;\n      }\n    }\n    return count;\n  }\n\n  // ─── Phase 2: Named Queues ───\n\n  getQueues(): string[] {\n    return Array.from(this.queues.keys());\n  }\n\n  // ─── Phase 5: Complete / Fail ───\n\n  completeTask(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot complete task in '${task.status}' state`);\n    }\n\n    task.status = 'completed';\n    task.progress = 100;\n\n    // Check if any blocked tasks can now be unblocked\n    this.checkDependents(taskId);\n  }\n\n  failTask(taskId: string, error?: Error): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot fail task in '${task.status}' state`);\n    }\n\n    task.error = error;\n    task.failureCount += 1;\n\n    if (task.attempt < task.maxRetries) {\n      // Retry with exponential backoff\n      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);\n      task.availableAt = new Date(Date.now() + delay);\n      task.status = 'delayed';\n      task.progress = 0;\n    } else {\n      // No retries left: move to dead letter queue\n      task.status = 'dead-lettered';\n      this.ensureDeadLetterQueue(task.queue);\n      this.deadLetterQueues.get(task.queue)!.add(taskId);\n      // Remove from main queue\n      const queue = this.queues.get(task.queue);\n      if (queue) queue.delete(taskId);\n    }\n  }\n\n  // ─── Phase 6: Dead Letter Queue ───\n\n  getDeadLetterTasks<T = unknown>(queueName: string = DEFAULT_QUEUE): Task<T>[] {\n    const dlq = this.deadLetterQueues.get(queueName);\n    if (!dlq) return [];\n\n    return Array.from(dlq).map(id => this.tasks.get(id) as Task<T>);\n  }\n\n  redriveTask(taskId: string): Task {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'dead-lettered') {\n      throw new Error(`Task is not dead-lettered`);\n    }\n\n    // Remove from DLQ\n    const dlq = this.deadLetterQueues.get(task.queue);\n    if (dlq) dlq.delete(taskId);\n\n    // Reset for fresh retries\n    task.status = 'pending';\n    task.attempt = 0;\n    task.progress = 0;\n    task.error = undefined;\n    task.availableAt = new Date();\n\n    // Add back to main queue\n    this.ensureQueue(task.queue);\n    this.queues.get(task.queue)!.add(taskId);\n\n    return task;\n  }\n\n  clearDeadLetterQueue(queueName: string = DEFAULT_QUEUE): number {\n    const dlq = this.deadLetterQueues.get(queueName);\n    if (!dlq) return 0;\n\n    const count = dlq.size;\n    for (const taskId of dlq) {\n      this.tasks.delete(taskId);\n    }\n    dlq.clear();\n    return count;\n  }\n\n  // ─── Phase 7: Task Dependencies ───\n\n  getTaskDependencyStatus(taskId: string): { total: number; resolved: number; pending: string[] } {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    const pending = task.dependencies.filter(\n      depId => !task.resolvedDependencies.has(depId)\n    );\n\n    return {\n      total: task.dependencies.length,\n      resolved: task.resolvedDependencies.size,\n      pending,\n    };\n  }\n\n  private detectCircularDependencies(newTaskId: string, dependencies: string[]): void {\n    // Check if any dependency (transitively) would create a cycle\n    // Since the new task doesn't exist yet, we check if any dependency\n    // depends on something that would eventually depend on the new task.\n    // But since the new task is new and no one depends on it yet,\n    // we only need to check that dependencies don't form internal cycles.\n    // Actually the real concern is: if task A depends on task B, and task B\n    // depends on task A - but since newTaskId doesn't exist yet, no existing\n    // task can depend on it. So circular deps can only occur if somehow\n    // the dependencies themselves form a chain back to one of the dependencies.\n    // For newly created tasks, we just need to ensure the dependency chain is valid.\n    // Real cycles would be caught when someone tries to create a task that depends\n    // on a task that (transitively) depends on an unresolved task that would need this one.\n\n    // Actually, since we're checking at creation time: a new task can't be part of a cycle\n    // because no other task can reference it yet (it doesn't have an ID assigned yet in the graph).\n    // However, we should check that the dependencies themselves don't contain cycles among themselves.\n    // And we should check that we're not creating a situation where task A depends on B and B depends on A\n    // indirectly.\n\n    // The real check: traverse dependencies of each dep - if any of them lead back to any dep, that's a cycle.\n    // But since newTaskId is brand new and hasn't been added yet, no existing task can depend on it.\n    // So there's no way to create a cycle with a brand new task. The existing tasks already had their\n    // cycles checked when they were created.\n\n    // The only case for cycle detection at creation is: if the spec says \"depending on a task that\n    // depends on this task\" - but this task doesn't exist yet. So cycle detection for new tasks is\n    // essentially a no-op unless there are indirect chains among the deps themselves that were\n    // somehow missed.\n\n    // To be safe, let's do BFS from each dependency - if we ever reach any of the other dependencies\n    // through the dependency graph, flag it. Actually that's not a cycle, that's just a shared dependency.\n\n    // A cycle would be: if we find that any dependency transitively depends on a task that hasn't been\n    // created yet. That can't happen. So the only check is verifying deps exist (done above).\n\n    // However, if we allow tasks to be added with deps on blocked tasks, and those blocked tasks\n    // depend on other things that eventually might need this task - we need to check the full graph.\n\n    // Let's do the proper check: after conceptually adding newTaskId -> dependencies edges,\n    // check if there's a cycle in the dependency graph.\n\n    // Build adjacency: task -> depends on\n    const visited = new Set<string>();\n    const stack = new Set<string>();\n\n    const hasCycle = (taskId: string): boolean => {\n      if (stack.has(taskId)) return true;\n      if (visited.has(taskId)) return false;\n\n      visited.add(taskId);\n      stack.add(taskId);\n\n      const deps = taskId === newTaskId\n        ? dependencies\n        : (this.tasks.get(taskId)?.dependencies ?? []);\n\n      for (const dep of deps) {\n        if (hasCycle(dep)) return true;\n      }\n\n      stack.delete(taskId);\n      return false;\n    };\n\n    if (hasCycle(newTaskId)) {\n      throw new Error('Circular dependency detected');\n    }\n  }\n\n  private checkDependents(completedTaskId: string): void {\n    // Check all tasks to see if any are blocked on this task\n    for (const [, task] of this.tasks) {\n      if (task.status !== 'blocked') continue;\n      if (!task.dependencies.includes(completedTaskId)) continue;\n\n      task.resolvedDependencies.add(completedTaskId);\n\n      // Check if all dependencies are now resolved\n      const allResolved = task.dependencies.every(depId =>\n        task.resolvedDependencies.has(depId)\n      );\n\n      if (allResolved) {\n        const now = new Date();\n        if (task.availableAt > now) {\n          task.status = 'delayed';\n        } else {\n          task.status = 'pending';\n        }\n      }\n    }\n  }\n\n  // ─── Phase 8: Concurrency Control ───\n\n  setConcurrency(queueName: string, limit: number): void {\n    if (limit < 1 || !Number.isInteger(limit)) {\n      throw new Error(`Invalid concurrency limit: ${limit}`);\n    }\n    this.concurrencyLimits.set(queueName, limit);\n  }\n\n  getConcurrency(queueName: string): number | undefined {\n    return this.concurrencyLimits.get(queueName);\n  }\n\n  getActiveCount(queueName: string = DEFAULT_QUEUE): number {\n    const queue = this.queues.get(queueName);\n    if (!queue) return 0;\n\n    let count = 0;\n    for (const taskId of queue) {\n      const task = this.tasks.get(taskId)!;\n      if (task.status === 'processing') count++;\n    }\n    return count;\n  }\n\n  // ─── Phase 9: Progress Tracking and Cancellation ───\n\n  updateProgress(taskId: string, progress: number, message?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot update progress for task in '${task.status}' state`);\n    }\n    if (progress < 0 || progress > 100) {\n      throw new Error(`Invalid progress: ${progress}. Must be between 0 and 100.`);\n    }\n\n    task.progress = progress;\n    task.progressMessage = message;\n\n    // Notify subscribers\n    const subs = this.progressSubscriptions.get(taskId);\n    if (subs) {\n      for (const callback of subs) {\n        callback(progress, message);\n      }\n    }\n  }\n\n  getProgress(taskId: string): { progress: number; message?: string } {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    return { progress: task.progress, message: task.progressMessage };\n  }\n\n  onProgress(taskId: string, callback: ProgressCallback): () => void {\n    if (!this.progressSubscriptions.has(taskId)) {\n      this.progressSubscriptions.set(taskId, new Set());\n    }\n    this.progressSubscriptions.get(taskId)!.add(callback);\n\n    // Return unsubscribe function\n    return () => {\n      const subs = this.progressSubscriptions.get(taskId);\n      if (subs) {\n        subs.delete(callback);\n        if (subs.size === 0) {\n          this.progressSubscriptions.delete(taskId);\n        }\n      }\n    };\n  }\n\n  cancelTask(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    if (task.status !== 'pending' && task.status !== 'processing' && task.status !== 'delayed' && task.status !== 'blocked') {\n      throw new Error(`Cannot cancel task in '${task.status}' state`);\n    }\n\n    const wasProcessing = task.status === 'processing';\n    task.status = 'cancelled';\n\n    // Remove from queue if pending/delayed/blocked\n    if (!wasProcessing) {\n      const queue = this.queues.get(task.queue);\n      if (queue) queue.delete(taskId);\n    }\n  }\n\n  // ─── Phase 10: Recurring Tasks ───\n\n  addSchedule(options: ScheduleOptions): Schedule {\n    if (this.isShuttingDown) {\n      throw new Error('Cannot add schedules: system is shutting down');\n    }\n\n    const schedule: Schedule = {\n      id: options.id,\n      cron: options.cron,\n      queue: options.queue,\n      payload: options.payload,\n      taskOptions: options.taskOptions,\n    };\n\n    this.schedules.set(options.id, schedule);\n    return schedule;\n  }\n\n  removeSchedule(scheduleId: string): boolean {\n    return this.schedules.delete(scheduleId);\n  }\n\n  getSchedules(): Schedule[] {\n    return Array.from(this.schedules.values());\n  }\n\n  tick(now: Date = new Date()): Task[] {\n    const createdTasks: Task[] = [];\n\n    for (const [, schedule] of this.schedules) {\n      if (this.shouldRunSchedule(schedule, now)) {\n        const task = this.addTask(schedule.payload, {\n          queue: schedule.queue,\n          ...schedule.taskOptions,\n        });\n        createdTasks.push(task);\n        schedule.lastRun = now;\n      }\n    }\n\n    return createdTasks;\n  }\n\n  private shouldRunSchedule(schedule: Schedule, now: Date): boolean {\n    const { cron, lastRun } = schedule;\n\n    // Parse simple cron subset\n    const parts = cron.split(/\\s+/);\n    if (parts.length !== 5) return false;\n\n    const [minutePart, hourPart] = parts;\n\n    const currentMinute = now.getMinutes();\n    const currentHour = now.getHours();\n\n    // Check minute match\n    let minuteMatch = false;\n    if (minutePart === '*') {\n      minuteMatch = true;\n    } else if (minutePart.startsWith('*/')) {\n      const interval = parseInt(minutePart.slice(2), 10);\n      minuteMatch = currentMinute % interval === 0;\n    } else {\n      minuteMatch = parseInt(minutePart, 10) === currentMinute;\n    }\n\n    // Check hour match\n    let hourMatch = false;\n    if (hourPart ===