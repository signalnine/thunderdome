+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01SbqpFS6rngRY1C9tMXBDF7","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01TBxhnmkG9GkMfk4fjiSPzS","name":"Write","input":{"file_path":"/workspace/src/task-queue.test.ts","content":"import { describe, it, expect, vi, beforeEach } from 'vitest';\nimport { TaskQueue } from './task-queue.js';\n\ndescribe('TaskQueue', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  // ─── Phase 1: Basic FIFO Queue ───\n  describe('Phase 1: Basic FIFO Queue', () => {\n    it('should add a task and return a task object', () => {\n      const task = tq.addTask({ message: 'hello' });\n      expect(task).toBeDefined();\n      expect(task.id).toBeDefined();\n      expect(task.payload).toEqual({ message: 'hello' });\n      expect(task.status).toBe('pending');\n      expect(task.createdAt).toBeInstanceOf(Date);\n    });\n\n    it('should generate unique IDs for each task', () => {\n      const t1 = tq.addTask('a');\n      const t2 = tq.addTask('b');\n      expect(t1.id).not.toBe(t2.id);\n    });\n\n    it('should return tasks in FIFO order', () => {\n      tq.addTask('first');\n      tq.addTask('second');\n      tq.addTask('third');\n\n      const next1 = tq.getNextTask();\n      expect(next1?.payload).toBe('first');\n      const next2 = tq.getNextTask();\n      expect(next2?.payload).toBe('second');\n      const next3 = tq.getNextTask();\n      expect(next3?.payload).toBe('third');\n    });\n\n    it('should transition task to processing when retrieved', () => {\n      tq.addTask('test');\n      const task = tq.getNextTask();\n      expect(task?.status).toBe('processing');\n    });\n\n    it('should return null when no tasks available', () => {\n      const task = tq.getNextTask();\n      expect(task).toBeNull();\n    });\n\n    it('should track pending count', () => {\n      expect(tq.getPendingCount()).toBe(0);\n      tq.addTask('a');\n      tq.addTask('b');\n      expect(tq.getPendingCount()).toBe(2);\n      tq.getNextTask();\n      expect(tq.getPendingCount()).toBe(1);\n    });\n\n    it('should not return already-processing tasks', () => {\n      tq.addTask('only');\n      tq.getNextTask();\n      expect(tq.getNextTask()).toBeNull();\n    });\n  });\n\n  // ─── Phase 2: Named Queues ───\n  describe('Phase 2: Named Queues', () => {\n    it('should support named queues', () => {\n      tq.addTask('email-task', { queue: 'email' });\n      tq.addTask('sms-task', { queue: 'sms' });\n\n      const emailTask = tq.getNextTask('email');\n      expect(emailTask?.payload).toBe('email-task');\n\n      const smsTask = tq.getNextTask('sms');\n      expect(smsTask?.payload).toBe('sms-task');\n    });\n\n    it('should use default queue when no name specified', () => {\n      tq.addTask('default-task');\n      const task = tq.getNextTask('default');\n      expect(task?.payload).toBe('default-task');\n    });\n\n    it('should list all queue names', () => {\n      tq.addTask('a', { queue: 'q1' });\n      tq.addTask('b', { queue: 'q2' });\n      const queues = tq.getQueues();\n      expect(queues).toContain('q1');\n      expect(queues).toContain('q2');\n    });\n\n    it('should return null for non-existent queue', () => {\n      expect(tq.getNextTask('nonexistent')).toBeNull();\n    });\n\n    it('should keep queues independent', () => {\n      tq.addTask('a', { queue: 'q1' });\n      expect(tq.getNextTask('q2')).toBeNull();\n      expect(tq.getNextTask('q1')?.payload).toBe('a');\n    });\n  });\n\n  // ─── Phase 3: Priority ───\n  describe('Phase 3: Priority', () => {\n    it('should return higher priority tasks first (lower number = higher priority)', () => {\n      tq.addTask('low', { priority: 10 });\n      tq.addTask('high', { priority: 1 });\n      tq.addTask('mid', { priority: 5 });\n\n      expect(tq.getNextTask()?.payload).toBe('high');\n      expect(tq.getNextTask()?.payload).toBe('mid');\n      expect(tq.getNextTask()?.payload).toBe('low');\n    });\n\n    it('should use FIFO order for same priority', () => {\n      tq.addTask('first', { priority: 5 });\n      tq.addTask('second', { priority: 5 });\n      tq.addTask('third', { priority: 5 });\n\n      expect(tq.getNextTask()?.payload).toBe('first');\n      expect(tq.getNextTask()?.payload).toBe('second');\n      expect(tq.getNextTask()?.payload).toBe('third');\n    });\n\n    it('should default to priority 5', () => {\n      const task = tq.addTask('test');\n      expect(task.priority).toBe(5);\n    });\n\n    it('should reject invalid priority values', () => {\n      expect(() => tq.addTask('bad', { priority: 0 })).toThrow();\n      expect(() => tq.addTask('bad', { priority: 11 })).toThrow();\n      expect(() => tq.addTask('bad', { priority: 1.5 })).toThrow();\n    });\n\n    it('should expose priority level on task', () => {\n      const task = tq.addTask('test', { priority: 3 });\n      expect(task.priority).toBe(3);\n    });\n  });\n\n  // ─── Phase 4: Delayed and Scheduled Tasks ───\n  describe('Phase 4: Delayed Tasks', () => {\n    it('should not return delayed tasks before their availability time', () => {\n      tq.addTask('delayed', { delay: 100000 });\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should return delayed tasks after their availability time', () => {\n      const past = new Date(Date.now() - 1000);\n      tq.addTask('available', { availableAt: past });\n      expect(tq.getNextTask()?.payload).toBe('available');\n    });\n\n    it('should prefer non-delayed tasks over unavailable delayed tasks', () => {\n      tq.addTask('delayed', { delay: 100000 });\n      tq.addTask('immediate');\n      expect(tq.getNextTask()?.payload).toBe('immediate');\n    });\n\n    it('should set status to delayed for future tasks', () => {\n      const task = tq.addTask('future', { delay: 100000 });\n      expect(task.status).toBe('delayed');\n    });\n\n    it('should indicate availability time on task', () => {\n      const task = tq.addTask('delayed', { delay: 5000 });\n      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now());\n    });\n\n    it('should support specific availableAt date', () => {\n      const future = new Date(Date.now() + 50000);\n      const task = tq.addTask('scheduled', { availableAt: future });\n      expect(task.availableAt).toEqual(future);\n      expect(task.status).toBe('delayed');\n    });\n\n    it('should order multiple available delayed tasks by availability time then priority', () => {\n      const past1 = new Date(Date.now() - 2000);\n      const past2 = new Date(Date.now() - 1000);\n      tq.addTask('later', { availableAt: past2, priority: 1 });\n      tq.addTask('earlier', { availableAt: past1, priority: 1 });\n\n      // Same priority, so ordered by availability time\n      expect(tq.getNextTask()?.payload).toBe('earlier');\n      expect(tq.getNextTask()?.payload).toBe('later');\n    });\n  });\n\n  // ─── Phase 5: Retry with Backoff ───\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should complete a processing task', () => {\n      const task = tq.addTask('test');\n      tq.getNextTask();\n      tq.completeTask(task.id);\n      expect(tq.getTask(task.id)?.status).toBe('completed');\n    });\n\n    it('should fail and retry a task with exponential backoff', () => {\n      const task = tq.addTask('retryable', { maxRetries: 3, backoffDelay: 100 });\n      tq.getNextTask();\n      tq.failTask(task.id, new Error('fail'));\n\n      const updated = tq.getTask(task.id)!;\n      expect(updated.status).toBe('delayed');\n      expect(updated.attempt).toBe(1);\n      expect(updated.failureCount).toBe(1);\n    });\n\n    it('should use exponential backoff formula: baseDelay * 2^(attempt-1)', () => {\n      const task = tq.addTask('test', { maxRetries: 3, backoffDelay: 1000 });\n\n      // First attempt\n      tq.getNextTask();\n      const beforeFail = Date.now();\n      tq.failTask(task.id, new Error('fail'));\n      const updated = tq.getTask(task.id)!;\n      // First retry delay: 1000 * 2^0 = 1000ms\n      expect(updated.availableAt.getTime()).toBeGreaterThanOrEqual(beforeFail + 1000 - 50);\n    });\n\n    it('should track attempt count', () => {\n      const task = tq.addTask('test', { maxRetries: 3, backoffDelay: 0 });\n\n      // First attempt\n      tq.getNextTask();\n      expect(tq.getTask(task.id)!.attempt).toBe(1);\n    });\n\n    it('should default maxRetries to 3', () => {\n      const task = tq.addTask('test');\n      expect(task.maxRetries).toBe(3);\n    });\n\n    it('should keep original queue and priority on retry', () => {\n      const task = tq.addTask('test', {\n        queue: 'myqueue',\n        priority: 2,\n        maxRetries: 3,\n        backoffDelay: 0\n      });\n      tq.getNextTask('myqueue');\n      tq.failTask(task.id);\n\n      const updated = tq.getTask(task.id)!;\n      expect(updated.queue).toBe('myqueue');\n      expect(updated.priority).toBe(2);\n    });\n\n    it('should move task to dead-lettered state when retries exhausted', () => {\n      const task = tq.addTask('test', { maxRetries: 1, backoffDelay: 0 });\n\n      tq.getNextTask();\n      tq.failTask(task.id, new Error('fail'));\n\n      const updated = tq.getTask(task.id)!;\n      expect(updated.status).toBe('dead-lettered');\n    });\n  });\n\n  // ─── Phase 6: Dead Letter Queue ───\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move exhausted tasks to DLQ', () => {\n      const task = tq.addTask('test', { maxRetries: 1, backoffDelay: 0 });\n      tq.getNextTask();\n      tq.failTask(task.id, new Error('permanent failure'));\n\n      const dlq = tq.getDeadLetterTasks();\n      expect(dlq.length).toBe(1);\n      expect(dlq[0].id).toBe(task.id);\n    });\n\n    it('should retain error information on dead-lettered tasks', () => {\n      const task = tq.addTask('test', { maxRetries: 1, backoffDelay: 0 });\n      tq.getNextTask();\n      tq.failTask(task.id, new Error('specific error'));\n\n      const dlq = tq.getDeadLetterTasks();\n      expect(dlq[0].error?.message).toBe('specific error');\n    });\n\n    it('should allow redriving dead-lettered tasks', () => {\n      const task = tq.addTask('test', { maxRetries: 1, backoffDelay: 0 });\n      tq.getNextTask();\n      tq.failTask(task.id, new Error('fail'));\n\n      const redriven = tq.redriveTask(task.id);\n      expect(redriven.status).toBe('pending');\n      expect(redriven.attempt).toBe(0);\n\n      const next = tq.getNextTask();\n      expect(next?.id).toBe(task.id);\n    });\n\n    it('should clear dead letter queue', () => {\n      const task = tq.addTask('test', { maxRetries: 1, backoffDelay: 0 });\n      tq.getNextTask();\n      tq.failTask(task.id);\n\n      const cleared = tq.clearDeadLetterQueue();\n      expect(cleared).toBe(1);\n      expect(tq.getDeadLetterTasks().length).toBe(0);\n    });\n\n    it('should have independent DLQs per queue', () => {\n      const t1 = tq.addTask('test1', { queue: 'q1', maxRetries: 1 });\n      const t2 = tq.addTask('test2', { queue: 'q2', maxRetries: 1 });\n\n      tq.getNextTask('q1');\n      tq.failTask(t1.id, new Error('fail'));\n      tq.getNextTask('q2');\n      tq.failTask(t2.id, new Error('fail'));\n\n      expect(tq.getDeadLetterTasks('q1').length).toBe(1);\n      expect(tq.getDeadLetterTasks('q2').length).toBe(1);\n    });\n  });\n\n  // ─── Phase 7: Task Dependencies ───\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block tasks with unresolved dependencies', () => {\n      const dep = tq.addTask('dependency');\n      const task = tq.addTask('dependent', { dependencies: [dep.id] });\n      expect(task.status).toBe('blocked');\n\n      // Should not return blocked task\n      const next = tq.getNextTask();\n      expect(next?.id).toBe(dep.id);\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should unblock tasks when dependencies complete', () => {\n      const dep = tq.addTask('dependency');\n      const task = tq.addTask('dependent', { dependencies: [dep.id] });\n\n      tq.getNextTask();\n      tq.completeTask(dep.id);\n\n      const next = tq.getNextTask();\n      expect(next?.id).toBe(task.id);\n    });\n\n    it('should reject dependencies on non-existent tasks', () => {\n      expect(() => tq.addTask('bad', { dependencies: ['nonexistent'] })).toThrow();\n    });\n\n    it('should block when dependency fails (remain blocked)', () => {\n      const dep = tq.addTask('dependency', { maxRetries: 1 });\n      tq.addTask('dependent', { dependencies: [dep.id] });\n\n      tq.getNextTask();\n      tq.failTask(dep.id, new Error('fail'));\n\n      // Dependent should still be blocked\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should inspect dependency status', () => {\n      const dep1 = tq.addTask('dep1');\n      const dep2 = tq.addTask('dep2');\n      const task = tq.addTask('dependent', { dependencies: [dep1.id, dep2.id] });\n\n      let status = tq.getTaskDependencyStatus(task.id);\n      expect(status.total).toBe(2);\n      expect(status.resolved).toBe(0);\n      expect(status.pending.length).toBe(2);\n\n      tq.getNextTask(); // gets dep1 (higher FIFO)\n      tq.completeTask(dep1.id);\n\n      status = tq.getTaskDependencyStatus(task.id);\n      expect(status.resolved).toBe(1);\n      expect(status.pending.length).toBe(1);\n    });\n\n    it('should handle multiple dependencies', () => {\n      const dep1 = tq.addTask('dep1');\n      const dep2 = tq.addTask('dep2');\n      const task = tq.addTask('dependent', { dependencies: [dep1.id, dep2.id] });\n\n      // Complete dep1\n      tq.getNextTask();\n      tq.completeTask(dep1.id);\n\n      // Task should still be blocked (dep2 not done)\n      const updatedTask = tq.getTask(task.id)!;\n      expect(updatedTask.status).toBe('blocked');\n\n      // Complete dep2\n      tq.getNextTask();\n      tq.completeTask(dep2.id);\n\n      // Now task should be available\n      const next = tq.getNextTask();\n      expect(next?.id).toBe(task.id);\n    });\n  });\n\n  // ─── Phase 8: Concurrency Control ───\n  describe('Phase 8: Concurrency Control', () => {\n    it('should limit concurrent processing tasks', () => {\n      tq.setConcurrency('default', 2);\n      tq.addTask('a');\n      tq.addTask('b');\n      tq.addTask('c');\n\n      expect(tq.getNextTask()?.payload).toBe('a');\n      expect(tq.getNextTask()?.payload).toBe('b');\n      expect(tq.getNextTask()).toBeNull(); // limit reached\n    });\n\n    it('should free up slots when tasks complete', () => {\n      tq.setConcurrency('default', 1);\n      const task = tq.addTask('a');\n      tq.addTask('b');\n\n      tq.getNextTask();\n      expect(tq.getNextTask()).toBeNull();\n\n      tq.completeTask(task.id);\n      expect(tq.getNextTask()?.payload).toBe('b');\n    });\n\n    it('should track active count', () => {\n      tq.addTask('a');\n      tq.addTask('b');\n\n      expect(tq.getActiveCount()).toBe(0);\n      tq.getNextTask();\n      expect(tq.getActiveCount()).toBe(1);\n    });\n\n    it('should default to no limit (unlimited)', () => {\n      expect(tq.getConcurrency('default')).toBeUndefined();\n    });\n\n    it('should interact correctly with priority', () => {\n      tq.setConcurrency('default', 1);\n      tq.addTask('low', { priority: 10 });\n      tq.addTask('high', { priority: 1 });\n\n      // Should get high priority first\n      expect(tq.getNextTask()?.payload).toBe('high');\n    });\n  });\n\n  // ─── Phase 9: Progress Tracking and Cancellation ───\n  describe('Phase 9: Progress and Cancellation', () => {\n    it('should update and query progress', () => {\n      const task = tq.addTask('test');\n      tq.getNextTask();\n\n      tq.updateProgress(task.id, 50, 'halfway');\n      const progress = tq.getProgress(task.id);\n      expect(progress.progress).toBe(50);\n      expect(progress.message).toBe('halfway');\n    });\n\n    it('should notify progress subscribers', () => {\n      const task = tq.addTask('test');\n      tq.getNextTask();\n\n      const updates: Array<{ progress: number; message?: string }> = [];\n      tq.onProgress(task.id, (progress, message) => {\n        updates.push({ progress, message });\n      });\n\n      tq.updateProgress(task.id, 25, 'quarter');\n      tq.updateProgress(task.id, 75, 'three-quarters');\n\n      expect(updates.length).toBe(2);\n      expect(updates[0].progress).toBe(25);\n      expect(updates[1].progress).toBe(75);\n    });\n\n    it('should support unsubscribing from progress', () => {\n      const task = tq.addTask('test');\n      tq.getNextTask();\n\n      const updates: number[] = [];\n      const unsub = tq.onProgress(task.id, (progress) => {\n        updates.push(progress);\n      });\n\n      tq.updateProgress(task.id, 25);\n      unsub();\n      tq.updateProgress(task.id, 75);\n\n      expect(updates.length).toBe(1);\n    });\n\n    it('should cancel a pending task', () => {\n      const task = tq.addTask('test');\n      tq.cancelTask(task.id);\n      expect(tq.getTask(task.id)?.status).toBe('cancelled');\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should cancel a processing task', () => {\n      const task = tq.addTask('test');\n      tq.getNextTask();\n      tq.cancelTask(task.id);\n      expect(tq.getTask(task.id)?.status).toBe('cancelled');\n    });\n\n    it('should not retry cancelled tasks', () => {\n      const task = tq.addTask('test', { maxRetries: 3 });\n      tq.getNextTask();\n      tq.cancelTask(task.id);\n      expect(tq.getTask(task.id)?.status).toBe('cancelled');\n    });\n\n    it('should reject invalid progress values', () => {\n      const task = tq.addTask('test');\n      tq.getNextTask();\n      expect(() => tq.updateProgress(task.id, -1)).toThrow();\n      expect(() => tq.updateProgress(task.id, 101)).toThrow();\n    });\n  });\n\n  // ─── Phase 10: Recurring Tasks ───\n  describe('Phase 10: Recurring Tasks', () => {\n    it('should create a schedule', () => {\n      const schedule = tq.addSchedule({\n        id: 'every-5-min',\n        cron: '*/5 * * * *',\n        queue: 'default',\n        payload: { type: 'cleanup' },\n      });\n      expect(schedule.id).toBe('every-5-min');\n    });\n\n    it('should create tasks on tick when schedule matches', () => {\n      tq.addSchedule({\n        id: 'every-5-min',\n        cron: '*/5 * * * *',\n        queue: 'default',\n        payload: { type: 'cleanup' },\n      });\n\n      // Tick at a time that matches */5 (minute divisible by 5)\n      const matchingTime = new Date();\n      matchingTime.setMinutes(10, 0, 0);\n      const tasks = tq.tick(matchingTime);\n      expect(tasks.length).toBe(1);\n      expect(tasks[0].payload).toEqual({ type: 'cleanup' });\n    });\n\n    it('should not create tasks when schedule does not match', () => {\n      tq.addSchedule({\n        id: 'hourly',\n        cron: '0 * * * *',\n        queue: 'default',\n        payload: 'hourly-task',\n      });\n\n      const nonMatchingTime = new Date();\n      nonMatchingTime.setMinutes(30, 0, 0);\n      const tasks = tq.tick(nonMatchingTime);\n      expect(tasks.length).toBe(0);\n    });\n\n    it('should not double-fire in the same minute', () => {\n      tq.addSchedule({\n        id: 'test',\n        cron: '*/5 * * * *',\n        queue: 'default',\n        payload: 'test',\n      });\n\n      const time = new Date();\n      time.setMinutes(10, 0, 0);\n      tq.tick(time);\n      const second = tq.tick(time);\n      expect(second.length).toBe(0);\n    });\n\n    it('should list schedules', () => {\n      tq.addSchedule({ id: 's1', cron: '* * * * *', queue: 'q1', payload: 'a' });\n      tq.addSchedule({ id: 's2', cron: '* * * * *', queue: 'q2', payload: 'b' });\n      expect(tq.getSchedules().length).toBe(2);\n    });\n\n    it('should remove a schedule', () => {\n      tq.addSchedule({ id: 's1', cron: '* * * * *', queue: 'default', payload: 'a' });\n      tq.removeSchedule('s1');\n      expect(tq.getSchedules().length).toBe(0);\n    });\n\n    it('should support daily at midnight cron', () => {\n      tq.addSchedule({\n        id: 'daily',\n        cron: '0 0 * * *',\n        queue: 'default',\n        payload: 'daily',\n      });\n\n      const midnight = new Date();\n      midnight.setHours(0, 0, 0, 0);\n      const tasks = tq.tick(midnight);\n      expect(tasks.length).toBe(1);\n\n      const noon = new Date();\n      noon.setHours(12, 0, 0, 0);\n      const noTasks = tq.tick(noon);\n      expect(noTasks.length).toBe(0);\n    });\n  });\n\n  // ─── Phase 11: Middleware Pipeline ───\n  describe('Phase 11: Middleware Pipeline', () => {\n    it('should execute middleware in order before processing', async () => {\n      const order: string[] = [];\n\n      tq.use('default', async (_task, next) => {\n        order.push('mw1-before');\n        await next();\n        order.push('mw1-after');\n      });\n\n      tq.use('default', async (_task, next) => {\n        order.push('mw2-before');\n        await next();\n        order.push('mw2-after');\n      });\n\n      tq.setProcessor('default', async () => {\n        order.push('processor');\n      });\n\n      tq.addTask('test');\n      await tq.processNext();\n\n      expect(order).toEqual([\n        'mw1-before',\n        'mw2-before',\n        'processor',\n        'mw2-after',\n        'mw1-after',\n      ]);\n    });\n\n    it('should allow middleware to modify task', async () => {\n      tq.use('default', async (task, next) => {\n        (task as Record<string, unknown>).modified = true;\n        await next();\n      });\n\n      tq.setProcessor('default', async (task) => {\n        expect((task as Record<string, unknown>).modified).toBe(true);\n      });\n\n      tq.addTask('test');\n      await tq.processNext();\n    });\n\n    it('should skip processing when middleware does not call next', async () => {\n      let processorCalled = false;\n\n      tq.use('default', async () => {\n        // Don't call next\n      });\n\n      tq.setProcessor('default', async () => {\n        processorCalled = true;\n      });\n\n      tq.addTask('test');\n      await tq.processNext();\n\n      expect(processorCalled).toBe(false);\n    });\n\n    it('should mark task as failed when middleware throws', async () => {\n      tq.use('default', async () => {\n        throw new Error('middleware error');\n      });\n\n      const task = tq.addTask('test');\n      await tq.processNext();\n\n      const updated = tq.getTask(task.id)!;\n      expect(updated.status === 'delayed' || updated.status === 'dead-lettered').toBe(true);\n    });\n\n    it('should auto-complete tasks processed through processNext', async () => {\n      tq.setProcessor('default', async () => {\n        // Successful processing\n      });\n\n      const task = tq.addTask('test');\n      await tq.processNext();\n      expect(tq.getTask(task.id)?.status).toBe('completed');\n    });\n\n    it('should return null when no tasks to process', async () => {\n      const result = await tq.processNext();\n      expect(result).toBeNull();\n    });\n\n    it('should have independent middleware stacks per queue', async () => {\n      const q1calls: string[] = [];\n      const q2calls: string[] = [];\n\n      tq.use('q1', async (_task, next) => {\n        q1calls.push('q1-mw');\n        await next();\n      });\n\n      tq.use('q2', async (_task, next) => {\n        q2calls.push('q2-mw');\n        await next();\n      });\n\n      tq.addTask('task1', { queue: 'q1' });\n      tq.addTask('task2', { queue: 'q2' });\n\n      await tq.processNext('q1');\n      await tq.processNext('q2');\n\n      expect(q1calls).toEqual(['q1-mw']);\n      expect(q2calls).toEqual(['q2-mw']);\n    });\n  });\n\n  // ─── Phase 12: Graceful Shutdown ───\n  describe('Phase 12: Graceful Shutdown', () => {\n    it('should reject new tasks after shutdown', async () => {\n      await tq.shutdown();\n      expect(() => tq.addTask('test')).toThrow(/shutting down/);\n    });\n\n    it('should return summary on shutdown', async () => {\n      const result = await tq.shutdown();\n      expect(result).toHaveProperty('completed');\n      expect(result).toHaveProperty('forceCancelled');\n      expect(result).toHaveProperty('elapsed');\n    });\n\n    it('should complete immediately with no processing tasks', async () => {\n      const result = await tq.shutdown();\n      expect(result.completed).toBe(0);\n      expect(result.forceCancelled).toBe(0);\n    });\n\n    it('should force-cancel tasks that exceed timeout', async () => {\n      tq.addTask('slow');\n      tq.getNextTask(); // now processing\n\n      const result = await tq.shutdown(50); // very short timeout\n      expect(result.forceCancelled).toBe(1);\n    });\n\n    it('should run shutdown callbacks', async () => {\n      let callbackRan = false;\n      tq.onShutdown(() => { callbackRan = true; });\n      await tq.shutdown();\n      expect(callbackRan).toBe(true);\n    });\n\n    it('should return same result for multiple shutdown calls', async () => {\n      const r1 = tq.shutdown();\n      const r2 = tq.shutdown();\n      expect(await r1).toBe(await r2);\n    });\n\n    it('should track shutdown status', async () => {\n      expect(tq.isShutdown).toBe(false);\n      await tq.shutdown();\n      expect(tq.isShutdown).toBe(true);\n    });\n  });\n\n  // ─── Integration Tests ───\n  describe('Integration', () => {\n    it('should handle priority + delay interaction', () => {\n      const past = new Date(Date.now() - 1000);\n      tq.addTask('delayed-high', { priority: 1, availableAt: past });\n      tq.addTask('immediate-low', { priority: 10 });\n\n      // High priority should come first even though it was delayed\n      expect(tq.getNextTask()?.payload).toBe('delayed-high');\n    });\n\n    it('should handle dependencies + priority', () => {\n      const dep = tq.addTask('dep', { priority: 10 });\n      tq.addTask('dependent', { priority: 1, dependencies: [dep.id] });\n      tq.addTask('independent', { priority: 5 });\n\n      // First should be independent (dep has lower priority, dependent is blocked)\n      const first = tq.getNextTask();\n      expect(first?.payload).toBe('independent');\n\n      // Next should be dep (only non-blocked remaining)\n      const second = tq.getNextTask();\n      expect(second?.payload).toBe('dep');\n    });\n\n    it('should handle retry + DLQ + redrive lifecycle', () => {\n      const task = tq.addTask('fragile', { maxRetries: 1, backoffDelay: 0 });\n\n      // First attempt fails\n      tq.getNextTask();\n      tq.failTask(task.id, new Error('boom'));\n\n      // Should be in DLQ\n      expect(tq.getTask(task.id)?.status).toBe('dead-lettered');\n      expect(tq.getDeadLetterTasks().length).toBe(1);\n\n      // Redrive it\n      tq.redriveTask(task.id);\n      expect(tq.getDeadLetterTasks().length).toBe(0);\n\n      // Should be available again\n      const next = tq.getNextTask();\n      expect(next?.id).toBe(task.id);\n    });\n\n    it('should process tasks end-to-end with middleware', async () => {\n      const results: string[] = [];\n\n      tq.use('jobs', async (task, next) => {\n        results.push(`pre:${task.payload}`);\n        await next();\n        results.push(`post:${task.payload}`);\n      });\n\n      tq.setProcessor('jobs', async (task) => {\n        results.push(`process:${task.payload}`);\n      });\n\n      tq.addTask('alpha', { queue: 'jobs', priority: 2 });\n      tq.addTask('beta', { queue: 'jobs', priority: 1 });\n\n      await tq.processNext('jobs');\n      await tq.processNext('jobs');\n\n      expect(results).toEqual([\n        'pre:beta',\n        'process:beta',\n        'post:beta',\n        'pre:alpha',\n        'process:alpha',\n        'post:alpha',\n      ]);\n    });\n\n    it('should handle concurrency + processNext', async () => {\n      tq.setConcurrency('default', 1);\n\n      tq.setProcessor('default', async () => {\n        // no-op\n      });\n\n      tq.addTask('a');\n      tq.addTask('b');\n\n      const first = await tq.processNext();\n      expect(first).not.toBeNull();\n\n      // b should now be available since a completed\n      const second = await tq.processNext();\n      expect(second).not.toBeNull();\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":592,"cache_read_input_tokens":35206,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":592},"output_tokens":18,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"d5a6ede0-da20-4658-b3ef-351c6e047148","uuid":"182e0161-4692-48f3-a7fa-01ae004d3d95"}
+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TBxhnmkG9GkMfk4fjiSPzS","type":"tool_result","content":"File created successfully at: /workspace/src/task-queue.test.ts"}]},"parent_tool_use_id":null,"session_id":"d5a6ede0-da20-4658-b3ef-351c6e047148","uuid":"15a9b8da-3fb1-4d4b-924f-1c88b56a5ff7","tool_use_result":{"type":"create","filePath":"/workspace/src/task-queue.test.ts","content":"import { describe, it, expect, vi, beforeEach } from 'vitest';\nimport { TaskQueue } from './task-queue.js';\n\ndescribe('TaskQueue', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  // ─── Phase 1: Basic FIFO Queue ───\n  describe('Phase 1: Basic FIFO Queue', () => {\n    it('should add a task and return a task object', () => {\n      const task = tq.addTask({ message: 'hello' });\n      expect(task).toBeDefined();\n      expect(task.id).toBeDefined();\n      expect(task.payload).toEqual({ message: 'hello' });\n      expect(task.status).toBe('pending');\n      expect(task.createdAt).toBeInstanceOf(Date);\n    });\n\n    it('should generate unique IDs for each task', () => {\n      const t1 = tq.addTask('a');\n      const t2 = tq.addTask('b');\n      expect(t1.id).not.toBe(t2.id);\n    });\n\n    it('should return tasks in FIFO order', () => {\n      tq.addTask('first');\n      tq.addTask('second');\n      tq.addTask('third');\n\n      const next1 = tq.getNextTask();\n      expect(next1?.payload).toBe('first');\n      const next2 = tq.getNextTask();\n      expect(next2?.payload).toBe('second');\n      const next3 = tq.getNextTask();\n      expect(next3?.payload).toBe('third');\n    });\n\n    it('should transition task to processing when retrieved', () => {\n      tq.addTask('test');\n      const task = tq.getNextTask();\n      expect(task?.status).toBe('processing');\n    });\n\n    it('should return null when no tasks available', () => {\n      const task = tq.getNextTask();\n      expect(task).toBeNull();\n    });\n\n    it('should track pending count', () => {\n      expect(tq.getPendingCount()).toBe(0);\n      tq.addTask('a');\n      tq.addTask('b');\n      expect(tq.getPendingCount()).toBe(2);\n      tq.getNextTask();\n      expect(tq.getPendingCount()).toBe(1);\n    });\n\n    it('should not return already-processing tasks', () => {\n      tq.addTask('only');\n      tq.getNextTask();\n      expect(tq.getNextTask()).toBeNull();\n    });\n  });\n\n  // ─── Phase 2: Named Queues ───\n  describe('Phase 2: Named Queues', () => {\n    it('should support named queues', () => {\n      tq.addTask('email-task', { queue: 'email' });\n      tq.addTask('sms-task', { queue: 'sms' });\n\n      const emailTask = tq.getNextTask('email');\n      expect(emailTask?.payload).toBe('email-task');\n\n      const smsTask = tq.getNextTask('sms');\n      expect(smsTask?.payload).toBe('sms-task');\n    });\n\n    it('should use default queue when no name specified', () => {\n      tq.addTask('default-task');\n      const task = tq.getNextTask('default');\n      expect(task?.payload).toBe('default-task');\n    });\n\n    it('should list all queue names', () => {\n      tq.addTask('a', { queue: 'q1' });\n      tq.addTask('b', { queue: 'q2' });\n      const queues = tq.getQueues();\n      expect(queues).toContain('q1');\n      expect(queues).toContain('q2');\n    });\n\n    it('should return null for non-existent queue', () => {\n      expect(tq.getNextTask('nonexistent')).toBeNull();\n    });\n\n    it('should keep queues independent', () => {\n      tq.addTask('a', { queue: 'q1' });\n      expect(tq.getNextTask('q2')).toBeNull();\n      expect(tq.getNextTask('q1')?.payload).toBe('a');\n    });\n  });\n\n  // ─── Phase 3: Priority ───\n  describe('Phase 3: Priority', () => {\n    it('should return higher priority tasks first (lower number = higher priority)', () => {\n      tq.addTask('low', { priority: 10 });\n      tq.addTask('high', { priority: 1 });\n      tq.addTask('mid', { priority: 5 });\n\n      expect(tq.getNextTask()?.payload).toBe('high');\n      expect(tq.getNextTask()?.payload).toBe('mid');\n      expect(tq.getNextTask()?.payload).toBe('low');\n    });\n\n    it('should use FIFO order for same priority', () => {\n      tq.addTask('first', { priority: 5 });\n      tq.addTask('second', { priority: 5 });\n      tq.addTask('third', { priority: 5 });\n\n      expect(tq.getNextTask()?.payload).toBe('first');\n      expect(tq.getNextTask()?.payload).toBe('second');\n      expect(tq.getNextTask()?.payload).toBe('third');\n    });\n\n    it('should default to priority 5', () => {\n      const task = tq.addTask('test');\n      expect(task.priority).toBe(5);\n    });\n\n    it('should reject invalid priority values', () => {\n      expect(() => tq.addTask('bad', { priority: 0 })).toThrow();\n      expect(() => tq.addTask('bad', { priority: 11 })).toThrow();\n      expect(() => tq.addTask('bad', { priority: 1.5 })).toThrow();\n    });\n\n    it('should expose priority level on task', () => {\n      const task = tq.addTask('test', { priority: 3 });\n      expect(task.priority).toBe(3);\n    });\n  });\n\n  // ─── Phase 4: Delayed and Scheduled Tasks ───\n  describe('Phase 4: Delayed Tasks', () => {\n    it('should not return delayed tasks before their availability time', () => {\n      tq.addTask('delayed', { delay: 100000 });\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should return delayed tasks after their availability time', () => {\n      const past = new Date(Date.now() - 1000);\n      tq.addTask('available', { availableAt: past });\n      expect(tq.getNextTask()?.payload).toBe('available');\n    });\n\n    it('should prefer non-delayed tasks over unavailable delayed tasks', () => {\n      tq.addTask('delayed', { delay: 100000 });\n      tq.addTask('immediate');\n      expect(tq.getNextTask()?.payload).toBe('immediate');\n    });\n\n    it('should set status to delayed for future tasks', () => {\n      const task = tq.addTask('future', { delay: 100000 });\n      expect(task.status).toBe('delayed');\n    });\n\n    it('should indicate availability time on task', () => {\n      const task = tq.addTask('delayed', { delay: 5000 });\n      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now());\n    });\n\n    it('should support specific availableAt date', () => {\n      const future = new Date(Date.now() + 50000);\n      const task = tq.addTask('scheduled', { availableAt: future });\n      expect(task.availableAt).toEqual(future);\n      expect(task.status).toBe('delayed');\n    });\n\n    it('should order multiple available delayed tasks by availability time then priority', () => {\n      const past1 = new Date(Date.now() - 2000);\n      const past2 = new Date(Date.now() - 1000);\n      tq.addTask('later', { availableAt: past2, priority: 1 });\n      tq.addTask('earlier', { availableAt: past1, priority: 1 });\n\n      // Same priority, so ordered by availability time\n      expect(tq.getNextTask()?.payload).toBe('earlier');\n      expect(tq.getNextTask()?.payload).toBe('later');\n    });\n  });\n\n  // ─── Phase 5: Retry with Backoff ───\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should complete a processing task', () => {\n      const task = tq.addTask('test');\n      tq.getNextTask();\n      tq.completeTask(task.id);\n      expect(tq.getTask(task.id)?.status).toBe('completed');\n    });\n\n    it('should fail and retry a task with exponential backoff', () => {\n      const task = tq.addTask('retryable', { maxRetries: 3, backoffDelay: 100 });\n      tq.getNextTask();\n      tq.failTask(task.id, new Error('fail'));\n\n      const updated = tq.getTask(task.id)!;\n      expect(updated.status).toBe('delayed');\n      expect(updated.attempt).toBe(1);\n      expect(updated.failureCount).toBe(1);\n    });\n\n    it('should use exponential backoff formula: baseDelay * 2^(attempt-1)', () => {\n      const task = tq.addTask('test', { maxRetries: 3, backoffDelay: 1000 });\n\n      // First attempt\n      tq.getNextTask();\n      const beforeFail = Date.now();\n      tq.failTask(task.id, new Error('fail'));\n      const updated = tq.getTask(task.id)!;\n      // First retry delay: 1000 * 2^0 = 1000ms\n      expect(updated.availableAt.getTime()).toBeGreaterThanOrEqual(beforeFail + 1000 - 50);\n    });\n\n    it('should track attempt count', () => {\n      const task = tq.addTask('test', { maxRetries: 3, backoffDelay: 0 });\n\n      // First attempt\n      tq.getNextTask();\n      expect(tq.getTask(task.id)!.attempt).toBe(1);\n    });\n\n    it('should default maxRetries to 3', () => {\n      const task = tq.addTask('test');\n      expect(task.maxRetries).toBe(3);\n    });\n\n    it('should keep original queue and priority on retry', () => {\n      const task = tq.addTask('test', {\n        queue: 'myqueue',\n        priority: 2,\n        maxRetries: 3,\n        backoffDelay: 0\n      });\n      tq.getNextTask('myqueue');\n      tq.failTask(task.id);\n\n      const updated = tq.getTask(task.id)!;\n      expect(updated.queue).toBe('myqueue');\n      expect(updated.priority).toBe(2);\n    });\n\n    it('should move task to dead-lettered state when retries exhausted', () => {\n      const task = tq.addTask('test', { maxRetries: 1, backoffDelay: 0 });\n\n      tq.getNextTask();\n      tq.failTask(task.id, new Error('fail'));\n\n      const updated = tq.getTask(task.id)!;\n      expect(updated.status).toBe('dead-lettered');\n    });\n  });\n\n  // ─── Phase 6: Dead Letter Queue ───\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move exhausted tasks to DLQ', () => {\n      const task = tq.addTask('test', { maxRetries: 1, backoffDelay: 0 });\n      tq.getNextTask();\n      tq.failTask(task.id, new Error('permanent failure'));\n\n      const dlq = tq.getDeadLetterTasks();\n      expect(dlq.length).toBe(1);\n      expect(dlq[0].id).toBe(task.id);\n    });\n\n    it('should retain error information on dead-lettered tasks', () => {\n      const task = tq.addTask('test', { maxRetries: 1, backoffDelay: 0 });\n      tq.getNextTask();\n      tq.failTask(task.id, new Error('specific error'));\n\n      const dlq = tq.getDeadLetterTasks();\n      expect(dlq[0].error?.message).toBe('specific error');\n    });\n\n    it('should allow redriving dead-lettered tasks', () => {\n      const task = tq.addTask('test', { maxRetries: 1, backoffDelay: 0 });\n      tq.getNextTask();\n      tq.failTask(task.id, new Error('fail'));\n\n      const redriven = tq.redriveTask(task.id);\n      expect(redriven.status).toBe('pending');\n      expect(redriven.attempt).toBe(0);\n\n      const next = tq.getNextTask();\n      expect(next?.id).toBe(task.id);\n    });\n\n    it('should clear dead letter queue', () => {\n      const task = tq.addTask('test', { maxRetries: 1, backoffDelay: 0 });\n      tq.getNextTask();\n      tq.failTask(task.id);\n\n      const cleared = tq.clearDeadLetterQueue();\n      expect(cleared).toBe(1);\n      expect(tq.getDeadLetterTasks().length).toBe(0);\n    });\n\n    it('should have independent DLQs per queue', () => {\n      const t1 = tq.addTask('test1', { queue: 'q1', maxRetries: 1 });\n      const t2 = tq.addTask('test2', { queue: 'q2', maxRetries: 1 });\n\n      tq.getNextTask('q1');\n      tq.failTask(t1.id, new Error('fail'));\n      tq.getNextTask('q2');\n      tq.failTask(t2.id, new Error('fail'));\n\n      expect(tq.getDeadLetterTasks('q1').length).toBe(1);\n      expect(tq.getDeadLetterTasks('q2').length).toBe(1);\n    });\n  });\n\n  // ─── Phase 7: Task Dependencies ───\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block tasks with unresolved dependencies', () => {\n      const dep = tq.addTask('dependency');\n      const task = tq.addTask('dependent', { dependencies: [dep.id] });\n      expect(task.status).toBe('blocked');\n\n      // Should not return blocked task\n      const next = tq.getNextTask();\n      expect(next?.id).toBe(dep.id);\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should unblock tasks when dependencies complete', () => {\n      const dep = tq.addTask('dependency');\n      const task = tq.addTask('dependent', { dependencies: [dep.id] });\n\n      tq.getNextTask();\n      tq.completeTask(dep.id);\n\n      const next = tq.getNextTask();\n      expect(next?.id).toBe(task.id);\n    });\n\n    it('should reject dependencies on non-existent tasks', () => {\n      expect(() => tq.addTask('bad', { dependencies: ['nonexistent'] })).toThrow();\n    });\n\n    it('should block when dependency fails (remain blocked)', () => {\n      const dep = tq.addTask('dependency', { maxRetries: 1 });\n      tq.addTask('dependent', { dependencies: [dep.id] });\n\n      tq.getNextTask();\n      tq.failTask(dep.id, new Error('fail'));\n\n      // Dependent should still be blocked\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should inspect dependency status', () => {\n      const dep1 = tq.addTask('dep1');\n      const dep2 = tq.addTask('dep2');\n      const task = tq.addTask('dependent', { dependencies: [dep1.id, dep2.id] });\n\n      let status = tq.getTaskDependencyStatus(task.id);\n      expect(status.total).toBe(2);\n      expect(status.resolved).toBe(0);\n      expect(status.pending.length).toBe(2);\n\n      tq.getNextTask(); // gets dep1 (higher FIFO)\n      tq.completeTask(dep1.id);\n\n      status = tq.getTaskDependencyStatus(task.id);\n      expect(status.resolved).toBe(1);\n      expect(status.pending.length).toBe(1);\n    });\n\n    it('should handle multiple dependencies', () => {\n      const dep1 = tq.addTask('dep1');\n      const dep2 = tq.addTask('dep2');\n      const task = tq.addTask('dependent', { dependencies: [dep1.id, dep2.id] });\n\n      // Complete dep1\n      tq.getNextTask();\n      tq.completeTask(dep1.id);\n\n      // Task should still be blocked (dep2 not done)\n      const updatedTask = tq.getTask(task.id)!;\n      expect(updatedTask.status).toBe('blocked');\n\n      // Complete dep2\n      tq.getNextTask();\n      tq.completeTask(dep2.id);\n\n      // Now task should be available\n      const next = tq.getNextTask();\n      expect(next?.id).toBe(task.id);\n    });\n  });\n\n  // ─── Phase 8: Concurrency Control ───\n  describe('Phase 8: Concurrency Control', () => {\n    it('should limit concurrent processing tasks', () => {\n      tq.setConcurrency('default', 2);\n      tq.addTask('a');\n      tq.addTask('b');\n      tq.addTask('c');\n\n      expect(tq.getNextTask()?.payload).toBe('a');\n      expect(tq.getNextTask()?.payload).toBe('b');\n      expect(tq.getNextTask()).toBeNull(); // limit reached\n    });\n\n    it('should free up slots when tasks complete', () => {\n      tq.setConcurrency('default', 1);\n      const task = tq.addTask('a');\n      tq.addTask('b');\n\n      tq.getNextTask();\n      expect(tq.getNextTask()).toBeNull();\n\n      tq.completeTask(task.id);\n      expect(tq.getNextTask()?.payload).toBe('b');\n    });\n\n    it('should track active count', () => {\n      tq.addTask('a');\n      tq.addTask('b');\n\n      expect(tq.getActiveCount()).toBe(0);\n      tq.getNextTask();\n      expect(tq.getActiveCount()).toBe(1);\n    });\n\n    it('should default to no limit (unlimited)', () => {\n      expect(tq.getConcurrency('default')).toBeUndefined();\n    });\n\n    it('should interact correctly with priority', () => {\n      tq.setConcurrency('default', 1);\n      tq.addTask('low', { priority: 10 });\n      tq.addTask('high', { priority: 1 });\n\n      // Should get high priority first\n      expect(tq.getNextTask()?.payload).toBe('high');\n    });\n  });\n\n  // ─── Phase 9: Progress Tracking and Cancellation ───\n  describe('Phase 9: Progress and Cancellation', () => {\n    it('should update and query progress', () => {\n      const task = tq.addTask('test');\n      tq.getNextTask();\n\n      tq.updateProgress(task.id, 50, 'halfway');\n      const progress = tq.getProgress(task.id);\n      expect(progress.progress).toBe(50);\n      expect(progress.message).toBe('halfway');\n    });\n\n    it('should notify progress subscribers', () => {\n      const task = tq.addTask('test');\n      tq.getNextTask();\n\n      const updates: Array<{ progress: number; message?: string }> = [];\n      tq.onProgress(task.id, (progress, message) => {\n        updates.push({ progress, message });\n      });\n\n      tq.updateProgress(task.id, 25, 'quarter');\n      tq.updateProgress(task.id, 75, 'three-quarters');\n\n      expect(updates.length).toBe(2);\n      expect(updates[0].progress).toBe(25);\n      expect(updates[1].progress).toBe(75);\n    });\n\n    it('should support unsubscribing from progress', () => {\n      const task = tq.addTask('test');\n      tq.getNextTask();\n\n      const updates: number[] = [];\n      const unsub = tq.onProgress(task.id, (progress) => {\n        updates.push(progress);\n      });\n\n      tq.updateProgress(task.id, 25);\n      unsub();\n      tq.updateProgress(task.id, 75);\n\n      expect(updates.length).toBe(1);\n    });\n\n    it('should cancel a pending task', () => {\n      const task = tq.addTask('test');\n      tq.cancelTask(task.id);\n      expect(tq.getTask(task.id)?.status).toBe('cancelled');\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should cancel a processing task', () => {\n      const task = tq.addTask('test');\n      tq.getNextTask();\n      tq.cancelTask(task.id);\n      expect(tq.getTask(task.id)?.status).toBe('cancelled');\n    });\n\n    it('should not retry cancelled tasks', () => {\n      const task = tq.addTask('test', { maxRetries: 3 });\n      tq.getNextTask();\n      tq.cancelTask(task.id);\n      expect(tq.getTask(task.id)?.status).toBe('cancelled');\n    });\n\n    it('should reject invalid progress values', () => {\n      const task = tq.addTask('test');\n      tq.getNextTask();\n      expect(() => tq.updateProgress(task.id, -1)).toThrow();\n      expect(() => tq.updateProgress(task.id, 101)).toThrow();\n    