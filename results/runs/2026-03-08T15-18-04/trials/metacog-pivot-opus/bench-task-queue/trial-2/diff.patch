n    });\n\n    if (!nextCalled) {\n      setSkipped(true);\n    }\n  }","new_string":"  async processNext(queueName: string = DEFAULT_QUEUE): Promise<Task | null> {\n    const task = this.getNextTask(queueName);\n    if (!task) return null;\n\n    const middlewareStack = this.middlewares.get(queueName) ?? [];\n    const processor = this.processors.get(queueName);\n\n    try {\n      let handlerReached = false;\n\n      const runPipeline = (index: number): Promise<void> => {\n        if (index >= middlewareStack.length) {\n          // End of middleware chain - run the processor\n          handlerReached = true;\n          if (processor && task.status === 'processing') {\n            return processor(task);\n          }\n          return Promise.resolve();\n        }\n\n        return middlewareStack[index](task, () => runPipeline(index + 1));\n      };\n\n      await runPipeline(0);\n\n      if (!handlerReached) {\n        // Middleware didn't call next - task processing was skipped\n        if (task.status === 'processing') {\n          task.status = 'pending';\n          task.attempt -= 1;\n        }\n        return task;\n      }\n\n      if (task.status === 'processing') {\n        this.completeTask(task.id);\n      }\n    } catch (err) {\n      if (task.status === 'processing') {\n        this.failTask(task.id, err instanceof Error ? err : new Error(String(err)));\n      }\n    }\n\n    return task;\n  }"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":961,"cache_read_input_tokens":48031,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":961},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"d5a6ede0-da20-4658-b3ef-351c6e047148","uuid":"a28f70ec-ce4f-4c7c-8de6-279a95369f03"}
