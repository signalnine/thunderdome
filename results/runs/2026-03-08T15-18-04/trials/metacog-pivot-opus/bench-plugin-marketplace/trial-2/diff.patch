index 0000000..ebddaca
--- /dev/null
+++ b/src/runner/index.ts
@@ -0,0 +1,91 @@
+import vm from 'node:vm';
+import type { SandboxResult, RunnerService } from '../types.js';
+
+export function createRunner(): RunnerService {
+  async function runInSandbox(
+    code: string,
+    timeoutMs: number,
+    context: Record<string, unknown> = {},
+  ): Promise<SandboxResult> {
+    const startTime = performance.now();
+    const startMemory = process.memoryUsage().heapUsed;
+
+    try {
+      const sandbox: Record<string, unknown> = {
+        ...context,
+        console: {
+          log: (...args: unknown[]) => {
+            outputs.push(args.map(String).join(' '));
+          },
+          error: (...args: unknown[]) => {
+            outputs.push(args.map(String).join(' '));
+          },
+          warn: (...args: unknown[]) => {
+            outputs.push(args.map(String).join(' '));
+          },
+        },
+      };
+      const outputs: string[] = [];
+
+      const vmContext = vm.createContext(sandbox);
+
+      const script = new vm.Script(code, { filename: 'plugin.js' });
+      const result = script.runInContext(vmContext, {
+        timeout: timeoutMs,
+      });
+
+      const endTime = performance.now();
+      const endMemory = process.memoryUsage().heapUsed;
+
+      return {
+        success: true,
+        output: result !== undefined ? result : outputs.length > 0 ? outputs.join('\n') : undefined,
+        duration: endTime - startTime,
+        memoryUsed: Math.max(0, endMemory - startMemory),
+      };
+    } catch (err: unknown) {
+      const endTime = performance.now();
+      const endMemory = process.memoryUsage().heapUsed;
+
+      let errorMessage: string;
+      if (err instanceof Error) {
+        errorMessage = err.message;
+      } else if (
+        typeof err === 'object' &&
+        err !== null &&
+        'message' in err &&
+        typeof (err as { message: unknown }).message === 'string'
+      ) {
+        // VM sandbox errors aren't instanceof Error but have a message property
+        errorMessage = (err as { message: string }).message;
+      } else {
+        errorMessage = String(err);
+      }
+
+      return {
+        success: false,
+        output: undefined,
+        duration: endTime - startTime,
+        memoryUsed: Math.max(0, endMemory - startMemory),
+        error: errorMessage,
+      };
+    }
+  }
+
+  return {
+    async execute(
+      code: string,
+      context?: Record<string, unknown>,
+    ): Promise<SandboxResult> {
+      return runInSandbox(code, 5000, context);
+    },
+
+    async executeWithTimeout(
+      code: string,
+      timeoutMs: number,
+      context?: Record<string, unknown>,
+    ): Promise<SandboxResult> {
+      return runInSandbox(code, timeoutMs, context);
+    },
+  };
+}
