+import { describe, it, expect, beforeEach } from 'vitest';
+import { createResolver } from './index.js';
+import type { ResolverService } from '../types.js';
+
+describe('VersionResolver', () => {
+  let resolver: ResolverService;
+
+  beforeEach(() => {
+    resolver = createResolver();
+  });
+
+  it('should resolve a simple constraint', () => {
+    const results = resolver.resolve(
+      [{ name: 'foo', range: '^1.0.0' }],
+      { foo: ['1.0.0', '1.1.0', '1.2.0', '2.0.0'] },
+    );
+    expect(results).toHaveLength(1);
+    expect(results[0].name).toBe('foo');
+    expect(results[0].version).toBe('1.2.0');
+    expect(results[0].satisfies).toBe('^1.0.0');
+  });
+
+  it('should resolve multiple constraints', () => {
+    const results = resolver.resolve(
+      [
+        { name: 'foo', range: '^1.0.0' },
+        { name: 'bar', range: '~2.1.0' },
+      ],
+      {
+        foo: ['1.0.0', '1.5.0', '2.0.0'],
+        bar: ['2.0.0', '2.1.0', '2.1.5', '2.2.0'],
+      },
+    );
+    expect(results).toHaveLength(2);
+    expect(results[0].version).toBe('1.5.0');
+    expect(results[1].version).toBe('2.1.5');
+  });
+
+  it('should throw for unavailable plugin', () => {
+    expect(() =>
+      resolver.resolve(
+        [{ name: 'missing', range: '^1.0.0' }],
+        {},
+      ),
+    ).toThrow(/No versions available/);
+  });
+
+  it('should throw when no version satisfies range', () => {
+    expect(() =>
+      resolver.resolve(
+        [{ name: 'foo', range: '^3.0.0' }],
+        { foo: ['1.0.0', '2.0.0'] },
+      ),
+    ).toThrow(/No version of "foo" satisfies/);
+  });
+
+  it('satisfies should check version against range', () => {
+    expect(resolver.satisfies('1.2.3', '^1.0.0')).toBe(true);
+    expect(resolver.satisfies('2.0.0', '^1.0.0')).toBe(false);
+    expect(resolver.satisfies('1.0.0', '>=1.0.0 <2.0.0')).toBe(true);
+  });
+
+  it('maxSatisfying should find best match', () => {
+    expect(resolver.maxSatisfying(['1.0.0', '1.5.0', '2.0.0'], '^1.0.0')).toBe('1.5.0');
+    expect(resolver.maxSatisfying(['1.0.0', '2.0.0'], '^3.0.0')).toBeNull();
+  });
+
+  it('validRange should validate semver ranges', () => {
+    expect(resolver.validRange('^1.0.0')).toBe(true);
+    expect(resolver.validRange('~2.0.0')).toBe(true);
+    expect(resolver.validRange('>=1.0.0')).toBe(true);
+    expect(resolver.validRange('not-a-range')).toBe(false);
+  });
+});
