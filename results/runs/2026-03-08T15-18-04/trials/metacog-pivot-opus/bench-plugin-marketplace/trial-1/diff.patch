+import { describe, it, expect, beforeEach } from 'vitest';
+import { createReviewService } from './index.js';
+import type { ReviewService } from '../types.js';
+
+describe('ReviewService', () => {
+  let reviews: ReviewService;
+
+  beforeEach(() => {
+    reviews = createReviewService(':memory:');
+  });
+
+  it('adds and retrieves reviews', () => {
+    const review = reviews.addReview({
+      pluginName: 'my-plugin',
+      pluginVersion: '1.0.0',
+      userId: 'user1',
+      rating: 5,
+      comment: 'Great plugin!',
+    });
+    expect(review.id).toBeDefined();
+    expect(review.flagged).toBe(false);
+    expect(review.createdAt).toBeDefined();
+
+    const retrieved = reviews.getReviews('my-plugin');
+    expect(retrieved).toHaveLength(1);
+    expect(retrieved[0].comment).toBe('Great plugin!');
+  });
+
+  it('computes average rating excluding flagged', () => {
+    reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });
+    reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: '' });
+    const flagged = reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u3', rating: 1, comment: 'spam' });
+    reviews.flagReview(flagged.id);
+
+    const avg = reviews.getAverageRating('p');
+    expect(avg).toBe(4); // (5+3)/2 = 4
+  });
+
+  it('returns 0 average for no reviews', () => {
+    expect(reviews.getAverageRating('nonexistent')).toBe(0);
+  });
+
+  it('flags reviews', () => {
+    const review = reviews.addReview({
+      pluginName: 'p',
+      pluginVersion: '1.0.0',
+      userId: 'u1',
+      rating: 1,
+      comment: 'spam',
+    });
+    reviews.flagReview(review.id);
+    const flagged = reviews.getFlaggedReviews();
+    expect(flagged).toHaveLength(1);
+    expect(flagged[0].flagged).toBe(true);
+  });
+
+  it('removes reviews', () => {
+    const review = reviews.addReview({
+      pluginName: 'p',
+      pluginVersion: '1.0.0',
+      userId: 'u1',
+      rating: 5,
+      comment: 'nice',
+    });
+    expect(reviews.removeReview(review.id)).toBe(true);
+    expect(reviews.getReviews('p')).toHaveLength(0);
+  });
+
+  it('returns false when removing non-existent review', () => {
+    expect(reviews.removeReview(999)).toBe(false);
+  });
+
+  it('gets reviews by user', () => {
+    reviews.addReview({ pluginName: 'a', pluginVersion: '1.0.0', userId: 'user1', rating: 5, comment: '' });
+    reviews.addReview({ pluginName: 'b', pluginVersion: '1.0.0', userId: 'user1', rating: 4, comment: '' });
+    reviews.addReview({ pluginName: 'c', pluginVersion: '1.0.0', userId: 'user2', rating: 3, comment: '' });
+
+    const user1Reviews = reviews.getReviewsByUser('user1');
+    expect(user1Reviews).toHaveLength(2);
+  });
+
+  it('counts reviews for a plugin', () => {
+    reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });
+    reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u2', rating: 4, comment: '' });
+    expect(reviews.getReviewCount('p')).toBe(2);
+  });
+});
