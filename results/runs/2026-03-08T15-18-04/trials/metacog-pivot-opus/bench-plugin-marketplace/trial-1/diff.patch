@@ -0,0 +1,121 @@
+import type { DependencyNode, RegistryService, DepsService } from '../types.js';
+
+export function createDepsService(): DepsService {
+  function buildTreeInternal(
+    name: string,
+    registry: RegistryService,
+    visited: Set<string>
+  ): DependencyNode {
+    const manifest = registry.get(name);
+    if (!manifest) {
+      return { name, version: 'unknown', dependencies: [] };
+    }
+
+    const nodeKey = `${name}@${manifest.version}`;
+    if (visited.has(nodeKey)) {
+      return { name, version: manifest.version, dependencies: [] };
+    }
+    visited.add(nodeKey);
+
+    const deps: DependencyNode[] = [];
+    for (const depName of Object.keys(manifest.dependencies)) {
+      deps.push(buildTreeInternal(depName, registry, new Set(visited)));
+    }
+
+    return {
+      name,
+      version: manifest.version,
+      dependencies: deps,
+    };
+  }
+
+  function detectCyclesInternal(
+    name: string,
+    registry: RegistryService,
+    path: string[],
+    cycles: string[][]
+  ): void {
+    if (path.includes(name)) {
+      const cycleStart = path.indexOf(name);
+      cycles.push([...path.slice(cycleStart), name]);
+      return;
+    }
+
+    const manifest = registry.get(name);
+    if (!manifest) return;
+
+    path.push(name);
+    for (const depName of Object.keys(manifest.dependencies)) {
+      detectCyclesInternal(depName, registry, path, cycles);
+    }
+    path.pop();
+  }
+
+  function topoSortInternal(
+    name: string,
+    registry: RegistryService,
+    visited: Set<string>,
+    result: string[]
+  ): void {
+    if (visited.has(name)) return;
+    visited.add(name);
+
+    const manifest = registry.get(name);
+    if (manifest) {
+      for (const depName of Object.keys(manifest.dependencies)) {
+        topoSortInternal(depName, registry, visited, result);
+      }
+    }
+
+    result.push(name);
+  }
+
+  function flattenInternal(
+    name: string,
+    registry: RegistryService,
+    visited: Set<string>,
+    result: string[]
+  ): void {
+    const manifest = registry.get(name);
+    if (!manifest) return;
+
+    for (const depName of Object.keys(manifest.dependencies)) {
+      if (!visited.has(depName)) {
+        visited.add(depName);
+        result.push(depName);
+        flattenInternal(depName, registry, visited, result);
+      }
+    }
+  }
+
+  return {
+    buildTree(name: string, registry: RegistryService): DependencyNode {
+      return buildTreeInternal(name, registry, new Set());
+    },
+
+    detectCycles(name: string, registry: RegistryService): string[][] | null {
+      const cycles: string[][] = [];
+      detectCyclesInternal(name, registry, [], cycles);
+      return cycles.length > 0 ? cycles : null;
+    },
+
+    topologicalSort(name: string, registry: RegistryService): string[] {
+      const visited = new Set<string>();
+      const result: string[] = [];
+      topoSortInternal(name, registry, visited, result);
+      return result;
+    },
+
+    flattenDependencies(name: string, registry: RegistryService): string[] {
+      const visited = new Set<string>();
+      const result: string[] = [];
+      flattenInternal(name, registry, visited, result);
+      return result;
+    },
+
+    hasCircularDependency(name: string, registry: RegistryService): boolean {
+      const cycles = this.detectCycles(name, registry);
+      return cycles !== null;
+    },
+  };
+}
