+import express from 'express';
+import { createStore } from './store.js';
+import { createAuthMiddleware, createAuthRouter } from './auth.js';
+import { createFolderRouter } from './folders.js';
+import { createDocumentRouter } from './documents.js';
+import { createShareRouter } from './sharing.js';
+import { createActivityRouter } from './activity.js';
+
+export function createApp() {
+  const app = express();
+  const store = createStore();
+
+  app.use(express.json());
+
+  // Public routes
+  app.use('/auth', createAuthRouter(store));
+
+  // Protected routes
+  const authMiddleware = createAuthMiddleware(store);
+  app.use('/folders', authMiddleware, createFolderRouter(store));
+  app.use('/documents', authMiddleware, createDocumentRouter(store));
+  app.use('/share', authMiddleware, createShareRouter(store));
+  app.use('/activity', authMiddleware, createActivityRouter(store));
+
+  return app;
+}
