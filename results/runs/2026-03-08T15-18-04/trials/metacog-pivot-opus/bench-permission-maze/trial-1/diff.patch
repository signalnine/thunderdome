diff --git a/src/activity.ts b/src/activity.ts
new file mode 100644
index 0000000..235d597
--- /dev/null
+++ b/src/activity.ts
@@ -0,0 +1,44 @@
+import { Request, Response, Router } from 'express';
+import { ResourceType } from './types.js';
+import { Store, generateId } from './store.js';
+
+export function addActivity(
+  store: Store,
+  action: string,
+  userId: string,
+  resourceType: ResourceType,
+  resourceId: string,
+  details?: string
+): void {
+  store.activityLog.push({
+    id: generateId(store),
+    action,
+    userId,
+    resourceType,
+    resourceId,
+    timestamp: new Date().toISOString(),
+    details,
+  });
+}
+
+export function createActivityRouter(store: Store): Router {
+  const router = Router();
+
+  router.get('/', (req: Request, res: Response) => {
+    // Return activity log, optionally filtered
+    const { resourceType, resourceId } = req.query;
+    let logs = store.activityLog;
+
+    if (resourceType) {
+      logs = logs.filter((l) => l.resourceType === resourceType);
+    }
+    if (resourceId) {
+      logs = logs.filter((l) => l.resourceId === resourceId);
+    }
+
+    // Return in reverse chronological order
+    res.json(logs.slice().reverse());
+  });
+
+  return router;
+}
