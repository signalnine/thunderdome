+  it('should filter activity by resourceType', async () => {
+    const alice = await registerAndLogin('alice');
+    const bob = await registerAndLogin('bob');
+    const folder = await createFolder(alice.token, 'Folder');
+    await createDocument(alice.token, 'Doc', 'Content', folder.body.id);
+    await shareResource(alice.token, 'folder', folder.body.id, bob.userId, 'viewer');
+
+    const res = await request(app)
+      .get('/activity?resourceType=document')
+      .set('Authorization', `Bearer ${alice.token}`);
+    expect(res.status).toBe(200);
+    for (const entry of res.body) {
+      expect(entry.resourceType).toBe('document');
+    }
+  });
+
+  it('activity log entries have required fields', async () => {
+    const alice = await registerAndLogin('alice');
+    const folder = await createFolder(alice.token, 'Folder');
+    await createDocument(alice.token, 'Doc', 'Content', folder.body.id);
+
+    const res = await request(app)
+      .get('/activity')
+      .set('Authorization', `Bearer ${alice.token}`);
+    expect(res.body.length).toBeGreaterThan(0);
+    const entry = res.body[0];
+    expect(entry.action).toBeDefined();
+    expect(entry.userId).toBeDefined();
+    expect(entry.resourceType).toBeDefined();
+    expect(entry.resourceId).toBeDefined();
+    expect(entry.timestamp).toBeDefined();
+  });
+});
