+import { Request, Response, Router } from 'express';
+import { Store, generateId } from './store.js';
+import { canRead, canEdit, canDelete } from './permissions.js';
+
+export function createFolderRouter(store: Store): Router {
+  const router = Router();
+
+  // Create folder
+  router.post('/', (req: Request, res: Response) => {
+    const userId = req.userId!;
+    const { name, parentId } = req.body;
+    if (!name) {
+      res.status(400).json({ error: 'Folder name is required' });
+      return;
+    }
+    // Validate parent folder exists if provided
+    if (parentId) {
+      const parent = store.folders.get(parentId);
+      if (!parent) {
+        res.status(404).json({ error: 'Parent folder not found' });
+        return;
+      }
+      // Need at least editor access on parent to create subfolder
+      if (!canEdit(store, userId, 'folder', parentId)) {
+        res.status(403).json({ error: 'Insufficient permissions on parent folder' });
+        return;
+      }
+    }
+
+    const id = generateId(store);
+    const folder = {
+      id,
+      name,
+      parentId: parentId || null,
+      ownerId: userId,
+      createdAt: new Date().toISOString(),
+    };
+    store.folders.set(id, folder);
+
+    // Grant owner permission
+    store.permissions.push({
+      id: generateId(store),
+      resourceType: 'folder',
+      resourceId: id,
+      userId,
+      role: 'owner',
+    });
+
+    res.status(201).json(folder);
+  });
+
+  // Get folder
+  router.get('/:id', (req: Request, res: Response) => {
+    const userId = req.userId!;
+    const folder = store.folders.get(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+    if (!canRead(store, userId, 'folder', folder.id)) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    // Include child folders and documents
+    const children: { id: string; name: string }[] = [];
+    for (const f of store.folders.values()) {
+      if (f.parentId === folder.id) {
+        children.push({ id: f.id, name: f.name });
+      }
+    }
+    const documents: { id: string; title: string }[] = [];
+    for (const d of store.documents.values()) {
+      if (d.folderId === folder.id) {
+        documents.push({ id: d.id, title: d.title });
+      }
+    }
+
+    res.json({ ...folder, children, documents });
+  });
+
+  // Update folder
+  router.put('/:id', (req: Request, res: Response) => {
+    const userId = req.userId!;
+    const folder = store.folders.get(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+    if (!canEdit(store, userId, 'folder', folder.id)) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+    const { name, parentId } = req.body;
+    if (name !== undefined) folder.name = name;
+    if (parentId !== undefined) {
+      if (parentId !== null) {
+        const parent = store.folders.get(parentId);
+        if (!parent) {
+          res.status(404).json({ error: 'Parent folder not found' });
+          return;
+        }
+      }
+      folder.parentId = parentId;
+    }
+    res.json(folder);
+  });
+
+  // Delete folder
+  router.delete('/:id', (req: Request, res: Response) => {
+    const userId = req.userId!;
+    const folder = store.folders.get(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+    if (!canDelete(store, userId, 'folder', folder.id)) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+    store.folders.delete(folder.id);
+    // Remove associated permissions
+    store.permissions = store.permissions.filter(
+      (p) => !(p.resourceType === 'folder' && p.resourceId === folder.id)
+    );
+    res.status(204).send();
+  });
+
+  return router;
+}
diff --git a/src/permissions.ts b/src/permissions.ts
new file mode 100644
index 0000000..bffe67c
--- /dev/null
+++ b/src/permissions.ts
@@ -0,0 +1,138 @@
+import { Role, ResourceType } from './types.js';
+import { Store } from './store.js';
+
+const ROLE_LEVELS: Record<Role, number> = {
+  viewer: 1,
+  editor: 2,
+  owner: 3,
+};
+
+export function higherRole(a: Role | null, b: Role | null): Role | null {
+  if (!a) return b;
+  if (!b) return a;
+  return ROLE_LEVELS[a] >= ROLE_LEVELS[b] ? a : b;
+}
+
+export function getAncestorFolderIds(store: Store, folderId: string): string[] {
+  const ancestors: string[] = [];
+  let currentId: string | null = folderId;
+  const visited = new Set<string>();
+  while (currentId) {
+    if (visited.has(currentId)) break;
+    visited.add(currentId);
+    const folder = store.folders.get(currentId);
+    if (!folder) break;
+    if (folder.parentId) {
+      ancestors.push(folder.parentId);
+    }
+    currentId = folder.parentId;
+  }
+  return ancestors;
+}
+
+export function getEffectiveRole(
+  store: Store,
+  userId: string,
+  resourceType: ResourceType,
+  resourceId: string
+): Role | null {
+  let effectiveRole: Role | null = null;
+
+  // Check direct permissions on the resource
+  for (const perm of store.permissions) {
+    if (
+      perm.resourceType === resourceType &&
+      perm.resourceId === resourceId &&
+      perm.userId === userId
+    ) {
+      effectiveRole = higherRole(effectiveRole, perm.role);
+    }
+  }
+
+  // If it's a document, check permissions on its folder and ancestor folders
+  if (resourceType === 'document') {
+    const doc = store.documents.get(resourceId);
+    if (doc) {
+      const folderIds = [doc.folderId, ...getAncestorFolderIds(store, doc.folderId)];
+      for (const fid of folderIds) {
+        for (const perm of store.permissions) {
+          if (
+            perm.resourceType === 'folder' &&
+            perm.resourceId === fid &&
+            perm.userId === userId
+          ) {
+            effectiveRole = higherRole(effectiveRole, perm.role);
+          }
+        }
+      }
+    }
+  }
+
+  // If it's a folder, check ancestor folder permissions
+  if (resourceType === 'folder') {
+    const ancestorIds = getAncestorFolderIds(store, resourceId);
+    for (const fid of ancestorIds) {
+      for (const perm of store.permissions) {
+        if (
+          perm.resourceType === 'folder' &&
+          perm.resourceId === fid &&
+          perm.userId === userId
+        ) {
+          effectiveRole = higherRole(effectiveRole, perm.role);
+        }
+      }
+    }
+  }
+
+  return effectiveRole;
+}
+
+export function canRead(
+  store: Store,
+  userId: string,
+  resourceType: ResourceType,
+  resourceId: string
+): boolean {
+  const role = getEffectiveRole(store, userId, resourceType, resourceId);
+  return role !== null;
+}
+
+export function canEdit(
+  store: Store,
+  userId: string,
+  resourceType: ResourceType,
+  resourceId: string
+): boolean {
+  const role = getEffectiveRole(store, userId, resourceType, resourceId);
+  return role === 'editor' || role === 'owner';
+}
+
+export function canDelete(
+  store: Store,
+  userId: string,
+  resourceType: ResourceType,
+  resourceId: string
+): boolean {
+  const role = getEffectiveRole(store, userId, resourceType, resourceId);
+  return role === 'owner';
+}
+
+export function canShare(
+  store: Store,
+  userId: string,
+  resourceType: ResourceType,
+  resourceId: string
+): boolean {
+  const role = getEffectiveRole(store, userId, resourceType, resourceId);
+  return role === 'editor' || role === 'owner';
+}
+
+export function canManageRoles(
+  store: Store,
+  userId: string,
+  resourceType: ResourceType,
+  resourceId: string
+): boolean {
+  const role = getEffectiveRole(store, userId, resourceType, resourceId);
+  return role === 'owner';
+}
diff --git a/src/sharing.ts b/src/sharing.ts
new file mode 100644
index 0000000..42e3082
--- /dev/null
+++ b/src/sharing.ts
@@ -0,0 +1,121 @@
+import { Request, Response, Router } from 'express';
+import { Role, ResourceType } from './types.js';
+import { Store, generateId } from './store.js';
+import { canShare, canManageRoles, getEffectiveRole } from './permissions.js';
+import { addActivity } from './activity.js';
+
+const VALID_ROLES: Role[] = ['viewer', 'editor', 'owner'];
+
+export function createShareRouter(store: Store): Router {
+  const router = Router();
+
+  // Share a resource with a user
+  router.post('/', (req: Request, res: Response) => {
+    const userId = req.userId!;
+    const { resourceType, resourceId, targetUserId, role } = req.body as {
+      resourceType?: ResourceType;
+      resourceId?: string;
+      targetUserId?: string;
+      role?: Role;
+    };
+
+    if (!resourceType || !resourceId || !targetUserId || !role) {
+      res.status(400).json({ error: 'resourceType, resourceId, targetUserId, and role are required' });
+      return;
+    }
+
+    if (!VALID_ROLES.includes(role)) {
+      res.status(400).json({ error: 'Invalid role. Must be viewer, editor, or owner' });
+      return;
+    }
+
+    if (resourceType !== 'folder' && resourceType !== 'document') {
+      res.status(400).json({ error: 'Invalid resourceType. Must be folder or document' });
+      return;
+    }
+
+    // Verify resource exists
+    if (resourceType === 'folder' && !store.folders.has(resourceId)) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+    if (resourceType === 'document' && !store.documents.has(resourceId)) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    // Verify target user exists
+    if (!store.users.has(targetUserId)) {
+      res.status(404).json({ error: 'Target user not found' });
+      return;
+    }
+
+    // Check if the sharing user has permission to share
+    if (!canShare(store, userId, resourceType, resourceId)) {
+      res.status(403).json({ error: 'You do not have permission to share this resource' });
+      return;
+    }
+
+    // Only owners can assign owner role
+    if (role === 'owner' && !canManageRoles(store, userId, resourceType, resourceId)) {
+      res.status(403).json({ error: 'Only owners can assign the owner role' });
+      return;
+    }
+
+    // Check if a permission already exists for this user+resource combo
+    const existing = store.permissions.find(
+      (p) =>
+        p.resourceType === resourceType &&
+        p.resourceId === resourceId &&
+        p.userId === targetUserId
+    );
+
+    if (existing) {
+      existing.role = role;
+    } else {
+      store.permissions.push({
+        id: generateId(store),
+        resourceType,
+        resourceId,
+        userId: targetUserId,
+        role,
+      });
+    }
+
+    addActivity(
+      store,
+      'shared',
+      userId,
+      resourceType,
+      resourceId,
+      `Shared with user ${targetUserId} as ${role}`
+    );
+
+    res.status(200).json({ message: 'Permission granted', resourceType, resourceId, targetUserId, role });
+  });
+
+  // Get permissions for a resource
+  router.get('/:resourceType/:resourceId', (req: Request, res: Response) => {
+    const userId = req.userId!;
+    const { resourceType, resourceId } = req.params;
+
+    if (resourceType !== 'folder' && resourceType !== 'document') {
+      res.status(400).json({ error: 'Invalid resourceType' });
+      return;
+    }
+
+    // Check if user can at least read the resource
+    const role = getEffectiveRole(store, userId, resourceType as ResourceType, resourceId);
+    if (!role) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    const perms = store.permissions.filter(
+      (p) => p.resourceType === resourceType && p.resourceId === resourceId
+    );
+    res.json(perms);
+  });
+
+  return router;
+}
diff --git a/src/store.ts b/src/store.ts
