@@ -0,0 +1,25 @@
+import { User, Folder, Document, Permission, ActivityLogEntry } from './types.js';
+
+export interface Store {
+  users: Map<string, User>;
+  folders: Map<string, Folder>;
+  documents: Map<string, Document>;
+  permissions: Permission[];
+  activityLog: ActivityLogEntry[];
+  nextId: number;
+}
+
+export function createStore(): Store {
+  return {
+    users: new Map(),
+    folders: new Map(),
+    documents: new Map(),
+    permissions: [],
+    activityLog: [],
+    nextId: 1,
+  };
+}
+
+export function generateId(store: Store): string {
+  return String(store.nextId++);
+}
diff --git a/src/types.ts b/src/types.ts
new file mode 100644
index 0000000..3c6d982
--- /dev/null
+++ b/src/types.ts
@@ -0,0 +1,46 @@
+export type Role = 'viewer' | 'editor' | 'owner';
+
+export interface User {
+  id: string;
+  username: string;
+  password: string;
+  token: string | null;
+}
+
+export interface Folder {
+  id: string;
+  name: string;
+  parentId: string | null;
+  ownerId: string;
+  createdAt: string;
+}
+
+export interface Document {
+  id: string;
+  title: string;
+  content: string;
+  folderId: string;
+  ownerId: string;
+  createdAt: string;
+  updatedAt: string;
+}
+
+export type ResourceType = 'folder' | 'document';
+
+export interface Permission {
+  id: string;
+  resourceType: ResourceType;
+  resourceId: string;
+  userId: string;
+  role: Role;
+}
+
+export interface ActivityLogEntry {
