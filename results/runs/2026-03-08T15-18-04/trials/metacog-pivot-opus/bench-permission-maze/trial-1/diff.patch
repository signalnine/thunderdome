@@ -0,0 +1,116 @@
+import { Request, Response, Router } from 'express';
+import { Store, generateId } from './store.js';
+import { canRead, canEdit, canDelete } from './permissions.js';
+import { addActivity } from './activity.js';
+
+export function createDocumentRouter(store: Store): Router {
+  const router = Router();
+
+  // Create document
+  router.post('/', (req: Request, res: Response) => {
+    const userId = req.userId!;
+    const { title, content, folderId } = req.body;
+    if (!title || content === undefined || !folderId) {
+      res.status(400).json({ error: 'Title, content, and folderId are required' });
+      return;
+    }
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+    // Need at least editor access on the folder to create a document
+    if (!canEdit(store, userId, 'folder', folderId)) {
+      res.status(403).json({ error: 'Insufficient permissions on folder' });
+      return;
+    }
+
+    const id = generateId(store);
+    const now = new Date().toISOString();
+    const doc = {
+      id,
+      title,
+      content,
+      folderId,
+      ownerId: userId,
+      createdAt: now,
+      updatedAt: now,
+    };
+    store.documents.set(id, doc);
+
+    // Grant owner permission
+    store.permissions.push({
+      id: generateId(store),
+      resourceType: 'document',
+      resourceId: id,
+      userId,
+      role: 'owner',
+    });
+
+    addActivity(store, 'document_created', userId, 'document', id);
+
+    res.status(201).json(doc);
+  });
+
+  // Get document
+  router.get('/:id', (req: Request, res: Response) => {
+    const userId = req.userId!;
+    const doc = store.documents.get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    if (!canRead(store, userId, 'document', doc.id)) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+    res.json(doc);
+  });
+
+  // Update document
+  router.put('/:id', (req: Request, res: Response) => {
+    const userId = req.userId!;
+    const doc = store.documents.get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    if (!canEdit(store, userId, 'document', doc.id)) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+    const { title, content } = req.body;
+    if (title !== undefined) doc.title = title;
+    if (content !== undefined) doc.content = content;
+    doc.updatedAt = new Date().toISOString();
+
+    addActivity(store, 'document_updated', userId, 'document', doc.id);
+
+    res.json(doc);
+  });
+
+  // Delete document
+  router.delete('/:id', (req: Request, res: Response) => {
+    const userId = req.userId!;
+    const doc = store.documents.get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    if (!canDelete(store, userId, 'document', doc.id)) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    addActivity(store, 'document_deleted', userId, 'document', doc.id);
+
+    store.documents.delete(doc.id);
+    // Remove associated permissions
+    store.permissions = store.permissions.filter(
+      (p) => !(p.resourceType === 'document' && p.resourceId === doc.id)
+    );
+    res.status(204).send();
+  });
+
+  return router;
+}
