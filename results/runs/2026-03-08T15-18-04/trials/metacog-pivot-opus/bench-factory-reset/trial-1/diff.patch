+
+  // For binary, we can represent solutions more efficiently
+  // Generate all solutions for first half
+  const best = particular.slice();
+
+  // Generate all 2^half1 partial offsets from first half of null basis
+  const firstHalfSolutions: number[][] = [];
+  for (let mask = 0; mask < (1 << half1); mask++) {
+    const offset = new Array(numButtons).fill(0);
+    for (let f = 0; f < half1; f++) {
+      if (mask & (1 << f)) {
+        for (let i = 0; i < numButtons; i++) {
+          offset[i] ^= nullBasis[f][i];
+        }
+      }
+    }
+    firstHalfSolutions.push(offset);
+  }
+
+  // For each second-half combination, combine with all first-half combinations
+  for (let mask2 = 0; mask2 < (1 << half2); mask2++) {
+    const offset2 = new Array(numButtons).fill(0);
+    for (let f = 0; f < half2; f++) {
+      if (mask2 & (1 << f)) {
+        for (let i = 0; i < numButtons; i++) {
+          offset2[i] ^= nullBasis[half1 + f][i];
+        }
+      }
+    }
+
+    for (const offset1 of firstHalfSolutions) {
+      const candidate = new Array(numButtons);
+      for (let i = 0; i < numButtons; i++) {
+        candidate[i] = particular[i] ^ offset1[i] ^ offset2[i];
+      }
+      if (compareSolutions(candidate, best) < 0) {
+        for (let i = 0; i < numButtons; i++) {
+          best[i] = candidate[i];
+        }
+      }
+    }
+  }
+
+  return best;
+}
+
+function greedyMinimize(
+  particular: number[],
+  nullBasis: number[][],
+  numButtons: number,
+  modulus: number
+): number[] {
+  // Greedy approach: try each null basis vector with each scale
+  // and accept if it improves the solution
+  let current = particular.slice();
+  let improved = true;
+
+  while (improved) {
+    improved = false;
+    for (const nullVec of nullBasis) {
+      for (let scale = 1; scale < modulus; scale++) {
+        const candidate = addNullVector(current, nullVec, scale, modulus);
+        if (compareSolutions(candidate, current) < 0) {
+          current = candidate;
+          improved = true;
+        }
+      }
+    }
+  }
+
+  return current;
+}
+
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const numLights = target.length;
+  const numButtons = buttons.length;
+
+  // Convert boolean target to numeric (0/1)
+  const numericTarget = target.map(t => t ? 1 : 0);
+
+  const solution = solveLinearSystem(numLights, numButtons, buttons, numericTarget, 2);
+  if (solution === null) return null;
+
+  // Convert to array of button indices that are pressed (value=1), sorted ascending
+  const result: number[] = [];
+  for (let i = 0; i < numButtons; i++) {
+    if (solution[i] === 1) {
+      result.push(i);
+    }
+  }
+
+  return result;
+}
+
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numLights = lights.length;
+  const numButtons = buttons.length;
+
+  const solution = solveLinearSystem(numLights, numButtons, buttons, lights, modulus);
+  if (solution === null) return null;
+
+  return solution;
+}
