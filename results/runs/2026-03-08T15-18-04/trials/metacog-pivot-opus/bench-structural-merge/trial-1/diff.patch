versions.map((v) => ({\n   366→      id: v.id,\n   367→      timestamp: v.timestamp,\n   368→      content: deepClone(v.content),\n   369→    }));\n   370→  }\n   371→\n   372→  getVersion(id: string, versionId: string): object {\n   373→    const branch = this.getCurrentBranchData();\n   374→    const entry = branch.docs.get(id);\n   375→    if (!entry) {\n   376→      throw new Error(`Document \"${id}\" not found`);\n   377→    }\n   378→    const version = entry.versions.find((v) => v.id === versionId);\n   379→    if (!version) {\n   380→      throw new Error(`Version \"${versionId}\" not found for document \"${id}\"`);\n   381→    }\n   382→    return deepClone(version.content);\n   383→  }\n   384→\n   385→  // ── Branching ────────────────────────────────────────────────────────────\n   386→\n   387→  createBranch(name: string, fromBranch?: string): void {\n   388→    if (this.branches.has(name)) {\n   389→      throw new Error(`Branch \"${name}\" already exists`);\n   390→    }\n   391→\n   392→    const sourceName = fromBranch ?? this.currentBranch;\n   393→    const source = this.branches.get(sourceName);\n   394→    if (!source) {\n   395→      throw new Error(`Branch \"${sourceName}\" not found`);\n   396→    }\n   397→\n   398→    const clonedDocs = cloneDocs(source.docs);\n   399→    const snapshot = cloneDocs(source.docs);\n   400→\n   401→    this.branches.set(name, {\n   402→      docs: clonedDocs,\n   403→      parent: { branch: sourceName, snapshot },\n   404→    });\n   405→  }\n   406→\n   407→  switchBranch(name: string): void {\n   408→    if (!this.branches.has(name)) {\n   409→      throw new Error(`Branch \"${name}\" not found`);\n   410→    }\n   411→    this.currentBranch = name;\n   412→  }\n   413→\n   414→  getBranch(): string {\n   415→    return this.currentBranch;\n   416→  }\n   417→\n   418→  listBranches(): string[] {\n   419→    return Array.from(this.branches.keys());\n   420→  }\n   421→\n   422→  // ── Merging ───────────────