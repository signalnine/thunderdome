loneDocEntry(entry));\n  }\n  return result;\n}\n\n/**\n * Get the current content of a document (latest version), or null if deleted / not present.\n */\nfunction currentContent(entry: DocEntry | undefined): object | null {\n  if (!entry || entry.deleted || entry.versions.length === 0) return null;\n  return entry.versions[entry.versions.length - 1].content;\n}\n\n// ── Three-way merge utilities ────────────────────────────────────────────────\n\nfunction isPlainObject(val: unknown): val is Record<string, unknown> {\n  return val !== null && typeof val === \"object\" && !Array.isArray(val);\n}\n\ninterface DiffEntry {\n  path: string;\n  oldVal: unknown;\n  newVal: unknown;\n}\n\n/**\n * Compute a flat list of changed leaf paths between two objects.\n * `base` and `obj` are both plain objects (or null to represent absence).\n */\nfunction computeDiff(\n  base: Record<string, unknown> | null,\n  obj: Record<string, unknown> | null,\n  prefix: string = \"\"\n): DiffEntry[] {\n  const diffs: DiffEntry[] = [];\n  const baseObj = base ?? {};\n  const curObj = obj ?? {};\n\n  const allKeys = new Set([...Object.keys(baseObj), ...Object.keys(curObj)]);\n\n  for (const key of allKeys) {\n    const path = prefix ? `${prefix}.${key}` : key;\n    const baseVal = baseObj[key];\n    const curVal = curObj[key];\n\n    if (isPlainObject(baseVal) && isPlainObject(curVal)) {\n      diffs.push(...computeDiff(baseVal as Record<string, unknown>, curVal as Record<string, unknown>, path));\n    } else if (!deepEqual(baseVal, curVal)) {\n      diffs.push({ path, oldVal: baseVal, newVal: curVal });\n    }\n  }\n\n  return diffs;\n}\n\nfunction deepEqual(a: unknown, b: unknown): boolean {\n  if (a === b) return true;\n  if (a === null || b === null || a === undefined || b === undefined) return a === b;\n  if (typeof a !== typeof b) return false;\n  if (typeof a !== \"object\") return false;\n\n  if (Array.isArray(a) && Array.isArray(b)) {\n    if (a.length !== b.length) return false;\n    return a.every((val, i) => deepEqual(val, b[i]));\n  }\n\n  if (Array.isArray(a) !== Array.isArray(b)) return false;\n\n  const aObj = a as Record<string, unknown>;\n  const bObj = b as Record<string, unknown>;\n  const aKeys = Object.keys(aObj);\n  const bKeys = Object.keys(bObj);\n  if (aKeys.length !== bKeys.length) return false;\n  return aKeys.every((key) => deepEqual(aObj[key], bObj[key]));\n}\n\n/**\n * Set a value at a dot-separated path in an object. Creates intermediate objects as needed.\n */\nfunction setAtPath(obj: Record<string, unknown>, path: string, value: unknown): void {\n  const parts = path.split(\".\");\n  let cur: Record<string, unknown> = obj;\n  for (let i = 0; i < parts.length - 1; i++) {\n    if (!isPlainObject(cur[parts[i]])) {\n      cur[parts[i]] = {};\n    }\n    cur = cur[parts[i]] as Record<string, unknown>;\n  }\n  cur[parts[parts.length - 1]] = value;\n}\n\n/**\n * Delete a key at a dot-separated path in an object.\n */\nfunction deleteAtPath(obj: Record<string, unknown>, path: string): void {\n  const parts = path.split(\".\");\n  let cur: Record<string, unknown> = obj;\n  for (let i = 0; i < parts.length - 1; i++) {\n    if (!isPlainObject(cur[parts[i]])) return;\n    cur = cur[parts[i]] as Record<string, unknown>;\n  }\n  delete cur[parts[parts.length - 1]];\n}\n\n/**\n * Get a value at a dot-separated path.\n */\nfunction getAtPath(obj: Record<string, unknown>, path: string): unknown {\n  const parts = path.split(\".\");\n  let cur: unknown = obj;\n  for (const part of parts) {\n    if (!isPlainObject(cur)) return undefined;\n    cur = (cur as Record<string, unknown>)[part];\n  }\n  return cur;\n}\n\n/**\n * Three-way merge of two objects against a common base.\n * Returns the merged object and any conflicts.\n */\nfunction threeWayMerge(\n  base: Record<string, unknown> | null,\n  ours: Record<string, unknown> | null,\n  theirs: Record<string, unknown> | null,\n  documentId: string\n): { merged: Record<string, unknown>; conflicts: Conflict[] } {\n  const oursDiffs = computeDiff(base, ours);\n  const theirsDiffs = computeDiff(base, theirs);\n\n  const conflicts: Conflict[] = [];\n\n  // Start with a deep clone of ours as the base for the merged result\n  const merged = deepClone(ours ?? {}) as Record<string, unknown>;\n\n  // Build a map of theirs' changes by path for quick lookup\n  const theirsMap = new Map<string, DiffEntry>();\n  for (const d of theirsDiffs) {\n    theirsMap.set(d.path, d);\n  }\n\n  // Build a map of ours' changes by path\n  const oursMap = new Map<string, DiffEntry>();\n  for (const d of oursDiffs) {\n    oursMap.set(d.path, d);\n  }\n\n  // Apply theirs' changes that don't conflict\n  for (const theirDiff of theirsDiffs) {\n    const ourDiff = oursMap.get(theirDiff.path);\n\n    if (!ourDiff) {\n      // Only theirs changed this path — apply it\n      if (theirDiff.newVal === undefined) {\n        deleteAtPath(merged, theirDiff.path);\n      } else {\n        setAtPath(merged, theirDiff.path, deepClone(theirDiff.newVal));\n      }\n    } else {\n      // Both changed this path\n      if (deepEqual(ourDiff.newVal, theirDiff.newVal)) {\n        // Same change — no conflict, ours already has it\n      } else {\n        // Conflict — ours wins in merged, but report conflict\n        conflicts.push({\n          documentId,\n          path: theirDiff.path,\n          base: theirDiff.oldVal === undefined ? undefined : deepClone(theirDiff.oldVal),\n          ours: ourDiff.newVal === undefined ? undefined : deepClone(ourDiff.newVal),\n          theirs: theirDiff.newVal === undefined ? undefined : deepClone(theirDiff.newVal),\n        });\n      }\n    }\n  }\n\n  return { merged, conflicts };\n}\n\n// ── Find common ancestor ─────────────────────────────────────────────────────\n\n/**\n * Find the common ancestor snapshot between two branches.\n * We walk up the parent chain to find the fork point.\n */\nfunction findCommonAncestor(\n  branches: Map<string, BranchData>,\n  branchA: string,\n  branchB: string\n): Map<string, DocEntry> | null {\n  // Build ancestry chain for branchB (the source being merged)\n  // We need the snapshot of the target branch at the time source was forked from it,\n  // or the snapshot of their common ancestor.\n\n  // Collect ancestor chain for branchB: [branchB_parent_snapshot, grandparent_snapshot, ...]\n  const bAncestors = new Map<string, Map<string, DocEntry>>();\n  let cur: string | undefined = branchB;\n  while (cur) {\n    const data = branches.get(cur);\n    if (!data || !data.parent) break;\n    bAncestors.set(data.parent.branch, data.parent.snapshot);\n    cur = data.parent.branch;\n  }\n\n  // If branchA is in branchB's ancestry, use that snapshot\n  if (bAncestors.has(branchA)) {\n    return bAncestors.get(branchA)!;\n  }\n\n  // Collect ancestor chain for branchA\n  const aAncestors = new Map<string, Map<string, DocEntry>>();\n  cur = branchA;\n  while (cur) {\n    const data = branches.get(cur);\n    if (!data || !data.parent) break;\n    aAncestors.set(data.parent.branch, data.parent.snapshot);\n    cur = data.parent.branch;\n  }\n\n  // If branchB is in branchA's ancestry, use that snapshot\n  if (aAncestors.has(branchB)) {\n    return aAncestors.get(branchB)!;\n  }\n\n  // Look for common ancestor\n  for (const [name, snapshot] of aAncestors) {\n    if (bAncestors.has(name)) {\n      // Both descend from the same branch — use the earlier snapshot\n      // For simplicity, return either snapshot (they should be the same if forked at same time)\n      return snapshot;\n    }\n  }\n\n  // Fallback: if source was created from target, use source's parent snapshot\n  const sourceData = branches.get(branchB);\n  if (sourceData?.parent) {\n    return sourceData.parent.snapshot;\n  }\n\n  // No common ancestor found, treat as empty base\n  return new Map();\n}\n\n// ── DocumentStore ────────────────────────────────────────────────────────────\n\nexport class DocumentStore {\n  private branches: Map<string, BranchData> = new Map();\n  private currentBranch: string = \"main\";\n\n  constructor() {\n    this.branches.set(\"main\", { docs: new Map() });\n  }\n\n  // ── CRUD ─────────────────────────────────────────────────────────────────\n\n  create(id: string, content: object): void {\n    const branch = this.getCurrentBranchData();\n    const existing = branch.docs.get(id);\n    if (existing && !existing.deleted) {\n      throw new Error(`Document \"${id}\" already exists`);\n    }\n\n    const version: Version = {\n      id: nextVersionId(),\n      timestamp: Date.now(),\n      content: deepClone(content),\n    };\n\n    branch.docs.set(id, {\n      versions: existing?.deleted ? [...existing.versions, version] : [version],\n      deleted: false,\n    });\n  }\n\n  get(id: string): object {\n    const branch = this.getCurrentBranchData();\n    const entry = branch.docs.get(id);\n    if (!entry || entry.deleted) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    return deepClone(entry.versions[entry.versions.length - 1].content);\n  }\n\n  update(id: string, content: object): void {\n    const branch = this.getCurrentBranchData();\n    const entry = branch.docs.get(id);\n    if (!entry || entry.deleted) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n\n    const version: Version = {\n      id: nextVersionId(),\n      timestamp: Date.now(),\n      content: deepClone(content),\n    };\n\n    entry.versions.push(version);\n  }\n\n  delete(id: string): void {\n    const branch = this.getCurrentBranchData();\n    const entry = branch.docs.get(id);\n    if (!entry || entry.deleted) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    entry.deleted = true;\n  }\n\n  // ── Version History ──────────────────────────────────────────────────────\n\n  getHistory(id: string): Version[] {\n    const branch = this.getCurrentBranchData();\n    const entry = branch.docs.get(id);\n    if (!entry) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    return entry.versions.map((v) => ({\n      id: v.id,\n      timestamp: v.timestamp,\n      content: deepClone(v.content),\n    }));\n  }\n\n  getVersion(id: string, versionId: string): object {\n    const branch = this.getCurrentBranchData();\n    const entry = branch.docs.get(id);\n    if (!entry) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    const version = entry.versions.find((v) => v.id === versionId);\n    if (!version) {\n      throw new Error(`Version \"${versionId}\" not found for document \"${id}\"`);\n    }\n    return deepClone(version.content);\n  }\n\n  // ── Branching ────────────────────────────────────────────────────────────\n\n  createBranch(name: string, fromBranch?: string): void {\n    if (this.branches.has(name)) {\n      throw new Error(`Branch \"${name}\" already exists`);\n    }\n\n    const sourceName = fromBranch ?? this.currentBranch;\n    const source = this.branches.get(sourceName);\n    if (!source) {\n      throw new Error(`Branch \"${sourceName}\" not found`);\n    }\n\n    const clonedDocs = cloneDocs(source.docs);\n    const snapshot = cloneDocs(source.docs);\n\n    this.branches.set(name, {\n      docs: clonedDocs,\n      parent: { branch: sourceName, snapshot },\n    });\n  }\n\n  switchBranch(name: string): void {\n    if (!this.branches.has(name)) {\n      throw new Error(`Branch \"${name}\" not found`);\n    }\n    this.currentBranch = name;\n  }\n\n  getBranch(): string {\n    return this.currentBranch;\n  }\n\n  listBranches(): string[] {\n    return Array.from(this.branches.keys());\n  }\n\n  // ── Merging ──────────────────────────────────────────────────────────────\n\n  merge(sourceBranch: string): MergeResult {\n    const targetName = this.currentBranch;\n    if (sourceBranch === targetName) {\n      throw new Error(\"Cannot merge a branch into itself\");\n    }\n\n    const sourceData = this.branches.get(sourceBranch);\n    if (!sourceData) {\n      throw