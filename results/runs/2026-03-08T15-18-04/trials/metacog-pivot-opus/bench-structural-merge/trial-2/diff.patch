e('doc1', obj);\n      obj.nested.value = 999;\n      const got = store.get('doc1') as { nested: { value: number } };\n      expect(got.nested.value).toBe(1);\n      got.nested.value = 888;\n      expect((store.get('doc1') as { nested: { value: number } }).nested.value).toBe(1);\n    });\n  });\n\n  describe('Version History', () => {\n    it('should track versions on create and update', () => {\n      const store = new DocumentStore();\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n      store.update('doc1', { v: 3 });\n      const history = store.getHistory('doc1');\n      expect(history).toHaveLength(3);\n      expect(history[0].content).toEqual({ v: 1 });\n      expect(history[1].content).toEqual({ v: 2 });\n      expect(history[2].content).toEqual({ v: 3 });\n    });\n\n    it('should return versions in chronological order', () => {\n      const store = new DocumentStore();\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n      const history = store.getHistory('doc1');\n      expect(history[0].timestamp).toBeLessThanOrEqual(history[1].timestamp);\n    });\n\n    it('should get content at specific version', () => {\n      const store = new DocumentStore();\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n      const history = store.getHistory('doc1');\n      expect(store.getVersion('doc1', history[0].id)).toEqual({ v: 1 });\n      expect(store.getVersion('doc1', history[1].id)).toEqual({ v: 2 });\n    });\n\n    it('should throw for nonexistent version', () => {\n      const store = new DocumentStore();\n      store.create('doc1', { v: 1 });\n      expect(() => store.getVersion('doc1', 'bad-id')).toThrow();\n    });\n  });\n\n  describe('Branching', () => {\n    it('should default to main branch', () => {\n      const store = new DocumentStore();\n      expect(store.getBranch()).toBe('main');\n    });\n\n    it('should create and switch branches', () => {\n      const store = new DocumentStore();\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      expect(store.getBranch()).toBe('feature');\n    });\n\n    it('should list all branches', () => {\n      const store = new DocumentStore();\n      store.createBranch('a');\n      store.createBranch('b');\n      expect(store.listBranches()).toContain('main');\n      expect(store.listBranches()).toContain('a');\n      expect(store.listBranches()).toContain('b');\n    });\n\n    it('should isolate changes between branches', () => {\n      const store = new DocumentStore();\n      store.create('doc1', { branch: 'main' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { branch: 'feature' });\n      expect(store.get('doc1')).toEqual({ branch: 'feature' });\n      store.switchBranch('main');\n      expect(store.get('doc1')).toEqual({ branch: 'main' });\n    });\n\n    it('should throw when switching to nonexistent branch', () => {\n      const store = new DocumentStore();\n      expect(() => store.switchBranch('nope')).toThrow();\n    });\n\n    it('should throw when creating duplicate branch', () => {\n      const store = new DocumentStore();\n      store.createBranch('feature');\n      expect(() => store.createBranch('feature')).toThrow();\n    });\n\n    it('should create branch from specified branch', () => {\n      const store = new DocumentStore();\n      store.create('doc1', { v: 1 });\n      store.createBranch('a');\n      store.switchBranch('a');\n      store.update('doc1', { v: 2 });\n      store.switchBranch('main');\n      store.createBranch('b', 'a');\n      store.switchBranch('b');\n      expect(store.get('doc1')).toEqual({ v: 2 });\n    });\n  });\n\n  describe('Three-way Merge', () => {\n    it('should merge non-conflicting changes', () => {\n      const store = new DocumentStore();\n      store.create('doc1', { a: 1, b: 2, c: 3 });\n      store.createBranch('feature');\n\n      // Modify on main\n      store.update('doc1', { a: 10, b: 2, c: 3 });\n\n      // Modify on feature\n      store.switchBranch('feature');\n      store.update('doc1', { a: 1, b: 20, c: 3 });\n\n      // Merge feature into main\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(result.merged['doc1']).toEqual({ a: 10, b: 20, c: 3 });\n      expect(store.get('doc1')).toEqual({ a: 10, b: 20, c: 3 });\n    });\n\n    it('should detect conflicts', () => {\n      const store = new DocumentStore();\n      store.create('doc1', { a: 1 });\n      store.createBranch('feature');\n\n      store.update('doc1', { a: 2 });\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: 3 });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(false);\n      expect(result.conflicts).toHaveLength(1);\n      expect(result.conflicts[0].documentId).toBe('doc1');\n      expect(result.conflicts[0].path).toBe('a');\n      expect(result.conflicts[0].base).toBe(1);\n      expect(result.conflicts[0].ours).toBe(2);\n      expect(result.conflicts[0].theirs).toBe(3);\n    });\n\n    it('should not apply merge when there are conflicts', () => {\n      const store = new DocumentStore();\n      store.create('doc1', { a: 1 });\n      store.createBranch('feature');\n\n      store.update('doc1', { a: 2 });\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: 3 });\n\n      store.switchBranch('main');\n      store.merge('feature');\n\n      // Main should still have its own value\n      expect(store.get('doc1')).toEqual({ a: 2 });\n    });\n\n    it('should not conflict when both sides make same change', () => {\n      const store = new DocumentStore();\n      store.create('doc1', { a: 1 });\n      store.createBranch('feature');\n\n      store.update('doc1', { a: 42 });\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: 42 });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(result.merged['doc1']).toEqual({ a: 42 });\n    });\n\n    it('should merge new documents from source branch', () => {\n      const store = new DocumentStore();\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.create('newdoc', { x: 1 });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.merged['newdoc']).toEqual({ x: 1 });\n      expect(store.get('newdoc')).toEqual({ x: 1 });\n    });\n\n    it('should handle nested object merges', () => {\n      const store = new DocumentStore();\n      store.create('doc1', { settings: { color: 'red', size: 10 }, name: 'test' });\n      store.createBranch('feature');\n\n      store.update('doc1', { settings: { color: 'blue', size: 10 }, name: 'test' });\n\n      store.switchBranch('feature');\n      store.update('doc1', { settings: { color: 'red', size: 20 }, name: 'test' });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.merged['doc1']).toEqual({\n        settings: { color: 'blue', size: 20 },\n        name: 'test',\n      });\n    });\n\n    it('should handle independent documents merging cleanly', () => {\n      const store = new DocumentStore();\n      store.create('doc1', { a: 1 });\n      store.createBranch('feature');\n\n      store.create('doc2', { b: 2 });\n\n      store.switchBranch('feature');\n      store.create('doc3', { c: 3 });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.merged['doc3']).toEqual({ c: 3 });\n      expect(store.get('doc