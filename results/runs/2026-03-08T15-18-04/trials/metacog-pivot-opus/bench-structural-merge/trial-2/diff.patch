 create and get', () => {\n      const store = new DocumentStore();\n      const obj = { nested: { value: 1 } };\n      store.create('doc1', obj);\n      obj.nested.value = 999;\n      const got = store.get('doc1') as { nested: { value: number } };\n      expect(got.nested.value).toBe(1);\n      got.nested.value = 888;\n      expect((store.get('doc1') as { nested: { value: number } }).nested.value).toBe(1);\n    });\n  });\n\n  describe('Version History', () => {\n    it('should track versions on create and update', () => {\n      const store = new DocumentStore();\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n      store.update('doc1', { v: 3 });\n      const history = store.getHistory('doc1');\n      expect(history).toHaveLength(3);\n      expect(history[0].content).toEqual({ v: 1 });\n      expect(history[1].content).toEqual({ v: 2 });\n      expect(history[2].content).toEqual({ v: 3 });\n    });\n\n    it('should return versions in chronological order', () => {\n      const store = new DocumentStore();\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n      const history = store.getHistory('doc1');\n      expect(history[0].timestamp).toBeLessThanOrEqual(history[1].timestamp);\n    });\n\n    it('should get content at specific version', () => {\n      const store = new DocumentStore();\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n      const history = store.getHistory('doc1');\n      expect(store.getVersion('doc1', history[0].id)).toEqual({ v: 1 });\n      expect(store.getVersion('doc1', history[1].id)).toEqual({ v: 2 });\n    });\n\n    it('should throw for nonexistent version', () => {\n      const store = new DocumentStore();\n      store.create('doc1', { v: 1 });\n      expect(() => store.getVersion('doc1', 'bad-id')).toThrow();\n    });\n  });\n\n  describe('Branching', () => {\n    it('should default to main branch', () => {\n      const store = new DocumentStore