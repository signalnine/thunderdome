w DocumentStore();\n      store.create('doc1', { a: 1, b: 2, c: 3 });\n      store.createBranch('feature');\n\n      // Modify on main\n      store.update('doc1', { a: 10, b: 2, c: 3 });\n\n      // Modify on feature\n      store.switchBranch('feature');\n      store.update('doc1', { a: 1, b: 20, c: 3 });\n\n      // Merge feature into main\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(result.merged['doc1']).toEqual({ a: 10, b: 20, c: 3 });\n      expect(store.get('doc1')).toEqual({ a: 10, b: 20, c: 3 });\n    });\n\n    it('should detect conflicts', () => {\n      const store = new DocumentStore();\n      store.create('doc1', { a: 1 });\n      store.createBranch('feature');\n\n      store.update('doc1', { a: 2 });\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: 3 });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(false);\n      expect(result.conflicts).toHaveLength(1);\n      expect(result.conflicts[0].documentId).toBe('doc1');\n      expect(result.conflicts[0].path).toBe('a');\n      expect(result.conflicts[0].base).toBe(1);\n      expect(result.conflicts[0].ours).toBe(2);\n      expect(result.conflicts[0].theirs).toBe(3);\n    });\n\n    it('should not apply merge when there are conflicts', () => {\n      const store = new DocumentStore();\n      store.create('doc1', { a: 1 });\n      store.createBranch('feature');\n\n      store.update('doc1', { a: 2 });\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: 3 });\n\n      store.switchBranch('main');\n      store.merge('feature');\n\n      // Main should still have its own value\n      expect(store.get('doc1')).toEqual({ a: 2 });\n    });\n\n    it('should not conflict when both sides make same change', () => {\n      const store = new DocumentStore();\n     