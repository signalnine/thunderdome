+import { describe, it, expect } from 'vitest';
+import { DocumentStore } from './index.js';
+
+describe('DocumentStore', () => {
+  describe('Document CRUD', () => {
+    it('should create and get a document', () => {
+      const store = new DocumentStore();
+      store.create('doc1', { name: 'Alice', age: 30 });
+      expect(store.get('doc1')).toEqual({ name: 'Alice', age: 30 });
+    });
+
+    it('should throw when creating duplicate id', () => {
+      const store = new DocumentStore();
+      store.create('doc1', { a: 1 });
+      expect(() => store.create('doc1', { a: 2 })).toThrow();
+    });
+
+    it('should throw when getting nonexistent doc', () => {
+      const store = new DocumentStore();
+      expect(() => store.get('nope')).toThrow();
+    });
+
+    it('should update a document', () => {
+      const store = new DocumentStore();
+      store.create('doc1', { x: 1 });
+      store.update('doc1', { x: 2 });
+      expect(store.get('doc1')).toEqual({ x: 2 });
+    });
+
+    it('should throw when updating nonexistent doc', () => {
+      const store = new DocumentStore();
+      expect(() => store.update('nope', { x: 1 })).toThrow();
+    });
+
+    it('should delete a document', () => {
+      const store = new DocumentStore();
+      store.create('doc1', { x: 1 });
+      store.delete('doc1');
+      expect(() => store.get('doc1')).toThrow();
+    });
+
+    it('should throw when deleting nonexistent doc', () => {
+      const store = new DocumentStore();
+      expect(() => store.delete('nope')).toThrow();
+    });
+
+    it('should deep clone on create and get', () => {
+      const store = new DocumentStore();
+      const obj = { nested: { value: 1 } };
+      store.create('doc1', obj);
+      obj.nested.value = 999;
+      const got = store.get('doc1') as { nested: { value: number } };
+      expect(got.nested.value).toBe(1);
+      got.nested.value = 888;
+      expect((store.get('doc1') as { nested: { value: number } }).nested.value).toBe(1);
+    });
+  });
+
+  describe('Version History', () => {
+    it('should track versions on create and update', () => {
+      const store = new DocumentStore();
+      store.create('doc1', { v: 1 });
+      store.update('doc1', { v: 2 });
+      store.update('doc1', { v: 3 });
+      const history = store.getHistory('doc1');
+      expect(history).toHaveLength(3);
+      expect(history[0].content).toEqual({ v: 1 });
+      expect(history[1].content).toEqual({ v: 2 });
+      expect(history[2].content).toEqual({ v: 3 });
+    });
+
+    it('should return versions in chronological order', () => {
+      const store = new DocumentStore();
+      store.create('doc1', { v: 1 });
+      store.update('doc1', { v: 2 });
+      const history = store.getHistory('doc1');
+      expect(history[0].timestamp).toBeLessThanOrEqual(history[1].timestamp);
+    });
+
+    it('should get content at specific version', () => {
+      const store = new DocumentStore();
+      store.create('doc1', { v: 1 });
+      store.update('doc1', { v: 2 });
+      const history = store.getHistory('doc1');
+      expect(store.getVersion('doc1', history[0].id)).toEqual({ v: 1 });
+      expect(store.getVersion('doc1', history[1].id)).toEqual({ v: 2 });
+    });
+
+    it('should throw for nonexistent version', () => {
+      const store = new DocumentStore();
+      store.create('doc1', { v: 1 });
+      expect(() => store.getVersion('doc1', 'bad-id')).toThrow();
+    });
+  });
+
+  describe('Branching', () => {
+    it('should default to main branch', () => {
+      const store = new DocumentStore();
+      expect(store.getBranch()).toBe('main');
+    });
+
+    it('should create and switch branches', () => {
+      const store = new DocumentStore();
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      expect(store.getBranch()).toBe('feature');
+    });
+
+    it('should list all branches', () => {
+      const store = new DocumentStore();
+      store.createBranch('a');
+      store.createBranch('b');
+      expect(store.listBranches()).toContain('main');
+      expect(store.listBranches()).toContain('a');
+      expect(store.listBranches()).toContain('b');
+    });
+
+    it('should isolate changes between branches', () => {
+      const store = new DocumentStore();
+      store.create('doc1', { branch: 'main' });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { branch: 'feature' });
+      expect(store.get('doc1')).toEqual({ branch: 'feature' });
+      store.switchBranch('main');
+      expect(store.get('doc1')).toEqual({ branch: 'main' });
+    });
+
+    it('should throw when switching to nonexistent branch', () => {
+      const store = new DocumentStore();
+      expect(() => store.switchBranch('nope')).toThrow();
+    });
+
+    it('should throw when creating duplicate branch', () => {
+      const store = new DocumentStore();
+      store.createBranch('feature');
+      expect(() => store.createBranch('feature')).toThrow();
+    });
+
+    it('should create branch from specified branch', () => {
+      const store = new DocumentStore();
+      store.create('doc1', { v: 1 });
+      store.createBranch('a');
+      store.switchBranch('a');
+      store.update('doc1', { v: 2 });
+      store.switchBranch('main');
+      store.createBranch('b', 'a');
+      store.switchBranch('b');
+      expect(store.get('doc1')).toEqual({ v: 2 });
+    });
+  });
+
+  describe('Three-way Merge', () => {
+    it('should merge non-conflicting changes', () => {
+      const store = new DocumentStore();
+      store.create('doc1', { a: 1, b: 2, c: 3 });
+      store.createBranch('feature');
+
+      // Modify on main
+      store.update('doc1', { a: 10, b: 2, c: 3 });
+
+      // Modify on feature
+      store.switchBranch('feature');
+      store.update('doc1', { a: 1, b: 20, c: 3 });
+
+      // Merge feature into main
+      store.switchBranch('main');
+      const result = store.merge('feature');
+
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(result.merged['doc1']).toEqual({ a: 10, b: 20, c: 3 });
+      expect(store.get('doc1')).toEqual({ a: 10, b: 20, c: 3 });
+    });
+
+    it('should detect conflicts', () => {
+      const store = new DocumentStore();
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+
+      store.update('doc1', { a: 2 });
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 3 });
+
+      store.switchBranch('main');
+      const result = store.merge('feature');
+
+      expect(result.applied).toBe(false);
+      expect(result.conflicts).toHaveLength(1);
+      expect(result.conflicts[0].documentId).toBe('doc1');
+      expect(result.conflicts[0].path).toBe('a');
+      expect(result.conflicts[0].base).toBe(1);
+      expect(result.conflicts[0].ours).toBe(2);
+      expect(result.conflicts[0].theirs).toBe(3);
+    });
+
+    it('should not apply merge when there are conflicts', () => {
+      const store = new DocumentStore();
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+
+      store.update('doc1', { a: 2 });
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 3 });
+
+      store.switchBranch('main');
+      store.merge('feature');
+
+      // Main should still have its own value
+      expect(store.get('doc1')).toEqual({ a: 2 });
+    });
+
+    it('should not conflict when both sides make same change', () => {
+      const store = new DocumentStore();
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+
+      store.update('doc1', { a: 42 });
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 42 });
+
+      store.switchBranch('main');
+      const result = store.merge('feature');
+
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(result.merged['doc1']).toEqual({ a: 42 });
+    });
+
+    it('should merge new documents from source branch', () => {
+      const store = new DocumentStore();
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.create('newdoc', { x: 1 });
+
+      store.switchBranch('main');
+      const result = store.merge('feature');
+
+      expect(result.applied).toBe(true);
+      expect(result.merged['newdoc']).toEqual({ x: 1 });
+      expect(store.get('newdoc')).toEqual({ x: 1 });
+    });
+
+    it('should handle nested object merges', () => {
+      const store = new DocumentStore();
+      store.create('doc1', { settings: { color: 'red', size: 10 }, name: 'test' });
+      store.createBranch('feature');
+
+      store.update('doc1', { settings: { color: 'blue', size: 10 }, name: 'test' });
+
+      store.switchBranch('feature');
+      store.update('doc1', { settings: { color: 'red', size: 20 }, name: 'test' });
+
+      store.switchBranch('main');
+      const result = store.merge('feature');
+
+      expect(result.applied).toBe(true);
+      expect(result.merged['doc1']).toEqual({
+        settings: { color: 'blue', size: 20 },
+        name: 'test',
+      });
+    });
+
+    it('should handle independent documents merging cleanly', () => {
+      const store = new DocumentStore();
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+
+      store.create('doc2', { b: 2 });
+
+      store.switchBranch('feature');
+      store.create('doc3', { c: 3 });
+
+      store.switchBranch('main');
+      const result = store.merge('feature');
+
+      expect(result.applied).toBe(true);
+      expect(result.merged['doc3']).toEqual({ c: 3 });
+      expect(store.get('doc3')).toEqual({ c: 3 });
+    });
+
+    it('should provide merged content with ours for conflicts', () => {
+      const store = new DocumentStore();
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+
+      store.update('doc1', { a: 10, b: 2 });
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 20, b: 2 });
+
+      store.switchBranch('main');
+      const result = store.merge('feature');
+
+      expect(result.applied).toBe(false);
+      // merged should show ours for conflicts
+      expect(result.merged['doc1']).toEqual({ a: 10, b: 2 });
+    });
+
+    it('should handle merge when only source changed', () => {
+      const store = new DocumentStore();
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 2 });
+
+      store.switchBranch('main');
+      const result = store.merge('feature');
+
+      expect(result.applied).toBe(true);
+      expect(result.merged['doc1']).toEqual({ a: 2 });
+      expect(store.get('doc1')).toEqual({ a: 2 });
+    });
+
+    it('should handle merge when only target changed', () => {
+      const store = new DocumentStore();
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+
+      store.update('doc1', { a: 2 });
+
+      store.switchBranch('main');
+      const result = store.merge('feature');
+
+      expect(result.applied).toBe(true);
+      expect(result.merged['doc1']).toEqual({ a: 2 });
+    });
+  });
+});
diff --git a/src/index.ts b/src/index.ts
new file mode 100644
index 0000000..180d2a7
--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,654 @@
+export interface Version {
+  id: string;
+  timestamp: number;
+  content: object;
+}
+
+export interface Conflict {
+  documentId: string;
+  path: string;
+  base: unknown;
+  ours: unknown;
+  theirs: unknown;
+}
+
+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+interface DocEntry {
+  content: object;
+  versions: Version[];
+  deleted: boolean;
+}
+
+interface BranchData {
+  docs: Map<string, DocEntry>;
+  forkBase: Map<string, object | null> | null; // snapshot at fork point, null for main
+  parentBranch: string | null;
+}
+
+function deepClone<T>(obj: T): T {
+  if (obj === null || obj === undefined || typeof obj !== 'object') {
+    return obj;
+  }
+  return JSON.parse(JSON.stringify(obj));
+}
+
+function generateId(): string {
+  return Math.random().toString(36).slice(2) + Date.now().toString(36);
+}
+
+function isPlainObject(val: unknown): val is Record<string, unknown> {
+  return val !== null && typeof val === 'object' && !Array.isArray(val);
+}
+
+function deepEqual(a: unknown, b: unknown): boolean {
+  if (a === b) return true;
+  if (a === null || b === null) return a === b;
+  if (typeof a !== typeof b) return false;
+  if (typeof a !== 'object') return a === b;
+  if (Array.isArray(a) !== Array.isArray(b)) return false;
+  if (Array.isArray(a) && Array.isArray(b)) {
+    if (a.length !== b.length) return false;
+    for (let i = 0; i < a.length; i++) {
+      if (!deepEqual(a[i], b[i])) return false;
+    }
+    return true;
+  }
+  const aObj = a as Record<string, unknown>;
+  const bObj = b as Record<string, unknown>;
+  const aKeys = Object.keys(aObj);
+  const bKeys = Object.keys(bObj);
+  if (aKeys.length !== bKeys.length) return false;
+  for (const key of aKeys) {
+    if (!Object.prototype.hasOwnProperty.call(bObj, key)) return false;
+    if (!deepEqual(aObj[key], bObj[key])) return false;
+  }
+  return true;
+}
+
+function collectAllKeys(
+  base: Record<string, unknown> | undefined,
+  ours: Record<string, unknown> | undefined,
+  theirs: Record<string, unknown> | undefined
+): Set<string> {
+  const keys = new Set<string>();
+  if (base) Object.keys(base).forEach((k) => keys.add(k));
+  if (ours) Object.keys(ours).forEach((k) => keys.add(k));
+  if (theirs) Object.keys(theirs).forEach((k) => keys.add(k));
+  return keys;
+}
+
+function threeWayMergeValues(
+  baseVal: unknown,
+  oursVal: unknown,
+  theirsVal: unknown,
+  path: string,
+  documentId: string,
+  conflicts: Conflict[]
+): unknown {
+  const oursChanged = !deepEqual(baseVal, oursVal);
+  const theirsChanged = !deepEqual(baseVal, theirsVal);
+
+  if (!oursChanged && !theirsChanged) {
+    return deepClone(baseVal);
+  }
+  if (oursChanged && !theirsChanged) {
+    return deepClone(oursVal);
+  }
+  if (!oursChanged && theirsChanged) {
+    return deepClone(theirsVal);
+  }
+  // Both changed
+  if (deepEqual(oursVal, theirsVal)) {
+    return deepClone(oursVal);
+  }
+
+  // Both changed to different values - check if we can recurse into objects
+  if (isPlainObject(oursVal) && isPlainObject(theirsVal) && isPlainObject(baseVal)) {
+    return threeWayMergeObjects(
+      baseVal as Record<string, unknown>,
+      oursVal as Record<string, unknown>,
+      theirsVal as Record<string, unknown>,
+      path,
+      documentId,
+      conflicts
+    );
+  }
+
+  // Also handle case where base is undefined (new key on both sides with different values)
+  if (isPlainObject(oursVal) && isPlainObject(theirsVal) && baseVal === undefined) {
+    return threeWayMergeObjects(
+      undefined as unknown as Record<string, unknown>,
+      oursVal as Record<string, unknown>,
+      theirsVal as Record<string, unknown>,
+      path,
+      documentId,
+      conflicts
+    );
+  }
+
+  // Conflict at this leaf
+  conflicts.push({
+    documentId,
+    path,
+    base: deepClone(baseVal),
+    ours: deepClone(oursVal),
+    theirs: deepClone(theirsVal),
+  });
+  // Return "ours" for the merged preview
+  return deepClone(oursVal);
+}
+
+function threeWayMergeObjects(
+  base: Record<string, unknown> | undefined,
+  ours: Record<string, unknown>,
+  theirs: Record<string, unknown>,
+  parentPath: string,
+  documentId: string,
+  conflicts: Conflict[]
+): Record<string, unknown> {
+  const result: Record<string, unknown> = {};
+  const keys = collectAllKeys(base, ours, theirs);
+
+  for (const key of keys) {
+    const baseVal = base ? base[key] : undefined;
+    const oursVal = Object.prototype.hasOwnProperty.call(ours, key) ? ours[key] : undefined;
+    const theirsVal = Object.prototype.hasOwnProperty.call(theirs, key) ? theirs[key] : undefined;
+    const currentPath = parentPath ? `${parentPath}.${key}` : key;
+
+    // Check if the key was deleted on one/both sides
+    const baseHas = base ? Object.prototype.hasOwnProperty.call(base, key) : false;
+    const oursHas = Object.prototype.hasOwnProperty.call(ours, key);
+    const theirsHas = Object.prototype.hasOwnProperty.call(theirs, key);
+
+    // Key doesn't exist in result if both sides agree on deletion, or one deleted and the other didn't change
+    if (baseHas && !oursHas && !theirsHas) {
+      // Both deleted - agree
+      continue;
+    }
+    if (baseHas && !oursHas && theirsHas) {
+      // Ours deleted, theirs kept
+      if (deepEqual(baseVal, theirsVal)) {
+        // Theirs didn't change, ours deleted => take deletion
+        continue;
+      } else {
+        // Conflict: ours deleted but theirs modified
+        conflicts.push({
+          documentId,
+          path: currentPath,
+          base: deepClone(baseVal),
+          ours: undefined,
+          theirs: deepClone(theirsVal),
+        });
+        // "ours" wins in preview => omit key
+        continue;
+      }
+    }
+    if (baseHas && oursHas && !theirsHas) {
+      // Theirs deleted, ours kept
+      if (deepEqual(baseVal, oursVal)) {
+        // Ours didn't change, theirs deleted => take deletion
+        continue;
+      } else {
+        // Conflict: theirs deleted but ours modified
+        conflicts.push({
+          documentId,
+          path: currentPath,
+          base: deepClone(baseVal),
+          ours: deepClone(oursVal),
+          theirs: undefined,
+        });
+        // "ours" wins in preview => keep ours
+        result[key] = deepClone(oursVal);
+        continue;
+      }
+    }
+
+    // If key is new (not in base)
+    if (!baseHas) {
+      if (oursHas && !theirsHas) {
+        result[key] = deepClone(oursVal);
+        continue;
+      }
+      if (!oursHas && theirsHas) {
+        result[key] = deepClone(theirsVal);
+        continue;
+      }
+      // Both added the key
+      const merged = threeWayMergeValues(undefined, oursVal, theirsVal, currentPath, documentId, conflicts);
+      if (merged !== undefined) {
+        result[key] = merged;
+      }
+      continue;
+    }
+
+    // Normal case: key exists in base and both sides
+    const merged = threeWayMergeValues(baseVal, oursVal, theirsVal, currentPath, documentId, conflicts);
+    if (merged !== undefined) {
+      result[key] = merged;
+    }
+  }
+
+  return result;
+}
+
+export class DocumentStore {
+  private branches: Map<string, BranchData> = new Map();
+  private currentBranch: string = 'main';
+
+  constructor() {
+    this.branches.set('main', {
+      docs: new Map(),
+      forkBase: null,
+      parentBranch: null,
+    });
+  }
+
+  private getBranchData(name?: string): BranchData {
+    const branchName = name ?? this.currentBranch;
+    const branch = this.branches.get(branchName);
+    if (!branch) {
+      throw new Error(`Branch "${branchName}" does not exist`);
+    }
+    return branch;
+  }
+
+  // Document CRUD
+
+  create(id: string, content: object): void {
+    const branch = this.getBranchData();
+    const existing = branch.docs.get(id);
+    if (existing && !existing.deleted) {
+      throw new Error(`Document "${id}" already exists`);
+    }
+    const version: Version = {
+      id: generateId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+    branch.docs.set(id, {
+      content: deepClone(content),
+      versions: [version],
+      deleted: false,
+    });
+  }
+
+  get(id: string): object {
+    const branch = this.getBranchData();
+    const doc = branch.docs.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    return deepClone(doc.content);
+  }
+
+  update(id: string, content: object): void {
+    const branch = this.getBranchData();
+    const doc = branch.docs.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    const version: Version = {
+      id: generateId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+    doc.content = deepClone(content);
+    doc.versions.push(version);
+  }
+
+  delete(id: string): void {
+    const branch = this.getBranchData();
+    const doc = branch.docs.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    doc.deleted = true;
+  }
+
+  // Version history
+
+  getHistory(id: string): Version[] {
+    const branch = this.getBranchData();
+    const doc = branch.docs.get(id);
+    if (!doc) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    return doc.versions.map((v) => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    }));
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const branch = this.getBranchData();
+    const doc = branch.docs.get(id);
+    if (!doc) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    const version = doc.versions.find((v) => v.id === versionId);
+    if (!version) {
+      throw new Error(`Version "${versionId}" does not exist for document "${id}"`);
+    }
+    return deepClone(version.content);
+  }
+
+  // Branching
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch "${name}" already exists`);
+    }
+    const sourceName = fromBranch ?? this.currentBranch;
+    const source = this.getBranchData(sourceName);
+
+    // Deep clone all documents for the new branch
+    const newDocs = new Map<string, DocEntry>();
+    for (const [docId, entry] of source.docs) {
+      newDocs.set(docId, {
+        content: deepClone(entry.content),
+        versions: entry.versions.map((v) => ({
+          id: v.id,
+          timestamp: v.timestamp,
+          content: deepClone(v.content),
+        })),
+        deleted: entry.deleted,
+      });
+    }
+
+    // Record the fork base: current state of all docs on source branch
+    const forkBase = new Map<string, object | null>();
+    for (const [docId, entry] of source.docs) {
+      if (!entry.deleted) {
+        forkBase.set(docId, deepClone(entry.content));
+      } else {
+        forkBase.set(docId, null); // doc was deleted at fork time
+      }
+    }
+
+    this.branches.set(name, {
+      docs: newDocs,
+      forkBase,
+      parentBranch: sourceName,
+    });
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch "${name}" does not exist`);
+    }
+    this.currentBranch = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranch;
+  }
+
+  listBranches(): string[] {
+    return Array.from(this.branches.keys());
+  }
+
+  // Merging
+
+  merge(sourceBranch: string): MergeResult {
+    if (!this.branches.has(sourceBranch)) {
+      throw new Error(`Branch "${sourceBranch}" does not exist`);
+    }
+
+    const targetData = this.getBranchData();
+    const sourceData = this.getBranchData(sourceBranch);
+
+    // Find common ancestor - the fork base
+    // We need to determine the base state for three-way merge.
+    // The base is the state at the point where the branches diverged.
+    const base = this.findCommonBase(sourceBranch, this.currentBranch);
+
+    // Collect all document IDs from base, source, and target
+    const allDocIds = new Set<string>();
+    for (const id of base.keys()) allDocIds.add(id);
+    for (const [id, entry] of sourceData.docs) {
+      if (!entry.deleted) allDocIds.add(id);
+    }
+    for (const [id, entry] of targetData.docs) {
+      if (!entry.deleted) allDocIds.add(id);
+    }
+    // Also include deleted docs that existed in base
+    for (const [id, entry] of sourceData.docs) {
+      if (entry.deleted && base.has(id)) allDocIds.add(id);
+    }
+    for (const [id, entry] of targetData.docs) {
+      if (entry.deleted && base.has(id)) allDocIds.add(id);
+    }
+
+    const merged: Record<string, object> = {};
+    const conflicts: Conflict[] = [];
+
+    for (const docId of allDocIds) {
+      const baseContent = base.get(docId) ?? undefined;
+      const sourceEntry = sourceData.docs.get(docId);
+      const targetEntry = targetData.docs.get(docId);
+
+      const sourceContent = sourceEntry && !sourceEntry.deleted ? sourceEntry.content : undefined;
+      const targetContent = targetEntry && !targetEntry.deleted ? targetEntry.content : undefined;
+
+      const sourceDeleted = sourceEntry ? sourceEntry.deleted : !base.has(docId);
+      const targetDeleted = targetEntry ? targetEntry.deleted : !base.has(docId);
+
+      const sourceExists = sourceEntry && !sourceEntry.deleted;
+      const targetExists = targetEntry && !targetEntry.deleted;
+      const baseExists = baseContent !== undefined;
+
+      // Case: document exists nowhere
+      if (!baseExists && !sourceExists && !targetExists) {
+        continue;
+      }
+
+      // Case: document only in base (both deleted) - skip
+      if (baseExists && sourceDeleted && targetDeleted) {
+        continue;
+      }
+
+      // Case: only on source (new document on source branch)
+      if (!baseExists && sourceExists && !targetExists) {
+        merged[docId] = deepClone(sourceContent!);
+        continue;
+      }
+
+      // Case: only on target (new document on target branch)
+      if (!baseExists && !sourceExists && targetExists) {
+        merged[docId] = deepClone(targetContent!);
+        continue;
+      }
+
+      // Case: new on both sides
+      if (!baseExists && sourceExists && targetExists) {
+        const mergedDoc = threeWayMergeObjects(
+          undefined,
+          targetContent as Record<string, unknown>,
+          sourceContent as Record<string, unknown>,
+          '',
+          docId,
+          conflicts
+        );
+        merged[docId] = mergedDoc;
+        continue;
+      }
+
+      // Case: existed in base
+      if (baseExists) {
+        // Source deleted, target didn't change
+        if (sourceDeleted && targetExists && deepEqual(baseContent, targetContent)) {
+          // Source deleted, target unchanged => accept deletion
+          continue;
+        }
+        // Target deleted, source didn't change
+        if (targetDeleted && sourceExists && deepEqual(baseContent, sourceContent)) {
+          // Target deleted, source unchanged => keep deleted
+          continue;
+        }
+        // Source deleted, target modified
+        if (sourceDeleted && targetExists && !deepEqual(baseContent, targetContent)) {
+          // Conflict: one side deleted, other modified
+          conflicts.push({
+            documentId: docId,
+            path: '',
+            base: deepClone(baseContent),
+            ours: deepClone(targetContent!),
+            theirs: undefined,
+          });
+          merged[docId] = deepClone(targetContent!);
+          continue;
+        }
+        // Target deleted, source modified
+        if (targetDeleted && sourceExists && !deepEqual(baseContent, sourceContent)) {
+          conflicts.push({
+            documentId: docId,
+            path: '',
+            base: deepClone(baseContent),
+            ours: undefined,
+            theirs: deepClone(sourceContent!),
+          });
+          continue;
+        }
+        // Both exist — do three-way merge
+        if (sourceExists && targetExists) {
+          const mergedDoc = threeWayMergeObjects(
+            baseContent as Record<string, unknown>,
+            targetContent as Record<string, unknown>,
+            sourceContent as Record<string, unknown>,
+            '',
+            docId,
+            conflicts
+          );
+          merged[docId] = mergedDoc;
+          continue;
+        }
+
+        // Source deleted and target deleted already handled above
+        // Source unchanged and target unchanged
+        if (!sourceExists && !targetExists) {
+          continue;
+        }
+
+        // Only source or target has it
+        if (sourceExists) {
+          merged[docId] = deepClone(sourceContent!);
+        } else if (targetExists) {
+          merged[docId] = deepClone(targetContent!);
+        }
+      }
+    }
+
+    const applied = conflicts.length === 0;
+
+    if (applied) {
+      // Apply the merge to the current branch
+      // First, handle deletions: remove docs that are not in merged but were in base or current
+      for (const [docId, entry] of targetData.docs) {
+        if (!entry.deleted && !(docId in merged)) {
+          // Document was removed by the merge
+          entry.deleted = true;
+        }
+      }
+
+      // Apply merged content
+      for (const [docId, content] of Object.entries(merged)) {
+        const existing = targetData.docs.get(docId);
+        if (existing && !existing.deleted) {
+          // Update if changed
+          if (!deepEqual(existing.content, content)) {
+            const version: Version = {
+              id: generateId(),
+              timestamp: Date.now(),
+              content: deepClone(content),
+            };
+            existing.content = deepClone(content);
+            existing.versions.push(version);
+          }
+        } else if (existing && existing.deleted) {
+          // Revive document
+          const version: Version = {
+            id: generateId(),
+            timestamp: Date.now(),
+            content: deepClone(content),
+          };
+          existing.content = deepClone(content);
+          existing.versions.push(version);
+          existing.deleted = false;
+        } else {
+          // New document from source branch
+          const version: Version = {
+            id: generateId(),
+            timestamp: Date.now(),
+            content: deepClone(content),
+          };
+          targetData.docs.set(docId, {
+            content: deepClone(content),
+            versions: [version],
+            deleted: false,
+          });
+        }
+      }
+    }
+
+    // Deep clone the merged output
+    const mergedClone: Record<string, object> = {};
+    for (const [k, v] of Object.entries(merged)) {
+      mergedClone[k] = deepClone(v);
+    }
+
+    return {
+      merged: mergedClone,
+      conflicts,
+      applied,
+    };
+  }
+
+  private findCommonBase(sourceBranch: string, targetBranch: string): Map<string, object> {
+    const base = new Map<string, object>();
+
+    // The common ancestor is the fork base of whichever branch was created from the other,
+    // or the fork base of the source branch if both were forked from the same parent.
+    const sourceData = this.branches.get(sourceBranch)!;
+    const targetData = this.branches.get(targetBranch)!;
+
+    // If source was forked from target, use source's fork base
+    if (sourceData.parentBranch === targetBranch && sourceData.forkBase) {
+      for (const [id, content] of sourceData.forkBase) {
+        if (content !== null) {
+          base.set(id, content);
+        }
+      }
+      return base;
+    }
+
+    // If target was forked from source, use target's fork base
+    if (targetData.parentBranch === sourceBranch && targetData.forkBase) {
+      for (const [id, content] of targetData.forkBase) {
+        if (content !== null) {
+          base.set(id, content);
+        }
+      }
+      return base;
+    }
+
+    // Both forked from same parent — use the earlier fork point
+    // For simplicity, use source's fork base if available
+    if (sourceData.forkBase) {
+      for (const [id, content] of sourceData.forkBase) {
+        if (content !== null) {
+          base.set(id, content);
+        }
+      }
+      return base;
+    }
+
+    // Fallback: empty base (treat everything as new)
+    return base;
+  }
+}
