+import { describe, it, expect, beforeEach } from 'vitest';
+import { Spreadsheet } from './index.js';
+
+describe('Spreadsheet', () => {
+  let sheet: Spreadsheet;
+
+  beforeEach(() => {
+    sheet = new Spreadsheet();
+  });
+
+  describe('basic values', () => {
+    it('should store and retrieve numbers', () => {
+      sheet.set('A1', 42);
+      expect(sheet.get('A1')).toBe(42);
+    });
+
+    it('should store and retrieve strings', () => {
+      sheet.set('A1', 'hello');
+      expect(sheet.get('A1')).toBe('hello');
+    });
+
+    it('should store and retrieve booleans', () => {
+      sheet.set('A1', true);
+      expect(sheet.get('A1')).toBe(true);
+      sheet.set('A2', false);
+      expect(sheet.get('A2')).toBe(false);
+    });
+
+    it('should return null for empty cells', () => {
+      expect(sheet.get('A1')).toBeNull();
+    });
+
+    it('should store floating point numbers', () => {
+      sheet.set('A1', 3.14);
+      expect(sheet.get('A1')).toBe(3.14);
+    });
+  });
+
+  describe('cell references', () => {
+    it('should handle single letter columns', () => {
+      sheet.set('A1', 10);
+      sheet.set('Z1', 20);
+      expect(sheet.get('A1')).toBe(10);
+      expect(sheet.get('Z1')).toBe(20);
+    });
+
+    it('should handle multi-letter columns', () => {
+      sheet.set('AA1', 100);
+      sheet.set('AB1', 200);
+      expect(sheet.get('AA1')).toBe(100);
+      expect(sheet.get('AB1')).toBe(200);
+    });
+
+    it('should normalize cell references (case insensitive)', () => {
+      sheet.set('a1', 42);
+      expect(sheet.get('A1')).toBe(42);
+      expect(sheet.get('a1')).toBe(42);
+    });
+  });
+
+  describe('getDisplay', () => {
+    it('should display numbers', () => {
+      sheet.set('A1', 42);
+      expect(sheet.getDisplay('A1')).toBe('42');
+    });
+
+    it('should display strings', () => {
+      sheet.set('A1', 'hello');
+      expect(sheet.getDisplay('A1')).toBe('hello');
+    });
+
+    it('should display booleans', () => {
+      sheet.set('A1', true);
+      expect(sheet.getDisplay('A1')).toBe('true');
+    });
+
+    it('should display empty string for empty cells', () => {
+      expect(sheet.getDisplay('A1')).toBe('');
+    });
+
+    it('should display formula results', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.getDisplay('A3')).toBe('30');
+    });
+  });
+
+  describe('getCells', () => {
+    it('should return all non-empty cells', () => {
+      sheet.set('A1', 10);
+      sheet.set('B1', 20);
+      sheet.set('C1', '=A1+B1');
+      const cells = sheet.getCells();
+      expect(cells.size).toBe(3);
+      expect(cells.get('A1')).toBe(10);
+      expect(cells.get('B1')).toBe(20);
+      expect(cells.get('C1')).toBe(30);
+    });
+
+    it('should return an empty map when no cells are set', () => {
+      const cells = sheet.getCells();
+      expect(cells.size).toBe(0);
+    });
+  });
+
+  describe('formulas - arithmetic', () => {
+    it('should add two cell references', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should subtract values', () => {
+      sheet.set('A1', 50);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1-A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should multiply values', () => {
+      sheet.set('A1', 5);
+      sheet.set('A2', 6);
+      sheet.set('A3', '=A1*A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should divide values', () => {
+      sheet.set('A1', 100);
+      sheet.set('A2', 4);
+      sheet.set('A3', '=A1/A2');
+      expect(sheet.get('A3')).toBe(25);
+    });
+
+    it('should respect operator precedence', () => {
+      sheet.set('A1', 2);
+      sheet.set('A2', 3);
+      sheet.set('A3', 4);
+      sheet.set('A4', '=A1+A2*A3');
+      expect(sheet.get('A4')).toBe(14); // 2 + (3*4) = 14
+    });
+
+    it('should handle parentheses', () => {
+      sheet.set('A1', 2);
+      sheet.set('A2', 3);
+      sheet.set('A3', 4);
+      sheet.set('A4', '=(A1+A2)*A3');
+      expect(sheet.get('A4')).toBe(20); // (2+3)*4 = 20
+    });
+
+    it('should handle unary minus', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', '=-A1');
+      expect(sheet.get('A2')).toBe(-10);
+    });
+
+    it('should handle numeric literals in formulas', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', '=A1+5');
+      expect(sheet.get('A2')).toBe(15);
+    });
+
+    it('should handle complex expressions', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', '=(A1+5)*2-3');
+      expect(sheet.get('A2')).toBe(27);
+    });
+  });
+
+  describe('formulas - comparisons', () => {
+    it('should handle greater than', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 5);
+      sheet.set('A3', '=A1>A2');
+      expect(sheet.get('A3')).toBe(true);
+    });
+
+    it('should handle less than', () => {
+      sheet.set('A1', 3);
+      sheet.set('A2', 5);
+      sheet.set('A3', '=A1<A2');
+      expect(sheet.get('A3')).toBe(true);
+    });
+
+    it('should handle equals', () => {
+      sheet.set('A1', 5);
+      sheet.set('A2', 5);
+      sheet.set('A3', '=A1=A2');
+      expect(sheet.get('A3')).toBe(true);
+    });
+
+    it('should handle not equals', () => {
+      sheet.set('A1', 5);
+      sheet.set('A2', 3);
+      sheet.set('A3', '=A1<>A2');
+      expect(sheet.get('A3')).toBe(true);
+    });
+
+    it('should handle greater than or equal', () => {
+      sheet.set('A1', 5);
+      sheet.set('A2', 5);
+      sheet.set('A3', '=A1>=A2');
+      expect(sheet.get('A3')).toBe(true);
+    });
+
+    it('should handle less than or equal', () => {
+      sheet.set('A1', 5);
+      sheet.set('A2', 5);
+      sheet.set('A3', '=A1<=A2');
