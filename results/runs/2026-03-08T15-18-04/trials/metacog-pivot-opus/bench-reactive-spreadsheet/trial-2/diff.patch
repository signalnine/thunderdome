  sheet.set('A1', 10);\n      sheet.set('A2', 5);\n      sheet.set('A3', 20);\n      sheet.set('B1', '=MIN(A1:A3)');\n      expect(sheet.get('B1')).toBe(5);\n    });\n\n    it('should find maximum', () => {\n      sheet.set('A1', 10);\n      sheet.set('A2', 5);\n      sheet.set('A3', 20);\n      sheet.set('B1', '=MAX(A1:A3)');\n      expect(sheet.get('B1')).toBe(20);\n    });\n  });\n\n  describe('functions - COUNT', () => {\n    it('should count numeric values', () => {\n      sheet.set('A1', 10);\n      sheet.set('A2', 'hello');\n      sheet.set('A3', 20);\n      sheet.set('B1', '=COUNT(A1:A3)');\n      expect(sheet.get('B1')).toBe(2);\n    });\n\n    it('should count all numeric in range', () => {\n      sheet.set('A1', 1);\n      sheet.set('A2', 2);\n      sheet.set('A3', 3);\n      sheet.set('A4', 4);\n      sheet.set('A5', 5);\n      sheet.set('B1', '=COUNT(A1:A5)');\n      expect(sheet.get('B1')).toBe(5);\n    });\n  });\n\n  describe('functions - IF', () => {\n    it('should return true value when condition is true', () => {\n      sheet.set('A1', 50);\n      sheet.set('B1', '=IF(A1>30, \"big\", \"small\")');\n      expect(sheet.get('B1')).toBe('big');\n    });\n\n    it('should return false value when condition is false', () => {\n      sheet.set('A1', 10);\n      sheet.set('B1', '=IF(A1>30, \"big\", \"small\")');\n      expect(sheet.get('B1')).toBe('small');\n    });\n\n    it('should work with numeric results', () => {\n      sheet.set('A1', 5);\n      sheet.set('B1', '=IF(A1>3, A1*2, A1+1)');\n      expect(sheet.get('B1')).toBe(10);\n    });\n\n    it('should handle boolean conditions', () => {\n      sheet.set('A1', true);\n      sheet.set('B1', '=IF(A1, \"yes\", \"no\")');\n      // A1 is boolean true, the formula references A1 directly\n      expect(sheet.get('B1')).toBe('yes');\n    });\n  });\n\n  describe('reactive updates', () => {\n    it('should update dependent cells when a source cell changes', () => {\n      sheet.set('A1', 10);\n      sheet.