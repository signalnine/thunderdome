+    throw new Error(`Unexpected token: ${JSON.stringify(t)}`);
+  }
+}
+
+function parseFormula(formula: string): ASTNode {
+  const tokens = tokenize(formula);
+  const parser = new Parser(tokens);
+  return parser.parse();
+}
+
+// --- Dependency Extraction ---
+
+function extractDeps(node: ASTNode): Set<string> {
+  const deps = new Set<string>();
+  function walk(n: ASTNode): void {
+    switch (n.type) {
+      case 'cellref':
+        deps.add(n.ref);
+        break;
+      case 'range':
+        for (const ref of expandRange(n.start, n.end)) {
+          deps.add(ref);
+        }
+        break;
+      case 'binop':
+        walk(n.left);
+        walk(n.right);
+        break;
+      case 'unary':
+        walk(n.operand);
+        break;
+      case 'call':
+        for (const arg of n.args) walk(arg);
+        break;
+    }
+  }
+  walk(node);
+  return deps;
+}
+
+// --- Evaluator ---
+
+type CellValue = string | number | boolean | null;
+
+function toNumber(v: CellValue): number {
