+        case '/': {
+          const d = toNumber(right);
+          if (d === 0) throw new Error('Division by zero');
+          return toNumber(left) / d;
+        }
+        case '>': return toNumber(left) > toNumber(right);
+        case '<': return toNumber(left) < toNumber(right);
+        case '>=': return toNumber(left) >= toNumber(right);
+        case '<=': return toNumber(left) <= toNumber(right);
+        case '=': {
+          // Equality: compare by value
+          if (typeof left === typeof right) return left === right;
+          return toNumber(left) === toNumber(right);
+        }
+        case '<>': {
+          if (typeof left === typeof right) return left !== right;
+          return toNumber(left) !== toNumber(right);
+        }
+        default:
+          throw new Error(`Unknown operator: ${node.op}`);
+      }
+    }
+    case 'call': {
+      return evaluateFunction(node.name, node.args, getCell);
+    }
+  }
+}
+
+function resolveValues(args: ASTNode[], getCell: (ref: string) => CellValue): CellValue[] {
+  const values: CellValue[] = [];
+  for (const arg of args) {
+    if (arg.type === 'range') {
+      for (const ref of expandRange(arg.start, arg.end)) {
+        values.push(getCell(ref));
+      }
+    } else {
+      values.push(evaluateAST(arg, getCell));
+    }
+  }
+  return values;
+}
+
+function evaluateFunction(name: string, args: ASTNode[], getCell: (ref: string) => CellValue): CellValue {
+  switch (name) {
+    case 'SUM': {
+      const values = resolveValues(args, getCell);
+      let sum = 0;
+      for (const v of values) {
+        if (typeof v === 'number') sum += v;
+        else if (v !== null && v !== '') sum += toNumber(v);
+      }
+      return sum;
+    }
+    case 'AVERAGE': {
+      const values = resolveValues(args, getCell);
+      let sum = 0;
+      let count = 0;
+      for (const v of values) {
+        if (typeof v === 'number') {
+          sum += v;
+          count++;
+        }
+      }
+      if (count === 0) return 0;
+      return sum / count;
+    }
+    case 'MIN': {
+      const values = resolveValues(args, getCell);
+      let min = Infinity;
+      for (const v of values) {
+        if (typeof v === 'number' && v < min) min = v;
+      }
+      return min === Infinity ? 0 : min;
+    }
+    case 'MAX': {
+      const values = resolveValues(args, getCell);
+      let max = -Infinity;
+      for (const v of values) {
+        if (typeof v === 'number' && v > max) max = v;
+      }
+      return max === -Infinity ? 0 : max;
+    }
+    case 'COUNT': {
+      const values = resolveValues(args, getCell);
+      let count = 0;
+      for (const v of values) {
+        if (typeof v === 'number') count++;
+      }
+      return count;
+    }
+    case 'IF': {
+      if (args.length < 3) throw new Error('IF requires 3 arguments');
+      const condition = evaluateAST(args[0], getCell);
+      const isTruthy = typeof condition === 'boolean' ? condition : !!condition;
+      return isTruthy
+        ? evaluateAST(args[1], getCell)
+        : evaluateAST(args[2], getCell);
+    }
+    default:
+      throw new Error(`Unknown function: ${name}`);
+  }
+}
+
+// --- Spreadsheet Engine ---
+
+interface CellData {
+  raw: string | number | boolean;
+  formula: ASTNode | null;
+  value: CellValue;
+  deps: Set<string>; // cells this cell depends on
+}
+
+export class Spreadsheet {
+  private cells = new Map<string, CellData>();
+  // Reverse dependency map: cell -> set of cells that depend on it
+  private dependents = new Map<string, Set<string>>();
+
+  set(cell: string, value: string | number | boolean): void {
+    const ref = normalizeRef(cell);
+
+    // Remove old reverse deps
+    const existing = this.cells.get(ref);
+    if (existing) {
+      for (const dep of existing.deps) {
+        this.dependents.get(dep)?.delete(ref);
+      }
+    }
+
+    let formula: ASTNode | null = null;
+    let deps = new Set<string>();
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      formula = parseFormula(value.slice(1));
+      deps = extractDeps(formula);
+    }
+
+    // Check for circular references before committing
+    if (deps.size > 0) {
+      this.checkCircular(ref, deps);
+    }
+
+    // Register reverse deps
+    for (const dep of deps) {
+      if (!this.dependents.has(dep)) {
+        this.dependents.set(dep, new Set());
+      }
+      this.dependents.get(dep)!.add(ref);
+    }
+
+    const cellData: CellData = {
+      raw: value,
+      formula,
+      value: null,
+      deps,
+    };
+
+    this.cells.set(ref, cellData);
+
+    // Evaluate this cell
+    cellData.value = this.evaluate(cellData);
+
+    // Propagate changes to dependents
+    this.propagate(ref);
+  }
+
+  get(cell: string): CellValue {
+    const ref = normalizeRef(cell);
+    const data = this.cells.get(ref);
+    if (!data) return null;
+    return data.value;
+  }
+
+  getDisplay(cell: string): string {
+    const value = this.get(cell);
+    if (value === null) return '';
+    return String(value);
+  }
+
+  getCells(): Map<string, CellValue> {
+    const result = new Map<string, CellValue>();
+    for (const [ref, data] of this.cells) {
+      result.set(ref, data.value);
+    }
+    return result;
+  }
+
+  private evaluate(data: CellData): CellValue {
+    if (data.formula) {
+      return evaluateAST(data.formula, (ref) => {
+        const d = this.cells.get(ref);
+        return d ? d.value : null;
+      });
+    }
+    return data.raw as CellValue;
+  }
+
+  private propagate(changedRef: string): void {
+    // Topological sort of dependents, then evaluate in order
+    const visited = new Set<string>();
+    const order: string[] = [];
+
+    const visit = (ref: string): void => {
+      if (visited.has(ref)) return;
+      visited.add(ref);
+      const deps = this.dependents.get(ref);
+      if (deps) {
+        for (const dep of deps) {
+          visit(dep);
+        }
+      }
+      order.push(ref);
+    };
+
+    // Start from the cells that directly depend on changedRef
+    const directDeps = this.dependents.get(changedRef);
+    if (!directDeps || directDeps.size === 0) return;
+
+    for (const dep of directDeps) {
+      visit(dep);
+    }
+
+    // Reverse to get evaluation order (dependencies first)
+    order.reverse();
+
+    for (const ref of order) {
+      const cellData = this.cells.get(ref);
+      if (cellData) {
+        cellData.value = this.evaluate(cellData);
+      }
+    }
+  }
+
+  private checkCircular(ref: string, deps: Set<string>): void {
+    // BFS/DFS from deps: if we reach ref, it's circular
+    const visited = new Set<string>();
+    const stack = [...deps];
+    while (stack.length > 0) {
+      const current = stack.pop()!;
+      if (current === ref) {
+        throw new Error(`Circular reference detected involving ${ref}`);
+      }
+      if (visited.has(current)) continue;
+      visited.add(current);
+      // Follow current's dependencies
+      const currentData = this.cells.get(current);
+      if (currentData) {
+        for (const dep of currentData.deps) {
+          stack.push(dep);
+        }
+      }
+    }
+  }
+}
