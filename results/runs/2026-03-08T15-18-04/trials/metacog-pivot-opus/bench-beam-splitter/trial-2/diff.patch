@@ -0,0 +1,170 @@
+type Direction = 'down' | 'down-left' | 'down-right';
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+function findSource(grid: string[][]): [number, number] | null {
+  const cols = grid[0]?.length ?? 0;
+  for (let c = 0; c < cols; c++) {
+    if (grid[0][c] === 'S') {
+      return [0, c];
+    }
+  }
+  return null;
+}
+
+function advance(row: number, col: number, dir: Direction): [number, number] {
+  switch (dir) {
+    case 'down':       return [row + 1, col];
+    case 'down-left':  return [row + 1, col - 1];
+    case 'down-right': return [row + 1, col + 1];
+  }
+}
+
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+/**
+ * Count the number of distinct cells visited by any beam.
+ */
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  if (rows === 0) return 0;
+  const cols = grid[0].length;
+  if (cols === 0) return 0;
+
+  const source = findSource(grid);
+  if (!source) return 0;
+
+  const visited = new Set<number>();
+  const encode = (r: number, c: number): number => r * cols + c;
+
+  // BFS/queue-based simulation
+  const queue: Beam[] = [{ row: source[0], col: source[1], dir: 'down' }];
+  // Track (row, col, dir) to avoid reprocessing the same beam state
+  const seen = new Set<number>();
+  const encodeSeen = (r: number, c: number, d: number): number => (r * cols + c) * 3 + d;
+  const dirIndex = (d: Direction): number => d === 'down' ? 0 : d === 'down-left' ? 1 : 2;
+
+  const key0 = encodeSeen(source[0], source[1], dirIndex('down'));
+  seen.add(key0);
+
+  while (queue.length > 0) {
+    const beam = queue.pop()!;
+    const { row, col, dir } = beam;
+
+    if (!inBounds(row, col, rows, cols)) continue;
+
+    visited.add(encode(row, col));
+
+    const cell = grid[row][col];
+    if (cell === '^' || (cell === 'S' && row === source[0] && col === source[1] && dir === 'down')) {
+      // Splitter: split into down-left and down-right
+      // Source cell: beam goes straight down (only on initial step)
+      if (cell === '^') {
+        const dirs: Direction[] = ['down-left', 'down-right'];
+        for (const newDir of dirs) {
+          const [nr, nc] = advance(row, col, newDir);
+          if (inBounds(nr, nc, rows, cols)) {
+            const k = encodeSeen(nr, nc, dirIndex(newDir));
+            if (!seen.has(k)) {
+              seen.add(k);
+              queue.push({ row: nr, col: nc, dir: newDir });
+            }
+          }
+        }
+      } else {
+        // Source: beam goes down
+        const [nr, nc] = advance(row, col, 'down');
+        if (inBounds(nr, nc, rows, cols)) {
+          const k = encodeSeen(nr, nc, dirIndex('down'));
+          if (!seen.has(k)) {
+            seen.add(k);
+            queue.push({ row: nr, col: nc, dir: 'down' });
+          }
+        }
+      }
+    } else {
+      // Empty cell or source not at origin: continue in same direction
+      const [nr, nc] = advance(row, col, dir);
+      if (inBounds(nr, nc, rows, cols)) {
+        const k = encodeSeen(nr, nc, dirIndex(dir));
+        if (!seen.has(k)) {
+          seen.add(k);
+          queue.push({ row: nr, col: nc, dir: dir });
+        }
+      }
+    }
+  }
+
+  return visited.size;
+}
+
+/**
+ * Count distinct source-to-exit paths.
+ * Uses DP on splitter graph to avoid exponential enumeration.
+ *
+ * Key idea: trace beam from source downward. When it hits a splitter,
+ * it forks. Each fork either hits another splitter or exits the grid.
+ * We compute the number of paths by summing over the DAG of splitters.
+ */
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  if (rows === 0) return 0n;
+  const cols = grid[0].length;
+  if (cols === 0) return 0n;
+
+  const source = findSource(grid);
+  if (!source) return 0n;
+
+  // For each beam state (row, col, dir), compute the number of exit paths.
+  // We use memoization. A beam that exits the grid contributes 1 path.
+  // A beam that hits a splitter forks into two beams, each contributing their path counts.
+  // We need to handle the case where a beam might revisit a state (cycle detection),
+  // but since beams always move downward (row increases), there are no cycles.
+
+  // Since row always increases, we can process top-to-bottom without cycles.
+  // Memoize by (row, col, dir) -> bigint path count
+
+  const memo = new Map<number, bigint>();
+  const encodeMemo = (r: number, c: number, d: number): number => (r * cols + c) * 3 + d;
+  const dirIdx = (d: Direction): number => d === 'down' ? 0 : d === 'down-left' ? 1 : 2;
+
+  function countPaths(row: number, col: number, dir: Direction): bigint {
+    if (!inBounds(row, col, rows, cols)) {
+      // Beam has exited the grid — this is one complete path
+      return 1n;
+    }
+
+    const key = encodeMemo(row, col, dirIdx(dir));
+    const cached = memo.get(key);
+    if (cached !== undefined) return cached;
+
+    const cell = grid[row][col];
+    let result: bigint;
+
+    if (cell === '^') {
+      // Splitter: fork into down-left and down-right
+      const [lr, lc] = advance(row, col, 'down-left');
+      const [rr, rc] = advance(row, col, 'down-right');
+      result = countPaths(lr, lc, 'down-left') + countPaths(rr, rc, 'down-right');
+    } else {
+      // Continue in same direction
+      const [nr, nc] = advance(row, col, dir);
+      result = countPaths(nr, nc, dir);
+    }
+
+    memo.set(key, result);
+    return result;
+  }
+
+  // The beam starts at the source going down. The source cell itself is just a marker.
+  // From the source, the beam moves down.
+  const [sr, sc] = source;
+  const [nr, nc] = advance(sr, sc, 'down');
+  return countPaths(nr, nc, 'down');
+}
