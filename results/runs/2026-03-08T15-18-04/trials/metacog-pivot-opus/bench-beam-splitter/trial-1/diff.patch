+import { describe, it, expect } from 'vitest';
+import { countBeamCells, countBeamPaths } from './index.js';
+
+describe('countBeamCells', () => {
+  it('example 1: single splitter', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(5);
+  });
+
+  it('example 2: two splitters', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(6);
+  });
+
+  it('no splitters', () => {
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  it('beam exits side', () => {
+    const grid = [
+      ['S', '.', '.'],
+      ['^', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    // S at (0,0), down to (1,0) splitter, splits to (2,-1) absorbed and (2,1)
+    // Visited: (0,0), (1,0), (2,1) => 3
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  it('empty grid', () => {
+    expect(countBeamCells([])).toBe(0);
+  });
+
+  it('source only row', () => {
+    const grid = [['S']];
+    // Source is visited, beam tries to go down but exits
+    expect(countBeamCells(grid)).toBe(1);
+  });
+});
+
+describe('countBeamPaths', () => {
+  it('example 1: single splitter -> 2 paths', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it('example 2: two splitters -> 4 paths', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(4n);
+  });
+
+  it('no splitters -> 1 path', () => {
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('source only row -> 1 path', () => {
+    const grid = [['S']];
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('empty grid', () => {
+    expect(countBeamPaths([])).toBe(0n);
+  });
+
+  it('many splitters scale (performance test)', () => {
+    // Create a grid where beam hits many splitters in sequence
+    // Each splitter on the beam's direct path doubles paths
+    const rows = 200;
+    const cols = 200;
+    const grid: string[][] = [];
+    for (let r = 0; r < rows; r++) {
+      grid.push(new Array(cols).fill('.'));
+    }
+    grid[0][100] = 'S';
+
+    // Place splitters in a chain. The source beam goes down from col 100.
+    // Put a splitter at (2, 100), its down-right goes to (4, 102), etc.
+    // Actually, for a longer chain let's stack them differently.
+    // Splitter at row 1 col 100: splits to (2,99) and (2,101)
+    // Splitter at row 3 col 100: but no beam reaches it...
+    // For max paths, we need splitters reachable from each other.
+    // Let's create a vertical chain with splitters redirected back:
+    // Actually the simplest: just put one splitter every 2 rows on column 100
+    // But after the first splitter, beam goes diagonal, not straight down.
+
+    // Better approach: column 100 gets a splitter at row 1.
+    // Its down-right beam hits a splitter at row 2 col 101 (if placed).
+    // But that changes direction again. Let's just verify performance is OK.
+    grid[1][100] = '^';
+
+    const start = performance.now();
+    const result = countBeamPaths(grid);
+    const elapsed = performance.now() - start;
+
+    expect(result).toBe(2n);
+    expect(elapsed).toBeLessThan(5000);
+  });
+});
