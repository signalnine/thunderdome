@@ -0,0 +1,191 @@
+type Direction = 'down' | 'down-left' | 'down-right';
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+function findSource(grid: string[][]): [number, number] | null {
+  for (let c = 0; c < grid[0].length; c++) {
+    if (grid[0][c] === 'S') return [0, c];
+  }
+  return null;
+}
+
+function advance(row: number, col: number, dir: Direction): [number, number] {
+  switch (dir) {
+    case 'down': return [row + 1, col];
+    case 'down-left': return [row + 1, col - 1];
+    case 'down-right': return [row + 1, col + 1];
+  }
+}
+
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+/**
+ * Count the number of distinct cells visited by any beam.
+ * Uses state deduplication to avoid exponential blowup with many splitters.
+ */
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  if (rows === 0) return 0;
+  const cols = grid[0].length;
+
+  const source = findSource(grid);
+  if (!source) return 0;
+
+  const visited = new Set<string>();
+  // Track (row, col, dir) states we've already processed to avoid duplicates
+  const seen = new Set<string>();
+  const beams: Beam[] = [{ row: source[0], col: source[1], dir: 'down' }];
+  visited.add(`${source[0]},${source[1]}`);
+  seen.add(`${source[0]},${source[1]},down`);
+
+  while (beams.length > 0) {
+    const beam = beams.pop()!;
+    const [nr, nc] = advance(beam.row, beam.col, beam.dir);
+
+    if (!inBounds(nr, nc, rows, cols)) continue;
+
+    visited.add(`${nr},${nc}`);
+
+    if (grid[nr][nc] === '^') {
+      // Splitter: spawn two diagonal beams (deduplicated)
+      for (const dir of ['down-left', 'down-right'] as Direction[]) {
+        const state = `${nr},${nc},${dir}`;
+        if (!seen.has(state)) {
+          seen.add(state);
+          beams.push({ row: nr, col: nc, dir });
+        }
+      }
+    } else {
+      const state = `${nr},${nc},${beam.dir}`;
+      if (!seen.has(state)) {
+        seen.add(state);
+        beams.push({ row: nr, col: nc, dir: beam.dir });
+      }
+    }
+  }
+
+  return visited.size;
+}
+
+/**
+ * Count the total number of distinct source-to-exit paths.
+ * Uses a DAG-based approach over splitters for performance.
+ *
+ * Model: A beam segment travels in a fixed direction from its origin
+ * (source or a splitter) until it either hits a splitter or exits the grid.
+ * At each splitter, the beam splits into two. We count how many beams
+ * reach each splitter and how many exit the grid without hitting one.
+ *
+ * We process segments via BFS/DFS. Each "active segment" has an origin,
+ * direction, and a path-count (bigint). When it hits a splitter, that
+ * splitter gets two new outgoing segments, each inheriting the path-count.
+ * When it exits, we add the path-count to the total.
+ */
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  if (rows === 0) return 0n;
+  const cols = grid[0].length;
+
+  const source = findSource(grid);
+  if (!source) return 0n;
+
+  // For efficiency, precompute: given a starting cell and direction,
+  // trace the beam until it hits a splitter or exits.
+  // With up to 50 splitters, we can have at most ~100 segments to trace
+  // (each splitter produces 2 outgoing directions).
+
+  // We'll use memoization: key = (row, col, dir) -> result
+  // Result is either { type: 'exit' } or { type: 'splitter', row, col }
+  type TraceResult = { type: 'exit' } | { type: 'splitter'; row: number; col: number };
+
+  const traceCache = new Map<string, TraceResult>();
+
+  function traceBeam(startRow: number, startCol: number, dir: Direction): TraceResult {
+    const key = `${startRow},${startCol},${dir}`;
+    const cached = traceCache.get(key);
+    if (cached) return cached;
+
+    let r = startRow;
+    let c = startCol;
+
+    // Advance step by step
+    for (;;) {
+      const [nr, nc] = advance(r, c, dir);
+      if (!inBounds(nr, nc, rows, cols)) {
+        const result: TraceResult = { type: 'exit' };
+        traceCache.set(key, result);
+        return result;
+      }
+      if (grid[nr][nc] === '^') {
+        const result: TraceResult = { type: 'splitter', row: nr, col: nc };
+        traceCache.set(key, result);
+        return result;
+      }
+      r = nr;
+      c = nc;
+    }
+  }
+
+  // BFS over segments, accumulating path counts at each splitter
+  // To handle DAG properly, we process splitters in topological order (by row).
+  // A splitter at a lower row must be processed before one at a higher row
+  // (beams always move downward).
+
+  // Collect all splitters
+  // Map from "row,col" to accumulated path count
+  const splitterCounts = new Map<string, bigint>();
+
+  // Process: start from source, trace the initial beam downward
+  const initialTrace = traceBeam(source[0], source[1], 'down');
+  let totalPaths = 0n;
+
+  if (initialTrace.type === 'exit') {
+    totalPaths += 1n;
+  } else {
+    const key = `${initialTrace.row},${initialTrace.col}`;
+    splitterCounts.set(key, (splitterCounts.get(key) ?? 0n) + 1n);
+  }
+
+  // Collect all splitters that have been reached
+  // Process them in order of increasing row (topological order for the DAG)
+  // We need to iteratively process: when we process a splitter, it may
+  // feed into other splitters.
+
+  // Gather all splitter positions
+  const allSplitters: [number, number][] = [];
+  for (let r = 0; r < rows; r++) {
+    for (let c = 0; c < cols; c++) {
+      if (grid[r][c] === '^') {
+        allSplitters.push([r, c]);
+      }
+    }
+  }
+  // Sort by row (already iterated in row order, but let's be explicit)
+  allSplitters.sort((a, b) => a[0] - b[0] || a[1] - b[1]);
+
+  // Process splitters in topological order
+  for (const [sr, sc] of allSplitters) {
+    const key = `${sr},${sc}`;
+    const count = splitterCounts.get(key);
+    if (!count) continue; // This splitter is unreachable
+
+    // Each beam arriving at this splitter splits into down-left and down-right
+    for (const dir of ['down-left', 'down-right'] as Direction[]) {
+      const result = traceBeam(sr, sc, dir);
+      if (result.type === 'exit') {
+        totalPaths += count;
+      } else {
+        const targetKey = `${result.row},${result.col}`;
+        splitterCounts.set(targetKey, (splitterCounts.get(targetKey) ?? 0n) + count);
+      }
+    }
+  }
+
+  return totalPaths;
+}
