on cycle');\n}});\n\n// Test 4: Self-reference throws\ntests.push({ name: 'Self-reference', fn: () => {\n  let threw = false;\n  try {\n    schedule(\n      [{ id: 'a', name: 'A', duration: 60, prerequisites: ['a'] }],\n      [{ id: 'r1', name: 'Room 1', capacity: 20 }],\n      { startTime: 540, endTime: 1020 }\n    );\n  } catch { threw = true; }\n  assert(threw, 'should throw on self-ref');\n}});\n\n// Test 5: Capacity constraint\ntests.push({ name: 'Capacity', fn: () => {\n  const r = schedule(\n    [{ id: 'a', name: 'A', duration: 60, attendees: 30 }],\n    [{ id: 'r1', name: 'Room 1', capacity: 20 }],\n    { startTime: 540, endTime: 1020 }\n  );\n  assert(r.unscheduled.includes('a'), 'too many attendees');\n}});\n\n// Test 6: Preferred room\ntests.push({ name: 'Preferred room', fn: () => {\n  const r = schedule(\n    [{ id: 'a', name: 'A', duration: 60, attendees: 5, preferredRoom: 'r2' }],\n    [\n      { id: 'r1', name: 'Room 1', capacity: 20 },\n      { id: 'r2', name: 'Room 2', capacity: 10 },\n    ],\n    { startTime: 540, endTime: 1020 }\n  );\n  assert(r.assignments[0].roomId === 'r2', 'should use preferred room');\n}});\n\n// Test 7: Gap enforcement\ntests.push({ name: 'Gap enforcement', fn: () => {\n  const r = schedule(\n    [\n      { id: 'a', name: 'A', duration: 60 },\n      { id: 'b', name: 'B', duration: 60 },\n    ],\n    [{ id: 'r1', name: 'Room 1', capacity: 20 }],\n    { startTime: 540, endTime: 1020, gap: 30 }\n  );\n  const sorted = r.assignments.sort((a, b) => a.startTime - b.startTime);\n  assert(sorted[1].startTime >= sorted[0].endTime + 30, 'gap respected');\n}});\n\n// Test 8: Time window\ntests.push({ name: 'Time window', fn: () => {\n  const r = schedule(\n    [{ id: 'a', name: 'A', duration: 600 }],\n    [{ id: 'r1', name: 'Room 1', capacity: 20 }],\n    { startTime: 540, endTime: 1020 }\n  );\n  assert(r.unscheduled.includes('a'), 'too long for window');\n}});\n\n// Test 9: Empty events\ntests.push({ name: 'Empty events', fn: () =>