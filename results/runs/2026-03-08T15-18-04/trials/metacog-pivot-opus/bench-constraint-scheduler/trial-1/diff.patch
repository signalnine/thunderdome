nst sorted: string[] = [];\n  while (queue.length > 0) {\n    const node = queue.shift()!;\n    sorted.push(node);\n    for (const neighbor of adjacency.get(node) ?? []) {\n      const newDeg = (inDegree.get(neighbor) ?? 1) - 1;\n      inDegree.set(neighbor, newDeg);\n      if (newDeg === 0) {\n        queue.push(neighbor);\n      }\n    }\n  }\n\n  if (sorted.length !== events.length) {\n    throw new Error('Cycle detected in prerequisite graph');\n  }\n\n  return sorted;\n}\n\n/**\n * Compute the depth of each event in the prerequisite DAG.\n * Depth = longest path from a root to this event.\n */\nfunction computeDepths(events: Event[]): Map<string, number> {\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  const depths = new Map<string, number>();\n  const eventIds = new Set(events.map(e => e.id));\n\n  function getDepth(id: string): number {\n    if (depths.has(id)) return depths.get(id)!;\n    const event = eventMap.get(id);\n    if (!event || !event.prerequisites || event.prerequisites.length === 0) {\n      depths.set(id, 0);\n      return 0;\n    }\n    let maxPrereqDepth = 0;\n    for (const prereq of event.prerequisites) {\n      if (eventIds.has(prereq)) {\n        maxPrereqDepth = Math.max(maxPrereqDepth, getDepth(prereq) + 1);\n      }\n    }\n    depths.set(id, maxPrereqDepth);\n    return maxPrereqDepth;\n  }\n\n  for (const e of events) {\n    getDepth(e.id);\n  }\n\n  return depths;\n}\n\n/**\n * Count transitive dependents for each event (how many events depend on it).\n */\nfunction computeDependentCounts(events: Event[]): Map<string, number> {\n  const eventIds = new Set(events.map(e => e.id));\n  const adjacency = new Map<string, string[]>();\n  for (const e of events) {\n    adjacency.set(e.id, []);\n  }\n  for (const e of events) {\n    if (e.prerequisites) {\n      for (const prereq of e.prerequisites) {\n        if (eventIds.has(prereq)) {\n          adjacency.get(prereq)!.push(e.id);\n        }\n      }\n    }\n  }\n\n  const counts = new Map<string, number>();\n\n  function countDependents(id: string, visited: Set<string>): number {\n    if (counts.has(id)) return counts.get(id)!;\n    let count = 0;\n    for (const dep of adjacency.get(id) ?? []) {\n      if (!visited.has(dep)) {\n        visited.add(dep);\n        count += 1 + countDependents(dep, visited);\n      }\n    }\n    counts.set(id, count);\n    return count;\n  }\n\n  for (const e of events) {\n    if (!counts.has(e.id)) {\n      countDependents(e.id, new Set([e.id]));\n    }\n  }\n\n  return counts;\n}\n\ninterface RoomTimeline {\n  roomId: string;\n  capacity: number;\n  bookings: { start: number; end: number }[];\n}\n\nfunction findEarliestSlot(\n  timeline: RoomTimeline,\n  duration: number,\n  earliestStart: number,\n  endTime: number,\n  gap: number\n): number | null {\n  if (earliestStart + duration > endTime) return null;\n\n  // Sort bookings by start time\n  const bookings = [...timeline.bookings].sort((a, b) => a.start - b.start);\n\n  if (bookings.length === 0) {\n    return earliestStart;\n  }\n\n  // Try before first booking\n  if (earliestStart + duration + gap <= bookings[0].start) {\n    return earliestStart;\n  }\n\n  // Try between bookings\n  for (let i = 0; i < bookings.length; i++) {\n    const availableStart = Math.max(earliestStart, bookings[i].end + gap);\n    const nextBookingStart = i + 1 < bookings.length ? bookings[i + 1].start : endTime + gap;\n\n    if (availableStart + duration <= Math.min(endTime, nextBookingStart - gap) ||\n        (i + 1 >= bookings.length && availableStart + duration <= endTime)) {\n      return availableStart;\n    }\n  }\n\n  return null;\n}\n\nexport function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {\n  const gap = options.gap ?? 15;\n  const { startTime, endTime } = options;\n\n  if (events.length === 0) {\n    return { assignments: [], unscheduled: [] };\n  }\n\n  // Step 1: Detect cycles (throws on cycle)\n  topologicalSort(events);\n\n  // Step 2: Build event map\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n  const eventIds = new Set(events.map(e => e.id));\n\n  // Step 3: Compute priority ordering\n  const depths = computeDepths(events);\n  const dependentCounts = computeDependentCounts(events);\n\n  // Sort events: by depth first (prerequisites come first), then by\n  // number of dependents descending (schedule events that unlock others first),\n  // then by attendees descending (harder to place events first)\n  const sortedEvents = [...events].sort((a, b) => {\n    const depthA = depths.get(a.id) ?? 0;\n    const depthB = depths.get(b.id) ?? 0;\n    if (depthA !== depthB) return depthA - depthB;\n\n    const depsA = dependentCounts.get(a.id) ?? 0;\n    const depsB = dependentCounts.get(b.id) ?? 0;\n    if (depsA !== depsB) return depsB - depsA;\n\n    const attA = a.attendees ?? 1;\n    const attB = b.attendees ?? 1;\n    return attB - attA;\n  });\n\n  // Step 4: Initialize room timelines\n  const timelines = new Map<string, RoomTimeline>();\n  for (const room of rooms) {\n    timelines.set(room.id, {\n      roomId: room.id,\n      capacity: room.capacity,\n      bookings: [],\n    });\n  }\n\n  // Sort rooms by capacity ascending (prefer smaller rooms to leave big ones available)\n  const sortedRooms = [...rooms].sort((a, b) => a.capacity - b.capacity);\n\n  const assignments: Assignment[] = [];\n  const scheduled = new Map<string, Assignment>();\n  const unscheduled: string[] = [];\n\n  // Step 5: Schedule each event\n  for (const event of sortedEvents) {\n    const attendees = event.attendees ?? 1;\n    const duration = event.duration;\n\n    // Compute earliest possible start based on prerequisites\n    let earliestStart = startTime;\n    let prereqsSatisfied = true;\n\n    if (event.prerequisites) {\n      for (const prereq of event.prerequisites) {\n        if (!eventIds.has(prereq)) continue;\n        const prereqAssignment = scheduled.get(prereq);\n        if (!prereqAssignment) {\n          // Prerequisite wasn't scheduled - we can't schedule this event\n          prereqsSatisfied = false;\n          break;\n        }\n        earliestStart = Math.max(earliestStart, prereqAssignment.endTime + gap);\n      }\n    }\n\n    if (!prereqsSatisfied) {\n      unscheduled.push(event.id);\n      continue;\n    }\n\n    // Check if event can fit in the time window at all\n    if (earliestStart + duration > endTime) {\n      unscheduled.push(event.id);\n      continue;\n    }\n\n    // Try to find a room\n    let bestAssignment: Assignment | null = null;\n    let bestStartTime = Infinity;\n\n    // Try preferred room first\n    const roomOrder: Room[] = [];\n    if (event.preferredRoom) {\n      const prefRoom = rooms.find(r => r.id === event.preferredRoom);\n      if (prefRoom && prefRoom.capacity >= attendees) {\n        roomOrder.push(prefRoom);\n      }\n    }\n    // Add remaining rooms sorted by capacity\n    for (const room of sortedRooms) {\n      if (room.capacity >= attendees && room.id !== event.preferredRoom) {\n        roomOrder.push(room);\n      }\n    }\n\n    for (const room of roomOrder) {\n      const timeline = timelines.get(room.id)!;\n      const slotStart = findEarliestSlot(timeline, duration, earliestStart, endTime, gap);\n\n      if (slotStart !== null) {\n        // For preferred room, take it immediately if it gives an early enough start\n        if (event.preferredRoom && room.id === event.preferredRoom) {\n          bestAssignment = {\n            eventId: event.id,\n            roomId: room.id,\n            startTime: slotStart,\n            endTime: slotStart + duration,\n          };\n          break;\n        }\n\n        // For non-preferred rooms, pick the one with the earliest start time\n        if (slotStart < bestStartTime) {\n          bestStartTime = slotStart;\n          bestAssignment = {\n            eventId: event.id,\n            roomId: room.id,\n            startTime: slotStart,\n            endTime: slotStart + duration,\n          };\n        }\n      }\n    }\n\n    if (bestAssignment) {\n      assignments.push(bestAssignment);\n      scheduled.set(event.id, bestAssignment);\n      timelines.get(bestAssignment.roomId)!.bookings.push({\n        start: bestAssignment.startTime,\n        end: bestAssignment.endTime,\n      });\n    } else {\n      unscheduled.push(event.id);\n    }\n  }\n\n  return { assignments, unscheduled };\n}\n\n// Also export as a class for alternative API\nexport class Scheduler {\n  schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {\n    return schedule(events, rooms, options);\n  }\n}\n\nexport function createScheduler(): { schedule: typeof schedule } {\n  return { schedule };\n}\n\nexport default schedule;\n","structuredPatch":[],"originalFile":null}}
