esult {\n  assignments: Assignment[];\n  unscheduled: string[];\n}\n\n// ── Helpers ─────────────────────────────────────────────────────────\n\n/**\n * Detect cycles in the prerequisite graph using iterative DFS.\n * Throws if a cycle (including self-references) is found.\n * Returns a topologically-sorted list of event IDs (dependencies first).\n */\nfunction topologicalSort(events: Event[]): string[] {\n  const eventIds = new Set(events.map((e) => e.id));\n  const adj = new Map<string, string[]>(); // id -> dependents\n  const inDegree = new Map<string, number>();\n\n  for (const e of events) {\n    adj.set(e.id, []);\n    inDegree.set(e.id, 0);\n  }\n\n  for (const e of events) {\n    if (!e.prerequisites) continue;\n    for (const prereq of e.prerequisites) {\n      // Self-reference is always a cycle\n      if (prereq === e.id) {\n        throw new Error(`Cycle detected: event \"${e.id}\" lists itself as a prerequisite`);\n      }\n      // Only consider prerequisites that are in our event set\n      if (eventIds.has(prereq)) {\n        adj.get(prereq)!.push(e.id);\n        inDegree.set(e.id, (inDegree.get(e.id) ?? 0) + 1);\n      }\n    }\n  }\n\n  // Kahn's algorithm\n  const queue: string[] = [];\n  for (const [id, deg] of inDegree) {\n    if (deg === 0) queue.push(id);\n  }\n\n  const sorted: string[] = [];\n  while (queue.length > 0) {\n    const node = queue.shift()!;\n    sorted.push(node);\n    for (const dep of adj.get(node) ?? []) {\n      const newDeg = (inDegree.get(dep) ?? 1) - 1;\n      inDegree.set(dep, newDeg);\n      if (newDeg === 0) queue.push(dep);\n    }\n  }\n\n  if (sorted.length !== eventIds.size) {\n    throw new Error(\"Cycle detected in prerequisite graph\");\n  }\n\n  return sorted;\n}\n\n/**\n * Get the earliest start time for an event considering its prerequisites.\n */\nfunction earliestStartAfterPrereqs(\n  event: Event,\n  assignments: Map<string, Assignment>,\n  gap: number\n): number {\n  let earliest = 0;\n  if (event.prerequisites) {\n    for (const prereqId of event.prerequisites) {\n      const prereqAssignment = assignments.get(prereqId);\n      if (prereqAssignment) {\n        earliest = Math.max(earliest, prereqAssignment.endTime + gap);\n      }\n    }\n  }\n  return earliest;\n}\n\n/**\n * Find the earliest available start time in a room that doesn't conflict\n * with existing assignments.\n */\nfunction findEarliestSlot(\n  roomId: string,\n  duration: number,\n  earliestStart: number,\n  endTime: number,\n  gap: number,\n  roomAssignments: Assignment[]\n): number | null {\n  // Sort existing assignments in this room by start time\n  const sorted = roomAssignments\n    .filter((a) => a.roomId === roomId)\n    .sort((a, b) => a.startTime - b.startTime);\n\n  // Try to fit before the first assignment, between assignments, or after the last\n  const candidates: number[] = [earliestStart];\n\n  for (const a of sorted) {\n    // After each existing assignment\n    candidates.push(a.endTime + gap);\n  }\n\n  for (const candidateStart of candidates) {\n    const start = Math.max(candidateStart, earliestStart);\n    const end = start + duration;\n\n    if (end > endTime) continue;\n\n    // Check for conflicts with all assignments in this room\n    let conflict = false;\n    for (const a of sorted) {\n      // Our event occupies [start, end), existing occupies [a.startTime, a.endTime)\n      // With gap, we need: end + gap <= a.startTime OR a.endTime + gap <= start\n      if (!(end + gap <= a.startTime || a.endTime + gap <= start)) {\n        conflict = true;\n        break;\n      }\n    }\n\n    if (!conflict) return start;\n  }\n\n  return null;\n}\n\n// ── Main Scheduler ──────────────────────────────────────────────────\n\nexport function schedule(\n  events: Event[],\n  rooms: Room[],\n  options: ScheduleOptions\n): ScheduleResult {\n  const gap = options.gap ?? 15;\n\n  // 1. Cycle detection + topological sort\n  const sortedIds = topologicalSort(events);\n\n  const eventMap = new Map<string, Event>();\n  for (const e of events) eventMap.set(e.id, e);\n\n  // 2. Build topological levels for prioritisation within levels\n  const level = new Map<string, number>();\n  for (const id of sortedIds) {\n    const ev = eventMap.get(id)!;\n    let maxPrereqLevel = -1;\n    if (ev.prerequisites) {\n      for (const p of ev.prerequisites) {\n        if (level.has(p)) {\n          maxPrereqLevel = Math.max(maxPrereqLevel, level.get(p)!);\n        }\n      }\n    }\n    level.set(id, maxPrereqLevel + 1);\n  }\n\n  // 3. Sort: by topological level first, then most-constrained-first\n  //    (fewer valid rooms = more constrained, more attendees = more constrained)\n  const validRoomsCount = new Map<string, number>();\n  for (const e of events) {\n    const attendees = e.attendees ?? 1;\n    const count = rooms.filter((r) => r.capacity >= attendees).length;\n    validRoomsCount.set(e.id, count);\n  }\n\n  const orderedIds = [...sortedIds].sort((a, b) => {\n    const levelDiff = level.get(a)! - level.get(b)!;\n    if (levelDiff !== 0) return levelDiff;\n    // Most constrained first (fewer valid rooms first)\n    const roomDiff = validRoomsCount.get(a)! - validRoomsCount.get(b)!;\n    if (roomDiff !== 0) return roomDiff;\n    // Larger events first (harder to place)\n    const durA = eventMap.get(a)!.duration;\n    const durB = eventMap.get(b)!.duration;\n    return durB - durA;\n  });\n\n  // 4. Try to schedule with backtracking (limited depth)\n  const result = scheduleWithBacktracking(\n    orderedIds,\n    eventMap,\n    rooms,\n    options,\n    gap,\n    validRoomsCount\n  );\n\n  return result;\n}\n\ninterface Placement {\n  eventId: string;\n  roomId: string;\n  startTime: number;\n  endTime: number;\n}\n\nfunction scheduleWithBacktracking(\n  orderedIds: string[],\n  eventMap: Map<string, Event>,\n  rooms: Room[],\n  options: ScheduleOptions,\n  gap: number,\n  _validRoomsCount: Map<string, number>\n): ScheduleResult {\n  const assignments = new M