+// ── Data Model ──────────────────────────────────────────────────────
+
+export interface Event {
+  id: string;
+  name: string;
+  duration: number;
+  attendees?: number;
+  prerequisites?: string[];
+  preferredRoom?: string;
+}
+
+export interface Room {
+  id: string;
+  name: string;
+  capacity: number;
+}
+
+export interface ScheduleOptions {
+  startTime: number;
+  endTime: number;
+  gap?: number;
+}
+
+export interface Assignment {
+  eventId: string;
+  roomId: string;
+  startTime: number;
+  endTime: number;
+}
+
+export interface ScheduleResult {
+  assignments: Assignment[];
+  unscheduled: string[];
+}
+
+// ── Helpers ─────────────────────────────────────────────────────────
+
+/**
+ * Detect cycles in the prerequisite graph.
+ * Throws if a cycle (including self-references) is found.
+ * Returns a topologically-sorted list of event IDs (dependencies first).
+ */
+function topologicalSort(events: Event[]): string[] {
+  const eventIds = new Set(events.map((e) => e.id));
+  const adj = new Map<string, string[]>();
+  const inDegree = new Map<string, number>();
+
+  for (const e of events) {
+    adj.set(e.id, []);
+    inDegree.set(e.id, 0);
+  }
+
+  for (const e of events) {
+    if (!e.prerequisites) continue;
+    for (const prereq of e.prerequisites) {
+      if (prereq === e.id) {
+        throw new Error(
+          `Cycle detected: event "${e.id}" lists itself as a prerequisite`
+        );
+      }
+      if (eventIds.has(prereq)) {
+        adj.get(prereq)!.push(e.id);
+        inDegree.set(e.id, (inDegree.get(e.id) ?? 0) + 1);
+      }
+    }
+  }
+
+  // Kahn's algorithm
+  const queue: string[] = [];
+  for (const [id, deg] of inDegree) {
+    if (deg === 0) queue.push(id);
+  }
+
+  const sorted: string[] = [];
+  while (queue.length > 0) {
+    const node = queue.shift()!;
+    sorted.push(node);
+    for (const dep of adj.get(node) ?? []) {
+      const newDeg = (inDegree.get(dep) ?? 1) - 1;
+      inDegree.set(dep, newDeg);
+      if (newDeg === 0) queue.push(dep);
+    }
+  }
+
+  if (sorted.length !== eventIds.size) {
+    throw new Error("Cycle detected in prerequisite graph");
+  }
+
+  return sorted;
+}
+
+/**
+ * Find the earliest available start time in a room that doesn't conflict
+ * with existing assignments, respecting the gap constraint.
+ */
+function findEarliestSlot(
+  roomId: string,
+  duration: number,
+  earliestStart: number,
+  endTime: number,
+  gap: number,
+  assignments: Assignment[]
+): number | null {
+  const roomSlots = assignments
+    .filter((a) => a.roomId === roomId)
+    .sort((a, b) => a.startTime - b.startTime);
+
+  // Candidate start times: the earliest possible, and after each existing event + gap
+  const candidates: number[] = [earliestStart];
+  for (const a of roomSlots) {
+    candidates.push(a.endTime + gap);
+  }
+
+  for (const candidate of candidates) {
+    const start = Math.max(candidate, earliestStart);
+    const end = start + duration;
+    if (end > endTime) continue;
+
+    let conflict = false;
+    for (const a of roomSlots) {
+      if (!(end + gap <= a.startTime || a.endTime + gap <= start)) {
+        conflict = true;
+        break;
+      }
+    }
+    if (!conflict) return start;
+  }
+
+  return null;
+}
+
+// ── Main Scheduler ──────────────────────────────────────────────────
+
+export function schedule(
+  events: Event[],
+  rooms: Room[],
+  options: ScheduleOptions
+): ScheduleResult {
+  const gap = options.gap ?? 15;
+
+  // 1. Cycle detection + topological sort
+  const topoOrder = topologicalSort(events);
+
+  const eventMap = new Map<string, Event>();
+  for (const e of events) eventMap.set(e.id, e);
+
+  // 2. Compute valid rooms for each event
+  const validRooms = new Map<string, Room[]>();
+  for (const e of events) {
+    const attendees = e.attendees ?? 1;
+    const suitable = rooms
+      .filter((r) => r.capacity >= attendees)
+      .sort((a, b) => {
+        // Preferred room first
+        if (e.preferredRoom) {
+          if (a.id === e.preferredRoom && b.id !== e.preferredRoom) return -1;
+          if (b.id === e.preferredRoom && a.id !== e.preferredRoom) return 1;
+        }
+        return a.capacity - b.capacity;
+      });
+    validRooms.set(e.id, suitable);
+  }
+
+  // 4. Build dependency info: for each event, which events must come before it
+  const prereqsOf = new Map<string, Set<string>>();
+  for (const e of events) {
+    const prereqs = new Set<string>();
+    if (e.prerequisites) {
+      for (const p of e.prerequisites) {
+        if (eventMap.has(p)) prereqs.add(p);
+      }
+    }
+    prereqsOf.set(e.id, prereqs);
+  }
+
+  // 5. Use backtracking search to maximize the number of scheduled events.
+  //    We process events in topological order so prerequisites are always
+  //    handled before dependents. For each event, we try each valid room
+  //    placement, or we skip the event (adding it to unscheduled).
+  //    We prune branches that can't beat the current best.
+
+  let bestAssignments: Assignment[] = [];
+  let bestScheduledCount = 0;
+
+  const currentAssignments: Assignment[] = [];
+  const assignmentMap = new Map<string, Assignment>();
+
+  function getEarliestForEvent(eventId: string): number {
+    let earliest = options.startTime;
+    const prereqs = prereqsOf.get(eventId)!;
+    for (const prereqId of prereqs) {
+      const a = assignmentMap.get(prereqId);
+      if (a) {
+        earliest = Math.max(earliest, a.endTime + gap);
+      }
+    }
+    return earliest;
+  }
+
+  function canPrereqsBeSatisfied(eventId: string): boolean {
+    const prereqs = prereqsOf.get(eventId)!;
+    for (const prereqId of prereqs) {
+      if (!assignmentMap.has(prereqId)) {
+        return false;
+      }
+    }
+    return true;
+  }
+
+  function backtrack(index: number, scheduledCount: number): void {
+    // If we've processed all events, check if this is the best
+    if (index === topoOrder.length) {
+      if (scheduledCount > bestScheduledCount) {
+        bestScheduledCount = scheduledCount;
+        bestAssignments = [...currentAssignments];
+      }
+      return;
+    }
+
+    // Pruning: even if we schedule all remaining events, can we beat best?
+    const remaining = topoOrder.length - index;
+    if (scheduledCount + remaining <= bestScheduledCount) {
+      return;
+    }
+
+    const eventId = topoOrder[index];
+    const event = eventMap.get(eventId)!;
+    const eventRooms = validRooms.get(eventId)!;
+
+    // Option 1: Try to place this event
+    if (eventRooms.length > 0 && canPrereqsBeSatisfied(eventId)) {
+      const earliest = getEarliestForEvent(eventId);
+
+      for (const room of eventRooms) {
+        const start = findEarliestSlot(
+          room.id,
+          event.duration,
+          earliest,
+          options.endTime,
+          gap,
+          currentAssignments
+        );
+
+        if (start !== null) {
+          const assignment: Assignment = {
+            eventId,
+            roomId: room.id,
+            startTime: start,
+            endTime: start + event.duration,
+          };
+          currentAssignments.push(assignment);
+          assignmentMap.set(eventId, assignment);
+
+          backtrack(index + 1, scheduledCount + 1);
+
+          currentAssignments.pop();
+          assignmentMap.delete(eventId);
+
+          // If we've already found a perfect schedule, stop
+          if (bestScheduledCount === topoOrder.length) return;
+        }
+      }
+    }
+
+    // Option 2: Skip this event (mark as unscheduled)
+    // But only if skipping it won't prevent dependents from being scheduled
+    // (actually we always allow skip - dependents just won't have their prereqs met)
+    backtrack(index + 1, scheduledCount);
+  }
+
+  // For large inputs, limit backtracking with a call budget
+  let callCount = 0;
+  const CALL_BUDGET = 500000;
+
+  function backtrackBudgeted(index: number, scheduledCount: number): void {
+    callCount++;
+    if (callCount > CALL_BUDGET) {
+      // Over budget, stop exploring
+      if (scheduledCount > bestScheduledCount) {
+        bestScheduledCount = scheduledCount;
+        bestAssignments = [...currentAssignments];
+      }
+      return;
+    }
+
+    if (index === topoOrder.length) {
+      if (scheduledCount > bestScheduledCount) {
+        bestScheduledCount = scheduledCount;
+        bestAssignments = [...currentAssignments];
+      }
+      return;
+    }
+
+    const remaining = topoOrder.length - index;
+    if (scheduledCount + remaining <= bestScheduledCount) {
+      return;
+    }
+
+    const eventId = topoOrder[index];
+    const event = eventMap.get(eventId)!;
+    const eventRooms = validRooms.get(eventId)!;
+
+    // Option 1: Try to place this event
+    if (eventRooms.length > 0 && canPrereqsBeSatisfied(eventId)) {
+      const earliest = getEarliestForEvent(eventId);
+
+      for (const room of eventRooms) {
+        const start = findEarliestSlot(
+          room.id,
+          event.duration,
+          earliest,
+          options.endTime,
+          gap,
+          currentAssignments
+        );
+
+        if (start !== null) {
+          const assignment: Assignment = {
+            eventId,
+            roomId: room.id,
+            startTime: start,
+            endTime: start + event.duration,
+          };
+          currentAssignments.push(assignment);
+          assignmentMap.set(eventId, assignment);
+
+          backtrackBudgeted(index + 1, scheduledCount + 1);
+
+          currentAssignments.pop();
+          assignmentMap.delete(eventId);
+
+          if (bestScheduledCount === topoOrder.length) return;
+          if (callCount > CALL_BUDGET) return;
+        }
+      }
+    }
+
+    // Option 2: Skip this event
+    backtrackBudgeted(index + 1, scheduledCount);
+  }
+
+  // Decide strategy based on problem size
+  const totalPlacements = topoOrder.reduce(
+    (sum, id) => sum + (validRooms.get(id)?.length ?? 0),
+    0
+  );
+
+  if (events.length <= 20 && totalPlacements <= 100) {
+    // Small enough for full backtracking
+    backtrack(0, 0);
+  } else {
+    // Use budgeted backtracking
+    // First do a greedy pass to establish a good baseline
+    greedySchedule(
+      topoOrder,
+      eventMap,
+      validRooms,
+      prereqsOf,
+      options,
+      gap,
+      currentAssignments,
+      assignmentMap
+    );
+    bestScheduledCount = currentAssignments.length;
+    bestAssignments = [...currentAssignments];
+
+    // Clear and try backtracking with budget
+    currentAssignments.length = 0;
+    assignmentMap.clear();
+    backtrackBudgeted(0, 0);
+  }
+
+  // Build result
+  const scheduledIds = new Set(bestAssignments.map((a) => a.eventId));
+  const unscheduled = topoOrder.filter((id) => !scheduledIds.has(id));
+
+  return {
+    assignments: bestAssignments,
+    unscheduled,
+  };
+}
+
+/**
+ * Greedy scheduler: process events in topological order, placing each
+ * at the earliest valid slot. Prefer rooms with preference, then smallest
+ * sufficient room.
+ */
+function greedySchedule(
+  topoOrder: string[],
+  eventMap: Map<string, Event>,
+  validRooms: Map<string, Room[]>,
+  prereqsOf: Map<string, Set<string>>,
+  options: ScheduleOptions,
+  gap: number,
+  outAssignments: Assignment[],
+  outMap: Map<string, Assignment>
+): void {
+  for (const eventId of topoOrder) {
+    const event = eventMap.get(eventId)!;
+    const eventRooms = validRooms.get(eventId)!;
+
+    // Check prereqs
+    const prereqs = prereqsOf.get(eventId)!;
+    let prereqsMet = true;
+    let earliest = options.startTime;
+    for (const prereqId of prereqs) {
+      const a = outMap.get(prereqId);
+      if (!a) {
+        prereqsMet = false;
+        break;
+      }
+      earliest = Math.max(earliest, a.endTime + gap);
+    }
+
+    if (!prereqsMet) continue;
+
+    for (const room of eventRooms) {
+      const start = findEarliestSlot(
+        room.id,
+        event.duration,
+        earliest,
+        options.endTime,
+        gap,
+        outAssignments
+      );
+      if (start !== null) {
+        const assignment: Assignment = {
+          eventId,
+          roomId: room.id,
+          startTime: start,
+          endTime: start + event.duration,
+        };
+        outAssignments.push(assignment);
+        outMap.set(eventId, assignment);
+        break;
+      }
+    }
+  }
+}
+
+// Also export as a class for flexibility
+export class Scheduler {
+  schedule(
+    events: Event[],
+    rooms: Room[],
+    options: ScheduleOptions
+  ): ScheduleResult {
+    return schedule(events, rooms, options);
+  }
+}
+
+export function createScheduler(): Scheduler {
+  return new Scheduler();
+}
+
+export default schedule;
