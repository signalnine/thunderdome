in(Math.max(0, op.position), content.length);\n    return content.slice(0, pos) + op.text + content.slice(pos);\n  } else {\n    const pos = Math.min(Math.max(0, op.position), content.length);\n    const count = Math.min(op.count, content.length - pos);\n    return content.slice(0, pos) + content.slice(pos + count);\n  }\n}\n\n/**\n * Transform operation `op` against `applied` (which has already been applied).\n * Returns the transformed version of `op` that achieves the same intent\n * in the context where `applied` has already taken effect.\n */\nexport function transformOp(op: Operation, applied: Operation): Operation {\n  if (op.type === 'insert' && applied.type === 'insert') {\n    return transformInsertInsert(op, applied);\n  } else if (op.type === 'insert' && applied.type === 'delete') {\n    return transformInsertDelete(op, applied);\n  } else if (op.type === 'delete' && applied.type === 'insert') {\n    return transformDeleteInsert(op as DeleteOp, applied as InsertOp);\n  } else {\n    return transformDeleteDelete(op as DeleteOp, applied as DeleteOp);\n  }\n}\n\nfunction transformInsertInsert(op: InsertOp, applied: InsertOp): InsertOp {\n  if (op.position <= applied.position) {\n    // op inserts before or at the same position as applied; no shift needed.\n    // Tie-break: if same position, the \"applied\" op (server-side) wins the earlier spot.\n    // So if positions are equal, we shift op to the right.\n    if (op.position < applied.position) {\n      return { ...op };\n    }\n    // Same position: shift op to the right of applied's text\n    return { type: 'insert', position: op.position + applied.text.length, text: op.text };\n  }\n  // op inserts after applied; shift right by applied's text length\n  return { type: 'insert', position: op.position + applied.text.length, text: op.text };\n}\n\nfunction transformInsertDelete(op: InsertOp, applied: DeleteOp): InsertOp {\n  if (op.position <= applied.position) {\n    return { ...op };\n  }\n  if (op.position >= applied.position + applied.count) {\n    return { type: 'insert', position: op.position - applied.count, text: op.text };\n  }\n  // Insert was inside the deleted region; move to the start of deletion\n  return { type: 'insert', position: applied.position, text: op.text };\n}\n\nfunction transformDeleteInsert(op: DeleteOp, applied: InsertOp): DeleteOp {\n  if (op.position + op.count <= applied.position) {\n    // Delete region is entirely before the insert\n    return { ...op };\n  }\n  if (op.position >= applied.position) {\n    // Delete region is entirely after or at the insert point\n    return { type: 'delete', position: op.position + applied.text.length, count: op.count };\n  }\n  // The insert falls within the delete range; split the delete around the insert\n  // Delete from op.position to applied.position, then skip inserted text,\n  // then delete the rest\n  const beforeCount = applied.position - op.position;\n  const afterCount = op.count - beforeCount;\n  // We need to delete more characters total because inserted text split the region\n  // Actually we delete the same characters, but they're now in two segments\n  // For simplicity, we return a single delete that covers the whole range including the insert\n  // But that would delete inserted text, which is wrong.\n  // Instead, we return a delete that covers both segments. Since we can only return one op,\n  // we need to handle this carefully.\n  // The right approach: expand the delete to cover the new positions\n  return { type: 'delete', position: op.position, count: beforeCount + applied.text.length + afterCount };\n  // Wait, this would delete the inserted text too. That's wrong.\n  // Actually the correct OT approach: the delete should NOT delete the newly inserted text.\n  // We need to return TWO ops, or we adjust differently.\n  // Standard approach: return a single delete that just adjusts position and count\n  // to skip over the inserted text.\n  // Since we can only return one ope