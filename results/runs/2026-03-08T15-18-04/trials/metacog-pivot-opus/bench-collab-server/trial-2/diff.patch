--- /dev/null
+++ b/src/ot.ts
@@ -0,0 +1,205 @@
+/**
+ * Operational Transformation engine for collaborative editing.
+ *
+ * Operations:
+ *   - insert: { type: 'insert', position: number, text: string }
+ *   - delete: { type: 'delete', position: number, count: number }
+ *
+ * transform(a, b) returns a' such that:
+ *   apply(apply(doc, b), a') === apply(apply(doc, a), b')
+ * where b has already been applied to the document.
+ */
+
+export interface InsertOp {
+  type: 'insert';
+  position: number;
+  text: string;
+}
+
+export interface DeleteOp {
+  type: 'delete';
+  position: number;
+  count: number;
+}
+
+export type Operation = InsertOp | DeleteOp;
+
+export function applyOperation(content: string, op: Operation): string {
+  if (op.type === 'insert') {
+    const pos = Math.min(Math.max(0, op.position), content.length);
+    return content.slice(0, pos) + op.text + content.slice(pos);
+  } else {
+    const pos = Math.min(Math.max(0, op.position), content.length);
+    const count = Math.min(op.count, content.length - pos);
+    if (count <= 0) return content;
+    return content.slice(0, pos) + content.slice(pos + count);
+  }
+}
+
+export function applyOperations(content: string, ops: Operation[]): string {
+  let result = content;
+  for (const op of ops) {
+    result = applyOperation(result, op);
+  }
+  return result;
+}
+
+/**
+ * Transform operation `a` against already-applied operation `b`.
+ * Returns an array of operations (a') that achieves a's intent
+ * in the context where b has been applied.
+ * Usually returns a single operation, but may return two when
+ * an insert splits a delete range.
+ */
+export function transform(a: Operation, b: Operation): Operation[] {
+  if (a.type === 'insert' && b.type === 'insert') {
+    return [tII(a, b)];
+  } else if (a.type === 'insert' && b.type === 'delete') {
+    return [tID(a, b)];
+  } else if (a.type === 'delete' && b.type === 'insert') {
+    return tDI(a, b);
+  } else {
+    return [tDD(a as DeleteOp, b as DeleteOp)];
+  }
+}
+
+function tII(a: InsertOp, b: InsertOp): InsertOp {
+  if (a.position < b.position || (a.position === b.position && a.text <= b.text)) {
+    return { type: 'insert', position: a.position, text: a.text };
+  }
+  return { type: 'insert', position: a.position + b.text.length, text: a.text };
+}
+
+function tID(a: InsertOp, b: DeleteOp): InsertOp {
+  if (a.position <= b.position) {
+    return { type: 'insert', position: a.position, text: a.text };
+  }
+  if (a.position >= b.position + b.count) {
+    return { type: 'insert', position: a.position - b.count, text: a.text };
+  }
+  return { type: 'insert', position: b.position, text: a.text };
+}
+
+function tDI(a: DeleteOp, b: InsertOp): DeleteOp[] {
+  if (a.position + a.count <= b.position) {
+    return [{ type: 'delete', position: a.position, count: a.count }];
+  }
+  if (a.position >= b.position) {
+    return [{ type: 'delete', position: a.position + b.text.length, count: a.count }];
+  }
+  // Insert falls within delete range: split delete into two parts
+  // Part 1: delete chars before the insert
+  const beforeCount = b.position - a.position;
+  // Part 2: delete chars after the insert (shifted by insert text length)
+  const afterCount = a.count - beforeCount;
+  const ops: DeleteOp[] = [];
+  // Delete the after part first (higher position) so it doesn't affect the before part
+  if (afterCount > 0) {
+    ops.push({ type: 'delete', position: b.position + b.text.length, count: afterCount });
+  }
+  if (beforeCount > 0) {
+    ops.push({ type: 'delete', position: a.position, count: beforeCount });
+  }
+  return ops;
+}
+
+function tDD(a: DeleteOp, b: DeleteOp): DeleteOp {
+  if (a.position + a.count <= b.position) {
+    return { type: 'delete', position: a.position, count: a.count };
+  }
+  if (a.position >= b.position + b.count) {
+    return { type: 'delete', position: a.position - b.count, count: a.count };
+  }
+
+  const aEnd = a.position + a.count;
+  const bEnd = b.position + b.count;
+
+  if (a.position >= b.position && aEnd <= bEnd) {
+    return { type: 'delete', position: b.position, count: 0 };
+  }
+  if (a.position <= b.position && aEnd >= bEnd) {
+    return { type: 'delete', position: a.position, count: a.count - b.count };
+  }
+  if (a.position < b.position) {
+    const overlap = aEnd - b.position;
+    return { type: 'delete', position: a.position, count: a.count - overlap };
+  }
+  const overlap = bEnd - a.position;
+  return { type: 'delete', position: b.position, count: a.count - overlap };
+}
+
+/**
+ * Transform an operation against a single already-applied operation.
+ * Returns an array since a split can occur.
+ */
+function transformOne(op: Operation, applied: Operation): Operation[] {
+  return transform(op, applied);
+}
+
+/**
+ * Transform an array of operations against a single applied operation.
+ */
+function transformArrayAgainstOne(ops: Operation[], applied: Operation): Operation[] {
+  const result: Operation[] = [];
+  for (const op of ops) {
+    result.push(...transformOne(op, applied));
+  }
+  return result;
+}
+
+/**
+ * Transform an operation against a sequence of already-applied operations.
+ * May return multiple operations if splits occur.
+ */
+export function transformAgainstAll(op: Operation, appliedOps: Operation[]): Operation[] {
+  let transformed: Operation[] = [op];
+  for (const applied of appliedOps) {
+    transformed = transformArrayAgainstOne(transformed, applied);
+  }
+  return transformed;
+}
+
+/**
+ * Validate an operation against the current document content length.
+ * Returns null if valid, or an error message if invalid.
+ */
+export function validateOperation(op: Operation, contentLength: number): string | null {
+  if (op.type === 'insert') {
+    if (typeof op.position !== 'number' || op.position < 0) {
+      return 'Insert position must be a non-negative number';
+    }
+    if (op.position > contentLength) {
+      return `Insert position ${op.position} is beyond document length ${contentLength}`;
+    }
+    if (typeof op.text !== 'string' || op.text.length === 0) {
+      return 'Insert text must be a non-empty string';
+    }
+  } else if (op.type === 'delete') {
+    if (typeof op.position !== 'number' || op.position < 0) {
+      return 'Delete position must be a non-negative number';
+    }
+    if (typeof op.count !== 'number' || op.count < 0) {
+      return 'Delete count must be a non-negative number';
+    }
+    if (op.position + op.count > contentLength) {
+      return `Delete range [${op.position}, ${op.position + op.count}) exceeds document length ${contentLength}`;
+    }
+  } else {
+    return `Unknown operation type: ${(op as { type: string }).type}`;
+  }
+  return null;
+}
+
+export function validateOperations(ops: Operation[], contentLength: number): string | null {
+  let len = contentLength;
+  for (const op of ops) {
+    const err = validateOperation(op, len);
+    if (err) return err;
+    if (op.type === 'insert') {
+      len += op.text.length;
+    } else if (op.type === 'delete') {
+      len -= op.count;
+    }
+  }
+  return null;
+}
