l sync message.\n * Registers the message handler before the connection opens to avoid\n * missing the sync message.\n */\nfunction connectWs(docId: string): Promise<{ ws: WebSocket; sync: Record<string, unknown> }> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/documents/${docId}/ws`);\n    ws.on('message', function onFirstMessage(data) {\n      ws.off('message', onFirstMessage);\n      const msg = JSON.parse(data.toString());\n      resolve({ ws, sync: msg });\n    });\n    ws.on('error', reject);\n  });\n}\n\nfunction waitForMessage(ws: WebSocket, type?: string): Promise<Record<string, unknown>> {\n  return new Promise((resolve, reject) => {\n    const timeout = setTimeout(() => reject(new Error(`Timed out waiting for message type: ${type}`)), 5000);\n    const handler = (data: WebSocket.Data) => {\n      const msg = JSON.parse(data.toString());\n      if (!type || msg.type === type) {\n        ws.off('message', handler);\n        clearTimeout(timeout);\n        resolve(msg);\n      }\n    };\n    ws.on('message', handler);\n  });\n}\n\ndescribe('REST API', () => {\n  it('should create a document', async () => {\n    const doc = await createDoc('Test Doc', 'initial content');\n    expect(doc.id).toBeDefined();\n    expect(doc.title).toBe('Test Doc');\n    expect(doc.content).toBe('initial content');\n  });\n\n  it('should list documents', async () => {\n    await createDoc('Doc 1');\n    await createDoc('Doc 2');\n    const res = await fetch(`${baseUrl}/api/documents`);\n    const docs = await res.json() as unknown[];\n    expect(docs.length).toBe(2);\n  });\n\n  it('should get a document by id', async () => {\n    const created = await createDoc('My Doc', 'content here');\n    const doc = await getDoc(created.id as string);\n    expect(doc.title).toBe('My Doc');\n    expect(doc.content).toBe('content here');\n    expect(doc.version).toBe(0);\n  });\n\n  it('should update a document', async () => {\n    const created = await createDoc('Old Title');\n    const res = await fetch(`${baseUrl}/api/documents/${created.id}`, {\n      method: 'PUT',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'New Title', content: 'new content' }),\n    });\n    const updated = await res.json() as Record<string, unknown>;\n    expect(updated.title).toBe('New Title');\n    expect(updated.content).toBe('new content');\n  });\n\n  it('should delete a document', async () => {\n    const created = await createDoc('To Delete');\n    const res = await fetch(`${baseUrl}/api/documents/${created.id}`, {\n      method: 'DELETE',\n    });\n    expect(res.status).toBe(204);\n\n    const getRes = await fetch(`${baseUrl}/api/documents/${created.id}`);\n    expect(getRes.status).toBe(404);\n  });\n\n  it('should return 404 for non-existent document', async () => {\n    const res = await fetch(`${baseUrl}/api/documents/nonexistent`);\n    expect(res.status).toBe(404);\n  });\n\n  it('should return 400 for missing title', async () => {\n    const res = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({}),\n    });\n    expect(res.status).toBe(400);\n  });\n\n  it('should get version history', async () => {\n    const created = await createDoc('Versioned Doc', 'v0');\n    const res = await fetch(`${baseUrl}/api/documents/${created.id}/versions`);\n    const versions = await res.json() as unknown[];\n    expect(versions.length).toBe(1);\n    expect((versions[0] as Record<string, unknown>).version).toBe(0);\n    expect((versions[0] as Record<string, unknown>).content).toBe('v0');\n  });\n});\n\ndescribe('WebSocket collaboration', () => {\n  it('should send sync message on connect', async () => {\n    const doc = await createDoc('WS Doc', 'hello');\n    const { ws, sync } = await connectWs(doc.id as string);\n    expect(sync.type).toBe('sync');\n    expect(sync.content).toBe('hello');\n    expect(sync.version).toBe(0);\n    ws.close();\n  });\n\n  it('should handle insert operation and ack', async () => {\n    const doc = await createDoc('Edit Doc', 'hello');\n    const { ws } = await connectWs(doc.id as string);\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      operation: { type: 'insert', position: 5, text: ' world' },\n    }));\n\n    const ack = await waitForMessage(ws, 'ack');\n    expect(ack.version).toBe(1);\n\n    const updated = await getDoc(doc.id as string);\n    expect(updated.content).toBe('hello world');\n\n    ws.close();\n  });\n\n  it('should handle delete operation', async () => {\n    const doc = await createDoc('Delete Doc', 'hello world');\n    const { ws } = await connectWs(doc.id as string);\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      operation: { type: 'delete', position: 5, count: 6 },\n    }));\n\n    const ack = await waitForMessage(ws, 'ack');\n    expect(ack.version).toBe(1);\n\n    const updated = await getDoc(doc.id as string);\n    expect(updated.content).toBe('hello');\n\n    ws.close();\n  });\n\n  it('should broadcast operations to other clients', async () => {\n    const doc = await createDoc('Broadcast Doc', 'abc');\n    const { ws: ws1 } = await connectWs(doc.id as string);\n    const { ws: ws2 } = await connectWs(doc.id as string);\n\n    const broadcastPromise = waitForMessage(ws2, 'operation');\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      operation: { type: 'insert', position: 3, text: 'X' },\n    }));\n\n    await waitForMessage(ws1, 'ack');\n    const broadcast = await broadcastPromise;\n    expect(broadcast.version).toBe(1);\n    const ops = broadcast.operations as Record<string, unknown>[];\n    expect(ops.length).toBeGreaterThanOrEqual(1);\n    expect(ops[0].type).toBe('insert');\n    expect(ops[0].text).toBe('X');\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should handle concurrent edits with OT', async () => {\n    const doc = await createDoc('OT Doc', 'abcdef');\n    const { ws: ws1 } = await connectWs(doc.id as string);\n    const { ws: ws2 } = await connectWs(doc.id as string);\n\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      operation: { type: 'insert', position: 2, text: 'X' },\n    }));\n\n    const ack1 = await waitForMessage(ws1, 'ack');\n    expect(ack1.version).toBe(1);\n\n    ws2.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      operation: { type: 'insert', position: 4, text: 'Y' },\n    }));\n\n    const ack2 = await waitForMessage(ws2, 'ack');\n    expect(ack2.version).toBe(2);\n\n    const result = await getDoc(doc.id as string);\n    const content = result.content as string;\n    expect(content).toContain('X');\n    expect(content).toContain('Y');\n    expect(content.length).toBe(8);\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should reject invalid operations', async () => {\n    const doc = await createDoc('Invalid Op Doc', 'hi');\n    const { ws } = await connectWs(doc.id as string);\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      operation: { type: 'delete', position: 0, count: 100 },\n    }));\n\n    const error = await waitForMessage(ws, 'error');\n    expect(error.message).toBeDefined();\n\n    ws.close();\n  });\n\n  it('should reject malformed messages', async () => {\n    const doc = await createDoc('Malformed Doc', 'hi');\n    const { ws } = await connectWs(doc.id as string);\n\n    ws.send('not json');\n    const error = await waitForMessage(ws, 'error');\n    expect(error.message).toBeDefined();\n\n    ws.close();\n  });\n\n  it('should reject invalid message format', async () => {\n    const doc = await createDoc('Bad Format Doc', 'hi');\n    const { ws } = await connectWs(doc.id as string);\n\n    ws.send(JSON.stringify({ type: 'unknown' }));\n    const error = await waitForMessage(ws, 'error');\n    expect(error.message).toBeDefined();\n\n    ws.close();\n  });\n\n  it('should handle 10 concurrent clients', async () => {\n    const doc = await createDoc('Concurrent Doc', '');\n    const clients: WebSocket[] = [];\n\n    for (let i = 0; i < 10; i++) {\n      const { ws } = await connectWs(doc.id as string);\n      clients.push(ws);\n    }\n\n    for (let i = 0; i < 10; i++) {\n      clients[i].send(JSON.stringify({\n        type: 'operation',\n        version: i,\n        operation: { type: 'insert', position: i, text: String(i) },\n      }));\n      await waitForMessage(clients[i], 'ack');\n    }\n\n    const result = await getDoc(doc.id as string);\n    const content = result.content as string;\n    expect(content.length).toBe(10);\n\n    for (let i = 0; i < 10; i++) {\n      expect(content).toContain(String(i));\n    }\n\n    for (const ws of clients) ws.close();\n  });\n\n  it('should persist data across restarts', async () => {\n    const tmpDb = '/tmp/test-collab-persist.db';\n\n    const app1 = createApp(tmpDb);\n    const port1 = await app1.start(0);\n    const res1 = await fetch(`http://localhost:${port1}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Persistent', content: 'persisted data' }),\n    });\n    const doc1 = await res1.json() as Record<string, unknown>;\n    await app1.stop();\n\n    const app2 = createApp(tmpDb);\n    const port2 = await app2.start(0);\n    const res2 = await fetch(`http://localhost:${port2}/api/documents/${doc1.id}`);\n    const doc2 = await res2.json() as Record<string, unknown>;\n    expect(doc2.title).toBe('Persistent');\n    expect(doc2.content).toBe('persisted data');\n    await app2.stop();\n\n    const { unlinkSync } = await import('fs');\n    try { unlinkSync(tmpDb); } catch { /* ignore */ }\n  });\n\n  it('should track version history through WebSocket edits', async () => {\n    const doc = await createDoc('History Doc', 'start');\n    const { ws } = await connectWs(doc.id as string);\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      operation: { type: 'insert', position: 5, text: ' middle' },\n    }));\n    await waitForMessage(ws, 'ack');\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      version: 1,\n      operation: { type: 'insert', position: 12, text: ' end' },\n    }));\n    await waitForMessage(ws, 'ack');\n\n    const res = await fetch(`${baseUrl}/api/documents/${doc.id}/versions`);\n    const versions = await res.json() as Record<string, unknown>[];\n    expect(versions.length).toBe(3);\n    expect(versions[0].version).toBe(0);\n    expect(versions[1].version).toBe(1);\n    expect(versions[2].version).toBe(2);\n    expect(versions[2].content).toBe('start middle end');\n\n    ws.close();\n  });\n});\n","structuredPatch":[{"oldStart":13,"oldLines":7,"newStart":13,"newLines":7,"lines":[" });"," "," afterEach(async () => {","-  await app.stop();","+  await app.stop().catch(() => {});"," });"," "," async function createDoc(title: string, content: string = ''): Promise<Record<string, unknown>> {"]},{"oldStart":30,"oldLines":20,"newStart":30,"newLines":32,"lines":["   return res.json() as Promise<Record<string, unknown>>;"," }"," ","-function connectWs(docId: string): Promise<WebSocket> {","+/**","+ * Connect to a document's WebSocket endpoint.","+ * Returns { ws, sync } where sync is the initial sync message.","+ * Registers the message handler before the connection opens to avoid","+ * missing the sync message.","+ */","+function connectWs(docId: string): Promise<{ ws: WebSocket; sync: Record<string, unknown> }> {","   return new Promise((resolve, reject) => {","     const ws = new WebSocket(`ws://localhost:${port}/documents/${docId}/ws`);","-    ws.on('open', () => resolve(ws));","+    ws.on('message', function onFirstMessage(data) {","+      ws.off('message', onFirstMessage);","+      const msg = JSON.parse(data.toString());",