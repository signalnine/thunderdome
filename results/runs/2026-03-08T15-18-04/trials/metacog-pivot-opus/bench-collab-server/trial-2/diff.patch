: 'insert', position: 1, text: 'a' });\n  });\n\n  it('should shift a right when a is after b', () => {\n    const a: Operation = { type: 'insert', position: 5, text: 'a' };\n    const b: Operation = { type: 'insert', position: 2, text: 'bb' };\n    const result = transform(a, b);\n    expect(result).toEqual({ type: 'insert', position: 7, text: 'a' });\n  });\n\n  it('should use lexicographic tie-break at same position', () => {\n    const a: Operation = { type: 'insert', position: 3, text: 'b' };\n    const b: Operation = { type: 'insert', position: 3, text: 'a' };\n    const result = transform(a, b);\n    expect(result).toEqual({ type: 'insert', position: 4, text: 'b' });\n  });\n\n  it('should preserve both inserts at same position (convergence)', () => {\n    const doc = 'hello';\n    const a: Operation = { type: 'insert', position: 3, text: 'X' };\n    const b: Operation = { type: 'insert', position: 3, text: 'Y' };\n\n    const aPrime = transform(a, b);\n    const bPrime = transform(b, a);\n\n    const result1 = applyOperation(applyOperation(doc, a), bPrime);\n    const result2 = applyOperation(applyOperation(doc, b), aPrime);\n    expect(result1).toBe(result2);\n    expect(result1).toContain('X');\n    expect(result1).toContain('Y');\n  });\n});\n\ndescribe('transform insert vs delete', () => {\n  it('should not shift insert before delete', () => {\n    const a: Operation = { type: 'insert', position: 1, text: 'x' };\n    const b: Operation = { type: 'delete', position: 3, count: 2 };\n    const result = transform(a, b);\n    expect(result).toEqual({ type: 'insert', position: 1, text: 'x' });\n  });\n\n  it('should shift insert left when after delete', () => {\n    const a: Operation = { type: 'insert', position: 5, text: 'x' };\n    const b: Operation = { type: 'delete', position: 1, count: 2 };\n    const result = transform(a, b);\n    expect(result).toEqual({ type: 'insert', position: 3, text: 'x' });\n  });\n\n  it('should place insert at delete position 