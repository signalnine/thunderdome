ult = transform(a, b);\n    expect(result).toEqual([{ type: 'delete', position: 1, count: 2 }]);\n  });\n\n  it('should shift delete right when after insert', () => {\n    const a: Operation = { type: 'delete', position: 5, count: 2 };\n    const b: Operation = { type: 'insert', position: 2, text: 'xx' };\n    const result = transform(a, b);\n    expect(result).toEqual([{ type: 'delete', position: 7, count: 2 }]);\n  });\n\n  it('should split delete when insert falls within range', () => {\n    const a: Operation = { type: 'delete', position: 2, count: 4 };\n    const b: Operation = { type: 'insert', position: 3, text: 'X' };\n    const result = transform(a, b);\n    expect(result.length).toBe(2);\n    // Applying the split deletes to \"abcXdefgh\" should preserve X\n    const doc = 'abcXdefgh';\n    const applied = applyOperations(doc, result);\n    expect(applied).toBe('abXgh');\n  });\n});\n\ndescribe('transform delete vs delete', () => {\n  it('should handle non-overlapping deletes (a before b)', () => {\n    const a: Operation = { type: 'delete', position: 0, count: 2 };\n    const b: Operation = { type: 'delete', position: 5, count: 2 };\n    const result = transform(a, b);\n    expect(result).toEqual([{ type: 'delete', position: 0, count: 2 }]);\n  });\n\n  it('should handle non-overlapping deletes (a after b)', () => {\n    const a: Operation = { type: 'delete', position: 5, count: 2 };\n    const b: Operation = { type: 'delete', position: 0, count: 2 };\n    const result = transform(a, b);\n    expect(result).toEqual([{ type: 'delete', position: 3, count: 2 }]);\n  });\n\n  it('should handle fully overlapping deletes (a within b)', () => {\n    const a: Operation = { type: 'delete', position: 2, count: 2 };\n    const b: Operation = { type: 'delete', position: 1, count: 5 };\n    const result = transform(a, b);\n    expect(result).toEqual([{ type: 'delete', position: 1, count: 0 }]);\n  });\n\n  it('should handle identical deletes', () => {\n    const a: Op