@@ -0,0 +1,236 @@
+import { describe, it, expect } from 'vitest';
+import { applyOperation, applyOperations, transform, transformAgainstAll, validateOperation, Operation } from './ot.js';
+
+describe('applyOperation', () => {
+  it('should insert text at position', () => {
+    expect(applyOperation('hello', { type: 'insert', position: 5, text: ' world' })).toBe('hello world');
+  });
+
+  it('should insert text at beginning', () => {
+    expect(applyOperation('world', { type: 'insert', position: 0, text: 'hello ' })).toBe('hello world');
+  });
+
+  it('should insert text in middle', () => {
+    expect(applyOperation('helo', { type: 'insert', position: 2, text: 'l' })).toBe('hello');
+  });
+
+  it('should delete text at position', () => {
+    expect(applyOperation('hello world', { type: 'delete', position: 5, count: 6 })).toBe('hello');
+  });
+
+  it('should delete from beginning', () => {
+    expect(applyOperation('hello', { type: 'delete', position: 0, count: 2 })).toBe('llo');
+  });
+
+  it('should handle empty document insert', () => {
+    expect(applyOperation('', { type: 'insert', position: 0, text: 'hi' })).toBe('hi');
+  });
+
+  it('should clamp position to valid range', () => {
+    expect(applyOperation('hi', { type: 'insert', position: 100, text: '!' })).toBe('hi!');
+  });
+});
+
+describe('transform insert vs insert', () => {
+  it('should not shift when a is before b', () => {
+    const a: Operation = { type: 'insert', position: 1, text: 'a' };
+    const b: Operation = { type: 'insert', position: 3, text: 'b' };
+    const result = transform(a, b);
+    expect(result).toEqual([{ type: 'insert', position: 1, text: 'a' }]);
+  });
+
+  it('should shift a right when a is after b', () => {
+    const a: Operation = { type: 'insert', position: 5, text: 'a' };
+    const b: Operation = { type: 'insert', position: 2, text: 'bb' };
+    const result = transform(a, b);
+    expect(result).toEqual([{ type: 'insert', position: 7, text: 'a' }]);
+  });
+
+  it('should use lexicographic tie-break at same position', () => {
+    const a: Operation = { type: 'insert', position: 3, text: 'b' };
+    const b: Operation = { type: 'insert', position: 3, text: 'a' };
+    const result = transform(a, b);
+    expect(result).toEqual([{ type: 'insert', position: 4, text: 'b' }]);
+  });
+
+  it('should preserve both inserts at same position (convergence)', () => {
+    const doc = 'hello';
+    const a: Operation = { type: 'insert', position: 3, text: 'X' };
+    const b: Operation = { type: 'insert', position: 3, text: 'Y' };
+
+    const aPrime = transform(a, b);
+    const bPrime = transform(b, a);
+
+    const result1 = applyOperations(applyOperation(doc, a), bPrime);
+    const result2 = applyOperations(applyOperation(doc, b), aPrime);
+    expect(result1).toBe(result2);
+    expect(result1).toContain('X');
+    expect(result1).toContain('Y');
+  });
+});
+
+describe('transform insert vs delete', () => {
+  it('should not shift insert before delete', () => {
+    const a: Operation = { type: 'insert', position: 1, text: 'x' };
+    const b: Operation = { type: 'delete', position: 3, count: 2 };
+    const result = transform(a, b);
+    expect(result).toEqual([{ type: 'insert', position: 1, text: 'x' }]);
+  });
+
+  it('should shift insert left when after delete', () => {
+    const a: Operation = { type: 'insert', position: 5, text: 'x' };
+    const b: Operation = { type: 'delete', position: 1, count: 2 };
+    const result = transform(a, b);
+    expect(result).toEqual([{ type: 'insert', position: 3, text: 'x' }]);
+  });
+
+  it('should place insert at delete position when inside deleted range', () => {
+    const a: Operation = { type: 'insert', position: 3, text: 'x' };
+    const b: Operation = { type: 'delete', position: 2, count: 4 };
+    const result = transform(a, b);
+    expect(result).toEqual([{ type: 'insert', position: 2, text: 'x' }]);
+  });
+});
+
+describe('transform delete vs insert', () => {
+  it('should not shift delete before insert', () => {
+    const a: Operation = { type: 'delete', position: 1, count: 2 };
+    const b: Operation = { type: 'insert', position: 5, text: 'x' };
+    const result = transform(a, b);
+    expect(result).toEqual([{ type: 'delete', position: 1, count: 2 }]);
+  });
+
+  it('should shift delete right when after insert', () => {
+    const a: Operation = { type: 'delete', position: 5, count: 2 };
+    const b: Operation = { type: 'insert', position: 2, text: 'xx' };
+    const result = transform(a, b);
+    expect(result).toEqual([{ type: 'delete', position: 7, count: 2 }]);
+  });
+
+  it('should split delete when insert falls within range', () => {
+    const a: Operation = { type: 'delete', position: 2, count: 4 };
+    const b: Operation = { type: 'insert', position: 3, text: 'X' };
+    const result = transform(a, b);
+    expect(result.length).toBe(2);
+    // Applying the split deletes to "abcXdefgh" should preserve X
+    const doc = 'abcXdefgh';
+    const applied = applyOperations(doc, result);
+    expect(applied).toBe('abXgh');
+  });
+});
+
+describe('transform delete vs delete', () => {
+  it('should handle non-overlapping deletes (a before b)', () => {
+    const a: Operation = { type: 'delete', position: 0, count: 2 };
+    const b: Operation = { type: 'delete', position: 5, count: 2 };
+    const result = transform(a, b);
+    expect(result).toEqual([{ type: 'delete', position: 0, count: 2 }]);
+  });
+
+  it('should handle non-overlapping deletes (a after b)', () => {
+    const a: Operation = { type: 'delete', position: 5, count: 2 };
+    const b: Operation = { type: 'delete', position: 0, count: 2 };
+    const result = transform(a, b);
+    expect(result).toEqual([{ type: 'delete', position: 3, count: 2 }]);
+  });
+
+  it('should handle fully overlapping deletes (a within b)', () => {
+    const a: Operation = { type: 'delete', position: 2, count: 2 };
+    const b: Operation = { type: 'delete', position: 1, count: 5 };
+    const result = transform(a, b);
+    expect(result).toEqual([{ type: 'delete', position: 1, count: 0 }]);
+  });
+
+  it('should handle identical deletes', () => {
+    const a: Operation = { type: 'delete', position: 2, count: 3 };
+    const b: Operation = { type: 'delete', position: 2, count: 3 };
+    const result = transform(a, b);
+    expect(result).toEqual([{ type: 'delete', position: 2, count: 0 }]);
+  });
+});
+
+describe('transformAgainstAll', () => {
+  it('should transform against a sequence of operations', () => {
+    const op: Operation = { type: 'insert', position: 5, text: 'X' };
+    const applied: Operation[] = [
+      { type: 'insert', position: 2, text: 'ab' },
+      { type: 'insert', position: 0, text: 'c' },
+    ];
+    const result = transformAgainstAll(op, applied);
+    expect(result).toEqual([{ type: 'insert', position: 8, text: 'X' }]);
+  });
+});
+
+describe('validateOperation', () => {
+  it('should accept valid insert', () => {
+    expect(validateOperation({ type: 'insert', position: 3, text: 'hi' }, 5)).toBeNull();
+  });
+
+  it('should reject insert beyond document length', () => {
+    expect(validateOperation({ type: 'insert', position: 10, text: 'hi' }, 5)).not.toBeNull();
+  });
+
+  it('should reject insert with empty text', () => {
+    expect(validateOperation({ type: 'insert', position: 0, text: '' }, 5)).not.toBeNull();
+  });
+
+  it('should accept valid delete', () => {
+    expect(validateOperation({ type: 'delete', position: 1, count: 3 }, 5)).toBeNull();
+  });
+
+  it('should reject delete beyond document length', () => {
+    expect(validateOperation({ type: 'delete', position: 3, count: 5 }, 5)).not.toBeNull();
+  });
+
+  it('should reject negative position', () => {
+    expect(validateOperation({ type: 'insert', position: -1, text: 'x' }, 5)).not.toBeNull();
+  });
+});
+
+describe('convergence with multiple concurrent operations', () => {
+  it('should converge when two clients insert at the same position', () => {
+    const doc = 'abcdef';
+    const opA: Operation = { type: 'insert', position: 3, text: 'X' };
+    const opB: Operation = { type: 'insert', position: 3, text: 'Y' };
+
+    const aPrime = transform(opA, opB);
+    const bPrime = transform(opB, opA);
+
+    const result1 = applyOperations(applyOperation(doc, opA), bPrime);
+    const result2 = applyOperations(applyOperation(doc, opB), aPrime);
+
+    expect(result1).toBe(result2);
+    expect(result1.length).toBe(doc.length + 2);
+  });
+
+  it('should converge when one inserts and one deletes at overlapping positions', () => {
+    const doc = 'abcdef';
+    const opA: Operation = { type: 'insert', position: 3, text: 'X' };
+    const opB: Operation = { type: 'delete', position: 2, count: 2 };
+
+    const aPrime = transform(opA, opB);
+    const bPrime = transform(opB, opA);
+
+    const result1 = applyOperations(applyOperation(doc, opA), bPrime);
+    const result2 = applyOperations(applyOperation(doc, opB), aPrime);
+
+    expect(result1).toBe(result2);
+    expect(result1).toContain('X');
+    expect(result1).toBe('abXef');
+  });
+
+  it('should converge with two deletes at different positions', () => {
+    const doc = 'abcdefgh';
+    const opA: Operation = { type: 'delete', position: 1, count: 2 };
+    const opB: Operation = { type: 'delete', position: 5, count: 2 };
+
+    const aPrime = transform(opA, opB);
+    const bPrime = transform(opB, opA);
+
+    const result1 = applyOperations(applyOperation(doc, opA), bPrime);
+    const result2 = applyOperations(applyOperation(doc, opB), aPrime);
+
+    expect(result1).toBe(result2);
+    expect(result1).toBe('adeh');
+  });
+});
