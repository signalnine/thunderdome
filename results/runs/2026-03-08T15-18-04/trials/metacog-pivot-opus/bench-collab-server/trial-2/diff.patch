eration';\n  version: number;\n  operation: Operation;\n}\n\ninterface SyncMessage {\n  type: 'sync';\n  content: string;\n  version: number;\n  documentId: string;\n}\n\ninterface AckMessage {\n  type: 'ack';\n  version: number;\n}\n\ninterface BroadcastMessage {\n  type: 'operation';\n  version: number;\n  operation: Operation;\n  clientId: string;\n}\n\ninterface ErrorMessage {\n  type: 'error';\n  message: string;\n}\n\ntype ServerMessage = SyncMessage | AckMessage | BroadcastMessage | ErrorMessage;\n\nexport class CollaborationServer {\n  private wss: WebSocketServer;\n  private store: DocumentStore;\n  // Map of documentId -> Set of client connections\n  private documentClients: Map<string, Set<ClientConnection>> = new Map();\n\n  constructor(httpServer: HttpServer, store: DocumentStore) {\n    this.store = store;\n    this.wss = new WebSocketServer({ server: httpServer, path: undefined });\n\n    // Handle upgrade manually to extract document ID from path\n    httpServer.on('upgrade', (request, socket, head) => {\n      const url = new URL(request.url || '', `http://${request.headers.host}`);\n      const match = url.pathname.match(/^\\/documents\\/([^/]+)\\/ws$/);\n\n      if (!match) {\n        socket.write('HTTP/1.1 404 Not Found\\r\\n\\r\\n');\n        socket.destroy();\n        return;\n      }\n\n      const documentId = match[1];\n      const doc = this.store.getDocument(documentId);\n      if (!doc) {\n        socket.write('HTTP/1.1 404 Not Found\\r\\n\\r\\n');\n        socket.destroy();\n        return;\n      }\n\n      this.wss.handleUpgrade(request, socket, head, (ws) => {\n        this.wss.emit('connection', ws, request, documentId);\n      });\n    });\n\n    this.wss.on('connection', (ws: WebSocket, _request: unknown, documentId: string) => {\n      this.handleConnection(ws, documentId);\n    });\n  }\n\n  private handleConnection(ws: WebSocket, documentId: string): void {\n    const connectionId = randomUUID();\n    const client: ClientConnection = { id: connectionId, ws, documentId };\n\n    // Add to document clients\n    if (!this.documentClients.has(documentId)) {\n      this.documentClients.set(documentId, new Set());\n    }\n    this.documentClients.get(documentId)!.add(client);\n\n    // Track in DB\n    this.store.addConnection(connectionId, documentId);\n\n    // Send current document state\n    const doc = this.store.getDocument(documentId);\n    const version = this.store.getLatestVersion(documentId);\n    if (doc) {\n      this.send(ws, {\n        type: 'sync',\n        content: doc.content,\n        version,\n        documentId,\n      });\n    }\n\n    ws.on('message', (data) => {\n      try {\n        const message = JSON.parse(data.toString());\n        this.handleMessage(client, message);\n      } catch {\n        this.send(ws, { type: 'error', message: 'Invalid JSON' });\n      }\n    });\n\n    ws.on('close', () => {\n      this.handleDisconnect(client);\n    });\n\n    ws.on('error', () => {\n      this.handleDisconnect(client);\n    });\n  }\n\n  private handleMessage(client: ClientConnection, message: unknown): void {\n    if (!isOperationMessage(message)) {\n      this.send(client.ws, {\n        type: 'error',\n        message: 'Invalid message format. Expected: { type: \"operation\", version: number, operation: Operation }',\n      });\n      return;\n    }\n\n    const { version, operation } = message;\n    const doc = this.store.getDocument(client.documentId);\n    if (!doc) {\n      this.send(client.ws, { type: 'error', message: 'Document not found' });\n      return;\n    }\n\n    const currentVersion = this.store.getLatestVersion(client.documentId);\n\n    if (version < 0 || version > currentVersion) {\n      this.send(client.ws, {\n        type: 'error',\n        message: `Invalid version ${version}. Current version is ${currentVersion}`,\n      });\n      return;\n    }\n\n    // Get all operations applied since the client's base version\n    const opsSince = this.store.getOperationsSince(client.documentId, version);\n    const appliedOps: Operation[] = opsSince\n      .map((v) => {\n        try {\n          return JSON.parse(v.operation!) as Operation;\n        } catch {\n          return null;\n        }\n      })\n      .filter((op): op is Operation => op !== null);\n\n    // Transform the incoming operation against all operations since version\n    const transformedOp = transformAgainstAll(operation, appliedOps);\n\n    // Validate the transformed operation against current content\n    const validationError = validateOperation(transformedOp, doc.content.length);\n    if (validationError) {\n      this.send(client.ws, { type: 'error', message: validationError });\n      return;\n    }\n\n    // Apply the transformed operation\n    const newContent = applyOperation(doc.content, transformedOp);\n    const newVersion = currentVersion + 1;\n\n    // Persist\n    this.store.updateDocument(client.documentId, undefined, newContent);\n    this.store.addVersion(\n      client.documentId,\n      newVersion,\n      newContent,\n      JSON.stringify(transformedOp)\n    );\n\n    // Acknowledge the sender\n    this.send(client.ws, { type: 'ack', version: newVersion });\n\n    // Broadcast to other clients on this document\n    const clients = this.documentClients.get(client.documentId);\n    if (clients) {\n      for (const other of clients) {\n        if (other.id !== client.id && other.ws.readyState === WebSocket.OPEN) {\n          this.send(other.ws, {\n            type: 'operation',\n            version: newVersion,\n            operation: transformedOp,\n            clientId: client.id,\n          });\n        }\n      }\n    }\n  }\n\n  private handleDisconnect(client: ClientConnection): void {\n    const clients = this.documentClients.get(client.documentId);\n    if (clients) {\n      clients.delete(client);\n      if (clients.size === 0) {\n        this.documentClients.delete(client.documentId);\n      }\n    }\n    this.store.removeConnection(client.id);\n  }\n\n  private send(ws: WebSocket, message: ServerMessage): void {\n    if (ws.readyState === WebSocket.OPEN) {\n      ws.send(JSON.stringify(message));\n    }\n  }\n\n  closeAll(): void {\n    for (const [, clients] of this.documentClients) {\n      for (const client of clients) {\n        client.ws.close();\n      }\n    }\n    this.documentClients.clear();\n    this.wss.close();\n  }\n}\n\nfunction isOperationMessage(msg: unknown): msg is ClientOperationMessage {\n  if (typeof msg !== 'object' || msg === null) return false;\n  const m = msg as Record<string, unknown>;\n  if (m.type !== 'operation') return false;\n  if (typeof m.version !== 'number') return false;\n  if (typeof m.operation !== 'object' || m.operation === null) return false;\n  const op = m.operation as Record<string, unknown>;\n  if (op.type === 'insert') {\n    return typeof op.position === 'number' && typeof op.text === 'string';\n  }\n  if (op.type === 'delete') {\n    return typeof op.position === 'number' && typeof op.count === 'number';\n  }\n  return false;\n}\n","numLines":250,"startLine":1,"totalLines":250}}}
