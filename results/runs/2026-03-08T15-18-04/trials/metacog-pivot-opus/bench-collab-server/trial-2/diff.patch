e a non-empty string';\n    }\n  } else if (op.type === 'delete') {\n    if (typeof op.position !== 'number' || op.position < 0) {\n      return 'Delete position must be a non-negative number';\n    }\n    if (typeof op.count !== 'number' || op.count < 0) {\n      return 'Delete count must be a non-negative number';\n    }\n    if (op.position + op.count > contentLength) {\n      return `Delete range [${op.position}, ${op.position + op.count}) exceeds document length ${contentLength}`;\n    }\n  } else {\n    return `Unknown operation type: ${(op as { type: string }).type}`;\n  }\n  return null;\n}\n","structuredPatch":[{"oldStart":1,"oldLines":16,"newStart":1,"newLines":13,"lines":[" /**","- * Operational Transformation engine.","+ * Operational Transformation engine for collaborative editing.","  *","- * Operations are either:","+ * Operations:","  *   - insert: { type: 'insert', position: number, text: string }","  *   - delete: { type: 'delete', position: number, count: number }","  *","- * The transform function takes two concurrent operations (a, b) that were both","- * based on the same document state, and returns [a', b'] such that:","- *   apply(apply(doc, a), b') === apply(apply(doc, b), a')","- *","- * The server uses this to transform incoming client ops against all ops that","- * have been applied since the client's base version.","+ * transform(a, b) returns a' such that:","+ *   apply(apply(doc, b), a') === apply(apply(doc, a), b')","+ * where b has already been applied to the document.","  */"," "," export interface InsertOp {"]},{"oldStart":39,"oldLines":131,"newStart":36,"newLines":9,"lines":[" }"," "," /**","- * Transform operation `op` against `applied` (which has already been applied).","- * Returns the transformed version of `op` that achieves the same intent","- * in the context where `applied` has already taken effect.","+ * Transform operation `a` against already-applied operation `b`.","+ * Returns a' that achieves a's intent in the context