l;\n        }\n\n        if (server) {\n          server.close((err) => {\n            if (err) {\n              reject(err);\n            } else {\n              db.close();\n              server = null;\n              resolve();\n            }\n          });\n        } else {\n          db.close();\n          resolve();\n        }\n      });\n    },\n  };\n\n  return instance;\n}\n\n// Allow running directly\nconst isMainModule = process.argv[1] &&\n  (process.argv[1].endsWith('/server.js') || process.argv[1].endsWith('/server.ts'));\n\nif (isMainModule) {\n  const app = createApp('./collab.db');\n  app.start(3000).then((port) => {\n    console.log(`Collaborative editor server running on port ${port}`);\n  });\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":335,"cache_read_input_tokens":33810,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":335},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"b2514a29-8a8d-48f5-a37f-313cae0de48f","uuid":"b767179a-0d9a-404c-8c13-cb41c6b4c02b"}
