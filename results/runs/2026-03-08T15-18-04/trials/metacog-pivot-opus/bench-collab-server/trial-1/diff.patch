(201);\n\n        const docId = createRes.body.id;\n\n        // Make an edit via WebSocket\n        const bws = await connectWs(port1, docId);\n        await waitForMessage(bws); // sync\n        sendOp(bws, { type: 'insert', position: 5, text: '!' }, 0);\n        await waitForMessage(bws); // ack\n        bws.ws.close();\n\n        // Wait for close to propagate\n        await new Promise((resolve) => setTimeout(resolve, 100));\n\n        // Stop first instance\n        await app1.stop();\n\n        // Start second instance with same DB\n        const app2 = createApp(dbPath);\n        await app2.start(0);\n\n        // Verify document persisted\n        const getRes = await request(app2.app)\n          .get(`/api/documents/${docId}`)\n          .expect(200);\n\n        expect(getRes.body.title).toBe('Persistent Doc');\n        expect(getRes.body.content).toBe('Saved!');\n\n        // Verify versions persisted\n        const versionsRes = await request(app2.app)\n          .get(`/api/documents/${docId}/versions`)\n          .expect(200);\n\n        expect(versionsRes.body.length).toBeGreaterThanOrEqual(2);\n\n        await app2.stop();\n      } finally {\n        // Cleanup\n        try {\n          fs.unlinkSync(dbPath);\n          fs.unlinkSync(dbPath + '-wal');\n          fs.unlinkSync(dbPath + '-shm');\n        } catch {\n          // ignore cleanup errors\n        }\n      }\n    });\n  });\n});\n","structuredPatch":[{"oldStart":409,"oldLines":23,"newStart":409,"newLines":21,"lines":["         clients.push(bws);","       }"," ","-      // Each client inserts a character","-      const ackPromises: Promise<Record<string, unknown>>[] = [];","+      // Each client inserts a character sequentially to avoid complex broadcast interleaving","       for (let i = 0; i < clientCount; i++) {","-        const insertPromise = waitForMessage(clients[i]);","         sendOp(clients[i], { type: 'insert', position: 0, text: String(i) }, 0);","-        ackPromises.push(insertPr