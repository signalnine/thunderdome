ufferedWebSocket, operation: Record<string, unknown>, version: number): void {\n  bws.ws.send(JSON.stringify({ type: 'operation', operation, version }));\n}"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":808,"cache_read_input_tokens":62358,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":808},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"b2514a29-8a8d-48f5-a37f-313cae0de48f","uuid":"0f35efb4-9340-43ff-91aa-e8c6b8012e2c"}
