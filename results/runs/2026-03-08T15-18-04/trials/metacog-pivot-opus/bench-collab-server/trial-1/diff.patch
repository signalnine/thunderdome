aitForMessage(bws); // sync"," ","-      ws.send('not json');","-      const err = await waitForMessage(ws);","+      bws.ws.send('not json');","+      const err = await waitForMessage(bws);","       expect(err.type).toBe('error');"," ","-      ws.close();","+      bws.ws.close();","     });"," ","     it('should reject unknown message type', async () => {","-      const ws = await connectWs(port, docId);","-      await waitForMessage(ws);","+      const bws = await connectWs(port, docId);","+      await waitForMessage(bws);"," ","-      ws.send(JSON.stringify({ type: 'unknown' }));","-      const err = await waitForMessage(ws);","+      bws.ws.send(JSON.stringify({ type: 'unknown' }));","+      const err = await waitForMessage(bws);","       expect(err.type).toBe('error');"," ","-      ws.close();","+      bws.ws.close();","     });"," ","     it('should reject operation with invalid position', async () => {","-      const ws = await connectWs(port, docId);","-      await waitForMessage(ws);","+      const bws = await connectWs(port, docId);","+      await waitForMessage(bws);"," ","-      sendOp(ws, { type: 'insert', position: 100, text: 'x' }, 0);","-      const err = await waitForMessage(ws);","+      sendOp(bws, { type: 'insert', position: 100, text: 'x' }, 0);","+      const err = await waitForMessage(bws);","       expect(err.type).toBe('error');"," ","-      ws.close();","+      bws.ws.close();","     });"," ","     it('should reject delete beyond document bounds', async () => {","-      const ws = await connectWs(port, docId);","-      await waitForMessage(ws);","+      const bws = await connectWs(port, docId);","+      await waitForMessage(bws);"," ","-      sendOp(ws, { type: 'delete', position: 0, length: 100 }, 0);","-      const err = await waitForMessage(ws);","+      sendOp(bws, { type: 'delete', position: 0, length: 100 }, 0);","+      const err = await waitForMessage(bws);","       expect(err.type).toBe('error');"," ","-      ws.close();","+      bws.ws.close();","     });"," ","     it('should reject operation with future version', async () => {","-      const ws = await connectWs(port, docId);","-      await waitForMessage(ws);","+      const bws = await connectWs(port, docId);","+      await waitForMessage(bws);"," ","-      sendOp(ws, { type: 'insert', position: 0, text: 'x' }, 999);","-      const err = await waitForMessage(ws);","+      sendOp(bws, { type: 'insert', position: 0, text: 'x' }, 999);","+      const err = await waitForMessage(bws);","       expect(err.type).toBe('error');"," ","-      ws.close();","+      bws.ws.close();","     });","   });"," "]},{"oldStart":406,"oldLines":13,"newStart":400,"newLines":13,"lines":[" ","     it('should handle 10 concurrent clients', async () => {","       const clientCount = 10;","-      const clients: WebSocket[] = [];","+      const clients: BufferedWebSocket[] = [];"," ","       // Connect all clients","       for (let i = 0; i < clientCount; i++) {","-        const ws = await connectWs(port, docId);","-        await waitForMessage(ws); // sync","-        clients.push(ws);","+        const bws = await connectWs(port, docId);","+        await waitForMessage(bws); // sync","+        clients.push(bws);","       }"," ","       // Each client inserts a character"]},{"oldStart":443,"oldLines":8,"newStart":437,"newLines":8,"lines":["       }"," ","       // Close all","-      for (const ws of clients) {","-        ws.close();","+      for (const bws of clients) {","+        bws.ws.close();","       }","     });","   });"]},{"oldStart":471,"oldLines":11,"newStart":465,"newLines":11,"lines":["         const docId = createRes.body.id;"," ","         // Make an edit via WebSocket","-        const ws = await connectWs(port1, docId);","-        await waitForMessage(ws); // sync","-        sendOp(ws, { type: 'insert', position: 5, text: '!' }, 0);","-        await waitForMessage(ws); // ack","-        ws.close();","+        const bws = await connectWs(port1, docId);","+        await waitForMessage(bws); // sync","+        sendOp(bws, { type: 'insert', position: 5, text: '!' }, 0);","+        await waitForMessage(bws); // ack","+        bws.ws.close();"," ","         // Wait for close to propagate","         await new Promise((resolve) => setTimeout(resolve, 100));"]}],"originalFile":"import { describe, it, expect, beforeAll, afterAll, beforeEach } from 'vitest';\nimport request from 'supertest';\nimport WebSocket from 'ws';\nimport { createApp, AppInstance } from '../src/server.js';\n\ninterface BufferedWebSocket {\n  ws: WebSocket;\n  messages: Record<string, unknown>[];\n  waiters: Array<(msg: Record<string, unknown>) => void>;\n}\n\nfunction connectWs(port: number, docId: string): Promise<BufferedWebSocket> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://127.0.0.1:${port}/ws/${docId}`);\n    const bws: BufferedWebSocket = { ws, messages: [], waiters: [] };\n\n    ws.on('message', (data) => {\n      const msg = JSON.parse(data.toString());\n      if (bws.waiters.length > 0) {\n        const waiter = bws.waiters.shift()!;\n        waiter(msg);\n      } else {\n        bws.messages.push(msg);\n      }\n    });\n\n    ws.on('open', () => resolve(bws));\n    ws.on('error', reject);\n  });\n}\n\nfunction waitForMessage(bws: BufferedWebSocket): Promise<Record<string, unknown>> {\n  if (bws.messages.length > 0) {\n    return Promise.resolve(bws.messages.shift()!);\n  }\n  return new Promise((resolve) => {\n    bws.waiters.push(resolve);\n  });\n}\n\nfunction sendOp(bws: BufferedWebSocket, operation: Record<string, unknown>, version: number): void {\n  bws.ws.send(JSON.stringify({ type: 'operation', operation, version }));\n}\n\ndescribe('WebSocket Collaboration', () => {\n  let app: AppInstance;\n  let port: number;\n\n  beforeAll(async () => {\n    app = createApp();\n    port = await app.start(0);\n  });\n\n  afterAll(async () => {\n    await app.stop();\n  });\n\n  describe('Connection Lifecycle', () => {\n    let docId: string;\n\n    beforeEach(async () => {\n      const res = await request(app.app)\n        .post('/api/documents')\n        .send({ title: 'WS Test', content: 'Hello' })\n        .expect(201);\n      docId = res.body.id;\n    });\n\n    it('should receive sync message on connect', async () => {\n      const ws = await connectWs(port, docId);\n      const msg = await waitForMessage(ws);\n\n      expect(msg.type).toBe('sync');\n      expect(msg.content).toBe('Hello');\n      expect(msg.version).toBe(0);\n\n      ws.close();\n    });\n\n    it('should reject connection for nonexistent document', async () => {\n      return new Promise<void>((resolve) => {\n        const ws = new WebSocket(`ws://127.0.0.1:${port}/ws/nonexistent`);\n        ws.on('message', (data) => {\n          const msg = JSON.parse(data.toString());\n          expect(msg.type).toBe('error');\n          ws.close();\n        });\n        ws.on('close', () => resolve());\n      });\n    });\n\n    it('should handle invalid path', async () => {\n      return new Promise<void>((resolve) => {\n        const ws = new WebSocket(`ws://127.0.0.1:${port}/invalid`);\n        ws.on('message', (data) => {\n          const msg = JSON.parse(data.toString());\n          expect(msg.type).toBe('error');\n          ws.close();\n        });\n        ws.on('close', () => resolve());\n      });\n    });\n\n    it('should allow multiple clients on same document', async () => {\n      const ws1 = await connectWs(port, docId);\n      const msg1 = await waitForMessage(ws1);\n      expect(msg1.type).toBe('sync');\n\n      const ws2 = await connectWs(port, docId);\n      const msg2 = await waitForMessage(ws2);\n      expect(msg2.type).toBe('sync');\n\n      ws1.close();\n      ws2.close();\n    });\n\n    it('should connect via alternative path /documents/:id/ws', async () => {\n      return new Promise<void>((resolve) => {\n        const ws = new WebSocket(`ws://127.0.0.1:${port}/documents/${docId}/ws`);\n        ws.on('message', (data) => {\n          const msg = JSON.parse(data.toString());\n          expect(msg.type).toBe('sync');\n          expect(msg.content).toBe('Hello');\n          ws.close();\n        });\n        ws.on('close', () => resolve());\n      });\n    });\n  });\n\n  describe('Single Client Editing', () => {\n    let docId: string;\n\n    beforeEach(async () => {\n      const res = await request(app.app)\n        .post('/api/documents')\n        .send({ title: 'Edit Test', content: 'Hello' })\n        .expect(201);\n      docId = res.body.id;\n    });\n\n    it('should apply an insert operation', async () => {\n      const ws = await connectWs(port, docId);\n      await waitForMessage(ws); // sync\n\n      sendOp(ws, { type: 'insert', position: 5, text: ' World' }, 0);\n      const ack = await waitForMessage(ws);\n\n      expect(ack.type).toBe('ack');\n      expect(ack.version).toBe(1);\n\n      // Verify via REST\n      const res = await request(app.app).get(`/api/documents/${docId}`);\n      expect(res.body.content).toBe('Hello World');\n\n      ws.close();\n    });\n\n    it('should apply a delete operation', async () => {\n      const ws = await connectWs(port, docId);\n      await waitForMessage(ws); // sync\n\n      sendOp(ws, { type: 'delete', position: 0, length: 5 }, 0);\n      const ack = await waitForMessage(ws);\n\n      expect(ack.type).toBe('ack');\n      expect(ack.version).toBe(1);\n\n      const res = await request(app.app).get(`/api/documents/${docId}`);\n      expect(res.body.content).toBe('');\n\n      ws.close();\n    });\n\n    it('should apply multiple sequential operations', async () => {\n      const ws = await connectWs(port, docId);\n      await waitForMessage(ws); // sync\n\n      // Insert \" World\" at position 5\n      sendOp(ws, { type: 'insert', position: 5, text: ' World' }, 0);\n      const ack1 = await waitForMessage(ws);\n      expect(ack1.version).toBe(1);\n\n      // Insert \"!\" at end\n      sendOp(ws, { type: 'insert', position: 11, text: '!' }, 1);\n      const ack2 = await waitForMessage(ws);\n      expect(ack2.version).toBe(2);\n\n      const res = await request(app.app).get(`/api/documents/${docId}`);\n      expect(res.body.content).toBe('Hello World!');\n\n      ws.close();\n    });\n\n    it('should persist operations as versions', async () => {\n      const ws = await connectWs(port, docId);\n      await waitForMessage(ws);\n\n      sendOp(ws, { type: 'insert', position: 5, text: ' World' }, 0);\n      await waitForMessage(ws);\n\n      const versions = await request(app.app).get(`/api/documents/${docId}/versions`);\n      expect(versions.body.length).toBeGreaterThanOrEqual(2); // version 0 + version 1\n\n      ws.close();\n    });\n  });\n\n  describe('Two-Client Convergence', () => {\n    let docId: string;\n\n    beforeEach(async () => {\n      const res = await request(app.app)\n        .post('/api/documents')\n        .send({ title: 'Collab Test', content: 'Hello' })\n        .expect(201);\n      docId = res.body.id;\n    });\n\n    it('should broadcast operations to other clients', async () => {\n      const ws1 = await connectWs(port, docId);\n      await waitForMessage(ws1); // sync\n\n      const ws2 = await connectWs(port, docId);\n      await waitForMessage(ws2); // sync\n\n      const broadcastPromise = waitForMessage(ws2);\n      sendOp(ws1, { type: 'insert', position: 5, text: ' World' }, 0);\n      await waitForMessage(ws1); // ack\n\n      const broadcast = await broadcastPromise;\n      expect(broadcast.type).toBe('operation');\n      expect(broadcast.version).toBe(1);\n\n      ws1.close();\n      ws2.close();\n    });\n\n    it('should transform concurrent inserts', async () => {\n      const ws1 = await connectWs(port, docId);\n      await waitForMessage(ws1);\n\n      const ws2 = await connectWs(port, docId);\n      await waitForMessage(ws2);\n\n      // Both clients insert at different positions, both based on version 0\n      // Client 1: insert \"A\" at position 0 (before \"Hello\")\n      // Client 2: insert \"B\" at position 5 (after \"Hello\")\n      sendOp(ws1, { type: 'insert', position: 0, text: 'A' }, 0);\n      const ack1 = await waitForMessage(ws1);\n      expect(ack1.type).toBe('ack');\n\n      // ws2 receives the broadcast\n      const broadcast1 = await waitForMessage(ws2);\n      expect(broadcast1.type).toBe('operation');\n\n      // Client 2 sends its op, based on version 0\n      sendOp(ws2, { type: 'insert', position: 5, text: 'B' }, 0);\n      const ack2 = await waitForMessage(ws2);\n      expect(ack2.type).toBe('ack');\n\n      // Verify the document converged\n      const res = await request(app.app).get(`/api/documents/${docId}`);\n      // \"AHelloB\" - A at position 0, B at the end (position shifted from 5 to 6)\n      expect(res.body.content).toBe('AHelloB');\n\n      ws1.close();\n      ws2.close();\n    });\n\n    it('should handle concurrent inserts at same position', async () => {\n      const ws1 = await connectWs(port, docId);\n      await waitForMessage(ws1);\n\n      const ws2 = await connectWs(port, docId);\n      await waitForMessage(ws2);\n\n      // Both insert at position 5, based on version 0\n      sendOp(ws1, { type: 'insert', position: 5, text: 'X' }, 0);\n      await waitForMessage(ws1); // ack\n\n      // ws2 gets broadcast\n      await waitForMessage(ws2);\n\n      sendOp(ws2, { type: 'insert', position: 5, text: 'Y' }, 0);\n      await waitForMessage(ws2); // ack\n\n      // Both inserts should be preserved\n      const res = await request(app.app).get(`/api/documents/${docId}`);\n      const content = res.body.content;\n      expect(content).toContain('X');\n      expect(content).toContain('Y');\n      expect(content).toContain('Hello');\n      expect(content.length).toBe(7); // \"Hello\" + \"X\" + \"Y\"\n\n      ws1.close();\n      ws2.close();\n    });\n\n    it('should handle insert and delete concurrently', async () => {\n      // Start with \"Hello\"\n      const ws1 = await connectWs(port, docId);\n      await waitForMessage(ws1);\n\n      const ws2 = await connectWs(port, docId);\n      await waitForMessage(ws2);\n\n      // Client 1: delete \"He\" (position 0, length 2) based on version 0\n      sendOp(ws1, { type: 'delete', position: 0, length: 2 }, 0);\n      await waitForMessage(ws1); // ack\n\n      // ws2 receives broadcast\n      await waitForMessage(ws2);\n\n      // Client 2: insert \"!\" at position 5 (end), based on version 0\n      sendOp(ws2, { type: 'insert', position: 5, text: '!' }, 0);\n      await waitForMessage(ws2); // ack\n\n      const res = await request(app.app).get(`/api/documents/${docId}`);\n      // After deleting \"He\" from \"Hello\" -> \"llo\"\n      // Insert \"!\" at end (position 5 transforms to 3) -> \"llo!\"\n      expect(res.body.content).toBe('llo!');\n\n      ws1.close();\n      ws2.close();\n    });\n  });\n\n  describe('Error Handling', () => {\n    let docId: string;\n\n    beforeEach(async () => {\n      const res = await request(app.app)\n        .post('/api/documents')\n        .send({ title: 'Error Test', content: 'Hello' })\n        .expect(201);\n      docId = res.body.id;\n    });\n\n    it('should reject invalid JSON', async () => {\n      const ws = await connectWs(port, docId);\n      await waitForMessage(ws); // sync\n\n      ws.send('not json');\n      const err = await waitForMessage(ws);\n      expect(err.type).toBe('error');\n\n      ws.close();\n    });\n\n    it('should reject unknown message type', async () => {\n      const ws = await connectWs(port, docId);\n      await waitForMessage(ws);\n\n      ws.send(JSON.stringify({ type: 'unknown' }));\n      const err = await waitForMessage(ws);\n      expect(err.type).toBe('error');\n\n      ws.close();\n    });\n\n    it('should reject operation with invalid position', async () => {\n      const ws = await connectWs(port, docId);\n      await waitForMessage(ws);\n\n      sendOp(ws, { type: 'insert', position: 100, text: 'x' }, 0);\n      const err = await waitForMessage(ws);\n      expect(err.type).toBe('error');\n\n      ws.close();\n    });\n\n    it('should reject delete beyond document bounds', async () => {\n      const ws = await connectWs(port, docId);\n      await waitForMessage(ws);\n\n      sendOp(ws, { type: 'delete', position: 0, length: 100 }, 0);\n      const err = await waitForMessage(ws);\n      expect(err.type).toBe('error');\n\n      ws.close();\n    });\n\n    it('should reject operation with future version', async () => {\n      const ws = await connectWs(port, docId);\n      await waitForMessage(ws);\n\n      sendOp(ws, { type: 'insert', position: 0, text: 'x' }, 999);\n      const err = await waitForMessage(ws);\n      expect(err.type).toBe('error');\n\n      ws.close();\n    });\n  });\n\n  describe('Stress Test', () => {\n    let docId: string;\n\n    beforeEach(async () => {\n      const res = await request(app.app)\n        .post('/api/documents')\n        .send({ title: 'Stress Test', content: '' })\n        .expect(201);\n      docId = res.body.id;\n    });\n\n    it('should handle 10 concurrent clients', async () => {\n      const clientCount = 10;\n      const clients: WebSocket[] = [];\n\n      // Connect all clients\n      for (let i = 0; i < clientCount; i++) {\n        const ws = await connectWs(port, docId);\n        await waitForMessage(ws); // sync\n        clients.push(ws);\n      }\n\n      // Each client inserts a character\n      const ackPromises: Promise<Record<string, unknown>>[] = [];\n      for (let i = 0; i < clientCount; i++) {\n        const insertPromise = waitForMessage(clients[i]);\n        sendOp(clients[i], { type: 'insert', position: 0, text: String(i) }, 0);\n        ackPromises.push(insertPromise);\n      }\n\n      // Wait for all acks\n      const acks = await Promise.all(ackPromises);\n      for (const ack of acks) {\n        expect(ack.type).toBe('ack');\n      }\n\n      // Drain any remaining broadcast messages with a small delay\n      await new Promise((resolve) => setTimeout(resolve, 200));\n\n      // Verify document has all characters\n      const res = await request(app.app).get(`/api/documents/${docId}`);\n      const content = res.body.content;\n      expect(content.length).toBe(clientCount);\n\n      // All digits 0-9 should appear exactly once\n      for (let i = 0; i < clientCount; i++) {\n        expect(content).toContain(String(i));\n      }\n\n      // Close all\n      for (const ws of clients) {\n        ws.close();\n      }\n    });\n  });\n\n  describe('Persistence', () => {\n    it('should persist data across restarts', async () => {\n      const fs = await import('fs');\n      const path = await import('path');\n      const os = await import('os');\n\n      const dbPath = path.join(os.tmpdir(), `collab-test-${Date.now()}.db`);\n\n      try {\n        // Start first instance\n        const app1 = createApp(dbPath);\n        const port1 = await app1.start(0);\n\n        // Create a document\n        const createRes = await request(app1.app)\n          .post('/api/documents')\n          .send({ title: 'Persistent Doc', content: 'Saved' })\n          .expect(201);\n\n        const docId = createRes.body.id;\n\n        // Make an edit via WebSocket\n        const ws = await connectWs(port1, docId);\n        await waitForMessage(ws); // sync\n        sendOp(ws, { type: 'insert', position: 5, text: '!' }, 0);\n        await waitForMessage(ws); // ack\n        ws.close();\n\n        // Wait for close to propagate\n        await new Promise((resolve) => setTimeout(resolve, 100));\n\n        // Stop first instance\n        await app1.stop();\n\n        // Start second instance with same DB\n        const app2 = createApp(dbPath);\n        await app2.start(0);\n\n        // Verify document persisted\n        const getRes = await request(app2.app)\n          .get(`/api/documents/${docId}`)\n          .expect(200);\n\n        expect(getRes.body.title).toBe('Persistent Doc');\n        expect(getRes.body.content).toBe('Saved!');\n\n        // Verify versions persisted\n        const versionsRes = await request(app2.app)\n          .get(`/api/documents/${docId}/versions`)\n          .expect(200);\n\n        expect(versionsRes.body.length).toBeGreaterThanOrEqual(2);\n\n        await app2.stop();\n      } finally {\n        // Cleanup\n        try {\n          fs.unlinkSync(dbPath);\n          fs.unlinkSync(dbPath + '-wal');\n          fs.unlinkSync(dbPath + '-shm');\n        } catch {\n          // ignore cleanup errors\n        }\n      }\n    });\n  });\n});\n"}}
