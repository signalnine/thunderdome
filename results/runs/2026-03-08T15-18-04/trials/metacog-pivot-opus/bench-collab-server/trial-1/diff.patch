+import { describe, it, expect } from 'vitest';
+import {
+  applyOperation,
+  transformOp,
+  transformThroughHistory,
+  validateOperation,
+  Operation,
+} from '../src/ot.js';
+
+describe('OT Engine', () => {
+  describe('applyOperation', () => {
+    it('should insert text at position', () => {
+      expect(applyOperation('Hello', { type: 'insert', position: 5, text: ' World' })).toBe('Hello World');
+      expect(applyOperation('Hello', { type: 'insert', position: 0, text: 'Say ' })).toBe('Say Hello');
+      expect(applyOperation('', { type: 'insert', position: 0, text: 'Hi' })).toBe('Hi');
+    });
+
+    it('should delete text at position', () => {
+      expect(applyOperation('Hello World', { type: 'delete', position: 5, length: 6 })).toBe('Hello');
+      expect(applyOperation('Hello', { type: 'delete', position: 0, length: 5 })).toBe('');
+    });
+  });
+
+  describe('validateOperation', () => {
+    it('should accept valid insert', () => {
+      expect(validateOperation({ type: 'insert', position: 0, text: 'x' }, 5)).toBeNull();
+      expect(validateOperation({ type: 'insert', position: 5, text: 'x' }, 5)).toBeNull();
+    });
+
+    it('should reject insert with invalid position', () => {
+      expect(validateOperation({ type: 'insert', position: -1, text: 'x' }, 5)).not.toBeNull();
+      expect(validateOperation({ type: 'insert', position: 6, text: 'x' }, 5)).not.toBeNull();
+    });
+
+    it('should reject insert with empty text', () => {
+      expect(validateOperation({ type: 'insert', position: 0, text: '' }, 5)).not.toBeNull();
+    });
+
+    it('should accept valid delete', () => {
+      expect(validateOperation({ type: 'delete', position: 0, length: 5 }, 5)).toBeNull();
+    });
+
+    it('should reject delete beyond bounds', () => {
+      expect(validateOperation({ type: 'delete', position: 0, length: 6 }, 5)).not.toBeNull();
+    });
+  });
+
+  describe('transformOp', () => {
+    it('should transform insert vs insert (before)', () => {
+      const op: Operation = { type: 'insert', position: 0, text: 'A' };
+      const other: Operation = { type: 'insert', position: 5, text: 'B' };
+      const result = transformOp(op, other);
+      expect(result).toEqual({ type: 'insert', position: 0, text: 'A' });
+    });
+
+    it('should transform insert vs insert (after)', () => {
+      const op: Operation = { type: 'insert', position: 5, text: 'A' };
+      const other: Operation = { type: 'insert', position: 0, text: 'B' };
+      const result = transformOp(op, other);
+      expect(result).toEqual({ type: 'insert', position: 6, text: 'A' });
+    });
+
+    it('should transform insert vs delete (before deleted range)', () => {
+      const op: Operation = { type: 'insert', position: 0, text: 'A' };
+      const other: Operation = { type: 'delete', position: 3, length: 2 };
+      const result = transformOp(op, other);
+      expect(result).toEqual({ type: 'insert', position: 0, text: 'A' });
+    });
+
+    it('should transform insert vs delete (after deleted range)', () => {
+      const op: Operation = { type: 'insert', position: 5, text: 'A' };
+      const other: Operation = { type: 'delete', position: 0, length: 2 };
+      const result = transformOp(op, other);
+      expect(result).toEqual({ type: 'insert', position: 3, text: 'A' });
+    });
+
+    it('should transform delete vs insert (before insert)', () => {
+      const op: Operation = { type: 'delete', position: 0, length: 2 };
+      const other: Operation = { type: 'insert', position: 5, text: 'B' };
+      const result = transformOp(op, other);
+      expect(result).toEqual({ type: 'delete', position: 0, length: 2 });
+    });
+
+    it('should transform delete vs insert (after insert)', () => {
+      const op: Operation = { type: 'delete', position: 5, length: 2 };
+      const other: Operation = { type: 'insert', position: 0, text: 'B' };
+      const result = transformOp(op, other);
+      expect(result).toEqual({ type: 'delete', position: 6, length: 2 });
+    });
+
+    it('should transform delete vs delete (no overlap)', () => {
+      const op: Operation = { type: 'delete', position: 0, length: 2 };
+      const other: Operation = { type: 'delete', position: 5, length: 2 };
+      const result = transformOp(op, other);
+      expect(result).toEqual({ type: 'delete', position: 0, length: 2 });
+    });
+
+    it('should transform delete vs delete (identical)', () => {
+      const op: Operation = { type: 'delete', position: 2, length: 3 };
+      const other: Operation = { type: 'delete', position: 2, length: 3 };
+      const result = transformOp(op, other);
+      expect(result).toBeNull(); // no-op
+    });
+  });
+
+  describe('transformThroughHistory', () => {
+    it('should transform through multiple operations', () => {
+      // Start: "Hello"
+      // History: insert "A" at 0 (version 1), insert "B" at 0 (version 2)
+      // Op: insert "!" at position 5 (based on original "Hello")
+      const history: Operation[] = [
+        { type: 'insert', position: 0, text: 'A' },
+        { type: 'insert', position: 0, text: 'B' },
+      ];
+      const op: Operation = { type: 'insert', position: 5, text: '!' };
+      const result = transformThroughHistory(op, history);
+      expect(result).toEqual({ type: 'insert', position: 7, text: '!' });
+    });
+  });
+});
