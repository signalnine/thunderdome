+/**
+ * Operational Transformation engine for collaborative text editing.
+ *
+ * Operations are either insertions or deletions at a position in the document.
+ * The server maintains a linear history of applied operations. When a client
+ * sends an operation based on an older version, the server transforms it
+ * forward through all intervening operations before applying.
+ */
+
+export interface InsertOp {
+  type: 'insert';
+  position: number;
+  text: string;
+}
+
+export interface DeleteOp {
+  type: 'delete';
+  position: number;
+  length: number;
+}
+
+export type Operation = InsertOp | DeleteOp;
+
+/**
+ * Validate that an operation is well-formed and can be applied to a document
+ * of the given length.
+ */
+export function validateOperation(op: Operation, docLength: number): string | null {
+  if (op.type === 'insert') {
+    if (typeof op.position !== 'number' || op.position < 0 || op.position > docLength) {
+      return `Invalid insert position ${op.position} for document of length ${docLength}`;
+    }
+    if (typeof op.text !== 'string' || op.text.length === 0) {
+      return 'Insert operation must have non-empty text';
+    }
+    return null;
+  } else if (op.type === 'delete') {
+    if (typeof op.position !== 'number' || op.position < 0) {
+      return `Invalid delete position ${op.position}`;
+    }
+    if (typeof op.length !== 'number' || op.length <= 0) {
+      return 'Delete operation must have positive length';
+    }
+    if (op.position + op.length > docLength) {
+      return `Delete range [${op.position}, ${op.position + op.length}) exceeds document length ${docLength}`;
+    }
+    return null;
+  }
+  return `Unknown operation type: ${(op as { type: string }).type}`;
+}
+
+/**
+ * Apply an operation to a document string, returning the new document.
+ */
+export function applyOperation(doc: string, op: Operation): string {
+  if (op.type === 'insert') {
+    return doc.slice(0, op.position) + op.text + doc.slice(op.position);
+  } else {
+    return doc.slice(0, op.position) + doc.slice(op.position + op.length);
+  }
+}
+
+/**
+ * Transform operation `op` against a concurrent operation `other` that has
+ * already been applied to the document.
+ *
+ * This implements the inclusion transformation (IT) function:
+ * If both `op` and `other` were intended against the same document state,
+ * and `other` has already been applied, `transformOp(op, other)` returns
+ * the transformed version of `op` that achieves the same intent on the
+ * document that now includes `other`.
+ *
+ * Returns the transformed operation, or null if the operation becomes a no-op.
+ */
+export function transformOp(op: Operation, other: Operation): Operation | null {
+  if (op.type === 'insert' && other.type === 'insert') {
+    return transformInsertInsert(op, other);
+  } else if (op.type === 'insert' && other.type === 'delete') {
+    return transformInsertDelete(op, other);
+  } else if (op.type === 'delete' && other.type === 'insert') {
+    return transformDeleteInsert(op, other);
+  } else {
+    return transformDeleteDelete(op as DeleteOp, other as DeleteOp);
+  }
+}
+
+function transformInsertInsert(op: InsertOp, other: InsertOp): InsertOp {
+  // If op's position is before or at other's position, it stays.
+  // If after, shift right by the length of other's inserted text.
+  if (op.position <= other.position) {
+    return { ...op };
+  } else {
+    return { ...op, position: op.position + other.text.length };
+  }
+}
+
+function transformInsertDelete(op: InsertOp, other: DeleteOp): InsertOp {
+  if (op.position <= other.position) {
+    // Insert is before the deletion — no change
+    return { ...op };
+  } else if (op.position >= other.position + other.length) {
+    // Insert is after the entire deletion — shift left
+    return { ...op, position: op.position - other.length };
+  } else {
+    // Insert is within the deleted region — place at deletion start
+    return { ...op, position: other.position };
+  }
+}
+
+function transformDeleteInsert(op: DeleteOp, other: InsertOp): DeleteOp {
+  if (op.position + op.length <= other.position) {
+    // Delete range is entirely before the insertion — no change
+    return { ...op };
+  } else if (op.position >= other.position) {
+    // Delete range starts at or after the insertion — shift right
+    return { ...op, position: op.position + other.text.length };
+  } else {
+    // The insertion falls within the delete range.
+    // The delete range needs to expand to account for the inserted text
+    // sitting inside it, but we must NOT delete the newly inserted text.
+    // Split: delete before the insertion + delete after the insertion.
+    // For simplicity in a server-authoritative model, we expand the length
+    // to skip over the inserted text.
+    return { ...op, length: op.length + other.text.length };
+  }
+}
+
+function transformDeleteDelete(op: DeleteOp, other: DeleteOp): DeleteOp | null {
+  // Case 1: op is entirely before other
+  if (op.position + op.length <= other.position) {
+    return { ...op };
+  }
+  // Case 2: op is entirely after other
+  if (op.position >= other.position + other.length) {
+    return { ...op, position: op.position - other.length };
+  }
+  // Case 3: overlapping deletes
+  const opEnd = op.position + op.length;
+  const otherEnd = other.position + other.length;
+
+  if (op.position >= other.position && opEnd <= otherEnd) {
+    // op is entirely within other — already deleted, no-op
+    return null;
+  }
+
+  if (op.position <= other.position && opEnd >= otherEnd) {
+    // other is entirely within op — shrink op by other's length
+    return { ...op, length: op.length - other.length };
+  }
+
+  if (op.position < other.position) {
+    // op starts before other but overlaps at the end
+    const newLength = other.position - op.position;
+    return { ...op, length: newLength };
+  }
+
+  // op starts inside other but extends past it
+  const newPosition = other.position;
+  const newLength = opEnd - otherEnd;
+  return { ...op, position: newPosition, length: newLength };
+}
+
+/**
+ * Transform an operation through a sequence of operations that have been
+ * applied since the operation's base version.
+ *
+ * This is the core of server-authoritative OT: when a client sends an
+ * operation based on version N, and the server is at version M > N,
+ * we transform the operation through operations N+1..M.
+ */
+export function transformThroughHistory(
+  op: Operation,
+  history: Operation[]
+): Operation | null {
+  let current: Operation | null = op;
+  for (const histOp of history) {
+    if (current === null) return null;
+    current = transformOp(current, histOp);
+  }
+  return current;
+}
