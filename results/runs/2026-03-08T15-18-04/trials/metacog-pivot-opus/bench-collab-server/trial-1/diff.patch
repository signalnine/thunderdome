+import { describe, it, expect, beforeAll, afterAll } from 'vitest';
+import request from 'supertest';
+import { createApp, AppInstance } from '../src/server.js';
+
+describe('REST API', () => {
+  let app: AppInstance;
+
+  beforeAll(async () => {
+    app = createApp();
+    await app.start(0);
+  });
+
+  afterAll(async () => {
+    await app.stop();
+  });
+
+  describe('Document CRUD', () => {
+    let docId: string;
+
+    it('should create a document', async () => {
+      const res = await request(app.app)
+        .post('/api/documents')
+        .send({ title: 'Test Doc', content: 'Hello World' })
+        .expect(201);
+
+      expect(res.body).toHaveProperty('id');
+      expect(res.body.title).toBe('Test Doc');
+      expect(res.body.content).toBe('Hello World');
+      docId = res.body.id;
+    });
+
+    it('should reject document creation without title', async () => {
+      await request(app.app)
+        .post('/api/documents')
+        .send({ content: 'no title' })
+        .expect(400);
+    });
+
+    it('should list documents', async () => {
+      const res = await request(app.app)
+        .get('/api/documents')
+        .expect(200);
+
+      expect(Array.isArray(res.body)).toBe(true);
+      expect(res.body.length).toBeGreaterThanOrEqual(1);
+    });
+
+    it('should get a specific document', async () => {
