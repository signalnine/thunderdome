+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const n = target.length;
+  const m = buttons.length;
+
+  if (n === 0) return m === 0 ? [] : null;
+
+  const targetHash = target.map(t => (t ? 1 : 0)).join('');
+
+  function toggle(state: string, buttonIndex: number): string {
+    const lights = buttons[buttonIndex];
+    return state.split('').map((bit, idx) =>
+      (parseInt(bit) ^ Number(lights.includes(idx) ? 1 : 0))
+    ).join('');
+  }
+
+  const queue: [state: string, buttonPresses: number[]][] = [[''.padEnd(n, '0'), []]];
+  const visited = new Set([''.padEnd(n, '0')]);
+
+  while (queue.length > 0) {
+    const [state, buttonPresses] = queue.shift()!;
+
+    if (state === targetHash) {
+      return buttonPresses;
+    }
+
+    for (let i = 0; i < m; i++) {
+      const newState = toggle(state, i);
+      if (!visited.has(newState)) {
+        visited.add(newState);
+        queue.push([newState, [...buttonPresses, i]]);
+      }
+    }
+  }
+
+  return null;
+}
+
+export interface CounterPuzzle {
+  lights: number[];
+  buttons: number[][];
+  modulus: number;
+}
+
+function solveCounter(puzzle: CounterPuzzle): number[] | null {
+  const { lights, buttons, modulus } = puzzle;
+  const n = lights.length;
+  const m = buttons.length;
+
+  if (n === 0) return m === 0 ? [] : null;
+  if (lights.every(lv => lv === 0)) return [];
+
+  const target = lights.join(',');
+
+  function combine(state: number[], buttonIdx: number): number[] {
+    const newState = [...state];
+    for (const light of buttons[buttonIdx]) {
+      newState[light] = (newState[light] + 1) % modulus;
+    }
+    return newState;
+  }
+
+  const LIMIT = 1000;
+  for (let maxPresses = 1; maxPresses <= LIMIT; maxPresses++) {
+    const queue: [state: number[], buttonPresses: number[]][] = [[Array(n).fill(0), []]];
+    const visited = new Set<string>();
+    const solutions: number[][] = [];
+
+    while (queue.length > 0) {
+      const [state, buttonPresses] = queue.shift()!;
+
+      if (buttonPresses.length >= maxPresses) continue;
+      if (state.join(',') === target) {
+        solutions.push(buttonPresses);
+      }
+
+      for (let i = 0; i < m; i++) {
+        const newState = combine(state, i);
+        const key = newState.toString();
+        if (!visited.has(key)) {
+          visited.add(key);
+          queue.push([newState, [...buttonPresses, i]]);
+        }
+      }
+    }
+
+    if (solutions.length > 0) {
+      solutions.sort((a, b) => {
+        if (a.length !== b.length) return a.length - b.length;
+        return a.toString().localeCompare(b.toString());
+      });
+      return solutions[0];
+    }
+  }
+
+  return null;
+}
+
+export function solveTogglePuzzle(machine: Machine): number[] | null {
+  return solveToggle(machine);
+}
+
+export function solveCounterPuzzle(puzzle: CounterPuzzle): number[] | null {
+  return solveCounter(puzzle);
+}
