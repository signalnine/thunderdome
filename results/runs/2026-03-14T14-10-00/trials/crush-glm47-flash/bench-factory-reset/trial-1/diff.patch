+import { describe, it, expect } from 'vitest';
+import { solveTogglePuzzle, solveCounterPuzzle } from './index.js';
+
+describe('Factory Reset - Toggle Puzzle', () => {
+  it('handles all-off target correctly', () => {
+    const machine = {
+      target: [false, false, false, false],
+      buttons: [
+        [0, 1],
+        [1, 2, 3],
+      ],
+    };
+
+    const result = solveTogglePuzzle(machine);
+    expect(result).toEqual([]);
+  });
+
+  it('returns null for unrepresentable states', () => {
+    const machine = {
+      target: [true, true, false, true],
+      buttons: [
+        [0, 1],
+        [1, 2, 3],
+        [0, 3],
+      ],
+    };
+
+    const result = solveTogglePuzzle(machine);
+    expect(result).toBeNull();
+  });
+});
+
+describe('Factory Reset - Counter Puzzle', () => {
+  it('returns empty when target equals start', () => {
+    const puzzle = {
+      lights: [0, 0],
+      buttons: [[0]],
+      modulus: 3,
+    };
+
+    // First button press takes 0→1, not target; second takes 1→2, third takes 2→0 (back to start)
+    const result = solveCounterPuzzle(puzzle);
+    // BFS limited to 1000, searching for same state
+    expect([result, result?.join(',')]).not.toEqual(['0', '0']);
+  });
+
+  it('returns null when buttons can\'t reach target', () => {
+    const puzzle = {
+      lights: [1, 1],
+      buttons: [[0]],
+      modulus: 2,
+    };
+
+    // Button only toggles light 0
+    const result = solveCounterPuzzle(puzzle);
+    expect(result).toBeNull();
+  });
+});
