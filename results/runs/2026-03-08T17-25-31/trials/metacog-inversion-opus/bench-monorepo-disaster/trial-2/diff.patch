+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HiJg6Y4JQPMxGWcXzHv856","type":"tool_result","content":"     1→/**\n     2→ * Authentication middleware using core permissions.\n     3→ */\n     4→\n     5→import type { Request, Response, NextFunction } from 'express';\n     6→import { hasPermission, type Role, type Permission } from '@monorepo/core';\n     7→\n     8→/**\n     9→ * Basic auth middleware that checks for a token header.\n    10→ * In this benchmark, we use a simplified mock auth system.\n    11→ */\n    12→export function authMiddleware(\n    13→  req: Request,\n    14→  res: Response,\n    15→  next: NextFunction\n    16→): void {\n    17→  const token = req.headers['authorization']?.replace('Bearer ', '');\n    18→\n    19→  // Allow requests with valid mock tokens or role headers\n    20→  if (token?.startsWith('mock-token-') || req.headers['x-user-role']) {\n    21→    next();\n    22→    return;\n    23→  }\n    24→\n    25→  res.status(401).json({ error: 'Authentication required' });\n    26→}\n    27→\n    28→/**\n    29→ * Middleware factory to require a specific permission.\n    30→ */\n    31→export function requirePermissionMiddleware(permission: Permission) {\n    32→  return (req: Request, res: Response, next: NextFunction): void => {\n    33→    const role = (req.headers['x-user-role'] as Role) || 'viewer';\n    34→\n    35→    if (!hasPermission(role, permission)) {\n    36→      res.status(403).json({\n    37→        error: `Permission '${permission}' required`,\n    38→      });\n    39→      return;\n    40→    }\n    41→\n    42→    next();\n    43→  };\n    44→}\n    45→"}]},"parent_tool_use_id":null,"session_id":"a9ddcaa8-10fa-40da-ba24-feafe4556aeb","uuid":"8c311a35-c596-4504-8ddc-3b508a79ce36","tool_use_result":{"type":"text","file":{"filePath":"/workspace/packages/api/src/middleware/auth.ts","content":"/**\n * Authentication middleware using core permissions.\n */\n\nimport type { Request, Response, NextFunction } from 'express';\nimport { hasPermission, type Role, type Permission } from '@monorepo/core';\n\n/**\n * Basic auth middleware that checks for a token header.\n * In this benchmark, we use a simplified mock auth system.\n */\nexport function authMiddleware(\n  req: Request,\n  res: Response,\n  next: NextFunction\n): void {\n  const token = req.headers['authorization']?.replace('Bearer ', '');\n\n  // Allow requests with valid mock tokens or role headers\n  if (token?.startsWith('mock-token-') || req.headers['x-user-role']) {\n    next();\n    return;\n  }\n\n  res.status(401).json({ error: 'Authentication required' });\n}\n\n/**\n * Middleware factory to require a specific permission.\n */\nexport function requirePermissionMiddleware(permission: Permission) {\n  return (req: Request, res: Response, next: NextFunction): void => {\n    const role = (req.headers['x-user-role'] as Role) || 'viewer';\n\n    if (!hasPermission(role, permission)) {\n      res.status(403).json({\n        error: `Permission '${permission}' required`,\n      });\n      return;\n    }\n\n    next();\n  };\n}\n","numLines":45,"startLine":1,"totalLines":45}}}
