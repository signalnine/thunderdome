+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RbW2xvJ8oG6zWrqin9ivHG","type":"tool_result","content":"     1→/**\n     2→ * Worker entry point.\n     3→ * Runs background jobs on a schedule.\n     4→ */\n     5→\n     6→import { Scheduler } from './scheduler.js';\n     7→import { syncJob } from './jobs/sync.js';\n     8→import { cleanupJob } from './jobs/cleanup.js';\n     9→\n    10→export function createWorker(): Scheduler {\n    11→  const scheduler = new Scheduler();\n    12→\n    13→  // Register jobs\n    14→  scheduler.register('sync', syncJob, 60_000); // Every 60 seconds\n    15→  scheduler.register('cleanup', async () => { await cleanupJob(); }, 300_000); // Every 5 minutes\n    16→\n    17→  return scheduler;\n    18→}\n    19→\n    20→// Start worker if run directly\n    21→const isMainModule = process.argv[1]?.includes('worker/dist/index.js');\n    22→if (isMainModule) {\n    23→  console.log('Starting worker...');\n    24→  const worker = createWorker();\n    25→  worker.start();\n    26→\n    27→  process.on('SIGINT', () => {\n    28→    console.log('Shutting down worker...');\n    29→    worker.stop();\n    30→    process.exit(0);\n    31→  });\n    32→}\n    33→"}]},"parent_tool_use_id":null,"session_id":"a9ddcaa8-10fa-40da-ba24-feafe4556aeb","uuid":"32aa80d3-5ed4-40ee-bd6d-65cbb4653817","tool_use_result":{"type":"text","file":{"filePath":"/workspace/packages/worker/src/index.ts","content":"/**\n * Worker entry point.\n * Runs background jobs on a schedule.\n */\n\nimport { Scheduler } from './scheduler.js';\nimport { syncJob } from './jobs/sync.js';\nimport { cleanupJob } from './jobs/cleanup.js';\n\nexport function createWorker(): Scheduler {\n  const scheduler = new Scheduler();\n\n  // Register jobs\n  scheduler.register('sync', syncJob, 60_000); // Every 60 seconds\n  scheduler.register('cleanup', async () => { await cleanupJob(); }, 300_000); // Every 5 minutes\n\n  return scheduler;\n}\n\n// Start worker if run directly\nconst isMainModule = process.argv[1]?.includes('worker/dist/index.js');\nif (isMainModule) {\n  console.log('Starting worker...');\n  const worker = createWorker();\n  worker.start();\n\n  process.on('SIGINT', () => {\n    console.log('Shutting down worker...');\n    worker.stop();\n    process.exit(0);\n  });\n}\n","numLines":33,"startLine":1,"totalLines":33}}}
