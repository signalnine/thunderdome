+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EboFA1VLYZqa2myrCtj9ca","type":"tool_result","content":"     1→/**\n     2→ * Simple job scheduler for background tasks.\n     3→ */\n     4→\n     5→export interface JobDefinition {\n     6→  name: string;\n     7→  handler: () => Promise<void> | void;\n     8→  intervalMs: number;\n     9→  timer?: ReturnType<typeof setInterval>;\n    10→  lastRun?: Date;\n    11→  runCount: number;\n    12→  errors: string[];\n    13→}\n    14→\n    15→export class Scheduler {\n    16→  private jobs: Map<string, JobDefinition> = new Map();\n    17→  private running = false;\n    18→\n    19→  register(\n    20→    name: string,\n    21→    handler: () => Promise<void> | void,\n    22→    intervalMs: number\n    23→  ): void {\n    24→    this.jobs.set(name, {\n    25→      name,\n    26→      handler,\n    27→      intervalMs,\n    28→      runCount: 0,\n    29→      errors: [],\n    30→    });\n    31→  }\n    32→\n    33→  start(): void {\n    34→    if (this.running) return;\n    35→    this.running = true;\n    36→\n    37→    for (const [, job] of this.jobs) {\n    38→      job.timer = setInterval(async () => {\n    39→        try {\n    40→          await job.handler();\n    41→          job.lastRun = new Date();\n    42→          job.runCount++;\n    43→        } catch (err) {\n    44→          job.errors.push(\n    45→            err instanceof Error ? err.message : String(err)\n    46→          );\n    47→        }\n    48→      }, job.intervalMs);\n    49→    }\n    50→  }\n    51→\n    52→  stop(): void {\n    53→    if (!this.running) return;\n    54→    this.running = false;\n    55→\n    56→    for (const [, job] of this.jobs) {\n    57→      if (job.timer) {\n    58→        clearInterval(job.timer);\n    59→        job.timer = undefined;\n    60→      }\n    61→    }\n    62→  }\n    63→\n    64→  async runOnce(name: string): Promise<void> {\n    65→    const job = this.jobs.get(name);\n    66→    if (!job) {\n    67→      throw new Error(`Job '${name}' not found`);\n    68→    }\n    69→\n    70→    await job.handler();\n    71→    job.lastRun = new Date();\n    72→    job.runCount++;\n    73→  }\n    74→\n    75→  getStatus(): Array<{\n    76→    name: string;\n    77→    lastRun: Date | undefined;\n    78→    runCount: number;\n    79→    errorCount: number;\n    80→  }> {\n    81→    return Array.from(this.jobs.values()).map((job) => ({\n    82→      name: job.name,\n    83→      lastRun: job.lastRun,\n    84→      runCount: job.runCount,\n    85→      errorCount: job.errors.length,\n    86→    }));\n    87→  }\n    88→\n    89→  isRunning(): boolean {\n    90→    return this.running;\n    91→  }\n    92→}\n    93→"}]},"parent_tool_use_id":null,"session_id":"a9ddcaa8-10fa-40da-ba24-feafe4556aeb","uuid":"118248db-3f49-499a-bd80-efa46cfcddc9","tool_use_result":{"type":"text","file":{"filePath":"/workspace/packages/worker/src/scheduler.ts","content":"/**\n * Simple job scheduler for background tasks.\n */\n\nexport interface JobDefinition {\n  name: string;\n  handler: () => Promise<void> | void;\n  intervalMs: number;\n  timer?: ReturnType<typeof setInterval>;\n  lastRun?: Date;\n  runCount: number;\n  errors: string[];\n}\n\nexport class Scheduler {\n  private jobs: Map<string, JobDefinition> = new Map();\n  private running = false;\n\n  register(\n    name: string,\n    handler: () => Promise<void> | void,\n    intervalMs: number\n  ): void {\n    this.jobs.set(name, {\n      name,\n      handler,\n      intervalMs,\n      runCount: 0,\n      errors: [],\n    });\n  }\n\n  start(): void {\n    if (this.running) return;\n    this.running = true;\n\n    for (const [, job] of this.jobs) {\n      job.timer = setInterval(async () => {\n        try {\n          await job.handler();\n          job.lastRun = new Date();\n          job.runCount++;\n        } catch (err) {\n          job.errors.push(\n            err instanceof Error ? err.message : String(err)\n          );\n        }\n      }, job.intervalMs);\n    }\n  }\n\n  stop(): void {\n    if (!this.running) return;\n    this.running = false;\n\n    for (const [, job] of this.jobs) {\n      if (job.timer) {\n        clearInterval(job.timer);\n        job.timer = undefined;\n      }\n    }\n  }\n\n  async runOnce(name: string): Promise<void> {\n    const job = this.jobs.get(name);\n    if (!job) {\n      throw new Error(`Job '${name}' not found`);\n    }\n\n    await job.handler();\n    job.lastRun = new Date();\n    job.runCount++;\n  }\n\n  getStatus(): Array<{\n    name: string;\n    lastRun: Date | undefined;\n    runCount: number;\n    errorCount: number;\n  }> {\n    return Array.from(this.jobs.values()).map((job) => ({\n      name: job.name,\n      lastRun: job.lastRun,\n      runCount: job.runCount,\n      errorCount: job.errors.length,\n    }));\n  }\n\n  isRunning(): boolean {\n    return this.running;\n  }\n}\n","numLines":93,"startLine":1,"totalLines":93}}}
