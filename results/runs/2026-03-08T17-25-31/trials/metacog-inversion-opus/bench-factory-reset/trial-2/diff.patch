+  it('handles 40x40 toggle puzzle with unique solution', () => {
+    // Identity: each button toggles exactly one unique light
+    const n = 40;
+    const buttons: number[][] = [];
+    for (let i = 0; i < n; i++) {
+      buttons.push([i]);
+    }
+    const target = new Array(n).fill(false);
+    // Set every other light to true
+    for (let i = 0; i < n; i += 2) target[i] = true;
+
+    const machine: Machine = { target, buttons };
+    const result = solveToggle(machine);
+    expect(result).not.toBeNull();
+    expect(verifyToggle(machine, result)).toBe(true);
+    // Should press buttons 0, 2, 4, ..., 38
+    const expected = [];
+    for (let i = 0; i < n; i += 2) expected.push(i);
+    expect(result).toEqual(expected);
+  });
+
+  it('handles target zero with empty buttons', () => {
+    const result = solveCounter([0], [], 5);
+    expect(result).toEqual([]);
+  });
+
+  it('handles 20x20 counter puzzle with mod 7', () => {
+    const n = 20;
+    const buttons: number[][] = [];
+    for (let i = 0; i < n; i++) {
+      buttons.push([i]);
+    }
+    const target = new Array(n).fill(0);
+    for (let i = 0; i < n; i++) target[i] = (i * 3) % 7;
+
+    const result = solveCounter(target, buttons, 7);
+    expect(result).not.toBeNull();
+    expect(verifyCounter(target, buttons, 7, result)).toBe(true);
+  });
+
+  it('handles 40x40 counter puzzle with unique solution mod 97', () => {
+    const n = 40;
+    const buttons: number[][] = [];
+    for (let i = 0; i < n; i++) {
+      buttons.push([i]);
+    }
+    const target = new Array(n).fill(0);
+    for (let i = 0; i < n; i++) target[i] = (i * 7 + 3) % 97;
+
+    const result = solveCounter(target, buttons, 97);
+    expect(result).not.toBeNull();
+    expect(verifyCounter(target, buttons, 97, result)).toBe(true);
+    // With identity-like buttons, result[i] should be target[i]
+    expect(result).toEqual(target);
+  });
+});
