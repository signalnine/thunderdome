\n    // Minimum total: 1 (e.g., [0, 0, 1] or [0, 1, 0] or [1, 0, 0])\n    // Lex smallest: [0, 0, 1]\n    const result = solveCounter([1], [[0], [0], [0]], 3);\n    expect(result).toEqual([0, 0, 1]);\n    expect(verifyCounter([1], [[0], [0], [0]], 3, result)).toBe(true);\n  });\n\n  it('handles target zero with empty buttons', () => {\n    const result = solveCounter([0], [], 5);\n    // No buttons, but target is 0. Since everything starts at 0, this should work.\n    // But wait - buttons is empty, so result should be empty array [].\n    // Actually result length = buttons.length = 0, so [].\n    // But solveCounter returns null for empty buttons and non-zero target.\n    // For zero target and no buttons... let me check.\n    expect(result).toEqual([]);\n  });\n});\n","structuredPatch":[{"oldStart":2,"oldLines":13,"newStart":2,"newLines":51,"lines":[" import { solveToggle, solveCounter } from '../src/index.js';"," import type { Machine } from '../src/index.js';"," ","+// Helper to verify a toggle solution","+function verifyToggle(machine: Machine, result: number[] | null): boolean {","+  if (result === null) return true; // null means no solution, can't verify","+  const lights = new Array(machine.target.length).fill(false);","+  for (const btnIdx of result) {","+    for (const lightIdx of machine.buttons[btnIdx]) {","+      lights[lightIdx] = !lights[lightIdx];","+    }","+  }","+  for (let i = 0; i < machine.target.length; i++) {","+    if (lights[i] !== machine.target[i]) return false;","+  }","+  return true;","+}","+","+// Helper to verify a counter solution","+function verifyCounter(","+  target: number[],","+  buttons: number[][],","+  modulus: number,","+  result: number[] | null","+): boolean {","+  if (result === null) return true;","+  const counters = new Array(target.length).fill(0);","+  for (let btnIdx = 0; btnIdx < result.length; btnIdx++) {","+    const presses = result[btnIdx];","+    for (const counterIdx of buttons[btnIdx]) {","+      counter