y buttons', () => {","originalFile":"import { describe, it, expect } from 'vitest';\nimport { solveToggle, solveCounter } from '../src/index.js';\nimport type { Machine } from '../src/index.js';\n\n// Helper to verify a toggle solution\nfunction verifyToggle(machine: Machine, result: number[] | null): boolean {\n  if (result === null) return true; // null means no solution, can't verify\n  const lights = new Array(machine.target.length).fill(false);\n  for (const btnIdx of result) {\n    for (const lightIdx of machine.buttons[btnIdx]) {\n      lights[lightIdx] = !lights[lightIdx];\n    }\n  }\n  for (let i = 0; i < machine.target.length; i++) {\n    if (lights[i] !== machine.target[i]) return false;\n  }\n  return true;\n}\n\n// Helper to verify a counter solution\nfunction verifyCounter(\n  target: number[],\n  buttons: number[][],\n  modulus: number,\n  result: number[] | null\n): boolean {\n  if (result === null) return true;\n  const counters = new Array(target.length).fill(0);\n  for (let btnIdx = 0; btnIdx < result.length; btnIdx++) {\n    const presses = result[btnIdx];\n    for (const counterIdx of buttons[btnIdx]) {\n      counters[counterIdx] = (counters[counterIdx] + presses) % modulus;\n    }\n  }\n  for (let i = 0; i < target.length; i++) {\n    if (counters[i] !== target[i]) return false;\n  }\n  return true;\n}\n\ndescribe('solveToggle', () => {\n  it('returns empty array when target is all off', () => {\n    const machine: Machine = {\n      target: [false, false, false],\n      buttons: [[0, 1], [1, 2]],\n    };\n    const result = solveToggle(machine);\n    expect(result).toEqual([]);\n    expect(verifyToggle(machine, result)).toBe(true);\n  });\n\n  it('returns null when no solution exists (example from spec)', () => {\n    const machine: Machine = {\n      target: [true, true, false, true],\n      buttons: [[0, 1], [1, 2, 3], [0, 3]],\n    };\n    expect(solveToggle(machine)).toBeNull();\n  });\n\n  it('solves a simple single-button case', () => 