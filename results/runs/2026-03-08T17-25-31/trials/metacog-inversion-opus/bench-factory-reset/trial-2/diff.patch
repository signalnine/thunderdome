+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+/**
+ * Solve toggle puzzle using Gaussian elimination over GF(2).
+ * Returns minimum-size, then lexicographically smallest set of button indices, or null.
+ */
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const numLights = target.length;
+  const numButtons = buttons.length;
+
+  // Build augmented matrix over GF(2): rows = lights, cols = buttons + 1
+  const matrix: number[][] = [];
+  for (let i = 0; i < numLights; i++) {
+    const row = new Array(numButtons + 1).fill(0);
+    row[numButtons] = target[i] ? 1 : 0;
+    matrix.push(row);
+  }
+
+  for (let j = 0; j < numButtons; j++) {
+    for (const lightIdx of buttons[j]) {
+      if (lightIdx < numLights) {
+        matrix[lightIdx][j] ^= 1;
+      }
+    }
+  }
+
+  // Gaussian elimination over GF(2), full row reduction (RREF)
+  const pivotCol: number[] = [];
+  const pivotRow: number[] = new Array(numButtons).fill(-1);
+  let currentRow = 0;
+
+  for (let col = 0; col < numButtons && currentRow < numLights; col++) {
+    let pivotR = -1;
+    for (let r = currentRow; r < numLights; r++) {
+      if (matrix[r][col] === 1) {
+        pivotR = r;
+        break;
+      }
+    }
+    if (pivotR === -1) continue;
+
+    [matrix[currentRow], matrix[pivotR]] = [matrix[pivotR], matrix[currentRow]];
+    pivotCol.push(col);
+    pivotRow[col] = currentRow;
+
+    for (let r = 0; r < numLights; r++) {
+      if (r !== currentRow && matrix[r][col] === 1) {
+        for (let c = 0; c <= numButtons; c++) {
+          matrix[r][c] ^= matrix[currentRow][c];
+        }
+      }
+    }
+    currentRow++;
+  }
+
+  const rank = currentRow;
+
+  // Check consistency
+  for (let r = rank; r < numLights; r++) {
+    if (matrix[r][numButtons] === 1) {
+      return null;
+    }
+  }
+
+  // Get particular solution (free vars = 0)
+  const particular = new Array(numButtons).fill(0);
+  for (let r = 0; r < rank; r++) {
+    particular[pivotCol[r]] = matrix[r][numButtons];
+  }
+
+  // Identify free variables
+  const freeVars: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (pivotRow[col] === -1) {
+      freeVars.push(col);
+    }
+  }
+
+  const numFree = freeVars.length;
+
+  if (numFree === 0) {
+    const result: number[] = [];
+    for (let i = 0; i < numButtons; i++) {
+      if (particular[i] === 1) result.push(i);
+    }
+    return result;
+  }
+
+  // Build null space vectors
+  const nullVecs: number[][] = [];
+  for (const fv of freeVars) {
+    const vec = new Array(numButtons).fill(0);
+    vec[fv] = 1;
+    for (let r = 0; r < rank; r++) {
+      if (matrix[r][fv] === 1) {
+        vec[pivotCol[r]] = 1;
+      }
+    }
+    nullVecs.push(vec);
+  }
+
+  // For small null spaces, enumerate using Gray code
+  if (numFree <= 22) {
+    return grayCodeEnumToggle(particular, nullVecs, numFree, numButtons);
+  }
+
+  // For larger null spaces, use greedy approach
+  return greedyToggle(particular, nullVecs, numButtons);
+}
+
+function greedyToggle(
+  particular: number[],
+  nullVecs: number[][],
+  numButtons: number
+): number[] {
+  let bestSol = [...particular];
+  let bestWeight = bestSol.reduce((a, b) => a + b, 0);
+  let improved = true;
+  while (improved) {
+    improved = false;
+    for (const nv of nullVecs) {
+      const candidate = bestSol.map((v, i) => v ^ nv[i]);
+      const candWeight = candidate.reduce((a, b) => a + b, 0);
+      if (candWeight < bestWeight) {
+        bestSol = candidate;
+        bestWeight = candWeight;
+        improved = true;
+      }
+    }
+  }
+
+  const result: number[] = [];
+  for (let i = 0; i < numButtons; i++) {
+    if (bestSol[i] === 1) result.push(i);
+  }
+  return result;
+}
+
+/**
+ * Enumerate all null space combinations using Gray code order.
+ * Gray code means only 1 null vector is XORed per step, making each step O(numButtons).
+ */
+function grayCodeEnumToggle(
+  particular: number[],
+  nullVecs: number[][],
+  numFree: number,
+  numButtons: number
+): number[] {
+  const solution = [...particular];
+  let weight = 0;
+  for (let i = 0; i < numButtons; i++) {
+    if (solution[i] === 1) weight++;
+  }
+
+  let bestResult = extractPressed(solution, numButtons);
+  let bestCount = weight;
+
+  const totalCombinations = 1 << numFree;
+
+  for (let gray = 1; gray < totalCombinations; gray++) {
+    // In Gray code, exactly one bit changes per step
+    const grayCode = gray ^ (gray >> 1);
+    const prevGray = (gray - 1) ^ ((gray - 1) >> 1);
+    const diff = grayCode ^ prevGray;
+    const bitIdx = Math.log2(diff) | 0;
+
+    // XOR the null vector for this bit
+    const nv = nullVecs[bitIdx];
+    for (let i = 0; i < numButtons; i++) {
+      if (nv[i] === 1) {
+        if (solution[i] === 1) {
+          weight--;
+        } else {
+          weight++;
+        }
+        solution[i] ^= 1;
+      }
+    }
+
+    if (weight < bestCount) {
+      bestCount = weight;
+      bestResult = extractPressed(solution, numButtons);
+    } else if (weight === bestCount) {
+      const pressed = extractPressed(solution, numButtons);
+      if (lexSmaller(pressed, bestResult)) {
+        bestResult = pressed;
+      }
+    }
+  }
+
+  return bestResult;
+}
+
+function extractPressed(solution: number[], numButtons: number): number[] {
+  const pressed: number[] = [];
+  for (let i = 0; i < numButtons; i++) {
+    if (solution[i] === 1) pressed.push(i);
+  }
+  return pressed;
+}
+
+function lexSmaller(a: number[], b: number[]): boolean {
+  const len = Math.min(a.length, b.length);
+  for (let i = 0; i < len; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return a.length < b.length;
+}
+
+/**
+ * Solve counter puzzle using Gaussian elimination over GF(p).
+ * Returns array of press counts minimizing total presses, then lex-smallest, or null.
+ */
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numCounters = lights.length;
+  const numButtons = buttons.length;
+
+  // Build augmented matrix over GF(p)
+  const matrix: number[][] = [];
+  for (let i = 0; i < numCounters; i++) {
+    const row = new Array(numButtons + 1).fill(0);
+    row[numButtons] = ((lights[i] % modulus) + modulus) % modulus;
+    matrix.push(row);
+  }
+
+  for (let j = 0; j < numButtons; j++) {
+    for (const counterIdx of buttons[j]) {
+      if (counterIdx < numCounters) {
+        matrix[counterIdx][j] = (matrix[counterIdx][j] + 1) % modulus;
+      }
+    }
+  }
+
+  // Gaussian elimination over GF(p)
+  const pivotCol: number[] = [];
+  const pivotRow: number[] = new Array(numButtons).fill(-1);
+  let currentRow = 0;
+
+  for (let col = 0; col < numButtons && currentRow < numCounters; col++) {
+    let pivotR = -1;
+    for (let r = currentRow; r < numCounters; r++) {
+      if (matrix[r][col] !== 0) {
+        pivotR = r;
+        break;
+      }
+    }
+    if (pivotR === -1) continue;
+
+    [matrix[currentRow], matrix[pivotR]] = [matrix[pivotR], matrix[currentRow]];
+    pivotCol.push(col);
+    pivotRow[col] = currentRow;
+
+    const inv = modInverse(matrix[currentRow][col], modulus);
+    for (let c = 0; c <= numButtons; c++) {
+      matrix[currentRow][c] = (matrix[currentRow][c] * inv) % modulus;
+    }
+
+    for (let r = 0; r < numCounters; r++) {
+      if (r !== currentRow && matrix[r][col] !== 0) {
+        const factor = matrix[r][col];
+        for (let c = 0; c <= numButtons; c++) {
+          matrix[r][c] = ((matrix[r][c] - factor * matrix[currentRow][c]) % modulus + modulus) % modulus;
+        }
+      }
+    }
+    currentRow++;
+  }
+
+  const rank = currentRow;
+
+  // Check consistency
+  for (let r = rank; r < numCounters; r++) {
+    if (matrix[r][numButtons] !== 0) {
+      return null;
+    }
+  }
+
+  // Get particular solution
+  const particular = new Array(numButtons).fill(0);
+  for (let r = 0; r < rank; r++) {
+    particular[pivotCol[r]] = matrix[r][numButtons];
+  }
+
+  // Identify free variables
+  const freeVars: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (pivotRow[col] === -1) {
+      freeVars.push(col);
+    }
+  }
+
+  const numFree = freeVars.length;
+
+  if (numFree === 0) {
+    return particular;
+  }
+
+  // Build null space vectors
+  const nullVecs: number[][] = [];
+  for (const fv of freeVars) {
+    const vec = new Array(numButtons).fill(0);
+    vec[fv] = 1;
+    for (let r = 0; r < rank; r++) {
+      if (matrix[r][fv] !== 0) {
+        vec[pivotCol[r]] = (modulus - matrix[r][fv]) % modulus;
+      }
+    }
+    nullVecs.push(vec);
+  }
+
+  // Compute max enumerable combinations
+  let totalCombinations = 1;
+  let canEnumerate = true;
+  for (let i = 0; i < numFree; i++) {
+    totalCombinations *= modulus;
+    if (totalCombinations > 5_000_000) {
+      canEnumerate = false;
+      break;
+    }
+  }
+
+  if (canEnumerate) {
+    return enumerateCounter(particular, nullVecs, numFree, numButtons, modulus, totalCombinations);
+  }
+
+  return greedyCounter(particular, nullVecs, numButtons, modulus);
+}
+
+function enumerateCounter(
+  particular: number[],
+  nullVecs: number[][],
+  numFree: number,
+  numButtons: number,
+  modulus: number,
+  totalCombinations: number
+): number[] {
+  let bestResult: number[] | null = null;
+  let bestTotal = Infinity;
+
+  for (let combo = 0; combo < totalCombinations; combo++) {
+    const solution = [...particular];
+    let temp = combo;
+    for (let f = 0; f < numFree; f++) {
+      const mult = temp % modulus;
+      temp = Math.floor(temp / modulus);
+      if (mult !== 0) {
+        for (let i = 0; i < numButtons; i++) {
+          solution[i] = ((solution[i] + mult * nullVecs[f][i]) % modulus + modulus) % modulus;
+        }
+      }
+    }
+
+    const total = solution.reduce((a, b) => a + b, 0);
+
+    if (total < bestTotal || (total === bestTotal && lexSmallerArr(solution, bestResult!))) {
+      bestTotal = total;
+      bestResult = [...solution];
+    }
+  }
+
+  return bestResult!;
+}
+
+function greedyCounter(
+  particular: number[],
+  nullVecs: number[][],
+  numButtons: number,
+  modulus: number
+): number[] {
+  let bestSol = [...particular];
+  let improved = true;
+  while (improved) {
+    improved = false;
+    for (const nv of nullVecs) {
+      const origSol = [...bestSol];
+      let bestTotal = bestSol.reduce((a, b) => a + b, 0);
+
+      for (let mult = 1; mult < modulus; mult++) {
+        const candidate = new Array(numButtons);
+        let total = 0;
+        for (let i = 0; i < numButtons; i++) {
+          candidate[i] = ((origSol[i] + mult * nv[i]) % modulus + modulus) % modulus;
+          total += candidate[i];
+        }
+        if (total < bestTotal || (total === bestTotal && lexSmallerArr(candidate, bestSol))) {
+          bestTotal = total;
+          bestSol = candidate;
+          improved = true;
+        }
+      }
+    }
+  }
+
+  return bestSol;
+}
+
+function lexSmallerArr(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return false;
+}
+
+function modInverse(a: number, m: number): number {
+  a = ((a % m) + m) % m;
+  let [old_r, r] = [a, m];
+  let [old_s, s] = [1, 0];
+
+  while (r !== 0) {
+    const q = Math.floor(old_r / r);
+    [old_r, r] = [r, old_r - q * r];
+    [old_s, s] = [s, old_s - q * s];
+  }
+
+  return ((old_s % m) + m) % m;
+}
