\n    };\n    const result = solveToggle(machine);\n    expect(result).toEqual([1]);\n    expect(verifyToggle(machine, result)).toBe(true);\n  });\n\n  it('handles all target false with no buttons', () => {\n    const machine: Machine = {\n      target: [false, false],\n      buttons: [],\n    };\n    const result = solveToggle(machine);\n    expect(result).toEqual([]);\n  });\n\n  it('handles duplicate indices in button (double toggle = no toggle)', () => {\n    // Button 0 toggles light 0 twice → no effect\n    const machine: Machine = {\n      target: [true],\n      buttons: [[0, 0]],\n    };\n    // Button 0 toggles light 0 twice = no effect. Can't reach target.\n    expect(solveToggle(machine)).toBeNull();\n  });\n\n  it('handles larger system with unique solution', () => {\n    // Identity-like: each button toggles exactly one unique light\n    const machine: Machine = {\n      target: [true, false, true, true, false],\n      buttons: [[0], [1], [2], [3], [4]],\n    };\n    const result = solveToggle(machine);\n    expect(result).toEqual([0, 2, 3]);\n    expect(verifyToggle(machine, result)).toBe(true);\n  });\n\n  it('handles many free variables', () => {\n    // 1 light, 10 buttons all toggling light 0\n    // Any odd-sized subset works; minimum is 1 button\n    const machine: Machine = {\n      target: [true],\n      buttons: Array.from({ length: 10 }, () => [0]),\n    };\n    const result = solveToggle(machine);\n    expect(result).toEqual([0]); // lex smallest single button\n    expect(verifyToggle(machine, result)).toBe(true);\n  });\n});\n\ndescribe('solveCounter', () => {\n  it('returns all zeros when target is all zero', () => {\n    const result = solveCounter([0, 0, 0], [[0, 1], [1, 2]], 5);\n    expect(result).toEqual([0, 0]);\n  });\n\n  it('solves a simple single-button case', () => {\n    const result = solveCounter([3], [[0]], 5);\n    expect(result).toEqual([3]);\n    expect(verifyCounter([3], [[0]], 5, result)).toBe(true);\n  });\n\n  it('solves with two independent buttons', () => {\n    const result = solveCounter([2, 3], [[0], [1]], 5);\n    expect(result).toEqual([2, 3]);\n    expect(verifyCounter([2, 3], [[0], [1]], 5, result)).toBe(true);\n  });\n\n  it('returns null when no solution exists', () => {\n    const result = solveCounter([1, 2], [[0, 1]], 3);\n    expect(result).toBeNull();\n  });\n\n  it('handles modular arithmetic correctly', () => {\n    const result = solveCounter([0], [[0]], 5);\n    expect(result).toEqual([0]);\n  });\n\n  it('minimizes total presses', () => {\n    // Two buttons both affect counter 0. Target = 1 mod 5.\n    // Solution [0, 1] or [1, 0] - lex smallest with total 1 is [0, 1]\n    const result = solveCounter([1], [[0], [0]], 5);\n    expect(result).toEqual([0, 1]);\n    expect(verifyCounter([1], [[0], [0]], 5, result)).toBe(true);\n  });\n\n  it('handles wrapping with minimization', () => {\n    const result = solveCounter([4], [[0]], 5);\n    expect(result).toEqual([4]);\n    expect(verifyCounter([4], [[0]], 5, result)).toBe(true);\n  });\n\n  it('solves with overlapping buttons', () => {\n    const result = solveCounter([1, 2], [[0, 1], [1]], 3);\n    expect(result).toEqual([1, 1]);\n    expect(verifyCounter([1, 2], [[0, 1], [1]], 3, result)).toBe(true);\n  });\n\n  it('handles empty buttons', () => {\n    const result = solveCounter([1], [], 5);\n    expect(result).toBeNull();\n  });\n\n  it('handles prime modulus correctly', () => {\n    const result = solveCounter([6], [[0]], 7);\n    expect(result).toEqual([6]);\n    expect(verifyCounter([6], [[0]], 7, result)).toBe(true);\n  });\n\n  it('handles all zero target with buttons', () => {\n    const result = solveCounter([0, 0], [[0, 1], [0]], 3);\n    expect(result).toEqual([0, 0]);\n  });\n\n  it('handles larger modulus (97)', () => {\n    const result = solveCounter([50], [[0]], 97);\n    expect(result).toEqual([50]);\n    expect(verifyCounter([50], [[0]], 97, result)).toBe(true);\n  });\n\n  it('solves system requiring modular inverse', () => {\n    // Counter 0: 2*b0 ≡ 1 (mod 5)  → b0 = 3 (since 2*3 = 6 ≡ 1 mod 5)\n    // Button 0 affects counter 0 twice (appears twice in list)\n    const result = solveCounter([1], [[0, 0]], 5);\n    expect(result).toEqual([3]);\n    expect(verifyCounter([1], [[0, 0]], 5, result)).toBe(true);\n  });\n\n  it('handles free variables with counter minimization', () => {\n    // 1 counter, 3 buttons all affecting counter 0, mod 3\n    // b0 + b1 + b2 ≡ 1 (mod 3)\n    // Minimum total: 1 (e.g., [0, 0, 1] or [0, 1, 0] or [1, 0, 0])\n    // Lex smallest: [0, 0, 1]\n    const result = solveCounter([1], [[0], [0], [0]], 3);\n    expect(result).toEqual([0, 0, 1]);\n    expect(verifyCounter([1], [[0], [0], [0]], 3, result)).toBe(true);\n  });\n\n  it('handles medium-sized toggle puzzle (20 lights, 20 buttons)', () => {\n    // Create a solvable system: identity-like with some overlap\n    const numLights = 20;\n    const numButtons = 20;\n    const buttons: number[][] = [];\n    for (let i = 0; i < numButtons; i++) {\n      const btn: number[] = [i % numLights];\n      if (i + 1 < numLights) btn.push((i + 1) % numLights);\n      buttons.push(btn);\n    }\n    const target = new Array(numLights).fill(false);\n    target[0] = true;\n    target[5] = true;\n    target[10] = true;\n\n    const machine: Machine = { target, buttons };\n    const result = solveToggle(machine);\n    if (result !== null) {\n      expect(verifyToggle(machine, result)).toBe(true);\n    }\n  });\n\n  it('handles 40x40 toggle puzzle with unique solution', () => {\n    // Identity: each button toggles exactly one unique light\n    const n = 40;\n    const buttons: number[][] = [];\n    for (let i = 0; i < n; i++) {\n      buttons.push([i]);\n    }\n    const target = new Array(n).fill(false);\n    // Set every other light to true\n    for (let i = 0; i < n; i += 2) target[i] = true;\n\n    const machine: Machine = { target, buttons };\n    const result = solveToggle(machine);\n    expect(result).not.toBeNull();\n    expect(verifyToggle(machine, result)).toBe(true);\n    // Should press buttons 0, 2, 4, ..., 38\n    const expected = [];\n    for (let i = 0; i < n; i += 2) expected.push(i);\n    expect(result).toEqual(expected);\n  });\n\n  it('handles target zero with empty buttons', () => {\n    const result = solveCounter([0], [], 5);\n    // No buttons, but target is 0. Since everything starts at 0, this should work.\n    // But wait - buttons is empty, so result should be empty array [].\n    // Actually result length = buttons.length = 0, so [].\n    // But solveCounter returns null for empty buttons and non-zero target.\n    // For zero target and no buttons... let me check.\n    expect(result).toEqual([]);\n  });\n});\n","structuredPatch":[{"oldStart":310,"oldLines":11,"newStart":310,"newLines":36,"lines":[" ","   it('handles target zero with empty buttons', () => {","     const result = solveCounter([0], [], 5);","-    // No buttons, but target is 0. Since everything starts at 0, this should work.","-    // But wait - buttons is empty, so result should be empty array [].","-    // Actually result length = buttons.length = 0, so [].","-    // But solveCounter returns null for empty buttons and non-zero target.","-    // For zero target and no buttons... let me check.","     expect(result).toEqual([]);","   });","+","+  it('handles 20x20 counter puzzle with mod 7', () => {","+    const n = 20;","+    const buttons: number[][] = [];","+    for (let i = 0; i < n; i++) {","+      buttons.push([i]);","+    }","+    const target = new Array(n).fill(0);","+    for (let i = 0; i < n; i++) target[i] = (i * 3) % 7;","+","+    const result = solveCounter(target, buttons, 7);","+    expect(result).not.toBeNull();","+    expect(verifyCounter(target, buttons, 7, result)).toBe(true);","+  });","+","+  it('handles 40x40 counter puzzle with unique solution mod 97', () => {","+    const n = 40;","+    const buttons: number[][] = [];","+    for (let i 