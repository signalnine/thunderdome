 = {\n      target: [true, true],\n      buttons: [[0], [1]],\n    };\n    expect(solveToggle(machine)).toEqual([0, 1]);\n  });\n\n  it('prefers fewer button presses', () => {\n    // Light 0 can be toggled by button 0 alone, or by buttons 1 and 2 together\n    const machine: Machine = {\n      target: [true, false],\n      buttons: [[0], [0, 1], [1]],\n    };\n    // Button 0 alone sets light 0 to on. That's 1 press.\n    // Buttons 1 and 2: light 0 toggled by 1, light 1 toggled by 1 and 2 (cancel), result: [on, off]. 2 presses.\n    // So answer is [0]\n    expect(solveToggle(machine)).toEqual([0]);\n  });\n\n  it('returns lexicographically smallest on tie', () => {\n    // Two lights, three buttons\n    // Button 0: toggles light 0\n    // Button 1: toggles light 0\n    // Button 2: toggles light 1\n    const machine: Machine = {\n      target: [true, true],\n      buttons: [[0], [0], [1]],\n    };\n    // Solutions with 2 presses: [0, 2] or [1, 2]\n    // Lex smallest: [0, 2]\n    expect(solveToggle(machine)).toEqual([0, 2]);\n  });\n\n  it('handles no buttons needed', () => {\n    const machine: Machine = {\n      target: [false],\n      buttons: [[0]],\n    };\n    expect(solveToggle(machine)).toEqual([]);\n  });\n\n  it('handles empty buttons', () => {\n    const machine: Machine = {\n      target: [true],\n      buttons: [],\n    };\n    expect(solveToggle(machine)).toBeNull();\n  });\n\n  it('handles overlapping buttons', () => {\n    // 3 lights, 3 buttons\n    // Button 0: [0, 1]\n    // Button 1: [1, 2]\n    // Button 2: [0, 2]\n    // Target: [true, false, true]\n    // Press all three: light 0 toggled by 0,2 → 0. light 1 by 0,1 → 0. light 2 by 1,2 → 0. No.\n    // Press 1 and 2: light 0 by 2 → 1. light 1 by 1 → 1. light 2 by 1,2 → 0. [T, T, F] - no\n    // Press 0: [T, T, F, F] - not right dimensions\n    // Let me recalculate:\n    // b0 XOR b2 = 1 (light 0)\n    // b0 XOR b1 = 0 (light 1)\n    // b1 XOR b2 = 1 (light 2)\n    // From eq2: b0 = b1. From eq1: b1 XOR b2 = 1. From eq3: b1 XOR b2 = 1. Consistent.\n    // b0=0, b1=0, b2=1 → light0: 0 XOR 1 = 1 ✓, light1: 0 XOR 0 = 0 ✓, light2: 0 XOR 1 = 1 ✓\n    // b0=1, b1=1, b2=0 → light0: 1 XOR 0 = 1 ✓, light1: 1 XOR 1 = 0 ✓, light2: 1 XOR 0 = 1 ✓\n    // Min presses: [2] with 1 press\n    const machine: Machine = {\n      target: [true, false, true],\n      buttons: [[0, 1], [1, 2], [0, 2]],\n    };\n    expect(solveToggle(machine)).toEqual([2]);\n  });\n});\n\ndescribe('solveCounter', () => {\n  it('returns all zeros when target is all zero', () => {\n    const result = solveCounter([0, 0, 0], [[0, 1], [1, 2]], 5);\n    expect(result).toEqual([0, 0]);\n  });\n\n  it('solves a simple single-button case', () => {\n    const result = solveCounter([3], [[0]], 5);\n    expect(result).toEqual([3]);\n  });\n\n  it('solves with two independent buttons', () => {\n    const result = solveCounter([2, 3], [[0], [1]], 5);\n    expect(result).toEqual([2, 3]);\n  });\n\n  it('returns null when no solution exists', () => {\n    // Two counters, one button that affects both\n    // Target: [1, 2] mod 3\n    // Button 0 affects both counters equally, so they must match. No solution.\n    const result = solveCounter([1, 2], [[0, 1]], 3);\n    expect(result).toBeNull();\n  });\n\n  it('handles modular arithmetic correctly', () => {\n    // One counter, one button\n    // Target: 0, button toggles counter 0, modulus 5\n    // Press 0 times: 0. ✓\n    const result = solveCounter([0], [[0]], 5);\n    expect(result).toEqual([0]);\n  });\n\n  it('minimizes total presses', () => {\n    // Counter 0 target: 1, mod 5\n    // Button 0 affects counter 0\n    // Button 1 affects counter 0\n    // Press button 0 once: counter 0 = 1. Total: 1\n    // Press button 1 once: counter 0 = 1. Total: 1\n    // Both give total 1, so lex smallest is [1, 0] vs [0, 1] → [0, 1]\n    const result = solveCounter([1], [[0], [0]], 5);\n    expect(result).toEqual([0, 1]);\n  });\n\n  it('handles wrapping with minimization', () => {\n    // Counter 0 target: 4, mod 5\n    // Button 0 affects counter 0\n    // Press 4 times: total = 4. But also: since 4 ≡ -1 mod 5, no shortcut with single button.\n    const result = solveCounter([4], [[0]], 5);\n    expect(result).toEqual([4]);\n  });\n\n  it('solves with overlapping buttons', () => {\n    // 2 counters, 2 buttons, mod 3\n    // Button 0: affects counter 0 and 1\n    // Button 1: affects counter 1\n    // Target: [1, 2]\n    // b0 = 1 (from counter 0)\n    // b0 + b1 ≡ 2 (mod 3) → b1 = 1\n    const result = solveCounter([1, 2], [[0, 1], [1]], 3);\n    expect(result).toEqual([1, 1]);\n  });\n\n  it('handles empty buttons', () => {\n    const result = solveCounter([1], [], 5);\n    expect(result).toBeNull();\n  });\n\n  it('handles prime modulus correctly', () => {\n    // mod 7\n    const result = solveCounter([6], [[0]], 7);\n    expect(result).toEqual([6]);\n  });\n});\n"}}
