ct(result).toEqual([3]);\n  });\n\n  it('solves with two independent buttons', () => {\n    const result = solveCounter([2, 3], [[0], [1]], 5);\n    expect(result).toEqual([2, 3]);\n  });\n\n  it('returns null when no solution exists', () => {\n    // Two counters, one button that affects both\n    // Target: [1, 2] mod 3\n    // Button 0 affects both counters equally, so they must match. No solution.\n    const result = solveCounter([1, 2], [[0, 1]], 3);\n    expect(result).toBeNull();\n  });\n\n  it('handles modular arithmetic correctly', () => {\n    // One counter, one button\n    // Target: 0, button toggles counter 0, modulus 5\n    // Press 0 times: 0. ✓\n    const result = solveCounter([0], [[0]], 5);\n    expect(result).toEqual([0]);\n  });\n\n  it('minimizes total presses', () => {\n    // Counter 0 target: 1, mod 5\n    // Button 0 affects counter 0\n    // Button 1 affects counter 0\n    // Press button 0 once: counter 0 = 1. Total: 1\n    // Press button 1 once: counter 0 = 1. Total: 1\n    // Both give total 1, so lex smallest is [1, 0] vs [0, 1] → [0, 1]\n    const result = solveCounter([1], [[0], [0]], 5);\n    expect(result).toEqual([0, 1]);\n  });\n\n  it('handles wrapping with minimization', () => {\n    // Counter 0 target: 4, mod 5\n    // Button 0 affects counter 0\n    // Press 4 times: total = 4. But also: since 4 ≡ -1 mod 5, no shortcut with single button.\n    const result = solveCounter([4], [[0]], 5);\n    expect(result).toEqual([4]);\n  });\n\n  it('solves with overlapping buttons', () => {\n    // 2 counters, 2 buttons, mod 3\n    // Button 0: affects counter 0 and 1\n    // Button 1: affects counter 1\n    // Target: [1, 2]\n    // b0 = 1 (from counter 0)\n    // b0 + b1 ≡ 2 (mod 3) → b1 = 1\n    const result = solveCounter([1, 2], [[0, 1], [1]], 3);\n    expect(result).toEqual([1, 1]);\n  });\n\n  it('handles empty buttons', () => {\n    const result = solveCounter([1], [], 5);\n    expect(result).toBeNull();\n  });\n\n  it('handles p