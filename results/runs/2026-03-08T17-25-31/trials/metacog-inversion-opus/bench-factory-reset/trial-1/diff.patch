+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter } from './index.js';
+
+// ─── Helper: verify a toggle solution is correct ─────────────────────────────
+
+function verifyToggle(target: boolean[], buttons: number[][], pressed: number[]): boolean {
+  const state = new Array(target.length).fill(false);
+  for (const b of pressed) {
+    for (const l of buttons[b]) {
+      state[l] = !state[l];
+    }
+  }
+  return state.every((v, i) => v === target[i]);
+}
+
+// ─── Helper: verify a counter solution is correct ────────────────────────────
+
+function verifyCounter(target: number[], buttons: number[][], modulus: number, presses: number[]): boolean {
+  const state = new Array(target.length).fill(0);
+  for (let b = 0; b < presses.length; b++) {
+    for (const l of buttons[b]) {
+      state[l] = (state[l] + presses[b]) % modulus;
+    }
+  }
+  return state.every((v, i) => v === target[i]);
+}
+
+describe('solveToggle', () => {
+  it('returns null when no solution exists (example from spec)', () => {
+    const machine = {
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('solves a simple case with one button', () => {
+    const machine = {
+      target: [true, false],
+      buttons: [[0]],
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('solves with multiple buttons', () => {
+    const machine = {
+      target: [true, true],
+      buttons: [[0], [1]],
+    };
+    expect(solveToggle(machine)).toEqual([0, 1]);
+  });
+
+  it('returns empty array when target is all false', () => {
+    const machine = {
+      target: [false, false, false],
+      buttons: [[0, 1], [1, 2]],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('picks minimum presses', () => {
+    const machine = {
+      target: [true, true],
+      buttons: [[0, 1], [0], [1]],
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('picks lexicographically smallest on tie', () => {
+    const machine = {
+      target: [true, true],
+      buttons: [[0], [1], [0], [1]],
+    };
+    expect(solveToggle(machine)).toEqual([0, 1]);
+  });
+
+  it('handles overlapping buttons', () => {
+    const machine = {
+      target: [true, false, true],
+      buttons: [[0, 1, 2], [1]],
+    };
+    expect(solveToggle(machine)).toEqual([0, 1]);
+  });
+
+  it('handles no buttons available', () => {
+    const machine = {
+      target: [true],
+      buttons: [],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('handles no buttons needed (all false target)', () => {
+    const machine = {
+      target: [false],
+      buttons: [[0]],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('handles single light single button', () => {
+    const machine = {
+      target: [true],
+      buttons: [[0]],
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('handles identity-like system', () => {
+    // Each button toggles exactly one distinct light
+    const machine = {
+      target: [true, true, true, true, true],
+      buttons: [[0], [1], [2], [3], [4]],
+    };
+    expect(solveToggle(machine)).toEqual([0, 1, 2, 3, 4]);
+  });
+
+  it('handles cancellation (pressing same effect twice cancels)', () => {
+    // Two buttons toggle the same light — pressing both cancels
+    const machine = {
+      target: [false],
+      buttons: [[0], [0]],
+    };
+    // Solutions: press neither (0 presses) or press both (2 presses)
+    // Minimum: 0 presses
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('handles larger puzzle correctly', () => {
+    // 6 lights, 6 buttons
+    const machine = {
+      target: [true, false, true, false, true, false],
+      buttons: [
+        [0, 2, 4],    // toggles lights 0,2,4
+        [1, 3, 5],    // toggles lights 1,3,5
+        [0, 1],       // toggles lights 0,1
+        [2, 3],       // toggles lights 2,3
+        [4, 5],       // toggles lights 4,5
+        [0, 1, 2, 3, 4, 5], // toggles all
+      ],
+    };
+    const result = solveToggle(machine);
+    expect(result).not.toBeNull();
+    expect(verifyToggle(machine.target, machine.buttons, result!)).toBe(true);
+  });
+
+  it('handles 20 lights and 20 buttons within time', () => {
+    const n = 20;
+    const target = Array.from({ length: n }, (_, i) => i % 2 === 0);
+    const buttons: number[][] = [];
+    for (let i = 0; i < n; i++) {
+      const affected: number[] = [i];
+      if (i + 1 < n) affected.push(i + 1);
+      buttons.push(affected);
+    }
+    const machine = { target, buttons };
+    const result = solveToggle(machine);
+    if (result !== null) {
+      expect(verifyToggle(target, buttons, result)).toBe(true);
+    }
+  });
+});
+
+describe('solveCounter', () => {
+  it('solves a simple counter puzzle', () => {
+    expect(solveCounter([1, 1], [[0], [1]], 2)).toEqual([1, 1]);
+  });
+
+  it('returns null when no solution exists', () => {
+    expect(solveCounter([1], [], 2)).toBeNull();
+  });
+
+  it('handles modular arithmetic', () => {
+    expect(solveCounter([0], [[0]], 3)).toEqual([0]);
+  });
+
+  it('handles mod 3 counter', () => {
+    expect(solveCounter([2], [[0]], 3)).toEqual([2]);
+  });
+
+  it('handles multiple counters mod 5', () => {
+    expect(solveCounter([3, 4], [[0, 1], [1]], 5)).toEqual([3, 1]);
+  });
+
+  it('picks minimum total presses', () => {
+    expect(solveCounter([0], [[0]], 5)).toEqual([0]);
+  });
+
+  it('handles impossible counter puzzle', () => {
+    // 2 counters, target [1, 2], mod 3
+    // Button 0: affects [0, 1] — both counters get same increment
+    // Need counter0=1, counter1=2, but only one button affects both identically
+    // b0 = 1 (for counter 0), but b0 = 2 (for counter 1) — contradiction
+    expect(solveCounter([1, 2], [[0, 1]], 3)).toBeNull();
+  });
+
+  it('handles larger mod correctly', () => {
+    // mod 7, 3 counters, 3 buttons
+    // Button 0: [0], Button 1: [1], Button 2: [2]
+    // Target: [5, 3, 6]
+    expect(solveCounter([5, 3, 6], [[0], [1], [2]], 7)).toEqual([5, 3, 6]);
+  });
+
+  it('minimizes total presses with multiple solutions mod 5', () => {
+    // 1 counter, target [0], mod 5
+    // Button 0: affects [0]
+    // Button 1: affects [0]
+    // b0 + b1 = 0 mod 5
+    // Solutions: (0,0), (1,4), (2,3), (3,2), (4,1) — sums: 0, 5, 5, 5, 5
+    // Minimum: (0,0) with sum 0
+    expect(solveCounter([0], [[0], [0]], 5)).toEqual([0, 0]);
+  });
+
+  it('picks lex smallest on tie for counter', () => {
+    // 1 counter, target [3], mod 5
+    // Button 0: affects [0], Button 1: affects [0]
+    // b0 + b1 = 3 mod 5
+    // Solutions: (0,3), (1,2), (2,1), (3,0), (4,4)
+    // Sums: 3, 3, 3, 3, 8
+    // Min sum = 3, lex smallest: (0,3)
+    expect(solveCounter([3], [[0], [0]], 5)).toEqual([0, 3]);
+  });
+
+  it('handles 10 counters mod 7', () => {
+    const n = 10;
+    const target = Array.from({ length: n }, (_, i) => (i * 3 + 2) % 7);
+    const buttons: number[][] = [];
+    for (let i = 0; i < n; i++) {
+      buttons.push([i]); // each button affects exactly one counter
+    }
+    const result = solveCounter(target, buttons, 7);
+    expect(result).not.toBeNull();
+    expect(verifyCounter(target, buttons, 7, result!)).toBe(true);
+  });
+
+  it('handles mod 97 puzzle', () => {
+    // 3 counters, 3 buttons, mod 97
+    const target = [42, 17, 88];
+    const buttons = [[0], [1], [2]];
+    const result = solveCounter(target, buttons, 97);
+    expect(result).toEqual([42, 17, 88]);
+    expect(verifyCounter(target, buttons, 97, result!)).toBe(true);
+  });
+});
