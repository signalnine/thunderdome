e = a;\n  let exp = p - 2;\n  while (exp > 0) {\n    if (exp & 1) result = (result * base) % p;\n    base = (base * base) % p;\n    exp >>= 1;\n  }\n  return result;\n}\n\n/** Safe modular operation */\nfunction mod(a: number, p: number): number {\n  return ((a % p) + p) % p;\n}\n\n// ─── Core Solver over GF(p) ────────────────────────────────────────────────\n\n/**\n * Solves the system A * x = b over GF(p), finding the solution with minimum\n * sum of values, breaking ties lexicographically.\n *\n * A is the coefficient matrix (numLights × numButtons): A[light][button] = 1 if\n * button affects light, 0 otherwise.\n * b is the target vector.\n * p is the field modulus.\n *\n * Returns the solution vector x (length = numButtons), or null if no solution.\n */\nfunction solveLinearSystemModP(\n  numLights: number,\n  numButtons: number,\n  buttons: number[][],  // buttons[buttonIdx] = array of light indices affected\n  target: number[],     // target[lightIdx] = desired value\n  p: number\n): number[] | null {\n  // Build augmented matrix [A^T | b] where columns are buttons and rows are lights\n  // Actually we need A * x = b where A[i][j] = coefficient of button j in equation for light i\n  // Augmented matrix: each row = [A[i][0], A[i][1], ..., A[i][numButtons-1], b[i]]\n  const numRows = numLights;\n  const numCols = numButtons;\n\n  // Build the augmented matrix\n  const matrix: number[][] = [];\n  for (let i = 0; i < numRows; i++) {\n    const row = new Array(numCols + 1).fill(0);\n    row[numCols] = mod(target[i], p);\n    matrix.push(row);\n  }\n\n  // Fill in the coefficients: button j affects light i => A[i][j] = 1\n  for (let j = 0; j < numButtons; j++) {\n    for (const lightIdx of buttons[j]) {\n      if (lightIdx < numLights) {\n        matrix[lightIdx][j] = mod(matrix[lightIdx][j] + 1, p);\n      }\n    }\n  }\n\n  // Gaussian elimination with partial pivoting to get RREF\n  const pivotCol: number[] = []; // pivotCol[k] = column index of k-th pivot\n  const pivotRow: number[] = new Array(numCols).fill(-1); // pivotRow[col] = row of pivot in that col, or -1\n  let currentRow = 0;\n\n  for (let col = 0; col < numCols && currentRow < numRows; col++) {\n    // Find pivot in this column\n    let pivotR = -1;\n    for (let r = currentRow; r < numRows; r++) {\n      if (matrix[r][col] !== 0) {\n        pivotR = r;\n        break;\n      }\n    }\n    if (pivotR === -1) continue; // No pivot in this column — free variable\n\n    // Swap rows\n    [matrix[currentRow], matrix[pivotR]] = [matrix[pivotR], matrix[currentRow]];\n\n    // Scale pivot row so pivot element = 1\n    const inv = modInverse(matrix[currentRow][col], p);\n    for (let c = col; c <= numCols; c++) {\n      matrix[currentRow][c] = mod(matrix[currentRow][c] * inv, p);\n    }\n\n    // Eliminate all other entries in this column\n    for (let r = 0; r < numRows; r++) {\n      if (r === currentRow) continue;\n      const factor = matrix[r][col];\n      if (factor === 0) continue;\n      for (let c = col; c <= numCols; c++) {\n        matrix[r][c] = mod(matrix[r][c] - factor * matrix[currentRow][c], p);\n      }\n    }\n\n    pivotCol.push(col);\n    pivotRow[col] = currentRow;\n    currentRow++;\n  }\n\n  const rank = pivotCol.length;\n\n  // Check consistency: any row with all-zero coefficients but nonzero RHS => no solution\n  for (let r = rank; r < numRows; r++) {\n    if (matrix[r][numCols] !== 0) {\n      return null;\n    }\n  }\n\n  // Identify free variables (columns that aren't pivots)\n  const isPivot = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let col = 0; col < numCols; col++) {\n    if (!isPivot.has(col)) {\n      freeVars.push(col);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  // If no free variables, unique solution\n  if (numFree === 0) {\n    const solution = new Array(numCols).fill(0);\n    for (let k = 0; k < rank; k++) {\n      solution[pivotCol[k]] = matrix[k][numCols];\n    }\n    return solution;\n  }\n\n  // With free variables, we need to search the null space for the optimal solution.\n  // The particular solution comes from setting all free variables to 0.\n  // Then for each free variable assignment, the pivot variables are determined.\n  //\n  // For each free variable combination f = (f_0, f_1, ..., f_{numFree-1}):\n  //   pivot variable at pivotCol[k] = matrix[k][numCols] - sum(matrix[k][freeVars[j]] * f[j])\n  //\n  // We want to minimize total presses (sum of all values), then lex smallest.\n\n  // For small null spaces (numFree * log(p) manageable), enumerate all.\n  // For larger ones, we need a smarter approach.\n\n  // Precompute the null space structure:\n  // nullBasis[j][k] = -matrix[pivotRow_for_pivotCol[k]][freeVars[j]]  (mod p)\n  // i.e., the effect of free variable j on pivot variable k\n\n  // Particular solution (free vars = 0)\n  const particular = new Array(numCols).fill(0);\n  for (let k = 0; k < rank; k++) {\n    particular[pivotCol[k]] = matrix[k][numCols];\n  }\n\n  // Null space basis: nullBasis[j] is the null space vector for free variable j\n  // nullBasis[j][freeVars[j]] = 1, nullBasis[j][other free vars] = 0,\n  // nullBasis[j][pivotCol[k]] = -matrix[k][freeVars[j]] mod p\n  const nullBasis: number[][] = [];\n  for (let j = 0; j < numFree; j++) {\n    const vec = new Array(numCols).fill(0);\n    vec[freeVars[j]] = 1;\n    for (let k = 0; k < rank; k++) {\n      vec[pivotCol[k]] = mod(-matrix[k][freeVars[j]], p);\n    }\n    nullBasis.push(vec);\n  }\n\n  // Now we need to find coefficients c_0, c_1, ..., c_{numFree-1} in [0, p-1]\n  // that minimize the total sum, then lex order, of:\n  //   solution[i] = (particular[i] + sum_j(c_j * nullBasis[j][i])) mod p\n\n  // Total search space is p^numFree. With p up to 97 and numFree potentially up to ~40,\n  // this could be huge. However, in practice with well-constrained systems, numFree is small.\n  // We'll handle it with enumeration if feasible, otherwise use a greedy/heuristic approach.\n\n  const totalCombinations = Math.pow(p, numFree);\n\n  if (numFree <= getMaxFreeVarsForSearch(p)) {\n    // Enumerate all combinations\n    let bestSolution: number[] | null = null;\n    let bestSum = Infinity;\n\n    const coeffs = new Array(numFree).fill(0);\n\n    for (let iter = 0; iter < totalCombinations; iter++) {\n      // Compute solution for current coefficients\n      const sol = new Array(numCols).fill(0);\n      for (let i = 0; i < numCols; i++) {\n        let val = particular[i];\n        for (let j = 0; j < numFree; j++) {\n          val += coeffs[j] * nullBasis[j][i];\n        }\n        sol[i] = mod(val, p);\n      }\n\n      const sum = sol.reduce((a, b) => a + b, 0);\n\n      if (sum < bestSum || (sum === bestSum && lexSmaller(sol, bestSolution!))) {\n        bestSum = sum;\n        bestSolution = sol;\n      }\n\n      // Increment coefficients (odometer)\n      incrementCoeffs(coeffs, p);\n    }\n\n    return bestSolution;\n  }\n\n  // For large search spaces, try each free variable value independently\n  // This is a greedy approach that may not find the global optimum in all cases\n  // but should work for well-structured problems\n  return greedyNullSpaceSearch(particular, nullBasis, freeVars, pivotCol, numCols, p, rank, matrix);\n}\n\n/** Determine max free variables we can enumerate based on modulus */\nfunction getMaxFreeVarsForSearch(p: number): number {\n  // We want p^k to be manageable within a few seconds\n  // p=2: 2^25 ≈ 33M — feasible\n  // p=3: 3^16 ≈ 43M — feasible\n  // p=5: 5^11 ≈ 48M — feasible\n  // p=7: 7^9 ≈ 40M — feasible\n  // p=97: 97^4 ≈ 88M — borderline\n  // Be conservative to stay within 5 second limit:\n  if (p === 2) return 22;\n  if (p === 3) return 14;\n  if (p <= 5) return 10;\n  if (p <= 7) return 8;\n  if (p <= 13) return 7;\n  if (p <= 23) return 6;\n  if (p <= 47) return 5;\n  if (p <= 97) return 4;\n  return 3;\n}\n\n/** Increment coefficients like an odometer */\nfunction incrementCoeffs(coeffs: number[], p: number): void {\n  for (let i = coeffs.length - 1; i >= 0; i--) {\n    coeffs[i]++;\n    if (coeffs[i] < p) return;\n    coeffs[i] = 0;\n  }\n}\n\n/** Compare two arrays lexicographically. Returns true if a < b. */\nfunction lexSmaller(a: number[], b: number[]): boolean {\n  for (let i = 0; i < a.length; i++) {\n    if (a[i] < b[i]) return true;\n    if (a[i] > b[i]) return false;\n  }\n  return false;\n}\n\n/**\n * Greedy approach for large null spaces: for each free variable, try all p values\n * and pick the one that minimizes a cost heuristic.\n */\nfunction greedyNullSpaceSearch(\n  particular: number[],\n  nullBasis: number[][],\n  freeVars: number[],\n  _pivotCol: number[],\n  numCols: number,\n  p: number,\n  _rank: number,\n  _matrix: number[][]\n): number[] {\n  const numFree = freeVars.length;\n  const coeffs = new Array(numFree).fill(0);\n\n  // Try to minimize total sum. For each free variable independently,\n  // find the value that minimizes the partial contribution.\n  // We iterate multiple rounds to converge.\n  for (let round = 0; round < 10; round++) {\n    let improved = false;\n    for (let j = 0; j < numFree; j++) {\n      let bestVal = coeffs[j];\n      let bestSum = Infinity;\n      let bestSol: number[] | null = null;\n\n      for (let v = 0; v < p; v++) {\n        coeffs[j] = v;\n        const sol = computeSolution(particular, nullBasis, coeffs, numCols, p);\n        const sum = sol.reduce((a, b) => a + b, 0);\n        if (sum < bestSum || (sum === bestSum && bestSol !== null && lexSmaller(sol, bestSol))) {\n          bestSum = sum;\n          bestVal = v;\n          bestSol = sol;\n        }\n      }\n\n      if (bestVal !== coeffs[j]) improved = true;\n      coeffs[j] = bestVal;\n    }\n    if (!improved) break;\n  }\n\n  return computeSolution(particular, nullBasis, coeffs, numCols, p);\n}\n\nfunction computeSolution(\n  particular: number[],\n  nullBasis: number[][],\n  coeffs: number[],\n  numCols: number,\n  p: number\n): number[] {\n  const sol = new Array(numCols).fill(0);\n  for (let i = 0; i < numCols; i++) {\n    let val = particular[i];\n    for (let j = 0; j < coeffs.length; j++) {\n      val += coeffs[j] * nullBasis[j][i];\n    }\n    sol[i] = mod(val, p);\n  }\n  return sol;\n}\n\n// ─── Part 1: Toggle Puzzle ──────────────────────────────────────────────────\n\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const numLights = target.length;\n  const numButtons = buttons.length;\n\n  // Convert boolean target to numeric (0/1)\n  const targetNumeric = target.map(t => t ? 1 : 0);\n\n  // Solve over GF(2)\n  const solution = solveLinearSystemModP(numLights, numButtons, buttons, targetNumeric, 2);\n\n  if (solution === null) return null;\n\n  // Extract which buttons to press (those with value 1), sorted ascending\n  const pressed: number[] = [];\n  for (let i = 0; i < numButtons; i++) {\n    if (solution[i] === 1) pressed.push(i);\n  }\n\n  return pressed;\n}\n\n// ─── Part 2: Counter Puzzle ─────────────────────────────────────────────────\n\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const numLights = lights.length;\n  const numButtons = buttons.length;\n\n  const solution = solveLinearSystemModP(numLights, numButtons, buttons, lights, modulus);\n\n  return solution;\n}\n","numLines":374,"startLine":1,"totalLines":374}}}
