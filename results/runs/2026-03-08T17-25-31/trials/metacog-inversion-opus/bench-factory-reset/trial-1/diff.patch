+/**
+ * Factory Reset — Toggle & Counter Puzzle Solver
+ *
+ * Uses Gaussian elimination over finite fields (GF(2) for toggle, GF(p) for counter)
+ * to solve systems of linear equations, then searches the null space for optimal solutions.
+ */
+
+// ─── Types ───────────────────────────────────────────────────────────────────
+
+interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+type CompareMode = 'vector' | 'indices';
+
+// ─── Modular Arithmetic Helpers ──────────────────────────────────────────────
+
+function modInverse(a: number, p: number): number {
+  a = ((a % p) + p) % p;
+  if (a === 0) throw new Error("Cannot invert 0");
+  let result = 1;
+  let base = a;
+  let exp = p - 2;
+  while (exp > 0) {
+    if (exp & 1) result = (result * base) % p;
+    base = (base * base) % p;
+    exp >>= 1;
+  }
+  return result;
+}
+
+function mod(a: number, p: number): number {
+  return ((a % p) + p) % p;
+}
+
+// ─── Comparison helpers ─────────────────────────────────────────────────────
+
+/** For 'indices' mode (toggle): compare sorted lists of nonzero positions */
+function indicesToKey(sol: number[]): number[] {
+  const result: number[] = [];
+  for (let i = 0; i < sol.length; i++) {
+    if (sol[i] !== 0) result.push(i);
+  }
+  return result;
+}
+
+function lexSmallerArrays(a: number[], b: number[]): boolean {
+  const minLen = Math.min(a.length, b.length);
+  for (let i = 0; i < minLen; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return a.length < b.length;
+}
+
+/** Sum for 'indices' mode is just count of nonzero entries */
+function indicesSum(sol: number[]): number {
+  let count = 0;
+  for (let i = 0; i < sol.length; i++) {
+    if (sol[i] !== 0) count++;
+  }
+  return count;
+}
+
+/** Sum for 'vector' mode is sum of all values */
+function vectorSum(sol: number[]): number {
+  let s = 0;
+  for (let i = 0; i < sol.length; i++) s += sol[i];
+  return s;
+}
+
+function isBetter(
+  sol: number[],
+  solSum: number,
+  best: number[],
+  bestSum: number,
+  mode: CompareMode
+): boolean {
+  if (solSum < bestSum) return true;
+  if (solSum > bestSum) return false;
+  // Tied on sum — compare lex
+  if (mode === 'indices') {
+    return lexSmallerArrays(indicesToKey(sol), indicesToKey(best));
+  }
+  return lexSmallerArrays(sol, best);
+}
+
+function getSolutionSum(sol: number[], mode: CompareMode): number {
+  return mode === 'indices' ? indicesSum(sol) : vectorSum(sol);
+}
+
+// ─── Core Solver over GF(p) ────────────────────────────────────────────────
+
+function solveLinearSystemModP(
+  numLights: number,
+  numButtons: number,
+  buttons: number[][],
+  target: number[],
+  p: number,
+  compareMode: CompareMode
+): number[] | null {
+  const numRows = numLights;
+  const numCols = numButtons;
+
+  const matrix: number[][] = [];
+  for (let i = 0; i < numRows; i++) {
+    const row = new Array(numCols + 1).fill(0);
+    row[numCols] = mod(target[i], p);
+    matrix.push(row);
+  }
+
+  for (let j = 0; j < numButtons; j++) {
+    for (const lightIdx of buttons[j]) {
+      if (lightIdx < numLights) {
+        matrix[lightIdx][j] = mod(matrix[lightIdx][j] + 1, p);
+      }
+    }
+  }
+
+  // Gaussian elimination → RREF
+  const pivotCol: number[] = [];
+  let currentRow = 0;
+
+  for (let col = 0; col < numCols && currentRow < numRows; col++) {
+    let pivotR = -1;
+    for (let r = currentRow; r < numRows; r++) {
+      if (matrix[r][col] !== 0) {
+        pivotR = r;
+        break;
+      }
+    }
+    if (pivotR === -1) continue;
+
+    [matrix[currentRow], matrix[pivotR]] = [matrix[pivotR], matrix[currentRow]];
+
+    const inv = modInverse(matrix[currentRow][col], p);
+    for (let c = col; c <= numCols; c++) {
+      matrix[currentRow][c] = mod(matrix[currentRow][c] * inv, p);
+    }
+
+    for (let r = 0; r < numRows; r++) {
+      if (r === currentRow) continue;
+      const factor = matrix[r][col];
+      if (factor === 0) continue;
+      for (let c = col; c <= numCols; c++) {
+        matrix[r][c] = mod(matrix[r][c] - factor * matrix[currentRow][c], p);
+      }
+    }
+
+    pivotCol.push(col);
+    currentRow++;
+  }
+
+  const rank = pivotCol.length;
+
+  // Check consistency
+  for (let r = rank; r < numRows; r++) {
+    if (matrix[r][numCols] !== 0) {
+      return null;
+    }
+  }
+
+  // Identify free variables
+  const isPivot = new Set(pivotCol);
+  const freeVars: number[] = [];
+  for (let col = 0; col < numCols; col++) {
+    if (!isPivot.has(col)) {
+      freeVars.push(col);
+    }
+  }
+
+  const numFree = freeVars.length;
+
+  // Unique solution
+  if (numFree === 0) {
+    const solution = new Array(numCols).fill(0);
+    for (let k = 0; k < rank; k++) {
+      solution[pivotCol[k]] = matrix[k][numCols];
+    }
+    return solution;
+  }
+
+  // Particular solution (free vars = 0)
+  const particular = new Array(numCols).fill(0);
+  for (let k = 0; k < rank; k++) {
+    particular[pivotCol[k]] = matrix[k][numCols];
+  }
+
+  // Null space basis
+  const nullBasis: number[][] = [];
+  for (let j = 0; j < numFree; j++) {
+    const vec = new Array(numCols).fill(0);
+    vec[freeVars[j]] = 1;
+    for (let k = 0; k < rank; k++) {
+      vec[pivotCol[k]] = mod(-matrix[k][freeVars[j]], p);
+    }
+    nullBasis.push(vec);
+  }
+
+  const totalCombinations = Math.pow(p, numFree);
+
+  if (numFree <= getMaxFreeVarsForSearch(p)) {
+    // Enumerate all combinations
+    let bestSolution: number[] | null = null;
+    let bestSum = Infinity;
+
+    const coeffs = new Array(numFree).fill(0);
+
+    for (let iter = 0; iter < totalCombinations; iter++) {
+      const sol = computeSolution(particular, nullBasis, coeffs, numCols, p);
+      const sum = getSolutionSum(sol, compareMode);
+
+      if (bestSolution === null || isBetter(sol, sum, bestSolution, bestSum, compareMode)) {
+        bestSum = sum;
+        bestSolution = sol;
+      }
+
+      incrementCoeffs(coeffs, p);
+    }
+
+    return bestSolution;
+  }
+
+  // Greedy fallback for large search spaces
+  return greedyNullSpaceSearch(particular, nullBasis, freeVars, numCols, p, compareMode);
+}
+
+function getMaxFreeVarsForSearch(p: number): number {
+  if (p === 2) return 22;
+  if (p === 3) return 14;
+  if (p <= 5) return 10;
+  if (p <= 7) return 8;
+  if (p <= 13) return 7;
+  if (p <= 23) return 6;
+  if (p <= 47) return 5;
+  if (p <= 97) return 4;
+  return 3;
+}
+
+function incrementCoeffs(coeffs: number[], p: number): void {
+  for (let i = coeffs.length - 1; i >= 0; i--) {
+    coeffs[i]++;
+    if (coeffs[i] < p) return;
+    coeffs[i] = 0;
+  }
+}
+
+function greedyNullSpaceSearch(
+  particular: number[],
+  nullBasis: number[][],
+  freeVars: number[],
+  numCols: number,
+  p: number,
+  compareMode: CompareMode
+): number[] {
+  const numFree = freeVars.length;
+  const coeffs = new Array(numFree).fill(0);
+
+  for (let round = 0; round < 10; round++) {
+    let improved = false;
+    for (let j = 0; j < numFree; j++) {
+      let bestVal = coeffs[j];
+      let bestSum = Infinity;
+      let bestSol: number[] | null = null;
+
+      for (let v = 0; v < p; v++) {
+        coeffs[j] = v;
+        const sol = computeSolution(particular, nullBasis, coeffs, numCols, p);
+        const sum = getSolutionSum(sol, compareMode);
+        if (bestSol === null || isBetter(sol, sum, bestSol, bestSum, compareMode)) {
+          bestSum = sum;
+          bestVal = v;
+          bestSol = sol;
+        }
+      }
+
+      if (bestVal !== coeffs[j]) improved = true;
+      coeffs[j] = bestVal;
+    }
+    if (!improved) break;
+  }
+
+  return computeSolution(particular, nullBasis, coeffs, numCols, p);
+}
+
+function computeSolution(
+  particular: number[],
+  nullBasis: number[][],
+  coeffs: number[],
+  numCols: number,
+  p: number
+): number[] {
+  const sol = new Array(numCols).fill(0);
+  for (let i = 0; i < numCols; i++) {
+    let val = particular[i];
+    for (let j = 0; j < coeffs.length; j++) {
+      val += coeffs[j] * nullBasis[j][i];
+    }
+    sol[i] = mod(val, p);
+  }
+  return sol;
+}
+
+// ─── Part 1: Toggle Puzzle ──────────────────────────────────────────────────
+
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const numLights = target.length;
+  const numButtons = buttons.length;
+
+  const targetNumeric = target.map(t => t ? 1 : 0);
+
+  const solution = solveLinearSystemModP(numLights, numButtons, buttons, targetNumeric, 2, 'indices');
+
+  if (solution === null) return null;
+
+  const pressed: number[] = [];
+  for (let i = 0; i < numButtons; i++) {
+    if (solution[i] === 1) pressed.push(i);
+  }
+
+  return pressed;
+}
+
+// ─── Part 2: Counter Puzzle ─────────────────────────────────────────────────
+
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numLights = lights.length;
+  const numButtons = buttons.length;
+
+  return solveLinearSystemModP(numLights, numButtons, buttons, lights, modulus, 'vector');
+}
