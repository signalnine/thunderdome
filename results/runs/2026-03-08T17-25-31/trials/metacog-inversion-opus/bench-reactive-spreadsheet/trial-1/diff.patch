   for (const dep of newDeps) {\n      if (dep === ref) {\n        throw new Error(`Circular reference detected: ${ref} references itself`);\n      }\n      if (dfs(dep)) {\n        throw new Error(`Circular reference detected involving ${ref}`);\n      }\n    }\n  }\n\n  // Propagate changes after a cell value changes\n  private propagate(changedRef: string): void {\n    // Get all transitively dependent cells in topological order\n    const order = this.topologicalSort(changedRef);\n\n    // Recompute each in order (skip the first one, which is changedRef itself)\n    for (let i = 1; i < order.length; i++) {\n      const ref = order[i];\n      const data = this.cells.get(ref);\n      if (data && data.formula) {\n        data.computed = this.evaluate(data.formula);\n      }\n    }\n  }\n\n  // Topological sort of all cells that transitively depend on `startRef`\n  private topologicalSort(startRef: string): string[] {\n    const visited = new Set<string>();\n    const result: string[] = [];\n\n    const visit = (ref: string): void => {\n      if (visited.has(ref)) return;\n      visited.add(ref);\n      result.push(ref);\n\n      const dependents = this.dependedOnBy.get(ref);\n      if (dependents) {\n        for (const dep of dependents) {\n          visit(dep);\n        }\n      }\n    };\n\n    visit(startRef);\n    return result;\n  }\n\n  // Evaluate an AST node\n  private evaluate(node: ASTNode): CellValue {\n    switch (node.type) {\n      case 'number':\n        return node.value;\n      case 'string':\n        return node.value;\n      case 'boolean':\n        return node.value;\n      case 'cellRef': {\n        const data = this.cells.get(node.ref);\n        return data ? data.computed : null;\n      }\n      case 'range':\n        // Ranges should only appear as function arguments; evaluating a bare range\n        // returns the first value\n        return this.evaluateRange(node.start, node.end)[0] ?? null;\n      case 'unaryOp':\n        return this.eva