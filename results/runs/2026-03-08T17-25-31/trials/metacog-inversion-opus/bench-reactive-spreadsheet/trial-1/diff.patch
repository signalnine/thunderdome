+++ b/src/index.ts
@@ -0,0 +1,344 @@
+import {
+  parseFormula,
+  extractCellRefs,
+  expandRange,
+  type ASTNode,
+  type CellValue,
+} from './parser.js';
+
+interface CellData {
+  // The raw input value
+  raw: string | number | boolean;
+  // Parsed AST if this is a formula
+  formula: ASTNode | null;
+  // The computed value
+  computed: CellValue;
+  // Cells this cell depends on (its formula references)
+  dependsOn: Set<string>;
+}
+
+export class Spreadsheet {
+  // Cell storage
+  private cells: Map<string, CellData> = new Map();
+  // Reverse dependency map: for each cell, which cells depend on it
+  private dependedOnBy: Map<string, Set<string>> = new Map();
+
+  set(cell: string, value: string | number | boolean): void {
+    const ref = cell.toUpperCase();
+
+    // Parse the value
+    let formula: ASTNode | null = null;
+    let newDeps = new Set<string>();
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      formula = parseFormula(value);
+      const refs = extractCellRefs(formula);
+      newDeps = new Set(refs);
+    }
+
+    // Check for circular dependencies before committing
+    if (newDeps.size > 0) {
+      this.checkCircular(ref, newDeps);
+    }
+
+    // Remove old reverse dependencies
+    const existing = this.cells.get(ref);
+    if (existing) {
+      for (const dep of existing.dependsOn) {
+        const set = this.dependedOnBy.get(dep);
+        if (set) {
+          set.delete(ref);
+          if (set.size === 0) this.dependedOnBy.delete(dep);
+        }
+      }
+    }
+
+    // Add new reverse dependencies
+    for (const dep of newDeps) {
+      let set = this.dependedOnBy.get(dep);
+      if (!set) {
+        set = new Set();
+        this.dependedOnBy.set(dep, set);
+      }
+      set.add(ref);
+    }
+
+    // Compute the value
+    const computed = formula ? this.evaluate(formula) : this.coerceRawValue(value);
+
+    // Store the cell
+    this.cells.set(ref, {
+      raw: value,
+      formula,
+      computed,
+      dependsOn: newDeps,
+    });
+
+    // Propagate to dependents
+    this.propagate(ref);
+  }
+
+  get(cell: string): CellValue {
+    const ref = cell.toUpperCase();
+    const data = this.cells.get(ref);
+    if (!data) return null;
+    return data.computed;
+  }
+
+  getDisplay(cell: string): string {
+    const value = this.get(cell);
+    if (value === null) return '';
+    return String(value);
+  }
+
+  getCells(): Map<string, CellValue> {
+    const result = new Map<string, CellValue>();
+    for (const [ref, data] of this.cells) {
+      result.set(ref, data.computed);
+    }
+    return result;
+  }
+
+  private coerceRawValue(value: string | number | boolean): CellValue {
+    if (typeof value === 'number' || typeof value === 'boolean') {
+      return value;
+    }
+    // Try to parse as number
+    if (typeof value === 'string') {
+      const lower = value.toLowerCase();
+      if (lower === 'true') return true;
+      if (lower === 'false') return false;
+      const num = Number(value);
+      if (!isNaN(num) && value.trim() !== '') return num;
+    }
+    return value;
+  }
+
+  // Check if adding deps to `ref` would create a cycle
+  private checkCircular(ref: string, newDeps: Set<string>): void {
+    // DFS from each dependency, following their dependencies, to see if we reach `ref`
+    const visited = new Set<string>();
+
+    const dfs = (current: string): boolean => {
+      if (current === ref) return true;
+      if (visited.has(current)) return false;
+      visited.add(current);
+
+      const cellData = this.cells.get(current);
+      if (cellData) {
+        for (const dep of cellData.dependsOn) {
+          if (dfs(dep)) return true;
+        }
+      }
+      return false;
+    };
+
+    for (const dep of newDeps) {
+      if (dep === ref) {
+        throw new Error(`Circular reference detected: ${ref} references itself`);
+      }
+      if (dfs(dep)) {
+        throw new Error(`Circular reference detected involving ${ref}`);
+      }
+    }
+  }
+
+  // Propagate changes after a cell value changes
+  private propagate(changedRef: string): void {
+    // Get all transitively dependent cells in topological order
+    const order = this.topologicalSort(changedRef);
+
+    // Recompute each in order (skip the first one, which is changedRef itself)
+    for (let i = 1; i < order.length; i++) {
+      const ref = order[i];
+      const data = this.cells.get(ref);
+      if (data && data.formula) {
+        data.computed = this.evaluate(data.formula);
+      }
+    }
+  }
+
+  // Topological sort of all cells that transitively depend on `startRef`
+  // Uses post-order DFS so that a cell is always computed after all its dependencies
+  private topologicalSort(startRef: string): string[] {
+    // First, collect all affected cells (those transitively dependent on startRef)
+    const affected = new Set<string>();
+    const collectAffected = (ref: string): void => {
+      if (affected.has(ref)) return;
+      affected.add(ref);
+      const dependents = this.dependedOnBy.get(ref);
+      if (dependents) {
+        for (const dep of dependents) {
+          collectAffected(dep);
+        }
+      }
+    };
+    collectAffected(startRef);
+
+    // Now topologically sort the affected cells using post-order DFS
+    // A cell should appear after all its dependencies that are also in the affected set
+    const visited = new Set<string>();
+    const result: string[] = [];
+
+    const visit = (ref: string): void => {
+      if (visited.has(ref)) return;
+      visited.add(ref);
+
+      // Visit all dependencies first (but only those in the affected set)
+      const cellData = this.cells.get(ref);
+      if (cellData) {
+        for (const dep of cellData.dependsOn) {
+          if (affected.has(dep)) {
+            visit(dep);
+          }
+        }
+      }
+
+      result.push(ref);
+    };
+
+    for (const ref of affected) {
+      visit(ref);
+    }
+
+    return result;
+  }
+
+  // Evaluate an AST node
+  private evaluate(node: ASTNode): CellValue {
+    switch (node.type) {
+      case 'number':
+        return node.value;
+      case 'string':
+        return node.value;
+      case 'boolean':
+        return node.value;
+      case 'cellRef': {
+        const data = this.cells.get(node.ref);
+        return data ? data.computed : null;
+      }
+      case 'range':
+        // Ranges should only appear as function arguments; evaluating a bare range
+        // returns the first value
+        return this.evaluateRange(node.start, node.end)[0] ?? null;
+      case 'unaryOp':
+        return this.evaluateUnary(node);
+      case 'binaryOp':
+        return this.evaluateBinary(node);
+      case 'functionCall':
+        return this.evaluateFunction(node);
+    }
+  }
+
+  private evaluateUnary(node: ASTNode & { type: 'unaryOp' }): CellValue {
+    const val = this.evaluate(node.operand);
+    if (node.op === '-') {
+      if (typeof val === 'number') return -val;
+      return 0;
+    }
+    return val;
+  }
+
+  private evaluateBinary(node: ASTNode & { type: 'binaryOp' }): CellValue {
+    const left = this.evaluate(node.left);
+    const right = this.evaluate(node.right);
+
+    const lNum = typeof left === 'number' ? left : 0;
+    const rNum = typeof right === 'number' ? right : 0;
+
+    switch (node.op) {
+      case '+':
+        return lNum + rNum;
+      case '-':
+        return lNum - rNum;
+      case '*':
+        return lNum * rNum;
+      case '/':
+        if (rNum === 0) return 0; // Division by zero
+        return lNum / rNum;
+      case '>':
+        return lNum > rNum;
+      case '<':
+        return lNum < rNum;
+      case '>=':
+        return lNum >= rNum;
+      case '<=':
+        return lNum <= rNum;
+      case '=':
+        return left === right;
+      case '<>':
+        return left !== right;
+      default:
+        return 0;
+    }
+  }
+
+  private evaluateFunction(node: ASTNode & { type: 'functionCall' }): CellValue {
+    const name = node.name.toUpperCase();
+
+    switch (name) {
+      case 'SUM':
+        return this.evalAggregate(node.args, (vals) =>
+          vals.reduce((sum, v) => sum + v, 0)
+        );
+      case 'AVERAGE': {
+        return this.evalAggregate(node.args, (vals) =>
+          vals.length === 0 ? 0 : vals.reduce((sum, v) => sum + v, 0) / vals.length
+        );
+      }
+      case 'MIN':
+        return this.evalAggregate(node.args, (vals) =>
+          vals.length === 0 ? 0 : Math.min(...vals)
+        );
+      case 'MAX':
+        return this.evalAggregate(node.args, (vals) =>
+          vals.length === 0 ? 0 : Math.max(...vals)
+        );
+      case 'COUNT':
+        return this.evalAggregateCount(node.args);
+      case 'IF': {
+        if (node.args.length < 3) return 0;
+        const condition = this.evaluate(node.args[0]);
+        const isTruthy = condition === true || (typeof condition === 'number' && condition !== 0);
+        return isTruthy ? this.evaluate(node.args[1]) : this.evaluate(node.args[2]);
+      }
+      default:
+        return 0;
+    }
+  }
+
+  // Collect numeric values from arguments (expanding ranges)
+  private collectNumbers(args: ASTNode[]): number[] {
+    const nums: number[] = [];
+    for (const arg of args) {
+      if (arg.type === 'range') {
+        const values = this.evaluateRange(arg.start, arg.end);
+        for (const v of values) {
+          if (typeof v === 'number') nums.push(v);
+        }
+      } else {
+        const val = this.evaluate(arg);
+        if (typeof val === 'number') nums.push(val);
+      }
+    }
+    return nums;
+  }
+
+  private evalAggregate(args: ASTNode[], fn: (vals: number[]) => number): number {
+    const nums = this.collectNumbers(args);
+    return fn(nums);
+  }
+
+  private evalAggregateCount(args: ASTNode[]): number {
+    return this.collectNumbers(args).length;
+  }
+
+  // Get all cell values in a range
+  private evaluateRange(start: string, end: string): CellValue[] {
+    const refs = expandRange(start, end);
+    return refs.map((ref) => {
+      const data = this.cells.get(ref);
+      return data ? data.computed : null;
+    });
+  }
+}
