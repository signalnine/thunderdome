+import { describe, it, expect, beforeEach } from 'vitest';
+import { Spreadsheet } from './index.js';
+
+describe('Spreadsheet', () => {
+  let sheet: Spreadsheet;
+
+  beforeEach(() => {
+    sheet = new Spreadsheet();
+  });
+
+  describe('basic values', () => {
+    it('should return null for empty cells', () => {
+      expect(sheet.get('A1')).toBe(null);
+    });
+
+    it('should set and get a number', () => {
+      sheet.set('A1', 42);
+      expect(sheet.get('A1')).toBe(42);
+    });
+
+    it('should set and get a string', () => {
+      sheet.set('A1', 'hello');
+      expect(sheet.get('A1')).toBe('hello');
+    });
+
+    it('should set and get a boolean', () => {
+      sheet.set('A1', true);
+      expect(sheet.get('A1')).toBe(true);
+      sheet.set('A2', false);
+      expect(sheet.get('A2')).toBe(false);
+    });
+
+    it('should set and get a float', () => {
+      sheet.set('A1', 3.14);
+      expect(sheet.get('A1')).toBeCloseTo(3.14);
+    });
+
+    it('should be case-insensitive for cell references', () => {
+      sheet.set('a1', 10);
+      expect(sheet.get('A1')).toBe(10);
+      expect(sheet.get('a1')).toBe(10);
+    });
+  });
+
+  describe('getDisplay', () => {
+    it('should return empty string for empty cells', () => {
+      expect(sheet.getDisplay('A1')).toBe('');
+    });
+
+    it('should return string representation of numbers', () => {
+      sheet.set('A1', 42);
+      expect(sheet.getDisplay('A1')).toBe('42');
+    });
+
+    it('should return string representation of booleans', () => {
+      sheet.set('A1', true);
+      expect(sheet.getDisplay('A1')).toBe('true');
+    });
+
+    it('should return the string itself for string values', () => {
+      sheet.set('A1', 'hello');
+      expect(sheet.getDisplay('A1')).toBe('hello');
+    });
+
+    it('should return computed formula result as string', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.getDisplay('A3')).toBe('30');
+    });
+  });
+
+  describe('getCells', () => {
+    it('should return empty map for empty spreadsheet', () => {
+      const cells = sheet.getCells();
+      expect(cells.size).toBe(0);
+    });
+
+    it('should return all non-empty cells', () => {
+      sheet.set('A1', 10);
+      sheet.set('B1', 20);
+      sheet.set('C1', '=A1+B1');
+      const cells = sheet.getCells();
+      expect(cells.size).toBe(3);
+      expect(cells.get('A1')).toBe(10);
+      expect(cells.get('B1')).toBe(20);
+      expect(cells.get('C1')).toBe(30);
+    });
+  });
+
+  describe('simple formulas', () => {
+    it('should evaluate a simple addition formula', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should evaluate subtraction', () => {
+      sheet.set('A1', 50);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1-A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should evaluate multiplication', () => {
+      sheet.set('A1', 5);
+      sheet.set('A2', 6);
+      sheet.set('A3', '=A1*A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should evaluate division', () => {
+      sheet.set('A1', 100);
+      sheet.set('A2', 4);
+      sheet.set('A3', '=A1/A2');
+      expect(sheet.get('A3')).toBe(25);
+    });
+
+    it('should respect operator precedence', () => {
+      sheet.set('A1', 2);
+      sheet.set('A2', 3);
+      sheet.set('A3', 4);
+      sheet.set('B1', '=A1+A2*A3');
+      expect(sheet.get('B1')).toBe(14); // 2 + 3*4 = 14, not 20
+    });
+
+    it('should handle parentheses', () => {
+      sheet.set('A1', 2);
+      sheet.set('A2', 3);
+      sheet.set('A3', 4);
+      sheet.set('B1', '=(A1+A2)*A3');
+      expect(sheet.get('B1')).toBe(20); // (2+3)*4 = 20
+    });
+
+    it('should handle negative values with unary minus', () => {
+      sheet.set('A1', 5);
+      sheet.set('A2', '=-A1');
+      expect(sheet.get('A2')).toBe(-5);
+    });
+
+    it('should reference empty cells as 0 in arithmetic', () => {
+      sheet.set('A1', '=A2+5');
+      expect(sheet.get('A1')).toBe(5);
+    });
+
+    it('should handle a constant formula', () => {
+      sheet.set('A1', '=42');
+      expect(sheet.get('A1')).toBe(42);
+    });
+  });
+
+  describe('reactive updates', () => {
+    it('should update dependents when a cell changes', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.get('A3')).toBe(30);
+
+      sheet.set('A1', 50);
+      expect(sheet.get('A3')).toBe(70);
+    });
+
+    it('should propagate changes through a chain', () => {
+      sheet.set('A1', 1);
+      sheet.set('A2', '=A1+1');
+      sheet.set('A3', '=A2+1');
+      sheet.set('A4', '=A3+1');
+      expect(sheet.get('A4')).toBe(4);
+
+      sheet.set('A1', 10);
+      expect(sheet.get('A2')).toBe(11);
+      expect(sheet.get('A3')).toBe(12);
+      expect(sheet.get('A4')).toBe(13);
+    });
+
+    it('should handle diamond dependencies', () => {
+      // A1 is depended on by both B1 and C1, which are both depended on by D1
+      sheet.set('A1', 10);
+      sheet.set('B1', '=A1*2');
+      sheet.set('C1', '=A1*3');
+      sheet.set('D1', '=B1+C1');
+      expect(sheet.get('D1')).toBe(50); // 20 + 30
+
+      sheet.set('A1', 5);
+      expect(sheet.get('B1')).toBe(10);
+      expect(sheet.get('C1')).toBe(15);
+      expect(sheet.get('D1')).toBe(25);
+    });
+
+    it('should handle overwriting a formula with a value', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', '=A1+1');
+      expect(sheet.get('A2')).toBe(11);
+
+      sheet.set('A2', 99);
+      expect(sheet.get('A2')).toBe(99);
+
+      // A2 should no longer depend on A1
+      sheet.set('A1', 20);
+      expect(sheet.get('A2')).toBe(99);
+    });
+
+    it('should handle overwriting a value with a formula', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 99);
+      expect(sheet.get('A2')).toBe(99);
+
+      sheet.set('A2', '=A1*2');
+      expect(sheet.get('A2')).toBe(20);
+    });
+  });
+
+  describe('SUM function', () => {
+    it('should sum a column range', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', 30);
+      sheet.set('B1', '=SUM(A1:A3)');
+      expect(sheet.get('B1')).toBe(60);
+    });
+
+    it('should sum a row range', () => {
+      sheet.set('A1', 1);
+      sheet.set('B1', 2);
+      sheet.set('C1', 3);
+      sheet.set('D1', '=SUM(A1:C1)');
+      expect(sheet.get('D1')).toBe(6);
+    });
+
+    it('should ignore non-numeric values in SUM', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 'hello');
+      sheet.set('A3', 20);
+      sheet.set('B1', '=SUM(A1:A3)');
+      expect(sheet.get('B1')).toBe(30);
+    });
+
+    it('should reactively update SUM when range values change', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('B1', '=SUM(A1:A2)');
+      expect(sheet.get('B1')).toBe(30);
+
+      sheet.set('A1', 100);
+      expect(sheet.get('B1')).toBe(120);
+    });
+  });
+
+  describe('AVERAGE function', () => {
+    it('should compute average of a range', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', 30);
+      sheet.set('B1', '=AVERAGE(A1:A3)');
+      expect(sheet.get('B1')).toBe(20);
+    });
+  });
+
+  describe('MIN function', () => {
+    it('should find minimum of a range', () => {
+      sheet.set('A1', 30);
+      sheet.set('A2', 10);
+      sheet.set('A3', 20);
+      sheet.set('B1', '=MIN(A1:A3)');
+      expect(sheet.get('B1')).toBe(10);
+    });
+  });
+
+  describe('MAX function', () => {
+    it('should find maximum of a range', () => {
+      sheet.set('A1', 30);
+      sheet.set('A2', 10);
+      sheet.set('A3', 20);
+      sheet.set('B1', '=MAX(A1:A3)');
+      expect(sheet.get('B1')).toBe(30);
+    });
+  });
+
+  describe('COUNT function', () => {
+    it('should count numeric values in a range', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 'hello');
+      sheet.set('A3', 20);
+      sheet.set('A4', true);
+      sheet.set('B1', '=COUNT(A1:A4)');
+      expect(sheet.get('B1')).toBe(2);
+    });
+  });
+
+  describe('IF function', () => {
+    it('should return true value when condition is true', () => {
+      sheet.set('A1', 50);
+      sheet.set('B1', '=IF(A1>30, "big", "small")');
+      expect(sheet.get('B1')).toBe('big');
+    });
+
+    it('should return false value when condition is false', () => {
+      sheet.set('A1', 10);
+      sheet.set('B1', '=IF(A1>30, "big", "small")');
+      expect(sheet.get('B1')).toBe('small');
+    });
+
+    it('should reactively update IF result', () => {
+      sheet.set('A1', 10);
+      sheet.set('B1', '=IF(A1>30, "big", "small")');
+      expect(sheet.get('B1')).toBe('small');
+
+      sheet.set('A1', 50);
+      expect(sheet.get('B1')).toBe('big');
+    });
+
+    it('should handle numeric values in IF branches', () => {
+      sheet.set('A1', 10);
+      sheet.set('B1', '=IF(A1>5, A1*2, 0)');
+      expect(sheet.get('B1')).toBe(20);
+    });
+  });
+
+  describe('comparison operators', () => {
+    it('should evaluate greater than', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 5);
+      sheet.set('B1', '=A1>A2');
+      expect(sheet.get('B1')).toBe(true);
+    });
+
+    it('should evaluate less than', () => {
+      sheet.set('A1', 3);
+      sheet.set('A2', 5);
+      sheet.set('B1', '=A1<A2');
+      expect(sheet.get('B1')).toBe(true);
+    });
+
+    it('should evaluate equality', () => {
+      sheet.set('A1', 5);
+      sheet.set('A2', 5);
+      sheet.set('B1', '=A1=A2');
+      expect(sheet.get('B1')).toBe(true);
+    });
+
+    it('should evaluate not equal', () => {
+      sheet.set('A1', 5);
+      sheet.set('A2', 3);
+      sheet.set('B1', '=A1<>A2');
+      expect(sheet.get('B1')).toBe(true);
+    });
+
+    it('should evaluate greater than or equal', () => {
+      sheet.set('A1', 5);
+      sheet.set('A2', 5);
+      sheet.set('B1', '=A1>=A2');
+      expect(sheet.get('B1')).toBe(true);
+    });
+
+    it('should evaluate less than or equal', () => {
+      sheet.set('A1', 5);
+      sheet.set('A2', 5);
+      sheet.set('B1', '=A1<=A2');
+      expect(sheet.get('B1')).toBe(true);
+    });
+  });
+
+  describe('circular reference detection', () => {
+    it('should detect direct self-reference', () => {
+      expect(() => sheet.set('A1', '=A1')).toThrow(/circular/i);
+    });
+
+    it('should detect simple cycle between two cells', () => {
+      sheet.set('A1', '=B1');
+      expect(() => sheet.set('B1', '=A1')).toThrow(/circular/i);
+    });
+
+    it('should detect indirect cycle through three cells', () => {
+      sheet.set('A1', '=B1');
+      sheet.set('B1', '=C1');
+      expect(() => sheet.set('C1', '=A1')).toThrow(/circular/i);
+    });
+
+    it('should not throw for non-circular references', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', '=A1+1');
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.get('A3')).toBe(21);
+    });
+
+    it('should not modify cell state when circular reference is detected', () => {
+      sheet.set('A1', '=B1');
+      sheet.set('B1', 5);
+
+      expect(() => sheet.set('B1', '=A1')).toThrow(/circular/i);
+      // B1 should still have its old value
+      expect(sheet.get('B1')).toBe(5);
+    });
+  });
+
+  describe('block ranges', () => {
+    it('should sum a 2D block range', () => {
+      sheet.set('A1', 1);
+      sheet.set('A2', 2);
+      sheet.set('A3', 3);
+      sheet.set('B1', 4);
+      sheet.set('B2', 5);
+      sheet.set('B3', 6);
+      sheet.set('C1', 7);
+      sheet.set('C2', 8);
+      sheet.set('C3', 9);
+      sheet.set('D1', '=SUM(A1:C3)');
+      expect(sheet.get('D1')).toBe(45);
+    });
+  });
+
+  describe('column references beyond Z', () => {
+    it('should handle AA column', () => {
+      sheet.set('AA1', 100);
+      expect(sheet.get('AA1')).toBe(100);
+    });
+
+    it('should handle formulas with AA column references', () => {
+      sheet.set('AA1', 10);
+      sheet.set('AB1', 20);
+      sheet.set('AC1', '=AA1+AB1');
+      expect(sheet.get('AC1')).toBe(30);
+    });
+  });
+
+  describe('example from task description', () => {
+    it('should match the example usage exactly', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.get('A3')).toBe(30);
+      expect(sheet.getDisplay('A3')).toBe('30');
+
+      sheet.set('A1', 50);
+      expect(sheet.get('A3')).toBe(70);
+
+      sheet.set('B1', '=SUM(A1:A2)');
+      expect(sheet.get('B1')).toBe(70);
+
+      sheet.set('C1', '=IF(A1>30, "big", "small")');
+      expect(sheet.get('C1')).toBe('big');
+    });
+  });
+});
