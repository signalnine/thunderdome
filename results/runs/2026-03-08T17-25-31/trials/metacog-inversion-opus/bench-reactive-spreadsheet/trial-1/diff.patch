@@ -0,0 +1,457 @@
+// Formula parser: tokenizer + recursive descent parser with proper operator precedence
+// Grammar:
+//   expression  → comparison
+//   comparison  → addition (( '>' | '<' | '>=' | '<=' | '=' | '<>' ) addition)*
+//   addition    → multiplication (( '+' | '-' ) multiplication)*
+//   multiplication → unary (( '*' | '/' ) unary)*
+//   unary       → '-' unary | primary
+//   primary     → NUMBER | STRING | BOOLEAN | cellRef | functionCall | '(' expression ')'
+//   functionCall → IDENT '(' argList ')'
+//   argList     → (arg (',' arg)*)?
+//   arg         → range | expression
+//   range       → cellRef ':' cellRef
+
+export type CellValue = string | number | boolean | null;
+
+export interface NumberLiteral {
+  type: 'number';
+  value: number;
+}
+
+export interface StringLiteral {
+  type: 'string';
+  value: string;
+}
+
+export interface BooleanLiteral {
+  type: 'boolean';
+  value: boolean;
+}
+
+export interface CellRef {
+  type: 'cellRef';
+  ref: string; // e.g. "A1"
+}
+
+export interface RangeRef {
+  type: 'range';
+  start: string;
+  end: string;
+}
+
+export interface BinaryOp {
+  type: 'binaryOp';
+  op: string;
+  left: ASTNode;
+  right: ASTNode;
+}
+
+export interface UnaryOp {
+  type: 'unaryOp';
+  op: string;
+  operand: ASTNode;
+}
+
+export interface FunctionCall {
+  type: 'functionCall';
+  name: string;
+  args: ASTNode[];
+}
+
+export type ASTNode =
+  | NumberLiteral
+  | StringLiteral
+  | BooleanLiteral
+  | CellRef
+  | RangeRef
+  | BinaryOp
+  | UnaryOp
+  | FunctionCall;
+
+// Token types
+interface Token {
+  type:
+    | 'number'
+    | 'string'
+    | 'ident'
+    | 'cellRef'
+    | 'op'
+    | 'lparen'
+    | 'rparen'
+    | 'comma'
+    | 'colon'
+    | 'eof';
+  value: string;
+}
+
+function tokenize(input: string): Token[] {
+  const tokens: Token[] = [];
+  let i = 0;
+
+  while (i < input.length) {
+    const ch = input[i];
+
+    // Skip whitespace
+    if (ch === ' ' || ch === '\t') {
+      i++;
+      continue;
+    }
+
+    // String literal
+    if (ch === '"') {
+      let str = '';
+      i++; // skip opening quote
+      while (i < input.length && input[i] !== '"') {
+        str += input[i];
+        i++;
+      }
+      if (i < input.length) i++; // skip closing quote
+      tokens.push({ type: 'string', value: str });
+      continue;
+    }
+
+    // Number
+    if (ch >= '0' && ch <= '9') {
+      let num = '';
+      while (i < input.length && ((input[i] >= '0' && input[i] <= '9') || input[i] === '.')) {
+        num += input[i];
+        i++;
+      }
+      tokens.push({ type: 'number', value: num });
+      continue;
+    }
+
+    // Identifier or cell reference or boolean
+    if ((ch >= 'A' && ch <= 'Z') || (ch >= 'a' && ch <= 'z')) {
+      let word = '';
+      while (
+        i < input.length &&
+        ((input[i] >= 'A' && input[i] <= 'Z') ||
+          (input[i] >= 'a' && input[i] <= 'z') ||
+          (input[i] >= '0' && input[i] <= '9'))
+      ) {
+        word += input[i];
+        i++;
+      }
+
+      const upper = word.toUpperCase();
+      if (upper === 'TRUE' || upper === 'FALSE') {
+        tokens.push({ type: 'ident', value: upper });
+      } else if (/^[A-Z]+[0-9]+$/i.test(word)) {
+        tokens.push({ type: 'cellRef', value: upper });
+      } else {
+        tokens.push({ type: 'ident', value: upper });
+      }
+      continue;
+    }
+
+    // Multi-char operators
+    if (ch === '<' || ch === '>') {
+      if (i + 1 < input.length && input[i + 1] === '=') {
+        tokens.push({ type: 'op', value: ch + '=' });
+        i += 2;
+        continue;
+      }
+      if (ch === '<' && i + 1 < input.length && input[i + 1] === '>') {
+        tokens.push({ type: 'op', value: '<>' });
+        i += 2;
+        continue;
+      }
+      tokens.push({ type: 'op', value: ch });
+      i++;
+      continue;
+    }
+
+    // Single-char operators and punctuation
+    if (ch === '+' || ch === '-' || ch === '*' || ch === '/' || ch === '=') {
+      tokens.push({ type: 'op', value: ch });
+      i++;
+      continue;
+    }
+
+    if (ch === '(') {
+      tokens.push({ type: 'lparen', value: '(' });
+      i++;
+      continue;
+    }
+
+    if (ch === ')') {
+      tokens.push({ type: 'rparen', value: ')' });
+      i++;
+      continue;
+    }
+
+    if (ch === ',') {
+      tokens.push({ type: 'comma', value: ',' });
+      i++;
+      continue;
+    }
+
+    if (ch === ':') {
+      tokens.push({ type: 'colon', value: ':' });
+      i++;
+      continue;
+    }
+
+    // Unknown character — skip
+    i++;
+  }
+
+  tokens.push({ type: 'eof', value: '' });
+  return tokens;
+}
+
+class Parser {
+  private tokens: Token[];
+  private pos: number;
+
+  constructor(tokens: Token[]) {
+    this.tokens = tokens;
+    this.pos = 0;
+  }
+
+  private peek(): Token {
+    return this.tokens[this.pos];
+  }
+
+  private advance(): Token {
+    const t = this.tokens[this.pos];
+    this.pos++;
+    return t;
+  }
+
+  private expect(type: Token['type']): Token {
+    const t = this.peek();
+    if (t.type !== type) {
+      throw new Error(`Expected ${type} but got ${t.type} (${t.value})`);
+    }
+    return this.advance();
+  }
+
+  parse(): ASTNode {
+    const node = this.expression();
+    return node;
+  }
+
+  private expression(): ASTNode {
+    return this.comparison();
+  }
+
+  private comparison(): ASTNode {
+    let left = this.addition();
+
+    while (
+      this.peek().type === 'op' &&
+      ['>', '<', '>=', '<=', '=', '<>'].includes(this.peek().value)
+    ) {
+      const op = this.advance().value;
+      const right = this.addition();
+      left = { type: 'binaryOp', op, left, right };
+    }
+
+    return left;
+  }
+
+  private addition(): ASTNode {
+    let left = this.multiplication();
+
+    while (this.peek().type === 'op' && (this.peek().value === '+' || this.peek().value === '-')) {
+      const op = this.advance().value;
+      const right = this.multiplication();
+      left = { type: 'binaryOp', op, left, right };
+    }
+
+    return left;
+  }
+
+  private multiplication(): ASTNode {
+    let left = this.unary();
+
+    while (this.peek().type === 'op' && (this.peek().value === '*' || this.peek().value === '/')) {
+      const op = this.advance().value;
+      const right = this.unary();
+      left = { type: 'binaryOp', op, left, right };
+    }
+
+    return left;
+  }
+
+  private unary(): ASTNode {
+    if (this.peek().type === 'op' && this.peek().value === '-') {
+      this.advance();
+      const operand = this.unary();
+      return { type: 'unaryOp', op: '-', operand };
+    }
+    return this.primary();
+  }
+
+  private primary(): ASTNode {
+    const token = this.peek();
+
+    if (token.type === 'number') {
+      this.advance();
+      return { type: 'number', value: parseFloat(token.value) };
+    }
+
+    if (token.type === 'string') {
+      this.advance();
+      return { type: 'string', value: token.value };
+    }
+
+    if (token.type === 'ident') {
+      if (token.value === 'TRUE') {
+        this.advance();
+        return { type: 'boolean', value: true };
+      }
+      if (token.value === 'FALSE') {
+        this.advance();
+        return { type: 'boolean', value: false };
+      }
+
+      // Function call: IDENT '(' args ')'
+      this.advance();
+      const name = token.value;
+      this.expect('lparen');
+      const args: ASTNode[] = [];
+      if (this.peek().type !== 'rparen') {
+        args.push(this.arg());
+        while (this.peek().type === 'comma') {
+          this.advance();
+          args.push(this.arg());
+        }
+      }
+      this.expect('rparen');
+      return { type: 'functionCall', name, args };
+    }
+
+    if (token.type === 'cellRef') {
+      this.advance();
+      // Check if this is a range (cellRef ':' cellRef)
+      if (this.peek().type === 'colon') {
+        this.advance(); // consume ':'
+        const endToken = this.expect('cellRef');
+        return { type: 'range', start: token.value, end: endToken.value };
+      }
+      return { type: 'cellRef', ref: token.value };
+    }
+
+    if (token.type === 'lparen') {
+      this.advance();
+      const expr = this.expression();
+      this.expect('rparen');
+      return expr;
+    }
+
+    throw new Error(`Unexpected token: ${token.type} (${token.value})`);
+  }
+
+  private arg(): ASTNode {
+    // An argument can be a range or an expression
+    // We need to look ahead to check for range syntax (cellRef : cellRef)
+    if (this.peek().type === 'cellRef') {
+      const saved = this.pos;
+      const startToken = this.advance();
+      if (this.peek().type === 'colon') {
+        this.advance();
+        if (this.peek().type === 'cellRef') {
+          const endToken = this.advance();
+          return { type: 'range', start: startToken.value, end: endToken.value };
+        }
+      }
+      // Backtrack
+      this.pos = saved;
+    }
+    return this.expression();
+  }
+}
+
+export function parseFormula(formula: string): ASTNode {
+  // Remove the leading '='
+  const expr = formula.startsWith('=') ? formula.slice(1) : formula;
+  const tokens = tokenize(expr);
+  const parser = new Parser(tokens);
+  return parser.parse();
+}
+
+// Extract all cell references from an AST (for dependency tracking)
+export function extractCellRefs(node: ASTNode): string[] {
+  const refs: string[] = [];
+
+  function walk(n: ASTNode): void {
+    switch (n.type) {
+      case 'cellRef':
+        refs.push(n.ref);
+        break;
+      case 'range':
+        // Expand range to individual cell references
+        for (const ref of expandRange(n.start, n.end)) {
+          refs.push(ref);
+        }
+        break;
+      case 'binaryOp':
+        walk(n.left);
+        walk(n.right);
+        break;
+      case 'unaryOp':
+        walk(n.operand);
+        break;
+      case 'functionCall':
+        for (const arg of n.args) {
+          walk(arg);
+        }
+        break;
+      // number, string, boolean — no refs
+    }
+  }
+
+  walk(node);
+  return refs;
+}
+
+// Parse a cell reference like "A1" into { col: 0, row: 0 }
+export function parseCellRef(ref: string): { col: number; row: number } {
+  const match = ref.match(/^([A-Z]+)(\d+)$/i);
+  if (!match) throw new Error(`Invalid cell reference: ${ref}`);
+
+  const colStr = match[1].toUpperCase();
+  const row = parseInt(match[2], 10) - 1; // 0-based
+
+  let col = 0;
+  for (let i = 0; i < colStr.length; i++) {
+    col = col * 26 + (colStr.charCodeAt(i) - 64); // A=1, B=2, ...
+  }
+  col -= 1; // 0-based
+
+  return { col, row };
+}
+
+// Convert 0-based col/row back to cell reference string
+export function toCellRef(col: number, row: number): string {
+  let colStr = '';
+  let c = col + 1; // 1-based
+  while (c > 0) {
+    c--;
+    colStr = String.fromCharCode(65 + (c % 26)) + colStr;
+    c = Math.floor(c / 26);
+  }
+  return colStr + (row + 1);
+}
+
+// Expand a range like A1:C3 into individual cell references
+export function expandRange(start: string, end: string): string[] {
+  const s = parseCellRef(start);
+  const e = parseCellRef(end);
+
+  const minCol = Math.min(s.col, e.col);
+  const maxCol = Math.max(s.col, e.col);
+  const minRow = Math.min(s.row, e.row);
+  const maxRow = Math.max(s.row, e.row);
+
+  const refs: string[] = [];
+  for (let r = minRow; r <= maxRow; r++) {
+    for (let c = minCol; c <= maxCol; c++) {
+      refs.push(toCellRef(c, r));
+    }
+  }
+  return refs;
+}
