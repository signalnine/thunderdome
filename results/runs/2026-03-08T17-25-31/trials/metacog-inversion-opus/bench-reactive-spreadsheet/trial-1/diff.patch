et.set('A1', 'hello');\n      expect(sheet.getDisplay('A1')).toBe('hello');\n    });\n\n    it('should return computed formula result as string', () => {\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', '=A1+A2');\n      expect(sheet.getDisplay('A3')).toBe('30');\n    });\n  });\n\n  describe('getCells', () => {\n    it('should return empty map for empty spreadsheet', () => {\n      const cells = sheet.getCells();\n      expect(cells.size).toBe(0);\n    });\n\n    it('should return all non-empty cells', () => {\n      sheet.set('A1', 10);\n      sheet.set('B1', 20);\n      sheet.set('C1', '=A1+B1');\n      const cells = sheet.getCells();\n      expect(cells.size).toBe(3);\n      expect(cells.get('A1')).toBe(10);\n      expect(cells.get('B1')).toBe(20);\n      expect(cells.get('C1')).toBe(30);\n    });\n  });\n\n  describe('simple formulas', () => {\n    it('should evaluate a simple addition formula', () => {\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', '=A1+A2');\n      expect(sheet.get('A3')).toBe(30);\n    });\n\n    it('should evaluate subtraction', () => {\n      sheet.set('A1', 50);\n      sheet.set('A2', 20);\n      sheet.set('A3', '=A1-A2');\n      expect(sheet.get('A3')).toBe(30);\n    });\n\n    it('should evaluate multiplication', () => {\n      sheet.set('A1', 5);\n      sheet.set('A2', 6);\n      sheet.set('A3', '=A1*A2');\n      expect(sheet.get('A3')).toBe(30);\n    });\n\n    it('should evaluate division', () => {\n      sheet.set('A1', 100);\n      sheet.set('A2', 4);\n      sheet.set('A3', '=A1/A2');\n      expect(sheet.get('A3')).toBe(25);\n    });\n\n    it('should respect operator precedence', () => {\n      sheet.set('A1', 2);\n      sheet.set('A2', 3);\n      sheet.set('A3', 4);\n      sheet.set('B1', '=A1+A2*A3');\n      expect(sheet.get('B1')).toBe(14); // 2 + 3*4 = 14, not 20\n    });\n\n    it('should handle parentheses', () => {\n      sheet.set('A1', 2);\n      sheet.set('A2'