is.arg());\n        }\n      }\n      this.expect('rparen');\n      return { type: 'functionCall', name, args };\n    }\n\n    if (token.type === 'cellRef') {\n      this.advance();\n      // Check if this is a range (cellRef ':' cellRef)\n      if (this.peek().type === 'colon') {\n        this.advance(); // consume ':'\n        const endToken = this.expect('cellRef');\n        return { type: 'range', start: token.value, end: endToken.value };\n      }\n      return { type: 'cellRef', ref: token.value };\n    }\n\n    if (token.type === 'lparen') {\n      this.advance();\n      const expr = this.expression();\n      this.expect('rparen');\n      return expr;\n    }\n\n    throw new Error(`Unexpected token: ${token.type} (${token.value})`);\n  }\n\n  private arg(): ASTNode {\n    // An argument can be a range or an expression\n    // We need to look ahead to check for range syntax (cellRef : cellRef)\n    if (this.peek().type === 'cellRef') {\n      const saved = this.pos;\n      const startToken = this.advance();\n      if (this.peek().type === 'colon') {\n        this.advance();\n        if (this.peek().type === 'cellRef') {\n          const endToken = this.advance();\n          return { type: 'range', start: startToken.value, end: endToken.value };\n        }\n      }\n      // Backtrack\n      this.pos = saved;\n    }\n    return this.expression();\n  }\n}\n\nexport function parseFormula(formula: string): ASTNode {\n  // Remove the leading '='\n  const expr = formula.startsWith('=') ? formula.slice(1) : formula;\n  const tokens = tokenize(expr);\n  const parser = new Parser(tokens);\n  return parser.parse();\n}\n\n// Extract all cell references from an AST (for dependency tracking)\nexport function extractCellRefs(node: ASTNode): string[] {\n  const refs: string[] = [];\n\n  function walk(n: ASTNode): void {\n    switch (n.type) {\n      case 'cellRef':\n        refs.push(n.ref);\n        break;\n      case 'range':\n        // Expand range to individual cell ref