+
+function parseFormula(formula: string): ASTNode {
+  const tokens = tokenize(formula);
+  const parser = new Parser(tokens);
+  return parser.parse();
+}
+
+// ---- Dependency Extraction ----
+
+function extractDependencies(ast: ASTNode): Set<string> {
+  const deps = new Set<string>();
+
+  function walk(node: ASTNode): void {
+    switch (node.type) {
+      case 'cellref':
+        deps.add(node.ref);
+        break;
+      case 'range':
+        for (const ref of expandRange(node.start, node.end)) {
+          deps.add(ref);
+        }
+        break;
+      case 'binop':
+        walk(node.left);
+        walk(node.right);
+        break;
+      case 'unary':
+        walk(node.operand);
+        break;
+      case 'call':
+        for (const arg of node.args) {
+          walk(arg);
+        }
+        break;
+      // number, string, boolean have no dependencies
+    }
+  }
+
+  walk(ast);
+  return deps;
+}
+
+// ---- Evaluation ----
+
+type CellValue = string | number | boolean | null;
+
+function evaluate(ast: ASTNode, getCellValue: (ref: string) => CellValue): CellValue {
+  switch (ast.type) {
+    case 'number':
+      return ast.value;
+    case 'string':
+      return ast.value;
+    case 'boolean':
+      return ast.value;
+    case 'cellref':
+      return getCellValue(ast.ref);
+    case 'range':
+      throw new Error('Range cannot be used outside of a function');
+    case 'unary': {
+      const operand = evaluate(ast.operand, getCellValue);
+      if (ast.op === '-') {
+        return typeof operand === 'number' ? -operand : null;
+      }
+      return operand;
+    }
+    case 'binop': {
+      const left = evaluate(ast.left, getCellValue);
+      const right = evaluate(ast.right, getCellValue);
+      return evalBinop(ast.op, left, right);
+    }
+    case 'call':
+      return evalFunction(ast.name, ast.args, getCellValue);
+  }
+}
+
+function evalBinop(op: string, left: CellValue, right: CellValue): CellValue {
+  const l = typeof left === 'number' ? left : 0;
+  const r = typeof right === 'number' ? right : 0;
+
+  switch (op) {
+    case '+': return l + r;
+    case '-': return l - r;
+    case '*': return l * r;
+    case '/': return r === 0 ? null : l / r;
+    case '>': return l > r;
+    case '<': return l < r;
+    case '>=': return l >= r;
+    case '<=': return l <= r;
+    case '=': return left === right;
+    case '<>': return left !== right;
+    default: return null;
+  }
+}
+
+function resolveRangeValues(node: ASTNode, getCellValue: (ref: string) => CellValue): CellValue[] {
+  if (node.type === 'range') {
+    const cells = expandRange(node.start, node.end);
+    return cells.map(ref => getCellValue(ref));
+  }
+  // Single value
+  return [evaluate(node, getCellValue)];
+}
+
+function evalFunction(name: string, args: ASTNode[], getCellValue: (ref: string) => CellValue): CellValue {
+  switch (name) {
+    case 'SUM': {
+      let sum = 0;
+      for (const arg of args) {
+        const values = resolveRangeValues(arg, getCellValue);
+        for (const v of values) {
+          if (typeof v === 'number') sum += v;
+        }
+      }
+      return sum;
+    }
+    case 'AVERAGE': {
+      let sum = 0;
+      let count = 0;
+      for (const arg of args) {
+        const values = resolveRangeValues(arg, getCellValue);
+        for (const v of values) {
+          if (typeof v === 'number') { sum += v; count++; }
+        }
+      }
+      return count === 0 ? null : sum / count;
+    }
+    case 'MIN': {
+      let min = Infinity;
+      let found = false;
+      for (const arg of args) {
+        const values = resolveRangeValues(arg, getCellValue);
+        for (const v of values) {
+          if (typeof v === 'number') { min = Math.min(min, v); found = true; }
+        }
+      }
+      return found ? min : null;
+    }
+    case 'MAX': {
+      let max = -Infinity;
+      let found = false;
+      for (const arg of args) {
+        const values = resolveRangeValues(arg, getCellValue);
+        for (const v of values) {
+          if (typeof v === 'number') { max = Math.max(max, v); found = true; }
+        }
+      }
+      return found ? max : null;
+    }
+    case 'COUNT': {
+      let count = 0;
+      for (const arg of args) {
+        const values = resolveRangeValues(arg, getCellValue);
+        for (const v of values) {
+          if (typeof v === 'number') count++;
+        }
+      }
+      return count;
+    }
+    case 'IF': {
+      if (args.length < 3) throw new Error('IF requires 3 arguments');
+      const condition = evaluate(args[0], getCellValue);
+      const isTruthy = condition === true || (typeof condition === 'number' && condition !== 0);
+      return isTruthy
+        ? evaluate(args[1], getCellValue)
+        : evaluate(args[2], getCellValue);
+    }
+    default:
+      throw new Error(`Unknown function: ${name}`);
+  }
+}
+
+// ---- Cell Data ----
+
+interface CellData {
+  rawValue: string | number | boolean;
+  formula: ASTNode | null;
+  computedValue: CellValue;
+  dependencies: Set<string>;
+}
+
+// ---- Spreadsheet (Dependency-Graph-Driven) ----
+
+export class Spreadsheet {
+  private cells: Map<string, CellData> = new Map();
+  // Reverse dependency map: for cell X, dependents.get(X) = set of cells that depend on X
