    expect(sheet.get('C1')).toBe(22);\n      expect(sheet.get('D1')).toBe(23);\n    });\n  });\n\n  describe('SUM function', () => {\n    it('should sum a column range', () => {\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', 30);\n      sheet.set('B1', '=SUM(A1:A3)');\n      expect(sheet.get('B1')).toBe(60);\n    });\n\n    it('should sum a row range', () => {\n      sheet.set('A1', 1);\n      sheet.set('B1', 2);\n      sheet.set('C1', 3);\n      sheet.set('D1', '=SUM(A1:C1)');\n      expect(sheet.get('D1')).toBe(6);\n    });\n\n    it('should sum a block range', () => {\n      sheet.set('A1', 1);\n      sheet.set('A2', 2);\n      sheet.set('B1', 3);\n      sheet.set('B2', 4);\n      sheet.set('C1', '=SUM(A1:B2)');\n      expect(sheet.get('C1')).toBe(10);\n    });\n\n    it('should ignore non-numeric values in SUM', () => {\n      sheet.set('A1', 10);\n      sheet.set('A2', 'hello');\n      sheet.set('A3', 30);\n      sheet.set('B1', '=SUM(A1:A3)');\n      expect(sheet.get('B1')).toBe(40);\n    });\n\n    it('should reactively update SUM', () => {\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('B1', '=SUM(A1:A2)');\n      expect(sheet.get('B1')).toBe(30);\n\n      sheet.set('A1', 50);\n      expect(sheet.get('B1')).toBe(70);\n    });\n  });\n\n  describe('AVERAGE function', () => {\n    it('should calculate average', () => {\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', 30);\n      sheet.set('B1', '=AVERAGE(A1:A3)');\n      expect(sheet.get('B1')).toBe(20);\n    });\n\n    it('should ignore non-numeric values', () => {\n      sheet.set('A1', 10);\n      sheet.set('A2', 'text');\n      sheet.set('A3', 30);\n      sheet.set('B1', '=AVERAGE(A1:A3)');\n      expect(sheet.get('B1')).toBe(20);\n    });\n  });\n\n  describe('MIN function', () => {\n    it('should find minimum value', () => {\n      sheet.set('A1', 30);\n      sheet.set('A2', 10);\n      sheet.set('A3', 20);\n      sheet.set('B1', '=MIN(A1:A3)');\n      expect(sheet.get('B1')).toBe(10);\n    });\n  });\n\n  describe('MAX function', () => {\n    it('should find maximum value', () => {\n      sheet.set('A1', 30);\n      sheet.set('A2', 10);\n      sheet.set('A3', 20);\n      sheet.set('B1', '=MAX(A1:A3)');\n      expect(sheet.get('B1')).toBe(30);\n    });\n  });\n\n  describe('COUNT function', () => {\n    it('should count numeric values', () => {\n      sheet.set('A1', 10);\n      sheet.set('A2', 'hello');\n      sheet.set('A3', 30);\n      sheet.set('A4', true);\n      sheet.set('B1', '=COUNT(A1:A4)');\n      expect(sheet.get('B1')).toBe(2);\n    });\n  });\n\n  describe('IF function', () => {\n    it('should return trueValue when condition is true', () => {\n      sheet.set('A1', 50);\n      sheet.set('B1', '=IF(A1>30, \"big\", \"small\")');\n      expect(sheet.get('B1')).toBe('big');\n    });\n\n    it('should return falseValue when condition is false', () => {\n      sheet.set('A1', 10);\n      sheet.set('B1', '=IF(A1>30, \"big\", \"small\")');\n      expect(sheet.get('B1')).toBe('small');\n    });\n\n    it('should reactively update IF result', () => {\n      sheet.set('A1', 50);\n      sheet.set('B1', '=IF(A1>30, \"big\", \"small\")');\n      expect(sheet.get('B1')).toBe('big');\n\n      sheet.set('A1', 10);\n      expect(sheet.get('B1')).toBe('small');\n    });\n\n    it('should work with numeric results', () => {\n      sheet.set('A1', 5);\n      sheet.set('B1', '=IF(A1>3, A1*2, A1)');\n      expect(sheet.get('B1')).toBe(10);\n    });\n  });\n\n  describe('circular reference detection', () => {\n    it('should detect direct self-reference', () => {\n      expect(() => sheet.set('A1', '=A1')).toThrow(/[Cc]ircular/);\n    });\n\n    it('should detect simple circular dependency', () => {\n      sheet.set('A1', '=B1');\n      expect(() => sheet.set('B1', '=A1')).toThrow(/[Cc]ircular/);\n    });\n\n    it('should detect indirect circular dependency', () => {\n      sheet.set('A1', '=B1');\n      sheet.set('B1', '=C1');\n      expect(() => sheet.set('C1', '=A1')).toThrow(/[Cc]ircular/);\n    });\n\n    it('should allow non-circular dependencies', () => {\n      sheet.set('A1', 10);\n      sheet.set('B1', '=A1');\n      sheet.set('C1', '=B1');\n      expect(sheet.get('C1')).toBe(10);\n    });\n\n    it('should not throw when removing a dependency that would have been circular', () => {\n      sheet.set('A1', '=B1');\n      sheet.set('A1', 10); // overwrite with non-formula\n      expect(() => sheet.set('B1', '=A1')).not.toThrow();\n      expect(sheet.get('B1')).toBe(10);\n    });\n  });\n\n  describe('getDisplay', () => {\n    it('should display numbers', () => {\n      sheet.set('A1', 42);\n      expect(sheet.getDisplay('A1')).toBe('42');\n    });\n\n    it('should display strings', () => {\n      sheet.set('A1', 'hello');\n      expect(sheet.getDisplay('A1')).toBe('hello');\n    });\n\n    it('should display booleans', () => {\n      sheet.set('A1', true);\n      expect(sheet.getDisplay('A1')).toBe('TRUE');\n      sheet.set('A2', false);\n      expect(sheet.getDisplay('A2')).toBe('FALSE');\n    });\n\n    it('should display empty string for empty cells', () => {\n      expect(sheet.getDisplay('A1')).toBe('');\n    });\n\n    it('should display computed formula results', () => {\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', '=A1+A2');\n      expect(sheet.getDisplay('A3')).toBe('30');\n    });\n  });\n\n  describe('getCells', () => {\n    it('should return all non-empty cells', () => {\n      sheet.set('A1', 10);\n      sheet.set('B1', 20);\n      sheet.set('C1', '=A1+B1');\n      const cells = sheet.getCells();\n      expect(cells.size).toBe(3);\n      expect(cells.get('A1')).toBe(10);\n      expect(cells.get('B1')).toBe(20);\n      expect(cells.get('C1')).toBe(30);\n    });\n\n    it('should return empty map for empty spreadsheet', () => {\n      const cells = sheet.getCells();\n      expect(cells.size).toBe(0);\n    });\n  });\n\n  describe('example usage from spec', () => {\n    it('should match the example in the spec', () => {\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', '=A1+A2');\n      expect(sheet.get('A3')).toBe(30);\n      expect(sheet.getDisplay('A3')).toBe('30');\n\n      sheet.set('A1', 50);\n      expect(sheet.get('A3')).toBe(70);\n\n      sheet.set('B1', '=SUM(A1:A2)');\n      expect(sheet.get('B1')).toBe(70);\n\n      sheet.set('C1', '=IF(A1>30, \"big\", \"small\")');\n      expect(sheet.get('C1')).toBe('big');\n    });\n  });\n\n  describe('edge cases', () => {\n    it('should handle referencing empty cells as 0 in arithmetic', () => {\n      sheet.set('A1', '=B1+10');\n      expect(sheet.get('A1')).toBe(10);\n    });\n\n    it('should handle complex nested formulas', () => {\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', 30);\n      sheet.set('B1', '=SUM(A1:A3)*2');\n      expect(sheet.get('B1')).toBe(120);\n    });\n\n    it('should handle formula with multiple operations', () => {\n      sheet.set('A1', 2);\n      sheet.set('A2', 3);\n      sheet.set('A3', 4);\n      sheet.set('B1', '=A1+A2*A3');\n      expect(sheet.get('B1')).toBe(14); // operator precedence: 2 + (3*4)\n    });\n\n    it('should handle division by zero', () => {\n      sheet.set('A1', 10);\n      sheet.set('A2', 0);\n      sheet.set('B1', '=A1/A2');\n      expect(sheet.get('B1')).toBeNull();\n    });\n\n    it('should handle deeply nested reactive chains', () => {\n      sheet.set('A1', 1);\n      sheet.set('A2', '=A1+1');\n      sheet.set('A3', '=A2+1');\n      sheet.set('A4', '=A3+1');\n      sheet.set('A5', '=A4+1');\n      expect(sheet.get('A5')).toBe(5);\n\n      sheet.set('A1', 10);\n      expect(sheet.get('A5')).toBe(14);\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
