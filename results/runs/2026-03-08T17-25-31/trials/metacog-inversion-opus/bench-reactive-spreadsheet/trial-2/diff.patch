+    if (ch === ' ' || ch === '\t') {
+      i++;
+      continue;
+    }
+
+    if (ch === '"') {
+      let str = '';
+      i++; // skip opening quote
+      while (i < formula.length && formula[i] !== '"') {
+        str += formula[i];
+        i++;
+      }
+      if (i < formula.length) i++; // skip closing quote
+      tokens.push({ type: TokenType.String, value: str });
+      continue;
+    }
