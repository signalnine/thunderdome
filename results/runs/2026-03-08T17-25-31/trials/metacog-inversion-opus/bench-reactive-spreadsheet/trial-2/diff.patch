+      }
+    }
+
+    // Add new reverse dependencies
+    for (const dep of newDeps) {
+      if (!this.dependents.has(dep)) {
+        this.dependents.set(dep, new Set());
+      }
+      this.dependents.get(dep)!.add(ref);
+    }
+
+    // Compute value
+    const computedValue = formula
+      ? evaluate(formula, (r) => this.getComputedValue(r))
+      : (typeof value === 'string' && !value.startsWith('=') ? value : value);
+
+    const cellData: CellData = {
+      rawValue: value,
+      formula,
+      computedValue: computedValue as CellValue,
+      dependencies: newDeps,
+    };
+    this.cells.set(ref, cellData);
+
+    // Reactively update all transitive dependents in topological order
+    this.propagate(ref);
+  }
+
+  get(cell: string): string | number | boolean | null {
+    const ref = normalizeCellRef(cell);
+    return this.getComputedValue(ref);
+  }
+
+  getDisplay(cell: string): string {
+    const value = this.get(cell);
+    if (value === null) return '';
+    if (typeof value === 'boolean') return value ? 'TRUE' : 'FALSE';
+    return String(value);
+  }
+
+  getCells(): Map<string, CellValue> {
+    const result = new Map<string, CellValue>();
+    for (const [ref, data] of this.cells) {
+      result.set(ref, data.computedValue);
+    }
+    return result;
+  }
+
+  private getComputedValue(ref: string): CellValue {
+    const data = this.cells.get(ref);
+    if (!data) return null;
+    return data.computedValue;
+  }
+
+  private checkCircular(target: string, newDeps: Set<string>): void {
+    // DFS from each dependency to see if we can reach `target`
+    const visited = new Set<string>();
+
+    const dfs = (current: string): boolean => {
+      if (current === target) return true;
+      if (visited.has(current)) return false;
+      visited.add(current);
+
+      // Follow the dependencies of `current`
+      const cellData = this.cells.get(current);
+      if (cellData) {
+        for (const dep of cellData.dependencies) {
+          if (dfs(dep)) return true;
+        }
+      }
+      return false;
+    };
+
+    for (const dep of newDeps) {
+      if (dep === target) {
+        throw new Error(`Circular reference detected: ${target} references itself`);
+      }
+      if (dfs(dep)) {
+        throw new Error(`Circular reference detected involving ${target}`);
+      }
+    }
+  }
+
+  private propagate(changedCell: string): void {
+    // Collect all transitive dependents
+    const toRecompute: string[] = [];
+    const visited = new Set<string>();
+
+    const collectDependents = (cell: string): void => {
+      const deps = this.dependents.get(cell);
+      if (!deps) return;
+      for (const dep of deps) {
+        if (!visited.has(dep)) {
+          visited.add(dep);
+          toRecompute.push(dep);
+          collectDependents(dep);
+        }
+      }
+    };
+
+    collectDependents(changedCell);
+
+    // Topological sort of the dependents for correct evaluation order
+    // We need to recompute in an order where each cell's dependencies are computed first
+    const sorted = this.topologicalSort(toRecompute);
+
+    // Recompute each cell
+    for (const ref of sorted) {
+      const cellData = this.cells.get(ref);
+      if (cellData && cellData.formula) {
+        cellData.computedValue = evaluate(cellData.formula, (r) => this.getComputedValue(r));
+      }
+    }
+  }
+
+  private topologicalSort(cells: string[]): string[] {
+    const cellSet = new Set(cells);
+    const visited = new Set<string>();
+    const result: string[] = [];
+
+    const visit = (cell: string): void => {
+      if (visited.has(cell)) return;
+      if (!cellSet.has(cell)) return;
+      visited.add(cell);
+
+      // Visit dependencies first (that are also in the set)
+      const cellData = this.cells.get(cell);
+      if (cellData) {
+        for (const dep of cellData.dependencies) {
+          visit(dep);
+        }
+      }
+
+      result.push(cell);
+    };
+
+    for (const cell of cells) {
+      visit(cell);
+    }
+
+    return result;
+  }
+}
