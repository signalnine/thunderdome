+import { describe, it, expect, beforeEach } from 'vitest';
+import { Spreadsheet } from './index.js';
+
+describe('Spreadsheet', () => {
+  let sheet: Spreadsheet;
+
+  beforeEach(() => {
+    sheet = new Spreadsheet();
+  });
+
+  describe('basic values', () => {
+    it('should store and retrieve numbers', () => {
+      sheet.set('A1', 42);
+      expect(sheet.get('A1')).toBe(42);
+    });
+
+    it('should store and retrieve strings', () => {
+      sheet.set('A1', 'hello');
+      expect(sheet.get('A1')).toBe('hello');
+    });
+
+    it('should store and retrieve booleans', () => {
+      sheet.set('A1', true);
+      expect(sheet.get('A1')).toBe(true);
+      sheet.set('A2', false);
+      expect(sheet.get('A2')).toBe(false);
+    });
+
+    it('should return null for empty cells', () => {
+      expect(sheet.get('A1')).toBeNull();
+    });
+
+    it('should store floating point numbers', () => {
+      sheet.set('A1', 3.14);
+      expect(sheet.get('A1')).toBe(3.14);
+    });
+
+    it('should overwrite existing values', () => {
+      sheet.set('A1', 10);
+      sheet.set('A1', 20);
+      expect(sheet.get('A1')).toBe(20);
+    });
+  });
+
+  describe('cell references (case insensitive)', () => {
+    it('should handle lowercase cell references', () => {
+      sheet.set('a1', 42);
+      expect(sheet.get('a1')).toBe(42);
+      expect(sheet.get('A1')).toBe(42);
+    });
+
+    it('should handle multi-letter columns', () => {
+      sheet.set('AA1', 100);
+      expect(sheet.get('AA1')).toBe(100);
+    });
+
+    it('should handle large row numbers', () => {
+      sheet.set('Z100', 999);
+      expect(sheet.get('Z100')).toBe(999);
+    });
+  });
+
+  describe('simple formulas', () => {
+    it('should evaluate addition', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should evaluate subtraction', () => {
+      sheet.set('A1', 30);
+      sheet.set('A2', 12);
+      sheet.set('A3', '=A1-A2');
+      expect(sheet.get('A3')).toBe(18);
+    });
+
+    it('should evaluate multiplication', () => {
+      sheet.set('A1', 6);
+      sheet.set('A2', 7);
+      sheet.set('A3', '=A1*A2');
+      expect(sheet.get('A3')).toBe(42);
+    });
+
+    it('should evaluate division', () => {
+      sheet.set('A1', 100);
+      sheet.set('A2', 4);
+      sheet.set('A3', '=A1/A2');
+      expect(sheet.get('A3')).toBe(25);
+    });
+
+    it('should handle parentheses', () => {
+      sheet.set('A1', 2);
+      sheet.set('B1', 3);
+      sheet.set('C1', '=(A1+B1)*2');
+      expect(sheet.get('C1')).toBe(10);
+    });
+
+    it('should handle formulas with literal numbers', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', '=A1+5');
+      expect(sheet.get('A2')).toBe(15);
+    });
+
+    it('should handle unary minus', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', '=-A1');
+      expect(sheet.get('A2')).toBe(-10);
+    });
+
+    it('should handle comparison operators', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('B1', '=A1>A2');
+      sheet.set('B2', '=A1<A2');
+      sheet.set('B3', '=A1>=10');
+      sheet.set('B4', '=A1<=5');
+      sheet.set('B5', '=A1=10');
+      sheet.set('B6', '=A1<>A2');
+      expect(sheet.get('B1')).toBe(false);
+      expect(sheet.get('B2')).toBe(true);
+      expect(sheet.get('B3')).toBe(true);
+      expect(sheet.get('B4')).toBe(false);
+      expect(sheet.get('B5')).toBe(true);
+      expect(sheet.get('B6')).toBe(true);
+    });
+  });
+
+  describe('reactive updates', () => {
+    it('should update dependent cells when a source changes', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.get('A3')).toBe(30);
+
+      sheet.set('A1', 50);
+      expect(sheet.get('A3')).toBe(70);
+    });
+
+    it('should handle transitive dependencies', () => {
+      sheet.set('A1', 5);
+      sheet.set('A2', '=A1*2');
+      sheet.set('A3', '=A2+10');
+      expect(sheet.get('A3')).toBe(20);
+
+      sheet.set('A1', 10);
+      expect(sheet.get('A2')).toBe(20);
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should handle diamond dependencies', () => {
+      sheet.set('A1', 10);
+      sheet.set('B1', '=A1+1');
+      sheet.set('C1', '=A1+2');
+      sheet.set('D1', '=B1+C1');
+      expect(sheet.get('D1')).toBe(23);
+
+      sheet.set('A1', 20);
+      expect(sheet.get('B1')).toBe(21);
+      expect(sheet.get('C1')).toBe(22);
+      expect(sheet.get('D1')).toBe(43);
+    });
+
+    it('should update when overwriting a formula with a value', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', '=A1+5');
+      expect(sheet.get('A2')).toBe(15);
+
+      sheet.set('A2', 99);
+      expect(sheet.get('A2')).toBe(99);
+
+      // Changing A1 should no longer affect A2
+      sheet.set('A1', 100);
+      expect(sheet.get('A2')).toBe(99);
+    });
+
+    it('should update when overwriting a value with a formula', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      expect(sheet.get('A2')).toBe(20);
+
+      sheet.set('A2', '=A1*3');
+      expect(sheet.get('A2')).toBe(30);
+
+      sheet.set('A1', 5);
+      expect(sheet.get('A2')).toBe(15);
+    });
+
+    it('should handle multiple dependents of same cell', () => {
+      sheet.set('A1', 10);
+      sheet.set('B1', '=A1+1');
+      sheet.set('C1', '=A1+2');
+      sheet.set('D1', '=A1+3');
+
+      sheet.set('A1', 20);
+      expect(sheet.get('B1')).toBe(21);
+      expect(sheet.get('C1')).toBe(22);
+      expect(sheet.get('D1')).toBe(23);
+    });
+  });
+
+  describe('SUM function', () => {
+    it('should sum a column range', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', 30);
+      sheet.set('B1', '=SUM(A1:A3)');
+      expect(sheet.get('B1')).toBe(60);
+    });
+
+    it('should sum a row range', () => {
+      sheet.set('A1', 1);
+      sheet.set('B1', 2);
+      sheet.set('C1', 3);
+      sheet.set('D1', '=SUM(A1:C1)');
+      expect(sheet.get('D1')).toBe(6);
+    });
+
+    it('should sum a block range', () => {
+      sheet.set('A1', 1);
+      sheet.set('A2', 2);
+      sheet.set('B1', 3);
+      sheet.set('B2', 4);
+      sheet.set('C1', '=SUM(A1:B2)');
+      expect(sheet.get('C1')).toBe(10);
+    });
+
+    it('should ignore non-numeric values in SUM', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 'hello');
+      sheet.set('A3', 30);
+      sheet.set('B1', '=SUM(A1:A3)');
+      expect(sheet.get('B1')).toBe(40);
+    });
+
+    it('should reactively update SUM', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('B1', '=SUM(A1:A2)');
+      expect(sheet.get('B1')).toBe(30);
+
+      sheet.set('A1', 50);
+      expect(sheet.get('B1')).toBe(70);
+    });
+  });
+
+  describe('AVERAGE function', () => {
+    it('should calculate average', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', 30);
+      sheet.set('B1', '=AVERAGE(A1:A3)');
+      expect(sheet.get('B1')).toBe(20);
+    });
+
+    it('should ignore non-numeric values', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 'text');
+      sheet.set('A3', 30);
+      sheet.set('B1', '=AVERAGE(A1:A3)');
+      expect(sheet.get('B1')).toBe(20);
+    });
+  });
+
+  describe('MIN function', () => {
+    it('should find minimum value', () => {
+      sheet.set('A1', 30);
+      sheet.set('A2', 10);
+      sheet.set('A3', 20);
+      sheet.set('B1', '=MIN(A1:A3)');
+      expect(sheet.get('B1')).toBe(10);
+    });
+  });
+
+  describe('MAX function', () => {
+    it('should find maximum value', () => {
+      sheet.set('A1', 30);
+      sheet.set('A2', 10);
+      sheet.set('A3', 20);
+      sheet.set('B1', '=MAX(A1:A3)');
+      expect(sheet.get('B1')).toBe(30);
+    });
+  });
+
+  describe('COUNT function', () => {
+    it('should count numeric values', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 'hello');
+      sheet.set('A3', 30);
+      sheet.set('A4', true);
+      sheet.set('B1', '=COUNT(A1:A4)');
+      expect(sheet.get('B1')).toBe(2);
+    });
+  });
