ing): Token[] {\n  const tokens: Token[] = [];\n  let i = 0;\n\n  while (i < formula.length) {\n    const ch = formula[i];\n\n    if (ch === ' ' || ch === '\\t') {\n      i++;\n      continue;\n    }\n\n    if (ch === '\"') {\n      let str = '';\n      i++; // skip opening quote\n      while (i < formula.length && formula[i] !== '\"') {\n        str += formula[i];\n        i++;\n      }\n      if (i < formula.length) i++; // skip closing quote\n      tokens.push({ type: TokenType.String, value: str });\n      continue;\n    }\n\n    if (ch === '(') {\n      tokens.push({ type: TokenType.LParen, value: '(' });\n      i++;\n      continue;\n    }\n    if (ch === ')') {\n      tokens.push({ type: TokenType.RParen, value: ')' });\n      i++;\n      continue;\n    }\n    if (ch === ',') {\n      tokens.push({ type: TokenType.Comma, value: ',' });\n      i++;\n      continue;\n    }\n    if (ch === ':') {\n      tokens.push({ type: TokenType.Colon, value: ':' });\n      i++;\n      continue;\n    }\n\n    // Two-char operators\n    if (i + 1 < formula.length) {\n      const two = formula.slice(i, i + 2);\n      if (two === '>=' || two === '<=' || two === '<>') {\n        tokens.push({ type: TokenType.Operator, value: two });\n        i += 2;\n        continue;\n      }\n    }\n\n    if (ch === '+' || ch === '-' || ch === '*' || ch === '/' || ch === '>' || ch === '<' || ch === '=') {\n      tokens.push({ type: TokenType.Operator, value: ch });\n      i++;\n      continue;\n    }\n\n    // Numbers\n    if ((ch >= '0' && ch <= '9') || (ch === '.' && i + 1 < formula.length && formula[i + 1] >= '0' && formula[i + 1] <= '9')) {\n      let num = '';\n      while (i < formula.length && ((formula[i] >= '0' && formula[i] <= '9') || formula[i] === '.')) {\n        num += formula[i];\n        i++;\n      }\n      tokens.push({ type: TokenType.Number, value: num });\n      continue;\n    }\n\n    // Identifiers: cell references, function names, booleans\n    if ((ch >= 'A' && ch <= 'Z') || (ch >= 'a' && ch <= 'z')) {\n      let ident = '';\n      while (i < formula.length && ((formula[i] >= 'A' && formula[i] <= 'Z') || (formula[i] >= 'a' && formula[i] <= 'z') || (formula[i] >= '0' && formula[i] <= '9'))) {\n        ident += formula[i];\n        i++;\n      }\n      const upper = ident.toUpperCase();\n      if (upper === 'TRUE' || upper === 'FALSE') {\n        tokens.push({ type: TokenType.Boolean, value: upper });\n      } else if (i < formula.length && formula[i] === '(') {\n        // It's a function name\n        tokens.push({ type: TokenType.Function, value: upper });\n      } else if (/^[A-Z]+\\d+$/i.test(ident)) {\n        tokens.push({ type: TokenType.CellRef, value: upper });\n      } else {\n        // Treat as a function name anyway (for cases where parenthesis follows later)\n        tokens.push({ type: TokenType.Function, value: upper });\n      }\n      continue;\n    }\n\n    // Skip unknown characters\n    i++;\n  }\n\n  tokens.push({ type: TokenType.EOF, value: '' });\n  return tokens;\n}\n\n// ---- AST ----\n\ntype ASTNode =\n  | { type: 'number'; value: number }\n  | { type: 'string'; value: string }\n  | { type: 'boolean'; value: boolean }\n  | { type: 'cellref'; ref: string }\n  | { type: 'range'; start: string; end: string }\n  | { type: 'binop'; op: string; left: ASTNode; right: ASTNode }\n  | { type: 'unary'; op: string; operand: ASTNode }\n  | { type: 'call'; name: string; args: ASTNode[] };\n\n// ---- Parser (recursive descent) ----\n\nclass Parser {\n  private tokens: Token[];\n  private pos: number;\n\n  constructor(tokens: Token[]) {\n    this.tokens = tokens;\n    this.pos = 0;\n  }\n\n  private peek(): Token {\n    return this.tokens[this.pos];\n  }\n\n  private consume(): Token {\n    return this.tokens[this.pos++];\n  }\n\n  private expect(type: TokenType): Token {\n    const tok = this.consume();\n    if (tok.type !== type) {\n      throw new Error(`Expected token type ${type}, got ${tok.type} (${tok.value})`);\n    }\n    return tok;\n  }\n\n  parse(): ASTNode {\n    const node = this.parseComparison();\n    return node;\n  }\n\n  private parseComparison(): ASTNode {\n    let left = this.parseAddSub();\n    while (\n      this.peek().type === TokenType.Operator &&\n      ['>', '<', '>=', '<=', '=', '<>'].includes(this.peek().value)\n    ) {\n      const op = this.consume().value;\n      const right = this.parseAddSub();\n      left = { type: 'binop', op, left, right };\n    }\n    return left;\n  }\n\n  private parseAddSub(): ASTNode {\n    let left = this.parseMulDiv();\n    while (\n      this.peek().type === TokenType.Operator &&\n      (this.peek().value === '+' || this.peek().value === '-')\n    ) {\n      const op = this.consume().value;\n      const right = this.parseMulDiv();\n      left = { type: 'binop', op, left, right };\n    }\n    return left;\n  }\n\n  private parseMulDiv(): ASTNode {\n    let left = this.parseUnary();\n    while (\n      this.peek().type === TokenType.Operator &&\n      (this.peek().value === '*' || this.peek().value === '/')\n    ) {\n      const op = this.consume().value;\n      const right = this.parseUnary();\n      left = { type: 'binop', op, left, right };\n    }\n    return left;\n  }\n\n  private parseUnary(): ASTNode {\n    if (this.peek().type === TokenType.Operator && (this.peek().value === '-' || this.peek().value === '+')) {\n      const op = this.consume().value;\n      const operand = this.parseUnary();\n      if (op === '-') {\n        return { type: 'unary', op: '-', operand };\n      }\n      return operand;\n    }\n    return this.parsePrimary();\n  }\n\n  private parsePrimary(): ASTNode {\n    const tok = this.peek();\n\n    if (tok.type === TokenType.Number) {\n      this.consume();\n      return { type: 'number', value: parseFloat(tok.value) };\n    }\n\n    if (tok.type === TokenType.String) {\n      this.consume();\n      return { type: 'string', value: tok.value };\n    }\n\n    if (tok.type === TokenType.Boolean) {\n      this.consume();\n      return { type: 'boolean', value: tok.value === 'TRUE' };\n    }\n\n    if (tok.type === TokenType.Function) {\n      const name = this.consume().value;\n      this.expect(TokenType.LParen);\n      const args: ASTNode[] = [];\n      if (this.peek().type !== TokenType.RParen) {\n        args.push(this.parseArg());\n        while (this.peek().type === TokenType.Comma) {\n          this.consume();\n          args.push(this.parseArg());\n        }\n      }\n      this.expect(TokenType.RParen);\n      return { type: 'call', name, args };\n    }\n\n    if (tok.type === TokenType.CellRef) {\n      const ref = this.consume().value;\n      // Check if this is a range (A1:B2)\n      if (this.peek().type === TokenType.Colon) {\n        this.consume(); // consume ':'\n        const endRef = this.expect(TokenType.CellRef).value;\n        return { type: 'range', start: ref, end: endRef };\n      }\n      return { type: 'cellref', ref };\n    }\n\n    if (tok.type === TokenType.LParen) {\n      this.consume();\n      const node = this.parseComparison();\n      this.expect(TokenType.RParen);\n      return node;\n    }\n\n    throw new Error(`Unexpected token: ${tok.type} (${tok.value})`);\n  }\n\n  private parseArg(): ASTNode {\n    // An argument can be a range or an expression\n    const node = this.parseComparison();\n    // Check if this cell ref is followed by ':' to make a range\n    if (node.type === 'cellref' && this.peek().type === TokenType.Colon) {\n      this.consume(); // consume ':'\n      const endRef = this.expect(TokenType.CellRef).value;\n      return { type: 'range', start: node.ref, end: endRef };\n    }\n    return node;\n  }\n}\n\nfunction parseFormula(formula: string): ASTNode {\n  const tokens = tokenize(formula);\n  const parser = new Parser(tokens);\n  return parser.parse();\n}\n\n// ---- Dependency Extraction ----\n\nfunction extractDependencies(ast: ASTNode): Set<string> {\n  const deps = new Set<string>();\n\n  function walk(node: ASTNode): void {\n    switch (node.type) {\n      case 'cellref':\n        deps.add(node.ref);\n        break;\n      case 'range':\n        for (const ref of expandRange(node.start, node.end)) {\n          deps.add(ref);\n        }\n        break;\n      case 'binop':\n        walk(node.left);\n        walk(node.right);\n        break;\n      case 'unary':\n        walk(node.operand);\n        break;\n      case 'call':\n        for (const arg of node.args) {\n          walk(arg);\n        }\n        break;\n      // number, string, boolean have no dependencies\n    }\n  }\n\n  walk(ast);\n  return deps;\n}\n\n// ---- Evaluation ----\n\ntype CellValue = string | number | boolean | null;\n\nfunction evaluate(ast: ASTNode, getCellValue: (ref: string) => CellValue): CellValue {\n  switch (ast.type) {\n    case 'number':\n      return ast.value;\n    case 'string':\n      return ast.value;\n    case 'boolean':\n      return ast.value;\n    case 'cellref':\n      return getCellValue(ast.ref);\n    case 'range':\n      throw new Error('Range cannot be used outside of a function');\n    case 'unary': {\n      const operand = evaluate(ast.operand, getCellValue);\n      if (ast.op === '-') {\n        return typeof operand === 'number' ? -operand : null;\n      }\n      return operand;\n    }\n    case 'binop': {\n      const left = evaluate(ast.left, getCellValue);\n      const right = evaluate(ast.right, getCellValue);\n      return evalBinop(ast.op, left, right);\n    }\n    case 'call':\n      return evalFunction(ast.name, ast.args, getCellValue);\n  }\n}\n\nfunction evalBinop(op: string, left: CellValue, right: CellValue): CellValue {\n  const l = typeof left === 'number' ? left : 0;\n  const r = typeof right === 'number' ? right : 0;\n\n  switch (op) {\n    case '+': return l + r;\n    case '-': return l - r;\n    case '*': return l * r;\n    case '/': return r === 0 ? null : l / r;\n    case '>': return l > r;\n    case '<': return l < r;\n    case '>=': retu