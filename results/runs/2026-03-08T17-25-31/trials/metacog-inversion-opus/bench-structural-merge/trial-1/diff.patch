eted document', () => {\n      const store = new DocumentStore();\n      store.create('doc1', { name: 'test' });\n      store.delete('doc1');\n      expect(() => store.delete('doc1')).toThrow();\n    });\n\n    it('should deep clone on storage (no mutation)', () => {\n      const store = new DocumentStore();\n      const content = { name: 'test', nested: { value: 1 } };\n      store.create('doc1', content);\n      content.name = 'mutated';\n      content.nested.value = 999;\n      expect(store.get('doc1')).toEqual({ name: 'test', nested: { value: 1 } });\n    });\n\n    it('should deep clone on retrieval (no mutation)', () => {\n      const store = new DocumentStore();\n      store.create('doc1', { name: 'test', nested: { value: 1 } });\n      const retrieved = store.get('doc1') as Record<string, unknown>;\n      retrieved.name = 'mutated';\n      expect(store.get('doc1')).toEqual({ name: 'test', nested: { value: 1 } });\n    });\n  });\n\n  describe('Version history', () => {\n    it('should track versions on create', () => {\n      const store = new DocumentStore();\n      store.create('doc1', { name: 'v1' });\n      const history = store.getHistory('doc1');\n      expect(history).toHaveLength(1);\n      expect(history[0].content).toEqual({ name: 'v1' });\n    });\n\n    it('should track versions on update', () => {\n      const store = new DocumentStore();\n      store.create('doc1', { name: 'v1' });\n      store.update('doc1', { name: 'v2' });\n      store.update('doc1', { name: 'v3' });\n      const history = store.getHistory('doc1');\n      expect(history).toHaveLength(3);\n      expect(history[0].content).toEqual({ name: 'v1' });\n      expect(history[1].content).toEqual({ name: 'v2' });\n      expect(history[2].content).toEqual({ name: 'v3' });\n    });\n\n    it('should return versions in chronological order', () => {\n      const store = new DocumentStore();\n      store.create('doc1', { name: 'v1' });\n      store.update('doc1', { name: 'v2' });\n      co