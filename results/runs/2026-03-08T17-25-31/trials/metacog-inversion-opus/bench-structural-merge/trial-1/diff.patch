= branch.documents.get(id);\n   264→    if (!doc) {\n   265→      throw new Error(`Document \"${id}\" does not exist`);\n   266→    }\n   267→    const version = doc.versions.find(v => v.id === versionId);\n   268→    if (!version) {\n   269→      throw new Error(`Version \"${versionId}\" does not exist for document \"${id}\"`);\n   270→    }\n   271→    return deepClone(version.content);\n   272→  }\n   273→\n   274→  // --- Branching ---\n   275→\n   276→  createBranch(name: string, fromBranch?: string): void {\n   277→    if (this.branches.has(name)) {\n   278→      throw new Error(`Branch \"${name}\" already exists`);\n   279→    }\n   280→\n   281→    const sourceBranchName = fromBranch ?? this.currentBranch;\n   282→    const sourceBranch = this.branches.get(sourceBranchName);\n   283→    if (!sourceBranch) {\n   284→      throw new Error(`Branch \"${sourceBranchName}\" does not exist`);\n   285→    }\n   286→\n   287→    // Deep clone all documents from the source branch\n   288→    const newDocuments = new Map<string, DocumentEntry>();\n   289→    const forkSnapshot = new Map<string, object | null>();\n   290→\n   291→    for (const [docId, entry] of sourceBranch.documents) {\n   292→      newDocuments.set(docId, {\n   293→        content: deepClone(entry.content),\n   294→        versions: entry.versions.map(v => ({\n   295→          id: v.id,\n   296→          timestamp: v.timestamp,\n   297→          content: deepClone(v.content),\n   298→        })),\n   299→        deleted: entry.deleted,\n   300→      });\n   301→\n   302→      // Snapshot: store the content at fork time (null if deleted)\n   303→      forkSnapshot.set(docId, entry.deleted ? null : deepClone(entry.content));\n   304→    }\n   305→\n   306→    // Also store the fork snapshot on the source branch side for the merge base\n   307→    // We need to remember what the source branch looked like at fork time\n   308→    this.branches.set(name, {\n   309→      documents: newDocuments,\n   310→  