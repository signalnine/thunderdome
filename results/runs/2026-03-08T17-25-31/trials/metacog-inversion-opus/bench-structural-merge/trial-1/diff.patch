--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,477 @@
+// Versioned Document Store with Structural Merge
+
+type JsonValue = string | number | boolean | null | JsonObject | JsonValue[];
+type JsonObject = { [key: string]: JsonValue };
+
+export interface Version {
+  id: string;
+  timestamp: number;
+  content: object;
+}
+
+export interface Conflict {
+  documentId: string;
+  path: string;
+  base: JsonValue | undefined;
+  ours: JsonValue | undefined;
+  theirs: JsonValue | undefined;
+}
+
+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+interface DocumentEntry {
+  content: object;
+  versions: Version[];
+  deleted: boolean;
+}
+
+interface BranchData {
+  documents: Map<string, DocumentEntry>;
+  forkSnapshot: Map<string, object | null>;
+  parentBranch: string | null;
+}
+
+function deepClone<T>(obj: T): T {
+  if (obj === null || obj === undefined || typeof obj !== 'object') {
+    return obj;
+  }
+  return JSON.parse(JSON.stringify(obj));
+}
+
+function generateId(): string {
+  return Math.random().toString(36).substring(2) + Date.now().toString(36);
+}
+
+function allKeys(...objects: (JsonObject | null | undefined)[]): Set<string> {
+  const keys = new Set<string>();
+  for (const obj of objects) {
+    if (obj && typeof obj === 'object' && !Array.isArray(obj)) {
+      for (const key of Object.keys(obj)) {
+        keys.add(key);
+      }
+    }
+  }
+  return keys;
+}
+
+function deepEqual(a: JsonValue | undefined, b: JsonValue | undefined): boolean {
+  if (a === b) return true;
+  if (a === null || b === null) return a === b;
+  if (a === undefined || b === undefined) return a === b;
+  if (typeof a !== typeof b) return false;
+  if (typeof a !== 'object') return a === b;
+  if (Array.isArray(a) !== Array.isArray(b)) return false;
+  if (Array.isArray(a) && Array.isArray(b)) {
+    if (a.length !== b.length) return false;
+    for (let i = 0; i < a.length; i++) {
+      if (!deepEqual(a[i], b[i])) return false;
+    }
+    return true;
+  }
+  const objA = a as JsonObject;
+  const objB = b as JsonObject;
+  const keysA = Object.keys(objA);
+  const keysB = Object.keys(objB);
+  if (keysA.length !== keysB.length) return false;
+  for (const key of keysA) {
+    if (!Object.prototype.hasOwnProperty.call(objB, key)) return false;
+    if (!deepEqual(objA[key], objB[key])) return false;
+  }
+  return true;
+}
+
+function toJsonObject(val: object | null | undefined): JsonObject {
+  if (val && typeof val === 'object' && !Array.isArray(val)) {
+    return val as JsonObject;
+  }
+  return {};
+}
+
+function threeWayMerge(
+  base: object | null | undefined,
+  ours: object | null | undefined,
+  theirs: object | null | undefined,
+  documentId: string,
+  pathPrefix: string,
+  conflicts: Conflict[]
+): object {
+  const baseObj = toJsonObject(base);
+  const oursObj = toJsonObject(ours);
+  const theirsObj = toJsonObject(theirs);
+
+  const result: JsonObject = {};
+  const keys = allKeys(baseObj, oursObj, theirsObj);
+
+  for (const key of keys) {
+    const baseVal: JsonValue | undefined = baseObj[key];
+    const oursVal: JsonValue | undefined = oursObj[key];
+    const theirsVal: JsonValue | undefined = theirsObj[key];
+    const currentPath = pathPrefix ? `${pathPrefix}.${key}` : key;
+
+    const oursChanged = !deepEqual(baseVal, oursVal);
+    const theirsChanged = !deepEqual(baseVal, theirsVal);
+
+    if (!oursChanged && !theirsChanged) {
+      if (baseVal !== undefined) {
+        result[key] = deepClone(baseVal);
+      }
+    } else if (oursChanged && !theirsChanged) {
+      if (oursVal !== undefined) {
+        result[key] = deepClone(oursVal);
+      }
+    } else if (!oursChanged && theirsChanged) {
+      if (theirsVal !== undefined) {
+        result[key] = deepClone(theirsVal);
+      }
+    } else {
+      if (deepEqual(oursVal, theirsVal)) {
+        if (oursVal !== undefined) {
+          result[key] = deepClone(oursVal);
+        }
+      } else {
+        const oursIsObj = oursVal !== null && oursVal !== undefined && typeof oursVal === 'object' && !Array.isArray(oursVal);
+        const theirsIsObj = theirsVal !== null && theirsVal !== undefined && typeof theirsVal === 'object' && !Array.isArray(theirsVal);
+        const baseIsObj = baseVal !== null && baseVal !== undefined && typeof baseVal === 'object' && !Array.isArray(baseVal);
+
+        if (oursIsObj && theirsIsObj) {
+          result[key] = threeWayMerge(
+            baseIsObj ? baseVal as object : {},
+            oursVal as object,
+            theirsVal as object,
+            documentId,
+            currentPath,
+            conflicts
+          ) as JsonValue;
+        } else {
+          conflicts.push({
+            documentId,
+            path: currentPath,
+            base: deepClone(baseVal),
+            ours: deepClone(oursVal),
+            theirs: deepClone(theirsVal),
+          });
+          if (oursVal !== undefined) {
+            result[key] = deepClone(oursVal);
+          }
+        }
+      }
+    }
+  }
+
+  return result;
+}
+
+export class DocumentStore {
+  private branches: Map<string, BranchData>;
+  private currentBranch: string;
+
+  constructor() {
+    this.branches = new Map();
+    this.currentBranch = 'main';
+    this.branches.set('main', {
+      documents: new Map(),
+      forkSnapshot: new Map(),
+      parentBranch: null,
+    });
+  }
+
+  private getCurrentBranchData(): BranchData {
+    return this.branches.get(this.currentBranch)!;
+  }
+
+  create(id: string, content: object): void {
+    const branch = this.getCurrentBranchData();
+    const existing = branch.documents.get(id);
+    if (existing && !existing.deleted) {
+      throw new Error(`Document "${id}" already exists`);
+    }
+
+    const version: Version = {
+      id: generateId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+
+    branch.documents.set(id, {
+      content: deepClone(content),
+      versions: [version],
+      deleted: false,
+    });
+  }
+
+  get(id: string): object {
+    const branch = this.getCurrentBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    return deepClone(doc.content);
+  }
+
+  update(id: string, content: object): void {
+    const branch = this.getCurrentBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+
+    const version: Version = {
+      id: generateId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+
+    doc.content = deepClone(content);
+    doc.versions.push(version);
+  }
+
+  delete(id: string): void {
+    const branch = this.getCurrentBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    doc.deleted = true;
+  }
+
+  getHistory(id: string): Version[] {
+    const branch = this.getCurrentBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    return doc.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    }));
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const branch = this.getCurrentBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    const version = doc.versions.find(v => v.id === versionId);
+    if (!version) {
+      throw new Error(`Version "${versionId}" does not exist for document "${id}"`);
+    }
+    return deepClone(version.content);
+  }
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch "${name}" already exists`);
+    }
+
+    const sourceBranchName = fromBranch ?? this.currentBranch;
+    const sourceBranch = this.branches.get(sourceBranchName);
+    if (!sourceBranch) {
+      throw new Error(`Branch "${sourceBranchName}" does not exist`);
+    }
+
+    const newDocuments = new Map<string, DocumentEntry>();
+    const forkSnapshot = new Map<string, object | null>();
+
+    for (const [docId, entry] of sourceBranch.documents) {
+      newDocuments.set(docId, {
+        content: deepClone(entry.content),
+        versions: entry.versions.map(v => ({
+          id: v.id,
+          timestamp: v.timestamp,
+          content: deepClone(v.content),
+        })),
+        deleted: entry.deleted,
+      });
+
+      forkSnapshot.set(docId, entry.deleted ? null : deepClone(entry.content));
+    }
+
+    this.branches.set(name, {
+      documents: newDocuments,
+      forkSnapshot,
+      parentBranch: sourceBranchName,
+    });
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch "${name}" does not exist`);
+    }
+    this.currentBranch = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranch;
+  }
+
+  listBranches(): string[] {
+    return Array.from(this.branches.keys());
+  }
+
+  merge(sourceBranch: string): MergeResult {
+    const sourceBranchData = this.branches.get(sourceBranch);
+    if (!sourceBranchData) {
+      throw new Error(`Branch "${sourceBranch}" does not exist`);
+    }
+
+    const targetBranchData = this.getCurrentBranchData();
+
+    let forkSnapshot: Map<string, object | null>;
+
+    if (sourceBranchData.parentBranch === this.currentBranch) {
+      forkSnapshot = sourceBranchData.forkSnapshot;
+    } else if (targetBranchData.parentBranch === sourceBranch) {
+      forkSnapshot = targetBranchData.forkSnapshot;
+    } else {
+      forkSnapshot = new Map();
+    }
+
+    const allDocIds = new Set<string>();
+    for (const id of forkSnapshot.keys()) allDocIds.add(id);
+    for (const id of targetBranchData.documents.keys()) allDocIds.add(id);
+    for (const id of sourceBranchData.documents.keys()) allDocIds.add(id);
+
+    const merged: Record<string, object> = {};
+    const conflicts: Conflict[] = [];
+    const documentsToApply: Array<{id: string; content: object | null}> = [];
+
+    for (const docId of allDocIds) {
+      const baseContent = forkSnapshot.has(docId) ? forkSnapshot.get(docId) ?? null : null;
+      const baseExists = forkSnapshot.has(docId) && forkSnapshot.get(docId) !== null;
+
+      const oursEntry = targetBranchData.documents.get(docId);
+      const oursExists = oursEntry ? !oursEntry.deleted : false;
+      const oursContent = oursExists ? oursEntry!.content : null;
+
+      const theirsEntry = sourceBranchData.documents.get(docId);
+      const theirsExists = theirsEntry ? !theirsEntry.deleted : false;
+      const theirsContent = theirsExists ? theirsEntry!.content : null;
+
+      const oursDeleted = baseExists && !oursExists;
+      const theirsDeleted = baseExists && !theirsExists;
+      const oursCreated = !baseExists && oursExists;
+      const theirsCreated = !baseExists && theirsExists;
+
+      if (oursDeleted && theirsDeleted) {
+        continue;
+      }
+
+      if (oursDeleted && !theirsDeleted) {
+        if (theirsContent && !deepEqual(baseContent as JsonValue, theirsContent as JsonValue)) {
+          documentsToApply.push({ id: docId, content: null });
+        } else {
+          documentsToApply.push({ id: docId, content: null });
+        }
+        continue;
+      }
+
+      if (!oursDeleted && theirsDeleted) {
+        if (oursContent && !deepEqual(baseContent as JsonValue, oursContent as JsonValue)) {
+          merged[docId] = deepClone(oursContent) as object;
+        } else {
+          documentsToApply.push({ id: docId, content: null });
+        }
+        continue;
+      }
+
+      if (oursCreated && !theirsCreated) {
+        merged[docId] = deepClone(oursContent) as object;
+        continue;
+      }
+
+      if (!oursCreated && theirsCreated) {
+        merged[docId] = deepClone(theirsContent) as object;
+        documentsToApply.push({ id: docId, content: theirsContent });
+        continue;
+      }
+
+      if (oursCreated && theirsCreated) {
+        const mergeResult = threeWayMerge({}, oursContent!, theirsContent!, docId, '', conflicts);
+        merged[docId] = mergeResult;
+        documentsToApply.push({ id: docId, content: mergeResult });
+        continue;
+      }
+
+      if (!oursExists && !theirsExists) {
+        continue;
+      }
+
+      if (!oursExists || !theirsExists) {
+        continue;
+      }
+
+      const oursChanged = !deepEqual(baseContent as JsonValue, oursContent as JsonValue);
+      const theirsChanged = !deepEqual(baseContent as JsonValue, theirsContent as JsonValue);
+
+      if (!oursChanged && !theirsChanged) {
+        merged[docId] = deepClone(oursContent) as object;
+        continue;
+      }
+
+      if (oursChanged && !theirsChanged) {
+        merged[docId] = deepClone(oursContent) as object;
+        continue;
+      }
+
+      if (!oursChanged && theirsChanged) {
+        merged[docId] = deepClone(theirsContent) as object;
+        documentsToApply.push({ id: docId, content: theirsContent });
+        continue;
+      }
+
+      const mergeResult = threeWayMerge(
+        baseContent!,
+        oursContent!,
+        theirsContent!,
+        docId,
+        '',
+        conflicts
+      );
+      merged[docId] = mergeResult;
+      documentsToApply.push({ id: docId, content: mergeResult });
+    }
+
+    const applied = conflicts.length === 0;
+
+    if (applied) {
+      for (const { id, content } of documentsToApply) {
+        if (content === null) {
+          const doc = targetBranchData.documents.get(id);
+          if (doc) {
+            doc.deleted = true;
+          }
+        } else {
+          const existingDoc = targetBranchData.documents.get(id);
+          if (existingDoc && !existingDoc.deleted) {
+            const version: Version = {
+              id: generateId(),
+              timestamp: Date.now(),
+              content: deepClone(content),
+            };
+            existingDoc.content = deepClone(content);
+            existingDoc.versions.push(version);
+          } else {
+            const version: Version = {
+              id: generateId(),
+              timestamp: Date.now(),
+              content: deepClone(content),
+            };
+            targetBranchData.documents.set(id, {
+              content: deepClone(content),
+              versions: existingDoc ? [...existingDoc.versions, version] : [version],
+              deleted: false,
+            });
+          }
+        }
+      }
+    }
+
+    return { merged, conflicts, applied };
+  }
+}
