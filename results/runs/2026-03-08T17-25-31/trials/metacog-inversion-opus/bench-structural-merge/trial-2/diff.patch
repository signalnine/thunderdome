+
+    it('should throw when merging a non-existent branch', () => {
+      expect(() => store.merge('nonexistent')).toThrow();
+    });
+
+    it('should handle field additions on different sides', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+
+      // Main adds field 'b'
+      store.update('doc1', { a: 1, b: 2 });
+
+      // Feature adds field 'c'
+      store.switchBranch('feature');
+      store.update('doc1', { a: 1, c: 3 });
+
+      store.switchBranch('main');
+      const result = store.merge('feature');
+
+      expect(result.applied).toBe(true);
+      expect(result.merged['doc1']).toEqual({ a: 1, b: 2, c: 3 });
+    });
+
+    it('should handle field deletions', () => {
+      store.create('doc1', { a: 1, b: 2, c: 3 });
+      store.createBranch('feature');
+
+      // Main removes field 'b'
+      store.update('doc1', { a: 1, c: 3 });
+
+      // Feature is unchanged
+      store.switchBranch('feature');
+
+      store.switchBranch('main');
+      const result = store.merge('feature');
+
+      expect(result.applied).toBe(true);
+      expect(result.merged['doc1']).toEqual({ a: 1, c: 3 });
+    });
+
+    it('should handle arrays as atomic values', () => {
+      store.create('doc1', { tags: ['a', 'b'] });
+      store.createBranch('feature');
+
+      store.update('doc1', { tags: ['a', 'b', 'c'] });
+
+      store.switchBranch('feature');
+      store.update('doc1', { tags: ['x', 'y'] });
+
+      store.switchBranch('main');
+      const result = store.merge('feature');
+
+      expect(result.applied).toBe(false);
+      expect(result.conflicts).toHaveLength(1);
+      expect(result.conflicts[0].path).toBe('tags');
+    });
+  });
+});
