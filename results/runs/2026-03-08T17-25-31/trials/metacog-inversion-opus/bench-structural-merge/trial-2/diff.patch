+++ b/src/types.ts
@@ -0,0 +1,33 @@
+export interface Version {
+  id: string;
+  timestamp: number;
+  content: object;
+}
+
+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+export interface Conflict {
+  documentId: string;
+  path: string;
+  base: unknown;
+  ours: unknown;
+  theirs: unknown;
+}
+
+export interface DocumentEntry {
+  content: object;
+  versions: Version[];
+  deleted: boolean;
+}
+
+export interface BranchState {
+  documents: Map<string, DocumentEntry>;
+  /** The snapshot of all documents at the time this branch was created (fork point). */
+  forkPoint: Map<string, DocumentEntry> | null;
+  /** Name of the branch this was forked from. */
+  forkedFrom: string | null;
+}
diff --git a/src/utils.ts b/src/utils.ts
new file mode 100644
index 0000000..2fcf8ac
--- /dev/null
+++ b/src/utils.ts
@@ -0,0 +1,36 @@
+import type { DocumentEntry } from './types.js';
+
+export function deepClone<T>(obj: T): T {
+  return JSON.parse(JSON.stringify(obj));
+}
+
+export function generateId(): string {
+  return Math.random().toString(36).slice(2) + Date.now().toString(36);
+}
+
+export function cloneDocumentEntry(entry: DocumentEntry): DocumentEntry {
+  return {
+    content: deepClone(entry.content),
+    versions: entry.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    })),
+    deleted: entry.deleted,
+  };
+}
+
+export function cloneDocumentMap(map: Map<string, DocumentEntry>): Map<string, DocumentEntry> {
+  const result = new Map<string, DocumentEntry>();
+  for (const [id, entry] of map) {
+    result.set(id, cloneDocumentEntry(entry));
+  }
+  return result;
+}
+
+/**
+ * Check if a value is a plain object (not null, not array, not Date, etc.)
+ */
+export function isPlainObject(value: unknown): value is Record<string, unknown> {
+  return typeof value === 'object' && value !== null && !Array.isArray(value) && !(value instanceof Date);
+}
