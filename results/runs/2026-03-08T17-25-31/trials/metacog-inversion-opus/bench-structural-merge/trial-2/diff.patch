ore.delete('doc1');\n      expect(() => store.get('doc1')).toThrow();\n    });\n\n    it('should throw when deleting a non-existent document', () => {\n      expect(() => store.delete('nonexistent')).toThrow();\n    });\n\n    it('should throw when deleting an already deleted document', () => {\n      store.create('doc1', { name: 'test' });\n      store.delete('doc1');\n      expect(() => store.delete('doc1')).toThrow();\n    });\n\n    it('should deep clone on create (prevent mutation)', () => {\n      const content = { name: 'test', nested: { value: 1 } };\n      store.create('doc1', content);\n      content.nested.value = 999;\n      expect(store.get('doc1')).toEqual({ name: 'test', nested: { value: 1 } });\n    });\n\n    it('should deep clone on get (prevent mutation)', () => {\n      store.create('doc1', { name: 'test', nested: { value: 1 } });\n      const retrieved = store.get('doc1') as Record<string, unknown>;\n      retrieved.nested.value = 999;\n      expect(store.get('doc1')).toEqual({ name: 'test', nested: { value: 1 } });\n    });\n\n    it('should deep clone on update (prevent mutation)', () => {\n      store.create('doc1', { name: 'test' });\n      const content = { name: 'updated', nested: { value: 1 } };\n      store.update('doc1', content);\n      content.nested.value = 999;\n      expect(store.get('doc1')).toEqual({ name: 'updated', nested: { value: 1 } });\n    });\n  });\n\n  // ── Version History ─────────────────────────────────────────────────\n\n  describe('Version history', () => {\n    it('should track versions on create', () => {\n      store.create('doc1', { name: 'test' });\n      const history = store.getHistory('doc1');\n      expect(history).toHaveLength(1);\n      expect(history[0].content).toEqual({ name: 'test' });\n    });\n\n    it('should track versions on update', () => {\n      store.create('doc1', { name: 'v1' });\n      store.update('doc1', { name: 'v2' });\n      store.update('doc1', { name: 'v3' });\n      const history = store.getHistory('doc1');\n      expect(history).toHaveLength(3);\n      expect(history[0].content).toEqual({ name: 'v1' });\n      expect(history[1].content).toEqual({ name: 'v2' });\n      expect(history[2].content).toEqual({ name: 'v3' });\n    });\n\n    it('should return versions in chronological order', () => {\n      store.create('doc1', { name: 'v1' });\n      store.update('doc1', { name: 'v2' });\n      const history = store.getHistory('doc1');\n      expect(history[0].timestamp).toBeLessThanOrEqual(history[1].timestamp);\n    });\n\n    it('should get a specific version', () => {\n      store.create('doc1', { name: 'v1' });\n      store.update('doc1', { name: 'v2' });\n      const history = store.getHistory('doc1');\n      const v1Content = store.getVersion('doc1', history[0].id);\n      expect(v1Content).toEqual({ name: 'v1' });\n    });\n\n    it('should throw for non-existent version', () => {\n      store.create('doc1', { name: 'test' });\n      expect(() => store.getVersion('doc1', 'nonexistent')).toThrow();\n    });\n\n    it('should throw for non-existent document in getHistory', () => {\n      expect(() => store.getHistory('nonexistent')).toThrow();\n    });\n\n    it('should have unique version IDs', () => {\n      store.create('doc1', { name: 'v1' });\n      store.update('doc1', { name: 'v2' });\n      const history = store.getHistory('doc1');\n      expect(history[0].id).not.toBe(history[1].id);\n    });\n  });\n\n  // ── Branching ───────────────────────────────────────────────────────\n\n  describe('Branching', () => {\n    it('should start on main branch', () => {\n      expect(store.getBranch()).toBe('main');\n    });\n\n    it('should create and switch branches', () => {\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      expect(store.getBranch()).toBe('feature');\n    });\n\n    it('should list branches', () => {\n      store.createBranch('feature');\n      store.createBranch('hotfix');\n      expect(store.listBranches()).toEqual(expect.arrayContaining(['main', 'feature', 'hotfix']));\n    });\n\n    it('should throw when creating a branch with existing name', () => {\n      store.createBranch('feature');\n      expect(() => store.createBranch('feature')).toThrow();\n    });\n\n    it('should throw when switching to non-existent branch', () => {\n      expect(() => store.switchBranch('nonexistent')).toThrow();\n    });\n\n    it('should isolate changes between branches', () => {\n      store.create('doc1', { name: 'original' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n\n      store.update('doc1', { name: 'modified' });\n      expect(store.get('doc1')).toEqual({ name: 'modified' });\n\n      store.switchBranch('main');\n      expect(store.get('doc1')).toEqual({ name: 'original' });\n    });\n\n    it('should create branch from specified source branch', () => {\n      store.create('doc1', { name: 'main-doc' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'feature-doc' });\n\n      store.createBranch('sub-feature', 'feature');\n      store.switchBranch('sub-feature');\n      expect(store.get('doc1')).toEqual({ name: 'feature-doc' });\n    });\n\n    it('should snapshot branch state at creation (no leaking later changes)', () => {\n      store.create('doc1', { name: 'v1' });\n      store.createBranch('feature');\n\n      // Modify on main after branch creation\n      store.update('doc1', { name: 'v2' });\n\n      // Feature branch should still see v1\n      store.switchBranch('feature');\n      expect(store.get('doc1')).toEqual({ name: 'v1' });\n    });\n\n    it('should allow creating documents on a branch without affecting other branches', () => {\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.create('doc1', { name: 'feature-only' });\n\n      store.switchBranch('main');\n      expect(() => store.get('doc1')).toThrow();\n    });\n\n    it('should allow deleting documents on a branch without affecting other branches', () => {\n      store.create('doc1', { name: 'test' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.delete('doc1');\n      expect(() => store.get('doc1')).toThrow();\n\n      store.switchBranch('main');\n      expect(store.get('doc1')).toEqual({ name: 'test' });\n    });\n  });\n\n  // ── Merging ─────────────────────────────────────────────────────────\n\n  describe('Merging', () => {\n    it('should merge non-conflicting changes', () => {\n      store.create('doc1', { a: 1, b: 2 });\n      store.createBranch('feature');\n\n      // Modify field 'a' on main\n      store.update('doc1', { a: 10, b: 2 });\n\n      // Modify field 'b' on feature\n      store.switchBranch('feature');\n      store.update('doc1', { a: 1, b: 20 });\n\n      // Merge feature into main\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(result.merged['doc1']).toEqual({ a: 10, b: 20 });\n      expect(store.get('doc1')).toEqual({ a: 10, b: 20 });\n    });\n\n    it('should detect conflicts when both sides change the same field', () => {\n      store.create('doc1', { a: 1, b: 2 });\n      store.createBranch('feature');\n\n      // Modify field 'a' on main\n      store.update('doc1', { a: 10, b: 2 });\n\n      // Modify field 'a' on feature (different value)\n      store.switchBranch('feature');\n      store.update('doc1', { a: 20, b: 2 });\n\n      // Merge feature into main\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(false);\n      expect(result.conflicts).toHaveLength(1);\n      expect(result.conflicts[0]).toEqual({\n        documentId: 'doc1',\n        path: 'a',\n        base: 1,\n        ours: 10,\n        theirs: 20,\n      });\n    });\n\n    it('should not conflict when both sides make the same change', () => {\n      store.create('doc1', { a: 1, b: 2 });\n      store.createBranch('feature');\n\n      store.update('doc1', { a: 10, b: 2 });\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: 10, b: 2 });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(result.merged['doc1']).toEqual({ a: 10, b: 2 });\n    });\n\n    it('should merge new documents from source branch', () => {\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.create('doc1', { name: 'new-doc' });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.merged['doc1']).toEqual({ name: 'new-doc' });\n      expect(store.get('doc1')).toEqual({ name: 'new-doc' });\n    });\n\n    it('should handle multiple documents independently', () => {\n      store.create('doc1', { a: 1 });\n      store.create('doc2', { x: 1 });\n      store.createBranch('feature');\n\n      // Main modifies doc1\n      store.update('doc1', { a: 10 });\n\n      // Feature modifies doc2\n      store.switchBranch('feature');\n      store.update('doc2', { x: 10 });\n\n      // Merge should succeed\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(store.get('doc1')).toEqual({ a: 10 });\n      expect(store.get('doc2')).toEqual({ x: 10 });\n    });\n\n    it('should handle deep nested merges', () => {\n      store.create('doc1', { level1: { level2: { a: 1, b: 2 } } });\n      store.createBranch('feature');\n\n      store.update('doc1', { level1: { level2: { a: 10, b: 2 } } });\n\n      store.switchBranch('feature');\n      store.update('doc1', { level1: { level2: { a: 1, b: 20 } } });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.merged['doc1']).toEqual({ level1: { level2: { a: 10, b: 20 } } });\n    });\n\n    it('should report conflicts with correct dot-separated paths', () => {\n      store.create('doc1', { a: { b: { c: 1 } } });\n      store.createBranch('feature');\n\n      store.update('doc1', { a: { b: { c: 10 } } });\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: { b: { c: 20 } } });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(false);\n      expect(result.conflicts[0].path).toBe('a.b.c');\n    });\n\n    it('should not apply merge when there are conflicts', () => {\n      store.create('doc1', { a: 1 });\n      store.createBranch('feature');\n\n      store.update('doc1', { a: 10 });\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: 20 });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(false);\n      // Current branch remains unchanged\n      expect(store.get('doc1')).toEqual({ a: 10 });\n    });\n\n    it('should include ours-favored merged result even with conflicts', () => {\n      store.create('doc1', { a: 1, b: 2 });\n      store.createBranch('feature');\n\n      store.update('doc1', { a: 10, b: 20 });\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: 30, b: 40 });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      // merged should favor ours (main)\n      expect(result.merged['doc1']).toEqual({ a: 10, b: 20 });\n    });\n\n    it('should handle fast-forward merges (no changes on either side)', () => {\n      store.create('doc1', { a: 1 });\n      store.createBranch('feature');\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n    });\n\n    it('should throw when merging a non-existent branch', () => {\n      expect(() => store.merge('nonexistent')).toThrow();\n    });\n\n    it('should handle field additions on different sides', () => {\n      store.create('doc1', { a: 1 });\n      store.createBranch('feature');\n\n      // Main adds field 'b'\n      store.update('doc1', { a: 1, b: 2 });\n\n      // Feature adds field 'c'\n      store.switchBranch('feature');\n      store.update('doc1', { a: 1, c: 3 });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.merged['doc1']).toEqual({ a: 1, b: 2, c: 3 });\n    });\n\n    it('should handle field deletions', () => {\n      store.create('doc1', { a: 1, b: 2, c: 3 });\n      store.createBranch('feature');\n\n      // Main removes field 'b'\n      store.update('doc1', { a: 1, c: 3 });\n\n      // Feature is unchanged\n      store.switchBranch('feature');\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.merged['doc1']).toEqual({ a: 1, c: 3 });\n    });\n\n    it('should handle arrays as atomic values', () => {\n      store.create('doc1', { tags: ['a', 'b'] });\n      store.createBranch('feature');\n\n      store.update('doc1', { tags: ['a', 'b', 'c'] });\n\n      store.switchBranch('feature');\n      store.update('doc1', { tags: ['x', 'y'] });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(false);\n      expect(result.conflicts).toHaveLength(1);\n      expect(result.conflicts[0].path).toBe('tags');\n    });\n  });\n});\n","structuredPatch":[{"oldStart":60,"oldLines":7,"newStart":60,"newLines":7,"lines":[" ","     it('should deep clone on get (prevent mutation)', () => {","       store.cr