@@ -0,0 +1,156 @@
+import type { Conflict } from './types.js';
+import { deepClone, isPlainObject } from './utils.js';
+
+/**
+ * Perform a deep three-way merge of two objects against a common base.
+ * Returns the merged result and any conflicts found.
+ *
+ * Key insight (from inversion thinking): The most common bug is treating
+ * arrays/primitives as objects. We must recurse only into plain objects,
+ * and treat everything else (arrays, primitives, null) as atomic values.
+ */
+export function threeWayMerge(
+  documentId: string,
+  base: object | null,
+  ours: object | null,
+  theirs: object | null,
+): { merged: object; conflicts: Conflict[] } {
+  const conflicts: Conflict[] = [];
+
+  // If either side is null (document didn't exist or was deleted), handle specially
+  if (base === null && ours === null && theirs === null) {
+    return { merged: {}, conflicts: [] };
+  }
+
+  const merged = deepMerge(
+    documentId,
+    (base ?? {}) as Record<string, unknown>,
+    (ours ?? {}) as Record<string, unknown>,
+    (theirs ?? {}) as Record<string, unknown>,
+    '',
+    conflicts,
+  );
+
+  return { merged, conflicts };
+}
+
+function deepMerge(
+  documentId: string,
+  base: Record<string, unknown>,
+  ours: Record<string, unknown>,
+  theirs: Record<string, unknown>,
+  prefix: string,
+  conflicts: Conflict[],
+): Record<string, unknown> {
+  const result: Record<string, unknown> = {};
+  const allKeys = new Set([
+    ...Object.keys(base),
+    ...Object.keys(ours),
+    ...Object.keys(theirs),
+  ]);
+
+  for (const key of allKeys) {
+    const path = prefix ? `${prefix}.${key}` : key;
+    const baseVal = base[key];
+    const oursVal = ours[key];
+    const theirsVal = theirs[key];
+
+    const baseHas = key in base;
+    const oursHas = key in ours;
+    const theirsHas = key in theirs;
+
+    // Both sides are the same as base - no change
+    if (deepEqual(baseVal, oursVal) && deepEqual(baseVal, theirsVal)) {
+      if (baseHas) {
+        result[key] = deepClone(baseVal);
+      }
+      // If key doesn't exist in base and equals in both (both undefined), skip
+      continue;
+    }
+
+    // Only ours changed (theirs == base)
+    if (deepEqual(baseVal, theirsVal) && (!baseHas === !theirsHas)) {
+      if (oursHas) {
+        result[key] = deepClone(oursVal);
+      }
+      // If ours deleted the key (oursHas is false), don't include it
+      continue;
+    }
+
+    // Only theirs changed (ours == base)
+    if (deepEqual(baseVal, oursVal) && (!baseHas === !oursHas)) {
+      if (theirsHas) {
+        result[key] = deepClone(theirsVal);
+      }
+      // If theirs deleted the key, don't include it
+      continue;
+    }
+
+    // Both changed - check if they agree
+    if (deepEqual(oursVal, theirsVal) && (oursHas === theirsHas)) {
+      if (oursHas) {
+        result[key] = deepClone(oursVal);
+      }
+      continue;
+    }
+
+    // Both changed to different values - potential conflict
+    // If both are plain objects, recurse to find more granular conflicts
+    if (isPlainObject(oursVal) && isPlainObject(theirsVal)) {
+      const baseObj = isPlainObject(baseVal) ? baseVal : {};
+      result[key] = deepMerge(
+        documentId,
+        baseObj as Record<string, unknown>,
+        oursVal as Record<string, unknown>,
+        theirsVal as Record<string, unknown>,
+        path,
+        conflicts,
+      );
+      continue;
+    }
+
+    // Real conflict: both sides changed the same field to different values
+    conflicts.push({
+      documentId,
+      path,
+      base: baseHas ? deepClone(baseVal) : undefined,
+      ours: oursHas ? deepClone(oursVal) : undefined,
+      theirs: theirsHas ? deepClone(theirsVal) : undefined,
+    });
+
+    // For the merged result, favor "ours"
+    if (oursHas) {
+      result[key] = deepClone(oursVal);
+    }
+  }
+
+  return result;
+}
+
+function deepEqual(a: unknown, b: unknown): boolean {
+  if (a === b) return true;
+  if (a === null || b === null) return false;
+  if (a === undefined || b === undefined) return false;
+  if (typeof a !== typeof b) return false;
+
+  if (typeof a === 'object' && typeof b === 'object') {
+    // Both are non-null objects at this point
+    const aObj = a as Record<string, unknown>;
+    const bObj = b as Record<string, unknown>;
+
+    if (Array.isArray(aObj) !== Array.isArray(bObj)) return false;
+
+    if (Array.isArray(aObj) && Array.isArray(bObj)) {
+      if (aObj.length !== bObj.length) return false;
+      return aObj.every((val, i) => deepEqual(val, bObj[i]));
+    }
+
+    const aKeys = Object.keys(aObj);
+    const bKeys = Object.keys(bObj);
+    if (aKeys.length !== bKeys.length) return false;
+
+    return aKeys.every(key => key in bObj && deepEqual(aObj[key], bObj[key]));
+  }
+
+  return false;
+}
diff --git a/src/types.ts b/src/types.ts
new file mode 100644
