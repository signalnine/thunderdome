+++ b/src/index.ts
@@ -0,0 +1,349 @@
+import type { Version, MergeResult, Conflict, DocumentEntry, BranchState } from './types.js';
+import { threeWayMerge } from './merge.js';
+import { deepClone, generateId, cloneDocumentMap } from './utils.js';
+
+export type { Version, MergeResult, Conflict };
+
+export class DocumentStore {
+  private branches: Map<string, BranchState> = new Map();
+  private currentBranch: string = 'main';
+
+  constructor() {
+    this.branches.set('main', {
+      documents: new Map(),
+      forkPoint: null,
+      forkedFrom: null,
+    });
+  }
+
+  // ── Document CRUD ───────────────────────────────────────────────────
+
+  create(id: string, content: object): void {
+    const branch = this.getCurrentBranchState();
+    const existing = branch.documents.get(id);
+    if (existing && !existing.deleted) {
+      throw new Error(`Document "${id}" already exists`);
+    }
+
+    const version: Version = {
+      id: generateId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+
+    branch.documents.set(id, {
+      content: deepClone(content),
+      versions: existing?.deleted ? [...existing.versions, version] : [version],
+      deleted: false,
+    });
+  }
+
+  get(id: string): object {
+    const branch = this.getCurrentBranchState();
+    const entry = branch.documents.get(id);
+    if (!entry || entry.deleted) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    return deepClone(entry.content);
+  }
+
+  update(id: string, content: object): void {
+    const branch = this.getCurrentBranchState();
+    const entry = branch.documents.get(id);
+    if (!entry || entry.deleted) {
+      throw new Error(`Document "${id}" not found`);
+    }
+
+    const version: Version = {
+      id: generateId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+
+    entry.content = deepClone(content);
+    entry.versions.push(version);
+  }
+
+  delete(id: string): void {
+    const branch = this.getCurrentBranchState();
+    const entry = branch.documents.get(id);
+    if (!entry || entry.deleted) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    entry.deleted = true;
+    entry.content = {};
+  }
+
+  // ── Version History ─────────────────────────────────────────────────
+
+  getHistory(id: string): Version[] {
+    const branch = this.getCurrentBranchState();
+    const entry = branch.documents.get(id);
+    if (!entry) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    return entry.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    }));
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const branch = this.getCurrentBranchState();
+    const entry = branch.documents.get(id);
+    if (!entry) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    const version = entry.versions.find(v => v.id === versionId);
+    if (!version) {
+      throw new Error(`Version "${versionId}" not found for document "${id}"`);
+    }
+    return deepClone(version.content);
+  }
+
+  // ── Branching ───────────────────────────────────────────────────────
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch "${name}" already exists`);
+    }
+
+    const sourceName = fromBranch ?? this.currentBranch;
+    const source = this.branches.get(sourceName);
+    if (!source) {
+      throw new Error(`Branch "${sourceName}" not found`);
+    }
+
+    const clonedDocs = cloneDocumentMap(source.documents);
+
+    this.branches.set(name, {
+      documents: clonedDocs,
+      forkPoint: cloneDocumentMap(source.documents),
+      forkedFrom: sourceName,
+    });
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch "${name}" not found`);
+    }
+    this.currentBranch = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranch;
+  }
+
+  listBranches(): string[] {
+    return Array.from(this.branches.keys());
+  }
+
+  // ── Merging ─────────────────────────────────────────────────────────
+
+  merge(sourceBranch: string): MergeResult {
+    const sourceBranchState = this.branches.get(sourceBranch);
+    if (!sourceBranchState) {
+      throw new Error(`Branch "${sourceBranch}" not found`);
+    }
+
+    const targetBranchState = this.getCurrentBranchState();
+
+    // Find common ancestor: the fork point of the source branch
+    // This is the state at the time the source branch was created
+    const base = this.findCommonAncestor(sourceBranch);
+
+    const sourceDocs = sourceBranchState.documents;
+    const targetDocs = targetBranchState.documents;
+
+    // Collect all document IDs that exist in any of the three states
+    const allDocIds = new Set<string>();
+    for (const id of base.keys()) allDocIds.add(id);
+    for (const id of sourceDocs.keys()) allDocIds.add(id);
+    for (const id of targetDocs.keys()) allDocIds.add(id);
+
+    const merged: Record<string, object> = {};
+    const allConflicts: Conflict[] = [];
+
+    for (const docId of allDocIds) {
+      const baseEntry = base.get(docId);
+      const sourceEntry = sourceDocs.get(docId);
+      const targetEntry = targetDocs.get(docId);
+
+      const baseContent = baseEntry && !baseEntry.deleted ? baseEntry.content : null;
+      const sourceContent = sourceEntry && !sourceEntry.deleted ? sourceEntry.content : null;
+      const targetContent = targetEntry && !targetEntry.deleted ? targetEntry.content : null;
+
+      // Check if the document was deleted on either side
+      const baseExists = baseContent !== null;
+      const sourceExists = sourceContent !== null;
+      const targetExists = targetContent !== null;
+
+      // If nothing changed for this document, skip unless it exists
+      if (this.contentsEqual(baseContent, sourceContent) && this.contentsEqual(baseContent, targetContent)) {
+        if (targetExists) {
+          merged[docId] = deepClone(targetContent!);
+        }
+        continue;
+      }
+
+      // Document only exists in source (created on source branch)
+      if (!baseExists && !targetExists && sourceExists) {
+        merged[docId] = deepClone(sourceContent!);
+        continue;
+      }
+
+      // Document only exists in target (created on target branch)
+      if (!baseExists && sourceExists === false && targetExists) {
+        merged[docId] = deepClone(targetContent!);
+        continue;
+      }
+
+      // Document deleted on source, unchanged on target
+      if (baseExists && !sourceExists && this.contentsEqual(baseContent, targetContent)) {
+        // Take the delete - don't include in merged
+        continue;
+      }
+
+      // Document deleted on target, unchanged on source
+      if (baseExists && !targetExists && this.contentsEqual(baseContent, sourceContent)) {
+        // Target deleted it, keep deleted
+        continue;
+      }
+
+      // Document deleted on one side but modified on the other - conflict
+      if (baseExists && !sourceExists && targetExists && !this.contentsEqual(baseContent, targetContent)) {
+        // Source deleted, target modified - keep target's version (ours)
+        merged[docId] = deepClone(targetContent!);
+        allConflicts.push({
+          documentId: docId,
+          path: '',
+          base: deepClone(baseContent),
+          ours: deepClone(targetContent),
+          theirs: null,
+        });
+        continue;
+      }
+
+      if (baseExists && sourceExists && !targetExists && !this.contentsEqual(baseContent, sourceContent)) {
+        // Target deleted, source modified - conflict, favor ours (deleted)
+        allConflicts.push({
+          documentId: docId,
+          path: '',
+          base: deepClone(baseContent),
+          ours: null,
+          theirs: deepClone(sourceContent),
+        });
+        continue;
+      }
+
+      // Both sides have content - do three-way structural merge
+      if (sourceExists && targetExists) {
+        const { merged: mergedContent, conflicts } = threeWayMerge(
+          docId,
+          baseContent as object,
+          targetContent as object,  // ours = target (current branch)
+          sourceContent as object,  // theirs = source
+        );
+        merged[docId] = mergedContent;
+        allConflicts.push(...conflicts);
+        continue;
+      }
+
+      // Both sides created the same doc (not in base)
+      if (!baseExists && sourceExists && targetExists) {
+        const { merged: mergedContent, conflicts } = threeWayMerge(
+          docId,
+          null,
+          targetContent as object,
+          sourceContent as object,
+        );
+        merged[docId] = mergedContent;
+        allConflicts.push(...conflicts);
+        continue;
+      }
+
+      // Fallback: include whatever exists on target
+      if (targetExists) {
+        merged[docId] = deepClone(targetContent!);
+      }
+    }
+
+    const applied = allConflicts.length === 0;
+
+    if (applied) {
+      // Apply the merge to the current branch
+      for (const docId of allDocIds) {
+        if (docId in merged) {
+          const existingEntry = targetDocs.get(docId);
+          const mergedContent = deepClone(merged[docId]);
+
+          if (existingEntry && !existingEntry.deleted) {
+            // Check if content actually changed
+            if (!this.contentsEqual(existingEntry.content, mergedContent)) {
+              const version: Version = {
+                id: generateId(),
+                timestamp: Date.now(),
+                content: deepClone(mergedContent),
+              };
+              existingEntry.content = mergedContent;
+              existingEntry.versions.push(version);
+            }
+          } else {
+            // New document from source branch
+            const version: Version = {
+              id: generateId(),
+              timestamp: Date.now(),
+              content: deepClone(mergedContent),
+            };
+            targetDocs.set(docId, {
+              content: mergedContent,
+              versions: existingEntry ? [...existingEntry.versions, version] : [version],
+              deleted: false,
+            });
+          }
+        } else {
+          // Document was deleted in the merge
+          const existingEntry = targetDocs.get(docId);
+          if (existingEntry && !existingEntry.deleted) {
+            existingEntry.deleted = true;
+            existingEntry.content = {};
+          }
+        }
+      }
+    }
+
+    return { merged, conflicts: allConflicts, applied };
+  }
+
+  // ── Private helpers ─────────────────────────────────────────────────
+
+  private getCurrentBranchState(): BranchState {
+    const state = this.branches.get(this.currentBranch);
+    if (!state) {
+      throw new Error(`Branch "${this.currentBranch}" not found`);
+    }
+    return state;
+  }
+
+  private findCommonAncestor(sourceBranch: string): Map<string, DocumentEntry> {
+    const sourceState = this.branches.get(sourceBranch);
+    if (!sourceState) {
+      throw new Error(`Branch "${sourceBranch}" not found`);
+    }
+
+    // The fork point of the source branch is the common ancestor
+    if (sourceState.forkPoint) {
+      return sourceState.forkPoint;
+    }
+
+    // If no fork point (e.g., main), the common ancestor is an empty state
+    return new Map();
+  }
+
+  private contentsEqual(a: object | null, b: object | null): boolean {
+    if (a === null && b === null) return true;
+    if (a === null || b === null) return false;
+    return JSON.stringify(a) === JSON.stringify(b);
+  }
+}
