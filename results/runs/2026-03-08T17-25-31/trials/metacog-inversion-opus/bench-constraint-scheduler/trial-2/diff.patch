ns);\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toHaveLength(0);\n    });\n\n    it('should default attendees to 1 if not specified', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n    });\n  });\n\n  describe('room capacity', () => {\n    it('should not assign event to room with insufficient capacity', () => {\n      const smallRooms: Room[] = [\n        { id: 'small', name: 'Small Room', capacity: 5 },\n      ];\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, attendees: 10 },\n      ];\n      const result = schedule(events, smallRooms, defaultOptions);\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toContain('e1');\n    });\n\n    it('should place event in room with exact capacity match', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, attendees: 10 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n    });\n  });\n\n  describe('time window', () => {\n    it('should not schedule events that exceed the time window', () => {\n      const tightOptions: ScheduleOptions = {\n        startTime: 540,\n        endTime: 570,  // only 30 minutes\n      };\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n      ];\n      const result = schedule(events, rooms, tightOptions);\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toContain('e1');\n    });\n\n    it('should schedule event that exactly fits the time window', () => {\n      const tightOptions: ScheduleOptions = {\n        startTime: 540,\n        endTime: 600,  // exactly 60 minutes\n      };\n      const events: Event[] = [\n        { id: 'e