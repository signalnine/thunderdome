+import { describe, it, expect } from 'vitest';
+import { schedule, Event, Room, ScheduleOptions } from './index.js';
+
+describe('schedule', () => {
+  const defaultOptions: ScheduleOptions = {
+    startTime: 540,  // 9:00 AM
+    endTime: 1020,   // 5:00 PM
+  };
+
+  const rooms: Room[] = [
+    { id: 'room-a', name: 'Room A', capacity: 10 },
+    { id: 'room-b', name: 'Room B', capacity: 20 },
+    { id: 'room-c', name: 'Room C', capacity: 50 },
+  ];
+
+  describe('basic scheduling', () => {
+    it('should schedule a single event', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60, attendees: 5 },
+      ];
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(1);
+      expect(result.unscheduled).toHaveLength(0);
+      expect(result.assignments[0].eventId).toBe('e1');
+      expect(result.assignments[0].startTime).toBeGreaterThanOrEqual(540);
+      expect(result.assignments[0].endTime).toBeLessThanOrEqual(1020);
+      expect(result.assignments[0].endTime - result.assignments[0].startTime).toBe(60);
+    });
+
+    it('should schedule multiple events', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60, attendees: 5 },
+        { id: 'e2', name: 'Event 2', duration: 45, attendees: 8 },
+        { id: 'e3', name: 'Event 3', duration: 30, attendees: 3 },
+      ];
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(3);
+      expect(result.unscheduled).toHaveLength(0);
+    });
+
+    it('should return empty results for empty input', () => {
+      const result = schedule([], rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toHaveLength(0);
+    });
+
+    it('should default attendees to 1 if not specified', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+      ];
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(1);
+    });
+  });
+
+  describe('room capacity', () => {
+    it('should not assign event to room with insufficient capacity', () => {
+      const smallRooms: Room[] = [
+        { id: 'small', name: 'Small Room', capacity: 5 },
+      ];
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60, attendees: 10 },
+      ];
+      const result = schedule(events, smallRooms, defaultOptions);
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toContain('e1');
+    });
+
+    it('should place event in room with exact capacity match', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60, attendees: 10 },
+      ];
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(1);
+    });
+  });
+
+  describe('time window', () => {
+    it('should not schedule events that exceed the time window', () => {
+      const tightOptions: ScheduleOptions = {
+        startTime: 540,
+        endTime: 570,  // only 30 minutes
+      };
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+      ];
+      const result = schedule(events, rooms, tightOptions);
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toContain('e1');
+    });
+
+    it('should schedule event that exactly fits the time window', () => {
+      const tightOptions: ScheduleOptions = {
+        startTime: 540,
+        endTime: 600,  // exactly 60 minutes
+      };
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+      ];
+      const result = schedule(events, rooms, tightOptions);
+      expect(result.assignments).toHaveLength(1);
+      expect(result.assignments[0].startTime).toBe(540);
+      expect(result.assignments[0].endTime).toBe(600);
+    });
+  });
+
+  describe('room gaps', () => {
+    it('should enforce default 15-minute gap between events in same room', () => {
+      const singleRoom: Room[] = [
+        { id: 'room', name: 'Room', capacity: 100 },
+      ];
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60, attendees: 5 },
+        { id: 'e2', name: 'Event 2', duration: 60, attendees: 5 },
+      ];
+      const result = schedule(events, singleRoom, defaultOptions);
+      expect(result.assignments).toHaveLength(2);
+
+      const a1 = result.assignments.find(a => a.eventId === 'e1')!;
+      const a2 = result.assignments.find(a => a.eventId === 'e2')!;
+
+      if (a1.roomId === a2.roomId) {
+        const earlier = a1.startTime < a2.startTime ? a1 : a2;
+        const later = a1.startTime < a2.startTime ? a2 : a1;
+        expect(later.startTime - earlier.endTime).toBeGreaterThanOrEqual(15);
+      }
+    });
+
+    it('should use custom gap when specified', () => {
+      const singleRoom: Room[] = [
+        { id: 'room', name: 'Room', capacity: 100 },
+      ];
+      const optionsWithGap: ScheduleOptions = {
+        startTime: 540,
+        endTime: 1020,
+        gap: 30,
+      };
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60, attendees: 5 },
+        { id: 'e2', name: 'Event 2', duration: 60, attendees: 5 },
+      ];
+      const result = schedule(events, singleRoom, optionsWithGap);
+      expect(result.assignments).toHaveLength(2);
+
+      const a1 = result.assignments.find(a => a.eventId === 'e1')!;
+      const a2 = result.assignments.find(a => a.eventId === 'e2')!;
+
+      if (a1.roomId === a2.roomId) {
+        const earlier = a1.startTime < a2.startTime ? a1 : a2;
+        const later = a1.startTime < a2.startTime ? a2 : a1;
+        expect(later.startTime - earlier.endTime).toBeGreaterThanOrEqual(30);
+      }
+    });
+
+    it('should use zero gap when specified', () => {
+      const singleRoom: Room[] = [
+        { id: 'room', name: 'Room', capacity: 100 },
+      ];
+      const optionsWithZeroGap: ScheduleOptions = {
+        startTime: 540,
+        endTime: 660,  // 2 hours
+        gap: 0,
+      };
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60, attendees: 5 },
+        { id: 'e2', name: 'Event 2', duration: 60, attendees: 5 },
+      ];
+      const result = schedule(events, singleRoom, optionsWithZeroGap);
+      expect(result.assignments).toHaveLength(2);
+    });
+  });
+
+  describe('prerequisites', () => {
+    it('should schedule prerequisite before dependent event', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+        { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },
+      ];
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(2);
+
+      const a1 = result.assignments.find(a => a.eventId === 'e1')!;
+      const a2 = result.assignments.find(a => a.eventId === 'e2')!;
+
+      expect(a1.endTime).toBeLessThanOrEqual(a2.startTime);
+    });
+
+    it('should enforce gap between prerequisite and dependent event', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+        { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },
+      ];
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(2);
+
+      const a1 = result.assignments.find(a => a.eventId === 'e1')!;
+      const a2 = result.assignments.find(a => a.eventId === 'e2')!;
+
+      expect(a2.startTime - a1.endTime).toBeGreaterThanOrEqual(15);
+    });
+
+    it('should handle chain of prerequisites', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 30 },
+        { id: 'e2', name: 'Event 2', duration: 30, prerequisites: ['e1'] },
+        { id: 'e3', name: 'Event 3', duration: 30, prerequisites: ['e2'] },
+      ];
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(3);
+
+      const a1 = result.assignments.find(a => a.eventId === 'e1')!;
+      const a2 = result.assignments.find(a => a.eventId === 'e2')!;
+      const a3 = result.assignments.find(a => a.eventId === 'e3')!;
+
+      expect(a1.endTime + 15).toBeLessThanOrEqual(a2.startTime);
+      expect(a2.endTime + 15).toBeLessThanOrEqual(a3.startTime);
+    });
+
+    it('should handle multiple prerequisites for one event', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 30 },
+        { id: 'e2', name: 'Event 2', duration: 30 },
+        { id: 'e3', name: 'Event 3', duration: 30, prerequisites: ['e1', 'e2'] },
+      ];
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(3);
+
+      const a1 = result.assignments.find(a => a.eventId === 'e1')!;
+      const a2 = result.assignments.find(a => a.eventId === 'e2')!;
+      const a3 = result.assignments.find(a => a.eventId === 'e3')!;
+
+      expect(a3.startTime).toBeGreaterThanOrEqual(a1.endTime + 15);
+      expect(a3.startTime).toBeGreaterThanOrEqual(a2.endTime + 15);
+    });
+  });
+
+  describe('prerequisite cycles', () => {
+    it('should throw error for self-referencing prerequisite', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['e1'] },
