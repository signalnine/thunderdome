n        startTime: 540,\n        endTime: 600,  // exactly 60 minutes\n      };\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n      ];\n      const result = schedule(events, rooms, tightOptions);\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].startTime).toBe(540);\n      expect(result.assignments[0].endTime).toBe(600);\n    });\n  });\n\n  describe('room gaps', () => {\n    it('should enforce default 15-minute gap between events in same room', () => {\n      const singleRoom: Room[] = [\n        { id: 'room', name: 'Room', capacity: 100 },\n      ];\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, attendees: 5 },\n        { id: 'e2', name: 'Event 2', duration: 60, attendees: 5 },\n      ];\n      const result = schedule(events, singleRoom, defaultOptions);\n      expect(result.assignments).toHaveLength(2);\n\n      const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n      const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n\n      if (a1.roomId === a2.roomId) {\n        const earlier = a1.startTime < a2.startTime ? a1 : a2;\n        const later = a1.startTime < a2.startTime ? a2 : a1;\n        expect(later.startTime - earlier.endTime).toBeGreaterThanOrEqual(15);\n      }\n    });\n\n    it('should use custom gap when specified', () => {\n      const singleRoom: Room[] = [\n        { id: 'room', name: 'Room', capacity: 100 },\n      ];\n      const optionsWithGap: ScheduleOptions = {\n        startTime: 540,\n        endTime: 1020,\n        gap: 30,\n      };\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, attendees: 5 },\n        { id: 'e2', name: 'Event 2', duration: 60, attendees: 5 },\n      ];\n      const result = schedule(events, singleRoom, optionsWithGap);\n      expect(result.assignments).toHaveLength(2);\n\n      const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n      