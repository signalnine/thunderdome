  const inDegree = new Map<string, number>();\n  for (const e of events) {\n    if (!inDegree.has(e.id)) inDegree.set(e.id, 0);\n    if (e.prerequisites) {\n      for (const prereqId of e.prerequisites) {\n        if (!inDegree.has(prereqId)) inDegree.set(prereqId, 0);\n      }\n    }\n  }\n\n  // Build adjacency: prereq -> dependents\n  const dependents = new Map<string, string[]>();\n  for (const e of events) {\n    if (e.prerequisites) {\n      for (const prereqId of e.prerequisites) {\n        if (!dependents.has(prereqId)) dependents.set(prereqId, []);\n        dependents.get(prereqId)!.push(e.id);\n        inDegree.set(e.id, (inDegree.get(e.id) || 0) + 1);\n      }\n    }\n  }\n\n  const queue: string[] = [];\n  for (const e of events) {\n    if (inDegree.get(e.id) === 0) {\n      queue.push(e.id);\n    }\n  }\n\n  const result: string[] = [];\n  while (queue.length > 0) {\n    const id = queue.shift()!;\n    result.push(id);\n    const deps = dependents.get(id) || [];\n    for (const depId of deps) {\n      const newDeg = (inDegree.get(depId) || 0) - 1;\n      inDegree.set(depId, newDeg);\n      if (newDeg === 0) {\n        queue.push(depId);\n      }\n    }\n  }\n\n  return result;\n}\n\nexport function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {\n  if (events.length === 0) {\n    return { assignments: [], unscheduled: [] };\n  }\n\n  const gap = options.gap ?? 15;\n\n  // Detect cycles - throws if found\n  detectCycles(events);\n\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  // Sort rooms by capacity ascending for efficient packing\n  const sortedRooms = [...rooms].sort((a, b) => a.capacity - b.capacity);\n\n  // Get topological order\n  const topoOrder = topologicalSort(events);\n\n  // Filter to only events that exist in our event list\n  const eventIds = new Set(events.map(e => e.id));\n  const orderedIds = topoOrder.filter(id => eventIds.has(id));\n\n  // For each event, find which rooms can fit it\n  function getValidRooms(event: Event): Room[] {\n    const attendees = event.attendees ?? 1;\n    return sortedRooms.filter(r => r.capacity >= attendees);\n  }\n\n  // Track room schedules: roomId -> sorted list of {start, end}\n  type TimeSlot = { start: number; end: number; eventId: string };\n  const roomSchedules = new Map<string, TimeSlot[]>();\n  for (const room of rooms) {\n    roomSchedules.set(room.id, []);\n  }\n\n  // Find earliest start time for an event in a given room\n  function findEarliestSlot(roomId: string, duration: number, earliestStart: number): number | null {\n    const slots = roomSchedules.get(roomId)!;\n    let candidateStart = earliestStart;\n\n    for (const slot of slots) {\n      const candidateEnd = candidateStart + duration;\n      if (candidateEnd + gap <= slot.start || candidateStart >= slot.end + gap) {\n        if (candidateEnd <= options.endTime) {\n          // Check if this candidate doesn't overlap with this or any later slot\n          if (candidateEnd + gap <= slot.start) {\n            return candidateStart;\n          }\n          // Move past this slot\n          candidateStart = Math.max(candidateStart, slot.end + gap);\n        } else {\n          return null;\n        }\n      } else {\n        // Overlap - move past this slot\n        candidateStart = slot.end + gap;\n      }\n    }\n\n    // Check if we can fit after all existing slots\n    if (candidateStart + duration <= options.endTime) {\n      return candidateStart;\n    }\n    return null;\n  }\n\n  // Compute earliest possible start for an event based on prerequisites\n  function getPrereqEndTime(event: Event, assignments: Map<string, Assignment>): number {\n    let earliest = options.startTime;\n    if (event.prerequisites) {\n      for (const prereqId of event.prerequisites) {\n        const prereqAssignment = assignments.get(prereqId);\n        if (!prereqAssignment) {\n          return -1; // prereq not scheduled\n        }\n        earliest = Math.max(earliest, prereqAssignment.endTime + gap);\n      }\n    }\n    return earliest;\n  }\n\n  // Try to schedule using a backtracking approach with heuristics\n  // For efficiency, we use a greedy approach with smart ordering:\n  // Process events in topological order, and within the same topo-level,\n  // prioritize events with fewer valid room options (most constrained first)\n\n  // Build dependency levels\n  const depLevel = new Map<string, number>();\n  function getDepLevel(id: string): number {\n    if (depLevel.has(id)) return depLevel.get(id)!;\n    const event = eventMap.get(id)!;\n    let maxLevel = -1;\n    if (event.prerequisites) {\n      for (const prereqId of event.prerequisites) {\n        if (eventMap.has(prereqId)) {\n          maxLevel = Math.max(maxLevel, getDepLevel(prereqId));\n        }\n      }\n    }\n    const level = maxLevel + 1;\n    depLevel.set(id, level);\n    return level;\n  }\n  for (const e of events) {\n    getDepLevel(e.id);\n  }\n\n  // Sort events: by dep level first, then by number of valid rooms (most constrained first),\n  // then by duration (longest first)\n  const sortedEventIds = [...orderedIds].sort((a, b) => {\n    const levelA = depLevel.get(a)!;\n    const levelB = depLevel.get(b)!;\n    if (levelA !== levelB) return levelA - levelB;\n\n    const roomsA = getValidRooms(eventMap.get(a)!).length;\n    const roomsB = getValidRooms(eventMap.get(b)!).length;\n    if (roomsA !== roomsB) return roomsA - roomsB;\n\n    return eventMap.get(b)!.duration - eventMap.get(a)!.duration;\n  });\n\n  // Greedy scheduling with backtracking for optimization\n  const assignments = new Map<string, Assignment>();\n  const unscheduled: string[] = [];\n\n  function insertSlot(roomId: string, start: number, end: number, eventId: string): void {\n    const slots = roomSchedules.get(roomId)!;\n    const slot: TimeSlot = { start, end, eventId };\n    // Insert in sorted order by start time\n    let i = 0;\n    while (i < slots.length && slots[i].start < start) i++;\n    slots.splice(i, 0, slot);\n  }\n\n  function removeSlot(roomId: string, eventId: string): void {\n    const slots = roomSchedules.get(roomId)!;\n    const idx = slots.findIndex(s => s.eventId === eventId);\n    if (idx !== -1) slots.splice(idx, 1);\n  }\n\n  // First pass: greedy assignment\n  for (const eventId of sortedEventIds) {\n    const event = eventMap.get(eventId)!;\n    const validRooms = getValidRooms(event);\n\n    if (validRooms.length === 0) {\n      unscheduled.push(eventId);\n      continue;\n    }\n\n    const earliestFromPrereqs = getPrereqEndTime(event, assignments);\n    if (earliestFromPrereqs < 0) {\n      unscheduled.push(eventId);\n      continue;\n    }\n\n    // Try preferred room first if specified\n    const roomOrder = [...validRooms];\n    if (event.preferredRoom) {\n      const prefIdx = roomOrder.findIndex(r => r.id === event.preferredRoom);\n      if (prefIdx > 0) {\n        const [pref] = roomOrder.splice(prefIdx, 1);\n        roomOrder.unshift(pref);\n      }\n    }\n\n    let bestRoom: string | null = null;\n    let bestStart: number | null = null;\n\n    for (const room of roomOrder) {\n      const start = findEarliestSlot(room.id, event.duration, earliestFromPrereqs);\n      if (start !== null) {\n        if (bestStart === null || start < bestStart) {\n          bestRoom = room.id;\n          bestStart = start;\n          // If this is the preferred room, take it immediately\n          if (event.preferredRoom && room.id === event.preferredRoom) {\n            break;\n          }\n        }\n      }\n    }\n\n    if (bestRoom !== null && bestStart !== null) {\n      const endTime = bestStart + event.duration;\n      assignments.set(eventId, {\n        eventId,\n        roomId: bestRoom,\n        startTime: bestStart,\n        endTime,\n      });\n      insertSlot(bestRoom, bestStart, endTime, eventId);\n    } else {\n      unscheduled.push(eventId);\n    }\n  }\n\n  // Second pass: try to schedule unscheduled events by rearranging\n  // For each unscheduled event, see if we can swap or bump an existing assignment\n  if (unscheduled.length > 0) {\n    let improved = true;\n    let iterations = 0;\n    const maxIterations = unscheduled.length * rooms.length;\n\n    while (improved && iterations < maxIterations) {\n      improved = false;\n      iterations++;\n\n      for (let i = unscheduled.length - 1; i >= 0; i--) {\n        const eventId = unscheduled[i];\n        const event = eventMap.get(eventId)!;\n        const validRooms = getValidRooms(event);\n\n        if (validRooms.length === 0) continue;\n\n        const earliestFromPrereqs = getPrereqEndTime(event, assignments);\n        if (earliestFromPrereqs < 0) continue;\n\n        // Try each valid room\n        const roomOrder = [...validRooms];\n        if (event.preferredRoom) {\n          const prefIdx = roomOrder.findIndex(r => r.id === event.preferredRoom);\n          if (prefIdx > 0) {\n            const [pref] = roomOrder.splice(prefIdx, 1);\n            roomOrder.unshift(pref);\n          }\n        }\n\n        let placed = false;\n        for (const room of roomOrder) {\n          const start = findEarliestSlot(room.id, event.duration, earliestFromPrereqs);\n          if (start !== null) {\n            const endTime = start + event.duration;\n            assignments.set(eventId, {\n              eventId,\n              roomId: room.id,\n              startTime: start,\n              endTime,\n            });\n            insertSlot(room.id, start, endTime, eventId);\n            unscheduled.splice(i, 1);\n            placed = true;\n            improved = true;\n            break;\n          }\n        }\n\n        if (!placed) {\n          // Try bumping: find a scheduled event that, if removed,\n          // would allow this event AND the bumped event to both fit\n          for (const room of validRooms) {\n            const slots = roomSchedules.get(room.id)!;\n            for (const slot of slots) {\n              const bumpedEvent = eventMap.get(slot.eventId)!;\n              const bumpedAttendees = bumpedEvent.attendees ?? 1;\n\n              // Remove the bumped event temporarily\n              removeSlot(room.id, slot.eventId);\n              const bumpedAssignment = assignments.get(slot.eventId)!;\n              assignments.delete(slot.eventId);\n\n              // Try to place our event\n              const prereqEnd = getPrereqEndTime(event, assignments);\n              if (prereqEnd >= 0) {\n                const start = findEarliestSlot(room.id, event.duration, prereqEnd);\n                if (start !== null) {\n                  const endTime = start + event.duration;\n                  assignments.set(eventId, {\n                    eventId,\n                    roomId: room.id,\n                    startTime: start,\n                    endTime,\n                  });\n                  insertSlot(room.id, start, endTime, eventId);\n\n                  // Now try to re-place the bumped event somewhere\n                  const bumpedValidRooms = sortedRooms.filter(r => r.capacity >= bumpedAttendees);\n                  const bumpedPrereqEnd = getPrereqEndTime(bumpedEvent, assignments);\n                  let bumpedPlaced = false;\n\n                  if (bumpedPrereqEnd >= 0) {\n                    for (const bRoom of bumpedValidRooms) {\n                      const bStart = findEarliestSlot(bRoom.id, bumpedEvent.duration, bumpedPrereqEnd);\n                      if (bStart !== null) {\n                        const bEnd = bStart + bumpedEvent.duration;\n                        assignments.set(bumpedEvent.id, {\n                          eventId: bumpedEvent.id,\n                          roomId: bRoom.id,\n                          startTime: bStart,\n                          endTime: bEnd,\n                        });\n                        insertSlot(bRoom.id, bStart, bEnd, bumpedEvent.id);\n                        bumpedPlaced = true;\n                        break;\n                      }\n                    }\n                  }\n\n                  if (bumpedPlaced) {\n                    // Success - both events placed\n                    unscheduled.splice(i, 1);\n                    placed = true;\n                    improved = true;\n                    break;\n                  } else {\n                    // Undo - can't place both\n                    removeSlot(room.id, eventId);\n                    assignments.delete(eventId);\n                    assignments.set(bumpedEvent.id, bumpedAssignment);\n                    insertSlot(room.id, bumpedAssignment.startTime, bumpedAssignment.endTime, bumpedEvent.id);\n                  }\n                } else {\n                  // Couldn't place our event, restore\n                  assignments.set(bumpedEvent.id, bumpedAssignment);\n                  insertSlot(room.id, bumpedAssignment.startTime, bumpedAssignment.endTime, bumpedEvent.id);\n                }\n              } else {\n                // prereqs not met, restore\n                assignments.set(bumpedEvent.id, bumpedAssignment);\n                insertSlot(room.id, bumpedAssignment.startTime, bumpedAssignment.endTime, bumpedEvent.id);\n              }\n            }\n            if (placed) break;\n          }\n        }\n      }\n    }\n  }\n\n  return {\n    assignments: Array.from(assignments.values()),\n    unscheduled,\n  };\n}\n","structuredPatch":[],"originalFile":null}}
