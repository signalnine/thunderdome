e ScheduleOptions {\n  startTime: number;\n  endTime: number;\n  gap?: number;\n}\n\nexport interface Assignment {\n  eventId: string;\n  roomId: string;\n  startTime: number;\n  endTime: number;\n}\n\nexport interface ScheduleResult {\n  assignments: Assignment[];\n  unscheduled: string[];\n}\n\nfunction detectCycles(events: Event[]): void {\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  const WHITE = 0, GRAY = 1, BLACK = 2;\n  const color = new Map<string, number>();\n  for (const e of events) {\n    color.set(e.id, WHITE);\n  }\n\n  function dfs(id: string): void {\n    color.set(id, GRAY);\n    const event = eventMap.get(id);\n    if (event?.prerequisites) {\n      for (const prereqId of event.prerequisites) {\n        const c = color.get(prereqId);\n        if (c === GRAY) {\n          throw new Error(`Prerequisite cycle detected involving event \"${prereqId}\"`);\n        }\n        if (c === WHITE) {\n          dfs(prereqId);\n        }\n      }\n    }\n    color.set(id, BLACK);\n  }\n\n  for (const e of events) {\n    if (color.get(e.id) === WHITE) {\n      dfs(e.id);\n    }\n  }\n}\n\nfunction topologicalSort(events: Event[]): string[] {\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  const inDegree = new Map<string, number>();\n  for (const e of events) {\n    if (!inDegree.has(e.id)) inDegree.set(e.id, 0);\n    if (e.prerequisites) {\n      for (const prereqId of e.prerequisites) {\n        if (!inDegree.has(prereqId)) inDegree.set(prereqId, 0);\n      }\n    }\n  }\n\n  // Build adjacency: prereq -> dependents\n  const dependents = new Map<string, string[]>();\n  for (const e of events) {\n    if (e.prerequisites) {\n      for (const prereqId of e.prerequisites) {\n        if (!dependents.has(prereqId)) dependents.set(prereqId, []);\n        dependents.get(prereqId)!.push(e.id);\n        inDegree.set(e.id, (inDegree.get(e.id)