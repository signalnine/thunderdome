+        { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },
+      ];
+      expect(() => schedule(events, rooms, defaultOptions)).toThrow();
+    });
+
+    it('should throw error for multi-event cycle', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 30, prerequisites: ['e3'] },
+        { id: 'e2', name: 'Event 2', duration: 30, prerequisites: ['e1'] },
+        { id: 'e3', name: 'Event 3', duration: 30, prerequisites: ['e2'] },
+      ];
+      expect(() => schedule(events, rooms, defaultOptions)).toThrow();
+    });
+  });
+
+  describe('preferred room', () => {
+    it('should use preferred room when available', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60, attendees: 5, preferredRoom: 'room-b' },
+      ];
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(1);
+      expect(result.assignments[0].roomId).toBe('room-b');
+    });
+
+    it('should use different room when preferred is not feasible', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60, attendees: 15, preferredRoom: 'room-a' },
+      ];
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(1);
+      expect(result.assignments[0].roomId).not.toBe('room-a');
+    });
+  });
+
+  describe('batch optimization', () => {
+    it('should maximize scheduled events when resources are limited', () => {
+      const singleRoom: Room[] = [
+        { id: 'room', name: 'Room', capacity: 100 },
+      ];
+      const tightOptions: ScheduleOptions = {
+        startTime: 540,
+        endTime: 720,  // 3 hours
+        gap: 0,
+      };
+      // Three 60-minute events fit exactly in 3 hours with 0 gap
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+        { id: 'e2', name: 'Event 2', duration: 60 },
+        { id: 'e3', name: 'Event 3', duration: 60 },
+      ];
+      const result = schedule(events, singleRoom, tightOptions);
+      expect(result.assignments).toHaveLength(3);
+      expect(result.unscheduled).toHaveLength(0);
+    });
+
+    it('should handle events that cannot all fit', () => {
+      const singleRoom: Room[] = [
+        { id: 'room', name: 'Room', capacity: 100 },
+      ];
+      const tightOptions: ScheduleOptions = {
+        startTime: 540,
+        endTime: 660,  // 2 hours
+        gap: 0,
+      };
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+        { id: 'e2', name: 'Event 2', duration: 60 },
+        { id: 'e3', name: 'Event 3', duration: 60 },
+      ];
