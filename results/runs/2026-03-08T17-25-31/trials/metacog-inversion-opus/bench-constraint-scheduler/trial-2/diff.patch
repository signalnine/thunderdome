e.id);\n    66→    }\n    67→  }\n    68→}\n    69→\n    70→function topologicalSort(events: Event[]): string[] {\n    71→  const eventMap = new Map<string, Event>();\n    72→  for (const e of events) {\n    73→    eventMap.set(e.id, e);\n    74→  }\n    75→\n    76→  const inDegree = new Map<string, number>();\n    77→  for (const e of events) {\n    78→    if (!inDegree.has(e.id)) inDegree.set(e.id, 0);\n    79→    if (e.prerequisites) {\n    80→      for (const prereqId of e.prerequisites) {\n    81→        if (!inDegree.has(prereqId)) inDegree.set(prereqId, 0);\n    82→      }\n    83→    }\n    84→  }\n    85→\n    86→  // Build adjacency: prereq -> dependents\n    87→  const dependents = new Map<string, string[]>();\n    88→  for (const e of events) {\n    89→    if (e.prerequisites) {\n    90→      for (const prereqId of e.prerequisites) {\n    91→        if (!dependents.has(prereqId)) dependents.set(prereqId, []);\n    92→        dependents.get(prereqId)!.push(e.id);\n    93→        inDegree.set(e.id, (inDegree.get(e.id) || 0) + 1);\n    94→      }\n    95→    }\n    96→  }\n    97→\n    98→  const queue: string[] = [];\n    99→  for (const e of events) {\n   100→    if (inDegree.get(e.id) === 0) {\n   101→      queue.push(e.id);\n   102→    }\n   103→  }\n   104→\n   105→  const result: string[] = [];\n   106→  while (queue.length > 0) {\n   107→    const id = queue.shift()!;\n   108→    result.push(id);\n   109→    const deps = dependents.get(id) || [];\n   110→    for (const depId of deps) {\n   111→      const newDeg = (inDegree.get(depId) || 0) - 1;\n   112→      inDegree.set(depId, newDeg);\n   113→      if (newDeg === 0) {\n   114→        queue.push(depId);\n   115→      }\n   116→    }\n   117→  }\n   118→\n   119→  return result;\n   120→}\n   121→\n   122→export function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {\n   123→  if (events.length === 0) {\n   124→    return { assignments: [], unscheduled: [] };\n   125→  }\n   126→\n   127→  const gap = options.gap ?? 15;\n   128→\n   129→  // Detect cycles - throws if found\n   130→  detectCycles(events);\n   131→\n   132→  const eventMap = new Map<string, Event>();\n   133→  for (const e of events) {\n   134→    eventMap.set(e.id, e);\n   135→  }\n   136→\n   137→  // Sort rooms by capacity ascending for efficient packing\n   138→  const sortedRooms = [...rooms].sort((a, b) => a.capacity - b.capacity);\n   139→\n   140→  // Get topological order\n   141→  const topoOrder = topologicalSort(events);\n   142→\n   143→  // Filter to only events that exist in our event list\n   144→  const eventIds = new Set(events.map(e => e.id));\n   145→  const orderedIds = topoOrder.filter(id => eventIds.has(id));\n   146→\n   147→  // For each event, find which rooms can fit it\n   148→  function getValidRooms(event: Event): Room[] {\n   149→    const attendees = event.attendees ?? 1;\n   150→    return sortedRooms.filter(r => r.capacity >= attendees);\n   151→  }\n   152→\n   153→  // Track room schedules: roomId -> sorted list of {start, end}\n   154→  type TimeSlot = { start: number; end: number; eventId: string };\n   155→  const roomSchedules = new Map<string, TimeSlot[]>();\n   156→  for (const room of rooms) {\n   157→    roomSchedules.set(room.id, []);\n   158→  }\n   159→\n   160→  // Find earliest start time for an event in a given room\n   161→  function findEarliestSlot(roomId: string, duration: number, earliestStart: number): number | null {\n   162→    const slots = roomSchedules.get(roomId)!;\n   163→    let candidateStart = earliestStart;\n   164→\n   165→    for (const slot of slots) {\n   166→      const candidateEnd = candidateStart + duration;\n   167→      if (candidateEnd + gap <= slot.start || candidateStart >= slot.end + gap) {\n   168→        if (candidateEnd <= options.endTime) {\n   169→          // Check if this candidate doesn't overlap with this or any later slot\n   170→          if (candidateEnd + gap <= slot.start) {\n   171→            return candidateStart;\n   172→          }\n   173→          // Move past this slot\n   174→          candidateStart = Math.max(candidateStart, slot.end + gap);\n   175→        } else {\n   176→          return null;\n   177→        }\n   178→      } else {\n   179→        // Overlap - move past this slot\n   180→        candidateStart = slot.end + gap;\n   181→      }\n   182→    }\n   183→\n   184→    // Check if we can fit after all existing slots\n   185→    if (candidateStart + duration <= options.endTime) {\n   186→      return candidateStart;\n   187→    }\n   188→    return null;\n   189→  }\n   190→\n   191→  // Compute earliest possible start for an event based on prerequisites\n   192→  function getPrereqEndTime(event: Event, assignments: Map<string, Assignment>): number {\n   193→    let earliest = options.startTime;\n   194→    if (event.prerequisites) {\n   195→      for (const prereqId of event.prerequisites) {\n   196→        const prereqAssignment = assignments.get(prereqId);\n   197→        if (!prereqAssignment) {\n   198→          return -1; // prereq not scheduled\n   199→        }\n   200→        earliest = Math.max(earliest, prereqAssignment.endTime + gap);\n   201→      }\n   202→    }\n   203→    return earliest;\n   204→  }\n   205→\n   206→  // Try to schedule using a backtracking approach with heuristics\n   207→  // For efficiency, we use a greedy approach with smart ordering:\n   208→  // Process events in topological order, and within the same topo-level,\n   209→  // prioritize events with fewer valid room options (most constrained first)\n   210→\n   211→  // Build dependency levels\n   212→  const depLevel = new Map<string, number>();\n   213→  function getDepLevel(id: string): number {\n   214→    if (depLevel.has(id)) return depLevel.get(id)!;\n   215→    const event = eventMap.get(id)!;\n   216→    let maxLevel = -1;\n   217→    if (event.prerequisites) {\n   218→      for (const prereqId of event.