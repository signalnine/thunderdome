+import { describe, it, expect } from 'vitest';
+import { schedule, Event, Room, ScheduleOptions } from './index.js';
+
+const defaultOptions: ScheduleOptions = {
+  startTime: 540,  // 9:00 AM
+  endTime: 1020,   // 5:00 PM
+};
+
+const rooms: Room[] = [
+  { id: 'room-a', name: 'Room A', capacity: 10 },
+  { id: 'room-b', name: 'Room B', capacity: 20 },
+  { id: 'room-c', name: 'Room C', capacity: 50 },
+];
+
+describe('schedule', () => {
+  describe('basic scheduling', () => {
+    it('should schedule a single event', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+      ];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(1);
+      expect(result.unscheduled).toHaveLength(0);
+
+      const a = result.assignments[0];
+      expect(a.eventId).toBe('e1');
+      expect(a.endTime - a.startTime).toBe(60);
+      expect(a.startTime).toBeGreaterThanOrEqual(540);
+      expect(a.endTime).toBeLessThanOrEqual(1020);
+    });
+
+    it('should schedule multiple events', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+        { id: 'e2', name: 'Event 2', duration: 45 },
+        { id: 'e3', name: 'Event 3', duration: 30 },
+      ];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(3);
+      expect(result.unscheduled).toHaveLength(0);
+    });
+
+    it('should handle empty events', () => {
+      const result = schedule([], rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toHaveLength(0);
+    });
+  });
+
+  describe('room capacity', () => {
+    it('should respect room capacity', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60, attendees: 15 },
+      ];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(1);
+      const a = result.assignments[0];
+      // Should be in room-b (20) or room-c (50), not room-a (10)
+      expect(['room-b', 'room-c']).toContain(a.roomId);
+    });
+
+    it('should mark events as unscheduled if no room has enough capacity', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60, attendees: 100 },
+      ];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toEqual(['e1']);
+    });
+  });
+
+  describe('time window', () => {
+    it('should not schedule events outside the time window', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 500 },
+      ];
+
+      // Window is only 60 minutes
+      const result = schedule(events, rooms, { startTime: 540, endTime: 600 });
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toEqual(['e1']);
+    });
+
+    it('should schedule events within the time window', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+      ];
+
+      const result = schedule(events, rooms, defaultOptions);
+      const a = result.assignments[0];
+      expect(a.startTime).toBeGreaterThanOrEqual(540);
+      expect(a.endTime).toBeLessThanOrEqual(1020);
+    });
+  });
+
+  describe('room gaps', () => {
+    it('should maintain default gap of 15 minutes between events in same room', () => {
+      const smallRooms: Room[] = [{ id: 'r1', name: 'Room 1', capacity: 100 }];
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+        { id: 'e2', name: 'Event 2', duration: 60 },
+      ];
+
+      const result = schedule(events, smallRooms, defaultOptions);
+      expect(result.assignments).toHaveLength(2);
+
+      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);
+      expect(sorted[1].startTime - sorted[0].endTime).toBeGreaterThanOrEqual(15);
+    });
+
+    it('should respect custom gap', () => {
+      const smallRooms: Room[] = [{ id: 'r1', name: 'Room 1', capacity: 100 }];
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+        { id: 'e2', name: 'Event 2', duration: 60 },
+      ];
+
+      const result = schedule(events, smallRooms, { ...defaultOptions, gap: 30 });
+      expect(result.assignments).toHaveLength(2);
+
+      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);
+      expect(sorted[1].startTime - sorted[0].endTime).toBeGreaterThanOrEqual(30);
+    });
+  });
+
+  describe('prerequisites', () => {
+    it('should schedule prerequisites before dependent events', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+        { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },
+      ];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(2);
+
+      const a1 = result.assignments.find(a => a.eventId === 'e1')!;
+      const a2 = result.assignments.find(a => a.eventId === 'e2')!;
+      expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + 15);
+    });
+
+    it('should throw on prerequisite cycles', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['e2'] },
+        { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },
+      ];
+
+      expect(() => schedule(events, rooms, defaultOptions)).toThrow();
+    });
+
+    it('should throw on self-referencing prerequisites', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['e1'] },
+      ];
+
+      expect(() => schedule(events, rooms, defaultOptions)).toThrow();
+    });
+
+    it('should handle chain of prerequisites', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 30 },
+        { id: 'e2', name: 'Event 2', duration: 30, prerequisites: ['e1'] },
+        { id: 'e3', name: 'Event 3', duration: 30, prerequisites: ['e2'] },
+      ];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(3);
+
+      const a1 = result.assignments.find(a => a.eventId === 'e1')!;
+      const a2 = result.assignments.find(a => a.eventId === 'e2')!;
+      const a3 = result.assignments.find(a => a.eventId === 'e3')!;
+
+      expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + 15);
+      expect(a3.startTime).toBeGreaterThanOrEqual(a2.endTime + 15);
+    });
+  });
+
+  describe('preferred room', () => {
+    it('should honor preferred room when possible', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60, attendees: 5, preferredRoom: 'room-c' },
+      ];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(1);
+      expect(result.assignments[0].roomId).toBe('room-c');
+    });
+
+    it('should use another room when preferred room capacity is too small', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60, attendees: 15, preferredRoom: 'room-a' },
+      ];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(1);
+      expect(result.assignments[0].roomId).not.toBe('room-a');
+    });
+  });
+
+  describe('optimization', () => {
+    it('should maximize the number of scheduled events', () => {
+      const tightRooms: Room[] = [
+        { id: 'r1', name: 'Room 1', capacity: 10 },
+      ];
+
+      // Window: 540-660 = 120 minutes, gap: 0
+      // Should fit both 60-minute events
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+        { id: 'e2', name: 'Event 2', duration: 60 },
+      ];
+
+      const result = schedule(events, tightRooms, { startTime: 540, endTime: 660, gap: 0 });
+      expect(result.assignments).toHaveLength(2);
+      expect(result.unscheduled).toHaveLength(0);
+    });
+
+    it('should handle events that cannot all fit', () => {
+      const tightRooms: Room[] = [
+        { id: 'r1', name: 'Room 1', capacity: 10 },
+      ];
+
+      // Window: 120 minutes, gap: 15
+      // Can fit: 60 + 15 + 30 = 105 <= 120 (2 events)
+      // Cannot fit all three
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+        { id: 'e2', name: 'Event 2', duration: 60 },
+        { id: 'e3', name: 'Event 3', duration: 60 },
+      ];
+
+      const result = schedule(events, tightRooms, { startTime: 540, endTime: 660 });
+      // At most one event fits (60 min + 15 gap = 75, but only 120 total, so 60+15+60=135 > 120)
+      // So only 1 event fits
+      expect(result.assignments.length + result.unscheduled.length).toBe(3);
+      expect(result.unscheduled.length).toBeGreaterThan(0);
+    });
+  });
+
+  describe('prerequisite gap enforcement', () => {
+    it('should enforce gap between prerequisite and dependent event', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+        { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },
+      ];
+
+      const result = schedule(events, rooms, { ...defaultOptions, gap: 30 });
+      expect(result.assignments).toHaveLength(2);
+
+      const a1 = result.assignments.find(a => a.eventId === 'e1')!;
+      const a2 = result.assignments.find(a => a.eventId === 'e2')!;
+      expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + 30);
+    });
+  });
+
+  describe('edge cases', () => {
+    it('should handle events with zero gap', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+        { id: 'e2', name: 'Event 2', duration: 60 },
+      ];
+
+      const singleRoom: Room[] = [{ id: 'r1', name: 'Room 1', capacity: 100 }];
+      const result = schedule(events, singleRoom, { ...defaultOptions, gap: 0 });
+      expect(result.assignments).toHaveLength(2);
+
+      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);
+      expect(sorted[1].startTime).toBeGreaterThanOrEqual(sorted[0].endTime);
+    });
+
+    it('should handle default attendees of 1', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+      ];
+
+      const tinyRoom: Room[] = [{ id: 'r1', name: 'Tiny', capacity: 1 }];
+      const result = schedule(events, tinyRoom, defaultOptions);
+      expect(result.assignments).toHaveLength(1);
+    });
+
+    it('should throw on three-event cycle', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['e3'] },
+        { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },
+        { id: 'e3', name: 'Event 3', duration: 60, prerequisites: ['e2'] },
+      ];
+
+      expect(() => schedule(events, rooms, defaultOptions)).toThrow();
+    });
+
+    it('should ignore prerequisites referencing non-existent events', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['non-existent'] },
+      ];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(1);
+      expect(result.unscheduled).toHaveLength(0);
+    });
+  });
+});
