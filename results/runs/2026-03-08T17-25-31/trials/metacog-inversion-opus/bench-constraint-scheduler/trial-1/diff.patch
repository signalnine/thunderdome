port interface ScheduleResult {\n  assignments: Assignment[];\n  unscheduled: string[];\n}\n\nfunction detectCycles(events: Event[]): void {\n  const eventIds = new Set(events.map(e => e.id));\n  const adj = new Map<string, string[]>();\n  for (const e of events) {\n    adj.set(e.id, (e.prerequisites ?? []).filter(p => eventIds.has(p)));\n  }\n\n  const WHITE = 0, GRAY = 1, BLACK = 2;\n  const color = new Map<string, number>();\n  for (const id of eventIds) color.set(id, WHITE);\n\n  function dfs(node: string): boolean {\n    color.set(node, GRAY);\n    for (const neighbor of adj.get(node) ?? []) {\n      const c = color.get(neighbor);\n      if (c === GRAY) return true;\n      if (c === WHITE && dfs(neighbor)) return true;\n    }\n    color.set(node, BLACK);\n    return false;\n  }\n\n  for (const id of eventIds) {\n    if (color.get(id) === WHITE && dfs(id)) {\n      throw new Error('Prerequisite cycle detected');\n    }\n  }\n}\n\n/**\n * Produce multiple topological orderings to try different scheduling strategies.\n * Each ordering respects prerequisite dependencies but varies the tie-breaking.\n */\nfunction topologicalSortVariants(events: Event[]): Event[][] {\n  const eventMap = new Map<string, Event>();\n  for (const e of events) eventMap.set(e.id, e);\n\n  const eventIds = new Set(events.map(e => e.id));\n\n  type Comparator = (a: string, b: string) => number;\n\n  const comparators: Comparator[] = [\n    // Strategy 1: Most constrained first (more prereqs, then longer duration)\n    (a, b) => {\n      const ea = eventMap.get(a)!;\n      const eb = eventMap.get(b)!;\n      const aPrereqs = (ea.prerequisites ?? []).filter(p => eventIds.has(p)).length;\n      const bPrereqs = (eb.prerequisites ?? []).filter(p => eventIds.has(p)).length;\n      if (aPrereqs !== bPrereqs) return bPrereqs - aPrereqs;\n      return eb.duration - ea.duration;\n    },\n    // Strategy 2: Longest duration first\n    (a, b) => {\n      const ea = eventMap.get(a)!;\n      const eb = eventMap.get(b)!;\n      return eb.duration - ea.duration;\n    },\n    // Strategy 3: Shortest duration first (fit more events)\n    (a, b) => {\n      const ea = eventMap.get(a)!;\n      const eb = eventMap.get(b)!;\n      return ea.duration - eb.duration;\n    },\n    // Strategy 4: Most attendees first (harder to place due to capacity)\n    (a, b) => {\n      const ea = eventMap.get(a)!;\n      const eb = eventMap.get(b)!;\n      return (eb.attendees ?? 1) - (ea.attendees ?? 1);\n    },\n  ];\n\n  const results: Event[][] = [];\n\n  for (const comparator of comparators) {\n    const inDegree = new Map<string, number>();\n    const adj = new Map<string, string[]>();\n\n    for (const e of events) {\n      inDegree.set(e.id, 0);\n      adj.set(e.id, []);\n    }\n\n    for (const e of events) {\n      for (const prereq of e.prerequisites ?? []) {\n        if (eventIds.has(prereq)) {\n          adj.get(prereq)!.push(e.id);\n          inDegree.set(e.id, (inDegree.get(e.id) ?? 0) + 1);\n        }\n      }\n    }\n\n    const queue: string[] = [];\n    for (const [id, deg] of inDegree) {\n      if (deg === 0) queue.push(id);\n    }\n\n    const sorted: Event[] = [];\n    while (queue.length > 0) {\n      queue.sort(comparator);\n      const id = queue.shift()!;\n      sorted.push(eventMap.get(id)!);\n      for (const neighbor of adj.get(id) ?? []) {\n        const newDeg = (inDegree.get(neighbor) ?? 1) - 1;\n        inDegree.set(neighbor, newDeg);\n        if (newDeg === 0) queue.push(neighbor);\n      }\n    }\n\n    results.push(sorted);\n  }\n\n  return results;\n}\n\nfunction getEarliestStartAfterPrereqs(\n  event: Event,\n  assignments: Map<string, Assignment>,\n  gap: number,\n  startTime: number,\n): number {\n  let earliest = startTime;\n  for (const prereqId of event.prerequisites ?? []) {\n    const prereqAssignment = assignments.get(prereqId);\n    if (prereqAssignment) {\n      earliest = Math.max(earliest, prereqAssignment.endTime + gap);\n    }\n  }\n  return earliest;\n}\n\ninterface RoomSlot {\n  startTime: number;\n  endTime: number;\n}\n\nfunction findEarliestSlot(\n  roomSchedule: RoomSlot[],\n  duration: number,\n  earliest: number,\n  endTime: number,\n  gap: number,\n): number | null {\n  if (roomSchedule.length === 0) {\n    if (earliest + duration <= endTime) return earliest;\n    return null;\n  }\n\n  const sorted = [...roomSchedule].sort((a, b) => a.startTime - b.startTime);\n\n  // Try before first event\n  if (earliest + duration <= endTime) {\n    if (earliest + duration + gap <= sorted[0].startTime || earliest + duration <= sorted[0].startTime - gap + gap) {\n      // Check gap: our end + gap <= first event start\n      if (earliest + duration + gap <= sorted[0].startTime) {\n        return earliest;\n      }\n      // If gap is 0, just need our end <= first event start\n      if (gap === 0 && earliest + duration <= sorted[0].startTime) {\n        return earliest;\n      }\n    }\n  }\n\n  // Try after each existing event\n  for (let i = 0; i < sorted.length; i++) {\n    const slotStart = Math.max(earliest, sorted[i].endTime + gap);\n\n    if (i + 1 < sorted.length) {\n      // Between events: need slotStart + duration + gap <= next event start\n      if (slotStart + duration + gap <= sorted[i + 1].startTime && slotStart + duration <= endTime) {\n        return slotStart;\n      }\n      // Special case for gap=0: just need no overlap\n      if (gap === 0 && slotStart + duration <= sorted[i + 1].startTime && slotStart + duration <= endTime) {\n        return slotStart;\n      }\n    } else {\n      // After last event: just need to fit in time window\n      if (slotStart + duration <= endTime) {\n        return slotStart;\n      }\n    }\n  }\n\n  return null;\n}\n\nexport function schedule(\n  events: Event[],\n  rooms: Room[],\n  options: ScheduleOptions,\n): ScheduleResult {\n  if (events.length === 0) {\n    return { assignments: [], unscheduled: [] };\n  }\n\n  detectCycles(events);\n\n  const gap = options.gap ?? 15;\n  const { startTime, endTime } = options;\n  const eventIds = new Set(events.map(e => e.id));\n\n  const sortedRooms = [...rooms].sort((a, b) => a.capacity - b.capacity);\n\n  // Try multiple topological orderings and pick the best result\n  const variants = topologicalSortVariants(events);\n\n  let bestResult: ScheduleResult | null = null;\n\n  for (const ordering of variants) {\n    const result = greedySchedule(ordering, sortedRooms, gap, startTime, endTime, eventIds);\n    if (!bestResult || result.assignments.length > bestResult.assignments.length) {\n      bestResult = result;\n    }\n    // If we scheduled everything, no need to try more orderings\n    if (bestResult.unscheduled.length === 0) break;\n  }\n\n  return bestResult!;\n}\n\nfunction greedySchedule(\n  sortedEvents: Event[],\n  sortedRooms: Room[],\n  gap: number,\n  startTime: number,\n  endTime: number,\n  eventIds: Set<string>,\n): ScheduleResult {\n  const assignments = new Map<string, Assignment>();\n  const roomSchedules = new Map<string, RoomSlot[]>();\n  const unscheduled: string[] = [];\n\n  for (const room of sortedRooms) {\n    roomSchedules.set(room.id, []);\n  }\n\n  for (const event of sortedEvents) {\n    const attendees = event.attendees ?? 1;\n\n    // Check if all prerequisites are scheduled\n    const prereqs = (event.prerequisites ?? []).filter(p => eventIds.has(p));\n    const allPrereqsScheduled = prereqs.every(p => assignments.has(p));\n\n    if (!allPrereqsScheduled) {\n      unscheduled.push(event.id);\n      continue;\n    }\n\n    const earliestAfterPrereqs = getEarliestStartAfterPrereqs(\n      event, assignments, gap, startTime,\n    );\n\n    if (earliestAfterPrereqs + event.duration > endTime) {\n      unscheduled.push(event.id);\n      continue;\n    }\n\n    // Find eligible rooms (capacity check)\n    const eligibleRooms = sortedRooms.filter(r => r.capacity >= attendees);\n    if (eligibleRooms.length === 0) {\n      unscheduled.push(event.