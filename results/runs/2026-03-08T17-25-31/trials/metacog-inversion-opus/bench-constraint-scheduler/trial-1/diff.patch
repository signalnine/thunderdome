\nexport interface Assignment {\n  eventId: string;\n  roomId: string;\n  startTime: number;\n  endTime: number;\n}\n\nexport interface ScheduleResult {\n  assignments: Assignment[];\n  unscheduled: string[];\n}\n\nfunction detectCycles(events: Event[]): void {\n  const eventIds = new Set(events.map(e => e.id));\n  const adj = new Map<string, string[]>();\n  for (const e of events) {\n    adj.set(e.id, (e.prerequisites ?? []).filter(p => eventIds.has(p)));\n  }\n\n  const WHITE = 0, GRAY = 1, BLACK = 2;\n  const color = new Map<string, number>();\n  for (const id of eventIds) color.set(id, WHITE);\n\n  function dfs(node: string): boolean {\n    color.set(node, GRAY);\n    for (const neighbor of adj.get(node) ?? []) {\n      const c = color.get(neighbor);\n      if (c === GRAY) return true;\n      if (c === WHITE && dfs(neighbor)) return true;\n    }\n    color.set(node, BLACK);\n    return false;\n  }\n\n  for (const id of eventIds) {\n    if (color.get(id) === WHITE && dfs(id)) {\n      throw new Error('Prerequisite cycle detected');\n    }\n  }\n}\n\nfunction topologicalSort(events: Event[]): Event[] {\n  const eventMap = new Map<string, Event>();\n  for (const e of events) eventMap.set(e.id, e);\n\n  const eventIds = new Set(events.map(e => e.id));\n  const inDegree = new Map<string, number>();\n  const adj = new Map<string, string[]>();\n\n  for (const e of events) {\n    inDegree.set(e.id, 0);\n    adj.set(e.id, []);\n  }\n\n  for (const e of events) {\n    for (const prereq of e.prerequisites ?? []) {\n      if (eventIds.has(prereq)) {\n        adj.get(prereq)!.push(e.id);\n        inDegree.set(e.id, (inDegree.get(e.id) ?? 0) + 1);\n      }\n    }\n  }\n\n  const queue: string[] = [];\n  for (const [id, deg] of inDegree) {\n    if (deg === 0) queue.push(id);\n  }\n\n  const sorted: Event[] = [];\n  while (queue.length > 0) {\n    queue.sort((a, b) => {\n      const ea = eventMap.get(a)!;\n      const eb = eventMap.get(b)!;\n      // Process events with more prerequisites first (they're more constrained)\n      const aPrereqs = (ea.prerequisites ?? []).filter(p => eventIds.has(p)).length;\n      const bPrereqs = (eb.prerequisites ?? []).filter(p => eventIds.has(p)).length;\n      if (aPrereqs !== bPrereqs) return bPrereqs - aPrereqs;\n      // Then by duration (longer events first - harder to place)\n      return eb.duration - ea.duration;\n    });\n    const id = queue.shift()!;\n    sorted.push(eventMap.get(id)!);\n    for (const neighbor of adj.get(id) ?? []) {\n      const newDeg = (inDegree.get(neighbor) ?? 1) - 1;\n      inDegree.set(neighbor, newDeg);\n      if (newDeg === 0) queue.push(neighbor);\n    }\n  }\n\n  return sorted;\n}\n\nfunction getEarliestStartAfterPrereqs(\n  event: Event,\n  assignments: Map<string, Assignment>,\n  gap: number,\n  startTime: number,\n): number {\n  let earliest = startTime;\n  for (const prereqId of event.prerequisites ?? []) {\n    const prereqAssignment = assignments.get(prereqId);\n    if (prereqAssignment) {\n      earliest = Math.max(earliest, prereqAssignment.endTime + gap);\n    }\n  }\n  return earliest;\n}\n\ninterface RoomSlot {\n  startTime: number;\n  endTime: number;\n}\n\nfunction findEarliestSlot(\n  roomSchedule: RoomSlot[],\n  duration: number,\n  earliest: number,\n  endTime: number,\n  gap: number,\n): number | null {\n  if (roomSchedule.length === 0) {\n    if (earliest + duration <= endTime) return earliest;\n    return null;\n  }\n\n  // Sort by start time\n  const sorted = [...roomSchedule].sort((a, b) => a.startTime - b.startTime);\n\n  // Try before first event\n  if (earliest + duration + gap <= sorted[0].startTime) {\n    return earliest;\n  }\n\n  // Try between events\n  for (let i = 0; i < sorted.length; i++) {\n    const slotStart = Math.max(earliest, sorted[i].endTime + gap);\n    const slotEnd = i + 1 < sorted.length ? sorted[i + 1].startTime - gap : endTime;\n    if (slotStart + duration <= slotEnd) {\n      // Also make sure we don't violate gap 