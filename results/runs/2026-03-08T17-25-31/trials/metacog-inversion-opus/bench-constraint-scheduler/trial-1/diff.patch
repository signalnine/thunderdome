ost events\n\n  const bestResult = greedySchedule(sorted, sortedRooms, gap, startTime, endTime, eventIds);\n\n  return bestResult;\n}\n\nfunction greedySchedule(\n  sortedEvents: Event[],\n  sortedRooms: Room[],\n  gap: number,\n  startTime: number,\n  endTime: number,\n  eventIds: Set<string>,\n): ScheduleResult {\n  const assignments = new Map<string, Assignment>();\n  const roomSchedules = new Map<string, RoomSlot[]>();\n  const unscheduled: string[] = [];\n\n  for (const room of sortedRooms) {\n    roomSchedules.set(room.id, []);\n  }\n\n  for (const event of sortedEvents) {\n    const attendees = event.attendees ?? 1;\n\n    // Check if all prerequisites are scheduled\n    const prereqs = (event.prerequisites ?? []).filter(p => eventIds.has(p));\n    const allPrereqsScheduled = prereqs.every(p => assignments.has(p));\n\n    if (!allPrereqsScheduled) {\n      unscheduled.push(event.id);\n      continue;\n    }\n\n    const earliestAfterPrereqs = getEarliestStartAfterPrereqs(\n      event, assignments, gap, startTime,\n    );\n\n    if (earliestAfterPrereqs + event.duration > endTime) {\n      unscheduled.push(event.id);\n      continue;\n    }\n\n    // Find eligible rooms (capacity check)\n    const eligibleRooms = sortedRooms.filter(r => r.capacity >= attendees);\n    if (eligibleRooms.length === 0) {\n      unscheduled.push(event.id);\n      continue;\n    }\n\n    // Try preferred room first, then others\n    const orderedRooms = orderRooms(eligibleRooms, event.preferredRoom);\n\n    let bestPlacement: { roomId: string; start: number } | null = null;\n\n    for (const room of orderedRooms) {\n      const schedule = roomSchedules.get(room.id);\n      if (!schedule) continue;\n\n      const slotStart = findEarliestSlot(\n        schedule,\n        event.duration,\n        earliestAfterPrereqs,\n        endTime,\n        gap,\n      );\n\n      if (slotStart !== null) {\n        if (!bestPlacement || slotStart < bestPlacement.start) {\n          bestPlacement = { roomId: room.id, start: slotStart };\n          // If this is the preferred room and it can fit, use it\n          if (room.id === event.preferredRoom) break;\n        }\n        // If we already have a placement at the earliest possible time, stop\n        if (bestPlacement.start === earliestAfterPrereqs) {\n          // But prefer preferred room even if same time\n          if (room.id === event.preferredRoom) {\n            bestPlacement = { roomId: room.id, start: slotStart };\n          }\n          break;\n        }\n      }\n    }\n\n    if (bestPlacement) {\n      const assignment: Assignment = {\n        eventId: event.id,\n        roomId: bestPlacement.roomId,\n        startTime: bestPlacement.start,\n        endTime: bestPlacement.start + event.duration,\n      };\n      assignments.set(event.id, assignment);\n      roomSchedules.get(bestPlacement.roomId)!.push({\n        startTime: assignment.startTime,\n        endTime: assignment.endTime,\n      });\n    } else {\n      unscheduled.push(event.id);\n    }\n  }\n\n  return {\n    assignments: Array.from(assignments.values()),\n    unscheduled,\n  };\n}\n\nfunction orderRooms(eligibleRooms: Room[], preferredRoom?: string): Room[] {\n  if (!preferredRoom) return eligibleRooms;\n\n  const preferred = eligibleRooms.find(r => r.id === preferredRoom);\n  if (!preferred) return eligibleRooms;\n\n  return [preferred, ...eligibleRooms.filter(r => r.id !== preferredRoom)];\n}\n","structuredPatch":[],"originalFile":null}}
