 });\n    const res = await request(app).post('/auth/login').send({ username: 'alice', password: 'pass' });\n    expect(res.status).toBe(200);\n    expect(res.body.token).toBeDefined();\n    expect(res.body.userId).toBeDefined();\n  });\n\n  it('should reject wrong credentials', async () => {\n    await request(app).post('/auth/register').send({ username: 'alice', password: 'pass' });\n    const res = await request(app).post('/auth/login').send({ username: 'alice', password: 'wrong' });\n    expect(res.status).toBe(401);\n  });\n\n  it('should reject missing credentials on login', async () => {\n    const res = await request(app).post('/auth/login').send({});\n    expect(res.status).toBe(400);\n  });\n});\n\ndescribe('Folders', () => {\n  it('should require auth', async () => {\n    const res = await request(app).post('/folders').send({ name: 'test' });\n    expect(res.status).toBe(401);\n  });\n\n  it('should create a folder', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const res = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'My Folder' });\n    expect(res.status).toBe(201);\n    expect(res.body.name).toBe('My Folder');\n    expect(res.body.parentId).toBeNull();\n  });\n\n  it('should reject folder without name', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const res = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({});\n    expect(res.status).toBe(400);\n  });\n\n  it('should create nested folders', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const parent = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Parent' });\n    const child = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Child', parentId: parent.body.id });\n    expect(child.status).toBe(201);\n    expect(child.body.parentId).toBe(parent.body.id);\n  });\n\n  it('should reject nested folder in non-existent parent', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const res = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Child', parentId: '999' });\n    expect(res.status).toBe(404);\n  });\n\n  it('should get folder with children and documents', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Root' });\n    const child = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Child', parentId: folder.body.id });\n\n    const res = await request(app)\n      .get(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.children).toContain(child.body.id);\n  });\n\n  it('should update folder name', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Old Name' });\n\n    const res = await request(app)\n      .put(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'New Name' });\n    expect(res.status).toBe(200);\n    expect(res.body.name).toBe('New Name');\n  });\n\n  it('should delete folder', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'ToDelete' });\n\n    const del = await request(app)\n      .delete(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(del.status).toBe(204);\n\n    const get = await request(app)\n      .get(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(get.status).toBe(404);\n  });\n\n  it('should cascade delete folder contents', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const parent = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Parent' });\n    const child = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Child', parentId: parent.body.id });\n    const doc = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ title: 'Doc', content: 'text', folderId: child.body.id });\n\n    await request(app)\n      .delete(`/folders/${parent.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n\n    const getChild = await request(app)\n      .get(`/folders/${child.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(getChild.status).toBe(404);\n\n    const getDoc = await request(app)\n      .get(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(getDoc.status).toBe(404);\n  });\n});\n\ndescribe('Documents', () => {\n  it('should create a document', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Folder' });\n    const res = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ title: 'Doc', content: 'Hello World', folderId: folder.body.id });\n    expect(res.status).toBe(201);\n    expect(res.body.title).toBe('Doc');\n    expect(res.body.content).toBe('Hello World');\n    expect(res.body.folderId).toBe(folder.body.id);\n  });\n\n  it('should reject document