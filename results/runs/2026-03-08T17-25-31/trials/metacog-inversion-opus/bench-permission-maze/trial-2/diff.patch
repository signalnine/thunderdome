+++ b/src/routes/folders.ts
@@ -0,0 +1,166 @@
+import { Router, Response } from 'express';
+import { Store, generateId } from '../types.js';
+import { AuthRequest, authMiddleware } from '../middleware.js';
+import { getEffectiveRole, hasAtLeast } from '../permissions.js';
+
+export function folderRoutes(store: Store): Router {
+  const router = Router();
+  router.use(authMiddleware(store));
+
+  // Create folder
+  router.post('/', (req: AuthRequest, res: Response): void => {
+    const userId = req.userId!;
+    const { name, parentId } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: 'Folder name is required' });
+      return;
+    }
+
+    if (parentId) {
+      const parent = store.folders.get(parentId);
+      if (!parent) {
+        res.status(404).json({ error: 'Parent folder not found' });
+        return;
+      }
+      // Need at least editor on parent to create subfolder
+      const role = getEffectiveRole(store, userId, 'folder', parentId);
+      if (!role || !hasAtLeast(role, 'editor')) {
+        res.status(403).json({ error: 'Insufficient permissions on parent folder' });
+        return;
+      }
+    }
+
+    const id = generateId(store);
+    const folder = {
+      id,
+      name,
+      parentId: parentId || null,
+      ownerId: userId,
+      createdAt: new Date().toISOString(),
+    };
+    store.folders.set(id, folder);
+
+    // Owner permission
+    store.permissions.push({
+      id: generateId(store),
+      resourceType: 'folder',
+      resourceId: id,
+      userId,
+      role: 'owner',
+    });
+
+    res.status(201).json(folder);
+  });
+
+  // Get folder
+  router.get('/:id', (req: AuthRequest, res: Response): void => {
+    const userId = req.userId!;
+    const folder = store.folders.get(req.params.id);
+
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, userId, 'folder', folder.id);
+    if (!role) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    // Include child folders and documents
+    const children: string[] = [];
+    for (const f of store.folders.values()) {
+      if (f.parentId === folder.id) children.push(f.id);
+    }
+    const documents: string[] = [];
+    for (const d of store.documents.values()) {
+      if (d.folderId === folder.id) documents.push(d.id);
+    }
+
+    res.status(200).json({ ...folder, children, documents });
+  });
+
+  // Update folder
+  router.put('/:id', (req: AuthRequest, res: Response): void => {
+    const userId = req.userId!;
+    const folder = store.folders.get(req.params.id);
+
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, userId, 'folder', folder.id);
+    if (!role || !hasAtLeast(role, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    if (req.body.name !== undefined) {
+      folder.name = req.body.name;
+    }
+    if (req.body.parentId !== undefined) {
+      if (req.body.parentId !== null) {
+        const parent = store.folders.get(req.body.parentId);
+        if (!parent) {
+          res.status(404).json({ error: 'Parent folder not found' });
+          return;
+        }
+      }
+      folder.parentId = req.body.parentId;
+    }
+
+    res.status(200).json(folder);
+  });
+
+  // Delete folder
+  router.delete('/:id', (req: AuthRequest, res: Response): void => {
+    const userId = req.userId!;
+    const folder = store.folders.get(req.params.id);
+
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, userId, 'folder', folder.id);
+    if (!role || !hasAtLeast(role, 'owner')) {
+      res.status(403).json({ error: 'Only owners can delete folders' });
+      return;
+    }
+
+    // Delete folder and its contents recursively
+    deleteFolderRecursive(store, folder.id);
+
+    res.status(204).send();
+  });
+
+  return router;
+}
+
+function deleteFolderRecursive(store: Store, folderId: string): void {
+  // Delete child folders
+  for (const folder of store.folders.values()) {
+    if (folder.parentId === folderId) {
+      deleteFolderRecursive(store, folder.id);
+    }
+  }
+
+  // Delete documents in this folder
+  for (const doc of store.documents.values()) {
+    if (doc.folderId === folderId) {
+      store.documents.delete(doc.id);
+      store.permissions = store.permissions.filter(
+        (p) => !(p.resourceType === 'document' && p.resourceId === doc.id)
+      );
+    }
+  }
+
+  // Delete the folder itself
+  store.folders.delete(folderId);
+  store.permissions = store.permissions.filter(
+    (p) => !(p.resourceType === 'folder' && p.resourceId === folderId)
+  );
+}
diff --git a/src/routes/sharing.ts b/src/routes/sharing.ts
new file mode 100644
index 0000000..d87fe52
--- /dev/null
+++ b/src/routes/sharing.ts
@@ -0,0 +1,99 @@
+import { Router, Response } from 'express';
+import { Store, generateId, ResourceType, Role } from '../types.js';
+import { AuthRequest, authMiddleware } from '../middleware.js';
+import { getEffectiveRole, hasAtLeast } from '../permissions.js';
+
+export function sharingRoutes(store: Store): Router {
+  const router = Router();
+  router.use(authMiddleware(store));
+
+  // Share a resource
+  router.post('/', (req: AuthRequest, res: Response): void => {
+    const userId = req.userId!;
+    const { resourceType, resourceId, targetUserId, role } = req.body as {
+      resourceType?: ResourceType;
+      resourceId?: string;
+      targetUserId?: string;
+      role?: Role;
+    };
+
+    if (!resourceType || !resourceId || !targetUserId || !role) {
+      res.status(400).json({ error: 'resourceType, resourceId, targetUserId, and role are required' });
+      return;
+    }
+
+    if (!['folder', 'document'].includes(resourceType)) {
+      res.status(400).json({ error: 'resourceType must be folder or document' });
+      return;
+    }
+
+    if (!['viewer', 'editor', 'owner'].includes(role)) {
+      res.status(400).json({ error: 'role must be viewer, editor, or owner' });
+      return;
+    }
+
+    // Verify target user exists
+    if (!store.users.has(targetUserId)) {
+      res.status(404).json({ error: 'Target user not found' });
+      return;
+    }
+
+    // Verify resource exists
+    if (resourceType === 'folder' && !store.folders.has(resourceId)) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+    if (resourceType === 'document' && !store.documents.has(resourceId)) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    // Check that the sharing user has sufficient permissions
+    const sharerRole = getEffectiveRole(store, userId, resourceType, resourceId);
+    if (!sharerRole || !hasAtLeast(sharerRole, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions to share' });
+      return;
+    }
+
+    // Owners can assign any role; editors can only assign viewer or editor
+    if (role === 'owner' && !hasAtLeast(sharerRole, 'owner')) {
+      res.status(403).json({ error: 'Only owners can assign the owner role' });
+      return;
+    }
+
+    // Check if permission already exists, update if so
+    const existing = store.permissions.find(
+      (p) =>
+        p.resourceType === resourceType &&
+        p.resourceId === resourceId &&
+        p.userId === targetUserId
+    );
+
+    if (existing) {
+      existing.role = role;
+    } else {
+      store.permissions.push({
+        id: generateId(store),
+        resourceType,
+        resourceId,
+        userId: targetUserId,
+        role,
+      });
+    }
+
+    const now = new Date().toISOString();
+    store.activityLog.push({
+      id: generateId(store),
+      action: 'resource_shared',
+      userId,
+      resourceType,
+      resourceId,
+      timestamp: now,
+      details: `Shared with user ${targetUserId} as ${role}`,
+    });
+
+    res.status(200).json({ message: 'Permission granted', resourceType, resourceId, targetUserId, role });
+  });
+
+  return router;
+}
diff --git a/src/types.ts b/src/types.ts
new file mode 100644
index 0000000..78bef5c
--- /dev/null
+++ b/src/types.ts
@@ -0,0 +1,72 @@
+export type Role = 'viewer' | 'editor' | 'owner';
+
+export interface User {
+  id: string;
+  username: string;
+  password: string;
+  token?: string;
+}
+
+export interface Folder {
+  id: string;
+  name: string;
+  parentId: string | null;
+  ownerId: string;
+  createdAt: string;
+}
+
+export interface Document {
+  id: string;
+  title: string;
+  content: string;
+  folderId: string;
+  ownerId: string;
+  createdAt: string;
+  updatedAt: string;
+}
+
+export type ResourceType = 'folder' | 'document';
+
+export interface Permission {
+  id: string;
+  resourceType: ResourceType;
+  resourceId: string;
+  userId: string;
+  role: Role;
+}
+
+export interface ActivityLogEntry {
+  id: string;
+  action: string;
+  userId: string;
+  resourceType: ResourceType;
+  resourceId: string;
+  timestamp: string;
+  details?: string;
+}
+
+export interface Store {
+  users: Map<string, User>;
+  tokens: Map<string, string>; // token -> userId
+  folders: Map<string, Folder>;
+  documents: Map<string, Document>;
+  permissions: Permission[];
+  activityLog: ActivityLogEntry[];
+  nextId: number;
+}
+
+export function createStore(): Store {
+  return {
+    users: new Map(),
+    tokens: new Map(),
+    folders: new Map(),
+    documents: new Map(),
+    permissions: [],
+    activityLog: [],
+    nextId: 1,
+  };
+}
+
+export function generateId(store: Store): string {
+  return String(store.nextId++);
+}
