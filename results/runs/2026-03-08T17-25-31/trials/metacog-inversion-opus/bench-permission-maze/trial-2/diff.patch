Type === 'document' && !store.documents.has(resourceId)) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n\n    // Check that the sharing user has sufficient permissions\n    const sharerRole = getEffectiveRole(store, userId, resourceType, resourceId);\n    if (!sharerRole || !hasAtLeast(sharerRole, 'editor')) {\n      res.status(403).json({ error: 'Insufficient permissions to share' });\n      return;\n    }\n\n    // Owners can assign any role; editors can only assign viewer or editor\n    if (role === 'owner' && !hasAtLeast(sharerRole, 'owner')) {\n      res.status(403).json({ error: 'Only owners can assign the owner role' });\n      return;\n    }\n\n    // Check if permission already exists, update if so\n    const existing = store.permissions.find(\n      (p) =>\n        p.resourceType === resourceType &&\n        p.resourceId === resourceId &&\n        p.userId === targetUserId\n    );\n\n    if (existing) {\n      existing.role = role;\n    } else {\n      store.permissions.push({\n        id: generateId(store),\n        resourceType,\n        resourceId,\n        userId: targetUserId,\n        role,\n      });\n    }\n\n    const now = new Date().toISOString();\n    store.activityLog.push({\n      id: generateId(store),\n      action: 'resource_shared',\n      userId,\n      resourceType,\n      resourceId,\n      timestamp: now,\n      details: `Shared with user ${targetUserId} as ${role}`,\n    });\n\n    res.status(200).json({ message: 'Permission granted', resourceType, resourceId, targetUserId, role });\n  });\n\n  return router;\n}\n","structuredPatch":[],"originalFile":null}}
