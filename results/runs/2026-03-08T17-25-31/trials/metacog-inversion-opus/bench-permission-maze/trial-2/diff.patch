 bestRole = bestRole ? higherRole(bestRole, folderRole) : folderRole;\n      }\n    }\n  } else if (resourceType === 'folder') {\n    // Check ancestor folder permissions\n    const ancestorIds = getAncestorFolderIds(store, resourceId);\n    for (const ancestorId of ancestorIds) {\n      for (const perm of store.permissions) {\n        if (\n          perm.resourceType === 'folder' &&\n          perm.resourceId === ancestorId &&\n          perm.userId === userId\n        ) {\n          bestRole = bestRole ? higherRole(bestRole, perm.role) : perm.role;\n        }\n      }\n    }\n  }\n\n  return bestRole;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":545,"cache_read_input_tokens":20251,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":545},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"f4d1177d-b41f-492c-870d-e7755f84104c","uuid":"4eae36a9-cc73-4a47-b8d2-0a3a0d3b06d1"}
