@@ -0,0 +1,161 @@
+import { Router, Response } from 'express';
+import { Store, generateId } from '../types.js';
+import { AuthRequest, authMiddleware } from '../middleware.js';
+import { getEffectiveRole, hasAtLeast } from '../permissions.js';
+
+export function documentRoutes(store: Store): Router {
+  const router = Router();
+  router.use(authMiddleware(store));
+
+  // Create document
+  router.post('/', (req: AuthRequest, res: Response): void => {
+    const userId = req.userId!;
+    const { title, content, folderId } = req.body;
+
+    if (!title || content === undefined || !folderId) {
+      res.status(400).json({ error: 'Title, content, and folderId are required' });
+      return;
+    }
+
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    // Need at least editor on the folder to create documents
+    const folderRole = getEffectiveRole(store, userId, 'folder', folderId);
+    if (!folderRole || !hasAtLeast(folderRole, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions on folder' });
+      return;
+    }
+
+    const id = generateId(store);
+    const now = new Date().toISOString();
+    const doc = {
+      id,
+      title,
+      content,
+      folderId,
+      ownerId: userId,
+      createdAt: now,
+      updatedAt: now,
+    };
+    store.documents.set(id, doc);
+
+    // Owner permission
+    store.permissions.push({
+      id: generateId(store),
+      resourceType: 'document',
+      resourceId: id,
+      userId,
+      role: 'owner',
+    });
+
+    // Activity log
+    store.activityLog.push({
+      id: generateId(store),
+      action: 'document_created',
+      userId,
+      resourceType: 'document',
+      resourceId: id,
+      timestamp: now,
+    });
+
+    res.status(201).json(doc);
+  });
+
+  // Get document
+  router.get('/:id', (req: AuthRequest, res: Response): void => {
+    const userId = req.userId!;
+    const doc = store.documents.get(req.params.id);
+
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, userId, 'document', doc.id);
+    if (!role) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    res.status(200).json(doc);
+  });
+
+  // Update document
+  router.put('/:id', (req: AuthRequest, res: Response): void => {
+    const userId = req.userId!;
+    const doc = store.documents.get(req.params.id);
+
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, userId, 'document', doc.id);
+    if (!role || !hasAtLeast(role, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    if (req.body.title !== undefined) {
+      doc.title = req.body.title;
+    }
+    if (req.body.content !== undefined) {
+      doc.content = req.body.content;
+    }
+    doc.updatedAt = new Date().toISOString();
+
+    // Activity log
+    store.activityLog.push({
+      id: generateId(store),
+      action: 'document_updated',
+      userId,
+      resourceType: 'document',
+      resourceId: doc.id,
+      timestamp: doc.updatedAt,
+    });
+
+    res.status(200).json(doc);
+  });
+
+  // Delete document
+  router.delete('/:id', (req: AuthRequest, res: Response): void => {
+    const userId = req.userId!;
+    const doc = store.documents.get(req.params.id);
+
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, userId, 'document', doc.id);
+    if (!role || !hasAtLeast(role, 'owner')) {
+      res.status(403).json({ error: 'Only owners can delete documents' });
+      return;
+    }
+
+    const now = new Date().toISOString();
+
+    // Activity log
+    store.activityLog.push({
+      id: generateId(store),
+      action: 'document_deleted',
+      userId,
+      resourceType: 'document',
+      resourceId: doc.id,
+      timestamp: now,
+    });
+
+    store.documents.delete(doc.id);
+    store.permissions = store.permissions.filter(
+      (p) => !(p.resourceType === 'document' && p.resourceId === doc.id)
+    );
+
+    res.status(204).send();
+  });
+
+  return router;
+}
