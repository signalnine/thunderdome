+import { Store, Role, ResourceType } from './types.js';
+
+const ROLE_LEVEL: Record<Role, number> = {
+  viewer: 1,
+  editor: 2,
+  owner: 3,
+};
+
+export function higherRole(a: Role, b: Role): Role {
+  return ROLE_LEVEL[a] >= ROLE_LEVEL[b] ? a : b;
+}
+
+export function hasAtLeast(actual: Role, required: Role): boolean {
+  return ROLE_LEVEL[actual] >= ROLE_LEVEL[required];
+}
+
+function getAncestorFolderIds(store: Store, folderId: string): string[] {
+  const ancestors: string[] = [];
+  let currentId: string | null = folderId;
+  const visited = new Set<string>();
+  while (currentId) {
+    if (visited.has(currentId)) break;
+    visited.add(currentId);
+    const folder = store.folders.get(currentId);
+    if (!folder) break;
+    if (folder.parentId) {
+      ancestors.push(folder.parentId);
+      currentId = folder.parentId;
+    } else {
+      break;
+    }
+  }
+  return ancestors;
+}
+
+export function getEffectiveRole(
+  store: Store,
+  userId: string,
+  resourceType: ResourceType,
+  resourceId: string
+): Role | null {
+  let bestRole: Role | null = null;
+
+  // Check direct permissions on the resource
+  for (const perm of store.permissions) {
+    if (
+      perm.resourceType === resourceType &&
+      perm.resourceId === resourceId &&
+      perm.userId === userId
+    ) {
+      bestRole = bestRole ? higherRole(bestRole, perm.role) : perm.role;
+    }
+  }
+
+  // Check folder hierarchy permissions
+  if (resourceType === 'document') {
+    const doc = store.documents.get(resourceId);
+    if (doc) {
+      // Check permissions on the document's folder
+      const folderRole = getEffectiveRole(store, userId, 'folder', doc.folderId);
+      if (folderRole) {
+        bestRole = bestRole ? higherRole(bestRole, folderRole) : folderRole;
+      }
+    }
+  } else if (resourceType === 'folder') {
+    // Check ancestor folder permissions
+    const ancestorIds = getAncestorFolderIds(store, resourceId);
+    for (const ancestorId of ancestorIds) {
+      for (const perm of store.permissions) {
+        if (
+          perm.resourceType === 'folder' &&
+          perm.resourceId === ancestorId &&
+          perm.userId === userId
+        ) {
+          bestRole = bestRole ? higherRole(bestRole, perm.role) : perm.role;
+        }
+      }
+    }
+  }
+
+  return bestRole;
+}
