ation', `Bearer ${bob.token}`);\n    expect(get.status).toBe(403);\n  });\n\n  it('viewer cannot edit', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Shared' });\n\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({\n        resourceType: 'folder',\n        resourceId: folder.body.id,\n        targetUserId: bob.userId,\n        role: 'viewer',\n      });\n\n    const update = await request(app)\n      .put(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`)\n      .send({ name: 'Hacked' });\n    expect(update.status).toBe(403);\n  });\n\n  it('editor can edit but not delete', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Shared' });\n\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({\n        resourceType: 'folder',\n        resourceId: folder.body.id,\n        targetUserId: bob.userId,\n        role: 'editor',\n      });\n\n    const update = await request(app)\n      .put(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`)\n      .send({ name: 'Renamed' });\n    expect(update.status).toBe(200);\n\n    const del = await request(app)\n      .delete(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n    expect(del.status).toBe(403);\n  });\n\n  it('editor can share with others', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const charlie = await createU