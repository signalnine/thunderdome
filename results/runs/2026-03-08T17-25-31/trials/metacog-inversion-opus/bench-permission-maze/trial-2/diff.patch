+export function activityRoutes(store: Store): Router {
+  const router = Router();
+  router.use(authMiddleware(store));
+
+  // Get activity log
+  router.get('/', (req: AuthRequest, res: Response): void => {
+    // Return all activity log entries (optionally filter by resourceType or resourceId)
+    let entries = [...store.activityLog];
+
+    const { resourceType, resourceId } = req.query;
+    if (resourceType) {
+      entries = entries.filter((e) => e.resourceType === resourceType);
+    }
+    if (resourceId) {
+      entries = entries.filter((e) => e.resourceId === resourceId);
+    }
+
+    // Sort by most recent first
+    entries.sort((a, b) => new Date(b.timestamp).getTime() - new Date(a.timestamp).getTime());
+
+    res.status(200).json(entries);
+  });
+
+  return router;
+}
