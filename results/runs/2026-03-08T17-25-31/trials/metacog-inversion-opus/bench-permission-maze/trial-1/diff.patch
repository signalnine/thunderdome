new file mode 100644
index 0000000..1eace5b
--- /dev/null
+++ b/src/activity.ts
@@ -0,0 +1,15 @@
+import { Router, Response } from 'express';
+import { Store } from './store.js';
+import { AuthRequest, requireAuth } from './auth.js';
+
+export function createActivityRouter(store: Store): Router {
+  const router = Router();
+
+  router.get('/', requireAuth, (_req: AuthRequest, res: Response): void => {
+    // Return activity log sorted by newest first
+    const log = [...store.activityLog].reverse();
+    res.status(200).json(log);
+  });
+
+  return router;
+}
diff --git a/src/app.ts b/src/app.ts
new file mode 100644
index 0000000..80ab296
--- /dev/null
+++ b/src/app.ts
@@ -0,0 +1,23 @@
+import express from 'express';
+import { createStore } from './store.js';
+import { createAuthRouter, authMiddleware } from './auth.js';
+import { createFoldersRouter } from './folders.js';
+import { createDocumentsRouter } from './documents.js';
+import { createSharingRouter } from './sharing.js';
+import { createActivityRouter } from './activity.js';
+
+export function createApp() {
+  const app = express();
+  const store = createStore();
+
+  app.use(express.json());
+  app.use(authMiddleware(store));
+
+  app.use('/auth', createAuthRouter(store));
+  app.use('/folders', createFoldersRouter(store));
+  app.use('/documents', createDocumentsRouter(store));
+  app.use('/', createSharingRouter(store));
+  app.use('/activity', createActivityRouter(store));
+
+  return app;
+}
diff --git a/src/auth.ts b/src/auth.ts
new file mode 100644
index 0000000..ad7405e
--- /dev/null
+++ b/src/auth.ts
@@ -0,0 +1,90 @@
+import { Router, Request, Response, NextFunction } from 'express';
+import { Store } from './store.js';
+import crypto from 'crypto';
+
+export interface AuthRequest extends Request {
+  userId?: string;
+}
+
+export function authMiddleware(store: Store) {
+  return (req: AuthRequest, _res: Response, next: NextFunction): void => {
+    const authHeader = req.headers.authorization;
+    if (!authHeader || !authHeader.startsWith('Bearer ')) {
+      next();
+      return;
+    }
+    const token = authHeader.slice(7);
+    for (const user of store.users.values()) {
+      if (user.token === token) {
+        req.userId = user.id;
+        break;
+      }
+    }
+    next();
+  };
+}
+
+export function requireAuth(req: AuthRequest, res: Response, next: NextFunction): void {
+  if (!req.userId) {
+    res.status(401).json({ error: 'Authentication required' });
+    return;
+  }
+  next();
+}
+
+export function createAuthRouter(store: Store): Router {
+  const router = Router();
+
+  router.post('/register', (req: Request, res: Response): void => {
+    const { username, password } = req.body;
+    if (!username || !password) {
+      res.status(400).json({ error: 'Username and password are required' });
+      return;
+    }
+    if (typeof username !== 'string' || typeof password !== 'string') {
+      res.status(400).json({ error: 'Username and password must be strings' });
+      return;
+    }
+
+    for (const user of store.users.values()) {
+      if (user.username === username) {
+        res.status(409).json({ error: 'Username already exists' });
+        return;
+      }
+    }
+
+    const id = store.nextId();
+    const user = { id, username, password, token: null };
+    store.users.set(id, user);
+
+    res.status(201).json({ id, username });
+  });
+
+  router.post('/login', (req: Request, res: Response): void => {
+    const { username, password } = req.body;
+    if (!username || !password) {
+      res.status(400).json({ error: 'Username and password are required' });
+      return;
+    }
+
+    let foundUser = null;
+    for (const user of store.users.values()) {
+      if (user.username === username && user.password === password) {
+        foundUser = user;
+        break;
+      }
+    }
+
+    if (!foundUser) {
+      res.status(401).json({ error: 'Invalid credentials' });
+      return;
+    }
+
+    const token = crypto.randomBytes(32).toString('hex');
+    foundUser.token = token;
+
+    res.status(200).json({ token, userId: foundUser.id });
+  });
+
+  return router;
+}
diff --git a/src/documents.ts b/src/documents.ts
new file mode 100644
index 0000000..1578427
--- /dev/null
+++ b/src/documents.ts
@@ -0,0 +1,169 @@
+import { Router, Response } from 'express';
+import { Store } from './store.js';
+import { AuthRequest, requireAuth } from './auth.js';
+import { canRead, canEdit, canDelete } from './permissions.js';
+
+export function createDocumentsRouter(store: Store): Router {
+  const router = Router();
+
+  // Create document in a folder
+  router.post('/', requireAuth, (req: AuthRequest, res: Response): void => {
+    const userId = req.userId!;
+    const { title, content, folderId } = req.body;
+
+    if (!title || typeof title !== 'string') {
+      res.status(400).json({ error: 'Document title is required' });
+      return;
+    }
+    if (content === undefined || content === null) {
+      res.status(400).json({ error: 'Document content is required' });
+      return;
+    }
+    if (!folderId) {
+      res.status(400).json({ error: 'Folder ID is required' });
+      return;
+    }
+
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    // Must have at least editor access on folder to create document
+    if (!canEdit(store, userId, 'folder', folderId)) {
+      res.status(403).json({ error: 'No permission to create documents in this folder' });
+      return;
+    }
+
+    const id = store.nextId();
+    const now = new Date().toISOString();
+    const doc = {
+      id,
+      title,
+      content: String(content),
+      folderId,
+      ownerId: userId,
+      createdAt: now,
+      updatedAt: now,
+    };
+    store.documents.set(id, doc);
+
+    // Grant owner permission to creator
+    store.permissions.push({
+      id: store.nextId(),
+      resourceType: 'document',
+      resourceId: id,
+      userId,
+      role: 'owner',
+    });
+
+    // Log activity
+    store.activityLog.push({
+      id: store.nextId(),
+      action: 'document_created',
+      userId,
+      resourceType: 'document',
+      resourceId: id,
+      timestamp: now,
+    });
+
+    res.status(201).json(doc);
+  });
+
+  router.get('/:id', requireAuth, (req: AuthRequest, res: Response): void => {
+    const userId = req.userId!;
+    const doc = store.documents.get(req.params.id);
+
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!canRead(store, userId, 'document', doc.id)) {
+      res.status(403).json({ error: 'No permission to view this document' });
+      return;
+    }
+
+    res.status(200).json(doc);
+  });
+
+  router.put('/:id', requireAuth, (req: AuthRequest, res: Response): void => {
+    const userId = req.userId!;
+    const doc = store.documents.get(req.params.id);
+
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!canEdit(store, userId, 'document', doc.id)) {
+      res.status(403).json({ error: 'No permission to edit this document' });
+      return;
+    }
+
+    const { title, content } = req.body;
+    if (title !== undefined) {
+      if (typeof title !== 'string' || title.length === 0) {
+        res.status(400).json({ error: 'Title must be a non-empty string' });
+        return;
+      }
+      doc.title = title;
+    }
+    if (content !== undefined) {
+      doc.content = String(content);
+    }
+    doc.updatedAt = new Date().toISOString();
+
+    // Log activity
+    store.activityLog.push({
+      id: store.nextId(),
+      action: 'document_updated',
+      userId,
+      resourceType: 'document',
+      resourceId: doc.id,
+      timestamp: doc.updatedAt,
+    });
+
+    res.status(200).json(doc);
+  });
+
+  router.delete('/:id', requireAuth, (req: AuthRequest, res: Response): void => {
+    const userId = req.userId!;
+    const doc = store.documents.get(req.params.id);
+
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!canDelete(store, userId, 'document', doc.id)) {
+      res.status(403).json({ error: 'No permission to delete this document' });
+      return;
+    }
+
+    // Remove permissions for this document
+    for (let i = store.permissions.length - 1; i >= 0; i--) {
+      if (store.permissions[i].resourceType === 'document' && store.permissions[i].resourceId === doc.id) {
+        store.permissions.splice(i, 1);
+      }
+    }
+
+    // Log activity
+    const now = new Date().toISOString();
+    store.activityLog.push({
+      id: store.nextId(),
+      action: 'document_deleted',
+      userId,
+      resourceType: 'document',
+      resourceId: doc.id,
+      timestamp: now,
+    });
+
+    store.documents.delete(doc.id);
+
+    res.status(204).send();
+  });
+
+  return router;
+}
diff --git a/src/folders.ts b/src/folders.ts
new file mode 100644
index 0000000..cddb33e
--- /dev/null
+++ b/src/folders.ts
@@ -0,0 +1,211 @@
+import { Router, Response } from 'express';
+import { Store } from './store.js';
+import { AuthRequest, requireAuth } from './auth.js';
+import { canRead, canEdit, canDelete } from './permissions.js';
+
+export function createFoldersRouter(store: Store): Router {
+  const router = Router();
+
+  router.post('/', requireAuth, (req: AuthRequest, res: Response): void => {
+    const userId = req.userId!;
+    const { name, parentId } = req.body;
+
+    if (!name || typeof name !== 'string') {
+      res.status(400).json({ error: 'Folder name is required' });
+      return;
+    }
+
+    if (parentId !== undefined && parentId !== null) {
+      const parentFolder = store.folders.get(parentId);
+      if (!parentFolder) {
+        res.status(404).json({ error: 'Parent folder not found' });
+        return;
+      }
+      // Must have at least editor access on parent to create subfolder
+      if (!canEdit(store, userId, 'folder', parentId)) {
+        res.status(403).json({ error: 'No permission to create subfolder here' });
+        return;
+      }
+    }
+
+    const id = store.nextId();
+    const folder = {
+      id,
+      name,
+      parentId: parentId || null,
+      ownerId: userId,
+      createdAt: new Date().toISOString(),
+    };
+    store.folders.set(id, folder);
+
+    // Grant owner permission to creator
+    store.permissions.push({
+      id: store.nextId(),
+      resourceType: 'folder',
+      resourceId: id,
+      userId,
+      role: 'owner',
+    });
+
+    res.status(201).json(folder);
+  });
+
+  router.get('/:id', requireAuth, (req: AuthRequest, res: Response): void => {
+    const userId = req.userId!;
+    const folder = store.folders.get(req.params.id);
+
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!canRead(store, userId, 'folder', folder.id)) {
+      res.status(403).json({ error: 'No permission to view this folder' });
+      return;
+    }
+
+    // Include child folders and documents
+    const children: string[] = [];
+    for (const f of store.folders.values()) {
+      if (f.parentId === folder.id) {
+        children.push(f.id);
+      }
+    }
+
+    const docs: string[] = [];
+    for (const d of store.documents.values()) {
+      if (d.folderId === folder.id) {
+        docs.push(d.id);
+      }
+    }
+
+    res.status(200).json({ ...folder, children, documents: docs });
+  });
+
+  router.put('/:id', requireAuth, (req: AuthRequest, res: Response): void => {
+    const userId = req.userId!;
+    const folder = store.folders.get(req.params.id);
+
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!canEdit(store, userId, 'folder', folder.id)) {
+      res.status(403).json({ error: 'No permission to edit this folder' });
+      return;
+    }
+
+    const { name, parentId } = req.body;
+    if (name !== undefined) {
+      if (typeof name !== 'string' || name.length === 0) {
+        res.status(400).json({ error: 'Folder name must be a non-empty string' });
+        return;
+      }
+      folder.name = name;
+    }
+    if (parentId !== undefined) {
+      if (parentId !== null) {
+        const parentFolder = store.folders.get(parentId);
+        if (!parentFolder) {
+          res.status(404).json({ error: 'Parent folder not found' });
+          return;
+        }
+        // Prevent circular references
+        if (parentId === folder.id) {
+          res.status(400).json({ error: 'Folder cannot be its own parent' });
+          return;
+        }
+      }
+      folder.parentId = parentId;
+    }
+
+    res.status(200).json(folder);
+  });
+
+  router.delete('/:id', requireAuth, (req: AuthRequest, res: Response): void => {
+    const userId = req.userId!;
+    const folder = store.folders.get(req.params.id);
+
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!canDelete(store, userId, 'folder', folder.id)) {
+      res.status(403).json({ error: 'No permission to delete this folder' });
+      return;
+    }
+
+    // Delete all documents in this folder
+    for (const [docId, doc] of store.documents.entries()) {
+      if (doc.folderId === folder.id) {
+        store.documents.delete(docId);
+        // Remove permissions for the document
+        for (let i = store.permissions.length - 1; i >= 0; i--) {
+          if (store.permissions[i].resourceType === 'document' && store.permissions[i].resourceId === docId) {
+            store.permissions.splice(i, 1);
+          }
+        }
+      }
+    }
+
+    // Recursively delete child folders
+    const childIds: string[] = [];
+    for (const f of store.folders.values()) {
+      if (f.parentId === folder.id) {
+        childIds.push(f.id);
+      }
+    }
+    for (const childId of childIds) {
+      deleteFolder(store, childId);
+    }
+
+    // Remove permissions for this folder
+    for (let i = store.permissions.length - 1; i >= 0; i--) {
+      if (store.permissions[i].resourceType === 'folder' && store.permissions[i].resourceId === folder.id) {
+        store.permissions.splice(i, 1);
+      }
+    }
+
+    store.folders.delete(folder.id);
+
+    res.status(204).send();
+  });
+
+  return router;
+}
+
+function deleteFolder(store: Store, folderId: string): void {
+  // Delete documents in folder
+  for (const [docId, doc] of store.documents.entries()) {
+    if (doc.folderId === folderId) {
+      store.documents.delete(docId);
+      for (let i = store.permissions.length - 1; i >= 0; i--) {
+        if (store.permissions[i].resourceType === 'document' && store.permissions[i].resourceId === docId) {
+          store.permissions.splice(i, 1);
+        }
+      }
+    }
+  }
+
+  // Recursively delete children
+  const childIds: string[] = [];
+  for (const f of store.folders.values()) {
+    if (f.parentId === folderId) {
+      childIds.push(f.id);
+    }
+  }
+  for (const childId of childIds) {
+    deleteFolder(store, childId);
+  }
+
+  // Remove folder permissions
+  for (let i = store.permissions.length - 1; i >= 0; i--) {
+    if (store.permissions[i].resourceType === 'folder' && store.permissions[i].resourceId === folderId) {
+      store.permissions.splice(i, 1);
+    }
+  }
+
+  store.folders.delete(folderId);
+}
diff --git a/src/permissions.ts b/src/permissions.ts
new file mode 100644
index 0000000..a18b2ab
--- /dev/null
+++ b/src/permissions.ts
@@ -0,0 +1,75 @@
+import { Store } from './store.js';
+import { Role } from './types.js';
+
+const ROLE_LEVEL: Record<Role, number> = {
+  viewer: 1,
+  editor: 2,
+  owner: 3,
+};
+
+export function getEffectiveRole(
+  store: Store,
+  userId: string,
+  resourceType: 'folder' | 'document',
+  resourceId: string
+): Role | null {
+  let bestRole: Role | null = null;
+
+  // Check direct permissions on the resource
+  for (const perm of store.permissions) {
+    if (perm.resourceType === resourceType && perm.resourceId === resourceId && perm.userId === userId) {
+      if (!bestRole || ROLE_LEVEL[perm.role] > ROLE_LEVEL[bestRole]) {
+        bestRole = perm.role;
+      }
+    }
+  }
+
+  // If it's a document, also check permissions on its folder (and parent folders)
+  if (resourceType === 'document') {
+    const doc = store.documents.get(resourceId);
+    if (doc) {
+      const folderRole = getEffectiveRole(store, userId, 'folder', doc.folderId);
+      if (folderRole && (!bestRole || ROLE_LEVEL[folderRole] > ROLE_LEVEL[bestRole])) {
+        bestRole = folderRole;
+      }
+    }
+  }
+
+  // If it's a folder, also check parent folder permissions (inherited)
+  if (resourceType === 'folder') {
+    const folder = store.folders.get(resourceId);
+    if (folder && folder.parentId) {
+      const parentRole = getEffectiveRole(store, userId, 'folder', folder.parentId);
+      if (parentRole && (!bestRole || ROLE_LEVEL[parentRole] > ROLE_LEVEL[bestRole])) {
+        bestRole = parentRole;
+      }
+    }
+  }
+
+  return bestRole;
+}
+
+export function canRead(store: Store, userId: string, resourceType: 'folder' | 'document', resourceId: string): boolean {
+  const role = getEffectiveRole(store, userId, resourceType, resourceId);
+  return role !== null;
+}
+
+export function canEdit(store: Store, userId: string, resourceType: 'folder' | 'document', resourceId: string): boolean {
+  const role = getEffectiveRole(store, userId, resourceType, resourceId);
+  return role !== null && ROLE_LEVEL[role] >= ROLE_LEVEL['editor'];
+}
+
+export function canDelete(store: Store, userId: string, resourceType: 'folder' | 'document', resourceId: string): boolean {
+  const role = getEffectiveRole(store, userId, resourceType, resourceId);
+  return role !== null && ROLE_LEVEL[role] >= ROLE_LEVEL['owner'];
+}
+
+export function canShare(store: Store, userId: string, resourceType: 'folder' | 'document', resourceId: string): boolean {
+  const role = getEffectiveRole(store, userId, resourceType, resourceId);
+  return role !== null && ROLE_LEVEL[role] >= ROLE_LEVEL['editor'];
+}
+
+export function canManageRoles(store: Store, userId: string, resourceType: 'folder' | 'document', resourceId: string): boolean {
+  const role = getEffectiveRole(store, userId, resourceType, resourceId);
+  return role !== null && ROLE_LEVEL[role] >= ROLE_LEVEL['owner'];
+}
