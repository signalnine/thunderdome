    }\n\n    // Cannot share with yourself\n    if (targetUserId === userId) {\n      res.status(400).json({ error: 'Cannot share with yourself' });\n      return;\n    }\n\n    // If assigning owner role, need owner permission; otherwise editor+ can share\n    if (role === 'owner') {\n      if (!canManageRoles(store, userId, normalizedType, resourceId)) {\n        res.status(403).json({ error: 'Only owners can assign owner role' });\n        return;\n      }\n    } else {\n      if (!canShare(store, userId, normalizedType, resourceId)) {\n        res.status(403).json({ error: 'No permission to share this resource' });\n        return;\n      }\n    }\n\n    // Check if permission already exists for this user on this resource\n    let existingPerm = null;\n    for (const perm of store.permissions) {\n      if (perm.resourceType === normalizedType && perm.resourceId === resourceId && perm.userId === targetUserId) {\n        existingPerm = perm;\n        break;\n      }\n    }\n\n    if (existingPerm) {\n      existingPerm.role = role;\n    } else {\n      store.permissions.push({\n        id: store.nextId(),\n        resourceType: normalizedType,\n        resourceId,\n        userId: targetUserId,\n        role,\n      });\n    }\n\n    // Log activity\n    const now = new Date().toISOString();\n    store.activityLog.push({\n      id: store.nextId(),\n      action: 'resource_shared',\n      userId,\n      resourceType: normalizedType,\n      resourceId,\n      timestamp: now,\n      details: `Shared with user ${targetUserId} as ${role}`,\n    });\n\n    res.status(200).json({\n      message: 'Resource shared successfully',\n      resourceType: normalizedType,\n      resourceId,\n      targetUserId,\n      role,\n    });\n  });\n\n  // Get permissions for a resource\n  router.get('/:resourceType/:resourceId/permissions', requireAuth, (req: AuthRequest, res: Response): void => {\n    const userId = req.userId!;\n    const { resourceType, resourceId } = req.params;\n\n    const normalizedType = resourceType === 'folders' ? 'folder' : 'document';\n\n    // Check resource exists\n    if (normalizedType === 'folder' && !store.folders.has(resourceId)) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n    if (normalizedType === 'document' && !store.documents.has(resourceId)) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n\n    // Must have at least read access\n    const role = getEffectiveRole(store, userId, normalizedType, resourceId);\n    if (!role) {\n      res.status(403).json({ error: 'No permission to view this resource' });\n      return;\n    }\n\n    const perms = store.permissions.filter(\n      (p) => p.resourceType === normalizedType && p.resourceId === resourceId\n    );\n\n    res.status(200).json(perms);\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1510,"cache_read_input_tokens":24693,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1510},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"dbe45885-163e-4912-a1ff-7fb3ffc407df","uuid":"100827d5-7bdc-419c-a797-2c8cf279ac99"}
