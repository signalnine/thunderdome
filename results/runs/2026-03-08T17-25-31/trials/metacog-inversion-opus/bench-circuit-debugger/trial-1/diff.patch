its - 1).padStart(2, '0');\n    const lastZ = String(bits).padStart(2, '0');\n    // The final carry is c{bits-1} -> z{bits}\n    // In a real circuit this might be an OR gate that simply passes through\n    // But per the example, c03 -> z04 directly. Let's model it as an OR with a dummy.\n    // Actually, looking at the spec example more carefully, c03 -> z04 is just a wire rename.\n    // We need to represent this. Let's find the last OR gate and change its output.\n    // Actually, in the spec pattern, the last carry c(N-1) IS z(N).\n    // The simplest approach: change the last OR gate's output to z(N).\n    const lastGate = gates[gates.length - 1]; // This is the last OR gate\n    lastGate.out = `z${lastZ}`;\n\n    return gates;\n  }\n\n  /**\n   * Swap two gate outputs by wire name.\n   */\n  function swapOutputs(gates: Gate[], wire1: string, wire2: string): Gate[] {\n    return gates.map((g) => {\n      if (g.out === wire1) return { ...g, out: wire2 };\n      if (g.out === wire2) return { ...g, out: wire1 };\n      return { ...g };\n    });\n  }\n\n  it('should find swapped wires in a 4-bit adder', () => {\n    let gates = buildCorrectAdder(4);\n\n    // Swap 4 pairs\n    gates = swapOutputs(gates, 'z01', 'a01');\n    gates = swapOutputs(gates, 'z02', 't02');\n    gates = swapOutputs(gates, 'b03', 'z04');\n    gates = swapOutputs(gates, 'z03', 'b02');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual([\n      'a01',\n      'b02',\n      'b03',\n      't02',\n      'z01',\n      'z02',\n      'z03',\n      'z04',\n    ]);\n  });\n\n  it('should find swapped wires in a larger adder', () => {\n    let gates = buildCorrectAdder(10);\n\n    gates = swapOutputs(gates, 'z03', 'a03');\n    gates = swapOutputs(gates, 't05', 'z05');\n    gates = swapOutputs(gates, 'b07', 'z10');\n    gates = swapOutputs(gates, 'c08', 'z09');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual([\n      'a03',\n      'b07',\n      'c08',\n