esult = findSwappedWires(swappedGates);\n    const expected = [\n      'z03', rng(3, 'gen'),\n      rng(5, 'ps'), 'z05',\n      rng(7, 'prop'), 'z08',\n      rng(2, 'carry'), 'z02',\n    ].sort();\n\n    expect(result).toEqual(expected);\n  });\n});","originalFile":"import { describe, it, expect } from 'vitest';\nimport { simulate, findSwappedWires, Gate } from './index.js';\n\ndescribe('simulate', () => {\n  it('should evaluate a simple AND gate', () => {\n    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n    const result = simulate(gates, { a: 1, b: 1 });\n    expect(result.c).toBe(1);\n    expect(result.a).toBe(1);\n    expect(result.b).toBe(1);\n  });\n\n  it('should evaluate AND gate with 0 input', () => {\n    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n    const result = simulate(gates, { a: 1, b: 0 });\n    expect(result.c).toBe(0);\n  });\n\n  it('should evaluate OR gate', () => {\n    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 0, b: 1 }).c).toBe(1);\n    expect(simulate(gates, { a: 0, b: 0 }).c).toBe(0);\n    expect(simulate(gates, { a: 1, b: 1 }).c).toBe(1);\n  });\n\n  it('should evaluate XOR gate', () => {\n    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 0, b: 1 }).c).toBe(1);\n    expect(simulate(gates, { a: 1, b: 1 }).c).toBe(0);\n    expect(simulate(gates, { a: 0, b: 0 }).c).toBe(0);\n    expect(simulate(gates, { a: 1, b: 0 }).c).toBe(1);\n  });\n\n  it('should handle chained gates in dependency order', () => {\n    const gates: Gate[] = [\n      { op: 'AND', in1: 'a', in2: 'b', out: 'temp' },\n      { op: 'OR', in1: 'temp', in2: 'c', out: 'result' },\n    ];\n    const result = simulate(gates, { a: 1, b: 1, c: 0 });\n    expect(result.temp).toBe(1);\n    expect(result.result).toBe(1);\n  });\n\n  it('should simulate a 2-bit adder', () => {\n    // Build a 2-bit adder: x + y = z\n    con