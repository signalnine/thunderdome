+import { describe, it, expect } from 'vitest';
+import { simulate, findSwappedWires, Gate } from './index.js';
+
+describe('simulate', () => {
+  it('should evaluate a simple AND gate', () => {
+    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];
+    const result = simulate(gates, { a: 1, b: 1 });
+    expect(result.c).toBe(1);
+    expect(result.a).toBe(1);
+    expect(result.b).toBe(1);
+  });
+
+  it('should evaluate AND gate with 0 input', () => {
+    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];
+    const result = simulate(gates, { a: 1, b: 0 });
+    expect(result.c).toBe(0);
+  });
+
+  it('should evaluate OR gate', () => {
+    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 0, b: 1 }).c).toBe(1);
+    expect(simulate(gates, { a: 0, b: 0 }).c).toBe(0);
+    expect(simulate(gates, { a: 1, b: 1 }).c).toBe(1);
+  });
+
+  it('should evaluate XOR gate', () => {
+    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 0, b: 1 }).c).toBe(1);
+    expect(simulate(gates, { a: 1, b: 1 }).c).toBe(0);
+    expect(simulate(gates, { a: 0, b: 0 }).c).toBe(0);
+    expect(simulate(gates, { a: 1, b: 0 }).c).toBe(1);
+  });
+
+  it('should handle chained gates in dependency order', () => {
+    const gates: Gate[] = [
+      { op: 'AND', in1: 'a', in2: 'b', out: 'temp' },
+      { op: 'OR', in1: 'temp', in2: 'c', out: 'result' },
+    ];
+    const result = simulate(gates, { a: 1, b: 1, c: 0 });
+    expect(result.temp).toBe(1);
+    expect(result.result).toBe(1);
+  });
+
+  it('should simulate a 2-bit adder', () => {
+    // Build a 2-bit adder: x + y = z
+    const gates: Gate[] = [
+      // Bit 0 (half adder)
+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+      // Bit 1 (full adder)
+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },
+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },
+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },
+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },
+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },
+    ];
+
+    // Test: 3 + 3 = 6 (binary: 11 + 11 = 110)
+    const result = simulate(gates, { x00: 1, x01: 1, y00: 1, y01: 1 });
+    expect(result.z00).toBe(0);
+    expect(result.z01).toBe(1);
+    expect(result.z02).toBe(1);
+
+    // Test: 2 + 1 = 3 (binary: 10 + 01 = 011)
+    const result2 = simulate(gates, { x00: 0, x01: 1, y00: 1, y01: 0 });
+    expect(result2.z00).toBe(1);
+    expect(result2.z01).toBe(1);
+    expect(result2.z02).toBe(0);
+  });
+});
+
+describe('findSwappedWires', () => {
+  /**
+   * Build a correct N-bit ripple-carry adder.
+   */
+  function buildCorrectAdder(bits: number): Gate[] {
+    const gates: Gate[] = [];
+
+    // Bit 0: half adder
+    gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });
+    gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });
+
+    for (let i = 1; i < bits; i++) {
+      const nn = String(i).padStart(2, '0');
+      const prevNN = String(i - 1).padStart(2, '0');
+      const carryIn = 'c' + prevNN;
+
+      gates.push({ op: 'XOR', in1: `x${nn}`, in2: `y${nn}`, out: `t${nn}` });
+      gates.push({ op: 'XOR', in1: `t${nn}`, in2: carryIn, out: `z${nn}` });
+      gates.push({ op: 'AND', in1: `x${nn}`, in2: `y${nn}`, out: `a${nn}` });
+      gates.push({
+        op: 'AND',
+        in1: `t${nn}`,
+        in2: carryIn,
+        out: `b${nn}`,
+      });
+      gates.push({ op: 'OR', in1: `a${nn}`, in2: `b${nn}`, out: `c${nn}` });
+    }
+
+    // Last carry becomes the MSB of output
+    const lastZ = String(bits).padStart(2, '0');
+    // The final carry is c{bits-1} -> z{bits}
+    // In a real circuit this might be an OR gate that simply passes through
+    // But per the example, c03 -> z04 directly. Let's model it as an OR with a dummy.
+    // Actually, looking at the spec example more carefully, c03 -> z04 is just a wire rename.
+    // We need to represent this. Let's find the last OR gate and change its output.
+    // Actually, in the spec pattern, the last carry c(N-1) IS z(N).
+    // The simplest approach: change the last OR gate's output to z(N).
+    const lastGate = gates[gates.length - 1]; // This is the last OR gate
+    lastGate.out = `z${lastZ}`;
+
+    return gates;
+  }
+
+  /**
+   * Swap two gate outputs by wire name.
+   */
+  function swapOutputs(gates: Gate[], wire1: string, wire2: string): Gate[] {
+    return gates.map((g) => {
+      if (g.out === wire1) return { ...g, out: wire2 };
+      if (g.out === wire2) return { ...g, out: wire1 };
+      return { ...g };
+    });
+  }
+
+  it('should find swapped wires in a 4-bit adder', () => {
+    let gates = buildCorrectAdder(4);
+
+    // Swap 4 pairs
+    gates = swapOutputs(gates, 'z01', 'a01');
+    gates = swapOutputs(gates, 'z02', 't02');
+    gates = swapOutputs(gates, 'b03', 'z04');
+    gates = swapOutputs(gates, 'z03', 'b02');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual([
+      'a01',
+      'b02',
+      'b03',
+      't02',
+      'z01',
+      'z02',
+      'z03',
+      'z04',
+    ]);
+  });
+
+  it('should find swapped wires in a larger adder', () => {
+    let gates = buildCorrectAdder(10);
+
+    gates = swapOutputs(gates, 'z03', 'a03');
+    gates = swapOutputs(gates, 't05', 'z05');
+    gates = swapOutputs(gates, 'b07', 'z10');
+    gates = swapOutputs(gates, 'c08', 'z09');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual([
+      'a03',
+      'b07',
+      'c08',
+      't05',
+      'z03',
+      'z05',
+      'z09',
+      'z10',
+    ]);
+  });
+
+  it('should handle 45-bit adder within time constraints', () => {
+    let gates = buildCorrectAdder(45);
+
+    gates = swapOutputs(gates, 'z05', 'a05');
+    gates = swapOutputs(gates, 't20', 'z20');
+    gates = swapOutputs(gates, 'b30', 'z45');
+    gates = swapOutputs(gates, 'c40', 'z41');
+
+    const start = Date.now();
+    const result = findSwappedWires(gates);
+    const elapsed = Date.now() - start;
+
+    expect(result).toEqual([
+      'a05',
+      'b30',
+      'c40',
+      't20',
+      'z05',
+      'z20',
+      'z41',
+      'z45',
+    ]);
+    expect(elapsed).toBeLessThan(5000);
+  });
+
+  it('should find swapped wires with randomized internal wire names', () => {
+    // Build a correct 8-bit adder with random internal wire names
+    const gates: Gate[] = [];
+    const rng = (i: number, role: string) =>
+      `${role}${String.fromCharCode(97 + (i % 26))}${i}`;
+
+    // Bit 0: half adder
+    gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });
+    gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: rng(0, 'carry') });
+
+    for (let i = 1; i < 8; i++) {
+      const nn = String(i).padStart(2, '0');
+      const partialSum = rng(i, 'ps');
+      const gen = rng(i, 'gen');
+      const prop = rng(i, 'prop');
+      const carryOut = i === 7 ? 'z08' : rng(i, 'carry');
+      const carryIn = i === 1 ? rng(0, 'carry') : rng(i - 1, 'carry');
+
+      gates.push({ op: 'XOR', in1: `x${nn}`, in2: `y${nn}`, out: partialSum });
+      gates.push({ op: 'XOR', in1: partialSum, in2: carryIn, out: `z${nn}` });
+      gates.push({ op: 'AND', in1: `x${nn}`, in2: `y${nn}`, out: gen });
+      gates.push({ op: 'AND', in1: partialSum, in2: carryIn, out: prop });
+      gates.push({ op: 'OR', in1: gen, in2: prop, out: carryOut });
+    }
+
+    // Swap 4 pairs
+    let swappedGates = swapOutputs(gates, 'z03', rng(3, 'gen'));
+    swappedGates = swapOutputs(swappedGates, rng(5, 'ps'), 'z05');
+    swappedGates = swapOutputs(swappedGates, rng(7, 'prop'), 'z08');
+    swappedGates = swapOutputs(swappedGates, rng(2, 'carry'), 'z02');
+
+    const result = findSwappedWires(swappedGates);
+    const expected = [
+      'z03', rng(3, 'gen'),
+      rng(5, 'ps'), 'z05',
+      rng(7, 'prop'), 'z08',
+      rng(2, 'carry'), 'z02',
+    ].sort();
+
+    expect(result).toEqual(expected);
+  });
+});
