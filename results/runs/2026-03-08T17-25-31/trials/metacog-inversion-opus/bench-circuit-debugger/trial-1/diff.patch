\n\n    // Rule 2: z-output gates must be XOR (except the last z which is carry-out = OR)\n    if (\n      gate.out.startsWith('z') &&\n      gate.op !== 'XOR' &&\n      gate.out !== lastZWire\n    ) {\n      swapped.add(gate.out);\n    }\n\n    // Rule 3: XOR gates that don't have x/y inputs should output to z\n    // These are the \"tNN XOR carry -> zNN\" gates\n    if (\n      gate.op === 'XOR' &&\n      !hasXYInputs(gate) &&\n      !gate.out.startsWith('z')\n    ) {\n      swapped.add(gate.out);\n    }\n\n    // Rule 4: XOR gates with x/y inputs (except bit 0) must feed into another XOR gate\n    if (\n      gate.op === 'XOR' &&\n      hasXYInputs(gate) &&\n      gate.out !== 'z00' &&\n      !gate.out.startsWith('z') && // if it starts with z, already caught by rule 1\n      !isConsumedByOp(gate.out, 'XOR')\n    ) {\n      swapped.add(gate.out);\n    }\n\n    // Rule 5: AND gates must feed into OR gates (except x00 AND y00 when there's no full adder)\n    if (gate.op === 'AND') {\n      // x00 AND y00 is special — if bit count > 1, it feeds into an XOR and AND for bit 1\n      // Actually in a standard ripple carry, x00 AND y00 produces carry_0 which feeds into\n      // bit 1's XOR and AND. So the carry wire feeds into XOR and AND, not OR.\n      // But for bits > 0, the AND gates (generate and propagate) must feed into OR.\n      const isFirstBitAnd =\n        (gate.in1 === 'x00' || gate.in1 === 'y00') &&\n        (gate.in2 === 'x00' || gate.in2 === 'y00');\n      if (!isFirstBitAnd && !isConsumedByOp(gate.out, 'OR')) {\n        swapped.add(gate.out);\n      }\n    }\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[{"oldStart":153,"oldLines":12,"newStart":153,"newLines":8,"lines":["       swapped.add(gate.out);","     }"," ","-    // Rule 5: AND gates must feed into OR gates (except x00 AND y00 when there's no full adder)","+    // Rule 5: AND gates must feed into OR gates (except x00 AND y00)","     if (gate.op === 'AND') {","-      // x00 AND y