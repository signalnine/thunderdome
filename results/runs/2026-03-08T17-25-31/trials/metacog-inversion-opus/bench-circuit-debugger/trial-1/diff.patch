+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+/**
+ * Simulate a circuit of logic gates given initial wire values.
+ * Returns all wire values after the circuit fully evaluates.
+ */
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>,
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+
+  // Repeatedly process gates whose inputs are ready
+  let changed = true;
+  while (changed) {
+    changed = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        let result: number;
+        switch (gate.op) {
+          case 'AND':
+            result = a & b;
+            break;
+          case 'OR':
+            result = a | b;
+            break;
+          case 'XOR':
+            result = a ^ b;
+            break;
+        }
+        wires[gate.out] = result;
+        remaining.splice(i, 1);
+        changed = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+/**
+ * Find the 8 wires (4 swapped pairs) in a broken binary adder circuit.
+ *
+ * Strategy (inversion approach): Instead of trying to build up a correct circuit,
+ * we identify violations of the ripple-carry adder structure. Each violation
+ * points to a swapped wire.
+ *
+ * A correct N-bit ripple-carry adder has this structure for each bit i:
+ *   Bit 0 (half adder):
+ *     x00 XOR y00 -> z00      (sum)
+ *     x00 AND y00 -> carry_0   (carry)
+ *   Bit i > 0 (full adder):
+ *     xNN XOR yNN -> tNN       (partial sum, XOR of inputs)
+ *     tNN XOR carry_{i-1} -> zNN (final sum)
+ *     xNN AND yNN -> aNN       (generate)
+ *     tNN AND carry_{i-1} -> bNN (propagate)
+ *     aNN OR bNN -> cNN        (carry out)
+ *   Last bit:
+ *     carry_{N-1} -> z(N+1)    (MSB = final carry)
+ *
+ * Rules for a correct adder:
+ * 1. XOR gates with x/y inputs must NOT output to z (except z00)
+ * 2. XOR gates that output to z must have non-x/y inputs (except z00)
+ * 3. z-output gates must be XOR (except the last z bit which is OR for carry)
+ * 4. AND gates (except x00 AND y00) must feed into OR gates
+ * 5. XOR gates with non-x/y inputs must feed from an x/y XOR gate
+ */
+export function findSwappedWires(gates: Gate[]): string[] {
+  // Determine the highest z bit
+  const zBits = gates
+    .filter((g) => g.out.startsWith('z'))
+    .map((g) => parseInt(g.out.slice(1)));
+  const maxZ = Math.max(...zBits);
+  const lastZWire = 'z' + String(maxZ).padStart(2, '0');
+
+  // Build lookup maps
+  const gateByOutput = new Map<string, Gate>();
+  for (const gate of gates) {
+    gateByOutput.set(gate.out, gate);
+  }
+
+  // Collect gates that feed into each wire as an input
+  const consumedBy = new Map<string, Gate[]>();
+  for (const gate of gates) {
+    for (const inp of [gate.in1, gate.in2]) {
+      if (!consumedBy.has(inp)) consumedBy.set(inp, []);
+      consumedBy.get(inp)!.push(gate);
+    }
+  }
+
+  function hasXYInputs(gate: Gate): boolean {
+    return (
+      (gate.in1.startsWith('x') || gate.in1.startsWith('y')) &&
+      (gate.in2.startsWith('x') || gate.in2.startsWith('y'))
+    );
+  }
+
+  function isConsumedByOp(wire: string, op: string): boolean {
+    const consumers = consumedBy.get(wire) || [];
+    return consumers.some((g) => g.op === op);
+  }
+
+  const swapped = new Set<string>();
+
+  for (const gate of gates) {
+    // Rule 1: XOR with x/y inputs should not output z (except z00)
+    // In the adder pattern, xNN XOR yNN -> partial sum (not z), except bit 0
+    if (
+      gate.op === 'XOR' &&
+      hasXYInputs(gate) &&
+      gate.out.startsWith('z') &&
+      gate.out !== 'z00'
+    ) {
+      swapped.add(gate.out);
+    }
+
+    // Rule 2: z-output gates must be XOR (except the last z which is carry-out = OR)
+    if (
+      gate.out.startsWith('z') &&
+      gate.op !== 'XOR' &&
+      gate.out !== lastZWire
+    ) {
+      swapped.add(gate.out);
+    }
+
+    // Rule 3: XOR gates that don't have x/y inputs should output to z
+    // These are the "tNN XOR carry -> zNN" gates
+    if (
+      gate.op === 'XOR' &&
+      !hasXYInputs(gate) &&
+      !gate.out.startsWith('z')
+    ) {
+      swapped.add(gate.out);
+    }
+
+    // Rule 4: XOR gates with x/y inputs (except bit 0) must feed into another XOR gate
+    if (
+      gate.op === 'XOR' &&
+      hasXYInputs(gate) &&
+      gate.out !== 'z00' &&
+      !gate.out.startsWith('z') && // if it starts with z, already caught by rule 1
+      !isConsumedByOp(gate.out, 'XOR')
+    ) {
+      swapped.add(gate.out);
+    }
+
+    // Rule 5: AND gates must feed into OR gates (except x00 AND y00)
+    if (gate.op === 'AND') {
+      const isFirstBitAnd =
+        (gate.in1 === 'x00' || gate.in1 === 'y00') &&
+        (gate.in2 === 'x00' || gate.in2 === 'y00');
+      if (!isFirstBitAnd && !isConsumedByOp(gate.out, 'OR')) {
+        swapped.add(gate.out);
+      }
+    }
+
+    // Rule 6: The last z wire must come from an OR gate
+    if (gate.out === lastZWire && gate.op !== 'OR') {
+      swapped.add(gate.out);
+    }
+
+    // Rule 7: OR gates that don't output lastZ must feed into XOR and AND (as carry)
+    if (gate.op === 'OR' && gate.out !== lastZWire) {
+      const consumers = consumedBy.get(gate.out) || [];
+      const feedsXOR = consumers.some((g) => g.op === 'XOR');
+      const feedsAND = consumers.some((g) => g.op === 'AND');
+      if (!feedsXOR || !feedsAND) {
+        swapped.add(gate.out);
+      }
+    }
+  }
+
+  return [...swapped].sort();
+}
