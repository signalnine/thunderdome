 = swapOutputs(gates, 'z07', 'b07');\n    // Swap z09 <-> a09: detectable by Rule 1 + Rule 3\n    gates = swapOutputs(gates, 'z09', 'a09');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a01', 'a09', 'b07', 'c03', 'z01', 'z04', 'z07', 'z09']);\n  });\n\n  it('should handle a 45-bit adder with swaps in under 5 seconds', () => {\n    let gates = buildAdder(45);\n    gates = swapOutputs(gates, 'z10', 'a10');\n    gates = swapOutputs(gates, 'z20', 'b20');\n    gates = swapOutputs(gates, 'z30', 'c29');\n    gates = swapOutputs(gates, 'z40', 'a40');\n\n    const start = performance.now();\n    const result = findSwappedWires(gates);\n    const elapsed = performance.now() - start;\n\n    expect(elapsed).toBeLessThan(5000);\n    expect(result).toEqual(['a10', 'a40', 'b20', 'c29', 'z10', 'z20', 'z30', 'z40']);\n  });\n\n  it('should return sorted array', () => {\n    let gates = buildAdder(8);\n    gates = swapOutputs(gates, 'z01', 'a01');\n    gates = swapOutputs(gates, 'z03', 'b03');\n    gates = swapOutputs(gates, 'z05', 'a05');\n    gates = swapOutputs(gates, 'z07', 'b07');\n\n    const result = findSwappedWires(gates);\n    const sorted = [...result].sort();\n    expect(result).toEqual(sorted);\n  });\n\n  it('should find swapped wires when AND output goes to XOR instead of OR', () => {\n    // When an AND output is swapped with a final-sum XOR output,\n    // the AND output ends up going to z (caught by Rule 1),\n    // and the XOR output ends up in a non-z position (caught by Rule 3)\n    let gates = buildAdder(12);\n    gates = swapOutputs(gates, 'z02', 'a02');\n    gates = swapOutputs(gates, 'z05', 'b05');\n    gates = swapOutputs(gates, 'z08', 'a08');\n    gates = swapOutputs(gates, 'z11', 'b11');\n\n    const result = findSwappedWires(gates);\n    expect(result.length).toBe(8);\n    expect(result).toEqual(['a02', 'a08', 'b05', 'b11', 'z02', 'z05', 'z08', 'z11']);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_se