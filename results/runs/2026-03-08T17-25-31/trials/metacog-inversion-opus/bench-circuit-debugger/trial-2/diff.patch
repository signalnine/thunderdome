+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+/**
+ * Simulate a circuit: given gates and initial wire values, compute all wire values.
+ */
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+  let changed = true;
+
+  while (remaining.length > 0 && changed) {
+    changed = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        let result: number;
+        switch (gate.op) {
+          case 'AND':
+            result = a & b;
+            break;
+          case 'OR':
+            result = a | b;
+            break;
+          case 'XOR':
+            result = a ^ b;
+            break;
+        }
+        wires[gate.out] = result;
+        remaining.splice(i, 1);
+        changed = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+/**
+ * Find the 8 wires involved in 4 output-wire swaps in a broken ripple-carry adder.
+ * Uses structural pattern matching against the expected adder topology.
+ */
+export function findSwappedWires(gates: Gate[]): string[] {
+  // Determine the number of input bits by finding max x/y index
+  let maxBit = 0;
+  for (const gate of gates) {
+    for (const wire of [gate.in1, gate.in2]) {
+      const m = wire.match(/^[xy](\d+)$/);
+      if (m) {
+        maxBit = Math.max(maxBit, parseInt(m[1], 10));
+      }
+    }
+  }
+  const numBits = maxBit + 1;
+
+  // Build lookup structures
+  const gatesUsingWire = new Map<string, Gate[]>();
+
+  for (const gate of gates) {
+    for (const inp of [gate.in1, gate.in2]) {
+      if (!gatesUsingWire.has(inp)) {
+        gatesUsingWire.set(inp, []);
+      }
+      gatesUsingWire.get(inp)!.push(gate);
+    }
+  }
+
+  function getXYBit(gate: Gate): number | null {
+    const inputs = [gate.in1, gate.in2].sort();
+    const m1 = inputs[0].match(/^x(\d+)$/);
+    const m2 = inputs[1].match(/^y(\d+)$/);
+    if (m1 && m2 && m1[1] === m2[1]) {
+      return parseInt(m1[1], 10);
+    }
+    return null;
+  }
+
+  // Helper: check if wire name is a z output
+  function isZWire(wire: string): boolean {
+    return /^z\d+$/.test(wire);
+  }
+
+  const swapped = new Set<string>();
+
+  // Strategy: Check structural rules for a ripple-carry adder.
+  //
+  // In a correct adder:
+  // Rule 1: Every z output (except the last z which is the final carry) must be produced by XOR.
+  // Rule 2: XOR gates with x/y inputs (partial sum) should NOT output directly to z (except z00).
+  // Rule 3: XOR gates without x/y inputs (final sum gates) MUST output to z.
+  // Rule 4: AND/OR gates should NOT output to z (except the final carry bit).
+  // Rule 5: The output of an XOR gate with x/y inputs (partial sum) should be used by
+  //         exactly one XOR gate and one AND gate (the final sum and propagate carry gates).
+  // Rule 6: The output of an AND gate (carry generate or propagate) should feed into an OR gate.
+  //         Except for bit 0's AND (x00 AND y00) which feeds the carry into bit 1.
+
+  const lastZ = `z${numBits.toString().padStart(2, '0')}`;
+
+  for (const gate of gates) {
+    const bit = getXYBit(gate);
+
+    // Rule 1: z outputs (except last) must come from XOR
+    if (isZWire(gate.out) && gate.out !== lastZ && gate.op !== 'XOR') {
+      swapped.add(gate.out);
+    }
+
+    // Rule 2: XOR with x/y inputs should not go to z (except z00)
+    if (gate.op === 'XOR' && bit !== null && bit !== 0 && isZWire(gate.out)) {
+      swapped.add(gate.out);
+    }
+
+    // Rule 3: XOR without x/y inputs must output to z
+    if (gate.op === 'XOR' && bit === null && !isZWire(gate.out)) {
+      swapped.add(gate.out);
+    }
+
+    // Rule 5: XOR with x/y inputs (not bit 0) — output should be consumed by exactly
+    // one XOR and one AND. If consumed by OR, something is wrong.
+    if (gate.op === 'XOR' && bit !== null && bit !== 0 && !isZWire(gate.out)) {
+      const consumers = gatesUsingWire.get(gate.out) || [];
+      for (const consumer of consumers) {
+        if (consumer.op === 'OR') {
+          // The partial sum wire is being fed to an OR gate — this is wrong.
+          // The partial sum output is swapped with something.
+          swapped.add(gate.out);
+        }
+      }
+    }
+
+    // Rule 6: AND gates (except bit 0) should feed into OR gates
+    if (gate.op === 'AND' && !(bit === 0)) {
+      const consumers = gatesUsingWire.get(gate.out) || [];
+      for (const consumer of consumers) {
+        if (consumer.op !== 'OR' && !isZWire(gate.out)) {
+          swapped.add(gate.out);
+        }
+      }
+    }
+
+    // Rule 7: OR gates should feed into XOR and AND gates (carry -> next bit).
+    // If an OR output feeds into another OR, something is wrong.
+    // Exception: the last z output comes from an OR gate and has no consumers.
+    if (gate.op === 'OR' && !isZWire(gate.out)) {
+      const consumers = gatesUsingWire.get(gate.out) || [];
+      for (const consumer of consumers) {
+        if (consumer.op === 'OR') {
+          swapped.add(gate.out);
+        }
+      }
+    }
+  }
+
+  return [...swapped].sort();
+}
