 const result = simulate(gates, { a: 1, b: 1, d: 0 });\n    expect(result).toEqual({ a: 1, b: 1, c: 1, d: 0, e: 1 });\n  });\n\n  it('should handle a small example circuit', () => {\n    // From AoC-like example\n    const gates: Gate[] = [\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 'z01' },\n      { op: 'OR', in1: 'x02', in2: 'y02', out: 'z02' },\n    ];\n    const inputs: Record<string, number> = {\n      x00: 1, y00: 1,\n      x01: 1, y01: 0,\n      x02: 0, y02: 1,\n    };\n    const result = simulate(gates, inputs);\n    expect(result.z00).toBe(1); // 1 AND 1\n    expect(result.z01).toBe(1); // 1 XOR 0\n    expect(result.z02).toBe(1); // 0 OR 1\n  });\n\n  it('should simulate a correct 2-bit adder: 1+1=2', () => {\n    // 2-bit adder: x=01, y=01, z should be 010 (decimal 2)\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },\n    ];\n    // x=1 (01 in binary), y=1 (01 in binary) -> z=2 (010 in binary)\n    const inputs: Record<string, number> = {\n      x00: 1, y00: 1, x01: 0, y01: 0,\n    };\n    const result = simulate(gates, inputs);\n    expect(result.z00).toBe(0); // 1 XOR 1 = 0\n    expect(result.z01).toBe(1); // carry propagates\n    expect(result.z02).toBe(0); // no carry out\n  });\n\n  it('should simulate a correct 2-bit adder: 3+3=6', () => {\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },\n    ];\n    // x=3 (11), y=3 (11) -> z=6 (110)\n    const inputs: Record<string, number> = {\n      x00: 1, y00: 1, x01: 1, y01: 1,\n    };\n    const result = simulate(gates, inputs);\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(1);\n    expect(result.z02).toBe(1);\n  });\n\n  it('should simulate a 4-bit adder from the spec: 5+3=8', () => {\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n      { op: 'OR', in1: 'a03', in2: 'b03', out: 'c03' },\n    ];\n    // x=5 (0101), y=3 (0011) -> z=8 (01000) -> z04=1\n    const inputs: Record<string, number> = {\n      x00: 1, y00: 1, x01: 0, y01: 1, x02: 1, y02: 0, x03: 0, y03: 0,\n    };\n    const result = simulate(gates, inputs);\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(0);\n    expect(result.z02).toBe(0);\n    expect(result.z03).toBe(1);\n    expect(result.c03).toBe(0);\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  // Helper to build a correct N-bit ripple-carry adder\n  function buildAdder(numBits: number): Gate[] {\n    const gates: Gate[] = [];\n    // Bit 0: half adder\n    gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });\n    gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });\n\n    for (let i = 1; i < numBits; i++) {\n      const pad = i.toString().padStart(2, '0');\n      const prevCarry = `c${(i - 1).toString().padStart(2, '0')}`;\n      gates.push({ op: 'XOR', in1: `x${pad}`, in2: `y${pad}`, out: `t${pad}` });\n      gates.push({ op: 'XOR', in1: `t${pad}`, in2: prevCarry, out: `z${pad}` });\n      gates.push({ op: 'AND', in1: `x${pad}`, in2: `y${pad}`, out: `a${pad}` });\n      gates.push({ op: 'AND', in1: `t${pad}`, in2: prevCarry, out: `b${pad}` });\n      gates.push({ op: 'OR', in1: `a${pad}`, in2: `b${pad}`, out: `c${pad}` });\n    }\n\n    // The last carry becomes the MSB output\n    const lastCarry = `c${(numBits - 1).toString().padStart(2, '0')}`;\n    const lastZ = `z${numBits.toString().padStart(2, '0')}`;\n    // We need to rename the last carry to the last z\n    // Actually in the spec, \"c03 -> z04\" means the last carry IS the last z output\n    // We implement this by having the last OR gate output directly to zN\n    const lastGate = gates[gates.length - 1];\n    if (lastGate.out === lastCarry) {\n      lastGate.out = lastZ;\n    }\n\n    return gates;\n  }\n\n  // Helper to swap two gate outputs\n  function swapOutputs(gates: Gate[], out1: string, out2: string): Gate[] {\n    return gates.map(g => {\n      if (g.out === out1) return { ...g, out: out2 };\n      if (g.out === out2) return { ...g, out: out1 };\n      return { ...g };\n    });\n  }\n\n  it('should find swapped wires in a 4-bit adder with z01 and a01 swapped, plus z03 and b03', () => {\n    let gates = buildAdder(4);\n    gates = swapOutputs(gates, 'z01', 'a01');\n    gates = swapOutputs(gates, 'z03', 'b03');\n    // Need 4 swap pairs (8 wires), so add 2 more swaps\n    gates = swapOutputs(gates, 't02', 'c01');\n    gates = swapOutputs(gates, 'a03', 'b02');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a01', 'a03', 'b02', 'b03', 'c01', 't02', 'z01', 'z03']);\n  });\n\n  it('should find swapped wires in an 8-bit adder', () => {\n    let gates = buildAdder(8);\n    // Swap z02 with a02 (z output and AND output)\n    gates = swapOutputs(gates, 'z02', 'a02');\n    // Swap z05 with b05\n    gates = swapOutputs(gates, 'z05', 'b05');\n    // Swap t03 with c02\n    gates = swapOutputs(gates, 't03', 'c02');\n    // Swap a07 with b06\n    gates = swapOutputs(gates, 'a07', 'b06');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a02', 'a07', 'b05', 'b06', 'c02', 't03', 'z02', 'z05']);\n  });\n\n  it('should handle a 45-bit adder with swaps in under 5 seconds', () => {\n    let gates = buildAdder(45);\n    gates = swapOutputs(gates, 'z10', 'a10');\n    gates = swapOutputs(gates, 'z20', 'b20');\n    gates = swapOutputs(gates, 't30', 'c29');\n    gates = swapOutputs(gates, 'a40', 'b39');\n\n    const start = performance.now();\n    const result = findSwappedWires(gates);\n    const elapsed = performance.now() - start;\n\n    expect(elapsed).toBeLessThan(5000);\n    expect(result).toEqual(['a10', 'a40', 'b20', 'b39', 'c29', 't30', 'z10', 'z20']);\n  });\n\n  it('should return sorted array', () => {\n    let gates = buildAdder(8);\n    gates = swapOutputs(gates, 'z01', 'a01');\n    gates = swapOutputs(gates, 'z07', 't07');\n    gates = swapOutputs(gates, 'b03', 'c02');\n    gates = swapOutputs(gates, 'a05', 'b04');\n\n    const result = findSwappedWires(gates);\n    const sorted = [...result].sort();\n    expect(result).toEqual(sorted);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":247,"cache_read_input_tokens":36816,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":247},"outpu