+    }
+
+    const task = createTask(payload, options);
+    const queueState = this.getOrCreateQueue(task.queue);
+
+    // Phase 7: Validate dependencies
+    if (task.dependencies.length > 0) {
+      for (const depId of task.dependencies) {
+        const depTask = this.allTasks.get(depId);
+        if (!depTask) {
+          throw new Error(`Dependency task not found: ${depId}`);
+        }
+      }
+
+      // Check for circular dependencies
+      this.detectCircularDependencies(task);
+
+      // Check if some dependencies are already completed
+      for (const depId of task.dependencies) {
+        const depTask = this.allTasks.get(depId)!;
+        if (depTask.status === 'completed') {
+          task.resolvedDependencies.add(depId);
+        }
+      }
+
+      // If all deps already resolved, unblock
+      if (task.resolvedDependencies.size === task.dependencies.length) {
+        task.status = 'pending';
+      }
