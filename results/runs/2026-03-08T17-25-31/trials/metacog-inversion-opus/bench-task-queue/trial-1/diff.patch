+
+    // Return unsubscribe function
+    return () => {
+      listeners!.delete(listener);
+      if (listeners!.size === 0) {
+        this.progressListeners.delete(taskId);
+      }
+    };
+  }
+
+  // Phase 9: Cancel a task
+  cancel(taskId: string): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+
+    if (task.status !== 'pending' && task.status !== 'processing' && task.status !== 'blocked') {
+      throw new Error(`Cannot cancel task in status: ${task.status}`);
+    }
+
+    transitionTask(task, 'cancelled');
+
+    // Remove from queue's task list if pending/blocked
+    const queueState = this.queues.get(task.queue);
+    if (queueState) {
+      const idx = queueState.tasks.indexOf(task);
+      if (idx !== -1) {
+        queueState.tasks.splice(idx, 1);
+      }
+    }
+  }
+
+  // Phase 9: Get task by ID
+  getTask(taskId: string): Task | undefined {
+    return this.allTasks.get(taskId);
+  }
+
+  // Phase 10: Add a recurring schedule
+  addSchedule(
+    cronExpression: string,
+    queueName: string,
+    payload: unknown,
+    taskOptions?: Omit<TaskOptions, 'queue' | 'delay' | 'processAt' | 'dependencies'>
+  ): string {
+    if (this.isShutdown) {
+      throw new Error('Queue system is shut down. Cannot add schedules.');
+    }
+
+    const cronFields = parseCron(cronExpression);
+    const id = randomUUID();
+    this.schedules.set(id, {
+      id,
+      cronExpression,
+      queueName,
+      payload,
+      taskOptions,
+      cronFields,
+    });
+    return id;
+  }
+
+  // Phase 10: Remove a schedule
+  removeSchedule(scheduleId: string): void {
+    if (!this.schedules.has(scheduleId)) {
+      throw new Error(`Schedule not found: ${scheduleId}`);
+    }
+    this.schedules.delete(scheduleId);
+  }
+
+  // Phase 10: List active schedules
+  listSchedules(): ScheduleEntry[] {
+    return Array.from(this.schedules.values()).map(({ cronFields: _cf, ...entry }) => entry);
+  }
+
+  // Phase 10: Tick - check schedules and enqueue tasks
+  tick(now?: Date): Task[] {
+    const currentTime = now ?? new Date();
+    const created: Task[] = [];
+
+    for (const [, schedule] of this.schedules) {
+      if (cronMatches(schedule.cronFields, currentTime)) {
+        // Check if we already ran for this minute
+        if (
+          schedule.lastRun &&
+          schedule.lastRun.getFullYear() === currentTime.getFullYear() &&
+          schedule.lastRun.getMonth() === currentTime.getMonth() &&
+          schedule.lastRun.getDate() === currentTime.getDate() &&
+          schedule.lastRun.getHours() === currentTime.getHours() &&
+          schedule.lastRun.getMinutes() === currentTime.getMinutes()
+        ) {
+          continue;
+        }
+
+        schedule.lastRun = currentTime;
+        const task = this.add(schedule.payload, {
+          ...schedule.taskOptions,
+          queue: schedule.queueName,
+        });
+        created.push(task);
+      }
+    }
+
+    return created;
+  }
+
+  // Phase 11: Register middleware
+  use(queueName: string, middleware: MiddlewareFn): void {
+    const queueState = this.getOrCreateQueue(queueName);
+    queueState.middleware.push(middleware);
+  }
+
+  // Phase 11: Register handler
+  process(queueName: string, handler: TaskHandler): void {
+    const queueState = this.getOrCreateQueue(queueName);
+    queueState.handler = handler;
+  }
+
+  // Phase 11: Process next task through middleware pipeline
+  async processNext(queueName?: string): Promise<Task | null> {
+    const name = queueName ?? 'default';
+    const task = this.next(name);
+    if (!task) return null;
+
+    const queueState = this.queues.get(name)!;
+    const middlewares = [...queueState.middleware];
+    const handler = queueState.handler;
+
+    try {
+      await this.runMiddlewarePipeline(task, middlewares, handler);
+      if (task.status === 'processing') {
+        this.complete(task.id);
+      }
+    } catch (err: unknown) {
+      if (task.status === 'processing') {
+        const errorMessage = err instanceof Error ? err.message : String(err);
+        this.fail(task.id, errorMessage);
+      }
+    }
+
+    return task;
+  }
+
+  private async runMiddlewarePipeline(
+    task: Task,
+    middlewares: MiddlewareFn[],
+    handler: TaskHandler | null
+  ): Promise<void> {
+    let index = 0;
+    let nextCalled = false;
+
+    const executeNext = async (): Promise<void> => {
+      if (index < middlewares.length) {
+        const currentMiddleware = middlewares[index];
+        index++;
+        nextCalled = false;
+        await currentMiddleware(task, async () => {
+          nextCalled = true;
+          await executeNext();
+        });
+        // If middleware didn't call next, just return (skip rest of pipeline)
+        if (!nextCalled && index <= middlewares.length) {
+          return;
+        }
+      } else if (handler) {
+        await handler(task);
+      }
+    };
+
+    await executeNext();
+  }
+
+  // Phase 12: Register shutdown callback
+  onShutdown(callback: ShutdownCallback): void {
+    this.shutdownCallbacks.push(callback);
+  }
+
+  // Phase 12: Graceful shutdown
+  async shutdown(options?: ShutdownOptions): Promise<ShutdownResult> {
+    if (this.shutdownPromise) {
+      return this.shutdownPromise;
+    }
+
+    this.isShutdown = true;
+    this.shutdownPromise = this.performShutdown(options);
+    return this.shutdownPromise;
+  }
+
+  private async performShutdown(options?: ShutdownOptions): Promise<ShutdownResult> {
+    const startTime = Date.now();
+    const timeout = options?.timeout ?? 30000;
+    let completed = 0;
+    let forceCancelled = 0;
+
+    // Run shutdown callbacks
+    for (const cb of this.shutdownCallbacks) {
+      try {
+        await cb();
+      } catch {
+        // Ignore errors in shutdown callbacks
+      }
+    }
+
+    // Collect all processing tasks across all queues
+    const processingTasks: Task[] = [];
+    for (const [, queueState] of this.queues) {
+      for (const task of queueState.tasks) {
+        if (task.status === 'processing') {
+          processingTasks.push(task);
+        }
+      }
+    }
+
+    if (processingTasks.length === 0) {
+      return {
+        completed: 0,
+        forceCancelled: 0,
+        duration: Date.now() - startTime,
+      };
+    }
+
+    // Wait for processing tasks to complete, up to timeout
+    const waitForCompletion = new Promise<void>((resolve) => {
+      const check = (): void => {
+        const stillProcessing = processingTasks.filter(
+          (t) => t.status === 'processing'
+        );
+        if (stillProcessing.length === 0) {
+          resolve();
+        } else {
+          setTimeout(check, 10);
+        }
+      };
+      check();
+    });
+
+    const timeoutPromise = new Promise<'timeout'>((resolve) => {
+      setTimeout(() => resolve('timeout'), timeout);
+    });
+
+    const result = await Promise.race([
+      waitForCompletion.then(() => 'done' as const),
+      timeoutPromise,
+    ]);
+
+    // Count completed tasks
+    for (const task of processingTasks) {
+      if (task.status !== 'processing') {
+        completed++;
+      }
+    }
+
+    // Force-cancel remaining processing tasks
+    if (result === 'timeout') {
+      for (const task of processingTasks) {
+        if (task.status === 'processing') {
+          transitionTask(task, 'cancelled');
+          forceCancelled++;
+        }
+      }
+    }
+
+    return {
+      completed,
+      forceCancelled,
+      duration: Date.now() - startTime,
+    };
+  }
+}
