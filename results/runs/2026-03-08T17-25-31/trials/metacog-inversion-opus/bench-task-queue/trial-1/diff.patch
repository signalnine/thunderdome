+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CrhvF8NwVp9ykN9YJKqBkF","type":"tool_result","content":"The file /workspace/src/queue.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"e7ae74e6-7930-4c1a-a8d1-bb9320010819","uuid":"957abcc6-b0a3-4856-ac6c-5c26fe6c5f46","tool_use_result":{"filePath":"/workspace/src/queue.ts","oldString":"  TaskStatus,\n","newString":"\n","originalFile":"import { randomUUID } from 'node:crypto';\nimport { createTask, transitionTask } from './task.js';\nimport { parseCron, cronMatches, type CronFields } from './cron.js';\nimport type {\n  Task,\n  TaskOptions,\n  TaskStatus,\n  ProgressListener,\n  ScheduleEntry,\n  MiddlewareFn,\n  TaskHandler,\n  ShutdownOptions,\n  ShutdownResult,\n  ShutdownCallback,\n} from './types.js';\n\ninterface QueueState {\n  tasks: Task[];\n  deadLetterQueue: Task[];\n  concurrencyLimit: number | null;\n  middleware: MiddlewareFn[];\n  handler: TaskHandler | null;\n}\n\nexport class TaskQueue {\n  private queues: Map<string, QueueState> = new Map();\n  private allTasks: Map<string, Task> = new Map();\n  private progressListeners: Map<string, Set<ProgressListener>> = new Map();\n  private schedules: Map<string, ScheduleEntry & { cronFields: CronFields }> = new Map();\n  private isShutdown = false;\n  private shutdownPromise: Promise<ShutdownResult> | null = null;\n  private shutdownCallbacks: ShutdownCallback[] = [];\n\n  private getOrCreateQueue(name: string): QueueState {\n    let q = this.queues.get(name);\n    if (!q) {\n      q = {\n        tasks: [],\n        deadLetterQueue: [],\n        concurrencyLimit: null,\n        middleware: [],\n        handler: null,\n      };\n      this.queues.set(name, q);\n    }\n    return q;\n  }\n\n  // Phase 1 & 2: Add a task\n  add<T = unknown>(payload: T, options?: TaskOptions): Task<T> {\n    if (this.isShutdown) {\n      throw new Error('Queue system is shut down. Cannot add new tasks.');\n    }\n\n    const task = createTask(payload, options);\n    const queueState = this.getOrCreateQueue(task.queue);\n\n    // Phase 7: Validate dependencies\n    if (task.dependencies.length > 0) {\n      for (const depId of task.dependencies) {\n        const depTask = this.allTasks.get(depId);\n        if (!depTask) {\n          throw new Error(`Dependency task not found: ${depId}`);\n        }\n      }\n\n      // Check for circular dependencies\n      this.detectCircularDependencies(task);\n\n      // Check if some dependencies are already completed\n      for (const depId of task.dependencies) {\n        const depTask = this.allTasks.get(depId)!;\n        if (depTask.status === 'completed') {\n          task.resolvedDependencies.add(depId);\n        }\n      }\n\n      // If all deps already resolved, unblock\n      if (task.resolvedDependencies.size === task.dependencies.length) {\n        task.status = 'pending';\n      }\n    }\n\n    queueState.tasks.push(task);\n    this.allTasks.set(task.id, task);\n    return task;\n  }\n\n  // Phase 7: Detect circular dependencies using DFS\n  private detectCircularDependencies(newTask: Task): void {\n    // Build a dependency graph including the new task\n    const visited = new Set<string>();\n    const inStack = new Set<string>();\n\n    const dfs = (taskId: string): void => {\n      if (inStack.has(taskId)) {\n        throw new Error('Circular dependency detected');\n      }\n      if (visited.has(taskId)) return;\n\n      visited.add(taskId);\n      inStack.add(taskId);\n\n      let deps: string[];\n      if (taskId === newTask.id) {\n        deps = newTask.dependencies;\n      } else {\n        const t = this.allTasks.get(taskId);\n        deps = t ? t.dependencies : [];\n      }\n\n      for (const depId of deps) {\n        dfs(depId);\n      }\n\n      inStack.delete(taskId);\n    };\n\n    dfs(newTask.id);\n  }\n\n  // Phase 1: Get next task (with priority, delay, dependency, concurrency support)\n  next(queueName?: string): Task | null {\n    const name = queueName ?? 'default';\n    const queueState = this.queues.get(name);\n    if (!queueState) return null;\n\n    // Phase 8: Check concurrency limit\n    if (queueState.concurrencyLimit !== null) {\n      const activeCount = this.getActiveCount(name);\n      if (activeCount >= queueState.concurrencyLimit) {\n        return null;\n      }\n    }\n\n    const now = new Date();\n    const candidates = queueState.tasks.filter(\n      (t) =>\n        t.status === 'pending' &&\n        t.availableAt <= now\n    );\n\n    if (candidates.length === 0) return null;\n\n    // Sort by priority (lower = higher priority), then by availableAt, then by createdAt (FIFO)\n    candidates.sort((a, b) => {\n      if (a.priority !== b.priority) return a.priority - b.priority;\n      const availDiff = a.availableAt.getTime() - b.availableAt.getTime();\n      if (availDiff !== 0) return availDiff;\n      return a.createdAt.getTime() - b.createdAt.getTime();\n    });\n\n    const task = candidates[0];\n    transitionTask(task, 'processing');\n    task.attempts++;\n    return task;\n  }\n\n  // Phase 5: Complete a task\n  complete(taskId: string): void {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot complete task in status: ${task.status}`);\n    }\n\n    transitionTask(task, 'completed');\n    task.progress = 100;\n\n    // Phase 7: Resolve dependents\n    this.resolveDependents(taskId);\n  }\n\n  // Phase 5: Fail a task\n  fail(taskId: string, error?: string): void {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot fail task in status: ${task.status}`);\n    }\n\n    task.error = error;\n    task.failCount++;\n\n    if (task.attempts < task.maxRetries) {\n      // Retry with exponential backoff\n      const delay = task.backoffDelay * Math.pow(2, task.attempts - 1);\n      task.availableAt = new Date(Date.now() + delay);\n      transitionTask(task, 'pending');\n      task.progress = 0;\n    } else {\n      // Phase 6: Move to dead letter queue\n      transitionTask(task, 'failed');\n      const queueState = this.queues.get(task.queue);\n      if (queueState) {\n        // Remove from main tasks list\n        const idx = queueState.tasks.indexOf(task);\n        if (idx !== -1) {\n          queueState.tasks.splice(idx, 1);\n        }\n        queueState.deadLetterQueue.push(task);\n      }\n    }\n  }\n\n  // Phase 7: Resolve dependents when a task completes\n  private resolveDependents(completedTaskId: string): void {\n    for (const [, task] of this.allTasks) {\n      if (task.status !== 'blocked') continue;\n      if (!task.dependencies.includes(completedTaskId)) continue;\n\n      task.resolvedDependencies.add(completedTaskId);\n      if (task.resolvedDependencies.size === task.dependencies.length) {\n        transitionTask(task, 'pending');\n      }\n    }\n  }\n\n  // Phase 1: Get pending count\n  size(queueName?: string): number {\n    const name = queueName ?? 'default';\n    const queueState = this.queues.get(name);\n    if (!queueState) return 0;\n    return queueState.tasks.filter((t) => t.status === 'pending' || t.status === 'blocked').length;\n  }\n\n  // Phase 2: List all queue names\n  listQueues(): string[] {\n    return Array.from(this.queues.keys());\n  }\n\n  // Phase 6: Get dead letter queue tasks\n  getDeadLetterQueue(queueName?: string): Task[] {\n    const name = queueName ?? 'default';\n    const queueState = this.queues.get(name);\n    if (!queueState) return [];\n    return [...queueState.deadLetterQueue];\n  }\n\n  // Phase 6: Retry a dead-lettered task\n  retryDeadLetter(taskId: string): Task {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'failed') {\n      throw new Error(`Task is not in dead letter queue: ${taskId}`);\n    }\n\n    const queueState = this.queues.get(task.queue);\n    if (!queueState) throw new Error(`Queue not found: ${task.queue}`);\n\n    // Remove from DLQ\n    const dlqIdx = queueState.deadLetterQueue.indexOf(task);\n    if (dlqIdx !== -1) {\n      queueState.deadLetterQueue.splice(dlqIdx, 1);\n    }\n\n    // Reset for fresh retries\n    task.attempts = 0;\n    task.failCount = 0;\n    task.error = undefined;\n    task.progress = 0;\n    task.availableAt = new Date();\n    transitionTask(task, 'pending');\n\n    queueState.tasks.push(task);\n    return task;\n  }\n\n  // Phase 6: Clear dead letter queue\n  clearDeadLetterQueue(queueName?: string): void {\n    const name = queueName ?? 'default';\n    const queueState = this.queues.get(name);\n    if (!queueState) return;\n    for (const task of queueState.deadLetterQueue) {\n      this.allTasks.delete(task.id);\n    }\n    queueState.deadLetterQueue = [];\n  }\n\n  // Phase 7: Get dependency status\n  getDependencyStatus(taskId: string): { dependencies: string[]; resolved: string[]; pending: string[] } {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    const resolved = Array.from(task.resolvedDependencies);\n    const pending = task.dependencies.filter((d) => !task.resolvedDependencies.has(d));\n\n    return {\n      dependencies: [...task.dependencies],\n      resolved,\n      pending,\n    };\n  }\n\n  // Phase 8: Set concurrency limit\n  setConcurrency(queueName: string, limit: number | null): void {\n    const queueState = this.getOrCreateQueue(queueName);\n    queueState.concurrencyLimit = limit;\n  }\n\n  // Phase 8: Get concurrency limit\n  getConcurrency(queueName?: string): number | null {\n    const name = queueName ?? 'default';\n    const queueState = this.queues.get(name);\n    if (!queueState) return null;\n    return queueState.concurrencyLimit;\n  }\n\n  // Phase 8: Get active (processing) count\n  getActiveCount(queueName?: string): number {\n    const name = queueName ?? 'default';\n    const queueState = this.queues.get(name);\n    if (!queueState) return 0;\n    return queueState.tasks.filter((t) => t.status === 'processing').length;\n  }\n\n  // Phase 9: Report progress\n  reportProgress(taskId: string, progress: number, message?: string): void {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot report progress for task in status: ${task.status}`);\n    }\n    if (progress < 0 || progress > 100) {\n      throw new Error(`Progress must be between 0 and 100, got: ${progress}`);\n    }\n\n    task.progress = progress;\n    task.progressMessage = message;\n\n    // Notify listeners\n    const listeners = this.progressListeners.get(taskId);\n    if (listeners) {\n      for (const listener of listeners) {\n        listener(progress, message);\n      }\n    }\n  }\n\n  // Phase 9: Get progress\n  getProgress(taskId: string): { progress: number; message?: string } {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    return { progress: task.progress, message: task.progressMessage };\n  }\n\n  // Phase 9: Subscribe to progress updates\n  onProgress(taskId: string, listener: ProgressListener): () => void {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    let listeners = this.progressListeners.get(taskId);\n    if (!listeners) {\n      listeners = new Set();\n      this.progressListeners.set(taskId, listeners);\n    }\n    listeners.add(listener);\n\n    // Return unsubscribe function\n    return () => {\n      listeners!.delete(listener);\n      if (listeners!.size === 0) {\n        this.progressListeners.delete(taskId);\n      }\n    };\n  }\n\n  // Phase 9: Cancel a task\n  cancel(taskId: string): void {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    if (task.status !== 'pending' && task.status !== 'processing' && task.status !== 'blocked') {\n      throw new Error(`Cannot cancel task in status: ${task.status}`);\n    }\n\n    transitionTask(task, 'cancelled');\n\n    // Remove from queue's task list if pending/blocked\n    const queueState = this.queues.get(task.queue);\n    if (queueState) {\n      const idx = queueState.tasks.indexOf(task);\n      if (idx !== -1) {\n        queueState.tasks.splice(idx, 1);\n      }\n    }\n  }\n\n  // Phase 9: Get task by ID\n  getTask(taskId: string): Task | undefined {\n    return this.allTasks.get(taskId);\n  }\n\n  // Phase 10: Add a recurring schedule\n  addSchedule(\n    cronExpression: string,\n    queueName: string,\n    payload: unknown,\n    taskOptions?: Omit<TaskOptions, 'queue' | 'delay' | 'processAt' | 'dependencies'>\n  ): string {\n    if (this.isShutdown) {\n      throw new Error('Queue system is shut down. Cannot add schedules.');\n    }\n\n    const cronFields = parseCron(cronExpression);\n    const id = randomUUID();\n    this.schedules.set(id, {\n      id,\n      cronExpression,\n      queueName,\n      payload,\n      taskOptions,\n      cronFields,\n    });\n    return id;\n  }\n\n  // Phase 10: Remove a schedule\n  removeSchedule(scheduleId: string): void {\n    if (!this.schedules.has(scheduleId)) {\n      throw new Error(`Schedule not found: ${scheduleId}`);\n    }\n    this.schedules.delete(scheduleId);\n  }\n\n  // Phase 10: List active schedules\n  listSchedules(): ScheduleEntry[] {\n    return Array.from(this.schedules.values()).map(({ cronFields: _cf, ...entry }) => entry);\n  }\n\n  // Phase 10: Tick - check schedules and enqueue tasks\n  tick(now?: Date): Task[] {\n    const currentTime = now ?? new Date();\n    const created: Task[] = [];\n\n    for (const [, schedule] of this.schedules) {\n      if (cronMatches(schedule.cronFields, currentTime)) {\n        // Check if we already ran for this minute\n        if (\n          schedule.lastRun &&\n          schedule.lastRun.getFullYear() === currentTime.getFullYear() &&\n          schedule.lastRun.getMonth() === currentTime.getMonth() &&\n          schedule.lastRun.getDate() === currentTime.getDate() &&\n          schedule.lastRun.getHours() === currentTime.getHours() &&\n          schedule.lastRun.getMinutes() === currentTime.getMinutes()\n        ) {\n          continue;\n        }\n\n        schedule.lastRun = currentTime;\n        const task = this.add(schedule.payload, {\n          ...schedule.taskOptions,\n          queue: schedule.queueName,\n        });\n        created.push(task);\n      }\n    }\n\n    return created;\n  }\n\n  // Phase 11: Register middleware\n  use(queueName: string, middleware: MiddlewareFn): void {\n    const queueState = this.getOrCreateQueue(queueName);\n    queueState.middleware.push(middleware);\n  }\n\n  // Phase 11: Register handler\n  process(queueName: string, handler: TaskHandler): void {\n    const queueState = this.getOrCreateQueue(queueName);\n    queueState.handler = handler;\n  }\n\n  // Phase 11: Process next task through middleware pipeline\n  async processNext(queueName?: string): Promise<Task | null> {\n    const name = queueName ?? 'default';\n    const task = this.next(name);\n    if (!task) return null;\n\n    const queueState = this.queues.get(name)!;\n    const middlewares = [...queueState.middleware];\n    const handler = queueState.handler;\n\n    try {\n      await this.runMiddlewarePipeline(task, middlewares, handler);\n      if (task.status === 'processing') {\n        this.complete(task.id);\n      }\n    } catch (err: unknown) {\n      if (task.status === 'processing') {\n        const errorMessage = err instanceof Error ? err.message : String(err);\n        this.fail(task.id, errorMessage);\n      }\n    }\n\n    return task;\n  }\n\n  private async runMiddlewarePipeline(\n    task: Task,\n    middlewares: MiddlewareFn[],\n    handler: TaskHandler | null\n  ): Promise<void> {\n    let index = 0;\n    let nextCalled = false;\n\n    const executeNext = async (): Promise<void> => {\n      if (index < middlewares.length) {\n        const currentMiddleware = middlewares[index];\n        index++;\n        nextCalled = false;\n        await currentMiddleware(task, async () => {\n          nextCalled = true;\n          await executeNext();\n        });\n        // If middleware didn't call next, just return (skip rest of pipeline)\n        if (!nextCalled && index <= middlewares.length) {\n          return;\n        }\n      } else if (handler) {\n        await handler(task);\n      }\n    };\n\n    await executeNext();\n  }\n\n  // Phase 12: Register shutdown callback\n  onShutdown(callback: ShutdownCallback): void {\n    this.shutdownCallbacks.push(callback);\n  }\n\n  // Phase 12: Graceful shutdown\n  async shutdown(options?: ShutdownOptions): Promise<ShutdownResult> {\n    if (this.shutdownPromise) {\n      return this.shutdownPromise;\n    }\n\n    this.isShutdown = true;\n    this.shutdownPromise = this.performShutdown(options);\n    return this.shutdownPromise;\n  }\n\n  private async performShutdown(options?: ShutdownOptions): Promise<ShutdownResult> {\n    const startTime = Date.now();\n    const timeout = options?.timeout ?? 30000;\n    let completed = 0;\n    let forceCancelled = 0;\n\n    // Run shutdown callbacks\n    for (const cb of this.shutdownCallbacks) {\n      try {\n        await cb();\n      } catch {\n        // Ignore errors in shutdown callbacks\n      }\n    }\n\n    // Collect all processing tasks across all queues\n    const processingTasks: Task[] = [];\n    for (const [, queueState] of this.queues) {\n      for (const task of queueState.tasks) {\n        if (task.status === 'processing') {\n          processingTasks.push(task);\n        }\n      }\n    }\n\n    if (processingTasks.length === 0) {\n      return {\n        completed: 0,\n        forceCancelled: 0,\n        duration: Date.now() - startTime,\n      };\n    }\n\n    // Wait for processing tasks to complete, up to timeout\n    const waitForCompletion = new Promise<void>((resolve) => {\n      const check = (): void => {\n        const stillProcessing = processingTasks.filter(\n          (t) => t.status === 'processing'\n        );\n        if (stillProcessing.length === 0) {\n          resolve();\n        } else {\n          setTimeout(check, 10);\n        }\n      };\n      check();\n    });\n\n    const timeoutPromise = new Promise<'timeout'>((resolve) => {\n      setTimeout(() => resolve('timeout'), timeout);\n    });\n\n    const result = await Promise.race([\n      waitForCompletion.then(() => 'done' as const),\n      timeoutPromise,\n    ]);\n\n    // Count completed tasks\n    for (const task of processingTasks) {\n      if (task.status !== 'processing') {\n        completed++;\n      }\n    }\n\n    // Force-cancel remaining processing tasks\n    if (result === 'timeout') {\n      for (const task of processingTasks) {\n        if (task.status === 'processing') {\n          transitionTask(task, 'cancelled');\n          forceCancelled++;\n        }\n      }\n    }\n\n    return {\n      completed,\n      forceCancelled,\n      duration: Date.now() - startTime,\n    };\n  }\n}\n","structuredPatch":[{"oldStart":4,"oldLines":7,"newStart":4,"newLines":7,"lines":[" import type {","   Task,","   TaskOptions,","-  TaskStatus,","+","   ProgressListener,","   ScheduleEntry,","   MiddlewareFn,"]}],"userModified":false,"replaceAll":false}}
