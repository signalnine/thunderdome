e not found: ${task.queue}`);\n\n    // Remove from DLQ\n    const dlqIdx = queueState.deadLetterQueue.indexOf(task);\n    if (dlqIdx !== -1) {\n      queueState.deadLetterQueue.splice(dlqIdx, 1);\n    }\n\n    // Reset for fresh retries\n    task.attempts = 0;\n    task.failCount = 0;\n    task.error = undefined;\n    task.progress = 0;\n    task.availableAt = new Date();\n    transitionTask(task, 'pending');\n\n    queueState.tasks.push(task);\n    return task;\n  }\n\n  // Phase 6: Clear dead letter queue\n  clearDeadLetterQueue(queueName?: string): void {\n    const name = queueName ?? 'default';\n    const queueState = this.queues.get(name);\n    if (!queueState) return;\n    for (const task of queueState.deadLetterQueue) {\n      this.allTasks.delete(task.id);\n    }\n    queueState.deadLetterQueue = [];\n  }\n\n  // Phase 7: Get dependency status\n  getDependencyStatus(taskId: string): { dependencies: string[]; resolved: string[]; pending: string[] } {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    const resolved = Array.from(task.resolvedDependencies);\n    const pending = task.dependencies.filter((d) => !task.resolvedDependencies.has(d));\n\n    return {\n      dependencies: [...task.dependencies],\n      resolved,\n      pending,\n    };\n  }\n\n  // Phase 8: Set concurrency limit\n  setConcurrency(queueName: string, limit: number | null): void {\n    const queueState = this.getOrCreateQueue(queueName);\n    queueState.concurrencyLimit = limit;\n  }\n\n  // Phase 8: Get concurrency limit\n  getConcurrency(queueName?: string): number | null {\n    const name = queueName ?? 'default';\n    const queueState = this.queues.get(name);\n    if (!queueState) return null;\n    return queueState.concurrencyLimit;\n  }\n\n  // Phase 8: Get active (processing) count\n  getActiveCount(queueName?: string): number {\n    const name = queueName ?? 'default';\n    const queueState = this.queues.get(name);\n