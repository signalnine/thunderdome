+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WqdkS2a6gBt59KrRBSuGFL","type":"tool_result","content":"File created successfully at: /workspace/src/queue.test.ts"}]},"parent_tool_use_id":null,"session_id":"e7ae74e6-7930-4c1a-a8d1-bb9320010819","uuid":"0dc30eb9-0e48-40bb-b9a0-2f7012e2ef47","tool_use_result":{"type":"create","filePath":"/workspace/src/queue.test.ts","content":"import { describe, it, expect, vi, beforeEach } from 'vitest';\nimport { TaskQueue } from './queue.js';\n\ndescribe('Phase 1: Basic FIFO Queue', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  it('should add a task and return a task object', () => {\n    const task = tq.add({ message: 'hello' });\n    expect(task).toBeDefined();\n    expect(task.id).toBeDefined();\n    expect(task.payload).toEqual({ message: 'hello' });\n    expect(task.status).toBe('pending');\n    expect(task.createdAt).toBeInstanceOf(Date);\n  });\n\n  it('should return tasks in FIFO order', () => {\n    const t1 = tq.add('first');\n    const t2 = tq.add('second');\n    const t3 = tq.add('third');\n\n    const r1 = tq.next();\n    expect(r1?.id).toBe(t1.id);\n    expect(r1?.status).toBe('processing');\n\n    const r2 = tq.next();\n    expect(r2?.id).toBe(t2.id);\n\n    const r3 = tq.next();\n    expect(r3?.id).toBe(t3.id);\n  });\n\n  it('should return null when no tasks available', () => {\n    expect(tq.next()).toBeNull();\n  });\n\n  it('should transition task to processing state', () => {\n    tq.add('task');\n    const task = tq.next();\n    expect(task?.status).toBe('processing');\n  });\n\n  it('should track pending count', () => {\n    expect(tq.size()).toBe(0);\n    tq.add('a');\n    tq.add('b');\n    expect(tq.size()).toBe(2);\n    tq.next();\n    expect(tq.size()).toBe(1);\n  });\n\n  it('should have unique IDs for each task', () => {\n    const t1 = tq.add('a');\n    const t2 = tq.add('b');\n    expect(t1.id).not.toBe(t2.id);\n  });\n});\n\ndescribe('Phase 2: Named Queues', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  it('should use default queue when no name given', () => {\n    tq.add('task');\n    expect(tq.next()).not.toBeNull();\n    expect(tq.next('default')).toBeNull();\n  });\n\n  it('should support multiple named queues', () => {\n    tq.add('email', { queue: 'email' });\n    tq.add('sms', { queue: 'sms' });\n\n    expect(tq.next('email')?.payload).toBe('email');\n    expect(tq.next('sms')?.payload).toBe('sms');\n    expect(tq.next('email')).toBeNull();\n    expect(tq.next('sms')).toBeNull();\n  });\n\n  it('should list all queue names', () => {\n    tq.add('a', { queue: 'q1' });\n    tq.add('b', { queue: 'q2' });\n    const names = tq.listQueues();\n    expect(names).toContain('q1');\n    expect(names).toContain('q2');\n  });\n\n  it('should return null for non-existent queue', () => {\n    expect(tq.next('nonexistent')).toBeNull();\n  });\n\n  it('should create queue implicitly', () => {\n    tq.add('task', { queue: 'new-queue' });\n    expect(tq.listQueues()).toContain('new-queue');\n  });\n});\n\ndescribe('Phase 3: Priority', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  it('should default priority to 5', () => {\n    const task = tq.add('task');\n    expect(task.priority).toBe(5);\n  });\n\n  it('should process higher priority first (lower number)', () => {\n    tq.add('low', { priority: 10 });\n    tq.add('high', { priority: 1 });\n    tq.add('medium', { priority: 5 });\n\n    expect(tq.next()?.payload).toBe('high');\n    expect(tq.next()?.payload).toBe('medium');\n    expect(tq.next()?.payload).toBe('low');\n  });\n\n  it('should maintain FIFO within same priority', () => {\n    tq.add('first', { priority: 3 });\n    tq.add('second', { priority: 3 });\n\n    expect(tq.next()?.payload).toBe('first');\n    expect(tq.next()?.payload).toBe('second');\n  });\n\n  it('should reject invalid priorities', () => {\n    expect(() => tq.add('task', { priority: 0 })).toThrow();\n    expect(() => tq.add('task', { priority: 11 })).toThrow();\n    expect(() => tq.add('task', { priority: 1.5 })).toThrow();\n  });\n\n  it('should handle priorities per queue', () => {\n    tq.add('q1-low', { queue: 'q1', priority: 10 });\n    tq.add('q1-high', { queue: 'q1', priority: 1 });\n    tq.add('q2-low', { queue: 'q2', priority: 10 });\n\n    expect(tq.next('q1')?.payload).toBe('q1-high');\n    expect(tq.next('q2')?.payload).toBe('q2-low');\n  });\n});\n\ndescribe('Phase 4: Delayed Tasks', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  it('should delay task availability', () => {\n    tq.add('delayed', { delay: 10000 });\n    expect(tq.next()).toBeNull(); // not available yet\n  });\n\n  it('should make task available after delay', () => {\n    vi.useFakeTimers();\n    tq.add('delayed', { delay: 1000 });\n    expect(tq.next()).toBeNull();\n\n    vi.advanceTimersByTime(1000);\n    expect(tq.next()?.payload).toBe('delayed');\n    vi.useRealTimers();\n  });\n\n  it('should support processAt', () => {\n    const future = new Date(Date.now() + 60000);\n    const task = tq.add('scheduled', { processAt: future });\n    expect(task.availableAt.getTime()).toBe(future.getTime());\n    expect(tq.next()).toBeNull();\n  });\n\n  it('should prefer non-delayed tasks', () => {\n    vi.useFakeTimers();\n    tq.add('delayed', { delay: 500, priority: 1 });\n    tq.add('immediate', { priority: 5 });\n\n    expect(tq.next()?.payload).toBe('immediate');\n    vi.useRealTimers();\n  });\n\n  it('should expose availableAt', () => {\n    const task = tq.add('task', { delay: 5000 });\n    expect(task.availableAt.getTime()).toBeGreaterThan(task.createdAt.getTime());\n  });\n});\n\ndescribe('Phase 5: Retry with Backoff', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n    vi.useFakeTimers();\n  });\n\n  it('should complete a task', () => {\n    const task = tq.add('task');\n    tq.next();\n    tq.complete(task.id);\n    expect(task.status).toBe('completed');\n  });\n\n  it('should fail and retry a task', () => {\n    const task = tq.add('task', { maxRetries: 3, backoffDelay: 100 });\n    tq.next();\n    tq.fail(task.id, 'error');\n\n    expect(task.status).toBe('pending');\n    expect(task.attempts).toBe(1);\n    expect(task.failCount).toBe(1);\n    expect(task.error).toBe('error');\n  });\n\n  it('should use exponential backoff', () => {\n    const task = tq.add('task', { maxRetries: 3, backoffDelay: 1000 });\n\n    // First attempt\n    tq.next();\n    tq.fail(task.id, 'error');\n    // delay should be 1000 * 2^0 = 1000ms\n    expect(tq.next()).toBeNull();\n    vi.advanceTimersByTime(1000);\n    expect(tq.next()).not.toBeNull();\n\n    // Second attempt\n    tq.fail(task.id, 'error');\n    // delay should be 1000 * 2^1 = 2000ms\n    expect(tq.next()).toBeNull();\n    vi.advanceTimersByTime(2000);\n    expect(tq.next()).not.toBeNull();\n  });\n\n  it('should track attempts', () => {\n    const task = tq.add('task', { maxRetries: 2, backoffDelay: 100 });\n\n    tq.next();\n    expect(task.attempts).toBe(1);\n    tq.fail(task.id, 'err');\n\n    vi.advanceTimersByTime(200);\n    tq.next();\n    expect(task.attempts).toBe(2);\n  });\n\n  it('should keep original queue and priority on retry', () => {\n    const task = tq.add('task', { queue: 'myqueue', priority: 2, maxRetries: 3, backoffDelay: 100 });\n    tq.next('myqueue');\n    tq.fail(task.id, 'err');\n\n    expect(task.queue).toBe('myqueue');\n    expect(task.priority).toBe(2);\n  });\n\n  afterEach(() => {\n    vi.useRealTimers();\n  });\n});\n\ndescribe('Phase 6: Dead Letter Queue', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n    vi.useFakeTimers();\n  });\n\n  it('should move exhausted task to DLQ', () => {\n    const task = tq.add('task', { maxRetries: 1, backoffDelay: 100 });\n\n    // First and only attempt\n    tq.next();\n    tq.fail(task.id, 'error');\n\n    // task had maxRetries=1 so after 1 attempt it's exhausted\n    expect(task.status).toBe('failed');\n    expect(tq.getDeadLetterQueue()).toHaveLength(1);\n    expect(tq.getDeadLetterQueue()[0].id).toBe(task.id);\n  });\n\n  it('should retain error info in DLQ', () => {\n    const task = tq.add('task', { maxRetries: 1 });\n    tq.next();\n    tq.fail(task.id, 'specific error');\n\n    const dlq = tq.getDeadLetterQueue();\n    expect(dlq[0].error).toBe('specific error');\n    expect(dlq[0].failCount).toBe(1);\n  });\n\n  it('should retry dead-lettered task', () => {\n    const task = tq.add('task', { maxRetries: 1, backoffDelay: 100 });\n    tq.next();\n    tq.fail(task.id, 'error');\n\n    expect(tq.getDeadLetterQueue()).toHaveLength(1);\n    const retried = tq.retryDeadLetter(task.id);\n    expect(retried.status).toBe('pending');\n    expect(retried.attempts).toBe(0);\n    expect(tq.getDeadLetterQueue()).toHaveLength(0);\n\n    // Can process again\n    const fetched = tq.next();\n    expect(fetched?.id).toBe(task.id);\n  });\n\n  it('should clear dead letter queue', () => {\n    const t1 = tq.add('t1', { maxRetries: 1 });\n    const t2 = tq.add('t2', { maxRetries: 1 });\n    tq.next();\n    tq.fail(t1.id, 'err');\n    tq.next();\n    tq.fail(t2.id, 'err');\n\n    expect(tq.getDeadLetterQueue()).toHaveLength(2);\n    tq.clearDeadLetterQueue();\n    expect(tq.getDeadLetterQueue()).toHaveLength(0);\n  });\n\n  it('should have independent DLQs per queue', () => {\n    const t1 = tq.add('t1', { queue: 'q1', maxRetries: 1 });\n    const t2 = tq.add('t2', { queue: 'q2', maxRetries: 1 });\n\n    tq.next('q1');\n    tq.fail(t1.id, 'err');\n    tq.next('q2');\n    tq.fail(t2.id, 'err');\n\n    expect(tq.getDeadLetterQueue('q1')).toHaveLength(1);\n    expect(tq.getDeadLetterQueue('q2')).toHaveLength(1);\n\n    tq.clearDeadLetterQueue('q1');\n    expect(tq.getDeadLetterQueue('q1')).toHaveLength(0);\n    expect(tq.getDeadLetterQueue('q2')).toHaveLength(1);\n  });\n\n  afterEach(() => {\n    vi.useRealTimers();\n  });\n});\n\ndescribe('Phase 7: Task Dependencies', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  it('should block task with pending dependencies', () => {\n    const t1 = tq.add('parent');\n    const t2 = tq.add('child', { dependencies: [t1.id] });\n\n    expect(t2.status).toBe('blocked');\n    // Should not return blocked tasks\n    const next = tq.next();\n    expect(next?.id).toBe(t1.id);\n    expect(tq.next()).toBeNull(); // t2 is blocked\n  });\n\n  it('should unblock task when dependency completes', () => {\n    const t1 = tq.add('parent');\n    const t2 = tq.add('child', { dependencies: [t1.id] });\n\n    const fetched = tq.next();\n    tq.complete(fetched!.id);\n\n    expect(t2.status).toBe('pending');\n    const child = tq.next();\n    expect(child?.id).toBe(t2.id);\n  });\n\n  it('should detect circular dependencies', () => {\n    const t1 = tq.add('a');\n    const t2 = tq.add('b', { dependencies: [t1.id] });\n    expect(() => tq.add('c', { dependencies: [t2.id, t1.id] })).not.toThrow();\n\n    // Direct circular: t3 depends on t1, t1 can't depend on t3 since t1 has no deps\n    // Indirect: need to set up a chain\n  });\n\n  it('should reject dependency on non-existent task', () => {\n    expect(() => tq.add('task', { dependencies: ['nonexistent'] })).toThrow();\n  });\n\n  it('should handle multiple dependencies', () => {\n    const t1 = tq.add('dep1');\n    const t2 = tq.add('dep2');\n    const t3 = tq.add('child', { dependencies: [t1.id, t2.id] });\n\n    expect(t3.status).toBe('blocked');\n\n    tq.next(); // t1\n    tq.complete(t1.id);\n    expect(t3.status).toBe('blocked'); // still waiting on t2\n\n    tq.next(); // t2\n    tq.complete(t2.id);\n    expect(t3.status).toBe('pending'); // now unblocked\n  });\n\n  it('should show dependency status', () => {\n    const t1 = tq.add('dep1');\n    const t2 = tq.add('dep2');\n    const t3 = tq.add('child', { dependencies: [t1.id, t2.id] });\n\n    const status = tq.getDependencyStatus(t3.id);\n    expect(status.dependencies).toHaveLength(2);\n    expect(status.pending).toHaveLength(2);\n    expect(status.resolved).toHaveLength(0);\n\n    tq.next();\n    tq.complete(t1.id);\n\n    const updated = tq.getDependencyStatus(t3.id);\n    expect(updated.resolved).toContain(t1.id);\n    expect(updated.pending).toContain(t2.id);\n  });\n\n  it('should not fail dependents when dependency fails', () => {\n    const t1 = tq.add('parent', { maxRetries: 1 });\n    const t2 = tq.add('child', { dependencies: [t1.id] });\n\n    tq.next();\n    tq.fail(t1.id, 'error');\n\n    // t2 remains blocked (not failed)\n    expect(t2.status).toBe('blocked');\n  });\n\n  it('should auto-resolve already-completed dependencies', () => {\n    const t1 = tq.add('parent');\n    tq.next();\n    tq.complete(t1.id);\n\n    const t2 = tq.add('child', { dependencies: [t1.id] });\n    expect(t2.status).toBe('pending'); // immediately unblocked\n  });\n});\n\ndescribe('Phase 8: Concurrency Control', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  it('should limit concurrent processing', () => {\n    tq.setConcurrency('default', 2);\n    tq.add('a');\n    tq.add('b');\n    tq.add('c');\n\n    const t1 = tq.next();\n    const t2 = tq.next();\n    const t3 = tq.next();\n\n    expect(t1).not.toBeNull();\n    expect(t2).not.toBeNull();\n    expect(t3).toBeNull(); // concurrency limit reached\n  });\n\n  it('should free slot on completion', () => {\n    tq.setConcurrency('default', 1);\n    tq.add('a');\n    tq.add('b');\n\n    const t1 = tq.next()!;\n    expect(tq.next()).toBeNull();\n\n    tq.complete(t1.id);\n    expect(tq.next()).not.toBeNull();\n  });\n\n  it('should free slot on failure', () => {\n    tq.setConcurrency('default', 1);\n    tq.add('a', { maxRetries: 1 });\n    tq.add('b');\n\n    const t1 = tq.next()!;\n    expect(tq.next()).toBeNull();\n\n    tq.fail(t1.id, 'err');\n    // t1 moved to DLQ, slot freed\n    expect(tq.next()).not.toBeNull();\n  });\n\n  it('should have unlimited concurrency by default', () => {\n    expect(tq.getConcurrency()).toBeNull();\n\n    for (let i = 0; i < 100; i++) {\n      tq.add(`task-${i}`);\n    }\n    for (let i = 0; i < 100; i++) {\n      expect(tq.next()).not.toBeNull();\n    }\n  });\n\n  it('should report active count', () => {\n    tq.add('a');\n    tq.add('b');\n\n    expect(tq.getActiveCount()).toBe(0);\n    tq.next();\n    expect(tq.getActiveCount()).toBe(1);\n    tq.next();\n    expect(tq.getActiveCount()).toBe(2);\n  });\n\n  it('should still respect priority with concurrency', () => {\n    tq.setConcurrency('default', 1);\n    tq.add('low', { priority: 10 });\n    tq.add('high', { priority: 1 });\n\n    const task = tq.next()!;\n    expect(task.payload).toBe('high');\n  });\n});\n\ndescribe('Phase 9: Progress and Cancellation', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  it('should report progress on a task', () => {\n    const task = tq.add('task');\n    tq.next();\n\n    tq.reportProgress(task.id, 50, 'halfway');\n    const p = tq.getProgress(task.id);\n    expect(p.progress).toBe(50);\n    expect(p.message).toBe('halfway');\n  });\n\n  it('should notify progress listeners', () => {\n    const task = tq.add('task');\n    tq.next();\n\n    const updates: Array<{ progress: number; message?: string }> = [];\n    tq.onProgress(task.id, (progress, message) => {\n      updates.push({ progress, message });\n    });\n\n    tq.reportProgress(task.id, 25, 'quarter');\n    tq.reportProgress(task.id, 75, 'three quarters');\n\n    expect(updates).toHaveLength(2);\n    expect(updates[0].progress).toBe(25);\n    expect(updates[1].progress).toBe(75);\n  });\n\n  it('should support unsubscription', () => {\n    const task = tq.add('task');\n    tq.next();\n\n    let callCount = 0;\n    const unsub = tq.onProgress(task.id, () => { callCount++; });\n\n    tq.reportProgress(task.id, 25);\n    unsub();\n    tq.reportProgress(task.id, 50);\n\n    expect(callCount).toBe(1);\n  });\n\n  it('should cancel a pending task', () => {\n    const task = tq.add('task');\n    tq.cancel(task.id);\n\n    expect(task.status).toBe('cancelled');\n    expect(tq.next()).toBeNull();\n  });\n\n  it('should cancel a processing task', () => {\n    const task = tq.add('task');\n    tq.next();\n\n    tq.cancel(task.id);\n    expect(task.status).toBe('cancelled');\n  });\n\n  it('should not retry cancelled tasks', () => {\n    vi.useFakeTimers();\n    const task = tq.add('task', { maxRetries: 3 });\n    tq.next();\n    tq.cancel(task.id);\n\n    expect(task.status).toBe('cancelled');\n    vi.advanceTimersByTime(10000);\n    expect(tq.next()).toBeNull();\n    vi.useRealTimers();\n  });\n\n  it('should reject progress outside 0-100', () => {\n    const task = tq.add('task');\n    tq.next();\n\n    expect(() => tq.reportProgress(task.id, -1)).toThrow();\n    expect(() => tq.reportProgress(task.id, 101)).toThrow();\n  });\n\n  it('should get task by id', () => {\n    const task = tq.add('payload');\n    const fetched = tq.getTask(task.id);\n    expect(fetched?.payload).toBe('payload');\n  });\n});\n\ndescribe('Phase 10: Recurring Tasks', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  it('should add and list schedules', () => {\n    const id = tq.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });\n    expect(id).toBeDefined();\n\n    const schedules = tq.listSchedules();\n    expect(schedules).toHaveLength(1);\n    expect(schedules[0].cronExpression).toBe('*/5 * * * *');\n  });\n\n  it('should create tasks on tick when cron matches', () => {\n    tq.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });\n\n    // 12:05 - should match\n    const time = new Date(2024, 0, 1, 12, 5, 0);\n    const created = tq.tick(time);\n    expect(created).toHaveLength(1);\n    expect(created[0].payload).toEqual({ type: 'cleanup' });\n  });\n\n  it('should not create tasks when cron does not match', () => {\n    tq.addSchedule('0 * * * *', 'default', { type: 'hourly' });\n\n    // 12:30 - should not match (only on the hour)\n    const time = new Date(2024, 0, 1, 12, 30, 0);\n    const created = tq.tick(time);\n    expect(created).toHaveLength(0);\n  });\n\n  it('should not duplicate on same minute tick', () => {\n    tq.addSchedule('*/5 * * * *', 'default', { type: 'test' });\n\n    const time = new Date(2024, 0, 1, 12, 5, 0);\n    tq.tick(time);\n    const second = tq.tick(time);\n    expect(second).toHaveLength(0);\n  });\n\n  it('should remove schedule', () => {\n    const id = tq.addSchedule('*/5 * * * *', 'default', { type: 'test' });\n    tq.removeSchedule(id);\n\n    const created = tq.tick(new Date(2024, 0, 1, 12, 5, 0));\n    expect(created).toHaveLength(0);\n    expect(tq.listSchedules()).toHaveLength(0);\n  });\n\n  it('should support every day at midnight', () => {\n    tq.addSchedule('0 0 * * *', 'default', { type: 'daily' });\n\n    const midnight = new Date(2024, 0, 1, 0, 0, 0);\n    const noon = new Date(2024, 0, 1, 12, 0, 0);\n\n    expect(tq.tick(midnight)).toHaveLength(1);\n    expect(tq.tick(noon)).toHaveLength(0);\n  });\n});\n\ndescribe('Phase 11: Middleware Pipeline', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  it('should run middleware and handler', async () => {\n    const log: string[] = [];\n\n    tq.use('default', async (_task, next) => {\n      log.push('middleware1');\n      await next();\n    });\n\n    tq.process('default', () => {\n      log.push('handler');\n    });\n\n    tq.add('task');\n    await tq.processNext();\n\n    expect(log).toEqual(['middleware1', 'handler']);\n  });\n\n  it('should run multiple middleware in order', async () => {\n    const log: string[] = [];\n\n    tq.use('default', async (_task, next) => {\n      log.push('m1-before');\n      await next();\n      log.push('m1-after');\n    });\n\n    tq.use('default', async (_task, next) => {\n      log.push('m2-before');\n      await next();\n      log.push('m2-after');\n    });\n\n    tq.process('default', () => {\n      log.push('handler');\n    });\n\n    tq.add('task');\n    await tq.processNext();\n\n    expect(log).toEqual(['m1-before', 'm2-before', 'handler', 'm2-after', 'm1-after']);\n  });\n\n  it('should skip handler if middleware does not call next', async () => {\n    const log: string[] = [];\n\n    tq.use('default', async () => {\n      log.push('middleware-skip');\n      // intentionally NOT calling next\n    });\n\n    tq.process('default', () => {\n      log.push('handler-should-not-run');\n    });\n\n    tq.add('task');\n    await tq.processNext();\n\n    expect(log).toEqual(['middleware-skip']);\n  });\n\n  it('should fail task if middleware throws', async () => {\n    tq.use('default', async () => {\n      throw new Error('middleware error');\n    });\n\n    const task = tq.add('task', { maxRetries: 1 });\n    await tq.processNext();\n\n    expect(task.error).toBe('middleware error');\n  });\n\n  it('should modify task in middleware', async () => {\n    tq.use('default', async (task, next) => {\n      task.metadata['enriched'] = true;\n      await next();\n    });\n\n    let sawMetadata = false;\n    tq.process('default', (task) => {\n      sawMetadata = task.metadata['enriched'] === true;\n    });\n\n    tq.add('task');\n    await tq.processNext();\n\n    expect(sawMetadata).toBe(true);\n  });\n\n  it('should auto-complete task after handler', async () => {\n    tq.process('default', () => {\n      // do nothing\n    });\n\n    const task = tq.add('task');\n    await tq.processNext();\n\n    expect(task.status).toBe('completed');\n  });\n\n  it('should return null when no tasks available', async () => {\n    const result = await tq.processNext();\n    expect(result).toBeNull();\n  });\n\n  it('should have independent middleware per queue', async () => {\n    const log: string[] = [];\n\n    tq.use('q1', async (_task, next) => {\n      log.push('q1-middleware');\n      await next();\n    });\n\n    tq.use('q2', async (_task, next) => {\n      log.push('q2-middleware');\n      await next();\n    });\n\n    tq.add('task', { queue: 'q1' });\n    await tq.processNext('q1');\n\n    expect(log).toEqual(['q1-middleware']);\n  });\n});\n\ndescribe('Phase 12: Graceful Shutdown', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  it('should reject new tasks after shutdown', async () => {\n    await tq.shutdown();\n    expect(() => tq.add('task')).toThrow('shut down');\n  });\n\n  it('should complete immediately with no processing tasks', async () => {\n    tq.add('pending-task');\n    const result = await tq.shutdown();\n\n    expect(result.completed).toBe(0);\n    expect(result.forceCancelled).toBe(0);\n    expect(result.duration).toBeDefined();\n  });\n\n  it('should wait for processing tasks', async () => {\n    const task = tq.add('task');\n    tq.next();\n\n    // Complete in background\n    setTimeout(() => tq.complete(task.id), 50);\n\n    const result = await tq.shutdown({ timeout: 5000 });\n    expect(result.completed).toBe(1);\n    expect(result.forceCancelled).toBe(0);\n  });\n\n  it('should force-cancel on timeout', async () => {\n    tq.add('task');\n    tq.next(); // now processing\n\n    const result = await tq.shutdown({ timeout: 50 });\n    expect(result.forceCancelled).toBe(1);\n  });\n\n  it('should be idempotent', async () => {\n    const r1 = await tq.shutdown();\n    const r2 = await tq.shutdown();\n    expect(r1).toBe(r2);\n  });\n\n  it('should run shutdown callbacks', async () => {\n    let called = false;\n    tq.onShutdown(() => { called = true; });\n\n    await tq.shutdown();\n    expect(called).toBe(true);\n  });\n\n  it('should report shutdown duration', async () => {\n    const result = await tq.shutdown();\n    expect(typeof result.duration).toBe('number');\n    expect(result.duration).toBeGreaterThanOrEqual(0);\n  });\n});\n","structuredPatch":[],"originalFile":null}}
