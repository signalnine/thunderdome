aterThanOrEqual(0);\n    });\n  });\n\n  // ═══════════════════════════════════════════\n  // Cross-phase Integration Tests\n  // ═══════════════════════════════════════════\n  describe('Cross-phase Integration', () => {\n    it('priority + delay: non-delayed beats delayed even with lower priority', () => {\n      tq.addTask('delayed-high', { priority: 1, delay: 60000 });\n      tq.addTask('immediate-low', { priority: 10 });\n\n      const task = tq.getNextTask()!;\n      expect(task.payload).toBe('immediate-low');\n      expect(tq.getNextTask()).toBeNull(); // delayed not ready\n    });\n\n    it('dependencies + priority: unblocked high-priority goes first', () => {\n      const dep = tq.addTask('dep');\n      tq.addTask('blocked-high', { priority: 1, dependencies: [dep.id] });\n      tq.addTask('free-low', { priority: 10 });\n\n      // dep is pending, so both dep and free-low are available\n      // dep has priority 5, free-low has priority 10, so dep goes first\n      const first = tq.getNextTask()!;\n      expect(first.payload).toBe('dep');\n\n      // blocked-high still blocked, free-low available\n      const second = tq.getNextTask()!;\n      expect(second.payload).toBe('free-low');\n    });\n\n    it('concurrency + priority: respects both limits and ordering', () => {\n      tq.setConcurrency('default', 1);\n      tq.addTask('low', { priority: 10 });\n      tq.addTask('high', { priority: 1 });\n\n      const t = tq.getNextTask()!;\n      expect(t.payload).toBe('high');\n      expect(tq.getNextTask()).toBeNull(); // concurrency limit\n    });\n\n    it('retry + DLQ + replay: full lifecycle', () => {\n      const task = tq.addTask('fragile', { maxRetries: 2, backoffDelay: 0 });\n\n      // First attempt\n      let t = tq.getNextTask()!;\n      tq.failTask(t.id, 'err1');\n\n      // Second attempt\n      t = tq.getNextTask()!;\n      tq.failTask(t.id, 'err2');\n\n      // Now in DLQ\n      expect(tq.getDeadLetterTasks()).toHaveLength(1);\n\n      // Replay\n  