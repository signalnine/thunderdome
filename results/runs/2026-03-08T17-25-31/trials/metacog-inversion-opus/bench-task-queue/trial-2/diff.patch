;\n\n    it('should transition task to processing on retrieval', () => {\n      tq.addTask('work');\n      const task = tq.getNextTask();\n      expect(task?.status).toBe('processing');\n    });\n\n    it('should return null when no tasks available', () => {\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should count pending tasks', () => {\n      expect(tq.getPendingCount()).toBe(0);\n      tq.addTask('a');\n      tq.addTask('b');\n      expect(tq.getPendingCount()).toBe(2);\n\n      tq.getNextTask();\n      expect(tq.getPendingCount()).toBe(1);\n    });\n\n    it('should not return already-processing tasks', () => {\n      tq.addTask('a');\n      const first = tq.getNextTask();\n      expect(first?.payload).toBe('a');\n\n      const second = tq.getNextTask();\n      expect(second).toBeNull();\n    });\n  });\n\n  // ═══════════════════════════════════════════\n  // Phase 2: Named Queues\n  // ═══════════════════════════════════════════\n  describe('Phase 2: Named Queues', () => {\n    it('should add tasks to named queues', () => {\n      tq.addTask('email', { queue: 'email' });\n      tq.addTask('sms', { queue: 'sms' });\n\n      expect(tq.getPendingCount('email')).toBe(1);\n      expect(tq.getPendingCount('sms')).toBe(1);\n    });\n\n    it('should retrieve from specific queue', () => {\n      tq.addTask('email-task', { queue: 'email' });\n      tq.addTask('sms-task', { queue: 'sms' });\n\n      const task = tq.getNextTask('email');\n      expect(task?.payload).toBe('email-task');\n\n      expect(tq.getNextTask('email')).toBeNull();\n      expect(tq.getNextTask('sms')?.payload).toBe('sms-task');\n    });\n\n    it('should use default queue when no name given', () => {\n      tq.addTask('default-task');\n      const task = tq.getNextTask();\n      expect(task?.payload).toBe('default-task');\n      expect(task?.queue).toBe('default');\n    });\n\n    it('should list queue names', () => {\n      tq.addTask('a', { queue: 'q1' });\n      tq.addTask('b', { queue: 'q2' });\n      const queues = tq.getQueues();\n      expect(queues).toContain('q1');\n      expect(queues).toContain('q2');\n    });\n\n    it('should return null for non-existent queue', () => {\n      expect(tq.getNextTask('nonexistent')).toBeNull();\n    });\n\n    it('should be backward compatible (no queue name = default)', () => {\n      tq.addTask('test');\n      expect(tq.getPendingCount()).toBe(1);\n      expect(tq.getNextTask()?.payload).toBe('test');\n    });\n  });\n\n  // ═══════════════════════════════════════════\n  // Phase 3: Priority\n  // ═══════════════════════════════════════════\n  describe('Phase 3: Priority', () => {\n    it('should process higher priority tasks first', () => {\n      tq.addTask('low', { priority: 10 });\n      tq.addTask('high', { priority: 1 });\n      tq.addTask('mid', { priority: 5 });\n\n      expect(tq.getNextTask()?.payload).toBe('high');\n      expect(tq.getNextTask()?.payload).toBe('mid');\n      expect(tq.getNextTask()?.payload).toBe('low');\n    });\n\n    it('should use FIFO for same priority', () => {\n      tq.addTask('first', { priority: 5 });\n      tq.addTask('second', { priority: 5 });\n      tq.addTask('third', { priority: 5 });\n\n      expect(tq.getNextTask()?.payload).toBe('first');\n      expect(tq.getNextTask()?.payload).toBe('second');\n      expect(tq.getNextTask()?.payload).toBe('third');\n    });\n\n    it('should default to priority 5', () => {\n      const task = tq.addTask('test');\n      expect(task.priority).toBe(5);\n    });\n\n    it('should reject invalid priorities', () => {\n      expect(() => tq.addTask('x', { priority: 0 })).toThrow();\n      expect(() => tq.addTask('x', { priority: 11 })).toThrow();\n      expect(() => tq.addTask('x', { priority: 1.5 })).toThrow();\n    });\n\n    it('should expose priority on task object', () => {\n      const task = tq.addTask('test', { priority: 3 });\n      expect(task.priority).toBe(3);\n    });\n\n    it('should maintain per-queue priority ordering', () => {\n      tq.addTask('q1-low', { queue: 'q1', priority: 10 });\n      tq.addTask('q1-high', { queue: 'q1', priority: 1 });\n      tq.addTask('q2-low', { queue: 'q2', priority: 10 });\n      tq.addTask('q2-high', { queue: 'q2', priority: 1 });\n\n      expect(tq.getNextTask('q1')?.payload).toBe('q1-high');\n      expect(tq.getNextTask('q2')?.payload).toBe('q2-high');\n    });\n  });\n\n  // ═══════════════════════════════════════════\n  // Phase 4: Delayed Tasks\n  // ═══════════════════════════════════════════\n  describe('Phase 4: Delayed Tasks', () => {\n    it('should not return delayed tasks before their time', () => {\n      tq.addTask('delayed', { delay: 60000 });\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should return delayed tasks after their availability time', () => {\n      const pastTime = new Date(Date.now() - 1000);\n      tq.addTask('available', { availableAt: pastTime });\n      const task = tq.getNextTask();\n      expect(task?.payload).toBe('available');\n    });\n\n    it('should prefer non-delayed tasks over delayed ones', () => {\n      const pastTime = new Date(Date.now() - 1000);\n      tq.addTask('delayed-but-available', { availableAt: pastTime, priority: 1 });\n      tq.addTask('immediate', { priority: 1 });\n\n      // Both available, same priority, but immediate was added first\n      // Actually both are available, so sort by availableAt, then priority, then FIFO\n      // delayed-but-available has pastTime, immediate has ~now\n      // pastTime < now, so delayed-but-available should come first\n      const t1 = tq.getNextTask();\n      expect(t1?.payload).toBe('delayed-but-available');\n    });\n\n    it('should indicate availability time on task', () => {\n      const futureTime = new Date(Date.now() + 60000);\n      const task = tq.addTask('test', { availableAt: futureTime });\n      expect(task.availableAt.getTime()).toBe(futureTime.getTime());\n    });\n\n    it('should set delay correctly', () => {\n      const before = Date.now();\n      const task = tq.addTask('delayed', { delay: 5000 });\n      const after = Date.now();\n\n      expect(task.availableAt.getTime()).toBeGreaterThanOrEqual(before + 5000);\n      expect(task.availableAt.getTime()).toBeLessThanOrEqual(after + 5000);\n    });\n\n    it('should order available delayed tasks by availableAt, then priority, then FIFO', () => {\n      const earlier = new Date(Date.now() - 3000);\n      const later = new Date(Date.now() - 1000);\n\n      tq.addTask('later', { availableAt: later, priority: 1 });\n      tq.addTask('earlier', { availableAt: earlier, priority: 1 });\n\n      expect(tq.getNextTask()?.payload).toBe('earlier');\n      expect(tq.getNextTask()?.payload).toBe('later');\n    });\n\n    it('should work with named queues', () => {\n      tq.addTask('delayed', { queue: 'q1', delay: 60000 });\n      tq.addTask('immediate', { queue: 'q1' });\n\n      expect(tq.getNextTask('q1')?.payload).toBe('immediate');\n      expect(tq.getNextTask('q1')).toBeNull(); // delayed not ready\n    });\n  });\n\n  // ═══════════════════════════════════════════\n  // Phase 5: Retry with Backoff\n  // ═══════════════════════════════════════════\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should mark a task as completed', () => {\n      tq.addTask('work');\n      const task = tq.getNextTask()!;\n      tq.completeTask(task.id);\n      expect(tq.getTask(task.id)?.status).toBe('completed');\n    });\n\n    it('should mark a task as failed and requeue with backoff', () => {\n      tq.addTask('work', { backoffDelay: 100 });\n      const processing = tq.getNextTask()!;\n      expect(processing.attempt).toBe(1);\n\n      tq.failTask(processing.id, 'oops');\n      // Task should be pending again with delay\n      const t = tq.getTask(processing.id)!;\n      expect(t.status).toBe('pending');\n      expect(t.error).toBe('oops');\n      expect(t.availableAt.getTime()).toBeGreaterThan(Date.now());\n    });\n\n    it('should track attempt count', () => {\n      tq.addTask('work', { backoffDelay: 0, maxRetries: 5 });\n\n      // First attempt\n      let t = tq.getNextTask()!;\n      expect(t.attempt).toBe(1);\n      tq.failTask(t.id, 'fail');\n\n      // Second attempt (backoff delay 0, immediately available)\n      t = tq.getNextTask()!;\n      expect(t.attempt).toBe(2);\n    });\n\n    it('should apply exponential backoff', () => {\n      tq.addTask('work', { backoffDelay: 1000, maxRetries: 5 });\n\n      // First attempt: fail -> delay = 1000 * 2^0 = 1000ms\n      const t = tq.getNextTask()!;\n      tq.failTask(t.id, 'fail');\n      const firstRetryAvailable = tq.getTask(t.id)!.availableAt.getTime();\n      expect(firstRetryAvailable).toBeGreaterThanOrEqual(Date.now() + 900);\n    });\n\n    it('should keep original queue and priority on retry', () => {\n      tq.addTask('work', {\n        queue: 'myqueue',\n        priority: 2,\n        backoffDelay: 0,\n        maxRetries: 5,\n      });\n\n      const t = tq.getNextTask('myqueue')!;\n      tq.failTask(t.id, 'fail');\n\n      const retried = tq.getTask(t.id)!;\n      expect(retried.queue).toBe('myqueue');\n      expect(retried.priority).toBe(2);\n    });\n\n    it('should move to failed state when retries exhausted', () => {\n      tq.addTask('work', { backoffDelay: 0, maxRetries: 1 });\n\n      const t = tq.getNextTask()!;\n      tq.failTask(t.id, 'permanent failure');\n\n      const failed = tq.getTask(t.id)!;\n      expect(failed.status).toBe('failed');\n    });\n\n    it('should default to 3 max retries', () => {\n      const task = tq.addTask('work');\n      expect(task.maxRetries).toBe(3);\n    });\n\n    it('should throw when completing non-processing task', () => {\n      const task = tq.addTask('work');\n      expect(() => tq.completeTask(task.id)).toThrow();\n    });\n  });\n\n  // ═══════════════════════════════════════════\n  // Phase 6: Dead Letter Queue\n  // ═══════════════════════════════════════════\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move exhausted tasks to DLQ', () => {\n      const task = tq.addTask('work', { backoffDelay: 0, maxRetries: 1 });\n      const t = tq.getNextTask()!;\n      tq.failTask(t.id, 'fatal');\n\n      const dlq = tq.getDeadLetterTasks();\n      expect(dlq).toHaveLength(1);\n      expect(dlq[0].id).toBe(task.id);\n    });\n\n    it('should retain error info in DLQ', () => {\n      const task = tq.addTask('work', { backoffDelay: 0, maxRetries: 1 });\n      const t = tq.getNextTask()!;\n      tq.failTask(t.id, 'bad error');\n\n      const dlq = tq.getDeadLetterTasks();\n      expect(dlq[0].error).toBe('bad error');\n      expect(dlq[0].failCount).toBe(1);\n    });\n\n    it('should replay a dead-lettered task', () => {\n      const task = tq.addTask('work', { backoffDelay: 0, maxRetries: 1 });\n      const t = tq.getNextTask()!;\n      tq.failTask(t.id, 'fail');\n\n      const replayed = tq.replayDeadLetterTask(task.id);\n      expect(replayed.status).toBe('pending');\n      expect(replayed.attempt).toBe(0);\n\n      // Should be retrievable again\n      const next = tq.getNextTask()!;\n      expect(next.id).toBe(task.id);\n    });\n\n    it('should clear DLQ for a queue', () => {\n      const task = tq.addTask('work', { backoffDelay: 0, maxRetries: 1 });\n      const t = tq.getNextTask()!;\n      tq.failTask(t.id, 'fail');\n\n      tq.clearDeadLetterQueue();\n      expect(tq.getDeadLetterTasks()).toHaveLength(0);\n    });\n\n    it('should maintain per-queue DLQs', () => {\n      const t1 = tq.addTask('work1', { queue: 'q1', backoffDelay: 0, maxRetries: 1 });\n      const t2 = tq.addTask('work2', { queue: 'q2', backoffDelay: 0, maxRetries: 1 });\n\n      const p1 = tq.getNextTask('q1')!;\n      tq.failTask(p1.id, 'fail');\n      const p2 = tq.getNextTask('q2')!;\n      tq.failTask(p2.id, 'fail');\n\n      expect(tq.getDeadLetterTasks('q1')).toHaveLength(1);\n      expect(tq.getDeadLetterTasks('q2')).toHaveLength(1);\n\n      tq.clearDeadLetterQueue('q1');\n      expect(tq.getDeadLetterTasks('q1')).toHaveLength(0);\n      expect(tq.getDeadLetterTasks('q2')).toHaveLength(1);\n    });\n\n    it('should throw when replaying non-existent DLQ task', () => {\n      expect(() => tq.replayDeadLetterTask('nonexistent')).toThrow();\n    });\n  });\n\n  // ═══════════════════════════════════════════\n  // Phase 7: Task Dependencies\n  // ═══════════════════════════════════════════\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block tasks with unresolved dependencies', () => {\n      const dep = tq.addTask('dependency');\n      const dependent = tq.addTask('dependent', { dependencies: [dep.id] });\n\n      // Should get the dependency first (it has no blockers)\n      const first = tq.getNextTask()!;\n      expect(first.id).toBe(dep.id);\n\n      // Dependent should not be available yet\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should unblock tasks when dependencies complete', () => {\n      const dep = tq.addTask('dependency');\n      const dependent = tq.addTask('dependent', { dependencies: [dep.id] });\n\n      const first = tq.getNextTask()!;\n      tq.completeTask(first.id);\n\n      // Now the dependent should be available\n      const second = tq.getNextTask()!;\n      expect(second.id).toBe(dependent.id);\n    });\n\n    it('should error on non-existent dependency', () => {\n      expect(() => tq.addTask('x', { dependencies: ['nonexistent'] })).toThrow();\n    });\n\n    it('should keep dependents blocked when dependency fails', () => {\n      const dep = tq.addTask('dependency', { maxRetries: 1, backoffDelay: 0 });\n      const dependent = tq.addTask('dependent', { dependencies: [dep.id] });\n\n      const first = tq.getNextTask()!;\n      tq.failTask(first.id, 'fail');\n\n      // Dependent stays blocked since dependency is failed, not completed\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should provide dependency status', () => {\n      const dep1 = tq.addTask('dep1');\n      const dep2 = tq.addTask('dep2');\n      const dependent = tq.addTask('dependent', { dependencies: [dep1.id, dep2.id] });\n\n      const statuses = tq.getDependencyStatus(dependent.id);\n      expect(statuses).toHaveLength(2);\n      expect(statuses[0].status).toBe('pending');\n      expect(statuses[0].completed).toBe(false);\n    });\n\n    it('should handle multi-level dependencies', () => {\n      const a = tq.addTask('a');\n      const b = tq.addTask('b', { dependencies: [a.id] });\n      const c = tq.addTask('c', { dependencies: [b.id] });\n\n      // Only a is available\n      const first = tq.getNextTask()!;\n      expect(first.id).toBe(a.id);\n      expect(tq.getNextTask()).toBeNull();\n\n      tq.completeTask(a.id);\n\n      // Now b is available\n      const second = tq.getNextTask()!;\n      expect(second.id).toBe(b.id);\n      expect(tq.getNextTask()).toBeNull();\n\n      tq.completeTask(b.id);\n\n      // Now c is available\n      const third = tq.getNextTask()!;\n      expect(third.id).toBe(c.id);\n    });\n  });\n\n  // ═══════════════════════════════════════════\n  // Phase 8: Concurrency Control\n  // ═══════════════════════════════════════════\n  describe('Phase 8: Concurrency Control', () => {\n    it('should limit concurrent processing', () => {\n      tq.setConcurrency('default', 2);\n      tq.addTask('a');\n      tq.addTask('b');\n      tq.addTask('c');\n\n      const t1 = tq.getNextTask()!;\n      const t2 = tq.getNextTask()!;\n      expect(t1).not.toBeNull();\n      expect(t2).not.toBeNull();\n\n      // Third should be null due to concurrency limit\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should free slot on completion', () => {\n      tq.setConcurrency('default', 1);\n      tq.addTask('a');\n      tq.addTask('b');\n\n      const t1 = tq.getNextTask()!;\n      expect(tq.getNextTask()).toBeNull();\n\n      tq.completeTask(t1.id);\n      const t2 = tq.getNextTask()!;\n      expect(t2?.payload).toBe('b');\n    });\n\n    it('should free slot on failure', () => {\n      tq.setConcurrency('default', 1);\n      tq.addTask('a', { maxRetries: 1, backoffDelay: 0 });\n      tq.addTask('b');\n\n      const t1 = tq.getNextTask()!;\n      expect(tq.getNextTask()).toBeNull();\n\n      tq.failTask(t1.id, 'fail');\n      // Now slot is free, b should be available (a went to DLQ)\n      const t2 = tq.getNextTask()!;\n      expect(t2).not.toBeNull();\n    });\n\n    it('should default to unlimited concurrency', () => {\n      const info = tq.getConcurrency('default');\n      expect(info.limit).toBe(0);\n    });\n\n    it('should report concurrency state', () => {\n      tq.setConcurrency('default', 5);\n      tq.addTask('a');\n      tq.addTask('b');\n      tq.getNextTask();\n\n      const info = tq.getConcurrency();\n      expect(info.limit).toBe(5);\n      expect(info.active).toBe(1);\n    });\n\n    it('should respect priority within concurrency limits', () => {\n      tq.setConcurrency('default', 1);\n      tq.addTask('low', { priority: 10 });\n      tq.addTask('high', { priority: 1 });\n\n      const t = tq.getNextTask()!;\n      expect(t.payload).toBe('high');\n    });\n  });\n\n  // ═══════════════════════════════════════════\n  // Phase 9: Progress Tracking and Cancellation\n  // ═══════════════════════════════════════════\n  describe('Phase 9: Progress and Cancellation', () => {\n    it('should report and query progress', () => {\n      tq.addTask('work');\n      const task = tq.getNextTask()!;\n\n      tq.reportProgress(task.id, 50, 'halfway');\n\n      const progress = tq.getProgress(task.id);\n      expect(progress.progress).toBe(50);\n      expect(progress.message).toBe('halfway');\n    });\n\n    it('should notify progress listeners', () => {\n      tq.addTask('work');\n      const task = tq.getNextTask()!;\n\n      const updates: number[] = [];\n      tq.onProgress(task.id, (p) => updates.push(p));\n\n      tq.reportProgress(task.id, 25);\n      tq.reportProgress(task.id, 50);\n      tq.reportProgress(task.id, 75);\n\n      expect(updates).toEqual([25, 50, 75]);\n    });\n\n    it('should allow unsubscribing from progress', () => {\n      tq.addTask('work');\n      const task = tq.getNextTask()!;\n\n      const updates: number[] = [];\n      const unsub = tq.onProgress(task.id, (p) => updates.push(p));\n\n      tq.reportProgress(task.id, 25);\n      unsub();\n      tq.reportProgress(task.id, 50);\n\n      expect(updates).toEqual([25]);\n    });\n\n    it('should cancel a pending task', () => {\n      const task = tq.addTask('work');\n      tq.cancelTask(task.id);\n\n      expect(tq.getTask(task.id)?.status).toBe('cancelled');\n      expect(tq.getNextTask()).toBeNull();\n      expect(tq.getPendingCount()).toBe(0);\n    });\n\n    it('should cancel a processing task', () => {\n      tq.addTask('work');\n      const task = tq.getNextTask()!;\n\n      tq.cancelTask(task.id);\n      expect(tq.getTask(task.id)?.status).toBe('cancelled');\n    });\n\n    it('should not retry cancelled tasks', () => {\n      const task = tq.addTask('work', { maxRetries: 5 });\n      tq.getNextTask();\n      tq.cancelTask(task.id);\n\n      // Should not be requeued\n      expect(tq.getNextTask()).toBeNull();\n      expect(tq.getTask(task.id)?.status).toBe('cancelled');\n    });\n\n    it('should clamp progress to 0-100', () => {\n      tq.addTask('work');\n      const task = tq.getNextTask()!;\n\n      tq.reportProgress(task.id, 150);\n      expect(tq.getProgress(task.id).progress).toBe(100);\n\n      tq.reportProgress(task.id, -10);\n      expect(tq.getProgress(task.id).progress).toBe(0);\n    });\n\n    it('should throw when cancelling completed task', () => {\n      tq.addTask('work');\n      const task = tq.getNextTask()!;\n      tq.completeTask(task.id);\n\n      expect(() => tq.cancelTask(task.id)).toThrow();\n    });\n  });\n\n  // ═══════════════════════════════════════════\n  // Phase 10: Recurring Tasks\n  // ═══════════════════════════════════════════\n  describe('Phase 10: Recurring Tasks', () => {\n    it('should create a schedule', () => {\n      const entry = tq.addSchedule('every5min', '*/5 * * * *', 'default', { type: 'cleanup' });\n      expect(entry.id).toBe('every5min');\n      expect(entry.cron).toBe('*/5 * * * *');\n    });\n\n    it('should list schedules', () => {\n      tq.addSchedule('s1', '*/5 * * * *', 'default', {});\n      tq.addSchedule('s2', '0 * * * *', 'default', {});\n\n      const schedules = tq.getSchedules();\n      expect(schedules).toHaveLength(2);\n    });\n\n    it('should remove a schedule', () => {\n      tq.addSchedule('s1', '*/5 * * * *', 'default', {});\n      tq.removeSchedule('s1');\n\n      expect(tq.getSchedules()).toHaveLength(0);\n    });\n\n    it('should enqueue tasks on tick for matching schedules', () => {\n      tq.addSchedule('every5min', '*/5 * * * *', 'default', { type: 'recurring' });\n\n      // Tick at a time divisible by 5 minutes\n      const time = new Date(2024, 0, 1, 12, 0, 0);\n      const created = tq.tick(time);\n\n      expect(created).toHaveLength(1);\n      expect(created[0].payload).toEqual({ type: 'recurring' });\n      expect(created[0].status).toBe('pending');\n    });\n\n    it('should not re-enqueue for same minute', () => {\n      tq.addSchedule('every5min', '*/5 * * * *', 'default', { type: 'recurring' });\n\n      const time = new Date(2024, 0, 1, 12, 0, 0);\n      tq.tick(time);\n      const second = tq.tick(time);\n\n      expect(second).toHaveLength(0);\n    });\n\n    it('should support hourly schedules', () => {\n      tq.addSchedule('hourly', '0 * * * *', 'default', { type: 'hourly' });\n\n      const onTheHour = new Date(2024, 0, 1, 14, 0, 0);\n      const notOnTheHour = new Date(2024, 0, 1, 14, 30, 0);\n\n      expect(tq.tick(onTheHour)).toHaveLength(1);\n      expect(tq.tick(notOnTheHour)).toHaveLength(0);\n    });\n\n    it('should support daily schedules', () => {\n      tq.addSchedule('daily', '0 0 * * *', 'default', { type: 'daily' });\n\n      const midnight = new Date(2024, 0, 1, 0, 0, 0);\n      const noon = new Date(2024, 0, 1, 12, 0, 0);\n\n      expect(tq.tick(midnight)).toHaveLength(1);\n      expect(tq.tick(noon)).toHaveLength(0);\n    });\n\n    it('should stop creating tasks after schedule removal', () => {\n      tq.addSchedule('s1', '*/5 * * * *', 'default', {});\n\n      const time1 = new Date(2024, 0, 1, 12, 0, 0);\n      expect(tq.tick(time1)).toHaveLength(1);\n\n      tq.removeSchedule('s1');\n\n      const time2 = new Date(2024, 0, 1, 12, 5, 0);\n      expect(tq.tick(time2)).toHaveLength(0);\n    });\n  });\n\n  // ═══════════════════════════════════════════\n  // Phase 11: Middleware Pipeline\n  // ═══════════════════════════════════════════\n  describe('Phase 11: Middleware Pipeline', () => {\n    it('should execute middleware in order', async () => {\n      const order: string[] = [];\n\n      tq.use('default', async (_task, next) => {\n        order.push('mw1-before');\n        await next();\n        order.push('mw1-after');\n      });\n\n      tq.use('default', async (_task, next) => {\n        order.push('mw2-before');\n        await next();\n        order.push('mw2-after');\n      });\n\n      tq.setHandler('default', async () => {\n        order.push('handler');\n      });\n\n      tq.addTask('work');\n      await tq.processTask();\n\n      expect(order).toEqual(['mw1-before', 'mw2-before', 'handler', 'mw2-after', 'mw1-after']);\n    });\n\n    it('should allow middleware to skip processing', async () => {\n      let handlerCalled = false;\n\n      tq.use('default', async (_task, _next) => {\n        // Don't call next - skip processing\n      });\n\n      tq.setHandler('default', async () => {\n        handlerCalled = true;\n      });\n\n      tq.addTask('work');\n      await tq.processTask();\n\n      expect(handlerCalled).toBe(false);\n    });\n\n    it('should allow middleware to modify task', async () => {\n      tq.use('default', async (task, next) => {\n        (task.payload as Record<string, unknown>).modified = true;\n        await next();\n      });\n\n      let receivedPayload: unknown;\n      tq.setHandler('default', async (task) => {\n        receivedPayload = task.payload;\n      });\n\n      tq.addTask({ original: true });\n      await tq.processTask();\n\n      expect(receivedPayload).toEqual({ original: true, modified: true });\n    });\n\n    it('should mark task as failed on middleware error', async () => {\n      tq.use('default', async (_task, _next) => {\n        throw new Error('middleware error');\n      });\n\n      const task = tq.addTask('work', { maxRetries: 1, backoffDelay: 0 });\n      await tq.processTask();\n\n      const t = tq.getTask(task.id)!;\n      expect(t.status).toBe('failed');\n    });\n\n    it('should maintain per-queue middleware stacks', async () => {\n      const q1Order: string[] = [];\n      const q2Order: string[] = [];\n\n      tq.use('q1', async (_task, next) => {\n        q1Order.push('q1-mw');\n        await next();\n      });\n\n      tq.use('q2', async (_task, next) => {\n        q2Order.push('q2-mw');\n        await next();\n      });\n\n      tq.setHandler('q1', async () => { q1Order.push('q1-handler'); });\n      tq.setHandler('q2', async () => { q2Order.push('q2-handler'); });\n\n      tq.addTask('work', { queue: 'q1' });\n      tq.addTask('work', { queue: 'q2' });\n\n      await tq.processTask('q1');\n      await tq.processTask('q2');\n\n      expect(q1Order).toEqual(['q1-mw', 'q1-handler']);\n      expect(q2Order).toEqual(['q2-mw', 'q2-handler']);\n    });\n\n    it('should return null from processTask when no tasks', async () => {\n      const result = await tq.processTask();\n      expect(result).toBeNull();\n    });\n  });\n\n  // ═══════════════════════════════════════════\n  // Phase 12: Graceful Shutdown\n  // ═══════════════════════════════════════════\n  describe('Phase 12: Graceful Shutdown', () => {\n    it('should prevent adding tasks after shutdown', async () => {\n      await tq.shutdown();\n      expect(() => tq.addTask('new')).toThrow(/shutting down/);\n    });\n\n    it('should complete immediately if no processing tasks', async () => {\n      const summary = await tq.shutdown();\n      expect(summary.completed).toBe(0);\n      expect(summary.forceCancelled).toBe(0);\n      expect(summary.duration).toBeGreaterThanOrEqual(0);\n    });\n\n    it('should wait for processing tasks', async () => {\n      tq.addTask('work');\n      const task = tq.getNextTask()!;\n\n      // Complete the task asynchronously\n      setTimeout(() => {\n        tq.completeTask(task.id);\n      }, 50);\n\n      const summary = await tq.shutdown({ timeout: 2000 });\n      expect(summary.completed).toBe(1);\n      expect(summary.forceCancelled).toBe(0);\n    });\n\n    it('should force-cancel on timeout', async () => {\n      tq.addTask('long-running');\n      tq.getNextTask();\n\n      const summary = await tq.shutdown({ timeout: 50 });\n      expect(summary.forceCancelled).toBe(1);\n    });\n\n    it('should run shutdown callbacks', async () => {\n      let callbackRan = false;\n      tq.onShutdown(() => {\n        callbackRan = true;\n      });\n\n      await tq.shutdown();\n      expect(callbackRan).toBe(true);\n    });\n\n    it('should be safe to call shutdown multiple times', async () => {\n      const s1 = tq.shutdown();\n      const s2 = tq.shutdown();\n\n      const [r1, r2] = await Promise.all([s1, s2]);\n      expect(r1).toBe(r2);\n    });\n\n    it('should include duration in summary', async () => {\n      const summary = await tq.shutdown();\n      expect(typeof summary.duration).toBe('number');\n      expect(summary.duration).toBeGreaterThanOrEqual(0);\n    });\n  });\n\n  // ═══════════════════════════════════════════\n  // Cross-phase Integration Tests\n  // ═══════════════════════════════════════════\n  describe('Cross-phase Integration', () => {\n    it('priority 