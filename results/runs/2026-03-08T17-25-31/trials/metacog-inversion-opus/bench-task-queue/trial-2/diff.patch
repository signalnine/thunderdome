+      throw new Error('Queue is shutting down; cannot add new tasks');
+    }
+
+    const queue = options.queue ?? DEFAULT_QUEUE;
+    const priority = options.priority ?? DEFAULT_PRIORITY;
+
+    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {
+      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);
+    }
+
+    // Validate dependencies (Phase 7)
+    const dependencies = options.dependencies ?? [];
+    for (const depId of dependencies) {
+      const depTask = this.tasks.get(depId);
+      if (!depTask) {
+        throw new Error(`Dependency task not found: ${depId}`);
+      }
+    }
+
+    // Circular dependency detection
+    if (dependencies.length > 0) {
+      // We need to check that adding this task won't create a cycle.
+      // Since this task doesn't exist yet, we check if any dependency
+      // transitively depends on... well, this task doesn't exist yet,
+      // so direct cycles are impossible at creation time.
+      // But we need to detect if any dep chain leads back here.
+      // Since the task ID is new, the only cycle possible is if
+      // dependencies themselves form a cycle, but that's already prevented.
+      // Actually, we need to detect: if dep A depends on dep B which depends on something
+      // that hasn't completed. The real cycle check is: would this new task
+      // create a cycle if some existing task depended on it?
+      // Since this task is NEW, nothing depends on it yet, so no cycle is possible
+      // at creation. However, we should still validate the dependency graph:
+      // check that no dependency is waiting on another dependency in the same list
+      // in a way that creates a deadlock.
+      // Actually the real check: can any of the dependencies transitively depend on each other
+      // in a way that creates a cycle? No - dependencies are on existing completed/processing/pending tasks.
+      // The cycle scenario is: Task A depends on Task B, Task B depends on Task A.
+      // If Task A already exists and depends on us (we don't exist yet, impossible).
+      // If we depend on Task B and Task B depends on Task C which depends on... eventually us?
+      // We don't exist yet, so nothing can depend on us. No cycle possible at creation.
+      // BUT: the requirement says circular dependencies must be detected at creation time.
+      // This means: if Task A exists with dependency on Task B, and we're adding Task B
+      // with dependency on Task A - well Task B doesn't exist yet, so Task A can't depend on Task B.
+      // Wait - the ID is generated here, so nothing can depend on this task before it exists.
+      // The real case is: Task A depends on [Task B], Task B depends on [Task A].
+      // When adding Task B with dep on Task A: Task A already has dep on Task B. But Task B
+      // doesn't exist yet (we're creating it now). So Task A's dep list would contain the
+      // about-to-be-created ID? No, because we generate the ID here.
+      // I think the real scenario is: two tasks added sequentially where the second depends
+      // on the first, and then we try to add a dependency from the first to the second.
+      // Since we can't modify dependencies after creation, the only way to get a cycle
+      // is if we specify dependencies that form a cycle among themselves plus existing tasks.
+      // Let me think again: A exists (depends on nothing). B is added with dep on A. Fine.
+      // C is added with dep on B. Fine. Now D is added with deps on [C], but also A depends on D?
+      // No, A was already created without deps. So true cycles through "depends on this new task"
+      // are impossible since the task doesn't exist yet.
+      // HOWEVER: what if we have: A (pending, deps=[B_id]), and B doesn't exist yet,
+      // but we pre-allocated the ID? No, we validate deps exist at creation.
+      // So the only cycle case: already-created tasks that depend on each other through a chain
+      // that includes the new task's dependencies. But since the new task doesn't exist yet,
+      // no existing task can list it as a dependency.
+      // Conclusion: cycles are actually impossible with this design (deps must exist at creation,
+      // new tasks have new IDs). But the requirement asks for it, so I'll implement detection anyway.
+      this.detectCycle(dependencies);
