+      task.error = error;
+    } else {
+      // No retries left
+      task.status = 'failed';
+      task.error = error;
+
+      // Phase 6: Move to DLQ
+      this.moveToDeadLetterQueue(task);
+    }
+  }
+
+  // ──────────────────────────────────────────────
+  // Phase 6: Dead Letter Queue
+  // ──────────────────────────────────────────────
+
+  private moveToDeadLetterQueue(task: Task): void {
+    const dlqKey = task.queue;
+    if (!this.deadLetterQueues.has(dlqKey)) {
+      this.deadLetterQueues.set(dlqKey, []);
+    }
+    this.deadLetterQueues.get(dlqKey)!.push(task);
+  }
+
+  getDeadLetterTasks(queueName?: string): Task[] {
+    const queue = queueName ?? DEFAULT_QUEUE;
+    return this.deadLetterQueues.get(queue) ?? [];
+  }
+
+  replayDeadLetterTask(taskId: string): Task {
+    // Find and remove from DLQ
+    for (const [queueName, dlq] of this.deadLetterQueues) {
+      const idx = dlq.findIndex(t => t.id === taskId);
+      if (idx !== -1) {
+        const task = dlq[idx];
+        dlq.splice(idx, 1);
+
+        // Reset for fresh retry round
+        task.status = 'pending';
+        task.attempt = 0;
+        task.progress = 0;
+        task.error = undefined;
+        task.availableAt = new Date();
+        task._seq = this.seqCounter++;
+
+        // Task is still in this.tasks, just reset its state
+        // Make sure it's in the tasks map
+        this.tasks.set(task.id, task);
+        this.ensureQueueState(queueName);
+
+        return task;
+      }
+    }
+    throw new Error(`Task not found in dead letter queue: ${taskId}`);
+  }
+
+  clearDeadLetterQueue(queueName?: string): void {
+    const queue = queueName ?? DEFAULT_QUEUE;
+    this.deadLetterQueues.set(queue, []);
+  }
+
+  // ──────────────────────────────────────────────
+  // Phase 7: Task Dependencies
+  // ──────────────────────────────────────────────
+
+  private detectCycle(dependencies: string[]): void {
+    // Check if the dependency set itself contains cycles through existing tasks
+    // Build a sub-graph of tasks reachable from the dependencies and check for cycles
+    const visited = new Set<string>();
+    const stack = new Set<string>();
+
+    const hasCycle = (taskId: string): boolean => {
+      if (stack.has(taskId)) return true;
+      if (visited.has(taskId)) return false;
+
+      visited.add(taskId);
+      stack.add(taskId);
+
+      const task = this.tasks.get(taskId);
+      if (task) {
+        for (const depId of task.dependencies) {
+          if (hasCycle(depId)) return true;
+        }
+      }
+
+      stack.delete(taskId);
+      return false;
+    };
+
+    // Check each dependency
+    for (const depId of dependencies) {
+      visited.clear();
+      stack.clear();
+      if (hasCycle(depId)) {
+        throw new Error('Circular dependency detected');
+      }
+    }
+
+    // Also check that dependencies don't refer to each other in a cycle
+    // This checks if any dep transitively depends on another dep in our list
+    // Actually, the above DFS already handles this.
+  }
+
+  getDependencyStatus(taskId: string): { taskId: string; status: TaskStatus; completed: boolean }[] {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+
+    return task.dependencies.map(depId => {
+      const dep = this.tasks.get(depId);
+      if (!dep) return { taskId: depId, status: 'failed' as TaskStatus, completed: false };
+      return {
+        taskId: depId,
+        status: dep.status,
+        completed: dep.status === 'completed',
+      };
+    });
+  }
+
+  // ──────────────────────────────────────────────
+  // Phase 8: Concurrency Control
+  // ──────────────────────────────────────────────
+
+  setConcurrency(queueName: string, limit: number): void {
+    const state = this.ensureQueueState(queueName);
+    state.concurrencyLimit = limit;
+  }
+
+  getConcurrency(queueName?: string): { limit: number; active: number } {
+    const queue = queueName ?? DEFAULT_QUEUE;
+    const state = this.queueStates.get(queue);
+    return {
+      limit: state?.concurrencyLimit ?? 0,
+      active: state?.activeCount ?? 0,
+    };
+  }
+
+  private decrementActive(queueName: string): void {
+    const state = this.queueStates.get(queueName);
+    if (state && state.activeCount > 0) {
+      state.activeCount--;
+    }
+  }
+
+  // ──────────────────────────────────────────────
+  // Phase 9: Progress Tracking and Cancellation
+  // ──────────────────────────────────────────────
+
+  reportProgress(taskId: string, progress: number, message?: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot report progress for task in status: ${task.status}`);
+    }
+
+    task.progress = Math.max(0, Math.min(100, progress));
+    task.progressMessage = message;
+
+    // Notify listeners
+    const listeners = this.progressListeners.get(taskId);
+    if (listeners) {
+      for (const listener of listeners) {
+        listener(task.progress, message);
+      }
+    }
+  }
+
+  getProgress(taskId: string): { progress: number; message?: string } {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    return { progress: task.progress, message: task.progressMessage };
+  }
+
+  onProgress(taskId: string, listener: ProgressListener): () => void {
+    if (!this.progressListeners.has(taskId)) {
+      this.progressListeners.set(taskId, new Set());
+    }
+    this.progressListeners.get(taskId)!.add(listener);
+
+    // Return unsubscribe function
+    return () => {
+      const listeners = this.progressListeners.get(taskId);
+      if (listeners) {
+        listeners.delete(listener);
+      }
+    };
+  }
+
+  cancelTask(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+
+    if (task.status !== 'pending' && task.status !== 'processing') {
+      throw new Error(`Cannot cancel task in status: ${task.status}`);
+    }
+
+    const wasProcessing = task.status === 'processing';
+    task.status = 'cancelled';
+
+    if (wasProcessing) {
+      this.decrementActive(task.queue);
+    }
+  }
+
+  // ──────────────────────────────────────────────
+  // Phase 10: Recurring Tasks (Cron)
+  // ──────────────────────────────────────────────
+
+  addSchedule(
+    id: string,
+    cron: string,
+    queue: string,
+    payload: unknown,
+    taskOptions?: Omit<TaskOptions, 'queue' | 'delay' | 'availableAt' | 'dependencies'>
+  ): ScheduleEntry {
+    // Validate cron expression
+    this.parseCron(cron);
+
+    const entry: ScheduleEntry = {
+      id,
+      cron,
+      queue,
+      payload,
+      taskOptions,
+    };
+    this.schedules.set(id, entry);
+    return entry;
+  }
+
+  removeSchedule(id: string): void {
+    this.schedules.delete(id);
+  }
+
+  getSchedules(): ScheduleEntry[] {
+    return Array.from(this.schedules.values());
+  }
+
+  tick(now?: Date): Task[] {
+    const currentTime = now ?? new Date();
+    const created: Task[] = [];
+
+    for (const schedule of this.schedules.values()) {
+      if (this.shouldRun(schedule, currentTime)) {
+        const task = this.addTask(schedule.payload, {
+          queue: schedule.queue,
+          ...schedule.taskOptions,
+        });
+        created.push(task);
+        schedule.lastRun = currentTime;
+      }
+    }
+
+    return created;
+  }
+
+  private parseCron(expr: string): { minute: string; hour: string } {
+    const parts = expr.split(/\s+/);
+    if (parts.length !== 5) {
+      throw new Error(`Invalid cron expression: ${expr}`);
+    }
+    return { minute: parts[0], hour: parts[1] };
+  }
+
+  private shouldRun(schedule: ScheduleEntry, now: Date): boolean {
+    const { minute: minuteExpr, hour: hourExpr } = this.parseCron(schedule.cron);
+    const currentMinute = now.getMinutes();
+    const currentHour = now.getHours();
+
+    // Check minute expression
+    if (!this.matchesCronField(minuteExpr, currentMinute)) return false;
+
+    // Check hour expression
+    if (!this.matchesCronField(hourExpr, currentHour)) return false;
+
+    // Avoid running more than once for the same minute
+    if (schedule.lastRun) {
+      const lastMinute = schedule.lastRun.getMinutes();
+      const lastHour = schedule.lastRun.getHours();
+      const lastDate = schedule.lastRun.toDateString();
+      const nowDate = now.toDateString();
+
+      if (lastDate === nowDate && lastHour === currentHour && lastMinute === currentMinute) {
+        return false;
+      }
+    }
+
+    return true;
+  }
+
+  private matchesCronField(expr: string, value: number): boolean {
+    if (expr === '*') return true;
+
+    // */N pattern
+    const stepMatch = expr.match(/^\*\/(\d+)$/);
+    if (stepMatch) {
+      const step = parseInt(stepMatch[1], 10);
+      return value % step === 0;
+    }
+
+    // Exact number
+    const num = parseInt(expr, 10);
+    if (!isNaN(num)) {
+      return value === num;
+    }
+
+    return false;
+  }
+
+  // ──────────────────────────────────────────────
+  // Phase 11: Middleware Pipeline
+  // ──────────────────────────────────────────────
+
+  use(queueName: string, middleware: Middleware): void {
+    const state = this.ensureQueueState(queueName);
+    state.middlewares.push(middleware);
+  }
+
+  setHandler(queueName: string, handler: TaskHandler): void {
+    const state = this.ensureQueueState(queueName);
+    state.handler = handler;
+  }
+
+  async processTask(queueName?: string): Promise<Task | null> {
+    const queue = queueName ?? DEFAULT_QUEUE;
+    const task = this.getNextTask(queue);
+    if (!task) return null;
+
+    const state = this.queueStates.get(queue);
+    if (!state) return task;
+
+    const middlewares = state.middlewares;
+    const handler = state.handler;
+
+    try {
+      await this.runMiddlewarePipeline(task, middlewares, handler);
+    } catch (err) {
+      const errorMessage = err instanceof Error ? err.message : String(err);
+      // If the task is still processing (not already completed/failed), mark as failed
+      if (task.status === 'processing') {
+        this.failTask(task.id, errorMessage);
+      }
+    }
+
+    return task;
+  }
+
+  private async runMiddlewarePipeline(
+    task: Task,
+    middlewares: Middleware[],
+    handler?: TaskHandler
+  ): Promise<void> {
+    let index = 0;
+
+    const next = async (): Promise<void> => {
+      if (index < middlewares.length) {
+        const mw = middlewares[index++];
+        await mw(task, next);
+      } else if (handler) {
+        await handler(task);
+      }
+    };
+
+    await next();
+  }
+
+  // ──────────────────────────────────────────────
+  // Phase 12: Graceful Shutdown
+  // ──────────────────────────────────────────────
+
+  onShutdown(callback: () => void | Promise<void>): void {
+    this.shutdownCallbacks.push(callback);
+  }
+
+  async shutdown(options: ShutdownOptions = {}): Promise<ShutdownSummary> {
+    if (this.shutdownPromise) {
+      return this.shutdownPromise;
+    }
+
+    this.isShuttingDown = true;
+    this.shutdownPromise = this.performShutdown(options);
+    return this.shutdownPromise;
+  }
+
+  private async performShutdown(options: ShutdownOptions): Promise<ShutdownSummary> {
+    const startTime = Date.now();
+    const timeout = options.timeout ?? 5000;
+
+    // Run shutdown callbacks
+    for (const cb of this.shutdownCallbacks) {
+      await cb();
+    }
+
+    // Find all processing tasks
+    const processingTasks: Task[] = [];
+    for (const task of this.tasks.values()) {
+      if (task.status === 'processing') {
+        processingTasks.push(task);
+      }
+    }
+
+    let completed = 0;
+    let forceCancelled = 0;
+
+    if (processingTasks.length === 0) {
+      return {
+        completed: 0,
+        forceCancelled: 0,
+        duration: Date.now() - startTime,
+      };
+    }
+
+    // Wait for processing tasks to complete with timeout
+    const waitStart = Date.now();
+    await new Promise<void>(resolve => {
+      const checkInterval = setInterval(() => {
+        const stillProcessing = processingTasks.filter(t => t.status === 'processing');
+        const elapsed = Date.now() - waitStart;
+
+        if (stillProcessing.length === 0 || elapsed >= timeout) {
+          clearInterval(checkInterval);
+
+          // Count completed
+          for (const task of processingTasks) {
+            if (task.status === 'completed' || task.status === 'failed') {
+              completed++;
+            } else if (task.status === 'processing') {
+              // Force cancel
+              task.status = 'cancelled';
+              this.decrementActive(task.queue);
+              forceCancelled++;
+            }
+          }
+
+          resolve();
+        }
+      }, 10);
+    });
+
+    return {
+      completed,
+      forceCancelled,
+      duration: Date.now() - startTime,
+    };
+  }
+
+  // ──────────────────────────────────────────────
+  // Helpers
+  // ──────────────────────────────────────────────
+
+  private ensureQueueState(queueName: string): QueueState {
+    if (!this.queueStates.has(queueName)) {
+      this.queueStates.set(queueName, {
+        concurrencyLimit: 0, // 0 means unlimited
+        activeCount: 0,
+        middlewares: [],
+      });
+    }
+    return this.queueStates.get(queueName)!;
+  }
+}
