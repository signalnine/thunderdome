tring, StockRecord> = new Map();\n\n  setStock(productId: string, available: number): void {\n    const existing = this.store.get(productId);\n    this.store.set(productId, {\n      productId,\n      available,\n      reserved: existing?.reserved ?? 0,\n    });\n  }\n\n  getStock(productId: string): StockRecord | undefined {\n    const record = this.store.get(productId);\n    return record ? { ...record } : undefined;\n  }\n\n  reserve(productId: string, quantity: number): boolean {\n    const record = this.store.get(productId);\n    if (!record || record.available < quantity) return false;\n    record.available -= quantity;\n    record.reserved += quantity;\n    return true;\n  }\n\n  release(productId: string, quantity: number): boolean {\n    const record = this.store.get(productId);\n    if (!record || record.reserved < quantity) return false;\n    record.reserved -= quantity;\n    record.available += quantity;\n    return true;\n  }\n\n  clear(): void {\n    this.store.clear();\n  }\n}\n","numLines":44,"startLine":1,"totalLines":44}}}
