(1);\n    expect(sent[0].type).toBe('confirmation');\n    expect(sent[0].message).toContain('O1');\n  });\n\n  it('issues refund and updates payment status', async () => {\n    await billing.chargePayment(\n      'O1',\n      [{ productId: 'A', quantity: 1, unitPrice: 50 }],\n      0,\n      0,\n      'card'\n    );\n    const refund = await billing.issueRefund('O1', 50);\n    expect(refund?.status).toBe('refunded');\n  });\n\n  it('sends refund notification', async () => {\n    await billing.chargePayment(\n      'O1',\n      [{ productId: 'A', quantity: 1, unitPrice: 50 }],\n      0,\n      0,\n      'card'\n    );\n    await billing.issueRefund('O1', 50);\n    const sent = notifications.getSentNotifications();\n    const refundNotice = sent.find((n) => n.type === 'refund');\n    expect(refundNotice).toBeDefined();\n    expect(refundNotice!.message).toContain('50.00');\n  });\n});\n","numLines":128,"startLine":1,"totalLines":128}}}
