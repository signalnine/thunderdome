tem } from '../orders/repository.js';\n\nexport interface PaymentRecord {\n  orderId: string;\n  amount: number;\n  method: string;\n  status: 'charged' | 'refunded';\n  processedAt: number;\n}\n\nexport class BillingService {\n  private payments: Map<string, PaymentRecord> = new Map();\n\n  constructor(\n    private eventBus: EventBus,\n    private notificationService: NotificationService\n  ) {}\n\n  registerHandlers(): void {\n    this.eventBus.on(ORDER_EVENTS.STOCK_RESERVED, this.handleStockReserved.bind(this));\n    this.eventBus.on(ORDER_EVENTS.REFUNDED, this.handleRefund);\n  }\n\n  private async handleStockReserved(data: unknown): Promise<void> {\n    const event = data as { orderId: string; items: OrderItem[] };\n    // Payment would be charged here in a real system\n    await this.eventBus.emit(ORDER_EVENTS.PAYMENT_CHARGED, {\n      orderId: event.orderId,\n      amount: 0, // Actual amount set by order service\n      paymentMethod: 'card',\n      timestamp: Date.now(),\n    });\n  }\n\n  async chargePayment(\n    orderId: string,\n    items: OrderItem[],\n    discountPercent: number,\n    taxRate: number,\n    paymentMethod: string\n  ): Promise<PaymentRecord> {\n    const breakdown = calculateOrderTotal(items, discountPercent, taxRate);\n\n    const record: PaymentRecord = {\n      orderId,\n      amount: breakdown.total,\n      method: paymentMethod,\n      status: 'charged',\n      processedAt: Date.now(),\n    };\n\n    this.payments.set(orderId, record);\n    this.notificationService.sendConfirmation(orderId, breakdown.total);\n    return record;\n  }\n\n  private async handleRefund(data: unknown): Promise<void> {\n    const event = data as { orderId: string; amount: number };\n    const payment = this.payments.get(event.orderId);\n    if (payment) {\n      payment.status = 'refunded';\n      this.notificationService.sendRefundNotice(event.orderId, event.amount);\n    }\n  }\n\n  async issueRefund(orderId: string, amount: number): Promise<PaymentRecord | undefined> {\n    const payment = this.payments.get(orderId);\n    if (!payment) return undefined;\n\n    payment.status = 'refunded';\n\n    await this.eventBus.emit(ORDER_EVENTS.REFUNDED, {\n      orderId,\n      amount,\n      timestamp: Date.now(),\n    });\n\n    return { ...payment };\n  }\n\n  getPayment(orderId: string): PaymentRecord | undefined {\n    const p = this.payments.get(orderId);\n    return p ? { ...p } : undefined;\n  }\n\n  clear(): void {\n    this.payments.clear();\n  }\n}\n","numLines":94,"startLine":1,"totalLines":94}}}
