e event\n    44→    // The order service attaches items to the cancellation event\n    45→    const eventWithItems = data as OrderCancelledEvent & {\n    46→      items?: Array<{ productId: string; quantity: number }>;\n    47→      status?: string;\n    48→    };\n    49→\n    50→    if (eventWithItems.status !== 'cancelled') return;\n    51→\n    52→    if (eventWithItems.items) {\n    53→      for (const item of eventWithItems.items) {\n    54→        this.repo.release(item.productId, item.quantity);\n    55→      }\n    56→    }\n    57→\n    58→    await this.eventBus.emit(ORDER_EVENTS.STOCK_RELEASED, {\n    59→      orderId: event.orderId,\n    60→      timestamp: Date.now(),\n    61→    });\n    62→  }\n    63→\n    64→  setStock(productId: string, quantity: number): void {\n    65→    this.repo.setStock(productId, quantity);\n    66→  }\n    67→\n    68→  getStock(productId: string) {\n    69→    return this.repo.getStock(productId);\n    70→  }\n    71→}\n    72→"}]},"parent_tool_use_id":null,"session_id":"83bd9ab7-df95-494e-8efe-98d5ba10fca2","uuid":"c14551df-a6ac-4ab1-86bf-bc9a4dc1c476","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/inventory/service.ts","content":"import { EventBus } from '../events/bus.js';\nimport { ORDER_EVENTS, OrderCreatedEvent, OrderCancelledEvent } from '../events/types.js';\nimport { InventoryRepository } from './repository.js';\n\nexport class InventoryService {\n  constructor(\n    private repo: InventoryRepository,\n    private eventBus: EventBus\n  ) {}\n\n  registerHandlers(): void {\n    this.eventBus.on(ORDER_EVENTS.CREATED, this.handleOrderCreated.bind(this));\n    this.eventBus.on(ORDER_EVENTS.CANCELLED, this.handleOrderCancelled.bind(this));\n  }\n\n  private async handleOrderCreated(data: unknown): Promise<void> {\n    const event = data as OrderCreatedEvent;\n    const reservations: Array<{ productId: string; quantity: number }> = [];\n\n    for (const item of event.items) {\n      const success = this.repo.reserve(item.productId, item.quantity);\n      if (!success) {\n        // Rollback previous reservations\n        for (const res of reservations) {\n          this.repo.release(res.productId, res.quantity);\n        }\n        throw new Error(\n          `Insufficient stock for product ${item.productId}`\n        );\n      }\n      reservations.push({ productId: item.productId, quantity: item.quantity });\n    }\n\n    await this.eventBus.emit(ORDER_EVENTS.STOCK_RESERVED, {\n      orderId: event.orderId,\n      items: reservations,\n      timestamp: Date.now(),\n    });\n  }\n\n  private async handleOrderCancelled(data: unknown): Promise<void> {\n    const event = data as OrderCancelledEvent;\n    // Release reserved stock — look up original order items from the event\n    // The order service attaches items to the cancellation event\n    const eventWithItems = data as OrderCancelledEvent & {\n      items?: Array<{ productId: string; quantity: number }>;\n      status?: string;\n    };\n\n    if (eventWithItems.status !== 'cancelled') return;\n\n    if (eventWithItems.items) {\n      for (const item of eventWithItems.items) {\n        this.repo.release(item.productId, item.quantity);\n      }\n    }\n\n    await this.eventBus.emit(ORDER_EVENTS.STOCK_RELEASED, {\n      orderId: event.orderId,\n      timestamp: Date.now(),\n    });\n  }\n\n  setStock(productId: string, quantity: number): void {\n    this.repo.setStock(productId, quantity);\n  }\n\n  getStock(productId: string) {\n    return this.repo.getStock(productId);\n  }\n}\n","numLines":72,"startLine":1,"totalLines":72}}}
