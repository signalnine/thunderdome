+++ b/src/routes/dashboards.ts
@@ -0,0 +1,171 @@
+import { Router } from 'express';
+import Database from 'better-sqlite3';
+import { v4 as uuidv4 } from 'uuid';
+import { AuthenticatedRequest, authMiddleware } from '../auth.js';
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+interface WidgetRow {
+  id: string;
+  dashboard_id: string;
+  type: string;
+  config: string;
+  position_x: number;
+  position_y: number;
+  width: number;
+  height: number;
+}
+
+export function createDashboardRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Create dashboard
+  router.post('/', authMiddleware, (req: AuthenticatedRequest, res) => {
+    const { name, config } = req.body;
+    const tenantId = req.user!.tenantId;
+    const ownerId = req.user!.userId;
+
+    if (!name) {
+      res.status(400).json({ error: 'Dashboard name is required' });
+      return;
+    }
+
+    const id = uuidv4();
+    const dashConfig = config ? JSON.stringify(config) : '{}';
+
+    db.prepare(
+      'INSERT INTO dashboards (id, tenant_id, name, owner_id, config) VALUES (?, ?, ?, ?, ?)'
+    ).run(id, tenantId, name, ownerId, dashConfig);
+
+    res.status(201).json({
+      id,
+      tenant_id: tenantId,
+      name,
+      owner_id: ownerId,
+      config: config || {},
+    });
+  });
+
+  // List dashboards
+  router.get('/', authMiddleware, (req: AuthenticatedRequest, res) => {
+    const tenantId = req.user!.tenantId;
+    const rows = db.prepare('SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC').all(tenantId) as DashboardRow[];
+
+    const dashboards = rows.map(row => ({
+      ...row,
+      config: JSON.parse(row.config),
+    }));
+
+    res.json({ dashboards });
+  });
+
+  // Get single dashboard
+  router.get('/:id', authMiddleware, (req: AuthenticatedRequest, res) => {
+    const tenantId = req.user!.tenantId;
+    const row = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(req.params.id, tenantId) as DashboardRow | undefined;
+
+    if (!row) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+
+    const widgets = db.prepare('SELECT * FROM widgets WHERE dashboard_id = ?').all(row.id) as WidgetRow[];
+
+    res.json({
+      ...row,
+      config: JSON.parse(row.config),
+      widgets: widgets.map(w => ({ ...w, config: JSON.parse(w.config) })),
+    });
+  });
+
+  // Update dashboard
+  router.put('/:id', authMiddleware, (req: AuthenticatedRequest, res) => {
+    const tenantId = req.user!.tenantId;
+    const { name, config } = req.body;
+
+    const existing = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(req.params.id, tenantId) as DashboardRow | undefined;
+
+    if (!existing) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+
+    const newName = name || existing.name;
+    const newConfig = config ? JSON.stringify(config) : existing.config;
+
+    db.prepare(
+      "UPDATE dashboards SET name = ?, config = ?, updated_at = datetime('now') WHERE id = ?"
+    ).run(newName, newConfig, req.params.id);
+
+    res.json({
+      id: existing.id,
+      tenant_id: tenantId,
+      name: newName,
+      owner_id: existing.owner_id,
+      config: config || JSON.parse(existing.config),
+    });
+  });
+
+  // Delete dashboard
+  router.delete('/:id', authMiddleware, (req: AuthenticatedRequest, res) => {
+    const tenantId = req.user!.tenantId;
+
+    const existing = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(req.params.id, tenantId) as DashboardRow | undefined;
+
+    if (!existing) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+
+    db.prepare('DELETE FROM widgets WHERE dashboard_id = ?').run(req.params.id);
+    db.prepare('DELETE FROM dashboards WHERE id = ?').run(req.params.id);
+
+    res.status(204).send();
+  });
+
+  // Add widget to dashboard
+  router.post('/:id/widgets', authMiddleware, (req: AuthenticatedRequest, res) => {
+    const tenantId = req.user!.tenantId;
+    const { type, config, position_x, position_y, width, height } = req.body;
+
+    const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(req.params.id, tenantId) as DashboardRow | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+
+    if (!type || !['counter', 'timeseries', 'breakdown', 'funnel'].includes(type)) {
+      res.status(400).json({ error: 'Valid widget type is required (counter, timeseries, breakdown, funnel)' });
+      return;
+    }
+
+    const id = uuidv4();
+    const widgetConfig = config ? JSON.stringify(config) : '{}';
+
+    db.prepare(
+      'INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)'
+    ).run(id, req.params.id, type, widgetConfig, position_x || 0, position_y || 0, width || 1, height || 1);
+
+    res.status(201).json({
+      id,
+      dashboard_id: req.params.id,
+      type,
+      config: config || {},
+      position_x: position_x || 0,
+      position_y: position_y || 0,
+      width: width || 1,
+      height: height || 1,
+    });
+  });
+
+  return router;
+}
