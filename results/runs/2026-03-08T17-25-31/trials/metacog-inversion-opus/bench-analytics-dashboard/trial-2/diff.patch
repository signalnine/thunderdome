@@ -0,0 +1,160 @@
+import { Router } from 'express';
+import Database from 'better-sqlite3';
+import { AuthenticatedRequest, authMiddleware } from '../auth.js';
+
+interface EventRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string;
+  session_id: string | null;
+}
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+interface WidgetRow {
+  id: string;
+  dashboard_id: string;
+  type: string;
+  config: string;
+  position_x: number;
+  position_y: number;
+  width: number;
+  height: number;
+}
+
+function escapeCsvField(field: string): string {
+  const str = String(field ?? '');
+  if (str.includes(',') || str.includes('"') || str.includes('\n') || str.includes('\r')) {
+    return `"${str.replace(/"/g, '""')}"`;
+  }
+  return str;
+}
+
+function eventsToCsv(events: EventRow[]): string {
+  const header = 'id,tenant_id,name,properties,timestamp,user_id,session_id';
+  const rows = events.map(e =>
+    [e.id, e.tenant_id, e.name, e.properties, e.timestamp, e.user_id, e.session_id ?? ''].map(escapeCsvField).join(',')
+  );
+  return [header, ...rows].join('\n');
+}
+
+function dashboardsToCsv(dashboards: Array<DashboardRow & { widgets?: WidgetRow[] }>): string {
+  const header = 'id,tenant_id,name,owner_id,config,created_at,updated_at';
+  const rows = dashboards.map(d =>
+    [d.id, d.tenant_id, d.name, d.owner_id, d.config, d.created_at, d.updated_at].map(escapeCsvField).join(',')
+  );
+  return [header, ...rows].join('\n');
+}
+
+export function createExportRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Export events as JSON
+  router.get('/events/json', authMiddleware, (req: AuthenticatedRequest, res) => {
+    const tenantId = req.user!.tenantId;
+    const { name, start, end } = req.query;
+
+    let query = 'SELECT * FROM events WHERE tenant_id = ?';
+    const params: string[] = [tenantId];
+
+    if (name) {
+      query += ' AND name = ?';
+      params.push(name as string);
+    }
+    if (start) {
+      query += ' AND timestamp >= ?';
+      params.push(start as string);
+    }
+    if (end) {
+      query += ' AND timestamp <= ?';
+      params.push(end as string);
+    }
+
+    query += ' ORDER BY timestamp DESC';
+
+    const rows = db.prepare(query).all(...params) as EventRow[];
+
+    const events = rows.map(row => ({
+      ...row,
+      properties: JSON.parse(row.properties),
+    }));
+
+    res.setHeader('Content-Type', 'application/json');
+    res.setHeader('Content-Disposition', 'attachment; filename="events.json"');
+    res.json({ events });
+  });
+
+  // Export events as CSV
+  router.get('/events/csv', authMiddleware, (req: AuthenticatedRequest, res) => {
+    const tenantId = req.user!.tenantId;
+    const { name, start, end } = req.query;
+
+    let query = 'SELECT * FROM events WHERE tenant_id = ?';
+    const params: string[] = [tenantId];
+
+    if (name) {
+      query += ' AND name = ?';
+      params.push(name as string);
+    }
+    if (start) {
+      query += ' AND timestamp >= ?';
+      params.push(start as string);
+    }
+    if (end) {
+      query += ' AND timestamp <= ?';
+      params.push(end as string);
+    }
+
+    query += ' ORDER BY timestamp DESC';
+
+    const rows = db.prepare(query).all(...params) as EventRow[];
+
+    res.setHeader('Content-Type', 'text/csv');
+    res.setHeader('Content-Disposition', 'attachment; filename="events.csv"');
+    res.send(eventsToCsv(rows));
+  });
+
+  // Export dashboards as JSON
+  router.get('/dashboards/json', authMiddleware, (req: AuthenticatedRequest, res) => {
+    const tenantId = req.user!.tenantId;
+
+    const dashboards = db.prepare('SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC').all(tenantId) as DashboardRow[];
+
+    const result = dashboards.map(d => {
+      const widgets = db.prepare('SELECT * FROM widgets WHERE dashboard_id = ?').all(d.id) as WidgetRow[];
+      return {
+        ...d,
+        config: JSON.parse(d.config),
+        widgets: widgets.map(w => ({ ...w, config: JSON.parse(w.config) })),
+      };
+    });
+
+    res.setHeader('Content-Type', 'application/json');
+    res.setHeader('Content-Disposition', 'attachment; filename="dashboards.json"');
+    res.json({ dashboards: result });
+  });
+
+  // Export dashboards as CSV
+  router.get('/dashboards/csv', authMiddleware, (req: AuthenticatedRequest, res) => {
+    const tenantId = req.user!.tenantId;
+
+    const dashboards = db.prepare('SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC').all(tenantId) as DashboardRow[];
+
+    res.setHeader('Content-Type', 'text/csv');
+    res.setHeader('Content-Disposition', 'attachment; filename="dashboards.csv"');
+    res.send(dashboardsToCsv(dashboards));
+  });
+
+  return router;
+}
diff --git a/src/routes/queries.ts b/src/routes/queries.ts
new file mode 100644
index 0000000..e1d72f8
--- /dev/null
+++ b/src/routes/queries.ts
@@ -0,0 +1,144 @@
+import { Router } from 'express';
+import Database from 'better-sqlite3';
+import { AuthenticatedRequest, authMiddleware } from '../auth.js';
+
+export function createQueryRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Count query
+  router.post('/count', authMiddleware, (req: AuthenticatedRequest, res) => {
+    const tenantId = req.user!.tenantId;
+    const { event_name, start, end, filters } = req.body;
+
+    let query = 'SELECT COUNT(*) as count FROM events WHERE tenant_id = ?';
+    const params: string[] = [tenantId];
+
+    if (event_name) {
+      query += ' AND name = ?';
+      params.push(event_name);
+    }
+    if (start) {
+      query += ' AND timestamp >= ?';
+      params.push(start);
+    }
+    if (end) {
+      query += ' AND timestamp <= ?';
+      params.push(end);
+    }
+
+    if (filters && typeof filters === 'object') {
+      for (const [key, value] of Object.entries(filters)) {
+        query += ` AND json_extract(properties, ?) = ?`;
+        params.push(`$.${key}`);
+        params.push(String(value));
+      }
+    }
+
+    const result = db.prepare(query).get(...params) as { count: number };
+    res.json({ count: result.count });
+  });
+
+  // Timeseries query
+  router.post('/timeseries', authMiddleware, (req: AuthenticatedRequest, res) => {
+    const tenantId = req.user!.tenantId;
+    const { event_name, start, end, interval, filters } = req.body;
+
+    if (!event_name) {
+      res.status(400).json({ error: 'event_name is required' });
+      return;
+    }
+
+    // Determine the date grouping format based on interval
+    let dateFormat: string;
+    const bucketInterval = interval || 'day';
+    switch (bucketInterval) {
+      case 'hour':
+        dateFormat = '%Y-%m-%dT%H:00:00';
+        break;
+      case 'day':
+        dateFormat = '%Y-%m-%d';
+        break;
+      case 'week':
+        dateFormat = '%Y-%W';
+        break;
+      case 'month':
+        dateFormat = '%Y-%m';
+        break;
+      default:
+        dateFormat = '%Y-%m-%d';
+    }
+
+    let query = `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count FROM events WHERE tenant_id = ? AND name = ?`;
+    const params: string[] = [tenantId, event_name];
+
+    if (start) {
+      query += ' AND timestamp >= ?';
+      params.push(start);
+    }
+    if (end) {
+      query += ' AND timestamp <= ?';
+      params.push(end);
+    }
+
+    if (filters && typeof filters === 'object') {
+      for (const [key, value] of Object.entries(filters)) {
+        query += ` AND json_extract(properties, ?) = ?`;
+        params.push(`$.${key}`);
+        params.push(String(value));
+      }
+    }
+
+    query += ' GROUP BY bucket ORDER BY bucket ASC';
+
+    const rows = db.prepare(query).all(...params) as Array<{ bucket: string; count: number }>;
+
+    res.json({
+      event_name,
+      interval: bucketInterval,
+      data: rows,
+    });
+  });
+
+  // Breakdown query
+  router.post('/breakdown', authMiddleware, (req: AuthenticatedRequest, res) => {
+    const tenantId = req.user!.tenantId;
+    const { event_name, property, start, end, filters } = req.body;
+
+    if (!event_name || !property) {
+      res.status(400).json({ error: 'event_name and property are required' });
+      return;
+    }
+
+    let query = `SELECT json_extract(properties, ?) as property_value, COUNT(*) as count FROM events WHERE tenant_id = ? AND name = ?`;
+    const params: string[] = [`$.${property}`, tenantId, event_name];
+
+    if (start) {
+      query += ' AND timestamp >= ?';
+      params.push(start);
+    }
+    if (end) {
+      query += ' AND timestamp <= ?';
+      params.push(end);
+    }
+
+    if (filters && typeof filters === 'object') {
+      for (const [key, value] of Object.entries(filters)) {
+        query += ` AND json_extract(properties, ?) = ?`;
+        params.push(`$.${key}`);
+        params.push(String(value));
+      }
+    }
+
+    query += ' GROUP BY property_value ORDER BY count DESC';
+
+    const rows = db.prepare(query).all(...params) as Array<{ property_value: string | null; count: number }>;
+
+    res.json({
+      event_name,
+      property,
+      data: rows,
+    });
+  });
+
+  return router;
+}
