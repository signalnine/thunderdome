+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01AD23SNw2W7oTQg4W2Ju6sp","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Sn82CqorBn5WELjCoDGi47","name":"Write","input":{"file_path":"/workspace/src/routes/users.ts","content":"import { Router } from 'express';\nimport Database from 'better-sqlite3';\nimport { v4 as uuidv4 } from 'uuid';\nimport {\n  AuthenticatedRequest,\n  authMiddleware,\n  generateToken,\n  hashPassword,\n  verifyPassword,\n  requireRole,\n} from '../auth.js';\n\nexport function createUserRoutes(db: Database.Database): Router {\n  const router = Router();\n\n  // Register\n  router.post('/register', (req, res) => {\n    const { email, password, tenant_id } = req.body;\n\n    if (!email || !password || !tenant_id) {\n      res.status(400).json({ error: 'email, password, and tenant_id are required' });\n      return;\n    }\n\n    const existing = db.prepare('SELECT id FROM users WHERE email = ?').get(email);\n    if (existing) {\n      res.status(409).json({ error: 'Email already registered' });\n      return;\n    }\n\n    const id = uuidv4();\n    const passwordHash = hashPassword(password);\n\n    // First user in a tenant becomes admin\n    const tenantUsers = db.prepare('SELECT COUNT(*) as count FROM users WHERE tenant_id = ?').get(tenant_id) as { count: number };\n    const role = tenantUsers.count === 0 ? 'admin' : 'viewer';\n\n    db.prepare(\n      'INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)'\n    ).run(id, email, passwordHash, tenant_id, role);\n\n    const token = generateToken({ userId: id, email, tenantId: tenant_id, role });\n\n    res.status(201).json({\n      id,\n      email,\n      tenant_id,\n      role,\n      token,\n    });\n  });\n\n  // Login\n  router.post('/login', (req, res) => {\n    const { email, password } = req.body;\n\n    if (!email || !password) {\n      res.status(400).json({ error: 'email and password are required' });\n      return;\n    }\n\n    const user = db.prepare('SELECT * FROM users WHERE email = ?').get(email) as {\n      id: string;\n      email: string;\n      password_hash: string;\n      tenant_id: string;\n      role: string;\n    } | undefined;\n\n    if (!user || !verifyPassword(password, user.password_hash)) {\n      res.status(401).json({ error: 'Invalid email or password' });\n      return;\n    }\n\n    const token = generateToken({\n      userId: user.id,\n      email: user.email,\n      tenantId: user.tenant_id,\n      role: user.role,\n    });\n\n    res.json({\n      id: user.id,\n      email: user.email,\n      tenant_id: user.tenant_id,\n      role: user.role,\n      token,\n    });\n  });\n\n  // Get profile\n  router.get('/me', authMiddleware, (req: AuthenticatedRequest, res) => {\n    const user = db.prepare('SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?').get(req.user!.userId) as {\n      id: string;\n      email: string;\n      tenant_id: string;\n      role: string;\n      created_at: string;\n    } | undefined;\n\n    if (!user) {\n      res.status(404).json({ error: 'User not found' });\n      return;\n    }\n\n    res.json(user);\n  });\n\n  // Update user role (admin only)\n  router.put('/:userId/role', authMiddleware, requireRole('admin'), (req: AuthenticatedRequest, res) => {\n    const { userId } = req.params;\n    const { role } = req.body;\n\n    if (!role || !['admin', 'viewer', 'editor'].includes(role)) {\n      res.status(400).json({ error: 'Valid role is required (admin, viewer, editor)' });\n      return;\n    }\n\n    const targetUser = db.prepare('SELECT * FROM users WHERE id = ?').get(userId) as {\n      id: string;\n      tenant_id: string;\n    } | undefined;\n\n    if (!targetUser) {\n      res.status(404).json({ error: 'User not found' });\n      return;\n    }\n\n    // Tenant isolation: admin can only change roles within their own tenant\n    if (targetUser.tenant_id !== req.user!.tenantId) {\n      res.status(403).json({ error: 'Cannot modify users in other tenants' });\n      return;\n    }\n\n    db.prepare('UPDATE users SET role = ? WHERE id = ?').run(role, userId);\n\n    res.json({ id: userId, role });\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":384,"cache_read_input_tokens":23686,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":384},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"666af92f-7336-41b3-b68d-6c00efde72e0","uuid":"7f781a6c-54a6-42c2-86d5-e79c1a5b31b3"}
