@@ -0,0 +1,123 @@
+import { Router } from 'express';
+import Database from 'better-sqlite3';
+import { v4 as uuidv4 } from 'uuid';
+import { AuthenticatedRequest, authMiddleware } from '../auth.js';
+
+export function createEventRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Ingest single event
+  router.post('/', authMiddleware, (req: AuthenticatedRequest, res) => {
+    const { name, properties, timestamp, session_id } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: 'Event name is required' });
+      return;
+    }
+
+    const id = uuidv4();
+    const tenantId = req.user!.tenantId;
+    const userId = req.user!.userId;
+    const eventTimestamp = timestamp || new Date().toISOString();
+    const eventProperties = properties ? JSON.stringify(properties) : '{}';
+
+    db.prepare(
+      'INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)'
+    ).run(id, tenantId, name, eventProperties, eventTimestamp, userId, session_id || null);
+
+    res.status(201).json({
+      id,
+      tenant_id: tenantId,
+      name,
+      properties: properties || {},
+      timestamp: eventTimestamp,
+      user_id: userId,
+      session_id: session_id || null,
+    });
+  });
+
+  // Batch ingest events
+  router.post('/batch', authMiddleware, (req: AuthenticatedRequest, res) => {
+    const { events } = req.body;
+
+    if (!Array.isArray(events) || events.length === 0) {
+      res.status(400).json({ error: 'events array is required and must not be empty' });
+      return;
+    }
+
+    const tenantId = req.user!.tenantId;
+    const userId = req.user!.userId;
+
+    const stmt = db.prepare(
+      'INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)'
+    );
+
+    const results: Array<{ id: string; name: string }> = [];
+
+    const insertMany = db.transaction((eventList: typeof events) => {
+      for (const event of eventList) {
+        if (!event.name) continue;
+        const id = uuidv4();
+        const eventTimestamp = event.timestamp || new Date().toISOString();
+        const eventProperties = event.properties ? JSON.stringify(event.properties) : '{}';
+        stmt.run(id, tenantId, event.name, eventProperties, eventTimestamp, userId, event.session_id || null);
+        results.push({ id, name: event.name });
+      }
+    });
+
+    insertMany(events);
+
+    res.status(201).json({
+      inserted: results.length,
+      events: results,
+    });
+  });
+
+  // List events (with optional filters)
+  router.get('/', authMiddleware, (req: AuthenticatedRequest, res) => {
+    const tenantId = req.user!.tenantId;
+    const { name, start, end, limit: limitParam, offset: offsetParam } = req.query;
+
+    let query = 'SELECT * FROM events WHERE tenant_id = ?';
+    const params: (string | number)[] = [tenantId];
+
+    if (name) {
+      query += ' AND name = ?';
+      params.push(name as string);
+    }
+    if (start) {
+      query += ' AND timestamp >= ?';
+      params.push(start as string);
+    }
+    if (end) {
+      query += ' AND timestamp <= ?';
+      params.push(end as string);
+    }
+
+    query += ' ORDER BY timestamp DESC';
+
+    const limit = parseInt(limitParam as string) || 100;
+    const offset = parseInt(offsetParam as string) || 0;
+    query += ' LIMIT ? OFFSET ?';
+    params.push(limit, offset);
+
+    const rows = db.prepare(query).all(...params) as Array<{
+      id: string;
+      tenant_id: string;
+      name: string;
+      properties: string;
+      timestamp: string;
+      user_id: string;
+      session_id: string | null;
+    }>;
+
+    const events = rows.map(row => ({
+      ...row,
+      properties: JSON.parse(row.properties),
+    }));
+
+    res.json({ events, limit, offset });
+  });
+
+  return router;
+}
