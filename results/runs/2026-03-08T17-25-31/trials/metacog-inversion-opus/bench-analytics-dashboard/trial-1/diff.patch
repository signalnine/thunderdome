+
+export function createExportRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  router.use(authMiddleware);
+
+  // Export events as JSON
+  router.get("/events/json", (req: AuthenticatedRequest, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { name, startDate, endDate } = req.query;
+
+    let sql = "SELECT id, tenant_id, name, properties, timestamp, user_id, session_id FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [tenantId];
+
+    if (name) {
+      sql += " AND name = ?";
+      params.push(name);
+    }
+
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    sql += " ORDER BY timestamp DESC";
+
+    const rows = db.prepare(sql).all(...params) as Array<{
+      id: string;
+      tenant_id: string;
+      name: string;
+      properties: string;
+      timestamp: string;
+      user_id: string;
+      session_id: string | null;
