diff --git a/src/routes/queries.ts b/src/routes/queries.ts
new file mode 100644
index 0000000..58d7c52
--- /dev/null
+++ b/src/routes/queries.ts
@@ -0,0 +1,143 @@
+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { AuthenticatedRequest, authMiddleware } from "../auth.js";
+
+export function createQueryRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  router.use(authMiddleware);
+
+  // Count query
+  router.post("/count", (req: AuthenticatedRequest, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { eventName, startDate, endDate, filters } = req.body;
+
+    let sql = "SELECT COUNT(*) as count FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [tenantId];
+
+    if (eventName) {
+      sql += " AND name = ?";
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value);
+      }
+    }
+
+    const result = db.prepare(sql).get(...params) as { count: number };
+    res.json({ count: result.count });
+  });
+
+  // Timeseries query
+  router.post("/timeseries", (req: AuthenticatedRequest, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { eventName, startDate, endDate, interval, filters } = req.body;
+
+    // Default interval is 'day'
+    const bucket = interval || "day";
+    let dateFormat: string;
+
+    switch (bucket) {
+      case "hour":
+        dateFormat = "%Y-%m-%dT%H:00:00";
+        break;
+      case "day":
+        dateFormat = "%Y-%m-%d";
+        break;
+      case "week":
+        dateFormat = "%Y-W%W";
+        break;
+      case "month":
+        dateFormat = "%Y-%m";
+        break;
+      default:
+        dateFormat = "%Y-%m-%d";
+    }
+
+    let sql = `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: unknown[] = [tenantId];
+
+    if (eventName) {
+      sql += " AND name = ?";
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value);
+      }
+    }
+
+    sql += " GROUP BY bucket ORDER BY bucket";
+
+    const rows = db.prepare(sql).all(...params) as Array<{ bucket: string; count: number }>;
+    res.json({ timeseries: rows, interval: bucket });
+  });
+
+  // Breakdown query
+  router.post("/breakdown", (req: AuthenticatedRequest, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { eventName, property, startDate, endDate, filters } = req.body;
+
+    if (!property) {
+      res.status(400).json({ error: "property is required for breakdown queries" });
+      return;
+    }
+
+    let sql = `SELECT json_extract(properties, ?) as property_value, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: unknown[] = [`$.${property}`, tenantId];
+
+    if (eventName) {
+      sql += " AND name = ?";
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value);
+      }
+    }
+
+    sql += " GROUP BY property_value ORDER BY count DESC";
+
+    const rows = db.prepare(sql).all(...params) as Array<{ property_value: string | null; count: number }>;
+    res.json({ breakdown: rows, property });
+  });
+
+  return router;
+}
