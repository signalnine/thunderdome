t(\"should login with valid credentials\", async () => {\n      await request(app).post(\"/api/users/register\").send({\n        email: \"test@example.com\",\n        password: \"password123\",\n        tenantId: \"tenant-1\",\n      });\n      const res = await request(app).post(\"/api/users/login\").send({\n        email: \"test@example.com\",\n        password: \"password123\",\n      });\n      expect(res.status).toBe(200);\n      expect(res.body.token).toBeDefined();\n    });\n\n    it(\"should reject invalid password\", async () => {\n      await request(app).post(\"/api/users/register\").send({\n        email: \"test@example.com\",\n        password: \"password123\",\n        tenantId: \"tenant-1\",\n      });\n      const res = await request(app).post(\"/api/users/login\").send({\n        email: \"test@example.com\",\n        password: \"wrong\",\n      });\n      expect(res.status).toBe(401);\n    });\n\n    it(\"should get user profile with valid token\", async () => {\n      const reg = await request(app).post(\"/api/users/register\").send({\n        email: \"test@example.com\",\n        password: \"password123\",\n        tenantId: \"tenant-1\",\n      });\n      const res = await request(app)\n        .get(\"/api/users/profile\")\n        .set(\"Authorization\", `Bearer ${reg.body.token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.email).toBe(\"test@example.com\");\n    });\n\n    it(\"should reject profile request without token\", async () => {\n      const res = await request(app).get(\"/api/users/profile\");\n      expect(res.status).toBe(401);\n    });\n\n    it(\"should allow admin to change roles\", async () => {\n      const admin = await request(app).post(\"/api/users/register\").send({\n        email: \"admin@example.com\",\n        password: \"password123\",\n        tenantId: \"tenant-1\",\n        role: \"admin\",\n      });\n      const viewer = await request(app).post(\"/api/users/register\").send({\n        email: \"viewer@example.com\",\n        password: \"password123\",\n        tenantId: \"tenant-1\",\n      });\n      const res = await request(app)\n        .put(`/api/users/${viewer.body.id}/role`)\n        .set(\"Authorization\", `Bearer ${admin.body.token}`)\n        .send({ role: \"editor\" });\n      expect(res.status).toBe(200);\n      expect(res.body.role).toBe(\"editor\");\n    });\n\n    it(\"should prevent non-admin from changing roles\", async () => {\n      const viewer1 = await request(app).post(\"/api/users/register\").send({\n        email: \"viewer1@example.com\",\n        password: \"password123\",\n        tenantId: \"tenant-1\",\n      });\n      const viewer2 = await request(app).post(\"/api/users/register\").send({\n        email: \"viewer2@example.com\",\n        password: \"password123\",\n        tenantId: \"tenant-1\",\n      });\n      const res = await request(app)\n        .put(`/api/users/${viewer2.body.id}/role`)\n        .set(\"Authorization\", `Bearer ${viewer1.body.token}`)\n        .send({ role: \"admin\" });\n      expect(res.status).toBe(403);\n    });\n  });\n\n  describe(\"Event Ingestion\", () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const res = await request(app).post(\"/api/users/register\").send({\n        email: \"test@example.com\",\n        password: \"password123\",\n        tenantId: \"tenant-1\",\n      });\n      token = res.body.token;\n    });\n\n    it(\"should ingest a single event\", async () => {\n      const res = await request(app)\n        .post(\"/api/events\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"page_view\", properties: { url: \"/home\" } });\n      expect(res.status).toBe(201);\n      expect(res.body.name).toBe(\"page_view\");\n    });\n\n    it(\"should reject event without auth\", async () => {\n      const res = await request(app)\n        .post(\"/api/events\")\n        .send({ name: \"page_view\" });\n      expect(res.status).toBe(401);\n    });\n\n    it(\"should ingest batch events\", async () => {\n      const res = await request(app)\n        .post(\"/api/events/batch\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({\n          events: [\n            { name: \"page_view\", properties: { url: \"/home\" } },\n            { name: \"click\", properties: { button: \"signup\" } },\n            { name: \"page_view\", properties: { url: \"/about\" } },\n          ],\n        });\n      expect(res.status).toBe(201);\n      expect(res.body.inserted).toBe(3);\n    });\n\n    it(\"should list events\", async () => {\n      await request(app)\n        .post(\"/api/events\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"page_view\", properties: { url: \"/home\" } });\n\n      const res = await request(app)\n        .get(\"/api/events\")\n        .set(\"Authorization\", `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.events.length).toBe(1);\n    });\n  });\n\n  describe(\"Tenant Isolation\", () => {\n    it(\"should isolate events between tenants\", async () => {\n      const user1 = await request(app).post(\"/api/users/register\").send({\n        email: \"user1@tenant1.com\",\n        password: \"password123\",\n        tenantId: \"tenant-1\",\n      });\n      const user2 = await request(app).post(\"/api/users/register\").send({\n        email: \"user2@tenant2.com\",\n        password: \"password123\",\n        tenantId: \"tenant-2\",\n      });\n\n      await request(app)\n        .post(\"/api/events\")\n        .set(\"Authorization\", `Bearer ${user1.body.token}`)\n        .send({ name: \"page_view\" });\n\n      await request(app)\n        .post(\"/api/events\")\n        .set(\"Authorization\", `Bearer ${user2.body.token}`)\n        .send({ name: \"page_view\" });\n\n      const res1 = await request(app)\n        .get(\"/api/events\")\n        .set(\"Authorization\", `Bearer ${user1.body.token}`);\n      const res2 = await request(app)\n        .get(\"/api/events\")\n        .set(\"Authorization\", `Bearer ${user2.body.token}`);\n\n      expect(res1.body.events.length).toBe(1);\n      expect(res2.body.events.length).toBe(1);\n      expect(res1.body.events[0].tenantId).toBe(\"tenant-1\");\n      expect(res2.body.events[0].tenantId).toBe(\"tenant-2\");\n    });\n  });\n\n  describe(\"Query Engine\", () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const reg = await request(app).post(\"/api/users/register\").send({\n        email: \"test@example.com\",\n        password: \"password123\",\n        tenantId: \"tenant-1\",\n      });\n      token = reg.body.token;\n\n      // Insert test events\n      await request(app)\n        .post(\"/api/events/batch\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({\n          events: [\n            { name: \"page_view\", properties: { url: \"/home\" }, timestamp: \"2024-01-01T10:00:00Z\" },\n            { name: \"page_view\", properties: { url: \"/about\" }, timestamp: \"2024-01-01T14:00:00Z\" },\n            { name: \"page_view\", properties: { url: \"/home\" }, timestamp: \"2024-01-02T10:00:00Z\" },\n            { name: \"click\", properties: { button: \"signup\" }, timestamp: \"2024-01-01T11:00:00Z\" },\n            { name: \"click\", properties: { button: \"login\" }, timestamp: \"2024-01-02T12:00:00Z\" },\n          ],\n        });\n    });\n\n    it(\"should count events\", async () => {\n      const res = await request(app)\n        .post(\"/api/queries/count\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ eventName: \"page_view\" });\n      expect(res.status).toBe(200);\n      expect(res.body.count).toBe(3);\n    });\n\n    it(\"should count all events\", async () => {\n      const res = await request(app)\n        .post(\"/api/queries/count\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({});\n      expect(res.status).toBe(200);\n      expect(res.body.count).toBe(5);\n    });\n\n    it(\"should support timeseries query\", async () => {\n      const res = await request(app)\n        .post(\"/api/queries/timeseries\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ eventName: \"page_view\", interval: \"day\" });\n      expect(res.status).toBe(200);\n      expect(res.body.timeseries.length).toBe(2);\n    });\n\n    it(\"should support breakdown query\", async () => {\n      const res = await request(app)\n        .post(\"/api/queries/breakdown\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ eventName: \"page_view\", property: \"url\" });\n      expect(res.status).toBe(200);\n      expect(res.body.breakdown.length).toBe(2);\n      // /home appears twice, /about once\n      const homeEntry = res.body.breakdown.find((b: { property_value: string }) => b.property_value === \"/home\");\n      expect(homeEntry.count).toBe(2);\n    });\n\n    it(\"should require property for breakdown\", async () => {\n      const res = await request(app)\n        .post(\"/api/queries/breakdown\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ eventName: \"page_view\" });\n      expect(res.status).toBe(400);\n    });\n  });\n\n  describe(\"Dashboard CRUD\", () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const reg = await request(app).post(\"/api/users/register\").send({\n        email: \"test@example.com\",\n        password: \"password123\",\n        tenantId: \"tenant-1\",\n      });\n      token = reg.body.token;\n    });\n\n    it(\"should create a dashboard\", async () => {\n      const res = await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"My Dashboard\", config: { theme: \"dark\" } });\n      expect(res.status).toBe(201);\n      expect(res.body.name).toBe(\"My Dashboard\");\n    });\n\n    it(\"should list dashboards\", async () => {\n      await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"Dashboard 1\" });\n      await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"Dashboard 2\" });\n\n      const res = await request(app)\n        .get(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.dashboards.length).toBe(2);\n    });\n\n    it(\"should get a single dashboard\", async () => {\n      const created = await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"My Dashboard\" });\n      const res = await request(app)\n        .get(`/api/dashboards/${created.body.id}`)\n        .set(\"Authorization\", `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe(\"My Dashboard\");\n      expect(res.body.widgets).toBeDefined();\n    });\n\n    it(\"should update a dashboard\", async () => {\n      const created = await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"My Dashboard\" });\n      const res = await request(app)\n        .put(`/api/dashboards/${created.body.id}`)\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"Updated Dashboard\" });\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe(\"Updated Dashboard\");\n    });\n\n    it(\"should delete a dashboard\", async () => {\n      const created = await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"My Dashboard\" });\n      const res = await request(app)\n        .delete(`/api/dashboards/${created.body.id}`)\n        .set(\"Authorization\", `Bearer ${token}`);\n      expect(res.status).toBe(204);\n\n      const get = await request(app)\n        .get(`/api/dashboards/${created.body.id}`)\n        .set(\"Authorization\", `Bearer ${token}`);\n      expect(get.status).toBe(404);\n    });\n\n    it(\"should not access dashboards from another tenant\", async () => {\n      const created = await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"Tenant 1 Dashboard\" });\n\n      const other = await request(app).post(\"/api/users/register\").send({\n        email: \"other@tenant2.com\",\n        password: \"password123\",\n        tenantId: \"tenant-2\",\n      });\n\n      const res = await request(app)\n        .get(`/api/dashboards/${created.body.id}`)\n        .set(\"Authorization\", `Bearer ${other.body.token}`);\n      expect(res.status).toBe(404);\n    });\n  });\n\n  describe(\"Data Export\", () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const reg = await request(app).post(\"/api/users/register\").send({\n        email: \"test@example.com\",\n        password: \"password123\",\n        tenantId: \"tenant-1\",\n      });\n      token = reg.body.token;\n\n      await request(app)\n        .post(\"/api/events/batch\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({\n          events: [\n            { name: \"page_view\", properties: { url: \"/home\" } },\n            { name: \"click\", properties: { button: \"signup\" } },\n          ],\n        });\n    });\n\n    it(\"should export events as JSON\", async () => {\n      const res = await request(app)\n        .get(\"/api/export/events/json\")\n        .set(\"Authorization\", `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.events.length).toBe(2);\n    });\n\n    it(\"should export events as CSV\", async () => {\n      const res = await request(app)\n        .get(\"/api/export/events/csv\")\n        .set(\"Authorization\", `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n      expect(res.text).toContain(\"id,tenant_id,name\");\n    });\n\n    it(\"should export dashboard as JSON\", async () => {\n      const dashboard = await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"Export Test\" });\n\n      const res = await request(app)\n        .get(`/api/export/dashboards/${dashboard.body.id}/json`)\n        .set(\"Authorization\", `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.dashboard.name).toBe(\"Export Test\");\n    });\n\n    it(\"should export dashboard as CSV\", async () => {\n      const dashboard = await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"Export Test\" });\n\n      const res = await request(app)\n        .get(`/api/export/dashboards/${dashboard.body.id}/csv`)\n        .set(\"Authorization\", `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n    });\n\n    it(\"should reject export without auth\", async () => {\n      const res = await request(app).get(\"/api/export/events/json\");\n      expect(res.status).toBe(401);\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
