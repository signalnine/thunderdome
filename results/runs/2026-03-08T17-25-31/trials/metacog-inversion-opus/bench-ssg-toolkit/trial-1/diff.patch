p<string, ContentFile[]>;\n    expect(tagMap.size).toBe(0);\n  });\n\n  it('handles files with multiple tags', async () => {\n    const files = [\n      makeFile({ slug: 'post-1', title: 'Post 1', tags: ['js', 'node', 'web'] }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.beforeBuild!(ctx);\n    const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]>;\n    expect(tagMap.size).toBe(3);\n    expect(tagMap.has('js')).toBe(true);\n    expect(tagMap.has('node')).toBe(true);\n    expect(tagMap.has('web')).toBe(true);\n  });\n\n  it('tag pages list all files with that tag', async () => {\n    const files = [\n      makeFile({ slug: 'post-1', title: 'First Post', tags: ['tech'] }),\n      makeFile({ slug: 'post-2', title: 'Second Post', tags: ['tech'] }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.beforeBuild!(ctx);\n    await plugin.hooks.afterBuild!(ctx);\n    const tagPage = ctx.output.get('tags/tech.html')!;\n    expect(tagPage).toContain('First Post');\n    expect(tagPage).toContain('Second Post');\n  });\n\n  it('stores tag map in ctx.data', async () => {\n    const files = [\n      makeFile({ slug: 'post-1', title: 'Post 1', tags: ['alpha'] }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.beforeBuild!(ctx);\n    expect(ctx.data.has('taxonomy-tags')).toBe(true);\n  });\n\n  it('handles empty file list', async () => {\n    const ctx = makeCtx([]);\n    await plugin.hooks.beforeBuild!(ctx);\n    await plugin.hooks.afterBuild!(ctx);\n    const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]>;\n    expect(tagMap.size).toBe(0);\n  });\n\n  it('tags are case-normalized to lowercase', async () => {\n    const files = [\n      makeFile({ slug: 'post-1', title: 'Post 1', tags: ['JavaScript'] }),\n      makeFile({ slug: 'post-2', title: 'Post 2', tags: ['JAVASCRIPT'] }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.beforeBuild!(ctx);\n    const tagMap = ctx.