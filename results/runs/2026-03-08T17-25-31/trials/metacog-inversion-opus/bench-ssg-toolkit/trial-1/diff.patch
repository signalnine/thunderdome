+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AG8zJf5QVdgbDrsLD9PJ2L","type":"tool_result","content":"     1в†’import { describe, it, expect } from 'vitest';\n     2в†’import { BuildEngine, createDefaultTemplate, createListTemplate } from '../src/core/index.js';\n     3в†’import { ContentFile, Plugin, SiteConfig } from '../src/core/types.js';\n     4в†’\n     5в†’const testConfig: SiteConfig = {\n     6в†’  title: 'Test Site',\n     7в†’  baseUrl: 'https://example.com',\n     8в†’  outputDir: './dist',\n     9в†’  contentDir: './content',\n    10в†’  templateDir: './templates',\n    11в†’};\n    12в†’\n    13в†’function makeFile(overrides: Partial<ContentFile> = {}): ContentFile {\n    14в†’  return {\n    15в†’    slug: 'test-post',\n    16в†’    title: 'Test Post',\n    17в†’    content: '<p>Hello world</p>',\n    18в†’    metadata: {},\n    19в†’    ...overrides,\n    20в†’  };\n    21в†’}\n    22в†’\n    23в†’function makePlugin(overrides: Partial<Plugin> = {}): Plugin {\n    24в†’  return {\n    25в†’    name: 'test-plugin',\n    26в†’    version: '1.0.0',\n    27в†’    dependencies: [],\n    28в†’    hooks: {},\n    29в†’    ...overrides,\n    30в†’  };\n    31в†’}\n    32в†’\n    33в†’describe('BuildEngine', () => {\n    34в†’  it('registers plugins', () => {\n    35в†’    const engine = new BuildEngine(testConfig);\n    36в†’    const plugin = makePlugin({ name: 'my-plugin' });\n    37в†’    engine.registerPlugin(plugin);\n    38в†’    expect(engine.getPlugins()).toHaveLength(1);\n    39в†’    expect(engine.getPlugins()[0].name).toBe('my-plugin');\n    40в†’  });\n    41в†’\n    42в†’  it('registers templates', () => {\n    43в†’    const engine = new BuildEngine(testConfig);\n    44в†’    const template = createDefaultTemplate();\n    45в†’    engine.registerTemplate(template);\n    46в†’    expect(engine.getTemplates().has('default')).toBe(true);\n    47в†’  });\n    48в†’\n    49в†’  it('builds with default template and renders HTML', async () => {\n    50в†’    const engine = new BuildEngine(testConfig);\n    51в†’    engine.registerTemplate(createDefaultTemplate());\n    52в†’    const file = makeFile({ title: 'My Post', content: '<p>Content here</p>' });\n    53в†’    const ctx = await engine.build([file]);\n    54в†’    const output = ctx.output.get('test-post.html')!;\n    55в†’    expect(output).toContain('<!DOCTYPE html>');\n    56в†’    expect(output).toContain('My Post');\n    57в†’    expect(output).toContain('<p>Content here</p>');\n    58в†’    expect(output).toContain('Test Site');\n    59в†’  });\n    60в†’\n    61в†’  it('builds with list template and renders list HTML', async () => {\n    62в†’    const engine = new BuildEngine(testConfig);\n    63в†’    engine.registerTemplate(createListTemplate());\n    64в†’    const file = makeFile({ title: 'My List', content: '<ul><li>Item</li></ul>', template: 'list' });\n    65в†’    const ctx = await engine.build([file]);\n    66в†’    const output = ctx.output.get('test-post.html')!;\n    67в†’    expect(output).toContain('<!DOCTYPE html>');\n    68в†’    expect(output).toContain('My List');\n    69в†’    expect(output).toContain('<div class=\"list\">');\n    70в†’    expect(output).toContain('<ul><li>Item</li></ul>');\n    71в†’  });\n    72в†’\n    73в†’  it('outputs raw content when no matching template', async () => {\n    74в†’    const engine = new BuildEngine(testConfig);\n    75в†’    const file = makeFile({ content: '<p>Raw content</p>' });\n    76в†’    const ctx = await engine.build([file]);\n    77в†’    expect(ctx.output.get('test-post.html')).toBe('<p>Raw content</p>');\n    78в†’  });\n    79в†’\n    80в†’  it('calls plugin beforeBuild hook', async () => {\n    81в†’    const engine = new BuildEngine(testConfig);\n    82в†’    let called = false;\n    83в†’    engine.registerPlugin(makePlugin({\n    84в†’      hooks: {\n    85в†’        beforeBuild: () => { called = true; },\n    86в†’      },\n    87в†’    }));\n    88в†’    await engine.build([]);\n    89в†’    expect(called).toBe(true);\n    90в†’  });\n    91в†’\n    92в†’  it('calls plugin transformContent hook to transform files', async () => {\n    93в†’    const engine = new BuildEngine(testConfig);\n    94в†’    engine.registerPlugin(makePlugin({\n    95в†’      hooks: {\n    96в†’        transformContent: (file) => ({\n    97в†’          ...file,\n    98в†’          content: file.content.toUpperCase(),\n    99в†’        }),\n   100в†’      },\n   101в†’    }));\n   102в†’    const ctx = await engine.build([makeFile({ content: 'hello' })]);\n   103в†’    expect(ctx.files[0].content).toBe('HELLO');\n   104в†’  });\n   105в†’\n   106в†’  it('calls plugin afterBuild hook', async () => {\n   107в†’    const engine = new BuildEngine(testConfig);\n   108в†’    let called = false;\n   109в†’    engine.registerPlugin(makePlugin({\n   110в†’      hooks: {\n   111в†’        afterBuild: () => { called = true; },\n   112в†’      },\n   113в†’    }));\n   114в†’    await engine.build([]);\n   115в†’    expect(called).toBe(true);\n   116в†’  });\n   117в†’\n   118в†’  it('executes plugins in dependency order', () => {\n   119в†’    const engine = new BuildEngine(testConfig);\n   120в†’    engine.registerPlugin(makePlugin({ name: 'b', dependencies: ['a'] }));\n   121в†’    engine.registerPlugin(makePlugin({ name: 'a', dependencies: [] }));\n   122в†’    const order = engine.resolvePluginOrder();\n   123в†’    expect(order.map(p => p.name)).toEqual(['a', 'b']);\n   124в†’  });\n   125в†’\n   126в†’  it('throws on circular dependency', () => {\n   127в†’    const engine = new BuildEngine(testConfig);\n   128в†’    engine.registerPlugin(makePlugin({ name: 'a', dependencies: ['b'] }));\n   129в†’    engine.registerPlugin(makePlugin({ name: 'b', dependencies: ['a'] }));\n   130в†’    expect(() => engine.resolvePluginOrder()).toThrow('Circular dependency');\n   131в†’  });\n   132в†’\n   133в†’  it('throws on missing dependency', () => {\n   134в†’    const engine = new BuildEngine(testConfig);\n   135в†’    engine.registerPlugin(makePlugin({ name: 'a', dependencies: ['missing'] }));\n   136в†’    expect(() => engine.resolvePluginOrder()).toThrow('Missing dependency');\n   137в†’  });\n   138в†’\n   139в†’  it('applies multiple plugins transformContent in order', async () => {\n   140в†’    const engine = new BuildEngine(testConfig);\n   141в†’    engine.registerPlugin(makePlugin({\n   142в†’      name: 'first',\n   143в†’      hooks: {\n   144в†’        transformContent: (file) => ({\n   145в†’          ...file,\n   146в†’          content: file.content + ' [first]',\n   147в†’        }),\n   148в†’      },\n   149в†’    }));\n   150в†’    engine.registerPlugin(makePlugin({\n   151в†’      name: 'second',\n   152в†’      hooks: {\n   153в†’        transformContent: (file) => ({\n   154в†’          ...file,\n   155в†’          content: file.content + ' [second]',\n   156в†’        }),\n   157в†’      },\n   158в†’    }));\n   159в†’    const ctx = await engine.build([makeFile({ content: 'start' })]);\n   160в†’    expect(ctx.files[0].content).toBe('start [first] [second]');\n   161в†’  });\n   162в†’\n   163в†’  it('provides shared data store in build context', async () => {\n   164в†’    const engine = new BuildEngine(testConfig);\n   165в†’    engine.registerPlugin(makePlugin({\n   166в†’      hooks: {\n   167в†’        beforeBuild: (ctx) => { ctx.data.set('key', 'value'); },\n   168в†’      },\n   169в†’    }));\n   170в†’    const ctx = await engine.build([]);\n   171в†’    expect(ctx.data.get('key')).toBe('value');\n   172в†’  });\n   173в†’\n   174в†’  it('retains file metadata through build', async () => {\n   175в†’    const engine = new BuildEngine(testConfig);\n   176в†’    const file = makeFile({\n   177в†’      metadata: { author: 'Alice', category: 'tech' },\n   178в†’      date: '2024-01-01',\n   179в†’      tags: ['js', 'node'],\n   180в†’    });\n   181в†’    const ctx = await engine.build([file]);\n   182в†’    expect(ctx.files[0].metadata).toEqual({ author: 'Alice', category: 'tech' });\n   183в†’    expect(ctx.files[0].date).toBe('2024-01-01');\n   184в†’    expect(ctx.files[0].tags).toEqual(['js', 'node']);\n   185в†’  });\n   186в†’\n   187в†’  it('produces empty output for empty file list', async () => {\n   188в†’    const engine = new BuildEngine(testConfig);\n   189в†’    engine.registerTemplate(createDefaultTemplate());\n   190в†’    const ctx = await engine.build([]);\n   191в†’    expect(ctx.output.size).toBe(0);\n   192в†’    expect(ctx.files).toHaveLength(0);\n   193в†’  });\n   194в†’});\n   195в†’"}]},"parent_tool_use_id":"toolu_01SBLqtKP3cvyuEepzhxa7KL","session_id":"ce8f8a99-893f-45cd-8e7f-a152cbae183a","uuid":"02459022-3782-46f4-8fbe-0c4fe202eb59"}
