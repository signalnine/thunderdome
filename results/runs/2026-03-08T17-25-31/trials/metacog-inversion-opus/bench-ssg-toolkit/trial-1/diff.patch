--- /dev/null
+++ b/src/plugins/rss-feed.ts
@@ -0,0 +1,71 @@
+import { Plugin, BuildContext, ContentFile } from '../core/types.js';
+
+function escapeXml(str: string): string {
+  return str
+    .replace(/&/g, '&amp;')
+    .replace(/</g, '&lt;')
+    .replace(/>/g, '&gt;')
+    .replace(/"/g, '&quot;')
+    .replace(/'/g, '&apos;');
+}
+
+export function createRssFeedPlugin(): Plugin {
+  return {
+    name: 'rss-feed',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'taxonomy'],
+    hooks: {
+      afterBuild(ctx: BuildContext): void {
+        const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]> | undefined;
+
+        // Sort files by date (newest first), files without dates go to the end
+        const sortedFiles = [...ctx.files].sort((a, b) => {
+          if (!a.date && !b.date) return 0;
+          if (!a.date) return 1;
+          if (!b.date) return -1;
+          return new Date(b.date).getTime() - new Date(a.date).getTime();
+        });
+
+        const items = sortedFiles.map(file => {
+          // Build category tags from taxonomy
+          const categories: string[] = [];
+          if (file.tags && tagMap) {
+            for (const tag of file.tags) {
+              const normalized = tag.toLowerCase();
+              if (tagMap.has(normalized)) {
+                categories.push(normalized);
+              }
+            }
+          } else if (file.tags) {
+            categories.push(...file.tags);
+          }
+
+          const categoryTags = categories
+            .map(c => `      <category>${escapeXml(c)}</category>`)
+            .join('\n');
+
+          const pubDate = file.date ? `      <pubDate>${file.date}</pubDate>\n` : '';
+
+          return `    <item>
+      <title>${escapeXml(file.title)}</title>
+      <link>${ctx.config.baseUrl}/${file.slug}.html</link>
+${pubDate}      <description><![CDATA[${file.content}]]></description>
+${categoryTags}
+    </item>`;
+        }).join('\n');
+
+        const feed = `<?xml version="1.0" encoding="UTF-8"?>
+<rss version="2.0">
+  <channel>
+    <title>${escapeXml(ctx.config.title)}</title>
+    <link>${ctx.config.baseUrl}</link>
+    <description>${escapeXml(ctx.config.title)} RSS Feed</description>
+${items}
+  </channel>
+</rss>`;
+
+        ctx.output.set('feed.xml', feed);
+      },
+    },
+  };
+}
