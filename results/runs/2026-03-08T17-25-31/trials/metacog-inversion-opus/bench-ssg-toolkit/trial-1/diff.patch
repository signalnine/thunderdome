ml(file.title)}</title>\n      <link>${ctx.config.baseUrl}/${file.slug}.html</link>\n${pubDate}      <description><![CDATA[${file.content}]]></description>\n${categoryTags}\n    </item>`;\n        }).join('\\n');\n\n        const feed = `<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<rss version=\"2.0\">\n  <channel>\n    <title>${escapeXml(ctx.config.title)}</title>\n    <link>${ctx.config.baseUrl}</link>\n    <description>${escapeXml(ctx.config.title)} RSS Feed</description>\n${items}\n  </channel>\n</rss>`;\n\n        ctx.output.set('feed.xml', feed);\n      },\n    },\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":336,"cache_read_input_tokens":45522,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":336},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"ce8f8a99-893f-45cd-8e7f-a152cbae183a","uuid":"660388ca-7745-453d-8bc8-7113a0d6d7e8"}
