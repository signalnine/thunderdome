    47в†’    expect(result.content).toContain('<sup><a href=\"#fn-1\">1</a></sup>');\n    48в†’  });\n    49в†’\n    50в†’  it('renders footnote section at bottom of content', async () => {\n    51в†’    const file = makeFile({ content: 'Text[^1] and more[^2].\\n\\n[^1]: First note.\\n[^2]: Second note.' });\n    52в†’    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    53в†’    expect(result.content).toContain('<section class=\"footnotes\">');\n    54в†’    expect(result.content).toContain('<li id=\"fn-1\">First note.</li>');\n    55в†’    expect(result.content).toContain('<li id=\"fn-2\">Second note.</li>');\n    56в†’  });\n    57в†’\n    58в†’  it('converts :::note container to admonition div', async () => {\n    59в†’    const file = makeFile({ content: ':::note\\nThis is a note.\\n:::' });\n    60в†’    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    61в†’    expect(result.content).toContain('<div class=\"admonition admonition-note\">');\n    62в†’    expect(result.content).toContain('This is a note.');\n    63в†’  });\n    64в†’\n    65в†’  it('converts :::warning container to admonition div', async () => {\n    66в†’    const file = makeFile({ content: ':::warning\\nBe careful!\\n:::' });\n    67в†’    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    68в†’    expect(result.content).toContain('<div class=\"admonition admonition-warning\">');\n    69в†’    expect(result.content).toContain('Be careful!');\n    70в†’  });\n    71в†’\n    72в†’  it('converts :::tip container to admonition div', async () => {\n    73в†’    const file = makeFile({ content: ':::tip\\nHelpful hint.\\n:::' });\n    74в†’    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    75в†’    expect(result.content).toContain('<div class=\"admonition admonition-tip\">');\n    76в†’    expect(result.content).toContain('Helpful hint.');\n    77в†’  });\n    78в†’\n    79в†’  it('preserves existin