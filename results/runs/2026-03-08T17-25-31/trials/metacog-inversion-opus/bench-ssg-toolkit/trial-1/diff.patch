.hooks.transformContent!(file, ctx);\n    48в†’    expect(result.content).toContain('href=\"/assets/doc.pdf\"');\n    49в†’    expect(result.content).not.toContain('href=\"./doc.pdf\"');\n    50в†’  });\n    51в†’\n    52в†’  it('leaves absolute URLs unchanged', async () => {\n    53в†’    const file = makeFile({ content: '<img src=\"https://cdn.example.com/image.png\">' });\n    54в†’    const ctx = makeCtx();\n    55в†’    const result = await plugin.hooks.transformContent!(file, ctx);\n    56в†’    expect(result.content).toContain('src=\"https://cdn.example.com/image.png\"');\n    57в†’  });\n    58в†’\n    59в†’  it('generates asset manifest in ctx.data', async () => {\n    60в†’    const file = makeFile({ content: '<img src=\"./photo.jpg\">' });\n    61в†’    const ctx = makeCtx();\n    62в†’    await plugin.hooks.transformContent!(file, ctx);\n    63в†’    const manifest = ctx.data.get('asset-manifest') as { assets: string[] };\n    64в†’    expect(manifest).toBeDefined();\n    65в†’    expect(manifest.assets).toContain('photo.jpg');\n    66в†’  });\n    67в†’\n    68в†’  it('handles files with no asset references', async () => {\n    69в†’    const file = makeFile({ content: '<p>No assets here</p>' });\n    70в†’    const ctx = makeCtx();\n    71в†’    const result = await plugin.hooks.transformContent!(file, ctx);\n    72в†’    expect(result.content).toBe('<p>No assets here</p>');\n    73в†’  });\n    74в†’\n    75в†’  it('handles multiple assets in one file', async () => {\n    76в†’    const file = makeFile({\n    77в†’      content: '<img src=\"./a.png\"><img src=\"./b.jpg\"><a href=\"./c.pdf\">link</a>',\n    78в†’    });\n    79в†’    const ctx = makeCtx();\n    80в†’    await plugin.hooks.transformContent!(file, ctx);\n    81в†’    const manifest = ctx.data.get('asset-manifest') as { assets: string[] };\n    82в†’    expect(manifest.assets).toContain('a.png');\n    83в†’    expect(manifest.assets).toContain('b.jpg');\n    84в†’    expect(manifest.assets).toContain('c.pdf');\n    85в†’  });\n    86в†’\n    87в†’  it('asset manifest includes all discovered assets', async () => {\n    88в†’    const ctx = makeCtx();\n    89в†’    const file1 = makeFile({ content: '<img src=\"./one.png\">' });\n    90в†’    const file2 = makeFile({ content: '<img src=\"./two.png\">' });\n    91в†’    await plugin.hooks.transformContent!(file1, ctx);\n    92в†’    await plugin.hooks.transformContent!(file2, ctx);\n    93в†’    const manifest = ctx.data.get('asset-manifest') as { assets: string[] };\n    94в†’    expect(manifest.assets).toHaveLength(2);\n    95в†’    expect(manifest.assets).toContain('one.png');\n    96в†’    expect(manifest.assets).toContain('two.png');\n    97в†’  });\n    98в†’\n    99в†’  it('does not double-process already-rewritten URLs', async () => {\n   100в†’    const file = makeFile({ content: '<img src=\"/assets/image.png\">' });\n   101в†’    const ctx = makeCtx();\n   102в†’    const result = await plugin.hooks.transformContent!(file, ctx);\n   103в†’    expect(result.content).toBe('<img src=\"/assets/image.png\">');\n   104в†’    const manifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;\n   105в†’    expect(!manifest || manifest.assets.length === 0).toBe(true);\n   106в†’  });\n   107в†’});\n   108в†’"}]},"parent_tool_use_id":"toolu_01SBLqtKP3cvyuEepzhxa7KL","session_id":"ce8f8a99-893f-45cd-8e7f-a152cbae183a","uuid":"c97d10ed-0a0e-40f0-897b-fdf8acb2eb4f"}
