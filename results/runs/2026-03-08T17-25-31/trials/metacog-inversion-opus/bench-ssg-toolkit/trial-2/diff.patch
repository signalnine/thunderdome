      slug: 'post-1',\n    52→        title: 'Post 1',\n    53→        content: '<p>This is <strong>HTML</strong> content</p>',\n    54→        date: '2024-01-01',\n    55→      }),\n    56→    ];\n    57→    const ctx = makeCtx(files);\n    58→    await plugin.hooks.afterBuild!(ctx);\n    59→    const feed = ctx.output.get('feed.xml')!;\n    60→    expect(feed).toContain('<![CDATA[<p>This is <strong>HTML</strong> content</p>]]>');\n    61→  });\n    62→\n    63→  it('feed items include category tags from taxonomy', async () => {\n    64→    const files = [\n    65→      makeFile({ slug: 'post-1', title: 'Post 1', tags: ['javascript'], date: '2024-01-01' }),\n    66→    ];\n    67→    const tagMap = new Map<string, ContentFile[]>();\n    68→    tagMap.set('javascript', [files[0]]);\n    69→    const data = new Map<string, unknown>();\n    70→    data.set('taxonomy-tags', tagMap);\n    71→    const ctx = makeCtx(files, data);\n    72→    await plugin.hooks.afterBuild!(ctx);\n    73→    const feed = ctx.output.get('feed.xml')!;\n    74→    expect(feed).toContain('<category>javascript</category>');\n    75→  });\n    76→\n    77→  it('feed includes channel title from config', async () => {\n    78→    const files = [makeFile({ slug: 'post-1', title: 'Post 1' })];\n    79→    const ctx = makeCtx(files);\n    80→    await plugin.hooks.afterBuild!(ctx);\n    81→    const feed = ctx.output.get('feed.xml')!;\n    82→    expect(feed).toContain('<title>Test Site</title>');\n    83→  });\n    84→\n    85→  it('feed items sorted by date newest first', async () => {\n    86→    const files = [\n    87→      makeFile({ slug: 'old', title: 'Old Post', date: '2023-01-01' }),\n    88→      makeFile({ slug: 'new', title: 'New Post', date: '2024-06-15' }),\n    89→      makeFile({ slug: 'mid', title: 'Mid Post', date: '2024-01-01' }),\n    90→    ];\n    91→    const ctx = makeCtx(files);\n    92→    await plugin.hooks.afterBuild!(ctx);\n    93→    const feed = ctx.output.get('feed.xml')!;\n    94→    const newIdx = feed.indexOf('New Post');\n    95→    const midIdx = feed.indexOf('Mid Post');\n    96→    const oldIdx = feed.indexOf('Old Post');\n    97→    expect(newIdx).toBeLessThan(midIdx);\n    98→    expect(midIdx).toBeLessThan(oldIdx);\n    99→  });\n   100→\n   101→  it('handles files without dates', async () => {\n   102→    const files = [\n   103→      makeFile({ slug: 'no-date', title: 'No Date Post', content: '<p>No date</p>' }),\n   104→    ];\n   105→    const ctx = makeCtx(files);\n   106→    await plugin.hooks.afterBuild!(ctx);\n   107→    const feed = ctx.output.get('feed.xml')!;\n   108→    expect(feed).toContain('No Date Post');\n   109→    expect(feed).not.toContain('<pubDate>undefined</pubDate>');\n   110→  });\n   111→\n   112→  it('feed link uses baseUrl from config', async () => {\n   113→    const files = [makeFile({ slug: 'post-1', title: 'Post 1' })];\n   114→    const ctx = makeCtx(files);\n   115→    await plugin.hooks.afterBuild!(ctx);\n   116→    const feed = ctx.output.get('feed.xml')!;\n   117→    expect(feed).toContain('<link>https://example.com</link>');\n   118→    expect(feed).toContain('<link>https://example.com/post-1.html</link>');\n   119→  });\n   120→});\n   121→"}]},"parent_tool_use_id":"toolu_01GKM8t4NjZqLGZyZWFYCka5","session_id":"9fa1e8db-a52d-4916-99b5-248fa7fdfbc6","uuid":"1258338a-a685-4540-a78a-6279e802fffc"}
