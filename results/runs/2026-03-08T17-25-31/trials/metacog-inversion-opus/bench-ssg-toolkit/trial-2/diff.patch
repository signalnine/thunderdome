+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0196PLNMBVJBAvGjrzMszphN","type":"tool_result","content":"     1→import { describe, it, expect } from 'vitest';\n     2→import { createDevServerPlugin } from '../../src/plugins/dev-server.js';\n     3→import { BuildContext, SiteConfig } from '../../src/core/types.js';\n     4→\n     5→const testConfig: SiteConfig = {\n     6→  title: 'Test Site',\n     7→  baseUrl: 'https://example.com',\n     8→  outputDir: './dist',\n     9→  contentDir: './content',\n    10→  templateDir: './templates',\n    11→};\n    12→\n    13→interface DevServerConfig {\n    14→  port: number;\n    15→  routes: Array<{ path: string; handler: string }>;\n    16→  assetPaths: string[];\n    17→  searchIndexPath: string;\n    18→}\n    19→\n    20→function makeCtx(\n    21→  output?: Map<string, string>,\n    22→  data?: Map<string, unknown>\n    23→): BuildContext {\n    24→  return {\n    25→    config: testConfig,\n    26→    files: [],\n    27→    output: output || new Map(),\n    28→    assets: new Map(),\n    29→    data: data || new Map(),\n    30→  };\n    31→}\n    32→\n    33→describe('dev-server plugin', () => {\n    34→  const plugin = createDevServerPlugin();\n    35→\n    36→  it('stores dev-server-config in ctx.data', async () => {\n    37→    const ctx = makeCtx();\n    38→    await plugin.hooks.afterBuild!(ctx);\n    39→    expect(ctx.data.has('dev-server-config')).toBe(true);\n    40→  });\n    41→\n    42→  it('config includes port setting', async () => {\n    43→    const ctx = makeCtx();\n    44→    await plugin.hooks.afterBuild!(ctx);\n    45→    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    46→    expect(config.port).toBeDefined();\n    47→    expect(typeof config.port).toBe('number');\n    48→  });\n    49→\n    50→  it('config includes asset routes from asset-pipeline', async () => {\n    51→    const data = new Map<string, unknown>();\n    52→    data.set('asset-manifest', { assets: ['image.png', 'style.css'] });\n    53→    const ctx = makeCtx(new Map(), data);\n    54→    await plugin.hooks.afterBuild!(ctx);\n    55→    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    56→    expect(config.assetPaths).toContain('image.png');\n    57→    expect(config.assetPaths).toContain('style.css');\n    58→    const assetRoutes = config.routes.filter(r => r.handler === 'asset');\n    59→    expect(assetRoutes.length).toBeGreaterThanOrEqual(2);\n    60→  });\n    61→\n    62→  it('config includes search index path', async () => {\n    63→    const output = new Map<string, string>();\n    64→    output.set('search-index.json', '[]');\n    65→    const ctx = makeCtx(output);\n    66→    await plugin.hooks.afterBuild!(ctx);\n    67→    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    68→    expect(config.searchIndexPath).toBe('/search-index.json');\n    69→  });\n    70→\n    71→  it('config includes content routes', async () => {\n    72→    const output = new Map<string, string>();\n    73→    output.set('post-1.html', '<html></html>');\n    74→    output.set('post-2.html', '<html></html>');\n    75→    const ctx = makeCtx(output);\n    76→    await plugin.hooks.afterBuild!(ctx);\n    77→    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    78→    const contentRoutes = config.routes.filter(r => r.handler === 'static');\n    79→    expect(contentRoutes.length).toBe(2);\n    80→  });\n    81→\n    82→  it('default port is 3000', async () => {\n    83→    const ctx = makeCtx();\n    84→    await plugin.hooks.afterBuild!(ctx);\n    85→    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    86→    expect(config.port).toBe(3000);\n    87→  });\n    88→\n    89→  it('handles missing asset-pipeline data gracefully', async () => {\n    90→    const ctx = makeCtx();\n    91→    await plugin.hooks.afterBuild!(ctx);\n    92→    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    93→    expect(config.assetPaths).toEqual([]);\n    94→  });\n    95→});\n    96→"}]},"parent_tool_use_id":"toolu_01GKM8t4NjZqLGZyZWFYCka5","session_id":"9fa1e8db-a52d-4916-99b5-248fa7fdfbc6","uuid":"5dc30dfb-7145-465e-8276-dd8df1f56e60"}
