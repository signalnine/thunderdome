@@ -0,0 +1,140 @@
+// Direction of beam travel
+const enum Dir {
+  Down = 0,
+  DownLeft = 1,
+  DownRight = 2,
+}
+
+function findSource(grid: string[][]): [number, number] {
+  for (let c = 0; c < grid[0].length; c++) {
+    if (grid[0][c] === "S") return [0, c];
+  }
+  throw new Error("No source found");
+}
+
+function nextPos(row: number, col: number, dir: Dir): [number, number] {
+  switch (dir) {
+    case Dir.Down:
+      return [row + 1, col];
+    case Dir.DownLeft:
+      return [row + 1, col - 1];
+    case Dir.DownRight:
+      return [row + 1, col + 1];
+  }
+}
+
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+/**
+ * Count the number of distinct cells visited by any beam.
+ * Uses state deduplication to avoid exponential blowup.
+ */
+export function countBeamCells(grid: string[][]): number {
+  if (grid.length === 0 || grid[0].length === 0) return 0;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const [sr, sc] = findSource(grid);
+
+  const visitedCells = new Set<number>();
+  const encodeCell = (r: number, c: number) => r * cols + c;
+  const encodeState = (r: number, c: number, d: Dir) => r * cols * 3 + c * 3 + d;
+
+  visitedCells.add(encodeCell(sr, sc));
+
+  // Track unique beam states to avoid exponential duplication
+  const seenStates = new Set<number>();
+  const startState = encodeState(sr, sc, Dir.Down);
+  seenStates.add(startState);
+
+  let current = [startState];
+
+  while (current.length > 0) {
+    const next: number[] = [];
+
+    for (const state of current) {
+      const dir = state % 3;
+      const rest = (state - dir) / 3;
+      const col = rest % cols;
+      const row = (rest - col) / cols;
+
+      const [nr, nc] = nextPos(row, col, dir as Dir);
+
+      if (!inBounds(nr, nc, rows, cols)) continue;
+
+      visitedCells.add(encodeCell(nr, nc));
+
+      if (grid[nr][nc] === "^") {
+        const sl = encodeState(nr, nc, Dir.DownLeft);
+        const sr2 = encodeState(nr, nc, Dir.DownRight);
+        if (!seenStates.has(sl)) { seenStates.add(sl); next.push(sl); }
+        if (!seenStates.has(sr2)) { seenStates.add(sr2); next.push(sr2); }
+      } else {
+        const ns = encodeState(nr, nc, dir as Dir);
+        if (!seenStates.has(ns)) { seenStates.add(ns); next.push(ns); }
+      }
+    }
+
+    current = next;
+  }
+
+  return visitedCells.size;
+}
+
+/**
+ * Count total distinct source-to-exit paths.
+ * Uses beam multiplicity tracking to avoid exponential enumeration.
+ */
+export function countBeamPaths(grid: string[][]): bigint {
+  if (grid.length === 0 || grid[0].length === 0) return 0n;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const [sr, sc] = findSource(grid);
+
+  // Track count of beams at each (row, col, dir) state
+  // Key: row * cols * 3 + col * 3 + dir
+  const encode = (r: number, c: number, d: Dir) => r * cols * 3 + c * 3 + d;
+
+  let current = new Map<number, bigint>();
+  current.set(encode(sr, sc, Dir.Down), 1n);
+
+  let totalPaths = 0n;
+
+  while (current.size > 0) {
+    const next = new Map<number, bigint>();
+
+    for (const [key, count] of current) {
+      const dir = key % 3;
+      const rest = (key - dir) / 3;
+      const col = rest % cols;
+      const row = (rest - col) / cols;
+
+      const [nr, nc] = nextPos(row, col, dir as Dir);
+
+      if (!inBounds(nr, nc, rows, cols)) {
+        // Beam exits grid — these are completed paths
+        totalPaths += count;
+        continue;
+      }
+
+      if (grid[nr][nc] === "^") {
+        // Splitter: each beam becomes two beams
+        const keyL = encode(nr, nc, Dir.DownLeft);
+        const keyR = encode(nr, nc, Dir.DownRight);
+        next.set(keyL, (next.get(keyL) ?? 0n) + count);
+        next.set(keyR, (next.get(keyR) ?? 0n) + count);
+      } else {
+        // Continue in same direction
+        const nk = encode(nr, nc, dir as Dir);
+        next.set(nk, (next.get(nk) ?? 0n) + count);
+      }
+    }
+
+    current = next;
+  }
+
+  return totalPaths;
+}
