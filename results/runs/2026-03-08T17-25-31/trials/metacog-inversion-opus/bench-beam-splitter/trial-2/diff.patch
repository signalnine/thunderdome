+// Direction enum: 0 = down, 1 = down-left, 2 = down-right
+const DOWN = 0;
+const DOWN_LEFT = 1;
+const DOWN_RIGHT = 2;
+
+type Direction = typeof DOWN | typeof DOWN_LEFT | typeof DOWN_RIGHT;
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+function nextPos(row: number, col: number, dir: Direction): [number, number] {
+  switch (dir) {
+    case DOWN:
+      return [row + 1, col];
+    case DOWN_LEFT:
+      return [row + 1, col - 1];
+    case DOWN_RIGHT:
+      return [row + 1, col + 1];
+  }
+}
+
+function findSource(grid: string[][]): [number, number] | null {
+  for (let c = 0; c < grid[0].length; c++) {
+    if (grid[0][c] === 'S') {
+      return [0, c];
+    }
+  }
+  return null;
+}
+
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  if (rows === 0) return 0;
+  const cols = grid[0].length;
+
+  const source = findSource(grid);
+  if (!source) return 0;
+
+  const visited = new Set<string>();
+  // Track (row, col, dir) to avoid infinite processing of same beam state
+  const seen = new Set<string>();
+
+  const beams: Beam[] = [{ row: source[0], col: source[1], dir: DOWN }];
+  visited.add(`${source[0]},${source[1]}`);
+  seen.add(`${source[0]},${source[1]},${DOWN}`);
+
+  while (beams.length > 0) {
+    const beam = beams.pop()!;
+    const { row, col, dir } = beam;
+    const cell = grid[row][col];
+
+    if (cell === '^') {
+      // Splitter: produce two diagonal beams
+      const dirs: Direction[] = [DOWN_LEFT, DOWN_RIGHT];
+      for (const newDir of dirs) {
+        const [nr, nc] = nextPos(row, col, newDir);
+        if (inBounds(nr, nc, rows, cols)) {
+          const key = `${nr},${nc},${newDir}`;
+          if (!seen.has(key)) {
+            seen.add(key);
+            visited.add(`${nr},${nc}`);
+            beams.push({ row: nr, col: nc, dir: newDir });
+          }
+        }
+      }
+    } else {
+      // Continue in current direction
+      const [nr, nc] = nextPos(row, col, dir);
+      if (inBounds(nr, nc, rows, cols)) {
+        const key = `${nr},${nc},${dir}`;
+        if (!seen.has(key)) {
+          seen.add(key);
+          visited.add(`${nr},${nc}`);
+          beams.push({ row: nr, col: nc, dir: dir });
+        }
+      }
+    }
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  if (rows === 0) return 0n;
+  const cols = grid[0].length;
+
+  const source = findSource(grid);
+  if (!source) return 0n;
+
+  // Use BFS-like approach but aggregate path counts per (row, col, dir)
+  // Process row by row to ensure we handle merging correctly
+  // Map from "row,col,dir" -> accumulated path count
+  const statePaths = new Map<string, bigint>();
+  const startKey = `${source[0]},${source[1]},${DOWN}`;
+  statePaths.set(startKey, 1n);
+
+  let totalPaths = 0n;
+
+  // Process states row by row (top to bottom) to ensure correct ordering
+  for (let row = 0; row < rows; row++) {
+    for (let col = 0; col < cols; col++) {
+      for (let dir = 0; dir <= 2; dir++) {
+        const key = `${row},${col},${dir}`;
+        const paths = statePaths.get(key);
+        if (!paths) continue;
+
+        const cell = grid[row][col];
+
+        if (cell === '^') {
+          // Splitter: produce two diagonal beams
+          const dirs: Direction[] = [DOWN_LEFT, DOWN_RIGHT];
+          for (const newDir of dirs) {
+            const [nr, nc] = nextPos(row, col, newDir);
+            if (inBounds(nr, nc, rows, cols)) {
+              const nkey = `${nr},${nc},${newDir}`;
+              statePaths.set(nkey, (statePaths.get(nkey) ?? 0n) + paths);
+            } else {
+              totalPaths += paths;
+            }
+          }
+        } else {
+          // Continue in current direction
+          const [nr, nc] = nextPos(row, col, dir as Direction);
+          if (inBounds(nr, nc, rows, cols)) {
+            const nkey = `${nr},${nc},${dir}`;
+            statePaths.set(nkey, (statePaths.get(nkey) ?? 0n) + paths);
+          } else {
+            totalPaths += paths;
+          }
+        }
+      }
+    }
+  }
+
+  return totalPaths;
+}
