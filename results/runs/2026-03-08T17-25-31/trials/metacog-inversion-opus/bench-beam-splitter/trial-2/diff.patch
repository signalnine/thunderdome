nst dirs: Direction[] = [DOWN_LEFT, DOWN_RIGHT];\n          for (const newDir of dirs) {\n            const [nr, nc] = nextPos(row, col, newDir);\n            if (inBounds(nr, nc, rows, cols)) {\n              const nkey = `${nr},${nc},${newDir}`;\n              statePaths.set(nkey, (statePaths.get(nkey) ?? 0n) + paths);\n            } else {\n              totalPaths += paths;\n            }\n          }\n        } else {\n          // Continue in current direction\n          const [nr, nc] = nextPos(row, col, dir as Direction);\n          if (inBounds(nr, nc, rows, cols)) {\n            const nkey = `${nr},${nc},${dir}`;\n            statePaths.set(nkey, (statePaths.get(nkey) ?? 0n) + paths);\n          } else {\n            totalPaths += paths;\n          }\n        }\n      }\n    }\n  }\n\n  return totalPaths;\n}\n","structuredPatch":[],"originalFile":null}}
