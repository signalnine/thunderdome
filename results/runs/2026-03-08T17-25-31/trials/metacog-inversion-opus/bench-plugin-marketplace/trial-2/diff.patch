  });\n\n  it('should throw when updating a nonexistent plugin', () => {\n    expect(() => registry.update('nope', '1.0.0', {})).toThrow();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":128,"cache_read_input_tokens":28890,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":128},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"c8c9a8b0-c758-43b9-94aa-9b487995fe2f","uuid":"5687d5c5-0f98-4c01-a1fe-ba7741d741ff"}
