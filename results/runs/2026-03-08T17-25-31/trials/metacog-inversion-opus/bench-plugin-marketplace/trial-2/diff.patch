+  it('should reject invalid ratings', () => {
+    expect(() =>
+      reviews.addReview({
+        pluginName: 'test', pluginVersion: '1.0.0', userId: 'u', rating: 0, comment: 'bad',
+      })
+    ).toThrow();
+    expect(() =>
+      reviews.addReview({
+        pluginName: 'test', pluginVersion: '1.0.0', userId: 'u', rating: 6, comment: 'bad',
+      })
+    ).toThrow();
+  });
+
+  it('should get reviews for a plugin', () => {
+    reviews.addReview({
+      pluginName: 'a', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'great',
+    });
+    reviews.addReview({
+      pluginName: 'b', pluginVersion: '1.0.0', userId: 'u1', rating: 3, comment: 'ok',
+    });
+    reviews.addReview({
+      pluginName: 'a', pluginVersion: '2.0.0', userId: 'u2', rating: 4, comment: 'nice',
+    });
+
+    const aReviews = reviews.getReviews('a');
+    expect(aReviews).toHaveLength(2);
+  });
+
+  it('should compute average rating excluding flagged reviews', () => {
+    reviews.addReview({
+      pluginName: 'a', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'great',
+    });
+    reviews.addReview({
+      pluginName: 'a', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: 'ok',
+    });
+    // Average should be 4
+    expect(reviews.getAverageRating('a')).toBe(4);
+
+    // Flag one review
+    const allReviews = reviews.getReviews('a');
+    reviews.flagReview(allReviews[1].id); // flag the rating=3 review
+
+    // Now average should be 5 (only unflagged)
+    expect(reviews.getAverageRating('a')).toBe(5);
+  });
+
+  it('should return 0 average when no reviews', () => {
+    expect(reviews.getAverageRating('nonexistent')).toBe(0);
+  });
+
+  it('should flag a review', () => {
+    const review = reviews.addReview({
+      pluginName: 'a', pluginVersion: '1.0.0', userId: 'u1', rating: 1, comment: 'spam',
+    });
+    reviews.flagReview(review.id);
+    const flagged = reviews.getFlaggedReviews();
+    expect(flagged).toHaveLength(1);
+    expect(flagged[0].id).toBe(review.id);
+  });
+
+  it('should throw when flagging nonexistent review', () => {
+    expect(() => reviews.flagReview(999)).toThrow();
+  });
+
+  it('should remove a review', () => {
+    const review = reviews.addReview({
+      pluginName: 'a', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'great',
+    });
+    expect(reviews.removeReview(review.id)).toBe(true);
+    expect(reviews.getReviews('a')).toHaveLength(0);
+  });
+
+  it('should return false when removing nonexistent review', () => {
+    expect(reviews.removeReview(999)).toBe(false);
+  });
+
+  it('should get reviews by user', () => {
+    reviews.addReview({
+      pluginName: 'a', pluginVersion: '1.0.0', userId: 'user1', rating: 5, comment: 'great',
+    });
+    reviews.addReview({
+      pluginName: 'b', pluginVersion: '1.0.0', userId: 'user2', rating: 3, comment: 'ok',
+    });
+    reviews.addReview({
+      pluginName: 'c', pluginVersion: '1.0.0', userId: 'user1', rating: 4, comment: 'nice',
+    });
+
+    const userReviews = reviews.getReviewsByUser('user1');
+    expect(userReviews).toHaveLength(2);
+  });
+
+  it('should get review count', () => {
+    reviews.addReview({
+      pluginName: 'a', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'great',
+    });
+    reviews.addReview({
+      pluginName: 'a', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: 'ok',
+    });
+    expect(reviews.getReviewCount('a')).toBe(2);
+    expect(reviews.getReviewCount('b')).toBe(0);
+  });
+});
