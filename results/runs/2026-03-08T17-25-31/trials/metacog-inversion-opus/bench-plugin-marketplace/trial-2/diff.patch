+  it('should auto-increment review ids', () => {
+    const r1 = reviews.addReview({
+      pluginName: 'a', pluginVersion: '1.0.0', userId: 'u1', rating: 3, comment: 'ok',
+    });
+    const r2 = reviews.addReview({
+      pluginName: 'b', pluginVersion: '1.0.0', userId: 'u2', rating: 4, comment: 'good',
+    });
