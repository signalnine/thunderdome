' }),\n    );\n    marketplace.registry.register(\n      makeManifest({ name: 'dep-a', version: '1.5.0', entryPoint: '\"dep\"' }),\n    );\n\n    const manifest = makeManifest({\n      dependencies: { 'dep-a': '^1.0.0' },\n      entryPoint: '\"installed\"',\n    });\n\n    const result = await marketplace.installPlugin(manifest);\n\n    expect(result.executionResult.success).toBe(true);\n    expect(result.resolvedDependencies.length).toBe(1);\n    expect(result.resolvedDependencies[0].name).toBe('dep-a');\n    expect(result.resolvedDependencies[0].version).toBe('1.5.0');\n  });\n\n  it('should reject plugin without name', async () => {\n    const manifest = makeManifest({ name: '' });\n    await expect(marketplace.installPlugin(manifest)).rejects.toThrow('name');\n  });\n\n  it('should reject plugin without version', async () => {\n    const manifest = makeManifest({ version: '' });\n    await expect(marketplace.installPlugin(manifest)).rejects.toThrow('version');\n  });\n\n  it('should reject plugin without entryPoint', async () => {\n    const manifest = makeManifest({ entryPoint: '' });\n    await expect(marketplace.installPlugin(manifest)).rejects.toThrow(\n      'entryPoint',\n    );\n  });\n\n  it('should reject plugins with circular dependencies', async () => {\n    marketplace.registry.register(\n      makeManifest({\n        name: 'circular-b',\n        dependencies: { 'circular-a': '^1.0.0' },\n      }),\n    );\n\n    const manifest = makeManifest({\n      name: 'circular-a',\n      dependencies: { 'circular-b': '^1.0.0' },\n    });\n\n    await expect(marketplace.installPlugin(manifest)).rejects.toThrow(\n      'Circular dependency',\n    );\n\n    // Plugin should be removed from registry after rejection\n    expect(marketplace.registry.get('circular-a')).toBeNull();\n  });\n\n  it('should handle failed sandbox execution', async () => {\n    const manifest = makeManifest({\n      entryPoint: 'throw new Error(\"crash\")',\n    });\n    const result = await marketplace.installPlugin(manifest);\n    expect(result.executionResult.success).toBe(false);\n    expect(result.executionResult.error).toBe('crash');\n  });\n\n  it('should support the full lifecycle: install, review, search', async () => {\n    // Install\n    const manifest = makeManifest({\n      name: 'lifecycle-plugin',\n      description: 'A lifecycle test plugin',\n      entryPoint: '\"lifecycle\"',\n    });\n    await marketplace.installPlugin(manifest);\n\n    // Add reviews\n    marketplace.reviews.addReview({\n      pluginName: 'lifecycle-plugin',\n      pluginVersion: '1.0.0',\n      userId: 'user1',\n      rating: 5,\n      comment: 'Excellent!',\n    });\n    marketplace.reviews.addReview({\n      pluginName: 'lifecycle-plugin',\n      pluginVersion: '1.0.0',\n      userId: 'user2',\n      rating: 4,\n      comment: 'Pretty good',\n    });\n\n    // Check ratings\n    expect(marketplace.reviews.getAverageRating('lifecycle-plugin')).toBe(4.5);\n\n    // Search\n    const results = marketplace.registry.search('lifecycle');\n    expect(results.length).toBe(1);\n    expect(results[0].name).toBe('lifecycle-plugin');\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":272,"cache_read_input_tokens":27935,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":272},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"ae926c4f-ac0b-4d03-a3d3-4db5b827b4bf","uuid":"9b7e7a79-b1a6-4953-bde6-8d82cd6811be"}
