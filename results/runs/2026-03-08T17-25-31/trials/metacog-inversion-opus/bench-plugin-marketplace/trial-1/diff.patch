er.satisfies('1.5.0', '^1.0.0')).toBe(true);\n    });\n\n    it('should return false for non-matching version', () => {\n      expect(resolver.satisfies('2.0.0', '^1.0.0')).toBe(false);\n    });\n  });\n\n  describe('maxSatisfying', () => {\n    it('should return the best matching version', () => {\n      const result = resolver.maxSatisfying(\n        ['1.0.0', '1.5.0', '2.0.0'],\n        '^1.0.0',\n      );\n      expect(result).toBe('1.5.0');\n    });\n\n    it('should return null when no version matches', () => {\n      const result = resolver.maxSatisfying(\n        ['1.0.0', '2.0.0'],\n        '^3.0.0',\n      );\n      expect(result).toBeNull();\n    });\n  });\n\n  describe('validRange', () => {\n    it('should return true for valid ranges', () => {\n      expect(resolver.validRange('^1.0.0')).toBe(true);\n      expect(resolver.validRange('~2.0.0')).toBe(true);\n      expect(resolver.validRange('>=1.0.0 <2.0.0')).toBe(true);\n    });\n\n    it('should return false for invalid ranges', () => {\n      expect(resolver.validRange('not-a-range')).toBe(false);\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":272,"cache_read_input_tokens":27935,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":272},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"ae926c4f-ac0b-4d03-a3d3-4db5b827b4bf","uuid":"2c9f6ce4-ce71-4319-91df-b764da756150"}
