  beforeEach(() => {\n    bus = new EventBus();\n    inventory = createInventoryService(bus);\n  });\n\n  it('should set and get stock', () => {\n    inventory.setStock('p1', 100);\n    expect(inventory.getStock('p1')).toBe(100);\n  });\n\n  it('should return 0 for unknown product', () => {\n    expect(inventory.getStock('unknown')).toBe(0);\n  });\n\n  it('should reserve stock successfully', () => {\n    inventory.setStock('p1', 10);\n    expect(inventory.reserve('p1', 5)).toBe(true);\n    expect(inventory.getStock('p1')).toBe(5);\n  });\n\n  it('should fail to reserve more than available', () => {\n    inventory.setStock('p1', 5);\n    expect(inventory.reserve('p1', 10)).toBe(false);\n  });\n\n  it('should release reserved stock', () => {\n    inventory.setStock('p1', 10);\n    inventory.reserve('p1', 5);\n    inventory.release('p1', 3);\n    expect(inventory.getStock('p1')).toBe(8);\n  });\n\n  it('should emit low stock alert', async () => {\n    inventory.setLowStockThreshold('p1', 5);\n    inventory.setStock('p1', 3);\n    await new Promise(r => setTimeout(r, 10));\n    const log = bus.getLog();\n    const alerts = log.filter(e => e.event === Events.LOW_STOCK_ALERT);\n    expect(alerts.length).toBeGreaterThan(0);\n  });\n});\n\ndescribe('Cart Service', () => {\n  let bus: EventBus;\n  let cart: ReturnType<typeof createCartService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    cart = createCartService(bus);\n  });\n\n  it('should create a cart', () => {\n    const cartId = cart.createCart('user1');\n    expect(cartId).toBeDefined();\n    const c = cart.getCart(cartId);\n    expect(c).toBeDefined();\n    expect(c!.userId).toBe('user1');\n    expect(c!.items).toEqual([]);\n  });\n\n  it('should add items to cart', () => {\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 2);\n    const c = cart.getCart(cartId);\n    expect(c!.items).toHaveLength(1);\n    expect(c!.items[0]).toEqual({ productId: 'p1', quantity: 2 });\n  });\n\n  it('should consolidate duplicate items', () => {\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 2);\n    cart.addItem(cartId, 'p1', 3);\n    const c = cart.getCart(cartId);\n    expect(c!.items).toHaveLength(1);\n    expect(c!.items[0].quantity).toBe(5);\n  });\n\n  it('should remove items', () => {\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 2);\n    cart.addItem(cartId, 'p2', 1);\n    cart.removeItem(cartId, 'p1');\n    const c = cart.getCart(cartId);\n    expect(c!.items).toHaveLength(1);\n    expect(c!.items[0].productId).toBe('p2');\n  });\n\n  it('should update quantity', () => {\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 2);\n    cart.updateQuantity(cartId, 'p1', 5);\n    const c = cart.getCart(cartId);\n    expect(c!.items[0].quantity).toBe(5);\n  });\n\n  it('should clear cart', () => {\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 2);\n    cart.clearCart(cartId);\n    const c = cart.getCart(cartId);\n    expect(c!.items).toEqual([]);\n  });\n\n  it('should return null for non-existent cart', () => {\n    expect(cart.getCart('nonexistent')).toBeNull();\n  });\n});\n\ndescribe('Pricing Service', () => {\n  let bus: EventBus;\n  let pricing: ReturnType<typeof createPricingService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    pricing = createPricingService(bus);\n  });\n\n  it('should calculate total with tax', () => {\n    const result = pricing.calculateTotal([\n      { productId: 'p1', quantity: 2, price: 10 },\n    ]);\n    expect(result.subtotal).toBe(20);\n    expect(result.discount).toBe(0);\n    expect(result.tax).toBe(2);\n    expect(result.total).toBe(22);\n  });\n\n  it('should apply discount code', () => {\n    pricing.addDiscountCode('SAVE10', 10);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'SAVE10',\n    );\n    expect(result.subtotal).toBe(100);\n    expect(result.discount).toBe(10);\n    expect(result.tax).toBe(9);\n    expect(result.total).toBe(99);\n  });\n\n  it('should ignore invalid discount code', () => {\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'INVALID',\n    );\n    expect(result.discount).toBe(0);\n    expect(result.total).toBe(110);\n  });\n\n  it('should track product prices from events', async () => {\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'Widget', price: 9.99, category: 'gadgets' });\n    expect(pricing.getPrice('p1')).toBe(9.99);\n  });\n\n  it('should return 0 for unknown product price', () => {\n    expect(pricing.getPrice('unknown')).toBe(0);\n  });\n});\n\ndescribe('Order Service', () => {\n  let bus: EventBus;\n  let orders: ReturnType<typeof createOrderService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    orders = createOrderService(bus);\n  });\n\n  it('should create an order in pending state', () => {\n    const orderId = orders.createOrder('user1', 'cart1', 99.99);\n    const order = orders.getOrder(orderId);\n    expect(order).toBeDefined();\n    expect(order!.status).toBe(OrderStatus.PENDING);\n    expect(order!.total).toBe(99.99);\n    expect(order!.userId).toBe('user1');\n  });\n\n  it('should update order status', () => {\n    const orderId = orders.createOrder('user1', 'cart1', 99.99);\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    expect(orders.getOrder(orderId)!.status).toBe(OrderStatus.CONFIRMED);\n  });\n\n  it('should emit order created event', async () => {\n    orders.createOrder('user1', 'cart1', 99.99);\n    await new Promise(r => setTimeout(r, 10));\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.ORDER_CREATED)).toBe(true);\n  });\n\n  it('should emit order status changed event with previous status', async () => {\n    const orderId = orders.createOrder('user1', 'cart1', 99.99);\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    await new Promise(r => setTimeout(r, 10));\n    const log = bus.getLog();\n    const statusEvents = log.filter(e => e.event === Events.ORDER_STATUS_CHANGED);\n    expect(statusEvents).toHaveLength(1);\n    const payload = statusEvents[0].payload as { previousStatus: string; status: string };\n    expect(payload.previousStatus).toBe(OrderStatus.PENDING);\n    expect(payload.status).toBe(OrderStatus.CONFIRMED);\n  });\n\n  it('should list orders by user', () => {\n    orders.createOrder('user1', 'cart1', 50);\n    orders.createOrder('user1', 'cart2', 75);\n    orders.createOrder('user2', 'cart3', 100);\n    expect(orders.listOrders('user1')).toHaveLength(2);\n    expect(orders.listOrders('user2')).toHaveLength(1);\n  });\n\n  it('should return null for non-existent order', () => {\n    expect(orders.getOrder('nonexistent')).toBeNull();\n  });\n\n  it('should cancel an order', () => {\n    const orderId = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(orderId, OrderStatus.CANCELLED);\n    expect(orders.getOrder(orderId)!.status).toBe(OrderStatus.CANCELLED);\n  });\n});\n\ndescribe('Payment Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should process payment successfully', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 99.99);\n    expect(result.status).toBe(PaymentStatus.SUCCESS);\n    expect(result.transactionId).toBeDefined();\n  });\n\n  it('should simulate payment failure', async () => {\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const result = await payment.processPayment('order1', 99.99);\n    expect(result.status).toBe(PaymentStatus.FAILED);\n    expect(result.error).toBeDefined();\n  });\n\n  it('should simulate payment timeout', async () => {\n    const payment = createPaymentService(bus, { simulateTimeout: true });\n    const result = await payment.processPayment('order1', 99.99);\n    expect(result.status).toBe(PaymentStatus.TIMEOUT);\n  });\n\n  it('should refund a successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 99.99);\n    const refunded = await payment.refund(result.transactionId!);\n    expect(refunded).toBe(true);\n  });\n\n  it('should not refund a non-existent transaction', async () => {\n    const payment = createPaymentService(bus);\n    const refunded = await payment.refund('nonexistent');\n    expect(refunded).toBe(false);\n  });\n\n  it('should emit payment processed event', async () => {\n    const payment = createPaymentService(bus);\n    await payment.processPayment('order1', 99.99);\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.PAYMENT_PROCESSED)).toBe(true);\n  });\n});\n\ndescribe('Notification Service', () => {\n  let bus: EventBus;\n  let notifications: ReturnType<typeof createNotificationService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    notifications = createNotificationService(bus);\n  });\n\n  it('should subscribe a user', () => {\n    notifications.subscribe('user1');\n    expect(notifications.getNotifications('user1')).toEqual([]);\n  });\n\n  it('should receive notification on order creation', async () => {\n    notifications.subscribe('user1');\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 50 });\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs).toHaveLength(1);\n    expect(notifs[0].type).toBe('order_created');\n  });\n\n  it('should receive notification on order status change', async () => {\n    notifications.subscribe('user1');\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 50 });\n    await bus.emit(Events.ORDER_STATUS_CHANGED, { orderId: 'o1', status: OrderStatus.CONFIRMED, previousStatus: OrderStatus.PENDING });\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs).toHaveLength(2);\n    expect(notifs[1].type).toBe('order_status');\n  });\n\n  it('should receive notification on payment processed', async () => {\n    notifications.subscribe('user1');\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 50 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 't1' });\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.some(n => n.type === 'payment')).toBe(true);\n  });\n\n  it('should not notify unsubscribed users', async () => {\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 50 });\n    expect(notifications.getNotifications('user1')).toEqual([]);\n  });\n});\n\ndescribe('Analytics Service', () => {\n  let bus: EventBus;\n  let analytics: ReturnType<typeof createAnalyticsService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    analytics = createAnalyticsService(bus);\n  });\n\n  it('should count events by type', async () => {\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'Widget', price: 10, category: 'gadgets' });\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p2', name: 'Gizmo', price: 20, category: 'gadgets' });\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n  });\n\n  it('should track revenue from successful payments', async () => {\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 't1' });\n    expect(analytics.getRevenue()).toBe(100);\n  });\n\n  it('should not count revenue from failed payments', async () => {\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.FAILED, error: 'fail' });\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  it('should calculate conversion rate', async () => {\n    // 2 unique carts, 1 order\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [{ productId: 'p1', quantity: 1 }] });\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c2', userId: 'u2', items: [{ productId: 'p2', quantity: 1 }] });\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 50 });\n    expect(analytics.getConversionRate()).toBe(0.5);\n  });\n\n  it('should return 0 conversion rate with no carts', () => {\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n\n  it('should rank top products', async () => {\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [{ productId: 'p1', quantity: 5 }, { productId: 'p2', quantity: 2 }] });\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 50 });\n    const top = analytics.getTopProducts(2);\n    expect(top).toHaveLength(2);\n    expect(top[0].productId).toBe('p1');\n    expect(top[0].count).toBe(5);\n    expect(top[1].productId).toBe('p2');\n    expect(top[1].count).toBe(2);\n  });\n});\n\ndescribe('Integration: Full order flow', () => {\n  it('should handle a complete order lifecycle', async () => {\n    const bus = new EventBus();\n\n    // Create all services\n    const catalog = createCatalogService(bus);\n    const inventory = createInventoryService(bus);\n    const cart = createCartService(bus);\n    const pricing = createPricingService(bus);\n    const orderService = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    const notifications = createNotificationService(bus);\n    const analytics = createAnalyticsService(bus);\n\n    // Subscribe user for notifications\n    notifications.subscribe('user1');\n\n    // Create products\n    const p1 = catalog.createProduct('Laptop', 999.99, 'electronics');\n    const p2 = catalog.createProduct('Mouse', 29.99, 'electronics');\n\n    // Set stock\n    inventory.setStock(p1, 10);\n    inventory.setStock(p2, 50);\n\n    // Create cart and add items\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, p1, 1);\n    cart.addItem(cartId, p2, 2);\n\n    // Calculate total\n    const cartData = cart.getCart(cartId)!;\n    const items = cartData.items.map(i => ({\n      productId: i.productId,\n      quantity: i.quantity,\n      price: pricing.getPrice(i.productId),\n    }));\n    const total = pricing.calculateTotal(items);\n\n    // Create order\n    const orderId = orderService.createOrder('user1', cartId, total.total);\n\n    // Process payment\n    const payResult = await payment.processPayment(orderId, total.total);\n    expect(payResult.status).toBe(PaymentStatus.SUCCESS);\n\n    // Confirm order after successful payment\n    orderService.updateStatus(orderId, OrderStatus.CONFIRMED);\n\n    // Ship and deliver\n    orderService.updateStatus(orderId, OrderStatus.SHIPPED);\n    orderService.updateStatus(orderId, OrderStatus.DELIVERED);\n\n    // Check final state\n    const order = orderService.getOrder(orderId);\n    expect(order!.status).toBe(OrderStatus.DELIVERED);\n\n    // Check notifications were received\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThan(0);\n\n    // Check analytics\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBe(1);\n    expect(analytics.getRevenue()).toBe(total.total);\n    expect(analytics.getConversionRate()).toBeGreaterThan(0);\n  });\n});\n","structuredPatch":[],"originalFile":null}}
