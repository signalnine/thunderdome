+describe('Integration: Full order flow', () => {
+  it('should process a complete order from catalog to notification', async () => {
+    // Set up all services on the same bus
+    const analytics = createAnalyticsService(bus);
+    const catalog = createCatalogService(bus);
+    const inventory = createInventoryService(bus);
+    const cartSvc = createCartService(bus);
+    const pricing = createPricingService(bus);
+    const orders = createOrderService(bus);
+    const payment = createPaymentService(bus);
+    const notifications = createNotificationService(bus);
+
+    // Subscribe user
+    notifications.subscribe('alice');
+
+    // Create products
+    const p1 = catalog.createProduct('Laptop', 999.99, 'electronics');
+    const p2 = catalog.createProduct('Mouse', 29.99, 'electronics');
+
+    // Set inventory
+    inventory.setStock(p1, 10);
+    inventory.setStock(p2, 50);
+
+    // Create cart and add items
+    const cartId = cartSvc.createCart('alice');
+    cartSvc.addItem(cartId, p1, 1);
+    cartSvc.addItem(cartId, p2, 2);
+
+    await new Promise(r => setTimeout(r, 10));
+
+    // Calculate pricing
+    const cartData = cartSvc.getCart(cartId)!;
+    const items = cartData.items.map(i => ({
+      productId: i.productId,
+      quantity: i.quantity,
+      price: pricing.getPrice(i.productId),
+    }));
+
+    const totals = pricing.calculateTotal(items);
+    expect(totals.subtotal).toBeCloseTo(1059.97, 1);
+
+    // Reserve inventory
+    for (const item of cartData.items) {
+      expect(inventory.reserve(item.productId, item.quantity)).toBe(true);
+    }
+
+    // Create order
+    const orderId = orders.createOrder('alice', cartId, totals.total);
+    expect(orders.getOrder(orderId)!.status).toBe(OrderStatus.PENDING);
+
+    // Process payment
+    const paymentResult = await payment.processPayment(orderId, totals.total);
+    expect(paymentResult.status).toBe(PaymentStatus.SUCCESS);
+
+    // Confirm order
+    orders.updateStatus(orderId, OrderStatus.CONFIRMED);
+    await new Promise(r => setTimeout(r, 10));
+
+    // Verify notifications
+    const notifs = notifications.getNotifications('alice');
+    expect(notifs.length).toBeGreaterThanOrEqual(3); // order_created, payment, order_status
+
+    // Verify analytics
+    expect(analytics.getRevenue()).toBeCloseTo(totals.total, 1);
+    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);
+    expect(analytics.getConversionRate()).toBeGreaterThan(0);
+
+    // Verify inventory decreased
+    expect(inventory.getStock(p1)).toBe(9);
+    expect(inventory.getStock(p2)).toBe(48);
+  });
+});
