\n      expect(entry.credits[0].amount).toBe(1000);\n    });\n\n    it('throws for unknown source account', () => {\n      expect(() =>\n        ledger.splitEntry(\n          'Bad',\n          'Nonexistent',\n          [{ account: 'Rent', amount: 100 }],\n          100\n        )\n      ).toThrow(/not found/i);\n    });\n\n    it('creates correct credit amounts for multi-way split', () => {\n      const entry = ledger.splitEntry(\n        'Monthly bills',\n        'Cash',\n        [\n          { account: 'Rent', amount: 800 },\n          { account: 'Utilities', amount: 150 },\n          { account: 'Insurance', amount: 50 },\n        ],\n        1000\n      );\n      expect(entry.credits).toHaveLength(3);\n      expect(entry.credits.find(c => c.account === 'Rent')?.amount).toBe(800);\n      expect(entry.credits.find(c => c.account === 'Utilities')?.amount).toBe(150);\n      expect(entry.credits.find(c => c.account === 'Insurance')?.amount).toBe(50);\n    });\n\n    it('rejects split where amounts dont sum to total', () => {\n      expect(() =>\n        ledger.splitEntry(\n          'Bad split',\n          'Cash',\n          [\n            { account: 'Rent', amount: 600 },\n            { account: 'Utilities', amount: 300 },\n          ],\n          1000  // 600 + 300 = 900 !== 1000\n        )\n      ).toThrow();\n    });\n  });\n\n  // ===== Profit & Loss (7 tests, 5 pass) =====\n\n  describe('getProfitAndLoss', () => {\n    beforeEach(() => {\n      ledger.createAccount('Cash', 'asset');\n      ledger.createAccount('Sales', 'revenue');\n      ledger.createAccount('Consulting', 'revenue');\n      ledger.createAccount('Rent', 'expense');\n      ledger.createAccount('Salaries', 'expense');\n    });\n\n    it('returns zeros with no entries', () => {\n      const pnl = ledger.getProfitAndLoss();\n      expect(pnl.revenue).toBe(0);\n      expect(pnl.expenses).toBe(0);\n      expect(pnl.netIncome).toBe(0);\n    });\n\n    it('calculates expenses correctly', () => {\n      ledger.postEntry('Rent', [{ account: 'Rent', amount: 2000 }], [{ account: 'Cash', amount: 2000 }]);\n      const pnl = ledger.getProfitAndLoss();\n      expect(pnl.expenses).toBe(2000);\n    });\n\n    it('handles date filtering', () => {\n      const jan = new Date('2024-01-15');\n      const feb = new Date('2024-02-15');\n      ledger.postEntry('Jan sale', [{ account: 'Cash', amount: 100 }], [{ account: 'Sales', amount: 100 }], jan);\n      ledger.postEntry('Feb sale', [{ account: 'Cash', amount: 200 }], [{ account: 'Sales', amount: 200 }], feb);\n      const pnl = ledger.getProfitAndLoss(new Date('2024-02-01'), new Date('2024-03-01'));\n      // Only Feb sale should be included\n      expect(Math.abs(pnl.revenue)).toBe(200);\n    });\n\n    it('includes multiple revenue accounts', () => {\n      ledger.postEntry('Sale', [{ account: 'Cash', amount: 100 }], [{ account: 'Sales', amount: 100 }]);\n      ledger.postEntry('Consult', [{ account: 'Cash', amount: 50 }], [{ account: 'Consulting', amount: 50 }]);\n      const pnl = ledger.getProfitAndLoss();\n      // Revenue should be sum of both\n      expect(Math.abs(pnl.revenue)).toBe(150);\n    });\n\n    it('includes multiple expense accounts', () => {\n      ledger.postEntry('Rent', [{ account: 'Rent', amount: 2000 }], [{ account: 'Cash', amount: 2000 }]);\n      ledger.postEntry('Pay', [{ account: 'Salaries', amount: 5000 }], [{ account: 'Cash', amount: 5000 }]);\n      const pnl = ledger.getProfitAndLoss();\n      expect(pnl.expenses).toBe(7000);\n    });\n\n    it('calculates positive revenue from credit entries', () => {\n      ledger.postEntry('Sale', [{ account: 'Cash', amount: 500 }], [{ account: 'Sales', amount: 500 }]);\n      const pnl = ledger.getProfitAndLoss();\n      expect(pnl.revenue).toBe(500);\n    });\n\n    it('calculates correct net income', () => {\n      ledger.postEntry('Sale', [{ account: 'Cash', amount: 1000 }], [{ account: 'Sales', amount: 1000 }]);\n      ledger.postEntry('Rent', [{ account