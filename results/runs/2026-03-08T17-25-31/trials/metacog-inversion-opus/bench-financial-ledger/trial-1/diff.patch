+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XBgWLBaRaVMNQMR8yCKHtP","type":"tool_result","content":"     1→/**\n     2→ * Double-entry accounting ledger\n     3→ */\n     4→\n     5→export type AccountType = 'asset' | 'liability' | 'equity' | 'revenue' | 'expense';\n     6→\n     7→export interface Account {\n     8→  name: string;\n     9→  type: AccountType;\n    10→  currency: string;\n    11→}\n    12→\n    13→export interface LineItem {\n    14→  account: string;\n    15→  amount: number;\n    16→}\n    17→\n    18→export interface JournalEntry {\n    19→  id: number;\n    20→  description: string;\n    21→  debits: LineItem[];\n    22→  credits: LineItem[];\n    23→  date: Date;\n    24→}\n    25→\n    26→export interface BalanceEntry {\n    27→  account: string;\n    28→  type: AccountType;\n    29→  debit: number;\n    30→  credit: number;\n    31→}\n    32→\n    33→export interface StatementLine {\n    34→  date: Date;\n    35→  description: string;\n    36→  debit: number;\n    37→  credit: number;\n    38→  balance: number;\n    39→}\n    40→\n    41→export interface ProfitAndLoss {\n    42→  revenue: number;\n    43→  expenses: number;\n    44→  netIncome: number;\n    45→}\n    46→\n    47→export class Ledger {\n    48→  private accounts: Map<string, Account> = new Map();\n    49→  private entries: JournalEntry[] = [];\n    50→  private nextId = 1;\n    51→\n    52→  createAccount(name: string, type: AccountType, currency: string = 'USD'): Account {\n    53→    const account: Account = { name, type, currency };\n    54→    this.accounts.set(name, account);\n    55→    return account;\n    56→  }\n    57→\n    58→  postEntry(\n    59→    description: string,\n    60→    debits: LineItem[],\n    61→    credits: LineItem[],\n    62→    date?: Date\n    63→  ): JournalEntry {\n    64→    for (const d of debits) {\n    65→      if (!this.accounts.has(d.account)) {\n    66→        throw new Error(`Account not found: ${d.account}`);\n    67→      }\n    68→    }\n    69→    for (const c of credits) {\n    70→      if (!this.accounts.has(c.account)) {\n    71→        throw new Error(`Account not found: ${c.account}`);\n    72→      }\n    73→    }\n    74→\n    75→    const totalDebits = debits.reduce((sum, d) => sum + d.amount, 0);\n    76→    const totalCredits = credits.reduce((sum, c) => sum + c.amount, 0);\n    77→    if (totalDebits !== totalCredits) {\n    78→      throw new Error(`Debits (${totalDebits}) must equal credits (${totalCredits})`);\n    79→    }\n    80→\n    81→    for (const d of debits) {\n    82→      if (d.amount <= 0) throw new Error('Amounts must be positive');\n    83→    }\n    84→    for (const c of credits) {\n    85→      if (c.amount <= 0) throw new Error('Amounts must be positive');\n    86→    }\n    87→\n    88→    const entry: JournalEntry = {\n    89→      id: this.nextId++,\n    90→      description,\n    91→      debits: [...debits],\n    92→      credits: [...credits],\n    93→      date: date ?? new Date(),\n    94→    };\n    95→    this.entries.push(entry);\n    96→    return entry;\n    97→  }\n    98→\n    99→  getBalance(accountName: string): number {\n   100→    const account = this.accounts.get(accountName);\n   101→    if (!account) throw new Error(`Account not found: ${accountName}`);\n   102→\n   103→    let balance = 0;\n   104→    for (const entry of this.entries) {\n   105→      for (const d of entry.debits) {\n   106→        if (d.account === accountName) balance += d.amount;\n   107→      }\n   108→      for (const c of entry.credits) {\n   109→        if (c.account === accountName) balance -= c.amount;\n   110→      }\n   111→    }\n   112→\n   113→    return balance;\n   114→  }\n   115→\n   116→  getTrialBalance(): BalanceEntry[] {\n   117→    const result: BalanceEntry[] = [];\n   118→\n   119→    for (const [name, account] of this.accounts) {\n   120→      let totalDebits = 0;\n   121→      // eslint-disable-next-line prefer-cons