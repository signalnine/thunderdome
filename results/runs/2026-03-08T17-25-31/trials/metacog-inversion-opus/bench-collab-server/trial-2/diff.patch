new file mode 100644
index 0000000..4c08577
--- /dev/null
+++ b/src/ot.ts
@@ -0,0 +1,415 @@
+/**
+ * Operational Transform (OT) engine for collaborative text editing.
+ *
+ * Operations are represented as arrays of components:
+ *   - number > 0: retain N characters
+ *   - string: insert the given string
+ *   - number < 0: delete |N| characters
+ *
+ * The OT transform function takes two concurrent operations (a, b) that were
+ * both applied to the same document state, and returns [a', b'] such that:
+ *   apply(apply(doc, a), b') === apply(apply(doc, b), a')
+ */
+
+export type OTComponent = number | string;
+export type OTOperation = OTComponent[];
+
+export interface Operation {
+  type: "operation";
+  docId: string;
+  clientId: string;
+  version: number; // The version this op was based on
+  ops: OTOperation;
+}
+
+export interface InsertOp {
+  type: "insert";
+  position: number;
+  text: string;
+}
+
+export interface DeleteOp {
+  type: "delete";
+  position: number;
+  count: number;
+}
+
+export type SimpleOp = InsertOp | DeleteOp;
+
+/**
+ * Convert a simple operation (insert/delete at position) to an OT operation
+ * given the document length.
+ */
+export function simpleToOT(op: SimpleOp, docLength: number): OTOperation {
+  const result: OTOperation = [];
+
+  if (op.type === "insert") {
+    if (op.position > 0) result.push(op.position); // retain before
+    result.push(op.text); // insert
+    const after = docLength - op.position;
+    if (after > 0) result.push(after); // retain after
+  } else {
+    if (op.position > 0) result.push(op.position); // retain before
+    result.push(-op.count); // delete
+    const after = docLength - op.position - op.count;
+    if (after > 0) result.push(after); // retain after
+  }
+
+  return result;
+}
+
+/**
+ * Compute the input length (base document length) that an operation expects.
+ */
+export function inputLength(op: OTOperation): number {
+  let len = 0;
+  for (const c of op) {
+    if (typeof c === "number") {
+      if (c > 0) len += c; // retain
+      else len += Math.abs(c); // delete
+    }
+    // inserts don't consume input
+  }
+  return len;
+}
+
+/**
+ * Compute the output length after applying an operation.
+ */
+export function outputLength(op: OTOperation): number {
+  let len = 0;
+  for (const c of op) {
+    if (typeof c === "number") {
+      if (c > 0) len += c; // retain
+      // delete produces no output
+    } else {
+      len += c.length; // insert
+    }
+  }
+  return len;
+}
+
+/**
+ * Apply an OT operation to a document string.
+ */
+export function apply(doc: string, op: OTOperation): string {
+  const expectedLen = inputLength(op);
+  if (doc.length !== expectedLen) {
+    throw new Error(
+      `Operation input length (${expectedLen}) doesn't match document length (${doc.length})`
+    );
+  }
+
+  let result = "";
+  let pos = 0;
+
+  for (const c of op) {
+    if (typeof c === "number") {
+      if (c > 0) {
+        // retain
+        result += doc.slice(pos, pos + c);
+        pos += c;
+      } else {
+        // delete
+        pos += Math.abs(c);
+      }
+    } else {
+      // insert
+      result += c;
+    }
+  }
+
+  return result;
+}
+
+/**
+ * Normalize an operation by merging adjacent components of the same type
+ * and removing no-ops.
+ */
+function normalize(op: OTOperation): OTOperation {
+  const result: OTOperation = [];
+
+  for (const c of op) {
+    if (typeof c === "number" && c === 0) continue;
+    if (typeof c === "string" && c === "") continue;
+
+    if (result.length === 0) {
+      result.push(c);
+      continue;
+    }
+
+    const last = result[result.length - 1];
+
+    if (typeof c === "number" && typeof last === "number") {
+      // Both are numbers - merge if same sign
+      if ((c > 0 && last > 0) || (c < 0 && last < 0)) {
+        result[result.length - 1] = last + c;
+      } else {
+        result.push(c);
+      }
+    } else if (typeof c === "string" && typeof last === "string") {
+      result[result.length - 1] = last + c;
+    } else {
+      result.push(c);
+    }
+  }
+
+  return result;
+}
+
+/**
+ * Iterator helper for walking through operation components character by character.
+ */
+class OpIterator {
+  private ops: OTOperation;
+  private index: number;
+  private offset: number;
+
+  constructor(ops: OTOperation) {
+    this.ops = ops;
+    this.index = 0;
+    this.offset = 0;
+  }
+
+  hasNext(): boolean {
+    return this.index < this.ops.length;
+  }
+
+  /**
+   * Take up to `n` characters from the current component.
+   * For retains/deletes, returns a number.
+   * For inserts, returns a string.
+   */
+  take(n: number): OTComponent {
+    if (!this.hasNext()) {
+      throw new Error("No more components to take from");
+    }
+
+    const c = this.ops[this.index];
+
+    if (typeof c === "string") {
+      // Insert - take up to n characters from the string
+      const remaining = c.length - this.offset;
+      if (n >= remaining) {
+        const result = c.slice(this.offset);
+        this.index++;
+        this.offset = 0;
+        return result;
+      } else {
+        const result = c.slice(this.offset, this.offset + n);
+        this.offset += n;
+        return result;
+      }
+    } else {
+      // Retain (positive) or Delete (negative)
+      const absC = Math.abs(c);
+      const remaining = absC - this.offset;
+      const sign = c > 0 ? 1 : -1;
+
+      if (n >= remaining) {
+        this.index++;
+        this.offset = 0;
+        return remaining * sign;
+      } else {
+        this.offset += n;
+        return n * sign;
+      }
+    }
+  }
+
+  /**
+   * Peek at the type of the current component.
+   */
+  peekType(): "retain" | "insert" | "delete" | "end" {
+    if (!this.hasNext()) return "end";
+    const c = this.ops[this.index];
+    if (typeof c === "string") return "insert";
+    if (c > 0) return "retain";
+    return "delete";
+  }
+
+  /**
+   * Take the entire current component (for inserts in transform).
+   */
+  takeInsert(): string {
+    if (!this.hasNext()) throw new Error("No more components");
+    const c = this.ops[this.index];
+    if (typeof c !== "string") throw new Error("Not an insert");
+    const result = c.slice(this.offset);
+    this.index++;
+    this.offset = 0;
+    return result;
+  }
+
+  peekLength(): number {
+    if (!this.hasNext()) return Infinity;
+    const c = this.ops[this.index];
+    if (typeof c === "string") return c.length - this.offset;
+    return Math.abs(c) - this.offset;
+  }
+}
+
+/**
+ * Transform two concurrent operations so they can be applied in sequence.
+ *
+ * Given operations a and b that both apply to the same document state,
+ * returns [a', b'] where:
+ *   apply(apply(doc, a), b') === apply(apply(doc, b), a')
+ *
+ * The `priority` parameter determines insert ordering when both ops
+ * insert at the same position. If priority is "left", a's insert comes first.
+ */
+export function transform(
+  a: OTOperation,
+  b: OTOperation,
+  priority: "left" | "right" = "left"
+): [OTOperation, OTOperation] {
+  const iterA = new OpIterator(a);
+  const iterB = new OpIterator(b);
+  const aPrime: OTOperation = [];
+  const bPrime: OTOperation = [];
+
+  while (iterA.hasNext() || iterB.hasNext()) {
+    const typeA = iterA.peekType();
+    const typeB = iterB.peekType();
+
+    // If a inserts, push it through (b' retains over it)
+    if (typeA === "insert" && (priority === "left" || typeB !== "insert")) {
+      const ins = iterA.takeInsert();
+      aPrime.push(ins);
+      bPrime.push(ins.length); // b' retains over a's insert
+      continue;
+    }
+
+    // If b inserts, push it through (a' retains over it)
+    if (typeB === "insert") {
+      const ins = iterB.takeInsert();
+      bPrime.push(ins);
+      aPrime.push(ins.length); // a' retains over b's insert
+      continue;
+    }
+
+    if (typeA === "end" && typeB === "end") break;
+
+    if (typeA === "end" || typeB === "end") {
+      throw new Error("Operations have different base lengths");
+    }
+
+    const lenA = iterA.peekLength();
+    const lenB = iterB.peekLength();
+    const minLen = Math.min(lenA, lenB);
+
+    if (typeA === "retain" && typeB === "retain") {
+      // Both retain - both retain in their primes
+      iterA.take(minLen);
+      iterB.take(minLen);
+      aPrime.push(minLen);
+      bPrime.push(minLen);
+    } else if (typeA === "delete" && typeB === "delete") {
+      // Both delete same chars - cancel out
+      iterA.take(minLen);
+      iterB.take(minLen);
+      // Neither prime needs anything - both deleted the same chars
+    } else if (typeA === "delete" && typeB === "retain") {
+      // a deletes, b retains - a' deletes, b' does nothing (chars are gone)
+      iterA.take(minLen);
+      iterB.take(minLen);
+      aPrime.push(-minLen);
+    } else if (typeA === "retain" && typeB === "delete") {
+      // b deletes, a retains - b' deletes, a' does nothing
+      iterA.take(minLen);
+      iterB.take(minLen);
+      bPrime.push(-minLen);
+    }
+  }
+
+  return [normalize(aPrime), normalize(bPrime)];
+}
+
+/**
+ * Compose two sequential operations into a single operation.
+ * compose(a, b) produces an operation c such that apply(doc, c) === apply(apply(doc, a), b)
+ */
+export function compose(a: OTOperation, b: OTOperation): OTOperation {
+  if (outputLength(a) !== inputLength(b)) {
+    throw new Error("Operations cannot be composed: output length of a doesn't match input length of b");
+  }
+
+  const iterA = new OpIterator(a);
+  const iterB = new OpIterator(b);
+  const result: OTOperation = [];
+
+  while (iterA.hasNext() || iterB.hasNext()) {
+    const typeA = iterA.peekType();
+    const typeB = iterB.peekType();
+
+    // If a deletes, push through (doesn't affect b's input)
+    if (typeA === "delete") {
+      result.push(iterA.take(iterA.peekLength()));
+      continue;
+    }
+
+    // If b inserts, push through
+    if (typeB === "insert") {
+      result.push(iterB.takeInsert());
+      continue;
+    }
+
+    if (typeA === "end" && typeB === "end") break;
+    if (typeA === "end" || typeB === "end") {
+      throw new Error("Composition failed: mismatched operation lengths");
+    }
+
+    const lenA = iterA.peekLength();
+    const lenB = iterB.peekLength();
+    const minLen = Math.min(lenA, lenB);
+
+    if (typeA === "retain" && typeB === "retain") {
+      iterA.take(minLen);
+      iterB.take(minLen);
+      result.push(minLen);
+    } else if (typeA === "retain" && typeB === "delete") {
+      iterA.take(minLen);
+      iterB.take(minLen);
+      result.push(-minLen);
+    } else if (typeA === "insert" && typeB === "retain") {
+      const ins = iterA.take(minLen);
+      iterB.take(minLen);
+      result.push(ins);
+    } else if (typeA === "insert" && typeB === "delete") {
+      // a inserts, b deletes the same chars - they cancel out
+      iterA.take(minLen);
+      iterB.take(minLen);
+    }
+  }
+
+  return normalize(result);
+}
+
+/**
+ * Validate that an operation is well-formed for a document of the given length.
+ */
+export function validateOperation(op: OTOperation, docLength: number): string | null {
+  if (!Array.isArray(op)) {
+    return "Operation must be an array";
+  }
+
+  for (const c of op) {
+    if (typeof c !== "number" && typeof c !== "string") {
+      return `Invalid component type: ${typeof c}`;
+    }
+    if (typeof c === "number" && c === 0) {
+      return "Zero-length component is not allowed";
+    }
+    if (typeof c === "string" && c.length === 0) {
+      return "Empty string insert is not allowed";
+    }
+  }
+
+  const expectedInput = inputLength(op);
+  if (expectedInput !== docLength) {
+    return `Operation input length (${expectedInput}) doesn't match document length (${docLength})`;
+  }
+
+  return null;
+}
