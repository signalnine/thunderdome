atch(/^\\/ws\\/documents\\/(.+)$/);\n\n      if (!match) {\n        socket.write(\"HTTP/1.1 400 Bad Request\\r\\n\\r\\n\");\n        socket.destroy();\n        return;\n      }\n\n      const documentId = match[1];\n      const doc = this.db.getDocument(documentId);\n\n      if (!doc) {\n        socket.write(\"HTTP/1.1 404 Not Found\\r\\n\\r\\n\");\n        socket.destroy();\n        return;\n      }\n\n      this.wss.handleUpgrade(request, socket, head, (ws) => {\n        this.wss.emit(\"connection\", ws, request, documentId);\n      });\n    });\n\n    this.wss.on(\n      \"connection\",\n      (ws: WebSocket, _request: IncomingMessage, documentId: string) => {\n        this.handleConnection(ws, documentId);\n      }\n    );\n  }\n\n  private getDocumentState(documentId: string): DocumentState {\n    if (!this.documents.has(documentId)) {\n      const doc = this.db.getDocument(documentId);\n      if (!doc) {\n        throw new Error(`Document ${documentId} not found`);\n      }\n\n      // Load version history from db\n      const versions = this.db.getVersionHistory(documentId);\n      const operations: { ops: OTOperation; clientId: string }[] = [];\n      for (const v of versions) {\n        if (v.operation) {\n          try {\n            const parsed = JSON.parse(v.operation);\n            operations.push({ ops: parsed.ops || parsed, clientId: parsed.clientId || \"unknown\" });\n          } catch {\n            // Skip unparseable operations\n          }\n        }\n      }\n\n      this.documents.set(documentId, {\n        version: versions.length > 0 ? versions[versions.length - 1].version : 0,\n        content: doc.content,\n        operations,\n      });\n    }\n    return this.documents.get(documentId)!;\n  }\n\n  private handleConnection(ws: WebSocket, documentId: string): void {\n    const clientId = randomUUID();\n    this.clients.set(clientId, { ws, clientId, documentId });\n    this.db.addConnection(clientId, documentId);\n\n    const state = this.getDocumentState(documentId);\n\n    // Send sync message with current document state\n    this.sendMessage(ws, {\n      type: \"sync\",\n      content: state.content,\n      version: state.version,\n      clientId,\n    });\n\n    ws.on(\"message\", (data) => {\n      try {\n        const message = JSON.parse(data.toString()) as IncomingWSMessage;\n        this.handleMessage(clientId, message);\n      } catch (err) {\n        this.sendMessage(ws, {\n          type: \"error\",\n          message: err instanceof Error ? err.message : \"Invalid message\",\n        });\n      }\n    });\n\n    ws.on(\"close\", () => {\n      this.clients.delete(clientId);\n      this.db.removeConnection(clientId);\n    });\n\n    ws.on(\"error\", () => {\n      this.clients.delete(clientId);\n      this.db.removeConnection(clientId);\n    });\n  }\n\n  private handleMessage(clientId: string, message: IncomingWSMessage): void {\n    const client = this.clients.get(clientId);\n    if (!client) return;\n\n    if (message.type === \"operation\") {\n      this.handleOperation(clientId, client.documentId, message);\n    } else if (message.type === \"cursor\") {\n      // Broadcast cursor position to other clients\n      this.broadcastToDocument(\n        client.documentId,\n        {\n          type: \"cursor\",\n          clientId,\n          position: message.position,\n        },\n        clientId\n      );\n    }\n  }\n\n  private handleOperation(\n    clientId: string,\n    documentId: string,\n    message: IncomingMessage_Op\n  ): void {\n    const client = this.clients.get(clientId);\n    if (!client) return;\n\n    const state = this.getDocumentState(documentId);\n    let ops = message.ops;\n    const clientVersion = message.version;\n\n    // Validate version\n    if (typeof clientVersion !== \"number\" || clientVersion < 0 || clientVersion > state.version) {\n      this.sendMessage(client.ws, {\n        type: \"error\",\n        message: `Invalid version: ${clientVersion}. Current version is ${state.version}`,\n      });\n      return;\n    }\n\n    // Transform against all operations that happened since the client's version\n    try {\n      // We need to get the document content at the client's version to validate\n      // Then transform through all subsequent operations\n      for (let v = clientVersion; v < state.version; v++) {\n        const serverOp = state.operations[v];\n        if (serverOp) {\n          const [transformedClient] = transform(ops, serverOp.ops, \"left\");\n          ops = transformedClient;\n        }\n      }\n\n      // Validate the transformed operation against current document\n      const validationError = validateOperation(ops, state.content.length);\n      if (validationError) {\n        this.sendMessage(client.ws, {\n          type: \"error\",\n          message: validationError,\n        });\n        return;\n      }\n\n      // Apply the transformed operation\n      const newContent = apply(state.content, ops);\n\n      // Update state\n      state.operations.push({ ops, clientId });\n      state.version++;\n      state.content = newContent;\n\n      // Persist\n      this.db.applyOperation(documentId, newContent, { ops, clientId });\n\n      // Send ack to the sending client\n      this.sendMessage(client.ws, {\n        type: \"ack\",\n        version: state.version,\n      });\n\n      // Broadcast the transformed operation to all other clients\n      this.broadcastToDocument(\n        documentId,\n        {\n          type: \"operation\",\n          ops,\n          version: state.version,\n          clientId,\n        },\n        clientId\n      );\n    } catch (err) {\n      this.sendMessage(client.ws, {\n        type: \"error\",\n        message: err instanceof Error ? err.message : \"Failed to apply operation\",\n      });\n    }\n  }\n\n  private broadcastToDocument(\n    documentId: string,\n    message: object,\n    excludeClientId?: string\n  ): void {\n    for (const [id, client] of this.clients) 