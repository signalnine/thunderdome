t from \"supertest\";\nimport WebSocket from \"ws\";\nimport { createApp, AppInstance } from \"../src/server.js\";\n\nfunction connectWS(port: number, docId: string): Promise<WebSocket> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/${docId}`);\n    ws.on(\"open\", () => resolve(ws));\n    ws.on(\"error\", reject);\n  });\n}\n\nfunction waitForMessage(ws: WebSocket): Promise<Record<string, unknown>> {\n  return new Promise((resolve) => {\n    ws.once(\"message\", (data) => {\n      resolve(JSON.parse(data.toString()));\n    });\n  });\n}\n\ndescribe(\"Stress Test\", () => {\n  let app: AppInstance;\n  let port: number;\n\n  beforeAll(async () => {\n    app = createApp();\n    port = await app.start(0);\n  });\n\n  afterAll(async () => {\n    await app.stop();\n  });\n\n  it(\"should handle 10 concurrent clients on same document\", async () => {\n    const res = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Stress\", content: \"\" });\n    const docId = res.body.id;\n\n    const clients: WebSocket[] = [];\n    const syncMessages: Record<string, unknown>[] = [];\n\n    // Connect 10 clients\n    for (let i = 0; i < 10; i++) {\n      const ws = await connectWS(port, docId);\n      const sync = await waitForMessage(ws);\n      clients.push(ws);\n      syncMessages.push(sync);\n    }\n\n    expect(clients.length).toBe(10);\n    expect(app.wsHandler.getClientCount(docId)).toBe(10);\n\n    // Clean up\n    for (const ws of clients) {\n      ws.close();\n    }\n\n    await new Promise((r) => setTimeout(r, 200));\n  });\n\n  it(\"should handle 10 concurrent inserts without corruption\", async () => {\n    const res = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Concurrent Inserts\", content: \"\" });\n    const docId = res.body.id;\n\n    const clients: { ws: WebSocket; version: number }[] = [];\n\n    // Connect 10 clients\n    for (let i = 0; i < 10; i++) {\n      const ws = await connectWS(port, docId);\n      const sync = await waitForMessage(ws);\n      clients.push({ ws, version: sync.version as number });\n    }\n\n    // Each client sends one insert sequentially (to avoid test flakiness)\n    for (let i = 0; i < clients.length; i++) {\n      const client = clients[i];\n      const char = String.fromCharCode(65 + i); // A, B, C, ...\n\n      client.ws.send(JSON.stringify({\n        type: \"operation\",\n        version: client.version,\n        ops: [char],\n      }));\n\n      // Wait for ack\n      const ack = await waitForMessage(client.ws);\n      expect(ack.type).toBe(\"ack\");\n      const newVersion = ack.version as number;\n\n      // Update all other clients' versions by consuming their broadcast\n      for (let j = 0; j < clients.length; j++) {\n        if (j !== i) {\n          const broadcast = await waitForMessage(clients[j].ws);\n          expect(broadcast.type).toBe(\"operation\");\n          clients[j].version = broadcast.version as number;\n        }\n      }\n      client.version = newVersion;\n    }\n\n    await new Promise((r) => setTimeout(r, 300));\n\n    // Verify document has all 10 characters\n    const docRes = await request(app.app).get(`/documents/${docId}`);\n    const content = docRes.body.content;\n    expect(content.length).toBe(10);\n\n    for (let i = 0; i < 10; i++) {\n      expect(content).toContain(String.fromCharCode(65 + i));\n    }\n\n    for (const c of clients) {\n      c.ws.close();\n    }\n  });\n\n  it(\"should not crash when clients disconnect mid-operation\", async () => {\n    const res = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Disconnect Test\", content: \"Start\" });\n    const docId = res.body.id;\n\n    const ws1 = await connectWS(port, docId);\n    const sync1 = await waitForMessage(ws1);\n\n    const ws2 = await connectWS(port, docId);\n    await waitForMessage(ws2);\n\n    // Client 1 sends operation and immediately disconnects\n    ws1.send(JSON.stringify({\n      type: \"operation\",\n      version: sync1.version as number,\n      ops: [5, \" End\"],\n    }));\n\n    ws1.close();\n\n    // Give time for processing\n    await new Promise((r) => setTimeout(r, 300));\n\n    // Server should still be running; ws2 should still be connected\n    const ws3 = await connectWS(port, docId);\n    const sync3 = await waitForMessage(ws3);\n    expect(sync3.type).toBe(\"sync\");\n\n    ws2.close();\n    ws3.close();\n  });\n\n  it(\"should handle rapid sequential operations from one client\", async () => {\n    const res = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Rapid Seq\", content: \"\" });\n    const docId = res.body.id;\n\n    const ws = await connectWS(port, docId);\n    const sync = await waitForMessage(ws);\n    let version = sync.version as number;\n\n    // Send 20 sequential operations\n    for (let i = 0; i < 20; i++) {\n      const currentLen = i; // Each op adds 1 char\n      const ops = currentLen > 0 ? [currentLen, String(i % 10)] : [String(i % 10)];\n\n      ws.send(JSON.stringify({\n        type: \"operation\",\n        version,\n        ops,\n      }));\n\n      const ack = await waitForMessage(ws);\n      expect(ack.type).toBe(\"ack\");\n      version = ack.version as number;\n    }\n\n    const docRes = await request(app.app).get(`/documents/${docId}`);\n    expect(docRes.body.content.length).toBe(20);\n\n    ws.close();\n  });\n\n  it(\"should maintain document integrity after many operations\", async () => {\n    const res = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Integrity\", content: \"Hello\" });\n    const docId = res.body.id;\n\n    const ws = await connectWS(port, docId);\n    const sync = await waitForMessage(ws);\n    let version = sync.version as number;\n\n    // Append \" World\"\n    ws.send(JSON.stringify({\n      type: \"operation\",\n      version,\n      ops: [5, \" World\"],\n    }));\n    let ack = await waitForMessage(ws);\n    version = ack.version as number;\n\n    // Delete \"World\" (5 chars from position 6)\n    ws.send(JSON.stringify({\n      type: \"operation\",\n      version,\n      ops: [6, -5],\n    }));\n    ack = await waitForMessage(ws);\n    version = ack.version as number;\n\n    // Insert \"Earth\"\n    ws.send(JSON.stringify({\n      type: \"operation\",\n      version,\n      ops: [6, \"Earth\"],\n    }));\n    ack = await waitForMessage(ws);\n\n    const docRes = await request(app.app).get(`/documents/${docId}`);\n    expect(docRes.body.content).toBe(\"Hello Earth\");\n\n    ws.close();\n  });\n});\n"}}
