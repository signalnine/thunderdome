+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01WrdWCi1XvhKf7f4Wnp1Csj","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01BTiw6cP8YjU1HmeVDSm74h","name":"Write","input":{"file_path":"/workspace/tests/stress.test.ts","content":"import { describe, it, expect, beforeAll, afterAll } from \"vitest\";\nimport request from \"supertest\";\nimport { createApp, AppInstance } from \"../src/server.js\";\nimport { connectAndSync } from \"./helpers.js\";\n\ndescribe(\"Stress Test\", () => {\n  let app: AppInstance;\n  let port: number;\n\n  beforeAll(async () => {\n    app = createApp();\n    port = await app.start(0);\n  });\n\n  afterAll(async () => {\n    await app.stop();\n  });\n\n  it(\"should handle 10 concurrent clients on same document\", async () => {\n    const res = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Stress\", content: \"\" });\n    const docId = res.body.id;\n\n    const clients = [];\n\n    // Connect 10 clients\n    for (let i = 0; i < 10; i++) {\n      const { client } = await connectAndSync(port, docId);\n      clients.push(client);\n    }\n\n    expect(clients.length).toBe(10);\n    expect(app.wsHandler.getClientCount(docId)).toBe(10);\n\n    // Clean up\n    for (const c of clients) {\n      c.ws.close();\n    }\n\n    await new Promise((r) => setTimeout(r, 200));\n  });\n\n  it(\"should handle 10 concurrent inserts without corruption\", async () => {\n    const res = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Concurrent Inserts\", content: \"\" });\n    const docId = res.body.id;\n\n    const clients: { client: ReturnType<typeof connectAndSync> extends Promise<infer T> ? T : never; version: number }[] = [];\n\n    // Connect 10 clients\n    for (let i = 0; i < 10; i++) {\n      const result = await connectAndSync(port, docId);\n      clients.push({ ...result, version: result.sync.version as number });\n    }\n\n    // Each client sends one insert sequentially\n    for (let i = 0; i < clients.length; i++) {\n      const c = clients[i];\n      const char = String.fromCharCode(65 + i); // A, B, C, ...\n\n      c.client.ws.send(JSON.stringify({\n        type: \"operation\",\n        version: c.version,\n        ops: [char],\n      }));\n\n      // Wait for ack\n      const ack = await c.client.waitForMessage((m) => m.type === \"ack\");\n      expect(ack.type).toBe(\"ack\");\n      const newVersion = ack.version as number;\n\n      // Update all other clients' versions by consuming their broadcast\n      for (let j = 0; j < clients.length; j++) {\n        if (j !== i) {\n          const broadcast = await clients[j].client.waitForMessage((m) => m.type === \"operation\");\n          expect(broadcast.type).toBe(\"operation\");\n          clients[j].version = broadcast.version as number;\n        }\n      }\n      c.version = newVersion;\n    }\n\n    await new Promise((r) => setTimeout(r, 300));\n\n    // Verify document has all 10 characters\n    const docRes = await request(app.app).get(`/documents/${docId}`);\n    const content = docRes.body.content;\n    expect(content.length).toBe(10);\n\n    for (let i = 0; i < 10; i++) {\n      expect(content).toContain(String.fromCharCode(65 + i));\n    }\n\n    for (const c of clients) {\n      c.client.ws.close();\n    }\n  });\n\n  it(\"should not crash when clients disconnect mid-operation\", async () => {\n    const res = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Disconnect Test\", content: \"Start\" });\n    const docId = res.body.id;\n\n    const { client: c1, sync: s1 } = await connectAndSync(port, docId);\n    const { client: c2 } = await connectAndSync(port, docId);\n\n    // Client 1 sends operation and immediately disconnects\n    c1.ws.send(JSON.stringify({\n      type: \"operation\",\n      version: s1.version as number,\n      ops: [5, \" End\"],\n    }));\n\n    c1.ws.close();\n\n    // Give time for processing\n    await new Promise((r) => setTimeout(r, 300));\n\n    // Server should still be running; new connection should work\n    const { client: c3, sync: s3 } = await connectAndSync(port, docId);\n    expect(s3.type).toBe(\"sync\");\n\n    c2.ws.close();\n    c3.ws.close();\n  });\n\n  it(\"should handle rapid sequential operations from one client\", async () => {\n    const res = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Rapid Seq\", content: \"\" });\n    const docId = res.body.id;\n\n    const { client, sync } = await connectAndSync(port, docId);\n    let version = sync.version as number;\n\n    // Send 20 sequential operations\n    for (let i = 0; i < 20; i++) {\n      const currentLen = i; // Each op adds 1 char\n      const ops = currentLen > 0 ? [currentLen, String(i % 10)] : [String(i % 10)];\n\n      client.ws.send(JSON.stringify({\n        type: \"operation\",\n        version,\n        ops,\n      }));\n\n      const ack = await client.waitForMessage((m) => m.type === \"ack\");\n      expect(ack.type).toBe(\"ack\");\n      version = ack.version as number;\n    }\n\n    const docRes = await request(app.app).get(`/documents/${docId}`);\n    expect(docRes.body.content.length).toBe(20);\n\n    client.ws.close();\n  });\n\n  it(\"should maintain document integrity after many operations\", async () => {\n    const res = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Integrity\", content: \"Hello\" });\n    const docId = res.body.id;\n\n    const { client, sync } = await connectAndSync(port, docId);\n    let version = sync.version as number;\n\n    // Append \" World\"\n    client.ws.send(JSON.stringify({\n      type: \"operation\",\n      version,\n      ops: [5, \" World\"],\n    }));\n    let ack = await client.waitForMessage((m) => m.type === \"ack\");\n    version = ack.version as number;\n\n    // Delete \"World\" (5 chars from position 6)\n    client.ws.send(JSON.stringify({\n      type: \"operation\",\n      version,\n      ops: [6, -5],\n    }));\n    ack = await client.waitForMessage((m) => m.type === \"ack\");\n    version = ack.version as number;\n\n    // Insert \"Earth\"\n    client.ws.send(JSON.stringify({\n      type: \"operation\",\n      version,\n      ops: [6, \"Earth\"],\n    }));\n    ack = await client.waitForMessage((m) => m.type === \"ack\");\n\n    const docRes = await request(app.app).get(`/documents/${docId}`);\n    expect(docRes.body.content).toBe(\"Hello Earth\");\n\n    client.ws.close();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":809,"cache_read_input_tokens":77168,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":809},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"683b7004-71e2-42a0-bc85-5b5277d63d2f","uuid":"7188bf69-60ac-44f2-83c5-556329f5b09e"}
