s/${docId}`);\n    ws.on(\"open\", () => resolve(ws));\n    ws.on(\"error\", reject);\n  });\n}\n\nfunction waitForMessage(ws: WebSocket): Promise<Record<string, unknown>> {\n  return new Promise((resolve) => {\n    ws.once(\"message\", (data) => {\n      resolve(JSON.parse(data.toString()));\n    });\n  });\n}\n\ndescribe(\"WebSocket Lifecycle\", () => {\n  let app: AppInstance;\n  let port: number;\n  let docId: string;\n\n  beforeAll(async () => {\n    app = createApp();\n    port = await app.start(0);\n  });\n\n  afterAll(async () => {\n    await app.stop();\n  });\n\n  beforeEach(async () => {\n    const res = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"WS Test\", content: \"Hello\" });\n    docId = res.body.id;\n  });\n\n  it(\"should connect to a document via WebSocket\", async () => {\n    const ws = await connectWS(port, docId);\n    const msg = await waitForMessage(ws);\n\n    expect(msg.type).toBe(\"sync\");\n    expect(msg.content).toBe(\"Hello\");\n    expect(msg.version).toBe(0);\n    expect(msg).toHaveProperty(\"clientId\");\n\n    ws.close();\n  });\n\n  it(\"should receive sync message with current content\", async () => {\n    // Update the document first\n    await request(app.app)\n      .put(`/documents/${docId}`)\n      .send({ content: \"Updated content\" });\n\n    // Invalidate the in-memory cache\n    app.wsHandler.invalidateDocument(docId);\n\n    const ws = await connectWS(port, docId);\n    const msg = await waitForMessage(ws);\n\n    expect(msg.type).toBe(\"sync\");\n    expect(msg.content).toBe(\"Updated content\");\n\n    ws.close();\n  });\n\n  it(\"should assign unique client IDs\", async () => {\n    const ws1 = await connectWS(port, docId);\n    const msg1 = await waitForMessage(ws1);\n\n    const ws2 = await connectWS(port, docId);\n    const msg2 = await waitForMessage(ws2);\n\n    expect(msg1.clientId).not.toBe(msg2.clientId);\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should reject connection to non-existent document\", async () => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/nonexistent`);\n    return new Promise<void>((resolve) => {\n      ws.on(\"error\", () => {\n        resolve();\n      });\n      ws.on(\"close\", () => {\n        resolve();\n      });\n    });\n  });\n\n  it(\"should reject connection to invalid path\", async () => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/invalid`);\n    return new Promise<void>((resolve) => {\n      ws.on(\"error\", () => {\n        resolve();\n      });\n      ws.on(\"close\", () => {\n        resolve();\n      });\n    });\n  });\n\n  it(\"should handle clean disconnect\", async () => {\n    const ws = await connectWS(port, docId);\n    await waitForMessage(ws); // sync\n\n    ws.close();\n\n    // Wait for close to propagate\n    await new Promise((r) => setTimeout(r, 100));\n\n    expect(app.wsHandler.getClientCount(docId)).toBe(0);\n  });\n\n  it(\"should support multiple clients on same document\", async () => {\n    const ws1 = await connectWS(port, docId);\n    await waitForMessage(ws1);\n\n    const ws2 = await connectWS(port, docId);\n    await waitForMessage(ws2);\n\n    const ws3 = await connectWS(port, docId);\n    await waitForMessage(ws3);\n\n    expect(app.wsHandler.getClientCount(docId)).toBe(3);\n\n    ws1.close();\n    ws2.close();\n    ws3.close();\n  });\n\n  it(\"should include version number in sync message\", async () => {\n    const ws = await connectWS(port, docId);\n    const msg = await waitForMessage(ws);\n\n    expect(typeof msg.version).toBe(\"number\");\n    expect(msg.version).toBeGreaterThanOrEqual(0);\n\n    ws.close();\n  });\n});\n"}}
