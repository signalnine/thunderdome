+import { describe, it, expect, beforeAll, afterAll, beforeEach } from "vitest";
+import request from "supertest";
+import { createApp, AppInstance } from "../src/server.js";
+import { connectAndSync } from "./helpers.js";
+
+describe("Error Handling", () => {
+  let app: AppInstance;
+  let port: number;
+  let docId: string;
+
+  beforeAll(async () => {
+    app = createApp();
+    port = await app.start(0);
+  });
+
+  afterAll(async () => {
+    await app.stop();
+  });
+
+  beforeEach(async () => {
+    const res = await request(app.app)
+      .post("/documents")
+      .send({ title: "Error Test", content: "Hello" });
+    docId = res.body.id;
+  });
+
+  it("should reject malformed JSON over WebSocket", async () => {
+    const { client } = await connectAndSync(port, docId);
+
+    client.ws.send("not valid json");
+
+    const msg = await client.waitForMessage((m) => m.type === "error");
+    expect(msg.type).toBe("error");
+
+    client.ws.close();
+  });
+
+  it("should reject operation with invalid version", async () => {
+    const { client } = await connectAndSync(port, docId);
+
+    client.ws.send(JSON.stringify({
+      type: "operation",
+      version: 999,
+      ops: ["test"],
+    }));
+
+    const msg = await client.waitForMessage((m) => m.type === "error");
+    expect(msg.type).toBe("error");
+
+    client.ws.close();
+  });
+
+  it("should reject operation with wrong document length", async () => {
+    const { client, sync } = await connectAndSync(port, docId);
+
+    client.ws.send(JSON.stringify({
+      type: "operation",
+      version: sync.version as number,
+      ops: [100, "extra"],
+    }));
+
+    const msg = await client.waitForMessage((m) => m.type === "error");
+    expect(msg.type).toBe("error");
+
+    client.ws.close();
+  });
+
+  it("should handle delete of non-existent document via REST", async () => {
+    await request(app.app)
+      .delete("/documents/nonexistent")
+      .expect(404);
+  });
+
+  it("should handle update of non-existent document via REST", async () => {
+    await request(app.app)
+      .put("/documents/nonexistent")
+      .send({ title: "Nope" })
+      .expect(404);
+  });
+});
diff --git a/tests/helpers.ts b/tests/helpers.ts
new file mode 100644
index 0000000..2e7c3b5
--- /dev/null
+++ b/tests/helpers.ts
@@ -0,0 +1,74 @@
+import WebSocket from "ws";
+
+export interface WSClient {
+  ws: WebSocket;
+  messages: Record<string, unknown>[];
+  waitForMessage: (predicate?: (msg: Record<string, unknown>) => boolean) => Promise<Record<string, unknown>>;
+}
+
+/**
+ * Connect to a document via WebSocket. Sets up message buffering
+ * so no messages are lost between connect and waitForMessage calls.
+ */
+export function connectWS(port: number, docId: string): Promise<WSClient> {
+  return new Promise((resolve, reject) => {
+    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/${docId}`);
+    const messages: Record<string, unknown>[] = [];
+    const waiters: Array<{
+      predicate: (msg: Record<string, unknown>) => boolean;
+      resolve: (msg: Record<string, unknown>) => void;
+    }> = [];
+
+    ws.on("message", (data) => {
+      const msg = JSON.parse(data.toString()) as Record<string, unknown>;
+
+      // Check if any waiter wants this message
+      for (let i = 0; i < waiters.length; i++) {
+        if (waiters[i].predicate(msg)) {
+          const waiter = waiters.splice(i, 1)[0];
+          waiter.resolve(msg);
+          return;
+        }
+      }
+
+      // No waiter - buffer it
+      messages.push(msg);
+    });
+
+    ws.on("open", () => {
+      resolve({
+        ws,
+        messages,
+        waitForMessage: (predicate?: (msg: Record<string, unknown>) => boolean) => {
+          const pred = predicate || (() => true);
+
+          // Check buffered messages first
+          for (let i = 0; i < messages.length; i++) {
+            if (pred(messages[i])) {
+              return Promise.resolve(messages.splice(i, 1)[0]);
+            }
+          }
+
+          // Wait for next matching message
+          return new Promise<Record<string, unknown>>((res) => {
+            waiters.push({ predicate: pred, resolve: res });
+          });
+        },
+      });
+    });
+
+    ws.on("error", reject);
+  });
+}
+
+/**
+ * Connect and return the sync message.
+ */
+export async function connectAndSync(port: number, docId: string): Promise<{
+  client: WSClient;
+  sync: Record<string, unknown>;
+}> {
+  const client = await connectWS(port, docId);
+  const sync = await client.waitForMessage((m) => m.type === "sync");
+  return { client, sync };
+}
