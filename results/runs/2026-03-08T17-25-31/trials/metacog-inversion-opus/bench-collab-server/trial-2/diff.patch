tching message\n          return new Promise<Record<string, unknown>>((res) => {\n            waiters.push({ predicate: pred, resolve: res });\n          });\n        },\n      });\n    });\n\n    ws.on(\"error\", reject);\n  });\n}\n\n/**\n * Connect and return the sync message.\n */\nexport async function connectAndSync(port: number, docId: string): Promise<{\n  client: WSClient;\n  sync: Record<string, unknown>;\n}> {\n  const client = await connectWS(port, docId);\n  const sync = await client.waitForMessage((m) => m.type === \"sync\");\n  return { client, sync };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":357,"cache_read_input_tokens":76811,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":357},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"683b7004-71e2-42a0-bc85-5b5277d63d2f","uuid":"a1f30f19-78e9-4eff-bf65-4718c7c9d356"}
