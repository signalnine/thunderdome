t c1.waitForMessage((m) => m.type === \"ack\");\n\n    const opMsg = await c2.waitForMessage((m) => m.type === \"operation\");\n    expect(opMsg.type).toBe(\"operation\");\n    expect(opMsg.ops).toEqual([\"Hello\"]);\n\n    c1.ws.close();\n    c2.ws.close();\n  });\n\n  it(\"should handle concurrent inserts at different positions\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Concurrent Test\", content: \"Hello World\" });\n    const id = createRes.body.id;\n\n    const { client: c1, sync: s1 } = await connectAndSync(port, id);\n    const version = s1.version as number;\n    const { client: c2 } = await connectAndSync(port, id);\n\n    c1.ws.send(JSON.stringify({\n      type: \"operation\",\n      version,\n      ops: [\"Dear \", 11],\n    }));\n    await c1.waitForMessage((m) => m.type === \"ack\");\n\n    c2.ws.send(JSON.stringify({\n      type: \"operation\",\n      version,\n      ops: [11, \"!\"],\n    }));\n    await c2.waitForMessage((m) => m.type === \"ack\");\n\n    await new Promise((r) => setTimeout(r, 200));\n\n    const res = await request(app.app).get(`/documents/${id}`);\n    expect(res.body.content).toBe(\"Dear Hello World!\");\n\n    c1.ws.close();\n    c2.ws.close();\n  });\n\n  it(\"should handle concurrent inserts at the same position\", async () => {\n    const { client: c1, sync: s1 } = await connectAndSync(port, docId);\n    const version = s1.version as number;\n    const { client: c2 } = await connectAndSync(port, docId);\n\n    c1.ws.send(JSON.stringify({\n      type: \"operation\",\n      version,\n      ops: [\"A\"],\n    }));\n    await c1.waitForMessage((m) => m.type === \"ack\");\n\n    c2.ws.send(JSON.stringify({\n      type: \"operation\",\n      version,\n      ops: [\"B\"],\n    }));\n    await c2.waitForMessage((m) => m.type === \"ack\");\n\n    await new Promise((r) => setTimeout(r, 200));\n\n    const res = await request(app.app).get(`/documents/${docId}`);\n    const content = res.body.content;\n    expect(content).toContain(\"A\");\n    expect(content).toContain(\"B\");\n    expect(content.length).toBe(2);\n\n    c1.ws.close();\n    c2.ws.close();\n  });\n\n  it(\"should converge after concurrent edits\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Convergence\", content: \"abc\" });\n    const id = createRes.body.id;\n\n    const { client: c1, sync: s1 } = await connectAndSync(port, id);\n    const version = s1.version as number;\n    const { client: c2 } = await connectAndSync(port, id);\n\n    c1.ws.send(JSON.stringify({\n      type: \"operation\",\n      version,\n      ops: [1, \"X\", 2],\n    }));\n    await c1.waitForMessage((m) => m.type === \"ack\");\n\n    c2.ws.send(JSON.stringify({\n      type: \"operation\",\n      version,\n      ops: [2, \"Y\", 1],\n    }));\n    await c2.waitForMessage((m) => m.type === \"ack\");\n\n    await new Promise((r) => setTimeout(r, 200));\n\n    const res = await request(app.app).get(`/documents/${id}`);\n    const content = res.body.content;\n    expect(content).toContain(\"X\");\n    expect(content).toContain(\"Y\");\n    expect(content).toContain(\"a\");\n    expect(content).toContain(\"b\");\n    expect(content).toContain(\"c\");\n    expect(content.length).toBe(5);\n\n    c1.ws.close();\n    c2.ws.close();\n  });\n\n  it(\"should handle insert and delete concurrently\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Insert Delete\", content: \"Hello World\" });\n    const id = createRes.body.id;\n\n    const { client: c1, sync: s1 } = await connectAndSync(port, id);\n    const version = s1.version as number;\n    const { client: c2 } = await connectAndSync(port, id);\n\n    c1.ws.send(JSON.stringify({\n      type: \"operation\",\n      version,\n      ops: [6, -5],\n    }));\n    await c1.waitForMessage((m) => m.type === \"ack\");\n\n    c2.ws.send(JSON.stringify({\n      type: \"operation\",\n      version,\n      ops: [6, \"Beautiful \", 5],\n    }));\n    await c2.waitForMessage((m) => m.type === \"ack\");\n\n    await new Promise((r) => setTimeout(r, 200));\n\n    const res = await request(app.app).get(`/documents/${id}`);\n    expect(res.body.content).toContain(\"Hello \");\n    expect(res.body.content).toContain(\"Beautiful \");\n\n    c1.ws.close();\n    c2.ws.close();\n  });\n\n  it(\"should not lose any characters from concurrent inserts\", async () => {\n    const { client: c1, sync: s1 } = await connectAndSync(port, docId);\n    const version = s1.version as number;\n    const { client: c2 } = await connectAndSync(port, docId);\n\n    c1.ws.send(JSON.stringify({\n      type: \"operation\",\n      version,\n      ops: [\"Hello\"],\n    }));\n    await c1.waitForMessage((m) => m.type === \"ack\");\n\n    c2.ws.send(JSON.stringify({\n      type: \"operation\",\n      version,\n      ops: [\"World\"],\n    }));\n    await c2.waitForMessage((m) => m.type === \"ack\");\n\n    await new Promise((r) => setTimeout(r, 200));\n\n    const res = await request(app.app).get(`/documents/${docId}`);\n    expect(res.body.content).toContain(\"Hello\");\n    expect(res.body.content).toContain(\"World\");\n    expect(res.body.content.length).toBe(10);\n\n    c1.ws.close();\n    c2.ws.close();\n  });\n\n  it(\"should maintain version consistency\", async () => {\n    const { client: c1, sync: s1 } = await connectAndSync(port, docId);\n    const version = s1.version as number;\n    const { client: c2 } = await connectAndSync(port, docId);\n\n    c1.ws.send(JSON.stringify({\n      type: \"operation\",\n      version,\n      ops: [\"A\"],\n    }));\n    const ack1 = await c1.waitForMessage((m) => m.type === \"ack\");\n    expect(ack1.type).toBe(\"ack\");\n    expect(ack1.version).toBe(version + 1);\n\n    c2.ws.send(JSON.stringify({\n      type: \"operation\",\n      version,\n      ops: [\"B\"],\n    }));\n    const ack2 = await c2.waitForMessage((m) => m.type === \"ack\");\n    expect(ack2.type).toBe(\"ack\");\n    expect(ack2.version).toBe(version + 2);\n\n    c1.ws.close();\n    c2.ws.close();\n  });\n\n  it(\"should handle rapid concurrent edits\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Rapid\", content: \"start\" });\n    const id = createRes.body.id;\n\n    const { client: c1, sync: s1 } = await connectAndSync(port, id);\n    let version1 = s1.version as number;\n    const { client: c2 } = await connectAndSync(port, id);\n\n    c1.ws.send(JSON.stringify({\n      type: \"operation\",\n      version: version1,\n      ops: [5, \"A\"],\n    }));\n    const ack1 = await c1.waitForMessage((m) => m.type === \"ack\");\n    version1 = ack1.version as number;\n\n    const broadcast = await c2.waitForMessage((m) => m.type === \"operation\");\n    const version2 = broadcast.version as number;\n\n    c2.ws.send(JSON.stringify({\n      type: \"operation\",\n      version: version2,\n      ops: [6, \"B\"],\n    }));\n    await c2.waitForMessage((m) => m.type === \"ack\");\n\n    await new Promise((r) => setTimeout(r, 200));\n\n    const res = await request(app.app).get(`/documents/${id}`);\n    expect(res.body.content).toContain(\"start\");\n    expect(res.body.content).toContain(\"A\");\n    expect(res.body.content).toContain(\"B\");\n\n    c1.ws.close();\n    c2.ws.close();\n  });\n});\n","structuredPatch":[{"oldStart":1,"oldLines":40,"newStart":1,"newLines":8,"lines":[" import { describe, it, expect, beforeAll, afterAll, beforeEach } from \"vitest\";"," import request from \"supertest\";","-import WebSocket from \"ws\";"," import { createApp, AppInstance } from \"../src/server.js\";","+import { connectAndSync } from \"./helpers.js\";"," ","-function connectWS(port: number, docId: string): Promise<WebSocket> {","-  return new Promise((resolve, reject) => {","-    const ws = new WebSocket(`ws://localhost:${po