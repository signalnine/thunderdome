+import { describe, it, expect, beforeAll, afterAll } from "vitest";
+import request from "supertest";
+import { createApp, AppInstance } from "../src/server.js";
+
+describe("REST CRUD", () => {
+  let app: AppInstance;
+
+  beforeAll(async () => {
+    app = createApp();
+    await app.start(0);
+  });
+
+  afterAll(async () => {
+    await app.stop();
+  });
+
+  it("should create a document", async () => {
+    const res = await request(app.app)
+      .post("/documents")
+      .send({ title: "Test Doc", content: "Hello" })
+      .expect(201);
+
+    expect(res.body).toHaveProperty("id");
+    expect(res.body.title).toBe("Test Doc");
+    expect(res.body.content).toBe("Hello");
+    expect(res.body).toHaveProperty("created_at");
+    expect(res.body).toHaveProperty("updated_at");
+  });
+
+  it("should create a document with empty content", async () => {
+    const res = await request(app.app)
+      .post("/documents")
+      .send({ title: "Empty Doc" })
+      .expect(201);
+
+    expect(res.body.title).toBe("Empty Doc");
+    expect(res.body.content).toBe("");
+  });
+
+  it("should reject document creation without title", async () => {
+    await request(app.app)
+      .post("/documents")
+      .send({ content: "No title" })
+      .expect(400);
+  });
+
+  it("should get a document by ID", async () => {
+    const created = await request(app.app)
+      .post("/documents")
+      .send({ title: "Get Me", content: "Content" });
+
+    const res = await request(app.app)
+      .get(`/documents/${created.body.id}`)
+      .expect(200);
+
+    expect(res.body.id).toBe(created.body.id);
+    expect(res.body.title).toBe("Get Me");
+    expect(res.body.content).toBe("Content");
+  });
+
+  it("should return 404 for non-existent document", async () => {
+    await request(app.app)
+      .get("/documents/nonexistent-id")
+      .expect(404);
+  });
+
+  it("should list all documents", async () => {
+    const res = await request(app.app)
+      .get("/documents")
+      .expect(200);
+
+    expect(Array.isArray(res.body)).toBe(true);
+    expect(res.body.length).toBeGreaterThanOrEqual(1);
+  });
+
+  it("should update a document", async () => {
+    const created = await request(app.app)
+      .post("/documents")
+      .send({ title: "Original", content: "Original content" });
+
+    const res = await request(app.app)
+      .put(`/documents/${created.body.id}`)
+      .send({ title: "Updated", content: "Updated content" })
+      .expect(200);
+
+    expect(res.body.title).toBe("Updated");
+    expect(res.body.content).toBe("Updated content");
+  });
+
+  it("should partially update a document", async () => {
+    const created = await request(app.app)
+      .post("/documents")
+      .send({ title: "Original Title", content: "Keep this" });
+
+    const res = await request(app.app)
+      .patch(`/documents/${created.body.id}`)
+      .send({ title: "New Title" })
+      .expect(200);
+
+    expect(res.body.title).toBe("New Title");
+    expect(res.body.content).toBe("Keep this");
+  });
+
+  it("should delete a document", async () => {
+    const created = await request(app.app)
+      .post("/documents")
+      .send({ title: "Delete Me" });
+
+    await request(app.app)
+      .delete(`/documents/${created.body.id}`)
+      .expect(204);
+
+    await request(app.app)
+      .get(`/documents/${created.body.id}`)
+      .expect(404);
+  });
+
+  it("should get version history for a document", async () => {
+    const created = await request(app.app)
+      .post("/documents")
+      .send({ title: "Versioned", content: "Initial" });
+
+    const res = await request(app.app)
+      .get(`/documents/${created.body.id}/versions`)
+      .expect(200);
+
+    expect(Array.isArray(res.body)).toBe(true);
+    expect(res.body.length).toBeGreaterThanOrEqual(1);
+    expect(res.body[0].content).toBe("Initial");
+    expect(res.body[0].version).toBe(0);
+  });
+});
