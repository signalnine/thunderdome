, docId);\n    const sync1 = await waitForMessage(ws1);\n\n    const ws2 = await connectWS(port, docId);\n    await waitForMessage(ws2);\n\n    const opPromise = waitForSpecificMessage(ws2, (m) => m.type === \"operation\");\n\n    // Client 1 sends an operation\n    ws1.send(JSON.stringify({\n      type: \"operation\",\n      version: sync1.version as number,\n      ops: [\"Hello\"],\n    }));\n\n    await waitForMessage(ws1); // ack\n\n    // Client 2 should receive the operation\n    const opMsg = await opPromise;\n    expect(opMsg.type).toBe(\"operation\");\n    expect(opMsg.ops).toEqual([\"Hello\"]);\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should handle concurrent inserts at different positions\", async () => {\n    // Start with \"Hello World\"\n    const createRes = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Concurrent Test\", content: \"Hello World\" });\n    const id = createRes.body.id;\n\n    const ws1 = await connectWS(port, id);\n    const sync1 = await waitForMessage(ws1);\n    const version = sync1.version as number;\n\n    const ws2 = await connectWS(port, id);\n    await waitForMessage(ws2);\n\n    // Client 1 inserts \"Dear \" at position 0, client 2 inserts \"!\" at end\n    // Both based on same version\n    ws1.send(JSON.stringify({\n      type: \"operation\",\n      version,\n      ops: [\"Dear \", 11],\n    }));\n\n    await waitForMessage(ws1); // ack for client 1\n\n    ws2.send(JSON.stringify({\n      type: \"operation\",\n      version,\n      ops: [11, \"!\"],\n    }));\n\n    await waitForMessage(ws2); // ack for client 2\n\n    // Wait a bit for operations to settle\n    await new Promise((r) => setTimeout(r, 200));\n\n    // Both inserts should be preserved\n    const res = await request(app.app).get(`/documents/${id}`);\n    expect(res.body.content).toBe(\"Dear Hello World!\");\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should handle concurrent inserts at the same position\", async () => {\n    const ws1 = await connectWS(port, docId);\n    const sync1 = await waitForMessage(ws1);\n    const version = sync1.version as number;\n\n    const ws2 = await connectWS(port, docId);\n    await waitForMessage(ws2);\n\n    // Both clients insert at position 0\n    ws1.send(JSON.stringify({\n      type: \"operation\",\n      version,\n      ops: [\"A\"],\n    }));\n\n    await waitForMessage(ws1); // ack\n\n    ws2.send(JSON.stringify({\n      type: \"operation\",\n      version,\n      ops: [\"B\"],\n    }));\n\n    await waitForMessage(ws2); // ack\n\n    await new Promise((r) => setTimeout(r, 200));\n\n    // Both should be present in the document\n    const res = await request(app.app).get(`/documents/${docId}`);\n    const content = res.body.content;\n    expect(content).toContain(\"A\");\n    expect(content).toContain(\"B\");\n    expect(content.length).toBe(2);\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should converge after concurrent edits\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Convergence\", content: \"abc\" });\n    const id = createRes.body.id;\n\n    const ws1 = await connectWS(port, id);\n    const sync1 = await waitForMessage(ws1);\n    const version = sync1.version as number;\n\n    const ws2 = await connectWS(port, id);\n    await waitForMessage(ws2);\n\n    // Client 1: insert \"X\" at position 1 (between a and b): \"aXbc\"\n    ws1.send(JSON.stringify({\n      type: \"operation\",\n      version,\n      ops: [1, \"X\", 2],\n    }));\n\n    await waitForMessage(ws1); // ack\n\n    // Client 2: insert \"Y\" at position 2 (between b and c): \"abYc\"\n    // Based on original version (concurrent)\n    ws2.send(JSON.stringify({\n      type: \"operation\",\n      version,\n      ops: [2, \"Y\", 1],\n    }));\n\n    await waitForMessage(ws2); // ack\n\n    await new Promise((r) => setTimeout(r, 200));\n\n    const res = await request(app.app).get(`/documents/${id}`);\n    const content = res.body.content;\n    // Both X and Y should be present\n    expect(content).toContain(\"X\");\n    expect(content).toContain(\"Y\");\n    expect(content).toContain(\"a\");\n    expect(content).toContain(\"b\");\n    expect(content).toContain(\"c\");\n    expect(content.length).toBe(5);\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should handle insert and delete concurrently\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Insert Delete\", content: \"Hello World\" });\n    const id = createRes.body.id;\n\n    const ws1 = await connectWS(port, id);\n    const sync1 = await waitForMessage(ws1);\n    const version = sync1.version as number;\n\n    const ws2 = await connectWS(port, id);\n    await waitForMessage(ws2);\n\n    // Client 1: delete \"World\" (5 chars from position 6)\n    ws1.send(JSON.stringify({\n      type: \"operation\",\n      version,\n      ops: [6, -5],\n    }));\n\n    await waitForMessage(ws1); // ack\n\n    // Client 2: insert \"Beautiful \" at position 6 (before \"World\")\n    ws2.send(JSON.stringify({\n      type: \"operation\",\n      version,\n      ops: [6, \"Beautiful \", 5],\n    }));\n\n    await waitForMessage(ws2); // ack\n\n    await new Promise((r) => setTimeout(r, 200));\n\n    const res = await request(app.app).get(`/documents/${id}`);\n    // \"Beautiful \" should be preserved, \"World\" should be deleted\n    expect(res.body.content).toContain(\"Hello \");\n    expect(res.body.content).toContain(\"Beautiful \");\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should not lose any characters from concurrent inserts\", async () => {\n    const ws1 = await connectWS(port, docId);\n    const sync1 = await waitForMessage(ws1);\n    const version = sync1.version as number;\n\n    const ws2 = await connectWS(port, docId);\n    await waitForMessage(ws2);\n\n    // Client 1: insert \"Hello\"\n    ws1.send(JSON.stringify({\n      type: \"operation\",\n      version,\n      ops: [\"Hello\"],\n    }));\n\n    await waitForMessage(ws1); // ack\n\n    // Client 2: insert \"World\" (concurrent, based on same version)\n    ws2.send(JSON.stringify({\n      type: \"operation\",\n      version,\n      ops: [\"World\"],\n    }));\n\n    await waitForMessage(ws2); // ack\n\n    await new Promise((r) => setTimeout(r, 200));\n\n    const res = await request(app.app).get(`/documents/${docId}`);\n    expect(res.body.content).toContain(\"Hello\");\n    expect(res.body.content).toContain(\"World\");\n    expect(res.body.content.length).toBe(10);\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should maintain version consistency\", async () => {\n    const ws1 = await connectWS(port, docId);\n    const sync1 = await waitForMessage(ws1);\n    const version = sync1.version as number;\n\n    const ws2 = await connectWS(port, docId);\n    await waitForMessage(ws2);\n\n    // Send operations from both clients\n    ws1.send(JSON.stringify({\n      type: \"operation\",\n      version,\n      ops: [\"A\"],\n    }));\n\n    const ack1 = await waitForMessage(ws1);\n    expect(ack1.type).toBe(\"ack\");\n    expect(ack1.version).toBe(version + 1);\n\n    ws2.send(JSON.stringify({\n      type: \"operation\",\n      version,\n      ops: [\"B\"],\n    }));\n\n    const ack2 = await waitForMessage(ws2);\n    expect(ack2.type).toBe(\"ack\");\n    expect(ack2.version).toBe(version + 2);\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should handle rapid concurrent edits\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/documents\")\n      .send({ title: \"Rapid\", content: \"start\" });\n    const id = createRes.body.id;\n\n    const ws1 = await connectWS(port, id);\n    const sync1 = await waitForMessage(ws1);\n    let version1 = sync1.version as number;\n\n    const ws2 = await connectWS(port, id);\n    const sync2 = await waitForMessage(ws2);\n    let version2 = sync2.version as number;\n\n    // Client 1: append \"A\"\n    ws1.send(JSON.stringify({\n      type: \"operation\",\n      version: version1,\n      ops: [5, \"A\"],\n    }));\n    const ack1 = await waitForMessage(ws1);\n    version1 = ack1.version as number;\n\n    // Client 2: append \"B\" (may be concurrent)\n    // Wait for broadcast to arrive at client 2 first\n    const broadcast = await waitForSpecificMessage(ws2, (m) => m.type === \"operation\");\n    version2 = broadcast.version as number;\n\n    ws2.send(JSON.stringify({\n      type: \"operation\",\n      version: version2,\n      ops: [6, \"B\"],\n    }));\n    await waitForMessage(ws2);\n\n    await new Promise((r) => setTimeout(r, 200));\n\n    const res = await request(app.app).get(`/documents/${id}`);\n    expect(res.body.content).toContain(\"start\");\n    expect(res.body.content).toContain(\"A\");\n    expect(res.body.content).toContain(\"B\");\n\n    ws1.close();\n    ws2.close();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1757,"cache_read_input_tokens":37692,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1757},"output_tokens":18,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"683b7004-71e2-42a0-bc85-5b5277d63d2f","uuid":"808c5283-2aef-410e-aa08-07ebce1fd8c2"}
