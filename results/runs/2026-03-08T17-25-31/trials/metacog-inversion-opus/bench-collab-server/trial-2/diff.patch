@@ -0,0 +1,128 @@
+import { describe, it, expect, afterEach } from "vitest";
+import request from "supertest";
+import { createApp, AppInstance } from "../src/server.js";
+import { join } from "path";
+import { tmpdir } from "os";
+import { unlinkSync } from "fs";
+import { connectAndSync } from "./helpers.js";
+
+describe("Persistence", () => {
+  const dbPath = join(tmpdir(), `collab-test-${Date.now()}.db`);
+  const apps: AppInstance[] = [];
+
+  afterEach(async () => {
+    for (const a of apps) {
+      try {
+        await a.stop();
+      } catch {
+        // ignore
+      }
+    }
+    apps.length = 0;
+    try {
+      unlinkSync(dbPath);
+    } catch {
+      // ignore
+    }
+  });
+
+  it("should persist documents across server restarts", async () => {
+    const app1 = createApp(dbPath);
+    apps.push(app1);
+    await app1.start(0);
+
+    const res = await request(app1.app)
+      .post("/documents")
+      .send({ title: "Persistent", content: "Survive restart" });
+    const docId = res.body.id;
+
+    await app1.stop();
+    apps.length = 0;
+
+    const app2 = createApp(dbPath);
+    apps.push(app2);
+    await app2.start(0);
+
+    const getRes = await request(app2.app)
+      .get(`/documents/${docId}`)
+      .expect(200);
+
+    expect(getRes.body.title).toBe("Persistent");
+    expect(getRes.body.content).toBe("Survive restart");
+  });
+
+  it("should persist edits made via WebSocket across restarts", async () => {
+    const app1 = createApp(dbPath);
+    apps.push(app1);
+    const port1 = await app1.start(0);
+
+    const res = await request(app1.app)
+      .post("/documents")
+      .send({ title: "WS Persist", content: "Hello" });
+    const docId = res.body.id;
+
+    const { client, sync } = await connectAndSync(port1, docId);
+
+    client.ws.send(JSON.stringify({
+      type: "operation",
+      version: sync.version as number,
+      ops: [5, " World"],
+    }));
+
+    await client.waitForMessage((m) => m.type === "ack");
+    client.ws.close();
+
+    await new Promise((r) => setTimeout(r, 100));
+
+    await app1.stop();
+    apps.length = 0;
+
+    const app2 = createApp(dbPath);
+    apps.push(app2);
+    await app2.start(0);
+
+    const getRes = await request(app2.app)
+      .get(`/documents/${docId}`)
+      .expect(200);
+
+    expect(getRes.body.content).toBe("Hello World");
+  });
+
+  it("should persist version history across restarts", async () => {
+    const app1 = createApp(dbPath);
+    apps.push(app1);
+    const port1 = await app1.start(0);
+
+    const res = await request(app1.app)
+      .post("/documents")
+      .send({ title: "Version Persist", content: "v0" });
+    const docId = res.body.id;
+
+    const { client, sync } = await connectAndSync(port1, docId);
+
+    client.ws.send(JSON.stringify({
+      type: "operation",
+      version: sync.version as number,
+      ops: [2, " updated"],
+    }));
+
+    await client.waitForMessage((m) => m.type === "ack");
+    client.ws.close();
+
+    await new Promise((r) => setTimeout(r, 100));
+
+    await app1.stop();
+    apps.length = 0;
+
+    const app2 = createApp(dbPath);
+    apps.push(app2);
+    await app2.start(0);
+
+    const versionsRes = await request(app2.app)
+      .get(`/documents/${docId}/versions`)
+      .expect(200);
+
+    expect(versionsRes.body.length).toBeGreaterThanOrEqual(2);
+    expect(versionsRes.body[0].content).toBe("v0");
+  });
+});
