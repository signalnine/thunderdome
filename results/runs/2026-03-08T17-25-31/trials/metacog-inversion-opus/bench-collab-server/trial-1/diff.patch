new file mode 100644
index 0000000..9097eaa
--- /dev/null
+++ b/src/db.ts
@@ -0,0 +1,161 @@
+import Database from 'better-sqlite3';
+import { randomUUID } from 'crypto';
+
+export interface Document {
+  id: string;
+  title: string;
+  content: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface Version {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operation: string | null;
+  created_at: string;
+}
+
+export function createDatabase(dbPath?: string): Database.Database {
+  const db = new Database(dbPath || ':memory:');
+  db.pragma('journal_mode = WAL');
+  db.pragma('foreign_keys = ON');
+  initSchema(db);
+  return db;
+}
+
+function initSchema(db: Database.Database): void {
+  db.exec(`
+    CREATE TABLE IF NOT EXISTS documents (
+      id TEXT PRIMARY KEY,
+      title TEXT NOT NULL,
+      content TEXT NOT NULL DEFAULT '',
+      created_at TEXT NOT NULL DEFAULT (datetime('now')),
+      updated_at TEXT NOT NULL DEFAULT (datetime('now'))
+    );
+
+    CREATE TABLE IF NOT EXISTS versions (
+      id INTEGER PRIMARY KEY AUTOINCREMENT,
+      document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
+      version INTEGER NOT NULL,
+      content TEXT NOT NULL,
+      operation TEXT,
+      created_at TEXT NOT NULL DEFAULT (datetime('now')),
+      UNIQUE(document_id, version)
+    );
+
+    CREATE TABLE IF NOT EXISTS active_connections (
+      id TEXT PRIMARY KEY,
+      document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
+      connected_at TEXT NOT NULL DEFAULT (datetime('now'))
+    );
+  `);
+}
+
+export function createDocument(db: Database.Database, title: string, content: string = ''): Document {
+  const id = randomUUID();
+  const stmt = db.prepare(
+    'INSERT INTO documents (id, title, content) VALUES (?, ?, ?)'
+  );
+  stmt.run(id, title, content);
+
+  // Create initial version (version 0)
+  const versionStmt = db.prepare(
+    'INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)'
+  );
+  versionStmt.run(id, 0, content, null);
+
+  return getDocument(db, id)!;
+}
+
+export function getDocument(db: Database.Database, id: string): Document | undefined {
+  const stmt = db.prepare('SELECT * FROM documents WHERE id = ?');
+  return stmt.get(id) as Document | undefined;
+}
+
+export function listDocuments(db: Database.Database): Document[] {
+  const stmt = db.prepare('SELECT * FROM documents ORDER BY updated_at DESC');
+  return stmt.all() as Document[];
+}
+
+export function updateDocument(
+  db: Database.Database,
+  id: string,
+  updates: { title?: string; content?: string }
+): Document | undefined {
+  const doc = getDocument(db, id);
+  if (!doc) return undefined;
+
+  const title = updates.title ?? doc.title;
+  const content = updates.content ?? doc.content;
+
+  const stmt = db.prepare(
+    "UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?"
+  );
+  stmt.run(title, content, id);
+
+  return getDocument(db, id);
+}
+
+export function deleteDocument(db: Database.Database, id: string): boolean {
+  const stmt = db.prepare('DELETE FROM documents WHERE id = ?');
+  const result = stmt.run(id);
+  return result.changes > 0;
+}
+
+export function getDocumentVersion(db: Database.Database, docId: string): number {
+  const stmt = db.prepare(
+    'SELECT COALESCE(MAX(version), 0) as version FROM versions WHERE document_id = ?'
+  );
+  const row = stmt.get(docId) as { version: number } | undefined;
+  return row?.version ?? 0;
+}
+
+export function addVersion(
+  db: Database.Database,
+  docId: string,
+  version: number,
+  content: string,
+  operation: object
+): void {
+  const versionStmt = db.prepare(
+    'INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)'
+  );
+  versionStmt.run(docId, version, content, JSON.stringify(operation));
+
+  const updateStmt = db.prepare(
+    "UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?"
+  );
+  updateStmt.run(content, docId);
+}
+
+export function getVersions(db: Database.Database, docId: string): Version[] {
+  const stmt = db.prepare(
+    'SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC'
+  );
+  return stmt.all(docId) as Version[];
+}
+
+export function getVersionByNumber(
+  db: Database.Database,
+  docId: string,
+  version: number
+): Version | undefined {
+  const stmt = db.prepare(
+    'SELECT * FROM versions WHERE document_id = ? AND version = ?'
+  );
+  return stmt.get(docId, version) as Version | undefined;
+}
+
+export function getOperationsSinceVersion(
+  db: Database.Database,
+  docId: string,
+  sinceVersion: number
+): Version[] {
+  const stmt = db.prepare(
+    'SELECT * FROM versions WHERE document_id = ? AND version > ? ORDER BY version ASC'
+  );
+  return stmt.all(docId, sinceVersion) as Version[];
+}
diff --git a/src/ot.ts b/src/ot.ts
new file mode 100644
index 0000000..a395eca
--- /dev/null
+++ b/src/ot.ts
@@ -0,0 +1,190 @@
+/**
+ * Operational Transform (OT) engine for collaborative text editing.
+ *
+ * Operations are either insertions or deletions at specific positions.
+ * When two operations are concurrent (based on the same document version),
+ * we transform one against the other so both can be applied and converge.
+ */
+
+export interface InsertOp {
+  type: 'insert';
+  position: number;
+  text: string;
+}
+
+export interface DeleteOp {
+  type: 'delete';
+  position: number;
+  count: number;
+}
+
+export type Operation = InsertOp | DeleteOp;
+
+/**
+ * Apply an operation to a document string, returning the new content.
+ */
+export function applyOperation(content: string, op: Operation): string {
+  if (op.type === 'insert') {
+    const pos = Math.min(Math.max(0, op.position), content.length);
+    return content.slice(0, pos) + op.text + content.slice(pos);
+  } else {
+    const pos = Math.min(Math.max(0, op.position), content.length);
+    const count = Math.min(op.count, content.length - pos);
+    if (count <= 0) return content;
+    return content.slice(0, pos) + content.slice(pos + count);
+  }
+}
+
+/**
+ * Transform operation `op` against `other` that was applied first.
+ * Returns a new operation that achieves the same intent as `op`
+ * but in the context where `other` has already been applied.
+ *
+ * This implements the standard OT inclusion transformation (IT).
+ */
+export function transformOperation(op: Operation, other: Operation): Operation {
+  if (op.type === 'insert' && other.type === 'insert') {
+    return transformInsertInsert(op, other);
+  } else if (op.type === 'insert' && other.type === 'delete') {
+    return transformInsertDelete(op, other);
+  } else if (op.type === 'delete' && other.type === 'insert') {
+    return transformDeleteInsert(op as DeleteOp, other as InsertOp);
+  } else {
+    return transformDeleteDelete(op as DeleteOp, other as DeleteOp);
+  }
+}
+
+function transformInsertInsert(op: InsertOp, other: InsertOp): InsertOp {
+  // If op's position is after other's insert (or at same position),
+  // shift op forward by the length of other's text.
+  // Tie-breaking: if same position, the "other" (already applied) goes first.
+  if (op.position > other.position) {
+    return { ...op, position: op.position + other.text.length };
+  } else if (op.position < other.position) {
+    return { ...op };
+  } else {
+    // Same position: other was applied first, so shift op after it.
+    return { ...op, position: op.position + other.text.length };
+  }
+}
+
+function transformInsertDelete(op: InsertOp, other: DeleteOp): InsertOp {
+  if (op.position <= other.position) {
+    // Insert is before or at the delete position - no change needed
+    return { ...op };
+  } else if (op.position >= other.position + other.count) {
+    // Insert is after the deleted region - shift back by delete count
+    return { ...op, position: op.position - other.count };
+  } else {
+    // Insert is within the deleted region - place at delete position
+    return { ...op, position: other.position };
+  }
+}
+
+function transformDeleteInsert(op: DeleteOp, other: InsertOp): DeleteOp {
+  if (op.position >= other.position) {
+    // Delete starts after or at insert position - shift forward
+    return { ...op, position: op.position + other.text.length };
+  } else if (op.position + op.count <= other.position) {
+    // Delete ends before insert position - no change needed
+    return { ...op };
+  } else {
+    // Delete range spans the insert position - expand the delete count
+    // to account for inserted text being in the middle
+    // Actually, we should NOT delete the newly inserted text.
+    // We split into two deletes or adjust. Simplest correct approach:
+    // the delete range grows because the insert pushed chars forward.
+    return { ...op, count: op.count + other.text.length };
+  }
+}
+
+function transformDeleteDelete(op: DeleteOp, other: DeleteOp): DeleteOp {
+  // After 'other' delete is applied, adjust 'op' delete
+  if (op.position >= other.position + other.count) {
+    // op is entirely after other's deletion range
+    return { ...op, position: op.position - other.count };
+  } else if (op.position + op.count <= other.position) {
+    // op is entirely before other's deletion range
+    return { ...op };
+  } else {
+    // Overlapping deletes
+    const opEnd = op.position + op.count;
+    const otherEnd = other.position + other.count;
+
+    if (op.position >= other.position && opEnd <= otherEnd) {
+      // op is entirely within other - nothing left to delete
+      return { ...op, position: other.position, count: 0 };
+    } else if (op.position <= other.position && opEnd >= otherEnd) {
+      // op contains other entirely - reduce count by other's count
+      return { ...op, count: op.count - other.count };
+    } else if (op.position < other.position) {
+      // op starts before other but overlaps
+      const newCount = other.position - op.position;
+      return { ...op, count: newCount };
+    } else {
+      // op starts inside other but extends beyond
+      const newCount = opEnd - otherEnd;
+      return { ...op, position: other.position, count: newCount };
+    }
+  }
+}
+
+/**
+ * Transform an operation against a sequence of operations that have
+ * already been applied (server history since the client's base version).
+ */
+export function transformAgainstHistory(op: Operation, history: Operation[]): Operation {
+  let transformed = op;
+  for (const past of history) {
+    transformed = transformOperation(transformed, past);
+  }
+  return transformed;
+}
+
+/**
+ * Validate that an operation is well-formed.
+ */
+export function validateOperation(op: unknown): op is Operation {
+  if (typeof op !== 'object' || op === null) return false;
+  const obj = op as Record<string, unknown>;
+
+  if (obj.type === 'insert') {
+    return (
+      typeof obj.position === 'number' &&
+      Number.isInteger(obj.position) &&
+      obj.position >= 0 &&
+      typeof obj.text === 'string' &&
+      obj.text.length > 0
+    );
+  } else if (obj.type === 'delete') {
+    return (
+      typeof obj.position === 'number' &&
+      Number.isInteger(obj.position) &&
+      obj.position >= 0 &&
+      typeof obj.count === 'number' &&
+      Number.isInteger(obj.count) &&
+      obj.count > 0
+    );
+  }
+
+  return false;
+}
+
+/**
+ * Validate that an operation is applicable to a document of given length.
+ */
+export function validateOperationForContent(op: Operation, contentLength: number): string | null {
+  if (op.type === 'insert') {
+    if (op.position > contentLength) {
+      return `Insert position ${op.position} is beyond document length ${contentLength}`;
+    }
+  } else if (op.type === 'delete') {
+    if (op.position >= contentLength) {
+      return `Delete position ${op.position} is at or beyond document length ${contentLength}`;
+    }
+    if (op.position + op.count > contentLength) {
+      return `Delete range [${op.position}, ${op.position + op.count}) exceeds document length ${contentLength}`;
+    }
+  }
+  return null;
+}
diff --git a/src/routes.ts b/src/routes.ts
new file mode 100644
index 0000000..c1d3ddf
--- /dev/null
+++ b/src/routes.ts
@@ -0,0 +1,100 @@
+import { Router, Request, Response } from 'express';
+import type Database from 'better-sqlite3';
+import {
+  createDocument,
+  getDocument,
+  listDocuments,
+  updateDocument,
+  deleteDocument,
+  getVersions,
+  getVersionByNumber,
+} from './db.js';
+
+export function createRouter(db: Database.Database): Router {
+  const router = Router();
+
+  // Create a document
+  router.post('/docs', (req: Request, res: Response) => {
+    const { title, content } = req.body;
+
+    if (!title || typeof title !== 'string') {
+      res.status(400).json({ error: 'Title is required and must be a string' });
+      return;
+    }
+
+    const doc = createDocument(db, title, content || '');
+    res.status(201).json(doc);
+  });
+
+  // List all documents
+  router.get('/docs', (_req: Request, res: Response) => {
+    const docs = listDocuments(db);
+    res.json(docs);
+  });
+
+  // Get a single document
+  router.get('/docs/:id', (req: Request, res: Response) => {
+    const doc = getDocument(db, req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.json(doc);
+  });
+
+  // Update a document
+  router.put('/docs/:id', (req: Request, res: Response) => {
+    const { title, content } = req.body;
+    const doc = updateDocument(db, req.params.id, { title, content });
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.json(doc);
+  });
+
+  // Delete a document
+  router.delete('/docs/:id', (req: Request, res: Response) => {
+    const deleted = deleteDocument(db, req.params.id);
+    if (!deleted) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.status(204).send();
+  });
+
+  // Get version history for a document
+  router.get('/docs/:id/versions', (req: Request, res: Response) => {
+    const doc = getDocument(db, req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    const versions = getVersions(db, req.params.id);
+    res.json(versions);
+  });
+
+  // Get a specific version
+  router.get('/docs/:id/versions/:version', (req: Request, res: Response) => {
+    const doc = getDocument(db, req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    const versionNum = parseInt(req.params.version, 10);
+    if (isNaN(versionNum)) {
+      res.status(400).json({ error: 'Version must be a number' });
+      return;
+    }
+
+    const version = getVersionByNumber(db, req.params.id, versionNum);
+    if (!version) {
+      res.status(404).json({ error: 'Version not found' });
+      return;
+    }
+    res.json(version);
+  });
+
+  return router;
+}
