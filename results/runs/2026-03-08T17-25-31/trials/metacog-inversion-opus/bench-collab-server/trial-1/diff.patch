insert operation', async () => {\n   220→    const doc = await createDoc('Edit Doc', 'Hello');\n   221→    const client = await connectWs(doc.id as string);\n   222→    const syncMsg = await client.nextMessage();\n   223→\n   224→    sendOp(client, { type: 'insert', position: 5, text: ' World' }, syncMsg.version as number);\n   225→    const ack = await client.nextMessage();\n   226→\n   227→    expect(ack.type).toBe('ack');\n   228→    expect(ack.version).toBe(1);\n   229→\n   230→    const res = await request(appInstance.app).get(`/docs/${doc.id}`);\n   231→    expect(res.body.content).toBe('Hello World');\n   232→\n   233→    client.close();\n   234→  });\n   235→\n   236→  it('should apply a delete operation', async () => {\n   237→    const doc = await createDoc('Delete Doc', 'Hello World');\n   238→    const client = await connectWs(doc.id as string);\n   239→    const syncMsg = await client.nextMessage();\n   240→\n   241→    sendOp(client, { type: 'delete', position: 5, count: 6 }, syncMsg.version as number);\n   242→    const ack = await client.nextMessage();\n   243→\n   244→    expect(ack.type).toBe('ack');\n   245→\n   246→    const res = await request(appInstance.app).get(`/docs/${doc.id}`);\n   247→    expect(res.body.content).toBe('Hello');\n   248→\n   249→    client.close();\n   250→  });\n   251→\n   252→  it('should apply multiple sequential operations', async () => {\n   253→    const doc = await createDoc('Sequential Doc', '');\n   254→    const client = await connectWs(doc.id as string);\n   255→    await client.nextMessage(); // sync\n   256→\n   257→    sendOp(client, { type: 'insert', position: 0, text: 'Hello' }, 0);\n   258→    const ack1 = await client.nextMessage();\n   259→    expect(ack1.version).toBe(1);\n   260→\n   261→    sendOp(client, { type: 'insert', position: 5, text: ' World' }, 1);\n   262→    const ack2 = await client.nextMessage();\n   263→    expect(ack2.version).toBe(2);\n   264→\n   265→    const res = await request(appInstance.app).get(`/docs/${doc.id}`);\n   266→    expect(res.body.content).toBe('Hello World');\n   267→\n   268→    client.close();\n   269→  });\n   270→\n   271→  it('should track versions in history', async () => {\n   272→    const doc = await createDoc('History Doc', 'A');\n   273→    const client = await connectWs(doc.id as string);\n   274→    await client.nextMessage(); // sync\n   275→\n   276→    sendOp(client, { type: 'insert', position: 1, text: 'B' }, 0);\n   277→    await client.nextMessage(); // ack\n   278→\n   279→    sendOp(client, { type: 'insert', position: 2, text: 'C' }, 1);\n   280→    await client.nextMessage(); // ack\n   281→\n   282→    const res = await request(appInstance.app).get(`/docs/${doc.id}/versions`);\n   283→    expect(res.body.length).toBeGreaterThanOrEqual(3);\n   284→\n   285→    client.close();\n   286→  });\n   287→});\n   288→\n   289→describe('Two-Client Convergence', () => {\n   290→  it('should broadcast operations to other clients', async () => {\n   291→    const doc = await createDoc('Broadcast Doc', 'Hello');\n   292→    const c1 = await connectWs(doc.id as string);\n   293→    const c2 = await connectWs(doc.id as string);\n   294→\n   295→    await c1.nextMessage(); // sync\n   296→    await c2.nextMessage(); // sync\n   297→\n   298→    sendOp(c1, { type: 'insert', position: 5, text: '!' }, 0);\n   299→    const ack = await c1.nextMessage();\n   300→    expect(ack.type).toBe('ack');\n   301→\n   302→    const broadcast = await c2.nextMessage();\n   303→    expect(broadcast.type).toBe('operation');\n   304→    expect(broadcast.version).toBe(1);\n   305→\n   306→    c1.close();\n   307→    c2.close();\n   308→  });\n   309→\n   310→  it('should handle concurrent inserts at different positions', async () => {\n   311→    const doc = await createDoc('Concurrent Doc', 'AB');\n   312→    const c1 = await connectWs(doc.id as string);\n   313→    const c2 = await connectWs(doc.id as string);\n   314→\n   315→    await c1.nextMessage(); // sync\n   316→    await c2.nextMessage(); // sync\n   317→\n   318→    // Client 1 inserts 'X' at position 1\n   319→    sendOp(c1, { type: 'insert', position: 1, text: 'X' }, 0);\n   320→    const ack1 = await c1.nextMessage();\n   321→    expect(ack1.type).toBe('ack');\n   322→    await c2.nextMessage(); // broadcast\n   323→\n   324→    // Client 2 inserts 'Y' at position 2, based on version 0\n   325→    sendOp(c2, { type: 'insert', position: 2, text: 'Y' }, 0);\n   326→    const ack2 = await c2.nextMessage();\n   327→    expect(ack2.type).toBe('ack');\n   328→\n   329→    const res = await request(appInstance.app).get(`/docs/${doc.id}`);\n   330→    expect(res.body.content).toContain('X');\n   331→    expect(res.body.content).toContain('Y');\n   332→    expect(res.body.content).toContain('A');\n   333→    expect(res.body.content).toContain('B');\n   334→    expect(res.body.content.length).toBe(4);\n   335→\n   336→    c1.close();\n   337→    c2.close();\n   338→  });\n   339→\n   340→  it('should handle concurrent inserts at same position', async () => {\n   341→    const doc = await createDoc('Same Pos Doc', 'AB');\n   342→    const c1 = await connectWs(doc.id as string);\n   343→    const c2 = await connectWs(doc.id as string);\n   344→\n   345→    await c1.nextMessage(); // sync\n   346→    await c2.nextMessage(); // sync\n   347→\n   348→    sendOp(c1, { type: 'insert', position: 1, text: 'X' }, 0);\n   349→    await c1.nextMessage(); // ack\n   350→    await c2.nextMessage(); // broadcast\n   351→\n   352→    sendOp(c2, { type: 'insert', position: 1, text: 'Y' }, 0);\n   353→    await c2.nextMessage(); // ack\n   354→\n   355→    const res = await request(appInstance.app).get(`/docs/${doc.id}`);\n   356→    expect(res.body.content).toContain('X');\n   357→    expect(res.body.content).toContain('Y');\n   358→    expect(res.body.content.length).toBe(4);\n   359→\n   360→    c1.close();\n   361→    c2.close();\n   362→  });\n   363→\n   364→  it('should handle insert and delete concurrently', async () => {\n   365→    const doc = await createDoc('Ins Del Doc', 'ABCD');\n   366→    const c1 = await connectWs(doc.id as string);\n   367→    const c2 = await connectWs(doc.id as string);\n   368→\n   369→    await c1.nextMessage(); // sync\n   370→    await c2.nextMessage(); // sync\n   371→\n   372→    // Client 1 inserts 'X' at position 2\n   373→    sendOp(c1, { type: 'insert', position: 2, text: 'X' }, 0);\n   374→    await c1.nextMessage(); // ack\n   375→    await c2.nextMessage(); // broadcast\n   376→\n   377→    // Client 2 deletes 'C' (position 2, count 1) based on version 0\n   378→    sendOp(c2, { type: 'delete', position: 2, count: 1 }, 0);\n   379→    await c2.nextMessage(); // ack\n   380→\n   381→    const res = await request(appInstance.app).get(`/docs/${doc.id}`);\n   382→    expect(res.body.content).toContain('X');\n   383→    expect(res.body.content).toContain('A');\n   384→    expect(res.body.content).toContain('B');\n   385→    expect(res.body.content).toContain('D');\n   386→    expect(res.body.content).not.toContain('C');\n   387→\n   388→    c1.close();\n   389→    c2.close();\n   390→  });\n   391→\n   392→  it('should converge with rapid alternating edits', async () => {\n   393→    const doc = await createDoc('Rapid Doc', '');\n   394→    const c1 = await connectWs(doc.id as string);\n   395→    const c2 = await connectWs(doc.id as string);\n   396→\n   397→    await c1.nextMessage(); // sync\n   398→    await c2.nextMessage(); // sync\n   399→\n   400→    // C1 inserts 'A'\n   401→    sendOp(c1, { type: 'insert', position: 0, text: 'A' }, 0);\n   402→    const ack1 = await c1.nextMessage();\n   403→    await c2.nextMessage(); // broadcast\n   404→\n   405→    // C2 inserts 'B' with correct version\n   406→    sendOp(c2, { type: 'insert', position: 1, text: 'B' }, ack1.version as number);\n   407→    await c2.nextMessage(); // ack\n   408→    await c1.nextMessage(); // broadcast\n   409→\n   410→    const res = await request(appInstance.app).get(`/docs/${doc.id}`);\n   411→    expect(res.body.content).toBe('AB');\n   412→\n   413→    c1.close();\n   414→    c2.close();\n   415→  });\n   416→});\n   417→\n   418→describe('Error Handling', () => {\n   419→  it('should reject invalid JSON', async () => {\n   420→    const doc = await createDoc('Error Doc', 'content');\n   421→    const client = await connectWs(doc.id as string);\n   422→    await client.nextMessage(); // sync\n   423→\n   424→    client.ws.send('not json');\n   425→    const error = await client.nextMessage();\n   426→    expect(error.type).toBe('error');\n   427→\n   428→    client.close();\n   429→  });\n   430→\n   431→  it('should reject invalid operation type', async () => {\n   432→    const doc = await createDoc('Invalid Op Doc', 'content');\n   433→    const client = await connectWs(doc.id as string);\n   434→    await client.nextMessage(); // sync\n   435→\n   436→    client.ws.send(JSON.stringify({ type: 'operation', operation: { type: 'invalid' } }));\n   437→    const error = await client.nextMessage();\n   438→    expect(error.type).toBe('error');\n   439→\n   440→    client.close();\n   441→  });\n   442→\n   443→  it('should reject operation with missing fields', async () => {\n   444→    const doc = await createDoc('Missing Fields Doc', 'content');\n   445→    const client = await connectWs(doc.id as string);\n   446→    await client.nextMessage(); // sync\n   447→\n   448→    client.ws.send(JSON.stringify({ type: 'operation', operation: { type: 'insert' } }));\n   449→    const error = await client.nextMessage();\n   450→    expect(error.type).toBe('error');\n   451→\n   452→    client.close();\n   453→  });\n   454→\n   455→  it('should reject unknown message type', async () => {\n   456→    const doc = await createDoc('Unknown Type Doc', 'content');\n   457→    const client = await connectWs(doc.id as string);\n   458→    await client.nextMessage(); // sync\n   459→\n   460→    client.ws.send(JSON.stringify({ type: 'foobar' }));\n   461→    const error = await client.nextMessage();\n   462→    expect(error.type).toBe('error');\n   463→\n   464→    client.close();\n   465→  });\n   466→\n   467→  it('should reject missing title on create', async () => {\n   468→    await request(appInstance.app)\n   469→      .post('/docs')\n   470→      .send({ content: 'no title' })\n   471→      .expect(400);\n   472→  });\n   473→});\n   474→\n   475→describe('Stress Test', () => {\n   476→  it('should handle 10 concurrent clients without corruption', async () => {\n   477→    const doc = await createDoc('Stress Doc', '');\n   478→    const clients: WsClient[] = [];\n   479→\n   480→    // Connect 10 clients\n   481→    for (let i = 0; i < 10; i++) {\n   482→      const client = await connectWs(doc.id as string);\n   483→      await client.nextMessage(); // sync\n   484→      clients.push(client);\n   485→    }\n   486→\n   487→    // Each client sequentially inserts their digit\n   488→    for (let i = 0; i < 10; i++) {\n   489→      sendOp(clients[i], { type: 'insert', position: i, text: String(i) }, i);\n   490→      const ack = await clients[i].nextMessage();\n   491→      expect(ack.type).toBe('ack');\n   492→\n   493→      // Consume broadcasts on all other clients\n   494→      for (let j = 0; j < 10; j++) {\n   495→        if (j !== i) {\n   496→          await clients[j].nextMessage();\n   497→        }\n   498→      }\n   499→    }\n   500→\n   501→    // Verify all digits present\n   502→    const res = await request(appInstance.app).get(`/docs/${doc.id}`);\n   503→    expect(res.body.content.length).toBe(10);\n   504→    for (let i = 0; i < 10; i++) {\n   505→      expect(res.body.content).toContain(String(i));\n   506→    }\n   507→\n   508→    for (const client of clients) {\n   509→      client.close();\n   510→    }\n   511→  }, 30000);\n   512→\n   513→  it('should handle concurrent operations from many clients', async () => {\n   514→    const doc = await createDoc('Concurrent Stress', '');\n   515→    const clients: WsClient[] = [];\n   516→\n   517→    // Connect 10 clients\n   518→    for (let i = 0; i < 10; i++) {\n   519→      const client = await connectWs(doc.id as string);\n   520→      await client.nextMessage(); // sync\n   521→      clients.push(client);\n   522→    }\n   523→\n   524→    // All clients send insert at position 0 concurrently, all based on version 0\n   525→    const ackPromises: Promise<Record<string, unknown>>[] = [];\n   526→    for (let i = 0; i < 10; i++) {\n   527→      sendOp(clients[i], { type: 'insert', position: 0, text: String(i) }, 0);\n   528→      ackPromises.push(clients[i].nextMessage());\n   529→    }\n   530→\n   531→    const acks = await Promise.all(ackPromises);\n   532→    for (const ack of acks) {\n   533→      expect(ack.type).toBe('ack');\n   534→    }\n   535→\n   536→    // Wait for broadcasts to settle\n   537→    await new Promise(resolve => setTimeout(resolve, 500));\n   538→\n   539→    // Verify all digits present\n   540→    const res = await request(appInstance.app).get(`/docs/${doc.id}`);\n   541→    expect(res.body.content.length).toBe(10);\n   542→    for (let i = 0; i < 10; i++) {\n   543→      expect(res.body.content).toContain(String(i));\n   544→    }\n   545→\n   546→    for (const client of clients) {\n   547→      client.close();\n   548→    }\n   549→  }, 30000);\n   550→});\n   551→\n   552→describe('Persistence', () => {\n   553→  it('should persist data across server restarts', async () => {\n   554→    const tmpDb = `/tmp/test-collab-${Date.now()}.db`;\n   555→\n   556→    const app1 = createApp(tmpDb);\n   557→    await app1.start(0);\n   558→\n   559→    const res = await request(app1.app)\n   560→      .post('/docs')\n   561→      .send({ title: 'Persistent Doc', content: 'persisted content' })\n   562→      .expect(201);\n   563→\n   564→    const docId = res.body.id;\n   565→    await app1.stop();\n   566→\n   567→    const app2 = createApp(tmpDb);\n   568→    await app2.start(0);\n   569→\n   570→    const res2 = await request(app2.app)\n   571→      .get(`/docs/${docId}`)\n   572→      .expect(200);\n   573→\n   574→    expect(res2.body.title).toBe('Persistent Doc');\n   575→    expect(res2.body.content).toBe('persisted content');\n   576→\n   577→    await app2.stop();\n   578→\n   579→    const fs = await import('fs');\n   580→    try { fs.unlinkSync(tmpDb); } catch { /* ignore */ }\n   581→    try { fs.unlinkSync(tmpDb + '-wal'); } catch { /* ignore */ }\n   582→    try { fs.unlinkSync(tmpDb + '-shm'); } catch { /* ignore */ }\n   583→  });\n   584→\n   585→  it('should persist version history across restarts', async () => {\n   586→    const tmpDb = `/tmp/test-collab-versions-${Date.now()}.db`;\n   587→\n   588→    const app1 = createApp(tmpDb);\n   589→    await app1.start(0);\n   590→\n   591→    const res = await request(app1.app)\n   592→      .post('/docs')\n   593→      .send({ title: 'V Doc', content: 'initial' })\n   594→      .expect(201);\n   595→\n   596→    const docId = res.body.id;\n   597→\n   598→    // Check versions\n   599→    const v1 = await request(app1.app).get(`/docs/${docId}/versions`);\n   600→    expect(v1.body.length).toBe(1);\n   601→\n   602→    await app1.stop();\n   603→\n   604→    const app2 = createApp(tmpDb);\n   605→    await app2.start(0);\n   606→\n   607→    const v2 = await request(app2.app).get(`/docs/${docId}/versions`);\n   608→    expect(v2.body.length).toBe(1);\n   609→    expect(v2.body[0].content).toBe('initial');\n   610→\n   611→    await app2.stop();\n   612→\n   613→    const fs = await import('fs');\n   614→    try { fs.unlinkSync(tmpDb); } catch { /* ignore */ }\n   615→    try { fs.unlinkSync(tmpDb + '-wal'); } catch { /* ignore */ }\n   616→    try { fs.unlinkSync(tmpDb + '-shm'); } catch { /* ignore */ }\n   617→  });\n   618→});\n   619→"}]},"parent_tool_use_id":null,"session_id":"e43f491b-905c-4860-a1c8-46b93f296faf","uuid":"9e5ab3f0-3c86-4565-9080-3c32d8bb1038","tool_use_result":{"type":"update","filePath":"/workspace/tests/collab.test.ts","content":"import { describe, it, expect, beforeEach, afterEach } from 'vitest';\nimport request from 'supertest';\nimport WebSocket from 'ws';\nimport { createApp, AppInstance } from '../src/server.js';\n\nlet appInstance: AppInstance;\nlet port: number;\n\ninterface WsClient {\n  ws: WebSocket;\n  nextMessage: () => Promise<Record<string, unknown>>;\n  close: () => void;\n}\n\nfunction wsUrl(docId: string): string {\n  return `ws://localhost:${port}/${docId}`;\n}\n\nfunction connectWs(docId: string): Promise<WsClient> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(wsUrl(docId));\n    const messages: Record<string, unknown>[] = [];\n    const waiters: Array<(msg: Record<string, unknown>) => void> = [];\n\n    ws.on('message', (data) => {\n      const msg = JSON.parse(String(data));\n      if (waiters.length > 0) {\n        const waiter = waiters.shift()!;\n        waiter(msg);\n      } else {\n        messages.push(msg);\n      }\n    });\n\n    ws.on('open', () => {\n      resolve({\n        ws,\n        nextMessage: () => {\n          if (messages.length > 0) {\n            return Promise.resolve(messages.shift()!);\n          }\n          return new Promise<Record<string, unknown>>((res) => {\n            waiters.push(res);\n          });\n        },\n        close: () => ws.close(),\n      });\n    });\n\n    ws.on('error', reject);\n  });\n}\n\nfunction sendOp(client: WsClient, operation: object, version?: number): void {\n  const msg: Record<string, unknown> = { type: 'operation', operation };\n  if (version !== undefined) msg.version = version;\n  client.ws.send(JSON.stringify(msg));\n}\n\nasync function createDoc(title: string, content: string = ''): Promise<Record<string, unknown>> {\n  const res = await request(appInstance.app)\n    .post('/docs')\n    .send({ title, content });\n  return res.body;\n}\n\nbeforeEach(async () => {\n  appInstance = createApp();\n  port = await appInstance.start(0);\n});\n\nafterEach(async () => {\n  await appInstance.stop();\n});\n\ndescribe('REST API', () => {\n  it('should create a document', async () => {\n    const res = await request(appInstance.app)\n      .post('/docs')\n      .send({ title: 'Test Doc', content: 'Hello' })\n      .expect(201);\n\n    expect(res.body.id).toBeDefined();\n    expect(res.body.title).toBe('Test Doc');\n    expect(res.body.content).toBe('Hello');\n  });\n\n  it('should create a document with empty content', async () => {\n    const res = await request(appInstance.app)\n      .post('/docs')\n      .send({ title: 'Empty Doc' })\n      .expect(201);\n\n    expect(res.body.content).toBe('');\n  });\n\n  it('should list documents', async () => {\n    await createDoc('Doc 1');\n    await createDoc('Doc 2');\n\n    const res = await request(appInstance.app)\n      .get('/docs')\n      .expect(200);\n\n    expect(res.body).toHaveLength(2);\n  });\n\n  it('should get a document by id', async () => {\n    const doc = await createDoc('My Doc', 'content here');\n\n    const res = await request(appInstance.app)\n      .get(`/docs/${doc.id}`)\n      .expect(200);\n\n    expect(res.body.title).toBe('My Doc');\n    expect(res.body.content).toBe('content here');\n  });\n\n  it('should return 404 for non-existent document', async () => {\n    await request(appInstance.app)\n      .get('/docs/nonexistent')\n      .expect(404);\n  });\n\n  it('should update a document', async () => {\n    const doc = await createDoc('Old Title', 'old content');\n\n    const res = await request(appInstance.app)\n      .put(`/docs/${doc.id}`)\n      .send({ title: 'New Title', content: 'new content' })\n      .expect(200);\n\n    expect(res.body.title).toBe('New Title');\n    expect(res.body.content).toBe('new content');\n  });\n\n  it('should delete a document', async () => {\n    const doc = await createDoc('To Delete');\n\n    await request(appInstance.app)\n      .delete(`/docs/${doc.id}`)\n      .expect(204);\n\n    await request(appInstance.app)\n      .get(`/docs/${doc.id}`)\n      .expect(404);\n  });\n\n  it('should get version history', async () => {\n    const doc = await createDoc('Versioned Doc', 'initial');\n\n    const res = await request(appInstance.app)\n      .get(`/docs/${doc.id}/versions`)\n      .expect(200);\n\n    expect(res.body).toHaveLength(1);\n    expect(res.body[0].version).toBe(0);\n    expect(res.body[0].content).toBe('initial');\n  });\n\n  it('should get a specific version', async () => {\n    const doc = await createDoc('Version Doc', 'v0 content');\n\n    const res = await request(appInstance.app)\n      .get(`/docs/${doc.id}/versions/0`)\n      .expect(200);\n\n    expect(res.body.version).toBe(0);\n    expect(res.body.content).toBe('v0 content');\n  });\n\n  it('should return 404 for non-existent version', async () => {\n    const doc = await createDoc('Version Doc', 'content');\n\n    await request(appInstance.app)\n      .get(`/docs/${doc.id}/versions/999`)\n      .expect(404);\n  });\n});\n\ndescribe('WebSocket Lifecycle', () => {\n  it('should connect and receive sync message', async () => {\n    const doc = await createDoc('WS Doc', 'hello world');\n    const client = await connectWs(doc.id as string);\n    const syncMsg = await client.nextMessage();\n\n    expect(syncMsg.type).toBe('sync');\n    expect(syncMsg.content).toBe('hello world');\n    expect(syncMsg.version).toBe(0);\n    expect(syncMsg.documentId).toBe(doc.id);\n\n    client.close();\n  });\n\n  it('should reject connection for non-existent document', async () => {\n    const client = await connectWs('nonexistent');\n    const msg = await client.nextMessage();\n    expect(msg.type).toBe('error');\n    client.close();\n  });\n\n  it('should allow multiple clients on same document', async () => {\n    const doc = await createDoc('Multi Doc', 'content');\n    const c1 = await connectWs(doc.id as string);\n    const c2 = await connectWs(doc.id as string);\n\n    const sync1 = await c1.nextMessage();\n    const sync2 = await c2.nextMessage();\n\n    expect(sync1.type).toBe('sync');\n    expect(sync2.type).toBe('sync');\n\n    c1.close();\n    c2.close();\n  });\n});\n\ndescribe('Single Client Editing', () => {\n  it('should apply an insert operation', async () => {\n    const doc = await createDoc('Edit Doc', 'Hello');\n    const client = await connectWs(doc.id as string);\n    const syncMsg = await client.nextMessage();\n\n    sendOp(client, { type: 'insert', position: 5, text: ' World' }, syncMsg.version as number);\n    const ack = await client.nextMessage();\n\n    expect(ack.type).toBe('ack');\n    expect(ack.version).toBe(1);\n\n    const res = await request(appInstance.app).get(`/docs/${doc.id}`);\n    expect(res.body.content).toBe('Hello World');\n\n    client.close();\n  });\n\n  it('should apply a delete operation', async () => {\n    const doc = await createDoc('Delete Doc', 'Hello World');\n    const client = await connectWs(doc.id as string);\n    const syncMsg = await client.nextMessage();\n\n    sendOp(client, { type: 'delete', position: 5, count: 6 }, syncMsg.version as number);\n    const ack = await client.nextMessage();\n\n    expect(ack.type).toBe('ack');\n\n    const res = await request(appInstance.app).get(`/docs/${doc.id}`);\n    expect(res.body.content).toBe('Hello');\n\n    client.close();\n  });\n\n  it('should apply multiple sequential operations', async () => {\n    const doc = await createDoc('Sequential Doc', '');\n    const client = await connectWs(doc.id as string);\n    await client.nextMessage(); // sync\n\n    sendOp(client, { type: 'insert', position: 0, text: 'Hello' }, 0);\n    const ack1 = await client.nextMessage();\n    expect(ack1.version).toBe(1);\n\n    sendOp(client, { type: 'insert', position: 5, text: ' World' }, 1);\n    const ack2 = await client.nextMessage();\n    expect(ack2.version).toBe(2);\n\n    const res = await request(appInstance.app).get(`/docs/${doc.id}`);\n    expect(res.body.content).toBe('Hello World');\n\n    client.close();\n  });\n\n  it('should track versions in history', async () => {\n    const doc = await createDoc('History Doc', 'A');\n    const client = await connectWs(doc.id as string);\n    await client.nextMessage(); // sync\n\n    sendOp(client, { type: 'insert', position: 1, text: 'B' }, 0);\n    await client.nextMessage(); // ack\n\n    sendOp(client, { type: 'insert', position: 2, text: 'C' }, 1);\n    await client.nextMessage(); // ack\n\n    const res = await request(appInstance.app).get(`/docs/${doc.id}/versions`);\n    expect(res.body.length).toBeGreaterThanOrEqual(3);\n\n    client.close();\n  });\n});\n\ndescribe('Two-Client Convergence', () => {\n  it('should broadcast operations to other clients', async () => {\n    const doc = await createDoc('Broadcast Doc', 'Hello');\n    const c1 = await connectWs(doc.id as string);\n    const c2 = await connectWs(doc.id as string);\n\n    await c1.nextMessage(); // sync\n    await c2.nextMessage(); // sync\n\n    sendOp(c1, { type: 'insert', position: 5, text: '!' }, 0);\n    const ack = await c1.nextMessage();\n    expect(ack.type).toBe('ack');\n\n    const broadcast = await c2.nextMessage();\n    expect(broadcast.type).toBe('operation');\n    expect(broadcast.version).toBe(1);\n\n    c1.close();\n    c2.close();\n  });\n\n  it('should handle concurrent inserts at different positions', async () => {\n    const doc = await createDoc('Concurrent Doc', 'AB');\n    const c1 = await connectWs(doc.id as string);\n    const c2 = await connectWs(doc.id as string);\n\n    await c1.nextMessage(); // sync\n    await c2.nextMessage(); // sync\n\n    // Client 1 inserts 'X' at position 1\n    sendOp(c1, { type: 'insert', position: 1, text: 'X' }, 0);\n    const ack1 = await c1.nextMessage();\n    expect(ack1.type).toBe('ack');\n    await c2.nextMessage(); // broadcast\n\n    // Client 2 inserts 'Y' at position 2, based on version 0\n    sendOp(c2, { type: 'insert', position: 2, text: 'Y' }, 0);\n    const ack2 = await c2.nextMessage();\n    expect(ack2.type).toBe('ack');\n\n    const res = await request(appInstance.app).get(`/docs/${doc.id}`);\n    expect(res.body.content).toContain('X');\n    expect(res.body.content).toContain('Y');\n    expect(res.body.content).toContain('A');\n    expect(res.body.content).toContain('B');\n    expect(res.body.content.length).toBe(4);\n\n    c1.close();\n    c2.close();\n  });\n\n  it('should handle concurrent inserts at same position', async () => {\n    const doc = await createDoc('Same Pos Doc', 'AB');\n    const c1 = await connectWs(doc.id as string);\n    const c2 = await connectWs(doc.id as string);\n\n    await c1.nextMessage(); // sync\n    await c2.nextMessage(); // sync\n\n    sendOp(c1, { type: 'insert', position: 1, text: 'X' }, 0);\n    await c1.nextMessage(); // ack\n    await c2.nextMessage(); // broadcast\n\n    sendOp(c2, { type: 'insert', position: 1, text: 'Y' }, 0);\n    await c2.nextMessage(); // ack\n\n    const res = await request(appInstance.app).get(`/docs/${doc.id}`);\n    expect(res.body.content).toContain('X');\n    expect(res.body.content).toContain('Y');\n    expect(res.body.content.length).toBe(4);\n\n    c1.close();\n    c2.close();\n  });\n\n  it('should handle insert and delete concurrently', async () => {\n    const doc = await createDoc('Ins Del Doc', 'ABCD');\n    const c1 = await connectWs(doc.id as string);\n    const c2 = await connectWs(doc.id as string);\n\n    await c1.nextMessage(); // sync\n    await c2.nextMessage(); // sync\n\n    // Client 1 inserts 'X' at position 2\n    sendOp(c1, { type: 'insert', position: 2, text: 'X' }, 0);\n    await c1.nextMessage(); // ack\n    await c2.nextMessage(); // broadcast\n\n    // Client 2 deletes 'C' (position 2, count 1) based on version 0\n    sendOp(c2, { type: 'delete', position: 2, count: 1 }, 0);\n    await c2.nextMessage(); // ack\n\n    const res = await request(appInstance.app).get(`/docs/${doc.id}`);\n    expect(res.body.content).toContain('X');\n    expect(res.body.content).toContain('A');\n    expect(res.body.content).toContain('B');\n    expect(res.body.content).toContain('D');\n    expect(res.body.content).not.toContain('C');\n\n    c1.close();\n    c2.close();\n  });\n\n  it('should converge with rapid alternating edits', async () => {\n    const doc = await createDoc('Rapid Doc', '');\n    const c1 = await connectWs(doc.id as string);\n    const c2 = await connectWs(doc.id as string);\n\n    await c1.nextMessage(); // sync\n    await c2.nextMessage(); // sync\n\n    // C1 inserts 'A'\n    sendOp(c1, { type: 'insert', position: 0, text: 'A' }, 0);\n    const ack1 = await c1.nextMessage();\n    await c2.nextMessage(); // broadcast\n\n    // C2 inserts 'B' with correct version\n    sendOp(c2, { type: 'insert', position: 1, text: 'B' }, ack1.version as number);\n    await c2.nextMessage(); // ack\n    await c1.nextMessage(); // broadcast\n\n    const res = await request(appInstance.app).get(`/docs/${doc.id}`);\n    expect(res.body.content).toBe('AB');\n\n    c1.close();\n    c2.close();\n  });\n});\n\ndescribe('Error Handling', () => {\n  it('should reject invalid JSON', async () => {\n    const doc = await createDoc('Error Doc', 'content');\n    const client = await connectWs(doc.id as string);\n    await client.nextMessage(); // sync\n\n    client.ws.send('not json');\n    const error = await client.nextMessage();\n    expect(error.type).toBe('error');\n\n    client.close();\n  });\n\n  it('should reject invalid operation type', async () => {\n    const doc = await createDoc('Invalid Op Doc', 'content');\n    const client = await connectWs(doc.id as string);\n    await client.nextMessage(); // sync\n\n    client.ws.send(JSON.stringify({ type: 'operation', operation: { type: 'invalid' } }));\n    const error = await client.nextMessage();\n    expect(error.type).toBe('error');\n\n    client.close();\n  });\n\n  it('should reject operation with missing fields', async () => {\n    const doc = await createDoc('Missing Fields Doc', 'content');\n    const client = await connectWs(doc.id as string);\n    await client.nextMessage(); // sync\n\n    client.ws.send(JSON.stringify({ type: 'operation', operation: { type: 'insert' } }));\n    const error = await client.nextMessage();\n    expect(error.type).toBe('error');\n\n    client.close();\n  });\n\n  it('should reject unknown message type', async () => {\n    const doc = await createDoc('Unknown Type Doc', 'content');\n    const client = await connectWs(doc.id as string);\n    await client.nextMessage(); // sync\n\n    client.ws.send(JSON.stringify({ type: 'foobar' }));\n    const error = await client.nextMessage();\n    expect(error.type).toBe('error');\n\n    client.close();\n  });\n\n  it('should reject missing title on create', async () => {\n    await request(appInstance.app)\n      .post('/docs')\n      .send({ content: 'no title' })\n      .expect(400);\n  });\n});\n\ndescribe('Stress Test', () => {\n  it('should handle 10 concurrent clients without corruption', async () => {\n    const doc = await createDoc('Stress Doc', '');\n    const clients: WsClient[] = [];\n\n    // Connect 10 clients\n    for (let i = 0; i < 10; i++) {\n      const client = await connectWs(doc.id as string);\n      await client.nextMessage(); // sync\n      clients.push(client);\n    }\n\n    // Each client sequentially inserts their digit\n    for (let i = 0; i < 10; i++) {\n      sendOp(clients[i], { type: 'insert', position: i, text: String(i) }, i);\n      const ack = await clients[i].nextMessage();\n      expect(ack.type).toBe('ack');\n\n      // Consume broadcasts on all other clients\n      for (let j = 0; j < 10; j++) {\n        if (j !== i) {\n          await clients[j].nextMessage();\n        }\n      }\n    }\n\n    // Verify all digits present\n    const res = await request(appInstance.app).get(`/docs/${doc.id}`);\n    expect(res.body.content.length).toBe(10);\n    for (let i = 0; i < 10; i++) {\n      expect(res.body.content).toContain(String(i));\n    }\n\n    for (const client of clients) {\n      client.close();\n    }\n  }, 30000);\n\n  it('should handle concurrent operations from many clients', async () => {\n    const doc = await createDoc('Concurrent Stress', '');\n    const clients: WsClient[] = [];\n\n    // Connect 10 clients\n    for (let i = 0; i < 10; i++) {\n      const client = await connectWs(doc.id as string);\n      await client.nextMessage(); // sync\n      clients.push(client);\n    }\n\n    // All clients send insert at position 0 concurrently, all based on version 0\n    const ackPromises: Promise<Record<string, unknown>>[] = [];\n    for (let i = 0; i < 10; i++) {\n      sendOp(clients[i], { type: 'insert', position: 0, text: String(i) }, 0);\n      ackPromises.push(clients[i].nextMessage());\n    }\n\n    const acks = await Promise.all(ackPromises);\n    for (const ack of acks) {\n      expect(ack.type).toBe('ack');\n    }\n\n    // Wait for broadcasts to settle\n    await new Promise(resolve => setTimeout(resolve, 500));\n\n    // Verify all digits present\n    const res = await request(appInstance.app).get(`/docs/${doc.id}`);\n    expect(res.body.content.length).toBe(10);\n    for (let i = 0; i < 10; i++) {\n      expect(res.body.content).toContain(String(i));\n    }\n\n    for (const client of clients) {\n      client.close();\n    }\n  }, 30000);\n});\n\ndescribe('Persistence', () => {\n  it('should persist data across server restarts', async () => {\n    const tmpDb = `/tmp/test-collab-${Date.now()}.db`;\n\n    const app1 = createApp(tmpDb);\n    await app1.start(0);\n\n    const res = await request(app1.app)\n      .post('/docs')\n      .send({ title: 'Persistent Doc', content: 'persisted content' })\n      .expect(201);\n\n    const docId = res.body.id;\n    await app1.stop();\n\n    const app2 = createApp(tmpDb);\n    await app2.