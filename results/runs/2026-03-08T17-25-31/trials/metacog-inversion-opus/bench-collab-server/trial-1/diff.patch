t.nextMessage();\n    expect(ack1.version).toBe(1);\n\n    sendOp(client, { type: 'insert', position: 5, text: ' World' }, 1);\n    const ack2 = await client.nextMessage();\n    expect(ack2.version).toBe(2);\n\n    const res = await request(appInstance.app).get(`/docs/${doc.id}`);\n    expect(res.body.content).toBe('Hello World');\n\n    client.close();\n  });\n\n  it('should track versions in history', async () => {\n    const doc = await createDoc('History Doc', 'A');\n    const client = await connectWs(doc.id as string);\n    await client.nextMessage(); // sync\n\n    sendOp(client, { type: 'insert', position: 1, text: 'B' }, 0);\n    await client.nextMessage(); // ack\n\n    sendOp(client, { type: 'insert', position: 2, text: 'C' }, 1);\n    await client.nextMessage(); // ack\n\n    const res = await request(appInstance.app).get(`/docs/${doc.id}/versions`);\n    expect(res.body.length).toBeGreaterThanOrEqual(3); // v0, v1, v2\n\n    client.close();\n  });\n});\n\ndescribe('Two-Client Convergence', () => {\n  it('should broadcast operations to other clients', async () => {\n    const doc = await createDoc('Broadcast Doc', 'Hello');\n    const c1 = await connectWs(doc.id as string);\n    const c2 = await connectWs(doc.id as string);\n\n    await c1.nextMessage(); // sync\n    await c2.nextMessage(); // sync\n\n    sendOp(c1, { type: 'insert', position: 5, text: '!' }, 0);\n    const ack = await c1.nextMessage(); // ack\n    expect(ack.type).toBe('ack');\n\n    const broadcast = await c2.nextMessage();\n    expect(broadcast.type).toBe('operation');\n    expect(broadcast.version).toBe(1);\n\n    c1.close();\n    c2.close();\n  });\n\n  it('should handle concurrent inserts at different positions', async () => {\n    const doc = await createDoc('Concurrent Doc', 'AB');\n    const c1 = await connectWs(doc.id as string);\n    const c2 = await connectWs(doc.id as string);\n\n    await c1.nextMessage(); // sync\n    await c2.nextMessage(); // sync\n\n    // Client 1 inserts 'X' at position 1\n    sendOp(c1, { type: 'insert', position: 1, text: 'X' }, 0);\n    const ack1 = await c1.nextMessage(); // ack\n    expect(ack1.type).toBe('ack');\n    await c2.nextMessage(); // broadcast\n\n    // Client 2 inserts 'Y' at position 2, based on version 0\n    sendOp(c2, { type: 'insert', position: 2, text: 'Y' }, 0);\n    const ack2 = await c2.nextMessage(); // ack\n    expect(ack2.type).toBe('ack');\n\n    // Verify convergence\n    const res = await request(appInstance.app).get(`/docs/${doc.id}`);\n    expect(res.body.content).toContain('X');\n    expect(res.body.content).toContain('Y');\n    expect(res.body.content).toContain('A');\n    expect(res.body.content).toContain('B');\n    expect(res.body.content.length).toBe(4);\n\n    c1.close();\n    c2.close();\n  });\n\n  it('should handle concurrent inserts at same position', async () => {\n    const doc = await createDoc('Same Pos Doc', 'AB');\n    const c1 = await connectWs(doc.id as string);\n    const c2 = await connectWs(doc.id as string);\n\n    await c1.nextMessage(); // sync\n    await c2.nextMessage(); // sync\n\n    // Both insert at position 1, based on version 0\n    sendOp(c1, { type: 'insert', position: 1, text: 'X' }, 0);\n    await c1.nextMessage(); // ack\n    await c2.nextMessage(); // broadcast\n\n    sendOp(c2, { type: 'insert', position: 1, text: 'Y' }, 0);\n    await c2.nextMessage(); // ack\n\n    const res = await request(appInstance.app).get(`/docs/${doc.id}`);\n    expect(res.body.content).toContain('X');\n    expect(res.body.content).toContain('Y');\n    expect(res.body.content.length).toBe(4);\n\n    c1.close();\n    c2.close();\n  });\n\n  it('should handle insert and delete concurrently', async () => {\n    const doc = await createDoc('Ins Del Doc', 'ABCD');\n    const c1 = await connectWs(doc.id as string);\n    const c2 = await connectWs(doc.id as string);\n\n    await c1.nextMessage(); // sync\n    await c2.nextMessage(); // sync\n\n    // Client 1 inserts 'X' at position 2\n    sendOp(c1, { type: 'insert', position: 2, text: 'X' }, 0);\n    await c1.nextMessage(); // ack\n    await c2.nextMessage(); // broadcast\n\n    // Client 2 deletes 'C' (position 2, count 1) based on version 0\n    sendOp(c2, { type: 'delete', position: 2, count: 1 }, 0);\n    await c2.nextMessage(); // ack\n\n    const res = await request(appInstance.app).get(`/docs/${doc.id}`);\n    // Original: ABCD -> insert X at 2 -> ABXCD -> delete at pos 3 (C shifted) -> ABXD\n    expect(res.body.content).toContain('X');\n    expect(res.body.content).toContain('A');\n    expect(res.body.content).toContain('B');\n    expect(res.body.content).toContain('D');\n    expect(res.body.content).not.toContain('C');\n\n    c1.close();\n    c2.close();\n  });\n\n  it('should converge with rapid alternating edits', async () => {\n    const doc = await createDoc('Rapid Doc', '');\n    const c1 = await connectWs(doc.id as string);\n    const c2 = await connectWs(doc.id as string);\n\n    await c1.nextMessage(); // sync\n    await c2.nextMessage(); // sync\n\n    // C1 inserts 'A'\n    sendOp(c1, { type: 'insert', position: 0, text: 'A' }, 0);\n    const ack1 = await c1.nextMessage();\n    await c2.nextMessage(); // broadcast\n\n    // C2 inserts 'B' with correct version\n    sendOp(c2, { type: 'insert', position: 1, text: 'B' }, ack1.version as number);\n    await c2.nextMessage(); // ack\n    await c1.nextMessage(); // broadcast\n\n    const res = await request(appInstance.app).get(`/docs/${doc.id}`);\n    expect(res.body.content).toBe('AB');\n\n    c1.close();\n    c2.close();\n  });\n});\n\ndescribe('Error Handling', () => {\n  it('should reject invalid JSON', async () => {\n    const doc = await createDoc('Error Doc', 'content');\n    const client = await connectWs(doc.id as string);\n    await client.nextMessage(); // sync\n\n    client.ws.send('not json');\n    const error = await client.nextMessage();\n    expect(error.type).toBe('error');\n\n    client.close();\n  