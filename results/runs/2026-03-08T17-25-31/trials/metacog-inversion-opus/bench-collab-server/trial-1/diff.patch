+import express from 'express';
+import { createServer, Server as HttpServer } from 'http';
+import type Database from 'better-sqlite3';
+import { createDatabase } from './db.js';
+import { createRouter } from './routes.js';
+import { CollaborationManager } from './ws.js';
+
+export interface AppInstance {
+  app: express.Express;
+  start: (port?: number) => Promise<number>;
+  stop: () => Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db: Database.Database = createDatabase(dbPath);
+  const app = express();
+  let server: HttpServer | null = null;
+
+  app.use(express.json());
+
+  const router = createRouter(db);
+  app.use(router);
+
+  const collaborationManager = new CollaborationManager(db);
+
+  const start = async (port?: number): Promise<number> => {
+    return new Promise((resolve) => {
+      server = createServer(app);
+      collaborationManager.attach(server);
+
+      server.listen(port || 0, () => {
+        const addr = server!.address();
+        const actualPort = typeof addr === 'object' && addr ? addr.port : 0;
+        resolve(actualPort);
+      });
+    });
+  };
+
+  const stop = async (): Promise<void> => {
+    return new Promise((resolve, reject) => {
+      collaborationManager.closeAll();
+
+      if (server) {
+        server.close((err) => {
+          db.close();
+          if (err) reject(err);
+          else resolve();
+        });
+        server = null;
+      } else {
+        db.close();
+        resolve();
+      }
+    });
+  };
+
+  return { app, start, stop };
+}
