+import { WebSocketServer, WebSocket } from 'ws';
+import type { Server as HttpServer } from 'http';
+import type Database from 'better-sqlite3';
+import { getDocument, getDocumentVersion, addVersion, getOperationsSinceVersion } from './db.js';
+import { Operation, applyOperation, transformOperation, validateOperation, validateOperationForContent } from './ot.js';
+
+interface ClientInfo {
+  ws: WebSocket;
+  documentId: string;
+}
+
+interface OperationMessage {
+  type: 'operation';
+  operation: Operation;
+  version?: number;
+}
+
+interface IncomingMessage {
+  type: string;
+  [key: string]: unknown;
+}
+
+export class CollaborationManager {
+  private wss: WebSocketServer | null = null;
+  private clients: Map<WebSocket, ClientInfo> = new Map();
+  private db: Database.Database;
+
+  constructor(db: Database.Database) {
+    this.db = db;
+  }
+
+  attach(server: HttpServer): void {
+    this.wss = new WebSocketServer({ server });
+
+    this.wss.on('connection', (ws: WebSocket, req) => {
+      const url = req.url;
+      if (!url) {
+        ws.send(JSON.stringify({ type: 'error', message: 'No URL provided' }));
+        ws.close();
+        return;
+      }
+
+      // Extract document ID from URL path: /docId or /ws/docId etc.
+      // Support paths like /:docId or /ws/:docId
+      const pathParts = url.split('/').filter(Boolean);
+      const documentId = pathParts[pathParts.length - 1];
+
+      if (!documentId) {
+        ws.send(JSON.stringify({ type: 'error', message: 'No document ID provided' }));
+        ws.close();
+        return;
+      }
+
+      // Look up the document
+      const doc = getDocument(this.db, documentId);
+      if (!doc) {
+        ws.send(JSON.stringify({ type: 'error', message: 'Document not found' }));
+        ws.close();
+        return;
+      }
+
+      // Register client
+      this.clients.set(ws, { ws, documentId });
+
+      // Send initial sync with current document state
+      const version = getDocumentVersion(this.db, documentId);
+      ws.send(JSON.stringify({
+        type: 'sync',
+        content: doc.content,
+        version,
+        documentId,
+      }));
+
+      ws.on('message', (data) => {
+        this.handleMessage(ws, data);
+      });
+
+      ws.on('close', () => {
+        this.clients.delete(ws);
+      });
+
+      ws.on('error', () => {
+        this.clients.delete(ws);
+      });
+    });
+  }
+
+  private handleMessage(ws: WebSocket, data: unknown): void {
+    let message: IncomingMessage;
+    try {
+      message = JSON.parse(String(data)) as IncomingMessage;
+    } catch {
+      ws.send(JSON.stringify({ type: 'error', message: 'Invalid JSON' }));
+      return;
+    }
+
+    if (!message || typeof message.type !== 'string') {
+      ws.send(JSON.stringify({ type: 'error', message: 'Message must have a type field' }));
+      return;
+    }
+
+    if (message.type === 'operation') {
+      this.handleOperation(ws, message as unknown as OperationMessage);
+    } else {
+      ws.send(JSON.stringify({ type: 'error', message: `Unknown message type: ${message.type}` }));
+    }
+  }
+
+  private handleOperation(ws: WebSocket, message: OperationMessage): void {
+    const clientInfo = this.clients.get(ws);
+    if (!clientInfo) {
+      ws.send(JSON.stringify({ type: 'error', message: 'Not connected to a document' }));
+      return;
+    }
+
+    const { documentId } = clientInfo;
+
+    // Validate the operation
+    if (!message.operation || !validateOperation(message.operation)) {
+      ws.send(JSON.stringify({
+        type: 'error',
+        message: 'Invalid operation. Must be { type: "insert", position: number, text: string } or { type: "delete", position: number, count: number }',
+      }));
+      return;
+    }
+
+    let op: Operation = message.operation;
+    const clientVersion = typeof message.version === 'number' ? message.version : undefined;
+
+    // Get current document
+    const doc = getDocument(this.db, documentId);
+    if (!doc) {
+      ws.send(JSON.stringify({ type: 'error', message: 'Document no longer exists' }));
+      return;
+    }
+
+    const serverVersion = getDocumentVersion(this.db, documentId);
+
+    // If client sent a version, transform against all operations since that version
+    if (clientVersion !== undefined && clientVersion < serverVersion) {
+      const history = getOperationsSinceVersion(this.db, documentId, clientVersion);
+      for (const pastVersion of history) {
+        if (pastVersion.operation) {
+          const pastOp = JSON.parse(pastVersion.operation) as Operation;
+          op = transformOperation(op, pastOp);
+        }
+      }
+    }
+
+    // Validate operation against current content
+    const validationError = validateOperationForContent(op, doc.content.length);
+    if (validationError) {
+      ws.send(JSON.stringify({ type: 'error', message: validationError }));
+      return;
+    }
+
+    // Apply the operation
+    const newContent = applyOperation(doc.content, op);
+    const newVersion = serverVersion + 1;
+
+    // Persist
+    addVersion(this.db, documentId, newVersion, newContent, op);
+
+    // Send ack to the sender
+    ws.send(JSON.stringify({
+      type: 'ack',
+      version: newVersion,
+    }));
+
+    // Broadcast to other clients on the same document
+    this.broadcast(documentId, ws, {
+      type: 'operation',
+      operation: op,
+      version: newVersion,
+    });
+  }
+
+  private broadcast(documentId: string, excludeWs: WebSocket, message: object): void {
+    const data = JSON.stringify(message);
+    for (const [clientWs, info] of this.clients) {
+      if (info.documentId === documentId && clientWs !== excludeWs && clientWs.readyState === WebSocket.OPEN) {
+        clientWs.send(data);
+      }
+    }
+  }
+
+  closeAll(): void {
+    for (const [ws] of this.clients) {
+      ws.close();
+    }
+    this.clients.clear();
+    if (this.wss) {
+      this.wss.close();
+      this.wss = null;
+    }
+  }
+}
