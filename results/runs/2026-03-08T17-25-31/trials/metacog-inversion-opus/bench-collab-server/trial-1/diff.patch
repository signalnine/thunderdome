ther.type === 'insert') {\n    return transformDeleteInsert(op as DeleteOp, other as InsertOp);\n  } else {\n    return transformDeleteDelete(op as DeleteOp, other as DeleteOp);\n  }\n}\n\nfunction transformInsertInsert(op: InsertOp, other: InsertOp): InsertOp {\n  // If op's position is after other's insert (or at same position),\n  // shift op forward by the length of other's text.\n  // Tie-breaking: if same position, the \"other\" (already applied) goes first.\n  if (op.position > other.position) {\n    return { ...op, position: op.position + other.text.length };\n  } else if (op.position < other.position) {\n    return { ...op };\n  } else {\n    // Same position: other was applied first, so shift op after it.\n    return { ...op, position: op.position + other.text.length };\n  }\n}\n\nfunction transformInsertDelete(op: InsertOp, other: DeleteOp): InsertOp {\n  if (op.position <= other.position) {\n    // Insert is before or at the delete position - no change needed\n    return { ...op };\n  } else if (op.position >= other.position + other.count) {\n    // Insert is after the deleted region - shift back by delete count\n    return { ...op, position: op.position - other.count };\n  } else {\n    // Insert is within the deleted region - place at delete position\n    return { ...op, position: other.position };\n  }\n}\n\nfunction transformDeleteInsert(op: DeleteOp, other: InsertOp): DeleteOp {\n  if (op.position >= other.position) {\n    // Delete starts after or at insert position - shift forward\n    return { ...op, position: op.position + other.text.length };\n  } else if (op.position + op.count <= other.position) {\n    // Delete ends before insert position - no change needed\n    return { ...op };\n  } else {\n    // Delete range spans the insert position - expand the delete count\n    // to account for inserted text being in the middle\n    // Actually, we should NOT delete the newly inserted text.\n    // We split into two deletes or adjust. Simplest correct approach:\n    // the delete range grows because the insert pushed chars forward.\n    return { ...op, count: op.count + other.text.length };\n  }\n}\n\nfunction transformDeleteDelete(op: DeleteOp, other: DeleteOp): DeleteOp {\n  // After 'other' delete is applied, adjust 'op' delete\n  if (op.position >= other.position + other.count) {\n    // op is entirely after other's deletion range\n    return { ...op, position: op.position - other.count };\n  } else if (op.position + op.count <= other.position) {\n    // op is entirely before other's deletion range\n    return { ...op };\n  } else {\n    // Overlapping deletes\n    const opEnd = op.position + op.count;\n    const otherEnd = other.position + other.count;\n\n    if (op.position >= other.position && opEnd <= otherEnd) {\n      // op is entirely within other - nothing left to delete\n      return { ...op, position: other.position, count: 0 };\n    } else if (op.position <= other.position && opEnd >= otherEnd) {\n      // op contains other entirely - reduce count by other's count\n      return { ...op, count: op.count - other.count };\n    } else if (op.position < other.position) {\n      // op starts before other but overlaps\n      const newCount = other.position - op.position;\n      return { ...op, count: newCount };\n    } else {\n      // op starts inside other but extends beyond\n      const newCount = opEnd - otherEnd;\n      return { ...op, position: other.position, count: newCount };\n    }\n  }\n}\n\n/**\n * Transform an operation against a sequence of operations that have\n * already been applied (server history since the client's base version).\n */\nexport function transformAgainstHistory(op: Operation, history: Operation[]): Operation {\n  let transformed = op;\n  for (const past of history) {\n    transformed = transformOperation(transformed, past);\n  }\n  return transformed;\n}\n\n/**\n * Validate that an operation is well-formed.\n */\nexport function validateOperation(op: unknown): op is Oper