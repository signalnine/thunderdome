+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016onwdDbfkxxgPcM7ToiqWm","type":"tool_result","content":"931\n\n    await delay(100);\n    const doc1 = await request(app.app).get(`/docs/${docId}`);\n    const doc2 = await request(app.app).get(`/docs/${docId}`);\n    expect(doc1.body.content).toBe(doc2.body.content);\n    expect(doc1.body.content).toBe('Start End');\n\n    await closeClient(c1);\n    await closeClient(c2);\n  });\n\n  it('Version history contains all operations in order', async () => {\n    const res = await request(app.app).post('/docs').send({ title: 'History', content: '' });\n    const docId = res.body.id;\n\n    const client = await createWsClient(port, docId);\n    await waitForMsg(client, 0); // sync\n\n    sendOp(client, { type: 'insert', position: 0, text: 'A' });\n    await waitForMsg(client, 1);\n    sendOp(client, { type: 'insert', position: 1, text: 'B' });\n    await waitForMsg(client, 2);\n    sendOp(client, { type: 'insert', position: 2, text: 'C' });\n    await waitForMsg(client, 3);\n\n    const versions = await request(app.app).get(`/docs/${docId}/versions`);\n    expect(versions.body.length).toBeGreaterThanOrEqual(4); // version 0 + 3 edits\n    for (let i = 1; i < versions.body.length; i++) {\n      expect(versions.body[i].version).toBeGreaterThan(versions.body[i - 1].version);\n    }\n\n    await closeClient(client);\n  });\n\n  it('Concurrent edits do not lose data', async () => {\n    const res = await request(app.app).post('/docs').send({ title: 'NoLoss', content: '' });\n    const docId = res.body.id;\n\n    const c1 = await createWsClient(port, docId);\n    const sync1 = await waitForMsg(c1, 0);\n    const c2 = await createWsClient(port, docId);\n    await waitForMsg(c2, 0);\n    const version = (sync1 as { version: number }).version;\n\n    // Both send edits based on same initial version\n    sendOp(c1, { type: 'insert', position: 0, text: 'FIRST' }, version);\n    sendOp(c2, { type: 'insert', position: 0, text: 'SECOND' }, version);\n\n    // Wait for messages to settle\n    await delay(500);\n\n    const doc = await request(app.app).get(`/docs/${docId}`);\n    expect(doc.body.content).toContain('FIRST');\n    expect(doc.body.content).toContain('SECOND');\n\n    await closeClient(c1);\n    await closeClient(c2);\n  });\n\n  it('Edit at end of document while other edits beginning', async () => {\n    const res = await request(app.app).post('/docs').send({ title: 'EndBegin', content: 'MIDDLE' });\n    const docId = res.body.id;\n\n    const c1 = await createWsClient(port, docId);\n    const sync1 = await waitForMsg(c1, 0);\n    const c2 = await createWsClient(port, docId);\n    await waitForMsg(c2, 0);\n    const version = (sync1 as { version: number }).version;\n\n    sendOp(c1, { type: 'insert', position: 0, text: 'START' }, version);\n    await waitForMsg(c1, 1); // ack\n    await waitForMsg(c2, 1); // broadcast\n\n    // After c1's edit, doc is \"STARTMIDDLE\" (11 chars)\n    sendOp(c2, { type: 'insert', position: 11, text: 'END' }, version + 1);\n    await waitForMsg(c2, 2); // ack\n\n    await delay(100);\n    const doc = await request(app.app).get(`/docs/${docId}`);\n    expect(doc.body.content).toBe('STARTMIDDLEEND');\n\n    await closeClient(c1);\n    await closeClient(c2);\n  });\n});\n\n// ============================================================\n// Stress Tests\n// ============================================================\n\ndescribe('Stress Test', () => {\n  let app: AppInstance;\n  let port: number;\n\n  beforeAll(async () => {\n    app = createApp();\n    port = await app.start(0);\n  });\n\n  afterAll(async () => {\n    await app.stop();\n  });\n\n  it('10 clients connect to same document simultaneously', async () => {\n    const res = await request(app.app).post('/docs').send({ title: 'Stress' });\n    const docId = res.body.id;\n\n    const clients: WsClient[] = [];\n    for (let i = 0; i < 10; i++) {\n      const c = await createWsClient(port, docId);\n      await waitForMsg(c, 0); // sync\n      clients.push(c);\n    }\n\n    expect(clients.length).toBe(10);\n    for (const c of clients) {\n      expect(c.ws.readyState).toBe(WebSocket.OPEN);\n    }\n\n    for (const c of clients) await closeClient(c);\n  });\n\n  it('10 clients each send an edit, all edits present in final document', async () => {\n    const res = await request(app.app).post('/docs').send({ title: 'StressEdit', content: '' });\n    const docId = res.body.id;\n\n    const clients: WsClient[] = [];\n    for (let i = 0; i < 10; i++) {\n      const c = await createWsClient(port, docId);\n      await waitForMsg(c, 0); // sync\n      clients.push(c);\n    }\n\n    // Each client sends a unique character sequentially\n    for (let i = 0; i < 10; i++) {\n      sendOp(clients[i], { type: 'insert', position: 0, text: String(i) });\n      await delay(30);\n    }\n\n    await delay(1000);\n    const doc = await request(app.app).get(`/docs/${docId}`);\n\n    for (let i = 0; i < 10; i++) {\n      expect(doc.body.content).toContain(String(i));\n    }\n\n    for (const c of clients) await closeClient(c);\n  });\n\n  it('Document content identical across all 10 clients after sync', async () => {\n    const res = await request(app.app).post('/docs').send({ title: 'Sync10', content: '' });\n    const docId = res.body.id;\n\n    const clients: WsClient[] = [];\n    for (let i = 0; i < 10; i++) {\n      const c = await createWsClient(port, docId);\n      await waitForMsg(c, 0); // sync\n      clients.push(c);\n    }\n\n    // One client makes an edit\n    sendOp(clients[0], { type: 'insert', position: 0, text: 'SHARED' });\n    await delay(500);\n\n    for (const c of clients) await closeClient(c);\n    await delay(100);\n\n    // All clients reconnect to get fresh state\n    const contents: string[] = [];\n    for (let i = 0; i < 10; i++) {\n      const c = await createWsClient(port, docId);\n      const sync = await waitForMsg(c, 0);\n      contents.push((sync as { content: string }).content);\n      await closeClient(c);\n    }\n\n    for (const ct of contents) {\n      expect(ct).toBe(contents[0]);\n    }\n    expect(contents[0]).toContain('SHARED');\n  });\n\n  it('Server handles rapid-fire edits without crashing', async () => {\n    const res = await request(app.app).post('/docs').send({ title: 'RapidFire', content: '' });\n    const docId = res.body.id;\n\n    const client = await createWsClient(port, docId);\n    await waitForMsg(client, 0); // sync\n\n    // Send 50 rapid edits\n    for (let i = 0; i < 50; i++) {\n      sendOp(client, { type: 'insert', position: i, text: 'x' });\n    }\n\n    await delay(2000);\n    const doc = await request(app.app).get(`/docs/${docId}`);\n    expect(doc.body.content.length).toBe(50);\n\n    await closeClient(client);\n  });\n\n  it('All clients can disconnect without error', async () => {\n    const res = await request(app.app).post('/docs').send({ title: 'Disconnect' });\n    const docId = res.body.id;\n\n    const clients: WsClient[] = [];\n    for (let i = 0; i < 10; i++) {\n      const c = await createWsClient(port, docId);\n      await waitForMsg(c, 0);\n      clients.push(c);\n    }\n\n    // Disconnect all at once\n    await Promise.all(clients.map((c) => closeClient(c)));\n\n    // Server should still be healthy\n    const check = await request(app.app).get('/docs');\n    expect(check.status).toBe(200);\n  });\n});\n\n// ============================================================\n// Error Handling Tests\n// ============================================================\n\ndescribe('Error Handling', () => {\n  let app: AppInstance;\n  let port: number;\n\n  beforeAll(async () => {\n    app = createApp();\n    port = await app.start(0);\n  });\n\n  afterAll(async () => {\n    await app.stop();\n  });\n\n  it('Connecting to non-existent document returns error', async () => {\n    const ws = new WebSocket(`ws://localhost:${port}/nonexistent-doc-id`);\n    const messages: Record<string, unknown>[] = [];\n    ws.on('message', (data) => messages.push(JSON.parse(data.toString())));\n    await new Promise<void>((resolve) => ws.on('open', resolve));\n\n    // Wait for the error message\n    await new Promise<void>((resolve) => {\n      const interval = setInterval(() => {\n        if (messages.length > 0) {\n          clearInterval(interval);\n          resolve();\n        }\n      }, 10);\n      setTimeout(() => { clearInterval(interval); resolve(); }, 2000);\n    });\n\n    expect(messages.length).toBeGreaterThan(0);\n    expect(messages[0].type).toBe('error');\n    expect(String(messages[0].message)).toContain('not found');\n    await delay(100);\n  });\n\n  it('Malformed operation JSON rejected', async () => {\n    const res = await request(app.app).post('/docs').send({ title: 'ErrDoc' });\n    const docId = res.body.id;\n\n    const client = await createWsClient(port, docId);\n    await waitForMsg(client, 0); // sync\n\n    client.ws.send('not valid json{{{');\n    const errMsg = await waitForMsg(client, 1);\n    expect(errMsg.type).toBe('error');\n\n    await closeClient(client);\n  });\n\n  it('Invalid operation type rejected', async () => {\n    const res = await request(app.app).post('/docs').send({ title: 'ErrType' });\n    const docId = res.body.id;\n\n    const client = await createWsClient(port, docId);\n    await waitForMsg(client, 0); // sync\n\n    client.ws.send(JSON.stringify({ type: 'operation', operation: { type: 'replace', position: 0, text: 'x' } }));\n    const errMsg = await waitForMsg(client, 1);\n    expect(errMsg.type).toBe('error');\n\n    await closeClient(client);\n  });\n\n  it('Operation with out-of-bounds position rejected', async () => {\n    const res = await request(app.app).post('/docs').send({ title: 'ErrBounds', content: 'Hi' });\n    const docId = res.body.id;\n\n    const client = await createWsClient(port, docId);\n    await waitForMsg(client, 0); // sync\n\n    client.ws.send(JSON.stringify({ type: 'operation', operation: { type: 'delete', position: 0, count: 100 } }));\n    const errMsg = await waitForMsg(client, 1);\n    expect(errMsg.type).toBe('error');\n\n    await closeClient(client);\n  });\n\n  it('Server remains stable after malformed input', async () => {\n    const res = await request(app.app).post('/docs').send({ title: 'Stable' });\n    const docId = res.body.id;\n\n    const client = await createWsClient(port, docId);\n    await waitForMsg(client, 0); // sync\n\n    // Send garbage\n    client.ws.send('garbage');\n    const errMsg = await waitForMsg(client, 1);\n    expect(errMsg.type).toBe('error');\n\n    // Server should still work\n    const check = await request(app.app).get('/docs');\n    expect(check.status).toBe(200);\n\n    // WS should still work\n    sendOp(client, { type: 'insert', position: 0, text: 'OK' });\n    const ack = await waitForMsg(client, 2);\n    expect(ack.type).toBe('ack');\n\n    await closeClient(client);\n  });\n});\n\n// ============================================================\n// Persistence Tests\n// ============================================================\n\ndescribe('Persistence', () => {\n  const dbPath = '/tmp/test-collab-persist-' + Date.now() + '.db';\n\n  it('Document survives server restart', async () => {\n    const app1 = createApp(dbPath);\n    await app1.start(0);\n\n    await request(app1.app).post('/docs').send({ title: 'Persistent', content: 'data' });\n    const docs1 = await request(app1.app).get('/docs');\n    expect(docs1.body.length).toBe(1);\n\n    await app1.stop();\n\n    const app2 = createApp(dbPath);\n    await app2.start(0);\n\n    const docs2 = await request(app2.app).get('/docs');\n    expect(docs2.body.length).toBe(1);\n    expect(docs2.body[0].title).toBe('Persistent');\n    expect(docs2.body[0].content).toBe('data');\n\n    await app2.stop();\n  });\n\n  it('Edit history survives server restart', async () => {\n    const app1 = createApp(dbPath);\n    await app1.start(0);\n\n    const docs = await request(app1.app).get('/docs');\n    const docId = docs.body[0].id;\n    const versions1 = await request(app1.app).get(`/docs/${docId}/versions`);\n\n    await app1.stop();\n\n    const app2 = createApp(dbPath);\n    await app2.start(0);\n\n    const versions2 = await request(app2.app).get(`/docs/${docId}/versions`);\n    expect(versions2.body.length).toBe(versions1.body.length);\n\n    await app2.stop();\n  });\n\n  it('Active connections cleared on restart', async () => {\n    const app1 = createApp(dbPath);\n    const port1 = await app1.start(0);\n\n    const docs = await request(app1.app).get('/docs');\n    const docId = docs.body[0].id;\n\n    const client = await createWsClient(port1, docId);\n    await waitForMsg(client, 0);\n\n    const connsBefore = app1.db.prepare('SELECT COUNT(*) as cnt FROM active_connections').get() as { cnt: number };\n    expect(connsBefore.cnt).toBeGreaterThan(0);\n\n    await closeClient(client);\n    await app1.stop();\n\n    const app2 = createApp(dbPath);\n    await app2.start(0);\n\n    const connsAfter = app2.db.prepare('SELECT COUNT(*) as cnt FROM active_connections').get() as { cnt: number };\n    expect(connsAfter.cnt).toBe(0);\n\n    await app2.stop();\n  });\n});","is_error":false}]},"parent_tool_use_id":"toolu_01Q4V1fAKwMJLL7SBv2J4gCA","session_id":"e43f491b-905c-4860-a1c8-46b93f296faf","uuid":"1544f925-6740-4b80-a4ce-ad8237572f18"}
