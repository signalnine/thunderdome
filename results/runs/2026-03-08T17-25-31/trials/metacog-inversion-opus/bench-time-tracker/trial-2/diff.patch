+++ b/src/tracker.ts
@@ -0,0 +1,128 @@
+import { readFileSync, writeFileSync, mkdirSync, existsSync } from "node:fs";
+import { dirname } from "node:path";
+
+export interface TimeEntry {
+  task: string;
+  start: string; // ISO 8601
+  end: string | null; // ISO 8601 or null if running
+}
+
+export interface TimeSummary {
+  [task: string]: number; // milliseconds
+}
+
+export class TimeTracker {
+  private entries: TimeEntry[] = [];
+  private filePath: string;
+
+  constructor(filePath: string) {
+    this.filePath = filePath;
+    this.load();
+  }
+
+  /**
+   * Start a named timer. If a timer is already running, it is stopped first.
+   */
+  start(task: string): void {
+    if (!task || task.trim().length === 0) {
+      throw new Error("Task name must not be empty");
+    }
+
+    // Auto-stop any running timer
+    const running = this.getRunningEntry();
+    if (running) {
+      running.end = new Date().toISOString();
+    }
+
+    this.entries.push({
+      task,
+      start: new Date().toISOString(),
+      end: null,
+    });
+
+    this.save();
+  }
+
+  /**
+   * Stop the currently running timer.
+   */
+  stop(): TimeEntry {
+    const running = this.getRunningEntry();
+    if (!running) {
+      throw new Error("No timer is currently running");
+    }
+
+    running.end = new Date().toISOString();
+    this.save();
+    return { ...running };
+  }
+
+  /**
+   * Get the currently running entry, or null if none.
+   */
+  getRunningEntry(): TimeEntry | null {
+    return this.entries.find((e) => e.end === null) ?? null;
+  }
+
+  /**
+   * Get all entries, optionally filtered by date range.
+   * Both `from` and `to` are inclusive bounds on the entry start time.
+   */
+  getEntries(options?: { from?: Date; to?: Date }): TimeEntry[] {
+    let result = this.entries.map((e) => ({ ...e }));
+
+    if (options?.from) {
+      const fromTime = options.from.getTime();
+      result = result.filter((e) => new Date(e.start).getTime() >= fromTime);
+    }
+
+    if (options?.to) {
+      const toTime = options.to.getTime();
+      result = result.filter((e) => new Date(e.start).getTime() <= toTime);
+    }
+
+    return result;
+  }
+
+  /**
+   * Get a summary of total time per task name in milliseconds.
+   * Running tasks use the current time for their duration.
+   */
+  getSummary(): TimeSummary {
+    const summary: TimeSummary = {};
+    const now = Date.now();
+
+    for (const entry of this.entries) {
+      const startTime = new Date(entry.start).getTime();
+      const endTime = entry.end ? new Date(entry.end).getTime() : now;
+      const duration = endTime - startTime;
+
+      summary[entry.task] = (summary[entry.task] ?? 0) + duration;
+    }
+
+    return summary;
+  }
+
+  private load(): void {
+    try {
+      if (existsSync(this.filePath)) {
+        const data = readFileSync(this.filePath, "utf-8");
+        const parsed: unknown = JSON.parse(data);
+        if (Array.isArray(parsed)) {
+          this.entries = parsed as TimeEntry[];
+        }
+      }
+    } catch {
+      // If the file is corrupt or unreadable, start fresh
+      this.entries = [];
+    }
+  }
+
+  private save(): void {
+    const dir = dirname(this.filePath);
+    if (!existsSync(dir)) {
+      mkdirSync(dir, { recursive: true });
+    }
+    writeFileSync(this.filePath, JSON.stringify(this.entries, null, 2), "utf-8");
+  }
+}
