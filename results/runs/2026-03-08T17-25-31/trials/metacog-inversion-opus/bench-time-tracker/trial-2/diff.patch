@@ -0,0 +1,161 @@
+import { describe, it, expect, beforeEach, afterEach } from "vitest";
+import { TimeTracker } from "./tracker.js";
+import { existsSync, rmSync } from "node:fs";
+import { join } from "node:path";
+import { tmpdir } from "node:os";
+
+const TEST_DIR = join(tmpdir(), "time-tracker-test-" + Date.now());
+const TEST_FILE = join(TEST_DIR, "data.json");
+
+function cleanup() {
+  if (existsSync(TEST_DIR)) {
+    rmSync(TEST_DIR, { recursive: true });
+  }
+}
+
+beforeEach(() => {
+  cleanup();
+});
+
+afterEach(() => {
+  cleanup();
+});
+
+describe("TimeTracker", () => {
+  describe("start/stop", () => {
+    it("should start and stop a timer", () => {
+      const tracker = new TimeTracker(TEST_FILE);
+      tracker.start("coding");
+      const entry = tracker.stop();
+      expect(entry.task).toBe("coding");
+      expect(entry.start).toBeTruthy();
+      expect(entry.end).toBeTruthy();
+    });
+
+    it("should throw when starting with empty name", () => {
+      const tracker = new TimeTracker(TEST_FILE);
+      expect(() => tracker.start("")).toThrow("Task name must not be empty");
+      expect(() => tracker.start("   ")).toThrow("Task name must not be empty");
+    });
+
+    it("should throw when stopping with no running timer", () => {
+      const tracker = new TimeTracker(TEST_FILE);
+      expect(() => tracker.stop()).toThrow("No timer is currently running");
+    });
+
+    it("should auto-stop previous timer when starting new one", () => {
+      const tracker = new TimeTracker(TEST_FILE);
+      tracker.start("task1");
+      tracker.start("task2");
+
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(2);
+      expect(entries[0].end).not.toBeNull(); // task1 was auto-stopped
+      expect(entries[1].end).toBeNull(); // task2 is running
+    });
+  });
+
+  describe("persistence", () => {
+    it("should create parent directories automatically", () => {
+      const deepPath = join(TEST_DIR, "a", "b", "c", "data.json");
+      const tracker = new TimeTracker(deepPath);
+      tracker.start("test");
+      tracker.stop();
+      expect(existsSync(deepPath)).toBe(true);
+    });
+
+    it("should persist entries across instances", () => {
+      const tracker1 = new TimeTracker(TEST_FILE);
+      tracker1.start("task1");
+      tracker1.stop();
+
+      const tracker2 = new TimeTracker(TEST_FILE);
+      const entries = tracker2.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].task).toBe("task1");
+    });
+  });
+
+  describe("getEntries", () => {
+    it("should return all entries", () => {
+      const tracker = new TimeTracker(TEST_FILE);
+      tracker.start("task1");
+      tracker.stop();
+      tracker.start("task2");
+      tracker.stop();
+
+      expect(tracker.getEntries()).toHaveLength(2);
+    });
+
+    it("should filter by date range", () => {
+      const tracker = new TimeTracker(TEST_FILE);
+      tracker.start("task1");
+      tracker.stop();
+
+      const now = new Date();
+      const past = new Date(now.getTime() - 60000);
+      const future = new Date(now.getTime() + 60000);
+
+      // Should find entry in range
+      expect(tracker.getEntries({ from: past, to: future })).toHaveLength(1);
+
+      // Should not find entry before range
+      expect(tracker.getEntries({ from: future })).toHaveLength(0);
+
+      // Should not find entry after range
+      expect(tracker.getEntries({ to: past })).toHaveLength(0);
+    });
+  });
+
+  describe("getSummary", () => {
+    it("should sum durations per task", () => {
+      const tracker = new TimeTracker(TEST_FILE);
+      tracker.start("coding");
+      tracker.stop();
+      tracker.start("coding");
+      tracker.stop();
+
+      const summary = tracker.getSummary();
+      expect(summary["coding"]).toBeGreaterThanOrEqual(0);
+      expect("coding" in summary).toBe(true);
+    });
+
+    it("should include running tasks using current time", () => {
+      const tracker = new TimeTracker(TEST_FILE);
+      tracker.start("active");
+
+      const summary = tracker.getSummary();
+      expect(summary["active"]).toBeGreaterThanOrEqual(0);
+    });
+  });
+
+  describe("unicode support", () => {
+    it("should handle unicode task names", () => {
+      const tracker = new TimeTracker(TEST_FILE);
+      tracker.start("编码任务");
+      tracker.stop();
+
+      const entries = tracker.getEntries();
+      expect(entries[0].task).toBe("编码任务");
+    });
+
+    it("should handle emoji task names", () => {
+      const tracker = new TimeTracker(TEST_FILE);
+      tracker.start("🚀 rocket task");
+      tracker.stop();
+
+      const entries = tracker.getEntries();
+      expect(entries[0].task).toBe("🚀 rocket task");
+    });
+
+    it("should persist unicode names correctly", () => {
+      const tracker1 = new TimeTracker(TEST_FILE);
+      tracker1.start("日本語タスク 🎌");
+      tracker1.stop();
+
+      const tracker2 = new TimeTracker(TEST_FILE);
+      const entries = tracker2.getEntries();
+      expect(entries[0].task).toBe("日本語タスク 🎌");
+    });
+  });
+});
