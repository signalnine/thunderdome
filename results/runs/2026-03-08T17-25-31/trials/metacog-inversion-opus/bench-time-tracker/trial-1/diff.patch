+import { describe, it, expect, beforeEach, afterEach } from "vitest";
+import * as fs from "node:fs";
+import * as path from "node:path";
+import * as os from "node:os";
+import { TimeTracker } from "../src/index.js";
+
+function tmpFile(): string {
+  const dir = fs.mkdtempSync(path.join(os.tmpdir(), "tt-"));
+  return path.join(dir, "data.json");
+}
+
+function cleanup(filePath: string) {
+  try {
+    fs.rmSync(path.dirname(filePath), { recursive: true, force: true });
+  } catch {
+    // ignore
+  }
+}
+
+describe("TimeTracker", () => {
+  let filePath: string;
+
+  beforeEach(() => {
+    filePath = tmpFile();
+  });
+
+  afterEach(() => {
+    cleanup(filePath);
+  });
+
+  describe("start / stop", () => {
+    it("should start and stop a timer", () => {
+      const tracker = new TimeTracker({ filePath });
+      tracker.start("coding");
+      const running = tracker.getRunning();
+      expect(running).not.toBeNull();
+      expect(running!.task).toBe("coding");
+      expect(running!.stop).toBeNull();
+
+      const stopped = tracker.stop();
+      expect(stopped.task).toBe("coding");
+      expect(stopped.stop).not.toBeNull();
+      expect(tracker.getRunning()).toBeNull();
+    });
+
+    it("should auto-stop the previous timer when starting a new one", () => {
+      const tracker = new TimeTracker({ filePath });
+      tracker.start("task1");
+      tracker.start("task2");
+
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(2);
+      expect(entries[0].task).toBe("task1");
+      expect(entries[0].stop).not.toBeNull();
+      expect(entries[1].task).toBe("task2");
+      expect(entries[1].stop).toBeNull();
+    });
+
+    it("should throw when starting with an empty name", () => {
+      const tracker = new TimeTracker({ filePath });
+      expect(() => tracker.start("")).toThrow();
+      expect(() => tracker.start("   ")).toThrow();
+    });
+
+    it("should throw when stopping with nothing running", () => {
+      const tracker = new TimeTracker({ filePath });
+      expect(() => tracker.stop()).toThrow();
+    });
+  });
+
+  describe("persistence", () => {
+    it("should persist entries to disk and reload them", () => {
+      const tracker1 = new TimeTracker({ filePath });
+      tracker1.start("reading");
+      tracker1.stop();
+
+      const tracker2 = new TimeTracker({ filePath });
+      const entries = tracker2.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].task).toBe("reading");
+    });
+
+    it("should create parent directories automatically", () => {
+      const nested = path.join(os.tmpdir(), "tt-nested-" + Date.now(), "a", "b", "c", "data.json");
+      const tracker = new TimeTracker({ filePath: nested });
+      tracker.start("test");
+      tracker.stop();
+
+      expect(fs.existsSync(nested)).toBe(true);
+      fs.rmSync(path.join(os.tmpdir(), "tt-nested-" + Date.now().toString().slice(0, -3)), {
+        recursive: true,
+        force: true,
+      });
+    });
+  });
+
+  describe("querying entries", () => {
+    it("should return all entries with no filter", () => {
+      const tracker = new TimeTracker({ filePath });
+      tracker.start("a");
+      tracker.stop();
+      tracker.start("b");
+      tracker.stop();
+
+      expect(tracker.getEntries()).toHaveLength(2);
+    });
+
+    it("should filter by date range", () => {
+      const tracker = new TimeTracker({ filePath });
+
+      // Create entries at known times by writing directly
+      const now = Date.now();
+      const entries = [
+        { task: "old", start: new Date(now - 86400000 * 3).toISOString(), stop: new Date(now - 86400000 * 3 + 1000).toISOString() },
+        { task: "mid", start: new Date(now - 86400000).toISOString(), stop: new Date(now - 86400000 + 1000).toISOString() },
+        { task: "new", start: new Date(now).toISOString(), stop: new Date(now + 1000).toISOString() },
+      ];
+      fs.writeFileSync(filePath, JSON.stringify(entries), "utf-8");
+
+      const tracker2 = new TimeTracker({ filePath });
+      const filtered = tracker2.getEntries({
+        from: new Date(now - 86400000 * 2),
+        to: new Date(now - 100),
+      });
+      expect(filtered).toHaveLength(1);
+      expect(filtered[0].task).toBe("mid");
+    });
+  });
+
+  describe("summary", () => {
+    it("should sum durations per task name", () => {
+      const now = Date.now();
+      const entries = [
+        { task: "coding", start: new Date(now - 10000).toISOString(), stop: new Date(now - 5000).toISOString() },
+        { task: "coding", start: new Date(now - 4000).toISOString(), stop: new Date(now - 2000).toISOString() },
+        { task: "review", start: new Date(now - 3000).toISOString(), stop: new Date(now - 1000).toISOString() },
+      ];
+      fs.writeFileSync(filePath, JSON.stringify(entries), "utf-8");
+
+      const tracker = new TimeTracker({ filePath });
+      const summary = tracker.getSummary();
+      expect(summary["coding"]).toBe(7000);
+      expect(summary["review"]).toBe(2000);
+    });
+
+    it("should use current time for running tasks", async () => {
+      const tracker = new TimeTracker({ filePath });
+      tracker.start("running-task");
+
+      // Wait a bit so there's measurable elapsed time
+      await new Promise((resolve) => setTimeout(resolve, 20));
+
+      const summary = tracker.getSummary();
+      expect(summary["running-task"]).toBeGreaterThan(0);
+    });
+  });
+
+  describe("unicode support", () => {
+    it("should handle unicode task names", () => {
+      const tracker = new TimeTracker({ filePath });
+      tracker.start("日本語タスク");
+      tracker.stop();
+      tracker.start("🚀 rocket task 🎉");
+      tracker.stop();
+
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(2);
+      expect(entries[0].task).toBe("日本語タスク");
+      expect(entries[1].task).toBe("🚀 rocket task 🎉");
+
+      // Verify persistence with unicode
+      const tracker2 = new TimeTracker({ filePath });
+      const reloaded = tracker2.getEntries();
+      expect(reloaded[0].task).toBe("日本語タスク");
+      expect(reloaded[1].task).toBe("🚀 rocket task 🎉");
+
+      // Verify summary groups by unicode names
+      const summary = tracker2.getSummary();
+      expect(summary["日本語タスク"]).toBeGreaterThanOrEqual(0);
+      expect(summary["🚀 rocket task 🎉"]).toBeGreaterThanOrEqual(0);
+    });
+  });
+
+  describe("edge cases", () => {
+    it("should return copies of entries, not references", () => {
+      const tracker = new TimeTracker({ filePath });
+      tracker.start("test");
+      tracker.stop();
+
+      const entries = tracker.getEntries();
+      entries[0].task = "modified";
+
+      const fresh = tracker.getEntries();
+      expect(fresh[0].task).toBe("test");
+    });
   });
 });
