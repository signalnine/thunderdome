new file mode 100644
index 0000000..13a9bd3
--- /dev/null
+++ b/src/cart/index.ts
@@ -0,0 +1,70 @@
+import { v4 as uuidv4 } from 'uuid';
+import { EventBus } from '../bus.js';
+import { CartService, CartUpdatedEvent, Events } from '../types.js';
+
+type Cart = { id: string; userId: string; items: Map<string, number> };
+
+export function createCartService(bus: EventBus): CartService {
+  const carts = new Map<string, Cart>();
+
+  function emitUpdated(cart: Cart) {
+    const payload: CartUpdatedEvent = {
+      cartId: cart.id,
+      userId: cart.userId,
+      items: Array.from(cart.items.entries()).map(([productId, quantity]) => ({
+        productId,
+        quantity,
+      })),
+    };
+    bus.emit(Events.CART_UPDATED, payload);
+  }
+
+  return {
+    createCart(userId) {
+      const id = uuidv4();
+      carts.set(id, { id, userId, items: new Map() });
+      return id;
+    },
+
+    addItem(cartId, productId, quantity) {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+      cart.items.set(productId, (cart.items.get(productId) ?? 0) + quantity);
+      emitUpdated(cart);
+    },
+
+    removeItem(cartId, productId) {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+      cart.items.delete(productId);
+      emitUpdated(cart);
+    },
+
+    getCart(cartId) {
+      const cart = carts.get(cartId);
+      if (!cart) return null;
+      return {
+        id: cart.id,
+        userId: cart.userId,
+        items: Array.from(cart.items.entries()).map(([productId, quantity]) => ({
+          productId,
+          quantity,
+        })),
+      };
+    },
+
+    clearCart(cartId) {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+      cart.items.clear();
+      emitUpdated(cart);
+    },
+
+    updateQuantity(cartId, productId, quantity) {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+      cart.items.set(productId, quantity);
+      emitUpdated(cart);
+    },
+  };
+}
