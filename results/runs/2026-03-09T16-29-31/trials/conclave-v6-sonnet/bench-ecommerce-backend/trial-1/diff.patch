+
+  beforeEach(() => {
+    bus = new EventBus();
+    catalog = createCatalogService(bus);
+  });
+
+  it('creates a product and returns an id', () => {
+    const id = catalog.createProduct('Widget', 9.99, 'tools');
+    expect(typeof id).toBe('string');
+    expect(id.length).toBeGreaterThan(0);
+  });
+
+  it('getProduct returns the product', () => {
+    const id = catalog.createProduct('Widget', 9.99, 'tools');
+    const p = catalog.getProduct(id);
+    expect(p).toEqual({ id, name: 'Widget', price: 9.99, category: 'tools' });
+  });
+
+  it('getProduct returns null for unknown id', () => {
+    expect(catalog.getProduct('nope')).toBeNull();
+  });
+
+  it('listProducts returns all products', () => {
+    catalog.createProduct('A', 1, 'cat1');
+    catalog.createProduct('B', 2, 'cat2');
+    expect(catalog.listProducts()).toHaveLength(2);
+  });
+
+  it('listProducts filters by category', () => {
+    catalog.createProduct('A', 1, 'cat1');
+    catalog.createProduct('B', 2, 'cat2');
+    expect(catalog.listProducts('cat1')).toHaveLength(1);
+    expect(catalog.listProducts('cat1')[0].name).toBe('A');
+  });
+
+  it('searchProducts finds by name (case-insensitive)', () => {
+    catalog.createProduct('Red Widget', 5, 'tools');
+    catalog.createProduct('Blue Gadget', 8, 'tools');
+    const results = catalog.searchProducts('widget');
+    expect(results).toHaveLength(1);
+    expect(results[0].name).toBe('Red Widget');
+  });
+
+  it('updateProduct changes fields', () => {
+    const id = catalog.createProduct('Widget', 9.99, 'tools');
+    catalog.updateProduct(id, { price: 12.5 });
+    expect(catalog.getProduct(id)!.price).toBe(12.5);
+    expect(catalog.getProduct(id)!.name).toBe('Widget');
+  });
+
+  it('removeProduct removes and returns true', () => {
+    const id = catalog.createProduct('Widget', 9.99, 'tools');
+    expect(catalog.removeProduct(id)).toBe(true);
+    expect(catalog.getProduct(id)).toBeNull();
+  });
+
+  it('removeProduct returns false for unknown id', () => {
+    expect(catalog.removeProduct('nope')).toBe(false);
+  });
+
+  it('emits product:created on createProduct', async () => {
+    const events: unknown[] = [];
+    bus.on(Events.PRODUCT_CREATED, p => { events.push(p); });
+    const id = catalog.createProduct('Widget', 9.99, 'tools');
+    await new Promise<void>(r => { setTimeout(r, 0); });
+    expect(events).toHaveLength(1);
+    expect(events[0]).toMatchObject({ productId: id, name: 'Widget', price: 9.99, category: 'tools' });
+  });
+});
