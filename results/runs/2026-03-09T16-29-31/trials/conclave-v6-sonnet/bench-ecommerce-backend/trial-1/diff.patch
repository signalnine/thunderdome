+```typescript
+// src/payment/index.ts
+import { v4 as uuidv4 } from 'uuid';
+import { EventBus } from '../bus.js';
+import { Events, PaymentProcessedEvent, PaymentService, PaymentStatus } from '../types.js';
+
+type PaymentOptions = { outcome?: 'success' | 'failure' | 'timeout' };
+
+export function createPaymentService(bus: EventBus, options: PaymentOptions = {}): PaymentService {
+  const transactions = new Set<string>();
+  const outcome = options.outcome ?? 'success';
+
+  return {
+    async processPayment(orderId, _amount) {
+      let status: PaymentStatus;
+      let transactionId: string | undefined;
+      let error: string | undefined;
+
+      if (outcome === 'success') {
+        status = PaymentStatus.SUCCESS;
+        transactionId = uuidv4();
+        transactions.add(transactionId);
+      } else if (outcome === 'failure') {
+        status = PaymentStatus.FAILED;
+        error = 'Payment declined';
+      } else {
+        status = PaymentStatus.TIMEOUT;
+        error = 'Payment timed out';
+      }
+
+      const payload: PaymentProcessedEvent = { orderId, status, transactionId, error };
+      await bus.emit(Events.PAYMENT_PROCESSED, payload);
+      return { status, transactionId, error };
+    },
+
+    async refund(transactionId) {
+      if (!transactions.has(transactionId)) return false;
+      transactions.delete(transactionId);
+      return true;
+    },
+  };
+}
+```
