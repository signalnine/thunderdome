 expect(results[0].name).toBe('Red Widget');\n  });\n\n  it('updateProduct changes fields', () => {\n    const id = catalog.createProduct('Widget', 9.99, 'tools');\n    catalog.updateProduct(id, { price: 12.5 });\n    expect(catalog.getProduct(id)!.price).toBe(12.5);\n    expect(catalog.getProduct(id)!.name).toBe('Widget');\n  });\n\n  it('removeProduct removes and returns true', () => {\n    const id = catalog.createProduct('Widget', 9.99, 'tools');\n    expect(catalog.removeProduct(id)).toBe(true);\n    expect(catalog.getProduct(id)).toBeNull();\n  });\n\n  it('removeProduct returns false for unknown id', () => {\n    expect(catalog.removeProduct('nope')).toBe(false);\n  });\n\n  it('emits product:created on createProduct', async () => {\n    const events: unknown[] = [];\n    bus.on(Events.PRODUCT_CREATED, p => events.push(p));\n    const id = catalog.createProduct('Widget', 9.99, 'tools');\n    await new Promise(r => setTimeout(r, 0));\n    expect(events).toHaveLength(1);\n    expect(events[0]).toMatchObject({ productId: id, name: 'Widget', price: 9.99, category: 'tools' });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":230,"cache_read_input_tokens":54226,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":230},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"c80e475f-f825-4ce5-a47d-b03a8f167a56","uuid":"d0530e24-6cb9-497c-ba5f-a024cacf5693"}
