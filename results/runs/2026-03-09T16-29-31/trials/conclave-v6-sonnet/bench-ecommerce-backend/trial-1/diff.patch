@@ -0,0 +1,53 @@
+import { EventBus } from '../bus.js';
+import {
+  Events,
+  NotificationService,
+  OrderCreatedEvent,
+  OrderStatusChangedEvent,
+  PaymentProcessedEvent,
+} from '../types.js';
+
+type Notification = { type: string; message: string; timestamp: number };
+
+export function createNotificationService(bus: EventBus): NotificationService {
+  const subscribers = new Set<string>();
+  const notificationStore = new Map<string, Notification[]>();
+  const orderOwners = new Map<string, string>();
+
+  function store(userId: string, type: string, message: string) {
+    if (!subscribers.has(userId)) return;
+    if (!notificationStore.has(userId)) notificationStore.set(userId, []);
+    notificationStore.get(userId)!.push({ type, message, timestamp: Date.now() });
+  }
+
+  bus.on(Events.ORDER_CREATED, payload => {
+    const e = payload as OrderCreatedEvent;
+    orderOwners.set(e.orderId, e.userId);
+  });
+
+  bus.on(Events.ORDER_STATUS_CHANGED, payload => {
+    const e = payload as OrderStatusChangedEvent;
+    const userId = orderOwners.get(e.orderId);
+    if (userId) {
+      store(userId, 'order_status', `Order ${e.orderId} status changed to ${e.status}`);
+    }
+  });
+
+  bus.on(Events.PAYMENT_PROCESSED, payload => {
+    const e = payload as PaymentProcessedEvent;
+    const userId = orderOwners.get(e.orderId);
+    if (userId) {
+      store(userId, 'payment', `Payment for order ${e.orderId}: ${e.status}`);
+    }
+  });
+
+  return {
+    subscribe(userId) {
+      subscribers.add(userId);
+    },
+
+    getNotifications(userId) {
+      return notificationStore.get(userId) ?? [];
+    },
+  };
+}
