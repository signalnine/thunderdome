+  it('does not notify unsubscribed users', async () => {
+    const orderId = orders.createOrder('user2', 'cart1', 100);
+    orders.updateStatus(orderId, OrderStatus.CONFIRMED);
+    await new Promise<void>(r => { setTimeout(r, 0); });
+    expect(notifications.getNotifications('user2')).toEqual([]);
+  });
+});
