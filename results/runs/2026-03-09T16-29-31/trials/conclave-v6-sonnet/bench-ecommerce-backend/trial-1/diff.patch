currentQuantity: 4, threshold: 5 });\n  });\n\n  it('does not emit LOW_STOCK_ALERT when stock stays above threshold', async () => {\n    const alerts: unknown[] = [];\n    bus.on(Events.LOW_STOCK_ALERT, p => alerts.push(p));\n    inventory.setStock('p1', 10);\n    inventory.setLowStockThreshold('p1', 5);\n    inventory.reserve('p1', 3); // stock goes to 7, above threshold\n    await new Promise(r => setTimeout(r, 0));\n    expect(alerts).toHaveLength(0);\n  });\n});\n```\n\n**Step 2: Run test to verify it fails**\n\n```bash\ncd /workspace && npm test -- src/inventory/inventory.test.ts\n```\nExpected: FAIL\n\n**Step 3: Implement**\n\n```typescript\n// src/inventory/index.ts\nimport { EventBus } from '../bus.js';\nimport { Events, InventoryService, LowStockAlertEvent } from '../types.js';\n\nexport function createInventoryService(bus: EventBus): InventoryService {\n  const stock = new Map<string, number>();\n  const thresholds = new Map<string, number>();\n\n  function checkLowStock(productId: string) {\n    const qty = stock.get(productId) ?? 0;\n    const threshold = thresholds.get(productId);\n    if (threshold !== undefined && qty < threshold) {\n      const payload: LowStockAlertEvent = { productId, currentQuantity: qty, threshold };\n      bus.emit(Events.LOW_STOCK_ALERT, payload);\n    }\n  }\n\n  return {\n    setStock(productId, quantity) {\n      stock.set(productId, quantity);\n      checkLowStock(productId);\n    },\n\n    getStock(productId) {\n      return stock.get(productId) ?? 0;\n    },\n\n    reserve(productId, quantity) {\n      const current = stock.get(productId) ?? 0;\n      if (current < quantity) return false;\n      stock.set(productId, current - quantity);\n      checkLowStock(productId);\n      return true;\n    },\n\n    release(productId, quantity) {\n      const current = stock.get(productId) ?? 0;\n      stock.set(productId, current + quantity);\n    },\n\n    setLowStockThreshold(productId, threshold) {\n      thresholds.set(productId, threshold);\n    },\n  };\n}\n```\n\n**Step 4: Run tests to verify they pass**\n\n```bash\ncd /workspace && npm test -- src/inventory/inventory.test.ts\n```\nExpected: all tests PASS\n\n**Step 5: Commit**\n\n```bash\ncd /workspace && git add src/inventory/ && git commit -m \"feat: add InventoryService\"\n```\n\n---\n\n### Task 3: Cart Service\n\n**Files:**\n- Create: `src/cart/index.ts`\n- Create: `src/cart/cart.test.ts`\n\n**Dependencies:** none\n\n**Step 1: Write the failing test**\n\n```typescript\n// src/cart/cart.test.ts\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { EventBus } from '../bus.js';\nimport { createCartService } from './index.js';\nimport { Events } from '../types.js';\n\ndescribe('CartService', () => {\n  let bus: EventBus;\n  let cart: ReturnType<typeof createCartService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    cart = createCartService(bus);\n  });\n\n  it('createCart returns a cartId', () => {\n    const id = cart.createCart('user1');\n    expect(typeof id).toBe('string');\n  });\n\n  it('getCart returns cart', () => {\n    const id = cart.createCart('user1');\n    const c = cart.getCart(id);\n    expect(c).toMatchObject({ id, userId: 'user1', items: [] });\n  });\n\n  it('getCart returns null for unknown cart', () => {\n    expect(cart.getCart('nope')).toBeNull();\n  });\n\n  it('addItem adds to cart', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    expect(cart.getCart(id)!.items).toEqual([{ productId: 'p1', quantity: 2 }]);\n  });\n\n  it('addItem consolidates same product', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p1', 3);\n    const items = cart.getCart(id)!.items;\n    expect(items).toHaveLength(1);\n    expect(items[0]).toEqual({ productId: 'p1', quantity: 5 });\n  });\n\n  it('removeItem removes product', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.r