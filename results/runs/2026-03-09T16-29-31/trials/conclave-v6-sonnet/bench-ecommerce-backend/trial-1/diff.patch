OrderService {\n  const orders = new Map<string, Order>();\n\n  return {\n    createOrder(userId, cartId, total) {\n      const id = uuidv4();\n      orders.set(id, { id, userId, cartId, status: OrderStatus.PENDING, total });\n      const payload: OrderCreatedEvent = { orderId: id, userId, cartId, total };\n      bus.emit(Events.ORDER_CREATED, payload);\n      return id;\n    },\n\n    getOrder(orderId) {\n      const o = orders.get(orderId);\n      if (!o) return null;\n      return { id: o.id, userId: o.userId, status: o.status, total: o.total };\n    },\n\n    updateStatus(orderId, status) {\n      const o = orders.get(orderId);\n      if (!o) return;\n      const previousStatus = o.status;\n      o.status = status;\n      const payload: OrderStatusChangedEvent = { orderId, status, previousStatus };\n      bus.emit(Events.ORDER_STATUS_CHANGED, payload);\n    },\n\n    listOrders(userId) {\n      return Array.from(orders.values())\n        .filter(o => o.userId === userId)\n        .map(o => ({ id: o.id, status: o.status, total: o.total }));\n    },\n  };\n}\n```\n\n**Step 4: Run tests to verify they pass**\n\n```bash\ncd /workspace && npm test -- src/orders/orders.test.ts\n```\nExpected: all tests PASS\n\n**Step 5: Commit**\n\n```bash\ncd /workspace && git add src/orders/ && git commit -m \"feat: add OrderService\"\n```\n\n---\n\n### Task 6: Payment Service\n\n**Files:**\n- Create: `src/payment/index.ts`\n- Create: `src/payment/payment.test.ts`\n\n**Dependencies:** none\n\n**Step 1: Write the failing test**\n\n```typescript\n// src/payment/payment.test.ts\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { EventBus } from '../bus.js';\nimport { createPaymentService } from './index.js';\nimport { Events, PaymentStatus } from '../types.js';\n\ndescribe('PaymentService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('processes payment successfully by default', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 99.99);\n    expect(result.status).toBe(PaymentStatus.SUCCESS);\n    expect(typeof result.transactionId).toBe('string');\n  });\n\n  it('simulates failure when configured', async () => {\n    const payment = createPaymentService(bus, { outcome: 'failure' });\n    const result = await payment.processPayment('order1', 99.99);\n    expect(result.status).toBe(PaymentStatus.FAILED);\n    expect(result.error).toBeTruthy();\n  });\n\n  it('simulates timeout when configured', async () => {\n    const payment = createPaymentService(bus, { outcome: 'timeout' });\n    const result = await payment.processPayment('order1', 99.99);\n    expect(result.status).toBe(PaymentStatus.TIMEOUT);\n  });\n\n  it('emits PAYMENT_PROCESSED on success', async () => {\n    const payment = createPaymentService(bus);\n    const events: unknown[] = [];\n    bus.on(Events.PAYMENT_PROCESSED, p => events.push(p));\n    await payment.processPayment('order1', 99.99);\n    expect(events).toHaveLength(1);\n    expect(events[0]).toMatchObject({ orderId: 'order1', status: PaymentStatus.SUCCESS });\n  });\n\n  it('refund returns true for valid transactionId', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 99.99);\n    const refunded = await payment.refund(result.transactionId!);\n    expect(refunded).toBe(true);\n  });\n\n  it('refund returns false for unknown transactionId', async () => {\n    const payment = createPaymentService(bus);\n    const refunded = await payment.refund('unknown-txn');\n    expect(refunded).toBe(false);\n  });\n});\n```\n\n**Step 2: Run test to verify it fails**\n\n```bash\ncd /workspace && npm test -- src/payment/payment.test.ts\n```\nExpected: FAIL\n\n**Step 3: Implement**\n\n```typescript\n// src/payment/index.ts\nimport { v4 as uuidv4 } from 'uuid';\nimport { EventBus } from '../bus.js';\nimport { Events, PaymentProcessedEvent, PaymentService, PaymentStatus } from '../types.js';\n\ntype PaymentOptions = { outcome?: 'success' | 'failure' | 'timeout' };\n\nexport function createPaymentService(bus: EventBus, options: PaymentOptions = {}): PaymentService {\n  const transactions = new Set<string>();\n  const outcome = options.outcome ?? 'success';\n\n  return {\n    async processPayment(orderId, _amount) {\n      let status: PaymentStatus;\n      let transactionId: string | undefined;\n      let error: string | undefined;\n\n      if (outcome === 'success') {\n        status = PaymentStatus.SUCCESS;\n        transactionId = uuidv4();\n        transactions.add(transactionId);\n      } else if (outcome === 'failure') {\n        status = PaymentStatus.FAILED;\n        error = 'Payment declined';\n      } else {\n        status = PaymentStatus.TIMEOUT;\n        error = 'Payment timed out';\n      }\n\n      const payload: PaymentProcessedEvent = { orderId, status, transactionId, error };\n      await bus.emit(Events.PAYMENT_PROCESSED, payload);\n      return { status, transactionId, error };\n    },\n\n    async refund(transactionId) {\n      if (!transactions.has(transactionId)) return false;\n      transactions.delete(transactionId);\n      return true;\n    },\n  };\n}\n```\n\n**Step 4: Run tests to verify they pass**\n\n```bash\ncd /workspace && npm test -- src/payment/payment.test.ts\n```\nExpected: all tests PASS\n\n**Step 5: Commit**\n\n```bash\ncd /workspace && git add src/payment/ && git commit -m \"feat: add PaymentService\"\n```\n\n---\n\n### Task 7: Notifications Service\n\n**Files:**\n- Create: `src/notifications/index.ts`\n- Create: `src/notifications/notifications.test.ts`\n\n**Dependencies:** Task 5 (Orders), Task 6 (Payment) — listens to their events\n\n**Step 1: Write the failing test**\n\n```typescript\n// src/notifications/notifications.test.ts\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { EventBus } from '../bus.js';\nimport { createNotificationService } from './index.js';\nimport { createOrderService } from '../orders/index.js';\nimport { createPaymentService } from '../payment/index.js';\nimport { Events, OrderStatus } from '../types.js';\n\ndescribe('NotificationService', () => {\n  let bus: EventBus;\n  let notifications: ReturnType<typeof createNotificationService>;\n  let orders: ReturnType<typeof createOrderService>;\n  let payment: ReturnType<typeof createPaymentService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    notifications = createNotificationService(bus);\n    orders = createOrderService(bus);\n    payment = createPaymentService(bus);\n  });\n\n  it('getNotifications returns empty for unsubscribed user', () => {\n    expect(notifications.getNotifications('user1')).toEqual([]);\n  });\n\n  it('getNotifications returns empty for subscribed user with no events', () => {\n    notifications.subscribe('user1');\n    expect(notifications.getNotifications('user1')).toEqual([]);\n  });\n\n  it('receives notification on order status change', async () => {\n    notifications.subscribe('user1');\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    await new Promise(r => setTimeout(r, 0));\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    await new Promise(r => setTimeout(r, 0));\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThan(0);\n    expect(notifs[0]).toHaveProperty('type');\n    expect(notifs[0]).toHaveProperty('message');\n    expect(notifs[0]).toHaveProperty('timestamp');\n  });\n\n  it('receives notification on successful payment', async () => {\n    notifications.subscribe('user1');\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    await payment.processPayment(orderId, 100);\n    await new Promise(r => setTimeout(r, 0));\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.some(n => n.type === 'payment')).toBe(true);\n  });\n\n  it('does not notify unsubscribed users', async () => {\n    // user2 not subscribed\n    const orderId = orders.createOrder('user2', 'cart1', 100);\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    await new Promise(r => setTimeout(r, 0));\n    expect(notifications.getNotifications('user2')).toEqual([]);\n  });\n});\n```\n\n**Step 2: Run test to verify it fails**\n\n```bash\ncd /workspace && npm test -- src/notifications/notifications.test.ts\n```\nExpected: FAIL\n\n**Step 3: Implement**\n\n```typescript\n// src/notifications/index.ts\nimport { EventBus } from '../bus.js';\nimport {\n  Events,\n  NotificationService,\n  OrderCreatedEvent,\n  OrderStatusChangedEvent,\n  PaymentProcessedEvent,\n} from '../types.js';\n\ntype Notification = { type: string; message: string; timestamp: number };\n\nexport function createNotificationService(bus: EventBus): NotificationService {\n  const subscribers = new Set<string>();\n  const notificationStore = new Map<string, Notification[]>();\n\n  // Map orderId -> userId so we can look up who to notify\n  const orderOwners = new Map<string, string>();\n\n  function store(userId: string, type: string, message: string) {\n    if (!subscribers.has(userId)) return;\n    if (!notificationStore.has(userId)) notificationStore.set(userId, []);\n    notificationStore.get(userId)!.push({ type, message, timestamp: Date.now() });\n  }\n\n  bus.on(Events.ORDER_CREATED, (payload) => {\n    const e = payload as OrderCreatedEvent;\n    orderOwners.set(e.orderId, e.userId);\n  });\n\n  bus.on(Events.ORDER_STATUS_CHANGED, (payload) => {\n    const e = payload as OrderStatusChangedEvent;\n    const userId = orderOwners.get(e.orderId);\n    if (userId) store(userId, 'order_status', `Order ${e.orderId} status changed to ${e.status}`);\n  });\n\n  bus.on(Events.PAYMENT_PROCESSED, (payload) => {\n    const e = payload as PaymentProcessedEvent;\n    const userId = orderOwners.get(e.orderId);\n    if (userId) store(userId, 'payment', `Payment for order ${e.orderId}: ${e.status}`);\n  });\n\n  return {\n    subscribe(userId) {\n      subscribers.add(userId);\n    },\n\n    getNotifications(userId) {\n      return notificationStore.get(userId) ?? [];\n    },\n  };\n}\n```\n\n**Step 4: Run tests to verify they pass**\n\n```bash\ncd /workspace && npm test -- src/notifications/notifications.test.ts\n```\nExpected: all tests PASS\n\n**Step 5: Commit**\n\n```bash\ncd /workspace && git add src/notifications/ && git commit -m \"feat: add NotificationService\"\n```\n\n---\n\n### Task 8: Analytics Service\n\n**Files:**\n- Create: `src/analytics/index.ts`\n- Create: `src/analytics/analytics.test.ts`\n\n**Dependencies:** Tasks 2-7 (listens to all events)\n\n**Step 1: Write the failing test**\n\n```typescript\n// src/analytics/analytics.test.ts\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { EventBus } from '../bus.js';\nimport { createAnalyticsService } from './index.js';\nimport { createCartService } from '../cart/index.js';\nimport { createOrderService } from '../orders/index.js';\nimport { createPaymentService } from '../payment/index.js';\nimport { Events, PaymentStatus } from '../types.js';\n\ndescribe('AnalyticsService', () => {\n  let bus: EventBus;\n  let analytics: ReturnType<typeof createAnalyticsService>;\n  let cart: ReturnType<typeof createCartService>;\n  let orders: ReturnType<typeof createOrderService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    analytics = createAnalyticsService(bus);\n    cart = createCartService(bus);\n    orders = createOrderService(bus);\n  });\n\n  it('getEventCount returns 0 for unknown event', () => {\n    expect(analytics.getEventCount('no:such')).toBe(0);\n  });\n\n  it('counts cart:updated events', async () => {\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 1);\n    await new Promise(r => setTimeout(r, 0));\n    expect(analytics.getEventCount(Events.CART_UPDATED)).toBe(1);\n  });\n\n  it('getRevenue sums successful payments', async () => {\n    const payment = createPaymentService(bus);\n    const orderId = orders.createOrder('user1', 'cart1', 150);\n    await payment.processPayment(orderId, 150);\n    await new Promise(r => setTimeout(r, 0));\n    expect(analytics.getRevenue()).toBe(150);\n  });\n\n  it('getRevenue excludes failed payments', async () => {\n    const payment = createPaymentService(bus, { outcome: 'failure' });\n    const orderId = orders.createOrder('user1', 'cart1', 150);\n    await payment.processPayment(orderId, 150);\n    await new Promise(r => setTimeout(r, 0));\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  it('getConversionRate returns orders/carts', async () => {\n    cart.createCart('user1');\n    cart.createCart('user2');\n    orders.createOrder('user1', 'cart1', 100);\n    await new Promise(r => setTimeout(r, 0));\n    expect(analytics.getConversionRate()).toBeCloseTo(0.5);\n  });\n\n  it('getConversionRate returns 0 when no carts', () => {\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n\n  it('getTopProducts returns products ranked by order quantity', async () => {\n    // Simulate ORDER_CREATED events with items via bus\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 10 });\n    // We need products tracked from cart — use a lower-level approach:\n    // track via CART_UPDATED (analytics tracks unique product orderings)\n    // Actually getTopProducts tracks by order quantity from ORDER_CREATED items\n    // Since OrderCreatedEvent doesn't have items, analytics must track from cart items at order time\n    // The simplest approach: analytics listens to CART_UPDATED to track products per cart, then ORDER_CREATED to score\n    const cartId1 = cart.createCart('user1');\n    cart.addItem(cartId1, 'p1', 3);\n    cart.addItem(cartId1, 'p2', 1);\n    orders.createOrder('user1', cartId1, 100);\n    await new Promise(r => setTimeout(r, 0));\n    const top = analytics.getTopProducts(2);\n    expect(top.length).toBeGreaterThan(0);\n    expect(top[0]).toHaveProperty('productId');\n    expect(top[0]).toHaveProperty('count');\n  });\n\n  it('getTopProducts respects limit', async () => {\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 1);\n    cart.addItem(cartId, 'p2', 1);\n    cart.addItem(cartId, 'p3', 1);\n    orders.createOrder('user1', cartId, 30);\n    await new Promise(r => setTimeout(r, 0));\n    expect(analytics.getTopProducts(2)).toHaveLength(2);\n  });\n});\n```\n\n**Step 2: Run test to verify it fails**\n\n```bash\ncd /workspace && npm test -- src/analytics/analytics.test.ts\n```\nExpected: FAIL\n\n**Step 3: Implement**\n\nKey design decision: `OrderCreatedEvent` doesn't include line items. Analytics tracks products by listening to `CART_UPDATED` events (last known cart contents per cartId), then on `ORDER_CREATED` uses the stored cart contents to score products.\n\n```typescript\n// src/analytics/index.ts\nimport { EventBus } from '../bus.js';\nimport {\n  AnalyticsService,\n  CartUpdatedEvent,\n  Events,\n  OrderCreatedEvent,\n  PaymentProcessedEvent,\n  PaymentStatus,\n} from '../types.js';\n\nexport function createAnalyticsService(bus: EventBus): AnalyticsService {\n  const eventCounts = new Map<string, number>();\n  let revenue = 0;\n  let cartCount = 0;\n  let orderCount = 0;\n  const productCounts = new Map<string, number>();\n\n  // Track last-known cart contents (cartId -> items)\n  const cartSnapshots = new Map<string, Array<{ productId: string; quantity: number }>>();\n\n  // Track payment amounts by orderId for revenue\n  const orderAmounts = new Map<string, number>();\n\n  function countEvent(event: string) {\n    eventCounts.set(event, (eventCounts.get(event) ?? 0) + 1);\n  }\n\n  // Count all events generically\n  bus.on(Events.PRODUCT_CREATED, () => countEvent(Events.PRODUCT_CREATED));\n  bus.on(Events.INVENTORY_UPDATED, () => countEvent(Events.INVENTORY_UPDATED));\n  bus.on(Events.LOW_STOCK_ALERT, () => countEvent(Events.LOW_STOCK_ALERT));\n  bus.on(Events.PRICE_CALCULATED, () => countEvent(Events.PRICE_CALCULATED));\n  bus.on(Events.NOTIFICATION_SENT, () => countEvent(Events.NOTIFICATION_SENT));\n  bus.on(Events.ANALYTICS_EVENT, () => countEvent(Events.ANALYTICS_EVENT));\n\n  bus.on(Events.CART_UPDATED, (payload) => {\n    countEvent(Events.CART_UPDATED);\n    const e = payload as CartUpdatedEvent;\n    cartSnapshots.set(e.cartId, e.items);\n  });\n\n  bus.on(Events.ORDER_CREATED, (payload) => {\n    countEvent(Events.ORDER_CREATED);\n    orderCount++;\n    const e = payload as OrderCreatedEvent;\n    orderAmounts.set(e.orderId, e.total);\n\n    // Score products from cart snapshot\n    const items = cartSnapshots.get(e.cartId) ?? [];\n    for (const item of items) {\n      productCounts.set(item.productId, (productCounts.get(item.productId) ?? 0) + item.quantity);\n    }\n  });\n\n  bus.on(Events.ORDER_STATUS_CHANGED, () => countEvent(Events.ORDER_STATUS_CHANGED));\n\n  bus.on(Events.PAYMENT_PROCESSED, (payload) => {\n    countEvent(Events.PAYMENT_PROCESSED);\n    const e = payload as PaymentProcessedEvent;\n    if (e.status === PaymentStatus.SUCCESS) {\n      revenue += orderAmounts.get(e.orderId) ?? 0;\n    }\n  });\n\n  // CART_UPDATED doesn't fire on createCart — track cart count from when a cartId first appears\n  const seenCarts = new Set<string>();\n  bus.on(Events.CART_UPDATED, (payload) => {\n    const e = payload as CartUpdatedEvent;\n    if (!seenCarts.has(e.cartId)) {\n      seenCarts.add(e.cartId);\n      cartCount++;\n    }\n  });\n\n  // Also track carts created via ORDER_CREATED (in case cart was never updated)\n  bus.on(Events.ORDER_CREATED, (payload) => {\n    const e = payload as OrderCreatedEvent;\n    if (!seenCarts.has(e.cartId)) {\n      seenCarts.add(e.cartId);\n      cartCount++;\n    }\n  });\n\n  return {\n    getEventCount(eventType) {\n      return eventCounts.get(eventType) ?? 0;\n    },\n\n    getRevenue() {\n      return revenue;\n    },\n\n    getConversionRate() {\n      if (cartCount === 0) return 0;\n      return orderCount / cartCount;\n    },\n\n    getTopProducts(limit) {\n      return Array.from(productCounts.entries())\n        .map(([productId, count]) => ({ productId, count }))\n        .sort((a, b) => b.count - a.count)\n        .slice(0, limit);\n    },\n  };\n}\n```\n\n**Note:** There is a subtle issue with the above — the `CART_UPDATED` handler is registered twice. Consolidate the cart snapshot and seenCarts tracking into a single handler. Here is the corrected implementation:\n\n```typescript\n// src/analytics/index.ts\nimport { EventBus } from '../bus.js';\nimport {\n  AnalyticsService,\n  CartUpdatedEvent,\n  Events,\n  OrderCreatedEvent,\n  PaymentProcessedEvent,\n  PaymentStatus,\n} from '../types.js';\n\nexport function createAnalyticsService(bus: EventBus): AnalyticsService {\n  const eventCounts = new Map<string, number>();\n  let revenue = 0;\n  let orderCount = 0;\n  const productCounts = new Map<string, number>();\n  const cartSnapshots = new Map<string, Array<{ productId: string; quantity: number }>>();\n  const orderAmounts = new Map<string, number>();\n  const seenCarts = new Set<string>();\n\n  function countEvent(event: string) {\n    eventCounts.set(event, (eventCounts.get(event) ?? 0) + 1);\n  }\n\n  bus.on(Events.PRODUCT_CREATED, () => countEvent(Events.PRODUCT_CREATED));\n  bus.on(Events.INVENTORY_UPDATED, () => countEvent(Events.INVENTORY_UPDATED));\n  bus.on(Events.LOW_STOCK_ALERT, () => countEvent(Events.LOW_STOCK_ALERT));\n  bus.on(Events.PRICE_CALCULATED, () => countEvent(Events.PRICE_CALCULATED));\n  bus.on(Events.NOTIFICATION_SENT, () => countEvent(Events.NOTIFICATION_SENT));\n  bus.on(Events.ANALYTICS_EVENT, () => countEvent(Events.ANALYTICS_EVENT));\n  bus.on(Events.ORDER_STATUS_CHANGED, () => countEvent(Events.ORDER_STATUS_CHANGED));\n\n  bus.on(Events.CART_UPDATED, (payload) => {\n    countEvent(Events.CART_UPDATED);\n    const e = payload as CartUpdatedEvent;\n    cartSnapshots.set(e.cartId, e.items);\n    seenCarts.add(e.cartId);\n  });\n\n  bus.on(Events.ORDER_CREATED, (payload) => {\n    countEvent(Events.ORDER_CREATED);\n    orderCount++;\n    const e = payload as OrderCreatedEvent;\n    orderAmounts.set(e.orderId, e.total);\n    seenCarts.add(e.cartId);\n    const items = cartSnapshots.get(e.cartId) ?? [];\n    for (const item of items) {\n      productCounts.set(item.productId, (productCounts.get(item.productId) ?? 0) + item.quantity);\n    }\n  });\n\n  bus.on(Events.PAYMENT_PROCESSED, (payload) => {\n    countEvent(Events.PAYMENT_PROCESSED);\n    const e = payload as PaymentProcessedEvent;\n    if (e.status === PaymentStatus.SUCCESS) {\n      revenue += orderAmounts.get(e.orderId) ?? 0;\n    }\n  });\n\n  return {\n    getEventCount(eventType) {\n      return eventCounts.get(eventType) ?? 0;\n    },\n\n    getRevenue() {\n      return revenue;\n    },\n\n    getConversionRate() {\n      if (seenCarts.size === 0) return 0;\n      return orderCount / seenCarts.size;\n    },\n\n    getTopProducts(limit) {\n      return Array.from(productCounts.entries())\n        .map(([productId, count]) => ({ productId, count }))\n        .sort((a, b) => b.count - a.count)\n        .slice(0, limit);\n    },\n  };\n}\n```\n\n**Step 4: Run tests to verify they pass**\n\n```bash\ncd /workspace && npm test -- src/analytics/analytics.test.ts\n```\nExpected: all tests PASS\n\n**Step 5: Commit**\n\n```bash\ncd /workspace && git add src/analytics/ && git commit -m \"feat: add AnalyticsService\"\n```\n\n---\n\n### Task 9: Wire up src/index.ts\n\n**Files:**\n- Create: `src/index.ts`\n\n**Dependencies:** Tasks 1-8\n\n**Step 1: Write the failing test**\n\n```typescript\n// src/index.test.ts\nimport { describe, it, expect } from 'vitest';\nimport {\n  createCatalogService,\n  createInventoryService,\n  createCartService,\n  createPricingService,\n  createOrderService,\n  createPaymentService,\n  createNotificationService,\n  createAnalyticsService,\