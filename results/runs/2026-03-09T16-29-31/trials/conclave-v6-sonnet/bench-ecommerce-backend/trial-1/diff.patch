urn {\n    calculateTotal(items, discountCode?) {\n      const subtotal = items.reduce((sum, item) => sum + item.price * item.quantity, 0);\n      const discountPct = discountCode ? (discounts.get(discountCode) ?? 0) : 0;\n      const discount = subtotal * (discountPct / 100);\n      const taxable = subtotal - discount;\n      const tax = taxable * TAX_RATE;\n      const total = taxable + tax;\n      return { subtotal, discount, tax, total };\n    },\n\n    addDiscountCode(code, percentage) {\n      discounts.set(code, percentage);\n    },\n\n    getPrice(productId) {\n      return prices.get(productId) ?? 0;\n    },\n  };\n}\n```\n\n**Step 4: Run tests to verify they pass**\n\n```bash\ncd /workspace && npm test -- src/pricing/pricing.test.ts\n```\nExpected: all tests PASS\n\n**Step 5: Commit**\n\n```bash\ncd /workspace && git add src/pricing/ && git commit -m \"feat: add PricingService\"\n```\n\n---\n\n### Task 5: Orders Service\n\n**Files:**\n- Create: `src/orders/index.ts`\n- Create: `src/orders/orders.test.ts`\n\n**Dependencies:** none\n\n**Step 1: Write the failing test**\n\n```typescript\n// src/orders/orders.test.ts\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { EventBus } from '../bus.js';\nimport { createOrderService } from './index.js';\nimport { Events, OrderStatus } from '../types.js';\n\ndescribe('OrderService', () => {\n  let bus: EventBus;\n  let orders: ReturnType<typeof createOrderService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    orders = createOrderService(bus);\n  });\n\n  it('createOrder returns an orderId', () => {\n    const id = orders.createOrder('user1', 'cart1', 99.99);\n    expect(typeof id).toBe('string');\n  });\n\n  it('getOrder returns order in PENDING status', () => {\n    const id = orders.createOrder('user1', 'cart1', 99.99);\n    expect(orders.getOrder(id)).toMatchObject({\n      id,\n      userId: 'user1',\n      status: OrderStatus.PENDING,\n      total: 99.99,\n    });\n  });\n\n  it('getOr