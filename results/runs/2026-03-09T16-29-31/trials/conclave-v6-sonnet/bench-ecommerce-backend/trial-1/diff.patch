derId, 150);\n    await new Promise(r => setTimeout(r, 0));\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  it('getConversionRate returns orders/carts', async () => {\n    cart.createCart('user1');\n    const cartId2 = cart.createCart('user2');\n    cart.addItem(cartId2, 'p1', 1);\n    orders.createOrder('user1', cartId2, 100);\n    await new Promise(r => setTimeout(r, 0));\n    // seenCarts = cartId2 (from CART_UPDATED), orderCount = 1\n    expect(analytics.getConversionRate()).toBeCloseTo(1);\n  });\n\n  it('getConversionRate returns 0 when no carts', () => {\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n\n  it('getTopProducts returns products ranked by order quantity', async () => {\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 3);\n    cart.addItem(cartId, 'p2', 1);\n    orders.createOrder('user1', cartId, 100);\n    await new Promise(r => setTimeout(r, 0));\n    const top = analytics.getTopProducts(2);\n    expect(top.length).toBeGreaterThan(0);\n    expect(top[0]).toHaveProperty('productId');\n    expect(top[0]).toHaveProperty('count');\n    expect(top[0].productId).toBe('p1');\n    expect(top[0].count).toBe(3);\n  });\n\n  it('getTopProducts respects limit', async () => {\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 1);\n    cart.addItem(cartId, 'p2', 1);\n    cart.addItem(cartId, 'p3', 1);\n    orders.createOrder('user1', cartId, 30);\n    await new Promise(r => setTimeout(r, 0));\n    expect(analytics.getTopProducts(2)).toHaveLength(2);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":805,"cache_read_input_tokens":59710,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":805},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"c80e475f-f825-4ce5-a47d-b03a8f167a56","