c/catalog/catalog.test.ts\n```\nExpected: all tests PASS\n\n**Step 5: Commit**\n\n```bash\ncd /workspace && git add src/catalog/ && git commit -m \"feat: add CatalogService\"\n```\n\n---\n\n### Task 2: Inventory Service\n\n**Files:**\n- Create: `src/inventory/index.ts`\n- Create: `src/inventory/inventory.test.ts`\n\n**Dependencies:** none\n\n**Step 1: Write the failing test**\n\n```typescript\n// src/inventory/inventory.test.ts\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { EventBus } from '../bus.js';\nimport { createInventoryService } from './index.js';\nimport { Events } from '../types.js';\n\ndescribe('InventoryService', () => {\n  let bus: EventBus;\n  let inventory: ReturnType<typeof createInventoryService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    inventory = createInventoryService(bus);\n  });\n\n  it('returns 0 for unknown product', () => {\n    expect(inventory.getStock('unknown')).toBe(0);\n  });\n\n  it('setStock and getStock', () => {\n    inventory.setStock('p1', 100);\n    expect(inventory.getStock('p1')).toBe(100);\n  });\n\n  it('reserve succeeds when stock sufficient', () => {\n    inventory.setStock('p1', 10);\n    expect(inventory.reserve('p1', 5)).toBe(true);\n    expect(inventory.getStock('p1')).toBe(5);\n  });\n\n  it('reserve fails when stock insufficient', () => {\n    inventory.setStock('p1', 3);\n    expect(inventory.reserve('p1', 5)).toBe(false);\n    expect(inventory.getStock('p1')).toBe(3);\n  });\n\n  it('release increases stock', () => {\n    inventory.setStock('p1', 5);\n    inventory.reserve('p1', 3);\n    inventory.release('p1', 2);\n    expect(inventory.getStock('p1')).toBe(4);\n  });\n\n  it('emits LOW_STOCK_ALERT when stock falls below threshold', async () => {\n    const alerts: unknown[] = [];\n    bus.on(Events.LOW_STOCK_ALERT, p => alerts.push(p));\n    inventory.setStock('p1', 10);\n    inventory.setLowStockThreshold('p1', 5);\n    inventory.reserve('p1', 6); // stock goes to 4, below threshold of 5\n    await new Promise(r => setTimeout(r, 0));\n    expect(alerts).toHaveLength(1);\n    expect(alerts[0]).toMatchObject({ productId: 'p1', currentQuantity: 4, threshold: 5 });\n  });\n\n  it('does not emit LOW_STOCK_ALERT when stock stays above threshold', async () => {\n    const alerts: unknown[] = [];\n    bus.on(Events.LOW_STOCK_ALERT, p => alerts.push(p));\n    inventory.setStock('p1', 10);\n    inventory.setLowStockThreshold('p1', 5);\n    inventory.reserve('p1', 3); // stock goes to 7, above threshold\n    await new Promise(r => setTimeout(r, 0));\n    expect(alerts).toHaveLength(0);\n  });\n});\n```\n\n**Step 2: Run test to verify it fails**\n\n```bash\ncd /workspace && npm test -- src/inventory/inventory.test.ts\n```\nExpected: FAIL\n\n**Step 3: Implement**\n\n```typescript\n// src/inventory/index.ts\nimport { EventBus } from '../bus.js';\nimport { Events, InventoryService, LowStockAlertEvent } from '../types.js';\n\nexport function createInventoryService(bus: EventBus): InventoryService {\n  const stock = new Map<string, number>();\n  const thresholds = new Map<string, number>();\n\n  function checkLowStock(productId: string) {\n    const qty = stock.get(productId) ?? 0;\n    const threshold = thresholds.get(productId);\n    if (threshold !== undefined && qty < threshold) {\n      const payload: LowStockAlertEvent = { productId, currentQuantity: qty, threshold };\n      bus.emit(Events.LOW_STOCK_ALERT, payload);\n    }\n  }\n\n  return {\n    setStock(productId, quantity) {\n      stock.set(productId, quantity);\n      checkLowStock(productId);\n    },\n\n    getStock(productId) {\n      return stock.get(productId) ?? 0;\n    },\n\n    reserve(productId, quantity) {\n      const current = stock.get(productId) ?? 0;\n      if (current < quantity) return false;\n      stock.set(productId, current - quantity);\n      checkLowStock(productId);\n      return true;\n    },\n\n    release(productId, quantity) {\n      const current = stock.get(productId) ?? 0;\n      stock.set(productId, current + quantity);\n    },\n\n    setLowStockThreshold(productId, threshold) {\n      thresholds.set(productId, threshold);\n    },\n  };\n}\n```\n\n**Step 4: Run tests to verify they pass**\n\n```bash\ncd /workspace && npm test -- src/inventory/inventory.test.ts\n```\nExpected: all tests PASS\n\n**Step 5: Commit**\n\n```bash\ncd /workspace && git add src/inventory/ && git commit -m \"feat: add InventoryService\"\n```\n\n---\n\n### Task 3: Cart Service\n\n**Files:**\n- Create: `src/cart/index.ts`\n- Create: `src/cart/cart.test.ts`\n\n**Dependencies:** none\n\n**Step 1: Write the failing test**\n\n```typescript\n// src/cart/cart.test.ts\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { EventBus } from '../bus.js';\nimport { createCartService } from './index.js';\nimport { Events } from '../types.js';\n\ndescribe('CartService', () => {\n  let bus: EventBus;\n  let cart: ReturnType<typeof createCartService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    cart = createCartService(bus);\n  });\n\n  it('createCart returns a cartId', () => {\n    const id = cart.createCart('user1');\n    expect(typeof id).toBe('string');\n  });\n\n  it('getCart returns cart', () => {\n    const id = cart.createCart('user1');\n    const c = cart.getCart(id);\n    expect(c).toMatchObject({ id, userId: 'user1', items: [] });\n  });\n\n  it('getCart returns null for unknown cart', () => {\n    expect(cart.getCart('nope')).toBeNull();\n  });\n\n  it('addItem adds to cart', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    expect(cart.getCart(id)!.items).toEqual([{ productId: 'p1', quantity: 2 }]);\n  });\n\n  it('addItem consolidates same product', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p1', 3);\n    const items = cart.getCart(id)!.items;\n    expect(items).toHaveLength(1);\n    expect(items[0]).toEqual({ productId: 'p1', quantity: 5 });\n  });\n\n  it('removeItem removes product', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.removeItem(id, 'p1');\n    expect(cart.getCart(id)!.items).toHaveLength(0);\n  });\n\n  it('updateQuantity changes quantity', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.updateQuantity(id, 'p1', 10);\n    expect(cart.getCart(id)!.items[0].quantity).toBe(10);\n  });\n\n  it('clearCart empties items', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.clearCart(id);\n    expect(cart.getCart(id)!.items).toHaveLength(0);\n  });\n\n  it('emits CART_UPDATED on addItem', async () => {\n    const events: unknown[] = [];\n    bus.on(Events.CART_UPDATED, p => events.push(p));\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    await new Promise(r => setTimeout(r, 0));\n    expect(events).toHaveLength(1);\n    expect(events[0]).toMatchObject({ cartId: id, userId: 'user1' });\n  });\n});\n```\n\n**Step 2: Run test to verify it fails**\n\n```bash\ncd /workspace && npm test -- src/cart/cart.test.ts\n```\nExpected: FAIL\n\n**Step 3: Implement**\n\n```typescript\n// src/cart/index.ts\nimport { v4 as uuidv4 } from 'uuid';\nimport { EventBus } from '../bus.js';\nimport { CartService, CartUpdatedEvent, Events } from '../types.js';\n\ntype Cart = { id: string; userId: string; items: Map<string, number> };\n\nexport function createCartService(bus: EventBus): CartService {\n  const carts = new Map<string, Cart>();\n\n  function emitUpdated(cart: Cart) {\n    const payload: CartUpdatedEvent = {\n      cartId: cart.id,\n      userId: cart.userId,\n      items: Array.from(cart.items.entries()).map(([productId, quantity]) => ({ productId, quantity })),\n    };\n    bus.emit(Events.CART_UPDATED, payload);\n  }\n\n  return {\n    createCart(userId) {\n      const id = uuidv4();\n      carts.set(id, { id, userId, items: new Map() });\n      return id;\n    },\n\n    addItem(cartId, productId, quantity) {\n      const cart = carts.get(cartId);\n      if (!cart) return;\n      cart.items.set(productId, (cart.items.get(productId) ?? 0) + quantity);\n      emitUpdated(cart);\n    },\n\n    removeItem(cartId, productId) {\n      const cart = carts.get(cartId);\n      if (!cart) return;\n      cart.items.delete(productId);\n      emitUpdated(cart);\n    },\n\n    getCart(cartId) {\n      const cart = carts.get(cartId);\n      if (!cart) return null;\n      return {\n        id: cart.id,\n        userId: cart.userId,\n        items: Array.from(cart.items.entries()).map(([productId, quantity]) => ({ productId, quantity })),\n      };\n    },\n\n    clearCart(cartId) {\n      const cart = carts.get(cartId);\n      if (!cart) return;\n      cart.items.clear();\n      emitUpdated(cart);\n    },\n\n    updateQuantity(cartId, productId, quantity) {\n      const cart = carts.get(cartId);\n      if (!cart) return;\n      cart.items.set(productId, quantity);\n      emitUpdated(cart);\n    },\n  };\n}\n```\n\n**Step 4: Run tests to verify they pass**\n\n```bash\ncd /workspace && npm test -- src/cart/cart.test.ts\n```\nExpected: all tests PASS\n\n**Step 5: Commit**\n\n```bash\ncd /workspace && git add src/cart/ && git commit -m \"feat: add CartService\"\n```\n\n---\n\n### Task 4: Pricing Service\n\n**Files:**\n- Create: `src/pricing/index.ts`\n- Create: `src/pricing/pricing.test.ts`\n\n**Dependencies:** none (but listens for PRODUCT_CREATED events — tested with EventBus)\n\n**Step 1: Write the failing test**\n\n```typescript\n// src/pricing/pricing.test.ts\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { EventBus } from '../bus.js';\nimport { createPricingService } from './index.js';\nimport { Events, ProductCreatedEvent } from '../types.js';\n\ndescribe('PricingService', () => {\n  let bus: EventBus;\n  let pricing: ReturnType<typeof createPricingService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    pricing = createPricingService(bus);\n  });\n\n  it('calculates subtotal, 10% tax, and total', () => {\n    const result = pricing.calculateTotal([\n      { productId: 'p1', quantity: 2, price: 10 },\n    ]);\n    expect(result.subtotal).toBe(20);\n    expect(result.discount).toBe(0);\n    expect(result.tax).toBeCloseTo(2);\n    expect(result.total).toBeCloseTo(22);\n  });\n\n  it('applies percentage discount code before tax', () => {\n    pricing.addDiscountCode('SAVE10', 10); // 10% off\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'SAVE10'\n    );\n    expect(result.subtotal).toBe(100);\n    expect(result.discount).toBe(10);\n    expect(result.tax).toBeCloseTo(9); // 10% of 90\n    expect(result.total).toBeCloseTo(99);\n  });\n\n  it('ignores unknown discount code', () => {\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'INVALID'\n    );\n    expect(result.discount).toBe(0);\n    expect(result.total).toBeCloseTo(110);\n  });\n\n  it('getPrice returns 0 for unknown product', () => {\n    expect(pricing.getPrice('unknown')).toBe(0);\n  });\n\n  it('tracks price from PRODUCT_CREATED event', async () => {\n    const payload: ProductCreatedEvent = { productId: 'p1', name: 'Widget', price: 9.99, category: 'tools' };\n    await bus.emit(Events.PRODUCT_CREATED, payload);\n    expect(pricing.getPrice('p1')).toBe(9.99);\n  });\n});\n```\n\n**Step 2: Run test to verify it fails**\n\n```bash\ncd /workspace && npm test -- src/pricing/pricing.test.ts\n```\nExpected: FAIL\n\n**Step 3: Implement**\n\n```typescript\n// src/pricing/index.ts\nimport { EventBus } from '../bus.js';\nimport { Events, PricingService, ProductCreatedEvent } from '../types.js';\n\nconst TAX_RATE = 0.1;\n\nexport function createPricingService(bus: EventBus): PricingService {\n  const prices = new Map<string, number>();\n  const discounts = new Map<string, number>();\n\n  bus.on(Events.PRODUCT_CREATED, (payload) => {\n    const e = payload as ProductCreatedEvent;\n    prices.set(e.productId, e.price);\n  });\n\n  return {\n    calculateTotal(items, discountCode?) {\n      const subtotal = items.reduce((sum, item) => sum + item.price * item.quantity, 0);\n      const discountPct = discountCode ? (discounts.get(discountCode) ?? 0) : 0;\n      const discount = subtotal * (discountPct / 100);\n      const taxable = subtotal - discount;\n      const tax = taxable * TAX_RATE;\n      const total = taxable + tax;\n      return { subtotal, discount, tax, total };\n    },\n\n    addDiscountCode(code, percentage) {\n      discounts.set(code, percentage);\n    },\n\n    getPrice(productId) {\n      return prices.get(productId) ?? 0;\n    },\n  };\n}\n```\n\n**Step 4: Run tests to verify they pass**\n\n```bash\ncd /workspace && npm test -- src/pricing/pricing.test.ts\n```\nExpected: all tests PASS\n\n**Step 5: Commit**\n\n```bash\ncd /workspace && git add src/pricing/ && git commit -m \"feat: add PricingService\"\n```\n\n---\n\n### Task 5: Orders Service\n\n**Files:**\n- Create: `src/orders/index.ts`\n- Create: `src/orders/orders.test.ts`\n\n**Dependencies:** none\n\n**Step 1: Write the failing test**\n\n```typescript\n// src/orders/orders.test.ts\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { EventBus } from '../bus.js';\nimport { createOrderService } from './index.js';\nimport { Events, OrderStatus } from '../types.js';\n\ndescribe('OrderService', () => {\n  let bus: EventBus;\n  let orders: ReturnType<typeof createOrderService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    orders = createOrderService(bus);\n  });\n\n  it('createOrder returns an orderId', () => {\n    const id = orders.createOrder('user1', 'cart1', 99.99);\n    expect(typeof id).toBe('string');\n  });\n\n  it('getOrder returns order in PENDING status', () => {\n    const id = orders.createOrder('user1', 'cart1', 99.99);\n    expect(orders.getOrder(id)).toMatchObject({\n      id,\n      userId: 'user1',\n      status: OrderStatus.PENDING,\n      total: 99.99,\n    });\n  });\n\n  it('getOrder returns null for unknown id', () => {\n    expect(orders.getOrder('nope')).toBeNull();\n  });\n\n  it('updateStatus changes status', () => {\n    const id = orders.createOrder('user1', 'cart1', 99.99);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.CONFIRMED);\n  });\n\n  it('listOrders returns orders for user', () => {\n    orders.createOrder('user1', 'cart1', 10);\n    orders.createOrder('user1', 'cart2', 20);\n    orders.createOrder('user2', 'cart3', 30);\n    expect(orders.listOrders('user1')).toHaveLength(2);\n  });\n\n  it('emits ORDER_CREATED on createOrder', async () => {\n    const events: unknown[] = [];\n    bus.on(Events.ORDER_CREATED, p => events.push(p));\n    const id = orders.createOrder('user1', 'cart1', 99.99);\n    await new Promise(r => setTimeout(r, 0));\n    expect(events[0]).toMatchObject({ orderId: id, userId: 'user1', cartId: 'cart1', total: 99.99 });\n  });\n\n  it('emits ORDER_STATUS_CHANGED with previousStatus', async () => {\n    const events: unknown[] = [];\n    bus.on(Events.ORDER_STATUS_CHANGED, p => events.push(p));\n    const id = orders.createOrder('user1', 'cart1', 99.99);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    await new Promise(r => setTimeout(r, 0));\n    expect(events[0]).toMatchObject({\n      orderId: id,\n      status: OrderStatus.CONFIRMED,\n      previousStatus: OrderStatus.PENDING,\n    });\n  });\n});\n```\n\n**Step 2: Run test to verify it fails**\n\n```bash\ncd /workspace && npm test -- src/orders/orders.test.ts\n```\nExpected: FAIL\n\n**Step 3: Implement**\n\n```typescript\n// src/orders/index.ts\nimport { v4 as uuidv4 } from 'uuid';\nimport { EventBus } from '../bus.js';\nimport { Events, OrderCreatedEvent, OrderService, OrderStatus, OrderStatusChangedEvent } from '../types.js';\n\ntype Order = { id: string; userId: string; cartId: string; status: OrderStatus; total: number };\n\nexport function createOrderService(bus: EventBus): OrderService {\n  const orders = new Map<string, Order>();\n\n  return {\n    createOrder(userId, cartId, total) {\n      const id = uuidv4();\n      orders.set(id, { id, userId, cartId, status: OrderStatus.PENDING, total });\n      const payload: OrderCreatedEvent = { orderId: id, userId, cartId, total };\n      bus.emit(Events.ORDER_CREATED, payload);\n      return id;\n    },\n\n    getOrder(orderId) {\n      const o = orders.get(orderId);\n      if (!o) return null;\n      return { id: o.id, userId: o.userId, status: o.status, total: o.total };\n    },\n\n    updateStatus(orderId, status) {\n      const o = orders.get(orderId);\n      if (!o) return;\n      const previousStatus = o.status;\n      o.status = status;\n      const payload: OrderStatusChangedEvent = { orderId, status, previousStatus };\n      bus.emit(Events.ORDER_STATUS_CHANGED, payload);\n    },\n\n    listOrders(userId) {\n      return Array.from(orders.values())\n        .filter(o => o.userId === userId)\n        .map(o => ({ id: o.id, status: o.status, total: o.total }));\n    },\n  };\n}\n```\n\n**Step 4: Run tests to verify they pass**\n\n```bash\ncd /workspace && npm test -- src/orders/orders.test.ts\n```\nExpected: all tests PASS\n\n**Step 5: Commit**\n\n```bash\ncd /workspace && git add src/orders/ && git commit -m \"feat: add OrderService\"\n```\n\n---\n\n### Task 6: Payment Service\n\n**Files:**\n- Create: `src/payment/index.ts`\n- Create: `src/payment/payment.test.ts`\n\n**Dependencies:** none\n\n**Step 1: Write the failing test**\n\n```typescript\n// src/payment/payment.test.ts\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { EventBus } from '../bus.js';\nimport { createPaymentService } from './index.js';\nimport { Events, PaymentStatus } from '../types.js';\n\ndescribe('PaymentService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('processes payment successfully by default', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 99.99);\n    expect(result.status).toBe(PaymentStatus.SUCCESS);\n    expect(typeof result.transactionId).toBe('string');\n  });\n\n  it('simulates failure when configured', async () => {\n    const payment = createPaymentService(bus, { outcome: 'failure' });\n    const result = await payment.processPayment('order1', 99.99);\n    expect(result.status).toBe(PaymentStatus.FAILED);\n    expect(result.error).toBeTruthy();\n  });\n\n  it('simulates timeout when configured', async () => {\n    const payment = createPaymentService(bus, { outcome: 'timeout' });\n    const result = await payment.processPayment('order1', 99.99);\n    expect(result.status).toBe(PaymentStatus.TIMEOUT);\n  });\n\n  it('emits PAYMENT_PROCESSED on success', async () => {\n    const payment = createPaymentService(bus);\n    const events: unknown[] = [];\n    bus.on(Events.PAYMENT_PROCESSED, p => events.push(p));\n    await payment.processPayment('order1', 99.99);\n    expect(events).toHaveLength(1);\n    expect(events[0]).toMatchObject({ orderId: 'order1', status: PaymentStatus.SUCCESS });\n  });\n\n  it('refund returns true for valid transactionId', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 99.99);\n    const refunded = await payment.refund(result.transactionId!);\n    expect(refunded).toBe(true);\n  });\n\n  it('refund returns false for unknown transactionId', async () => {\n    const payment = createPaymentService(bus);\n    const refunded = await payment.refund('unknown-txn');\n    expect(refunded).toBe(false);\n  });\n});\n```\n\n**Step 2: Run test to verify it fails**\n\n```bash\ncd /workspace && npm test -- src/payment/payment.test.ts\n```\nExpected: FAIL\n\n**Step 3: Implement**\n\n```typescript\n// src/payment/index.ts\nimport { v4 as uuidv4 } from 'uuid';\nimport { EventBus } from '../bus.js';\nimport { Events, PaymentProcessedEvent, PaymentService, PaymentStatus } from '../types.js';\n\ntype PaymentOptions = { outcome?: 'success' | 'failure' | 'timeout' };\n\nexport function createPaymentService(bus: EventBus, options: PaymentOptions = {}): PaymentService {\n  const transactions = new Set<string>();\n  const outcome = options.outcome ?? 'success';\n\n  return {\n    async processPayment(orderId, _amount) {\n      let status: PaymentStatus;\n      let transactionId: string | undefined;\n      let error: string | undefined;\n\n      if (outcome === 'success') {\n        status = PaymentStatus.SUCCESS;\n        transactionId = uuidv4();\n        transactions.add(transactionId);\n      } else if (outcome === 'failure') {\n        status = PaymentStatus.FAILED;\n        error = 'Payment declined';\n      } else {\n        status = PaymentStatus.TIMEOUT;\n        error = 'Payment timed out';\n      }\n\n      const payload: PaymentProcessedEvent = { orderId, status, transactionId, error };\n      await bus.emit(Events.PAYMENT_PROCESSED, payload);\n      return { status, transactionId, error };\n    },\n\n    async refund(transactionId) {\n      if (!transactions.has(transactionId)) return false;\n      transactions.delete(transactionId);\n      return true;\n    },\n  };\n}\n```\n\n**Step 4: Run tests to verify they pass**\n\n```bash\ncd /workspace && npm test -- src/payment/payment.test.ts\n```\nExpected: all tests PASS\n\n**Step 5: Commit**\n\n```bash\ncd /workspace && git add src/payment/ && git commit -m \"feat: add PaymentService\"\n```\n\n---\n\n### Task 7: Notifications Service\n\n**Files:**\n- Create: `src/notifications/index.ts`\n- Create: `src/notifications/notifications.test.ts`\n\n**Dependencies:** Task 5 (Orders), Task 6 (Payment) — listens to their events\n\n**Step 1: Write the failing test**\n\n```typescript\n// src/notifications/notifications.test.ts\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { EventBus } from '../bus.js';\nimport { createNotificationService } from './index.js';\nimport { createOrderService } from '../orders/index.js';\nimport { createPaymentService } from '../payment/index.js';\nimport { Events, OrderStatus } from '../types.js';\n\ndescribe('NotificationService', () => {\n  let bus: EventBus;\n  let notifications: ReturnType<typeof createNotificationService>;\n  let orders: ReturnType<typeof createOrderService>;\n  let payment: ReturnType<typeof createPaymentService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    notifications = createNotificationService(bus);\n    orders = createOrderService(bus);\n    payment = createPaymentService(bus);\n  });\n\n  it('getNotifications returns empty for unsubscribed user', () => {\n    expect(notifications.getNotifications('user1')).toEqual([]);\n  });\n\n  it('getNotifications returns empty for subscribed user with no events', () => {\n    notifications.subscribe('user1');\n    expect(notifications.getNotifications('user1')).toEqual([]);\n  });\n\n  it('receives notification on order status change', async () => {\n    notifications.subscribe('user1');\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    await new Promise(r => setTimeout(r, 0));\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    await new Promise(r => setTimeout(r, 0));\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThan(0);\n    expect(notifs[0]).toHaveProperty('type');\n    expect(notifs[0]).toHaveProperty('message');\n    expect(notifs[0]).toHaveProperty('timestamp');\n  });\n\n  it('receives notification on successful payment', async () => {\n    notifications.subscribe('user1');\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    await payment.processPayment(orderId, 100);\n    await new Promise(r => setTimeout(r, 0));\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.some(n => n.type === 'payment')).toBe(true);\n  });\n\n  it('does not notify unsubscribed users', async () => {\n    // user2 not subscribed\n    const orderId = orders.createOrder('user2', 'cart1', 100);\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    await new Promise(r => setTimeout(r, 0));\n    expect(notifications.getNotifications('user2')).toEqual([]);\n  });\n});\n```\n\n**Step 2: Run test to verify it fails**\n\n```bash\ncd /workspace && npm test -- src/notifications/notifications.test.ts\n```\nExpected: FAIL\n\n**Step 3: Implement**\n\n```typescript\n// src/notifications/index.ts\nimport { EventBus } from '../bus.js';\nimport {\n  Events,\n  NotificationService,\n  OrderCreatedEvent,\n  OrderStatusChangedEvent,\n  PaymentProcessedEvent,\n} from '../types.js';\n\ntype Notification = { type: string; message: string; timestamp: number };\n\nexport function createNotificationService(bus: EventBus): NotificationService {\n  const subscribers = new Set<string>();\n  const notificationStore = new Map<string, Notification[]>();\n\n  // Map orderId -> userId so we can look up who to notify\n  const orderOwners = new Map<string, string>();\n\n  function store(userId: string, type: string, message: string) {\n    if (!subscribers.has(userId)) return;\n    if (!notificationStore.has(userId)) notificationStore.set(userId, []);\n    notificationStore.get(userId)!.push({ type, message, timestamp: Date.now() });\n  }\n\n  bus.on(Events.ORDER_CREATED, (payload) => {\n    const e = payload as OrderCreatedEvent;\n    orderOwners.set(e.orderId, e.userId);\n  });\n\n  bus.on(Events.ORDER_STATUS_CHANGED, (payload) => {\n    const e = payload as OrderStatusChangedEvent;\n    const userId = orderOwners.get(e.orderId);\n    if (userId) store(userId, 'order_status', `Order ${e.orderId} status changed to ${e.status}`);\n  });\n\n  bus.on(Events.PAYMENT_PROCESSED, (payload) => {\n    const e = payload as PaymentProcessedEvent;\n    const userId = orderOwners.get(e.orderId);\n    if (userId) store(userId, 'payment', `Payment for order ${e.orderId}: ${e.status}`);\n  });\n\n  return {\n    subscribe(userId) {\n      subscribers.add(userId);\n    },\n\n    getNotifications(userId) {\n      return notificationStore.get(userId) ?? [];\n    },\n  };\n}\n```\n\n**Step 4: Run tests to verify they pass**\n\n```bash\ncd /workspace && npm test -- src/notifications/notifications.test.ts\n```\nExpected: all tests PASS\n\n**Step 5: Commit**\n\n```bash\ncd /workspace && git add src/notifications/ && git commit -m \"feat: add NotificationService\"\n```\n\n---\n\n### Task 8: Analytics Service\n\n**Files:**\n- Create: `src/analytics/index.ts`\n- Create: `src/analytics/analytics.test.ts`\n\n**Dependencies:** Tasks 2-7 (listens to all events)\n\n**Step 1: Write the failing test**\n\n```typescript\n// src/analytics/analytics.test.ts\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { EventBus } from '../bus.js';\nimport { createAnalyticsService } from './index.js';\nimport { createCartService } from '../cart/index.js';\nimport { createOrderService } from '../orders/index.js';\nimport { createPaymentService } from '../payment/index.js';\nimport { Events, PaymentStatus } from '../types.js';\n\ndescribe('AnalyticsService', () => {\n  let bus: EventBus;\n  let analytics: ReturnType<typeof createAnalyticsService>;\n  let cart: ReturnType<typeof createCartService>;\n  let orders: ReturnType<typeof createOrderService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    analytics = createAnalyticsService(bus);\n    cart = createCartService(bus);\n    orders = createOrderService(bus);\n  });\n\n  it('getEventCount returns 0 for unknown event', () => {\n    expect(analytics.getEventCount('no:such')).toBe(0);\n  });\n\n  it('counts cart:updated events', async () => {\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 1);\n    await new Promise(r => setTimeout(r, 0));\n    expect(analytics.getEventCount(Events.CART_UPDATED)).toBe(1);\n  });\n\n  it('getRevenue sums successful payments', async () => {\n    const payment = createPaymentService(bus);\n    const orderId = orders.createOrder('user1', 'cart1', 150);\n    await payment.processPayment(orderId, 150);\n    await new Promise(r => setTimeout(r, 0));\n    expect(analytics.getRevenue()).toBe(150);\n  });\n\n  it('getRevenue excludes failed payments', async () => {\n    const payment = createPaymentService(bus, { outcome: 'failure' });\n    const orderId = orders.createOrder('user1', 'cart1', 150);\n    await payment.processPayment(orderId, 150);\n    await new Promise(r => setTimeout(r, 0));\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  it('getConversionRate returns orders/carts', async () => {\n    cart.createCart('user1');\n    cart.createCart('user2');\n    orders.createOrder('user1', 'cart1', 100);\n    await new Promise(r => setTimeout(r, 0));\n    expect(analytics.getConversionRate()).toBeCloseTo(0.5);\n  });\n\n  it('getConversionRate returns 0 when no carts', () => {\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n\n  it('getTopProducts returns products ranked by order quantity', async () => {\n    // Simulate ORDER_CREATED events with items via bus\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 10 });\n    // We need products tracked from cart — use a lower-level approach:\n    // track via CART_UPDATED (analytics tracks unique product orderings)\n    // Actually getTopProducts tracks by order quantity from ORDER_CREATED items\n    // Since OrderCreatedEvent doesn't have items, analytics must track from cart items at order time\n    // The simplest approach: analytics listens to CART_UPDATED to track products per cart, then ORDER_CREATED to score\n    const cartId1 = cart.createCart('user1');\n    cart.addItem(cartId1, 'p1', 3);\n    cart.addItem(cartId1, 'p2', 1);\n    orders.createOrder('user1', cartId1, 100);\n    await new Promise(r => setTimeout(r, 0));\n    const top = analytics.getTopProducts(2);\n    expect(top.length).toBeGreaterThan(0);\n    expect(top[0]).toHaveProperty('productId');\n    expect(top[0]).toHaveProperty('count');\n  });\n\n  it('getTopProducts respects limit', async () => {\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 1);\n    cart.addItem(cartId, 'p2', 1);\n    cart.addItem(cartId, 'p3', 1);\n    orders.createOrder('user1', cartId, 30);\n    await new Promise(r => setTimeout(r, 0));\n    expect(analytics.getTopProducts(2)).toHaveLength(2);\n  });\n});\n```\n\n**Step 2: Run test to verify it fails**\n\n```bash\ncd /workspace && npm test -- src/analytics/analytics.test.ts\n```\nExpected: FAIL\n\n**Step 3: Implement**\n\nKey design decision: `OrderCreatedEvent` doesn't include line items. Analytics tracks products by listening to `CART_UPDATED` events (last known cart contents per cartId), then on `ORDER_CREATED` uses the stored cart contents to score products.\n\n```typescript\n// src/analytics/index.ts\nimport { EventBus } from '../bus.js';\nimport {\n  AnalyticsService,\n  CartUpdatedEvent,\n  Events,\n  OrderCreatedEvent,\n  PaymentProcessedEvent,\n  PaymentStatus,\n} from '../types.js';\n\nexport function createAnalyticsService(bus: EventBus): AnalyticsService {\n  const eventCounts = new Map<string, number>();\n  let revenue = 0;\n  let cartCount = 0;\n  let orderCount = 0;\n  const productCounts = new Map<string, number>();\n\n  // Track last-known cart contents (cartId -> items)\n  const cartSnapshots = new Map<string, Array<{ productId: string; quantity: number }>>();\n\n  // Track payment amounts by orderId for revenue\n  const orderAmounts = new Map<string, number>();\n\n  function countEvent(event: string) {\n    eventCounts.set(event, (eventCounts.get(event) ?? 0) + 1);\n  }\n\n  // Count all events generically\n  bus.on(Events.PRODUCT_CREATED, () => countEvent(Events.PRODUCT_CREATED));\n  bus.on(Events.INVENTORY_UPDATED, () => countEvent(Events.INVENTORY_UPDATED));\n  bus.on(Events.LOW_STOCK_ALERT, () => countEvent(Events.LOW_STOCK_ALERT));\n  bus.on(Events.PRICE_CALCULATED, () => countEvent(Events.PRICE_CALCULATED));\n  bus.on(Events.NOTIFICATION_SENT, () => countEvent(Events.NOTIFICATION_SENT));\n  bus.on(Events.ANALYTICS_EVENT, () => countEvent(Events.ANALYTICS_EVENT));\n\n  bus.on(Events.CART_UPDATED, (payload) => {\n    countEvent(Events.CART_UPDATED);\n    const e = payload as CartUpdatedEvent;\n    cartSnapshots.set(e.cartId, e.items);\n  });\n\n  bus.on(Events.ORDER_CREATED, (payload) => {\n    countEvent(Events.ORDER_CREATED);\n    orderCount++;\n    const e = payload as OrderCreatedEvent;\n    orderAmounts.set(e.orderId, e.total);\n\n    // Score products from cart snapshot\n    const items = cartSnapshots.get(e.cartId) ?? [];\n    for (const item of items) {\n      productCounts.set(item.productId, (productCounts.get(item.productId) ?? 0) + item.quantity);\n    }\n  });\n\n  bus.on(Events.ORDER_STATUS_CHANGED, () => countEvent(Events.ORDER_STATUS_CHANGED));\n\n  bus.on(Events.PAYMENT_PROCESSED, (payload) => {\n    countEvent(Events.PAYMENT_PROCESSED);\n    const e = payload as PaymentProcessedEvent;\n    if (e.status === PaymentStatus.SUCCESS) {\n      revenue += orderAmounts.get(e.orderId) ?? 0;\n    }\n  });\n\n  // CART_UPDATED doesn't fire on createCart — track cart count from when a cartId first appears\n  const seenCarts = new Set<string>();\n  bus.on(Events.CART_UPDATED, (payload) => {\n    const e = payload as CartUpdatedEvent;\n    if (!seenCarts.has(e.cartId)) {\n      seenCarts.add(e.cartId);\n      cartCount++;\n    }\n  });\n\n  // Also track carts created via ORDER_CREATED (in case cart was never updated)\n  bus.on(Events.ORDER_CREATED, (payload) => {\n    const e = payload as OrderCreatedEvent;\n    if (!seenCarts.has(e.cartId)) {\n      seenCarts.add(e.cartId);\n      cartCount++;\n    }\n  });\n\n  return {\n    getEventCount(eventType) {\n      return eventCounts.get(eventType) ?? 0;\n    },\n\n    getRevenue() {\n      return revenue;\n    },\n\n    getConversionRate() {\n      if (cartCount === 0) return 0;\n      return orderCount / cartCount;\n    },\n\n    getTopProducts(limit) {\n      return Array.from(productCounts.entries())\n        .map(([productId, count]) => ({ productId, count }))\n        .sort((a, b) => b.count - a.count)\n        .slice(0, limit);\n    },\n  };\n}\n```\n\n**Note:** There is a subtle issue with the above — the `CART_UPDATED` handler is registered twice. Consolidate the cart snapshot and seenCarts tracking into a single handler. Here is the corrected implementation:\n\n```typescript\n// src/analytics/index.ts\nimport { EventBus } from '../bus.js';\nimport {\n  AnalyticsService,\n  CartUpdatedEvent,\n  Events,\n  OrderCreatedEvent,\n  PaymentProcessedEvent,\n  PaymentStatus,\n} from '../types.js';\n\nexport function createAnalyticsService(bus: EventBus): AnalyticsService {\n  const eventCounts = new Map<string, number>();\n  let revenue = 0;\n  let orderCount = 0;\n  const productCounts = new Map<string, number>();\n  const cartSnapshots = new Map<string, Array<{ productId: string; quantity: number }>>();\n  const orderAmounts = new Map<string, number>();\n  const seenCarts = new Set<string>();\n\n  function countEvent(event: string) {\n    eventCounts.set(event, (eventCounts.get(event) ?? 0) + 1);\n  }\n\n  bus.on(Events.PRODUCT_CREATED, () => countEvent(Events.PRODUCT_CREATED));\n  bus.on(Events.INVENTORY_UPDATED, () => countEvent(Events.INVENTORY_UPDATED));\n  bus.on(Events.LOW_STOCK_ALERT, () => countEvent(Events.LOW_STOCK_ALERT));\n  bus.on(Events.PRICE_CALCULATED, () => countEvent(Events.PRICE_CALCULATED));\n  bus.on(Events.NOTIFICATION_SENT, () => countEvent(Events.NOTIFICATION_SENT));\n  bus.on(Events.ANALYTICS_EVENT, () => countEvent(Events.ANALYTICS_EVENT));\n  bus.on(Events.ORDER_STATUS_CHANGED, () => countEvent(Events.ORDER_STATUS_CHANGED));\n\n  bus.on(Events.CART_UPDATED, (payload) => {\n    countEvent(Events.CART_UPDATED);\n    const e = payload as CartUpdatedEvent;\n    cartSnapshots.set(e.cartId, e.items);\n    seenCarts.add(e.cartId);\n  });\n\n  bus.on(Events.ORDER_CREATED, (payload) => {\n    countEvent(Events.ORDER_CREATED);\n    orderCount++;\n    const e = payload as OrderCreatedEvent;\n    orderAmounts.set(e.orderId, e.total);\n    seenCarts.add(e.cartId);\n    const items = cartSnapshots.get(e.cartId) ?? [];\n    for (const item of items) {\n      productCounts.set(item.productId, (productCounts.get(item.productId) ?? 0) + item.quantity);\n    }\n  });\n\n  bus.on(Events.PAYMENT_PROCESSED, (payload) => {\n    countEvent(Events.PAYMENT_PROCESSED);\n    const e = payload as PaymentProcessedEvent;\n    if (e.status === PaymentStatus.SUCCESS) {\n      revenue += orderAmounts.get(e.orderId) ?? 0;\n    }\n  });\n\n  return {\n    getEventCount(eventType) {\n      return eventCounts.get(eventType) ?? 0;\n    },\n\n    getRevenue() {\n      return revenue;\n    },\n\n    getConversionRate() {\n      if (seenCarts.size === 0) return 0;\n      return orderCount / seenCarts.size;\n    },\n\n    getTopProducts(limit) {\n      return Array.from(productCounts.entries())\n        .map(([productId, count]) => ({ productId, count }))\n        .sort((a, b) => b.count - a.count)\n        .slice(0, limit);\n    },\n  };\n}\n```\n\n**Step 4: Run tests to verify they pass**\n\n```bash\ncd /workspace && npm test -- src/analytics/analytics.test.ts\n```\nExpected: all tests PASS\n\n**Step 5: Commit**\n\n```bash\ncd /workspace && git add src/analytics/ && git commit -m \"feat: add AnalyticsService\"\n```\n\n---\n\n### Task 9: Wire up src/index.ts\n\n**Files:**\n- Create: `src/index.ts`\n\n**Dependencies:** Tasks 1-8\n\n**Step 1: Write the failing test**\n\n```typescript\n// src/index.test.ts\nimport { describe, it, expect } from 'vitest';\nimport {\n  createCatalogService,\n  createInventoryService,\n  createCartService,\n  createPricingService,\n  createOrderService,\n  createPaymentService,\n  createNotificationService,\n  createAnalyticsService,\n} from './index.js';\nimport { EventBus } from './bus.js';\n\ndescribe('src/index.ts exports', () => {\n  it('exports all 8 factory functions', () => {\n    const bus = new EventBus();\n    expect(typeof createCatalogService(bus)).toBe('object');\n    expect(typeof createInventoryService(bus)).toBe('object');\n    expect(typeof createCartService(bus)).toBe('object');\n    expect(typeof createPricingService(bus)).toBe('object');\n    expect(typeof createOrderService(bus)).toBe('object');\n    expect(typeof createPaymentService(bus)).toBe('object');\n    expect(typeof createNotificationService(bus)).toBe('object');\n    expect(typeof createAnalyticsService(bus)).toBe('object');\n  });\n});\n```\n\n**Step 2: Run test to verify it fails**\n\n```bash\ncd /workspace && npm test -- src/index.test.ts\n```\nExpected: FAIL — cannot find module `./index.js`\n\n**Step 3: Implement**\n\n```typescript\n// src/index.ts\nexport { createCatalogService } from './catalog/index.js';\nexport { createInventoryService } from './inventory/index.js';\nexport { createCartService } from './cart/index.js';\nexport { createPricingService } from './pricing/index.js';\nexport { createOrderService } from './orders/index.js';\nexport { createPaymentService } from './payment/index.js';\nexport { createNotificationService } from './notifications/index.js';\nexport { createAnalyticsService } from './analytics/index.js';\n```\n\n**Step 4: Run tests**\n\n```bash\ncd /workspace && npm test -- src/index.test.ts\n```\nExpected: all tests PASS\n\n**Step 5: Run full verification**\n\n```bash\ncd /workspace && npm run build && npm run lint && npm test\n```\nExpected: build succeeds, no lint errors, all tests pass.\n\n**Step 6: Commit**\n\n```bash\ncd /workspace && git add src/index.ts src/index.test.ts && git commit -m \"feat: wire up src/index.ts exports\"