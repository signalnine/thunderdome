+import { describe, it, expect, beforeEach } from 'vitest';
+import { EventBus } from '../bus.js';
+import { createNotificationService } from './index.js';
+import { createOrderService } from '../orders/index.js';
+import { createPaymentService } from '../payment/index.js';
+import { OrderStatus } from '../types.js';
+
+describe('NotificationService', () => {
+  let bus: EventBus;
+  let notifications: ReturnType<typeof createNotificationService>;
+  let orders: ReturnType<typeof createOrderService>;
+  let payment: ReturnType<typeof createPaymentService>;
+
+  beforeEach(() => {
+    bus = new EventBus();
+    notifications = createNotificationService(bus);
+    orders = createOrderService(bus);
+    payment = createPaymentService(bus);
+  });
+
+  it('getNotifications returns empty for unsubscribed user', () => {
+    expect(notifications.getNotifications('user1')).toEqual([]);
+  });
+
+  it('getNotifications returns empty for subscribed user with no events', () => {
+    notifications.subscribe('user1');
+    expect(notifications.getNotifications('user1')).toEqual([]);
+  });
+
+  it('receives notification on order status change', async () => {
+    notifications.subscribe('user1');
+    const orderId = orders.createOrder('user1', 'cart1', 100);
+    await new Promise<void>(r => { setTimeout(r, 0); });
+    orders.updateStatus(orderId, OrderStatus.CONFIRMED);
+    await new Promise<void>(r => { setTimeout(r, 0); });
+    const notifs = notifications.getNotifications('user1');
+    expect(notifs.length).toBeGreaterThan(0);
+    expect(notifs[0]).toHaveProperty('type');
+    expect(notifs[0]).toHaveProperty('message');
+    expect(notifs[0]).toHaveProperty('timestamp');
+  });
+
+  it('receives notification on successful payment', async () => {
+    notifications.subscribe('user1');
+    const orderId = orders.createOrder('user1', 'cart1', 100);
+    await new Promise<void>(r => { setTimeout(r, 0); });
+    await payment.processPayment(orderId, 100);
+    await new Promise<void>(r => { setTimeout(r, 0); });
+    const notifs = notifications.getNotifications('user1');
