+```typescript
+// src/orders/index.ts
+import { v4 as uuidv4 } from 'uuid';
+import { EventBus } from '../bus.js';
+import { Events, OrderCreatedEvent, OrderService, OrderStatus, OrderStatusChangedEvent } from '../types.js';
+
+type Order = { id: string; userId: string; cartId: string; status: OrderStatus; total: number };
+
+export function createOrderService(bus: EventBus): OrderService {
+  const orders = new Map<string, Order>();
+
+  return {
+    createOrder(userId, cartId, total) {
+      const id = uuidv4();
+      orders.set(id, { id, userId, cartId, status: OrderStatus.PENDING, total });
+      const payload: OrderCreatedEvent = { orderId: id, userId, cartId, total };
+      bus.emit(Events.ORDER_CREATED, payload);
+      return id;
+    },
+
+    getOrder(orderId) {
+      const o = orders.get(orderId);
+      if (!o) return null;
+      return { id: o.id, userId: o.userId, status: o.status, total: o.total };
+    },
+
+    updateStatus(orderId, status) {
+      const o = orders.get(orderId);
+      if (!o) return;
+      const previousStatus = o.status;
+      o.status = status;
+      const payload: OrderStatusChangedEvent = { orderId, status, previousStatus };
+      bus.emit(Events.ORDER_STATUS_CHANGED, payload);
+    },
+
+    listOrders(userId) {
+      return Array.from(orders.values())
+        .filter(o => o.userId === userId)
+        .map(o => ({ id: o.id, status: o.status, total: o.total }));
+    },
+  };
+}
+```
