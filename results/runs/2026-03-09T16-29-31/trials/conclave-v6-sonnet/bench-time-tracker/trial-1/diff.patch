+++ b/src/tracker.ts
@@ -0,0 +1,96 @@
+import { readFileSync, writeFileSync, mkdirSync, existsSync } from 'node:fs';
+import { dirname } from 'node:path';
+
+export interface TimeEntry {
+  name: string;
+  startedAt: number;
+  stoppedAt?: number;
+}
+
+interface StorageData {
+  entries: TimeEntry[];
+}
+
+export class TimeTracker {
+  private readonly filePath: string;
+
+  constructor(filePath: string) {
+    this.filePath = filePath;
+  }
+
+  private load(): StorageData {
+    if (!existsSync(this.filePath)) {
+      return { entries: [] };
+    }
+    const raw = readFileSync(this.filePath, 'utf-8');
+    return JSON.parse(raw) as StorageData;
+  }
+
+  private save(data: StorageData): void {
+    const dir = dirname(this.filePath);
+    mkdirSync(dir, { recursive: true });
+    writeFileSync(this.filePath, JSON.stringify(data, null, 2), 'utf-8');
+  }
+
+  start(name: string): TimeEntry {
+    if (!name.trim()) {
+      throw new Error('Task name must not be empty');
+    }
+
+    const data = this.load();
+    const now = Date.now();
+
+    // Auto-stop any running timer
+    for (const entry of data.entries) {
+      if (entry.stoppedAt === undefined) {
+        entry.stoppedAt = now;
+      }
+    }
+
+    const entry: TimeEntry = { name, startedAt: now };
+    data.entries.push(entry);
+    this.save(data);
+    return { ...entry };
+  }
+
+  stop(): TimeEntry {
+    const data = this.load();
+    const running = data.entries.find((e) => e.stoppedAt === undefined);
+    if (!running) {
+      throw new Error('No timer is currently running');
+    }
+    running.stoppedAt = Date.now();
+    this.save(data);
+    return { ...running };
+  }
+
+  getEntries(filter?: { from?: number; to?: number }): TimeEntry[] {
+    const data = this.load();
+    let entries = data.entries;
+
+    if (filter?.from !== undefined) {
+      const from = filter.from;
+      entries = entries.filter((e) => e.startedAt >= from);
+    }
+    if (filter?.to !== undefined) {
+      const to = filter.to;
+      entries = entries.filter((e) => e.startedAt <= to);
+    }
+
+    return entries.map((e) => ({ ...e }));
+  }
+
+  getSummary(): Record<string, number> {
+    const data = this.load();
+    const now = Date.now();
+    const summary: Record<string, number> = {};
+
+    for (const entry of data.entries) {
+      const end = entry.stoppedAt ?? now;
+      const duration = end - entry.startedAt;
+      summary[entry.name] = (summary[entry.name] ?? 0) + duration;
+    }
+
+    return summary;
+  }
+}
