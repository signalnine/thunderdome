!canRead(store, userId, 'document', req.params.id)) {\n      res.status(403).json({ error: 'Forbidden' });\n      return;\n    }\n    res.status(200).json(doc);\n  });\n\n  app.patch('/documents/:id', auth, (req, res): void => {\n    const userId = res.locals.userId as string;\n    const doc = store.documents.get(req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    if (!canEdit(store, userId, 'document', req.params.id)) {\n      res.status(403).json({ error: 'Forbidden' });\n      return;\n    }\n    const { title, content } = req.body ?? {};\n    if (title !== undefined) doc.title = title;\n    if (content !== undefined) doc.content = content;\n    doc.updatedAt = new Date();\n\n    logActivity(store, { action: 'document.updated', userId, resourceType: 'document', resourceId: req.params.id });\n\n    res.status(200).json(doc);\n  });\n\n  app.delete('/documents/:id', auth, (req, res): void => {\n    const userId = res.locals.userId as string;\n    const doc = store.documents.get(req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    if (!canDelete(store, userId, 'document', req.params.id)) {\n      res.status(403).json({ error: 'Forbidden' });\n      return;\n    }\n\n    logActivity(store, { action: 'document.deleted', userId, resourceType: 'document', resourceId: req.params.id });\n\n    store.documents.delete(req.params.id);\n    store.permissions = store.permissions.filter(\n      (p) => !(p.resourceType === 'document' && p.resourceId === req.params.id),\n    );\n    res.status(204).send();\n  });\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1289,"cache_read_input_tokens":29648,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1289},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"contex