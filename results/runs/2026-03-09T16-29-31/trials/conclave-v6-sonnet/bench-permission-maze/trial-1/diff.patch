diff --git a/src/routes/auth.ts b/src/routes/auth.ts
new file mode 100644
index 0000000..48823cc
--- /dev/null
+++ b/src/routes/auth.ts
@@ -0,0 +1,44 @@
+import { Express } from 'express';
+import { Store } from '../store.js';
+import { randomUUID } from 'crypto';
+
+export function registerAuthRoutes(app: Express, store: Store): void {
+  app.post('/auth/register', (req, res): void => {
+    const { username, password } = req.body ?? {};
+    if (!username || !password) {
+      res.status(400).json({ error: 'username and password required' });
+      return;
+    }
+    for (const user of store.users.values()) {
+      if (user.username === username) {
+        res.status(409).json({ error: 'Username already taken' });
+        return;
+      }
+    }
+    const id = randomUUID();
+    store.users.set(id, { id, username, passwordHash: password });
+    res.status(201).json({ id, username });
+  });
+
+  app.post('/auth/login', (req, res): void => {
+    const { username, password } = req.body ?? {};
+    if (!username || !password) {
+      res.status(400).json({ error: 'username and password required' });
+      return;
+    }
+    let found: import('../store.js').User | undefined;
+    for (const user of store.users.values()) {
+      if (user.username === username && user.passwordHash === password) {
+        found = user;
+        break;
+      }
+    }
+    if (!found) {
+      res.status(401).json({ error: 'Invalid credentials' });
+      return;
+    }
+    const token = randomUUID();
+    store.tokens.set(token, found.id);
+    res.status(200).json({ token });
+  });
+}
diff --git a/src/routes/documents.ts b/src/routes/documents.ts
new file mode 100644
index 0000000..b0a4ccb
--- /dev/null
+++ b/src/routes/documents.ts
@@ -0,0 +1,97 @@
+import { Express } from 'express';
+import { Store } from '../store.js';
+import { requireAuth } from '../middleware/auth.js';
+import { canRead, canEdit, canDelete } from '../permissions.js';
+import { logActivity } from '../activity.js';
+import { randomUUID } from 'crypto';
+
+export function registerDocumentRoutes(app: Express, store: Store): void {
+  const auth = requireAuth(store);
+
+  app.post('/folders/:folderId/documents', auth, (req, res): void => {
+    const userId = res.locals.userId as string;
+    const { folderId } = req.params;
+    const { title, content } = req.body ?? {};
+
+    if (!title) {
+      res.status(400).json({ error: 'title required' });
+      return;
+    }
+
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+    if (!canRead(store, userId, 'folder', folderId)) {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+
+    const id = randomUUID();
+    const now = new Date();
+    const doc = { id, title, content: content ?? '', folderId, ownerId: userId, createdAt: now, updatedAt: now };
+    store.documents.set(id, doc);
+    store.permissions.push({ resourceType: 'document', resourceId: id, userId, role: 'owner' });
+
+    logActivity(store, { action: 'document.created', userId, resourceType: 'document', resourceId: id });
+
+    res.status(201).json(doc);
+  });
+
+  app.get('/documents/:id', auth, (req, res): void => {
+    const userId = res.locals.userId as string;
+    const doc = store.documents.get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    if (!canRead(store, userId, 'document', req.params.id)) {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+    res.status(200).json(doc);
+  });
+
+  app.patch('/documents/:id', auth, (req, res): void => {
+    const userId = res.locals.userId as string;
+    const doc = store.documents.get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    if (!canEdit(store, userId, 'document', req.params.id)) {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+    const { title, content } = req.body ?? {};
+    if (title !== undefined) doc.title = title;
+    if (content !== undefined) doc.content = content;
+    doc.updatedAt = new Date();
+
+    logActivity(store, { action: 'document.updated', userId, resourceType: 'document', resourceId: req.params.id });
+
+    res.status(200).json(doc);
+  });
+
+  app.delete('/documents/:id', auth, (req, res): void => {
+    const userId = res.locals.userId as string;
+    const doc = store.documents.get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    if (!canDelete(store, userId, 'document', req.params.id)) {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+
+    logActivity(store, { action: 'document.deleted', userId, resourceType: 'document', resourceId: req.params.id });
+
+    store.documents.delete(req.params.id);
+    store.permissions = store.permissions.filter(
+      (p) => !(p.resourceType === 'document' && p.resourceId === req.params.id),
+    );
+    res.status(204).send();
+  });
+}
diff --git a/src/routes/folders.ts b/src/routes/folders.ts
new file mode 100644
