st bobRegRes = await request(app).post('/auth/register').send({ username: 'bob', password: 'password' });\n      const bobId = bobRegRes.body.id;\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ resourceType: 'folder', resourceId: folder.id, targetUserId: bobId, role: 'viewer' });\n      const bobLoginRes = await request(app).post('/auth/login').send({ username: 'bob', password: 'password' });\n      const bobToken = bobLoginRes.body.token;\n\n      const res = await request(app)\n        .get(`/documents/${doc.id}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n\n      expect(res.status).toBe(200);\n    });\n\n    it('folder viewer cannot edit documents inside', async () => {\n      const folder = await createFolder(app, aliceToken, 'Folder');\n      const doc = await createDocument(app, aliceToken, folder.id, 'MyDoc', 'content');\n\n      const bobRegRes = await request(app).post('/auth/register').send({ username: 'bob', password: 'password' });\n      const bobId = bobRegRes.body.id;\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ resourceType: 'folder', resourceId: folder.id, targetUserId: bobId, role: 'viewer' });\n      const bobLoginRes = await request(app).post('/auth/login').send({ username: 'bob', password: 'password' });\n      const bobToken = bobLoginRes.body.token;\n\n      const res = await request(app)\n        .patch(`/documents/${doc.id}`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ content: 'changed' });\n\n      expect(res.status).toBe(403);\n    });\n\n    it('most permissive role wins when user has multiple paths', async () => {\n      const folder = await createFolder(app, aliceToken, 'Folder');\n      const doc = await createDocument(app, aliceToken, folder.id, 'MyDoc', 'original');\n\n      const bobRegRes = await request(app).post('/auth/register').send({ username: 'bob', password: 'password' });\n      const bobId = bobRegRes.body.id;\n\n      // viewer on folder, editor on document directly\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ resourceType: 'folder', resourceId: folder.id, targetUserId: bobId, role: 'viewer' });\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ resourceType: 'document', resourceId: doc.id, targetUserId: bobId, role: 'editor' });\n\n      const bobLoginRes = await request(app).post('/auth/login').send({ username: 'bob', password: 'password' });\n      const bobToken = bobLoginRes.body.token;\n\n      // editor role means bob can update even though folder role is viewer\n      const res = await request(app)\n        .patch(`/documents/${doc.id}`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ content: 'edited' });\n\n      expect(res.status).toBe(200);\n    });\n  });\n\n  describe('Nested folder permission inheritance', () => {\n    it('access to parent folder propagates to child folder', async () => {\n      const parent = await createFolder(app, aliceToken, 'Parent');\n      const child = await createFolder(app, aliceToken, 'Child', parent.id);\n\n      const bobRegRes = await request(app).post('/auth/register').send({ username: 'bob', password: 'password' });\n      const bobId = bobRegRes.body.id;\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ resourceType: 'folder', resourceId: parent.id, targetUserId: bobId, role: 'viewer' });\n      const bobLoginRes = await request(app).post('/auth/login').send({ username: 'bob', password: 'password' });\n      const bobToken = bobLoginRes.body.token;\n\n      const res = await request(app)\n        .get(`/folders/${child.id}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n\n      expect(res.status).