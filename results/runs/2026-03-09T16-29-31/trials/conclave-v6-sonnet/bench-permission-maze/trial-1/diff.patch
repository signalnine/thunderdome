 });\n\n    it('returns 404 for unknown folder', async () => {\n      const res = await request(app)\n        .post('/folders/nonexistent/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'Doc' });\n\n      expect(res.status).toBe(404);\n    });\n\n    it('returns 403 when user has no folder access', async () => {\n      const bobToken = await registerAndLogin(app, 'bob');\n      const res = await request(app)\n        .post(`/folders/${folderId}/documents`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ title: 'Sneaky Doc' });\n\n      expect(res.status).toBe(403);\n    });\n  });\n\n  describe('GET /documents/:id', () => {\n    it('returns the document', async () => {\n      const doc = await createDocument(app, token, folderId, 'MyDoc', 'body');\n      const res = await request(app)\n        .get(`/documents/${doc.id}`)\n        .set('Authorization', `Bearer ${token}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body.id).toBe(doc.id);\n      expect(res.body.content).toBe('body');\n    });\n\n    it('returns 404 for unknown document', async () => {\n      const res = await request(app)\n        .get('/documents/nope')\n        .set('Authorization', `Bearer ${token}`);\n\n      expect(res.status).toBe(404);\n    });\n\n    it('returns 403 when user has no access', async () => {\n      const doc = await createDocument(app, token, folderId, 'Private');\n      const bobToken = await registerAndLogin(app, 'bob');\n      const res = await request(app)\n        .get(`/documents/${doc.id}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n\n      expect(res.status).toBe(403);\n    });\n  });\n\n  describe('PATCH /documents/:id', () => {\n    it('updates title and content', async () => {\n      const doc = await createDocument(app, token, folderId, 'Old', 'old content');\n      const res = await request(app)\n        .patch(`/documents/${doc.id}`)\n        .set('Authorization', `Bearer ${token}`