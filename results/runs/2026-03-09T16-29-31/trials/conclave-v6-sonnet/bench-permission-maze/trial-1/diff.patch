@@ -0,0 +1,219 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import request from 'supertest';
+import { createApp } from '../app.js';
+import { registerAndLogin, createFolder, createDocument } from './helpers.js';
+
+describe('Sharing & Permissions', () => {
+  let app: ReturnType<typeof createApp>;
+  let aliceToken: string;
+
+  beforeEach(async () => {
+    app = createApp();
+    aliceToken = await registerAndLogin(app, 'alice');
+  });
+
+  describe('POST /share', () => {
+    it('owner can share a folder with another user', async () => {
+      const folder = await createFolder(app, aliceToken, 'Shared Folder');
+      const bobRegRes = await request(app).post('/auth/register').send({ username: 'bob', password: 'password' });
+      const bobId = bobRegRes.body.id;
+
+      const res = await request(app)
+        .post('/share')
+        .set('Authorization', `Bearer ${aliceToken}`)
+        .send({ resourceType: 'folder', resourceId: folder.id, targetUserId: bobId, role: 'viewer' });
+
+      expect(res.status).toBe(200);
+      expect(res.body.role).toBe('viewer');
+    });
+
+    it('viewer gains read access after sharing', async () => {
+      const folder = await createFolder(app, aliceToken, 'Folder');
+      const bobRegRes = await request(app).post('/auth/register').send({ username: 'bob', password: 'password' });
+      const bobId = bobRegRes.body.id;
+      await request(app)
+        .post('/share')
+        .set('Authorization', `Bearer ${aliceToken}`)
+        .send({ resourceType: 'folder', resourceId: folder.id, targetUserId: bobId, role: 'viewer' });
+      const bobLoginRes = await request(app).post('/auth/login').send({ username: 'bob', password: 'password' });
+      const bobToken = bobLoginRes.body.token;
+
+      const res = await request(app)
+        .get(`/folders/${folder.id}`)
+        .set('Authorization', `Bearer ${bobToken}`);
+
+      expect(res.status).toBe(200);
+    });
+
+    it('editor can modify after sharing', async () => {
+      const folder = await createFolder(app, aliceToken, 'Folder');
+      const bobRegRes = await request(app).post('/auth/register').send({ username: 'bob', password: 'password' });
+      const bobId = bobRegRes.body.id;
+      await request(app)
+        .post('/share')
+        .set('Authorization', `Bearer ${aliceToken}`)
+        .send({ resourceType: 'folder', resourceId: folder.id, targetUserId: bobId, role: 'editor' });
+      const bobLoginRes = await request(app).post('/auth/login').send({ username: 'bob', password: 'password' });
+      const bobToken = bobLoginRes.body.token;
+
+      const res = await request(app)
+        .patch(`/folders/${folder.id}`)
+        .set('Authorization', `Bearer ${bobToken}`)
+        .send({ name: 'Bob Renamed' });
+
+      expect(res.status).toBe(200);
+    });
+
+    it('returns 403 when non-editor/owner tries to share', async () => {
+      const folder = await createFolder(app, aliceToken, 'Folder');
+      const bobRegRes = await request(app).post('/auth/register').send({ username: 'bob', password: 'password' });
+      const bobId = bobRegRes.body.id;
+      await request(app)
+        .post('/share')
+        .set('Authorization', `Bearer ${aliceToken}`)
+        .send({ resourceType: 'folder', resourceId: folder.id, targetUserId: bobId, role: 'viewer' });
+      const bobLoginRes = await request(app).post('/auth/login').send({ username: 'bob', password: 'password' });
+      const bobToken = bobLoginRes.body.token;
+
+      const charlieRegRes = await request(app).post('/auth/register').send({ username: 'charlie', password: 'password' });
+      const charlieId = charlieRegRes.body.id;
+
+      const res = await request(app)
+        .post('/share')
+        .set('Authorization', `Bearer ${bobToken}`)
+        .send({ resourceType: 'folder', resourceId: folder.id, targetUserId: charlieId, role: 'viewer' });
+
+      expect(res.status).toBe(403);
+    });
+
+    it('returns 400 for invalid role', async () => {
+      const folder = await createFolder(app, aliceToken, 'Folder');
+      const bobRegRes = await request(app).post('/auth/register').send({ username: 'bob', password: 'password' });
+      const bobId = bobRegRes.body.id;
+
+      const res = await request(app)
+        .post('/share')
+        .set('Authorization', `Bearer ${aliceToken}`)
+        .send({ resourceType: 'folder', resourceId: folder.id, targetUserId: bobId, role: 'superuser' });
+
+      expect(res.status).toBe(400);
+    });
+
+    it('returns 404 for unknown resource', async () => {
+      const bobRegRes = await request(app).post('/auth/register').send({ username: 'bob', password: 'password' });
+      const bobId = bobRegRes.body.id;
+
+      const res = await request(app)
+        .post('/share')
+        .set('Authorization', `Bearer ${aliceToken}`)
+        .send({ resourceType: 'folder', resourceId: 'nope', targetUserId: bobId, role: 'viewer' });
+
+      expect(res.status).toBe(404);
+    });
+
+    it('returns 404 for unknown target user', async () => {
+      const folder = await createFolder(app, aliceToken, 'Folder');
+
+      const res = await request(app)
+        .post('/share')
+        .set('Authorization', `Bearer ${aliceToken}`)
+        .send({ resourceType: 'folder', resourceId: folder.id, targetUserId: 'nope', role: 'viewer' });
+
+      expect(res.status).toBe(404);
+    });
+  });
+
+  describe('Inherited permissions (folder → document)', () => {
+    it('user with folder access can read documents inside', async () => {
+      const folder = await createFolder(app, aliceToken, 'Folder');
+      const doc = await createDocument(app, aliceToken, folder.id, 'MyDoc', 'content');
+
+      const bobRegRes = await request(app).post('/auth/register').send({ username: 'bob', password: 'password' });
+      const bobId = bobRegRes.body.id;
+      await request(app)
+        .post('/share')
+        .set('Authorization', `Bearer ${aliceToken}`)
+        .send({ resourceType: 'folder', resourceId: folder.id, targetUserId: bobId, role: 'viewer' });
+      const bobLoginRes = await request(app).post('/auth/login').send({ username: 'bob', password: 'password' });
+      const bobToken = bobLoginRes.body.token;
+
+      const res = await request(app)
+        .get(`/documents/${doc.id}`)
+        .set('Authorization', `Bearer ${bobToken}`);
+
+      expect(res.status).toBe(200);
+    });
+
+    it('folder viewer cannot edit documents inside', async () => {
+      const folder = await createFolder(app, aliceToken, 'Folder');
+      const doc = await createDocument(app, aliceToken, folder.id, 'MyDoc', 'content');
+
+      const bobRegRes = await request(app).post('/auth/register').send({ username: 'bob', password: 'password' });
+      const bobId = bobRegRes.body.id;
+      await request(app)
+        .post('/share')
+        .set('Authorization', `Bearer ${aliceToken}`)
+        .send({ resourceType: 'folder', resourceId: folder.id, targetUserId: bobId, role: 'viewer' });
+      const bobLoginRes = await request(app).post('/auth/login').send({ username: 'bob', password: 'password' });
+      const bobToken = bobLoginRes.body.token;
+
+      const res = await request(app)
+        .patch(`/documents/${doc.id}`)
+        .set('Authorization', `Bearer ${bobToken}`)
+        .send({ content: 'changed' });
+
+      expect(res.status).toBe(403);
+    });
+
+    it('most permissive role wins when user has multiple paths', async () => {
+      const folder = await createFolder(app, aliceToken, 'Folder');
+      const doc = await createDocument(app, aliceToken, folder.id, 'MyDoc', 'original');
+
+      const bobRegRes = await request(app).post('/auth/register').send({ username: 'bob', password: 'password' });
+      const bobId = bobRegRes.body.id;
+
+      // viewer on folder, editor on document directly
+      await request(app)
+        .post('/share')
+        .set('Authorization', `Bearer ${aliceToken}`)
+        .send({ resourceType: 'folder', resourceId: folder.id, targetUserId: bobId, role: 'viewer' });
+      await request(app)
+        .post('/share')
+        .set('Authorization', `Bearer ${aliceToken}`)
+        .send({ resourceType: 'document', resourceId: doc.id, targetUserId: bobId, role: 'editor' });
+
+      const bobLoginRes = await request(app).post('/auth/login').send({ username: 'bob', password: 'password' });
+      const bobToken = bobLoginRes.body.token;
+
+      // editor role means bob can update even though folder role is viewer
+      const res = await request(app)
+        .patch(`/documents/${doc.id}`)
+        .set('Authorization', `Bearer ${bobToken}`)
+        .send({ content: 'edited' });
+
+      expect(res.status).toBe(200);
+    });
+  });
+
+  describe('Nested folder permission inheritance', () => {
+    it('access to parent folder propagates to child folder', async () => {
+      const parent = await createFolder(app, aliceToken, 'Parent');
+      const child = await createFolder(app, aliceToken, 'Child', parent.id);
+
+      const bobRegRes = await request(app).post('/auth/register').send({ username: 'bob', password: 'password' });
+      const bobId = bobRegRes.body.id;
+      await request(app)
+        .post('/share')
+        .set('Authorization', `Bearer ${aliceToken}`)
+        .send({ resourceType: 'folder', resourceId: parent.id, targetUserId: bobId, role: 'viewer' });
+      const bobLoginRes = await request(app).post('/auth/login').send({ username: 'bob', password: 'password' });
+      const bobToken = bobLoginRes.body.token;
+
+      const res = await request(app)
+        .get(`/folders/${child.id}`)
+        .set('Authorization', `Bearer ${bobToken}`);
+
+      expect(res.status).toBe(200);
+    });
+  });
+});
