@@ -0,0 +1,35 @@
+import request from 'supertest';
+import { Express } from 'express';
+
+export async function registerAndLogin(app: Express, username: string, password = 'password'): Promise<string> {
+  await request(app).post('/auth/register').send({ username, password });
+  const res = await request(app).post('/auth/login').send({ username, password });
+  return res.body.token as string;
+}
+
+export async function createFolder(
+  app: Express,
+  token: string,
+  name: string,
+  parentId?: string,
+): Promise<{ id: string; name: string; parentId: string | null; ownerId: string }> {
+  const res = await request(app)
+    .post('/folders')
+    .set('Authorization', `Bearer ${token}`)
+    .send({ name, parentId });
+  return res.body;
+}
+
+export async function createDocument(
+  app: Express,
+  token: string,
+  folderId: string,
+  title: string,
+  content = '',
+): Promise<{ id: string; title: string; content: string; folderId: string; ownerId: string }> {
+  const res = await request(app)
+    .post(`/folders/${folderId}/documents`)
+    .set('Authorization', `Bearer ${token}`)
+    .send({ title, content });
+  return res.body;
+}
