+++ b/src/routes/folders.ts
@@ -0,0 +1,85 @@
+import { Express } from 'express';
+import { Store } from '../store.js';
+import { requireAuth } from '../middleware/auth.js';
+import { canRead, canEdit, canDelete } from '../permissions.js';
+import { randomUUID } from 'crypto';
+
+export function registerFolderRoutes(app: Express, store: Store): void {
+  const auth = requireAuth(store);
+
+  app.post('/folders', auth, (req, res): void => {
+    const { name, parentId } = req.body ?? {};
+    if (!name) {
+      res.status(400).json({ error: 'name required' });
+      return;
+    }
+    const userId = res.locals.userId as string;
+
+    if (parentId) {
+      const parent = store.folders.get(parentId);
+      if (!parent) {
+        res.status(404).json({ error: 'Parent folder not found' });
+        return;
+      }
+      if (!canRead(store, userId, 'folder', parentId)) {
+        res.status(403).json({ error: 'Forbidden' });
+        return;
+      }
+    }
+
+    const id = randomUUID();
+    const folder = { id, name, parentId: parentId ?? null, ownerId: userId, createdAt: new Date() };
+    store.folders.set(id, folder);
+    // Grant owner permission
+    store.permissions.push({ resourceType: 'folder', resourceId: id, userId, role: 'owner' });
+    res.status(201).json(folder);
+  });
+
+  app.get('/folders/:id', auth, (req, res): void => {
+    const userId = res.locals.userId as string;
+    const folder = store.folders.get(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+    if (!canRead(store, userId, 'folder', req.params.id)) {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+    res.status(200).json(folder);
+  });
+
+  app.patch('/folders/:id', auth, (req, res): void => {
+    const userId = res.locals.userId as string;
+    const folder = store.folders.get(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+    if (!canEdit(store, userId, 'folder', req.params.id)) {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+    const { name } = req.body ?? {};
+    if (name) folder.name = name;
+    res.status(200).json(folder);
+  });
+
+  app.delete('/folders/:id', auth, (req, res): void => {
+    const userId = res.locals.userId as string;
+    const folder = store.folders.get(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+    if (!canDelete(store, userId, 'folder', req.params.id)) {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+    store.folders.delete(req.params.id);
+    store.permissions = store.permissions.filter(
+      (p) => !(p.resourceType === 'folder' && p.resourceId === req.params.id),
+    );
+    res.status(204).send();
+  });
+}
diff --git a/src/routes/share.ts b/src/routes/share.ts
new file mode 100644
index 0000000..e194041
--- /dev/null
+++ b/src/routes/share.ts
@@ -0,0 +1,58 @@
+import { Express } from 'express';
+import { Store, Role } from '../store.js';
+import { requireAuth } from '../middleware/auth.js';
+import { canShare } from '../permissions.js';
+import { logActivity } from '../activity.js';
+
+const VALID_ROLES: Role[] = ['viewer', 'editor', 'owner'];
+
+export function registerShareRoutes(app: Express, store: Store): void {
+  const auth = requireAuth(store);
+
+  app.post('/share', auth, (req, res): void => {
+    const userId = res.locals.userId as string;
+    const { resourceType, resourceId, targetUserId, role } = req.body ?? {};
+
+    if (!resourceType || !resourceId || !targetUserId || !role) {
+      res.status(400).json({ error: 'resourceType, resourceId, targetUserId, role required' });
+      return;
+    }
+    if (resourceType !== 'folder' && resourceType !== 'document') {
+      res.status(400).json({ error: 'resourceType must be folder or document' });
+      return;
+    }
+    if (!VALID_ROLES.includes(role)) {
+      res.status(400).json({ error: 'role must be viewer, editor, or owner' });
+      return;
+    }
+
+    const map = resourceType === 'folder' ? store.folders : store.documents;
+    if (!map.has(resourceId)) {
+      res.status(404).json({ error: 'Resource not found' });
+      return;
+    }
+    if (!store.users.has(targetUserId)) {
+      res.status(404).json({ error: 'Target user not found' });
+      return;
+    }
+    if (!canShare(store, userId, resourceType, resourceId)) {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+
+    // Upsert: remove existing direct permission for this user+resource, then add new one
+    store.permissions = store.permissions.filter(
+      (p) => !(p.resourceType === resourceType && p.resourceId === resourceId && p.userId === targetUserId),
+    );
+    store.permissions.push({ resourceType, resourceId, userId: targetUserId, role });
+
+    logActivity(store, {
+      action: 'share',
+      userId,
+      resourceType,
+      resourceId,
+    });
+
+    res.status(200).json({ resourceType, resourceId, targetUserId, role });
+  });
+}
