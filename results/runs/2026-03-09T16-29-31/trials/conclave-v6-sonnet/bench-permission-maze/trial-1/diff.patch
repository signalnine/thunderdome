+      .patch(`/documents/${doc.id}`)
+      .set('Authorization', `Bearer ${token}`)
+      .send({ content: 'new content' });
+
+    const res = await request(app)
+      .get('/activity')
+      .set('Authorization', `Bearer ${token}`);
+
+    expect(res.status).toBe(200);
+    const entry = res.body.find((e: { action: string }) => e.action === 'document.updated');
+    expect(entry).toBeDefined();
+  });
+
+  it('logs document deletion', async () => {
+    const doc = await createDocument(app, token, folderId, 'ToDelete');
+    await request(app)
+      .delete(`/documents/${doc.id}`)
+      .set('Authorization', `Bearer ${token}`);
+
+    const res = await request(app)
+      .get('/activity')
+      .set('Authorization', `Bearer ${token}`);
+
+    expect(res.status).toBe(200);
+    const entry = res.body.find((e: { action: string }) => e.action === 'document.deleted');
+    expect(entry).toBeDefined();
+  });
+
+  it('logs share event', async () => {
