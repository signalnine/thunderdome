+import { Store } from './store.js';
+import { randomUUID } from 'crypto';
+
+interface LogInput {
+  action: string;
+  userId: string;
+  resourceType: 'folder' | 'document';
+  resourceId: string;
+}
+
+export function logActivity(store: Store, input: LogInput): void {
+  store.activity.push({
+    id: randomUUID(),
+    action: input.action,
+    userId: input.userId,
+    resourceType: input.resourceType,
+    resourceId: input.resourceId,
+    timestamp: new Date(),
+  });
+}
