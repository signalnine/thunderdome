+{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01Wq2yShCaEBgs9WaNr3S7pa","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Se5wGSMHiUvfg1rX71kJc3","name":"Write","input":{"file_path":"/workspace/src/permissions.ts","content":"import { Store, Role } from './store.js';\n\nconst ROLE_RANK: Record<Role, number> = { viewer: 1, editor: 2, owner: 3 };\n\nfunction higherRole(a: Role, b: Role): Role {\n  return ROLE_RANK[a] >= ROLE_RANK[b] ? a : b;\n}\n\nexport function getEffectiveRole(\n  store: Store,\n  userId: string,\n  resourceType: 'folder' | 'document',\n  resourceId: string,\n): Role | null {\n  let effective: Role | null = null;\n\n  // Direct permission on the resource\n  for (const p of store.permissions) {\n    if (p.userId === userId && p.resourceType === resourceType && p.resourceId === resourceId) {\n      effective = effective ? higherRole(effective, p.role) : p.role;\n    }\n  }\n\n  // For documents: check permissions on the containing folder (and its ancestors)\n  if (resourceType === 'document') {\n    const doc = store.documents.get(resourceId);\n    if (doc) {\n      const folderRole = getEffectiveRole(store, userId, 'folder', doc.folderId);\n      if (folderRole) {\n        effective = effective ? higherRole(effective, folderRole) : folderRole;\n      }\n    }\n  }\n\n  // For folders: check ancestor folders\n  if (resourceType === 'folder') {\n    const folder = store.folders.get(resourceId);\n    if (folder && folder.parentId) {\n      const parentRole = getEffectiveRole(store, userId, 'folder', folder.parentId);\n      if (parentRole) {\n        effective = effective ? higherRole(effective, parentRole) : parentRole;\n      }\n    }\n  }\n\n  return effective;\n}\n\nexport function canRead(store: Store, userId: string, resourceType: 'folder' | 'document', resourceId: string): boolean {\n  const role = getEffectiveRole(store, userId, resourceType, resourceId);\n  return role !== null;\n}\n\nexport function canEdit(store: Store, userId: string, resourceType: 'folder' | 'document', resourceId: string): boolean {\n  const role = getEffectiveRole(store, userId, resourceType, resourceId);\n  return role === 'editor' || role === 'owner';\n}\n\nexport function canDelete(store: Store, userId: string, resourceType: 'folder' | 'document', resourceId: string): boolean {\n  const role = getEffectiveRole(store, userId, resourceType, resourceId);\n  return role === 'owner';\n}\n\nexport function canShare(store: Store, userId: string, resourceType: 'folder' | 'document', resourceId: string): boolean {\n  const role = getEffectiveRole(store, userId, resourceType, resourceId);\n  return role === 'editor' || role === 'owner';\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":289,"cache_read_input_tokens":27884,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":289},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"fe8a621f-9a0b-41c4-b673-7c874e955721","uuid":"61fcb2ec-35dc-4157-b964-00cf3d7db9f8"}
