+import { marked } from 'marked';
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file: ContentFile, _ctx: BuildContext): ContentFile {
+        let content = file.content;
+
+        // Process admonition containers (:::type ... :::)
+        content = content.replace(
+          /^:::(note|warning|tip)\n([\s\S]*?)^:::$/gm,
+          (_match, type: string, inner: string) => {
+            return `<div class="admonition admonition-${type}">${inner.trim()}</div>`;
+          }
+        );
+
+        // Process footnote definitions and references
+        const footnoteMap = new Map<string, string>();
+        // Extract footnote definitions [^N]: text
+        content = content.replace(/^\[\^(\d+)\]:\s*(.+)$/gm, (_match, num: string, text: string) => {
+          footnoteMap.set(num, text.trim());
+          return '';
+        });
+
+        // Replace footnote references [^N] with superscript links
+        content = content.replace(/\[\^(\d+)\]/g, (_match, num: string) => {
+          return `<sup><a href="#fn-${num}">${num}</a></sup>`;
+        });
+
+        // Convert markdown to HTML using marked
+        const html = marked.parse(content) as string;
+
+        // Append footnotes section if any footnotes were found
+        let result = html;
+        if (footnoteMap.size > 0) {
+          const footnoteItems = Array.from(footnoteMap.entries())
+            .map(([num, text]) => `<li id="fn-${num}">${text}</li>`)
+            .join('\n');
+          result += `\n<section class="footnotes">\n<ol>\n${footnoteItems}\n</ol>\n</section>`;
+        }
+
+        return { ...file, content: result };
+      },
+    },
+  };
+}
diff --git a/src/plugins/rss-feed.ts b/src/plugins/rss-feed.ts
