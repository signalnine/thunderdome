index 0000000..2f68cf0
--- /dev/null
+++ b/src/plugins/rss-feed.ts
@@ -0,0 +1,48 @@
+import { Plugin, BuildContext, ContentFile } from '../core/types.js';
+
+export function createRssFeedPlugin(): Plugin {
+  return {
+    name: 'rss-feed',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'taxonomy'],
+    hooks: {
+      afterBuild(ctx: BuildContext): void {
+        const { config, files } = ctx;
+        const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]> | undefined;
+
+        // Build a reverse map: slug -> tags
+        const slugToTags = new Map<string, string[]>();
+        if (tagMap) {
+          for (const [tag, tagFiles] of tagMap.entries()) {
+            for (const f of tagFiles) {
+              if (!slugToTags.has(f.slug)) {
+                slugToTags.set(f.slug, []);
+              }
+              slugToTags.get(f.slug)!.push(tag);
+            }
+          }
+        }
+
+        // Sort files by date, newest first; undated files go last
+        const sorted = [...files].sort((a, b) => {
+          if (!a.date && !b.date) return 0;
+          if (!a.date) return 1;
+          if (!b.date) return -1;
+          return b.date.localeCompare(a.date);
+        });
+
+        const items = sorted.map(file => {
+          const link = `${config.baseUrl}/${file.slug}.html`;
+          const pubDate = file.date ? `\n    <pubDate>${file.date}</pubDate>` : '';
+          const fileTags = slugToTags.get(file.slug) ?? file.tags ?? [];
+          const categories = fileTags.map(t => `\n    <category>${t}</category>`).join('');
+          return `  <item>\n    <title>${file.title}</title>\n    <link>${link}</link>\n    <description><![CDATA[${file.content}]]></description>${pubDate}${categories}\n  </item>`;
+        }).join('\n');
+
+        const feed = `<?xml version="1.0" encoding="UTF-8"?>\n<rss version="2.0">\n  <channel>\n    <title>${config.title}</title>\n    <link>${config.baseUrl}</link>\n${items}\n  </channel>\n</rss>`;
+
+        ctx.output.set('feed.xml', feed);
+      },
+    },
+  };
+}
