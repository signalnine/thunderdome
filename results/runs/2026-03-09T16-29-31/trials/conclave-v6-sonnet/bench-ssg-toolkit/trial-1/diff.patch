@@ -0,0 +1,38 @@
+import { Plugin, BuildContext, ContentFile } from '../core/types.js';
+
+export function createSitemapPlugin(): Plugin {
+  return {
+    name: 'sitemap',
+    version: '1.0.0',
+    dependencies: ['taxonomy', 'rss-feed'],
+    hooks: {
+      afterBuild(ctx: BuildContext): void {
+        const { config } = ctx;
+        const urls = new Set<string>();
+
+        // Add all files from ctx.output (excluding sitemap.xml itself)
+        for (const key of ctx.output.keys()) {
+          if (key !== 'sitemap.xml') {
+            urls.add(`${config.baseUrl}/${key}`);
+          }
+        }
+
+        // Add tag pages from taxonomy (these may already be in output, but ensure they're included)
+        const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]> | undefined;
+        if (tagMap) {
+          for (const tag of tagMap.keys()) {
+            urls.add(`${config.baseUrl}/tags/${tag}.html`);
+          }
+        }
+
+        const urlElements = Array.from(urls)
+          .map(url => `  <url>\n    <loc>${url}</loc>\n  </url>`)
+          .join('\n');
+
+        const sitemap = `<?xml version="1.0" encoding="UTF-8"?>\n<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">\n${urlElements}\n</urlset>`;
+
+        ctx.output.set('sitemap.xml', sitemap);
+      },
+    },
+  };
+}
