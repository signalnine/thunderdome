s/${docId}/ws`;\n}\n\ninterface WsClient {\n  ws: WebSocket;\n  nextMessage: () => Promise<unknown>;\n  close: () => Promise<void>;\n}\n\nfunction connectWs(docId: string): Promise<WsClient> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(wsUrl(docId));\n    const queue: unknown[] = [];\n    const waiters: Array<(msg: unknown) => void> = [];\n\n    ws.on('message', (data: Buffer) => {\n      let parsed: unknown;\n      try {\n        parsed = JSON.parse(data.toString());\n      } catch {\n        parsed = data.toString();\n      }\n      if (waiters.length > 0) {\n        waiters.shift()!(parsed);\n      } else {\n        queue.push(parsed);\n      }\n    });\n\n    function nextMessage(): Promise<unknown> {\n      return new Promise((res) => {\n        if (queue.length > 0) {\n          res(queue.shift()!);\n        } else {\n          waiters.push(res);\n        }\n      });\n    }\n\n    function close(): Promise<void> {\n      return new Promise((res) => {\n        if (ws.readyState === WebSocket.CLOSED) { res(); return; }\n        ws.once('close', () => res());\n        ws.close();\n      });\n    }\n\n    ws.on('open', () => resolve({ ws, nextMessage, close }));\n    ws.on('error', reject);\n  });\n}\n\nfunction closeWs(ws: WebSocket): Promise<void> {\n  return new Promise((resolve) => {\n    if (ws.readyState === WebSocket.CLOSED) {\n      resolve();\n      return;\n    }\n    ws.once('close', () => resolve());\n    ws.close();\n  });\n}","originalFile":"import { describe, it, expect, beforeEach, afterEach } from 'vitest';\nimport { WebSocket } from 'ws';\nimport { createApp } from '../server.js';\nimport os from 'os';\nimport path from 'path';\nimport fs from 'fs';\n\nlet appInstance: ReturnType<typeof createApp>;\nlet port: number;\nlet dbPath: string;\n\nfunction wsUrl(docId: string) {\n  return `ws://localhost:${port}/documents/${docId}/ws`;\n}\n\nfunction connectWs(docId: string): Promise<WebSocket> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(wsUrl(docId));\n    ws.on('open', () => resolve(ws));\n    ws.on('error', reject);\n  });\n}\n\nfunction nextMessage(ws: WebSocket): Promise<unknown> {\n  return new Promise((resolve, reject) => {\n    ws.once('message', (data: Buffer) => {\n      try {\n        resolve(JSON.parse(data.toString()));\n      } catch (e) {\n        reject(e);\n      }\n    });\n    ws.once('error', reject);\n  });\n}\n\nfunction closeWs(ws: WebSocket): Promise<void> {\n  return new Promise((resolve) => {\n    if (ws.readyState === WebSocket.CLOSED) {\n      resolve();\n      return;\n    }\n    ws.once('close', () => resolve());\n    ws.close();\n  });\n}\n\nbeforeEach(async () => {\n  dbPath = path.join(os.tmpdir(), `ws-test-${Date.now()}.db`);\n  appInstance = createApp(dbPath);\n  port = await appInstance.start(0);\n});\n\nafterEach(async () => {\n  await appInstance.stop();\n  if (fs.existsSync(dbPath)) fs.unlinkSync(dbPath);\n});\n\nasync function createDocViaApi(title: string, content: string): Promise<string> {\n  const res = await fetch(`http://localhost:${port}/documents`, {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify({ title, content }),\n  });\n  const body = await res.json() as { id: string };\n  return body.id;\n}\n\ndescribe('WebSocket - connection and sync', () => {\n  it('sends sync message with current document state on connect', async () => {\n    const docId = await createDocViaApi('Test', 'hello world');\n    const ws = await connectWs(docId);\n    const msg = await nextMessage(ws) as { type: string; content: string; version: number };\n\n    expect(msg.type).toBe('sync');\n    expect(msg.content).toBe('hello world');\n    expect(msg.version).toBe(1);\n\n    await closeWs(ws);\n  });\n\n  it('closes with error message for non-existent document', async () => {\n    const ws = new WebSocket(`ws://localhost:${port}/documents/nonexistent/ws`);\n    const msg = await new Promise<unknown>((resolve) => {\n      ws.on('message', (data: Buffer) => resolve(JSON.parse(data.toString())));\n    });\n\n    expect((msg as { type: string }).type).toBe('error');\n    await closeWs(ws);\n  });\n});\n\ndescribe('WebSocket - sending operations', () => {\n  it('applies insert operation and broadcasts to other clients', async () => {\n    const docId = await createDocViaApi('Test', 'hello');\n\n    const ws1 = await connectWs(docId);\n    await nextMessage(ws1); // sync\n\n    const ws2 = await connectWs(docId);\n    await nextMessage(ws2); // sync\n\n    // ws1 sends insert at pos 5\n    const op = { type: 'insert', pos: 5, text: ' world' };\n    ws1.send(JSON.stringify({ type: 'op', op, version: 1 }));\n\n    // ws2 should receive the op broadcast\n    const broadcast = await nextMessage(ws2) as { type: string; op: { type: string; text: string }; version: number };\n    expect(broadcast.type).toBe('op');\n    expect(broadcast.op.type).toBe('insert');\n    expect(broadcast.op.text).toBe(' world');\n    expect(broadcast.version).toBe(2);\n\n    await closeWs(ws1);\n    await closeWs(ws2);\n  });\n\n  it('applies delete operation and broadcasts to other clients', async () => {\n    const docId = await createDocViaApi('Test', 'hello world');\n\n    const ws1 = await connectWs(docId);\n    await nextMessage(ws1); // sync\n\n    const ws2 = await connectWs(docId);\n    await nextMessage(ws2); // sync\n\n    const op = { type: 'delete', pos: 5, length: 6 };\n    ws1.send(JSON.stringify({ type: 'op', op, version: 1 }));\n\n    const broadcast = await nextMessage(ws2) as { type: string; op: { type: string; length: number } };\n    expect(broadcast.type).toBe('op');\n    expect(broadcast.op.type).toBe('delete');\n    expect(broadcast.op.length).toBe(6);\n\n    await closeWs(ws1);\n    await closeWs(ws2);\n  });\n\n  it('persists changes to database after operation', async () => {\n    const docId = await createDocViaApi('Test', 'hello');\n\n    const ws = await connectWs(docId);\n    await nextMessage(ws); // sync\n\n    const op = { type: 'insert', pos: 5, text: '!' };\n    ws.send(JSON.stringify({ type: 'op', op, version: 1 }));\n    await nextMessage(ws); // ack\n\n    await closeWs(ws);\n\n    // Check DB via REST\n    const res = await fetch(`http://localhost:${port}/documents/${docId}`);\n    const doc = await res.json() as { content: string; version: number };\n    expect(doc.content).toBe('hello!');\n    expect(doc.version).toBe(2);\n  });\n\n  it('rejects malformed messages with error', async () => {\n    const docId = await createDocViaApi('Test', 'hello');\n    const ws = await connectWs(docId);\n    await nextMessage(ws); // sync\n\n    ws.send('not valid json');\n    const err = await nextMessage(ws) as { type: string; message: string };\n    expect(err.type).toBe('error');\n    expect(err.message).toContain('Invalid JSON');\n\n    await closeWs(ws);\n  });\n\n  it('rejects operations with missing fields', async () => {\n    const docId = await createDocViaApi('Test', 'hello');\n    const ws = await connectWs(docId);\n    await nextMessage(ws); // sync\n\n    ws.send(JSON.stringify({ type: 'op', op: { type: 'insert', pos: 0 }, version: 1 }));\n    const err = await nextMessage(ws) as { type: string };\n    expect(err.type).toBe('error');\n\n    await closeWs(ws);\n  });\n});\n\ndescribe('WebSocket - 10 concurrent clients', () => {\n  it('handles 10 concurrent clients without corruption', async () => {\n    const docId = await createDocViaApi('Concurrent', '');\n\n    // Connect 10 clients\n    const clients: WebSocket[] = [];\n    for (let i = 0; i < 10; i++) {\n      const ws = await connectWs(docId);\n      await nextMessage(ws); // sync\n      clients.push(ws);\n    }\n\n    // Each client sends one insert\n    const sends: Promise<unknown>[] = [];\n    for (let i = 0; i < 10; i++) {\n      const ws = clients[i];\n      // Collect the ack for each sender\n      const ackPromise = nextMessage(ws);\n      ws.send(JSON.stringify({\n        type: 'op',\n        op: { type: 'insert', pos: 0, text: String(i) },\n        version: 1,\n      }));\n      sends.push(ackPromise);\n    }\n\n    await Promise.all(sends);\n\n    // Give a moment for all broadcasts to settle\n    await new Promise(r => setTimeout(r, 50));\n\n    // Fetch final document state\n    const res = await fetch(`http://localhost:${port}/documents/${docId}`);\n    const doc = await res.json() as { content: string; version: number };\n\n    // All 10 digits should be in the content\n    for (let i = 0; i < 10; i++) {\n      expect(doc.content).toContain(String(i));\n    }\n    expect(doc.content.length).toBe(10);\n\n    for (const ws of clients) await closeWs(ws);\n  });\n});\n","structuredPatch":[{"oldStart":13,"oldLines":24,"newStart":13,"newLines":52,"lines":["   return `ws://localhost:${port}/documents/${docId}/ws`;"," }"," ","-function connectWs(docId: string): Promise<WebSocket> {","-  return new Promise((resolve, reject) => {","-    const ws = new WebSocket(wsUrl(docId));","-    ws.on('open', () => resolve(ws));","-    ws.on('error', reject);","-  });","+interface WsClient {","+  ws: WebSocket;","+  nextMessage: () => Promise<unknown>;","+  close: () => Promise<void>;"," }"," ","-function nextMessage(ws: WebSocket): Promise<unknown> {","+function connectWs(docId: string): Promise<WsClient> {","   return new Promise((resolve, reject) => {","-    ws.once('message', (data: Buffer) => {","+    const ws = new WebSocket(wsUrl(docId));","+    const queue: unknown[] = [];","+    const waiters: Array<(msg: unknown) => void> = [];","+","+    ws.on('message', (data: Buffer) => {","+      let parsed: unknown;","       try {","-        resolve(JSON.parse(data.toString()));","-      } catch (e) {","-        reject(e);","+        parsed = JSON.parse(data.toString());","+      } catch {","+        parsed = data.toString();","       }","+      if (waiters.length > 0) {","+        waiters.shift()!(parsed);","