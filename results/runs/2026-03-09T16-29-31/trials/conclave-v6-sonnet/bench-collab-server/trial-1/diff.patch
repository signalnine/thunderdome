+import { describe, it, expect, beforeEach, afterEach } from 'vitest';
+import { Database } from '../database.js';
+import fs from 'fs';
+import os from 'os';
+import path from 'path';
+
+let db: Database;
+let dbPath: string;
+
+beforeEach(() => {
+  dbPath = path.join(os.tmpdir(), `test-${Date.now()}.db`);
+  db = new Database(dbPath);
+});
+
+afterEach(() => {
+  db.close();
+  if (fs.existsSync(dbPath)) fs.unlinkSync(dbPath);
+});
+
+describe('Database - documents', () => {
+  it('creates and retrieves a document', () => {
+    const doc = db.createDocument('My Doc', 'Hello world');
+    expect(doc.id).toBeTruthy();
+    expect(doc.title).toBe('My Doc');
+    expect(doc.content).toBe('Hello world');
+    expect(doc.version).toBe(1);
+
+    const found = db.getDocument(doc.id);
+    expect(found).not.toBeNull();
+    expect(found!.title).toBe('My Doc');
+    expect(found!.content).toBe('Hello world');
+  });
+
+  it('returns null for missing document', () => {
+    const found = db.getDocument('nonexistent-id');
+    expect(found).toBeNull();
+  });
+
+  it('lists all documents', () => {
+    db.createDocument('Doc A', 'Content A');
+    db.createDocument('Doc B', 'Content B');
+    const docs = db.listDocuments();
+    expect(docs).toHaveLength(2);
+    const titles = docs.map(d => d.title);
+    expect(titles).toContain('Doc A');
+    expect(titles).toContain('Doc B');
+  });
+
+  it('updates document content and increments version', () => {
+    const doc = db.createDocument('Test', 'initial');
+    const updated = db.updateDocument(doc.id, 'updated content', 'insert at 0: "updated "');
+    expect(updated).not.toBeNull();
+    expect(updated!.content).toBe('updated content');
+    expect(updated!.version).toBe(2);
+  });
+
+  it('deletes a document', () => {
+    const doc = db.createDocument('To Delete', '');
+    db.deleteDocument(doc.id);
+    expect(db.getDocument(doc.id)).toBeNull();
+  });
+
+  it('persists data across reconnection (same file)', () => {
+    const doc = db.createDocument('Persistent', 'stays here');
+    db.close();
+
+    const db2 = new Database(dbPath);
+    const found = db2.getDocument(doc.id);
+    expect(found).not.toBeNull();
+    expect(found!.content).toBe('stays here');
+    db2.close();
+    // re-open for afterEach cleanup
+    db = new Database(dbPath);
+  });
+});
+
+describe('Database - version history', () => {
+  it('records initial version on create', () => {
+    const doc = db.createDocument('Versioned', 'v1 content');
+    const history = db.getVersionHistory(doc.id);
+    expect(history).toHaveLength(1);
+    expect(history[0].version).toBe(1);
+    expect(history[0].content).toBe('v1 content');
+  });
+
+  it('records versions on each update', () => {
+    const doc = db.createDocument('Versioned', 'v1');
+    db.updateDocument(doc.id, 'v2', 'op1');
+    db.updateDocument(doc.id, 'v3', 'op2');
+    const history = db.getVersionHistory(doc.id);
+    expect(history).toHaveLength(3);
+    expect(history[0].version).toBe(1);
+    expect(history[1].version).toBe(2);
+    expect(history[2].version).toBe(3);
+    expect(history[2].content).toBe('v3');
+  });
+
+  it('deletes version history when document is deleted', () => {
+    const doc = db.createDocument('ToDelete', 'content');
+    db.updateDocument(doc.id, 'updated', 'op');
+    db.deleteDocument(doc.id);
+    const history = db.getVersionHistory(doc.id);
+    expect(history).toHaveLength(0);
+  });
+});
