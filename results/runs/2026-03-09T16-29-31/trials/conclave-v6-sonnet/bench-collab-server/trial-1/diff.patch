;\nimport { Database } from './database.js';\nimport { applyOp, transformOp, TextOp } from './ot.js';\nimport { IncomingMessage } from 'http';\n\n// ─── Types ────────────────────────────────────────────────────────────────────\n\ninterface ClientMessage {\n  type: string;\n  op: { type: string; pos?: number; text?: string; length?: number };\n  version: number; // client's current document version\n}\n\ninterface ServerSyncMessage {\n  type: 'sync';\n  docId: string;\n  content: string;\n  version: number;\n}\n\ninterface ServerOpMessage {\n  type: 'op';\n  op: TextOp;\n  version: number;\n}\n\ninterface ServerErrorMessage {\n  type: 'error';\n  message: string;\n}\n\ntype ServerMessage = ServerSyncMessage | ServerOpMessage | ServerErrorMessage;\n\ninterface ConnectedClient {\n  ws: WebSocket;\n  docId: string;\n}\n\n// ─── Document Room ─────────────────────────────────────────────────────────────\n// Tracks in-memory state for a document with active WS connections\n\ninterface DocRoom {\n  docId: string;\n  clients: Set<ConnectedClient>;\n  // pending ops that have been applied server-side since last DB flush\n  currentContent: string;\n  currentVersion: number;\n}\n\n// ─── createApp ─────────────────────────────────────────────────────────────────\n\nexport function createApp(dbPath?: string) {\n  const db = new Database(dbPath);\n  const expressApp = express();\n  expressApp.use(express.json());\n\n  const httpServer: HttpServer = createServer(expressApp);\n  const wss = new WebSocketServer({ noServer: true });\n\n  // In-memory rooms keyed by document ID\n  const rooms = new Map<string, DocRoom>();\n\n  function getOrCreateRoom(docId: string, content: string, version: number): DocRoom {\n    if (!rooms.has(docId)) {\n      rooms.set(docId, { docId, clients: new Set(), currentContent: content, currentVersion: version });\n    }\n    return rooms.get(docId)!;\n  }\n\n  function broadcast(room: DocRoom, message: ServerMessage, exclude?: ConnectedClient): void {\n    const data = JSON.stringify(message);\n    for (const client of room.clients) {\n      if (client === exclude) continue;\n      if (client.ws.readyState === WebSocket.OPEN) {\n        client.ws.send(data);\n      }\n    }\n  }\n\n  function send(client: ConnectedClient, message: ServerMessage): void {\n    if (client.ws.readyState === WebSocket.OPEN) {\n      client.ws.send(JSON.stringify(message));\n    }\n  }\n\n  // ─── WebSocket upgrade ──────────────────────────────────────────────────────\n  // URL format: /documents/:docId/ws\n\n  httpServer.on('upgrade', (req: IncomingMessage, socket, head) => {\n    const url = req.url ?? '';\n    const match = url.match(/^\\/documents\\/([^/]+)\\/ws$/);\n    if (!match) {\n      socket.destroy();\n      return;\n    }\n\n    wss.handleUpgrade(req, socket, head, (ws) => {\n      wss.emit('connection', ws, req, match[1]);\n    });\n  });\n\n  wss.on('connection', (ws: WebSocket, _req: IncomingMessage, docId: string) => {\n    const doc = db.getDocument(docId);\n    if (!doc) {\n      ws.send(JSON.stringify({ type: 'error', message: `Document ${docId} not found` } as ServerErrorMessage));\n      ws.close();\n      return;\n    }\n\n    const room = getOrCreateRoom(doc.id, doc.content, doc.version);\n    const client: ConnectedClient = { ws, docId };\n    room.clients.add(client);\n\n    // Send current state to new client\n    send(client, { type: 'sync', docId: doc.id, content: room.currentContent, version: room.currentVersion });\n\n    ws.on('message', (raw: Buffer | string) => {\n      let msg: ClientMessage;\n      try {\n        msg = JSON.parse(raw.toString()) as ClientMessage;\n      } catch {\n        send(client, { type: 'error', message: 'Invalid JSON' });\n        return;\n      }\n\n      if (msg.type !== 'op') {\n        send(client, { type: 'error', message: `Unknown message type: ${msg.type}` });\n        return;\n      }\n\n      const op = msg.op;\n      if (!op || !op.type) {\n        send(client, { type: 'error', message: 'Missing or invalid operation' });\n        return;\n      }\n      if (op.type !== 'insert' && op.type !== 'delete') {\n        send(client, { type: 'error', message: `Unknown op type: ${op.type}` });\n        return;\n      }\n      if (op.type === 'insert' && (typeof op.pos !== 'number' || typeof op.text !== 'string')) {\n        send(client, { type: 'error', message: 'Insert op requires pos (number) and text (string)' });\n        return;\n      }\n      if (op.type === 'delete' && (typeof op.pos !== 'number' || typeof op.length !== 'number')) {\n        send(client, { type: 'error', message: 'Delete op requires pos (number) and length (number)' });\n        return;\n      }\n\n      // Transform client's op against any ops that happened since the client's version\n      // Since we're server-authoritative, the room's currentVersion is the server version.\n      // Client sends the version it was at when it generated this op.\n      // We need to find ops applied since that version and transform against them.\n      // For simplicity (and correctness), we track only current state; the client\n      // should be up to date via broadcasts. If versions differ, we apply directly\n      // since we don't buffer history of ops (only DB versions). The key invariant:\n      // the server applies ops in order and broadcasts the result.\n      let transformedOp: TextOp = op;\n\n      // If the client's version is behind, we need historical ops to transform.\n      // We use DB version history as a fallback approximation: re-derive content diff.\n      // For a simpler server-authoritative model: just apply to current server state.\n      // Clients must accept the server's authoritative content via broadcasts.\n      if (msg.version !== room.currentVersion) {\n        // Transform against the gap. We don't store individual ops in memory beyond\n        // the current state, so we use DB history to get content at client's version.\n        const history = db.getVersionHistory(docId);\n        const clientVersionEntry = history.find(h => h.version === msg.version);\n        if (!clientVersionEntry) {\n          // Client version too old or invalid, reject\n          send(client, { type: 'error', message: `Unknown client version: ${msg.version}` });\n          return;\n        }\n        // We need to transform the op against all ops from msg.version+1 to currentVersion.\n        // Since we store content snapshots but not individual ops between REST updates,\n        // we store op JSON in version records when applied via WS.\n        // Look up operations from history after client's version:\n        const opsToTransformAgainst = history\n          .filter(h => h.version > msg.version && h.operation)\n          .map(h => JSON.parse(h.operation!) as TextOp);\n\n        for (const prevOp of opsToTransformAgainst) {\n          transformedOp = transformOp(transformedOp, prevOp);\n        }\n      }\n\n      // Apply the (possibly transformed) op\n      const newContent = applyOp(room.currentContent, transformedOp);\n      const newVersion = room.currentVersion + 1;\n\n      // Persist to DB\n      db.updateDocument(docId, newContent, JSON.stringify(transformedOp));\n\n      // Update room\n      room.currentContent = newContent;\n      room.currentVersion = newVersion;\n\n      // Broadcast to all OTHER clients\n      broadcast(room, { type: 'op', op: transformedOp, version: newVersion }, client);\n\n      // Acknowledge to the sender with the new version\n      send(client, { type: 'op', op: transformedOp, version: newVersion });\n    });\n\n    ws.on('close', () => {\n      room.clients.delete(client);\n      if (room.clients.size === 0) {\n        rooms.delete(docId);\n      }\n    });\n\n    ws.on('error', () => {\n      room.clients.delete(client);\n      if (room.clients.size === 0) {\n        rooms.delete(docId);\n      }\n    });\n  });\n\n  // ─── REST API ───────────────────────────────────────────────────────────────\n\n  // List documents\n  expressApp.get('/documents', (_req: Request, res: Response) => {\n    const docs = db.listDocuments();\n    res.json(docs);\n  });\n\n  // Create document\n  expressApp.post('/documents', (req: Request, res: Response) => {\n    const { title, content = '' } = req.body as { title?: string; content?: string };\n    if (!title || typeof title !== 'string' || !title.trim()) {\n      res.status(400).json({ error: 'title is required' });\n      return;\n    }\n    const doc = db.createDocument(title.trim(), content);\n    res.status(201).json(doc);\n  });\n\n  // Get document\n  expressApp.get('/documents/:id', (req: Request, res: Response) => {\n    const doc = db.getDocument(req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    res.json(doc);\n  });\n\n  // Update document\n  expressApp.put('/documents/:id', (req: Request, res: Response) => {\n    const existing = db.getDocument(req.params.id);\n    if (!existing) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    const { title, content } = req.body as { title?: string; content?: string };\n    const newContent = content !== undefined ? content : existing.content;\n    const newTitle = title !== undefined ? title : existing.title;\n\n    // Update title separately if needed (just update DB directly for title)\n    if (title !== undefined && title !== existing.title) {\n      // Update title in documents table\n      const updated = db.updateDocumentTitle(req.params.id, newTitle);\n      if (!updated) {\n        res.status(500).json({ error: 'Failed to update' });\n        return;\n      }\n    }\n\n    const updated = db.updateDocument(req.params.id, newContent, 'rest-update');\n    if (!updated) {\n      res.status(500).json({ error: 'Failed to update document' });\n      return;\n    }\n\n    // Sync room if active\n    const room = rooms.get(req.params.id);\n    if (room) {\n      room.currentContent = newContent;\n      room.currentVersion = updated.version;\n      broadcast(room, { type: 'sync', docId: req.params.id, content: newContent, version: updated.version });\n    }\n\n    res.json(updated);\n  });\n\n  // Delete document\n  expressApp.delete('/documents/:id', (req: Request, res: Response) => {\n    const existing = db.getDocument(req.params.id);\n    if (!existing) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    db.deleteDocument(req.params.id);\n\n    // Close all WS clients for this document\n    const room = rooms.get(req.params.id);\n    if (room) {\n      for (const client of room.clients) {\n        client.ws.close();\n      }\n      rooms.delete(req.params.id);\n    }\n\n    res.status(204).send();\n  });\n\n  // Get version history\n  expressApp.get('/documents/:id/history', (req: Request, res: Response) => {\n    const doc = db.getDocument(req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    const history = db.getVersionHistory(req.params.id);\n    res.json(history);\n  });\n\n  // ─── Start / Stop ────────────────────────────────────────────────────────────\n\n  let listeningPort: number | null = null;\n\n  function start(port?: number): Promise<number> {\n    return new Promise((resolve, reject) => {\n      httpServer.listen(port ?? 0, () => {\n        const addr = httpServer.address();\n        if (addr && typeof addr === 'object') {\n          listeningPort = addr.port;\n          resolve(listeningPort);\n        } else {\n          reject(new Error('Could not determine port'));\n        }\n      });\n      httpServer.on('error', reject);\n    });\n  }\n\n  function stop(): Promise<void> {\n    return new Promise((resolve) => {\n      // Close all WebSocket connections\n      for (const room of rooms.values()) {\n        for (const client of room.clients) {\n          client.ws.terminate();\n        }\n      }\n      rooms.clear();\n\n      const cleanup = () => {\n        db.close();\n        resolve();\n      };\n\n      wss.close(() => {\n        if (!httpServer.listening) {\n          cleanup();\n          return;\n        }\n        httpServer.close(() => cleanup());\n      });\n    });\n  }\n\n  return {\n    app: expressApp,\n    httpServer,\n    start,\n    stop,\n  };\n}\n","structuredPatch":[{"oldStart":156,"oldLines":7,"newStart":156,"newLines":7,"lines":["       // should be up to date via broadcasts. If versions differ, we apply directly","       // since we don't buffer history of ops (only DB versions). The key invariant:","       // the server applies ops in order and broadcasts the result.","-      let transformedOp: TextOp = op;","+      let transformedOp: TextOp = op as TextOp;"," ","       // If the client's version is behind, we need historical ops to transform.","       // We use DB version history as a fallback approximation: re-derive content diff."]}],"userModified":false,"replaceAll":false}}
