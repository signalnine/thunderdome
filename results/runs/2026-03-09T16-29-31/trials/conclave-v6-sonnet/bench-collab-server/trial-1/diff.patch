on starts before insert\n    const deleteEnd = opB.pos + opB.length;\n    if (deleteEnd <= opA.pos) {\n      // Delete is entirely before the insert: unchanged\n      return opB;\n    }\n    // Delete spans across the insert point: extend length to include the inserted text\n    return { type: 'delete', pos: opB.pos, length: opB.length + opA.text.length };\n  }\n\n  if (opA.type === 'delete' && opB.type === 'insert') {\n    // opA deleted text starting at opA.pos with opA.length chars.\n    const deleteEnd = opA.pos + opA.length;\n    if (opB.pos <= opA.pos) {\n      // Insert is before the deleted region: unchanged\n      return opB;\n    }\n    if (opB.pos >= deleteEnd) {\n      // Insert is after the deleted region: shift left\n      return { type: 'insert', pos: opB.pos - opA.length, text: opB.text };\n    }\n    // Insert is within the deleted region: place it at the start of the deletion\n    return { type: 'insert', pos: opA.pos, text: opB.text };\n  }\n\n  if (opA.type === 'delete' && opB.type === 'delete') {\n    const aEnd = opA.pos + opA.length;\n    const bEnd = opB.pos + opB.length;\n\n    if (opB.pos >= aEnd) {\n      // B is entirely after A: shift left\n      return { type: 'delete', pos: opB.pos - opA.length, length: opB.length };\n    }\n    if (bEnd <= opA.pos) {\n      // B is entirely before A: unchanged\n      return opB;\n    }\n    // Overlapping deletes: only delete the part that wasn't already deleted by A\n    const newPos = Math.min(opB.pos, opA.pos);\n    // How many chars in B's range were NOT already deleted by A\n    const overlapStart = Math.max(opB.pos, opA.pos);\n    const overlapEnd = Math.min(bEnd, aEnd);\n    const overlap = Math.max(0, overlapEnd - overlapStart);\n    const newLength = opB.length - overlap;\n    return { type: 'delete', pos: newPos, length: Math.max(0, newLength) };\n  }\n\n  return opB;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_t