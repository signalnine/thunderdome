diff --git a/src/database.ts b/src/database.ts
new file mode 100644
index 0000000..70dffb7
--- /dev/null
+++ b/src/database.ts
@@ -0,0 +1,130 @@
+import BetterSqlite3 from 'better-sqlite3';
+import { randomUUID } from 'crypto';
+
+export interface DocumentRecord {
+  id: string;
+  title: string;
+  content: string;
+  version: number;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface VersionRecord {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operation: string | null;
+  created_at: string;
+}
+
+export class Database {
+  private db: BetterSqlite3.Database;
+
+  constructor(filePath = ':memory:') {
+    this.db = new BetterSqlite3(filePath);
+    this.db.pragma('journal_mode = WAL');
+    this.db.pragma('foreign_keys = ON');
+    this.initialize();
+  }
+
+  private initialize(): void {
+    this.db.exec(`
+      CREATE TABLE IF NOT EXISTS documents (
+        id TEXT PRIMARY KEY,
+        title TEXT NOT NULL,
+        content TEXT NOT NULL DEFAULT '',
+        version INTEGER NOT NULL DEFAULT 1,
+        created_at TEXT NOT NULL DEFAULT (datetime('now')),
+        updated_at TEXT NOT NULL DEFAULT (datetime('now'))
+      );
+
+      CREATE TABLE IF NOT EXISTS versions (
+        id INTEGER PRIMARY KEY AUTOINCREMENT,
+        document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
+        version INTEGER NOT NULL,
+        content TEXT NOT NULL,
+        operation TEXT,
+        created_at TEXT NOT NULL DEFAULT (datetime('now')),
+        UNIQUE(document_id, version)
+      );
+    `);
+  }
+
+  createDocument(title: string, content: string): DocumentRecord {
+    const id = randomUUID();
+    const now = new Date().toISOString();
+
+    this.db.transaction(() => {
+      this.db.prepare(
+        `INSERT INTO documents (id, title, content, version, created_at, updated_at)
+         VALUES (?, ?, ?, 1, ?, ?)`
+      ).run(id, title, content, now, now);
+
+      this.db.prepare(
+        `INSERT INTO versions (document_id, version, content, operation, created_at)
+         VALUES (?, 1, ?, NULL, ?)`
+      ).run(id, content, now);
+    })();
+
+    return this.getDocument(id)!;
+  }
+
+  getDocument(id: string): DocumentRecord | null {
+    const row = this.db.prepare(
+      `SELECT id, title, content, version, created_at, updated_at FROM documents WHERE id = ?`
+    ).get(id) as DocumentRecord | undefined;
+    return row ?? null;
+  }
+
+  listDocuments(): DocumentRecord[] {
+    return this.db.prepare(
+      `SELECT id, title, content, version, created_at, updated_at FROM documents ORDER BY created_at DESC`
+    ).all() as DocumentRecord[];
+  }
+
+  updateDocument(id: string, content: string, operation: string): DocumentRecord | null {
+    const doc = this.getDocument(id);
+    if (!doc) return null;
+
+    const newVersion = doc.version + 1;
+    const now = new Date().toISOString();
+
+    this.db.transaction(() => {
+      this.db.prepare(
+        `UPDATE documents SET content = ?, version = ?, updated_at = ? WHERE id = ?`
+      ).run(content, newVersion, now, id);
+
+      this.db.prepare(
+        `INSERT INTO versions (document_id, version, content, operation, created_at)
+         VALUES (?, ?, ?, ?, ?)`
+      ).run(id, newVersion, content, operation, now);
+    })();
+
+    return this.getDocument(id);
+  }
+
+  updateDocumentTitle(id: string, title: string): DocumentRecord | null {
+    const doc = this.getDocument(id);
+    if (!doc) return null;
+    const now = new Date().toISOString();
+    this.db.prepare(`UPDATE documents SET title = ?, updated_at = ? WHERE id = ?`).run(title, now, id);
+    return this.getDocument(id);
+  }
+
+  deleteDocument(id: string): void {
+    this.db.prepare(`DELETE FROM documents WHERE id = ?`).run(id);
+  }
+
+  getVersionHistory(documentId: string): VersionRecord[] {
+    return this.db.prepare(
+      `SELECT id, document_id, version, content, operation, created_at
+       FROM versions WHERE document_id = ? ORDER BY version ASC`
+    ).all(documentId) as VersionRecord[];
+  }
+
+  close(): void {
+    this.db.close();
+  }
+}
