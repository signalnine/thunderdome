+import { describe, it, expect } from 'vitest';
+import { applyOp, transformOp, type TextOp } from '../ot.js';
+
+describe('applyOp - insert', () => {
+  it('inserts text at position 0', () => {
+    const result = applyOp('world', { type: 'insert', pos: 0, text: 'hello ' });
+    expect(result).toBe('hello world');
+  });
+
+  it('inserts text in the middle', () => {
+    const result = applyOp('helo', { type: 'insert', pos: 3, text: 'l' });
+    expect(result).toBe('hello');
+  });
+
+  it('inserts text at end', () => {
+    const result = applyOp('hello', { type: 'insert', pos: 5, text: ' world' });
+    expect(result).toBe('hello world');
+  });
+
+  it('inserts into empty string', () => {
+    const result = applyOp('', { type: 'insert', pos: 0, text: 'abc' });
+    expect(result).toBe('abc');
+  });
+
+  it('clamps insert position to document length', () => {
+    const result = applyOp('hello', { type: 'insert', pos: 100, text: '!' });
+    expect(result).toBe('hello!');
+  });
+});
+
+describe('applyOp - delete', () => {
+  it('deletes characters at position', () => {
+    const result = applyOp('hello world', { type: 'delete', pos: 5, length: 6 });
+    expect(result).toBe('hello');
+  });
+
+  it('deletes from the start', () => {
+    const result = applyOp('hello world', { type: 'delete', pos: 0, length: 6 });
+    expect(result).toBe('world');
+  });
+
+  it('deletes partial text', () => {
+    const result = applyOp('hello', { type: 'delete', pos: 1, length: 3 });
+    expect(result).toBe('ho');
+  });
+
+  it('clamps delete length to document end', () => {
+    const result = applyOp('hello', { type: 'delete', pos: 3, length: 100 });
+    expect(result).toBe('hel');
+  });
+
+  it('no-op delete with length 0', () => {
+    const result = applyOp('hello', { type: 'delete', pos: 2, length: 0 });
+    expect(result).toBe('hello');
+  });
+});
+
+describe('transformOp - two concurrent inserts', () => {
+  it('transforms insert after another insert at earlier position', () => {
+    // Client A inserts 'X' at pos 0: "Xhello"
+    // Client B inserts 'Y' at pos 2: needs to become pos 3 because A shifted content
+    const opA: TextOp = { type: 'insert', pos: 0, text: 'X' };
+    const opB: TextOp = { type: 'insert', pos: 2, text: 'Y' };
+
+    // Transform opB against opA (opA was applied first)
+    const transformed = transformOp(opB, opA);
+    expect(transformed.type).toBe('insert');
+    expect((transformed as Extract<TextOp, { type: 'insert' }>).pos).toBe(3);
+  });
+
+  it('transforms insert before another insert (position unchanged)', () => {
+    // Client A inserts at pos 5, Client B inserts at pos 2
+    // B's position is before A's, so B doesn't move when A is applied first
+    const opA: TextOp = { type: 'insert', pos: 5, text: 'XX' };
+    const opB: TextOp = { type: 'insert', pos: 2, text: 'Y' };
+
+    const transformed = transformOp(opB, opA);
+    expect(transformed.type).toBe('insert');
+    expect((transformed as Extract<TextOp, { type: 'insert' }>).pos).toBe(2);
+  });
+
+  it('two inserts at same position - both preserved, second deferred', () => {
+    const opA: TextOp = { type: 'insert', pos: 3, text: 'A' };
+    const opB: TextOp = { type: 'insert', pos: 3, text: 'B' };
+
+    // After A applied, B should insert after A's text
+    const transformed = transformOp(opB, opA);
+    expect(transformed.type).toBe('insert');
+    expect((transformed as Extract<TextOp, { type: 'insert' }>).pos).toBe(4);
+  });
+});
+
+describe('transformOp - insert vs delete', () => {
+  it('insert after deleted region shifts left', () => {
+    // Delete 3 chars at pos 0, then insert at pos 5 -> becomes pos 2
+    const opA: TextOp = { type: 'delete', pos: 0, length: 3 };
+    const opB: TextOp = { type: 'insert', pos: 5, text: 'X' };
+
+    const transformed = transformOp(opB, opA);
+    expect(transformed.type).toBe('insert');
+    expect((transformed as Extract<TextOp, { type: 'insert' }>).pos).toBe(2);
+  });
+
+  it('insert before deleted region unchanged', () => {
+    const opA: TextOp = { type: 'delete', pos: 5, length: 3 };
+    const opB: TextOp = { type: 'insert', pos: 2, text: 'X' };
+
+    const transformed = transformOp(opB, opA);
+    expect(transformed.type).toBe('insert');
+    expect((transformed as Extract<TextOp, { type: 'insert' }>).pos).toBe(2);
+  });
+});
+
+describe('transformOp - delete vs insert', () => {
+  it('delete after an insert shifts right', () => {
+    const opA: TextOp = { type: 'insert', pos: 0, text: 'XX' };
+    const opB: TextOp = { type: 'delete', pos: 3, length: 2 };
+
+    const transformed = transformOp(opB, opA);
+    expect(transformed.type).toBe('delete');
+    expect((transformed as Extract<TextOp, { type: 'delete' }>).pos).toBe(5);
+  });
+});
+
+describe('OT convergence - apply in different orders', () => {
+  it('two concurrent inserts converge', () => {
+    const doc = 'hello';
+    const opA: TextOp = { type: 'insert', pos: 0, text: 'A' };
+    const opB: TextOp = { type: 'insert', pos: 5, text: 'B' };
+
+    // Path 1: apply A first, then transform B and apply
+    const doc_A = applyOp(doc, opA);
+    const opB_transformed = transformOp(opB, opA);
+    const result1 = applyOp(doc_A, opB_transformed);
+
+    // Path 2: apply B first, then transform A and apply
+    const doc_B = applyOp(doc, opB);
+    const opA_transformed = transformOp(opA, opB);
+    const result2 = applyOp(doc_B, opA_transformed);
+
+    expect(result1).toBe(result2);
+    // Both A and B text should be in the result
+    expect(result1).toContain('A');
+    expect(result1).toContain('B');
+    expect(result1).toContain('hello');
+  });
+});
diff --git a/src/tests/websocket.test.ts b/src/tests/websocket.test.ts
new file mode 100644
index 0000000..8fa2cfc
--- /dev/null
+++ b/src/tests/websocket.test.ts
@@ -0,0 +1,241 @@
+import { describe, it, expect, beforeEach, afterEach } from 'vitest';
+import { WebSocket } from 'ws';
+import { createApp } from '../server.js';
+import os from 'os';
+import path from 'path';
+import fs from 'fs';
+
+let appInstance: ReturnType<typeof createApp>;
+let port: number;
+let dbPath: string;
+
+function wsUrl(docId: string) {
+  return `ws://localhost:${port}/documents/${docId}/ws`;
+}
+
+interface WsClient {
+  ws: WebSocket;
+  nextMessage: () => Promise<unknown>;
+  close: () => Promise<void>;
+}
+
+function connectWs(docId: string): Promise<WsClient> {
+  return new Promise((resolve, reject) => {
+    const ws = new WebSocket(wsUrl(docId));
+    const queue: unknown[] = [];
+    const waiters: Array<(msg: unknown) => void> = [];
+
+    ws.on('message', (data: Buffer) => {
+      let parsed: unknown;
+      try {
+        parsed = JSON.parse(data.toString());
+      } catch {
+        parsed = data.toString();
+      }
+      if (waiters.length > 0) {
+        waiters.shift()!(parsed);
+      } else {
+        queue.push(parsed);
+      }
+    });
+
+    function nextMessage(): Promise<unknown> {
+      return new Promise((res) => {
+        if (queue.length > 0) {
+          res(queue.shift()!);
+        } else {
+          waiters.push(res);
+        }
+      });
+    }
+
+    function close(): Promise<void> {
+      return new Promise((res) => {
+        if (ws.readyState === WebSocket.CLOSED) { res(); return; }
+        ws.once('close', () => res());
+        ws.close();
+      });
+    }
+
+    ws.on('open', () => resolve({ ws, nextMessage, close }));
+    ws.on('error', reject);
+  });
+}
+
+beforeEach(async () => {
+  dbPath = path.join(os.tmpdir(), `ws-test-${Date.now()}.db`);
+  appInstance = createApp(dbPath);
+  port = await appInstance.start(0);
+});
+
+afterEach(async () => {
+  await appInstance.stop();
+  if (fs.existsSync(dbPath)) fs.unlinkSync(dbPath);
+});
+
+async function createDocViaApi(title: string, content: string): Promise<string> {
+  const res = await fetch(`http://localhost:${port}/documents`, {
+    method: 'POST',
+    headers: { 'Content-Type': 'application/json' },
+    body: JSON.stringify({ title, content }),
+  });
+  const body = await res.json() as { id: string };
+  return body.id;
+}
+
+describe('WebSocket - connection and sync', () => {
+  it('sends sync message with current document state on connect', async () => {
+    const docId = await createDocViaApi('Test', 'hello world');
+    const client = await connectWs(docId);
+    const msg = await client.nextMessage() as { type: string; content: string; version: number };
+
+    expect(msg.type).toBe('sync');
+    expect(msg.content).toBe('hello world');
+    expect(msg.version).toBe(1);
+
+    await client.close();
+  });
+
+  it('closes with error message for non-existent document', async () => {
+    return new Promise<void>((resolve) => {
+      const ws = new WebSocket(`ws://localhost:${port}/documents/nonexistent/ws`);
+      ws.on('message', (data: Buffer) => {
+        const msg = JSON.parse(data.toString()) as { type: string };
+        expect(msg.type).toBe('error');
+        ws.close();
+        resolve();
+      });
+    });
+  });
+});
+
+describe('WebSocket - sending operations', () => {
+  it('applies insert operation and broadcasts to other clients', async () => {
+    const docId = await createDocViaApi('Test', 'hello');
+
+    const c1 = await connectWs(docId);
+    await c1.nextMessage(); // sync
+
+    const c2 = await connectWs(docId);
+    await c2.nextMessage(); // sync
+
+    // c1 sends insert at pos 5
+    const op = { type: 'insert', pos: 5, text: ' world' };
+    c1.ws.send(JSON.stringify({ type: 'op', op, version: 1 }));
+
+    // c2 should receive the op broadcast
+    const broadcast = await c2.nextMessage() as { type: string; op: { type: string; text: string }; version: number };
+    expect(broadcast.type).toBe('op');
+    expect(broadcast.op.type).toBe('insert');
+    expect(broadcast.op.text).toBe(' world');
+    expect(broadcast.version).toBe(2);
+
+    await c1.close();
+    await c2.close();
+  });
+
+  it('applies delete operation and broadcasts to other clients', async () => {
+    const docId = await createDocViaApi('Test', 'hello world');
+
+    const c1 = await connectWs(docId);
+    await c1.nextMessage(); // sync
+
+    const c2 = await connectWs(docId);
+    await c2.nextMessage(); // sync
+
+    const op = { type: 'delete', pos: 5, length: 6 };
+    c1.ws.send(JSON.stringify({ type: 'op', op, version: 1 }));
+
+    const broadcast = await c2.nextMessage() as { type: string; op: { type: string; length: number } };
+    expect(broadcast.type).toBe('op');
+    expect(broadcast.op.type).toBe('delete');
+    expect(broadcast.op.length).toBe(6);
+
+    await c1.close();
+    await c2.close();
+  });
+
+  it('persists changes to database after operation', async () => {
+    const docId = await createDocViaApi('Test', 'hello');
+
+    const client = await connectWs(docId);
+    await client.nextMessage(); // sync
+
+    const op = { type: 'insert', pos: 5, text: '!' };
+    client.ws.send(JSON.stringify({ type: 'op', op, version: 1 }));
+    await client.nextMessage(); // ack
+
+    await client.close();
+
+    // Check DB via REST
+    const res = await fetch(`http://localhost:${port}/documents/${docId}`);
+    const doc = await res.json() as { content: string; version: number };
+    expect(doc.content).toBe('hello!');
+    expect(doc.version).toBe(2);
+  });
+
+  it('rejects malformed messages with error', async () => {
+    const docId = await createDocViaApi('Test', 'hello');
+    const client = await connectWs(docId);
+    await client.nextMessage(); // sync
+
+    client.ws.send('not valid json');
+    const err = await client.nextMessage() as { type: string; message: string };
+    expect(err.type).toBe('error');
+    expect(err.message).toContain('Invalid JSON');
+
+    await client.close();
+  });
+
+  it('rejects operations with missing fields', async () => {
+    const docId = await createDocViaApi('Test', 'hello');
+    const client = await connectWs(docId);
+    await client.nextMessage(); // sync
+
+    client.ws.send(JSON.stringify({ type: 'op', op: { type: 'insert', pos: 0 }, version: 1 }));
+    const err = await client.nextMessage() as { type: string };
+    expect(err.type).toBe('error');
+
+    await client.close();
+  });
+});
+
+describe('WebSocket - 10 concurrent clients', () => {
+  it('handles 10 concurrent clients without corruption', async () => {
+    const docId = await createDocViaApi('Concurrent', '');
+
+    // Connect 10 clients and drain their sync messages
+    const clients: WsClient[] = [];
+    for (let i = 0; i < 10; i++) {
+      const c = await connectWs(docId);
+      await c.nextMessage(); // sync
+      clients.push(c);
+    }
+
+    // Each client sends one insert sequentially and awaits ack
+    for (let i = 0; i < 10; i++) {
+      const c = clients[i];
+      c.ws.send(JSON.stringify({
+        type: 'op',
+        op: { type: 'insert', pos: 0, text: String(i) },
+        version: 1,
+      }));
+      await c.nextMessage(); // ack (may also be broadcasts from others, but we just need one)
+    }
+
+    // Give a moment for all broadcasts to settle
+    await new Promise(r => setTimeout(r, 100));
+
+    // Fetch final document state
+    const res = await fetch(`http://localhost:${port}/documents/${docId}`);
+    const doc = await res.json() as { content: string; version: number };
+
+    // All 10 digits should be in the content
+    for (let i = 0; i < 10; i++) {
+      expect(doc.content).toContain(String(i));
+    }
+    expect(doc.content.length).toBe(10);
+
+    for (const c of clients) await c.close();
+  });
+});
