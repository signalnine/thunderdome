.db`);\n  appInstance = createApp(dbPath);\n  port = await appInstance.start(0);\n});\n\nafterEach(async () => {\n  await appInstance.stop();\n  if (fs.existsSync(dbPath)) fs.unlinkSync(dbPath);\n});\n\nasync function createDoc(content: string): Promise<string> {\n  const res = await fetch(`http://localhost:${port}/documents`, {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify({ title: 'Test', content }),\n  });\n  return ((await res.json()) as { id: string }).id;\n}\n\nasync function getDocContent(docId: string): Promise<string> {\n  const res = await fetch(`http://localhost:${port}/documents/${docId}`);\n  return ((await res.json()) as { content: string }).content;\n}\n\ndescribe('Conflict resolution - OT convergence', () => {\n  it('two concurrent inserts at different positions both preserved', async () => {\n    // Doc: \"hello\"\n    // Client A inserts 'A' at pos 0 -> \"Ahello\"\n    // Client B inserts 'B' at pos 5 -> \"helloBo\" after transformation\n    // Server applies A first, transforms B -> pos 6 -> \"AhelloB\"\n    const docId = await createDoc('hello');\n\n    const cA = await connectWs(docId);\n    const syncA = await cA.nextMessage() as { version: number };\n\n    const cB = await connectWs(docId);\n    const syncB = await cB.nextMessage() as { version: number };\n\n    // Both clients are at version 1\n    expect(syncA.version).toBe(1);\n    expect(syncB.version).toBe(1);\n\n    // Send ops concurrently (both at version 1)\n    cA.ws.send(JSON.stringify({ type: 'op', op: { type: 'insert', pos: 0, text: 'A' }, version: 1 }));\n    cB.ws.send(JSON.stringify({ type: 'op', op: { type: 'insert', pos: 5, text: 'B' }, version: 1 }));\n\n    // Wait for both acks\n    await cA.nextMessage();\n    await cB.nextMessage();\n\n    // Allow time for both to process\n    await new Promise(r => setTimeout(r, 50));\n\n    const content = await getDocContent(docId);\n    expect(content).toContain('A');\n    expect(content).toContain('B');\n    expect(content).toContain('hello');\n    // All characters preserved\n    expect(content.length).toBe(7); // 'hello' (5) + 'A' (1) + 'B' (1)\n\n    await cA.close();\n    await cB.close();\n  });\n\n  it('two concurrent inserts at same position - both chars preserved', async () => {\n    const docId = await createDoc('hello');\n\n    const cA = await connectWs(docId);\n    await cA.nextMessage(); // sync\n\n    const cB = await connectWs(docId);\n    await cB.nextMessage(); // sync\n\n    // Both insert at position 0, version 1\n    cA.ws.send(JSON.stringify({ type: 'op', op: { type: 'insert', pos: 0, text: 'X' }, version: 1 }));\n    cB.ws.send(JSON.stringify({ type: 'op', op: { type: 'insert', pos: 0, text: 'Y' }, version: 1 }));\n\n    await cA.nextMessage();\n    await cB.nextMessage();\n\n    await new Promise(r => setTimeout(r, 50));\n\n    const content = await getDocContent(docId);\n    expect(content).toContain('X');\n    expect(content).toContain('Y');\n    expect(content).toContain('hello');\n    expect(content.length).toBe(7);\n\n    await cA.close();\n    await cB.close();\n  });\n\n  it('insert and concurrent delete - both operations applied', async () => {\n    // Doc: \"hello world\"\n    // Client A deletes \" world\" (pos 5, len 6)\n    // Client B inserts \"!\" at pos 5 (concurrent, same version)\n    // Result should preserve both: \"!\" either moved or in place, \" world\" deleted\n    const docId = await createDoc('hello world');\n\n    const cA = await connectWs(docId);\n    await cA.nextMessage(); // sync\n\n    const cB = await connectWs(docId);\n    await cB.nextMessage(); // sync\n\n    cA.ws.send(JSON.stringify({ type: 'op', op: { type: 'delete', pos: 5, length: 6 }, version: 1 }));\n    cB.ws.send(JSON.stringify({ type: 'op', op: { type: 'insert', pos: 5, text: '!' }, version: 1 }));\n\n    await cA.nextMessage();\n    await cB.nextMessage();\n\n    await new Promise(r => setTimeout(r, 50));\n\n    const content = await getDocContent(docId);\n    // \"hello\" must be preserved, \"!\" must be preserved, \" world\" deleted\n    expect(content).toContain('hello');\n    expect(content).toContain('!');\n    expect(content).not.toContain('world');\n\n    await cA.close();\n    await cB.close();\n  });\n\n  it('sequential operations from multiple clients produce correct result', async () => {\n    const docId = await createDoc('');\n\n    const cA = await connectWs(docId);\n    await cA.nextMessage(); // sync\n\n    // A inserts \"Hello\"\n    cA.ws.send(JSON.stringify({ type: 'op', op: { type: 'insert', pos: 0, text: 'Hello' }, version: 1 }));\n    const ack1 = await cA.nextMessage() as { version: number };\n\n    const cB = await connectWs(docId);\n    const syncB = await cB.nextMessage() as { content: string; version: number };\n    expect(syncB.content).toBe('Hello');\n\n    // B inserts \" World\" at pos 5\n    cB.ws.send(JSON.stringify({ type: 'op', op: { type: 'insert', pos: 5, text: ' World' }, version: ack1.version }));\n    await cB.nextMessage();\n\n    const content = await getDocContent(docId);\n    expect(content).toBe('Hello World');\n\n    await cA.close();\n    await cB.close();\n  });\n\n  it('no data corruption with 10 concurrent inserts at position 0', async () => {\n    const docId = await createDoc('');\n\n    const clients: WsClient[] = [];\n    for (let i = 0; i < 10; i++) {\n      const c = await connectWs(docId);\n      await c.nextMessage(); // sync\n      clients.push(c);\n    }\n\n    // All 10 clients simultaneously insert a single character at pos 0\n    const chars = 'abcdefghij';\n    const ackPromises = clients.map((c, i) => {\n      const ackP = c.nextMessage();\n      c.ws.send(JSON.stringify({\n        type: 'op',\n        op: { type: 'insert', pos: 0, text: chars[i] },\n        version: 1,\n      }));\n      return ackP;\n    });\n\n    await Promise.all(ackPromises);\n    await new Promise(r => setTimeout(r, 100));\n\n    const content = await getDocContent(docId);\n    // All 10 characters must appear exactly once\n    for (const ch of chars) {\n      expect(content.split(ch).length - 1).toBe(1); // exactly one occurrence\n    }\n    expect(content.length).toBe(10);\n\n    for (const c of clients) await c.close();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":380,"cache_read_input_tokens":66928,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":380},"output_tokens":18,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"e4228706-d4c1-40ce-b921-56d892cabeec","uuid":"955d5bb1-1636-44a6-b233-7b74972c176e"}
