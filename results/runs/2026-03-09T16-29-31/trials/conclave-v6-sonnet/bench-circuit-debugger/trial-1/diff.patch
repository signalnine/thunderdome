+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+
+  while (remaining.length > 0) {
+    const prevLen = remaining.length;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        if (gate.op === 'AND') wires[gate.out] = a & b;
+        else if (gate.op === 'OR') wires[gate.out] = a | b;
+        else wires[gate.out] = a ^ b;
+        remaining.splice(i, 1);
+      }
+    }
+    if (remaining.length === prevLen) break; // no progress, circuit stuck
+  }
+
+  return wires;
+}
+
+// ── findSwappedWires ──────────────────────────────────────────────────────────
+//
+// Strategy: structural analysis of the ripple-carry adder.
+//
+// In a correct N-bit ripple-carry adder each bit position i (i > 0) uses:
+//   - XOR(xi, yi)       → partial sum wire (call it Pi)
+//   - XOR(Pi, carry_in) → Zi  (output bit)
+//   - AND(xi, yi)       → generate wire (Gi)
+//   - AND(Pi, carry_in) → propagate wire (Ti)
+//   - OR(Gi, Ti)        → carry out (Ci)
+//
+// Bit 0 (half adder):
+//   - XOR(x00, y00) → z00
+//   - AND(x00, y00) → c00
+//
+// Rules that must hold for a correct gate:
+//   R1. A gate XOR(xi, yi) must output a non-z wire (partial sum Pi) UNLESS i==0.
+//   R2. A gate XOR(Pi, carry_in) must output zi.
+//   R3. A gate AND(xi, yi) must output a non-z wire (generate Gi).
+//   R4. A gate OR(Gi, Ti) must output a non-z wire unless it is the final carry
+//       (which becomes the MSB output bit).
+//   R5. A gate AND(Pi, carry_in) must output a non-z wire.
+//   R6. A z-wire (other than the final carry z(N+1)) must come from a XOR gate.
+//
+// We check these rules and collect wires that violate them. This gives us the 8
+// swapped wires without brute force enumeration.
+
+export function findSwappedWires(gates: Gate[]): string[] {
+  // Determine number of input bits
+  let maxBit = -1;
+  for (const gate of gates) {
+    for (const wire of [gate.in1, gate.in2, gate.out]) {
+      const m = wire.match(/^[xy](\d+)$/);
+      if (m) maxBit = Math.max(maxBit, parseInt(m[1], 10));
+    }
+  }
+  if (maxBit < 0) return [];
+
+  const N = maxBit + 1; // number of input bits
+  const finalCarryWire = `z${String(N).padStart(2, '0')}`;
+
+  // Index gates by their inputs (unordered pair) for quick lookup
+  const byInputs = new Map<string, Gate[]>();
+  for (const g of gates) {
+    for (const key of [`${g.in1}|${g.in2}`, `${g.in2}|${g.in1}`]) {
+      if (!byInputs.has(key)) byInputs.set(key, []);
+      byInputs.get(key)!.push(g);
+    }
+  }
+
+  const suspicious = new Set<string>();
+
+  // Rule R6: every z-wire (except the final carry) must come from XOR
+  for (const g of gates) {
+    if (g.out.startsWith('z') && g.out !== finalCarryWire) {
+      if (g.op !== 'XOR') suspicious.add(g.out);
+    }
+  }
+
+  // Check structural rules per bit
+  for (let i = 0; i < N; i++) {
+    const xi = `x${String(i).padStart(2, '0')}`;
+    const yi = `y${String(i).padStart(2, '0')}`;
+    const zi = `z${String(i).padStart(2, '0')}`;
+
+    // Find XOR(xi, yi) and AND(xi, yi)
+    const key = `${xi}|${yi}`;
+    const xyGates = byInputs.get(key) ?? [];
+    const xyXor = xyGates.find(g => g.op === 'XOR');
+    const xyAnd = xyGates.find(g => g.op === 'AND');
+
+    if (i === 0) {
+      // Half adder: XOR(x00,y00)->z00, AND(x00,y00)->carry
+      if (xyXor && xyXor.out !== zi) {
+        suspicious.add(xyXor.out);
+        suspicious.add(zi);
+      }
+      if (xyAnd && xyAnd.out.startsWith('z') && xyAnd.out !== finalCarryWire) {
+        suspicious.add(xyAnd.out);
+      }
+      continue;
+    }
+
+    // Rule R1: XOR(xi,yi) must not output a z-wire (for i > 0)
+    if (xyXor && xyXor.out.startsWith('z')) {
+      suspicious.add(xyXor.out);
+    }
+
+    // Rule R3: AND(xi,yi) must not output a z-wire
+    if (xyAnd && xyAnd.out.startsWith('z') && xyAnd.out !== finalCarryWire) {
+      suspicious.add(xyAnd.out);
+    }
+
+    // The partial sum wire Pi = xyXor.out
+    if (xyXor) {
+      const pi = xyXor.out;
+      // search all gates with pi as input
+      const piXors = gates.filter(g => (g.in1 === pi || g.in2 === pi) && g.op === 'XOR');
+      const piAnds = gates.filter(g => (g.in1 === pi || g.in2 === pi) && g.op === 'AND');
+
+      // Rule R2: XOR(Pi, carry_in) → zi
+      for (const g of piXors) {
+        if (g.out !== zi) {
+          suspicious.add(g.out);
+          suspicious.add(zi);
+        }
+      }
+
+      // Rule R5: AND(Pi, carry_in) must not output a z-wire
+      for (const g of piAnds) {
+        if (g.out.startsWith('z') && g.out !== finalCarryWire) {
+          suspicious.add(g.out);
+        }
+      }
+    }
+  }
+
+  // Check OR gates (carry generators): their outputs should not be z-wires
+  // (except the final carry)
+  for (const g of gates) {
+    if (g.op === 'OR' && g.out.startsWith('z') && g.out !== finalCarryWire) {
+      suspicious.add(g.out);
+    }
+  }
+
+  return [...suspicious].sort();
+}
