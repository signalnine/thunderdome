V5sKmDlBKWIYbA3lRb2PTHACE0mgKwA8yQ2xq9vxDTuk4iPrECBAEW2aoFXY0Q==\",\n       \"dev\": true,\n       \"license\": \"MIT\",\n-      \"peer\": true,\n       \"dependencies\": {\n         \"@vitest/expect\": \"2.1.9\",\n         \"@vitest/mocker\": \"2.1.9\",\ndiff --git a/src/index.test.ts b/src/index.test.ts\nnew file mode 100644\nindex 0000000..ab17037\n--- /dev/null\n+++ b/src/index.test.ts\n@@ -0,0 +1,181 @@\n+import { describe, test, expect } from 'vitest';\n+import { simulate, findSwappedWires } from './index.js';\n+import type { Gate } from './index.js';\n+\n+describe('simulate', () => {\n+  test('AND gate: 1 AND 1 = 1', () => {\n+    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n+    const result = simulate(gates, { a: 1, b: 1 });\n+    expect(result['c']).toBe(1);\n+  });\n+\n+  test('AND gate: 1 AND 0 = 0', () => {\n+    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n+    const result = simulate(gates, { a: 1, b: 0 });\n+    expect(result['c']).toBe(0);\n+  });\n+\n+  test('OR gate: 0 OR 1 = 1', () => {\n+    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];\n+    const result = simulate(gates, { a: 0, b: 1 });\n+    expect(result['c']).toBe(1);\n+  });\n+\n+  test('OR gate: 0 OR 0 = 0', () => {\n+    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];\n+    const result = simulate(gates, { a: 0, b: 0 });\n+    expect(result['c']).toBe(0);\n+  });\n+\n+  test('XOR gate: 1 XOR 1 = 0', () => {\n+    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n+    const result = simulate(gates, { a: 1, b: 1 });\n+    expect(result['c']).toBe(0);\n+  });\n+\n+  test('XOR gate: 1 XOR 0 = 1', () => {\n+    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n+    const result = simulate(gates, { a: 1, b: 0 });\n+    expect(result['c']).toBe(1);\n+  });\n+\n+  test('returns all wire values including inputs', () => {\n+    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n+    const result = simulate(gates, { a: 1, b: 0 });\n+    expect(result['a']).toBe(1);\n+    expect(result['b']).toBe(0);\n+    expect(result['c']).toBe(0);\n+  });\n+\n+  test('processes gates in dependency order', () => {\n+    // c = a AND b, d = c OR b\n+    const gates: Gate[] = [\n+      { op: 'OR', in1: 'c', in2: 'b', out: 'd' },   // depends on c\n+      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },   // must fire first\n+    ];\n+    const result = simulate(gates, { a: 1, b: 1 });\n+    expect(result['c']).toBe(1);\n+    expect(result['d']).toBe(1);\n+  });\n+\n+  test('4-bit adder computes 3 + 5 = 8', () => {\n+    // 3 = 0011, 5 = 0101, 8 = 01000\n+    const gates: Gate[] = [\n+      // bit 0 half adder\n+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n+      // bit 1 full adder\n+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n+      // bit 2 full adder\n+      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n+      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n+      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n+      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n+      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n+      // bit 3 full adder\n+      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n+      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n+      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n+      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n+      { op: 'OR', in1: 'a03', in2: 'b03', out: 'c03' },\n+      // carry out\n+      { op: 'OR', in1: 'c03', in2: 'c03', out: 'z04' },\n+    ];\n+    // x = 3 (0011): x00=1, x01=1, x02=0, x03=0\n+    // y = 5 (0101): y00=1, y01=0, y02=1, y03=0\n+    const inputs: Record<string, number> = {\n+      x00: 1, x01: 1, x02: 0, x03: 0,\n+      y00: 1, y01: 0, y02: 1, y03: 0,\n+    };\n+    const result = simulate(gates, inputs);\n+    // 8 = 01000: z00=0, z01=0, z02=0, z03=1, z04=0\n+    expect(result['z00']).toBe(0);\n+    expect(result['z01']).toBe(0);\n+    expect(result['z02']).toBe(0);\n+    expect(result['z03']).toBe(1);\n+    expect(result['z04']).toBe(0);\n+  });\n+});\n+\n+describe('findSwappedWires', () => {\n+  test('finds no swaps in correct 4-bit adder', () => {\n+    const gates: Gate[] = [\n+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n+      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n+      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n+      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n+      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n+      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n+      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n+      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n+      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n+      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n+      { op: 'OR', in1: 'a03', in2: 'b03', out: 'c03' },\n+      { op: 'OR', in1: 'c03', in2: 'c03', out: 'z04' },\n+    ];\n+    const swapped = findSwappedWires(gates);\n+    expect(swapped).toEqual([]);\n+  });\n+\n+  test('finds 2 swapped wires in 4-bit adder', () => {\n+    // Swap z00 <-> c00 (half adder outputs)\n+    const gates: Gate[] = [\n+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'c00' },  // swapped: should be z00\n+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'z00' },  // swapped: should be c00\n+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n+      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n+      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n+      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n+      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n+      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n+      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n+      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n+      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n+      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n+      { op: 'OR', in1: 'a03', in2: 'b03', out: 'c03' },\n+      { op: 'OR', in1: 'c03', in2: 'c03', out: 'z04' },\n+    ];\n+    const swapped = findSwappedWires(gates);\n+    expect(swapped).toEqual(['c00', 'z00']);\n+  });\n+\n+  test('finds 4 swapped wires in 4-bit adder', () => {\n+    // Swap z00 <-> c00 AND z02 <-> a02\n+    const gates: Gate[] = [\n+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'c00' },  // swapped\n+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'z00' },  // swapped\n+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n+      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n+      { op: 'XOR', in1: 't02', in2: 'c01', out: 'a02' },  // swapped: should be z02\n+      { op: 'AND', in1: 'x02', in2: 'y02', out: 'z02' },  // swapped: should be a02\n+      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n+      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n+      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n+      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n+      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n+      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n+      { op: 'OR', in1: 'a03', in2: 'b03', out: 'c03' },\n+      { op: 'OR', in1: 'c03', in2: 'c03', out: 'z04' },\n+    ];\n+    const swapped = findSwappedWires(gates);\n+    expect(swapped).toEqual(['a02', 'c00', 'z00', 'z02']);\n+  });\n+});\ndiff --git a/src/index.ts b/src/index.ts\nnew file mode 100644\nindex 0000000..8a82922\n--- /dev/null\n+++ b/src/index.ts\n@@ -0,0 +1,157 @@\n+export interface Gate {\n+  op: 'AND' | 'OR' | 'XOR';\n+  in1: string;\n+  in2: string;\n+  out: string;\n+}\n+\n+export function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number> {\n+  const wires: Record<string, number> = { ...inputs };\n+  const remaining = [...gates];\n+\n+  while (remaining.length > 0) {\n+    const prevLen = remaining.length;\n+    for (let i = remaining.length - 1; i >= 0; i--) {\n+      const gate = remaining[i];\n+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {\n+        const a = wires[gate.in1];\n+        const b = wires[gate.in2];\n+        if (gate.op === 'AND') wires[gate.out] = a & b;\n+        else if (gate.op === 'OR') wires[gate.out] = a | b;\n+        else wires[gate.out] = a ^ b;\n+        remaining.splice(i, 1);\n+      }\n+    }\n+    if (remaining.length === prevLen) break; // no progress, circuit stuck\n+  }\n+\n+  return wires;\n+}\n+\n+// ── findSwappedWires ──────────────────────────────────────────────────────────\n+//\n+// Strategy: structural analysis of the ripple-carry adder.\n+//\n+// In a correct N-bit ripple-carry adder each bit position i (i > 0) uses:\n+//   - XOR(xi, yi)       → partial sum wire (call it Pi)\n+//   - XOR(Pi, carry_in) → Zi  (output bit)\n+//   - AND(xi, yi)       → generate wire (Gi)\n+//   - AND(Pi, carry_in) → propagate wire (Ti)\n+//   - OR(Gi, Ti)        → carry out (Ci)\n+//\n+// Bit 0 (half adder):\n+//   - XOR(x00, y00) → z00\n+//   - AND(x00, y00) → c00\n+//\n+// Rules that must hold for a correct gate:\n+//   R1. A gate XOR(xi, yi) must output a non-z wire (partial sum Pi) UNLESS i==0.\n+//   R2. A gate XOR(Pi, carry_in) must output zi.\n+//   R3. A gate AND(xi, yi) must output a non-z wire (generate Gi).\n+//   R4. A gate OR(Gi, Ti) must output a non-z wire unless it is the final carry\n+//       (which becomes the MSB output bit).\n+//   R5. A gate AND(Pi, carry_in) must output a non-z wire.\n+//   R6. A z-wire (other than the final carry z(N+1)) must come from a XOR gate.\n+//\n+// We check these rules and collect wires that violate them. This gives us the 8\n+// swapped wires without brute force enumeration.\n+\n+export function findSwappedWires(gates: Gate[]): string[] {\n+  // Determine number of input bits\n+  let maxBit = -1;\n+  for (const gate of gates) {\n+    for (const wire of [gate.in1, gate.in2, gate.out]) {\n+      const m = wire.match(/^[xy](\\d+)$/);\n+      if (m) maxBit = Math.max(maxBit, parseInt(m[1], 10));\n+    }\n+  }\n+  if (maxBit < 0) return [];\n+\n+  const N = maxBit + 1; // number of input bits\n+  const finalCarryWire = `z${String(N).padStart(2, '0')}`;\n+\n+  // Index gates by their inputs (unordered pair) for quick lookup\n+  const byInputs = new Map<string, Gate[]>();\n+  for (const g of gates) {\n+    for (const key of [`${g.in1}|${g.in2}`, `${g.in2}|${g.in1}`]) {\n+      if (!byInputs.has(key)) byInputs.set(key, []);\n+      byInputs.get(key)!.push(g);\n+    }\n+  }\n+\n+  const suspicious = new Set<string>();\n+\n+  // Rule R6: every z-wire (except the final carry) must come from XOR\n+  for (const g of gates) {\n+    if (g.out.startsWith('z') && g.out !== finalCarryWire) {\n+      if (g.op !== 'XOR') suspicious.add(g.out);\n+    }\n+  }\n+\n+  // Check structural rules per bit\n+  for (let i = 0; i < N; i++) {\n+    const xi = `x${String(i).padStart(2, '0')}`;\n+    const yi = `y${String(i).padStart(2, '0')}`;\n+    const zi = `z${String(i).padStart(2, '0')}`;\n+\n+    // Find XOR(xi, yi) and AND(xi, yi)\n+    const key = `${xi}|${yi}`;\n+    const xyGates = byInputs.get(key) ?? [];\n+    const xyXor = xyGates.find(g => g.op === 'XOR');\n+    const xyAnd = xyGates.find(g => g.op === 'AND');\n+\n+    if (i === 0) {\n+      // Half adder: XOR(x00,y00)->z00, AND(x00,y00)->carry\n+      if (xyXor && xyXor.out !== zi) {\n+        suspicious.add(xyXor.out);\n+        suspicious.add(zi);\n+      }\n+      if (xyAnd && xyAnd.out.startsWith('z') && xyAnd.out !== finalCarryWire) {\n+        suspicious.add(xyAnd.out);\n+      }\n+      continue;\n+    }\n+\n+    // Rule R1: XOR(xi,yi) must not output a z-wire (for i > 0)\n+    if (xyXor && xyXor.out.startsWith('z')) {\n+      suspicious.add(xyXor.out);\n+    }\n+\n+    // Rule R3: AND(xi,yi) must not output a z-wire\n+    if (xyAnd && xyAnd.out.startsWith('z') && xyAnd.out !== finalCarryWire) {\n+      suspicious.add(xyAnd.out);\n+    }\n+\n+    // The partial sum wire Pi = xyXor.out\n+    if (xyXor) {\n+      const pi = xyXor.out;\n+      // search all gates with pi as input\n+      const piXors = gates.filter(g => (g.in1 === pi || g.in2 === pi) && g.op === 'XOR');\n+      const piAnds = gates.filter(g => (g.in1 === pi || g.in2 === pi) && g.op === 'AND');\n+\n+      // Rule R2: XOR(Pi, carry_in) → zi\n+      for (const g of piXors) {\n+        if (g.out !== zi) {\n+          suspicious.add(g.out);\n+          suspicious.add(zi);\n+        }\n+      }\n+\n+      // Rule R5: AND(Pi, carry_in) must not output a z-wire\n+      for (const g of piAnds) {\n+        if (g.out.startsWith('z') && g.out !== finalCarryWire) {\n+          suspicious.add(g.out);\n+        }\n+      }\n+    }\n+  }\n+\n+  // Check OR gates (carry generators): their outputs should not be z-wires\n+  // (except the final carry)\n+  for (const g of gates) {\n+    if (