r } from './types.js';\n\nexport interface DatabaseConnection {\n  db: Database.Database;\n  close: () => void;\n}\n\nexport function createDatabase(path: string = ':memory:'): DatabaseConnection {\n  const db = new Database(path);\n\n  // Enable WAL mode for better concurrent read performance\n  db.pragma('journal_mode = WAL');\n  db.pragma('foreign_keys = ON');\n\n  return {\n    db,\n    close: () => db.close(),\n  };\n}\n\nexport function createTables(conn: DatabaseConnection): void {\n  conn.db.exec(`\n    CREATE TABLE IF NOT EXISTS users (\n      id INTEGER PRIMARY KEY AUTOINCREMENT,\n      name TEXT NOT NULL,\n      email TEXT NOT NULL UNIQUE,\n      role TEXT NOT NULL CHECK(role IN ('admin', 'user', 'viewer')),\n      created_at TEXT NOT NULL DEFAULT (datetime('now')),\n      updated_at TEXT NOT NULL DEFAULT (datetime('now'))\n    );\n\n    CREATE INDEX IF NOT EXISTS idx_users_email ON users(email);\n    CREATE INDEX IF NOT EXISTS idx_users_role ON users(role);\n  `);\n}\n\nexport function insertUser(\n  conn: DatabaseConnection,\n  user: { name: string; email: string; role: string }\n): User {\n  const stmt = conn.db.prepare(\n    'INSERT INTO users (name, email, role) VALUES (?, ?, ?) RETURNING *'\n  );\n  const row = stmt.get(user.name, user.email, user.role) as {\n    id: number;\n    name: string;\n    email: string;\n    role: string;\n    created_at: string;\n    updated_at: string;\n  };\n  return {\n    id: row.id,\n    name: row.name,\n    email: row.email,\n    role: row.role as User['role'],\n    createdAt: row.created_at,\n    updatedAt: row.updated_at,\n  };\n}\n\nexport function findUserById(\n  conn: DatabaseConnection,\n  id: number\n): User | null {\n  const stmt = conn.db.prepare('SELECT * FROM users WHERE id = ?');\n  const row = stmt.get(id) as {\n    id: number;\n    name: string;\n    email: string;\n    role: string;\n    created_at: string;\n    updated_at: string;\n  } | undefined;\n  if (!row) return null;\n  return {\n    id: row.id,\n    name: row.name,\n    email: row.email,\n    role: row.role as User['role'],\n    createdAt: row.created_at,\n    updatedAt: row.updated_at,\n  };\n}\n\nexport function findAllUsers(conn: DatabaseConnection): User[] {\n  const stmt = conn.db.prepare('SELECT * FROM users ORDER BY id');\n  const rows = stmt.all() as Array<{\n    id: number;\n    name: string;\n    email: string;\n    role: string;\n    created_at: string;\n    updated_at: string;\n  }>;\n  return rows.map((row) => ({\n    id: row.id,\n    name: row.name,\n    email: row.email,\n    role: row.role as User['role'],\n    createdAt: row.created_at,\n    updatedAt: row.updated_at,\n  }));\n}\n```\n\n### `/workspace/packages/core/src/user.ts`\n```typescript\n/**\n * User management: creation, validation, and retrieval.\n */\n\nimport type { User, CreateUserInput } from './types.js';\nimport { validateCreateUser } from './validation.js';\nimport { hasPermission } from './permissions.js';\nimport {\n  createDatabase,\n  createTables,\n  insertUser,\n  findUserById,\n  findAllUsers,\n  type DatabaseConnection,\n} from './database.js';\n\nlet defaultConn: DatabaseConnection | null = null;\n\nexport function getDefaultConnection(): DatabaseConnection {\n  if (!defaultConn) {\n    defaultConn = createDatabase(':memory:');\n    createTables(defaultConn);\n  }\n  return defaultConn;\n}\n\nexport function resetDefaultConnection(): void {\n  if (defaultConn) {\n    defaultConn.close();\n    defaultConn = null;\n  }\n}\n\nexport function registerUser(input: CreateUserInput): User {\n  const validation = validateCreateUser(input);\n  if (!validation.success) {\n    throw new Error(`Invalid user data: ${validation.errors?.join(', ')}`);\n  }\n\n  const conn = getDefaultConnection();\n  return insertUser(conn, input);\n}\n\nexport function validateUser(input: unknown): {\n  valid: boolean;\n  errors?: string[];\n} {\n  const result = validateCreateUser(input);\n  return {\n    valid: result.success,\n    errors: result.errors,\n  };\n}\n\nexport function getUserById(id: number): User | null {\n  const conn = getDefaultConnection();\n  return findUserById(conn, id);\n}\n\nexport function getAllUsers(): User[] {\n  const conn = getDefaultConnection();\n  return findAllUsers(conn);\n}\n\nexport function canUserPerformAction(\n  userRole: User['role'],\n  action: 'read' | 'write' | 'delete'\n): boolean {\n  return hasPermission(userRole, action);\n}\n```\n\n### `/workspace/packages/core/src/permissions.ts`\n```typescript\n/**\n * Permission checking and role-based access control.\n */\n\nimport type { Role, Permission } from './types.js';\n\nconst ROLE_PERMISSIONS: Record<Role, Permission[]> = {\n  admin: ['read', 'write', 'delete', 'manage_users', 'view_reports'],\n  user: ['read', 'write', 'view_reports'],\n  viewer: ['read'],\n};\n\nexport function hasPermission(role: Role, permission: Permission): boolean {\n  const permissions = ROLE_PERMISSIONS[role];\n  return permissions.includes(permission);\n}\n\nexport function getAllPermissions(role: Role): Permission[] {\n  return [...ROLE_PERMISSIONS[role]];\n}\n\nexport function canManageUsers(role: Role): boolean {\n  return hasPermission(role, 'manage_users');\n}\n\nexport function canWrite(role: Role): boolean {\n  return hasPermission(role, 'write');\n}\n\nexport function canDelete(role: Role): boolean {\n  return hasPermission(role, 'delete');\n}\n\nexport function requirePermission(\n  role: Role,\n  permission: Permission\n): void {\n  if (!hasPermission(role, permission)) {\n    throw new Error(\n      `Role '${role}' does not have permission '${permission}'`\n    );\n  }\n}\n```\n\n### `/workspace/packages/core/src/validation.ts`\n```typescript\n/**\n * Schema validation using zod.\n * Uses z.pipe() for string-to-number coercion (requires zod >= 3.22).\n */\n\nimport { z } from 'zod';\nimport type { Role } from './types.js';\n\nexport const roleSchema = z.enum(['admin', 'user', 'viewer']);\n\nexport const createUserSchema = z.object({\n  name: z\n    .string()\n    .min(1, 'Name is required')\n    .max(100, 'Name must be 100 characters or less'),\n  email: z.string().email('Invalid email address'),\n  role: roleSchema,\n});\n\nexport const userIdSchema = z\n  .string()\n  .pipe(z.coerce.number().int().positive('User ID must be a positive integer'));\n\nexport const userFiltersSchema = z.object({\n  role: roleSchema.optional(),\n  search: z.string().optional(),\n  limit: z\n    .string()\n    .pipe(z.coerce.number().int().min(1).max(100))\n    .optional()\n    .default('20'),\n  offset: z\n    .string()\n    .pipe(z.coerce.number().int().min(0))\n    .optional()\n    .default('0'),\n});\n\nexport function validateCreateUser(data: unknown): {\n  success: boolean;\n  data?: { name: string; email: string; role: Role };\n  errors?: string[];\n} {\n  const result = createUserSchema.safeParse(data);\n  if (result.success) {\n    return { success: true, data: result.data };\n  }\n  return {\n    success: false,\n    errors: result.error.errors.map((e) => e.message),\n  };\n}\n\nexport function validateUserId(id: string): {\n  success: boolean;\n  data?: number;\n  errors?: string[];\n} {\n  const result = userIdSchema.safeParse(id);\n  if (result.success) {\n    return { success: true, data: result.data };\n  }\n  return {\n    success: false,\n    errors: result.error.errors.map((e) => e.message),\n  };\n}\n```\n\n---\n\n## 5. API PACKAGE SOURCE FILES\n\n### `/workspace/packages/api/src/index.ts`\n```typescript\n/**\n * Express API application setup.\n */\n\nimport express from 'express';\nimport { usersRouter } from './routes/users.js';\nimport { authRouter } from './routes/auth.js';\nimport { authMiddleware } from './middleware/auth.js';\n\nexport function createApp() {\n  const app = express();\n\n  app.use(express.json());\n\n  // Health check\n  app.get('/health', (_req, res) => {\n    res.json({ status: 'ok' });\n  });\n\n  // Public routes\n  app.use('/auth', authRouter);\n\n  // Protected routes\n  app.use('/users', authMiddleware, usersRouter);\n\n  // Error handler\n  app.use(\n    (\n      err: Error,\n      _req: express.Request,\n      res: express.Response,\n      _next: express.NextFunction\n    ) => {\n      console.error(err.message);\n      res.status(500).json({ error: 'Internal server error' });\n    }\n  );\n\n  return app;\n}\n\n// Start server if run directly\nconst isMainModule = process.argv[1]?.includes('api/dist/index.js');\nif (isMainModule) {\n  const port = process.env['PORT'] || 3000;\n  const app = createApp();\n  app.listen(port, () => {\n    console.log(`API server running on port ${port}`);\n  });\n}\n```\n\n### `/workspace/packages/api/src/middleware/auth.ts`\n```typescript\n/**\n * Authentication middleware using core permissions.\n */\n\nimport type { Request, Response, NextFunction } from 'express';\nimport { hasPermission, type Role, type Permission } from '@monorepo/core';\n\n/**\n * Basic auth middleware that checks for a token header.\n * In this benchmark, we use a simplified mock auth system.\n */\nexport function authMiddleware(\n  req: Request,\n  res: Response,\n  next: NextFunction\n): void {\n  const token = req.headers['authorization']?.replace('Bearer ', '');\n\n  // Allow requests with valid mock tokens or role headers\n  if (token?.startsWith('mock-token-') || req.headers['x-user-role']) {\n    next();\n    return;\n  }\n\n  res.status(401).json({ error: 'Authentication required' });\n}\n\n/**\n * Middleware factory to require a specific permission.\n */\nexport function requirePermissionMiddleware(permission: Permission) {\n  return (req: Request, res: Response, next: NextFunction): void => {\n    const role = (req.headers['x-user-role'] as Role) || 'viewer';\n\n    if (!hasPermission(role, permission)) {\n      res.status(403).json({\n        error: `Permission '${permission}' required`,\n      });\n      return;\n    }\n\n    next();\n  };\n}\n```\n\n### `/workspace/packages/api/src/routes/auth.ts`\n```typescript\n/**\n * Authentication routes.\n */\n\nimport { Router, type Request, type Response } from 'express';\nimport { validateCreateUser, registerUser, type Role } from '@monorepo/core';\n\nexport const authRouter = Router();\n\n// Simple registration (public)\nauthRouter.post('/register', (req: Request, res: Response) => {\n  try {\n    const validation = validateCreateUser({\n      ...req.body,\n      role: 'user', // Force 'user' role for self-registration\n    });\n\n    if (!validation.success) {\n      res.status(400).json({ errors: validation.errors });\n      return;\n    }\n\n    const user = registerUser({\n      name: req.body.name,\n      email: req.body.email,\n      role: 'user' as Role,\n    });\n\n    res.status(201).json({\n      user,\n      token: `mock-token-${user.id}`, // Simplified for benchmark\n    });\n  } catch (err) {\n    if (err instanceof Error && err.message.includes('UNIQUE')) {\n      res.status(409).json({ error: 'Email already registered' });\n      return;\n    }\n    res.status(500).json({ error: 'Registration failed' });\n  }\n});\n\n// Simple login (mock)\nauthRouter.post('/login', (req: Request, res: Response) => {\n  try {\n    const { email } = req.body as { email?: string };\n    if (!email) {\n      res.status(400).json({ error: 'Email is required' });\n      return;\n    }\n\n    // In a real app, we'd verify credentials\n    res.json({\n      token: `mock-token-for-${email}`,\n      message: 'Login successful',\n    });\n  } catch (err) {\n    res.status(500).json({ error: 'Login failed' });\n  }\n});\n\n// Token validation (mock)\nauthRouter.get('/verify', (req: Request, res: Response) => {\n  const token = req.headers['authorization']?.replace('Bearer ', '');\n  if (!token) {\n    res.status(401).json({ error: 'No token provided' });\n    return;\n  }\n\n  // Simplified: any token with correct format is valid\n  if (token.startsWith('mock-token-')) {\n    res.json({ valid: true, token });\n  } else {\n    res.status(401).json({ valid: false, error: 'Invalid token' });\n  }\n});\n```\n\n### `/workspace/packages/api/src/routes/users.ts`\n```typescript\n/**\n * User CRUD routes.\n */\n\nimport { Router, type Request, type Response } from 'express';\nimport {\n  createUser,\n  getUserById,\n  getAllUsers,\n  validateCreateUser,\n  validateUserId,\n  canManageUsers,\n  type Role,\n} from '@monorepo/core';\n\nexport const usersRouter = Router();\n\n// List all users\nusersRouter.get('/', (_req: Request, res: Response) => {\n  try {\n    const users = getAllUsers();\n    res.json({ users });\n  } catch (err) {\n    res.status(500).json({ error: 'Failed to fetch users' });\n  }\n});\n\n// Get user by ID\nusersRouter.get('/:id', (req: Request, res: Response) => {\n  try {\n    const validation = validateUserId(req.params['id']!);\n    if (!validation.success) {\n      res.status(400).json({ errors: validation.errors });\n      return;\n    }\n\n    const user = getUserById(validation.data!);\n    if (!user) {\n      res.status(404).json({ error: 'User not found' });\n      return;\n    }\n    res.json({ user });\n  } catch (err) {\n    res.status(500).json({ error: 'Failed to fetch user' });\n  }\n});\n\n// Create a new user\nusersRouter.post('/', (req: Request, res: Response) => {\n  try {\n    const callerRole = (req.headers['x-user-role'] as Role) || 'viewer';\n    if (!canManageUsers(callerRole)) {\n      res.status(403).json({ error: 'Insufficient permissions' });\n      return;\n    }\n\n    const validation = validateCreateUser(req.body);\n    if (!validation.success) {\n      res.status(400).json({ errors: validation.errors });\n      return;\n    }\n\n    const user = createUser(req.body);\n    res.status(201).json({ user });\n  } catch (err) {\n    if (err instanceof Error && err.message.includes('UNIQUE')) {\n      res.status(409).json({ error: 'Email already exists' });\n      return;\n    }\n    res.status(500).json({ error: 'Failed to create user' });\n  }\n});\n\n// Delete user by ID\nusersRouter.delete('/:id', (req: Request, res: Response) => {\n  try {\n    const callerRole = (req.headers['x-user-role'] as Role) || 'viewer';\n    if (!canManageUsers(callerRole)) {\n      res.status(403).json({ error: 'Insufficient permissions' });\n      return;\n    }\n\n    const validation = validateUserId(req.params['id']!);\n    if (!validation.success) {\n      res.status(400).json({ errors: validation.errors });\n      return;\n    }\n\n    const user = getUserById(validation.data!);\n    if (!user) {\n      res.status(404).json({ error: 'User not found' });\n      return;\n    }\n\n    // In a real app, we'd delete here\n    res.status(200).json({ message: 'User deleted', user });\n  } catch (err) {\n    res.status(500).json({ error: 'Failed to delete user' });\n  }\n});\n```\n\n---\n\n## 6. WORKER PACKAGE SOURCE FILES\n\n### `/workspace/packages/worker/src/index.ts`\n```typescript\n/**\n * Worker entry point.\n * Runs background jobs on a schedule.\n */\n\nimport { Scheduler } from './scheduler.js';\nimport { syncJob } from './jobs/sync.js';\nimport { cleanupJob } from './jobs/cleanup.js';\n\nexport function createWorker(): Scheduler {\n  const scheduler = new Scheduler();\n\n  // Register jobs\n  scheduler.register('sync', syncJob, 60_000); // Every 60 seconds\n  scheduler.register('cleanup', async () => { await cleanupJob(); }, 300_000); // Every 5 minutes\n\n  return scheduler;\n}\n\n// Start worker if run directly\nconst isMainModule = process.argv[1]?.includes('worker/dist/index.js');\nif (isMainModule) {\n  console.log('Starting worker...');\n  const worker = createWorker();\n  worker.start();\n\n  process.on('SIGINT', () => {\n    console.log('Shutting down worker...');\n    worker.stop();\n    process.exit(0);\n  });\n}\n```\n\n### `/workspace/packages/worker/src/scheduler.ts`\n```typescript\n/**\n * Simple job scheduler for background tasks.\n */\n\nexport interface JobDefinition {\n  name: string;\n  handler: () => Promise<void> | void;\n  intervalMs: number;\n  timer?: ReturnType<typeof setInterval>;\n  lastRun?: Date;\n  runCount: number;\n  errors: string[];\n}\n\nexport class Scheduler {\n  private jobs: Map<string, JobDefinition> = new Map();\n  private running = false;\n\n  register(\n    name: string,\n    handler: () => Promise<void> | void,\n    intervalMs: number\n  ): void {\n    this.jobs.set(name, {\n      name,\n      handler,\n      intervalMs,\n      runCount: 0,\n      errors: [],\n    });\n  }\n\n  start(): void {\n    if (this.running) return;\n    this.running = true;\n\n    for (const [, job] of this.jobs) {\n      job.timer = setInterval(async () => {\n        try {\n          await job.handler();\n          job.lastRun = new Date();\n          job.runCount++;\n        } catch (err) {\n          job.errors.push(\n            err instanceof Error ? err.message : String(err)\n          );\n        }\n      }, job.intervalMs);\n    }\n  }\n\n  stop(): void {\n    if (!this.running) return;\n    this.running = false;\n\n    for (const [, job] of this.jobs) {\n      if (job.timer) {\n        clearInterval(job.timer);\n        job.timer = undefined;\n      }\n    }\n  }\n\n  async runOnce(name: string): Promise<void> {\n    const job = this.jobs.get(name);\n    if (!job) {\n      throw new Error(`Job '${name}' not found`);\n    }\n\n    await job.handler();\n    job.lastRun = new Date();\n    job.runCount++;\n  }\n\n  getStatus(): Array<{\n    name: string;\n    lastRun: Date | undefined;\n    runCount: number;\n    errorCount: number;\n  }> {\n    return Array.from(this.jobs.values()).map((job) => ({\n      name: job.name,\n      lastRun: job.lastRun,\n      runCount: job.runCount,\n      errorCount: job.errors.length,\n    }));\n  }\n\n  isRunning(): boolean {\n    return this.running;\n  }\n}\n```\n\n### `/workspace/packages/worker/src/jobs/cleanup.ts`\n```typescript\n/**\n * Cleanup job.\n * Removes stale data and performs maintenance tasks.\n */\n\nimport { getAllUsers } from '@monorepo/core';\n\nexport interface CleanupResult {\n  staleRecords: number;\n  cleanedUp: number;\n  duration: number;\n}\n\nexport async function cleanupJob(): Promise<CleanupResult> {\n  const startTime = Date.now();\n\n  // Get all users to check for stale records\n  const users = getAllUsers();\n\n  let staleRecords = 0;\n  let cleanedUp = 0;\n\n  for (const user of users) {\n    const createdDate = new Date(user.createdAt);\n    const now = new Date();\n    const daysSinceCreation =\n      (now.getTime() - createdDate.getTime()) / (1000 * 60 * 60 * 24);\n\n    // Mark records older than 365 days as stale (simulation)\n    if (daysSinceCreation > 365) {\n      staleRecords++;\n      // In a real app, we'd archive or delete\n      cleanedUp++;\n    }\n  }\n\n  const duration = Date.now() - startTime;\n\n  console.log(\n    `Cleanup complete: ${staleRecords} stale, ${cleanedUp} cleaned in ${duration}ms`\n  );\n\n  return { staleRecords, cleanedUp, duration };\n}\n\nexport function getCleanupThresholdDays(): number {\n  return 365;\n}\n```\n\n### `/workspace/packages/worker/src/jobs/sync.ts`\n```typescript\n/**\n * Data sync job.\n * Syncs external user data into the local database.\n */\n\nimport {\n  createUser,\n  getUserById,\n  getAllUsers,\n  type CreateUserInput,\n} from '@monorepo/core';\n\ninterface ExternalUser {\n  name: string;\n  email: string;\n  role: 'admin' | 'user' | 'viewer';\n}\n\n// Simulated external data source\nfunction fetchExternalUsers(): ExternalUser[] {\n  return [\n    { name: 'External User 1', email: 'ext1@example.com', role: 'user' },\n    { name: 'External User 2', email: 'ext2@example.com', role: 'viewer' },\n  ];\n}\n\nexport async function syncJob(): Promise<void> {\n  const externalUsers = fetchExternalUsers();\n  const existingUsers = getAllUsers();\n  const existingEmails = new Set(existingUsers.map((u) => u.email));\n\n  let synced = 0;\n  let skipped = 0;\n\n  for (const extUser of externalUsers) {\n    if (existingEmails.has(extUser.email)) {\n      skipped++;\n      continue;\n    }\n\n    const input: CreateUserInput = {\n      name: extUser.name,\n      email: extUser.email,\n      role: extUser.role,\n    };\n\n    try {\n      const newUser = createUser(input);\n      if (newUser.id) {\n        synced++;\n      }\n    } catch (err) {\n      console.error(`Failed to sync user ${extUser.email}:`, err);\n    }\n  }\n\n  console.log(`Sync complete: ${synced} synced, ${skipped} skipped`);\n}\n\nexport async function syncSingleUser(userId: number): Promise<boolean> {\n  const user = getUserById(userId);\n  if (!user) {\n    console.error(`User ${userId} not found for sync`);\n    return false;\n  }\n\n  // In a real app, we'd sync to an external service here\n  console.log(`Synced user ${user.name} (${user.email})`);\n  return true;\n}\n```\n\n---\n\n## 7. ALL TEST FILES\n\n### `/workspace/packages/core/tests/user.test.ts`\n```typescript\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport {\n  registerUser,\n  validateUser,\n  getUserById,\n  getAllUsers,\n  resetDefaultConnection,\n} from '../src/user.js';\n\ndescribe('User Management', () => {\n  beforeEach(() => {\n    resetDefaultConnection();\n  });\n\n  it('registers a new user with valid data', () => {\n    const user = registerUser({\n      name: 'Alice',\n      email: 'alice@example.com',\n      role: 'admin',\n    });\n    expect(user.id).toBe(1);\n    expect(user.name).toBe('Alice');\n    expect(user.email).toBe('alice@example.com');\n    expect(user.role).toBe('admin');\n  });\n\n  it('throws on invalid user data', () => {\n    expect(() =>\n      registerUser({ name: '', email: 'bad', role: 'admin' })\n    ).toThrow('Invalid user data');\n  });\n\n  it('retrieves a user by id', () => {\n    const created = registerUser({\n      name: 'Bob',\n      email: 'bob@example.com',\n      role: 'user',\n    });\n    const found = getUserById(created.id);\n    expect(found).not.toBeNull();\