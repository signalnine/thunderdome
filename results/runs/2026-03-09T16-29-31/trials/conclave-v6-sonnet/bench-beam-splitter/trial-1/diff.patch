+    // . ^ . . .
+    // ^ . ^ . .
+    // . . . . .
+    const g = grid(`
+      . S . . .
+      . ^ . . .
+      ^ . ^ . .
+      . . . . .
+    `);
+    // 4 paths as spec says
+    expect(countBeamPaths(g)).toBe(4n);
+  });
+
