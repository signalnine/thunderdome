@@ -0,0 +1,230 @@
+import { describe, test, expect } from 'vitest';
+import { countBeamCells, countBeamPaths } from './index.js';
+
+// Helper to build a grid from a string template
+function grid(template: string): string[][] {
+  return template
+    .trim()
+    .split('\n')
+    .map(row => row.trim().split(' '));
+}
+
+describe('countBeamCells', () => {
+  test('source cell is visited on a single-cell grid', () => {
+    const g = [['S']];
+    expect(countBeamCells(g)).toBe(1);
+  });
+
+  test('beam travels straight down from source until it exits', () => {
+    // S
+    // .
+    // .
+    const g = grid(`
+      S
+      .
+      .
+    `);
+    expect(countBeamCells(g)).toBe(3);
+  });
+
+  test('example from spec: single splitter', () => {
+    // . S . . .
+    // . . . . .
+    // . ^ . . .
+    // . . . . .
+    const g = grid(`
+      . S . . .
+      . . . . .
+      . ^ . . .
+      . . . . .
+    `);
+    expect(countBeamCells(g)).toBe(5);
+  });
+
+  test('splitter cell itself counts as visited', () => {
+    // S
+    // ^
+    const g = grid(`
+      S
+      ^
+    `);
+    // visits: (0,0)=S, (1,0)=^  -- splits to (-1) col left absorbed, col+1 absorbed
+    // Actually col-1 = -1 is out of bounds. col+1 = 1 is out of bounds (1-col grid).
+    // So only S and ^ are visited.
+    expect(countBeamCells(g)).toBe(2);
+  });
+
+  test('two-splitter example from spec', () => {
+    // . S . . .
+    // . ^ . . .
+    // ^ . ^ . .
+    // . . . . .
+    const g = grid(`
+      . S . . .
+      . ^ . . .
+      ^ . ^ . .
+      . . . . .
+    `);
+    // (0,1)=S, (1,1)=^, (2,0)=^, (2,2)=^, (3,1) visited by two beams, (3,3)
+    // (2,0) splits: down-left=(3,-1) absorbed, down-right=(3,1)
+    // (2,2) splits: down-left=(3,1), down-right=(3,3)
+    expect(countBeamCells(g)).toBe(6);
+  });
+
+  test('beam going off left edge is absorbed', () => {
+    // S .
+    // ^ .
+    const g = grid(`
+      S .
+      ^ .
