+    // down-right: (2,2)=^ splits: (3,1),(3,3)
+    // visited: (0,1),(1,1),(2,0),(2,2),(3,1),(3,3)
+    expect(countBeamCells(g)).toBe(6);
+  });
+
+  test('multiple beams visiting same cell counts once', () => {
+    // . S . . .
+    // . ^ . . .
+    // ^ . ^ . .
+    // . . . . .
+    // Already tested above - (3,1) is visited by two beams but counted once
+    const g = grid(`
