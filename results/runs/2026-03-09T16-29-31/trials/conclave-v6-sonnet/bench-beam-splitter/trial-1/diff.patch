s true cycles)\n  const seenStates = new Set<string>();\n  const stateKey = (b: Beam) => `${b.row},${b.col},${b.dir}`;\n\n  while (queue.length > 0) {\n    const beam = queue.shift()!;\n    const { row, col, dir } = beam;\n\n    if (!inBounds(row, col, rows, cols)) continue;\n\n    const sk = stateKey(beam);\n    if (seenStates.has(sk)) continue;\n    seenStates.add(sk);\n\n    visited.add(key(row, col));\n\n    const cell = grid[row][col];\n\n    if (cell === '^') {\n      // Splits into two diagonal beams\n      const left: Beam = { row: row + 1, col: col - 1, dir: 'down-left' };\n      const right: Beam = { row: row + 1, col: col + 1, dir: 'down-right' };\n      if (inBounds(left.row, left.col, rows, cols)) queue.push(left);\n      if (inBounds(right.row, right.col, rows, cols)) queue.push(right);\n    } else {\n      // Continue in same direction\n      const next = step(beam);\n      if (inBounds(next.row, next.col, rows, cols)) queue.push(next);\n    }\n  }\n\n  return visited.size;\n}\n\n/**\n * Count the total number of distinct source-to-exit paths.\n *\n * Key insight: all beams strictly increase their row each step, so there are\n * no cycles. We process row by row, propagating path counts forward.\n *\n * State: (row, col, direction) → bigint path count arriving at that cell.\n * We process all states at row R before row R+1 (topological order).\n */\nexport function countBeamPaths(grid: string[][]): bigint {\n  const rows = grid.length;\n  const cols = grid[0].length;\n\n  // Find the source 'S'\n  let sourceCol = -1;\n  for (let c = 0; c < cols; c++) {\n    if (grid[0][c] === 'S') {\n      sourceCol = c;\n      break;\n    }\n  }\n  if (sourceCol === -1) return 0n;\n\n  const stateKey = (r: number, c: number, d: Direction) => `${r},${c},${d}`;\n\n  // Map from state key → incoming path count\n  const incoming = new Map<string, bigint>();\n  incoming.set(stateKey(0, sourceCol, 'down'), 1n);\n\n  // Active states per row (we process row by row for correct ordering)\n  // Use a set of state keys per row to know what to process\n  const rowStates: Map<number, Set<string>> = new Map();\n  rowStates.set(0, new Set([stateKey(0, sourceCol, 'down')]));\n\n  let totalPaths = 0n;\n\n  for (let row = 0; row < rows; row++) {\n    const states = rowStates.get(row);\n    if (!states) continue;\n\n    for (const sk of states) {\n      const paths = incoming.get(sk) ?? 0n;\n      if (paths === 0n) continue;\n\n      // Parse state key\n      const parts = sk.split(',');\n      const col = parseInt(parts[1]);\n      const dir = parts[2] as Direction;\n\n      const cell = grid[row][col];\n\n      if (cell === '^') {\n        // Split: emit down-left and down-right\n        const destinations: Array<{ r: number; c: number; d: Direction }> = [\n          { r: row + 1, c: col - 1, d: 'down-left' },\n          { r: row + 1, c: col + 1, d: 'down-right' },\n        ];\n        for (const { r, c, d } of destinations) {\n          if (inBounds(r, c, rows, cols)) {\n            const nsk = stateKey(r, c, d);\n            incoming.set(nsk, (incoming.get(nsk) ?? 0n) + paths);\n            if (!rowStates.has(r)) rowStates.set(r, new Set());\n            rowStates.get(r)!.add(nsk);\n          } else {\n            totalPaths += paths;\n          }\n        }\n      } else {\n        // Continue in same direction\n        const next = step({ row, col, dir });\n        if (inBounds(next.row, next.col, rows, cols)) {\n          const nsk = stateKey(next.row, next.col, next.dir);\n          incoming.set(nsk, (incoming.get(nsk) ?? 0n) + paths);\n          if (!rowStates.has(next.row)) rowStates.set(next.row, new Set());\n          rowStates.get(next.row)!.add(nsk);\n        } else {\n          totalPaths += paths;\n        }\n      }\n    }\n  }\n\n  return totalPaths;\n}\n","structuredPatch":[{"oldStart":50,"oldLines":7,"newStart":50,"newLines":7,"lines":[" ","   while (queue.length > 0) {","     const beam = queue.shift()!;","-    const { row, co