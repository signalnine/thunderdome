st result = solveCounter([2, 3], [[0], [1]], 5);\n    expect(result).toEqual([2, 3]);\n  });\n\n  test('button affects multiple counters', () => {\n    // Button 0 increments counters [0, 1]. Target [2, 2], mod 5.\n    // Press button 0 twice.\n    const result = solveCounter([2, 2], [[0, 1]], 5);\n    expect(result).toEqual([2]);\n  });\n\n  test('button affects multiple counters, need two buttons', () => {\n    // Button 0 affects [0, 1]. Button 1 affects [1, 2].\n    // Target [1, 0, 1], mod 5.\n    // b0 = 1 (counter 0 needs 1). b1 = 1 (counter 2 needs 1).\n    // Counter 1: b0 + b1 = 1 + 1 = 2. But target is 0.\n    // That's wrong. Let me pick a solvable target.\n    // b0 affects [0,1], b1 affects [1,2].\n    // counter 0: b0 = target[0]\n    // counter 1: b0 + b1 = target[1]\n    // counter 2: b1 = target[2]\n    // Target [1, 2, 1]: b0=1, b1=1, check: 1+1=2 ✓\n    const result = solveCounter([1, 2, 1], [[0, 1], [1, 2]], 5);\n    expect(result).toEqual([1, 1]);\n  });\n\n  test('minimum presses preferred over larger values', () => {\n    // Button 0 increments counter 0. Target: counter 0 = 0.\n    // Could press 0 times (0) or 5 times (wraps to 0), minimum is 0.\n    const result = solveCounter([0], [[0]], 5);\n    expect(result).toEqual([0]);\n  });\n\n  test('prime modulus 7 - basic', () => {\n    const result = solveCounter([3, 5], [[0], [1]], 7);\n    expect(result).toEqual([3, 5]);\n  });\n\n  test('prime modulus 7 - needs mod inverse', () => {\n    // Button 0 increments both counter 0 and 1 (by 1 each).\n    // Button 1 increments counter 0 by 1.\n    // Target: [0, 3], mod 7.\n    // counter 1: b0 = 3, so b0 = 3\n    // counter 0: b0 + b1 = 0 (mod 7), so 3 + b1 = 0 → b1 = 4\n    // Presses: [3, 4], total = 7\n    const result = solveCounter([0, 3], [[0, 1], [0]], 7);\n    expect(result).toEqual([3, 4]);\n  });\n\n  test('no buttons with zero target', () => {\n    const result = solveCounter([0, 0], [], 5);\n    expect(result).toEqual([]);\n  });\n\n