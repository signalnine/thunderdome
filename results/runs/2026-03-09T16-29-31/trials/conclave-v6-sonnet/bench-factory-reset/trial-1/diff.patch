\n * Find minimum Hamming weight solution in an affine subspace of GF(2)^n.\n *\n * Given particular solution xp and null space vectors nullVecs, finds the\n * combination mask (subset of null vecs to XOR in) that minimizes weight,\n * with lexicographic tiebreaking on indices.\n *\n * Uses meet-in-the-middle for large null spaces (up to 2*2^(numFree/2) work).\n */\nfunction minWeightGF2(\n  xp: number[],\n  nullVecs: number[][],\n  cols: number\n): number[] {\n  const numFree = nullVecs.length;\n\n  if (numFree === 0) {\n    return xp.map((v, i) => v ? i : -1).filter(i => i >= 0);\n  }\n\n  // For small numFree, direct enumeration\n  if (numFree <= 24) {\n    return minWeightEnumerate(xp, nullVecs, cols, numFree);\n  }\n\n  // Meet in the middle: split into left and right halves\n  const half = Math.floor(numFree / 2);\n  const leftVecs = nullVecs.slice(0, half);\n  const rightVecs = nullVecs.slice(half);\n\n  // Enumerate all left half combinations: for each mask, store the XOR result\n  // Map from XOR result (as sorted indices string) to {mask, weight, indices}\n  // Actually store: map from state vector -> best (weight, mask, indices)\n  // Use a Map from state representation to best result\n\n  type Entry = { weight: number; indices: number[] };\n  // For the left half: state after xoring xp with left subset\n  // key: indices joined string\n  // value: best entry (minimum weight seen)\n  const leftMap = new Map<string, Entry>();\n\n  const leftTotal = 1 << half;\n  for (let lmask = 0; lmask < leftTotal; lmask++) {\n    const x = xp.slice();\n    for (let k = 0; k < half; k++) {\n      if ((lmask >> k) & 1) {\n        for (let c = 0; c < cols; c++) {\n          x[c] ^= leftVecs[k][c];\n        }\n      }\n    }\n    const indices = x.map((v, i) => v ? i : -1).filter(i => i >= 0);\n    // Store the raw x state as key for meeting, with indices as value info\n    const stateKey = x.join(',');\n    const existing = leftMap.get(stateKey);\n    if (!existing) {\n      leftMap.set(stateKey, { weight: indices.length, indices });\n    } else if (\n      indices.length < existing.weight ||\n      (indices.length === existing.weight && lexSmaller(indices, existing.indices))\n    ) {\n      leftMap.set(stateKey, { weight: indices.length, indices });\n    }\n  }\n\n  // For the right half: we want rightMask such that leftState XOR rightDelta = minimum weight\n  // rightDelta = XOR of right vecs according to rightMask\n  // For each rightMask, compute rightDelta, look up leftState = xp XOR rightDelta... wait.\n  // Actually: full solution = xp XOR (left subset XOR right subset)\n  // So leftState = xp XOR leftSubset, rightDelta = rightSubset\n  // full solution = leftState XOR rightDelta\n  // We want minimum weight of (leftState XOR rightDelta) over all leftState in leftMap and rightDelta.\n  // This doesn't simplify to a direct map lookup unless we key differently.\n\n  // Alternative: key leftMap by the XOR state directly.\n  // For a given rightDelta, we want the leftState such that leftState XOR rightDelta has minimum weight.\n  // This is the minimum weight XOR problem → we just enumerate right combinations and for each,\n  // compute the target leftState and look it up... but that doesn't work unless we can enumerate efficiently.\n\n  // Better approach: the meet-in-the-middle should compute:\n  // left: enumerate all xp XOR leftSubset → store in map indexed by XOR state\n  // right: enumerate all rightSubset → for each, the \"full\" solution would be\n  //   (xp XOR leftSubset) XOR rightSubset = lookup leftState where leftState = xp XOR leftSubset\n  //   But we want min weight of leftState XOR rightSubset for any leftState in leftMap.\n\n  // This is the Closest Vector Problem variant. Without additional structure, the best\n  // meet-in-the-middle for minimum weight finds: for each right combination, it checks\n  // which left combination, when XOR'd together, gives minimum weight.\n\n  // The correct MITM for minimum weight