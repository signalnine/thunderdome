): number => {\n    a = ((a % mod) + mod) % mod;\n    // Extended Euclidean\n    let [old_r, r] = [a, mod];\n    let [old_s, s] = [1, 0];\n    while (r !== 0) {\n      const q = Math.floor(old_r / r);\n      [old_r, r] = [r, old_r - q * r];\n      [old_s, s] = [s, old_s - q * s];\n    }\n    return ((old_s % mod) + mod) % mod;\n  };\n\n  const mod = (x: number) => ((x % p) + p) % p;\n\n  const pivotRow: number[] = new Array(cols).fill(-1);\n  const pivotCol: number[] = [];\n  let curRow = 0;\n\n  for (let col = 0; col < cols && curRow < rows; col++) {\n    // Find pivot\n    let found = -1;\n    for (let r = curRow; r < rows; r++) {\n      if (aug[r][col] !== 0) { found = r; break; }\n    }\n    if (found === -1) continue;\n\n    [aug[curRow], aug[found]] = [aug[found], aug[curRow]];\n\n    // Scale pivot row so pivot = 1\n    const inv = modInv(aug[curRow][col], p);\n    for (let c = 0; c <= cols; c++) {\n      aug[curRow][c] = mod(aug[curRow][c] * inv);\n    }\n\n    pivotRow[col] = curRow;\n    pivotCol.push(col);\n\n    // Eliminate\n    for (let r = 0; r < rows; r++) {\n      if (r !== curRow && aug[r][col] !== 0) {\n        const factor = aug[r][col];\n        for (let c = 0; c <= cols; c++) {\n          aug[r][c] = mod(aug[r][c] - factor * aug[curRow][c]);\n        }\n      }\n    }\n    curRow++;\n  }\n\n  // Check inconsistency\n  for (let r = 0; r < rows; r++) {\n    let allZero = true;\n    for (let c = 0; c < cols; c++) {\n      if (aug[r][c] !== 0) { allZero = false; break; }\n    }\n    if (allZero && aug[r][cols] !== 0) return null;\n  }\n\n  // Identify free variables\n  const pivotSet = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let c = 0; c < cols; c++) {\n    if (!pivotSet.has(c)) freeVars.push(c);\n  }\n\n  const numFree = freeVars.length;\n\n  // Particular solution (free vars = 0)\n  const xp: number[] = new Array(cols).fill(0);\n  for (let i = 0; i < pivotCol.length; i++) {\n    const pc = pivotCol[i];\n    const pr = pivotRo