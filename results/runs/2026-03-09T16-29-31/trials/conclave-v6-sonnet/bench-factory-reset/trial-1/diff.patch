+  // Particular solution (free vars = 0)
+  const xp: number[] = new Array(cols).fill(0);
+  for (const pc of pivotCol) {
+    xp[pc] = aug[pivotRow[pc]][cols];
+  }
+
+  // Free variables
+  const pivotSet = new Set(pivotCol);
+  const freeVars: number[] = [];
+  for (let c = 0; c < cols; c++) {
+    if (!pivotSet.has(c)) freeVars.push(c);
+  }
+
+  if (freeVars.length === 0) {
+    return xp.map((v, i) => v ? i : -1).filter(i => i >= 0);
+  }
+
+  // Null space vectors: nullVecs[k] is the null vector when free var k = 1
+  const nullVecs: number[][] = freeVars.map(fv => {
+    const vec = new Array(cols).fill(0);
+    vec[fv] = 1;
+    for (const pc of pivotCol) {
+      vec[pc] = aug[pivotRow[pc]][fv];
+    }
+    return vec;
+  });
+
+  return minWeightGF2(xp, nullVecs, cols);
+}
+
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const numLights = target.length;
+  const numButtons = buttons.length;
+
+  if (numButtons === 0) {
+    return target.every(t => !t) ? [] : null;
+  }
+
+  const matrix: number[][] = Array.from({ length: numLights }, () =>
+    new Array(numButtons).fill(0)
+  );
+
+  for (let b = 0; b < numButtons; b++) {
+    for (const light of buttons[b]) {
+      if (light < numLights) {
+        matrix[light][b] ^= 1;
+      }
+    }
+  }
+
+  return solveGF2(numLights, numButtons, matrix, target.map(t => t ? 1 : 0));
+}
