+/**
+ * Solve Ax = b over GF(2) using Gaussian elimination.
+ * Returns minimum Hamming weight solution, or null if no solution.
+ */
+function solveGF2(
+  numLights: number,
+  numButtons: number,
+  matrix: number[][],
+  target: number[]
+): number[] | null {
+  const rows = numLights;
+  const cols = numButtons;
+
+  if (cols === 0) {
+    return target.every(t => t === 0) ? [] : null;
+  }
+
+  // Augmented matrix [A | b]
+  const aug: number[][] = Array.from({ length: rows }, (_, r) => {
+    const row = matrix[r].slice();
+    row.push(target[r]);
+    return row;
+  });
+
+  const pivotRow: number[] = new Array(cols).fill(-1);
+  const pivotCol: number[] = [];
+  let curRow = 0;
+
+  for (let col = 0; col < cols && curRow < rows; col++) {
+    let found = -1;
+    for (let r = curRow; r < rows; r++) {
+      if (aug[r][col] === 1) { found = r; break; }
+    }
+    if (found === -1) continue;
+
+    [aug[curRow], aug[found]] = [aug[found], aug[curRow]];
+    pivotRow[col] = curRow;
+    pivotCol.push(col);
+
+    for (let r = 0; r < rows; r++) {
+      if (r !== curRow && aug[r][col] === 1) {
+        for (let c = 0; c <= cols; c++) aug[r][c] ^= aug[curRow][c];
+      }
+    }
+    curRow++;
+  }
+
+  // Inconsistency check
+  for (let r = 0; r < rows; r++) {
+    let allZero = true;
+    for (let c = 0; c < cols; c++) {
+      if (aug[r][c] !== 0) { allZero = false; break; }
+    }
+    if (allZero && aug[r][cols] === 1) return null;
+  }
