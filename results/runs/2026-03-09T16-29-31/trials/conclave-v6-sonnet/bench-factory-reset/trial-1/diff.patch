 indices.length;\n          bestIndices = indices;\n        }\n      }\n      if (bestWeight === 0) break;\n    }\n  }\n\n  return bestIndices;\n}\n\n/**\n * Direct enumeration for numFree <= 24.\n */\nfunction minWeightEnumerate(\n  xp: number[],\n  nullVecs: number[][],\n  cols: number,\n  numFree: number\n): number[] {\n  const totalCombinations = 1 << numFree;\n  let bestSolution: number[] = xp.map((v, i) => v ? i : -1).filter(i => i >= 0);\n  let bestWeight = bestSolution.length;\n\n  for (let mask = 1; mask < totalCombinations; mask++) {\n    const x = xp.slice();\n    for (let k = 0; k < numFree; k++) {\n      if ((mask >> k) & 1) {\n        for (let c = 0; c < cols; c++) {\n          x[c] ^= nullVecs[k][c];\n        }\n      }\n    }\n    const indices = x.map((v, i) => v ? i : -1).filter(i => i >= 0);\n    const weight = indices.length;\n\n    if (weight < bestWeight || (weight === bestWeight && lexSmaller(indices, bestSolution))) {\n      bestWeight = weight;\n      bestSolution = indices;\n    }\n    if (bestWeight === 0) break;\n  }\n\n  return bestSolution;\n}\n\n/**\n * Solve a system of linear equations over GF(2).\n * Returns the minimum-weight solution (fewest 1s), with lexicographic tiebreaking.\n */\nfunction solveGF2(\n  numLights: number,\n  numButtons: number,\n  matrix: number[][],\n  target: number[]\n): number[] | null {\n  const rows = numLights;\n  const cols = numButtons;\n\n  if (cols === 0) {\n    return target.every(t => t === 0) ? [] : null;\n  }\n\n  // Augmented matrix [A | b]\n  const aug: number[][] = Array.from({ length: rows }, (_, r) => {\n    const row = matrix[r].slice();\n    row.push(target[r]);\n    return row;\n  });\n\n  // Gaussian elimination over GF(2) (reduced row echelon form)\n  const pivotRow: number[] = new Array(cols).fill(-1);\n  const pivotCol: number[] = [];\n  let curRow = 0;\n\n  for (let col = 0; col < cols && curRow < rows; col++) {\n    let found = -1;\n    for (let r = curRow; r < rows; r++) {\n      if (aug[r][col] === 1) { found = r; break; }\n    }\n    if (found === -1) continue;\n\n    [aug[curRow], aug[found]] = [aug[found], aug[curRow]];\n    pivotRow[col] = curRow;\n    pivotCol.push(col);\n\n    for (let r = 0; r < rows; r++) {\n      if (r !== curRow && aug[r][col] === 1) {\n        for (let c = 0; c <= cols; c++) {\n          aug[r][c] ^= aug[curRow][c];\n        }\n      }\n    }\n    curRow++;\n  }\n\n  // Inconsistency check\n  for (let r = 0; r < rows; r++) {\n    let allZero = true;\n    for (let c = 0; c < cols; c++) {\n      if (aug[r][c] !== 0) { allZero = false; break; }\n    }\n    if (allZero && aug[r][cols] === 1) return null;\n  }\n\n  // Particular solution (free vars = 0)\n  const xp: number[] = new Array(cols).fill(0);\n  for (const pc of pivotCol) {\n    const pr = pivotRow[pc];\n    xp[pc] = aug[pr][cols];\n  }\n\n  // Free variables\n  const pivotSet = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let c = 0; c < cols; c++) {\n    if (!pivotSet.has(c)) freeVars.push(c);\n  }\n\n  if (freeVars.length === 0) {\n    return xp.map((v, i) => v ? i : -1).filter(i => i >= 0);\n  }\n\n  // Null space vectors\n  const nullVecs: number[][] = freeVars.map(fv => {\n    const vec = new Array(cols).fill(0);\n    vec[fv] = 1;\n    for (const pc of pivotCol) {\n      const pr = pivotRow[pc];\n      vec[pc] = aug[pr][fv];\n    }\n    return vec;\n  });\n\n  return minWeightGF2(xp, nullVecs, cols);\n}\n\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const numLights = target.length;\n  const numButtons = buttons.length;\n\n  if (numButtons === 0) {\n    return target.every(t => !t) ? [] : null;\n  }\n\n  const matrix: number[][] = Array.from({ length: numLights }, () =>\n    new Array(numButtons).fill(0)\n  );\n\n  for (let b = 0; b < numButtons; b++) {\n    for (const light of buttons[b]) {\n      if (light < numLights) {\n        matrix[light][b] ^= 1;\n      }\n    }\n  }\n\n  const targetVec = target.map(t => t ? 1 : 0);\n  return solveGF2(numLights, numButtons, matrix, targetVec);\n}\n\n// --- GF(p) solver ---\n\nfunction modInverse(a: number, p: number): number {\n  a = ((a % p) + p) % p;\n  let [old_r, r] = [a, p];\n  let [old_s, s] = [1, 0];\n  while (r !== 0) {\n    const q = Math.floor(old_r / r);\n    [old_r, r] = [r, old_r - q * r];\n    [old_s, s] = [s, old_s - q * s];\n  }\n  return ((old_s % p) + p) % p;\n}\n\n/**\n * Solve Ax = b over GF(p) (p prime).\n * Returns minimum total presses solution, lexicographic tiebreak.\n */\nfunction solveGFp(\n  numLights: number,\n  numButtons: number,\n  matrix: number[][],\n  target: number[],\n  p: number\n): number[] | null {\n  const rows = numLights;\n  const cols = numButtons;\n\n  if (cols === 0) {\n    return target.every(t => t === 0) ? [] : null;\n  }\n\n  const mod = (x: number) => ((x % p) + p) % p;\n\n  const aug: number[][] = Array.from({ length: rows }, (_, r) => {\n    const row = matrix[r].slice();\n    row.push(mod(target[r]));\n    return row;\n  });\n\n  const pivotRow: number[] = new Array(cols).fill(-1);\n  const pivotCol: number[] = [];\n  let curRow = 0;\n\n  for (let col = 0; col < cols && curRow < rows; col++) {\n    let found = -1;\n    for (let r = curRow; r < rows; r++) {\n      if (aug[r][col] !== 0) { found = r; break; }\n    }\n    if (found === -1) continue;\n\n    [aug[curRow], aug[found]] = [aug[found], aug[curRow]];\n\n    const inv = modInverse(aug[curRow][col], p);\n    for (let c = 0; c <= cols; c++) {\n      aug[curRow][c] = mod(aug[curRow][c] * inv);\n    }\n\n    pivotRow[col] = curRow;\n    pivotCol.push(col);\n\n    for (let r = 0; r < rows; r++) {\n      if (r !== curRow && aug[r][col] !== 0) {\n        const factor = aug[r][col];\n        for (let c = 0; c <= cols; c++) {\n          aug[r][c] = mod(aug[r][c] - factor * aug[curRow][c]);\n        }\n      }\n    }\n    curRow++;\n  }\n\n  // Inconsistency check\n  for (let r = 0; r < rows; r++) {\n    let allZero = true;\n    for (let c = 0; c < cols; c++) {\n      if (aug[r][c] !== 0) { allZero = false; break; }\n    }\n    if (allZero && aug[r][cols] !== 0) return null;\n  }\n\n  const pivotSet = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let c = 0; c < cols; c++) {\n    if (!pivotSet.has(c)) freeVars.push(c);\n  }\n\n  const numFree = freeVars.length;\n\n  // Particular solution (free vars = 0)\n  const xp: number[] = new Array(cols).fill(0);\n  for (const pc of pivotCol) {\n    xp[pc] = aug[pivotRow[pc]][cols];\n  }\n\n  if (numFree === 0) {\n    return xp;\n  }\n\n  // Null space: for each free var fv set to 1, the null vector\n  const nullMat: number[][] = freeVars.map(fv => {\n    const vec = new Array(cols).fill(0);\n    vec[fv] = 1;\n    for (const pc of pivotCol) {\n      vec[pc] = mod(-(aug[pivotRow[pc]][fv]));\n    }\n    return vec;\n  });\n\n  // Compute x from free variable values\n  const computeX = (freeVals: number[]): number[] => {\n    const x = xp.slice();\n    for (let k = 0; k < numFree; k++) {\n      if (freeVals[k] === 0) continue;\n      for (let c = 0; c < cols; c++) {\n        x[c] = mod(x[c] + freeVals[k] * nullMat[k][c]);\n      }\n    }\n    return x;\n  };\n\n  let bestSol: number[] = xp.slice();\n  let bestSum = xp.reduce((a, b) => a + b, 0);\n\n  // Determine enumeration feasibility\n  // p^numFree total combinations\n  // Safe to enumerate if p^numFree <= 2M\n  let totalCombinations = 1;\n  let canEnumerate = true;\n  for (let i = 0; i < numFree; i++) {\n    totalCombinations *= p;\n    if (totalCombinations > 2_000_000) { canEnumerate = false; break; }\n  }\n\n  if (canEnumerate) {\n    // Full enumeration via odometer\n    const freeVals = new Array(numFree).fill(0);\n    while (true) {\n      const x = computeX(freeVals);\n      const sum = x.reduce((a, b) => a + b, 0);\n      if (sum < bestSum || (sum === bestSum && lexSmaller(x, bestSol))) {\n        bestSum = sum;\n        bestSol = x;\n      }\n\n      // Increment odometer\n      let carry = 1;\n      for (let k = numFree - 1; k >= 0 && carry; k--) {\n        freeVals[k] += carry;\n        if (freeVals[k] >= p) {\n          freeVals[k] = 0;\n          carry = 1;\n        } else {\n          carry = 0;\n        }\n      }\n      if (carry) break; // All combinations done\n    }\n  } else {\n    // Coordinate descent: for each free variable, find the best value independently.\n    // Multiple passes for convergence.\n    const freeVals = new Array(numFree).fill(0);\n\n    for (let pass = 0; pass < 20; pass++) {\n      let improved = false;\n      for (let k = 0; k < numFree; k++) {\n        let bestV = freeVals[k];\n        let bestLocalSum = bestSum;\n        let bestLocalX = bestSol;\n\n        for (let v = 0; v < p; v++) {\n          freeVals[k] = v;\n          const nx = computeX(freeVals);\n          const ns = nx.reduce((a, b) => a + b, 0);\n          if (ns < bestLocalSum || (ns === bestLocalSum && lexSmaller(nx, bestLocalX))) {\n            bestLocalSum = ns;\n            bestLocalX = nx;\n            bestV = v;\n          }\n        }\n\n        freeVals[k] = bestV;\n        if (bestLocalSum < bestSum || (bestLocalSum === bestSum && lexSmaller(bestLocalX, bestSol))) {\n          bestSum = bestLocalSum;\n          bestSol = bestLocalX;\n          improved = true;\n        }\n      }\n      if (!improved) break;\n    }\n  }\n\n  return bestSol;\n}\n\nfunction lexSmaller(a: number[], b: number[]): boolean {\n  for (let i = 0; i < a.length && i < b.length; i++) {\n    if (a[i] < b[i]) return true;\n    if (a[i] > b[i]) return false;\n  }\n  return a.length < b.length;\n}\n\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const numLights = lights.length;\n  const numButtons = buttons.length;\n\n  if (numButtons === 0) {\n    return lights.every(l => l === 0) ? [] : null;\n  }\n\n  const matrix: number[][] = Array.from({ length: numLights }, () =>\n    new Array(numButtons).fill(0)\n  );\n\n  for (let b = 0; b < numButtons; b++) {\n    for (const light of buttons[b]) {\n      if (light < numLights) {\n        matrix[light][b] = (matrix[light][b] + 1) % modulus;\n      }\n    }\n  }\n\n  return solveGFp(numLights, numButtons, matrix, lights, modulus);\n}\n","structuredPatch":[{"oldStart":4,"oldLines":61,"newStart":4,"newLines":348,"lines":[" }"," "," /**","- * Solve a system of linear equations over GF(2).","- * A is (numLights × numButtons), b is the target vector.","- * Returns all solution vectors as arrays of 0/1 of length numButtons,","- * or null if no solution exists.","+ * Find minimum Hamming weight solution in an affine subspace of GF(2)^n.","  *","- * The system is: A * x = b (mod 2)","- * where x[j] ∈ {0,1} indicates whether button j is pressed.","+ * Given particular solution xp and null space vectors nullVecs, finds the","+ * combination mask (subset of null vecs to XOR in) that minimizes weight,","+ * with lexicographic tiebreaking on indices.","  *","- * Uses Gaussian elimination to find the solution space:","- * - A particular solution xp","- * - The null space (free variable combinations)","- *","- * Then enumerates all solutions (2^(num free vars)) to find","- * the one with minimum weight, breaking ties lexicographically.","+ * Uses meet-in-the-middle for large null spaces (up to 2*2^(numFree/2) work).","  */","+function minWeightGF2(","+  xp: number[],","+  nullVecs: number[][],","+  cols: number","+): number[] {","+  const numFree = nullVecs.length;","+","+  if (numFree === 0) {","+    return xp.map((v, i) => v ? i : -1).filter(i => i >= 0);","+  }","+","+  // For small numFree, direct enumeration","+  if (numFree <= 24) {","+    return minWeightEnumerate(xp, nullVecs, cols, numFree);","+  }","+","+  // Meet in the middle: split into left and right halves","+  const half = Math.floor(numFree / 2);","+  const leftVecs = nullVecs.slice(0, half);","+  const rightVecs = nullVecs.s