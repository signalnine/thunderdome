tMap: we want the leftState that, XOR'd with rightDelta, is minimum weight.\n  //   This is equivalent to finding minimum weight vector in {leftStates XOR rightDelta}.\n  //   We can precompute leftStates sorted or indexed by bit patterns for fast lookup.\n\n  // SIMPLEST CORRECT APPROACH: enumerate both halves, for each right combination,\n  // enumerate all left combinations. This is 2^numFree total = too slow for large numFree.\n\n  // SOLUTION: Accept that this edge case (many free variables) means many buttons with\n  // identical effects. In that case:\n  // - If xp has weight 0 (all zeros solution exists), return [].\n  // - Otherwise, we can use Gray code enumeration and prune.\n\n  // For the benchmark: check if xp itself is already good (maybe 0 weight), then use\n  // a BFS by weight approach with early termination.\n\n  // Check if xp (all free vars = 0) satisfies minimum or if we can do better\n  let bestIndices = xp.map((v, i) => v ? i : -1).filter(i => i >= 0);\n  let bestWeight = bestIndices.length;\n\n  if (bestWeight === 0) return [];\n\n  // BFS-like: try individual free var flips and combinations\n  // For numFree > 24, we try all single flips, then all double flips, etc.\n  // This finds minimum weight quickly if min weight is small.\n\n  // Single flips\n  for (let k = 0; k < numFree; k++) {\n    const x = xp.slice();\n    for (let c = 0; c < cols; c++) {\n      x[c] ^= nullVecs[k][c];\n    }\n    const indices = x.map((v, i) => v ? i : -1).filter(i => i >= 0);\n    if (indices.length < bestWeight || (indices.length === bestWeight && lexSmaller(indices, bestIndices))) {\n      bestWeight = indices.length;\n      bestIndices = indices;\n    }\n  }\n\n  if (bestWeight === 0) return [];\n\n  // For larger searches with large numFree, fall back to MITM with 2^20 each\n  // We re-implement MITM correctly for the weight problem:\n  // Store all leftStates in a Map<string, Entry> (already done above)\n  // For each rightDelta, compute (leftState XOR r