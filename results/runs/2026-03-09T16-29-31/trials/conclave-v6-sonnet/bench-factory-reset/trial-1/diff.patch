+import { describe, test, expect } from 'vitest';
+import { solveToggle } from '../src/index.js';
+
+describe('solveToggle', () => {
+  test('returns empty array when target is all off (trivial solution)', () => {
+    const machine = {
+      target: [false, false, false],
+      buttons: [[0], [1], [2]],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  test('single button matches single light', () => {
+    const machine = {
+      target: [true],
+      buttons: [[0]],
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  test('returns null when no solution exists', () => {
+    // Light 0 must be on, but no button affects light 0
+    const machine = {
+      target: [true],
+      buttons: [[1]],  // only affects light index 1, not 0
+    };
+    // target has 1 light (index 0), but button only toggles index 1 which is out of range
+    // Actually light index 1 doesn't exist in a 1-light system, but target[0]=true can't be satisfied
+    const machine2 = {
+      target: [true, false],
+      buttons: [[1]],  // only button toggles light 1, but target needs light 0 on
+    };
+    expect(solveToggle(machine2)).toBeNull();
+  });
+
+  test('returns null from the problem spec example', () => {
+    // From the spec: target [T,T,F,T] with buttons [0,1],[1,2,3],[0,3] has no solution
+    const machine = {
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  test('simple two-button solution', () => {
+    // Light 0: button 0 toggles it. Light 1: button 1 toggles it.
+    // Target [true, true]: press both buttons
+    const machine = {
+      target: [true, true],
+      buttons: [[0], [1]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0, 1]);
+  });
+
+  test('prefers fewer button presses', () => {
+    // Button 0 toggles light 0. Button 1 toggles light 0.
+    // Pressing either one achieves target [true].
+    // Pressing both gives [false] (wrong).
+    // Minimum is 1 press: [0] is lexicographically smaller than [1]
+    const machine = {
+      target: [true],
+      buttons: [[0], [0]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0]);
+  });
+
+  test('lexicographically smallest among equal-count solutions', () => {
+    // Two lights. Button 0 toggles [0,1]. Button 1 toggles [0,1].
+    // Button 2 toggles [0]. Button 3 toggles [1].
+    // Target [true, true]:
+    //   - Press 0: [on,on] → 1 button, indices [0] ✓
+    //   - Press 1: [on,on] → 1 button, indices [1]
+    //   - Press 2 and 3: [on,on] → 2 buttons
+    // Minimum: 1 button, lexicographically smallest is [0]
+    const machine = {
+      target: [true, true],
+      buttons: [[0, 1], [0, 1], [0], [1]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0]);
+  });
+
+  test('multiple buttons needed, correct order', () => {
+    // Light 0: needs buttons 0 XOR some combo
+    // Use a 3-light system: b0=[0,1], b1=[1,2], b2=[0,2]
+    // Solve for target [true, false, true]:
+    // light 0: b0 XOR b2 = 1
+    // light 1: b0 XOR b1 = 0
+    // light 2: b1 XOR b2 = 1
+    // From light1: b0=b1. From light0: b0 XOR b2=1. From light2: b1 XOR b2=1
+    // If b0=0,b1=0: b2=1 from light0. light2: 0 XOR 1=1 ✓  → solution: {2}
+    // If b0=1,b1=1: b2=0 from light0. light2: 1 XOR 0=1 ✓  → solution: {0,1}
+    // Minimum is 1 press: [2]
+    const machine = {
+      target: [true, false, true],
+      buttons: [[0, 1], [1, 2], [0, 2]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([2]);
+  });
+
+  test('handles no buttons with all-off target', () => {
+    const machine = {
+      target: [false, false],
+      buttons: [],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  test('handles no buttons with non-trivial target (null)', () => {
+    const machine = {
+      target: [true, false],
+      buttons: [],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  test('handles solution with free variables - picks minimum presses', () => {
+    // All buttons toggle all lights. Target: [true, true].
+    // Any single button press achieves it.
+    // b0 XOR b1 XOR b2 = 1 (for each light)
+    // Solutions: press exactly 1 button (any of 3), or press all 3
+    // Minimum: 1 press, smallest index: [0]
+    const machine = {
+      target: [true, true],
+      buttons: [[0, 1], [0, 1], [0, 1]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0]);
+  });
+
+  test('larger system with known solution', () => {
+    // 5 lights, target all on
+    // Button i toggles only light i
+    const machine = {
+      target: [true, true, true, true, true],
+      buttons: [[0], [1], [2], [3], [4]],
+    };
+    expect(solveToggle(machine)).toEqual([0, 1, 2, 3, 4]);
+  });
+});
