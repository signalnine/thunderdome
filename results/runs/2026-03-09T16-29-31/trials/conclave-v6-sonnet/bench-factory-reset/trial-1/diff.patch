+    const x = xp.slice();
+    for (let k = 0; k < numFree; k++) {
+      if (freeVals[k] === 0) continue;
+      for (let c = 0; c < cols; c++) {
+        x[c] = mod(x[c] + freeVals[k] * nullMat[k][c]);
+      }
+    }
+    return x;
+  };
+
+  let bestSol: number[] = xp.slice();
+  let bestSum = xp.reduce((a, b) => a + b, 0);
+
+  // Enumerate if feasible: p^numFree <= 2M
+  let totalCombinations = 1;
+  let canEnumerate = true;
+  for (let i = 0; i < numFree; i++) {
+    totalCombinations *= p;
+    if (totalCombinations > 2_000_000) { canEnumerate = false; break; }
+  }
+
+  if (canEnumerate) {
+    // Odometer enumeration over all free variable combinations
+    const freeVals = new Array(numFree).fill(0);
+    let done = false;
+    while (!done) {
+      const x = computeX(freeVals);
+      const sum = x.reduce((a, b) => a + b, 0);
+      if (sum < bestSum || (sum === bestSum && lexSmaller(x, bestSol))) {
+        bestSum = sum;
+        bestSol = x;
+      }
+
+      // Increment odometer (last digit first)
+      let carry = 1;
+      for (let k = numFree - 1; k >= 0 && carry; k--) {
+        freeVals[k]++;
+        if (freeVals[k] >= p) { freeVals[k] = 0; } else { carry = 0; }
+      }
+      if (carry) done = true;
+    }
+  } else {
+    // Coordinate descent: optimize each free variable in turn, repeat until stable.
+    // May not find global optimum but is fast and effective for well-structured problems.
+    const freeVals = new Array(numFree).fill(0);
+
+    for (let pass = 0; pass < 20; pass++) {
+      let improved = false;
+      for (let k = 0; k < numFree; k++) {
+        let bestV = freeVals[k];
+        let bestLocalSum = bestSum;
+        let bestLocalX = bestSol;
+
+        for (let v = 0; v < p; v++) {
+          freeVals[k] = v;
+          const nx = computeX(freeVals);
+          const ns = nx.reduce((a, b) => a + b, 0);
+          if (ns < bestLocalSum || (ns === bestLocalSum && lexSmaller(nx, bestLocalX))) {
+            bestLocalSum = ns;
+            bestLocalX = nx;
+            bestV = v;
+          }
+        }
+
+        freeVals[k] = bestV;
+        if (bestLocalSum < bestSum || (bestLocalSum === bestSum && lexSmaller(bestLocalX, bestSol))) {
+          bestSum = bestLocalSum;
+          bestSol = bestLocalX;
+          improved = true;
+        }
+      }
+      if (!improved) break;
+    }
+  }
+
+  return bestSol;
+}
+
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numLights = lights.length;
+  const numButtons = buttons.length;
+
+  if (numButtons === 0) {
+    return lights.every(l => l === 0) ? [] : null;
+  }
+
+  const matrix: number[][] = Array.from({ length: numLights }, () =>
+    new Array(numButtons).fill(0)
+  );
+
+  for (let b = 0; b < numButtons; b++) {
+    for (const light of buttons[b]) {
+      if (light < numLights) {
+        matrix[light][b] = (matrix[light][b] + 1) % modulus;
+      }
+    }
+  }
+
+  return solveGFp(numLights, numButtons, matrix, lights, modulus);
+}
