+import { describe, test, expect } from 'vitest';
+import { solveCounter } from '../src/index.js';
+
+describe('solveCounter', () => {
+  test('all zeros target returns all zeros presses', () => {
+    const result = solveCounter([0, 0, 0], [[0], [1], [2]], 5);
+    expect(result).toEqual([0, 0, 0]);
+  });
+
+  test('single button, single counter, press once', () => {
+    const result = solveCounter([1], [[0]], 5);
+    expect(result).toEqual([1]);
+  });
+
+  test('single button pressed multiple times', () => {
+    const result = solveCounter([3], [[0]], 5);
+    expect(result).toEqual([3]);
+  });
+
+  test('no solution returns null - unreachable target', () => {
+    // Counter 0 needs to reach 1, but button only affects counter 1
+    const result = solveCounter([1, 0], [[1]], 5);
+    expect(result).toBeNull();
+  });
+
+  test('two buttons, two independent counters', () => {
+    // Button 0 increments counter 0. Button 1 increments counter 1.
+    const result = solveCounter([2, 3], [[0], [1]], 5);
+    expect(result).toEqual([2, 3]);
+  });
+
+  test('button affects multiple counters', () => {
+    // Button 0 increments counters [0, 1]. Target [2, 2], mod 5.
+    const result = solveCounter([2, 2], [[0, 1]], 5);
+    expect(result).toEqual([2]);
+  });
+
+  test('two buttons each affecting multiple counters', () => {
+    // b0 affects [0,1], b1 affects [1,2].
+    // counter 0: b0 = 1, counter 1: b0+b1 = 2, counter 2: b1 = 1
+    // So b0=1, b1=1 satisfies [1,2,1]
+    const result = solveCounter([1, 2, 1], [[0, 1], [1, 2]], 5);
+    expect(result).toEqual([1, 1]);
+  });
+
+  test('prime modulus 7 - basic', () => {
+    const result = solveCounter([3, 5], [[0], [1]], 7);
+    expect(result).toEqual([3, 5]);
+  });
+
+  test('prime modulus 7 - needs mod inverse to solve', () => {
+    // Button 0 increments counters [0, 1].
+    // Button 1 increments counter 0.
+    // counter 1: b0 = 3, so b0 = 3
+    // counter 0: b0 + b1 = 0 (mod 7), so 3 + b1 = 0 → b1 = 4
+    const result = solveCounter([0, 3], [[0, 1], [0]], 7);
+    expect(result).toEqual([3, 4]);
+  });
+
+  test('no buttons with zero target returns empty array', () => {
+    const result = solveCounter([0, 0], [], 5);
+    expect(result).toEqual([]);
+  });
+
+  test('no buttons with nonzero target returns null', () => {
+    const result = solveCounter([1, 0], [], 5);
+    expect(result).toBeNull();
+  });
+
+  test('free variable - minimum total presses chosen', () => {
+    // Two buttons that both increment counter 0 by 1.
+    // Target [1], mod 5. b0 + b1 = 1 (mod 5).
+    // Solutions with minimum sum=1: (b0=0,b1=1) and (b0=1,b1=0)
+    // Lexicographically, [0,1] < [1,0]
+    const result = solveCounter([1], [[0], [0]], 5);
+    expect(result).toEqual([0, 1]);
+  });
+
+  test('larger system with prime 11', () => {
+    // Diagonal: each button i only affects counter i
+    const result = solveCounter([1, 2, 3], [[0], [1], [2]], 11);
+    expect(result).toEqual([1, 2, 3]);
+  });
+
+  test('solution correctness: verifies output satisfies equations', () => {
+    const lights = [2, 4, 1];
+    const buttons = [[0, 1], [1, 2], [0, 2]];
+    const modulus = 5;
+    const result = solveCounter(lights, buttons, modulus);
+    expect(result).not.toBeNull();
+    if (result) {
+      const actual = new Array(lights.length).fill(0);
+      for (let b = 0; b < buttons.length; b++) {
+        for (const l of buttons[b]) {
+          actual[l] = (actual[l] + result[b]) % modulus;
+        }
+      }
+      expect(actual).toEqual(lights);
+    }
+  });
+
+  test('modulus 2 behaves like toggle (mod 2) - solvable', () => {
+    // With modulus=2, each button is pressed 0 or 1 times
+    // counter0: b0+b2=1, counter1: b0+b1=1, counter2: b1+b2=0
+    // b1=b2 from eq2. b0+b1=1 from eq0. b0+b1=1 from eq1. Consistent.
+    // Solution: b0=1,b1=0,b2=0 → [1,0,0]
+    const result = solveCounter([1, 1, 0], [[0, 1], [1, 2], [0, 2]], 2);
+    expect(result).toEqual([1, 0, 0]);
+  });
+
+  test('modulus 2 - truly unsolvable case', () => {
+    // 2 counters, 1 button affecting both. Target [1, 0].
+    // b0=1 for counter0, but b0=0 for counter1. Contradiction.
+    const result = solveCounter([1, 0], [[0, 1]], 2);
+    expect(result).toBeNull();
+  });
+
+  test('modulus 2 - solvable case', () => {
+    // counter0: b0=1 → b0=1
+    // counter1: b1=1 → b1=1
+    const result = solveCounter([1, 1], [[0], [1]], 2);
+    expect(result).toEqual([1, 1]);
+  });
+
+  test('prime 3 - value 2 is the efficient choice', () => {
+    // Target counter 0 = 2, mod 3. Button 0 increments counter 0.
+    // Press 2 times (not 3+2=5 times).
+    const result = solveCounter([2], [[0]], 3);
+    expect(result).toEqual([2]);
+  });
+
+  test('underdetermined system - minimum sum solution chosen', () => {
+    // 1 light, 3 buttons all incrementing it. Target=1, mod 5.
+    // b0+b1+b2=1 (mod 5). Minimum sum solutions:
+    // sum=1: [1,0,0], [0,1,0], [0,0,1] → lex smallest is [0,0,1]
+    const result = solveCounter([1], [[0], [0], [0]], 5);
+    // With Gaussian elimination, button 0 is pivot (free vars are b1, b2).
+    // xp: b0=1, b1=0, b2=0 → [1,0,0] sum=1
+    // Can also do: b0=0, b1=0, b2=1 → [0,0,1] sum=1 lex smaller
+    // Can also do: b0=0, b1=1, b2=0 → [0,1,0] sum=1
+    // Lex smallest among sum=1 solutions: [0,0,1]
+    expect(result).toEqual([0, 0, 1]);
+  });
+
+  test('large prime modulus 97', () => {
+    // Simple case: each button increments its own counter
+    const result = solveCounter([50, 75, 30], [[0], [1], [2]], 97);
+    expect(result).toEqual([50, 75, 30]);
+  });
+
+  test('solution uses mod arithmetic correctly for large values', () => {
+    // Target 0, mod 97, button increments counter 0 by 1.
+    // Press 0 times (minimum), not 97.
+    const result = solveCounter([0], [[0]], 97);
+    expect(result).toEqual([0]);
+  });
+});
