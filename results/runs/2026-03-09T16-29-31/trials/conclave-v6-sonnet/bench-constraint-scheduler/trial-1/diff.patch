V5sKmDlBKWIYbA3lRb2PTHACE0mgKwA8yQ2xq9vxDTuk4iPrECBAEW2aoFXY0Q==\",\n       \"dev\": true,\n       \"license\": \"MIT\",\n-      \"peer\": true,\n       \"dependencies\": {\n         \"@vitest/expect\": \"2.1.9\",\n         \"@vitest/mocker\": \"2.1.9\",\ndiff --git a/src/index.ts b/src/index.ts\nnew file mode 100644\nindex 0000000..36a9bd8\n--- /dev/null\n+++ b/src/index.ts\n@@ -0,0 +1,299 @@\n+export interface Event {\n+  id: string;\n+  name: string;\n+  duration: number;\n+  attendees?: number;\n+  prerequisites?: string[];\n+  preferredRoom?: string;\n+}\n+\n+export interface Room {\n+  id: string;\n+  name: string;\n+  capacity: number;\n+}\n+\n+export interface ScheduleOptions {\n+  startTime: number;\n+  endTime: number;\n+  gap?: number;\n+}\n+\n+export interface Assignment {\n+  eventId: string;\n+  roomId: string;\n+  startTime: number;\n+  endTime: number;\n+}\n+\n+export interface ScheduleResult {\n+  assignments: Assignment[];\n+  unscheduled: string[];\n+}\n+\n+/**\n+ * Detect cycles in the prerequisite graph using DFS.\n+ * Throws if any cycle (including self-reference) is found.\n+ */\n+function detectCycles(events: Event[]): void {\n+  const graph = new Map<string, string[]>();\n+  for (const event of events) {\n+    graph.set(event.id, event.prerequisites ?? []);\n+  }\n+\n+  const WHITE = 0, GRAY = 1, BLACK = 2;\n+  const color = new Map<string, number>();\n+  for (const id of graph.keys()) {\n+    color.set(id, WHITE);\n+  }\n+\n+  function dfs(id: string): void {\n+    color.set(id, GRAY);\n+    for (const dep of graph.get(id) ?? []) {\n+      if (color.get(dep) === GRAY) {\n+        throw new Error(`Prerequisite cycle detected involving event \"${dep}\"`);\n+      }\n+      if (color.get(dep) === WHITE) {\n+        dfs(dep);\n+      }\n+    }\n+    color.set(id, BLACK);\n+  }\n+\n+  for (const id of graph.keys()) {\n+    if (color.get(id) === WHITE) {\n+      dfs(id);\n+    }\n+  }\n+}\n+\n+/**\n+ * Topologically sort events so prerequisites come first.\n+ * Returns event IDs in a valid processing order.\n+ */\n+function topologicalSort(events: Event[]): string[] {\n+  const inDegree = new Map<string, number>();\n+  const dependents = new Map<string, string[]>(); // prereq -> events that need it\n+\n+  for (const event of events) {\n+    if (!inDegree.has(event.id)) inDegree.set(event.id, 0);\n+    for (const dep of event.prerequisites ?? []) {\n+      if (!dependents.has(dep)) dependents.set(dep, []);\n+      dependents.get(dep)!.push(event.id);\n+      inDegree.set(event.id, (inDegree.get(event.id) ?? 0) + 1);\n+    }\n+  }\n+\n+  const queue: string[] = [];\n+  for (const [id, deg] of inDegree) {\n+    if (deg === 0) queue.push(id);\n+  }\n+\n+  const result: string[] = [];\n+  while (queue.length > 0) {\n+    const id = queue.shift()!;\n+    result.push(id);\n+    for (const dependent of dependents.get(id) ?? []) {\n+      const newDeg = (inDegree.get(dependent) ?? 0) - 1;\n+      inDegree.set(dependent, newDeg);\n+      if (newDeg === 0) queue.push(dependent);\n+    }\n+  }\n+\n+  return result;\n+}\n+\n+/**\n+ * Find the earliest start time for an event in a specific room,\n+ * given the room's existing assignments and the event's earliest allowed start.\n+ */\n+function findEarliestSlot(\n+  roomAssignments: Assignment[],\n+  duration: number,\n+  earliestStart: number,\n+  latestEnd: number,\n+  gap: number,\n+): number | null {\n+  // Sort existing assignments in this room by start time\n+  const sorted = [...roomAssignments].sort((a, b) => a.startTime - b.startTime);\n+\n+  // Try to place before any existing assignment or in gaps between them\n+  let candidateStart = earliestStart;\n+\n+  for (const existing of sorted) {\n+    // If the event fits before this existing assignment\n+    if (candidateStart + duration <= existing.startTime - gap || candidateStart >= existing.startTime) {\n+      // Check if it fits before the existing assignment\n+      if (candidateStart + duration <= existing.startTime - gap) {\n+        // Fits in this gap\n+        if (candidateStart + duration <= latestEnd) {\n+          return candidateStart;\n+        }\n+      }\n+    }\n+    // Move candidate past this assignment\n+    const afterExisting = existing.endTime + gap;\n+    if (afterExisting > candidateStart) {\n+      candidateStart = afterExisting;\n+    }\n+  }\n+\n+  // Try after all existing assignments\n+  if (candidateStart + duration <= latestEnd) {\n+    return candidateStart;\n+  }\n+\n+  return null;\n+}\n+\n+/**\n+ * Attempt to schedule a single event into the best available room slot.\n+ * Returns an Assignment or null if no valid slot exists.\n+ * Respects preferredRoom hint.\n+ */\n+function tryScheduleEvent(\n+  event: Event,\n+  rooms: Room[],\n+  roomAssignments: Map<string, Assignment[]>,\n+  earliestStart: number,\n+  options: ScheduleOptions,\n+): Assignment | null {\n+  const gap = options.gap ?? 15;\n+  const attendees = event.attendees ?? 1;\n+\n+  // Build candidate rooms: preferred first, then others by smallest capacity (most specific fit)\n+  const eligible = rooms.filter(r => r.capacity >= attendees);\n+  if (eligible.length === 0) return null;\n+\n+  const preferred = event.preferredRoom\n+    ? eligible.filter(r => r.id === event.preferredRoom)\n+    : [];\n+  const others = eligible.filter(r => r.id !== event.preferredRoom);\n+  // Sort others by capacity ascending (use smallest fitting room first)\n+  others.sort((a, b) => a.capacity - b.capacity);\n+\n+  const candidates = [...preferred, ...others];\n+\n+  for (const room of candidates) {\n+    const assignments = roomAssignments.get(room.id) ?? [];\n+    const slot = findEarliestSlot(\n+      assignments,\n+      event.duration,\n+      earliestStart,\n+      options.endTime,\n+      gap,\n+    );\n+    if (slot !== null) {\n+      return {\n+        eventId: event.id,\n+        roomId: room.id,\n+        startTime: slot,\n+        endTime: slot + event.duration,\n+      };\n+    }\n+  }\n+\n+  return null;\n+}\n+\n+/**\n+ * Schedule all events, maximizing the number scheduled.\n+ *\n+ * Strategy:\n+ * 1. Detect prerequisite cycles (throw if found).\n+ * 2. Topologically sort to ensure prerequisites are scheduled before dependents.\n+ * 3. Use a greedy approach with backtracking-light optimization:\n+ *    - Process events in topological order.\n+ *    - For each event, find the earliest valid slot respecting all constraints.\n+ *    - Events that can't be placed go to `unscheduled`.\n+ *\n+ * For maximization, we try shorter events first within the same topological level\n+ * (events with no mutual dependencies), as smaller events are easier to pack.\n+ */\n+export function schedule(\n+  events: Event[],\n+  rooms: Room[],\n+  options: ScheduleOptions,\n+): ScheduleResult {\n+  if (events.length === 0) {\n+    return { assignments: [], unscheduled: [] };\n+  }\n+\n+  // Step 1: Detect cycles\n+  detectCycles(events);\n+\n+  const gap = options.gap ?? 15;\n+  const eventMap = new Map<string, Event>(events.map(e => [e.id, e]));\n+\n+  // Step 2: Topological sort to get processing order\n+  const topoOrder = topologicalSort(events);\n+\n+  // We'll try to maximize by sorting same-level events by duration (shorter first)\n+  // Build levels from topo order using prerequisite depth\n+  const depth = new Map<string, number>();\n+  for (const id of topoOrder) {\n+    const event = eventMap.get(id)!;\n+    const prereqDepths = (event.prerequisites ?? []).map(p => depth.get(p) ?? 0);\n+    depth.set(id, prereqDepths.length > 0 ? Math.max(...prereqDepths) + 1 : 0);\n+  }\n+\n+  // Sort: by depth (topo level) first, then by duration ascending within same level\n+  const sortedIds = [...topoOrder].sort((a, b) => {\n+    const depthDiff = (depth.get(a) ?? 0) - (depth.get(b) ?? 0);\n+    if (depthDiff !== 0) return depthDiff;\n+    return (eventMap.get(a)!.duration) - (eventMap.get(b)!.duration);\n+  });\n+\n+  // Step 3: Greedy scheduling\n+  const roomAssignments = new Map<string, Assignment[]>();\n+  for (const room of rooms) {\n+    roomAssignments.set(room.id, []);\n+  }\n+\n+  const scheduledMap = new Map<string, Assignment>(); // eventId -> assignment\n+  const unscheduled: string[] = [];\n+\n+  for (const eventId of sortedIds) {\n+    const event = eventMap.get(eventId)!;\n+\n+    // Check if any prerequisite was unscheduled\n+    const prereqUnscheduled = (event.prerequisites ?? []).some(\n+      pid => unscheduled.includes(pid),\n+    );\n+    if (prereqUnscheduled) {\n+      unscheduled.push(eventId);\n+      continue;\n+    }\n+\n+    // Determine earliest start: max of window start and (latest prereq end + gap)\n+    let earliestStart = options.startTime;\n+    for (const prereqId of event.prerequisites ?? []) {\n+      const prereqAssignment = scheduledMap.get(prereqId);\n+      if (prereqAssignment) {\n+        earliestStart = Math.max(earliestStart, prereqAssignment.endTime + gap);\n+      }\n+    }\n+\n+    const assignment = tryScheduleEvent(\n+      event,\n+      rooms,\n+      roomAssignments,\n+      earliestStart,\n+      options,\n+    );\n+\n+    if (assignment) {\n+      scheduledMap.set(eventId, assignment);\n+      roomAssignments.get(assignment.roomId)!.push(assignment);\n+    } else {\n+      unscheduled.push(eventId);\n+    }\n+  }\n+\n+  return {\n+    assignments: [...scheduledMap.values()],\n+    unscheduled,\n+  };\n+}\n+\n+export default schedule;\ndiff --git a/src/scheduler.test.ts b/src/scheduler.test.ts\nnew file mode 100644\nindex 0000000..d0fef67\n--- /dev/null\n+++ b/src/scheduler.test.ts\n@@ -0,0 +1,333 @@\n+import { describe, test, expect } from 'vitest';\n+import { schedule } from './index.js';\n+import type { Event, Room, ScheduleOptions } from './index.js';\n+\n+const defaultOptions: ScheduleOptions = {\n+  startTime: 540,  // 9:00 AM\n+  endTime: 1020,   // 5:00 PM\n+  gap: 15,\n+};\n+\n+const smallRoom: Room = { id: 'r1', name: 'Small Room', capacity: 10 };\n+const bigRoom: Room = { id: 'r2', name: 'Big Room', capacity: 50 };\n+\n+// ─── Cycle Detection ─────────────────────────────────────────────────────────\n+\n+describe('cycle detection', () => {\n+  test('throws on self-referencing prerequisite', () => {\n+    const events: Event[] = [\n+      { id: 'A', name: 'Event A', duration: 30, prerequisites: ['A'] },\n+    ];\n+    expect(() => schedule(events, [smallRoom], defaultOptions)).toThrow();\n+  });\n+\n+  test('throws on two-event cycle', () => {\n+    const events: Event[] = [\n+      { id: 'A', name: 'Event A', duration: 30, prerequisites: ['B'] },\n+      { id: 'B', name: 'Event B', duration: 30, prerequisites: ['A'] },\n+    ];\n+    expect(() => schedule(events, [smallRoom], defaultOptions)).toThrow();\n+  });\n+\n+  test('throws on three-event cycle', () => {\n+    const events: Event[] = [\n+      { id: 'A', name: 'Event A', duration: 30, prerequisites: ['C'] },\n+      { id: 'B', name: 'Event B', duration: 30, prerequisites: ['A'] },\n+      { id: 'C', name: 'Event C', duration: 30, prerequisites: ['B'] },\n+    ];\n+    expect(() => schedule(events, [smallRoom], defaultOptions)).toThrow();\n+  });\n+\n+  test('does not throw on valid DAG', () => {\n+    const events: Event[] = [\n+      { id: 'A', name: 'Event A', duration: 30 },\n+      { id: 'B', name: 'Event B', duration: 30, prerequisites: ['A'] },\n+      { id: 'C', name: 'Event C', duration: 30, prerequisites: ['A'] },\n+      { id: 'D', name: 'Event D', duration: 30, prerequisites: ['B', 'C'] },\n+    ];\n+    expect(() => schedule(events, [smallRoom], defaultOptions)).not.toThrow();\n+  });\n+});\n+\n+// ─── Basic Scheduling ─────────────────────────────────────────────────────────\n+\n+describe('basic scheduling', () => {\n+  test('schedules a single event', () => {\n+    const events: Event[] = [\n+      { id: 'A', name: 'Event A', duration: 60 },\n+    ];\n+    const result = schedule(events, [smallRoom], defaultOptions);\n+    expect(result.assignments).toHaveLength(1);\n+    expect(result.unscheduled).toHaveLength(0);\n+    const a = result.assignments[0];\n+    expect(a.eventId).toBe('A');\n+    expect(a.roomId).toBe('r1');\n+    expect(a.startTime).toBeGreaterThanOrEqual(540);\n+    expect(a.endTime).toBeLessThanOrEqual(1020);\n+    expect(a.endTime - a.startTime).toBe(60);\n+  });\n+\n+  test('schedules multiple non-conflicting events', () => {\n+    const events: Event[] = [\n+      { id: 'A', name: 'Event A', duration: 60 },\n+      { id: 'B', name: 'Event B', duration: 60 },\n+    ];\n+    const result = schedule(events, [smallRoom], defaultOptions);\n+    expect(result.assignments).toHaveLength(2);\n+    expect(result.unscheduled).toHaveLength(0);\n+  });\n+\n+  test('rejects event exceeding room capacity', () => {\n+    const events: Event[] = [\n+      { id: 'A', name: 'Event A', duration: 60, attendees: 100 },\n+    ];\n+    const result = schedule(events, [smallRoom], defaultOptions);\n+    expect(result.unscheduled).toContain('A');\n+    expect(result.assignments).toHaveLength(0);\n+  });\n+\n+  test('places event in a room with sufficient capacity', () => {\n+    const events: Event[] = [\n+      { id: 'A', name: 'Event A', duration: 60, attendees: 40 },\n+    ];\n+    const result = schedule(events, [smallRoom, bigRoom], defaultOptions);\n+    expect(result.assignments).toHaveLength(1);\n+    expect(result.assignments[0].roomId).toBe('r2');\n+    expect(result.unscheduled).toHaveLength(0);\n+  });\n+\n+  test('rejects event that exceeds time window', () => {\n+    const events: Event[] = [\n+      // 480-minute duration = 8 hours, longer than 9-5 window\n+      { id: 'A', name: 'Event A', duration: 481 },\n+    ];\n+    const result = schedule(events, [smallRoom], defaultOptions);\n+    expect(result.unscheduled).toContain('A');\n+  });\n+\n+  test('enforces minimum gap between events in same room', () => {\n+    const events: Event[] = [\n+      { id: 'A', name: 'Event A', duration: 60 },\n+      { id: 'B', name: 'Event B', duration: 60 },\n+    ];\n+    const result = schedule(events, [smallRoom], defaultOptions);\n+    expect(result.assignments).toHaveLength(2);\n+    const assignments = result.assignments.sort((a, b) => a.startTime - b.startTime);\n+    const gap = assignments[1].startTime - assignments[0].endTime;\n+    expect(gap).toBeGreaterThanOrEqual(15);\n+  });\n+\n+  test('custom gap is respected', () => {\n+    const events: Event[] = [\n+      { id: 'A', name: 'Event A', duration: 60 },\n+      { id: 'B', name: 'Event B', duration: 60 },\n+    ];\n+    const opts: ScheduleOptions = { ...defaultOptions, gap: 30 };\n+    const result = schedule(events, [smallRoom], opts);\n+    expect(result.assignments).toHaveLength(2);\n+    const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);\n+    const gap = sorted[1].startTime - sorted[0].endTime;\n+    expect(gap).toBeGreaterThanOrEqual(30);\n+  });\n+\n+  test('events in different rooms can overlap in time', () => {\n+    const events: Event[] = [\n+      { id: 'A', name: 'Event A', duration: 60 },\n+      { id: 'B', name: 'Event B', duration: 60 },\n+    ];\n+    const result = schedule(events, [smallRoom, bigRoom], defaultOptions);\n+    expect(result.assignments).toHaveLength(2);\n+    // Both can start at the same time since they're in different rooms\n+    // They might overlap in time since different rooms allow that\n+    expect(result.unscheduled).toHaveLength(0);\n+  });\n+\n+  test('schedules events back-to-back when only one room and many events', () => {\n+    const events: Event[] = Array.from({ length: 5 }, (_, i) => ({\n+      id: `E${i}`,\n+      name: `Event ${i}`,\n+      duration: 60,\n+    }));\n+    // 5 events × 60 min + 4 gaps × 15 min = 360 min, fits in 480-min window\n+    const result = schedule(events, [smallRoom], defaultOptions);\n+    expect(result.assignments).toHaveLength(5);\n+    expect(result.unscheduled).toHaveLength(0);\n+  });\n+\n+  test('puts unschedulable events in unscheduled list', () => {\n+    // Fill the room, then one more event can't fit\n+    const events: Event[] = Array.from({ length: 8 }, (_, i) => ({\n+      id: `E${i}`,\n+      name: `Event ${i}`,\n+      duration: 60,\n+    }));\n+    // 8 × 60 + 7 × 15 = 585 min needed, but window is 480 min → can't fit all\n+    const result = schedule(events, [smallRoom], defaultOptions);\n+    expect(result.assignments.length + result.unscheduled.length).toBe(8);\n+    expect(result.assignments.length).toBeGreaterThan(0);\n+  });\n+\n+  test('default attendees is 1 and fits any room', () => {\n+    const events: Event[] = [\n+      { id: 'A', name: 'Event A', duration: 30 },\n+    ];\n+    const tinyRoom: Room = { id: 'tiny', name: 'Tiny', capacity: 1 };\n+    const result = schedule(events, [tinyRoom], defaultOptions);\n+    expect(result.assignments).toHaveLength(1);\n+  });\n+});\n+\n+// ─── Prerequisites ────────────────────────────────────────────────────────────\n+\n+describe('prerequisites', () => {\n+  test('prerequisite event finishes before dependent starts (same room)', () => {\n+    const events: Event[] = [\n+      { id: 'A', name: 'Event A', duration: 60 },\n+      { id: 'B', name: 'Event B', duration: 60, prerequisites: ['A'] },\n+    ];\n+    const result = schedule(events, [smallRoom], defaultOptions);\n+    expect(result.assignments).toHaveLength(2);\n+    const a = result.assignments.find(x => x.eventId === 'A')!;\n+    const b = result.assignments.find(x => x.eventId === 'B')!;\n+    expect(b.startTime).toBeGreaterThanOrEqual(a.endTime + 15);\n+  });\n+\n+  test('prerequisite event finishes before dependent starts (different rooms)', () => {\n+    const events: Event[] = [\n+      { id: 'A', name: 'Event A', duration: 60 },\n+      { id: 'B', name: 'Event B', duration: 60, prerequisites: ['A'] },\n+    ];\n+    const result = schedule(events, [smallRoom, bigRoom], defaultOptions);\n+    expect(result.assignments).toHaveLength(2);\n+    const a = result.assignments.find(x => x.eventId === 'A')!;\n+    const b = result.assignments.find(x => x.eventId === 'B')!;\n+    // gap applies between prereq and dependent even if different rooms\n+    expect(b.startTime).toBeGreaterThanOrEqual(a.endTime + 15);\n+  });\n+\n+  test('chain of prerequisites are all scheduled in order', () => {\n+    const events: Event[] = [\n+      { id: 'A', name: 'Event A', duration: 30 },\n+      { id: 'B', name: 'Event B', duration: 30, prerequisites: ['A'] },\n+      { id: 'C', name: 'Event C', duration: 30, prerequisites: ['B'] },\n+    ];\n+    const result = schedule(events, [smallRoom], defaultOptions);\n+    expect(result.assignments).toHaveLength(3);\n+    const a = result.assignments.find(x => x.eventId === 'A')!;\n+    const b = result.assignments.find(x => x.eventId === 'B')!;\n+    const c = result.assignments.find(x => x.eventId === 'C')!;\n+    expect(b.startTime).toBeGreaterThanOrEqual(a.endTime + 15);\n+    expect(c.startTime).toBeGreaterThanOrEqual(b.endTime + 15);\n+  });\n+\n+  test('multiple prerequisites - dependent starts after all finish', () => {\n+    const events: Event[] = [\n+      { id: 'A', name: 'Event A', duration: 60 },\n+      { id: 'B', name: 'Event B', duration: 30 },\n+      { id: 'C', name: 'Event C', duration: 30, prerequisites: ['A', 'B'] },\n+    ];\n+    const result = schedule(events, [smallRoom, bigRoom], defaultOptions);\n+    expect(result.assignments).toHaveLength(3);\n+    const a = result.assignments.find(x => x.eventId === 'A')!;\n+    const b = result.assignments.find(x => x.eventId === 'B')!;\n+    const c = result.assignments.find(x => x.eventId === 'C')!;\n+    const latestPrereqEnd = Math.max(a.endTime, b.endTime);\n+    expect(c.startTime).toBeGreaterThanOrEqual(latestPrereqEnd + 15);\n+  });\n+\n+  test('unschedulable prerequisite causes dependent to be unscheduled too', () => {\n+    const events: Event[] = [\n+      { id: 'A', name: 'Event A', duration: 60, attendees: 100 }, // can't fit in any room\n+      { id: 'B', name: 'Event B', duration: 30, prerequisites: ['A'] },\n+    ];\n+    const result = schedule(events, [smallRoom], defaultOptions);\n+    expect(result.unscheduled).toContain('A');\n+    expect(result.unscheduled).toContain('B');\n+  });\n+});\n+\n+// ─── Preferred Room ───────────────────────────────────────────────────────────\n+\n+describe('preferred room', () => {\n+  test('honors preferred room when available', () => {\n+    const events: Event[] = [\n+      { id: 'A', name: 'Event A', duration: 30, preferredRoom: 'r2' },\n+    ];\n+    const result = schedule(events, [smallRoom, bigRoom], defaultOptions);\n+    expect(result.assignments).toHaveLength(1);\n+    expect(result.assignments[0].roomId).toBe('r2');\n+  });\n+\n+  test('falls back to another room when preferred is unavailable due to capacity', () => {\n+    const events: Event[] = [\n+      { id: 'A', name: 'Event A', duration: 30, attendees: 40, preferredRoom: 'r1' },\n+    ];\n+    // r1 capacity is 10, attendees is 40 → fallback to r2\n+    const result = schedule(events, [smallRoom, bigRoom], defaultOptions);\n+    expect(result.assignments).toHaveLength(1);\n+    expect(result.assignments[0].roomId).toBe('r2');\n+  });\n+\n+  test('falls back to another room when preferred is full', () => {\n+    const events: Event[] = [\n+      { id: 'A', name: 'Event A', duration: 480 }, // fills the whole day in r1\n+      { id: 'B', name: 'Event B', duration: 30, preferredRoom: 'r1' },\n+    ];\n+    const result = schedule(events, [smallRoom, bigRoom], defaultOptions);\n+    const b = result.assignments.find(x => x.eventId === 'B');\n+    expect(b).toBeDefined();\n+    // B should be scheduled somewhere\n+    expect(result.unscheduled).not.toContain('B');\n+  });\n+});\n+\n+// ─── Optimization ─────────────────────────────────────────────────────────────\n+\n+describe('optimization', () => {\n+  test('maximizes scheduled events - prefers scheduling more eve