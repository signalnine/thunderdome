s);\n    expect(result.assignments).toHaveLength(6);\n    expect(result.unscheduled).toHaveLength(0);\n  });\n\n  test('empty events list returns empty result', () => {\n    const result = schedule([], [smallRoom], defaultOptions);\n    expect(result.assignments).toHaveLength(0);\n    expect(result.unscheduled).toHaveLength(0);\n  });\n\n  test('empty rooms list returns all events unscheduled', () => {\n    const events: Event[] = [{ id: 'A', name: 'Event A', duration: 30 }];\n    const result = schedule(events, [], defaultOptions);\n    expect(result.unscheduled).toContain('A');\n    expect(result.assignments).toHaveLength(0);\n  });\n});\n","structuredPatch":[],"originalFile":null}}
