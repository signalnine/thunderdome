diff --git a/src/TaskQueue.ts b/src/TaskQueue.ts
new file mode 100644
index 0000000..6f249ee
--- /dev/null
+++ b/src/TaskQueue.ts
@@ -0,0 +1,547 @@
+import {
+  Task,
+  AddOptions,
+  DependencyStatus,
+  ConcurrencyInfo,
+  ScheduleDefinition,
+  ScheduleOptions,
+  MiddlewareFn,
+  HandlerFn,
+  ProgressListener,
+  ShutdownCallback,
+  ShutdownOptions,
+  ShutdownResult,
+} from './types.js';
+import { generateId, parseCronIntervalMs } from './utils.js';
+
+const DEFAULT_QUEUE = 'default';
+
+export class TaskQueue {
+  // Global task registry
+  private tasks = new Map<string, Task>();
+
+  // Per-queue ordered list of task IDs (pending/processing tasks)
+  private queues = new Map<string, string[]>();
+
+  // Dead letter queues: queueName -> Task[]
+  private dlqs = new Map<string, Task[]>();
+
+  // Concurrency limits per queue
+  private concurrencyLimits = new Map<string, number>();
+
+  // Active processing count per queue
+  private activeCounts = new Map<string, number>();
+
+  // Progress listeners: taskId -> Set of listeners
+  private progressListeners = new Map<string, Set<ProgressListener>>();
+
+  // Schedules
+  private schedules = new Map<string, ScheduleDefinition>();
+
+  // Middleware per queue
+  private middlewares = new Map<string, MiddlewareFn[]>();
+
+  // Handlers per queue
+  private handlers = new Map<string, HandlerFn>();
+
+  // Shutdown state
+  private isShutdown = false;
+  private shutdownResult: ShutdownResult | null = null;
+  private shutdownCallbacks: ShutdownCallback[] = [];
+
+  // ----------------------------------------------------------------
+  // Phase 1 & 2 & 3 & 4: add / dequeue / size / listQueues
+  // ----------------------------------------------------------------
+
+  add(payload: unknown, options: AddOptions = {}): Task {
+    if (this.isShutdown) {
+      throw new Error('TaskQueue is shut down. No new tasks can be added.');
+    }
+
+    const queue = options.queue ?? DEFAULT_QUEUE;
+    const priority = options.priority ?? 5;
+
+    if (priority < 1 || priority > 10) {
+      throw new Error(`Invalid priority ${priority}. Must be between 1 and 10.`);
+    }
+
+    // Resolve dependencies
+    const dependsOn = options.dependsOn ?? [];
+    for (const depId of dependsOn) {
+      if (!this.tasks.has(depId)) {
+        throw new Error(`Dependency task '${depId}' does not exist.`);
+      }
+    }
+
+    // Circular dependency check
+    if (dependsOn.length > 0) {
+      this._checkCircularDependency(dependsOn, new Set<string>());
+    }
+
+    // Compute availableAt
+    let availableAt: Date | undefined;
+    if (options.availableAt) {
+      availableAt = options.availableAt;
+    } else if (options.delay !== undefined && options.delay > 0) {
+      availableAt = new Date(Date.now() + options.delay);
+    }
+
+    const task: Task = {
+      id: generateId(),
+      queue,
+      payload,
+      status: 'pending',
+      priority,
+      createdAt: new Date(),
+      availableAt,
+      attempts: 0,
+      maxRetries: options.maxRetries ?? 3,
+      baseDelay: options.baseDelay ?? 1000,
+      dependsOn,
+    };
+
+    this.tasks.set(task.id, task);
+    this._enqueueId(queue, task.id);
+
+    return task;
+  }
+
+  private _enqueueId(queue: string, id: string): void {
+    if (!this.queues.has(queue)) {
+      this.queues.set(queue, []);
+    }
+    this.queues.get(queue)!.push(id);
+  }
+
+  dequeue(queue: string = DEFAULT_QUEUE): Task | null {
+    const ids = this.queues.get(queue);
+    if (!ids || ids.length === 0) return null;
+
+    // Check concurrency limit
+    const limit = this.concurrencyLimits.get(queue) ?? null;
+    if (limit !== null) {
+      const active = this.activeCounts.get(queue) ?? 0;
+      if (active >= limit) return null;
+    }
+
+    const now = Date.now();
+
+    // Find best available task: not blocked by dependencies, not delayed
+    // Sort criteria: available (not delayed) first, then by priority, then by createdAt (FIFO)
+    let bestIdx = -1;
+    let bestTask: Task | null = null;
+
+    for (let i = 0; i < ids.length; i++) {
+      const task = this.tasks.get(ids[i]);
+      if (!task || task.status !== 'pending') continue;
+
+      // Check delay
+      if (task.availableAt && task.availableAt.getTime() > now) continue;
+
+      // Check dependencies
+      if (task.dependsOn.length > 0) {
+        const blocked = task.dependsOn.some(depId => {
+          const dep = this.tasks.get(depId);
+          return !dep || dep.status !== 'completed';
+        });
+        if (blocked) continue;
+      }
+
+      if (bestTask === null) {
+        bestIdx = i;
+        bestTask = task;
+      } else {
+        // Compare: lower priority number = higher priority
+        if (task.priority < bestTask.priority) {
+          bestIdx = i;
+          bestTask = task;
+        } else if (task.priority === bestTask.priority) {
+          // FIFO: earlier createdAt wins
+          if (task.createdAt < bestTask.createdAt) {
+            bestIdx = i;
+            bestTask = task;
+          }
+        }
+      }
+    }
+
+    if (!bestTask || bestIdx === -1) return null;
+
+    // Remove from queue list
+    ids.splice(bestIdx, 1);
+
+    // Update status
+    bestTask.status = 'processing';
+    this.activeCounts.set(queue, (this.activeCounts.get(queue) ?? 0) + 1);
+
+    return bestTask;
+  }
+
+  size(queue: string = DEFAULT_QUEUE): number {
+    const ids = this.queues.get(queue);
+    if (!ids) return 0;
+    // Count only truly pending tasks
+    return ids.filter(id => {
+      const task = this.tasks.get(id);
+      return task && task.status === 'pending';
+    }).length;
+  }
+
+  listQueues(): string[] {
+    return Array.from(this.queues.keys());
+  }
+
+  getTask(id: string): Task | null {
+    return this.tasks.get(id) ?? null;
+  }
+
+  // ----------------------------------------------------------------
+  // Phase 5: complete / fail (with retry + backoff)
+  // ----------------------------------------------------------------
+
+  complete(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) return;
+    if (task.status === 'cancelled') return;
+
+    task.status = 'completed';
+    this._decrementActive(task.queue);
+
+    // Unblock dependent tasks (they remain in queue, dequeue will pick them up)
+    // Nothing to do - dequeue checks dependencies dynamically
+  }
+
+  fail(taskId: string, error: Error): void {
+    const task = this.tasks.get(taskId);
+    if (!task) return;
+    if (task.status === 'cancelled') return;
+
+    task.error = error;
+    task.attempts += 1;
+
+    this._decrementActive(task.queue);
+
+    if (task.attempts <= task.maxRetries) {
+      // Re-queue with backoff delay
+      const delay = task.baseDelay * Math.pow(2, task.attempts - 1);
+      task.availableAt = new Date(Date.now() + delay);
+      task.status = 'pending';
+      this._enqueueId(task.queue, task.id);
+    } else {
+      task.status = 'failed';
+      // Move to DLQ
+      this._addToDlq(task);
+    }
+  }
+
+  private _decrementActive(queue: string): void {
+    const current = this.activeCounts.get(queue) ?? 0;
+    this.activeCounts.set(queue, Math.max(0, current - 1));
+  }
+
+  // ----------------------------------------------------------------
+  // Phase 6: Dead Letter Queue
+  // ----------------------------------------------------------------
+
+  private _addToDlq(task: Task): void {
+    const dlq = this.dlqs.get(task.queue) ?? [];
+    dlq.push(task);
+    this.dlqs.set(task.queue, dlq);
+  }
+
+  getDeadLetterQueue(queue: string = DEFAULT_QUEUE): Task[] {
+    return this.dlqs.get(queue) ?? [];
+  }
+
+  requeueDeadLetter(taskId: string): void {
+    for (const [queue, dlq] of this.dlqs.entries()) {
+      const idx = dlq.findIndex(t => t.id === taskId);
+      if (idx !== -1) {
+        const [task] = dlq.splice(idx, 1);
+        task.status = 'pending';
+        task.error = undefined;
+        task.availableAt = undefined;
+        task.attempts = 0;
+        this._enqueueId(queue, task.id);
+        return;
+      }
+    }
+    throw new Error(`Task '${taskId}' not found in any dead letter queue.`);
+  }
+
+  clearDeadLetterQueue(queue: string = DEFAULT_QUEUE): void {
+    this.dlqs.set(queue, []);
+  }
+
+  // ----------------------------------------------------------------
+  // Phase 7: Dependency graph
+  // ----------------------------------------------------------------
+
+  private _checkCircularDependency(depIds: string[], _visited: Set<string>): void {
+    // Since we can only depend on existing tasks (which were already validated),
+    // circular dependency requires a cycle in the existing task graph.
+    // We do a DFS from each depId to see if any ancestor leads back to...
+    // Actually, since we don't have the new task's ID yet, we just need to verify
+    // the existing dependency graph has no cycles that would be introduced.
+    // Since we enforce dep existence at creation, any existing dependency graph is valid.
+    // A new task creating a cycle is impossible because:
+    //   - The new task doesn't exist yet (no ID)
+    //   - Existing tasks can't depend on a not-yet-created task
+    // So circular detection is only needed for self-references, which can't happen.
+    // The phase spec says "circular dependencies must be detected" - this primarily
+    // means A->B->A type scenarios, but since we can only reference existing task IDs,
+    // and new tasks always get fresh IDs, we verify the deps themselves don't form a cycle
+    // among existing tasks (which they can't by induction, since each was validated at creation).
+    // The non-existent ID check covers the main error case.
+    // Nothing else to do here - the graph is always DAG by construction.
+    void depIds;
+  }
+
+  getDependencyStatus(taskId: string): DependencyStatus {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task '${taskId}' not found.`);
+
+    const blocked = task.dependsOn.some(depId => {
+      const dep = this.tasks.get(depId);
+      return !dep || dep.status !== 'completed';
+    });
+
+    return {
+      dependsOn: task.dependsOn,
+      blocked,
+    };
+  }
+
+  // ----------------------------------------------------------------
+  // Phase 8: Concurrency Control
+  // ----------------------------------------------------------------
+
+  setConcurrency(queue: string, limit: number): void {
+    this.concurrencyLimits.set(queue, limit);
+  }
+
+  getConcurrencyInfo(queue: string = DEFAULT_QUEUE): ConcurrencyInfo {
+    return {
+      limit: this.concurrencyLimits.get(queue) ?? null,
+      active: this.activeCounts.get(queue) ?? 0,
+    };
+  }
+
+  // ----------------------------------------------------------------
+  // Phase 9: Progress and Cancellation
+  // ----------------------------------------------------------------
+
+  reportProgress(taskId: string, percent: number, message?: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task '${taskId}' not found.`);
+
+    task.progress = { percent, message };
+
+    const listeners = this.progressListeners.get(taskId);
+    if (listeners) {
+      for (const listener of listeners) {
+        listener(task.progress);
+      }
+    }
+  }
+
+  onProgress(taskId: string, listener: ProgressListener): () => void {
+    if (!this.progressListeners.has(taskId)) {
+      this.progressListeners.set(taskId, new Set());
+    }
+    const listeners = this.progressListeners.get(taskId)!;
+    listeners.add(listener);
+
+    return () => {
+      listeners.delete(listener);
+    };
+  }
+
+  cancel(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) return;
+
+    const previousStatus = task.status;
+    if (previousStatus === 'pending' || previousStatus === 'processing') {
+      // Remove from queue list
+      const queueIds = this.queues.get(task.queue);
+      if (queueIds) {
+        const idx = queueIds.indexOf(taskId);
+        if (idx !== -1) queueIds.splice(idx, 1);
+      }
+
+      // Free concurrency slot if was processing
+      if (previousStatus === 'processing') {
+        this._decrementActive(task.queue);
+      }
+
+      task.status = 'cancelled';
+    }
+  }
+
+  // ----------------------------------------------------------------
+  // Phase 10: Recurring Tasks
+  // ----------------------------------------------------------------
+
+  schedule(cron: string, payload: unknown, options: ScheduleOptions = {}): string {
+    const id = generateId();
+    const queue = options.queue ?? DEFAULT_QUEUE;
+
+    // Validate cron
+    parseCronIntervalMs(cron);
+
+    const def: ScheduleDefinition = {
+      id,
+      cron,
+      queue,
+      payload,
+      lastRun: options.lastRun,
+    };
+
+    this.schedules.set(id, def);
+    return id;
+  }
+
+  removeSchedule(id: string): void {
+    this.schedules.delete(id);
+  }
+
+  listSchedules(): ScheduleDefinition[] {
+    return Array.from(this.schedules.values());
+  }
+
+  tick(): void {
+    const now = Date.now();
+    for (const [, schedule] of this.schedules) {
+      const intervalMs = parseCronIntervalMs(schedule.cron);
+      const lastRun = schedule.lastRun?.getTime() ?? 0;
+
+      if (now - lastRun >= intervalMs) {
+        this.add(schedule.payload, { queue: schedule.queue });
+        schedule.lastRun = new Date(now);
+      }
+    }
+  }
+
+  // ----------------------------------------------------------------
+  // Phase 11: Middleware
+  // ----------------------------------------------------------------
+
+  use(queue: string, middleware: MiddlewareFn): void {
+    if (!this.middlewares.has(queue)) {
+      this.middlewares.set(queue, []);
+    }
+    this.middlewares.get(queue)!.push(middleware);
+  }
+
+  registerHandler(queue: string, handler: HandlerFn): void {
+    this.handlers.set(queue, handler);
+  }
+
+  async process(queue: string = DEFAULT_QUEUE): Promise<void> {
+    const task = this.dequeue(queue);
+    if (!task) return;
+
+    const middlewares = this.middlewares.get(queue) ?? [];
+    const handler = this.handlers.get(queue);
+
+    // Build middleware chain
+    let index = 0;
+    const next = async (): Promise<void> => {
+      if (index < middlewares.length) {
+        const mw = middlewares[index++];
+        await mw(task, next);
+      } else if (handler) {
+        await handler(task);
+      }
+    };
+
+    try {
+      await next();
+      if (task.status === 'processing') {
+        this.complete(task.id);
+      }
+    } catch (err) {
+      if (task.status === 'processing') {
+        this.fail(task.id, err instanceof Error ? err : new Error(String(err)));
+      }
+    }
+  }
+
+  // ----------------------------------------------------------------
+  // Phase 12: Graceful Shutdown
+  // ----------------------------------------------------------------
+
+  onShutdown(callback: ShutdownCallback): void {
+    this.shutdownCallbacks.push(callback);
+  }
+
+  async shutdown(options: ShutdownOptions = {}): Promise<ShutdownResult> {
+    // Idempotent
+    if (this.shutdownResult !== null) {
+      return this.shutdownResult;
+    }
+
+    if (this.isShutdown) {
+      // Already in progress, wait for result
+      return new Promise(resolve => {
+        const check = setInterval(() => {
+          if (this.shutdownResult !== null) {
+            clearInterval(check);
+            resolve(this.shutdownResult);
+          }
+        }, 10);
+      });
+    }
+
+    this.isShutdown = true;
+    const startTime = Date.now();
+    const timeout = options.timeout ?? 30000;
+
+    // Run shutdown callbacks
+    for (const cb of this.shutdownCallbacks) {
+      await cb();
+    }
+
+    // Count currently processing tasks
+    const getProcessingTasks = (): Task[] => {
+      return Array.from(this.tasks.values()).filter(t => t.status === 'processing');
+    };
+
+    let completed = 0;
+    let forceCancelled = 0;
+
+    const processingAtStart = getProcessingTasks();
+
+    if (processingAtStart.length > 0) {
+      // Wait for processing tasks to finish
+      const deadline = Date.now() + timeout;
+
+      await new Promise<void>(resolve => {
+        const check = setInterval(() => {
+          const stillProcessing = getProcessingTasks();
+          if (stillProcessing.length === 0 || Date.now() >= deadline) {
+            clearInterval(check);
+            resolve();
+          }
+        }, 10);
+      });
+
+      // Check which ones finished and which need force-cancellation
+      for (const task of processingAtStart) {
+        const current = this.tasks.get(task.id);
+        if (!current || current.status === 'completed') {
+          completed++;
+        } else if (current.status === 'processing') {
+          current.status = 'cancelled';
+          forceCancelled++;
+        }
+      }
+    }
+
+    const durationMs = Date.now() - startTime;
+
+    this.shutdownResult = { completed, forceCancelled, durationMs };
+    return this.shutdownResult;
+  }
+}
