+let counter = 0;
+
+export function generateId(): string {
+  return `task-${Date.now()}-${Math.random().toString(36).slice(2, 9)}-${counter++}`;
+}
+
+/**
+ * Parse a simple cron expression and return interval in milliseconds.
+ * Supported:
+ *   `*\/N * * * *`  — every N minutes
+ *   `0 * * * *`     — every hour
+ *   `0 0 * * *`     — every day
+ */
+export function parseCronIntervalMs(cron: string): number {
+  const parts = cron.trim().split(/\s+/);
+  if (parts.length !== 5) throw new Error(`Unsupported cron: ${cron}`);
+  const [min, hour, dom, month, dow] = parts;
+
+  // Every N minutes: `*/N * * * *`
+  if (min.startsWith('*/') && hour === '*' && dom === '*' && month === '*' && dow === '*') {
+    const n = parseInt(min.slice(2), 10);
+    if (isNaN(n) || n <= 0) throw new Error(`Invalid cron interval: ${cron}`);
+    return n * 60 * 1000;
+  }
+
+  // Every hour: `0 * * * *`
+  if (min === '0' && hour === '*' && dom === '*' && month === '*' && dow === '*') {
+    return 60 * 60 * 1000;
+  }
+
+  // Every day at midnight: `0 0 * * *`
+  if (min === '0' && hour === '0' && dom === '*' && month === '*' && dow === '*') {
+    return 24 * 60 * 60 * 1000;
+  }
+
+  throw new Error(`Unsupported cron expression: ${cron}`);
+}
