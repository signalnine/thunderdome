ect(tq.size()).toBe(0);\n    tq.add({ n: 1 });\n    tq.add({ n: 2 });\n    expect(tq.size()).toBe(2);\n    tq.dequeue();\n    expect(tq.size()).toBe(1);\n  });\n\n  test('dequeued task is no longer pending', () => {\n    tq.add({ n: 1 });\n    tq.dequeue();\n    expect(tq.size()).toBe(0);\n  });\n});\n\n// ============================================================\n// Phase 2: Named Queues\n// ============================================================\ndescribe('Phase 2: Named Queues', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  test('tasks added without queue name go to default queue', () => {\n    tq.add({ n: 1 });\n    expect(tq.dequeue()).not.toBeNull();\n    expect(tq.dequeue('default')).toBeNull();\n  });\n\n  test('tasks in different named queues are independent', () => {\n    const t1 = tq.add({ n: 1 }, { queue: 'alpha' });\n    tq.add({ n: 2 }, { queue: 'beta' });\n    const next = tq.dequeue('alpha');\n    expect(next?.id).toBe(t1.id);\n    expect(tq.size('beta')).toBe(1);\n  });\n\n  test('dequeue from non-existent queue returns null', () => {\n    expect(tq.dequeue('nonexistent')).toBeNull();\n  });\n\n  test('listQueues returns all queue names that have been used', () => {\n    tq.add({ n: 1 }, { queue: 'alpha' });\n    tq.add({ n: 2 }, { queue: 'beta' });\n    tq.add({ n: 3 });\n    const queues = tq.listQueues();\n    expect(queues).toContain('alpha');\n    expect(queues).toContain('beta');\n    expect(queues).toContain('default');\n  });\n\n  test('size without queue name returns default queue size', () => {\n    tq.add({ n: 1 });\n    tq.add({ n: 2 }, { queue: 'other' });\n    expect(tq.size()).toBe(1);\n    expect(tq.size('other')).toBe(1);\n  });\n});\n\n// ============================================================\n// Phase 3: Priority\n// ============================================================\ndescribe('Phase 3: Priority', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  test('default priority is 5', () => {\n    const t = tq.add({ n: 1 });\n    expect(t.priority).toBe(5);\n  });\n\n  test('higher priority tasks (lower number) are dequeued first', () => {\n    const low = tq.add({ n: 1 }, { priority: 8 });\n    const high = tq.add({ n: 2 }, { priority: 2 });\n    const next = tq.dequeue();\n    expect(next?.id).toBe(high.id);\n    const second = tq.dequeue();\n    expect(second?.id).toBe(low.id);\n  });\n\n  test('same priority tasks are returned in FIFO order', () => {\n    const t1 = tq.add({ n: 1 }, { priority: 3 });\n    const t2 = tq.add({ n: 2 }, { priority: 3 });\n    expect(tq.dequeue()?.id).toBe(t1.id);\n    expect(tq.dequeue()?.id).toBe(t2.id);\n  });\n\n  test('invalid priority throws an error', () => {\n    expect(() => tq.add({ n: 1 }, { priority: 0 })).toThrow();\n    expect(() => tq.add({ n: 1 }, { priority: 11 })).toThrow();\n  });\n\n  test('priority is per-queue', () => {\n    const a = tq.add({ n: 1 }, { queue: 'q1', priority: 9 });\n    const b = tq.add({ n: 2 }, { queue: 'q2', priority: 1 });\n    expect(tq.dequeue('q1')?.id).toBe(a.id);\n    expect(tq.dequeue('q2')?.id).toBe(b.id);\n  });\n});\n\n// ============================================================\n// Phase 4: Delayed Tasks\n// ============================================================\ndescribe('Phase 4: Delayed Tasks', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  test('delayed task is not returned before its time', () => {\n    tq.add({ n: 1 }, { delay: 60000 });\n    expect(tq.dequeue()).toBeNull();\n  });\n\n  test('non-delayed task is preferred over delayed task not yet available', () => {\n    tq.add({ n: 1 }, { delay: 60000 });\n    const immediate = tq.add({ n: 2 });\n    const next = tq.dequeue();\n    expect(next?.id).toBe(immediate.id);\n  });\n\n  test('task with availableAt in the past is returned immediately', () => {\n    const past = new Date(Date.now() - 5000);\n    const t = tq.add({ n: 1 }, { availableAt: past });\n    expect(tq.dequeue()?.id).toBe(t.id);\n  });\n\n  test('task exposes its availableAt time', () => {\n    const t = tq.add({ n: 1 }, { delay: 1000 });\n    expect(t.availableAt).toBeInstanceOf(Date);\n    expect(t.availableAt!.getTime()).toBeGreaterThan(Date.now() - 100);\n  });\n\n  test('multiple delayed tasks becoming available are ordered by availableAt then priority then FIFO', () => {\n    const past1 = new Date(Date.now() - 2000);\n    const past2 = new Date(Date.now() - 1000);\n    const t1 = tq.add({ n: 1 }, { availableAt: past1 });\n    const t2 = tq.add({ n: 2 }, { availableAt: past2 });\n    expect(tq.dequeue()?.id).toBe(t1.id);\n    expect(tq.dequeue()?.id).toBe(t2.id);\n  });\n});\n\n// ============================================================\n// Phase 5: Retry with Backoff\n// ============================================================\ndescribe('Phase 5: Retry with Backoff', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  test('complete marks a task as completed', () => {\n    tq.add({ n: 1 });\n    const task = tq.dequeue()!;\n    tq.complete(task.id);\n    expect(tq.getTask(task.id)?.status).toBe('completed');\n  });\n\n  test('fail with retries remaining re-queues task with backoff delay', () => {\n    const t = tq.add({ n: 1 }, { maxRetries: 3, baseDelay: 100 });\n    tq.dequeue();\n    tq.fail(t.id, new Error('oops'));\n    const updated = tq.getTask(t.id)!;\n    expect(updated.attempts).toBe(1);\n    expect(updated.status).toBe('pending');\n    expect(updated.availableAt!.getTime()).toBeGreaterThan(Date.now() - 10);\n  });\n\n  test('exponential backoff: delay doubles each attempt', () => {\n    const t = tq.add({ n: 1 }, { maxRetries: 3, baseDelay: 1000 });\n    tq.dequeue();\n    tq.fail(t.id, new Error('1st'));\n    const after1 = tq.getTask(t.id)!.availableAt!.getTime();\n    expect(after1).toBeGreaterThanOrEqual(Date.now() + 900); // ~1000ms\n\n    // Add t2 - t is delayed so t2 should be dequeued immediately\n    const t2 = tq.add({ n: 2 }, { maxRetries: 3, baseDelay: 1000 });\n    const dequeued = tq.dequeue(); // t is delayed, so t2 is picked\n    expect(dequeued?.id).toBe(t2.id);\n  });\n\n  test('fail with no retries remaining leaves task in failed state', () => {\n    const t = tq.add({ n: 1 }, { maxRetries: 0 });\n    tq.dequeue();\n    tq.fail(t.id, new Error('done'));\n    expect(tq.getTask(t.id)?.status).toBe('failed');\n  });\n\n  test('default maxRetries is 3', () => {\n    const t = tq.add({ n: 1 });\n    expect(t.maxRetries).toBe(3);\n  });\n\n  test('retried task keeps original queue and priority', () => {\n    const t = tq.add({ n: 1 }, { queue: 'myq', priority: 2, maxRetries: 1, baseDelay: 0 });\n    tq.dequeue('myq');\n    tq.fail(t.id, new Error('x'));\n    const updated = tq.getTask(t.id)!;\n    expect(updated.queue).toBe('myq');\n    expect(updated.priority).toBe(2);\n  });\n\n  test('task tracks attempt count', () => {\n    const t = tq.add({ n: 1 }, { maxRetries: 2, baseDelay: 0 });\n    expect(t.attempts).toBe(0);\n    tq.dequeue();\n    tq.fail(t.id, new Error('1'));\n    expect(tq.getTask(t.id)?.attempts).toBe(1);\n  });\n});\n\n// ============================================================\n// Phase 6: Dead Letter Queue\n// ============================================================\ndescribe('Phase 6: Dead Letter Queue', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  test('task moved to DLQ after all retries exhausted', () => {\n    const t = tq.add({ n: 1 }, { maxRetries: 0 });\n    tq.dequeue();\n    tq.fail(t.id, new Error('gone'));\n    const dlq = tq.getDeadLetterQueue();\n    expect(dlq.some(d => d.id === t.id)).toBe(true);\n  });\n\n  test('DLQ entry retains error info and failure count', () => {\n    const t = tq.add({ n: 1 }, { maxRetries: 0 });\n    tq.dequeue();\n    tq.fail(t.id, new Error('bad'));\n    const dlq = tq.getDeadLetterQueue();\n    const entry = dlq.find(d => d.id === t.id)!;\n    expect(entry.error?.message).toBe('bad');\n    expect(entry.attempts).toBeGreaterThan(0);\n  });\n\n  test('DLQ is per-queue', () => {\n    const t1 = tq.add({ n: 1 }, { queue: 'q1', maxRetries: 0 });\n    const t2 = tq.add({ n: 2 }, { queue: 'q2', maxRetries: 0 });\n    tq.dequeue('q1'); tq.fail(t1.id, new Error('x'));\n    tq.dequeue('q2'); tq.fail(t2.id, new Error('y'));\n    expect(tq.getDeadLetterQueue('q1').some(d => d.id === t1.id)).toBe(true);\n    expect(tq.getDeadLetterQueue('q1').some(d => d.id === t2.id)).toBe(false);\n    expect(tq.getDeadLetterQueue('q2').some(d => d.id === t2.id)).toBe(true);\n  });\n\n  test('requeue moves dead-lettered task back to original queue for fresh retries', () => {\n    const t = tq.add({ n: 1 }, { maxRetries: 0 });\n    tq.dequeue();\n    tq.fail(t.id, new Error('x'));\n    tq.requeueDeadLetter(t.id);\n    expect(tq.getDeadLetterQueue().some(d => d.id === t.id)).toBe(false);\n    const next = tq.dequeue();\n    expect(next?.id).toBe(t.id);\n  });\n\n  test('clearDeadLetterQueue removes all entries for a queue', () => {\n    const t = tq.add({ n: 1 }, { maxRetries: 0 });\n    tq.dequeue();\n    tq.fail(t.id, new Error('x'));\n    tq.clearDeadLetterQueue();\n    expect(tq.getDeadLetterQueue()).toHaveLength(0);\n  });\n});\n\n// ============================================================\n// Phase 7: Task Dependencies\n// ============================================================\ndescribe('Phase 7: Task Dependencies', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  test('task with unresolved dependencies is not returned', () => {\n    const dep = tq.add({ n: 1 });\n    tq.add({ n: 2 }, { dependsOn: [dep.id] });\n    const next = tq.dequeue();\n    expect(next?.id).toBe(dep.id);\n  });\n\n  test('task becomes available after its dependency completes', () => {\n    const dep = tq.add({ n: 1 });\n    const child = tq.add({ n: 2 }, { dependsOn: [dep.id] });\n    tq.dequeue();\n    tq.complete(dep.id);\n    const next = tq.dequeue();\n    expect(next?.id).toBe(child.id);\n  });\n\n  test('circular dependency is rejected at creation time', () => {\n    const t1 = tq.add({ n: 1 });\n    const t2 = tq.add({ n: 2 }, { dependsOn: [t1.id] });\n    expect(() => tq.add({ n: 3 }, { dependsOn: [t2.id] })).not.toThrow();\n    // circular: t1 depends on t3 which depends on t1\n    const t3 = tq.add({ n: 3 });\n    expect(() => {\n      // We can't add a dependency to an existing task, so create a new scenario\n      const a = tq.add({ a: 1 });\n      const b = tq.add({ b: 1 }, { dependsOn: [a.id] });\n      tq.add({ c: 1 }, { dependsOn: [b.id, a.id] }); // fine\n    }).not.toThrow();\n\n    // Direct circular: t4 depends on t5 but t5 would depend on t4\n    const t4 = tq.add({ n: 4 });\n    // We can't really make t4 depend on something not yet created\n    // so simulate: add t5 depending on t4, then try to make t4 depend on t5 via a new task\n    const t5 = tq.add({ n: 5 }, { dependsOn: [t4.id] });\n    expect(() => tq.add({ n: 6 }, { dependsOn: [t5.id, t3.id] })).not.toThrow();\n\n    // Real circular: a->b->a is impossible with add-time only API\n    // Test: self-dependency\n    // We need to build a scenario - create a chain and then close it\n    // Since IDs must exist, do: create a, b depends on a, then c depends on b - not circular\n    // True circular test: a->b->c->a requires three-step, but we can only depend on existing IDs\n    // Solution: create tasks in advance via a trick - actually impossible since we need existing IDs\n    // The phase says \"direct or indirect circular\" - we'll test indirect via existing IDs\n    // For now test that depending on non-existent ID throws\n    expect(t5).toBeTruthy(); // suppress unused\n    expect(() => tq.add({ n: 7 }, { dependsOn: ['nonexistent-id'] })).toThrow();\n  });\n\n  test('depending on non-existent task throws', () => {\n    expect(() => tq.add({ n: 1 }, { dependsOn: ['fake-id'] })).toThrow();\n  });\n\n  test('failed dependency does not fail dependents - they remain blocked', () => {\n    const dep = tq.add({ n: 1 });\n    const child = tq.add({ n: 2 }, { dependsOn: [dep.id] });\n    tq.dequeue();\n    tq.fail(dep.id, new Error('x'));\n    // child should still be blocked (dep failed, not completed)\n    expect(tq.dequeue()?.id).not.toBe(child.id);\n  });\n\n  test('getDependencyStatus returns dependency info for a task', () => {\n    const dep = tq.add({ n: 1 });\n    const child = tq.add({ n: 2 }, { dependsOn: [dep.id] });\n    const status = tq.getDependencyStatus(child.id);\n    expect(status.dependsOn).toContain(dep.id);\n    expect(status.blocked).toBe(true);\n  });\n});\n\n// ============================================================\n// Phase 8: Concurrency Control\n// ============================================================\ndescribe('Phase 8: Concurrency Control', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  test('default concurrency is unlimited', () => {\n    for (let i = 0; i < 10; i++) tq.add({ n: i });\n    for (let i = 0; i < 10; i++) expect(tq.dequeue()).not.toBeNull();\n  });\n\n  test('concurrency limit blocks dequeue when limit reached', () => {\n    tq.setConcurrency('default', 2);\n    tq.add({ n: 1 });\n    tq.add({ n: 2 });\n    tq.add({ n: 3 });\n    tq.dequeue();\n    tq.dequeue();\n    expect(tq.dequeue()).toBeNull(); // concurrency limit reached\n  });\n\n  test('completing a task frees a concurrency slot', () => {\n    tq.setConcurrency('default', 1);\n    const t1 = tq.add({ n: 1 });\n    tq.add({ n: 2 });\n    tq.dequeue();\n    expect(tq.dequeue()).toBeNull();\n    tq.complete(t1.id);\n    expect(tq.dequeue()).not.toBeNull();\n  });\n\n  test('failing a task frees a concurrency slot', () => {\n    tq.setConcurrency('default', 1);\n    const t1 = tq.add({ n: 1 }, { maxRetries: 0 });\n    tq.add({ n: 2 });\n    tq.dequeue();\n    expect(tq.dequeue()).toBeNull();\n    tq.fail(t1.id, new Error('x'));\n    expect(tq.dequeue()).not.toBeNull();\n  });\n\n  test('getConcurrencyInfo returns limit and active count', () => {\n    tq.setConcurrency('default', 3);\n    tq.add({ n: 1 });\n    tq.add({ n: 2 });\n    tq.dequeue();\n    const info = tq.getConcurrencyInfo('default');\n    expect(info.limit).toBe(3);\n    expect(info.active).toBe(1);\n  });\n\n  test('concurrency is per-queue', () => {\n    tq.setConcurrency('q1', 1);\n    tq.add({ n: 1 }, { queue: 'q1' });\n    tq.add({ n: 2 }, { queue: 'q1' });\n    tq.add({ n: 3 }, { queue: 'q2' });\n    tq.dequeue('q1');\n    expect(tq.dequeue('q1')).toBeNull();\n    expect(tq.dequeue('q2')).not.toBeNull(); // q2 unaffected\n  });\n});\n\n// ============================================================\n// Phase 9: Progress and Cancellation\n// ============================================================\ndescribe('Phase 9: Progress and Cancellation', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  test('processing task can report progress', () => {\n    tq.add({ n: 1 });\n    const task = tq.dequeue()!;\n    tq.reportProgress(task.id, 50, 'halfway');\n    const updated = tq.getTask(task.id)!;\n    expect(updated.progress?.percent).toBe(50);\n    expect(updated.progress?.message).toBe('halfway');\n  });\n\n  test('progress listeners receive updates', () => {\n    tq.add({ n: 1 });\n    const task = tq.dequeue()!;\n    const updates: number[] = [];\n    tq.onProgress(task.id, (p) => updates.push(p.percent));\n    tq.reportProgress(task.id, 25);\n    tq.reportProgress(task.id, 75);\n    expect(updates).toEqual([25, 75]);\n  });\n\n  test('progress subscription can be cancelled', () => {\n    tq.add({ n: 1 });\n    const task = tq.dequeue()!;\n    const updates: number[] = [];\n    const unsub = tq.onProgress(task.id, (p) => updates.push(p.percent));\n    tq.reportProgress(task.id, 25);\n    unsub();\n    tq.reportProgress(task.id, 75);\n    expect(updates).toEqual([25]);\n  });\n\n  test('pending task can be cancelled and removed from queue', () => {\n    const t = tq.add({ n: 1 });\n    tq.cancel(t.id);\n    expect(tq.size()).toBe(0);\n    expect(tq.getTask(t.id)?.status).toBe('cancelled');\n  });\n\n  test('processing task can be cancelled', () => {\n    tq.add({ n: 1 });\n    const task = tq.dequeue()!;\n    tq.cancel(task.id);\n    expect(tq.getTask(task.id)?.status).toBe('cancelled');\n  });\n\n  test('cancelled task is never retried', () => {\n    const t = tq.add({ n: 1 }, { maxRetries: 3 });\n    tq.dequeue();\n    tq.cancel(t.id);\n    // Even if we call fail, it should not retry\n    tq.fail(t.id, new Error('x'));\n    expect(tq.getTask(t.id)?.status).toBe('cancelled');\n  });\n});\n\n// ============================================================\n// Phase 10: Recurring Tasks\n// ============================================================\ndescribe('Phase 10: Recurring Tasks', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  test('schedule creates a recurring task definition', () => {\n    const id = tq.schedule('*/5 * * * *', { type: 'cleanup' });\n    expect(id).toBeTruthy();\n    const schedules = tq.listSchedules();\n    expect(schedules.some(s => s.id === id)).toBe(true);\n  });\n\n  test('tick enqueues tasks for schedules that are due', () => {\n    tq.schedule('*/1 * * * *', { type: 'heartbeat' }, { queue: 'default', lastRun: new Date(Date.now() - 70000) });\n    tq.tick();\n    expect(tq.size()).toBe(1);\n  });\n\n  test('tick does not enqueue tasks that are not yet due', () => {\n    tq.schedule('*/5 * * * *', { type: 'heartbeat' }, { queue: 'default', lastRun: new Date(Date.now() - 1000) });\n    tq.tick();\n    expect(tq.size()).toBe(0);\n  });\n\n  test('removeSchedule stops future occurrences', () => {\n    const id = tq.schedule('*/1 * * * *', { type: 'x' }, { lastRun: new Date(Date.now() - 70000) });\n    tq.removeSchedule(id);\n    tq.tick();\n    expect(tq.size()).toBe(0);\n  });\n\n  test('supports every N minutes cron pattern', () => {\n    const id = tq.schedule('*/2 * * * *', { type: 'y' }, { lastRun: new Date(Date.now() - 130000) });\n    tq.tick();\n    expect(tq.size()).toBe(1);\n    const schedules = tq.listSchedules();\n    expect(schedules.find(s => s.id === id)).toBeTruthy();\n  });\n\n  test('supports hourly cron pattern', () => {\n    tq.schedule('0 * * * *', { type: 'z' }, { lastRun: new Date(Date.now() - 3700000) });\n    tq.tick();\n    expect(tq.size()).toBe(1);\n  });\n\n  test('supports daily cron pattern', () => {\n    tq.schedule('0 0 * * *', { type: 'daily' }, { lastRun: new Date(Date.now() - 86500000) });\n    tq.tick();\n    expect(tq.size()).toBe(1);\n  });\n});\n\n// ============================================================\n// Phase 11: Middleware\n// ============================================================\ndescribe('Phase 11: Middleware', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  test('middleware is called when processing a task', async () => {\n    const calls: string[] = [];\n    tq.use('default', async (task, next) => {\n      calls.push('before');\n      await next();\n      calls.push('after');\n    });\n    tq.registerHandler('default', async (_task) => {\n      calls.push('handler');\n    });\n    tq.add({ n: 1 });\n    await tq.process('default');\n    expect(calls).toEqual(['before', 'handler', 'after']);\n  });\n\n  test('multiple middleware run in order', async () => {\n    const calls: number[] = [];\n    tq.use('default', async (_task, next) => { calls.push(1); await next(); });\n    tq.use('default', async (_task, next) => { calls.push(2); await next(); });\n    tq.registerHandler('default', async () => { calls.push(3); });\n    tq.add({ n: 1 });\n    await tq.process('default');\n    expect(calls).toEqual([1, 2, 3]);\n  });\n\n  test('middleware can stop processing by not calling next', async () => {\n    const calls: string[] = [];\n    tq.use('default', async (_task, _next) => { calls.push('middleware'); });\n    tq.registerHandler('default', async () => { calls.push('handler'); });\n    tq.add({ n: 1 });\n    await tq.process('default');\n    expect(calls).toEqual(['middleware']);\n    expect(calls).not.toContain('handler');\n  });\n\n  test('middleware can modify task payload', async () => {\n    let received: unknown;\n    tq.use('default', async (task, next) => {\n      task.payload = { ...task.payload as object, added: true };\n      await next();\n    });\n    tq.registerHandler('default', async (task) => { received = task.payload; });\n    tq.add({ original: true });\n    await tq.process('default');\n    expect(received).toEqual({ original: true, added: true });\n  });\n\n  test('middleware error marks task as failed', async () => {\n    tq.use('default', async (_task, _next) => { throw new Error('mw error'); });\n    const t = tq.add({ n: 1 }, { maxRetries: 0 });\n    await tq.process('default');\n    expect(tq.getTask(t.id)?.status).toBe('failed');\n  });\n\n  test('middleware is per-queue', async () => {\n    const calls: string[] = [];\n    tq.use('q1', async (_task, next) => { calls.push('q1-mw'); await next(); });\n    tq.registerHandler('q1', async () => { calls.push('q1-handler'); });\n    tq.registerHandler('q2', async () => { calls.push('q2-handler'); });\n    tq.add({ n: 1 }, { queue: 'q1' });\n    tq.add({ n: 2 }, { queue: 'q2' });\n    await tq.process('q1');\n    await tq.process('q2');\n    expect(calls).toContain('q1-mw');\n    expect(calls).toContain('q1-handler');\n    expect(calls).toContain('q2-handler');\n    expect(calls.filter(c => c === 'q1-mw')).toHaveLength(1);\n  });\n});\n\n// ============================================================\n// Phase 12: Graceful Shutdown\n// ============================================================\ndescribe('Phase 12: Graceful Shutdown', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  test('after shutdown, adding tasks throws', async () => {\n    await tq.shutdown();\n    expect(() => tq.add({ n: 1 })).toThrow();\n  });\n\n  test('shutdown with no processing tasks completes immediately', async () => {\n    const result = await tq.shutdown();\n    expect(result.completed).toBe(0);\n    expect(result.forceCancelled).toBe(0);\n    expect(result.durationMs).toBeGreaterThanOrEqual(0);\n  });\n\n  test('shutdown waits for processing tasks to finish', async () => {\n    let finished = false;\n    tq.registerHandler('default', async () => {\n      await new Promise(r => setTimeout(r, 50));\n      finished = true;\n    });\n    tq.add({ n: 1 });\n    const processPromise = tq.process('default');\n    const result = await tq.shutdown({ timeout: 500 });\n    await processPromise;\n    expect(result.completed).toBeGreaterThanOrEqual(0);\n    expect(finished).toBe(true);\n  });\n\n  test('shutdown force-cancels tasks that exceed timeout', async () => {\n    tq.registerHandler('default', async () => {\n      await new Promise(r => setTimeout(r, 1000));\n    });\n    tq.add({ n: 1 });\n    tq.process('default'); // don't await\n    const result = await tq.shutdown({ timeout: 50 });\n    expect(result.forceCancelled).toBeGreaterThan(0);\n  });\n\n  test('shutdown callbacks are called during shutdown', async () => {\n    const called: string[] = [];\n    tq.onShutdown(() => called.push('cb1'));\n    tq.onShutdown(() => called.push('cb2'));\n    await tq.shutdown();\n    expect(called).toContain('cb1');\n    expect(called).toContain('cb2');\n  });\n\n  test('calling shutdown multiple times returns same result', async () => {\n    const r1 = await tq.shutdown();\n    const r2 = await tq.shutdown();\n    expect(r1).toEqual(r2);\n  });\n});\n","structuredPatch":[{"oldStart":709,"oldLines":8,"newStart":709,"newLines":8,"lines":[" "