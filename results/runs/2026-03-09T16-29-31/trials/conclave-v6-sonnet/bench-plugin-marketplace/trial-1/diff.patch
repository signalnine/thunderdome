+import { describe, it, expect } from 'vitest';
+import { createRunner } from './index.js';
+
+describe('SandboxedRunner', () => {
+  const runner = createRunner();
+
+  it('executes simple code and returns output', async () => {
+    const result = await runner.execute('exports.result = 1 + 2;');
+    expect(result.success).toBe(true);
+    expect(result.output).toEqual({ result: 3 });
+    expect(result.duration).toBeGreaterThanOrEqual(0);
+    expect(result.memoryUsed).toBeGreaterThanOrEqual(0);
+  });
+
+  it('passes context variables into sandbox', async () => {
+    const result = await runner.execute('exports.result = x + y;', { x: 10, y: 20 });
+    expect(result.success).toBe(true);
+    expect((result.output as Record<string, unknown>).result).toBe(30);
+  });
+
+  it('returns error on thrown exception', async () => {
+    const result = await runner.execute('throw new Error("oops");');
+    expect(result.success).toBe(false);
+    expect(result.error).toContain('oops');
+  });
+
+  it('enforces timeout with executeWithTimeout', async () => {
+    const result = await runner.executeWithTimeout('while(true){}', 100);
+    expect(result.success).toBe(false);
+    expect(result.error).toContain('timeout');
+  });
