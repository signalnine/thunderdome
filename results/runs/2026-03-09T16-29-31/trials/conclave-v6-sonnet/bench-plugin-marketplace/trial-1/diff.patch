+  it('default execute has a reasonable timeout', async () => {
+    // Should not hang indefinitely - uses 5s default
+    const result = await runner.executeWithTimeout('while(true){}', 200);
+    expect(result.success).toBe(false);
+  });
+
+  it('captures exported output', async () => {
+    const result = await runner.execute('exports.hello = "world";');
