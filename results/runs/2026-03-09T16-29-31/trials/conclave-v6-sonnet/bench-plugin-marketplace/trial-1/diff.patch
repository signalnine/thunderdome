+import Database from 'better-sqlite3';
+import type { Review, ReviewService } from '../types.js';
+
+export function createReviewService(dbPath = ':memory:'): ReviewService {
+  const db = new Database(dbPath);
+
+  db.exec(`
+    CREATE TABLE IF NOT EXISTS reviews (
+      id INTEGER PRIMARY KEY AUTOINCREMENT,
+      pluginName TEXT NOT NULL,
+      pluginVersion TEXT NOT NULL,
+      userId TEXT NOT NULL,
+      rating INTEGER NOT NULL,
+      comment TEXT NOT NULL,
+      flagged INTEGER NOT NULL DEFAULT 0,
+      createdAt TEXT NOT NULL
+    )
+  `);
+
+  function rowToReview(row: Record<string, unknown>): Review {
+    return {
+      id: row.id as number,
+      pluginName: row.pluginName as string,
+      pluginVersion: row.pluginVersion as string,
+      userId: row.userId as string,
+      rating: row.rating as number,
+      comment: row.comment as string,
+      flagged: Boolean(row.flagged),
+      createdAt: row.createdAt as string,
+    };
+  }
+
+  return {
+    addReview(review: Omit<Review, 'id' | 'createdAt' | 'flagged'>): Review {
+      const createdAt = new Date().toISOString();
+      const result = db.prepare(
+        'INSERT INTO reviews (pluginName, pluginVersion, userId, rating, comment, flagged, createdAt) VALUES (?, ?, ?, ?, ?, 0, ?)'
+      ).run(review.pluginName, review.pluginVersion, review.userId, review.rating, review.comment, createdAt);
+      return {
+        ...review,
+        id: result.lastInsertRowid as number,
+        flagged: false,
+        createdAt,
+      };
+    },
+
+    getReviews(pluginName: string): Review[] {
+      const rows = db.prepare('SELECT * FROM reviews WHERE pluginName = ?').all(pluginName) as Record<string, unknown>[];
+      return rows.map(rowToReview);
+    },
+
+    getAverageRating(pluginName: string): number {
+      const rows = db.prepare('SELECT rating FROM reviews WHERE pluginName = ? AND flagged = 0').all(pluginName) as { rating: number }[];
+      if (rows.length === 0) return 0;
+      const sum = rows.reduce((acc, r) => acc + r.rating, 0);
+      return sum / rows.length;
+    },
+
+    flagReview(reviewId: number): void {
+      db.prepare('UPDATE reviews SET flagged = 1 WHERE id = ?').run(reviewId);
+    },
+
+    getFlaggedReviews(): Review[] {
+      const rows = db.prepare('SELECT * FROM reviews WHERE flagged = 1').all() as Record<string, unknown>[];
+      return rows.map(rowToReview);
+    },
+
+    removeReview(reviewId: number): boolean {
+      const result = db.prepare('DELETE FROM reviews WHERE id = ?').run(reviewId);
+      return result.changes > 0;
+    },
+
+    getReviewsByUser(userId: string): Review[] {
+      const rows = db.prepare('SELECT * FROM reviews WHERE userId = ?').all(userId) as Record<string, unknown>[];
+      return rows.map(rowToReview);
+    },
+
+    getReviewCount(pluginName: string): number {
+      const row = db.prepare('SELECT COUNT(*) as count FROM reviews WHERE pluginName = ?').get(pluginName) as { count: number };
+      return row.count;
+    },
+  };
+}
