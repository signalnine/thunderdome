+import vm from 'vm';
+import type { SandboxResult, RunnerService } from '../types.js';
+
+const DEFAULT_TIMEOUT_MS = 5000;
+
+export function createRunner(): RunnerService {
+  async function runInSandbox(
+    code: string,
+    timeoutMs: number,
+    context?: Record<string, unknown>
+  ): Promise<SandboxResult> {
+    const startTime = Date.now();
+    const startMemory = process.memoryUsage().heapUsed;
+
+    try {
+      const exports: Record<string, unknown> = {};
+      const sandbox = vm.createContext({
+        exports,
+        ...context,
+      });
+
+      const script = new vm.Script(code);
+      script.runInContext(sandbox, { timeout: timeoutMs });
+
+      const duration = Date.now() - startTime;
+      const memoryUsed = process.memoryUsage().heapUsed - startMemory;
+
+      return {
+        success: true,
+        output: exports,
+        duration,
+        memoryUsed: Math.max(0, memoryUsed),
+      };
+    } catch (err: unknown) {
+      const duration = Date.now() - startTime;
+      const memoryUsed = process.memoryUsage().heapUsed - startMemory;
+      const error = err instanceof Error ? err.message : String(err);
+      const isTimeout = error.includes('Script execution timed out') || error.toLowerCase().includes('timeout');
+
+      return {
+        success: false,
+        output: null,
+        duration,
+        memoryUsed: Math.max(0, memoryUsed),
+        error: isTimeout ? `Execution timeout after ${timeoutMs}ms` : error,
+      };
+    }
+  }
+
+  return {
+    execute(code: string, context?: Record<string, unknown>): Promise<SandboxResult> {
+      return runInSandbox(code, DEFAULT_TIMEOUT_MS, context);
+    },
+
+    executeWithTimeout(code: string, timeoutMs: number, context?: Record<string, unknown>): Promise<SandboxResult> {
+      return runInSandbox(code, timeoutMs, context);
+    },
+  };
+}
