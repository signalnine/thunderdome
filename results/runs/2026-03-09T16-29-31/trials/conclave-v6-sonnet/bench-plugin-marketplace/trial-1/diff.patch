cord<string, unknown>): Promise<SandboxResult> {\n      return runInSandbox(code, DEFAULT_TIMEOUT_MS, context);\n    },\n\n    executeWithTimeout(code: string, timeoutMs: number, context?: Record<string, unknown>): Promise<SandboxResult> {\n      return runInSandbox(code, timeoutMs, context);\n    },\n  };\n}\n```\n\n**Step 4: Run test to verify it passes**\n\n```bash\ncd /workspace && npx vitest run src/runner/runner.test.ts 2>&1 | tail -20\n```\nExpected: PASS\n\n**Step 5: Commit**\n\n```bash\ncd /workspace && git add src/runner/ && git commit -m \"feat: implement sandboxed runner using Node.js vm module\"\n```\n\n---\n\n### Task 4: Review System\n\n**Files:**\n- Create: `src/reviews/index.ts`\n- Create: `src/reviews/reviews.test.ts`\n\n**Dependencies:** none\n\n**Step 1: Write the failing tests**\n\n```typescript\n// src/reviews/reviews.test.ts\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { createReviewService } from './index.js';\n\ndescribe('ReviewService', () => {\n  let service: ReturnType<typeof createReviewService>;\n\n  beforeEach(() => {\n    service = createReviewService();\n  });\n\n  it('adds and retrieves reviews for a plugin', () => {\n    const review = service.addReview({\n      pluginName: 'cool-plugin',\n      pluginVersion: '1.0.0',\n      userId: 'user1',\n      rating: 5,\n      comment: 'Awesome!',\n    });\n    expect(review.id).toBeDefined();\n    expect(review.flagged).toBe(false);\n    expect(review.createdAt).toBeDefined();\n    const reviews = service.getReviews('cool-plugin');\n    expect(reviews).toHaveLength(1);\n    expect(reviews[0].comment).toBe('Awesome!');\n  });\n\n  it('computes average rating excluding flagged reviews', () => {\n    service.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });\n    service.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: '' });\n    expect(service.getAverageRating('p')).toBe(4);\n\n    // Flag