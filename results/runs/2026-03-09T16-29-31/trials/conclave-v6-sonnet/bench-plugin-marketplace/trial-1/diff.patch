   return rows.map(rowToReview);\n    },\n\n    getAverageRating(pluginName: string): number {\n      const rows = db.prepare('SELECT rating FROM reviews WHERE pluginName = ? AND flagged = 0').all(pluginName) as { rating: number }[];\n      if (rows.length === 0) return 0;\n      const sum = rows.reduce((acc, r) => acc + r.rating, 0);\n      return sum / rows.length;\n    },\n\n    flagReview(reviewId: number): void {\n      db.prepare('UPDATE reviews SET flagged = 1 WHERE id = ?').run(reviewId);\n    },\n\n    getFlaggedReviews(): Review[] {\n      const rows = db.prepare('SELECT * FROM reviews WHERE flagged = 1').all() as Record<string, unknown>[];\n      return rows.map(rowToReview);\n    },\n\n    removeReview(reviewId: number): boolean {\n      const result = db.prepare('DELETE FROM reviews WHERE id = ?').run(reviewId);\n      return result.changes > 0;\n    },\n\n    getReviewsByUser(userId: string): Review[] {\n      const rows = db.prepare('SELECT * FROM reviews WHERE userId = ?').all(userId) as Record<string, unknown>[];\n      return rows.map(rowToReview);\n    },\n\n    getReviewCount(pluginName: string): number {\n      const row = db.prepare('SELECT COUNT(*) as count FROM reviews WHERE pluginName = ?').get(pluginName) as { count: number };\n      return row.count;\n    },\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":617,"cache_read_input_tokens":50746,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":617},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"5166ceb0-5040-47e2-9af7-ab90016811d5","uuid":"3b63d9c2-46b9-4be5-9da8-53aaaea09e58"}
