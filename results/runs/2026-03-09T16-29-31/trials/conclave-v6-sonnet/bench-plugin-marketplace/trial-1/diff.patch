+++ b/src/deps/deps.test.ts
@@ -0,0 +1,70 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { createDepsService } from './index.js';
+import { createRegistry } from '../registry/index.js';
+
+function makeManifest(name: string, deps: Record<string, string> = {}) {
+  return { name, version: '1.0.0', description: '', author: '', dependencies: deps, entryPoint: '', permissions: [] };
+}
+
+describe('DepsService', () => {
+  let registry: ReturnType<typeof createRegistry>;
+  const deps = createDepsService();
+
+  beforeEach(() => {
+    registry = createRegistry();
+  });
+
+  it('builds a dependency tree', () => {
+    registry.register(makeManifest('root', { child: '1.0.0' }));
+    registry.register(makeManifest('child'));
+    const tree = deps.buildTree('root', registry);
+    expect(tree.name).toBe('root');
+    expect(tree.dependencies).toHaveLength(1);
+    expect(tree.dependencies[0].name).toBe('child');
+  });
+
+  it('detects circular dependencies', () => {
+    registry.register(makeManifest('a', { b: '1.0.0' }));
+    registry.register(makeManifest('b', { a: '1.0.0' }));
+    const cycles = deps.detectCycles('a', registry);
+    expect(cycles).not.toBeNull();
+    expect(cycles!.length).toBeGreaterThan(0);
+  });
+
+  it('returns null when no cycles', () => {
+    registry.register(makeManifest('a', { b: '1.0.0' }));
+    registry.register(makeManifest('b'));
+    const cycles = deps.detectCycles('a', registry);
+    expect(cycles).toBeNull();
+  });
+
+  it('produces topological sort', () => {
+    registry.register(makeManifest('a', { b: '1.0.0', c: '1.0.0' }));
+    registry.register(makeManifest('b', { c: '1.0.0' }));
+    registry.register(makeManifest('c'));
+    const order = deps.topologicalSort('a', registry);
+    expect(order.indexOf('c')).toBeLessThan(order.indexOf('b'));
+    expect(order.indexOf('b')).toBeLessThan(order.indexOf('a'));
+  });
+
+  it('flattens transitive dependencies', () => {
+    registry.register(makeManifest('a', { b: '1.0.0' }));
+    registry.register(makeManifest('b', { c: '1.0.0' }));
+    registry.register(makeManifest('c'));
+    const flat = deps.flattenDependencies('a', registry);
+    expect(flat).toContain('b');
+    expect(flat).toContain('c');
+    expect(flat).not.toContain('a');
+  });
+
+  it('hasCircularDependency returns true/false', () => {
+    registry.register(makeManifest('x', { y: '1.0.0' }));
+    registry.register(makeManifest('y', { x: '1.0.0' }));
+    expect(deps.hasCircularDependency('x', registry)).toBe(true);
+
+    const reg2 = createRegistry();
+    reg2.register(makeManifest('p', { q: '1.0.0' }));
+    reg2.register(makeManifest('q'));
+    expect(deps.hasCircularDependency('p', reg2)).toBe(false);
+  });
+});
diff --git a/src/deps/index.ts b/src/deps/index.ts
new file mode 100644
index 0000000..cf88f61
--- /dev/null
+++ b/src/deps/index.ts
@@ -0,0 +1,84 @@
+import type { DependencyNode, DepsService, RegistryService } from '../types.js';
+
+export function createDepsService(): DepsService {
+  function buildTreeHelper(name: string, registry: RegistryService, visiting: Set<string>): DependencyNode {
+    const manifest = registry.get(name);
+    if (!manifest) return { name, version: 'unknown', dependencies: [] };
+    if (visiting.has(name)) return { name, version: manifest.version, dependencies: [] };
+    const newVisiting = new Set(visiting);
+    newVisiting.add(name);
+    const depNodes = Object.keys(manifest.dependencies).map(depName =>
+      buildTreeHelper(depName, registry, newVisiting)
+    );
+    return { name, version: manifest.version, dependencies: depNodes };
+  }
+
+  function findCycles(name: string, registry: RegistryService): string[][] {
+    const cycles: string[][] = [];
+
+    function dfs(current: string, path: string[], visiting: Set<string>): void {
+      if (visiting.has(current)) {
+        const cycleStart = path.indexOf(current);
+        if (cycleStart !== -1) {
+          cycles.push([...path.slice(cycleStart), current]);
+        }
+        return;
+      }
+      visiting.add(current);
+      path.push(current);
+      const manifest = registry.get(current);
+      if (manifest) {
+        for (const dep of Object.keys(manifest.dependencies)) {
+          dfs(dep, [...path], new Set(visiting));
+        }
+      }
+    }
+
+    dfs(name, [], new Set());
+    return cycles;
+  }
+
+  function topoSort(name: string, registry: RegistryService): string[] {
+    const visited = new Set<string>();
+    const result: string[] = [];
+
+    function dfs(current: string): void {
+      if (visited.has(current)) return;
+      visited.add(current);
+      const manifest = registry.get(current);
+      if (manifest) {
+        for (const dep of Object.keys(manifest.dependencies)) {
+          dfs(dep);
+        }
+      }
+      result.push(current);
+    }
+
+    dfs(name);
+    return result;
+  }
+
+  return {
+    buildTree(name: string, registry: RegistryService): DependencyNode {
+      return buildTreeHelper(name, registry, new Set());
+    },
+
+    detectCycles(name: string, registry: RegistryService): string[][] | null {
+      const cycles = findCycles(name, registry);
+      return cycles.length > 0 ? cycles : null;
+    },
+
+    topologicalSort(name: string, registry: RegistryService): string[] {
+      return topoSort(name, registry);
+    },
+
+    flattenDependencies(name: string, registry: RegistryService): string[] {
+      const order = topoSort(name, registry);
+      return order.filter(n => n !== name);
+    },
+
+    hasCircularDependency(name: string, registry: RegistryService): boolean {
+      return findCycles(name, registry).length > 0;
+    },
+  };
+}
diff --git a/src/index.ts b/src/index.ts
new file mode 100644
index 0000000..cd4786d
--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,64 @@
+import { createRegistry } from './registry/index.js';
+import { createResolver } from './resolver/index.js';
+import { createRunner } from './runner/index.js';
+import { createReviewService } from './reviews/index.js';
+import { createDepsService } from './deps/index.js';
+import type { PluginManifest, ResolvedVersion, SandboxResult } from './types.js';
+
+export interface InstallResult {
+  resolvedDeps: ResolvedVersion[];
+  sandboxResult: SandboxResult;
+}
+
+export interface Marketplace {
+  registry: ReturnType<typeof createRegistry>;
+  resolver: ReturnType<typeof createResolver>;
+  runner: ReturnType<typeof createRunner>;
+  reviews: ReturnType<typeof createReviewService>;
+  deps: ReturnType<typeof createDepsService>;
+  installPlugin(manifest: PluginManifest): Promise<InstallResult>;
+}
+
+export function createMarketplace(): Marketplace {
+  const registry = createRegistry();
+  const resolver = createResolver();
+  const runner = createRunner();
+  const reviews = createReviewService();
+  const deps = createDepsService();
+
+  async function installPlugin(manifest: PluginManifest): Promise<InstallResult> {
+    // Validate required fields
+    if (!manifest.name || !manifest.version || !manifest.entryPoint) {
+      throw new Error('Plugin manifest must have name, version, and entryPoint');
+    }
+
+    // Register the plugin
+    registry.register(manifest);
+
+    // Resolve dependencies
+    const depConstraints = Object.entries(manifest.dependencies).map(([name, range]) => ({ name, range }));
+    let resolvedDeps: ResolvedVersion[] = [];
+
+    if (depConstraints.length > 0) {
+      const available: Record<string, string[]> = {};
+      for (const { name } of depConstraints) {
+        available[name] = registry.listVersions(name);
+      }
+      resolvedDeps = resolver.resolve(depConstraints, available);
+    }
+
+    // Check for circular dependencies
+    if (deps.hasCircularDependency(manifest.name, registry)) {
+      throw new Error(`Circular dependency detected for plugin "${manifest.name}"`);
+    }
+
+    // Execute the entry point in the sandbox
+    const sandboxResult = await runner.execute(manifest.entryPoint);
+
+    return { resolvedDeps, sandboxResult };
+  }
+
+  return { registry, resolver, runner, reviews, deps, installPlugin };
+}
+
+export * from './types.js';
