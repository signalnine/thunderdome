evaluate(node.left, getter);\n      const r = evaluate(node.right, getter);\n      switch (node.op) {\n        case '+': return (l as number) + (r as number);\n        case '-': return (l as number) - (r as number);\n        case '*': return (l as number) * (r as number);\n        case '/': return (l as number) / (r as number);\n        case '>': return (l as number) > (r as number);\n        case '<': return (l as number) < (r as number);\n        case '>=': return (l as number) >= (r as number);\n        case '<=': return (l as number) <= (r as number);\n        case '=': return l === r;\n        case '<>': return l !== r;\n        default: throw new Error(`Unknown operator: ${node.op}`);\n      }\n    }\n\n    case 'func': {\n      const name = node.name;\n\n      if (name === 'IF') {\n        if (node.args.length !== 3) throw new Error('IF requires 3 arguments');\n        const cond = evaluate(node.args[0], getter);\n        return cond ? evaluate(node.args[1], getter) : evaluate(node.args[2], getter);\n      }\n\n      // Range functions: first arg should be a range node\n      const rangeArg = node.args[0];\n      if (rangeArg.type !== 'range') throw new Error(`${name} expects a range argument`);\n      const cells = expandRange(rangeArg.start, rangeArg.end);\n      const nums = cells\n        .map((ref) => getter(ref))\n        .filter((v): v is number => typeof v === 'number');\n\n      switch (name) {\n        case 'SUM': return nums.reduce((a, b) => a + b, 0);\n        case 'AVERAGE': return nums.length > 0 ? nums.reduce((a, b) => a + b, 0) / nums.length : 0;\n        case 'MIN': return nums.length > 0 ? Math.min(...nums) : 0;\n        case 'MAX': return nums.length > 0 ? Math.max(...nums) : 0;\n        case 'COUNT': return nums.length;\n        default: throw new Error(`Unknown function: ${name}`);\n      }\n    }\n\n    case 'range':\n      throw new Error('Range cannot appear outside a function call');\n  }\n}\n\n/** Collect all cell references that a formula AST depends on. */\nfunction collectDeps(node: ASTNode): string[] {\n  switch (node.type) {\n    case 'number':\n    case 'string':\n    case 'boolean':\n      return [];\n    case 'cell':\n      return [node.ref];\n    case 'range':\n      return expandRange(node.start, node.end);\n    case 'binop':\n      return [...collectDeps(node.left), ...collectDeps(node.right)];\n    case 'func':\n      return node.args.flatMap(collectDeps);\n  }\n}\n\n// ─── Spreadsheet class ───────────────────────────────────────────────────────\n\ninterface CellData {\n  /** Raw input: string formula, number, boolean, or string text. */\n  raw: string | number | boolean;\n  /** Parsed AST for formula cells. */\n  ast: ASTNode | null;\n  /** Computed value. */\n  value: CellValue;\n  /** Cells this cell depends on (only non-empty if formula). */\n  deps: string[];\n}\n\nexport class Spreadsheet {\n  /** Stores cell data keyed by canonical cell reference string. */\n  private cells = new Map<string, CellData>();\n\n  /** Forward dependency map: for each cell, the set of cells that depend on it. */\n  private dependents = new Map<string, Set<string>>();\n\n  set(cell: string, value: string | number | boolean): void {\n    // Normalise cell reference\n    const ref = cell.toUpperCase();\n\n    // Parse formula if applicable\n    let ast: ASTNode | null = null;\n    let deps: string[] = [];\n\n    if (typeof value === 'string' && value.startsWith('=')) {\n      const formulaBody = value.slice(1);\n      ast = new Parser(formulaBody).parseExpr();\n      deps = [...new Set(collectDeps(ast))];\n    }\n\n    // Circular reference detection: build proposed dependency graph and DFS\n    if (deps.length > 0) {\n      this.detectCycle(ref, deps);\n    }\n\n    // Remove old dependency registrations for this cell\n    const existing = this.cells.get(ref);\n    if (existing) {\n      for (const dep of existing.deps) {\n        this.dependents.get(dep)?.delete(ref);\n      }\n    }\n\n    // Regi