+import { describe, test, expect } from 'vitest';
+import { Spreadsheet } from './index.js';
+
+// ─── Cell address parsing ────────────────────────────────────────────────────
+describe('cell address parsing', () => {
+  test('single letter column A1', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', 42);
+    expect(sheet.get('A1')).toBe(42);
+  });
+
+  test('single letter column Z1', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('Z1', 99);
+    expect(sheet.get('Z1')).toBe(99);
+  });
+
+  test('double letter column AA1', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('AA1', 7);
+    expect(sheet.get('AA1')).toBe(7);
+  });
+
+  test('double letter column AZ1', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('AZ1', 3);
+    expect(sheet.get('AZ1')).toBe(3);
+  });
+
+  test('double letter column BA1', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('BA1', 5);
+    expect(sheet.get('BA1')).toBe(5);
+  });
+
+  test('large row number', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A100', 1);
+    expect(sheet.get('A100')).toBe(1);
+  });
+
+  test('empty cell returns null', () => {
+    const sheet = new Spreadsheet();
+    expect(sheet.get('A1')).toBeNull();
+  });
+});
+
+// ─── Basic set/get ───────────────────────────────────────────────────────────
+describe('basic set/get', () => {
+  test('sets and gets a number', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('B2', 3.14);
+    expect(sheet.get('B2')).toBe(3.14);
+  });
+
+  test('sets and gets a string', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('C3', 'hello');
+    expect(sheet.get('C3')).toBe('hello');
+  });
+
+  test('sets and gets a boolean true', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('D4', true);
+    expect(sheet.get('D4')).toBe(true);
+  });
+
+  test('sets and gets a boolean false', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('E5', false);
+    expect(sheet.get('E5')).toBe(false);
+  });
+
+  test('overwriting a value replaces it', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', 10);
+    sheet.set('A1', 20);
+    expect(sheet.get('A1')).toBe(20);
+  });
+
+  test('getCells returns all non-empty cells', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', 1);
+    sheet.set('B2', 2);
+    const cells = sheet.getCells();
+    expect(cells.get('A1')).toBe(1);
+    expect(cells.get('B2')).toBe(2);
+    expect(cells.size).toBe(2);
+  });
+
+  test('getDisplay returns string representation of number', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', 42);
+    expect(sheet.getDisplay('A1')).toBe('42');
+  });
+
+  test('getDisplay returns string value directly', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', 'hello');
+    expect(sheet.getDisplay('A1')).toBe('hello');
+  });
+
+  test('getDisplay returns boolean as string', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', true);
+    expect(sheet.getDisplay('A1')).toBe('true');
+  });
+
+  test('getDisplay returns empty string for empty cell', () => {
+    const sheet = new Spreadsheet();
+    expect(sheet.getDisplay('A1')).toBe('');
+  });
+});
+
+// ─── Formulas: arithmetic ────────────────────────────────────────────────────
+describe('formula arithmetic', () => {
+  test('constant formula returns number', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', '=5');
+    expect(sheet.get('A1')).toBe(5);
+  });
+
+  test('addition of two numbers', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', '=1+2');
+    expect(sheet.get('A1')).toBe(3);
+  });
+
+  test('subtraction', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', '=10-3');
+    expect(sheet.get('A1')).toBe(7);
+  });
+
+  test('multiplication', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', '=3*4');
+    expect(sheet.get('A1')).toBe(12);
+  });
+
+  test('division', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', '=8/2');
+    expect(sheet.get('A1')).toBe(4);
+  });
+
+  test('operator precedence: multiplication before addition', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', '=2+3*4');
+    expect(sheet.get('A1')).toBe(14);
+  });
+
+  test('parentheses override precedence', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', '=(2+3)*4');
+    expect(sheet.get('A1')).toBe(20);
+  });
+
+  test('cell reference in formula', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', 10);
+    sheet.set('B1', '=A1');
+    expect(sheet.get('B1')).toBe(10);
+  });
+
+  test('formula with two cell references', () => {
