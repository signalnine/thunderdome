+// ─── Reactive updates ────────────────────────────────────────────────────────
+describe('reactive updates', () => {
+  test('formula cell updates when dependency changes', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', 5);
+    sheet.set('B1', '=A1+1');
+    expect(sheet.get('B1')).toBe(6);
+    sheet.set('A1', 10);
+    expect(sheet.get('B1')).toBe(11);
+  });
+
+  test('chain of dependent cells all update', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', 1);
+    sheet.set('B1', '=A1+1');
+    sheet.set('C1', '=B1+1');
+    expect(sheet.get('C1')).toBe(3);
+    sheet.set('A1', 10);
+    expect(sheet.get('B1')).toBe(11);
+    expect(sheet.get('C1')).toBe(12);
+  });
+
+  test('multiple dependents update when shared dependency changes', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', 5);
+    sheet.set('B1', '=A1*2');
+    sheet.set('C1', '=A1*3');
+    sheet.set('A1', 10);
+    expect(sheet.get('B1')).toBe(20);
+    expect(sheet.get('C1')).toBe(30);
+  });
+
+  test('SUM formula updates reactively', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', 10);
+    sheet.set('A2', 20);
+    sheet.set('B1', '=SUM(A1:A2)');
+    expect(sheet.get('B1')).toBe(30);
+    sheet.set('A1', 50);
+    expect(sheet.get('B1')).toBe(70);
+  });
+
+  test('example from spec: A1=10, A2=20, A3=A1+A2, change A1 to 50', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', 10);
+    sheet.set('A2', 20);
+    sheet.set('A3', '=A1+A2');
+    expect(sheet.get('A3')).toBe(30);
+    sheet.set('A1', 50);
+    expect(sheet.get('A3')).toBe(70);
+  });
+});
