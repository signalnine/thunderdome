  }\n    return left;\n  }","originalFile":"// ─── Cell address utilities ──────────────────────────────────────────────────\n\n/** Convert column letters (A, Z, AA, AZ, BA…) to 0-based column index. */\nfunction colLettersToIndex(letters: string): number {\n  let result = 0;\n  for (let i = 0; i < letters.length; i++) {\n    result = result * 26 + (letters.charCodeAt(i) - 64); // A=1, Z=26\n  }\n  return result - 1; // 0-based\n}\n\n/** Convert 0-based column index back to column letters. */\nfunction indexToColLetters(index: number): string {\n  let result = '';\n  let n = index + 1; // 1-based for conversion\n  while (n > 0) {\n    const rem = (n - 1) % 26;\n    result = String.fromCharCode(65 + rem) + result;\n    n = Math.floor((n - 1) / 26);\n  }\n  return result;\n}\n\n/** Parse a cell reference string like \"A1\" or \"AA10\" into {col, row} (both 0-based). */\nfunction parseCell(ref: string): { col: number; row: number } {\n  const match = ref.match(/^([A-Z]+)(\\d+)$/);\n  if (!match) throw new Error(`Invalid cell reference: ${ref}`);\n  const col = colLettersToIndex(match[1]);\n  const row = parseInt(match[2], 10) - 1; // 0-based\n  return { col, row };\n}\n\n/** Expand a range like \"A1:C3\" into an array of canonical cell reference strings. */\nfunction expandRange(start: string, end: string): string[] {\n  const s = parseCell(start);\n  const e = parseCell(end);\n  const minCol = Math.min(s.col, e.col);\n  const maxCol = Math.max(s.col, e.col);\n  const minRow = Math.min(s.row, e.row);\n  const maxRow = Math.max(s.row, e.row);\n  const cells: string[] = [];\n  for (let row = minRow; row <= maxRow; row++) {\n    for (let col = minCol; col <= maxCol; col++) {\n      cells.push(`${indexToColLetters(col)}${row + 1}`);\n    }\n  }\n  return cells;\n}\n\n// ─── AST types ───────────────────────────────────────────────────────────────\n\ntype ASTNode =\n  | { type: 'number'; value: number }\n  | { type: 'string'; value: string }\n  | { type: 'boolean'; value: boolean }\n  | { type: 'cell'; ref: string }\n  | { type: 'range'; start: string; end: string }\n  | { type: 'binop'; op: string; left: ASTNode; right: ASTNode }\n  | { type: 'func'; name: string; args: ASTNode[] };\n\n// ─── Parser ──────────────────────────────────────────────────────────────────\n\nclass Parser {\n  private pos = 0;\n  constructor(private src: string) {}\n\n  private peek(): string {\n    return this.src[this.pos] ?? '';\n  }\n\n  private consume(expected?: string): string {\n    const ch = this.src[this.pos++];\n    if (expected !== undefined && ch !== expected) {\n      throw new Error(`Expected '${expected}' but got '${ch}' at ${this.pos - 1}`);\n    }\n    return ch;\n  }\n\n  private skipWhitespace(): void {\n    while (this.pos < this.src.length && /\\s/.test(this.src[this.pos])) {\n      this.pos++;\n    }\n  }\n\n  /** Top-level entry: parses a comparison or arithmetic expression. */\n  parseExpr(): ASTNode {\n    return this.parseComparison();\n  }\n\n  /** Handles comparison operators: >, <, >=, <=, =, <> */\n  private parseComparison(): ASTNode {\n    let left = this.parseAddSub();\n    this.skipWhitespace();\n    const ops = ['<>', '>=', '<=', '>', '<', '='];\n    for (const op of ops) {\n      if (this.src.startsWith(op, this.pos)) {\n        this.pos += op.length;\n        this.skipWhitespace();\n        const right = this.parseAddSub();\n        left = { type: 'binop', op, left, right };\n        return left; // single comparison only\n      }\n    }\n    return left;\n  }\n\n  private parseAddSub(): ASTNode {\n    let left = this.parseMulDiv();\n    while (true) {\n      this.skipWhitespace();\n      const ch = this.peek();\n      if (ch === '+' || ch === '-') {\n        this.pos++;\n        this.skipWhitespace();\n        const right = this.parseMulDiv();\n        left = { type: 'binop', op: ch, left, right };\n      } else {\n        break;\n      }\n    }\n    return left;\n  }\n\n  private parseMulDiv(): ASTNode {\n    let left = this.parseUnary();\n    while (true) {\n      this.skipWhitespace();\n      const ch = this.peek();\n      if (ch === '*' || ch === '/') {\n        this.pos++;\n        this.skipWhitespace();\n        const right = this.parseUnary();\n        left = { type: 'binop', op: ch, left, right };\n      } else {\n        break;\n      }\n    }\n    return left;\n  }\n\n  private parseUnary(): ASTNode {\n    this.skipWhitespace();\n    if (this.peek() === '-') {\n      this.pos++;\n      const operand = this.parsePrimary();\n      return { type: 'binop', op: '*', left: { type: 'number', value: -1 }, right: operand };\n    }\n    return this.parsePrimary();\n  }\n\n  private parsePrimary(): ASTNode {\n    this.skipWhitespace();\n    const ch = this.peek();\n\n    // String literal\n    if (ch === '\"') {\n      this.pos++;\n      let str = '';\n      while (this.pos < this.src.length && this.src[this.pos] !== '\"') {\n        str += this.src[this.pos++];\n      }\n      this.consume('\"');\n      return { type: 'string', value: str };\n    }\n\n    // Parenthesised expression\n    if (ch === '(') {\n      this.pos++;\n      const inner = this.parseExpr();\n      this.skipWhitespace();\n      this.consume(')');\n      return inner;\n    }\n\n    // Number\n    if (/\\d/.test(ch) || (ch === '.' && /\\d/.test(this.src[this.pos + 1] ?? ''))) {\n      return this.parseNumber();\n    }\n\n    // Identifier: function name, cell reference, range, or boolean literal\n    if (/[A-Za-z]/.test(ch)) {\n      return this.parseIdentifier();\n    }\n\n    throw new Error(`Unexpected character '${ch}' at position ${this.pos}`);\n  }\n\n  private parseNumber(): ASTNode {\n    let num = '';\n    while (this.pos < this.src.length && /[\\d.]/.test(this.src[this.pos])) {\n      num += this.src[this.pos++];\n    }\n    return { type: 'number', value: parseFloat(num) };\n  }\n\n  private parseIdentifier(): ASTNode {\n    // Read only letters for the identifier base (function names and column lett