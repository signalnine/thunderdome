+// ─── Circular reference detection ────────────────────────────────────────────
+describe('circular reference detection', () => {
+  test('direct self-reference throws', () => {
+    const sheet = new Spreadsheet();
+    expect(() => sheet.set('A1', '=A1')).toThrow();
+  });
+
+  test('two-cell cycle throws', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', '=B1+1');
+    expect(() => sheet.set('B1', '=A1+1')).toThrow();
+  });
+
+  test('indirect cycle through three cells throws', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', '=B1+1');
+    sheet.set('B1', '=C1+1');
+    expect(() => sheet.set('C1', '=A1+1')).toThrow();
+  });
+
+  test('circular reference does not corrupt existing value', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', 42);
+    sheet.set('B1', '=A1+1');
+    expect(() => sheet.set('A1', '=B1')).toThrow();
+    // A1 should still hold its old value after failed set
+    expect(sheet.get('A1')).toBe(42);
+  });
+
+  test('valid non-circular formula does not throw', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', 10);
+    expect(() => sheet.set('B1', '=A1+1')).not.toThrow();
+  });
+});
