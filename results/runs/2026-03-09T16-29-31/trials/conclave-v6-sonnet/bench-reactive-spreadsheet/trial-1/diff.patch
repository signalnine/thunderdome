index 0000000..e9daaaf
--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,479 @@
+// ─── Cell address utilities ──────────────────────────────────────────────────
+
+/** Convert column letters (A, Z, AA, AZ, BA…) to 0-based column index. */
+function colLettersToIndex(letters: string): number {
+  let result = 0;
+  for (let i = 0; i < letters.length; i++) {
+    result = result * 26 + (letters.charCodeAt(i) - 64); // A=1, Z=26
+  }
+  return result - 1; // 0-based
+}
+
+/** Convert 0-based column index back to column letters. */
+function indexToColLetters(index: number): string {
+  let result = '';
+  let n = index + 1; // 1-based for conversion
+  while (n > 0) {
+    const rem = (n - 1) % 26;
+    result = String.fromCharCode(65 + rem) + result;
+    n = Math.floor((n - 1) / 26);
+  }
+  return result;
+}
+
+/** Parse a cell reference string like "A1" or "AA10" into {col, row} (both 0-based). */
+function parseCell(ref: string): { col: number; row: number } {
+  const match = ref.match(/^([A-Z]+)(\d+)$/);
+  if (!match) throw new Error(`Invalid cell reference: ${ref}`);
+  const col = colLettersToIndex(match[1]);
+  const row = parseInt(match[2], 10) - 1; // 0-based
+  return { col, row };
+}
+
+/** Expand a range like "A1:C3" into an array of canonical cell reference strings. */
+function expandRange(start: string, end: string): string[] {
+  const s = parseCell(start);
+  const e = parseCell(end);
+  const minCol = Math.min(s.col, e.col);
+  const maxCol = Math.max(s.col, e.col);
+  const minRow = Math.min(s.row, e.row);
+  const maxRow = Math.max(s.row, e.row);
+  const cells: string[] = [];
+  for (let row = minRow; row <= maxRow; row++) {
+    for (let col = minCol; col <= maxCol; col++) {
+      cells.push(`${indexToColLetters(col)}${row + 1}`);
+    }
+  }
+  return cells;
+}
+
+// ─── AST types ───────────────────────────────────────────────────────────────
+
+type ASTNode =
+  | { type: 'number'; value: number }
+  | { type: 'string'; value: string }
+  | { type: 'boolean'; value: boolean }
+  | { type: 'cell'; ref: string }
+  | { type: 'range'; start: string; end: string }
+  | { type: 'binop'; op: string; left: ASTNode; right: ASTNode }
+  | { type: 'func'; name: string; args: ASTNode[] };
+
+// ─── Parser ──────────────────────────────────────────────────────────────────
+
+class Parser {
+  private pos = 0;
+  constructor(private src: string) {}
+
+  private peek(): string {
+    return this.src[this.pos] ?? '';
+  }
+
+  private consume(expected?: string): string {
+    const ch = this.src[this.pos++];
+    if (expected !== undefined && ch !== expected) {
+      throw new Error(`Expected '${expected}' but got '${ch}' at ${this.pos - 1}`);
+    }
+    return ch;
+  }
+
+  private skipWhitespace(): void {
+    while (this.pos < this.src.length && /\s/.test(this.src[this.pos])) {
+      this.pos++;
+    }
+  }
+
+  /** Top-level entry: parses a comparison or arithmetic expression. */
+  parseExpr(): ASTNode {
+    return this.parseComparison();
+  }
+
+  /** Handles comparison operators: >, <, >=, <=, =, <> */
+  private parseComparison(): ASTNode {
+    let left = this.parseAddSub();
+    this.skipWhitespace();
+    const ops = ['<>', '>=', '<=', '>', '<', '='];
+    for (const op of ops) {
+      if (this.src.startsWith(op, this.pos)) {
+        this.pos += op.length;
+        this.skipWhitespace();
+        const right = this.parseAddSub();
+        left = { type: 'binop', op, left, right };
+        return left; // single comparison only
+      }
+    }
+    return left;
+  }
+
+  private parseAddSub(): ASTNode {
+    let left = this.parseMulDiv();
+    this.skipWhitespace();
+    let ch = this.peek();
+    while (ch === '+' || ch === '-') {
+      this.pos++;
+      this.skipWhitespace();
+      const right = this.parseMulDiv();
+      left = { type: 'binop', op: ch, left, right };
+      this.skipWhitespace();
+      ch = this.peek();
+    }
+    return left;
+  }
+
+  private parseMulDiv(): ASTNode {
+    let left = this.parseUnary();
+    this.skipWhitespace();
+    let ch = this.peek();
+    while (ch === '*' || ch === '/') {
+      this.pos++;
+      this.skipWhitespace();
+      const right = this.parseUnary();
+      left = { type: 'binop', op: ch, left, right };
+      this.skipWhitespace();
+      ch = this.peek();
+    }
+    return left;
+  }
+
+  private parseUnary(): ASTNode {
+    this.skipWhitespace();
+    if (this.peek() === '-') {
+      this.pos++;
+      const operand = this.parsePrimary();
+      return { type: 'binop', op: '*', left: { type: 'number', value: -1 }, right: operand };
+    }
+    return this.parsePrimary();
+  }
+
+  private parsePrimary(): ASTNode {
+    this.skipWhitespace();
+    const ch = this.peek();
+
+    // String literal
+    if (ch === '"') {
+      this.pos++;
+      let str = '';
+      while (this.pos < this.src.length && this.src[this.pos] !== '"') {
+        str += this.src[this.pos++];
+      }
+      this.consume('"');
+      return { type: 'string', value: str };
+    }
+
+    // Parenthesised expression
+    if (ch === '(') {
+      this.pos++;
+      const inner = this.parseExpr();
+      this.skipWhitespace();
+      this.consume(')');
+      return inner;
+    }
+
+    // Number
+    if (/\d/.test(ch) || (ch === '.' && /\d/.test(this.src[this.pos + 1] ?? ''))) {
+      return this.parseNumber();
+    }
+
+    // Identifier: function name, cell reference, range, or boolean literal
+    if (/[A-Za-z]/.test(ch)) {
+      return this.parseIdentifier();
+    }
+
+    throw new Error(`Unexpected character '${ch}' at position ${this.pos}`);
+  }
+
+  private parseNumber(): ASTNode {
+    let num = '';
+    while (this.pos < this.src.length && /[\d.]/.test(this.src[this.pos])) {
+      num += this.src[this.pos++];
+    }
+    return { type: 'number', value: parseFloat(num) };
+  }
+
+  private parseIdentifier(): ASTNode {
+    // Read only letters for the identifier base (function names and column letters)
+    let ident = '';
+    while (this.pos < this.src.length && /[A-Za-z]/.test(this.src[this.pos])) {
+      ident += this.src[this.pos++];
+    }
+
+    // Boolean literals
+    if (ident.toLowerCase() === 'true') return { type: 'boolean', value: true };
+    if (ident.toLowerCase() === 'false') return { type: 'boolean', value: false };
+
+    // Function call: identifier followed immediately by '('
+    this.skipWhitespace();
+    if (this.peek() === '(') {
+      this.pos++; // consume '('
+      const args: ASTNode[] = [];
+      this.skipWhitespace();
+      if (this.peek() !== ')') {
+        args.push(this.parseExpr());
+        this.skipWhitespace();
+        while (this.peek() === ',') {
+          this.pos++;
+          this.skipWhitespace();
+          args.push(this.parseExpr());
+          this.skipWhitespace();
+        }
+      }
+      this.consume(')');
+      return { type: 'func', name: ident.toUpperCase(), args };
+    }
+
+    // Cell reference or range
+    // ident is uppercase letters; check if followed by digits
+    const upperIdent = ident.toUpperCase();
+    if (/^[A-Z]+$/.test(upperIdent) && /\d/.test(this.peek())) {
+      let rowStr = '';
+      while (this.pos < this.src.length && /\d/.test(this.src[this.pos])) {
+        rowStr += this.src[this.pos++];
+      }
+      const cellRef = `${upperIdent}${rowStr}`;
+      // Check for range colon
+      if (this.peek() === ':') {
+        this.pos++;
+        // Parse second cell reference
+        let col2 = '';
+        while (this.pos < this.src.length && /[A-Za-z]/.test(this.src[this.pos])) {
+          col2 += this.src[this.pos++].toUpperCase();
+        }
+        let row2 = '';
+        while (this.pos < this.src.length && /\d/.test(this.src[this.pos])) {
+          row2 += this.src[this.pos++];
+        }
+        return { type: 'range', start: cellRef, end: `${col2}${row2}` };
+      }
+      return { type: 'cell', ref: cellRef };
+    }
+
+    throw new Error(`Unknown identifier: ${ident}`);
+  }
+}
+
+// ─── Evaluator ───────────────────────────────────────────────────────────────
+
+type CellValue = string | number | boolean | null;
+
+function evaluate(node: ASTNode, getter: (ref: string) => CellValue): CellValue {
+  switch (node.type) {
+    case 'number': return node.value;
+    case 'string': return node.value;
+    case 'boolean': return node.value;
+
+    case 'cell': {
+      const val = getter(node.ref);
+      return val === null ? 0 : val;
+    }
+
+    case 'binop': {
+      const l = evaluate(node.left, getter);
+      const r = evaluate(node.right, getter);
+      switch (node.op) {
+        case '+': return (l as number) + (r as number);
+        case '-': return (l as number) - (r as number);
+        case '*': return (l as number) * (r as number);
+        case '/': return (l as number) / (r as number);
+        case '>': return (l as number) > (r as number);
+        case '<': return (l as number) < (r as number);
+        case '>=': return (l as number) >= (r as number);
+        case '<=': return (l as number) <= (r as number);
+        case '=': return l === r;
+        case '<>': return l !== r;
+        default: throw new Error(`Unknown operator: ${node.op}`);
+      }
+    }
+
+    case 'func': {
+      const name = node.name;
+
+      if (name === 'IF') {
+        if (node.args.length !== 3) throw new Error('IF requires 3 arguments');
+        const cond = evaluate(node.args[0], getter);
+        return cond ? evaluate(node.args[1], getter) : evaluate(node.args[2], getter);
+      }
+
+      // Range functions: first arg should be a range node
+      const rangeArg = node.args[0];
+      if (rangeArg.type !== 'range') throw new Error(`${name} expects a range argument`);
+      const cells = expandRange(rangeArg.start, rangeArg.end);
+      const nums = cells
+        .map((ref) => getter(ref))
+        .filter((v): v is number => typeof v === 'number');
+
+      switch (name) {
+        case 'SUM': return nums.reduce((a, b) => a + b, 0);
+        case 'AVERAGE': return nums.length > 0 ? nums.reduce((a, b) => a + b, 0) / nums.length : 0;
+        case 'MIN': return nums.length > 0 ? Math.min(...nums) : 0;
+        case 'MAX': return nums.length > 0 ? Math.max(...nums) : 0;
+        case 'COUNT': return nums.length;
+        default: throw new Error(`Unknown function: ${name}`);
+      }
+    }
+
+    case 'range':
+      throw new Error('Range cannot appear outside a function call');
+  }
+}
+
+/** Collect all cell references that a formula AST depends on. */
+function collectDeps(node: ASTNode): string[] {
+  switch (node.type) {
+    case 'number':
+    case 'string':
+    case 'boolean':
+      return [];
+    case 'cell':
+      return [node.ref];
+    case 'range':
+      return expandRange(node.start, node.end);
+    case 'binop':
+      return [...collectDeps(node.left), ...collectDeps(node.right)];
+    case 'func':
+      return node.args.flatMap(collectDeps);
+  }
+}
+
+// ─── Spreadsheet class ───────────────────────────────────────────────────────
+
+interface CellData {
+  /** Raw input: string formula, number, boolean, or string text. */
+  raw: string | number | boolean;
+  /** Parsed AST for formula cells. */
+  ast: ASTNode | null;
+  /** Computed value. */
+  value: CellValue;
+  /** Cells this cell depends on (only non-empty if formula). */
+  deps: string[];
+}
+
+export class Spreadsheet {
+  /** Stores cell data keyed by canonical cell reference string. */
+  private cells = new Map<string, CellData>();
+
+  /** Forward dependency map: for each cell, the set of cells that depend on it. */
+  private dependents = new Map<string, Set<string>>();
+
+  set(cell: string, value: string | number | boolean): void {
+    // Normalise cell reference
+    const ref = cell.toUpperCase();
+
+    // Parse formula if applicable
+    let ast: ASTNode | null = null;
+    let deps: string[] = [];
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      const formulaBody = value.slice(1);
+      ast = new Parser(formulaBody).parseExpr();
+      deps = [...new Set(collectDeps(ast))];
+    }
+
+    // Circular reference detection: build proposed dependency graph and DFS
+    if (deps.length > 0) {
+      this.detectCycle(ref, deps);
+    }
+
+    // Remove old dependency registrations for this cell
+    const existing = this.cells.get(ref);
+    if (existing) {
+      for (const dep of existing.deps) {
+        this.dependents.get(dep)?.delete(ref);
+      }
+    }
+
+    // Register new dependencies
+    for (const dep of deps) {
+      if (!this.dependents.has(dep)) this.dependents.set(dep, new Set());
+      this.dependents.get(dep)!.add(ref);
+    }
+
+    // Compute value
+    const computedValue = ast
+      ? evaluate(ast, (r) => this.cells.get(r)?.value ?? null)
+      : (value as CellValue);
+
+    this.cells.set(ref, { raw: value, ast, value: computedValue, deps });
+
+    // Propagate updates to dependents in topological order
+    this.propagate(ref);
+  }
+
+  get(cell: string): CellValue {
+    return this.cells.get(cell.toUpperCase())?.value ?? null;
+  }
+
+  getDisplay(cell: string): string {
+    const val = this.get(cell);
+    if (val === null) return '';
+    return String(val);
+  }
+
+  getCells(): Map<string, CellValue> {
+    const result = new Map<string, CellValue>();
+    for (const [ref, data] of this.cells) {
+      result.set(ref, data.value);
+    }
+    return result;
+  }
+
+  // ─── Private helpers ───────────────────────────────────────────────────────
+
+  /**
+   * Detect cycles by checking if `target` is reachable from any of its new deps
+   * through the *existing* dependency graph, plus the proposed new edges.
+   *
+   * We build a temporary graph: existing edges + the proposed (dep -> target) edges
+   * and check if target is reachable from any of its deps.
+   */
+  private detectCycle(target: string, newDeps: string[]): void {
+    // Build proposed reverse graph: cell -> what it depends on
+    // (We use the deps map on each CellData)
+    const visited = new Set<string>();
+    const stack = [...newDeps];
+    while (stack.length > 0) {
+      const current = stack.pop()!;
+      if (current === target) {
+        throw new Error(`Circular reference detected involving cell ${target}`);
+      }
+      if (visited.has(current)) continue;
+      visited.add(current);
+      const data = this.cells.get(current);
+      if (data) {
+        stack.push(...data.deps);
+      }
+    }
+  }
+
+  /**
+   * Propagate value changes from `changedRef` to all transitive dependents
+   * using topological order (BFS over the forward-dependency graph, Kahn's algorithm).
+   */
+  private propagate(changedRef: string): void {
+    // Collect all cells that need recomputation via BFS
+    const toRecompute: string[] = [];
+    const seen = new Set<string>();
+    const queue: string[] = [changedRef];
+
+    while (queue.length > 0) {
+      const cur = queue.shift()!;
+      const deps = this.dependents.get(cur);
+      if (!deps) continue;
+      for (const dep of deps) {
+        if (!seen.has(dep)) {
+          seen.add(dep);
+          toRecompute.push(dep);
+          queue.push(dep);
+        }
+      }
+    }
+
+    // Recompute in topological order: for each cell in toRecompute, ensure
+    // its dependencies are computed first.  Since we collected via BFS from
+    // changedRef, we can sort by a simple count of how far they are from the
+    // source; BFS order already guarantees that.
+    for (const ref of toRecompute) {
+      const data = this.cells.get(ref);
+      if (!data || !data.ast) continue;
+      data.value = evaluate(data.ast, (r) => this.cells.get(r)?.value ?? null);
+    }
+  }
+}
