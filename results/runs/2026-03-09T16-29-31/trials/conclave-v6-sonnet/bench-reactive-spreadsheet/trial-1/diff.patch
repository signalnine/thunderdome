+// ─── IF function and comparison operators ────────────────────────────────────
+describe('IF function', () => {
+  test('IF returns trueValue when condition is true', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', 50);
+    sheet.set('B1', '=IF(A1>30, "big", "small")');
+    expect(sheet.get('B1')).toBe('big');
+  });
+
+  test('IF returns falseValue when condition is false', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', 10);
+    sheet.set('B1', '=IF(A1>30, "big", "small")');
+    expect(sheet.get('B1')).toBe('small');
+  });
+
+  test('IF with less-than comparison', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', 5);
+    sheet.set('B1', '=IF(A1<10, 1, 0)');
+    expect(sheet.get('B1')).toBe(1);
+  });
+
+  test('IF with >= comparison', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', 10);
+    sheet.set('B1', '=IF(A1>=10, 1, 0)');
+    expect(sheet.get('B1')).toBe(1);
+  });
+
+  test('IF with <= comparison', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', 9);
+    sheet.set('B1', '=IF(A1<=9, 1, 0)');
+    expect(sheet.get('B1')).toBe(1);
+  });
+
+  test('IF with = comparison (equality)', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', 5);
+    sheet.set('B1', '=IF(A1=5, 1, 0)');
+    expect(sheet.get('B1')).toBe(1);
+  });
+
+  test('IF with <> comparison (not equal)', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', 5);
+    sheet.set('B1', '=IF(A1<>3, 1, 0)');
+    expect(sheet.get('B1')).toBe(1);
+  });
+
+  test('IF with boolean true result', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', '=IF(1=1, true, false)');
+    expect(sheet.get('A1')).toBe(true);
+  });
+});
