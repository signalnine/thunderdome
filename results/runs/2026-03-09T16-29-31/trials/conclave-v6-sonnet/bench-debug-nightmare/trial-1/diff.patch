ice.getStock('SKU-1');\n    expect(stock?.available).toBe(10);\n    expect(stock?.reserved).toBe(0);\n  });\n\n  it('refuses to cancel a non-confirmed order', async () => {\n    inventoryService.setStock('SKU-1', 10);\n    await orderService.createOrder('O1', 'C1', [\n      { productId: 'SKU-1', quantity: 1, unitPrice: 10 },\n    ]);\n    await orderService.cancelOrder('O1', 'first cancel');\n    // Try to cancel again — already cancelled\n    const result = await orderService.cancelOrder('O1', 'second cancel');\n    expect(result).toBeUndefined();\n  });\n\n  it('refunds a cancelled order within 30 days', async () => {\n    inventoryService.setStock('SKU-1', 10);\n    await orderService.createOrder('O1', 'C1', [\n      { productId: 'SKU-1', quantity: 1, unitPrice: 100 },\n    ]);\n    await orderService.cancelOrder('O1', 'not needed');\n    const refunded = await orderService.refundOrder('O1');\n    expect(refunded?.status).toBe('refunded');\n  });\n\n  it('allows refund on exactly day 30', async () => {\n    inventoryService.setStock('SKU-1', 10);\n    await orderService.createOrder('O1', 'C1', [\n      { productId: 'SKU-1', quantity: 1, unitPrice: 100 },\n    ]);\n    // Manually backdate the order to exactly 30 days ago\n    const thirtyDaysMs = 30 * 24 * 60 * 60 * 1000;\n    orderRepo.update('O1', { createdAt: Date.now() - thirtyDaysMs });\n    await orderService.cancelOrder('O1', 'late cancel');\n    const refunded = await orderService.refundOrder('O1');\n    expect(refunded?.status).toBe('refunded');\n  });\n\n  it('rejects refund after 30-day window', async () => {\n    inventoryService.setStock('SKU-1', 10);\n    await orderService.createOrder('O1', 'C1', [\n      { productId: 'SKU-1', quantity: 1, unitPrice: 100 },\n    ]);\n    // Backdate to 31 days ago\n    const thirtyOneDaysMs = 31 * 24 * 60 * 60 * 1000;\n    orderRepo.update('O1', { createdAt: Date.now() - thirtyOneDaysMs });\n    await orderService.cancelOrder('O1', 'very late');\n    await expect(orderService.refundOrder('O1')).rejects.toThrow('Refund window expired');\n  });\n});\n\ndescribe('OrderRepository', () => {\n  let repo: OrderRepository;\n\n  beforeEach(() => {\n    repo = new OrderRepository();\n  });\n\n  it('creates and retrieves an order', () => {\n    const order = repo.create({\n      id: 'O1',\n      customerId: 'C1',\n      items: [],\n      status: 'pending',\n      total: 0,\n      discount: 0,\n      taxRate: 0.1,\n      createdAt: Date.now(),\n      updatedAt: Date.now(),\n    });\n    expect(repo.findById('O1')).toEqual(order);\n  });\n\n  it('updates order preserves other fields', () => {\n    repo.create({\n      id: 'O1',\n      customerId: 'C1',\n      items: [{ productId: 'A', quantity: 1, unitPrice: 10 }],\n      status: 'pending',\n      total: 10,\n      discount: 0,\n      taxRate: 0.1,\n      createdAt: 1000,\n      updatedAt: 1000,\n      notes: 'rush delivery',\n    });\n    const updated = repo.update('O1', { status: 'confirmed' });\n    expect(updated?.status).toBe('confirmed');\n    expect(updated?.customerId).toBe('C1');\n    expect(updated?.notes).toBe('rush delivery');\n    expect(updated?.items).toHaveLength(1);\n    expect(updated?.total).toBe(10);\n  });\n\n  it('returns undefined for missing order', () => {\n    expect(repo.findById('NOPE')).toBeUndefined();\n  });\n\n  it('finds orders by customer', () => {\n    repo.create({\n      id: 'O1', customerId: 'C1', items: [], status: 'pending',\n      total: 0, discount: 0, taxRate: 0, createdAt: 0, updatedAt: 0,\n    });\n    repo.create({\n      id: 'O2', customerId: 'C2', items: [], status: 'pending',\n      total: 0, discount: 0, taxRate: 0, createdAt: 0, updatedAt: 0,\n    });\n    repo.create({\n      id: 'O3', customerId: 'C1', items: [], status: 'pending',\n      total: 0, discount: 0, taxRate: 0, createdAt: 0, updatedAt: 0,\n    });\n    expect(repo.findByCustomer('C1')).toHaveLength(2);\n  });\n});\n```\n\n#### /workspace/tests/notifications.test.ts\n```typescript\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { NotificationService } from '../src/notifications/service.js';\n\ndescribe('NotificationService', () => {\n  let service: NotificationService;\n\n  beforeEach(() => {\n    service = new NotificationService();\n  });\n\n  it('sends order confirmation', () => {\n    const record = service.sendConfirmation('O1', 99.99);\n    expect(record.type).toBe('confirmation');\n    expect(record.message).toContain('O1');\n    expect(record.message).toContain('99.99');\n  });\n\n  it('sends cancellation notice', () => {\n    const record = service.sendCancellation('O1', 'changed mind');\n    expect(record.type).toBe('cancellation');\n    expect(record.message).toContain('changed mind');\n  });\n\n  it('sends refund notice', () => {\n    const record = service.sendRefundNotice('O1', 50.00);\n    expect(record.type).toBe('refund');\n    expect(record.message).toContain('50.00');\n  });\n\n  it('tracks all sent notifications', () => {\n    service.sendConfirmation('O1', 100);\n    service.sendCancellation('O2', 'duplicate');\n    service.sendRefundNotice('O3', 75);\n    expect(service.getSentNotifications()).toHaveLength(3);\n  });\n});\n```\n\n#### /workspace/tests/billing.test.ts\n```typescript\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { EventBus } from '../src/events/bus.js';\nimport { NotificationService } from '../src/notifications/service.js';\nimport { BillingService } from '../src/billing/service.js';\nimport { calculateOrderTotal } from '../src/billing/calculator.js';\n\ndescribe('calculateOrderTotal', () => {\n  it('calculates total with no discount or tax', () => {\n    const result = calculateOrderTotal(\n      [{ productId: 'A', quantity: 2, unitPrice: 50 }],\n      0,\n      0\n    );\n    expect(result.total).toBe(100);\n    expect(result.discountAmount).toBe(0);\n    expect(result.taxAmount).toBe(0);\n  });\n\n  it('applies percentage discount before tax', () => {\n    const result = calculateOrderTotal(\n      [{ productId: 'A', quantity: 1, unitPrice: 100 }],\n      10,\n      0.08\n    );\n    // $100 - 10% = $90, + 8% tax = $97.20\n    expect(result.total).toBe(97.2);\n  });\n\n  it('handles multiple items with discount and tax', () => {\n    const result = calculateOrderTotal(\n      [\n        { productId: 'A', quantity: 3, unitPrice: 29.99 },\n        { productId: 'B', quantity: 1, unitPrice: 49.99 },\n      ],\n      15,\n      0.1\n    );\n    // subtotal = 3*29.99 + 49.99 = 139.96\n    // discount = 139.96 * 0.15 = 20.994\n    // after discount = 118.966\n    // tax = 118.966 * 0.1 = 11.8966\n    // total = 130.8626 -> rounded to 130.86\n    expect(result.total).toBe(130.86);\n  });\n\n  it('rounds correctly for penny-edge amounts', () => {\n    // This specifically tests that we don't double-round\n    const result = calculateOrderTotal(\n      [{ productId: 'A', quantity: 1, unitPrice: 33.33 }],\n      5,\n      0.07\n    );\n    // subtotal = 33.33\n    // discount = 33.33 * 0.05 = 1.6665\n    // after discount = 31.6635\n    // tax = 31.6635 * 0.07 = 2.21644...\n    // total = 33.87994... -> 33.88\n    expect(result.total).toBe(33.88);\n  });\n});\n\ndescribe('BillingService', () => {\n  let bus: EventBus;\n  let notifications: NotificationService;\n  let billing: BillingService;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    notifications = new NotificationService();\n    billing = new BillingService(bus, notifications);\n    billing.registerHandlers();\n  });\n\n  it('charges payment and records it', async () => {\n    const record = await billing.chargePayment(\n      'O1',\n      [{ productId: 'A', quantity: 1, unitPrice: 100 }],\n      0,\n      0.1,\n      'card'\n    );\n    expect(record.amount).toBe(110);\n    expect(record.status).toBe('charged');\n    expect(record.method).toBe('card');\n  });\n\n  it('sends confirmation notification on charge', async () => {\n    await billing.chargePayment(\n      'O1',\n      [{ productId: 'A', quantity: 1, unitPrice: 100 }],\n      0,\n      0.1,\n      'card'\n    );\n    const sent = notifications.getSentNotifications();\n    expect(sent).toHaveLength(1);\n    expect(sent[0].type).toBe('confirmation');\n    expect(sent[0].message).toContain('O1');\n  });\n\n  it('issues refund and updates payment status', async () => {\n    await billing.chargePayment(\n      'O1',\n      [{ productId: 'A', quantity: 1, unitPrice: 50 }],\n      0,\n      0,\n      'card'\n    );\n    const refund = await billing.issueRefund('O1', 50);\n    expect(refund?.status).toBe('refunded');\n  });\n\n  it('sends refund notification', async () => {\n    await billing.chargePayment(\n      'O1',\n      [{ productId: 'A', quantity: 1, unitPrice: 50 }],\n      0,\n      0,\n      'card'\n    );\n    await billing.issueRefund('O1', 50);\n    const sent = notifications.getSentNotifications();\n    const refundNotice = sent.find((n) => n.type === 'refund');\n    expect(refundNotice).toBeDefined();\n    expect(refundNotice!.message).toContain('50.00');\n  });\n});\n```\n\n---\n\nThat completes all source files and test files in the workspace. The codebase implements an event-driven order processing system with services for orders, inventory, billing, and notifications that communicate through an event bus."}],"totalDurationMs":58847,"totalTokens":37731,"totalToolUseCount":17,"usage":{"input_tokens":7,"cache_creation_input_tokens":16173,"cache_read_input_tokens":10852,"output_tokens":10699,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":16173,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[]}}}
