+    if (startTime) { sql += ` AND timestamp >= ?`; params.push(startTime); }
+    if (endTime) { sql += ` AND timestamp <= ?`; params.push(endTime); }
+    sql += ` ORDER BY timestamp`;
+    const rows = db.prepare(sql).all(...params as [unknown]) as EventRow[];
+    const data = rows.map(r => ({
+      id: r.id,
+      name: r.name,
+      properties: r.properties,
+      timestamp: r.timestamp,
+      userId: r.user_id,
+      sessionId: r.session_id,
+    }));
+
+    if (format === 'csv') {
+      res.setHeader('Content-Type', 'text/csv');
+      res.setHeader('Content-Disposition', 'attachment; filename="events.csv"');
+      res.send(toCsv(data as Record<string, unknown>[], ['id', 'name', 'properties', 'timestamp', 'userId', 'sessionId']));
+    } else {
+      res.json(data);
+    }
+  });
+
+  // GET /api/export/dashboards?format=json|csv
