+{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01P9SVwn3n8MHoS53EcmQsB5","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01HMTHeW41d7nXPL7QonnmRB","name":"Write","input":{"file_path":"/workspace/docs/plans/2026-03-09-analytics-dashboard.md","content":"# Analytics Dashboard Implementation Plan\n\n> **For Claude:** REQUIRED SUB-SKILL: Use conclave:executing-plans to implement this plan task-by-task.\n\n**Goal:** Build a multi-tenant analytics dashboard HTTP API with user management, event ingestion, query engine, dashboard CRUD, and CSV/JSON data export.\n\n**Architecture:** Express.js REST API with SQLite via better-sqlite3. JWT auth middleware guards all tenant-scoped routes. All business logic separated into service modules; routes stay thin. Schema is provided in schema.sql and loaded at startup.\n\n**Tech Stack:** TypeScript (strict, ES2022, Node16), Express 4, better-sqlite3, jsonwebtoken, uuid, vitest for tests.\n\n---\n\n## Task 1: Database and App Bootstrap\n\n**Files:**\n- Create: `src/db.ts`\n- Create: `src/app.ts`\n\n**Dependencies:** none\n\n**Step 1: Create database module**\n\n```typescript\n// src/db.ts\nimport Database from 'better-sqlite3';\nimport fs from 'fs';\nimport path from 'path';\nimport { fileURLToPath } from 'url';\n\nconst __dirname = path.dirname(fileURLToPath(import.meta.url));\n\nlet _db: Database.Database | null = null;\n\nexport function getDb(dbPath = ':memory:'): Database.Database {\n  if (!_db) {\n    _db = new Database(dbPath);\n    _db.pragma('journal_mode = WAL');\n    const schema = fs.readFileSync(\n      path.join(__dirname, '..', 'schema.sql'),\n      'utf-8'\n    );\n    _db.exec(schema);\n  }\n  return _db;\n}\n\nexport function setDb(db: Database.Database): void {\n  _db = db;\n}\n\nexport function closeDb(): void {\n  if (_db) {\n    _db.close();\n    _db = null;\n  }\n}\n```\n\n**Step 2: Create app module**\n\n```typescript\n// src/app.ts\nimport express from 'express';\nimport { getDb } from './db.js';\nimport { createUserRouter } from './routes/users.js';\nimport { createEventsRouter } from './routes/events.js';\nimport { createQueryRouter } from './routes/query.js';\nimport { createDashboardRouter } from './routes/dashboards.js';\nimport { createExportRouter } from './routes/export.js';\nimport type Database from 'better-sqlite3';\n\nexport function createApp(db?: Database.Database): express.Application {\n  const app = express();\n  app.use(express.json());\n\n  const database = db ?? getDb();\n\n  app.use('/api/users', createUserRouter(database));\n  app.use('/api/events', createEventsRouter(database));\n  app.use('/api/query', createQueryRouter(database));\n  app.use('/api/dashboards', createDashboardRouter(database));\n  app.use('/api/export', createExportRouter(database));\n\n  return app;\n}\n```\n\n**Step 3: Build and verify**\n\nRun: `npm run build`\nExpected: no errors\n\n**Step 4: Commit**\n\n```bash\ngit add src/db.ts src/app.ts\ngit commit -m \"feat: add database bootstrap and app factory\"\n```\n\n---\n\n## Task 2: Auth Middleware and JWT Utilities\n\n**Files:**\n- Create: `src/auth.ts`\n\n**Dependencies:** Task 1\n\n**Step 1: Create auth module**\n\n```typescript\n// src/auth.ts\nimport jwt from 'jsonwebtoken';\nimport type { Request, Response, NextFunction } from 'express';\n\nexport const JWT_SECRET = process.env['JWT_SECRET'] ?? 'dev-secret-change-in-prod';\n\nexport interface TokenPayload {\n  userId: string;\n  tenantId: string;\n  role: string;\n}\n\nexport interface AuthRequest extends Request {\n  user?: TokenPayload;\n}\n\nexport function signToken(payload: TokenPayload): string {\n  return jwt.sign(payload, JWT_SECRET, { expiresIn: '24h' });\n}\n\nexport function requireAuth(\n  req: AuthRequest,\n  res: Response,\n  next: NextFunction\n): void {\n  const header = req.headers['authorization'];\n  if (!header?.startsWith('Bearer ')) {\n    res.status(401).json({ error: 'Unauthorized' });\n    return;\n  }\n  const token = header.slice(7);\n  try {\n    const payload = jwt.verify(token, JWT_SECRET) as TokenPayload;\n    req.user = payload;\n    next();\n  } catch {\n    res.status(401).json({ error: 'Unauthorized' });\n  }\n}\n\nexport function requireRole(role: 'admin' | 'editor') {\n  return (req: AuthRequest, res: Response, next: NextFunction): void => {\n    if (!req.user) {\n      res.status(401).json({ error: 'Unauthorized' });\n      return;\n    }\n    const roleRank = { viewer: 0, editor: 1, admin: 2 };\n    if (roleRank[req.user.role as keyof typeof roleRank] < roleRank[role]) {\n      res.status(403).json({ error: 'Forbidden' });\n      return;\n    }\n    next();\n  };\n}\n```\n\n**Step 2: Build and verify**\n\nRun: `npm run build`\nExpected: no errors\n\n**Step 3: Commit**\n\n```bash\ngit add src/auth.ts\ngit commit -m \"feat: add JWT auth middleware\"\n```\n\n---\n\n## Task 3: User Routes (Register, Login, Profile, Role Management)\n\n**Files:**\n- Create: `src/routes/users.ts`\n\n**Dependencies:** Task 1, Task 2\n\n**Step 1: Create users router**\n\n```typescript\n// src/routes/users.ts\nimport { Router } from 'express';\nimport { v4 as uuidv4 } from 'uuid';\nimport crypto from 'crypto';\nimport type Database from 'better-sqlite3';\nimport { signToken, requireAuth, requireRole } from '../auth.js';\nimport type { AuthRequest } from '../auth.js';\n\nfunction hashPassword(password: string): string {\n  return crypto.createHash('sha256').update(password).digest('hex');\n}\n\ninterface UserRow {\n  id: string;\n  email: string;\n  password_hash: string;\n  tenant_id: string;\n  role: string;\n  created_at: string;\n}\n\nexport function createUserRouter(db: Database.Database): Router {\n  const router = Router();\n\n  // POST /api/users/register\n  router.post('/register', (req, res) => {\n    const { email, password, tenantId, role } = req.body as {\n      email?: string;\n      password?: string;\n      tenantId?: string;\n      role?: string;\n    };\n    if (!email || !password || !tenantId) {\n      res.status(400).json({ error: 'email, password, tenantId required' });\n      return;\n    }\n    const id = uuidv4();\n    const password_hash = hashPassword(password);\n    const userRole = role ?? 'viewer';\n    try {\n      db.prepare(\n        `INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)`\n      ).run(id, email, password_hash, tenantId, userRole);\n      const token = signToken({ userId: id, tenantId, role: userRole });\n      res.status(201).json({ id, email, tenantId, role: userRole, token });\n    } catch {\n      res.status(409).json({ error: 'Email already exists' });\n    }\n  });\n\n  // POST /api/users/login\n  router.post('/login', (req, res) => {\n    const { email, password } = req.body as { email?: string; password?: string };\n    if (!email || !password) {\n      res.status(400).json({ error: 'email and password required' });\n      return;\n    }\n    const user = db.prepare(`SELECT * FROM users WHERE email = ?`).get(email) as UserRow | undefined;\n    if (!user || user.password_hash !== hashPassword(password)) {\n      res.status(401).json({ error: 'Invalid credentials' });\n      return;\n    }\n    const token = signToken({ userId: user.id, tenantId: user.tenant_id, role: user.role });\n    res.json({ id: user.id, email: user.email, tenantId: user.tenant_id, role: user.role, token });\n  });\n\n  // GET /api/users/me\n  router.get('/me', requireAuth, (req: AuthRequest, res) => {\n    const user = db.prepare(`SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?`).get(req.user!.userId) as UserRow | undefined;\n    if (!user) {\n      res.status(404).json({ error: 'User not found' });\n      return;\n    }\n    res.json({ id: user.id, email: user.email, tenantId: user.tenant_id, role: user.role, createdAt: user.created_at });\n  });\n\n  // PATCH /api/users/:userId/role\n  router.patch('/:userId/role', requireAuth, requireRole('admin'), (req: AuthRequest, res) => {\n    const { userId } = req.params;\n    const { role } = req.body as { role?: string };\n    if (!role || !['admin', 'editor', 'viewer'].includes(role)) {\n      res.status(400).json({ error: 'Invalid role' });\n      return;\n    }\n    const user = db.prepare(`SELECT * FROM users WHERE id = ? AND tenant_id = ?`).get(userId, req.user!.tenantId) as UserRow | undefined;\n    if (!user) {\n      res.status(404).json({ error: 'User not found' });\n      return;\n    }\n    db.prepare(`UPDATE users SET role = ? WHERE id = ?`).run(role, userId);\n    res.json({ id: userId, role });\n  });\n\n  return router;\n}\n```\n\n**Step 2: Build and verify**\n\nRun: `npm run build`\nExpected: no errors\n\n**Step 3: Commit**\n\n```bash\ngit add src/routes/users.ts\ngit commit -m \"feat: add user registration, login, profile, role management routes\"\n```\n\n---\n\n## Task 4: Event Ingestion Routes\n\n**Files:**\n- Create: `src/routes/events.ts`\n\n**Dependencies:** Task 1, Task 2\n\n**Step 1: Create events router**\n\n```typescript\n// src/routes/events.ts\nimport { Router } from 'express';\nimport { v4 as uuidv4 } from 'uuid';\nimport type Database from 'better-sqlite3';\nimport { requireAuth } from '../auth.js';\nimport type { AuthRequest } from '../auth.js';\n\ninterface EventInput {\n  name?: string;\n  properties?: Record<string, unknown>;\n  timestamp?: string;\n  sessionId?: string;\n}\n\nexport function createEventsRouter(db: Database.Database): Router {\n  const router = Router();\n\n  router.use(requireAuth);\n\n  // POST /api/events - ingest single event\n  router.post('/', (req: AuthRequest, res) => {\n    const { name, properties, timestamp, sessionId } = req.body as EventInput;\n    if (!name) {\n      res.status(400).json({ error: 'name is required' });\n      return;\n    }\n    const id = uuidv4();\n    const ts = timestamp ?? new Date().toISOString();\n    const props = JSON.stringify(properties ?? {});\n    db.prepare(\n      `INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)`\n    ).run(id, req.user!.tenantId, name, props, ts, req.user!.userId, sessionId ?? null);\n    res.status(201).json({ id, name, tenantId: req.user!.tenantId, timestamp: ts });\n  });\n\n  // POST /api/events/batch - ingest multiple events\n  router.post('/batch', (req: AuthRequest, res) => {\n    const { events } = req.body as { events?: EventInput[] };\n    if (!Array.isArray(events) || events.length === 0) {\n      res.status(400).json({ error: 'events array required' });\n      return;\n    }\n    const insert = db.prepare(\n      `INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)`\n    );\n    const insertMany = db.transaction((evts: EventInput[]) => {\n      const ids: string[] = [];\n      for (const evt of evts) {\n        if (!evt.name) continue;\n        const id = uuidv4();\n        const ts = evt.timestamp ?? new Date().toISOString();\n        const props = JSON.stringify(evt.properties ?? {});\n        insert.run(id, req.user!.tenantId, evt.name, props, ts, req.user!.userId, evt.sessionId ?? null);\n        ids.push(id);\n      }\n      return ids;\n    });\n    const ids = insertMany(events);\n    res.status(201).json({ inserted: ids.length, ids });\n  });\n\n  return router;\n}\n```\n\n**Step 2: Build and verify**\n\nRun: `npm run build`\nExpected: no errors\n\n**Step 3: Commit**\n\n```bash\ngit add src/routes/events.ts\ngit commit -m \"feat: add event ingestion routes (single and batch)\"\n```\n\n---\n\n## Task 5: Query Engine Routes\n\n**Files:**\n- Create: `src/routes/query.ts`\n\n**Dependencies:** Task 1, Task 2\n\n**Step 1: Create query router**\n\n```typescript\n// src/routes/query.ts\nimport { Router } from 'express';\nimport type Database from 'better-sqlite3';\nimport { requireAuth } from '../auth.js';\nimport type { AuthRequest } from '../auth.js';\n\nexport function createQueryRouter(db: Database.Database): Router {\n  const router = Router();\n\n  router.use(requireAuth);\n\n  // POST /api/query/count\n  // Body: { eventName?: string, startTime?: string, endTime?: string, filters?: Record<string,string> }\n  router.post('/count', (req: AuthRequest, res) => {\n    const { eventName, startTime, endTime } = req.body as {\n      eventName?: string;\n      startTime?: string;\n      endTime?: string;\n    };\n    let sql = `SELECT COUNT(*) as count FROM events WHERE tenant_id = ?`;\n    const params: unknown[] = [req.user!.tenantId];\n    if (eventName) { sql += ` AND name = ?`; params.push(eventName); }\n    if (startTime) { sql += ` AND timestamp >= ?`; params.push(startTime); }\n    if (endTime) { sql += ` AND timestamp <= ?`; params.push(endTime); }\n    const row = db.prepare(sql).get(...params as [unknown]) as { count: number };\n    res.json({ count: row.count });\n  });\n\n  // POST /api/query/timeseries\n  // Body: { eventName?: string, startTime?: string, endTime?: string, interval?: 'hour'|'day'|'week'|'month' }\n  router.post('/timeseries', (req: AuthRequest, res) => {\n    const { eventName, startTime, endTime, interval = 'day' } = req.body as {\n      eventName?: string;\n      startTime?: string;\n      endTime?: string;\n      interval?: string;\n    };\n    const formatMap: Record<string, string> = {\n      hour: '%Y-%m-%dT%H:00:00',\n      day: '%Y-%m-%d',\n      week: '%Y-%W',\n      month: '%Y-%m',\n    };\n    const fmt = formatMap[interval] ?? '%Y-%m-%d';\n    let sql = `SELECT strftime('${fmt}', timestamp) as bucket, COUNT(*) as count FROM events WHERE tenant_id = ?`;\n    const params: unknown[] = [req.user!.tenantId];\n    if (eventName) { sql += ` AND name = ?`; params.push(eventName); }\n    if (startTime) { sql += ` AND timestamp >= ?`; params.push(startTime); }\n    if (endTime) { sql += ` AND timestamp <= ?`; params.push(endTime); }\n    sql += ` GROUP BY bucket ORDER BY bucket`;\n    const rows = db.prepare(sql).all(...params as [unknown]) as { bucket: string; count: number }[];\n    res.json({ interval, data: rows });\n  });\n\n  // POST /api/query/breakdown\n  // Body: { eventName?: string, property: string, startTime?: string, endTime?: string }\n  router.post('/breakdown', (req: AuthRequest, res) => {\n    const { eventName, property, startTime, endTime } = req.body as {\n      eventName?: string;\n      property?: string;\n      startTime?: string;\n      endTime?: string;\n    };\n    if (!property) {\n      res.status(400).json({ error: 'property is required' });\n      return;\n    }\n    let sql = `SELECT json_extract(properties, '$.${property}') as value, COUNT(*) as count FROM events WHERE tenant_id = ?`;\n    const params: unknown[] = [req.user!.tenantId];\n    if (eventName) { sql += ` AND name = ?`; params.push(eventName); }\n    if (startTime) { sql += ` AND timestamp >= ?`; params.push(startTime); }\n    if (endTime) { sql += ` AND timestamp <= ?`; params.push(endTime); }\n    sql += ` GROUP BY value ORDER BY count DESC`;\n    const rows = db.prepare(sql).all(...params as [unknown]) as { value: string; count: number }[];\n    res.json({ property, data: rows });\n  });\n\n  return router;\n}\n```\n\n**Step 2: Build and verify**\n\nRun: `npm run build`\nExpected: no errors\n\n**Step 3: Commit**\n\n```bash\ngit add src/routes/query.ts\ngit commit -m \"feat: add query engine routes (count, timeseries, breakdown)\"\n```\n\n---\n\n## Task 6: Dashboard CRUD Routes\n\n**Files:**\n- Create: `src/routes/dashboards.ts`\n\n**Dependencies:** Task 1, Task 2\n\n**Step 1: Create dashboards router**\n\n```typescript\n// src/routes/dashboards.ts\nimport { Router } from 'express';\nimport { v4 as uuidv4 } from 'uuid';\nimport type Database from 'better-sqlite3';\nimport { requireAuth } from '../auth.js';\nimport type { AuthRequest } from '../auth.js';\n\ninterface DashboardRow {\n  id: string;\n  tenant_id: string;\n  name: string;\n  owner_id: string;\n  config: string;\n  created_at: string;\n  updated_at: string;\n}\n\ninterface WidgetRow {\n  id: string;\n  dashboard_id: string;\n  type: string;\n  config: string;\n  position_x: number;\n  position_y: number;\n  width: number;\n  height: number;\n}\n\nexport function createDashboardRouter(db: Database.Database): Router {\n  const router = Router();\n\n  router.use(requireAuth);\n\n  // GET /api/dashboards\n  router.get('/', (req: AuthRequest, res) => {\n    const rows = db.prepare(`SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC`).all(req.user!.tenantId) as DashboardRow[];\n    res.json(rows.map(r => ({\n      id: r.id,\n      name: r.name,\n      tenantId: r.tenant_id,\n      ownerId: r.owner_id,\n      config: JSON.parse(r.config),\n      createdAt: r.created_at,\n      updatedAt: r.updated_at,\n    })));\n  });\n\n  // POST /api/dashboards\n  router.post('/', (req: AuthRequest, res) => {\n    const { name, config } = req.body as { name?: string; config?: Record<string, unknown> };\n    if (!name) {\n      res.status(400).json({ error: 'name is required' });\n      return;\n    }\n    const id = uuidv4();\n    const now = new Date().toISOString();\n    db.prepare(\n      `INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)`\n    ).run(id, req.user!.tenantId, name, req.user!.userId, JSON.stringify(config ?? {}), now, now);\n    res.status(201).json({ id, name, tenantId: req.user!.tenantId, ownerId: req.user!.userId, config: config ?? {}, createdAt: now, updatedAt: now });\n  });\n\n  // GET /api/dashboards/:id\n  router.get('/:id', (req: AuthRequest, res) => {\n    const row = db.prepare(`SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?`).get(req.params['id'], req.user!.tenantId) as DashboardRow | undefined;\n    if (!row) {\n      res.status(404).json({ error: 'Dashboard not found' });\n      return;\n    }\n    const widgets = db.prepare(`SELECT * FROM widgets WHERE dashboard_id = ?`).all(row.id) as WidgetRow[];\n    res.json({\n      id: row.id,\n      name: row.name,\n      tenantId: row.tenant_id,\n      ownerId: row.owner_id,\n      config: JSON.parse(row.config),\n      createdAt: row.created_at,\n      updatedAt: row.updated_at,\n      widgets: widgets.map(w => ({ id: w.id, type: w.type, config: JSON.parse(w.config), position: { x: w.position_x, y: w.position_y }, size: { width: w.width, height: w.height } })),\n    });\n  });\n\n  // PUT /api/dashboards/:id\n  router.put('/:id', (req: AuthRequest, res) => {\n    const row = db.prepare(`SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?`).get(req.params['id'], req.user!.tenantId) as DashboardRow | undefined;\n    if (!row) {\n      res.status(404).json({ error: 'Dashboard not found' });\n      return;\n    }\n    const { name, config } = req.body as { name?: string; config?: Record<string, unknown> };\n    const newName = name ?? row.name;\n    const newConfig = JSON.stringify(config ?? JSON.parse(row.config));\n    const now = new Date().toISOString();\n    db.prepare(`UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?`).run(newName, newConfig, now, row.id);\n    res.json({ id: row.id, name: newName, tenantId: row.tenant_id, ownerId: row.owner_id, config: JSON.parse(newConfig), updatedAt: now });\n  });\n\n  // DELETE /api/dashboards/:id\n  router.delete('/:id', (req: AuthRequest, res) => {\n    const row = db.prepare(`SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?`).get(req.params['id'], req.user!.tenantId) as DashboardRow | undefined;\n    if (!row) {\n      res.status(404).json({ error: 'Dashboard not found' });\n      return;\n    }\n    db.prepare(`DELETE FROM dashboards WHERE id = ?`).run(row.id);\n    res.status(204).send();\n  });\n\n  // POST /api/dashboards/:id/widgets\n  router.post('/:id/widgets', (req: AuthRequest, res) => {\n    const dashboard = db.prepare(`SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?`).get(req.params['id'], req.user!.tenantId) as DashboardRow | undefined;\n    if (!dashboard) {\n      res.status(404).json({ error: 'Dashboard not found' });\n      return;\n    }\n    const { type, config, position, size } = req.body as {\n      type?: string;\n      config?: Record<string, unknown>;\n      position?: { x?: number; y?: number };\n      size?: { width?: number; height?: number };\n    };\n    if (!type || !['counter', 'timeseries', 'breakdown', 'funnel'].includes(type)) {\n      res.status(400).json({ error: 'Invalid widget type' });\n      return;\n    }\n    const id = uuidv4();\n    db.prepare(\n      `INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)`\n    ).run(id, dashboard.id, type, JSON.stringify(config ?? {}), position?.x ?? 0, position?.y ?? 0, size?.width ?? 1, size?.height ?? 1);\n    res.status(201).json({ id, dashboardId: dashboard.id, type, config: config ?? {} });\n  });\n\n  return router;\n}\n```\n\n**Step 2: Build and verify**\n\nRun: `npm run build`\nExpected: no errors\n\n**Step 3: Commit**\n\n```bash\ngit add src/routes/dashboards.ts\ngit commit -m \"feat: add dashboard CRUD and widget management routes\"\n```\n\n---\n\n## Task 7: Data Export Routes\n\n**Files:**\n- Create: `src/routes/export.ts`\n\n**Dependencies:** Task 1, Task 2, Task 6\n\n**Step 1: Create export router**\n\n```typescript\n// src/routes/export.ts\nimport { Router } from 'express';\nimport type Database from 'better-sqlite3';\nimport { requireAuth } from '../auth.js';\nimport type { AuthRequest } from '../auth.js';\n\ninterface EventRow {\n  id: string;\n  tenant_id: string;\n  name: string;\n  properties: string;\n  timestamp: string;\n  user_id: string | null;\n  session_id: string | null;\n}\n\ninterface DashboardRow {\n  id: string;\n  tenant_id: string;\n  name: string;\n  owner_id: string;\n  config: string;\n  created_at: string;\n  updated_at: string;\n}\n\nfunction toCsv(rows: Record<string, unknown>[], columns: string[]): string {\n  const header = columns.join(',');\n  const lines = rows.map(row =>\n    columns.map(col => {\n      const val = row[col] ?? '';\n      const str = String(val);\n      return str.includes(',') || str.includes('\"') || str.includes('\\n')\n        ? `\"${str.replace(/\"/g, '\"\"')}\"`\n        : str;\n    }).join(',')\n  );\n  return [header, ...lines].join('\\n');\n}\n\nexport function createExportRouter(db: Database.Database): Router {\n  const router = Router();\n\n  router.use(requireAuth);\n\n  // GET /api/export/events?format=json|csv&startTime=&endTime=&eventName=\n  router.get('/events', (req: AuthRequest, res) => {\n    const { format = 'json', startTime, endTime, eventName } = req.query as {\n      format?: string;\n      startTime?: string;\n      endTime?: string;\n      eventName?: string;\n    };\n    let sql = `SELECT * FROM events WHERE tenant_id = ?`;\n    const params: unknown[] = [req.user!.tenantId];\n    if (eventName) { sql += ` AND name = ?`; params.push(eventName); }\n    if (startTime) { sql += ` AND timestamp >= ?`; params.push(startTime); }\n    if (endTime) { sql += ` AND timestamp <= ?`; params.push(endTime); }\n    sql += ` ORDER BY timestamp`;\n    const rows = db.prepare(sql).all(...params as [unknown]) as EventRow[];\n    const data = rows.map(r => ({\n      id: r.id,\n      name: r.name,\n      properties: r.properties,\n      timestamp: r.timestamp,\n      userId: r.user_id,\n      sessionId: r.session_id,\n    }));\n\n    if (format === 'csv') {\n      res.setHeader('Content-Type', 'text/csv');\n      res.setHeader('Content-Disposition', 'attachment; filename=\"events.csv\"');\n      res.send(toCsv(data as Record<string, unknown>[], ['id', 'name', 'properties', 'timestamp', 'userId', 'sessionId']));\n    } else {\n      res.json(data);\n    }\n  });\n\n  // GET /api/export/dashboards?format=json|csv\n  router.get('/dashboards', (req: AuthRequest, res) => {\n    const { format = 'json' } = req.query as { format?: string };\n    const rows = db.prepare(`SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at`).all(req.user!.tenantId) as DashboardRow[];\n    const data = rows.map(r => ({\n      id: r.id,\n      name: r.name,\n      ownerId: r.owner_id,\n      config: r.config,\n      createdAt: r.created_at,\n      updatedAt: r.updated_at,\n    }));\n\n    if (format === 'csv') {\n      res.setHeader('Content-Type', 'text/csv');\n      res.setHeader('Content-Disposition', 'attachment; filename=\"dashboards.csv\"');\n      res.send(toCsv(data as Record<string, unknown>[], ['id', 'name', 'ownerId', 'config', 'createdAt', 'updatedAt']));\n    } else {\n      res.json(data);\n    }\n  });\n\n  // GET /api/export/dashboards/:id?format=json|csv\n  router.get('/dashboards/:id', (req: AuthRequest, res) => {\n    const { format = 'json' } = req.query as { format?: string };\n    const row = db.prepare(`SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?`).get(req.params['id'], req.user!.tenantId) as DashboardRow | undefined;\n    if (!row) {\n      res.status(404).json({ error: 'Dashboard not found' });\n      return;\n    }\n    const data = {\n      id: row.id,\n      name: row.name,\n      ownerId: row.owner_id,\n      config: row.config,\n      createdAt: row.created_at,\n      updatedAt: row.updated_at,\n    };\n\n    if (format === 'csv') {\n      res.setHeader('Content-Type', 'text/csv');\n      res.setHeader('Content-Disposition', `attachment; filename=\"dashboard-${row.id}.csv\"`);\n      res.send(toCsv([data as Record<string, unknown>], ['id', 'name', 'ownerId', 'config', 'createdAt', 'updatedAt']));\n    } else {\n      res.json(data);\n    }\n  });\n\n  return router;\n}\n```\n\n**Step 2: Build and verify**\n\nRun: `npm run build`\nExpected: no errors\n\n**Step 3: Commit**\n\n```bash\ngit add src/routes/export.ts\ngit commit -m \"feat: add CSV/JSON export routes for events and dashboards\"\n```\n\n---\n\n## Task 8: Wire Up and Final Verification\n\n**Files:**\n- Create: `src/index.ts` (re-export createApp)\n\n**Dependencies:** Tasks 1-7\n\n**Step 1: Create index.ts**\n\n```typescript\n// src/index.ts\nexport { createApp } from './app.js';\n```\n\n**Step 2: Run build**\n\nRun: `npm run build`\nExpected: 0 errors\n\n**Step 3: Run lint**\n\nRun: `npm run lint`\nExpected: 0 errors\n\n**Step 4: Fix any build/lint issues found**\n\n**Step 5: Commit**\n\n```bash\ngit add src/index.ts\ngit commit -m \"feat: export createApp from index\"\n```\n\n---\n\n## Task 9: Integration Tests\n\n**Files:**\n- Create: `src/tests/app.test.ts`\n\n**Dependencies:** Tasks 1-8\n\n**Step 1: Write integration tests**\n\n```typescript\n// src/tests/app.test.ts\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport request from 'supertest';\nimport Database from 'better-sqlite3';\nimport fs from 'fs';\nimport path from 'path';\nimport { fileURLToPath } from 'url';\nimport { createApp } from '../app.js';\nimport { setDb } from '../db.js';\n\nconst __dirname = path.dirname(fileURLToPath(import.meta.url));\n\nfunction createTestDb(): Database.Database {\n  const db = new Database(':memory:');\n  const schema = fs.readFileSync(path.join(__dirname, '..', '..', 'schema.sql'), 'utf-8');\n  db.exec(schema);\n  return db;\n}\n\ndescribe('Analytics Dashboard API', () => {\n  let app: ReturnType<typeof createApp>;\n  let db: Database.Database;\n\n  beforeEach(() => {\n    db = createTestDb();\n    setDb(db);\n    app = createApp(db);\n  });\n\n  describe('User Management', () => {\n    it('registers a new user', async () => {\n      const res = await request(app).post('/api/users/register').send({ email: 'alice@example.com', password: 'pass', tenantId: 'tenant1', role: 'admin' });\n      expect(res.status).toBe(201);\n      expect(res.body.token).toBeDefined();\n    });\n\n    it('rejects duplicate registration', async () => {\n      await request(app).post('/api/users/register').send({ email: 'a@b.com', password: 'x', tenantId: 'tenant1' });\n      const res = await request(app).post('/api/users/register').send({ email: 'a@b.com', password: 'x', tenantId: 'tenant1' });\n      expect(res.status).toBe(409);\n    });\n\n    it('logs in successfully', async () => {\n      await request(app).post('/api/users/register').send({ email: 'a@b.com', password: 'pass', tenantId: 't1' });\n      const res = await request(app).post('/api/users/login').send({ email: 'a@b.com', password: 'pass' });\n      expect(res.status).toBe(200);\n      expect(res.body.token).toBeDefined();\n    });\n\n    it('rejects wrong password', async () => {\n      await request(app).post('/api/users/register').send({ email: 'a@b.com', password: 'pass', tenantId: 't1' });\n      const res = await request(app).post('/api/users/login').send({ email: 'a@b.com', password: 'wrong' });\n      expect(res.status).toBe(401);\n    });\n\n    it('returns 401 for unauthenticated /me', async () => {\n      const res = await request(app).get('/api/users/me');\n      expect(res.status).toBe(401);\n    });\n\n    it('returns profile for authenticated user', async () => {\n      const reg = await request(app).post('/api/users/register').send({ email: 'a@b.com', password: 'pass', tenantId: 't1', role: 'admin' });\n      const res = await request(app).get('/api/users/me').set('Authorization', `Bearer ${reg.body.token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.email).toBe('a@b.com');\n    });\n  });\n\n  describe('Event Ingestion', () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const reg = await request(app).post('/api/users/register').send({ email: 'a@b.com', password: 'pass', tenantId: 'tenant1', role: 'admin' });\n      token = reg.body.token as string;\n    });\n\n    it('rejects unauthenticated event ingestion', async () => {\n      const res = await request(app).post('/api/events').send({ name: 'page_view' });\n      expect(res.status).toBe(401);\n    });\n\n    it('ingests a single event', async () => {\n      const res = await request(app).post('/api/events').set('Authorization', `Bearer ${token}`).send({ name: 'page_view', properties: { url: '/home' } });\n      expect(res.status).toBe(201);\n      expect(res.body.id).toBeDefined();\n    });\n\n    it('ingests a batch of events', async () => {\n      const res = await request(app).post('/api/events/batch').set('Authorization', `Bearer ${token}`).send({ events: [{ name: 'e1' }, { name: 'e2' }] });\n      expect(res.status).toBe(201);\n      expect(res.body.inserted).toBe(2);\n    });\n  });\n\n  describe('Query Engine', () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const reg = await request(app).post('/api/users/register').send({ email: 'a@b.com', password: 'pass', tenantId: 'tenant1', role: 'admin' });\n      token = reg.body.token as string;\n      await request(app).post('/api/events/batch').set('Authorization', `Bearer ${token}`).send({ events: [\n        { name: 'page_view', properties: { url: '/home' }, timestamp: '2024-01-01T10:00:00Z' },\n        { name: 'page_view', properties: { url: '/about' }, timestamp: '2024-01-01T11:00:00Z' },\n        { name: 'click', properties: { url: '/home' }, timestamp: '2024-01-02T10:00:00Z' },\n      ]});\n    });\n\n    it('counts events', async () => {\n      const res = await request(app).post('/api/query/count').set('Authorization', `Bearer ${token}`).send({ eventName: 'page_view' });\n      expect(res.status).toBe(200);\n      expect(res.body.count).toBe(2);\n    });\n\n    it('returns timeseries', async () => {\n      const res = await request(app).post('/api/query/timeseries').set('Authorization', `Bearer ${token}`).send({ eventName: 'page_view', interval: 'day' });\n      expect(res.status).toBe(200);\n      expect(res.body.data.length).toBeGreaterThan(0);\n    });\n\n    it('returns breakdown by property', async () => {\n      const res = await request(app).post('/api/query/breakdown').set('Authorization', `Bearer ${token}`).send({ eventName: 'page_view', property: 'url' });\n      expect(res.status).toBe(200);\n      expect(res.body.data.length).toBe(2);\n    });\n\n    it('enforces tenant isolation', async () => {\n      const reg2 = await request(app).post('/api/users/register').send({ email: 'b@b.com', password: 'pass', tenantId: 'tenant2', role: 'admin' });\n      const res = await request(app).post('/api/query/count').set('Authorization', `Bearer ${reg2.body.token}`).send({});\n      expect(res.body.count).toBe(0);\n    });\n  });\n\n  describe('Dashboards', () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const reg = await request(app).post('/api/users/register').send({ email: 'a@b.com', password: 'pass', tenantId: 'tenant1', role: 'admin' });\n      token = reg.body.token as string;\n    });\n\n    it('creates a dashboard', async () => {\n      const res = await request(app).post('/api/dashboards').set('Authorization', `Bearer ${token}`).send({ name: 'My Dashboard' });\n      expect(res.status).toBe(201);\n      expect(res.body.id).toBeDefined();\n    });\n\n    it('lists dashboards', async () => {\n      await request(app).post('/api/dashboards').set('Authorization', `Bearer ${token}`).send({ name: 'D1' });\n      const res = await request(app).get('/api/dashboards').set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.length).toBe(1);\n    });\n\n    it('updates a dashboard', async () => {\n      const created = await request(app).post('/api/dashboards').set('Authorization', `Bearer ${token}`).send({ name: 'D1' });\n      const res = await request(app).put(`/api/dashboards/${created.body.id}`).set('Authorization', `Bearer ${token}`).send({ name: 'D1 Updated' });\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe('D1 Updated');\n    });\n\n    it('deletes a dashboard', async () => {\n      const created = await request(app).post('/api/dashboards').set('Authorization', `Bearer ${token}`).send({ name: 'D1' });\n      const res = await request(app).delete(`/api/dashboards/${created.body.id}`).set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(204);\n    });\n  });\n\n  describe('Export', () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const reg = await request(app).post('/api/users/register').send({ email: 'a@b.com', password: 'pass', tenantId: 'tenant1', role: 'admin' });\n      token = reg.body.token as string;\n      await request(app).post('/api/events').set('Authorization', `Bearer ${token}`).send({ name: 'page_view' });\n    });\n\n    it('exports events as JSON', async () => {\n      const res = await request(app).get('/api/export/events').set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(Array.isArray(res.body)).toBe(true);\n    });\n\n    it('exports events as CSV', async () => {\n      const res = await request(app).get('/api/export/events?format=csv').set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.headers['content-type']).toContain('text/csv');\n    });\n\n    it('exports dashboards as JSON', async () => {\n      await request(app).post('/api/dashboards').set('Authorization', `Bearer ${token}`).send({ name: 'D' });\n      const res = await request(app).get('/api/export/dashboards').set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(Array.isArray(res.body)).toBe(true);\n    });\n  });\n});\n```\n\n**Step 2: Run tests**\n\nRun: `npm test`\nExpected: all pass\n\n**Step 3: Commit**\n\n```bash\ngit add src/tests/app.test.ts\ngit commit -m \"test: add integration tests for all API endpoints\"\n```\n\n---\n\n## Notes on better-sqlite3 Variadic Params\n\n`better-sqlite3`'s `get()` and `all()` accept positional params as rest args. When building dynamic queries, collect params in an array and spread:\n\n```typescript\nconst row = db.prepare(sql).get(...params as [unknown]);\nconst rows = db.prepare(sql).all(...params as [unknown]);\n```\n\nThis is the standard pattern for this library.\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":118,"cache_read_input_tokens":26856,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":118},"output_tokens":18,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"f4c6aeb2-97e0-4263-8af4-c03fe4a80281","uuid":"6306c855-aeca-49bb-ab78-997b986e98b7"}
+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HMTHeW41d7nXPL7QonnmRB","type":"tool_result","content":"File created successfully at: /workspace/docs/plans/2026-03-09-analytics-dashboard.md"}]},"parent_tool_use_id":null,"session_id":"f4c6aeb2-97e0-4263-8af4-c03fe4a80281","uuid":"fe4991c6-c31d-4abf-8877-2b87a926d6bb","tool_use_result":{"type":"create","filePath":"/workspace/docs/plans/2026-03-09-analytics-dashboard.md","content":"# Analytics Dashboard Implementation Plan\n\n> **For Claude:** REQUIRED SUB-SKILL: Use conclave:executing-plans to implement this plan task-by-task.\n\n**Goal:** Build a multi-tenant analytics dashboard HTTP API with user management, event ingestion, query engine, dashboard CRUD, and CSV/JSON data export.\n\n**Architecture:** Express.js REST API with SQLite via better-sqlite3. JWT auth middleware guards all tenant-scoped routes. All business logic separated into service modules; routes stay thin. Schema is provided in schema.sql and loaded at startup.\n\n**Tech Stack:** TypeScript (strict, ES2022, Node16), Express 4, better-sqlite3, jsonwebtoken, uuid, vitest for tests.\n\n---\n\n## Task 1: Database and App Bootstrap\n\n**Files:**\n- Create: `src/db.ts`\n- Create: `src/app.ts`\n\n**Dependencies:** none\n\n**Step 1: Create database module**\n\n```typescript\n// src/db.ts\nimport Database from 'better-sqlite3';\nimport fs from 'fs';\nimport path from 'path';\nimport { fileURLToPath } from 'url';\n\nconst __dirname = path.dirname(fileURLToPath(import.meta.url));\n\nlet _db: Database.Database | null = null;\n\nexport function getDb(dbPath = ':memory:'): Database.Database {\n  if (!_db) {\n    _db = new Database(dbPath);\n    _db.pragma('journal_mode = WAL');\n    const schema = fs.readFileSync(\n      path.join(__dirname, '..', 'schema.sql'),\n      'utf-8'\n    );\n    _db.exec(schema);\n  }\n  return _db;\n}\n\nexport function setDb(db: Database.Database): void {\n  _db = db;\n}\n\nexport function closeDb(): void {\n  if (_db) {\n    _db.close();\n    _db = null;\n  }\n}\n```\n\n**Step 2: Create app module**\n\n```typescript\n// src/app.ts\nimport express from 'express';\nimport { getDb } from './db.js';\nimport { createUserRouter } from './routes/users.js';\nimport { createEventsRouter } from './routes/events.js';\nimport { createQueryRouter } from './routes/query.js';\nimport { createDashboardRouter } from './routes/dashboards.js';\nimport { createExportRouter } from './routes/export.js';\nimport type Database from 'better-sqlite3';\n\nexport function createApp(db?: Database.Database): express.Application {\n  const app = express();\n  app.use(express.json());\n\n  const database = db ?? getDb();\n\n  app.use('/api/users', createUserRouter(database));\n  app.use('/api/events', createEventsRouter(database));\n  app.use('/api/query', createQueryRouter(database));\n  app.use('/api/dashboards', createDashboardRouter(database));\n  app.use('/api/export', createExportRouter(database));\n\n  return app;\n}\n```\n\n**Step 3: Build and verify**\n\nRun: `npm run build`\nExpected: no errors\n\n**Step 4: Commit**\n\n```bash\ngit add src/db.ts src/app.ts\ngit commit -m \"feat: add database bootstrap and app factory\"\n```\n\n---\n\n## Task 2: Auth Middleware and JWT Utilities\n\n**Files:**\n- Create: `src/auth.ts`\n\n**Dependencies:** Task 1\n\n**Step 1: Create auth module**\n\n```typescript\n// src/auth.ts\nimport jwt from 'jsonwebtoken';\nimport type { Request, Response, NextFunction } from 'express';\n\nexport const JWT_SECRET = process.env['JWT_SECRET'] ?? 'dev-secret-change-in-prod';\n\nexport interface TokenPayload {\n  userId: string;\n  tenantId: string;\n  role: string;\n}\n\nexport interface AuthRequest extends Request {\n  user?: TokenPayload;\n}\n\nexport function signToken(payload: TokenPayload): string {\n  return jwt.sign(payload, JWT_SECRET, { expiresIn: '24h' });\n}\n\nexport function requireAuth(\n  req: AuthRequest,\n  res: Response,\n  next: NextFunction\n): void {\n  const header = req.headers['authorization'];\n  if (!header?.startsWith('Bearer ')) {\n    res.status(401).json({ error: 'Unauthorized' });\n    return;\n  }\n  const token = header.slice(7);\n  try {\n    const payload = jwt.verify(token, JWT_SECRET) as TokenPayload;\n    req.user = payload;\n    next();\n  } catch {\n    res.status(401).json({ error: 'Unauthorized' });\n  }\n}\n\nexport function requireRole(role: 'admin' | 'editor') {\n  return (req: AuthRequest, res: Response, next: NextFunction): void => {\n    if (!req.user) {\n      res.status(401).json({ error: 'Unauthorized' });\n      return;\n    }\n    const roleRank = { viewer: 0, editor: 1, admin: 2 };\n    if (roleRank[req.user.role as keyof typeof roleRank] < roleRank[role]) {\n      res.status(403).json({ error: 'Forbidden' });\n      return;\n    }\n    next();\n  };\n}\n```\n\n**Step 2: Build and verify**\n\nRun: `npm run build`\nExpected: no errors\n\n**Step 3: Commit**\n\n```bash\ngit add src/auth.ts\ngit commit -m \"feat: add JWT auth middleware\"\n```\n\n---\n\n## Task 3: User Routes (Register, Login, Profile, Role Management)\n\n**Files:**\n- Create: `src/routes/users.ts`\n\n**Dependencies:** Task 1, Task 2\n\n**Step 1: Create users router**\n\n```typescript\n// src/routes/users.ts\nimport { Router } from 'express';\nimport { v4 as uuidv4 } from 'uuid';\nimport crypto from 'crypto';\nimport type Database from 'better-sqlite3';\nimport { signToken, requireAuth, requireRole } from '../auth.js';\nimport type { AuthRequest } from '../auth.js';\n\nfunction hashPassword(password: string): string {\n  return crypto.createHash('sha256').update(password).digest('hex');\n}\n\ninterface UserRow {\n  id: string;\n  email: string;\n  password_hash: string;\n  tenant_id: string;\n  role: string;\n  created_at: string;\n}\n\nexport function createUserRouter(db: Database.Database): Router {\n  const router = Router();\n\n  // POST /api/users/register\n  router.post('/register', (req, res) => {\n    const { email, password, tenantId, role } = req.body as {\n      email?: string;\n      password?: string;\n      tenantId?: string;\n      role?: string;\n    };\n    if (!email || !password || !tenantId) {\n      res.status(400).json({ error: 'email, password, tenantId required' });\n      return;\n    }\n    const id = uuidv4();\n    const password_hash = hashPassword(password);\n    const userRole = role ?? 'viewer';\n    try {\n      db.prepare(\n        `INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)`\n      ).run(id, email, password_hash, tenantId, userRole);\n      const token = signToken({ userId: id, tenantId, role: userRole });\n      res.status(201).json({ id, email, tenantId, role: userRole, token });\n    } catch {\n      res.status(409).json({ error: 'Email already exists' });\n    }\n  });\n\n  // POST /api/users/login\n  router.post('/login', (req, res) => {\n    const { email, password } = req.body as { email?: string; password?: string };\n    if (!email || !password) {\n      res.status(400).json({ error: 'email and password required' });\n      return;\n    }\n    const user = db.prepare(`SELECT * FROM users WHERE email = ?`).get(email) as UserRow | undefined;\n    if (!user || user.password_hash !== hashPassword(password)) {\n      res.status(401).json({ error: 'Invalid credentials' });\n      return;\n    }\n    const token = signToken({ userId: user.id, tenantId: user.tenant_id, role: user.role });\n    res.json({ id: user.id, email: user.email, tenantId: user.tenant_id, role: user.role, token });\n  });\n\n  // GET /api/users/me\n  router.get('/me', requireAuth, (req: AuthRequest, res) => {\n    const user = db.prepare(`SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?`).get(req.user!.userId) as UserRow | undefined;\n    if (!user) {\n      res.status(404).json({ error: 'User not found' });\n      return;\n    }\n    res.json({ id: user.id, email: user.email, tenantId: user.tenant_id, role: user.role, createdAt: user.created_at });\n  });\n\n  // PATCH /api/users/:userId/role\n  router.patch('/:userId/role', requireAuth, requireRole('admin'), (req: AuthRequest, res) => {\n    const { userId } = req.params;\n    const { role } = req.body as { role?: string };\n    if (!role || !['admin', 'editor', 'viewer'].includes(role)) {\n      res.status(400).json({ error: 'Invalid role' });\n      return;\n    }\n    const user = db.prepare(`SELECT * FROM users WHERE id = ? AND tenant_id = ?`).get(userId, req.user!.tenantId) as UserRow | undefined;\n    if (!user) {\n      res.status(404).json({ error: 'User not found' });\n      return;\n    }\n    db.prepare(`UPDATE users SET role = ? WHERE id = ?`).run(role, userId);\n    res.json({ id: userId, role });\n  });\n\n  return router;\n}\n```\n\n**Step 2: Build and verify**\n\nRun: `npm run build`\nExpected: no errors\n\n**Step 3: Commit**\n\n```bash\ngit add src/routes/users.ts\ngit commit -m \"feat: add user registration, login, profile, role management routes\"\n```\n\n---\n\n## Task 4: Event Ingestion Routes\n\n**Files:**\n- Create: `src/routes/events.ts`\n\n**Dependencies:** Task 1, Task 2\n\n**Step 1: Create events router**\n\n```typescript\n// src/routes/events.ts\nimport { Router } from 'express';\nimport { v4 as uuidv4 } from 'uuid';\nimport type Database from 'better-sqlite3';\nimport { requireAuth } from '../auth.js';\nimport type { AuthRequest } from '../auth.js';\n\ninterface EventInput {\n  name?: string;\n  properties?: Record<string, unknown>;\n  timestamp?: string;\n  sessionId?: string;\n}\n\nexport function createEventsRouter(db: Database.Database): Router {\n  const router = Router();\n\n  router.use(requireAuth);\n\n  // POST /api/events - ingest single event\n  router.post('/', (req: AuthRequest, res) => {\n    const { name, properties, timestamp, sessionId } = req.body as EventInput;\n    if (!name) {\n      res.status(400).json({ error: 'name is required' });\n      return;\n    }\n    const id = uuidv4();\n    const ts = timestamp ?? new Date().toISOString();\n    const props = JSON.stringify(properties ?? {});\n    db.prepare(\n      `INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)`\n    ).run(id, req.user!.tenantId, name, props, ts, req.user!.userId, sessionId ?? null);\n    res.status(201).json({ id, name, tenantId: req.user!.tenantId, timestamp: ts });\n  });\n\n  // POST /api/events/batch - ingest multiple events\n  router.post('/batch', (req: AuthRequest, res) => {\n    const { events } = req.body as { events?: EventInput[] };\n    if (!Array.isArray(events) || events.length === 0) {\n      res.status(400).json({ error: 'events array required' });\n      return;\n    }\n    const insert = db.prepare(\n      `INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)`\n    );\n    const insertMany = db.transaction((evts: EventInput[]) => {\n      const ids: string[] = [];\n      for (const evt of evts) {\n        if (!evt.name) continue;\n        const id = uuidv4();\n        const ts = evt.timestamp ?? new Date().toISOString();\n        const props = JSON.stringify(evt.properties ?? {});\n        insert.run(id, req.user!.tenantId, evt.name, props, ts, req.user!.userId, evt.sessionId ?? null);\n        ids.push(id);\n      }\n      return ids;\n    });\n    const ids = insertMany(events);\n    res.status(201).json({ inserted: ids.length, ids });\n  });\n\n  return router;\n}\n```\n\n**Step 2: Build and verify**\n\nRun: `npm run build`\nExpected: no errors\n\n**Step 3: Commit**\n\n```bash\ngit add src/routes/events.ts\ngit commit -m \"feat: add event ingestion routes (single and batch)\"\n```\n\n---\n\n## Task 5: Query Engine Routes\n\n**Files:**\n- Create: `src/routes/query.ts`\n\n**Dependencies:** Task 1, Task 2\n\n**Step 1: Create query router**\n\n```typescript\n// src/routes/query.ts\nimport { Router } from 'express';\nimport type Database from 'better-sqlite3';\nimport { requireAuth } from '../auth.js';\nimport type { AuthRequest } from '../auth.js';\n\nexport function createQueryRouter(db: Database.Database): Router {\n  const router = Router();\n\n  router.use(requireAuth);\n\n  // POST /api/query/count\n  // Body: { eventName?: string, startTime?: string, endTime?: string, filters?: Record<string,string> }\n  router.post('/count', (req: AuthRequest, res) => {\n    const { eventName, startTime, endTime } = req.body as {\n      eventName?: string;\n      startTime?: string;\n      endTime?: string;\n    };\n    let sql = `SELECT COUNT(*) as count FROM events WHERE tenant_id = ?`;\n    const params: unknown[] = [req.user!.tenantId];\n    if (eventName) { sql += ` AND name = ?`; params.push(eventName); }\n    if (startTime) { sql += ` AND timestamp >= ?`; params.push(startTime); }\n    if (endTime) { sql += ` AND timestamp <= ?`; params.push(endTime); }\n    const row = db.prepare(sql).get(...params as [unknown]) as { count: number };\n    res.json({ count: row.count });\n  });\n\n  // POST /api/query/timeseries\n  // Body: { eventName?: string, startTime?: string, endTime?: string, interval?: 'hour'|'day'|'week'|'month' }\n  router.post('/timeseries', (req: AuthRequest, res) => {\n    const { eventName, startTime, endTime, interval = 'day' } = req.body as {\n      eventName?: string;\n      startTime?: string;\n      endTime?: string;\n      interval?: string;\n    };\n    const formatMap: Record<string, string> = {\n      hour: '%Y-%m-%dT%H:00:00',\n      day: '%Y-%m-%d',\n      week: '%Y-%W',\n      month: '%Y-%m',\n    };\n    const fmt = formatMap[interval] ?? '%Y-%m-%d';\n    let sql = `SELECT strftime('${fmt}', timestamp) as bucket, COUNT(*) as count FROM events WHERE tenant_id = ?`;\n    const params: unknown[] = [req.user!.tenantId];\n    if (eventName) { sql += ` AND name = ?`; params.push(eventName); }\n    if (startTime) { sql += ` AND timestamp >= ?`; params.push(startTime); }\n    if (endTime) { sql += ` AND timestamp <= ?`; params.push(endTime); }\n    sql += ` GROUP BY bucket ORDER BY bucket`;\n    const rows = db.prepare(sql).all(...params as [unknown]) as { bucket: string; count: number }[];\n    res.json({ interval, data: rows });\n  });\n\n  // POST /api/query/breakdown\n  // Body: { eventName?: string, property: string, startTime?: string, endTime?: string }\n  router.post('/breakdown', (req: AuthRequest, res) => {\n    const { eventName, property, startTime, endTime } = req.body as {\n      eventName?: string;\n      property?: string;\n      startTime?: string;\n      endTime?: string;\n    };\n    if (!property) {\n      res.status(400).json({ error: 'property is required' });\n      return;\n    }\n    let sql = `SELECT json_extract(properties, '$.${property}') as value, COUNT(*) as count FROM events WHERE tenant_id = ?`;\n    const params: unknown[] = [req.user!.tenantId];\n    if (eventName) { sql += ` AND name = ?`; params.push(eventName); }\n    if (startTime) { sql += ` AND timestamp >= ?`; params.push(startTime); }\n    if (endTime) { sql += ` AND timestamp <= ?`; params.push(endTime); }\n    sql += ` GROUP BY value ORDER BY count DESC`;\n    const rows = db.prepare(sql).all(...params as [unknown]) as { value: string; count: number }[];\n    res.json({ property, data: rows });\n  });\n\n  return router;\n}\n```\n\n**Step 2: Build and verify**\n\nRun: `npm run build`\nExpected: no errors\n\n**Step 3: Commit**\n\n```bash\ngit add src/routes/query.ts\ngit commit -m \"feat: add query engine routes (count, timeseries, breakdown)\"\n```\n\n---\n\n## Task 6: Dashboard CRUD Routes\n\n**Files:**\n- Create: `src/routes/dashboards.ts`\n\n**Dependencies:** Task 1, Task 2\n\n**Step 1: Create dashboards router**\n\n```typescript\n// src/routes/dashboards.ts\nimport { Router } from 'express';\nimport { v4 as uuidv4 } from 'uuid';\nimport type Database from 'better-sqlite3';\nimport { requireAuth } from '../auth.js';\nimport type { AuthRequest } from '../auth.js';\n\ninterface DashboardRow {\n  id: string;\n  tenant_id: string;\n  name: string;\n  owner_id: string;\n  config: string;\n  created_at: string;\n  updated_at: string;\n}\n\ninterface WidgetRow {\n  id: string;\n  dashboard_id: string;\n  type: string;\n  config: string;\n  position_x: number;\n  position_y: number;\n  width: number;\n  height: number;\n}\n\nexport function createDashboardRouter(db: Database.Database): Router {\n  const router = Router();\n\n  router.use(requireAuth);\n\n  // GET /api/dashboards\n  router.get('/', (req: AuthRequest, res) => {\n    const rows = db.prepare(`SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC`).all(req.user!.tenantId) as DashboardRow[];\n    res.json(rows.map(r => ({\n      id: r.id,\n      name: r.name,\n      tenantId: r.tenant_id,\n      ownerId: r.owner_id,\n      config: JSON.parse(r.config),\n      createdAt: r.created_at,\n      updatedAt: r.updated_at,\n    })));\n  });\n\n  // POST /api/dashboards\n  router.post('/', (req: AuthRequest, res) => {\n    const { name, config } = req.body as { name?: string; config?: Record<string, unknown> };\n    if (!name) {\n      res.status(400).json({ error: 'name is required' });\n      return;\n    }\n    const id = uuidv4();\n    const now = new Date().toISOString();\n    db.prepare(\n      `INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)`\n    ).run(id, req.user!.tenantId, name, req.user!.userId, JSON.stringify(config ?? {}), now, now);\n    res.status(201).json({ id, name, tenantId: req.user!.tenantId, ownerId: req.user!.userId, config: config ?? {}, createdAt: now, updatedAt: now });\n  });\n\n  // GET /api/dashboards/:id\n  router.get('/:id', (req: AuthRequest, res) => {\n    const row = db.prepare(`SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?`).get(req.params['id'], req.user!.tenantId) as DashboardRow | undefined;\n    if (!row) {\n      res.status(404).json({ error: 'Dashboard not found' });\n      return;\n    }\n    const widgets = db.prepare(`SELECT * FROM widgets WHERE dashboard_id = ?`).all(row.id) as WidgetRow[];\n    res.json({\n      id: row.id,\n      name: row.name,\n      tenantId: row.tenant_id,\n      ownerId: row.owner_id,\n      config: JSON.parse(row.config),\n      createdAt: row.created_at,\n      updatedAt: row.updated_at,\n      widgets: widgets.map(w => ({ id: w.id, type: w.type, config: JSON.parse(w.config), position: { x: w.position_x, y: w.position_y }, size: { width: w.width, height: w.height } })),\n    });\n  });\n\n  // PUT /api/dashboards/:id\n  router.put('/:id', (req: AuthRequest, res) => {\n    const row = db.prepare(`SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?`).get(req.params['id'], req.user!.tenantId) as DashboardRow | undefined;\n    if (!row) {\n      res.status(404).json({ error: 'Dashboard not found' });\n      return;\n    }\n    const { name, config } = req.body as { name?: string; config?: Record<string, unknown> };\n    const newName = name ?? row.name;\n    const newConfig = JSON.stringify(config ?? JSON.parse(row.config));\n    const now = new Date().toISOString();\n    db.prepare(`UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?`).run(newName, newConfig, now, row.id);\n    res.json({ id: row.id, name: newName, tenantId: row.tenant_id, ownerId: row.owner_id, config: JSON.parse(newConfig), updatedAt: now });\n  });\n\n  // DELETE /api/dashboards/:id\n  router.delete('/:id', (req: AuthRequest, res) => {\n    const row = db.prepare(`SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?`).get(req.params['id'], req.user!.tenantId) as DashboardRow | undefined;\n    if (!row) {\n      res.status(404).json({ error: 'Dashboard not found' });\n      return;\n    }\n    db.prepare(`DELETE FROM dashboards WHERE id = ?`).run(row.id);\n    res.status(204).send();\n  });\n\n  // POST /api/dashboards/:id/widgets\n  router.post('/:id/widgets', (req: AuthRequest, res) => {\n    const dashboard = db.prepare(`SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?`).get(req.params['id'], req.user!.tenantId) as DashboardRow | undefined;\n    if (!dashboard) {\n      res.status(404).json({ error: 'Dashboard not found' });\n      return;\n    }\n    const { type, config, position, size } = req.body as {\n      type?: string;\n      config?: Record<string, unknown>;\n      position?: { x?: number; y?: number };\n      size?: { width?: number; height?: number };\n    };\n    if (!type || !['counter', 'timeseries', 'breakdown', 'funnel'].includes(type)) {\n      res.status(400).json({ error: 'Invalid widget type' });\n      return;\n    }\n    const id = uuidv4();\n    db.prepare(\n      `INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)`\n    ).run(id, dashboard.id, type, JSON.stringify(config ?? {}), position?.x ?? 0, position?.y ?? 0, size?.width ?? 1, size?.height ?? 1);\n    res.status(201).json({ id, dashboardId: dashboard.id, type, config: config ?? {} });\n  });\n\n  return router;\n}\n```\n\n**Step 2: Build and verify**\n\nRun: `npm run build`\nExpected: no errors\n\n**Step 3: Commit**\n\n```bash\ngit add src/routes/dashboards.ts\ngit commit -m \"feat: add dashboard CRUD and widget management routes\"\n```\n\n---\n\n## Task 7: Data Export Routes\n\n**Files:**\n- Create: `src/routes/export.ts`\n\n**Dependencies:** Task 1, Task 2, Task 6\n\n**Step 1: Create export router**\n\n```typescript\n// src/routes/export.ts\nimport { Router } from 'express';\nimport type Database from 'better-sqlite3';\nimport { requireAuth } from '../auth.js';\nimport type { AuthRequest } from '../auth.js';\n\ninterface EventRow {\n  id: string;\n  tenant_id: string;\n  name: string;\n  properties: string;\n  timestamp: string;\n  user_id: string | null;\n  session_id: string | null;\n}\n\ninterface DashboardRow {\n  id: string;\n  tenant_id: string;\n  name: string;\n  owner_id: string;\n  config: string;\n  created_at: string;\n  updated_at: string;\n}\n\nfunction toCsv(rows: Record<string, unknown>[], columns: string[]): string {\n  const header = columns.join(',');\n  const lines = rows.map(row =>\n    columns.map(col => {\n      const val = row[col] ?? '';\n      const str = String(val);\n      return str.includes(',') || str.includes('\"') || str.includes('\\n')\n        ? `\"${str.replace(/\"/g, '\"\"')}\"`\n        : str;\n    }).join(',')\n  );\n  return [header, ...lines].join('\\n');\n}\n\nexport function createExportRouter(db: Database.Database): Router {\n  const router = Router();\n\n  router.use(requireAuth);\n\n  // GET /api/export/events?format=json|csv&startTime=&endTime=&eventName=\n  router.get('/events', (req: AuthRequest, res) => {\n    const { format = 'json', startTime, endTime, eventName } = req.query as {\n      format?: string;\n      startTime?: string;\n      endTime?: string;\n      eventName?: string;\n    };\n    let sql = `SELECT * FROM events WHERE tenant_id = ?`;\n    const params: unknown[] = [req.user!.tenantId];\n    if (eventName) { sql += ` AND name = ?`; params.push(eventName); }\n    if (startTime) { sql += ` AND timestamp >= ?`; params.push(startTime); }\n    if (endTime) { sql += ` AND timestamp <= ?`; params.push(endTime); }\n    sql += ` ORDER BY timestamp`;\n    const rows = db.prepare(sql).all(...params as [unknown]) as EventRow[];\n    const data = rows.map(r => ({\n      id: r.id,\n      name: r.name,\n      properties: r.properties,\n      timestamp: r.timestamp,\n      userId: r.user_id,\n      sessionId: r.session_id,\n    }));\n\n    if (format === 'csv') {\n      res.setHeader('Content-Type', 'text/csv');\n      res.setHeader('Content-Disposition', 'attachment; filename=\"events.csv\"');\n      res.send(toCsv(data as Record<string, unknown>[], ['id', 'name', 'properties', 'timestamp', 'userId', 'sessionId']));\n    } else {\n      res.json(data);\n    }\n  });\n\n  // GET /api/export/dashboards?format=json|csv\n  router.get('/dashboards', (req: AuthRequest, res) => {\n    const { format = 'json' } = req.query as { format?: string };\n    const rows = db.prepare(`SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at`).all(req.user!.tenantId) as DashboardRow[];\n    const data = rows.map(r => ({\n      id: r.id,\n      name: r.name,\n      ownerId: r.owner_id,\n      config: r.config,\n      createdAt: r.created_at,\n      updatedAt: r.updated_at,\n    }));\n\n    if (format === 'csv') {\n      res.setHeader('Content-Type', 'text/csv');\n      res.setHeader('Content-Disposition', 'attachment; filename=\"dashboards.csv\"');\n      res.send(toCsv(data as Record<string, unknown>[], ['id', 'name', 'ownerId', 'config', 'createdAt', 'updatedAt']));\n    } else {\n      res.json(data);\n    }\n  });\n\n  // GET /api/export/dashboards/:id?format=json|csv\n  router.get('/dashboards/:id', (req: AuthRequest, res) => {\n    const { format = 'json' } = req.query as { format?: string };\n    const row = db.prepare(`SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?`).get(req.params['id'], req.user!.tenantId) as DashboardRow | undefined;\n    if (!row) {\n      res.status(404).json({ error: 'Dashboard not found' });\n      return;\n    }\n    const data = {\n      id: row.id,\n      name: row.name,\n      ownerId: row.owner_id,\n      config: row.config,\n      createdAt: row.created_at,\n      updatedAt: row.updated_at,\n    };\n\n    if (format === 'csv') {\n      res.setHeader('Content-Type', 'text/csv');\n      res.setHeader('Content-Disposition', `attachment; filename=\"dashboard-${row.id}.csv\"`);\n      res.send(toCsv([data as Record<string, unknown>], ['id', 'name', 'ownerId', 'config', 'createdAt', 'updatedAt']));\n    } else {\n      res.json(data);\n    }\n  });\n\n  return router;\n}\n```\n\n**Step 2: Build and verify**\n\nRun: `npm run build`\nExpected: no errors\n\n**Step 3: Commit**\n\n```bash\ngit add src/routes/export.ts\ngit commit -m \"feat: add CSV/JSON export routes for events and dashboards\"\n```\n\n---\n\n## Task 8: Wire Up and Final Verification\n\n**Files:**\n- Create: `src/index.ts` (re-export createApp)\n\n**Dependencies:** Tasks 1-7\n\n**Step 1: Create index.ts**\n\n```typescript\n// src/index.ts\nexport { createApp } from './app.js';\n```\n\n**Step 2: Run build**\n\nRun: `npm run build`\nExpected: 0 errors\n\n**Step 3: Run lint**\n\nRun: `npm run lint`\nExpected: 0 errors\n\n**Step 4: Fix any build/lint issues found**\n\n**Step 5: Commit**\n\n```bash\ngit add src/index.ts\ngit commit -m \"feat: export createApp from index\"\n```\n\n---\n\n## Task 9: Integration Tests\n\n**Files:**\n- Create: `src/tests/app.test.ts`\n\n**Dependencies:** Tasks 1-8\n\n**Step 1: Write integration tests**\n\n```typescript\n// src/tests/app.test.ts\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport request from 'supertest';\nimport Database from 'better-sqlite3';\nimport fs from 'fs';\nimport path from 'path';\nimport { fileURLToPath } from 'url';\nimport { createApp } from '../app.js';\nimport { setDb } from '../db.js';\n\nconst __dirname = path.dirname(fileURLToPath(import.meta.url));\n\nfunction createTestDb(): Database.Database {\n  const db = new Database(':memory:');\n  const schema = fs.readFileSync(path.join(__dirname, '..', '..', 'schema.sql'), 'utf-8');\n  db.exec(schema);\n  return db;\n}\n\ndescribe('Analytics Dashboard API', () => {\n  let app: ReturnType<typeof createApp>;\n  let db: Database.Database;\n\n  beforeEach(() => {\n    db = createTestDb();\n    setDb(db);\n    app = createApp(db);\n  });\n\n  describe('User Management', () => {\n    it('registers a new user', async () => {\n      const res = await request(app).post('/api/users/register').send({ email: 'alice@example.com', password: 'pass', tenantId: 'tenant1', role: 'admin' });\n      expect(res.status).toBe(201);\n      expect(res.body.token).toBeDefined();\n    });\n\n    it('rejects duplicate registration', async () => {\n      await request(app).post('/api/users/register').send({ email: 'a@b.com', password: 'x', tenantId: 'tenant1' });\n      const res = await request(app).post('/api/users/register').send({ email: 'a@b.com', password: 'x', tenantId: 'tenant1' });\n      expect(res.status).toBe(409);\n    });\n\n    it('logs in successfully', async () => {\n      await request(app).post('/api/users/register').send({ email: 'a@b.com', password: 'pass', tenantId: 't1' });\n      const res = await request(app).post('/api/users/login').send({ email: 'a@b.com', password: 'pass' });\n      expect(res.status).toBe(200);\n      expect(res.body.token).toBeDefined();\n    });\n\n    it('rejects wrong password', async () => {\n      await request(app).post('/api/users/register').send({ email: 'a@b.com', password: 'pass', tenantId: 't1' });\n      const res = await request(app).post('/api/users/login').send({ email: 'a@b.com', password: 'wrong' });\n      expect(res.status).toBe(401);\n    });\n\n    it('returns 401 for unauthenticated /me', async () => {\n      const res = await request(app).get('/api/users/me');\n      expect(res.status).toBe(401);\n    });\n\n    it('returns profile for authenticated user', async () => {\n      const reg = await request(app).post('/api/users/register').send({ email: 'a@b.com', password: 'pass', tenantId: 't1', role: 'admin' });\n      const res = await request(app).get('/api/users/me').set('Authorization', `Bearer ${reg.body.token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.email).toBe('a@b.com');\n    });\n  });\n\n  describe('Event Ingestion', () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const reg = await request(app).post('/api/users/register').send({ email: 'a@b.com', password: 'pass', tenantId: 'tenant1', role: 'admin' });\n      token = reg.body.token as string;\n    });\n\n    it('rejects unauthenticated event ingestion', async () => {\n      const res = await request(app).post('/api/events').send({ name: 'page_view' });\n      expect(res.status).toBe(401);\n    });\n\n    it('ingests a single event', async () => {\n      const res = await request(app).post('/api/events').set('Authorization', `Bearer ${token}`).send({ name: 'page_view', properties: { url: '/home' } });\n      expect(res.status).toBe(201);\n      expect(res.body.id).toBeDefined();\n    });\n\n    it('ingests a batch of events', async () => {\n      const res = await request(app).post('/api/events/batch').set('Authorization', `Bearer ${token}`).send({ events: [{ name: 'e1' }, { name: 'e2' }] });\n      expect(res.status).toBe(201);\n      expect(res.body.inserted).toBe(2);\n    });\n  });\n\n  describe('Query Engine', () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const reg = await request(app).post('/api/users/register').send({ email: 'a@b.com', password: 'pass', tenantId: 'tenant1', role: 'admin' });\n      token = reg.body.token as string;\n      await request(app).post('/api/events/batch').set('Authorization', `Bearer ${token}`).send({ events: [\n        { name: 'page_view', properties: { url: '/home' }, timestamp: '2024-01-01T10:00:00Z' },\n        { name: 'page_view', properties: { url: '/about' }, timestamp: '2024-01-01T11:00:00Z' },\n        { name: 'click', properties: { url: '/home' }, timestamp: '2024-01-02T10:00:00Z' },\n      ]});\n    });\n\n    it('counts events', async () => {\n      const res = await request(app).post('/api/query/count').set('Authorization', `Bearer ${token}`).send({ eventName: 'page_view' });\n      expect(res.status).toBe(200);\n      expect(res.body.count).toBe(2);\n    });\n\n    it('returns timeseries', async () => {\n      const res = await request(app).post('/api/query/timeseries').set('Authorization', `Bearer ${token}`).send({ eventName: 'page_view', interval: 'day' });\n      expect(res.status).toBe(200);\n      expect(res.body.data.length).toBeGreaterThan(0);\n    });\n\n    it('returns breakdown by property', async () => {\n      const res = await request(app).post('/api/query/breakdown').set('Authorization', `Bearer ${token}`).send({ eventName: 'page_view', property: 'url' });\n      expect(res.status).toBe(200);\n      expect(res.body.data.length).toBe(2);\n    });\n\n    it('enforces tenant isolation', async () => {\n      const reg2 = await request(app).post('/api/users/register').send({ email: 'b@b.com', password: 'pass', tenantId: 'tenant2', role: 'admin' });\n      const res = await request(app).post('/api/query/count').set('Authorization', `Bearer ${reg2.body.token}`).send({});\n      expect(res.body.count).toBe(0);\n    });\n  });\n\n  describe('Dashboards', () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const reg = await request(app).post('/api/users/register').send({ email: 'a@b.com', password: 'pass', tenantId: 'tenant1', role: 'admin' });\n      token = reg.body.token as string;\n    });\n\n    it('creates a dashboard', async () => {\n      const res = await request(app).post('/api/dashboards').set('Authorization', `Bearer ${token}`).send({ name: 'My Dashboard' });\n      expect(res.status).toBe(201);\n      expect(res.body.id).toBeDefined();\n    });\n\n    it('lists dashboards', async () => {\n      await request(app).post('/api/dashboards').set('Authorization', `Bearer ${token}`).send({ name: 'D1' });\n      const res = await request(app).get('/api/dashboards').set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.length).toBe(1);\n    });\n\n    it('updates a dashboard', async () => {\n      const created = await request(app).post('/api/dashboards').set('Authorization', `Bearer ${token}`).send({ name: 'D1' });\n      const res = await request(app).put(`/api/dashboards/${created.body.id}`).set('Authorization', `Bearer ${token}`).send({ name: 'D1 Updated' });\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe('D1 Updated');\n    });\n\n    it('deletes a dashboard', async () => {\n      const created = await request(app).post('/api/dashboards').set('Authorization', `Bearer ${token}`).send({ name: 'D1' });\n      const res = await request(app).delete(`/api/dashboards/${created.body.id}`).set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(204);\n    });\n  });\n\n  describe('Export', () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const reg = await request(app).post('/api/users/register').send({ email: 'a@b.com', password: 'pass', tenantId: 'tenant1', role: 'admin' });\n      token = reg.body.token as string;\n      await request(app).post('/api/events').set('Authorization', `Bearer ${token}`).send({ name: 'page_view' });\n    });\n\n    it('exports events as JSON', async () => {\n      const res = await request(app).get('/api/export/events').set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(Array.isArray(res.body)).toBe(true);\n    });\n\n    it('exports events as CSV', async () => {\n      const res = await request(app).get('/api/export/events?format=csv').set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.headers['content-type']).toContain('text/csv');\n    });\n\n    it('exports dashboards as JSON', async () => {\n      await request(app).post('/api/dashboards').set('Authorization', `Bearer ${token}`).send({ name: 'D' });\n      const res = await request(app).get('/api/export/dashboards').set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(Array.isArray(res.body)).toBe(true);\n    });\n  });\n});\n```\n\n**Step 2: Run tests**\n\nRun: `npm test`\nExpected: all pass\n\n**Step 3: Commit**\n\n```bash\ngit add src/tests/app.test.ts\ngit commit -m \"test: add integration tests for all API endpoints\"\n```\n\n---\n\n## Notes on better-sqlite3 Variadic Params\n\n`better-sqlite3`'s `get()` and `all()` accept positional params as rest args. When building dynamic queries, collect params in an array and spread:\n\n```typescript\nconst row = db.prepare(sql).get(...params as [unknown]);\nconst rows = db.prepare(sql).all(...params as [unknown]);\n```\n\nThis is the standard pattern for this library.\n","structuredPatch":[],"originalFile":null}}
