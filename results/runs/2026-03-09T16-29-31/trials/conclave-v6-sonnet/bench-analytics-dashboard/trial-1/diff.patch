     params.push(startTime);\n    }\n    if (endTime) {\n      sql += ` AND timestamp <= ?`;\n      params.push(endTime);\n    }\n    sql += ` ORDER BY timestamp`;\n    const rows = db.prepare(sql).all(...(params as [unknown])) as EventRow[];\n    const data = rows.map(r => ({\n      id: r.id,\n      name: r.name,\n      properties: r.properties,\n      timestamp: r.timestamp,\n      userId: r.user_id,\n      sessionId: r.session_id,\n    }));\n\n    if (format === 'csv') {\n      res.setHeader('Content-Type', 'text/csv');\n      res.setHeader('Content-Disposition', 'attachment; filename=\"events.csv\"');\n      res.send(\n        toCsv(data as Record<string, unknown>[], [\n          'id',\n          'name',\n          'properties',\n          'timestamp',\n          'userId',\n          'sessionId',\n        ])\n      );\n    } else {\n      res.json(data);\n    }\n  });\n\n  // GET /api/export/dashboards?format=json|csv\n  router.get('/dashboards', (req: AuthRequest, res) => {\n    const { format = 'json' } = req.query as { format?: string };\n    const rows = db\n      .prepare(`SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at`)\n      .all(req.user!.tenantId) as DashboardRow[];\n    const data = rows.map(r => ({\n      id: r.id,\n      name: r.name,\n      ownerId: r.owner_id,\n      config: r.config,\n      createdAt: r.created_at,\n      updatedAt: r.updated_at,\n    }));\n\n    if (format === 'csv') {\n      res.setHeader('Content-Type', 'text/csv');\n      res.setHeader('Content-Disposition', 'attachment; filename=\"dashboards.csv\"');\n      res.send(\n        toCsv(data as Record<string, unknown>[], [\n          'id',\n          'name',\n          'ownerId',\n          'config',\n          'createdAt',\n          'updatedAt',\n        ])\n      );\n    } else {\n      res.json(data);\n    }\n  });\n\n  // GET /api/export/dashboards/:id?format=json|csv\n  router.get('/dashboards/:id', (req: AuthRequest, res) => {\n    const { format = 'json'