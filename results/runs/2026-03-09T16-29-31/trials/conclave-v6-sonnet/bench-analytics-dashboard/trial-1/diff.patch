+import express from 'express';
+import { getDb } from './db.js';
+import { createUserRouter } from './routes/users.js';
+import { createEventsRouter } from './routes/events.js';
+import { createQueryRouter } from './routes/query.js';
+import { createDashboardRouter } from './routes/dashboards.js';
+import { createExportRouter } from './routes/export.js';
+import type Database from 'better-sqlite3';
+
+export function createApp(db?: Database.Database): express.Application {
+  const app = express();
+  app.use(express.json());
+
+  const database = db ?? getDb();
+
+  app.use('/api/users', createUserRouter(database));
+  app.use('/api/events', createEventsRouter(database));
+  app.use('/api/query', createQueryRouter(database));
+  app.use('/api/dashboards', createDashboardRouter(database));
+  app.use('/api/export', createExportRouter(database));
+
+  return app;
+}
diff --git a/src/auth.ts b/src/auth.ts
