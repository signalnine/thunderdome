+{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01Xz1Yq2bxQWBoCEZaXmJBen","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01VMAx9ZRcERjsvoSERojbLa","name":"Write","input":{"file_path":"/workspace/src/routes/users.ts","content":"import { Router } from 'express';\nimport { v4 as uuidv4 } from 'uuid';\nimport crypto from 'crypto';\nimport type Database from 'better-sqlite3';\nimport { signToken, requireAuth, requireRole } from '../auth.js';\nimport type { AuthRequest } from '../auth.js';\n\nfunction hashPassword(password: string): string {\n  return crypto.createHash('sha256').update(password).digest('hex');\n}\n\ninterface UserRow {\n  id: string;\n  email: string;\n  password_hash: string;\n  tenant_id: string;\n  role: string;\n  created_at: string;\n}\n\nexport function createUserRouter(db: Database.Database): Router {\n  const router = Router();\n\n  // POST /api/users/register\n  router.post('/register', (req, res) => {\n    const { email, password, tenantId, role } = req.body as {\n      email?: string;\n      password?: string;\n      tenantId?: string;\n      role?: string;\n    };\n    if (!email || !password || !tenantId) {\n      res.status(400).json({ error: 'email, password, tenantId required' });\n      return;\n    }\n    const id = uuidv4();\n    const password_hash = hashPassword(password);\n    const userRole = role ?? 'viewer';\n    try {\n      db.prepare(\n        `INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)`\n      ).run(id, email, password_hash, tenantId, userRole);\n      const token = signToken({ userId: id, tenantId, role: userRole });\n      res.status(201).json({ id, email, tenantId, role: userRole, token });\n    } catch {\n      res.status(409).json({ error: 'Email already exists' });\n    }\n  });\n\n  // POST /api/users/login\n  router.post('/login', (req, res) => {\n    const { email, password } = req.body as { email?: string; password?: string };\n    if (!email || !password) {\n      res.status(400).json({ error: 'email and password required' });\n      return;\n    }\n    const user = db.prepare(`SELECT * FROM users WHERE email = ?`).get(email) as UserRow | undefined;\n    if (!user || user.password_hash !== hashPassword(password)) {\n      res.status(401).json({ error: 'Invalid credentials' });\n      return;\n    }\n    const token = signToken({ userId: user.id, tenantId: user.tenant_id, role: user.role });\n    res.json({ id: user.id, email: user.email, tenantId: user.tenant_id, role: user.role, token });\n  });\n\n  // GET /api/users/me\n  router.get('/me', requireAuth, (req: AuthRequest, res) => {\n    const user = db\n      .prepare(`SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?`)\n      .get(req.user!.userId) as UserRow | undefined;\n    if (!user) {\n      res.status(404).json({ error: 'User not found' });\n      return;\n    }\n    res.json({\n      id: user.id,\n      email: user.email,\n      tenantId: user.tenant_id,\n      role: user.role,\n      createdAt: user.created_at,\n    });\n  });\n\n  // PATCH /api/users/:userId/role\n  router.patch('/:userId/role', requireAuth, requireRole('admin'), (req: AuthRequest, res) => {\n    const { userId } = req.params;\n    const { role } = req.body as { role?: string };\n    if (!role || !['admin', 'editor', 'viewer'].includes(role)) {\n      res.status(400).json({ error: 'Invalid role' });\n      return;\n    }\n    const user = db\n      .prepare(`SELECT * FROM users WHERE id = ? AND tenant_id = ?`)\n      .get(userId, req.user!.tenantId) as UserRow | undefined;\n    if (!user) {\n      res.status(404).json({ error: 'User not found' });\n      return;\n    }\n    db.prepare(`UPDATE users SET role = ? WHERE id = ?`).run(role, userId);\n    res.json({ id: userId, role });\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens