UES (?, ?, ?, ?, ?, ?, ?)`\n    ).run(id, req.user!.tenantId, name, req.user!.userId, JSON.stringify(config ?? {}), now, now);\n    res.status(201).json({\n      id,\n      name,\n      tenantId: req.user!.tenantId,\n      ownerId: req.user!.userId,\n      config: config ?? {},\n      createdAt: now,\n      updatedAt: now,\n    });\n  });\n\n  // GET /api/dashboards/:id\n  router.get('/:id', (req: AuthRequest, res) => {\n    const row = db\n      .prepare(`SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?`)\n      .get(req.params['id'], req.user!.tenantId) as DashboardRow | undefined;\n    if (!row) {\n      res.status(404).json({ error: 'Dashboard not found' });\n      return;\n    }\n    const widgets = db\n      .prepare(`SELECT * FROM widgets WHERE dashboard_id = ?`)\n      .all(row.id) as WidgetRow[];\n    res.json({\n      id: row.id,\n      name: row.name,\n      tenantId: row.tenant_id,\n      ownerId: row.owner_id,\n      config: JSON.parse(row.config) as Record<string, unknown>,\n      createdAt: row.created_at,\n      updatedAt: row.updated_at,\n      widgets: widgets.map(w => ({\n        id: w.id,\n        type: w.type,\n        config: JSON.parse(w.config) as Record<string, unknown>,\n        position: { x: w.position_x, y: w.position_y },\n        size: { width: w.width, height: w.height },\n      })),\n    });\n  });\n\n  // PUT /api/dashboards/:id\n  router.put('/:id', (req: AuthRequest, res) => {\n    const row = db\n      .prepare(`SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?`)\n      .get(req.params['id'], req.user!.tenantId) as DashboardRow | undefined;\n    if (!row) {\n      res.status(404).json({ error: 'Dashboard not found' });\n      return;\n    }\n    const { name, config } = req.body as {\n      name?: string;\n      config?: Record<string, unknown>;\n    };\n    const newName = name ?? row.name;\n    const newConfig = JSON.stringify(config ?? (JSON.parse(row.config) as Record<string, unknown>));\n    const now = new Date().toISOString();\n    db.prepare(`UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?`).run(\n      newName,\n      newConfig,\n      now,\n      row.id\n    );\n    res.json({\n      id: row.id,\n      name: newName,\n      tenantId: row.tenant_id,\n      ownerId: row.owner_id,\n      config: JSON.parse(newConfig) as Record<string, unknown>,\n      updatedAt: now,\n    });\n  });\n\n  // DELETE /api/dashboards/:id\n  router.delete('/:id', (req: AuthRequest, res) => {\n    const row = db\n      .prepare(`SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?`)\n      .get(req.params['id'], req.user!.tenantId) as DashboardRow | undefined;\n    if (!row) {\n      res.status(404).json({ error: 'Dashboard not found' });\n      return;\n    }\n    db.prepare(`DELETE FROM dashboards WHERE id = ?`).run(row.id);\n    res.status(204).send();\n  });\n\n  // POST /api/dashboards/:id/widgets\n  router.post('/:id/widgets', (req: AuthRequest, res) => {\n    const dashboard = db\n      .prepare(`SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?`)\n      .get(req.params['id'], req.user!.tenantId) as DashboardRow | undefined;\n    if (!dashboard) {\n      res.status(404).json({ error: 'Dashboard not found' });\n      return;\n    }\n    const { type, config, position, size } = req.body as {\n      type?: string;\n      config?: Record<string, unknown>;\n      position?: { x?: number; y?: number };\n      size?: { width?: number; height?: number };\n    };\n    if (!type || !['counter', 'timeseries', 'breakdown', 'funnel'].includes(type)) {\n      res.status(400).json({ error: 'Invalid widget type' });\n      return;\n    }\n    const id = uuidv4();\n    db.prepare(\n      `INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)`\n    ).run(\n      id,\n      dashboard.id,\n      type,\n      JSON.stringify(config ?? {}),\n      position?.x ?? 0,\n      position?.y ?? 0,\n      size?.width ?? 1,\n      size?.height ?? 1\n    );\n    res.status(201).json({ id, dashboardId: dashboard.id, type, config: config ?? {} });\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1156,"cache_read_input_tokens":46226,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1156},"output_tokens":18,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"f4c6aeb2-97e0-4263-8af4-c03fe4a80281","uuid":"2e796a6e-4e34-4701-ac1b-ca434de6a26f"}
