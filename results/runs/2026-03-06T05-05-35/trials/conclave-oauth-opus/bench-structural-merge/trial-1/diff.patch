te('doc1');\n    expect(() => store.get('doc1')).toThrow();\n  });\n\n  it('delete throws if document does not exist', () => {\n    expect(() => store.delete('nonexistent')).toThrow();\n  });\n\n  it('delete throws if document already deleted', () => {\n    store.create('doc1', { a: 1 });\n    store.delete('doc1');\n    expect(() => store.delete('doc1')).toThrow();\n  });\n\n  it('update throws on deleted document', () => {\n    store.create('doc1', { a: 1 });\n    store.delete('doc1');\n    expect(() => store.update('doc1', { a: 2 })).toThrow();\n  });\n});\n```\n\n**Step 2: Create `src/store.ts` with CRUD implementation**\n\n```typescript\nimport { Version, MergeResult, DocState, BranchState } from './types.js';\n\nexport class DocumentStore {\n  private branches: Map<string, BranchState> = new Map();\n  private currentBranch: string = 'main';\n  private versionCounter: number = 0;\n\n  constructor() {\n    this.branches.set('main', {\n      documents: new Map(),\n      forkBase: new Map(),\n      parentBranch: null,\n    });\n  }\n\n  private getBranchState(): BranchState {\n    const state = this.branches.get(this.currentBranch);\n    if (!state) throw new Error(`Branch \"${this.currentBranch}\" does not exist`);\n    return state;\n  }\n\n  private nextVersionId(): string {\n    return `v${++this.versionCounter}`;\n  }\n\n  create(id: string, content: object): void {\n    const branch = this.getBranchState();\n    const existing = branch.documents.get(id);\n    if (existing && !existing.deleted) {\n      throw new Error(`Document \"${id}\" already exists`);\n    }\n    const cloned = structuredClone(content);\n    const version: Version = {\n      id: this.nextVersionId(),\n      timestamp: Date.now(),\n      content: structuredClone(cloned),\n    };\n    branch.documents.set(id, {\n      content: cloned,\n      versions: [version],\n      deleted: false,\n    });\n  }\n\n  get(id: string): object {\n    const branch = this.getBranchState();\n    const doc = branch.documents.get(id);\n    if (!doc || doc.deleted) {\n      throw new Error(`Document \"${id}\" does not exist`);\n    }\n    return structuredClone(doc.content);\n  }\n\n  update(id: string, content: object): void {\n    const branch = this.getBranchState();\n    const doc = branch.documents.get(id);\n    if (!doc || doc.deleted) {\n      throw new Error(`Document \"${id}\" does not exist`);\n    }\n    const cloned = structuredClone(content);\n    const version: Version = {\n      id: this.nextVersionId(),\n      timestamp: Date.now(),\n      content: structuredClone(cloned),\n    };\n    doc.content = cloned;\n    doc.versions.push(version);\n  }\n\n  delete(id: string): void {\n    const branch = this.getBranchState();\n    const doc = branch.documents.get(id);\n    if (!doc || doc.deleted) {\n      throw new Error(`Document \"${id}\" does not exist`);\n    }\n    doc.deleted = true;\n  }\n\n  // Stubs for later tasks\n  getHistory(id: string): Version[] { throw new Error('Not implemented'); }\n  getVersion(id: string, versionId: string): object { throw new Error('Not implemented'); }\n  createBranch(name: string, fromBranch?: string): void { throw new Error('Not implemented'); }\n  switchBranch(name: string): void { throw new Error('Not implemented'); }\n  getBranch(): string { return this.currentBranch; }\n  listBranches(): string[] { throw new Error('Not implemented'); }\n  merge(sourceBranch: string): MergeResult { throw new Error('Not implemented'); }\n}\n```\n\n**Step 3: Create `src/index.ts`**\n\n```typescript\nexport { DocumentStore } from './store.js';\nexport type { Version, MergeResult, Conflict } from './types.js';\n```\n\n**Step 4: Run tests**\n\nRun: `npx vitest run src/__tests__/crud.test.ts`\nExpected: All tests PASS.\n\n**Step 5: Commit**\n\n```bash\ngit add src/\ngit commit -m \"feat: implement CRUD operations with tests\"\n```\n\n---\n\n### Task 3: Version history — tests and implementation\n\n**Files:**\n- Create: `src/__tests__/version.test.ts`\n- Modify: `src/store.ts` (replace getHistory and getVersion stubs)\n\n**Dependencies:** Task 2\n\n**Step 1: Write failing version history tests**\n\nCreate `src/__tests__/version.test.ts`:\n\n```typescript\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { DocumentStore } from '../index.js';\n\ndescribe('DocumentStore Version History', () => {\n  let store: DocumentStore;\n\n  beforeEach(() => {\n    store = new DocumentStore();\n  });\n\n  it('getHistory returns versions in chronological order', () => {\n    store.create('doc1', { v: 1 });\n    store.update('doc1', { v: 2 });\n    store.update('doc1', { v: 3 });\n    const history = store.getHistory('doc1');\n    expect(history).toHaveLength(3);\n    expect(history[0].content).toEqual({ v: 1 });\n    expect(history[1].content).toEqual({ v: 2 });\n    expect(history[2].content).toEqual({ v: 3 });\n  });\n\n  it('each version has a unique id and timestamp', () => {\n    store.create('doc1', { v: 1 });\n    store.update('doc1', { v: 2 });\n    const history = store.getHistory('doc1');\n    expect(history[0].id).not.toBe(history[1].id);\n    expect(typeof history[0].timestamp).toBe('number');\n  });\n\n  it('getVersion returns content at a specific version', () => {\n    store.create('doc1', { v: 1 });\n    store.update('doc1', { v: 2 });\n    const history = store.getHistory('doc1');\n    const v1Content = store.getVersion('doc1', history[0].id);\n    expect(v1Content).toEqual({ v: 1 });\n  });\n\n  it('getVersion returns deep clone', () => {\n    store.create('doc1', { nested: { v: 1 } });\n    const history = store.getHistory('doc1');\n    const content = store.getVersion('doc1', history[0].id) as any;\n    content.nested.v = 999;\n    expect((store.getVersion('doc1', history[0].id) as any).nested.v).toBe(1);\n  });\n\n  it('getHistory returns deep clones', () => {\n    store.create('doc1', { nested: { v: 1 } });\n    const history = store.getHistory('doc1');\n    (history[0].content as any).nested.v = 999;\n    const history2 = store.getHistory('doc1');\n    expect((history2[0].content as any).nested.v).toBe(1);\n  });\n\n  it('getHistory throws for nonexistent document', () => {\n    expect(() => store.getHistory('nonexistent')).toThrow();\n  });\n\n  it('getVersion throws for nonexistent version', () => {\n    store.create('doc1', { v: 1 });\n    expect(() => store.getVersion('doc1', 'bad-id')).toThrow();\n  });\n});\n```\n\n**Step 2: Implement getHistory and getVersion in `src/store.ts`**\n\nReplace the stubs:\n\n```typescript\ngetHistory(id: string): Version[] {\n  const branch = this.getBranchState();\n  const doc = branch.documents.get(id);\n  if (!doc) {\n    throw new Error(`Document \"${id}\" does not exist`);\n  }\n  return doc.versions.map(v => ({\n    id: v.id,\n    timestamp: v.timestamp,\n    content: structuredClone(v.content),\n  }));\n}\n\ngetVersion(id: string, versionId: string): object {\n  const branch = this.getBranchState();\n  const doc = branch.documents.get(id);\n  if (!doc) {\n    throw new Error(`Document \"${id}\" does not exist`);\n  }\n  const version = doc.versions.find(v => v.id === versionId);\n  if (!version) {\n    throw new Error(`Version \"${versionId}\" does not exist for document \"${id}\"`);\n  }\n  return structuredClone(version.content);\n}\n```\n\n**Step 3: Run tests**\n\nRun: `npx vitest run src/__tests__/version.test.ts`\nExpected: All tests PASS.\n\n**Step 4: Commit**\n\n```bash\ngit add src/\ngit commit -m \"feat: implement version history with tests\"\n```\n\n---\n\n### Task 4: Branching — tests and implementation\n\n**Files:**\n- Create: `src/__tests__/branch.test.ts`\n- Modify: `src/store.ts` (replace branching stubs)\n\n**Dependencies:** Task 2\n\n**Step 1: Write failing branching tests**\n\nCreate `src/__tests__/branch.test.ts`:\n\n```typescript\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { DocumentStore } from '../index.js';\n\ndescribe('DocumentStore Branching', () => {\n  let store: DocumentStore;\n\n  beforeEach(() => {\n    store = new DocumentStore();\n  });\n\n  it('default branch is main', () => {\n    expect(store.getBranch()).toBe('main');\n  });\n\n  it('listBranches returns all branches', () => {\n    expect(store.listBranches()).toEqual(['main']);\n    store.createBranch('feature');\n    expect(store.listBranches().sort()).toEqual(['feature', 'main']);\n  });\n\n  it('createBranch copies current state', () => {\n    store.create('doc1', { a: 1 });\n    store.createBranch('feature');\n    store.switchBranch('feature');\n    expect(store.get('doc1')).toEqual({ a: 1 });\n  });\n\n  it('changes on one branch are not visible on another', () => {\n    store.create('doc1', { a: 1 });\n    store.createBranch('feature');\n    store.switchBranch('feature');\n    store.update('doc1', { a: 2 });\n    store.switchBranch('main');\n    expect(store.get('doc1')).toEqual({ a: 1 });\n  });\n\n  it('createBranch from a specific branch', () => {\n    store.create('doc1', { a: 1 });\n    store.createBranch('feature');\n    store.switchBranch('feature');\n    store.update('doc1', { a: 2 });\n    // Create branch2 from feature, while on feature\n    store.createBranch('feature2', 'feature');\n    store.switchBranch('feature2');\n    expect(store.get('doc1')).toEqual({ a: 2 });\n  });\n\n  it('createBranch throws if name already exists', () => {\n    store.createBranch('feature');\n    expect(() => store.createBranch('feature')).toThrow();\n  });\n\n  it('switchBranch throws if branch does not exist', () => {\n    expect(() => store.switchBranch('nonexistent')).toThrow();\n  });\n\n  it('branch isolates new documents', () => {\n    store.createBranch('feature');\n    store.switchBranch('feature');\n    store.create('doc1', { a: 1 });\n    store.switchBranch('main');\n    expect(() => store.get('doc1')).toThrow();\n  });\n\n  it('branch isolates deletes', () => {\n    store.create('doc1', { a: 1 });\n    store.createBranch('feature');\n    store.switchBranch('feature');\n    store.delete('doc1');\n    store.switchBranch('main');\n    expect(store.get('doc1')).toEqual({ a: 1 });\n  });\n\n  it('branch state is deep-cloned (no shared references)', () => {\n    store.create('doc1', { nested: { v: 1 } });\n    store.createBranch('feature');\n    store.switchBranch('feature');\n    store.update('doc1', { nested: { v: 2 } });\n    store.switchBranch('main');\n    expect((store.get('doc1') as any).nested.v).toBe(1);\n  });\n});\n```\n\n**Step 2: Implement branching in `src/store.ts`**\n\nReplace the branching stubs:\n\n```typescript\nprivate cloneBranchDocuments(source: Map<string, DocState>): Map<string, DocState> {\n  const cloned = new Map<string, DocState>();\n  for (const [id, doc] of source) {\n    cloned.set(id, {\n      content: structuredClone(doc.content),\n      versions: doc.versions.map(v => ({\n        id: v.id,\n        timestamp: v.timestamp,\n        content: structuredClone(v.content),\n      })),\n      deleted: doc.deleted,\n    });\n  }\n  return cloned;\n}\n\ncreateBranch(name: string, fromBranch?: string): void {\n  if (this.branches.has(name)) {\n    throw new Error(`Branch \"${name}\" already exists`);\n  }\n  const sourceName = fromBranch ?? this.currentBranch;\n  const source = this.branches.get(sourceName);\n  if (!source) {\n    throw new Error(`Branch \"${sourceName}\" does not exist`);\n  }\n  // Snapshot current content as fork base\n  const forkBase = new Map<string, object | null>();\n  for (const [id, doc] of source.documents) {\n    forkBase.set(id, doc.deleted ? null : structuredClone(doc.content));\n  }\n  this.branches.set(name, {\n    documents: this.cloneBranchDocuments(source.documents),\n    forkBase,\n    parentBranch: sourceName,\n  });\n}\n\nswitchBranch(name: string): void {\n  if (!this.branches.has(name)) {\n    throw new Error(`Branch \"${name}\" does not exist`);\n  }\n  this.currentBranch = name;\n}\n\ngetBranch(): string {\n  return this.currentBranch;\n}\n\nlistBranches(): string[] {\n  return Array.from(this.branches.keys());\n}\n```\n\n**Step 3: Run tests**\n\nRun: `npx vitest run src/__tests__/branch.test.ts`\nExpected: All tests PASS.\n\n**Step 4: Commit**\n\n```bash\ngit add src/\ngit commit -m \"feat: implement branching with tests\"\n```\n\n---\n\n### Task 5: Three-way merge — implementation\n\n**Files:**\n- Create: `src/merge.ts`\n\n**Dependencies:** Task 1\n\n**Step 1: Create `src/merge.ts`**\n\n```typescript\nimport { Conflict } from './types.js';\n\nexport interface MergeDocInput {\n  documentId: string;\n  base: object | null;   // null = didn't exist at fork point\n  ours: object | null;   // null = deleted or doesn't exist on target\n  theirs: object | null;  // null = deleted or doesn't exist on source\n}\n\nexport interface DocMergeResult {\n  content: object | null;  // null = document should be deleted\n  conflicts: Conflict[];\n}\n\nfunction deepEqual(a: any, b: any): boolean {\n  if (a === b) return true;\n  if (a === null || b === null) return a === b;\n  if (typeof a !== typeof b) return false;\n  if (typeof a !== 'object') return false;\n  if (Array.isArray(a) !== Array.isArray(b)) return false;\n  if (Array.isArray(a)) {\n    if (a.length !== b.length) return false;\n    return a.every((val: any, i: number) => deepEqual(val, b[i]));\n  }\n  const keysA = Object.keys(a);\n  const keysB = Object.keys(b);\n  if (keysA.length !== keysB.length) return false;\n  return keysA.every(key => key in b && deepEqual(a[key], b[key]));\n}\n\nexport function mergeObjects(\n  base: Record<string, any>,\n  ours: Record<string, any>,\n  theirs: Record<string, any>,\n  documentId: string,\n  pathPrefix: string = ''\n): { merged: Record<string, any>; conflicts: Conflict[] } {\n  const merged: Record<string, any> = {};\n  const conflicts: Conflict[] = [];\n\n  const allKeys = new Set([\n    ...Object.keys(base),\n    ...Object.keys(ours),\n    ...Object.keys(theirs),\n  ]);\n\n  for (const key of allKeys) {\n    const path = pathPrefix ? `${pathPrefix}.${key}` : key;\n    const baseVal = base[key];\n    const oursVal = ours[key];\n    const theirsVal = theirs[key];\n\n    const oursChanged = !deepEqual(baseVal, oursVal);\n    const theirsChanged = !deepEqual(baseVal, theirsVal);\n\n    if (!oursChanged && !theirsChanged) {\n      // Neither changed — keep base value (if it exists)\n      if (key in base) merged[key] = structuredClone(baseVal);\n    } else if (oursChanged && !theirsChanged) {\n      // Only ours changed\n      if (key in ours) merged[key] = structuredClone(oursVal);\n      // else: ours deleted this key, omit from merged\n    } else if (!oursChanged && theirsChanged) {\n      // Only theirs changed\n      if (key in theirs) merged[key] = structuredClone(theirsVal);\n      // else: theirs deleted this key, omit from merged\n    } else {\n      // Both changed\n      if (deepEqual(oursVal, theirsVal)) {\n        // Both changed to the same value — no conflict\n        if (key in ours) merged[key] = structuredClone(oursVal);\n      } else if (\n        typeof oursVal === 'object' && oursVal !== null && !Array.isArray(oursVal) &&\n        typeof theirsVal === 'object' && theirsVal !== null && !Array.isArray(theirsVal) &&\n        typeof baseVal === 'object' && baseVal !== null && !Array.isArray(baseVal)\n      ) {\n        // Both are objects — recurse\n        const sub = mergeObjects(baseVal, oursVal, theirsVal, documentId, path);\n        merged[key] = sub.merged;\n        conflicts.push(...sub.conflicts);\n      } else {\n        // Conflict — favor ours for merged result\n        conflicts.push({ documentId, path, base: baseVal, ours: oursVal, theirs: theirsVal });\n        merged[key] = structuredClone(oursVal);\n      }\n    }\n  }\n\n  return { merged, conflicts };\n}\n\nexport function mergeDocument(input: MergeDocInput): DocMergeResult {\n  const { documentId, base, ours, theirs } = input;\n\n  const baseExists = base !== null;\n  const oursExists = ours !== null;\n  const theirsExists = theirs !== null;\n\n  // No changes\n  if (deepEqual(base, ours) && deepEqual(base, theirs)) {\n    return { content: ours ? structuredClone(ours) : null, conflicts: [] };\n  }\n\n  // Document only on one side (created after fork)\n  if (!baseExists && !oursExists && theirsExists) {\n    return { content: structuredClone(theirs), conflicts: [] };\n  }\n  if (!baseExists && oursExists && !theirsExists) {\n    return { content: structuredClone(ours), conflicts: [] };\n  }\n  if (!baseExists && oursExists && theirsExists) {\n    // Both created — treat as conflict if different\n    if (deepEqual(ours, theirs)) {\n      return { content: structuredClone(ours), conflicts: [] };\n    }\n    const result = mergeObjects({}, ours as Record<string, any>, theirs as Record<string, any>, documentId);\n    return { content: result.merged, conflicts: result.conflicts };\n  }\n\n  // Deletion cases\n  if (baseExists && !oursExists && !theirsExists) {\n    // Both deleted\n    return { content: null, conflicts: [] };\n  }\n  if (baseExists && oursExists && !theirsExists) {\n    // Theirs deleted\n    if (deepEqual(base, ours)) {\n      // Ours unchanged, theirs deleted — apply delete\n      return { content: null, conflicts: [] };\n    }\n    // Ours modified, theirs deleted — conflict\n    return {\n      content: structuredClone(ours),\n      conflicts: [{ documentId, path: '', base, ours, theirs: null }],\n    };\n  }\n  if (baseExists && !oursExists && theirsExists) {\n    // Ours deleted\n    if (deepEqual(base, theirs)) {\n      // Theirs unchanged, ours deleted — keep deleted\n      return { content: null, conflicts: [] };\n    }\n    // Theirs modified, ours deleted — conflict\n    return {\n      content: null,\n      conflicts: [{ documentId, path: '', base, ours: null, theirs }],\n    };\n  }\n\n  // Both exist — field-level merge\n  const result = mergeObjects(\n    base as Record<string, any>,\n    ours as Record<string, any>,\n    theirs as Record<string, any>,\n    documentId\n  );\n  return { content: result.merged, conflicts: result.conflicts };\n}\n```\n\n**Step 2: Verify it compiles**\n\nRun: `npx tsc --noEmit`\nExpected: No errors.\n\n**Step 3: Commit**\n\n```bash\ngit add src/merge.ts\ngit commit -m \"feat: implement three-way structural merge algorithm\"\n```\n\n---\n\n### Task 6: Merge integration — tests and wiring into store\n\n**Files:**\n- Create: `src/__tests__/merge.test.ts`\n- Modify: `src/store.ts` (replace merge stub)\n\n**Dependencies:** Task 4, Task 5\n\n**Step 1: Write merge tests**\n\nCreate `src/__tests__/merge.test.ts`:\n\n```typescript\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { DocumentStore } from '../index.js';\n\ndescribe('DocumentStore Merge', () => {\n  let store: DocumentStore;\n\n  beforeEach(() => {\n    store = new DocumentStore();\n  });\n\n  it('merge with no changes is a no-op', () => {\n    store.create('doc1', { a: 1 });\n    store.createBranch('feature');\n    const result = store.merge('feature');\n    expect(result.applied).toBe(true);\n    expect(result.conflicts).toHaveLength(0);\n  });\n\n  it('merge brings in changes from source branch', () => {\n    store.create('doc1', { a: 1, b: 2 });\n    store.createBranch('feature');\n    store.switchBranch('feature');\n    store.update('doc1', { a: 1, b: 3 });\n    store.switchBranch('main');\n    const result = store.merge('feature');\n    expect(result.applied).toBe(true);\n    expect(result.merged['doc1']).toEqual({ a: 1, b: 3 });\n    expect(store.get('doc1')).toEqual({ a: 1, b: 3 });\n  });\n\n  it('merge keeps changes on current branch', () => {\n    store.create('doc1', { a: 1, b: 2 });\n    store.createBranch('feature');\n    store.update('doc1', { a: 99, b: 2 });\n    const result = store.merge('feature');\n    expect(result.applied).toBe(true);\n    expect(store.get('doc1')).toEqual({ a: 99, b: 2 });\n  });\n\n  it('non-conflicting changes on different fields merge cleanly', () => {\n    store.create('doc1', { a: 1, b: 2 });\n    store.createBranch('feature');\n    store.switchBranch('feature');\n    store.update('doc1', { a: 1, b: 3 });\n    store.switchBranch('main');\n    store.update('doc1', { a: 99, b: 2 });\n    const result = store.merge('feature');\n    expect(result.applied).toBe(true);\n    expect(result.merged['doc1']).toEqual({ a: 99, b: 3 });\n    expect(store.get('doc1')).toEqual({ a: 99, b: 3 });\n  });\n\n  it('same change on both sides: no conflict', () => {\n    store.create('doc1', { a: 1 });\n    store.createBranch('feature');\n    store.switchBranch('feature');\n    store.update('doc1', { a: 2 });\n    store.switchBranch('main');\n    store.update('doc1', { a: 2 });\n    const result = store.merge('feature');\n    expect(result.applied).toBe(true);\n    expect(result.conflicts).toHaveLength(0);\n    expect(store.get('doc1')).toEqual({ a: 2 });\n  });\n\n  it('conflicting changes on same field', () => {\n    store.create('doc1', { a: 1 });\n    store.createBranch('feature');\n    store.switchBranch('feature');\n    store.update('doc1', { a: 2 });\n    store.switchBranch('main');\n    store.update('doc1', { a: 3 });\n    const result = store.merge('feature');\n    expect(result.applied).toBe(false);\n    expect(result.conflicts).toHaveLength(1);\n    expect(result.conflicts[0]).toEqual({\n      documentId: 'doc1',\n      path: 'a',\n      base: 1,\n      ours: 3,\n      theirs: 2,\n    });\n    // Current branch unchanged\n    expect(store.get('doc1')).toEqual({ a: 3 });\n    // merged shows ours-favored result\n    expect(result.merged['doc1']).toEqual({ a: 3 });\n  });\n\n  it('nested object merge', () => {\n    store.create('doc1', { config: { x: 1, y: 2 } });\n    store.createBranch('feature');\n    store.switchBranch('feature');\n    store.update('doc1', { config: { x: 1, y: 3 } });\n    store.switchBranch('main');\n    store.update('doc1', { config: { x: 99, y: 2 } });\n    const result = store.merge('feature');\n    expect(result.applied).toBe(true);\n    expect(result.merged['doc1']).toEqual({ config: { x: 99, y: 3 } });\n  });\n\n  it('new document on source branch is brought in', () => {\n    store.createBranch('feature');\n    store.switchBranch('feature');\n    store.create('doc1', { a: 1 });\n    store.switchBranch('main');\n    const result = store.merge('feature');\n    expect(result.applied).toBe(true);\n    expect(store.get('doc1')).toEqual({ a: 1 });\n  });\n\n  it('document deleted on source, unchanged on target: apply delete', () => {\n    store.create('doc1', { a: 1 });\n    store.createBranch('feature');\n    store.switchBranch('feature');\n    store.delete('doc1');\n    store.switchBranch('main');\n    const result = store.merge('feature');\n    expect(result.applied).toBe(true);\n    expect(() => store.get('doc1')).toThrow();\n  });\n\n  it('document deleted on source, modified on target: conflict', () => {\n    store.create('doc1', { a: 1 });\n    store.createBranch('feature');\n    store.switchBranch('feature');\n    store.delete('doc1');\n    store.switchBranch('main');\n    store.update('doc1', { a: 2 });\n    const result = store.merge('feature');\n    expect(result.applied).toBe(false);\n    expect(result.conflicts.length).toBeGreaterThan(0);\n    // Current branch unchanged\n    expect(store.get('doc1')).toEqual({ a: 2 });\n  });\n\n  it('independent documents on different branches merge cleanly', () => {\n    store.createBranch('feature');\n    store.switchBranch('feature');\n    store.create('doc-feature', { f: 1 });\n    store.switchBranch('main');\n    store.create('doc-main', { m: 1 });\n    const result = store.merge('feature');\n    expect(result.applied).toBe(true);\n    expect(store.get('doc-feature')).toEqual({ f: 1 });\n    expect(store.get('doc-main')).toEqual({ m: 1 });\n  });\n\n  it('merge throws if source branch does not exist', () => {\n    expect(() => store.merge('nonexistent')).toThrow();\n  });\n\n  it('conflict path uses dot notation for nested fields', () => {\n    store.create('doc1', { a: { b: { c: 1 } } });\n    store.createBranch('feature');\n    store.switchBranch('feature');\n    store.update('doc1', { a: { b: { c: 2 } } });\n    store.switchBranch('main');\n    store.update('doc1', { a: { b: { c: 3 } } });\n    const result = store.merge('feature');\n    expect(result.applied).toBe(false);\n    expect(result.conflicts[0].path).toBe('a.b.c');\n  });\n});\n```\n\n**Step 2: Implement merge method in `src/store.ts`**\n\nReplace the merge stub. Import `mergeDocument` from `./merge.js`. The merge method:\n\n1. Validates source branch exists.\n2. Gets source branch state. Gets fork base from source branch.\n3. Collects all document IDs across forkBase, current docs, and source docs.\n4. For each document ID, calls `mergeDocument` with base/ours/theirs.\n5. Builds `MergeResult`.\n6. If no conflicts, applies merged state to current branch.\n\n```typescript\n// Add to imports at top of store.ts:\nimport { mergeDocument } from './merge.js';\n\n// Replace merge stub:\nmerge(sourceBranch: string): MergeResult {\n  const source = this.branches.get(sourceBranch);\n  if (!source) {\n    throw new Error(`Branch \"${sourceBranch}\" does not exist`);\n  }\n  const target = this.getBranchState();\n  const forkBase = source.forkBase;\n\n  // Collect all document IDs\n  const allDocIds = new Set<string>();\n  for (const id of forkBase.keys()) allDocIds.add(id);\n  for (const id of target.documents.keys()) allDocIds.add(id);\n  for (const id of source.documents.keys()) allDocIds.add(id);\n\n  const merged: Record<string, object> = {};\n  const allConflicts: Conflict[] = [];\n  const mergedStates: { id: string; content: object | null }[] = [];\n\n  for (const docId of allDocIds) {\n    const baseContent = forkBase.has(docId) ? forkBase.get(docId)! : null;\n    const targetDoc = target.documents.get(docId);\n    const sourceDoc = source.documents.get(docId);\n    const oursContent = (targetDoc && !targetDoc.deleted) ? targetDoc.content : null;\n    const theirsContent = (sourceDoc && !sourceDoc.deleted) ? sourceDoc.content : null;\n\n    const result = mergeDocument({\n      documentId: docId,\n      base: baseContent,\n      ours: oursContent,\n      theirs: theirsContent,\n    });\n\n    allConflicts.push(...result.conflicts);\n    if (result.content !== null) {\n      merged[docId] = result.content;\n    }\n    mergedStates.push({ id: docId, content: result.content });\n  }\n\n  const applied = allConflicts.length === 0;\n\n  if (applied) {\n    // Apply merged state to current branch\n    for (const { id, content } of mergedStates) {\n      if (content === null) {\n        // Document should be deleted/absent\n        const existing = target.documents.get(id);\n        if (existing) {\n          existing.deleted = true;\n        }\n      } else {\n        const existing = target.documents.get(id);\n        if (existing && !existing.deleted) {\n          // Update existing document\n          const version: Version = {\n            id: this.nextVersionId(),\n            timestamp: Date.now(),\n            content: structuredClone(content),\n          };\n          existing.content = structuredClone(content);\n          existing.versions.push(version);\n        } else {\n          // New document (from source branch)\n          const version: Version = {\n            id: this.nextVersionId(),\n            timestamp: Date.now(),\n            content: structuredClone(content),\n          };\n          target.documents.set(id, {\n            content: structuredClone(content),\n            versions: [version],\n            deleted: false,\n          });\n        }\n      }\n    }\n  }\n\n  return { merged, conflicts: allConflicts, applied };\n}\n```\n\n**Step 3: Run all tests**\n\nRun: `npx vitest run`\nExpected: All tests PASS.\n\n**Step 4: Commit**\n\n```bash\ngit add src/\ngit commit -m \"feat: implement three-way merge with tests\"\n```\n\n---\n\n### Task 7: Final 