+export interface Version {
+  id: string;
+  timestamp: number;
+  content: object;
+}
+
+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+export interface Conflict {
+  documentId: string;
+  path: string;
+  base: any;
+  ours: any;
+  theirs: any;
+}
+
+export interface DocState {
+  content: object;
+  versions: Version[];
+  deleted: boolean;
+}
+
+export interface BranchState {
+  documents: Map<string, DocState>;
+  forkBase: Map<string, object | null>;
+  parentBranch: string | null;
+}
+```
