+import { describe, it, expect, beforeEach } from 'vitest';
+import { DocumentStore } from '../index.js';
+
+describe('DocumentStore CRUD', () => {
+  let store: DocumentStore;
+
+  beforeEach(() => {
+    store = new DocumentStore();
+  });
+
+  it('create and get a document', () => {
+    store.create('doc1', { name: 'Alice', age: 30 });
+    const doc = store.get('doc1');
+    expect(doc).toEqual({ name: 'Alice', age: 30 });
+  });
+
+  it('get returns a deep clone (mutation-safe)', () => {
+    store.create('doc1', { nested: { value: 1 } });
+    const doc = store.get('doc1') as { nested: { value: number } };
+    doc.nested.value = 999;
+    expect((store.get('doc1') as { nested: { value: number } }).nested.value).toBe(1);
+  });
+
+  it('create stores a deep clone (mutation-safe)', () => {
+    const original = { nested: { value: 1 } };
+    store.create('doc1', original);
+    original.nested.value = 999;
+    expect((store.get('doc1') as { nested: { value: number } }).nested.value).toBe(1);
+  });
+
+  it('create throws if ID already exists', () => {
+    store.create('doc1', { a: 1 });
+    expect(() => store.create('doc1', { a: 2 })).toThrow();
+  });
+
+  it('get throws if document does not exist', () => {
+    expect(() => store.get('nonexistent')).toThrow();
+  });
+
+  it('update replaces content', () => {
+    store.create('doc1', { a: 1 });
+    store.update('doc1', { a: 2, b: 3 });
+    expect(store.get('doc1')).toEqual({ a: 2, b: 3 });
+  });
+
+  it('update throws if document does not exist', () => {
+    expect(() => store.update('nonexistent', { a: 1 })).toThrow();
+  });
+
+  it('delete removes a document', () => {
+    store.create('doc1', { a: 1 });
+    store.delete('doc1');
+    expect(() => store.get('doc1')).toThrow();
+  });
+
+  it('delete throws if document does not exist', () => {
+    expect(() => store.delete('nonexistent')).toThrow();
+  });
+
+  it('delete throws if document already deleted', () => {
+    store.create('doc1', { a: 1 });
+    store.delete('doc1');
+    expect(() => store.delete('doc1')).toThrow();
+  });
+
+  it('update throws on deleted document', () => {
+    store.create('doc1', { a: 1 });
+    store.delete('doc1');
+    expect(() => store.update('doc1', { a: 2 })).toThrow();
+  });
+});
