r is created', async () => {\n    inventoryService.setStock('SKU-1', 10);\n    await orderService.createOrder('O1', 'C1', [\n      { productId: 'SKU-1', quantity: 3, unitPrice: 10 },\n    ]);\n    const stock = inventoryService.getStock('SKU-1');\n    expect(stock?.available).toBe(7);\n    expect(stock?.reserved).toBe(3);\n  });\n\n  it('cancels a confirmed order', async () => {\n    inventoryService.setStock('SKU-1', 10);\n    await orderService.createOrder('O1', 'C1', [\n      { productId: 'SKU-1', quantity: 2, unitPrice: 10 },\n    ]);\n    const cancelled = await orderService.cancelOrder('O1', 'changed mind');\n    expect(cancelled?.status).toBe('cancelled');\n  });\n\n  it('releases stock when order is cancelled', async () => {\n    inventoryService.setStock('SKU-1', 10);\n    await orderService.createOrder('O1', 'C1', [\n      { productId: 'SKU-1', quantity: 4, unitPrice: 10 },\n    ]);\n    await orderService.cancelOrder('O1', 'changed mind');\n    const stock = inventoryService.getStock('SKU-1');\n    expect(stock?.available).toBe(10);\n    expect(stock?.reserved).toBe(0);\n  });\n\n  it('refuses to cancel a non-confirmed order', async () => {\n    inventoryService.setStock('SKU-1', 10);\n    await orderService.createOrder('O1', 'C1', [\n      { productId: 'SKU-1', quantity: 1, unitPrice: 10 },\n    ]);\n    await orderService.cancelOrder('O1', 'first cancel');\n    // Try to cancel again — already cancelled\n    const result = await orderService.cancelOrder('O1', 'second cancel');\n    expect(result).toBeUndefined();\n  });\n\n  it('refunds a cancelled order within 30 days', async () => {\n    inventoryService.setStock('SKU-1', 10);\n    await orderService.createOrder('O1', 'C1', [\n      { productId: 'SKU-1', quantity: 1, unitPrice: 100 },\n    ]);\n    await orderService.cancelOrder('O1', 'not needed');\n    const refunded = await orderService.refundOrder('O1');\n    expect(refunded?.status).toBe('refunded');\n  });\n\n  it('allows refund on exactly day 3