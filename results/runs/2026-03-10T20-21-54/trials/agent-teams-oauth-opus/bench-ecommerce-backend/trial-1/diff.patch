+import { describe, it, expect, beforeEach } from 'vitest';
+import { EventBus } from '../src/bus.js';
+import {
+  createCatalogService,
+  createInventoryService,
+  createCartService,
+  createPricingService,
+  createOrderService,
+  createPaymentService,
+  createNotificationService,
+  createAnalyticsService,
+} from '../src/index.js';
+import { OrderStatus, PaymentStatus, Events } from '../src/types.js';
+
+let bus: EventBus;
+
+beforeEach(() => {
+  bus = new EventBus();
+});
+
+describe('CatalogService', () => {
+  it('should create and retrieve a product', () => {
+    const catalog = createCatalogService(bus);
+    const id = catalog.createProduct('Widget', 9.99, 'gadgets');
+    expect(id).toBeTruthy();
+    const product = catalog.getProduct(id);
+    expect(product).toEqual({ id, name: 'Widget', price: 9.99, category: 'gadgets' });
+  });
+
+  it('should list products by category', () => {
+    const catalog = createCatalogService(bus);
+    catalog.createProduct('A', 1, 'cat1');
+    catalog.createProduct('B', 2, 'cat2');
+    catalog.createProduct('C', 3, 'cat1');
+    expect(catalog.listProducts('cat1')).toHaveLength(2);
+    expect(catalog.listProducts('cat2')).toHaveLength(1);
+    expect(catalog.listProducts()).toHaveLength(3);
+  });
+
+  it('should search products', () => {
+    const catalog = createCatalogService(bus);
+    catalog.createProduct('Blue Widget', 5, 'gadgets');
+    catalog.createProduct('Red Gizmo', 10, 'gadgets');
+    expect(catalog.searchProducts('widget')).toHaveLength(1);
+    expect(catalog.searchProducts('gadgets')).toHaveLength(2);
+  });
+
+  it('should update and remove products', () => {
+    const catalog = createCatalogService(bus);
+    const id = catalog.createProduct('Widget', 5, 'gadgets');
+    catalog.updateProduct(id, { price: 7 });
+    expect(catalog.getProduct(id)!.price).toBe(7);
+    expect(catalog.removeProduct(id)).toBe(true);
+    expect(catalog.getProduct(id)).toBeNull();
+  });
+
+  it('should emit product:created event', async () => {
+    const catalog = createCatalogService(bus);
+    catalog.createProduct('Widget', 9.99, 'gadgets');
+    const log = bus.getLog();
+    expect(log.some(e => e.event === Events.PRODUCT_CREATED)).toBe(true);
+  });
+});
+
+describe('InventoryService', () => {
+  it('should set and get stock', () => {
+    const inv = createInventoryService(bus);
+    inv.setStock('p1', 100);
+    expect(inv.getStock('p1')).toBe(100);
+  });
+
+  it('should reserve and release stock', () => {
+    const inv = createInventoryService(bus);
+    inv.setStock('p1', 10);
+    expect(inv.reserve('p1', 5)).toBe(true);
+    expect(inv.getStock('p1')).toBe(5);
+    expect(inv.reserve('p1', 6)).toBe(false);
+    inv.release('p1', 3);
+    expect(inv.getStock('p1')).toBe(8);
+  });
+
+  it('should emit low stock alert', async () => {
+    const inv = createInventoryService(bus);
+    inv.setStock('p1', 10);
+    inv.setLowStockThreshold('p1', 5);
+    inv.setStock('p1', 3);
+    const log = bus.getLog();
+    expect(log.some(e => e.event === Events.LOW_STOCK_ALERT)).toBe(true);
+  });
+});
+
+describe('CartService', () => {
+  it('should create cart and add items', () => {
+    const cart = createCartService(bus);
+    const id = cart.createCart('user1');
+    cart.addItem(id, 'p1', 2);
+    cart.addItem(id, 'p2', 1);
+    const c = cart.getCart(id);
+    expect(c!.items).toHaveLength(2);
+    expect(c!.userId).toBe('user1');
+  });
+
+  it('should consolidate same product additions', () => {
+    const cart = createCartService(bus);
+    const id = cart.createCart('user1');
+    cart.addItem(id, 'p1', 2);
+    cart.addItem(id, 'p1', 3);
+    const c = cart.getCart(id);
+    expect(c!.items).toHaveLength(1);
+    expect(c!.items[0].quantity).toBe(5);
+  });
+
+  it('should remove items and clear cart', () => {
+    const cart = createCartService(bus);
+    const id = cart.createCart('user1');
+    cart.addItem(id, 'p1', 2);
+    cart.addItem(id, 'p2', 1);
+    cart.removeItem(id, 'p1');
+    expect(cart.getCart(id)!.items).toHaveLength(1);
+    cart.clearCart(id);
+    expect(cart.getCart(id)!.items).toHaveLength(0);
+  });
+
+  it('should update quantity', () => {
+    const cart = createCartService(bus);
+    const id = cart.createCart('user1');
+    cart.addItem(id, 'p1', 2);
+    cart.updateQuantity(id, 'p1', 5);
+    expect(cart.getCart(id)!.items[0].quantity).toBe(5);
+  });
+
+  it('should return null for non-existent cart', () => {
+    const cart = createCartService(bus);
+    expect(cart.getCart('fake')).toBeNull();
+  });
+});
+
+describe('PricingService', () => {
+  it('should calculate total with tax', () => {
+    const pricing = createPricingService(bus);
+    const result = pricing.calculateTotal([
+      { productId: 'p1', quantity: 2, price: 10 },
+    ]);
+    expect(result.subtotal).toBe(20);
+    expect(result.tax).toBe(2);
+    expect(result.total).toBe(22);
+    expect(result.discount).toBe(0);
+  });
+
+  it('should apply discount code', () => {
+    const pricing = createPricingService(bus);
+    pricing.addDiscountCode('SAVE10', 10);
+    const result = pricing.calculateTotal(
+      [{ productId: 'p1', quantity: 1, price: 100 }],
+      'SAVE10'
+    );
+    expect(result.subtotal).toBe(100);
+    expect(result.discount).toBe(10);
+    expect(result.tax).toBe(9); // (100-10) * 0.1
+    expect(result.total).toBe(99); // 90 + 9
+  });
+
+  it('should track prices from product:created events', () => {
+    const pricing = createPricingService(bus);
+    const catalog = createCatalogService(bus);
+    const id = catalog.createProduct('Widget', 15, 'gadgets');
+    expect(pricing.getPrice(id)).toBe(15);
+  });
+});
+
+describe('OrderService', () => {
+  it('should create and retrieve an order', () => {
+    const orders = createOrderService(bus);
+    const id = orders.createOrder('user1', 'cart1', 50);
+    const order = orders.getOrder(id);
+    expect(order).toBeTruthy();
+    expect(order!.status).toBe(OrderStatus.PENDING);
+    expect(order!.total).toBe(50);
+    expect(order!.userId).toBe('user1');
+  });
+
+  it('should update order status', () => {
+    const orders = createOrderService(bus);
+    const id = orders.createOrder('user1', 'cart1', 50);
+    orders.updateStatus(id, OrderStatus.CONFIRMED);
+    expect(orders.getOrder(id)!.status).toBe(OrderStatus.CONFIRMED);
+  });
+
+  it('should emit events with previous status', () => {
+    const orders = createOrderService(bus);
+    const id = orders.createOrder('user1', 'cart1', 50);
+    orders.updateStatus(id, OrderStatus.CONFIRMED);
+    const log = bus.getLog();
+    const statusEvent = log.find(e => e.event === Events.ORDER_STATUS_CHANGED);
+    expect(statusEvent).toBeTruthy();
+    const payload = statusEvent!.payload as { previousStatus: string; status: string };
+    expect(payload.previousStatus).toBe(OrderStatus.PENDING);
+    expect(payload.status).toBe(OrderStatus.CONFIRMED);
+  });
+
+  it('should list orders for a user', () => {
+    const orders = createOrderService(bus);
+    orders.createOrder('user1', 'c1', 10);
+    orders.createOrder('user2', 'c2', 20);
+    orders.createOrder('user1', 'c3', 30);
+    expect(orders.listOrders('user1')).toHaveLength(2);
+    expect(orders.listOrders('user2')).toHaveLength(1);
+  });
+
+  it('should support cancellation', () => {
+    const orders = createOrderService(bus);
+    const id = orders.createOrder('user1', 'cart1', 50);
+    orders.updateStatus(id, OrderStatus.CANCELLED);
+    expect(orders.getOrder(id)!.status).toBe(OrderStatus.CANCELLED);
+  });
+});
+
+describe('PaymentService', () => {
+  it('should process payment successfully', async () => {
+    const payment = createPaymentService(bus);
+    const result = await payment.processPayment('order1', 50);
+    expect(result.status).toBe(PaymentStatus.SUCCESS);
+    expect(result.transactionId).toBeTruthy();
+  });
+
+  it('should simulate failure', async () => {
+    const payment = createPaymentService(bus, { simulateFailure: true });
+    const result = await payment.processPayment('order1', 50);
+    expect(result.status).toBe(PaymentStatus.FAILED);
+    expect(result.error).toBeTruthy();
+  });
+
+  it('should simulate timeout', async () => {
+    const payment = createPaymentService(bus, { simulateTimeout: true });
+    const result = await payment.processPayment('order1', 50);
+    expect(result.status).toBe(PaymentStatus.TIMEOUT);
+  });
+
+  it('should refund a successful payment', async () => {
+    const payment = createPaymentService(bus);
+    const result = await payment.processPayment('order1', 50);
+    const refunded = await payment.refund(result.transactionId!);
+    expect(refunded).toBe(true);
+  });
+
+  it('should not refund non-existent transaction', async () => {
+    const payment = createPaymentService(bus);
+    const refunded = await payment.refund('fake_txn');
+    expect(refunded).toBe(false);
+  });
+
+  it('should emit payment:processed event', async () => {
+    const payment = createPaymentService(bus);
+    await payment.processPayment('order1', 50);
+    const log = bus.getLog();
+    expect(log.some(e => e.event === Events.PAYMENT_PROCESSED)).toBe(true);
+  });
+});
+
+describe('NotificationService', () => {
+  it('should deliver notifications to subscribed users', async () => {
+    const notifications = createNotificationService(bus);
+    const orders = createOrderService(bus);
+
+    notifications.subscribe('user1');
+    const orderId = orders.createOrder('user1', 'cart1', 50);
+    orders.updateStatus(orderId, OrderStatus.CONFIRMED);
+
+    const userNotifs = notifications.getNotifications('user1');
+    expect(userNotifs.length).toBeGreaterThan(0);
+    expect(userNotifs.some(n => n.type === 'order_status')).toBe(true);
+  });
+
+  it('should not deliver to unsubscribed users', () => {
+    const notifications = createNotificationService(bus);
+    const orders = createOrderService(bus);
+
+    const orderId = orders.createOrder('user1', 'cart1', 50);
+    orders.updateStatus(orderId, OrderStatus.CONFIRMED);
+
+    expect(notifications.getNotifications('user1')).toHaveLength(0);
+  });
+
+  it('should deliver payment notifications', async () => {
+    const notifications = createNotificationService(bus);
+    const orders = createOrderService(bus);
+    const payment = createPaymentService(bus);
+
+    notifications.subscribe('user1');
+    const orderId = orders.createOrder('user1', 'cart1', 50);
+    await payment.processPayment(orderId, 50);
+
+    const userNotifs = notifications.getNotifications('user1');
+    expect(userNotifs.some(n => n.type === 'payment')).toBe(true);
+  });
+});
+
+describe('AnalyticsService', () => {
+  it('should count events', () => {
+    const analytics = createAnalyticsService(bus);
+    const catalog = createCatalogService(bus);
+
+    catalog.createProduct('A', 10, 'cat1');
+    catalog.createProduct('B', 20, 'cat1');
+
+    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);
+  });
+
+  it('should calculate conversion rate', () => {
+    const analytics = createAnalyticsService(bus);
+    const cart = createCartService(bus);
+    const orders = createOrderService(bus);
+
+    const c1 = cart.createCart('user1');
+    cart.addItem(c1, 'p1', 1);
+    const c2 = cart.createCart('user2');
+    cart.addItem(c2, 'p2', 1);
+
+    orders.createOrder('user1', c1, 10);
+
+    // 1 order / 2 unique carts = 0.5
+    expect(analytics.getConversionRate()).toBe(0.5);
+  });
+
+  it('should track revenue from successful payments', async () => {
+    const analytics = createAnalyticsService(bus);
+    const payment = createPaymentService(bus);
+
+    // The analytics service listens for payment:processed with amount
+    // We need to emit events with amount info
+    await bus.emit(Events.PAYMENT_PROCESSED, {
+      orderId: 'o1',
+      status: PaymentStatus.SUCCESS,
+      transactionId: 'txn_1',
+      amount: 100,
+    });
+
+    expect(analytics.getRevenue()).toBe(100);
+  });
+});
+
+describe('Integration: Full order flow', () => {
+  it('should handle complete order lifecycle', async () => {
+    const catalog = createCatalogService(bus);
+    const inventory = createInventoryService(bus);
+    const cartSvc = createCartService(bus);
+    const pricing = createPricingService(bus);
+    const orders = createOrderService(bus);
+    const payment = createPaymentService(bus);
+    const notifications = createNotificationService(bus);
+    const analytics = createAnalyticsService(bus);
+
+    // Subscribe user for notifications
+    notifications.subscribe('user1');
+
+    // Create products
+    const p1 = catalog.createProduct('Laptop', 999, 'electronics');
+    const p2 = catalog.createProduct('Mouse', 29, 'accessories');
+
+    // Set inventory
+    inventory.setStock(p1, 10);
+    inventory.setStock(p2, 50);
+
+    // Create cart and add items
+    const cartId = cartSvc.createCart('user1');
+    cartSvc.addItem(cartId, p1, 1);
+    cartSvc.addItem(cartId, p2, 2);
+
+    // Calculate price
+    const cart = cartSvc.getCart(cartId)!;
+    const items = cart.items.map(i => ({
+      productId: i.productId,
+      quantity: i.quantity,
+      price: pricing.getPrice(i.productId),
+    }));
+    const totals = pricing.calculateTotal(items);
+
+    // Reserve inventory
+    expect(inventory.reserve(p1, 1)).toBe(true);
+    expect(inventory.reserve(p2, 2)).toBe(true);
+
+    // Create order
+    const orderId = orders.createOrder('user1', cartId, totals.total);
+    expect(orders.getOrder(orderId)!.status).toBe(OrderStatus.PENDING);
+
+    // Process payment
+    const paymentResult = await payment.processPayment(orderId, totals.total);
+    expect(paymentResult.status).toBe(PaymentStatus.SUCCESS);
+
+    // Update order status
+    orders.updateStatus(orderId, OrderStatus.CONFIRMED);
+    orders.updateStatus(orderId, OrderStatus.SHIPPED);
+    orders.updateStatus(orderId, OrderStatus.DELIVERED);
+
+    expect(orders.getOrder(orderId)!.status).toBe(OrderStatus.DELIVERED);
+
+    // Check notifications
+    const userNotifs = notifications.getNotifications('user1');
+    expect(userNotifs.length).toBeGreaterThan(0);
+
+    // Check analytics
+    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBe(1);
+    expect(analytics.getEventCount(Events.PAYMENT_PROCESSED)).toBe(1);
+  });
+});
