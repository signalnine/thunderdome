new file mode 100644
index 0000000..b888f78
--- /dev/null
+++ b/src/cart/index.ts
@@ -0,0 +1,61 @@
+import { EventBus } from '../bus.js';
+import { CartService, Events, CartUpdatedEvent } from '../types.js';
+
+export function createCartService(bus: EventBus): CartService {
+  const carts = new Map<string, { id: string; userId: string; items: Map<string, number> }>();
+  let nextId = 1;
+
+  function emitCartUpdated(cart: { id: string; userId: string; items: Map<string, number> }): void {
+    const items = Array.from(cart.items.entries()).map(([productId, quantity]) => ({ productId, quantity }));
+    const event: CartUpdatedEvent = { cartId: cart.id, userId: cart.userId, items };
+    void bus.emit(Events.CART_UPDATED, event);
+  }
+
+  return {
+    createCart(userId: string): string {
+      const id = `cart_${nextId++}`;
+      carts.set(id, { id, userId, items: new Map() });
+      return id;
+    },
+
+    addItem(cartId: string, productId: string, quantity: number): void {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+      const current = cart.items.get(productId) ?? 0;
+      cart.items.set(productId, current + quantity);
+      emitCartUpdated(cart);
+    },
+
+    removeItem(cartId: string, productId: string): void {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+      cart.items.delete(productId);
+      emitCartUpdated(cart);
+    },
+
+    getCart(cartId: string) {
+      const cart = carts.get(cartId);
+      if (!cart) return null;
+      const items = Array.from(cart.items.entries()).map(([productId, quantity]) => ({ productId, quantity }));
+      return { id: cart.id, userId: cart.userId, items };
+    },
+
+    clearCart(cartId: string): void {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+      cart.items.clear();
+      emitCartUpdated(cart);
+    },
+
+    updateQuantity(cartId: string, productId: string, quantity: number): void {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+      if (quantity <= 0) {
+        cart.items.delete(productId);
+      } else {
+        cart.items.set(productId, quantity);
+      }
+      emitCartUpdated(cart);
+    },
+  };
+}
