    const userId = orderUserMap.get(event.orderId);\n    if (userId) {\n      addNotification(userId, 'payment', `Payment for order ${event.orderId}: ${event.status}`);\n    }\n  });\n\n  return {\n    subscribe(userId: string): void {\n      subscriptions.add(userId);\n    },\n\n    getNotifications(userId: string) {\n      return notifications.get(userId) ?? [];\n    },\n  };\n}\n","structuredPatch":[],"originalFile":null},"sourceToolAssistantUUID":"a8c7e50e-7b49-4eef-8101-4a2763ad8977"}
