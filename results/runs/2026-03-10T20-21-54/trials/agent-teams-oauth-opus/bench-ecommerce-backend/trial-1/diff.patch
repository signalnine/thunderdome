;\n    },\n\n    async refund(transactionId: string): Promise<boolean> {\n      const txn = transactions.get(transactionId);\n      if (!txn || txn.status !== PaymentStatus.SUCCESS) return false;\n      txn.status = PaymentStatus.FAILED;\n\n      const event: PaymentProcessedEvent = {\n        orderId: txn.orderId,\n        status: PaymentStatus.FAILED,\n        transactionId,\n        error: 'Refunded',\n      };\n      await bus.emit(Events.PAYMENT_PROCESSED, event);\n\n      return true;\n    },\n  };\n}\n","structuredPatch":[],"originalFile":null},"sourceToolAssistantUUID":"16d70f16-8ef0-45f1-b859-a90fd14f559c"}
