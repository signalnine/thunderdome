@@ -0,0 +1,349 @@
+import type { Event, Room, ScheduleOptions, Assignment, ScheduleResult } from './types.js';
+
+export function schedule(
+  events: Event[],
+  rooms: Room[],
+  options: ScheduleOptions
+): ScheduleResult {
+  const { startTime, endTime, gap = 15 } = options;
+
+  if (events.length === 0) {
+    return { assignments: [], unscheduled: [] };
+  }
+
+  if (rooms.length === 0) {
+    return { assignments: [], unscheduled: events.map(e => e.id) };
+  }
+
+  const eventMap = new Map<string, Event>();
+  for (const event of events) {
+    eventMap.set(event.id, event);
+  }
+
+  detectCycles(events, eventMap);
+
+  const levels = computeLevels(events, eventMap);
+
+  const validRoomsMap = new Map<string, Room[]>();
+  for (const event of events) {
+    const attendees = event.attendees ?? 1;
+    validRoomsMap.set(
+      event.id,
+      rooms.filter(r => r.capacity >= attendees)
+    );
+  }
+
+  const maxLevel = Math.max(...Array.from(levels.values()));
+  const levelGroups: string[][] = [];
+  for (let i = 0; i <= maxLevel; i++) {
+    levelGroups.push([]);
+  }
+  for (const event of events) {
+    levelGroups[levels.get(event.id)!].push(event.id);
+  }
+
+  const orderings = generateOrderings(levelGroups, eventMap, validRoomsMap);
+
+  let bestResult: ScheduleResult | null = null;
+
+  for (const ordering of orderings) {
+    for (const honorPrefs of [true, false]) {
+      const result = greedySchedule(
+        ordering, eventMap, rooms, validRoomsMap, startTime, endTime, gap, honorPrefs
+      );
+      if (!bestResult || result.assignments.length > bestResult.assignments.length) {
+        bestResult = result;
+        if (result.unscheduled.length === 0) break;
+      }
+    }
+    if (bestResult && bestResult.unscheduled.length === 0) break;
+  }
+
+  return bestResult!;
+}
+
+function detectCycles(events: Event[], eventMap: Map<string, Event>): void {
+  const WHITE = 0, GRAY = 1, BLACK = 2;
+  const color = new Map<string, number>();
+
+  for (const event of events) {
+    color.set(event.id, WHITE);
+  }
+
+  function dfs(id: string): void {
+    color.set(id, GRAY);
+    const event = eventMap.get(id);
+    if (event?.prerequisites) {
+      for (const prereqId of event.prerequisites) {
+        if (prereqId === id) {
+          throw new Error(`Prerequisite cycle detected: event "${id}" references itself`);
+        }
+        if (!eventMap.has(prereqId)) continue;
+        const c = color.get(prereqId)!;
+        if (c === GRAY) {
+          throw new Error('Prerequisite cycle detected');
+        }
+        if (c === WHITE) {
+          dfs(prereqId);
+        }
+      }
+    }
+    color.set(id, BLACK);
+  }
+
+  for (const event of events) {
+    if (color.get(event.id) === WHITE) {
+      dfs(event.id);
+    }
+  }
+}
+
+function computeLevels(events: Event[], eventMap: Map<string, Event>): Map<string, number> {
+  const levels = new Map<string, number>();
+
+  function getLevel(id: string): number {
+    if (levels.has(id)) return levels.get(id)!;
+
+    const event = eventMap.get(id);
+    if (!event?.prerequisites || event.prerequisites.length === 0) {
+      levels.set(id, 0);
+      return 0;
+    }
+
+    let maxPrereqLevel = -1;
+    for (const prereqId of event.prerequisites) {
+      if (eventMap.has(prereqId)) {
+        maxPrereqLevel = Math.max(maxPrereqLevel, getLevel(prereqId));
+      }
+    }
+
+    const level = maxPrereqLevel + 1;
+    levels.set(id, level);
+    return level;
+  }
+
+  for (const event of events) {
+    getLevel(event.id);
+  }
+
+  return levels;
+}
+
+function generateOrderings(
+  levelGroups: string[][],
+  eventMap: Map<string, Event>,
+  validRoomsMap: Map<string, Room[]>
+): string[][] {
+  const ordering1 = flattenWithSort(levelGroups, (a, b) => {
+    const da = eventMap.get(a)!.duration;
+    const db = eventMap.get(b)!.duration;
+    if (da !== db) return da - db;
+    const ra = validRoomsMap.get(a)!.length;
+    const rb = validRoomsMap.get(b)!.length;
+    if (ra !== rb) return ra - rb;
+    return a.localeCompare(b);
+  });
+
+  const ordering2 = flattenWithSort(levelGroups, (a, b) => {
+    const ra = validRoomsMap.get(a)!.length;
+    const rb = validRoomsMap.get(b)!.length;
+    if (ra !== rb) return ra - rb;
+    const da = eventMap.get(a)!.duration;
+    const db = eventMap.get(b)!.duration;
+    if (da !== db) return da - db;
+    return a.localeCompare(b);
+  });
+
+  const ordering3 = flattenWithSort(levelGroups, (a, b) => {
+    const aa = eventMap.get(a)!.attendees ?? 1;
+    const ab = eventMap.get(b)!.attendees ?? 1;
+    if (aa !== ab) return ab - aa;
+    const ra = validRoomsMap.get(a)!.length;
+    const rb = validRoomsMap.get(b)!.length;
+    if (ra !== rb) return ra - rb;
+    return a.localeCompare(b);
+  });
+
+  const ordering4 = flattenWithSort(levelGroups, (a, b) => {
+    const da = eventMap.get(a)!.duration;
+    const db = eventMap.get(b)!.duration;
+    if (da !== db) return db - da;
+    const ra = validRoomsMap.get(a)!.length;
+    const rb = validRoomsMap.get(b)!.length;
+    if (ra !== rb) return ra - rb;
+    return a.localeCompare(b);
+  });
+
+  const seen = new Set<string>();
+  const result: string[][] = [];
+  for (const ordering of [ordering1, ordering2, ordering3, ordering4]) {
+    const key = ordering.join(',');
+    if (!seen.has(key)) {
+      seen.add(key);
+      result.push(ordering);
+    }
+  }
+
+  return result;
+}
+
+function flattenWithSort(
+  levelGroups: string[][],
+  compareFn: (a: string, b: string) => number
+): string[] {
+  const result: string[] = [];
+  for (const group of levelGroups) {
+    const sorted = [...group].sort(compareFn);
+    result.push(...sorted);
+  }
+  return result;
+}
+
+function greedySchedule(
+  orderedEventIds: string[],
+  eventMap: Map<string, Event>,
+  rooms: Room[],
+  validRoomsMap: Map<string, Room[]>,
+  startTime: number,
+  endTime: number,
+  gap: number,
+  honorPreferences: boolean = true
+): ScheduleResult {
+  const roomSchedules = new Map<string, Array<{ start: number; end: number }>>();
+  for (const room of rooms) {
+    roomSchedules.set(room.id, []);
+  }
+
+  const eventAssignments = new Map<string, Assignment>();
+  const assignments: Assignment[] = [];
+  const unscheduled: string[] = [];
+
+  for (const eventId of orderedEventIds) {
+    const event = eventMap.get(eventId)!;
+    const duration = event.duration;
+
+    let earliestStart = startTime;
+    let prereqsSatisfied = true;
+
+    if (event.prerequisites) {
+      for (const prereqId of event.prerequisites) {
+        if (!eventMap.has(prereqId)) continue;
+        const prereqAssignment = eventAssignments.get(prereqId);
+        if (!prereqAssignment) {
+          prereqsSatisfied = false;
+          break;
+        }
+        earliestStart = Math.max(earliestStart, prereqAssignment.endTime + gap);
+      }
+    }
+
+    if (!prereqsSatisfied || earliestStart + duration > endTime) {
+      unscheduled.push(eventId);
+      continue;
+    }
+
+    const validRooms = validRoomsMap.get(eventId)!;
+    if (validRooms.length === 0) {
+      unscheduled.push(eventId);
+      continue;
+    }
+
+    const candidateRooms = orderCandidateRooms(
+      validRooms,
+      honorPreferences ? event.preferredRoom : undefined
+    );
+
+    let bestAssignment: Assignment | null = null;
+
+    for (const room of candidateRooms) {
+      const schedule = roomSchedules.get(room.id)!;
+      const slotStart = findEarliestSlot(schedule, earliestStart, duration, gap, endTime);
+
+      if (slotStart !== null) {
+        const assignment: Assignment = {
+          eventId,
+          roomId: room.id,
+          startTime: slotStart,
+          endTime: slotStart + duration,
+        };
+
+        if (honorPreferences && room.id === event.preferredRoom) {
+          bestAssignment = assignment;
+          break;
+        }
+
+        if (
+          !bestAssignment ||
+          slotStart < bestAssignment.startTime ||
+          (slotStart === bestAssignment.startTime &&
+            room.capacity < rooms.find(r => r.id === bestAssignment!.roomId)!.capacity)
+        ) {
+          bestAssignment = assignment;
+        }
+      }
+    }
+
+    if (bestAssignment) {
+      assignments.push(bestAssignment);
+      eventAssignments.set(eventId, bestAssignment);
+      insertIntoSchedule(
+        roomSchedules.get(bestAssignment.roomId)!,
+        bestAssignment.startTime,
+        bestAssignment.endTime
+      );
+    } else {
+      unscheduled.push(eventId);
+    }
+  }
+
+  return { assignments, unscheduled };
+}
+
+function orderCandidateRooms(validRooms: Room[], preferredRoomId?: string): Room[] {
+  const sorted = [...validRooms].sort((a, b) => a.capacity - b.capacity);
+
+  if (!preferredRoomId) return sorted;
+
+  const preferredIdx = sorted.findIndex(r => r.id === preferredRoomId);
+  if (preferredIdx <= 0) return sorted;
+
+  const preferred = sorted.splice(preferredIdx, 1)[0];
+  sorted.unshift(preferred);
+  return sorted;
+}
+
+function findEarliestSlot(
+  schedule: Array<{ start: number; end: number }>,
+  earliestStart: number,
+  duration: number,
+  gap: number,
+  endTime: number
+): number | null {
+  let candidateStart = earliestStart;
+
+  for (const interval of schedule) {
+    if (candidateStart + duration + gap <= interval.start) {
+      break;
+    }
+    candidateStart = Math.max(candidateStart, interval.end + gap);
+  }
+
+  if (candidateStart + duration <= endTime) {
+    return candidateStart;
+  }
+
+  return null;
+}
+
+function insertIntoSchedule(
+  schedule: Array<{ start: number; end: number }>,
+  start: number,
+  end: number
+): void {
+  const idx = schedule.findIndex(s => s.start > start);
+  if (idx === -1) {
+    schedule.push({ start, end });
+  } else {
+    schedule.splice(idx, 0, { start, end });
+  }
+}
