.toEqual(['e1']);\n    });\n\n    it('should schedule multiple events in sequence with gap', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Meeting 1', duration: 60 },\n        { id: 'e2', name: 'Meeting 2', duration: 60 },\n      ];\n      const rooms: Room[] = [\n        { id: 'r1', name: 'Room A', capacity: 10 },\n      ];\n\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(2);\n      expect(result.unscheduled).toHaveLength(0);\n\n      const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n      const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n\n      // Events should not overlap and should have gap\n      const first = a1.startTime < a2.startTime ? a1 : a2;\n      const second = a1.startTime < a2.startTime ? a2 : a1;\n      expect(second.startTime).toBeGreaterThanOrEqual(first.endTime + 15);\n    });\n  });\n\n  describe('capacity constraints', () => {\n    it('should respect room capacity', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Big Meeting', duration: 60, attendees: 50 },\n      ];\n      const rooms: Room[] = [\n        { id: 'r1', name: 'Small Room', capacity: 10 },\n        { id: 'r2', name: 'Big Room', capacity: 100 },\n      ];\n\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('r2');\n    });\n\n    it('should mark event as unscheduled if no room fits', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Huge Meeting', duration: 60, attendees: 200 },\n      ];\n      const rooms: Room[] = [\n        { id: 'r1', name: 'Room A', capacity: 10 },\n        { id: 'r2', name: 'Room B', capacity: 50 },\n      ];\n\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toEqual(['e1']);\n    });\n\n    it('should default attendees to 1', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Solo Meeting', duration: 60 },\n      ];\n      const rooms: Room[] = [\n        { id: 'r1', name: 'Room A', capacity: 1 },\n      ];\n\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(1);\n    });\n  });\n\n  describe('time window constraints', () => {\n    it('should keep events within time window', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Meeting', duration: 60 },\n      ];\n      const rooms: Room[] = [\n        { id: 'r1', name: 'Room A', capacity: 10 },\n      ];\n\n      const result = schedule(events, rooms, { startTime: 540, endTime: 600 });\n\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].startTime).toBeGreaterThanOrEqual(540);\n      expect(result.assignments[0].endTime).toBeLessThanOrEqual(600);\n    });\n\n    it('should not schedule event that exceeds time window', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Long Meeting', duration: 120 },\n      ];\n      const rooms: Room[] = [\n        { id: 'r1', name: 'Room A', capacity: 10 },\n      ];\n\n      const result = schedule(events, rooms, { startTime: 540, endTime: 600 });\n\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toEqual(['e1']);\n    });\n  });\n\n  describe('gap enforcement', () => {\n    it('should enforce gap between events in same room', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Meeting 1', duration: 60 },\n        { id: 'e2', name: 'Meeting 2', duration: 60 },\n      ];\n      const rooms: Room[] = [\n        { id: 'r1', name: 'Room A', capacity: 10 },\n      ];\n\n      const result = schedule(events, rooms, { ...defaultOptions, gap: 30 });\n\n      expect(result.assignments).toHaveLength(2);\n      const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n      const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n      const first = a1.startTime < a2.startTime ? a1 : a2;\n      const second = a1.startTime < a2.startTime ? a2 : a1;\n      expect(second.startTime - first.endTime).toBeGreaterThanOrEqual(30);\n    });\n\n    it('should use default gap of 15 minutes', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Meeting 1', duration: 60 },\n        { id: 'e2', name: 'Meeting 2', duration: 60 },\n      ];\n      const rooms: Room[] = [\n        { id: 'r1', name: 'Room A', capacity: 10 },\n      ];\n\n      const result = schedule(events, rooms, { startTime: 540, endTime: 1020 });\n\n      expect(result.assignments).toHaveLength(2);\n      const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n      const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n      const first = a1.startTime < a2.startTime ? a1 : a2;\n      const second = a1.startTime < a2.startTime ? a2 : a1;\n      expect(second.startTime - first.endTime).toBeGreaterThanOrEqual(15);\n    });\n\n    it('should handle gap of 0', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Meeting 1', duration: 60 },\n        { id: 'e2', name: 'Meeting 2', duration: 60 },\n      ];\n      const rooms: Room[] = [\n        { id: 'r1', name: 'Room A', capacity: 10 },\n      ];\n\n      const result = schedule(events, rooms, { startTime: 540, endTime: 660, gap: 0 });\n\n      expect(result.assignments).toHaveLength(2);\n      const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n      const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n      expect(\n        Math.max(a1.startTime, a2.startTime)\n      ).toBeGreaterThanOrEqual(\n        Math.min(a1.endTime, a2.endTime)\n      );\n    });\n  });\n\n  describe('prerequisite ordering', () => {\n    it('should schedule prerequisites before dependents', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Intro', duration: 60 },\n        { 