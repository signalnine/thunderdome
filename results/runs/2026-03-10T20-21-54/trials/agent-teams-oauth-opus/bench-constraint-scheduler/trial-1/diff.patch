h > bestResult.assignments.length) {\n      bestResult = result;\n      if (result.unscheduled.length === 0) break;\n    }\n  }\n\n  return bestResult!;\n}\n\nfunction detectCycles(events: Event[], eventMap: Map<string, Event>): void {\n  const WHITE = 0, GRAY = 1, BLACK = 2;\n  const color = new Map<string, number>();\n\n  for (const event of events) {\n    color.set(event.id, WHITE);\n  }\n\n  function dfs(id: string): void {\n    color.set(id, GRAY);\n    const event = eventMap.get(id);\n    if (event?.prerequisites) {\n      for (const prereqId of event.prerequisites) {\n        if (prereqId === id) {\n          throw new Error(`Prerequisite cycle detected: event \"${id}\" references itself`);\n        }\n        if (!eventMap.has(prereqId)) continue;\n        const c = color.get(prereqId)!;\n        if (c === GRAY) {\n          throw new Error('Prerequisite cycle detected');\n        }\n        if (c === WHITE) {\n          dfs(prereqId);\n        }\n      }\n    }\n    color.set(id, BLACK);\n  }\n\n  for (const event of events) {\n    if (color.get(event.id) === WHITE) {\n      dfs(event.id);\n    }\n  }\n}\n\nfunction computeLevels(events: Event[], eventMap: Map<string, Event>): Map<string, number> {\n  const levels = new Map<string, number>();\n\n  function getLevel(id: string): number {\n    if (levels.has(id)) return levels.get(id)!;\n\n    const event = eventMap.get(id);\n    if (!event?.prerequisites || event.prerequisites.length === 0) {\n      levels.set(id, 0);\n      return 0;\n    }\n\n    let maxPrereqLevel = -1;\n    for (const prereqId of event.prerequisites) {\n      if (eventMap.has(prereqId)) {\n        maxPrereqLevel = Math.max(maxPrereqLevel, getLevel(prereqId));\n      }\n    }\n\n    const level = maxPrereqLevel + 1;\n    levels.set(id, level);\n    return level;\n  }\n\n  for (const event of events) {\n    getLevel(event.id);\n  }\n\n  return levels;\n}\n\nfunction generateOrderings(\n  levelGroups: string[][],\n  eventMap: Map<string, Event>,\n  validRoomsMap: Map<string, Room[]>\n): string[][] {\n  const ordering1 = flattenWithSort(levelGroups, (a, b) => {\n    const da = eventMap.get(a)!.duration;\n    const db = eventMap.get(b)!.duration;\n    if (da !== db) return da - db;\n    const ra = validRoomsMap.get(a)!.length;\n    const rb = validRoomsMap.get(b)!.length;\n    if (ra !== rb) return ra - rb;\n    return a.localeCompare(b);\n  });\n\n  const ordering2 = flattenWithSort(levelGroups, (a, b) => {\n    const ra = validRoomsMap.get(a)!.length;\n    const rb = validRoomsMap.get(b)!.length;\n    if (ra !== rb) return ra - rb;\n    const da = eventMap.get(a)!.duration;\n    const db = eventMap.get(b)!.duration;\n    if (da !== db) return da - db;\n    return a.localeCompare(b);\n  });\n\n  const ordering3 = flattenWithSort(levelGroups, (a, b) => {\n    const aa = eventMap.get(a)!.attendees ?? 1;\n    const ab = eventMap.get(b)!.attendees ?? 1;\n    if (aa !== ab) return ab - aa;\n    const ra = validRoomsMap.get(a)!.length;\n    const rb = validRoomsMap.get(b)!.length;\n    if (ra !== rb) return ra - rb;\n    return a.localeCompare(b);\n  });\n\n  const ordering4 = flattenWithSort(levelGroups, (a, b) => {\n    const da = eventMap.get(a)!.duration;\n    const db = eventMap.get(b)!.duration;\n    if (da !== db) return db - da;\n    const ra = validRoomsMap.get(a)!.length;\n    const rb = validRoomsMap.get(b)!.length;\n    if (ra !== rb) return ra - rb;\n    return a.localeCompare(b);\n  });\n\n  const seen = new Set<string>();\n  const result: string[][] = [];\n  for (const ordering of [ordering1, ordering2, ordering3, ordering4]) {\n    const key = ordering.join(',');\n    if (!seen.has(key)) {\n      seen.add(key);\n      result.push(ordering);\n    }\n  }\n\n  return result;\n}\n\nfunction flattenWithSort(\n  levelGroups: string[][],\n  compareFn: (a: string, b: string) => number\n): string[] {\n  const result: string[] = [];\n  for (const group of levelGroups) {\n    const sorted = [...group].s