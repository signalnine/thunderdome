t seen = new Set<string>();\n  const result: string[][] = [];\n  for (const ordering of [ordering1, ordering2, ordering3, ordering4]) {\n    const key = ordering.join(',');\n    if (!seen.has(key)) {\n      seen.add(key);\n      result.push(ordering);\n    }\n  }\n\n  return result;\n}\n\nfunction flattenWithSort(\n  levelGroups: string[][],\n  compareFn: (a: string, b: string) => number\n): string[] {\n  const result: string[] = [];\n  for (const group of levelGroups) {\n    const sorted = [...group].sort(compareFn);\n    result.push(...sorted);\n  }\n  return result;\n}\n\nfunction greedySchedule(\n  orderedEventIds: string[],\n  eventMap: Map<string, Event>,\n  rooms: Room[],\n  validRoomsMap: Map<string, Room[]>,\n  startTime: number,\n  endTime: number,\n  gap: number,\n  honorPreferences: boolean = true\n): ScheduleResult {\n  const roomSchedules = new Map<string, Array<{ start: number; end: number }>>();\n  for (const room of rooms) {\n    roomSchedules.set(room.id, []);\n  }\n\n  const eventAssignments = new Map<string, Assignment>();\n  const assignments: Assignment[] = [];\n  const unscheduled: string[] = [];\n\n  for (const eventId of orderedEventIds) {\n    const event = eventMap.get(eventId)!;\n    const duration = event.duration;\n\n    let earliestStart = startTime;\n    let prereqsSatisfied = true;\n\n    if (event.prerequisites) {\n      for (const prereqId of event.prerequisites) {\n        if (!eventMap.has(prereqId)) continue;\n        const prereqAssignment = eventAssignments.get(prereqId);\n        if (!prereqAssignment) {\n          prereqsSatisfied = false;\n          break;\n        }\n        earliestStart = Math.max(earliestStart, prereqAssignment.endTime + gap);\n      }\n    }\n\n    if (!prereqsSatisfied || earliestStart + duration > endTime) {\n      unscheduled.push(eventId);\n      continue;\n    }\n\n    const validRooms = validRoomsMap.get(eventId)!;\n    if (validRooms.length === 0) {\n      unscheduled.push(eventId);\n      continue;\n    }\n\n    const candidateRooms = orderCandidateRooms(\n      validRooms,\n      honorPreferences ? event.preferredRoom : undefined\n    );\n\n    let bestAssignment: Assignment | null = null;\n\n    for (const room of candidateRooms) {\n      const schedule = roomSchedules.get(room.id)!;\n      const slotStart = findEarliestSlot(schedule, earliestStart, duration, gap, endTime);\n\n      if (slotStart !== null) {\n        const assignment: Assignment = {\n          eventId,\n          roomId: room.id,\n          startTime: slotStart,\n          endTime: slotStart + duration,\n        };\n\n        if (honorPreferences && room.id === event.preferredRoom) {\n          bestAssignment = assignment;\n          break;\n        }\n\n        if (\n          !bestAssignment ||\n          slotStart < bestAssignment.startTime ||\n          (slotStart === bestAssignment.startTime &&\n            room.capacity < rooms.find(r => r.id === bestAssignment!.roomId)!.capacity)\n        ) {\n          bestAssignment = assignment;\n        }\n      }\n    }\n\n    if (bestAssignment) {\n      assignments.push(bestAssignment);\n      eventAssignments.set(eventId, bestAssignment);\n      insertIntoSchedule(\n        roomSchedules.get(bestAssignment.roomId)!,\n        bestAssignment.startTime,\n        bestAssignment.endTime\n      );\n    } else {\n      unscheduled.push(eventId);\n    }\n  }\n\n  return { assignments, unscheduled };\n}\n\nfunction orderCandidateRooms(validRooms: Room[], preferredRoomId?: string): Room[] {\n  const sorted = [...validRooms].sort((a, b) => a.capacity - b.capacity);\n\n  if (!preferredRoomId) return sorted;\n\n  const preferredIdx = sorted.findIndex(r => r.id === preferredRoomId);\n  if (preferredIdx <= 0) return sorted;\n\n  const preferred = sorted.splice(preferredIdx, 1)[0];\n  sorted.unshift(preferred);\n  return sorted;\n}\n\nfunction findEarliestSlot(\n  schedule: Array<{ start: number; end: number }>,\n  earliestStart: number,\n  duration: number,\n  gap: number,\n  endTime: number\n): number | null {\n  let candidateStart = earliestStart;\n\n  for (const interval of schedule) {\n    if (candidateStart + duration + gap <= interval.start) {\n      break;\n    }\n    candidateStart = Math.max(candidateStart, interval.end + gap);\n  }\n\n  if (candidateStart + duration <= endTime) {\n    return candidateStart;\n  }\n\n  return null;\n}\n\nfunction insertIntoSchedule(\n  schedule: Array<{ start: number; end: number }>,\n  start: number,\n  end: number\n): void {\n  const idx = schedule.findIndex(s => s.start > start);\n  if (idx === -1) {\n    schedule.push({ start, end });\n  } else {\n    schedule.splice(idx, 0, { start, end });\n  }\n}\n","numLines":350,"startLine":1,"totalLines":350}},"sourceToolAssistantUUID":"563dde34-9653-40e0-b483-b141c0d24226"}
