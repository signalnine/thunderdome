+  const trimmed = q.trim();
+  if (trimmed.startsWith('"') && trimmed.endsWith('"') && trimmed.length > 2) {
+    const inner = trimmed.slice(1, -1).replace(/[^\w\s]/g, ' ').trim();
+    if (!inner) return '';
+    return `"${inner}"`;
+  }
+  return trimmed.replace(/[^\w\s]/g, ' ').replace(/\s+/g, ' ').trim();
+}
