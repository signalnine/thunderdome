th same DB","       const app2 = createApp(dbPath);","       const port2 = await app2.start(0);","       const url2 = `http://localhost:${port2}`;"]}],"originalFile":"import { describe, it, expect, beforeEach, afterEach } from \"vitest\";\nimport { createApp, type AppInstance } from \"../server.js\";\nimport WebSocket from \"ws\";\n\nlet app: AppInstance;\nlet port: number;\nlet baseUrl: string;\n\nbeforeEach(async () => {\n  app = createApp();\n  port = await app.start(0);\n  baseUrl = `http://localhost:${port}`;\n});\n\nafterEach(async () => {\n  await app.stop();\n});\n\nfunction connectWs(docId: string): Promise<WebSocket> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/${docId}`);\n    ws.on(\"open\", () => resolve(ws));\n    ws.on(\"error\", reject);\n  });\n}\n\nfunction waitForMessage(ws: WebSocket): Promise<Record<string, unknown>> {\n  return new Promise((resolve) => {\n    ws.once(\"message\", (data) => {\n      resolve(JSON.parse(data.toString()));\n    });\n  });\n}\n\nfunction sendOp(\n  ws: WebSocket,\n  operation: Record<string, unknown>,\n  version: number\n): void {\n  ws.send(JSON.stringify({ type: \"operation\", operation, version }));\n}\n\ndescribe(\"REST API\", () => {\n  it(\"creates a document\", async () => {\n    const res = await fetch(`${baseUrl}/api/documents`, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ title: \"Test Doc\", content: \"Hello\" }),\n    });\n    expect(res.status).toBe(201);\n    const doc = await res.json();\n    expect(doc.title).toBe(\"Test Doc\");\n    expect(doc.content).toBe(\"Hello\");\n    expect(doc.id).toBeTruthy();\n  });\n\n  it(\"lists documents\", async () => {\n    await fetch(`${baseUrl}/api/documents`, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ title: \"Doc 1\" }),\n    });\n    await fetch(`${baseUrl}/api/documents`, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ title: \"Doc 2\" }),\n    });\n\n    const res = await fetch(`${baseUrl}/api/documents`);\n    const docs = await res.json();\n    expect(docs.length).toBe(2);\n  });\n\n  it(\"gets a document by id\", async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ title: \"My Doc\", content: \"Content\" }),\n    });\n    const created = await createRes.json();\n\n    const res = await fetch(`${baseUrl}/api/documents/${created.id}`);\n    expect(res.status).toBe(200);\n    const doc = await res.json();\n    expect(doc.title).toBe(\"My Doc\");\n  });\n\n  it(\"returns 404 for missing document\", async () => {\n    const res = await fetch(`${baseUrl}/api/documents/nonexistent`);\n    expect(res.status).toBe(404);\n  });\n\n  it(\"updates a document\", async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ title: \"Original\" }),\n    });\n    const created = await createRes.json();\n\n    const res = await fetch(`${baseUrl}/api/documents/${created.id}`, {\n      method: \"PUT\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ title: \"Updated\" }),\n    });\n    expect(res.status).toBe(200);\n    const doc = await res.json();\n    expect(doc.title).toBe(\"Updated\");\n  });\n\n  it(\"deletes a document\", async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ title: \"To Delete\" }),\n    });\n    const created = await createRes.json();\n\n    const res = await fetch(`${baseUrl}/api/documents/${created.id}`, {\n      method: \"DELETE\",\n    });\n    expect(res.status).toBe(204);\n\n    const getRes = await fetch(`${baseUrl}/api/documents/${created.id}`);\n    expect(getRes.status).toBe(404);\n  });\n\n  it(\"rejects document creation without title\", async () => {\n    const res = await fetch(`${baseUrl}/api/documents`, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({}),\n    });\n    expect(res.status).toBe(400);\n  });\n\n  it(\"gets version history\", async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ title: \"Versioned\", content: \"v1\" }),\n    });\n    const created = await createRes.json();\n\n    const res = await fetch(\n      `${baseUrl}/api/documents/${created.id}/versions`\n    );\n    expect(res.status).toBe(200);\n    const versions = await res.json();\n    expect(versions.length).toBeGreaterThanOrEqual(1);\n    expect(versions[0].content).toBe(\"v1\");\n  });\n});\n\ndescribe(\"WebSocket collaboration\", () => {\n  it(\"receives sync message on connect\", async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ title: \"WS Test\", content: \"hello\" }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(doc.id);\n    const syncMsg = await waitForMessage(ws);\n\n    expect(syncMsg.type).toBe(\"sync\");\n    expect(syncMsg.content).toBe(\"hello\");\n    expect(syncMsg.version).toBe(1);\n    expect(syncMsg.clientId).toBeTruthy();\n\n    ws.close();\n  });\n\n  it(\"applies an insert operation and broadcasts\", async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ title: \"Collab\", content: \"hello\" }),\n    });\n    const doc = await createRes.json();\n\n    const ws1 = await connectWs(doc.id);\n    const sync1 = await waitForMessage(ws1);\n\n    const ws2 = await connectWs(doc.id);\n    await waitForMessage(ws2); // sync for ws2\n\n    // ws1 sends an insert\n    const broadcastPromise = waitForMessage(ws2);\n    sendOp(ws1, { type: \"insert\", position: 5, text: \" world\" }, sync1.version as number);\n\n    // ws1 gets ack\n    const ack = await waitForMessage(ws1);\n    expect(ack.type).toBe(\"ack\");\n    expect(ack.version).toBe(2);\n\n    // ws2 gets the broadcast\n    const broadcast = await broadcastPromise;\n    expect(broadcast.type).toBe(\"operation\");\n    expect((broadcast.operation as Record<string, unknown>).type).toBe(\"insert\");\n\n    // Verify via REST\n    const getRes = await fetch(`${baseUrl}/api/documents/${doc.id}`);\n    const updated = await getRes.json();\n    expect(updated.content).toBe(\"hello world\");\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"applies a delete operation\", async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ title: \"Delete Test\", content: \"hello world\" }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(doc.id);\n    const sync = await waitForMessage(ws);\n\n    sendOp(ws, { type: \"delete\", position: 5, count: 6 }, sync.version as number);\n\n    const ack = await waitForMessage(ws);\n    expect(ack.type).toBe(\"ack\");\n\n    const getRes = await fetch(`${baseUrl}/api/documents/${doc.id}`);\n    const updated = await getRes.json();\n    expect(updated.content).toBe(\"hello\");\n\n    ws.close();\n  });\n\n  it(\"handles concurrent inserts with OT\", async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ title: \"OT Test\", content: \"abc\" }),\n    });\n    const doc = await createRes.json();\n\n    const ws1 = await connectWs(doc.id);\n    const sync1 = await waitForMessage(ws1);\n\n    const ws2 = await connectWs(doc.id);\n    const sync2 = await waitForMessage(ws2);\n\n    // Both clients see version 1\n    expect(sync1.version).toBe(1);\n    expect(sync2.version).toBe(1);\n\n    // Client 1 inserts \"X\" at position 1 (between 'a' and 'b')\n    sendOp(ws1, { type: \"insert\", position: 1, text: \"X\" }, 1);\n    const ack1 = await waitForMessage(ws1);\n    expect(ack1.type).toBe(\"ack\");\n\n    // Client 2 also inserts \"Y\" at position 2 (between 'b' and 'c')\n    // based on version 1 (doesn't know about X yet)\n    const broadcast1 = await waitForMessage(ws2); // receives op from ws1\n    expect(broadcast1.type).toBe(\"operation\");\n\n    sendOp(ws2, { type: \"insert\", position: 2, text: \"Y\" }, 1);\n    const ack2 = await waitForMessage(ws2);\n    expect(ack2.type).toBe(\"ack\");\n\n    // Check final document content\n    const getRes = await fetch(`${baseUrl}/api/documents/${doc.id}`);\n    const final = await getRes.json();\n\n    // Both X and Y should be present\n    expect(final.content).toContain(\"X\");\n    expect(final.content).toContain(\"Y\");\n    expect(final.content).toContain(\"a\");\n    expect(final.content).toContain(\"b\");\n    expect(final.content).toContain(\"c\");\n    expect(final.content.length).toBe(5); // \"abc\" + \"X\" + \"Y\"\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"rejects invalid operations\", async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ title: \"Error Test\", content: \"hello\" }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(doc.id);\n    await waitForMessage(ws); // sync\n\n    // Send malformed message\n    ws.send(JSON.stringify({ type: \"unknown\" }));\n    const error = await waitForMessage(ws);\n    expect(error.type).toBe(\"error\");\n\n    // Send invalid JSON\n    ws.send(\"not json\");\n    const error2 = await waitForMessage(ws);\n    expect(error2.type).toBe(\"error\");\n\n    ws.close();\n  });\n\n  it(\"handles 10 concurrent clients\", async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ title: \"Concurrent Test\", content: \"\" }),\n    });\n    const doc = await createRes.json();\n\n    const clients: WebSocket[] = [];\n    const versions: number[] = [];\n\n    // Connect 10 clients\n    for (let i = 0; i < 10; i++) {\n      const ws = await connectWs(doc.id);\n      const sync = await waitForMessage(ws);\n      versions.push(sync.version as number);\n      clients.push(ws);\n    }\n\n    // Each client inserts a character sequentially\n    for (let i = 0; i < 10; i++) {\n      sendOp(\n        clients[i],\n        { type: \"insert\", position: i, text: String(i) },\n        versions[i]\n      );\n\n      // Wait for ack\n      const ack = await waitForMessage(clients[i]);\n      expect(ack.type).toBe(\"ack\");\n      versions[i] = ack.version as number;\n\n      // Drain broadcasts from other clients\n      for (let j = 0; j < 10; j++) {\n        if (j !== i) {\n          const msg = await waitForMessage(clients[j]);\n          expect(msg.type).toBe(\"operation\");\n          versions[j] = msg.version as number;\n        }\n      }\n    }\n\n    // Verify final content via REST\n    const getRes = await fetch(`${baseUrl}/api/documents/${doc.id}`);\n    const final = await getRes.json();\n    expect(final.content.length).toBe(10);\n\n    // All digits should be present\n    for (let i = 0; i < 10; i++) {\n      expect(final.content).toContain(String(i));\n    }\n\n    // Close all clients\n    for (const ws of clients) {\n      ws.close();\n    }\n  });\n\n  it(\"returns error for nonexistent document websocket\", async () => {\n    const ws = new WebSocket(\n      `ws://localhost:${port}/ws/documents/nonexistent`\n    );\n    return new Promise<void>((resolve) => {\n      ws.on(\"error\", () => {\n        resolve();\n      });\n      ws.on(\"unexpected-response\", () => {\n        resolve();\n      });\n    });\n  });\n\n  it(\"persists version history through WebSocket edits\", async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ title: \"Version Test\", content: \"start\" }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(doc.id);\n    const sync = await waitForMessage(ws);\n\n    // Make two edits\n    sendOp(ws, { type: \"insert\", position: 5, text: \" middle\" }, sync.version as number);\n    const ack1 = await waitForMessage(ws);\n\n    sendOp(\n      ws,\n      { type: \"insert\", position: 12, text: \" end\" },\n      ack1.version as number\n    );\n    await waitForMessage(ws);\n\n    ws.close();\n\n    // Check version history\n    const versionsRes = await fetch(\n      `${baseUrl}/api/documents/${doc.id}/versions`\n    );\n    const versions = await versionsRes.json();\n    expect(versions.length).toBe(3); // initial + 2 edits\n    expect(versions[0].version).toBe(1);\n    expect(versions[0].content).toBe(\"start\");\n    expect(versions[2].content).toBe(\"start middle end\");\n  });\n});\n\ndescribe(\"Persistence\", () => {\n  it(\"persists documents across server restarts\", async () => {\n    const fs = await import(\"fs\");\n    const os = await import(\"os\");\n    const path = await import(\"path\");\n    const dbPath = path.join(os.tmpdir(), `test-collab-${Date.now()}.db`);\n\n    try {\n      // Create first server and add a document\n      const app1 = createApp(dbPath);\n      const port1 = await app1.start(0);\n      const url1 = `http://localhost:${port1}`;\n\n      const createRes = await fetch(`${url1}/api/documents`, {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ title: \"Persistent\", content: \"saved data\" }),\n      });\n      const created = await createRes.json();\n      await app1.stop();\n\n      // Create second server with same DB\n      const app2 = createApp(dbPath);\n      const port2 = await app2.start(0);\n      const url2 = `http://localhost:${port2}`;\n\n      const getRes = await fetch(`${url2}/api/documents/${created.id}`);\n      expect(getRes.status).toBe(200);\n      const doc = await getRes.json();\n      expect(doc.title).toBe(\"Persistent\");\n      expect(doc.content).toBe(\"saved data\");\n\n      await app2.stop();\n    } finally {\n      try {\n        fs.unlinkSync(dbPath);\n        fs.unlinkSync(dbPath + \"-wal\");\n        fs.unlinkSync(dbPath + \"-shm\");\n      } catch {\n        // ignore cleanup errors\n      }\n    }\n  });\n});\n"},"sourceToolAssistantUUID":"e59c6506-564f-4359-90c0-213d06984d2a"}
