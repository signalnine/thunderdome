@@ -0,0 +1,55 @@
+import express from "express";
+import { createServer, type Server } from "http";
+import { DocumentDB } from "./db.js";
+import { createRouter } from "./routes.js";
+import { CollaborationServer } from "./websocket.js";
+
+export interface AppInstance {
+  app: express.Express;
+  start(port?: number): Promise<number>;
+  stop(): Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db = new DocumentDB(dbPath ?? ":memory:");
+  const app = express();
+  const router = createRouter(db);
+  app.use("/api", router);
+
+  let httpServer: Server | null = null;
+  let collabServer: CollaborationServer | null = null;
+
+  return {
+    app,
+    async start(port?: number): Promise<number> {
+      return new Promise((resolve) => {
+        httpServer = createServer(app);
+        collabServer = new CollaborationServer(httpServer, db);
+
+        httpServer.listen(port ?? 0, () => {
+          const addr = httpServer!.address();
+          const actualPort =
+            typeof addr === "object" && addr ? addr.port : port ?? 0;
+          resolve(actualPort);
+        });
+      });
+    },
+    async stop(): Promise<void> {
+      return new Promise((resolve, reject) => {
+        if (collabServer) {
+          collabServer.closeAll();
+        }
+        if (httpServer) {
+          httpServer.close((err) => {
+            db.close();
+            if (err) reject(err);
+            else resolve();
+          });
+        } else {
+          db.close();
+          resolve();
+        }
+      });
+    },
+  };
+}
