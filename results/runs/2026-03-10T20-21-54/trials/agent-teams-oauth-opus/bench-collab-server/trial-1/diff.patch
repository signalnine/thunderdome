ions = await res.json();\n    expect(versions.length).toBeGreaterThanOrEqual(1);\n    expect(versions[0].content).toBe(\"v1\");\n  });\n});\n\ndescribe(\"WebSocket collaboration\", () => {\n  it(\"receives sync message on connect\", async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ title: \"WS Test\", content: \"hello\" }),\n    });\n    const doc = await createRes.json();\n\n    const client = await createClient(doc.id);\n    const syncMsg = await nextMessage(client);\n\n    expect(syncMsg.type).toBe(\"sync\");\n    expect(syncMsg.content).toBe(\"hello\");\n    expect(syncMsg.version).toBe(1);\n    expect(syncMsg.clientId).toBeTruthy();\n\n    client.ws.close();\n  });\n\n  it(\"applies an insert operation and broadcasts\", async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ title: \"Collab\", content: \"hello\" }),\n    });\n    const doc = await createRes.json();\n\n    const c1 = await createClient(doc.id);\n    const sync1 = await nextMessage(c1);\n\n    const c2 = await createClient(doc.id);\n    await nextMessage(c2); // sync for c2\n\n    // c1 sends an insert\n    sendOp(c1, { type: \"insert\", position: 5, text: \" world\" }, sync1.version as number);\n\n    // c1 gets ack\n    const ack = await nextMessage(c1);\n    expect(ack.type).toBe(\"ack\");\n    expect(ack.version).toBe(2);\n\n    // c2 gets the broadcast\n    const broadcast = await nextMessage(c2);\n    expect(broadcast.type).toBe(\"operation\");\n    expect((broadcast.operation as Record<string, unknown>).type).toBe(\"insert\");\n\n    // Verify via REST\n    const getRes = await fetch(`${baseUrl}/api/documents/${doc.id}`);\n    const updated = await getRes.json();\n    expect(updated.content).toBe(\"hello world\");\n\n    c1.ws.close();\n    c2.ws.close();\n  });\n\n  it(\"applies a delete operation\", async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ title: \"Delete Test\", content: \"hello world\" }),\n    });\n    const doc = await createRes.json();\n\n    const client = await createClient(doc.id);\n    const sync = await nextMessage(client);\n\n    sendOp(client, { type: \"delete\", position: 5, count: 6 }, sync.version as number);\n\n    const ack = await nextMessage(client);\n    expect(ack.type).toBe(\"ack\");\n\n    const getRes = await fetch(`${baseUrl}/api/documents/${doc.id}`);\n    const updated = await getRes.json();\n    expect(updated.content).toBe(\"hello\");\n\n    client.ws.close();\n  });\n\n  it(\"handles concurrent inserts with OT\", async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ title: \"OT Test\", content: \"abc\" }),\n    });\n    const doc = await createRes.json();\n\n    const c1 = await createClient(doc.id);\n    const sync1 = await nextMessage(c1);\n\n    const c2 = await createClient(doc.id);\n    const sync2 = await nextMessage(c2);\n\n    expect(sync1.version).toBe(1);\n    expect(sync2.version).toBe(1);\n\n    // Client 1 inserts \"X\" at position 1\n    sendOp(c1, { type: \"insert\", position: 1, text: \"X\" }, 1);\n    const ack1 = await nextMessage(c1);\n    expect(ack1.type).toBe(\"ack\");\n\n    // Client 2 receives the broadcast\n    const broadcast1 = await nextMessage(c2);\n    expect(broadcast1.type).toBe(\"operation\");\n\n    // Client 2 inserts \"Y\" at position 2, based on version 1\n    sendOp(c2, { type: \"insert\", position: 2, text: \"Y\" }, 1);\n    const ack2 = await nextMessage(c2);\n    expect(ack2.type).toBe(\"ack\");\n\n    // Check final document content\n    const getRes = await fetch(`${baseUrl}/api/documents/${doc.id}`);\n    const final = await getRes.json();\n\n    expect(final.content).toContain(\"X\");\n    expect(final.content).toContain(\"Y\");\n    expect(final.content).toContain(\"a\");\n    expect(final.content).toContain(\"b\");\n    expect(final.content).toContain(\"c\");\n    expect(final.content.length).toBe(5);\n\n    c1.ws.close();\n    c2.ws.close();\n  });\n\n  it(\"rejects invalid operations\", async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ title: \"Error Test\", content: \"hello\" }),\n    });\n    const doc = await createRes.json();\n\n    const client = await createClient(doc.id);\n    await nextMessage(client); // sync\n\n    // Send malformed message\n    client.ws.send(JSON.stringify({ type: \"unknown\" }));\n    const error = await nextMessage(client);\n    expect(error.type).toBe(\"error\");\n\n    // Send invalid JSON\n    client.ws.send(\"not json\");\n    const error2 = await nextMessage(client);\n    expect(error2.type).toBe(\"error\");\n\n    client.ws.close();\n  });\n\n  it(\"handles 10 concurrent clients\", async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ title: \"Concurrent Test\", content: \"\" }),\n    });\n    const doc = await createRes.json();\n\n    const clients: QueuedClient[] = [];\n    const versions: number[] = [];\n\n    // Connect 10 clients\n    for (let i = 0; i < 10; i++) {\n      const client = await createClient(doc.id);\n      const sync = await nextMessage(client);\n      versions.push(sync.version as number);\n      clients.push(client);\n    }\n\n    // Each client inserts a character sequentially\n    for (let i = 0; i < 10; i++) {\n      sendOp(\n        clients[i],\n        { type: \"insert\", position: i, text: String(i) },\n        versions[i]\n      );\n\n      // Wait for ack\n      const ack = await nextMessage(clients[i]);\n      expect(ack.type).toBe(\"ack\");\n      versions[i] = ack.version as number;\n\n      // Drain broadcasts from other clients\n      for (let j = 0; j < 10; j++) {\n        if (j !== i) {\n          const msg = await nextMessage(clients[j]);\n          expect(msg.type).toBe(\"operation\");\n          versions[j] = msg.version as number;\n        }\n      }\n    }\n\n    // Verify final content via REST\n    const getRes = await fetch(`${baseUrl}/api/documents/${doc.id}`);\n    const final = await getRes.json();\n    expect(final.content.length).toBe(10);\n\n    for (let i = 0; i < 10; i++) {\n      expect(final.content).toContain(String(i));\n    }\n\n    for (const client of clients) {\n      client.ws.close();\n    }\n  });\n\n  it(\"returns error for nonexistent document websocket\", async () => {\n    const ws = new WebSocket(\n      `ws://localhost:${port}/ws/documents/nonexistent`\n    );\n    return new Promise<void>((resolve) => {\n      ws.on(\"error\", () => {\n        resolve();\n      });\n      ws.on(\"unexpected-response\", () => {\n        resolve();\n      });\n    });\n  });\n\n  it(\"persists version history through WebSocket edits\", async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ title: \"Version Test\", content: \"start\" }),\n    });\n    const doc = await createRes.json();\n\n    const client = await createClient(doc.id);\n    const sync = await nextMessage(client);\n\n    // Make two edits\n    sendOp(client, { type: \"insert\", position: 5, text: \" middle\" }, sync.version as number);\n    const ack1 = await nextMessage(client);\n\n    sendOp(\n      client,\n      { type: \"insert\", position: 12, text: \" end\" },\n      ack1.version as number\n    );\n    await nextMessage(client);\n\n    client.ws.close();\n\n    // Check version history\n    const versionsRes = await fetch(\n      `${baseUrl}/api/documents/${doc.id}/versions`\n    );\n    const versions = await versionsRes.json();\n    expect(versions.length).toBe(3);\n    expect(versions[0].version).toBe(1);\n    expect(versions[0].content).toBe(\"start\");\n    expect(versions[2].content).toBe(\"start middle end\");\n  });\n});\n\ndescribe(\"Persistence\", () => {\n  it(\"persists documents across server restarts\", async () => {\n    const fs = await import(\"fs\");\n    const os = await import(\"os\");\n    const path = await import(\"path\");\n    const dbPath = path.join(os.tmpdir(), `test-collab-${Date.now()}.db`);\n\n    try {\n      const app1 = createApp(dbPath);\n      const port1 = await app1.start(0);\n      const url1 = `http://localhost:${port1}`;\n\n      const createRes = await fetch(`${url1}/api/documents`, {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ title: \"Persistent\", content: \"saved data\" }),\n      });\n      const created = await createRes.json();\n      await app1.stop();\n\n      const app2 = createApp(dbPath);\n      const port2 = await app2.start(0);\n      const url2 = `http://localhost:${port2}`;\n\n      const getRes = await fetch(`${url2}/api/documents/${created.id}`);\n      expect(getRes.status).toBe(200);\n      const doc = await getRes.json();\n      expect(doc.title).toBe(\"Persistent\");\n      expect(doc.content).toBe(\"saved data\");\n\n      await app2.stop();\n    } finally {\n      try {\n        fs.unlinkSync(dbPath);\n        fs.unlinkSync(dbPath + \"-wal\");\n        fs.unlinkSync(dbPath + \"-shm\");\n      } catch {\n        // ignore cleanup errors\n      }\n    }\n  });\n});\n","structuredPatch":[{"oldStart":16,"oldLines":28,"newStart":16,"newLines":47,"lines":["   await app.stop();"," 