"Document not found\" });\n      return;\n    }\n    res.json(doc);\n  });\n\n  // Delete a document\n  router.delete(\"/documents/:id\", (req, res) => {\n    const deleted = db.deleteDocument(req.params.id);\n    if (!deleted) {\n      res.status(404).json({ error: \"Document not found\" });\n      return;\n    }\n    res.status(204).send();\n  });\n\n  // Get document version history\n  router.get(\"/documents/:id/versions\", (req, res) => {\n    const doc = db.getDocument(req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: \"Document not found\" });\n      return;\n    }\n    const versions = db.getVersionHistory(req.params.id);\n    res.json(versions);\n  });\n\n  // Get a specific version\n  router.get(\"/documents/:id/versions/:version\", (req, res) => {\n    const doc = db.getDocument(req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: \"Document not found\" });\n      return;\n    }\n    const versionNum = parseInt(req.params.version, 10);\n    if (isNaN(versionNum)) {\n      res.status(400).json({ error: \"Version must be a number\" });\n      return;\n    }\n    const version = db.getVersion(req.params.id, versionNum);\n    if (!version) {\n      res.status(404).json({ error: \"Version not found\" });\n      return;\n    }\n    res.json(version);\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":37,"cache_creation_input_tokens":162,"cache_read_input_tokens":29154,"output_tokens":935,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":162},"inference_geo":"","iterations":[],"speed":"standard"}},"requestId":"req_011CYv2PCBiSbrVGyhhHj1zW","type":"assistant","uuid":"f05e2d05-74e9-43ef-ace8-9a6847b8ca4f","timestamp":"2026-03-10T20:24:00.143Z"}
