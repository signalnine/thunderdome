+import { describe, it, expect, beforeEach, afterEach } from "vitest";
+import { createApp, type AppInstance } from "../server.js";
+import WebSocket from "ws";
+
+let app: AppInstance;
+let port: number;
+let baseUrl: string;
+
+beforeEach(async () => {
+  app = createApp();
+  port = await app.start(0);
+  baseUrl = `http://localhost:${port}`;
+});
+
+afterEach(async () => {
+  await app.stop();
+});
+
+interface QueuedClient {
+  ws: WebSocket;
+  messages: Record<string, unknown>[];
+  waiters: Array<(msg: Record<string, unknown>) => void>;
+}
+
+function createClient(docId: string): Promise<QueuedClient> {
+  return new Promise((resolve, reject) => {
+    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/${docId}`);
+    const client: QueuedClient = { ws, messages: [], waiters: [] };
+
+    ws.on("message", (data) => {
+      const msg = JSON.parse(data.toString());
+      if (client.waiters.length > 0) {
+        const waiter = client.waiters.shift()!;
+        waiter(msg);
+      } else {
+        client.messages.push(msg);
+      }
+    });
+
+    ws.on("open", () => resolve(client));
+    ws.on("error", reject);
+  });
+}
+
+function nextMessage(client: QueuedClient): Promise<Record<string, unknown>> {
+  if (client.messages.length > 0) {
+    return Promise.resolve(client.messages.shift()!);
+  }
+  return new Promise((resolve) => {
+    client.waiters.push(resolve);
+  });
+}
+
+function sendOp(
+  client: QueuedClient,
+  operation: Record<string, unknown>,
+  version: number
+): void {
+  client.ws.send(JSON.stringify({ type: "operation", operation, version }));
+}
+
+describe("REST API", () => {
