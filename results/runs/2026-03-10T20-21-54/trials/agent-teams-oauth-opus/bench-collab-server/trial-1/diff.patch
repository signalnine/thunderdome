diff --git a/src/__tests__/ot.test.ts b/src/__tests__/ot.test.ts
new file mode 100644
index 0000000..3ed9dcd
--- /dev/null
+++ b/src/__tests__/ot.test.ts
@@ -0,0 +1,180 @@
+import { describe, it, expect } from "vitest";
+import {
+  applyOperation,
+  validateOperation,
+  transformOperation,
+  transformOperationAgainstMultiple,
+} from "../ot.js";
+import type { Operation } from "../types.js";
+
+describe("applyOperation", () => {
+  it("inserts text at position", () => {
+    expect(
+      applyOperation("hello", { type: "insert", position: 5, text: " world" })
+    ).toBe("hello world");
+  });
+
+  it("inserts text at beginning", () => {
+    expect(
+      applyOperation("world", { type: "insert", position: 0, text: "hello " })
+    ).toBe("hello world");
+  });
+
+  it("inserts text in middle", () => {
+    expect(
+      applyOperation("helo", { type: "insert", position: 2, text: "l" })
+    ).toBe("hello");
+  });
+
+  it("deletes text at position", () => {
+    expect(
+      applyOperation("hello world", { type: "delete", position: 5, count: 6 })
+    ).toBe("hello");
+  });
+
+  it("deletes text at beginning", () => {
+    expect(
+      applyOperation("hello", { type: "delete", position: 0, count: 2 })
+    ).toBe("llo");
+  });
+
+  it("clamps insert position to content length", () => {
+    expect(
+      applyOperation("hi", { type: "insert", position: 100, text: "!" })
+    ).toBe("hi!");
+  });
+});
+
+describe("validateOperation", () => {
+  it("validates a good insert", () => {
+    expect(
+      validateOperation("hello", { type: "insert", position: 3, text: "x" })
+    ).toBeNull();
+  });
+
+  it("rejects insert past end", () => {
+    expect(
+      validateOperation("hello", { type: "insert", position: 10, text: "x" })
+    ).toBeTruthy();
+  });
+
+  it("rejects insert with empty text", () => {
+    expect(
+      validateOperation("hello", { type: "insert", position: 0, text: "" })
+    ).toBeTruthy();
+  });
+
+  it("validates a good delete", () => {
+    expect(
+      validateOperation("hello", { type: "delete", position: 1, count: 3 })
+    ).toBeNull();
+  });
+
+  it("rejects delete past end", () => {
+    expect(
+      validateOperation("hello", { type: "delete", position: 3, count: 5 })
+    ).toBeTruthy();
+  });
+
+  it("rejects negative position", () => {
+    expect(
+      validateOperation("hello", { type: "insert", position: -1, text: "x" })
+    ).toBeTruthy();
+  });
+});
+
+describe("transformOperation", () => {
+  it("transforms insert-insert: other before op", () => {
+    const op: Operation = { type: "insert", position: 5, text: "B" };
+    const other: Operation = { type: "insert", position: 2, text: "A" };
+    const result = transformOperation(op, other);
+    expect(result).toEqual({ type: "insert", position: 6, text: "B" });
+  });
+
+  it("transforms insert-insert: other after op", () => {
+    const op: Operation = { type: "insert", position: 2, text: "A" };
+    const other: Operation = { type: "insert", position: 5, text: "B" };
+    const result = transformOperation(op, other);
+    expect(result).toEqual({ type: "insert", position: 2, text: "A" });
+  });
+
+  it("transforms insert-insert: same position (other wins)", () => {
+    const op: Operation = { type: "insert", position: 3, text: "B" };
+    const other: Operation = { type: "insert", position: 3, text: "A" };
+    const result = transformOperation(op, other);
+    expect(result).toEqual({ type: "insert", position: 4, text: "B" });
+  });
+
+  it("transforms insert-delete: insert before delete", () => {
+    const op: Operation = { type: "insert", position: 2, text: "X" };
+    const other: Operation = { type: "delete", position: 5, count: 3 };
+    const result = transformOperation(op, other);
+    expect(result).toEqual({ type: "insert", position: 2, text: "X" });
+  });
+
+  it("transforms insert-delete: insert after delete", () => {
+    const op: Operation = { type: "insert", position: 8, text: "X" };
+    const other: Operation = { type: "delete", position: 2, count: 3 };
+    const result = transformOperation(op, other);
+    expect(result).toEqual({ type: "insert", position: 5, text: "X" });
+  });
+
+  it("transforms delete-insert: delete before insert", () => {
+    const op: Operation = { type: "delete", position: 0, count: 2 };
+    const other: Operation = { type: "insert", position: 5, text: "X" };
+    const result = transformOperation(op, other);
+    expect(result).toEqual({ type: "delete", position: 0, count: 2 });
+  });
+
+  it("transforms delete-insert: delete after insert", () => {
+    const op: Operation = { type: "delete", position: 5, count: 2 };
+    const other: Operation = { type: "insert", position: 2, text: "X" };
+    const result = transformOperation(op, other);
+    expect(result).toEqual({ type: "delete", position: 6, count: 2 });
+  });
+
+  it("transforms delete-delete: non-overlapping, other before", () => {
+    const op: Operation = { type: "delete", position: 5, count: 2 };
+    const other: Operation = { type: "delete", position: 0, count: 2 };
+    const result = transformOperation(op, other);
+    expect(result).toEqual({ type: "delete", position: 3, count: 2 });
+  });
+
+  it("transforms delete-delete: identical operations", () => {
+    const op: Operation = { type: "delete", position: 2, count: 3 };
+    const other: Operation = { type: "delete", position: 2, count: 3 };
+    const result = transformOperation(op, other);
+    // Should become a no-op (count 0)
+    expect(result.type).toBe("delete");
+    if (result.type === "delete") {
+      expect(result.count).toBe(0);
+    }
+  });
+
+  it("concurrent inserts both preserved", () => {
+    const doc = "hello";
+    const opA: Operation = { type: "insert", position: 5, text: " world" };
+    const opB: Operation = { type: "insert", position: 0, text: "say " };
+
+    // Apply A first, then transform B against A
+    const afterA = applyOperation(doc, opA);
+    const transformedB = transformOperation(opB, opA);
+    const result = applyOperation(afterA, transformedB);
+
+    expect(result).toContain("hello");
+    expect(result).toContain("world");
+    expect(result).toContain("say");
+  });
+});
+
+describe("transformOperationAgainstMultiple", () => {
+  it("transforms against a sequence of operations", () => {
+    const op: Operation = { type: "insert", position: 0, text: "X" };
+    const others: Operation[] = [
+      { type: "insert", position: 0, text: "A" },
+      { type: "insert", position: 1, text: "B" },
+    ];
+    const result = transformOperationAgainstMultiple(op, others);
+    expect(result).toEqual({ type: "insert", position: 2, text: "X" });
+  });
+});
