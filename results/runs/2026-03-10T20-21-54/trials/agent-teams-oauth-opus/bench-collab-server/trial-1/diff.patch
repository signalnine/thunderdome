s\";\nimport type { Server } from \"http\";\nimport type { DocumentDB } from \"./db.js\";\nimport type { Operation, ClientMessage, ServerMessage } from \"./types.js\";\nimport {\n  applyOperation,\n  validateOperation,\n  transformOperationAgainstMultiple,\n} from \"./ot.js\";\nimport { randomUUID } from \"crypto\";\n\ninterface ClientConnection {\n  id: string;\n  ws: WebSocket;\n  documentId: string;\n}\n\ninterface DocumentSession {\n  documentId: string;\n  clients: Map<string, ClientConnection>;\n  // Operations applied since version 1, indexed by version\n  // operationLog[i] is the operation that produced version i+2 (version 1 is initial)\n  operationLog: Operation[];\n  currentVersion: number;\n  currentContent: string;\n}\n\nexport class CollaborationServer {\n  private wss: WebSocketServer;\n  private sessions: Map<string, DocumentSession> = new Map();\n  private db: DocumentDB;\n\n  constructor(server: Server, db: DocumentDB) {\n    this.db = db;\n    this.wss = new WebSocketServer({ server, path: undefined });\n\n    // Handle upgrade manually to extract document ID from path\n    server.removeAllListeners(\"upgrade\");\n    server.on(\"upgrade\", (request, socket, head) => {\n      const url = new URL(request.url ?? \"/\", `http://${request.headers.host}`);\n      const match = url.pathname.match(/^\\/ws\\/documents\\/([^/]+)$/);\n\n      if (!match) {\n        socket.write(\"HTTP/1.1 404 Not Found\\r\\n\\r\\n\");\n        socket.destroy();\n        return;\n      }\n\n      const documentId = match[1];\n      const doc = this.db.getDocument(documentId);\n      if (!doc) {\n        socket.write(\"HTTP/1.1 404 Not Found\\r\\n\\r\\n\");\n        socket.destroy();\n        return;\n      }\n\n      this.wss.handleUpgrade(request, socket, head, (ws) => {\n        this.handleConnection(ws, documentId);\n      });\n    });\n  }\n\n  private getOrCreateSession(documentId: string): DocumentSession {\n    let session = this.sessions.get(documentId);\n    if (!session) {\n      const doc = this.db.getDocument(documentId)!;\n      const version = this.db.getLatestVersion(documentId);\n      session = {\n        documentId,\n        clients: new Map(),\n        operationLog: [],\n        currentVersion: version,\n        currentContent: doc.content,\n      };\n      this.sessions.set(documentId, session);\n    }\n    return session;\n  }\n\n  private handleConnection(ws: WebSocket, documentId: string): void {\n    const session = this.getOrCreateSession(documentId);\n    const clientId = randomUUID();\n    const client: ClientConnection = { id: clientId, ws, documentId };\n    session.clients.set(clientId, client);\n\n    // Send sync message with current document state\n    const syncMsg: ServerMessage = {\n      type: \"sync\",\n      content: session.currentContent,\n      version: session.currentVersion,\n      clientId,\n    };\n    ws.send(JSON.stringify(syncMsg));\n\n    ws.on(\"message\", (data) => {\n      try {\n        const rawMsg = JSON.parse(data.toString());\n        this.handleClientMessage(session, client, rawMsg);\n      } catch (e) {\n        const errorMsg: ServerMessage = {\n          type: \"error\",\n          message: e instanceof Error ? e.message : \"Invalid message format\",\n        };\n        ws.send(JSON.stringify(errorMsg));\n      }\n    });\n\n    ws.on(\"close\", () => {\n      session.clients.delete(clientId);\n      if (session.clients.size === 0) {\n        this.sessions.delete(documentId);\n      }\n    });\n\n    ws.on(\"error\", () => {\n      session.clients.delete(clientId);\n    });\n  }\n\n  private handleClientMessage(\n    session: DocumentSession,\n    client: ClientConnection,\n    msg: unknown\n  ): void {\n    if (!isClientMessage(msg)) {\n      const errorMsg: ServerMessage = {\n        type: \"error\",\n        message: \"Invalid message format. Expected {type: 'operation', operation: {...}, version: number}\",\n      };\n      client.ws.send(JSON.stringify(errorMsg));\n      return;\n    }\n\n    if (msg.type !== \"operation\") {\n      const errorMsg: ServerMessage = {\n        type: \"error\",\n        message: `Unknown message type: ${msg.type}`,\n      };\n      client.ws.send(JSON.stringify(errorMsg));\n      return;\n    }\n\n    const clientVersion = msg.version;\n    let operation = msg.operation;\n\n    // Validate version\n    if (clientVersion < 1 || clientVersion > session.currentVersion) {\n      const errorMsg: ServerMessage = {\n        type: \"error\",\n        message: `Invalid version ${clientVersion}. Current version is ${session.currentVersion}`,\n      };\n      client.ws.send(JSON.stringify(errorMsg));\n      return;\n    }\n\n    // Transform operation against all operations that happened since client's version\n    if (clientVersion < session.currentVersion) {\n      const missedOps = session.operationLog.slice(\n        clientVersion - 1\n      );\n      operation = transformOperationAgainstMultiple(operation, missedOps);\n    }\n\n    // Skip no-op deletes (e.g., from overlapping concurrent deletes)\n    if (operation.type === \"delete\" && operation.count === 0) {\n      const ackMsg: ServerMessage = {\n        type: \"ack\",\n        version: session.currentVersion,\n      };\n      client.ws.send(JSON.stringify(ackMsg));\n      return;\n    }\n\n    // Validate the transformed operation against current content\n    const validationError = validateOperation(\n      session.currentContent,\n      operation\n    );\n    if (validationError) {\n      const errorMsg: ServerMessage = {\n        type: \"error\",\n        message: validationError,\n      };\n      client.ws.send(JSON.stringify(errorMsg));\n      return;\n    }\n\n    // Apply operation\n    const newContent = applyOperation(session.currentContent, operation);\n    session.currentContent = newContent;\n    session.operationLog.push(operation);\n    session.currentVersion++;\n\n    // Persist to database\n    this.db.updateDocumentContent(\n      session.documentId,\n      newContent,\n      JSON.stringify(operation)\n    );\n\n    // Send ack to the originating client\n    const ackMsg: ServerMessage = {\n      type: \"ack\",\n      version: session.currentVersion,\n    };\n    client.ws.send(JSON.stringify(ackMsg));\n\n    // Broadcast operation to other clients\n    const broadcastMsg: ServerMessage = {\n      type: \"operation\",\n      operation,\n      version: session.currentVersion,\n      clientId: client.id,\n    };\n    const broadcastStr = JSON.stringify(broadcastMsg);\n    for (const [id, c] of session.clients) {\n      if (id !== client.id && c.ws.readyState === WebSocket.OPEN) {\n        c.ws.send(broadcastStr);\n      }\n    }\n  }\n\n  closeAll(): void {\n    for (const session of this.sessions.values()) {\n      for (const client of session.clients.values()) {\n        client.ws.close();\n      }\n    }\n    this.sessions.clear();\n    this.wss.close();\n  }\n}\n\nfunction isClientMessage(msg: unknown): msg is ClientMessage {\n  if (typeof msg !== \"object\" || msg === null) return false;\n  const m = msg as Record<string, unknown>;\n  if (m.type !== \"operation\") return false;\n  if (typeof m.version !== \"number\") return false;\n  if (typeof m.operation !== \"object\" || m.operation === null) return false;\n  const op = m.operation as Record<string, unknown>;\n  if (op.type === \"insert\") {\n    return typeof op.position === \"number\" && typeof op.text === \"string\";\n  }\n  if (op.type === \"delete\") {\n    return typeof op.position === \"number\" && typeof op.count === \"number\";\n  }\n  return false;\n}\n","numLines":249,"startLine":1,"totalLines":249}},"sourceToolAssistantUUID":"8efb5cd3-c011-42c7-82fe-377df3a968f6"}
