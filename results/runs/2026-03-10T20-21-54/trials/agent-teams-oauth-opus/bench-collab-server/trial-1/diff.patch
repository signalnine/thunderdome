index 0000000..bdc355d
--- /dev/null
+++ b/src/ot.ts
@@ -0,0 +1,154 @@
+import type { Operation } from "./types.js";
+
+/**
+ * Apply an operation to a document string, returning the new content.
+ */
+export function applyOperation(content: string, op: Operation): string {
+  if (op.type === "insert") {
+    const pos = Math.min(Math.max(0, op.position), content.length);
+    return content.slice(0, pos) + op.text + content.slice(pos);
+  } else {
+    const pos = Math.min(Math.max(0, op.position), content.length);
+    const count = Math.min(op.count, content.length - pos);
+    return content.slice(0, pos) + content.slice(pos + count);
+  }
+}
+
+/**
+ * Validate an operation against the current document content.
+ * Returns an error message if invalid, or null if valid.
+ */
+export function validateOperation(
+  content: string,
+  op: Operation
+): string | null {
+  if (op.type === "insert") {
+    if (typeof op.position !== "number" || op.position < 0) {
+      return "Insert position must be a non-negative number";
+    }
+    if (op.position > content.length) {
+      return `Insert position ${op.position} exceeds document length ${content.length}`;
+    }
+    if (typeof op.text !== "string" || op.text.length === 0) {
+      return "Insert text must be a non-empty string";
+    }
+  } else if (op.type === "delete") {
+    if (typeof op.position !== "number" || op.position < 0) {
+      return "Delete position must be a non-negative number";
+    }
+    if (typeof op.count !== "number" || op.count <= 0) {
+      return "Delete count must be a positive number";
+    }
+    if (op.position + op.count > content.length) {
+      return `Delete range [${op.position}, ${op.position + op.count}) exceeds document length ${content.length}`;
+    }
+  } else {
+    return "Unknown operation type";
+  }
+  return null;
+}
+
+/**
+ * Transform operation `op` against a concurrently applied operation `other`.
+ * Returns the transformed version of `op` that can be applied after `other`.
+ *
+ * This implements the standard OT transformation for insert/delete operations.
+ * The "left wins" convention is used for tie-breaking concurrent inserts at
+ * the same position: `op` (the incoming operation) is transformed assuming
+ * `other` (the already-applied operation) takes priority.
+ */
+export function transformOperation(op: Operation, other: Operation): Operation {
+  if (op.type === "insert" && other.type === "insert") {
+    // Both inserts: shift op's position if other inserts before or at the same position
+    if (other.position <= op.position) {
+      return { type: "insert", position: op.position + other.text.length, text: op.text };
+    }
+    return { ...op };
+  }
+
+  if (op.type === "insert" && other.type === "delete") {
+    // Insert vs delete: adjust position based on delete range
+    if (op.position <= other.position) {
+      return { ...op };
+    }
+    if (op.position >= other.position + other.count) {
+      return { type: "insert", position: op.position - other.count, text: op.text };
+    }
+    // Insert falls within deleted range - place it at delete start
+    return { type: "insert", position: other.position, text: op.text };
+  }
+
+  if (op.type === "delete" && other.type === "insert") {
+    // Delete vs insert: adjust position based on insert
+    if (other.position >= op.position + op.count) {
+      return { ...op };
+    }
+    if (other.position <= op.position) {
+      return { type: "delete", position: op.position + other.text.length, count: op.count };
+    }
+    // Insert falls within our delete range - split around it
+    // Delete the parts before and after the inserted text
+    const beforeCount = other.position - op.position;
+    const afterCount = op.count - beforeCount;
+    // We need to delete both parts, but OT typically returns one op
+    // We'll delete the before part and after part (after the inserted text)
+    // Combined: delete from op.position, skip the inserted text, then continue deleting
+    // Since we return a single operation, we delete everything except the inserted text
+    return {
+      type: "delete",
+      position: op.position,
+      count: beforeCount + afterCount,
+    };
+  }
+
+  // Both deletes
+  if (op.type === "delete" && other.type === "delete") {
+    // No overlap cases
+    if (other.position >= op.position + op.count) {
+      return { ...op };
+    }
+    if (op.position >= other.position + other.count) {
+      return { type: "delete", position: op.position - other.count, count: op.count };
+    }
+
+    // Overlapping deletes
+    const opEnd = op.position + op.count;
+    const otherEnd = other.position + other.count;
+
+    if (op.position >= other.position && opEnd <= otherEnd) {
+      // op is entirely within other - nothing left to delete
+      return { type: "delete", position: other.position, count: 0 };
+    }
+
+    if (other.position >= op.position && otherEnd <= opEnd) {
+      // other is entirely within op
+      return { type: "delete", position: op.position, count: op.count - other.count };
+    }
+
+    if (op.position < other.position) {
+      // op starts before other, partial overlap at the end
+      const newCount = other.position - op.position;
+      return { type: "delete", position: op.position, count: newCount };
+    }
+
+    // op starts within other, extends past
+    const newCount = opEnd - otherEnd;
+    return { type: "delete", position: other.position, count: newCount };
+  }
+
+  return { ...op } as Operation;
+}
+
+/**
+ * Transform an operation against multiple sequential operations.
+ */
+export function transformOperationAgainstMultiple(
+  op: Operation,
+  others: Operation[]
+): Operation {
+  let transformed = op;
+  for (const other of others) {
+    transformed = transformOperation(transformed, other);
+  }
+  return transformed;
+}
