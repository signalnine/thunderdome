st match = url.pathname.match(/^\\/ws\\/documents\\/([^/]+)$/);\n    42→\n    43→      if (!match) {\n    44→        socket.write(\"HTTP/1.1 404 Not Found\\r\\n\\r\\n\");\n    45→        socket.destroy();\n    46→        return;\n    47→      }\n    48→\n    49→      const documentId = match[1];\n    50→      const doc = this.db.getDocument(documentId);\n    51→      if (!doc) {\n    52→        socket.write(\"HTTP/1.1 404 Not Found\\r\\n\\r\\n\");\n    53→        socket.destroy();\n    54→        return;\n    55→      }\n    56→\n    57→      this.wss.handleUpgrade(request, socket, head, (ws) => {\n    58→        this.handleConnection(ws, documentId);\n    59→      });\n    60→    });\n    61→  }\n    62→\n    63→  private getOrCreateSession(documentId: string): DocumentSession {\n    64→    let session = this.sessions.get(documentId);\n    65→    if (!session) {\n    66→      const doc = this.db.getDocument(documentId)!;\n    67→      const version = this.db.getLatestVersion(documentId);\n    68→      session = {\n    69→        documentId,\n    70→        clients: new Map(),\n    71→        operationLog: [],\n    72→        currentVersion: version,\n    73→        currentContent: doc.content,\n    74→      };\n    75→      this.sessions.set(documentId, session);\n    76→    }\n    77→    return session;\n    78→  }\n    79→\n    80→  private handleConnection(ws: WebSocket, documentId: string): void {\n    81→    const session = this.getOrCreateSession(documentId);\n    82→    const clientId = randomUUID();\n    83→    const client: ClientConnection = { id: clientId, ws, documentId };\n    84→    session.clients.set(clientId, client);\n    85→\n    86→    // Send sync message with current document state\n    87→    const syncMsg: ServerMessage = {\n    88→      type: \"sync\",\n    89→      content: session.currentContent,\n    90→      version: session.currentVersion,\n    91→      clientId,\n    92→    };\n    93→    ws.send(JSON.stringify(syncMsg));\n    94→\n  