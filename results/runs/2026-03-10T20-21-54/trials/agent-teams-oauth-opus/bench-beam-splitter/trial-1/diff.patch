+type Direction = 'down' | 'down-left' | 'down-right';
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+function step(beam: Beam): { row: number; col: number } {
+  const row = beam.row + 1;
+  const col =
+    beam.dir === 'down' ? beam.col :
+    beam.dir === 'down-left' ? beam.col - 1 :
+    beam.col + 1;
+  return { row, col };
+}
+
+function findSource(grid: string[][]): { row: number; col: number } | null {
+  for (let col = 0; col < grid[0].length; col++) {
+    if (grid[0][col] === 'S') return { row: 0, col };
+  }
+  return null;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  if (rows === 0) return 0;
+  const cols = grid[0].length;
+
+  const source = findSource(grid);
+  if (!source) return 0;
+
+  const visited = new Set<number>();
+  visited.add(source.row * cols + source.col);
+
+  const beams: Beam[] = [{ row: source.row, col: source.col, dir: 'down' }];
+
+  while (beams.length > 0) {
+    const nextBeams: Beam[] = [];
+    for (const beam of beams) {
+      const next = step(beam);
+      if (next.row < 0 || next.row >= rows || next.col < 0 || next.col >= cols) {
+        continue; // absorbed
+      }
+      visited.add(next.row * cols + next.col);
+      const cell = grid[next.row][next.col];
+      if (cell === '^') {
+        nextBeams.push({ row: next.row, col: next.col, dir: 'down-left' });
+        nextBeams.push({ row: next.row, col: next.col, dir: 'down-right' });
+      } else {
+        nextBeams.push({ row: next.row, col: next.col, dir: beam.dir });
+      }
+    }
+    beams.length = 0;
+    beams.push(...nextBeams);
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  if (rows === 0) return 0n;
+  const cols = grid[0].length;
+
+  const source = findSource(grid);
+  if (!source) return 0n;
+
+  // Use a map from (row, col, dir) to path count (bigint).
+  // Process row by row since all movement goes downward.
+  // Key: `${row},${col},${dir}`
+  type State = { col: number; dir: Direction; count: bigint };
+
+  let currentStates: State[] = [{ col: source.col, dir: 'down', count: 1n }];
+  let totalPaths = 0n;
+
+  for (let fromRow = source.row; fromRow < rows; fromRow++) {
+    // Merge states with same (col, dir) to avoid explosion
+    const merged = new Map<string, bigint>();
+    for (const s of currentStates) {
+      const key = `${s.col},${s.dir}`;
+      merged.set(key, (merged.get(key) ?? 0n) + s.count);
+    }
+
+    const nextStates: State[] = [];
+    for (const [key, count] of merged) {
+      const [colStr, dir] = key.split(',') as [string, Direction];
+      const col = parseInt(colStr);
+      const next = step({ row: fromRow, col, dir });
+
+      if (next.row < 0 || next.row >= rows || next.col < 0 || next.col >= cols) {
+        totalPaths += count; // exits grid
+        continue;
+      }
+
+      const cell = grid[next.row][next.col];
+      if (cell === '^') {
+        nextStates.push({ col: next.col, dir: 'down-left', count });
+        nextStates.push({ col: next.col, dir: 'down-right', count });
+      } else {
+        nextStates.push({ col: next.col, dir, count });
+      }
+    }
+
+    currentStates = nextStates;
+  }
+
+  // Any beams still active after processing the last row exit the grid
+  for (const s of currentStates) {
+    totalPaths += s.count;
+  }
+
+  return totalPaths;
+}
