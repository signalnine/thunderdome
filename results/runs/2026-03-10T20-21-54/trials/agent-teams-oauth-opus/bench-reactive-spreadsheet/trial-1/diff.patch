index 0000000..b5b79d9
--- /dev/null
+++ b/src/parser.ts
@@ -0,0 +1,310 @@
+import { Token, ASTNode } from './types.js';
+import { expandRange } from './cellRef.js';
+
+const CELL_REF_RE = /^[A-Z]+\d+$/;
+
+function tokenize(input: string): Token[] {
+  const tokens: Token[] = [];
+  let i = 0;
+
+  while (i < input.length) {
+    const ch = input[i];
+
+    // Skip whitespace
+    if (ch === ' ' || ch === '\t') {
+      i++;
+      continue;
+    }
+
+    // String literal
+    if (ch === '"') {
+      let str = '';
+      i++; // skip opening quote
+      while (i < input.length && input[i] !== '"') {
+        str += input[i];
+        i++;
+      }
+      if (i < input.length) i++; // skip closing quote
+      tokens.push({ type: 'STRING', value: str });
+      continue;
+    }
+
+    // Number
+    if ((ch >= '0' && ch <= '9') || (ch === '.' && i + 1 < input.length && input[i + 1] >= '0' && input[i + 1] <= '9')) {
+      let num = '';
+      while (i < input.length && ((input[i] >= '0' && input[i] <= '9') || input[i] === '.')) {
+        num += input[i];
+        i++;
+      }
+      tokens.push({ type: 'NUMBER', value: num });
+      continue;
+    }
+
+    // Cell reference, function name, or boolean
+    if ((ch >= 'A' && ch <= 'Z') || (ch >= 'a' && ch <= 'z')) {
+      let word = '';
+      while (i < input.length && ((input[i] >= 'A' && input[i] <= 'Z') || (input[i] >= 'a' && input[i] <= 'z') || (input[i] >= '0' && input[i] <= '9'))) {
+        word += input[i];
+        i++;
+      }
+
+      const upper = word.toUpperCase();
+
+      if (upper === 'TRUE' || upper === 'FALSE') {
+        tokens.push({ type: 'BOOLEAN', value: upper });
+      } else if (i < input.length && input[i] === '(') {
+        tokens.push({ type: 'FUNCTION', value: upper });
+      } else if (CELL_REF_RE.test(upper)) {
+        tokens.push({ type: 'CELL_REF', value: upper });
+      } else {
+        tokens.push({ type: 'CELL_REF', value: upper });
+      }
+      continue;
+    }
+
+    // Colon (range operator)
+    if (ch === ':') {
+      i++;
+      tokens.push({ type: 'OPERATOR', value: ':' });
+      continue;
+    }
+
+    // Comparison operators (multi-char first)
+    if (ch === '>' || ch === '<' || ch === '=') {
+      if (i + 1 < input.length) {
+        const twoChar = ch + input[i + 1];
+        if (twoChar === '>=' || twoChar === '<=' || twoChar === '<>') {
+          tokens.push({ type: 'COMPARISON', value: twoChar });
+          i += 2;
+          continue;
+        }
+      }
+      tokens.push({ type: 'COMPARISON', value: ch });
+      i++;
+      continue;
+    }
+
+    // Arithmetic operators
+    if (ch === '+' || ch === '-' || ch === '*' || ch === '/') {
+      tokens.push({ type: 'OPERATOR', value: ch });
+      i++;
+      continue;
+    }
+
+    if (ch === '(') {
+      tokens.push({ type: 'LPAREN', value: '(' });
+      i++;
+      continue;
+    }
+    if (ch === ')') {
+      tokens.push({ type: 'RPAREN', value: ')' });
+      i++;
+      continue;
+    }
+
+    if (ch === ',') {
+      tokens.push({ type: 'COMMA', value: ',' });
+      i++;
+      continue;
+    }
+
+    throw new Error(`Unexpected character: ${ch}`);
+  }
+
+  return tokens;
+}
+
+class Parser {
+  private tokens: Token[];
+  private pos: number;
+
+  constructor(tokens: Token[]) {
+    this.tokens = tokens;
+    this.pos = 0;
+  }
+
+  private peek(): Token | undefined {
+    return this.tokens[this.pos];
+  }
+
+  private advance(): Token {
+    return this.tokens[this.pos++];
+  }
+
+  private expect(type: string): Token {
+    const token = this.advance();
+    if (!token || token.type !== type) {
+      throw new Error(`Expected ${type} but got ${token?.type ?? 'EOF'}`);
+    }
+    return token;
+  }
+
+  parse(): ASTNode {
+    const node = this.parseComparison();
+    return node;
+  }
+
+  private parseComparison(): ASTNode {
+    let left = this.parseExpression();
+
+    while (this.peek()?.type === 'COMPARISON') {
+      const op = this.advance().value;
+      const right = this.parseExpression();
+      left = { type: 'binary', op, left, right };
+    }
+
+    return left;
+  }
+
+  private parseExpression(): ASTNode {
+    let left = this.parseTerm();
+
+    while (this.peek()?.type === 'OPERATOR' && (this.peek()!.value === '+' || this.peek()!.value === '-')) {
+      const op = this.advance().value;
+      const right = this.parseTerm();
+      left = { type: 'binary', op, left, right };
+    }
+
+    return left;
+  }
+
+  private parseTerm(): ASTNode {
+    let left = this.parseUnary();
+
+    while (this.peek()?.type === 'OPERATOR' && (this.peek()!.value === '*' || this.peek()!.value === '/')) {
+      const op = this.advance().value;
+      const right = this.parseUnary();
+      left = { type: 'binary', op, left, right };
+    }
+
+    return left;
+  }
+
+  private parseUnary(): ASTNode {
+    if (this.peek()?.type === 'OPERATOR' && (this.peek()!.value === '-' || this.peek()!.value === '+')) {
+      const op = this.advance().value;
+      const operand = this.parseUnary();
+      if (op === '-') {
+        return { type: 'unary', op: '-', operand };
+      }
+      return operand;
+    }
+    return this.parsePrimary();
+  }
+
+  private parsePrimary(): ASTNode {
+    const token = this.peek();
+
+    if (!token) {
+      throw new Error('Unexpected end of expression');
+    }
+
+    if (token.type === 'NUMBER') {
+      this.advance();
+      return { type: 'number', value: parseFloat(token.value) };
+    }
+
+    if (token.type === 'STRING') {
+      this.advance();
+      return { type: 'string', value: token.value };
+    }
+
+    if (token.type === 'BOOLEAN') {
+      this.advance();
+      return { type: 'boolean', value: token.value === 'TRUE' };
+    }
+
+    if (token.type === 'FUNCTION') {
+      const name = this.advance().value;
+      this.expect('LPAREN');
+      const args: ASTNode[] = [];
+
+      if (this.peek()?.type !== 'RPAREN') {
+        args.push(this.parseFunctionArg());
+        while (this.peek()?.type === 'COMMA') {
+          this.advance(); // skip comma
+          args.push(this.parseFunctionArg());
+        }
+      }
+
+      this.expect('RPAREN');
+      return { type: 'function', name, args };
+    }
+
+    if (token.type === 'CELL_REF') {
+      const ref = this.advance().value;
+      if (this.peek()?.type === 'OPERATOR' && this.peek()!.value === ':') {
+        this.advance(); // skip ':'
+        const endToken = this.expect('CELL_REF');
+        return { type: 'range', start: ref, end: endToken.value };
+      }
+      return { type: 'cellRef', ref };
+    }
+
+    if (token.type === 'LPAREN') {
+      this.advance();
+      const expr = this.parseComparison();
+      this.expect('RPAREN');
+      return expr;
+    }
+
+    throw new Error(`Unexpected token: ${token.value}`);
+  }
+
+  private parseFunctionArg(): ASTNode {
+    // Check for range pattern: CELL_REF : CELL_REF
+    if (this.peek()?.type === 'CELL_REF' &&
+        this.pos + 2 < this.tokens.length &&
+        this.tokens[this.pos + 1].type === 'OPERATOR' &&
+        this.tokens[this.pos + 1].value === ':' &&
+        this.tokens[this.pos + 2].type === 'CELL_REF') {
+      const ref = this.advance().value;
+      this.advance(); // colon
+      const endRef = this.advance().value;
+      return { type: 'range', start: ref, end: endRef };
+    }
+    return this.parseComparison();
+  }
+}
+
+export function parseFormula(formula: string): ASTNode {
+  const expr = formula.startsWith('=') ? formula.slice(1) : formula;
+  const tokens = tokenize(expr);
+  const parser = new Parser(tokens);
+  return parser.parse();
+}
+
+/**
+ * Extract all cell references from an AST (for dependency tracking).
+ */
+export function extractDependencies(node: ASTNode): Set<string> {
+  const deps = new Set<string>();
+
+  function walk(n: ASTNode): void {
+    switch (n.type) {
+      case 'cellRef':
+        deps.add(n.ref);
+        break;
+      case 'range':
+        for (const ref of expandRange(n.start, n.end)) {
+          deps.add(ref);
+        }
+        break;
+      case 'binary':
+        walk(n.left);
+        walk(n.right);
+        break;
+      case 'unary':
+        walk(n.operand);
+        break;
+      case 'function':
+        for (const arg of n.args) {
+          walk(arg);
+        }
+        break;
+    }
+  }
+
+  walk(node);
+  return deps;
+}
