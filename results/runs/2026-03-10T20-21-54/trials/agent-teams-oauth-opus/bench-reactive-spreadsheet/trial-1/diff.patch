new file mode 100644
index 0000000..5dec78e
--- /dev/null
+++ b/src/cellRef.ts
@@ -0,0 +1,68 @@
+import { CellRef } from './types.js';
+
+/**
+ * Parse a column string (e.g., "A", "Z", "AA") into a 0-based column index.
+ */
+export function colToIndex(col: string): number {
+  let index = 0;
+  for (let i = 0; i < col.length; i++) {
+    index = index * 26 + (col.charCodeAt(i) - 64);
+  }
+  return index - 1;
+}
+
+/**
+ * Convert a 0-based column index to a column string.
+ */
+export function indexToCol(index: number): string {
+  let col = '';
+  let n = index + 1;
+  while (n > 0) {
+    n--;
+    col = String.fromCharCode(65 + (n % 26)) + col;
+    n = Math.floor(n / 26);
+  }
+  return col;
+}
+
+/**
+ * Parse a cell reference string (e.g., "A1", "AA100") into a CellRef.
+ */
+export function parseCellRef(ref: string): CellRef {
+  const match = ref.match(/^([A-Z]+)(\d+)$/);
+  if (!match) {
+    throw new Error(`Invalid cell reference: ${ref}`);
+  }
+  return {
+    col: colToIndex(match[1]),
+    row: parseInt(match[2], 10) - 1,
+  };
+}
+
+/**
+ * Normalize a cell reference to uppercase.
+ */
+export function normalizeRef(ref: string): string {
+  return ref.toUpperCase();
+}
+
+/**
+ * Expand a range (e.g., A1:C3) into an array of cell references.
+ */
+export function expandRange(startRef: string, endRef: string): string[] {
+  const start = parseCellRef(startRef);
+  const end = parseCellRef(endRef);
+
+  const minCol = Math.min(start.col, end.col);
+  const maxCol = Math.max(start.col, end.col);
+  const minRow = Math.min(start.row, end.row);
+  const maxRow = Math.max(start.row, end.row);
+
+  const refs: string[] = [];
+  for (let row = minRow; row <= maxRow; row++) {
+    for (let col = minCol; col <= maxCol; col++) {
+      refs.push(indexToCol(col) + (row + 1));
+    }
+  }
+  return refs;
+}
