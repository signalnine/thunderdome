index 0000000..1742624
--- /dev/null
+++ b/src/evaluator.ts
@@ -0,0 +1,145 @@
+import { ASTNode, CellValue } from './types.js';
+import { expandRange } from './cellRef.js';
+
+export type CellGetter = (ref: string) => CellValue;
+
+export function evaluate(node: ASTNode, getCell: CellGetter): CellValue {
+  switch (node.type) {
+    case 'number':
+      return node.value;
+
+    case 'string':
+      return node.value;
+
+    case 'boolean':
+      return node.value;
+
+    case 'cellRef':
+      return getCell(node.ref);
+
+    case 'range':
+      throw new Error('Range can only be used inside a function');
+
+    case 'unary': {
+      const val = evaluate(node.operand, getCell);
+      if (node.op === '-') {
+        return typeof val === 'number' ? -val : 0;
+      }
+      return val;
+    }
+
+    case 'binary':
+      return evaluateBinary(node.op, node.left, node.right, getCell);
+
+    case 'function':
+      return evaluateFunction(node.name, node.args, getCell);
+  }
+}
+
+function toNumber(val: CellValue): number {
+  if (typeof val === 'number') return val;
+  if (typeof val === 'boolean') return val ? 1 : 0;
+  if (typeof val === 'string') {
+    const n = parseFloat(val);
+    return isNaN(n) ? 0 : n;
+  }
+  return 0;
+}
+
+function evaluateBinary(op: string, left: ASTNode, right: ASTNode, getCell: CellGetter): CellValue {
+  const lVal = evaluate(left, getCell);
+  const rVal = evaluate(right, getCell);
+
+  // Arithmetic
+  if (op === '+') return toNumber(lVal) + toNumber(rVal);
+  if (op === '-') return toNumber(lVal) - toNumber(rVal);
+  if (op === '*') return toNumber(lVal) * toNumber(rVal);
+  if (op === '/') {
+    const divisor = toNumber(rVal);
+    if (divisor === 0) throw new Error('Division by zero');
+    return toNumber(lVal) / divisor;
+  }
+
+  // Comparisons
+  if (op === '>') return toNumber(lVal) > toNumber(rVal);
+  if (op === '<') return toNumber(lVal) < toNumber(rVal);
+  if (op === '>=') return toNumber(lVal) >= toNumber(rVal);
+  if (op === '<=') return toNumber(lVal) <= toNumber(rVal);
+  if (op === '=') {
+    if (typeof lVal === typeof rVal) return lVal === rVal;
+    return toNumber(lVal) === toNumber(rVal);
+  }
+  if (op === '<>') {
+    if (typeof lVal === typeof rVal) return lVal !== rVal;
+    return toNumber(lVal) !== toNumber(rVal);
+  }
+
+  throw new Error(`Unknown operator: ${op}`);
+}
+
+function resolveRangeValues(args: ASTNode[], getCell: CellGetter): number[] {
+  const values: number[] = [];
+
+  for (const arg of args) {
+    if (arg.type === 'range') {
+      const refs = expandRange(arg.start, arg.end);
+      for (const ref of refs) {
+        const val = getCell(ref);
+        if (typeof val === 'number') {
+          values.push(val);
+        }
+      }
+    } else {
+      const val = evaluate(arg, getCell);
+      if (typeof val === 'number') {
+        values.push(val);
+      }
+    }
+  }
+
+  return values;
+}
+
+function evaluateFunction(name: string, args: ASTNode[], getCell: CellGetter): CellValue {
+  switch (name) {
+    case 'SUM': {
+      const values = resolveRangeValues(args, getCell);
+      return values.reduce((sum, v) => sum + v, 0);
+    }
+
+    case 'AVERAGE': {
+      const values = resolveRangeValues(args, getCell);
+      if (values.length === 0) return 0;
+      return values.reduce((sum, v) => sum + v, 0) / values.length;
+    }
+
+    case 'MIN': {
+      const values = resolveRangeValues(args, getCell);
+      if (values.length === 0) return 0;
+      return Math.min(...values);
+    }
+
+    case 'MAX': {
+      const values = resolveRangeValues(args, getCell);
+      if (values.length === 0) return 0;
+      return Math.max(...values);
+    }
+
+    case 'COUNT': {
+      const values = resolveRangeValues(args, getCell);
+      return values.length;
+    }
+
+    case 'IF': {
+      if (args.length < 3) {
+        throw new Error('IF requires 3 arguments');
+      }
+      const condition = evaluate(args[0], getCell);
+      const isTruthy = typeof condition === 'boolean' ? condition : toNumber(condition) !== 0;
+      return evaluate(isTruthy ? args[1] : args[2], getCell);
+    }
+
+    default:
+      throw new Error(`Unknown function: ${name}`);
+  }
+}
diff --git a/src/index.ts b/src/index.ts
new file mode 100644
index 0000000..8c2f2e5
--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,173 @@
+import { CellValue, ASTNode } from './types.js';
+import { parseFormula, extractDependencies } from './parser.js';
+import { evaluate } from './evaluator.js';
+
+interface CellData {
+  raw: string | number | boolean;
+  formula: ASTNode | null;
+  value: CellValue;
+  deps: Set<string>;       // cells this cell depends on
+}
+
+export class Spreadsheet {
+  private cells: Map<string, CellData> = new Map();
+  private dependents: Map<string, Set<string>> = new Map(); // reverse deps: cell -> cells that depend on it
+
+  set(cell: string, value: string | number | boolean): void {
+    const ref = cell.toUpperCase();
+    const oldData = this.cells.get(ref);
+
+    // Remove old reverse dependencies
+    if (oldData) {
+      for (const dep of oldData.deps) {
+        this.dependents.get(dep)?.delete(ref);
+      }
+    }
+
+    let formula: ASTNode | null = null;
+    let deps = new Set<string>();
+    let computed: CellValue;
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      formula = parseFormula(value);
+      deps = extractDependencies(formula);
+
+      // Check for circular references before committing
+      this.checkCircular(ref, deps);
+
+      // Register reverse dependencies
+      for (const dep of deps) {
+        if (!this.dependents.has(dep)) {
+          this.dependents.set(dep, new Set());
+        }
+        this.dependents.get(dep)!.add(ref);
+      }
+
+      computed = evaluate(formula, (r) => this.getCellValue(r));
+    } else if (typeof value === 'string') {
+      computed = value;
+    } else {
+      computed = value;
+    }
+
+    this.cells.set(ref, {
+      raw: value,
+      formula,
+      value: computed,
+      deps,
+    });
+
+    // Propagate changes to dependent cells
+    this.propagate(ref);
+  }
+
+  get(cell: string): CellValue {
+    const ref = cell.toUpperCase();
+    return this.getCellValue(ref);
+  }
+
+  getDisplay(cell: string): string {
+    const value = this.get(cell);
+    if (value === null) return '';
+    return String(value);
+  }
+
+  getCells(): Map<string, CellValue> {
+    const result = new Map<string, CellValue>();
+    for (const [ref, data] of this.cells) {
+      result.set(ref, data.value);
+    }
+    return result;
+  }
+
+  private getCellValue(ref: string): CellValue {
+    const data = this.cells.get(ref);
+    if (!data) return null;
+    return data.value;
+  }
+
+  private checkCircular(startRef: string, newDeps: Set<string>): void {
+    // BFS/DFS from newDeps to see if we can reach startRef
+    const visited = new Set<string>();
+    const stack = [...newDeps];
+
+    while (stack.length > 0) {
+      const current = stack.pop()!;
+      if (current === startRef) {
+        throw new Error(`Circular reference detected: ${startRef}`);
+      }
+      if (visited.has(current)) continue;
+      visited.add(current);
+
+      // Follow the dependencies of `current`
+      const data = this.cells.get(current);
+      if (data) {
+        for (const dep of data.deps) {
+          if (!visited.has(dep)) {
+            stack.push(dep);
+          }
+        }
+      }
+    }
+  }
+
+  private propagate(changedRef: string): void {
+    // Topological sort of all transitive dependents, then re-evaluate
+    const order = this.topologicalSort(changedRef);
+
+    for (const ref of order) {
+      const data = this.cells.get(ref);
+      if (data?.formula) {
+        data.value = evaluate(data.formula, (r) => this.getCellValue(r));
+      }
+    }
+  }
+
+  private topologicalSort(startRef: string): string[] {
+    const visited = new Set<string>();
+    const result: string[] = [];
+
+    const visit = (ref: string): void => {
+      if (visited.has(ref)) return;
+      visited.add(ref);
+
+      const deps = this.dependents.get(ref);
+      if (deps) {
+        for (const dep of deps) {
+          visit(dep);
+        }
+      }
+
+      result.push(ref);
+    };
+
+    visit(startRef);
+
+    // Remove the start ref (it was the changed cell, already updated)
+    // Return in correct evaluation order (reverse of the DFS finish order,
+    // but we want dependents after their dependencies)
+    // Actually the order from this DFS puts leaves last and root first.
+    // We want to evaluate in the order: dependencies before dependents.
+    // The result has startRef at the end. We need to remove startRef
+    // and reverse the remaining items for correct topological order.
+
+    // Remove startRef from results
+    const idx = result.indexOf(startRef);
+    if (idx !== -1) result.splice(idx, 1);
+
+    // The DFS post-order gives us: dependents first, then the cell they depend on.
+    // We need the reverse: evaluate dependencies before dependents.
+    // Actually, let me reconsider. The visit function visits dependents recursively
+    // before pushing the current. So deeper dependents are pushed first.
+    // To evaluate correctly: we need to process items from the end toward the start.
+    // Actually no. Let me think again:
+    // If A depends on B depends on C:
+    //   dependents map: C -> {B}, B -> {A}
+    //   visit(C): visit(B): visit(A): push A; push B; push C
+    //   result = [A, B, C]
+    // We want to evaluate B before A.
+    // So we reverse: [C, B, A], remove C (startRef) -> [B, A]. Correct!
+    result.reverse();
+    return result;
+  }
+}
