);\n    });\n\n    it(\"should get profile\", async () => {\n      const res = await request(app)\n        .get(\"/auth/profile\")\n        .set(\"Authorization\", `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.email).toBe(\"admin@test.com\");\n    });\n\n    it(\"should require auth for profile\", async () => {\n      const res = await request(app).get(\"/auth/profile\");\n      expect(res.status).toBe(401);\n    });\n\n    it(\"should change user role\", async () => {\n      // Register a second user\n      const reg = await request(app)\n        .post(\"/auth/register\")\n        .send({ email: \"viewer@test.com\", password: \"password123\", tenantId });\n      expect(reg.body.role).toBe(\"viewer\");\n\n      const res = await request(app)\n        .put(`/auth/users/${reg.body.id}/role`)\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ role: \"editor\" });\n      expect(res.status).toBe(200);\n      expect(res.body.role).toBe(\"editor\");\n    });\n  });\n\n  describe(\"Event Ingestion\", () => {\n    it(\"should ingest a single event\", async () => {\n      const res = await request(app)\n        .post(\"/events\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"page_view\", properties: { url: \"/home\" } });\n      expect(res.status).toBe(201);\n      expect(res.body.name).toBe(\"page_view\");\n    });\n\n    it(\"should ingest batch events\", async () => {\n      const res = await request(app)\n        .post(\"/events/batch\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({\n          events: [\n            { name: \"page_view\", properties: { url: \"/about\" } },\n            { name: \"page_view\", properties: { url: \"/home\" } },\n            { name: \"click\", properties: { button: \"signup\" } },\n          ],\n        });\n      expect(res.status).toBe(201);\n      expect(res.body.inserted).toBe(3);\n    });\n\n    it(\"should require auth for events\", async () => {\n      const res = await request(app).post(\"/events\").send({ name: \"test\" });\n      expect(res.status).toBe(401);\n    });\n  });\n\n  describe(\"Query Engine\", () => {\n    it(\"should count events\", async () => {\n      const res = await request(app)\n        .post(\"/query/count\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ filter: { eventName: \"page_view\" } });\n      expect(res.status).toBe(200);\n      expect(res.body.count).toBe(3);\n    });\n\n    it(\"should count all events\", async () => {\n      const res = await request(app)\n        .post(\"/query/count\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({});\n      expect(res.status).toBe(200);\n      expect(res.body.count).toBe(4);\n    });\n\n    it(\"should do timeseries query\", async () => {\n      const res = await request(app)\n        .post(\"/query/timeseries\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ filter: { eventName: \"page_view\" }, interval: \"day\" });\n      expect(res.status).toBe(200);\n      expect(res.body.timeseries).toBeDefined();\n      expect(res.body.timeseries.length).toBeGreaterThan(0);\n    });\n\n    it(\"should do breakdown query\", async () => {\n      const res = await request(app)\n        .post(\"/query/breakdown\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ filter: { eventName: \"page_view\" }, property: \"url\" });\n      expect(res.status).toBe(200);\n      expect(res.body.breakdown).toBeDefined();\n      expect(res.body.breakdown.length).toBe(2);\n    });\n  });\n\n  describe(\"Dashboards\", () => {\n    let dashboardId: string;\n\n    it(\"should create a dashboard\", async () => {\n      const res = await request(app)\n        .post(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({\n          name: \"My Dashboard\",\n          config: { theme: \"dark\" },\n          widgets: [{ type: \"counter\", config: