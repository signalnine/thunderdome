+{"parentUuid":"ae7abe3f-91ed-4e59-b497-b30bdd63a917","isSidechain":false,"userType":"external","cwd":"/workspace","sessionId":"ad6c908d-602a-4936-b1f5-1bf25a1e8182","version":"2.1.63","gitBranch":"HEAD","slug":"tingly-wibbling-meadow","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EyX8EGEJR21GJBDgyhQ2qS","type":"tool_result","content":"File created successfully at: /workspace/src/routes/queries.ts"}]},"uuid":"f8f36d11-926a-47cf-86fe-9934eaf9a674","timestamp":"2026-03-10T20:55:49.713Z","toolUseResult":{"type":"create","filePath":"/workspace/src/routes/queries.ts","content":"import { Router } from \"express\";\nimport Database from \"better-sqlite3\";\nimport { AuthRequest, requireAuth } from \"../auth.js\";\n\ninterface QueryFilter {\n  eventName?: string;\n  startDate?: string;\n  endDate?: string;\n  properties?: Record<string, string>;\n}\n\nfunction buildWhereClause(tenantId: string, filter?: QueryFilter): { where: string; params: unknown[] } {\n  const conditions: string[] = [\"tenant_id = ?\"];\n  const params: unknown[] = [tenantId];\n\n  if (filter?.eventName) {\n    conditions.push(\"name = ?\");\n    params.push(filter.eventName);\n  }\n  if (filter?.startDate) {\n    conditions.push(\"timestamp >= ?\");\n    params.push(filter.startDate);\n  }\n  if (filter?.endDate) {\n    conditions.push(\"timestamp <= ?\");\n    params.push(filter.endDate);\n  }\n  if (filter?.properties) {\n    for (const [key, value] of Object.entries(filter.properties)) {\n      conditions.push(\"json_extract(properties, ?) = ?\");\n      params.push(`$.${key}`, value);\n    }\n  }\n\n  return { where: conditions.join(\" AND \"), params };\n}\n\nexport function createQueryRoutes(db: Database.Database): Router {\n  const router = Router();\n\n  router.post(\"/count\", requireAuth, (req: AuthRequest, res) => {\n    const { filter } = req.body as { filter?: QueryFilter };\n    const tenantId = req.user!.tenantId;\n    const { where, params } = buildWhereClause(tenantId, filter);\n\n    const result = db.prepare(`SELECT COUNT(*) as count FROM events WHERE ${where}`).get(...params) as { count: number };\n\n    res.json({ count: result.count });\n  });\n\n  router.post(\"/timeseries\", requireAuth, (req: AuthRequest, res) => {\n    const { filter, interval } = req.body as { filter?: QueryFilter; interval?: string };\n    const tenantId = req.user!.tenantId;\n    const { where, params } = buildWhereClause(tenantId, filter);\n\n    let dateFormat: string;\n    switch (interval) {\n      case \"hour\":\n        dateFormat = \"%Y-%m-%dT%H:00:00\";\n        break;\n      case \"month\":\n        dateFormat = \"%Y-%m-01\";\n        break;\n      case \"day\":\n      default:\n        dateFormat = \"%Y-%m-%d\";\n        break;\n    }\n\n    const rows = db.prepare(\n      `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count FROM events WHERE ${where} GROUP BY bucket ORDER BY bucket`\n    ).all(...params) as Array<{ bucket: string; count: number }>;\n\n    res.json({ timeseries: rows });\n  });\n\n  router.post(\"/breakdown\", requireAuth, (req: AuthRequest, res) => {\n    const { filter, property } = req.body as { filter?: QueryFilter; property: string };\n    const tenantId = req.user!.tenantId;\n\n    if (!property) {\n      res.status(400).json({ error: \"property is required for breakdown queries\" });\n      return;\n    }\n\n    const { where, params } = buildWhereClause(tenantId, filter);\n\n    const rows = db.prepare(\n      `SELECT json_extract(properties, ?) as value, COUNT(*) as count FROM events WHERE ${where} AND json_extract(properties, ?) IS NOT NULL GROUP BY value ORDER BY count DESC`\n    ).all(`$.${property}`, ...params, `$.${property}`) as Array<{ value: string; count: number }>;\n\n    res.json({ breakdown: rows });\n  });\n\n  return router;\n}\n","structuredPatch":[],"originalFile":null},"sourceToolAssistantUUID":"ae7abe3f-91ed-4e59-b497-b30bdd63a917"}
