q.query.format as string) || \"json\";\n    const eventName = req.query.eventName as string | undefined;\n\n    let query = \"SELECT * FROM events WHERE tenant_id = ?\";\n    const params: unknown[] = [tenantId];\n\n    if (eventName) {\n      query += \" AND name = ?\";\n      params.push(eventName);\n    }\n\n    query += \" ORDER BY timestamp DESC\";\n\n    const events = db.prepare(query).all(...params) as EventRow[];\n\n    if (format === \"csv\") {\n      res.setHeader(\"Content-Type\", \"text/csv\");\n      res.setHeader(\"Content-Disposition\", \"attachment; filename=events.csv\");\n      res.send(eventsToCsv(events));\n    } else {\n      res.json({\n        events: events.map(e => ({\n          id: e.id,\n          name: e.name,\n          properties: JSON.parse(e.properties),\n          timestamp: e.timestamp,\n          userId: e.user_id,\n          sessionId: e.session_id,\n        })),\n      });\n    }\n  });\n\n  router.get(\"/dashboards/:id\", requireAuth, (req: AuthRequest, res) => {\n    const tenantId = req.user!.tenantId;\n    const format = (req.query.format as string) || \"json\";\n\n    const dashboard = db.prepare(\n      \"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\"\n    ).get(req.params.id, tenantId) as DashboardRow | undefined;\n\n    if (!dashboard) {\n      res.status(404).json({ error: \"Dashboard not found\" });\n      return;\n    }\n\n    const widgets = db.prepare(\n      \"SELECT * FROM widgets WHERE dashboard_id = ?\"\n    ).all(dashboard.id) as WidgetRow[];\n\n    const data = {\n      id: dashboard.id,\n      name: dashboard.name,\n      tenantId: dashboard.tenant_id,\n      ownerId: dashboard.owner_id,\n      config: JSON.parse(dashboard.config),\n      widgets: widgets.map(w => ({\n        id: w.id,\n        type: w.type,\n        config: JSON.parse(w.config),\n        positionX: w.position_x,\n        positionY: w.position_y,\n        width: w.width,\n        height: w.height,\n      })),\n      createdAt: dashboard.created_at,\n      updatedAt: dashboard.updated_at,\n    };\n\n    if (format === \"csv\") {\n      res.setHeader(\"Content-Type\", \"text/csv\");\n      res.setHeader(\"Content-Disposition\", `attachment; filename=dashboard-${dashboard.id}.csv`);\n      const headers = [\"widget_id\", \"type\", \"config\", \"position_x\", \"position_y\", \"width\", \"height\"];\n      const lines = [headers.join(\",\")];\n      for (const w of widgets) {\n        const cfg = w.config.replace(/\"/g, '\"\"');\n        lines.push([w.id, w.type, `\"${cfg}\"`, w.position_x, w.position_y, w.width, w.height].join(\",\"));\n      }\n      res.send(lines.join(\"\\n\"));\n    } else {\n      res.json(data);\n    }\n  });\n\n  return router;\n}\n","structuredPatch":[],"originalFile":null},"sourceToolAssistantUUID":"0b79f172-ad2d-4eb4-8abe-a4a9516bfdd3"}
