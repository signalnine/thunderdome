@@ -0,0 +1,262 @@
+import { describe, it, expect, beforeAll } from "vitest";
+import request from "supertest";
+import { createApp } from "./app.js";
+
+const app = createApp();
+
+describe("Analytics Dashboard API", () => {
+  let token: string;
+  let userId: string;
+  const tenantId = "test-tenant";
+
+  describe("User Management", () => {
+    it("should register a new user", async () => {
+      const res = await request(app)
+        .post("/auth/register")
+        .send({ email: "admin@test.com", password: "password123", tenantId });
+      expect(res.status).toBe(201);
+      expect(res.body.token).toBeDefined();
+      expect(res.body.role).toBe("admin");
+      token = res.body.token;
+      userId = res.body.id;
+    });
+
+    it("should reject duplicate email", async () => {
+      const res = await request(app)
+        .post("/auth/register")
+        .send({ email: "admin@test.com", password: "password123", tenantId });
+      expect(res.status).toBe(409);
+    });
+
+    it("should login", async () => {
+      const res = await request(app)
+        .post("/auth/login")
+        .send({ email: "admin@test.com", password: "password123" });
+      expect(res.status).toBe(200);
+      expect(res.body.token).toBeDefined();
+    });
+
+    it("should reject bad login", async () => {
+      const res = await request(app)
+        .post("/auth/login")
+        .send({ email: "admin@test.com", password: "wrong" });
+      expect(res.status).toBe(401);
+    });
+
+    it("should get profile", async () => {
+      const res = await request(app)
+        .get("/auth/profile")
+        .set("Authorization", `Bearer ${token}`);
+      expect(res.status).toBe(200);
+      expect(res.body.email).toBe("admin@test.com");
+    });
+
+    it("should require auth for profile", async () => {
+      const res = await request(app).get("/auth/profile");
+      expect(res.status).toBe(401);
+    });
+
+    it("should change user role", async () => {
+      // Register a second user
+      const reg = await request(app)
+        .post("/auth/register")
+        .send({ email: "viewer@test.com", password: "password123", tenantId });
+      expect(reg.body.role).toBe("viewer");
+
+      const res = await request(app)
+        .put(`/auth/users/${reg.body.id}/role`)
+        .set("Authorization", `Bearer ${token}`)
+        .send({ role: "editor" });
+      expect(res.status).toBe(200);
+      expect(res.body.role).toBe("editor");
+    });
+  });
+
+  describe("Event Ingestion", () => {
+    it("should ingest a single event", async () => {
+      const res = await request(app)
+        .post("/events")
+        .set("Authorization", `Bearer ${token}`)
+        .send({ name: "page_view", properties: { url: "/home" } });
+      expect(res.status).toBe(201);
+      expect(res.body.name).toBe("page_view");
+    });
+
+    it("should ingest batch events", async () => {
+      const res = await request(app)
+        .post("/events/batch")
+        .set("Authorization", `Bearer ${token}`)
+        .send({
+          events: [
+            { name: "page_view", properties: { url: "/about" } },
+            { name: "page_view", properties: { url: "/home" } },
+            { name: "click", properties: { button: "signup" } },
+          ],
+        });
+      expect(res.status).toBe(201);
+      expect(res.body.inserted).toBe(3);
+    });
+
+    it("should require auth for events", async () => {
+      const res = await request(app).post("/events").send({ name: "test" });
+      expect(res.status).toBe(401);
+    });
+  });
+
+  describe("Query Engine", () => {
+    it("should count events", async () => {
+      const res = await request(app)
+        .post("/query/count")
+        .set("Authorization", `Bearer ${token}`)
+        .send({ filter: { eventName: "page_view" } });
+      expect(res.status).toBe(200);
+      expect(res.body.count).toBe(3);
+    });
+
+    it("should count all events", async () => {
+      const res = await request(app)
+        .post("/query/count")
+        .set("Authorization", `Bearer ${token}`)
+        .send({});
+      expect(res.status).toBe(200);
+      expect(res.body.count).toBe(4);
+    });
+
+    it("should do timeseries query", async () => {
+      const res = await request(app)
+        .post("/query/timeseries")
+        .set("Authorization", `Bearer ${token}`)
+        .send({ filter: { eventName: "page_view" }, interval: "day" });
+      expect(res.status).toBe(200);
+      expect(res.body.timeseries).toBeDefined();
+      expect(res.body.timeseries.length).toBeGreaterThan(0);
+    });
+
+    it("should do breakdown query", async () => {
+      const res = await request(app)
+        .post("/query/breakdown")
+        .set("Authorization", `Bearer ${token}`)
+        .send({ filter: { eventName: "page_view" }, property: "url" });
+      expect(res.status).toBe(200);
+      expect(res.body.breakdown).toBeDefined();
+      expect(res.body.breakdown.length).toBe(2);
+    });
+  });
+
+  describe("Dashboards", () => {
+    let dashboardId: string;
+
+    it("should create a dashboard", async () => {
+      const res = await request(app)
+        .post("/dashboards")
+        .set("Authorization", `Bearer ${token}`)
+        .send({
+          name: "My Dashboard",
+          config: { theme: "dark" },
+          widgets: [{ type: "counter", config: { eventName: "page_view" } }],
+        });
+      expect(res.status).toBe(201);
+      expect(res.body.name).toBe("My Dashboard");
+      expect(res.body.widgets).toHaveLength(1);
+      dashboardId = res.body.id;
+    });
+
+    it("should list dashboards", async () => {
+      const res = await request(app)
+        .get("/dashboards")
+        .set("Authorization", `Bearer ${token}`);
+      expect(res.status).toBe(200);
+      expect(res.body.dashboards.length).toBeGreaterThan(0);
+    });
+
+    it("should get a dashboard", async () => {
+      const res = await request(app)
+        .get(`/dashboards/${dashboardId}`)
+        .set("Authorization", `Bearer ${token}`);
+      expect(res.status).toBe(200);
+      expect(res.body.name).toBe("My Dashboard");
+      expect(res.body.widgets).toHaveLength(1);
+    });
+
+    it("should update a dashboard", async () => {
+      const res = await request(app)
+        .put(`/dashboards/${dashboardId}`)
+        .set("Authorization", `Bearer ${token}`)
+        .send({ name: "Updated Dashboard" });
+      expect(res.status).toBe(200);
+      expect(res.body.name).toBe("Updated Dashboard");
+    });
+
+    it("should delete a dashboard", async () => {
+      const res = await request(app)
+        .delete(`/dashboards/${dashboardId}`)
+        .set("Authorization", `Bearer ${token}`);
+      expect(res.status).toBe(204);
+    });
+  });
+
+  describe("Export", () => {
+    it("should export events as JSON", async () => {
+      const res = await request(app)
+        .get("/export/events?format=json")
+        .set("Authorization", `Bearer ${token}`);
+      expect(res.status).toBe(200);
+      expect(res.body.events).toBeDefined();
+      expect(res.body.events.length).toBe(4);
+    });
+
+    it("should export events as CSV", async () => {
+      const res = await request(app)
+        .get("/export/events?format=csv")
+        .set("Authorization", `Bearer ${token}`);
+      expect(res.status).toBe(200);
+      expect(res.headers["content-type"]).toContain("text/csv");
+      expect(res.text).toContain("id,name,properties,timestamp");
+    });
+
+    it("should export dashboard as JSON", async () => {
+      // Create a dashboard first
+      const dash = await request(app)
+        .post("/dashboards")
+        .set("Authorization", `Bearer ${token}`)
+        .send({ name: "Export Test" });
+
+      const res = await request(app)
+        .get(`/export/dashboards/${dash.body.id}?format=json`)
+        .set("Authorization", `Bearer ${token}`);
+      expect(res.status).toBe(200);
+      expect(res.body.name).toBe("Export Test");
+    });
+
+    it("should require auth for export", async () => {
+      const res = await request(app).get("/export/events");
+      expect(res.status).toBe(401);
+    });
+  });
+
+  describe("Tenant Isolation", () => {
+    let otherToken: string;
+
+    beforeAll(async () => {
+      const res = await request(app)
+        .post("/auth/register")
+        .send({ email: "other@other.com", password: "password123", tenantId: "other-tenant" });
+      otherToken = res.body.token;
+    });
+
+    it("should not see other tenant events", async () => {
+      const res = await request(app)
+        .post("/query/count")
+        .set("Authorization", `Bearer ${otherToken}`)
+        .send({});
+      expect(res.body.count).toBe(0);
+    });
+
+    it("should not see other tenant dashboards", async () => {
+      const res = await request(app)
+        .get("/dashboards")
+        .set("Authorization", `Bearer ${otherToken}`);
+      expect(res.body.dashboards).toHaveLength(0);
+    });
+  });
+});
