tHeader(\"Content-Type\", \"text/csv\");\n      res.setHeader(\"Content-Disposition\", `attachment; filename=dashboard-${dashboard.id}.csv`);\n      const headers = [\"widget_id\", \"type\", \"config\", \"position_x\", \"position_y\", \"width\", \"height\"];\n      const lines = [headers.join(\",\")];\n      for (const w of widgets) {\n        const cfg = w.config.replace(/\"/g, '\"\"');\n        lines.push([w.id, w.type, `\"${cfg}\"`, w.position_x, w.position_y, w.width, w.height].join(\",\"));\n      }\n      res.send(lines.join(\"\\n\"));\n    } else {\n      res.json(data);\n    }\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":105,"cache_read_input_tokens":26421,"cache_creation":{"ephemeral_5m_input_tokens":105,"ephemeral_1h_input_tokens":0},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"}},"requestId":"req_011CYv4joN66hZoQRMn1FuK1","type":"assistant","uuid":"0b79f172-ad2d-4eb4-8abe-a4a9516bfdd3","timestamp":"2026-03-10T20:55:46.852Z"}
