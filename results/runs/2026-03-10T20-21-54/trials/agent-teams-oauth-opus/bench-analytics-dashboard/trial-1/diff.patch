@@ -0,0 +1,143 @@
+import { Router } from "express";
+import Database from "better-sqlite3";
+import { AuthRequest, requireAuth } from "../auth.js";
+
+interface EventRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string;
+  session_id: string;
+}
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+interface WidgetRow {
+  id: string;
+  dashboard_id: string;
+  type: string;
+  config: string;
+  position_x: number;
+  position_y: number;
+  width: number;
+  height: number;
+}
+
+function eventsToCsv(events: EventRow[]): string {
+  const headers = ["id", "name", "properties", "timestamp", "user_id", "session_id"];
+  const lines = [headers.join(",")];
+  for (const evt of events) {
+    const props = evt.properties.replace(/"/g, '""');
+    lines.push([
+      evt.id,
+      evt.name,
+      `"${props}"`,
+      evt.timestamp,
+      evt.user_id || "",
+      evt.session_id || "",
+    ].join(","));
+  }
+  return lines.join("\n");
+}
+
+export function createExportRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  router.get("/events", requireAuth, (req: AuthRequest, res) => {
+    const tenantId = req.user!.tenantId;
+    const format = (req.query.format as string) || "json";
+    const eventName = req.query.eventName as string | undefined;
+
+    let query = "SELECT * FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [tenantId];
+
+    if (eventName) {
+      query += " AND name = ?";
+      params.push(eventName);
+    }
+
+    query += " ORDER BY timestamp DESC";
+
+    const events = db.prepare(query).all(...params) as EventRow[];
+
+    if (format === "csv") {
+      res.setHeader("Content-Type", "text/csv");
+      res.setHeader("Content-Disposition", "attachment; filename=events.csv");
+      res.send(eventsToCsv(events));
+    } else {
+      res.json({
+        events: events.map(e => ({
+          id: e.id,
+          name: e.name,
+          properties: JSON.parse(e.properties),
+          timestamp: e.timestamp,
+          userId: e.user_id,
+          sessionId: e.session_id,
+        })),
+      });
+    }
+  });
+
+  router.get("/dashboards/:id", requireAuth, (req: AuthRequest, res) => {
+    const tenantId = req.user!.tenantId;
+    const format = (req.query.format as string) || "json";
+
+    const dashboard = db.prepare(
+      "SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?"
+    ).get(req.params.id, tenantId) as DashboardRow | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const widgets = db.prepare(
+      "SELECT * FROM widgets WHERE dashboard_id = ?"
+    ).all(dashboard.id) as WidgetRow[];
+
+    const data = {
+      id: dashboard.id,
+      name: dashboard.name,
+      tenantId: dashboard.tenant_id,
+      ownerId: dashboard.owner_id,
+      config: JSON.parse(dashboard.config),
+      widgets: widgets.map(w => ({
+        id: w.id,
+        type: w.type,
+        config: JSON.parse(w.config),
+        positionX: w.position_x,
+        positionY: w.position_y,
+        width: w.width,
+        height: w.height,
+      })),
+      createdAt: dashboard.created_at,
+      updatedAt: dashboard.updated_at,
+    };
+
+    if (format === "csv") {
+      res.setHeader("Content-Type", "text/csv");
+      res.setHeader("Content-Disposition", `attachment; filename=dashboard-${dashboard.id}.csv`);
+      const headers = ["widget_id", "type", "config", "position_x", "position_y", "width", "height"];
+      const lines = [headers.join(",")];
+      for (const w of widgets) {
+        const cfg = w.config.replace(/"/g, '""');
+        lines.push([w.id, w.type, `"${cfg}"`, w.position_x, w.position_y, w.width, w.height].join(","));
+      }
+      res.send(lines.join("\n"));
+    } else {
+      res.json(data);
+    }
+  });
+
+  return router;
+}
diff --git a/src/routes/queries.ts b/src/routes/queries.ts
new file mode 100644
index 0000000..6751900
--- /dev/null
+++ b/src/routes/queries.ts
@@ -0,0 +1,96 @@
+import { Router } from "express";
+import Database from "better-sqlite3";
+import { AuthRequest, requireAuth } from "../auth.js";
+
+interface QueryFilter {
+  eventName?: string;
+  startDate?: string;
+  endDate?: string;
+  properties?: Record<string, string>;
+}
+
+function buildWhereClause(tenantId: string, filter?: QueryFilter): { where: string; params: unknown[] } {
+  const conditions: string[] = ["tenant_id = ?"];
+  const params: unknown[] = [tenantId];
+
+  if (filter?.eventName) {
+    conditions.push("name = ?");
+    params.push(filter.eventName);
+  }
+  if (filter?.startDate) {
+    conditions.push("timestamp >= ?");
+    params.push(filter.startDate);
+  }
+  if (filter?.endDate) {
+    conditions.push("timestamp <= ?");
+    params.push(filter.endDate);
+  }
+  if (filter?.properties) {
+    for (const [key, value] of Object.entries(filter.properties)) {
+      conditions.push("json_extract(properties, ?) = ?");
+      params.push(`$.${key}`, value);
+    }
+  }
+
+  return { where: conditions.join(" AND "), params };
+}
+
+export function createQueryRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  router.post("/count", requireAuth, (req: AuthRequest, res) => {
+    const { filter } = req.body as { filter?: QueryFilter };
+    const tenantId = req.user!.tenantId;
+    const { where, params } = buildWhereClause(tenantId, filter);
+
+    const result = db.prepare(`SELECT COUNT(*) as count FROM events WHERE ${where}`).get(...params) as { count: number };
+
+    res.json({ count: result.count });
+  });
+
+  router.post("/timeseries", requireAuth, (req: AuthRequest, res) => {
+    const { filter, interval } = req.body as { filter?: QueryFilter; interval?: string };
+    const tenantId = req.user!.tenantId;
+    const { where, params } = buildWhereClause(tenantId, filter);
+
+    let dateFormat: string;
+    switch (interval) {
+      case "hour":
+        dateFormat = "%Y-%m-%dT%H:00:00";
+        break;
+      case "month":
+        dateFormat = "%Y-%m-01";
+        break;
+      case "day":
+      default:
+        dateFormat = "%Y-%m-%d";
+        break;
+    }
+
+    const rows = db.prepare(
+      `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count FROM events WHERE ${where} GROUP BY bucket ORDER BY bucket`
+    ).all(...params) as Array<{ bucket: string; count: number }>;
+
+    res.json({ timeseries: rows });
+  });
+
+  router.post("/breakdown", requireAuth, (req: AuthRequest, res) => {
+    const { filter, property } = req.body as { filter?: QueryFilter; property: string };
+    const tenantId = req.user!.tenantId;
+
+    if (!property) {
+      res.status(400).json({ error: "property is required for breakdown queries" });
+      return;
+    }
+
+    const { where, params } = buildWhereClause(tenantId, filter);
+
+    const rows = db.prepare(
+      `SELECT json_extract(properties, ?) as value, COUNT(*) as count FROM events WHERE ${where} AND json_extract(properties, ?) IS NOT NULL GROUP BY value ORDER BY count DESC`
+    ).all(`$.${property}`, ...params, `$.${property}`) as Array<{ value: string; count: number }>;
+
+    res.json({ breakdown: rows });
+  });
+
+  return router;
+}
