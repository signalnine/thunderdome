@@ -0,0 +1,156 @@
+import { Router } from "express";
+import Database from "better-sqlite3";
+import { v4 as uuidv4 } from "uuid";
+import { AuthRequest, requireAuth } from "../auth.js";
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+interface WidgetRow {
+  id: string;
+  dashboard_id: string;
+  type: string;
+  config: string;
+  position_x: number;
+  position_y: number;
+  width: number;
+  height: number;
+}
+
+function formatDashboard(row: DashboardRow, widgets?: WidgetRow[]) {
+  return {
+    id: row.id,
+    tenantId: row.tenant_id,
+    name: row.name,
+    ownerId: row.owner_id,
+    config: JSON.parse(row.config),
+    widgets: widgets?.map(w => ({
+      id: w.id,
+      dashboardId: w.dashboard_id,
+      type: w.type,
+      config: JSON.parse(w.config),
+      positionX: w.position_x,
+      positionY: w.position_y,
+      width: w.width,
+      height: w.height,
+    })),
+    createdAt: row.created_at,
+    updatedAt: row.updated_at,
+  };
+}
+
+export function createDashboardRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  router.get("/", requireAuth, (req: AuthRequest, res) => {
+    const tenantId = req.user!.tenantId;
+    const rows = db.prepare("SELECT * FROM dashboards WHERE tenant_id = ?").all(tenantId) as DashboardRow[];
+    res.json({ dashboards: rows.map(r => formatDashboard(r)) });
+  });
+
+  router.post("/", requireAuth, (req: AuthRequest, res) => {
+    const { name, config, widgets } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: "Dashboard name is required" });
+      return;
+    }
+
+    const id = uuidv4();
+    const tenantId = req.user!.tenantId;
+    const ownerId = req.user!.userId;
+
+    db.prepare(
+      "INSERT INTO dashboards (id, tenant_id, name, owner_id, config) VALUES (?, ?, ?, ?, ?)"
+    ).run(id, tenantId, name, ownerId, JSON.stringify(config || {}));
+
+    const widgetRows: WidgetRow[] = [];
+    if (Array.isArray(widgets)) {
+      const insertWidget = db.prepare(
+        "INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)"
+      );
+      for (const w of widgets) {
+        const wid = uuidv4();
+        insertWidget.run(wid, id, w.type, JSON.stringify(w.config || {}), w.positionX || 0, w.positionY || 0, w.width || 1, w.height || 1);
+        widgetRows.push({
+          id: wid, dashboard_id: id, type: w.type,
+          config: JSON.stringify(w.config || {}),
+          position_x: w.positionX || 0, position_y: w.positionY || 0,
+          width: w.width || 1, height: w.height || 1,
+        });
+      }
+    }
+
+    const row = db.prepare("SELECT * FROM dashboards WHERE id = ?").get(id) as DashboardRow;
+    res.status(201).json(formatDashboard(row, widgetRows));
+  });
+
+  router.get("/:id", requireAuth, (req: AuthRequest, res) => {
+    const tenantId = req.user!.tenantId;
+    const row = db.prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?").get(req.params.id, tenantId) as DashboardRow | undefined;
+
+    if (!row) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const widgets = db.prepare("SELECT * FROM widgets WHERE dashboard_id = ?").all(row.id) as WidgetRow[];
+    res.json(formatDashboard(row, widgets));
+  });
+
+  router.put("/:id", requireAuth, (req: AuthRequest, res) => {
+    const tenantId = req.user!.tenantId;
+    const existing = db.prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?").get(req.params.id, tenantId) as DashboardRow | undefined;
+
+    if (!existing) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const { name, config, widgets } = req.body;
+    const updatedName = name || existing.name;
+    const updatedConfig = config !== undefined ? JSON.stringify(config) : existing.config;
+
+    db.prepare(
+      "UPDATE dashboards SET name = ?, config = ?, updated_at = datetime('now') WHERE id = ?"
+    ).run(updatedName, updatedConfig, req.params.id);
+
+    if (Array.isArray(widgets)) {
+      db.prepare("DELETE FROM widgets WHERE dashboard_id = ?").run(req.params.id);
+      const insertWidget = db.prepare(
+        "INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)"
+      );
+      for (const w of widgets) {
+        const wid = w.id || uuidv4();
+        insertWidget.run(wid, req.params.id, w.type, JSON.stringify(w.config || {}), w.positionX || 0, w.positionY || 0, w.width || 1, w.height || 1);
+      }
+    }
+
+    const row = db.prepare("SELECT * FROM dashboards WHERE id = ?").get(req.params.id) as DashboardRow;
+    const wRows = db.prepare("SELECT * FROM widgets WHERE dashboard_id = ?").all(req.params.id) as WidgetRow[];
+    res.json(formatDashboard(row, wRows));
+  });
+
+  router.delete("/:id", requireAuth, (req: AuthRequest, res) => {
+    const tenantId = req.user!.tenantId;
+    const existing = db.prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?").get(req.params.id, tenantId) as DashboardRow | undefined;
+
+    if (!existing) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    db.prepare("DELETE FROM widgets WHERE dashboard_id = ?").run(req.params.id);
+    db.prepare("DELETE FROM dashboards WHERE id = ?").run(req.params.id);
+    res.status(204).send();
+  });
+
+  return router;
+}
