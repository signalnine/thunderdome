+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter, Machine } from './index.js';
+
+function verifyToggle(machine: Machine, result: number[]): boolean {
+  const lights = new Array(machine.target.length).fill(false);
+  for (const btnIdx of result) {
+    for (const light of machine.buttons[btnIdx]) {
+      lights[light] = !lights[light];
+    }
+  }
+  return lights.every((v, i) => v === machine.target[i]);
+}
+
+function verifyCounter(
+  targets: number[], buttons: number[][], modulus: number, result: number[],
+): boolean {
+  const counters = new Array(targets.length).fill(0);
+  for (let j = 0; j < result.length; j++) {
+    for (let press = 0; press < result[j]; press++) {
+      for (const idx of buttons[j]) {
+        counters[idx] = (counters[idx] + 1) % modulus;
+      }
+    }
+  }
+  return counters.every((v, i) => v === targets[i]);
+}
+
+describe('solveToggle - MITM path (kFree > 25)', () => {
+  it('30 buttons, 5 lights, 29 free vars', () => {
+    // All buttons toggle light 0 only
+    const nButtons = 30;
+    const buttons: number[][] = [];
+    for (let j = 0; j < nButtons; j++) {
+      buttons.push([0]);
+    }
+    const target = [true, false, false, false, false];
+    const machine: Machine = { target, buttons };
+    const result = solveToggle(machine)!;
+    expect(result).not.toBeNull();
+    expect(result.length).toBe(1); // minimum 1 press
+    expect(result).toEqual([0]); // lex smallest
+    expect(verifyToggle(machine, result)).toBe(true);
+  });
+
+  it('35 buttons, 3 lights, 32 free vars', () => {
+    const nButtons = 35;
+    const nLights = 3;
+    const buttons: number[][] = [];
+    // First 3 buttons each toggle a unique light
+    for (let j = 0; j < nLights; j++) {
+      buttons.push([j]);
+    }
+    // Remaining buttons toggle light 0
+    for (let j = nLights; j < nButtons; j++) {
+      buttons.push([0]);
+    }
+    const target = [true, true, true];
+    const machine: Machine = { target, buttons };
+    const result = solveToggle(machine)!;
+    expect(result).not.toBeNull();
+    expect(result.length).toBe(3);
+    expect(result).toEqual([0, 1, 2]); // press buttons 0, 1, 2
+    expect(verifyToggle(machine, result)).toBe(true);
+  });
+
+  it('40 buttons, 5 lights, MITM with varied toggles', () => {
+    const nButtons = 40;
+    const nLights = 5;
+    const buttons: number[][] = [];
+    for (let j = 0; j < nButtons; j++) {
+      // Button j toggles lights where bit pattern of j matches
+      const affected: number[] = [];
+      for (let i = 0; i < nLights; i++) {
+        if ((j >> i) & 1) affected.push(i);
+      }
+      if (affected.length === 0) affected.push(0);
+      buttons.push(affected);
+    }
+    const target = [true, true, true, true, true];
+    const machine: Machine = { target, buttons };
+    const start = Date.now();
+    const result = solveToggle(machine);
+    const elapsed = Date.now() - start;
+    expect(elapsed).toBeLessThan(5000);
+    if (result !== null) {
+      expect(verifyToggle(machine, result)).toBe(true);
+    }
+  });
+});
