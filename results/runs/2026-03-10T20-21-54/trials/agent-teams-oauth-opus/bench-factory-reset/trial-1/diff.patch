fyToggle(machine, result)).toBe(true);\n  });\n\n  it('handles 20 lights, 20 buttons', () => {\n    const n = 20;\n    // Each button toggles two consecutive lights\n    const buttons = Array.from({ length: n }, (_, i) => [i, (i + 1) % n]);\n    const target = new Array(n).fill(false);\n    target[0] = true;\n    target[1] = true;\n    const machine: Machine = { target, buttons };\n    const result = solveToggle(machine);\n    if (result !== null) {\n      expect(verifyToggle(machine, result)).toBe(true);\n    }\n  });\n\n  it('handles many free variables (20 buttons, 5 lights)', () => {\n    // 20 buttons, but only 5 lights → up to 15 free variables\n    const nLights = 5;\n    const nButtons = 20;\n    const buttons: number[][] = [];\n    for (let j = 0; j < nButtons; j++) {\n      const affected: number[] = [];\n      for (let i = 0; i < nLights; i++) {\n        if ((j >> i) & 1) affected.push(i);\n      }\n      if (affected.length === 0) affected.push(0);\n      buttons.push(affected);\n    }\n    const target = [true, true, false, true, false];\n    const machine: Machine = { target, buttons };\n    const result = solveToggle(machine);\n    if (result !== null) {\n      expect(verifyToggle(machine, result)).toBe(true);\n    }\n  });\n\n  it('performance: 40 buttons, 40 lights (should complete in < 5s)', () => {\n    const n = 40;\n    // Diagonal matrix → unique solution, all buttons pressed\n    const target = new Array(n).fill(true);\n    const buttons = Array.from({ length: n }, (_, i) => [i]);\n    const machine: Machine = { target, buttons };\n    const start = Date.now();\n    const result = solveToggle(machine)!;\n    const elapsed = Date.now() - start;\n    expect(elapsed).toBeLessThan(5000);\n    expect(result.length).toBe(n);\n    expect(verifyToggle(machine, result)).toBe(true);\n  });\n\n  it('performance: 40 buttons, 20 lights (should complete in < 5s)', () => {\n    // 40 buttons, 20 lights → up to 20 free variables\n    const nLights = 20;\n    const nButtons = 40;\n    const buttons: number[][] = [];\n    for (let j = 0; j < nButtons; j++) {\n      const affected: number[] = [];\n      for (let i = 0; i < nLights; i++) {\n        // Deterministic pattern: button j affects light i if bit i of j is set\n        if ((j >> i) & 1) affected.push(i);\n      }\n      if (affected.length === 0) affected.push(0);\n      buttons.push(affected);\n    }\n    const target = new Array(nLights).fill(true);\n    const machine: Machine = { target, buttons };\n    const start = Date.now();\n    const result = solveToggle(machine);\n    const elapsed = Date.now() - start;\n    expect(elapsed).toBeLessThan(5000);\n    if (result !== null) {\n      expect(verifyToggle(machine, result)).toBe(true);\n    }\n  });\n});\n\ndescribe('solveCounter - larger cases', () => {\n  it('handles 10 counters, 10 buttons, modulus 5', () => {\n    const n = 10;\n    const p = 5;\n    const buttons = Array.from({ length: n }, (_, i) => [i]);\n    const targets = [1, 2, 3, 4, 0, 1, 2, 3, 4, 0];\n    const result = solveCounter(targets, buttons, p)!;\n    expect(result).not.toBeNull();\n    expect(verifyCounter(targets, buttons, p, result)).toBe(true);\n    expect(result).toEqual([1, 2, 3, 4, 0, 1, 2, 3, 4, 0]);\n  });\n\n  it('handles overlapping buttons with modulus 7', () => {\n    const buttons = [[0, 1], [1, 2], [0, 2]];\n    const targets = [3, 5, 2];\n    const p = 7;\n    const result = solveCounter(targets, buttons, p);\n    if (result !== null) {\n      expect(verifyCounter(targets, buttons, p, result)).toBe(true);\n    }\n  });\n\n  it('performance: 40 buttons, 40 counters, modulus 97 (diagonal)', () => {\n    const n = 40;\n    const p = 97;\n    const buttons = Array.from({ length: n }, (_, i) => [i]);\n    const targets = Array.from({ length: n }, (_, i) => (i * 7 + 3) % p);\n    const start = Date.now();\n    const result = solveCounter(targets, buttons, p)!;\n    const elapsed = Date.now() - start;\n    expect(elapsed).toBeLessTha