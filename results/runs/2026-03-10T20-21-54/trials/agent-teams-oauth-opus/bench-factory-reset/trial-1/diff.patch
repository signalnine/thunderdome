+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+// ─── GF(2) Toggle Solver ────────────────────────────────────────────
+
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const nLights = target.length;
+  const nButtons = buttons.length;
+
+  if (nButtons === 0) {
+    return target.every(t => !t) ? [] : null;
+  }
+  if (nLights === 0) {
+    return [];
+  }
+
+  // Build augmented matrix [A | b] over GF(2)
+  // A[i][j] = 1 if button j toggles light i
+  const nCols = nButtons + 1;
+  const mat: Uint8Array[] = [];
+  for (let i = 0; i < nLights; i++) {
+    const row = new Uint8Array(nCols);
+    for (let j = 0; j < nButtons; j++) {
+      if (buttons[j].indexOf(i) !== -1) {
+        row[j] = 1;
+      }
+    }
+    row[nButtons] = target[i] ? 1 : 0;
+    mat.push(row);
+  }
+
+  // Gaussian elimination → RREF over GF(2)
+  const pivotCols: number[] = [];
+  const pivotRowOf = new Int8Array(nButtons).fill(-1);
+  let curRow = 0;
+
+  for (let col = 0; col < nButtons && curRow < nLights; col++) {
+    let pivR = -1;
+    for (let r = curRow; r < nLights; r++) {
+      if (mat[r][col]) { pivR = r; break; }
+    }
+    if (pivR === -1) continue;
+
+    if (pivR !== curRow) {
+      [mat[curRow], mat[pivR]] = [mat[pivR], mat[curRow]];
+    }
+
+    for (let r = 0; r < nLights; r++) {
+      if (r !== curRow && mat[r][col]) {
+        for (let c = col; c < nCols; c++) {
+          mat[r][c] ^= mat[curRow][c];
+        }
+      }
+    }
+
+    pivotCols.push(col);
+    pivotRowOf[col] = curRow;
+    curRow++;
+  }
+
+  const rank = pivotCols.length;
+
+  // Check consistency
+  for (let r = rank; r < nLights; r++) {
+    if (mat[r][nButtons]) return null;
+  }
+
+  // Identify free variables
+  const freeVars: number[] = [];
+  for (let col = 0; col < nButtons; col++) {
+    if (pivotRowOf[col] === -1) freeVars.push(col);
+  }
+  const kFree = freeVars.length;
+
+  if (kFree === 0) {
+    const result: number[] = [];
+    for (let i = 0; i < rank; i++) {
+      if (mat[i][nButtons]) result.push(pivotCols[i]);
+    }
+    return result.sort((a, b) => a - b);
+  }
+
+  // Precompute pivot dependencies on free variables
+  // pivotConst[i]: value of pivot i when all free vars = 0
+  // freeAffectsPivots[fi]: list of pivot indices affected by free var fi
+  const pivotConst = new Uint8Array(rank);
+  const freeAffectsPivots: number[][] = Array.from({ length: kFree }, () => []);
+
+  for (let i = 0; i < rank; i++) {
+    pivotConst[i] = mat[i][nButtons];
+    for (let fi = 0; fi < kFree; fi++) {
+      if (mat[i][freeVars[fi]]) {
+        freeAffectsPivots[fi].push(i);
+      }
+    }
+  }
+
+  if (kFree <= 25) {
+    return toggleEnumerate(kFree, rank, pivotConst, freeAffectsPivots, pivotCols, freeVars, nButtons);
+  } else {
+    return toggleMITM(kFree, rank, pivotConst, freeAffectsPivots, pivotCols, freeVars, nButtons);
+  }
+}
+
+/** Compare two solutions represented as BigInt bitmasks.
+ *  Returns < 0 if a is lex-smaller, > 0 if b is, 0 if equal. */
+function compareBitmasks(a: bigint, b: bigint): number {
+  if (a === b) return 0;
+  const diff = a ^ b;
+  const lowest = diff & (-diff);
+  return (a & lowest) ? -1 : 1;
+}
+
+function buildBitmask(
+  pivotValues: Uint8Array,
+  freeValues: Uint8Array,
+  pivotCols: number[],
+  freeVars: number[],
+): bigint {
+  let mask = 0n;
+  for (let i = 0; i < pivotValues.length; i++) {
+    if (pivotValues[i]) mask |= 1n << BigInt(pivotCols[i]);
+  }
+  for (let i = 0; i < freeValues.length; i++) {
+    if (freeValues[i]) mask |= 1n << BigInt(freeVars[i]);
+  }
+  return mask;
+}
+
+function bitmaskToResult(mask: bigint, nButtons: number): number[] {
+  const result: number[] = [];
+  for (let i = 0; i < nButtons; i++) {
+    if ((mask >> BigInt(i)) & 1n) result.push(i);
+  }
+  return result;
+}
+
+/** Gray-code enumeration for kFree ≤ 25. */
+function toggleEnumerate(
+  kFree: number,
+  rank: number,
+  pivotConst: Uint8Array,
+  freeAffectsPivots: number[][],
+  pivotCols: number[],
+  freeVars: number[],
+  nButtons: number,
+): number[] {
+  const pivotValues = new Uint8Array(rank);
+  const freeValues = new Uint8Array(kFree);
+  let pivotWeight = 0;
+  for (let i = 0; i < rank; i++) {
+    pivotValues[i] = pivotConst[i];
+    pivotWeight += pivotConst[i];
+  }
+  let freeWeight = 0;
+  let bestWeight = pivotWeight; // freeWeight = 0 initially
+  let bestMask = buildBitmask(pivotValues, freeValues, pivotCols, freeVars);
+
+  const total = 1 << kFree;
+  for (let i = 1; i < total; i++) {
+    const lsb = i & -i;
+    const fi = 31 - Math.clz32(lsb);
+
+    if (freeValues[fi]) {
+      freeValues[fi] = 0;
+      freeWeight--;
+    } else {
+      freeValues[fi] = 1;
+      freeWeight++;
+    }
+
+    for (const pi of freeAffectsPivots[fi]) {
+      if (pivotValues[pi]) {
+        pivotValues[pi] = 0;
+        pivotWeight--;
+      } else {
+        pivotValues[pi] = 1;
+        pivotWeight++;
+      }
+    }
+
+    const w = freeWeight + pivotWeight;
+    if (w < bestWeight) {
+      bestWeight = w;
+      bestMask = buildBitmask(pivotValues, freeValues, pivotCols, freeVars);
+    } else if (w === bestWeight) {
+      const mask = buildBitmask(pivotValues, freeValues, pivotCols, freeVars);
+      if (compareBitmasks(mask, bestMask) < 0) {
+        bestMask = mask;
+      }
+    }
+  }
+
+  return bitmaskToResult(bestMask, nButtons);
+}
+
+/** Meet-in-the-middle for kFree > 25 (implies nPivot < 15). */
+function toggleMITM(
+  kFree: number,
+  rank: number,
+  pivotConst: Uint8Array,
+  freeAffectsPivots: number[][],
+  pivotCols: number[],
+  freeVars: number[],
+  nButtons: number,
+): number[] | null {
+  // pivotDepMask[fi] = bitmask of which pivots are affected by free var fi
+  const pivotDepMask = new Uint32Array(kFree);
+  for (let fi = 0; fi < kFree; fi++) {
+    let mask = 0;
+    for (const pi of freeAffectsPivots[fi]) {
+      mask |= 1 << pi;
+    }
+    pivotDepMask[fi] = mask;
+  }
+
+  // initPivotMask = bitmask of pivot values when all free vars = 0
+  let initPivotMask = 0;
+  for (let i = 0; i < rank; i++) {
+    if (pivotConst[i]) initPivotMask |= 1 << i;
+  }
+
+  const k1 = Math.floor(kFree / 2);
+  const k2 = kFree - k1;
+
+  type HalfEntry = { contrib: number; weight: number; mask: bigint };
+
+  function enumerateHalf(startFi: number, count: number): Map<number, HalfEntry> {
+    const best = new Map<number, HalfEntry>();
+    const total = 1 << count;
+    for (let assign = 0; assign < total; assign++) {
+      let contrib = 0;
+      let weight = 0;
+      let mask = 0n;
+      for (let b = 0; b < count; b++) {
+        if (assign & (1 << b)) {
+          weight++;
+          contrib ^= pivotDepMask[startFi + b];
+          mask |= 1n << BigInt(freeVars[startFi + b]);
+        }
+      }
+      const existing = best.get(contrib);
+      if (!existing || weight < existing.weight ||
+          (weight === existing.weight && compareBitmasks(mask, existing.mask) < 0)) {
+        best.set(contrib, { contrib, weight, mask });
+      }
+    }
+    return best;
+  }
+
+  const half1 = enumerateHalf(0, k1);
+  const half2 = enumerateHalf(k1, k2);
+
+  let bestWeight = Infinity;
+  let bestMask = 0n;
+
+  for (const [c1, e1] of half1) {
+    for (const [c2, e2] of half2) {
+      const finalPivot = initPivotMask ^ c1 ^ c2;
+      const pivotWeight = popcount32(finalPivot);
+      const w = e1.weight + e2.weight + pivotWeight;
+      if (w < bestWeight) {
+        bestWeight = w;
+        // Build full bitmask: free vars from both halves + pivot vars
+        let pivMask = 0n;
+        for (let pi = 0; pi < rank; pi++) {
+          if (finalPivot & (1 << pi)) {
+            pivMask |= 1n << BigInt(pivotCols[pi]);
+          }
+        }
+        bestMask = e1.mask | e2.mask | pivMask;
+      } else if (w === bestWeight) {
+        let pivMask = 0n;
+        for (let pi = 0; pi < rank; pi++) {
+          if (finalPivot & (1 << pi)) {
+            pivMask |= 1n << BigInt(pivotCols[pi]);
+          }
+        }
+        const mask = e1.mask | e2.mask | pivMask;
+        if (compareBitmasks(mask, bestMask) < 0) {
+          bestMask = mask;
+        }
+      }
+    }
+  }
+
+  if (bestWeight === Infinity) return [];
+  return bitmaskToResult(bestMask, nButtons);
+}
+
+function popcount32(n: number): number {
+  n = n - ((n >> 1) & 0x55555555);
+  n = (n & 0x33333333) + ((n >> 2) & 0x33333333);
+  return (((n + (n >> 4)) & 0x0f0f0f0f) * 0x01010101) >> 24;
+}
+
+// ─── GF(p) Counter Solver ───────────────────────────────────────────
+
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number,
+): number[] | null {
+  const nCounters = lights.length;
+  const nButtons = buttons.length;
+
+  if (nButtons === 0) {
+    return lights.every(v => v === 0) ? [] : null;
+  }
+  if (nCounters === 0) {
+    return new Array(nButtons).fill(0);
+  }
+
+  const p = modulus;
+
+  // Build augmented matrix [A | b] over GF(p)
+  // A[i][j] = 1 if button j affects counter i, else 0
+  const nCols = nButtons + 1;
+  const mat: number[][] = [];
+  for (let i = 0; i < nCounters; i++) {
+    const row = new Array(nCols).fill(0);
+    for (let j = 0; j < nButtons; j++) {
+      if (buttons[j].indexOf(i) !== -1) {
+        row[j] = 1;
+      }
+    }
+    row[nButtons] = lights[i] % p;
+    mat.push(row);
+  }
+
+  // Gaussian elimination over GF(p)
+  const pivotCols: number[] = [];
+  const pivotRowOf = new Int8Array(nButtons).fill(-1);
+  let curRow = 0;
+
+  for (let col = 0; col < nButtons && curRow < nCounters; col++) {
+    let pivR = -1;
+    for (let r = curRow; r < nCounters; r++) {
+      if (mat[r][col] !== 0) { pivR = r; break; }
+    }
+    if (pivR === -1) continue;
+
+    if (pivR !== curRow) {
+      [mat[curRow], mat[pivR]] = [mat[pivR], mat[curRow]];
+    }
+
+    // Normalize pivot row: multiply by inverse of pivot element
+    const pivVal = mat[curRow][col];
+    const inv = modInverse(pivVal, p);
+    for (let c = col; c < nCols; c++) {
+      mat[curRow][c] = (mat[curRow][c] * inv) % p;
+    }
+
+    // Eliminate column from all other rows
+    for (let r = 0; r < nCounters; r++) {
+      if (r !== curRow && mat[r][col] !== 0) {
+        const factor = mat[r][col];
+        for (let c = col; c < nCols; c++) {
+          mat[r][c] = ((mat[r][c] - factor * mat[curRow][c]) % p + p) % p;
+        }
+      }
+    }
+
+    pivotCols.push(col);
+    pivotRowOf[col] = curRow;
+    curRow++;
+  }
+
+  const rank = pivotCols.length;
+
+  // Consistency check
+  for (let r = rank; r < nCounters; r++) {
+    if (mat[r][nButtons] !== 0) return null;
+  }
+
+  // Identify free variables
+  const freeVars: number[] = [];
+  for (let col = 0; col < nButtons; col++) {
+    if (pivotRowOf[col] === -1) freeVars.push(col);
+  }
+  const kFree = freeVars.length;
+
+  // Precompute: for each pivot row i, the coefficient of each free variable
+  // pivotCoeffs[i][fi] = mat[i][freeVars[fi]]
+  // pivotRHS[i] = mat[i][nButtons]
+  // Pivot value = (pivotRHS[i] - sum(pivotCoeffs[i][fi] * freeVal[fi])) mod p
+  const pivotRHS = new Uint8Array(rank);
+  const pivotCoeffs: number[][] = [];
+  for (let i = 0; i < rank; i++) {
+    pivotRHS[i] = mat[i][nButtons];
+    const coeffs = new Array(kFree);
+    for (let fi = 0; fi < kFree; fi++) {
+      coeffs[fi] = mat[i][freeVars[fi]];
+    }
+    pivotCoeffs.push(coeffs);
+  }
+
+  if (kFree === 0) {
+    const result = new Array(nButtons).fill(0);
+    for (let i = 0; i < rank; i++) {
+      result[pivotCols[i]] = pivotRHS[i];
+    }
+    return result;
+  }
+
+  // Estimate total enumeration size
+  let totalEnum = 1;
+  let overflow = false;
+  for (let i = 0; i < kFree; i++) {
+    totalEnum *= p;
+    if (totalEnum > 8_000_000) { overflow = true; break; }
+  }
+
+  if (!overflow) {
+    return counterEnumerate(p, kFree, rank, nButtons, pivotCols, pivotRHS, pivotCoeffs, freeVars);
+  } else {
+    return counterBranchAndBound(p, kFree, rank, nButtons, pivotCols, pivotRHS, pivotCoeffs, freeVars);
+  }
+}
+
+function modInverse(a: number, p: number): number {
+  // Extended Euclidean algorithm
+  let [old_r, r] = [a % p, p];
+  let [old_s, s] = [1, 0];
+  while (r !== 0) {
+    const q = Math.floor(old_r / r);
+    [old_r, r] = [r, old_r - q * r];
+    [old_s, s] = [s, old_s - q * s];
+  }
+  return ((old_s % p) + p) % p;
+}
+
+/** Direct enumeration for counter problem with small p^kFree. */
+function counterEnumerate(
+  p: number,
+  kFree: number,
+  rank: number,
+  nButtons: number,
+  pivotCols: number[],
+  pivotRHS: Uint8Array,
+  pivotCoeffs: number[][],
+  freeVars: number[],
+): number[] {
+  // Enumerate all p^kFree assignments of free variables
+  const freeVals = new Uint8Array(kFree); // all start at 0
+  const pivotVals = new Uint8Array(rank);
+
+  // Compute initial pivot values (all free vars = 0)
+  for (let i = 0; i < rank; i++) {
+    pivotVals[i] = pivotRHS[i];
+  }
+
+  let bestWeight = Infinity;
+  let bestResult: number[] | null = null;
+
+  function computeResult(): number[] {
+    const result = new Array(nButtons).fill(0);
+    for (let i = 0; i < rank; i++) {
+      result[pivotCols[i]] = pivotVals[i];
+    }
+    for (let fi = 0; fi < kFree; fi++) {
+      result[freeVars[fi]] = freeVals[fi];
+    }
+    return result;
+  }
+
+  function computeWeight(): number {
+    let w = 0;
+    for (let i = 0; i < rank; i++) w += pivotVals[i];
+    for (let fi = 0; fi < kFree; fi++) w += freeVals[fi];
+    return w;
+  }
+
+  function lexCompare(a: number[], b: number[]): number {
+    for (let i = 0; i < a.length; i++) {
+      if (a[i] !== b[i]) return a[i] - b[i];
+    }
+    return 0;
+  }
+
+  // Enumerate using odometer pattern (base-p counter)
+  const totalEnum = Math.pow(p, kFree);
+
+  for (let idx = 0; idx < totalEnum; idx++) {
+    if (idx > 0) {
+      // Increment the counter: find the rightmost digit to increment
+      let carry = kFree - 1;
+      while (carry >= 0) {
+        const oldVal = freeVals[carry];
+        const newVal = oldVal + 1;
+        if (newVal < p) {
+          freeVals[carry] = newVal;
+          // Update pivot values: each pivot changes by -coeff mod p
+          for (let pi = 0; pi < rank; pi++) {
+            if (pivotCoeffs[pi][carry]) {
+              pivotVals[pi] = (pivotVals[pi] - pivotCoeffs[pi][carry] + p) % p;
+            }
+          }
+          break;
+        } else {
+          // Wrap around: val goes from p-1 to 0, change = -(p-1) ≡ +1
+          freeVals[carry] = 0;
+          for (let pi = 0; pi < rank; pi++) {
+            if (pivotCoeffs[pi][carry]) {
+              pivotVals[pi] = (pivotVals[pi] + pivotCoeffs[pi][carry] * (p - 1)) % p;
+            }
+          }
+          carry--;
+        }
+      }
+    }
+
+    const w = computeWeight();
+    if (w < bestWeight) {
+      bestWeight = w;
+      bestResult = computeResult();
+    } else if (w === bestWeight) {
+      const result = computeResult();
+      if (lexCompare(result, bestResult!) < 0) {
+        bestResult = result;
+      }
+    }
+  }
+
+  return bestResult!;
+}
+
+/** Branch and bound for counter problem with large p^kFree. */
+function counterBranchAndBound(
+  p: number,
+  kFree: number,
+  rank: number,
+  nButtons: number,
+  pivotCols: number[],
+  pivotRHS: Uint8Array,
+  pivotCoeffs: number[][],
+  freeVars: number[],
+): number[] {
+  // Precompute: for each pivot, the highest free var index affecting it
+  const lastFreeAffecting = new Int8Array(rank).fill(-1);
+  for (let pi = 0; pi < rank; pi++) {
+    for (let fi = kFree - 1; fi >= 0; fi--) {
+      if (pivotCoeffs[pi][fi]) {
+        lastFreeAffecting[pi] = fi;
+        break;
+      }
+    }
+  }
+
+  // First find a good upper bound using greedy approach
+  const greedyFree = new Uint8Array(kFree);
+  let bestWeight = computeTotalWeight(p, kFree, rank, pivotRHS, pivotCoeffs, greedyFree);
+
+  // Greedy: for each free variable, try all p values and pick the best
+  let improved = true;
+  while (improved) {
+    improved = false;
+    for (let fi = 0; fi < kFree; fi++) {
+      let bestVal = greedyFree[fi];
+      let bestW = bestWeight;
+      const origVal = greedyFree[fi];
+      for (let v = 0; v < p; v++) {
+        greedyFree[fi] = v;
+        const w = computeTotalWeight(p, kFree, rank, pivotRHS, pivotCoeffs, greedyFree);
+        if (w < bestW) {
+          bestW = w;
+          bestVal = v;
+        }
+      }
+      if (bestVal !== origVal) {
+        greedyFree[fi] = bestVal;
+        bestWeight = bestW;
+        improved = true;
+      } else {
+        greedyFree[fi] = origVal;
+      }
+    }
+  }
+
+  // Build the best result from greedy
+  let bestResult = buildCounterResult(p, kFree, rank, nButtons, pivotCols, pivotRHS, pivotCoeffs, freeVars, greedyFree);
+
+  // Branch and bound DFS
+  const currentFree = new Uint8Array(kFree);
+  const currentPivots = new Uint8Array(rank);
+  const savedPivotsStack: Uint8Array[] = [];
+  for (let i = 0; i < kFree; i++) savedPivotsStack.push(new Uint8Array(rank));
+
+  function dfs(fi: number, freeSum: number): void {
+    for (let v = 0; v < p; v++) {
+      // Basic monotonic pruning: freeSum + v only increases with v
+      if (freeSum + v > bestWeight) break;
+
+      currentFree[fi] = v;
+
+      // Save and update pivots
+      const saved = savedPivotsStack[fi];
+      saved.set(currentPivots);
+      for (let pi = 0; pi < rank; pi++) {
+        if (pivotCoeffs[pi][fi]) {
+          currentPivots[pi] = ((currentPivots[pi] - pivotCoeffs[pi][fi] * v % p) % p + p) % p;
+        }
+      }
+
+      // Tighter lower bound: add determined pivot values
+      let lb = freeSum + v;
+      for (let pi = 0; pi < rank; pi++) {
+        if (lastFreeAffecting[pi] <= fi) {
+          lb += currentPivots[pi];
+        }
+      }
+      if (lb > bestWeight) {
+        currentPivots.set(saved);
+        continue; // Don't break: different v may give lower pivot values
+      }
+
+      if (fi === kFree - 1) {
+        // All pivots are determined now, lb is the exact weight
+        if (lb < bestWeight) {
+          bestWeight = lb;
+          bestResult = buildCounterResult(p, kFree, rank, nButtons, pivotCols, pivotRHS, pivotCoeffs, freeVars, currentFree);
+        } else if (lb === bestWeight) {
+          const result = buildCounterResult(p, kFree, rank, nButtons, pivotCols, pivotRHS, pivotCoeffs, freeVars, currentFree);
+          if (lexCompareArrays(result, bestResult!) < 0) {
+            bestResult = result;
+          }
+        }
+      } else {
+        dfs(fi + 1, freeSum + v);
+      }
+
+      currentPivots.set(saved);
+    }
+    currentFree[fi] = 0;
+  }
+
+  // Initialize currentPivots for all free vars = 0
+  for (let i = 0; i < rank; i++) {
+    currentPivots[i] = pivotRHS[i];
+  }
+
+  dfs(0, 0);
+
+  return bestResult!;
+}
+
+function computeTotalWeight(
+  p: number,
+  kFree: number,
+  rank: number,
+  pivotRHS: Uint8Array,
+  pivotCoeffs: number[][],
+  freeVals: Uint8Array,
+): number {
+  let w = 0;
+  for (let fi = 0; fi < kFree; fi++) w += freeVals[fi];
+  for (let i = 0; i < rank; i++) {
+    let pv = pivotRHS[i];
+    for (let fi = 0; fi < kFree; fi++) {
+      if (pivotCoeffs[i][fi] && freeVals[fi]) {
+        pv = ((pv - pivotCoeffs[i][fi] * freeVals[fi]) % p + p) % p;
+      }
+    }
+    w += pv;
+  }
+  return w;
+}
+
+function buildCounterResult(
+  p: number,
+  kFree: number,
+  rank: number,
+  nButtons: number,
+  pivotCols: number[],
+  pivotRHS: Uint8Array,
+  pivotCoeffs: number[][],
+  freeVars: number[],
+  freeVals: Uint8Array,
+): number[] {
+  const result = new Array(nButtons).fill(0);
+  for (let fi = 0; fi < kFree; fi++) {
+    result[freeVars[fi]] = freeVals[fi];
+  }
+  for (let i = 0; i < rank; i++) {
+    let pv = pivotRHS[i];
+    for (let fi = 0; fi < kFree; fi++) {
+      if (pivotCoeffs[i][fi] && freeVals[fi]) {
+        pv = ((pv - pivotCoeffs[i][fi] * freeVals[fi]) % p + p) % p;
+      }
+    }
+    result[pivotCols[i]] = pv;
+  }
+  return result;
+}
+
+function lexCompareArrays(a: number[], b: number[]): number {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] !== b[i]) return a[i] - b[i];
+  }
+  return 0;
+}
