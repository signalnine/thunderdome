 freeAffectsPivots, pivotCols, freeVars, nButtons);\n   105→  }\n   106→}\n   107→\n   108→/** Compare two solutions represented as BigInt bitmasks.\n   109→ *  Returns < 0 if a is lex-smaller, > 0 if b is, 0 if equal. */\n   110→function compareBitmasks(a: bigint, b: bigint): number {\n   111→  if (a === b) return 0;\n   112→  const diff = a ^ b;\n   113→  const lowest = diff & (-diff);\n   114→  return (a & lowest) ? -1 : 1;\n   115→}\n   116→\n   117→function buildBitmask(\n   118→  pivotValues: Uint8Array,\n   119→  freeValues: Uint8Array,\n   120→  pivotCols: number[],\n   121→  freeVars: number[],\n   122→): bigint {\n   123→  let mask = 0n;\n   124→  for (let i = 0; i < pivotValues.length; i++) {\n   125→    if (pivotValues[i]) mask |= 1n << BigInt(pivotCols[i]);\n   126→  }\n   127→  for (let i = 0; i < freeValues.length; i++) {\n   128→    if (freeValues[i]) mask |= 1n << BigInt(freeVars[i]);\n   129→  }\n   130→  return mask;\n   131→}\n   132→\n   133→function bitmaskToResult(mask: bigint, nButtons: number): number[] {\n   134→  const result: number[] = [];\n   135→  for (let i = 0; i < nButtons; i++) {\n   136→    if ((mask >> BigInt(i)) & 1n) result.push(i);\n   137→  }\n   138→  return result;\n   139→}\n   140→\n   141→/** Gray-code enumeration for kFree ≤ 25. */\n   142→function toggleEnumerate(\n   143→  kFree: number,\n   144→  rank: number,\n   145→  pivotConst: Uint8Array,\n   146→  freeAffectsPivots: number[][],\n   147→  pivotCols: number[],\n   148→  freeVars: number[],\n   149→  nButtons: number,\n   150→): number[] {\n   151→  const pivotValues = new Uint8Array(rank);\n   152→  const freeValues = new Uint8Array(kFree);\n   153→  let pivotWeight = 0;\n   154→  for (let i = 0; i < rank; i++) {\n   155→    pivotValues[i] = pivotConst[i];\n   156→    pivotWeight += pivotConst[i];\n   157→  }\n   158→  let freeWeight = 0;\n   159→  let bestWeight = pivotWeight; // freeWeight = 0 initially\n   160→  let bestMask = buildBitmask(pivotValues, freeVal