n        greedyFree[fi] = v;\n        const w = computeTotalWeight(p, kFree, rank, pivotRHS, pivotCoeffs, greedyFree);\n        if (w < bestW) {\n          bestW = w;\n          bestVal = v;\n        }\n      }\n      if (bestVal !== origVal) {\n        greedyFree[fi] = bestVal;\n        bestWeight = bestW;\n        improved = true;\n      } else {\n        greedyFree[fi] = origVal;\n      }\n    }\n  }\n\n  // Build the best result from greedy\n  let bestResult = buildCounterResult(p, kFree, rank, nButtons, pivotCols, pivotRHS, pivotCoeffs, freeVars, greedyFree);\n\n  // Branch and bound DFS\n  const currentFree = new Uint8Array(kFree);\n  const currentPivots = new Uint8Array(rank);\n  const savedPivotsStack: Uint8Array[] = [];\n  for (let i = 0; i < kFree; i++) savedPivotsStack.push(new Uint8Array(rank));\n\n  function dfs(fi: number, freeSum: number): void {\n    for (let v = 0; v < p; v++) {\n      // Basic monotonic pruning: freeSum + v only increases with v\n      if (freeSum + v > bestWeight) break;\n\n      currentFree[fi] = v;\n\n      // Save and update pivots\n      const saved = savedPivotsStack[fi];\n      saved.set(currentPivots);\n      for (let pi = 0; pi < rank; pi++) {\n        if (pivotCoeffs[pi][fi]) {\n          currentPivots[pi] = ((currentPivots[pi] - pivotCoeffs[pi][fi] * v % p) % p + p) % p;\n        }\n      }\n\n      // Tighter lower bound: add determined pivot values\n      let lb = freeSum + v;\n      for (let pi = 0; pi < rank; pi++) {\n        if (lastFreeAffecting[pi] <= fi) {\n          lb += currentPivots[pi];\n        }\n      }\n      if (lb > bestWeight) {\n        currentPivots.set(saved);\n        continue; // Don't break: different v may give lower pivot values\n      }\n\n      if (fi === kFree - 1) {\n        // All pivots are determined now, lb is the exact weight\n        if (lb < bestWeight) {\n          bestWeight = lb;\n          bestResult = buildCounterResult(p, kFree, rank, nButtons, pivotCols, pivotRHS, pivotCoeffs