OR b3 XOR b4\n    // Weight 1 solutions: need exactly 1 button pressed\n    //   b4=1, rest 0: b0 = 1 XOR 0 XOR 1 = 0, b2 = 1 XOR 0 XOR 1 = 0. Total = 0+0+0+0+1 = 1. Pressed=[4]\n    // Weight 2 solutions: 2 buttons pressed, e.g., b1=1,b3=1: b0=0,b2=0. Total=0+1+0+1+0=2. Pressed=[1,3]\n    // Min weight=1, result=[4]\n    const machine: Machine = {\n      target: [true, true],\n      buttons: [[0], [0], [1], [1], [0, 1]],\n    };\n    expect(solveToggle(machine)).toEqual([4]);\n  });\n\ndescribe('solveCounter', () => {","originalFile":"import { describe, it, expect } from 'vitest';\nimport { solveToggle, solveCounter, Machine } from './index.js';\n\ndescribe('solveToggle', () => {\n  it('returns [] when target is all false', () => {\n    const machine: Machine = {\n      target: [false, false, false],\n      buttons: [[0, 1], [1, 2]],\n    };\n    expect(solveToggle(machine)).toEqual([]);\n  });\n\n  it('returns null when no solution exists', () => {\n    // From the example in TASK.md\n    const machine: Machine = {\n      target: [true, true, false, true],\n      buttons: [[0, 1], [1, 2, 3], [0, 3]],\n    };\n    expect(solveToggle(machine)).toBeNull();\n  });\n\n  it('solves simple single button', () => {\n    const machine: Machine = {\n      target: [true],\n      buttons: [[0]],\n    };\n    expect(solveToggle(machine)).toEqual([0]);\n  });\n\n  it('solves with minimum presses', () => {\n    // Two buttons both toggle light 0.\n    // Target: light 0 on.\n    // Button 0 toggles [0], Button 1 toggles [0].\n    // Solutions: press {0} or press {1}. Both have 1 press.\n    // Lex smallest: [0].\n    const machine: Machine = {\n      target: [true],\n      buttons: [[0], [0]],\n    };\n    expect(solveToggle(machine)).toEqual([0]);\n  });\n\n  it('prefers fewer presses over lex order', () => {\n    // 2 lights, 3 buttons\n    // Button 0: toggles [0, 1]\n    // Button 1: toggles [0]\n    // Button 2: toggles [1]\n    // Target: [true, true]\n    // Solution {0} has 1 press. Solutions {1,2} has 2 presses.\n    // Minimum is {0}.\n    const machine: Machine = {\n      target: [true, true],\n      buttons: [[0, 1], [0], [1]],\n    };\n    expect(solveToggle(machine)).toEqual([0]);\n  });\n\n  it('handles 0 buttons with all-false target', () => {\n    expect(solveToggle({ target: [false], buttons: [] })).toEqual([]);\n  });\n\n  it('handles 0 buttons with non-false target', () => {\n    expect(solveToggle({ target: [true], buttons: [] })).toBeNull();\n  });\n\n  it('handles 0 lights', () => {\n    expect(solveToggle({ target: [], buttons: [[]] })).toEqual([]);\n  });\n\n  it('solves a 4-light puzzle', () => {\n    // 4 lights, 4 buttons\n    // Button 0: [0]\n    // Button 1: [1]\n    // Button 2: [2]\n    // Button 3: [3]\n    // Target: [true, false, true, false]\n    // Solution: press 0 and 2\n    const machine: Machine = {\n      target: [true, false, true, false],\n      buttons: [[0], [1], [2], [3]],\n    };\n    expect(solveToggle(machine)).toEqual([0, 2]);\n  });\n\n  it('handles overlapping buttons', () => {\n    // 3 lights, 3 buttons\n    // Button 0: [0, 1]\n    // Button 1: [1, 2]\n    // Button 2: [0, 2]\n    // Target: [true, false, true]\n    // Pressing all 3: light 0 toggled by 0,2 (even → off), light 1 toggled by 0,1 (even → off), light 2 toggled by 1,2 (even → off) = [F,F,F]\n    // Button 2 alone: toggles [0, 2] → [T, F, T] ✓ (1 press, better than {0,1} with 2 presses)\n    const machine: Machine = {\n      target: [true, false, true],\n      buttons: [[0, 1], [1, 2], [0, 2]],\n    };\n    expect(solveToggle(machine)).toEqual([2]);\n  });\n\n  it('returns lex smallest when tied on press count', () => {\n    // 2 lights, 4 buttons\n    // Button 0: [0]\n    // Button 1: [0]\n    // Button 2: [1]\n    // Button 3: [1]\n    // Target: [true, true]\n    // Solutions with 2 presses: {0,2}, {0,3}, {1,2}, {1,3}\n    // Lex smallest: [0, 2]\n    const machine: Machine = {\n      target: [true, true],\n      buttons: [[0], [0], [1], [1]],\n    };\n    expect(solveToggle(machine)).toEqual([0, 2]);\n  });\n});\n\ndescribe('solveCounter', () => {\n  it('returns all zeros when target is all zero', () => {\n    expect(solveCounter([0, 0], [[0], [1]], 3)).toEqual([0, 0]);\n  });\n\n  it('returns null when no solution exists', () => {\n    // 1 counter, 1 button, modulus 3\n    // Button 0 affects counter 0\n    // Target: counter 0 = 2\n    // Press button 0 twice → 2. Should work.\n    // Actually let me make a truly unsolvable one:\n    // 1 counter, 0 buttons, target = 1\n    expect(solveCounter([1], [], 3)).toBeNull();\n  });\n\n  it('solves simple single button', () => {\n    // 1 counter, 1 button, modulus 5\n    // Button 0 affects counter 0\n    // Target: 3\n    // Press 3 times.\n    expect(solveCounter([3], [[0]], 5)).toEqual([3]);\n  });\n\n  it('solves with minimum total presses', () => {\n    // 1 counter, 2 buttons both affect counter 0, modulus 5\n    // Target: 2\n    // Options: (2,0) total=2, (1,1) total=2, (0,2) total=2\n    // Also (3,4) total=7, etc.\n    // Lex smallest with total=2: [0, 2]\n    expect(solveCounter([2], [[0], [0]], 5)).toEqual([0, 2]);\n  });\n\n  it('handles modular arithmetic', () => {\n    // 1 counter, 1 button, modulus 5\n    // Button 0 affects counter 0\n    // Target: 0\n    // Press 0 times (total = 0) or 5 times (but max is p-1=4)\n    // Minimum: 0 presses.\n    expect(solveCounter([0], [[0]], 5)).toEqual([0]);\n  });\n\n  it('solves 2-counter puzzle', () => {\n    // 2 counters, 2 buttons, modulus 3\n    // Button 0: affects [0]\n    // Button 1: affects [1]\n    // Target: [1, 2]\n    expect(solveCounter([1, 2], [[0], [1]], 3)).toEqual([1, 2]);\n  });\n\n  it('handles overlapping buttons', () => {\n    // 2 counters, 2 buttons, modulus 3\n    // Button 0: affects [0, 1]\n    // Button 1: affects [1]\n    // Target: [1, 0]\n    // Equations: b0 ≡ 1 (mod 3), b0 + b1 ≡ 0 (mod 3)\n    // b0 = 1, b1 = (0 - 1) mod 3 = 2\n    // Total = 3\n    expect(solveCounter([1, 0], [[0, 1], [1]], 3)).toEqual([1, 2]);\n  });\n\n  it('returns null for inconsistent system', () => {\n    // 2 counters, 1 button, modulus 3\n    // Button 0: affects [0, 1]\n    // Target: [1, 2]\n    // Equations: b0 ≡ 1 (mod 3) and b0 ≡ 2 (mod 3). Inconsistent!\n    expect(solveCounter([1, 2], [[0, 1]], 3)).toBeNull();\n  });\n\n  it('handles 0 counters', () => {\n    expect(solveCounter([], [[0]], 3)).toEqual([0]);\n  });\n\n  it('returns lex smallest when tied on total presses', () => {\n    // 2 counters, 3 buttons, modulus 5\n    // Button 0: [0]\n    // Button 1: [0]\n    // Button 2: [1]\n    // Target: [1, 1]\n    // Counter 0: b0 + b1 ≡ 1 (mod 5)\n    // Counter 1: b2 ≡ 1 (mod 5) → b2 = 1\n    // For counter 0: b0 + b1 ≡ 1 (mod 5). Minimize b0 + b1 + b2 = b0 + b1 + 1.\n    // Min b0+b1 with b0+b1≡1(mod 5): 1 (e.g., (0,1), (1,0)).\n    // Lex smallest result with [_, _, 1] and b0+b1=1: [0, 1, 1]\n    expect(solveCounter([1, 1], [[0], [0], [1]], 5)).toEqual([0, 1, 1]);\n  });\n});\n","structuredPatch":[{"oldStart":114,"oldLines":6,"newStart":114,"newLines":54,"lines":["   });"," });"," ","+  it('lex smallest considers pivot effects (later free var lowers earlier pivot)', () => {","+    // 4 buttons, 2 lights","+    // Button 0: [0]","+    // Button 1: [0, 1]","+    // Button 2: [1]","+    // Button 3: [0]","+    // Target: [true, true]","+    // GF(2) system: light 0: b0 + b1 + b3 = 1; light 1: b1 + b2 = 1","+    // After elim: pivot b0 from light 0, pivot b1 from light 1.","+    // Free: b2, b3.","+    // b1 = 1 - b2 mod 2 = 1 XOR b2","+    // b0 = 1 - b1 - b3 mod 2 = 1 XOR b1 XOR b3 = 1 XOR (1 XOR b2) XOR b3 = b2 XOR b3","+    // Solutions (b2, b3) → (b0, b1, b2, b3):","+    // (0, 0) → (0, 1, 0, 0): pressed=[1], weight=1","+    // (0, 1) → (1, 1, 0, 1): pressed=[0,1,3], weight=3","+    // (1, 0) → (1, 0, 1, 0): pressed=[0,2], weight=2","+    // (1, 1) → (0, 0, 1, 1): pressed=[2,3], weight=2","+    // Min weight=1, result