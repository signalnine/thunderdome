ot-separated notation.\n */\nfunction getAllPaths(obj: any, prefix = ''): string[] {\n  const paths: string[] = [];\n  if (obj === null || typeof obj !== 'object' || Array.isArray(obj)) {\n    return prefix ? [prefix] : [];\n  }\n  for (const key of Object.keys(obj)) {\n    const fullPath = prefix ? `${prefix}.${key}` : key;\n    const val = obj[key];\n    if (val !== null && typeof val === 'object' && !Array.isArray(val)) {\n      paths.push(...getAllPaths(val, fullPath));\n    } else {\n      paths.push(fullPath);\n    }\n  }\n  // If object has no keys, include prefix itself\n  if (Object.keys(obj).length === 0 && prefix) {\n    paths.push(prefix);\n  }\n  return paths;\n}\n\nfunction getAtPath(obj: any, path: string): any {\n  const parts = path.split('.');\n  let current = obj;\n  for (const part of parts) {\n    if (current === null || current === undefined || typeof current !== 'object') {\n      return undefined;\n    }\n    current = current[part];\n  }\n  return current;\n}\n\nfunction setAtPath(obj: any, path: string, value: any): void {\n  const parts = path.split('.');\n  let current = obj;\n  for (let i = 0; i < parts.length - 1; i++) {\n    const part = parts[i];\n    if (current[part] === undefined || current[part] === null || typeof current[part] !== 'object') {\n      current[part] = {};\n    }\n    current = current[part];\n  }\n  current[parts[parts.length - 1]] = value;\n}\n\nfunction deleteAtPath(obj: any, path: string): void {\n  const parts = path.split('.');\n  let current = obj;\n  for (let i = 0; i < parts.length - 1; i++) {\n    const part = parts[i];\n    if (current[part] === undefined || typeof current[part] !== 'object') {\n      return;\n    }\n    current = current[part];\n  }\n  delete current[parts[parts.length - 1]];\n}\n\nfunction deepEqual(a: any, b: any): boolean {\n  if (a === b) return true;\n  if (a === null || b === null) return a === b;\n  if (typeof a !== typeof b) return false;\n  if (typeof a !== 'object') return a ===