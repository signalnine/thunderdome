@@ -0,0 +1,347 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { DocumentStore } from './index.js';
+
+describe('DocumentStore', () => {
+  let store: DocumentStore;
+
+  beforeEach(() => {
+    store = new DocumentStore();
+  });
+
+  describe('Document CRUD', () => {
+    it('should create and get a document', () => {
+      store.create('doc1', { name: 'test', value: 42 });
+      expect(store.get('doc1')).toEqual({ name: 'test', value: 42 });
+    });
+
+    it('should deep clone on create and get', () => {
+      const original = { name: 'test', nested: { a: 1 } };
+      store.create('doc1', original);
+      original.nested.a = 999;
+      const retrieved = store.get('doc1') as Record<string, Record<string, number>>;
+      expect(retrieved.nested.a).toBe(1);
+      retrieved.nested.a = 888;
+      expect((store.get('doc1') as Record<string, Record<string, number>>).nested.a).toBe(1);
+    });
+
+    it('should throw when creating a duplicate document', () => {
+      store.create('doc1', { a: 1 });
+      expect(() => store.create('doc1', { a: 2 })).toThrow();
+    });
+
+    it('should throw when getting a non-existent document', () => {
+      expect(() => store.get('nonexistent')).toThrow();
+    });
+
+    it('should update a document', () => {
+      store.create('doc1', { a: 1 });
+      store.update('doc1', { a: 2, b: 3 });
+      expect(store.get('doc1')).toEqual({ a: 2, b: 3 });
+    });
+
+    it('should throw when updating a non-existent document', () => {
+      expect(() => store.update('nonexistent', { a: 1 })).toThrow();
+    });
+
+    it('should delete a document', () => {
+      store.create('doc1', { a: 1 });
+      store.delete('doc1');
+      expect(() => store.get('doc1')).toThrow();
+    });
+
+    it('should throw when deleting a non-existent document', () => {
+      expect(() => store.delete('nonexistent')).toThrow();
+    });
+
+    it('should throw when getting a deleted document', () => {
+      store.create('doc1', { a: 1 });
+      store.delete('doc1');
+      expect(() => store.get('doc1')).toThrow();
+    });
+  });
+
+  describe('Version History', () => {
+    it('should track versions on create', () => {
+      store.create('doc1', { a: 1 });
+      const history = store.getHistory('doc1');
+      expect(history).toHaveLength(1);
+      expect(history[0].content).toEqual({ a: 1 });
+    });
+
+    it('should track versions on update', () => {
+      store.create('doc1', { a: 1 });
+      store.update('doc1', { a: 2 });
+      store.update('doc1', { a: 3 });
+      const history = store.getHistory('doc1');
+      expect(history).toHaveLength(3);
+      expect(history[0].content).toEqual({ a: 1 });
+      expect(history[1].content).toEqual({ a: 2 });
+      expect(history[2].content).toEqual({ a: 3 });
+    });
+
+    it('should return versions in chronological order', () => {
+      store.create('doc1', { a: 1 });
+      store.update('doc1', { a: 2 });
+      const history = store.getHistory('doc1');
+      expect(history[0].timestamp).toBeLessThanOrEqual(history[1].timestamp);
+    });
+
+    it('should have unique version IDs', () => {
+      store.create('doc1', { a: 1 });
+      store.update('doc1', { a: 2 });
+      const history = store.getHistory('doc1');
+      expect(history[0].id).not.toBe(history[1].id);
+    });
+
+    it('should get a specific version', () => {
+      store.create('doc1', { a: 1 });
+      store.update('doc1', { a: 2 });
+      const history = store.getHistory('doc1');
+      expect(store.getVersion('doc1', history[0].id)).toEqual({ a: 1 });
+      expect(store.getVersion('doc1', history[1].id)).toEqual({ a: 2 });
+    });
+
+    it('should throw for non-existent version', () => {
+      store.create('doc1', { a: 1 });
+      expect(() => store.getVersion('doc1', 'nonexistent')).toThrow();
+    });
+
+    it('should throw for non-existent document in getHistory', () => {
+      expect(() => store.getHistory('nonexistent')).toThrow();
+    });
+
+    it('should deep clone version content', () => {
+      store.create('doc1', { nested: { a: 1 } });
+      const history = store.getHistory('doc1');
+      (history[0].content as Record<string, Record<string, number>>).nested.a = 999;
+      expect((store.getHistory('doc1')[0].content as Record<string, Record<string, number>>).nested.a).toBe(1);
+    });
+  });
+
+  describe('Branching', () => {
+    it('should default to main branch', () => {
+      expect(store.getBranch()).toBe('main');
+    });
+
+    it('should list branches', () => {
+      expect(store.listBranches()).toEqual(['main']);
+    });
+
+    it('should create and switch to a new branch', () => {
+      store.createBranch('feature');
+      expect(store.listBranches()).toContain('feature');
+      store.switchBranch('feature');
+      expect(store.getBranch()).toBe('feature');
+    });
+
+    it('should throw when creating a duplicate branch', () => {
+      store.createBranch('feature');
+      expect(() => store.createBranch('feature')).toThrow();
+    });
+
+    it('should throw when switching to non-existent branch', () => {
+      expect(() => store.switchBranch('nonexistent')).toThrow();
+    });
+
+    it('should isolate documents between branches', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      // doc1 should be visible (copied from main)
+      expect(store.get('doc1')).toEqual({ a: 1 });
+      // modify on feature
+      store.update('doc1', { a: 2 });
+      expect(store.get('doc1')).toEqual({ a: 2 });
+      // main should be unchanged
+      store.switchBranch('main');
+      expect(store.get('doc1')).toEqual({ a: 1 });
+    });
+
+    it('should create a new document on a branch without affecting main', () => {
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.create('doc1', { a: 1 });
+      store.switchBranch('main');
+      expect(() => store.get('doc1')).toThrow();
+    });
+
+    it('should create a branch from another branch', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { a: 2 });
+      // Create branch from feature (while on feature)
+      store.createBranch('sub-feature');
+      store.switchBranch('sub-feature');
+      expect(store.get('doc1')).toEqual({ a: 2 });
+    });
+
+    it('should create a branch from a named branch', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { a: 2 });
+      store.switchBranch('main');
+      // Create from feature while on main
+      store.createBranch('from-feature', 'feature');
+      store.switchBranch('from-feature');
+      expect(store.get('doc1')).toEqual({ a: 2 });
+    });
+  });
+
+  describe('Merging', () => {
+    it('should merge changes from one branch to another (no conflict)', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { a: 10, b: 2 });
+      store.switchBranch('main');
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(store.get('doc1')).toEqual({ a: 10, b: 2 });
+    });
+
+    it('should merge with no changes (fast-forward)', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(Object.keys(result.merged)).toHaveLength(0);
+    });
+
+    it('should detect conflicts when both branches change the same field', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+      // Change on feature
+      store.switchBranch('feature');
+      store.update('doc1', { a: 10, b: 2 });
+      // Change same field on main
+      store.switchBranch('main');
+      store.update('doc1', { a: 20, b: 2 });
+      const result = store.merge('feature');
+      expect(result.applied).toBe(false);
+      expect(result.conflicts).toHaveLength(1);
+      expect(result.conflicts[0].documentId).toBe('doc1');
+      expect(result.conflicts[0].path).toBe('a');
+      expect(result.conflicts[0].base).toBe(1);
+      expect(result.conflicts[0].ours).toBe(20);
+      expect(result.conflicts[0].theirs).toBe(10);
+      // Main should be unchanged
+      expect(store.get('doc1')).toEqual({ a: 20, b: 2 });
+    });
+
+    it('should not conflict if both change to same value', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { a: 42, b: 2 });
+      store.switchBranch('main');
+      store.update('doc1', { a: 42, b: 2 });
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+    });
+
+    it('should merge non-overlapping changes cleanly', () => {
+      store.create('doc1', { a: 1, b: 2, c: 3 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { a: 10, b: 2, c: 3 });
+      store.switchBranch('main');
+      store.update('doc1', { a: 1, b: 20, c: 3 });
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(store.get('doc1')).toEqual({ a: 10, b: 20, c: 3 });
+    });
+
+    it('should handle new documents on source branch', () => {
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.create('doc1', { a: 1 });
+      store.switchBranch('main');
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(store.get('doc1')).toEqual({ a: 1 });
+    });
+
+    it('should merge multiple documents independently', () => {
+      store.create('doc1', { a: 1 });
+      store.create('doc2', { x: 10 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { a: 2 });
+      store.switchBranch('main');
+      store.update('doc2', { x: 20 });
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(store.get('doc1')).toEqual({ a: 2 });
+      expect(store.get('doc2')).toEqual({ x: 20 });
+    });
+
+    it('should handle nested object merging', () => {
+      store.create('doc1', { nested: { a: 1, b: 2 } });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { nested: { a: 10, b: 2 } });
+      store.switchBranch('main');
+      store.update('doc1', { nested: { a: 1, b: 20 } });
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(store.get('doc1')).toEqual({ nested: { a: 10, b: 20 } });
+    });
+
+    it('should report conflicts with dot-separated paths for nested objects', () => {
+      store.create('doc1', { nested: { a: 1 } });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { nested: { a: 10 } });
+      store.switchBranch('main');
+      store.update('doc1', { nested: { a: 20 } });
+      const result = store.merge('feature');
+      expect(result.applied).toBe(false);
+      expect(result.conflicts[0].path).toBe('nested.a');
+    });
+
+    it('should include merged content in result even with conflicts (ours wins)', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { a: 10, b: 20 });
+      store.switchBranch('main');
+      store.update('doc1', { a: 100, b: 2 });
+      const result = store.merge('feature');
+      // a is conflicted (ours=100), b only changed on theirs (20)
+      expect(result.merged['doc1']).toEqual({ a: 100, b: 20 });
+    });
+
+    it('should not apply merge when there are conflicts', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { a: 10 });
+      store.switchBranch('main');
+      store.update('doc1', { a: 20 });
+      store.merge('feature');
+      // Main should still have its own version
+      expect(store.get('doc1')).toEqual({ a: 20 });
+    });
+
+    it('should handle adding new fields on one branch', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { a: 1, b: 2 });
+      store.switchBranch('main');
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(store.get('doc1')).toEqual({ a: 1, b: 2 });
+    });
+
+    it('should throw when merging from a non-existent branch', () => {
+      expect(() => store.merge('nonexistent')).toThrow();
+    });
+  });
+});
