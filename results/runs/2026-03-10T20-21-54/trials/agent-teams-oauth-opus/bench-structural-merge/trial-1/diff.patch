ction genVersionId(): string {\n  return `v${++versionCounter}_${Date.now()}`;\n}\n\nfunction deepClone<T>(obj: T): T {\n  if (obj === null || typeof obj !== 'object') return obj;\n  return JSON.parse(JSON.stringify(obj));\n}\n\nfunction cloneEntry(entry: DocumentEntry): DocumentEntry {\n  return {\n    content: deepClone(entry.content),\n    versions: entry.versions.map(v => ({\n      id: v.id,\n      timestamp: v.timestamp,\n      content: deepClone(v.content),\n    })),\n    deleted: entry.deleted,\n  };\n}\n\nfunction cloneDocMap(docs: Map<string, DocumentEntry>): Map<string, DocumentEntry> {\n  const result = new Map<string, DocumentEntry>();\n  for (const [id, entry] of docs) {\n    result.set(id, cloneEntry(entry));\n  }\n  return result;\n}\n\n/**\n * Get all nested paths of a plain object using dot-separated notation.\n */\nfunction getAllPaths(obj: any, prefix = ''): string[] {\n  const paths: string[] = [];\n  if (obj === null || typeof obj !== 'object' || Array.isArray(obj)) {\n    return prefix ? [prefix] : [];\n  }\n  for (const key of Object.keys(obj)) {\n    const fullPath = prefix ? `${prefix}.${key}` : key;\n    const val = obj[key];\n    if (val !== null && typeof val === 'object' && !Array.isArray(val)) {\n      paths.push(...getAllPaths(val, fullPath));\n    } else {\n      paths.push(fullPath);\n    }\n  }\n  // If object has no keys, include prefix itself\n  if (Object.keys(obj).length === 0 && prefix) {\n    paths.push(prefix);\n  }\n  return paths;\n}\n\nfunction getAtPath(obj: any, path: string): any {\n  const parts = path.split('.');\n  let current = obj;\n  for (const part of parts) {\n    if (current === null || current === undefined || typeof current !== 'object') {\n      return undefined;\n    }\n    current = current[part];\n  }\n  return current;\n}\n\nfunction setAtPath(obj: any, path: string, value: any): void {\n  const parts = path.split('.');\n  let current = obj;\n  for (let i = 0; i < parts.length - 1; i++) {\n    const part = parts[i];\n    if (current[part] === undefined || current[part] === null || typeof current[part] !== 'object') {\n      current[part] = {};\n    }\n    current = current[part];\n  }\n  current[parts[parts.length - 1]] = value;\n}\n\nfunction deleteAtPath(obj: any, path: string): void {\n  const parts = path.split('.');\n  let current = obj;\n  for (let i = 0; i < parts.length - 1; i++) {\n    const part = parts[i];\n    if (current[part] === undefined || typeof current[part] !== 'object') {\n      return;\n    }\n    current = current[part];\n  }\n  delete current[parts[parts.length - 1]];\n}\n\nfunction deepEqual(a: any, b: any): boolean {\n  if (a === b) return true;\n  if (a === null || b === null) return a === b;\n  if (typeof a !== typeof b) return false;\n  if (typeof a !== 'object') return a === b;\n  if (Array.isArray(a) !== Array.isArray(b)) return false;\n  if (Array.isArray(a)) {\n    if (a.length !== b.length) return false;\n    return a.every((v: any, i: number) => deepEqual(v, b[i]));\n  }\n  const keysA = Object.keys(a);\n  const keysB = Object.keys(b);\n  if (keysA.length !== keysB.length) return false;\n  return keysA.every(k => deepEqual(a[k], b[k]));\n}\n\n/**\n * Collect all leaf paths from multiple objects combined.\n */\nfunction collectAllPaths(...objs: any[]): Set<string> {\n  const paths = new Set<string>();\n  for (const obj of objs) {\n    if (obj !== undefined && obj !== null) {\n      for (const p of getAllPaths(obj)) {\n        paths.add(p);\n      }\n    }\n  }\n  return paths;\n}\n\n/**\n * Three-way merge of two objects against a common base.\n * Returns the merged result and any conflicts.\n */\nfunction threeWayMerge(\n  base: object | undefined,\n  ours: object | undefined,\n  theirs: object | undefined,\n  documentId: string,\n): { merged: object; conflicts: Conflict[] } {\n  const conflicts: Conflict[] = [];\n\n  // If base is undefined, both branches created independently - that's a conflict at root\n  const baseObj = base ?? {};\n  const oursObj = ours ?? {};\n  const theirsObj = theirs ?? {};\n\n  const merged = deepClone(oursObj) as any;\n  const allPaths = collectAllPaths(baseObj, oursObj, theirsObj);\n\n  for (const path of allPaths) {\n    const baseVal = getAtPath(baseObj, path);\n    const oursVal = getAtPath(oursObj, path);\n    const theirsVal = getAtPath(theirsObj, path);\n\n    const oursChanged = !deepEqual(baseVal, oursVal);\n    const theirsChanged = !deepEqual(baseVal, theirsVal);\n\n    if (!oursChanged && !theirsChanged) {\n      // No changes — keep as-is (already in merged from ours clone)\n      continue;\n    }\n\n    if (oursChanged && !theirsChanged) {\n      // Only ours changed — already in merged\n      continue;\n    }\n\n    if (!oursChanged && theirsChanged) {\n      // Only theirs changed — apply theirs\n      if (theirsVal === undefined) {\n        deleteAtPath(merged, path);\n      } else {\n        setAtPath(merged, path, deepClone(theirsVal));\n      }\n      continue;\n    }\n\n    // Both changed\n    if (deepEqual(oursVal, theirsVal)) {\n      // Both changed to same value — no conflict\n      continue;\n    }\n\n    // Conflict — keep ours in merged, record conflict\n    conflicts.push({\n      documentId,\n      path,\n      base: deepClone(baseVal),\n      ours: deepClone(oursVal),\n      theirs: deepClone(theirsVal),\n    });\n  }\n\n  return { merged, conflicts };\n}\n\nexport class DocumentStore {\n  private branches: Map<string, BranchState> = new Map();\n  private currentBranch: string = 'main';\n\n  constructor() {\n    this.branches.set('main', {\n      documents: new Map(),\n      forkSnapshots: new Map(),\n    });\n  }\n\n  // ---------- Document CRUD ----------\n\n  create(id: string, content: object): void {\n    const branch = this.getBranchState();\n    const existing = branch.documents.get(id);\n    if (existing && !existing.deleted) {\n      throw new Error(`Document \"${id}\" already exists`);\n    }\n    const cloned = deepClone(content);\n    const version: Version = {\n      id: genVersionId(),\n      timestamp: Date.now(),\n      content: deepClone(cloned),\n    };\n    branch.documents.set(id, {\n      content: cloned,\n      versions: [version],\n      deleted: false,\n    });\n  }\n\n  get(id: string): object {\n    const entry = this.getEntry(id);\n    return deepClone(entry.content);\n  }\n\n  update(id: string, content: object): void {\n    const entry = this.getEntry(id);\n    const cloned = deepClone(content);\n    const version: Version = {\n      id: genVersionId(),\n      timestamp: Date.now(),\n      content: deepClone(cloned),\n    };\n    entry.content = cloned;\n    entry.versions.push(version);\n  }\n\n  delete(id: string): void {\n    const entry = this.getEntry(id);\n    entry.deleted = true;\n    entry.content = {};\n  }\n\n  // ---------- Version History ----------\n\n  getHistory(id: string): Version[] {\n    const branch = this.getBranchState();\n    const entry = branch.documents.get(id);\n    if (!entry) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    return entry.versions.map(v => ({\n      id: v.id,\n      timestamp: v.timestamp,\n      content: deepClone(v.content),\n    }));\n  }\n\n  getVersion(id: string, versionId: string): object {\n    const branch = this.getBranchState();\n    const entry = branch.documents.get(id);\n    if (!entry) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    const version = entry.versions.find(v => v.id === versionId);\n    if (!version) {\n      throw new Error(`Version \"${versionId}\" not found for document \"${id}\"`);\n    }\n    return deepClone(version.content);\n  }\n\n  // ---------- Branching ----------\n\n  createBranch(name: string, fromBranch?: string): void {\n    if (this.branches.has(name)) {\n      throw new Error(`Branch \"${name}\" already exists`);\n    }\n    const sourceName = fromBranch ?? this.currentBranch;\n    const source = this.branches.get(sourceName);\n    if (!source) {\n      throw new Error(`Branch \"${sourceName}\" not found`);\n    }\n    const snapshot = cloneDocMap(source.documents);\n\n    // New branch inherits fork snapshots from source, plus a snapshot of source itself\n    const forkSnapshots = new Map<string, Map<string, DocumentEntry>>();\n    for (const [branchName, snap] of source.forkSnapshots) {\n      forkSnapshots.set(branchName, cloneDocMap(snap));\n    }\n    forkSnapshots.set(sourceName, cloneDocMap(source.documents));\n\n    // Also record the fork point on the source branch\n    source.forkSnapshots.set(name, cloneDocMap(source.documents));\n\n    this.branches.set(name, {\n      documents: snapshot,\n      forkSnapshots,\n    });\n  }\n\n  switchBranch(name: string): void {\n    if (!this.branches.has(name)) {\n      throw new Error(`Branch \"${name}\" not found`);\n    }\n    this.currentBranch = name;\n  }\n\n  getBranch(): string {\n    return this.currentBranch;\n  }\n\n  listBranches(): string[] {\n    return Array.from(this.branches.keys());\n  }\n\n  // ---------- Merging ----------\n\n  merge(sourceBranch: string): MergeResult {\n    const targetName = this.currentBranch;\n    const target = this.getBranchState();\n    const source = this.branches.get(sourceBranch);\n    if (!source) {\n      throw new Error(`Branch \"${sourceBranch}\" not found`);\n    }\n\n    // Find common ancestor: the snapshot of the target branch at the time source was forked,\n    // or the snapshot of the source branch at the time it was forked from target.\n    let baseDocuments: Map<string, DocumentEntry> | undefined;\n\n    // Check if source has a fork snapshot of target (source was forked from target)\n    if (source.forkSnapshots.has(targetName)) {\n      baseDocuments = source.forkSnapshots.get(targetName)!;\n    }\n    // Check if target has a fork snapshot of source (target was forked from source)\n    else if (target.forkSnapshots.has(sourceBranch)) {\n      baseDocuments = target.forkSnapshots.get(sourceBranch)!;\n    }\n    // No direct relationship - use empty base\n    else {\n      baseDocuments = new Map();\n    }\n\n    const allDocIds = new Set<string>();\n    for (const id of baseDocuments.keys()) allDocIds.add(id);\n    for (const id of target.documents.keys()) allDocIds.add(id);\n    for (const id of source.documents.keys()) allDocIds.add(id);\n\n    const merged: Record<string, object> = {};\n    const conflicts: Conflict[] = [];\n\n    for (const docId of allDocIds) {\n      const baseEntry = baseDocuments.get(docId);\n      const oursEntry = target.documents.get(docId);\n      const theirsEntry = source.documents.get(docId);\n\n      const baseContent = baseEntry && !baseEntry.deleted ? baseEntry.content : undefined;\n      const oursContent = oursEntry && !oursEntry.deleted ? oursEntry.content : undefined;\n      const theirsContent = theirsEntry && !theirsEntry.deleted ? theirsEntry.content : undefined;\n\n      // Skip if nothing changed\n      const oursChanged = !deepEqual(baseContent, oursContent);\n      const theirsChanged = !deepEqual(baseContent, theirsContent);\n\n      if (!oursChanged && !theirsChanged) {\n        // No changes for this doc\n        continue;\n      }\n\n      if (oursChanged && !theirsChanged) {\n        // Only our side changed - already in target\n        if (oursContent !== undefined) {\n          merged[docId] = deepClone(oursContent);\n        }\n        continue;\n      }\n\n      if (!oursChanged && theirsChanged) {\n        // Only their side changed - take theirs\n        if (theirsContent !== undefined) {\n          merged[docId] = deepClone(theirsContent);\n        }\n        // If theirs deleted it, we handle that below when applying\n        continue;\n      }\n\n      // Both sides changed\n      if (oursContent === undefined && theirsContent === undefined) {\n        // Both deleted - no conflict\n        continue;\n      }\n\n      if (oursContent === undefined || theirsContent === undefined) {\n        // One deleted, one modified - conflict at document level\n        const result = threeWayMerge(baseContent, oursContent, theirsContent, docId);\n        merged[docId] = result.merged;\n        conflicts.push(...result.conflicts);\n        // If no field-level conflicts were found but one side deleted, add a root conflict\n        if (result.conflicts.length === 0) {\n          conflicts.push({\n            documentId: docId,\n            path: '',\n            base: baseContent !== undefined ? deepClone(baseContent) : undefined,\n            ours: oursContent !== undefined ? deepClone(oursContent) : undefined,\n            theirs: theirsContent !== undefined ? deepClone(theirsContent) : undefined,\n          });\n        }\n        continue;\n      }\n\n      // Both modified - three-way merge\n      const result = threeWayMerge(baseContent, oursContent, theirsContent, docId);\n      merged[docId] = result.merged;\n      conflicts.push(...result.conflicts);\n    }\n\n    const applied = conflicts.length === 0;\n\n    if (applied) {\n      // Apply merged results to target branch\n      for (const docId of allDocIds) {\n        const baseEntry = baseDocuments.get(docId);\n        const oursEntry = target.documents.get(docId);\n        const theirsEntry = source.documents.get(docId);\n\n        const baseContent = baseEntry && !baseEntry.deleted ? baseEntry.content : undefined;\n        const oursContent = oursEntry && !oursEntry.deleted ? oursEntry.content : undefined;\n        const theirsContent = theirsEntry && !theirsEntry.deleted ? theirsEntry.content : undefined;\n\n        const oursChanged = !deepEqual(baseContent, oursContent);\n        const theirsChanged = !deepEqual(baseContent, theirsContent);\n\n        if (!theirsChanged) continue; // Nothing from theirs to apply\n\n        if (!oursChanged && theirsChanged) {\n          if (theirsContent === undefined) {\n            // Theirs deleted the doc\n            if (oursEntry) {\n              oursEntry.deleted = true;\n              oursEntry.content = {};\n            }\n          } else if (oursEntry) {\n            // Update existing entry\n            const newContent = deepClone(merged[docId] ?? theirsContent);\n            const version: Version = {\n              id: genVersionId(),\n              timestamp: Date.now(),\n              content: deepClone(newContent),\n            };\n            oursEntry.content = newContent;\n            oursEntry.deleted = false;\n            oursEntry.versions.push(version);\n          } else {\n            // Create new entry on target\n            const newContent = deepClone(merged[docId] ?? theirsContent);\n            const version: Version = {\n              id: genVersionId(),\n              timestamp: Date.now(),\n              content: deepClone(newContent),\n            };\n            target.documents.set(docId, {\n              content: newContent,\n              versions: [version],\n              deleted: false,\n            });\n          }\n        } else if (oursChanged && theirsChanged) {\n          // Both changed, no conflicts - apply merged result\n          if (merged[docId] !== undefined && oursEntry) {\n            const newContent = deepClone(merged[docId]);\n            const version: Version = {\n              id: genVersionId(),\n              timestamp: Date.now(),\n              content: deepClone(newContent),\n            };\n            oursEntry.content = newContent;\n            oursEntry.versions.push(version);\n          }\n        }\n      }\n\n      // Update fork snapshots to reflect the merge\n      target.forkSnapshots.set(sourceBranch, cloneDocMap(target.documents));\n      source.forkSnapshots.set(targetName, cloneDocMap(target.documents));\n    }\n\n    return { merged, conflicts, applied };\n  }\n\n  // ---------- Private helpers ----------\n\n  private getBranchState(): BranchState {\n    const state = this.branches.get(this.currentBranch);\n    if (!state) {\n      throw new