ta: 'x', maxRetries: 0 });\n\n    const task = await tq.process('q', async () => {\n      throw new Error('handler error');\n    });\n\n    expect(task!.status).toBe('dead-letter');\n    expect(task!.error).toBe('handler error');\n  });\n\n  it('should return null when no tasks available', async () => {\n    const result = await tq.process('q', async () => {});\n    expect(result).toBeNull();\n  });\n\n  it('should have independent middleware per queue', async () => {\n    tq.add({ queue: 'a', data: 'x' });\n    tq.add({ queue: 'b', data: 'y' });\n\n    let aMwCalled = false;\n    tq.use('a', async (_task, next) => { aMwCalled = true; await next(); });\n\n    await tq.process('b', async () => {});\n    expect(aMwCalled).toBe(false);\n\n    await tq.process('a', async () => {});\n    expect(aMwCalled).toBe(true);\n  });\n});\n\n// ═══════════════════════════════════════════════════════════════════════\n// Phase 12: Graceful Shutdown\n// ═══════════════════════════════════════════════════════════════════════\n\ndescribe('Phase 12: Graceful Shutdown', () => {\n  it('should complete immediately with no processing tasks', async () => {\n    tq.add({ data: 'pending' });\n    const result = await tq.shutdown();\n    expect(result.completed).toBe(0);\n    expect(result.forceCancelled).toBe(0);\n    expect(result.duration).toBeGreaterThanOrEqual(0);\n  });\n\n  it('should reject new tasks after shutdown', async () => {\n    await tq.shutdown();\n    expect(() => tq.add({ data: 'x' })).toThrow(/shutting down/);\n  });\n\n  it('should wait for processing tasks', async () => {\n    tq.add({ data: 'x' });\n    const task = tq.take()!;\n\n    const shutdownPromise = tq.shutdown({ timeout: 5000 });\n\n    // Complete the task\n    tq.complete(task.id);\n\n    const result = await shutdownPromise;\n    expect(result.completed).toBe(1);\n    expect(result.forceCancelled).toBe(0);\n  });\n\n  it('should force-cancel on timeout', async () => {\n    tq.add({ data: 'x' });\n    tq.take(