+{"parentUuid":"378a4b5c-ce67-4a33-aa1c-df090020add0","isSidechain":false,"userType":"external","cwd":"/workspace","sessionId":"48c65c94-e2dd-4cf2-aa8d-7771bf56cbe0","version":"2.1.63","gitBranch":"HEAD","slug":"drifting-pondering-pebble","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ruc34Y42CJkcf8Khx4dPwQ","type":"tool_result","content":"The file /workspace/src/task-queue.test.ts has been updated successfully."}]},"uuid":"7e4e5960-e9b1-40cd-9644-dadef4176edf","timestamp":"2026-03-10T20:52:09.741Z","toolUseResult":{"filePath":"/workspace/src/task-queue.test.ts","oldString":"import { describe, it, expect, vi, beforeEach } from 'vitest';","newString":"import { describe, it, expect, beforeEach } from 'vitest';","originalFile":"import { describe, it, expect, vi, beforeEach } from 'vitest';\nimport { TaskQueue } from './task-queue.js';\n\nlet tq: TaskQueue;\n\nbeforeEach(() => {\n  tq = new TaskQueue();\n});\n\n// ═══════════════════════════════════════════════════════════════════════\n// Phase 1: Basic FIFO Queue\n// ═══════════════════════════════════════════════════════════════════════\n\ndescribe('Phase 1: Basic FIFO Queue', () => {\n  it('should add a task and return a task object', () => {\n    const task = tq.add({ data: 'hello' });\n    expect(task).toBeDefined();\n    expect(task.id).toBeTruthy();\n    expect(task.status).toBe('pending');\n    expect(task.data).toBe('hello');\n    expect(task.createdAt).toBeInstanceOf(Date);\n  });\n\n  it('should assign unique ids to tasks', () => {\n    const t1 = tq.add({ data: 'a' });\n    const t2 = tq.add({ data: 'b' });\n    expect(t1.id).not.toBe(t2.id);\n  });\n\n  it('should retrieve tasks in FIFO order', () => {\n    tq.add({ data: 'first' });\n    tq.add({ data: 'second' });\n    tq.add({ data: 'third' });\n\n    expect(tq.take()!.data).toBe('first');\n    expect(tq.take()!.data).toBe('second');\n    expect(tq.take()!.data).toBe('third');\n  });\n\n  it('should transition taken task to processing', () => {\n    tq.add({ data: 'x' });\n    const task = tq.take()!;\n    expect(task.status).toBe('processing');\n  });\n\n  it('should return null when no tasks available', () => {\n    expect(tq.take()).toBeNull();\n  });\n\n  it('should not return already-processing tasks', () => {\n    tq.add({ data: 'only' });\n    tq.take();\n    expect(tq.take()).toBeNull();\n  });\n\n  it('should count waiting tasks', () => {\n    expect(tq.size()).toBe(0);\n    tq.add({ data: 'a' });\n    tq.add({ data: 'b' });\n    expect(tq.size()).toBe(2);\n    tq.take();\n    expect(tq.size()).toBe(1);\n  });\n\n  it('should accept empty options', () => {\n    const task = tq.add();\n    expect(task.data).toBeUndefined();\n    expect(task.status).toBe('pending');\n  });\n});\n\n// ═══════════════════════════════════════════════════════════════════════\n// Phase 2: Named Queues\n// ═══════════════════════════════════════════════════════════════════════\n\ndescribe('Phase 2: Named Queues', () => {\n  it('should use default queue when no name given', () => {\n    tq.add({ data: 'x' });\n    const task = tq.take()!;\n    expect(task.queue).toBe('default');\n  });\n\n  it('should support named queues independently', () => {\n    tq.add({ queue: 'emails', data: 'e1' });\n    tq.add({ queue: 'sms', data: 's1' });\n\n    expect(tq.take('emails')!.data).toBe('e1');\n    expect(tq.take('sms')!.data).toBe('s1');\n    expect(tq.take('emails')).toBeNull();\n  });\n\n  it('should not cross queues', () => {\n    tq.add({ queue: 'a', data: 'in-a' });\n    expect(tq.take('b')).toBeNull();\n    expect(tq.take('a')!.data).toBe('in-a');\n  });\n\n  it('should list queue names', () => {\n    tq.add({ queue: 'q1', data: 'x' });\n    tq.add({ queue: 'q2', data: 'y' });\n    const names = tq.queues();\n    expect(names).toContain('q1');\n    expect(names).toContain('q2');\n  });\n\n  it('should return null for non-existent queue', () => {\n    expect(tq.take('nonexistent')).toBeNull();\n  });\n\n  it('should track size per queue', () => {\n    tq.add({ queue: 'a', data: 'x' });\n    tq.add({ queue: 'a', data: 'y' });\n    tq.add({ queue: 'b', data: 'z' });\n    expect(tq.size('a')).toBe(2);\n    expect(tq.size('b')).toBe(1);\n  });\n});\n\n// ═══════════════════════════════════════════════════════════════════════\n// Phase 3: Priority\n// ═══════════════════════════════════════════════════════════════════════\n\ndescribe('Phase 3: Priority', () => {\n  it('should default to priority 5', () => {\n    const task = tq.add({ data: 'x' });\n    expect(task.priority).toBe(5);\n  });\n\n  it('should return higher priority (lower number) first', () => {\n    tq.add({ data: 'low', priority: 10 });\n    tq.add({ data: 'high', priority: 1 });\n    tq.add({ data: 'mid', priority: 5 });\n\n    expect(tq.take()!.data).toBe('high');\n    expect(tq.take()!.data).toBe('mid');\n    expect(tq.take()!.data).toBe('low');\n  });\n\n  it('should use FIFO for same priority', () => {\n    tq.add({ data: 'first', priority: 3 });\n    tq.add({ data: 'second', priority: 3 });\n\n    expect(tq.take()!.data).toBe('first');\n    expect(tq.take()!.data).toBe('second');\n  });\n\n  it('should reject invalid priority values', () => {\n    expect(() => tq.add({ priority: 0 })).toThrow();\n    expect(() => tq.add({ priority: 11 })).toThrow();\n    expect(() => tq.add({ priority: 1.5 })).toThrow();\n  });\n\n  it('should maintain priority per queue', () => {\n    tq.add({ queue: 'q', data: 'low', priority: 10 });\n    tq.add({ queue: 'q', data: 'high', priority: 1 });\n\n    expect(tq.take('q')!.data).toBe('high');\n    expect(tq.take('q')!.data).toBe('low');\n  });\n});\n\n// ═══════════════════════════════════════════════════════════════════════\n// Phase 4: Delayed Tasks\n// ═══════════════════════════════════════════════════════════════════════\n\ndescribe('Phase 4: Delayed Tasks', () => {\n  it('should delay a task by milliseconds', () => {\n    tq.add({ data: 'delayed', delay: 100_000 });\n    expect(tq.take()).toBeNull();\n  });\n\n  it('should return delayed task after time elapses', () => {\n    const past = new Date(Date.now() - 1000);\n    tq.add({ data: 'available', scheduledFor: past });\n    expect(tq.take()!.data).toBe('available');\n  });\n\n  it('should prefer non-delayed over not-yet-available delayed tasks', () => {\n    tq.add({ data: 'delayed', delay: 100_000 });\n    tq.add({ data: 'immediate' });\n\n    const task = tq.take()!;\n    expect(task.data).toBe('immediate');\n    expect(tq.take()).toBeNull(); // delayed not yet available\n  });\n\n  it('should set availableAt on delayed tasks', () => {\n    const before = Date.now();\n    const task = tq.add({ data: 'x', delay: 5000 });\n    expect(task.availableAt.getTime()).toBeGreaterThanOrEqual(before + 5000);\n  });\n\n  it('should order available delayed tasks by availableAt then priority', () => {\n    const now = Date.now();\n    tq.add({ data: 'later', scheduledFor: new Date(now - 1000), priority: 5 });\n    tq.add({ data: 'earlier', scheduledFor: new Date(now - 2000), priority: 5 });\n\n    expect(tq.take()!.data).toBe('earlier');\n    expect(tq.take()!.data).toBe('later');\n  });\n\n  it('should work with named queues', () => {\n    tq.add({ queue: 'q', data: 'delayed', delay: 100_000 });\n    tq.add({ queue: 'q', data: 'ready' });\n\n    expect(tq.take('q')!.data).toBe('ready');\n    expect(tq.take('q')).toBeNull();\n  });\n});\n\n// ═══════════════════════════════════════════════════════════════════════\n// Phase 5: Retry with Backoff\n// ═══════════════════════════════════════════════════════════════════════\n\ndescribe('Phase 5: Retry with Backoff', () => {\n  it('should complete a processing task', () => {\n    tq.add({ data: 'x' });\n    const task = tq.take()!;\n    const completed = tq.complete(task.id);\n    expect(completed.status).toBe('completed');\n  });\n\n  it('should fail a task and trigger retry', () => {\n    tq.add({ data: 'x', maxRetries: 3, retryDelay: 100 });\n    const task = tq.take()!;\n    const failed = tq.fail(task.id, 'oops');\n\n    expect(failed.status).toBe('pending');\n    expect(failed.error).toBe('oops');\n    expect(failed.failCount).toBe(1);\n    expect(failed.availableAt.getTime()).toBeGreaterThan(Date.now());\n  });\n\n  it('should use exponential backoff', () => {\n    const task = tq.add({ data: 'x', maxRetries: 3, retryDelay: 1000 });\n\n    // Attempt 1 fails\n    tq.take()!;\n    const before1 = Date.now();\n    tq.fail(task.id, 'e1');\n    expect(task.availableAt.getTime()).toBeGreaterThanOrEqual(before1 + 1000); // 1000 * 2^0\n\n    // Force availability for next attempt\n    task.availableAt = new Date(Date.now() - 1);\n\n    // Attempt 2 fails\n    tq.take()!;\n    const before2 = Date.now();\n    tq.fail(task.id, 'e2');\n    expect(task.availableAt.getTime()).toBeGreaterThanOrEqual(before2 + 2000); // 1000 * 2^1\n  });\n\n  it('should track attempts', () => {\n    const task = tq.add({ data: 'x', maxRetries: 2, retryDelay: 1 });\n    tq.take()!;\n    expect(task.attempts).toBe(1);\n\n    tq.fail(task.id);\n    task.availableAt = new Date(Date.now() - 1);\n\n    tq.take()!;\n    expect(task.attempts).toBe(2);\n  });\n\n  it('should keep original queue and priority on retry', () => {\n    const task = tq.add({ queue: 'myq', data: 'x', priority: 2, maxRetries: 1, retryDelay: 1 });\n    tq.take('myq')!;\n    tq.fail(task.id);\n\n    expect(task.queue).toBe('myq');\n    expect(task.priority).toBe(2);\n  });\n\n  it('should not complete non-processing tasks', () => {\n    const task = tq.add({ data: 'x' });\n    expect(() => tq.complete(task.id)).toThrow();\n  });\n\n  it('should not fail non-processing tasks', () => {\n    const task = tq.add({ data: 'x' });\n    expect(() => tq.fail(task.id)).toThrow();\n  });\n});\n\n// ═══════════════════════════════════════════════════════════════════════\n// Phase 6: Dead Letter Queue\n// ═══════════════════════════════════════════════════════════════════════\n\ndescribe('Phase 6: Dead Letter Queue', () => {\n  it('should move to DLQ when retries exhausted', () => {\n    const task = tq.add({ data: 'x', maxRetries: 1, retryDelay: 1 });\n\n    // Attempt 1\n    tq.take()!;\n    tq.fail(task.id, 'err1');\n    task.availableAt = new Date(Date.now() - 1);\n\n    // Attempt 2 (last retry)\n    tq.take()!;\n    tq.fail(task.id, 'err2');\n\n    expect(task.status).toBe('dead-letter');\n    expect(task.failCount).toBe(2);\n  });\n\n  it('should list dead-lettered tasks for a queue', () => {\n    const task = tq.add({ queue: 'q', data: 'x', maxRetries: 0, retryDelay: 1 });\n    tq.take('q')!;\n    tq.fail(task.id, 'err');\n\n    const dlq = tq.getDeadLetterQueue('q');\n    expect(dlq).toHaveLength(1);\n    expect(dlq[0].id).toBe(task.id);\n    expect(dlq[0].error).toBe('err');\n  });\n\n  it('should requeue a dead-lettered task', () => {\n    const task = tq.add({ data: 'x', maxRetries: 0, retryDelay: 1 });\n    tq.take()!;\n    tq.fail(task.id);\n\n    const requeued = tq.requeue(task.id);\n    expect(requeued.status).toBe('pending');\n    expect(requeued.attempts).toBe(0);\n\n    const taken = tq.take()!;\n    expect(taken.id).toBe(task.id);\n  });\n\n  it('should clear DLQ for a queue', () => {\n    const t1 = tq.add({ queue: 'q', data: 'a', maxRetries: 0 });\n    const t2 = tq.add({ queue: 'q', data: 'b', maxRetries: 0 });\n\n    tq.take('q')!; tq.fail(t1.id);\n    tq.take('q')!; tq.fail(t2.id);\n\n    expect(tq.getDeadLetterQueue('q')).toHaveLength(2);\n    tq.clearDeadLetterQueue('q');\n    expect(tq.getDeadLetterQueue('q')).toHaveLength(0);\n  });\n\n  it('should have independent DLQs per queue', () => {\n    const t1 = tq.add({ queue: 'a', data: 'x', maxRetries: 0 });\n    const t2 = tq.add({ queue: 'b', data: 'y', maxRetries: 0 });\n\n    tq.take('a')!; tq.fail(t1.id);\n    tq.take('b')!; tq.fail(t2.id);\n\n    expect(tq.getDeadLetterQueue('a')).toHaveLength(1);\n    expect(tq.getDeadLetterQueue('b')).toHaveLength(1);\n\n    tq.clearDeadLetterQueue('a');\n    expect(tq.getDeadLetterQueue('a')).toHaveLength(0);\n    expect(tq.getDeadLetterQueue('b')).toHaveLength(1);\n  });\n\n  it('should not requeue non-dead-letter tasks', () => {\n    const task = tq.add({ data: 'x' });\n    expect(() => tq.requeue(task.id)).toThrow();\n  });\n});\n\n// ═══════════════════════════════════════════════════════════════════════\n// Phase 7: Task Dependencies\n// ═══════════════════════════════════════════════════════════════════════\n\ndescribe('Phase 7: Task Dependencies', () => {\n  it('should block tasks with pending dependencies', () => {\n    const dep = tq.add({ data: 'dep' });\n    tq.add({ data: 'child', dependencies: [dep.id] });\n\n    // child should not be returned since dep is pending\n    const taken = tq.take()!;\n    expect(taken.data).toBe('dep'); // gets the dependency\n    expect(tq.take()).toBeNull(); // child still blocked\n  });\n\n  it('should unblock when dependencies complete', () => {\n    const dep = tq.add({ data: 'dep' });\n    tq.add({ data: 'child', dependencies: [dep.id] });\n\n    const taken = tq.take()!;\n    tq.complete(taken.id);\n\n    const child = tq.take()!;\n    expect(child.data).toBe('child');\n  });\n\n  it('should reject non-existent dependencies', () => {\n    expect(() => tq.add({ data: 'x', dependencies: ['nonexistent'] })).toThrow();\n  });\n\n  it('should detect self-referencing circular dependencies', () => {\n    expect(() => tq.add({ id: 'a', data: 'x', dependencies: ['a'] })).toThrow(/not found|[Cc]ircular|does not exist/);\n  });\n\n  it('should keep dependents blocked when dependency fails', () => {\n    const dep = tq.add({ data: 'dep', maxRetries: 0 });\n    tq.add({ data: 'child', dependencies: [dep.id] });\n\n    tq.take()!;\n    tq.fail(dep.id, 'err');\n\n    expect(tq.take()).toBeNull(); // child stays blocked\n  });\n\n  it('should report dependency status', () => {\n    const d1 = tq.add({ data: 'a' });\n    const d2 = tq.add({ data: 'b' });\n    const child = tq.add({ data: 'c', dependencies: [d1.id, d2.id] });\n\n    const status = tq.getDependencyStatus(child.id);\n    expect(status).toHaveLength(2);\n    expect(status.find(s => s.taskId === d1.id)!.status).toBe('pending');\n  });\n\n  it('should support multiple dependencies', () => {\n    const d1 = tq.add({ data: 'dep1' });\n    const d2 = tq.add({ data: 'dep2' });\n    tq.add({ data: 'child', dependencies: [d1.id, d2.id] });\n\n    // Complete first dep\n    const t1 = tq.take()!;\n    tq.complete(t1.id);\n\n    // Child still blocked (d2 not complete)\n    const t2 = tq.take()!;\n    expect(t2.data).toBe('dep2');\n\n    // Child still blocked while d2 processing\n    expect(tq.take()).toBeNull();\n\n    tq.complete(t2.id);\n\n    // Now child is available\n    const child = tq.take()!;\n    expect(child.data).toBe('child');\n  });\n});\n\n// ═══════════════════════════════════════════════════════════════════════\n// Phase 8: Concurrency Control\n// ═══════════════════════════════════════════════════════════════════════\n\ndescribe('Phase 8: Concurrency Control', () => {\n  it('should limit concurrent processing', () => {\n    tq.setConcurrency('default', 2);\n    tq.add({ data: 'a' });\n    tq.add({ data: 'b' });\n    tq.add({ data: 'c' });\n\n    const t1 = tq.take()!;\n    const t2 = tq.take()!;\n    expect(t1).toBeTruthy();\n    expect(t2).toBeTruthy();\n    expect(tq.take()).toBeNull(); // at limit\n\n    tq.complete(t1.id);\n    const t3 = tq.take()!;\n    expect(t3).toBeTruthy();\n  });\n\n  it('should default to unlimited concurrency', () => {\n    expect(tq.getConcurrency()).toBe(0);\n  });\n\n  it('should track active count', () => {\n    tq.add({ data: 'a' });\n    tq.add({ data: 'b' });\n    expect(tq.getActiveCount()).toBe(0);\n\n    const t1 = tq.take()!;\n    expect(tq.getActiveCount()).toBe(1);\n\n    tq.take()!;\n    expect(tq.getActiveCount()).toBe(2);\n\n    tq.complete(t1.id);\n    expect(tq.getActiveCount()).toBe(1);\n  });\n\n  it('should free slot on fail', () => {\n    tq.setConcurrency('default', 1);\n    tq.add({ data: 'a', maxRetries: 0 });\n    tq.add({ data: 'b' });\n\n    const t1 = tq.take()!;\n    expect(tq.take()).toBeNull(); // at limit\n\n    tq.fail(t1.id);\n    const t2 = tq.take()!;\n    expect(t2.data).toBe('b');\n  });\n\n  it('should respect priority with concurrency limits', () => {\n    tq.setConcurrency('default', 1);\n    tq.add({ data: 'low', priority: 10 });\n    tq.add({ data: 'high', priority: 1 });\n\n    const t = tq.take()!;\n    expect(t.data).toBe('high');\n  });\n});\n\n// ═══════════════════════════════════════════════════════════════════════\n// Phase 9: Progress and Cancellation\n// ═══════════════════════════════════════════════════════════════════════\n\ndescribe('Phase 9: Progress and Cancellation', () => {\n  it('should track progress', () => {\n    tq.add({ data: 'x' });\n    const task = tq.take()!;\n\n    tq.updateProgress(task.id, 50, 'halfway');\n    const prog = tq.getProgress(task.id);\n    expect(prog.progress).toBe(50);\n    expect(prog.message).toBe('halfway');\n  });\n\n  it('should notify progress listeners', () => {\n    tq.add({ data: 'x' });\n    const task = tq.take()!;\n\n    const updates: number[] = [];\n    tq.onProgress(task.id, (p) => updates.push(p));\n\n    tq.updateProgress(task.id, 25);\n    tq.updateProgress(task.id, 75);\n\n    expect(updates).toEqual([25, 75]);\n  });\n\n  it('should allow unsubscribing from progress', () => {\n    tq.add({ data: 'x' });\n    const task = tq.take()!;\n\n    const updates: number[] = [];\n    const unsub = tq.onProgress(task.id, (p) => updates.push(p));\n\n    tq.updateProgress(task.id, 25);\n    unsub();\n    tq.updateProgress(task.id, 75);\n\n    expect(updates).toEqual([25]);\n  });\n\n  it('should cancel a pending task', () => {\n    const task = tq.add({ data: 'x' });\n    const cancelled = tq.cancel(task.id);\n\n    expect(cancelled.status).toBe('cancelled');\n    expect(tq.take()).toBeNull();\n    expect(tq.size()).toBe(0);\n  });\n\n  it('should cancel a processing task', () => {\n    tq.add({ data: 'x' });\n    const task = tq.take()!;\n\n    const cancelled = tq.cancel(task.id);\n    expect(cancelled.status).toBe('cancelled');\n  });\n\n  it('should not retry cancelled tasks', () => {\n    tq.add({ data: 'x', maxRetries: 3 });\n    const task = tq.take()!;\n    tq.cancel(task.id);\n\n    expect(task.status).toBe('cancelled');\n    expect(tq.take()).toBeNull();\n  });\n\n  it('should reject invalid progress values', () => {\n    tq.add({ data: 'x' });\n    const task = tq.take()!;\n    expect(() => tq.updateProgress(task.id, -1)).toThrow();\n    expect(() => tq.updateProgress(task.id, 101)).toThrow();\n  });\n\n  it('should not cancel completed tasks', () => {\n    tq.add({ data: 'x' });\n    const task = tq.take()!;\n    tq.complete(task.id);\n    expect(() => tq.cancel(task.id)).toThrow();\n  });\n});\n\n// ═══════════════════════════════════════════════════════════════════════\n// Phase 10: Recurring Tasks\n// ═══════════════════════════════════════════════════════════════════════\n\ndescribe('Phase 10: Recurring Tasks', () => {\n  it('should create a schedule', () => {\n    const sched = tq.addSchedule({\n      id: 'every5min',\n      cron: '*/5 * * * *',\n      data: { action: 'cleanup' },\n    });\n    expect(sched.id).toBe('every5min');\n    expect(sched.cron).toBe('*/5 * * * *');\n  });\n\n  it('should enqueue tasks on tick when cron matches', () => {\n    tq.addSchedule({\n      id: 'hourly',\n      cron: '0 * * * *',\n      queue: 'jobs',\n      data: { type: 'hourly' },\n    });\n\n    const atHour = new Date(2024, 0, 1, 10, 0, 0);\n    const created = tq.tick(atHour);\n    expect(created).toHaveLength(1);\n    expect(created[0].queue).toBe('jobs');\n    expect(created[0].data).toEqual({ type: 'hourly' });\n  });\n\n  it('should not enqueue when cron does not match', () => {\n    tq.addSchedule({\n      id: 'hourly',\n      cron: '0 * * * *',\n    });\n\n    const notOnHour = new Date(2024, 0, 1, 10, 15, 0);\n    const created = tq.tick(notOnHour);\n    expect(created).toHaveLength(0);\n  });\n\n  it('should not double-enqueue in same minute', () => {\n    tq.addSchedule({ id: 's', cron: '*/5 * * * *' });\n\n    const t = new Date(2024, 0, 1, 10, 0, 0);\n    tq.tick(t);\n    const second = tq.tick(new Date(2024, 0, 1, 10, 0, 30));\n    expect(second).toHaveLength(0);\n  });\n\n  it('should remove a schedule', () => {\n    tq.addSchedule({ id: 's', cron: '* * * * *' });\n    tq.removeSchedule('s');\n\n    const t = new Date(2024, 0, 1, 10, 0, 0);\n    expect(tq.tick(t)).toHaveLength(0);\n  });\n\n  it('should list schedules', () => {\n    tq.addSchedule({ id: 'a', cron: '* * * * *' });\n    tq.addSchedule({ id: 'b', cron: '0 * * * *' });\n    expect(tq.listSchedules()).toHaveLength(2);\n  });\n\n  it('should reject duplicate schedule ids', () => {\n    tq.addSchedule({ id: 's', cron: '* * * * *' });\n    expect(() => tq.addSchedule({ id: 's', cron: '* * * * *' })).toThrow();\n  });\n\n  it('should reject removing non-existent schedule', () => {\n    expect(() => tq.removeSchedule('nope')).toThrow();\n  });\n\n  it('should support every-N-minutes cron', () => {\n    tq.addSchedule({ id: 's', cron: '*/15 * * * *' });\n\n    expect(tq.tick(new Date(2024, 0, 1, 10, 0, 0))).toHaveLength(1);\n    expect(tq.tick(new Date(2024, 0, 1, 10, 10, 0))).toHaveLength(0);\n    expect(tq.tick(new Date(2024, 0, 1, 10, 15, 0))).toHaveLength(1);\n    expect(tq.tick(new Date(2024, 0, 1, 10, 30, 0))).toHaveLength(1);\n  });\n\n  it('should support daily-at-midnight cron', () => {\n    tq.addSchedule({ id: 's', cron: '0 0 * * *' });\n\n    expect(tq.tick(new Date(2024, 0, 1, 0, 0, 0))).toHaveLength(1);\n    expect(tq.tick(new Date(2024, 0, 1, 12, 0, 0))).toHaveLength(0);\n    expect(tq.tick(new Date(2024, 0, 2, 0, 0, 0))).toHaveLength(1);\n  });\n\n  it('should enqueue tasks subject to queue rules', () => {\n    tq.addSchedule({\n      id: 's',\n      cron: '* * * * *',\n      queue: 'myq',\n      priority: 2,\n    });\n\n    const created = tq.tick(new Date(2024, 0, 1, 10, 0, 0));\n    expect(created[0].queue).toBe('myq');\n    expect(created[0].priority).toBe(2);\n  });\n});\n\n// ═══════════════════════════════════════════════════════════════════════\n// Phase 11: Middleware Pipeline\n// ═══════════════════════════════════════════════════════════════════════\n\ndescribe('Phase 11: Middleware Pipeline', () => {\n  it('should execute middleware before handler', async () => {\n    const order: string[] = [];\n    tq.add({ queue: 'q', data: 'x' });\n\n    tq.use('q', async (_task, next) => {\n      order.push('mw1');\n      await next();\n    });\n\n    const task = await tq.process('q', async () => {\n      order.push('handler');\n    });\n\n    expect(task).toBeTruthy();\n    expect(order).toEqual(['mw1', 'handler']);\n    expect(task!.status).toBe('completed');\n  });\n\n  it('should chain multiple middleware in order', async () => {\n    const order: string[] = [];\n    tq.add({ queue: 'q', data: 'x' });\n\n    tq.use('q', async (_task, next) => { order.push('mw1'); await next(); });\n    tq.use('q', async (_task, next) => { order.push('mw2'); await next(); });\n\n    await tq.process('q', async () => { order.push('handler'); });\n    expect(order).toEqual(['mw1', 'mw2', 'handler']);\n  });\n\n  it('should skip handler if middleware does not call next', async () => {\n    tq.add({ queue: 'q', data: 'x' });\n    let handlerCalled = false;\n\n    tq.use('q', async () => {\n      // deliberately not calling next\n    });\n\n    const task = await tq.process('q', async () => {\n      handlerCalled = true;\n    });\n\n    expect(handlerCalled).toBe(false);\n    expect(task).toBeTruthy();\n    // task stays in processing since middleware skipped\n    expect(task!.status).toBe('processing');\n  });\n\n  it('should allow middleware to modify task data', async () => {\n    tq.add({ queue: 'q', data: { value: 1 } });\n\n    tq.use('q', async (task, next) => {\n      (task.data as { value: number }).value = 42;\n      await next();\n    });\n\n    let receivedValue: number | undefined;\n    await tq.process('q', async (task) => {\n      receivedValue = (task.data as { value: number }).value;\n    });\n\n    expect(receivedValue).toBe(42);\n  });\n\n  it('should fail task when middleware throws', async () => {\n    tq.add({ queue: 'q', data: 'x', maxRetries: 0 });\n\n    tq.use('q', async () => {\n      throw new Error('middleware error');\n    });\n\n    const task = await tq.process('q', async () => {});\n    expect(task!.status).toBe('dead-letter');\n    expect(task!.error).toBe('middleware error');\n  });\n\n  it('should fail task when handler throws', async () => {\n    tq.add({ queue: 'q', data: 'x', maxRetries: 0 });\n\n    const task = await tq.process('q', async () => {\n      throw new Error('handler error');\n    });\n\n    expect(task!.status).toBe('dead-letter');\n    expect(task!.error).toBe('handler error');\n  });\n\n  it('should return null when no tasks available', async () => {\n    const result = await tq.process('q', async () => {});\n    expect(result).toBeNull();\n  });\n\n  it('should have independent middleware per queue', async () => {\n    tq.add({ queue: 'a', data: 'x' });\n    tq.add({ queue: 'b', data: 'y' });\n\n    let aMwCalled = false;\n    tq.use('a', async (_task, next) => { aMwCalled = true; await next(); });\n\n    await tq.process('b', async () => {});\n    expect(aMwCalled).toBe(false);\n\n    await tq.process('a', async () => {});\n    expect(aMwCalled).toBe(true);\n  });\n});\n\n// ═══════════════════════════════════════════════════════════════════════\n// Phase 12: Graceful Shutdown\n// ═══════════════════════════════════════════════════════════════════════\n\ndescribe('Phase 12: Graceful Shutdown', () => {\n  it('should complete immediately with no processing tasks', async () => {\n    tq.add({ data: 'pending' });\n    const result = await tq.shutdown();\n    expect(result.completed).toBe(0);\n    expect(result.forceCancelled).toBe(0);\n    expect(result.duration).toBeGreaterThanOrEqual(0);\n  });\n\n  it('should reject new tasks after shutdown', async () => {\n    await tq.shutdown();\n    expect(() => tq.add({ data: 'x' })).toThrow(/shutting down/);\n  });\n\n  it('should wait for processing tasks', async () => {\n    tq.add({ data: 'x' });\n    const task = tq.take()!;\n\n    const shutdownPromise = tq.shutdown({ timeout: 5000 });\n\n    // Complete the task\n    tq.complete(task.id);\n\n    const result = await shutdownPromise;\n    expect(result.completed).toBe(1);\n    expect(result.forceCancelled).toBe(0);\n  });\n\n  it('should force-cancel on timeout', async () => {\n    tq.add({ data: 'x' });\n    tq.take()!;\n\n    const result = await tq.shutdown({ timeout: 50 });\n    expect(result.forceCancelled).toBe(1);\n  });\n\n  it('should run shutdown callbacks', async () => {\n    let called = false;\n    tq.onShutdown(() => { called = true; });\n    await tq.shutdown();\n    expect(called).toBe(true);\n  });\n\n  it('should be safe to call shutdown multiple times', async () => {\n    const r1 = tq.shutdown();\n    const r2 = tq.shutdown();\n    const [result1, result2] = await Promise.all([r1, r2]);\n    expect(result1).toBe(result2);\n  });\n\n  it('should include duration in result', async () => {\n    const result = await tq.shutdown();\n    expect(typeof result.duration).toBe('number');\n    expect(result.duration).toBeGreaterThanOrEqual(0);\n  });\n});\n\n// ═══════════════════════════════════════════════════════════════════════\n// Integration / Cross-phase tests\n// ═══════════════════════════════════════════════════════════════════════\n\ndescribe('Cross-phase integration', () => {\n  it('should handle priority + delayed + named queues', () => {\n    const now = Date.now();\n    tq.add({ queue: 'q', data: 'delayed-high', priority: 1, scheduledFor: new Date(now - 100) });\n    tq.add({ queue: 'q', data: 'immediate-low', priority: 10 });\n    tq.add({ queue: 'q', data: 'immediate-high', priority: 1 });\n\n    // Priority 1 tasks come first; among them, delayed-high has earlier availableAt\n    const t1 = tq.take('q')!;\n    expect(t1.data).toBe('delayed-high');\n    const t2 = tq.take('q')!;\n    expect(t2.data).toBe('immediate-high');\n    const t3 = tq.take('q')!;\n    expect(t3.data).toBe('immediate-low');\n  });\n\n  it('should handle dependencies + retry', () => {\n    const dep = tq.add({ data: 'dep' });\n    const child = tq.add({ data: 'child', dependencies: [dep.id], maxRetries: 1, retryDelay: 1 });\n\n    // Complete dependency\n    tq.take()!;\n    tq.complete(dep.id);\n\n    // Take child, fail it\n    const taken = tq.take()!;\n    expect(taken.id).toBe(child.id);\n    tq.fail(child.id, 'err');\n    expect(child.status).toBe('pending'); // retrying\n\n    // Should still be available after retry delay\n    child.availableAt = new Date(Date.now() - 1);\n    const retried = tq.take()!;\n    expect(retried.id).toBe(child.id);\n  });\n\n  it('should handle concurrency + priority', () => {\n    tq.setConcurrency('default', 1);\n    tq.add({ data: 'low', priority: 10 });\n    tq.add({ data: 'high', priority: 1 });\n\n    const t = tq.take()!;\n    expect(t.data).toBe('high');\n    expect(tq.take()).toBeNull(); // concurrency limit\n  });\n\n  it('should handle getTask', () => {\n    const task = tq.add({ data: 'x' });\n    const fetched = tq.getTask(task.id);\n    expect(fetched.id).toBe(task.id);\n  });\n\n  it('should throw for non-existent task', () => {\n    expect(() => tq.getTask('nope')).toThrow();\n  });\n});\n","structuredPatch":[{"oldStart":1,"oldLines":4,"newStart":1,"newLines":4,"lines":["-import { describe, it, expect, vi, beforeEach } from 'vitest';","+import { describe, it, expect, beforeEach } from 'vitest';"," import { TaskQueue } from './task-queue.js';"," "," let tq: TaskQueue;"]}