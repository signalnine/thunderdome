+import { randomUUID } from 'node:crypto';
+import type {
+  TaskStatus,
+  Task,
+  AddTaskOptions,
+  MiddlewareFn,
+  ProcessHandler,
+  ProgressCallback,
+  ScheduleOptions,
+  Schedule,
+  ShutdownOptions,
+  ShutdownResult,
+} from './types.js';
+
+const DEFAULT_QUEUE = 'default';
+const DEFAULT_PRIORITY = 5;
+const DEFAULT_MAX_RETRIES = 3;
+const DEFAULT_RETRY_DELAY = 1000;
+
+interface QueueConfig {
+  concurrency: number;
+  middleware: MiddlewareFn[];
+}
+
+export class TaskQueue {
+  private tasks = new Map<string, Task>();
+  private queueConfigs = new Map<string, QueueConfig>();
+  private knownQueues = new Set<string>();
+  private schedules = new Map<string, Schedule>();
+  private progressListeners = new Map<string, Set<ProgressCallback>>();
+  private shutdownCallbacks: (() => void | Promise<void>)[] = [];
+  private _isShuttingDown = false;
+  private _shutdownPromise: Promise<ShutdownResult> | null = null;
+  private _shutdownResolve?: (result: ShutdownResult) => void;
+  private _shutdownStartTime = 0;
+  private _shutdownCompletedCount = 0;
+  private _shutdownProcessingIds = new Set<string>();
+  private _shutdownTimer?: ReturnType<typeof setTimeout>;
+
+  // ── Phase 1: Add a task ──────────────────────────────────────────────
+
+  add(options?: AddTaskOptions): Task {
+    if (this._isShuttingDown) {
+      throw new Error('Queue is shutting down');
+    }
+
+    const opts = options ?? {};
+    const priority = opts.priority ?? DEFAULT_PRIORITY;
+
+    if (!Number.isInteger(priority) || priority < 1 || priority > 10) {
+      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);
+    }
+
+    const queue = opts.queue ?? DEFAULT_QUEUE;
+    const now = new Date();
+
+    let availableAt = now;
+    if (opts.delay != null && opts.delay > 0) {
+      availableAt = new Date(now.getTime() + opts.delay);
+    } else if (opts.scheduledFor != null) {
+      availableAt = opts.scheduledFor;
+    }
+
+    const dependencies = opts.dependencies ?? [];
+    for (const depId of dependencies) {
+      if (!this.tasks.has(depId)) {
+        throw new Error(`Dependency task '${depId}' does not exist`);
+      }
+    }
+
+    const taskId = opts.id ?? randomUUID();
+
+    if (dependencies.length > 0) {
+      this.checkCircularDeps(taskId, dependencies);
+    }
+
+    const task: Task = {
+      id: taskId,
+      queue,
+      status: 'pending',
+      data: opts.data,
+      priority,
+      createdAt: now,
+      updatedAt: now,
+      availableAt,
+      attempts: 0,
+      maxRetries: opts.maxRetries ?? DEFAULT_MAX_RETRIES,
+      retryDelay: opts.retryDelay ?? DEFAULT_RETRY_DELAY,
+      dependencies,
+      progress: 0,
+      progressMessage: undefined,
+      error: undefined,
+      failCount: 0,
+    };
+
+    this.tasks.set(task.id, task);
+    this.knownQueues.add(queue);
+    this.ensureQueueConfig(queue);
+
+    return task;
+  }
+
+  // ── Phase 1: Get next task ───────────────────────────────────────────
+
+  take(queue?: string): Task | null {
+    const queueName = queue ?? DEFAULT_QUEUE;
+    const config = this.ensureQueueConfig(queueName);
+
+    if (config.concurrency > 0) {
+      const active = this.getActiveCount(queueName);
+      if (active >= config.concurrency) {
+        return null;
+      }
+    }
+
+    const now = new Date();
+    const candidates: Task[] = [];
+
+    for (const t of this.tasks.values()) {
+      if (
+        t.queue === queueName &&
+        t.status === 'pending' &&
+        t.availableAt <= now &&
+        this.depsCompleted(t)
+      ) {
+        candidates.push(t);
+      }
+    }
+
+    if (candidates.length === 0) return null;
+
+    candidates.sort((a, b) => {
+      if (a.priority !== b.priority) return a.priority - b.priority;
+      const at = a.availableAt.getTime(), bt = b.availableAt.getTime();
+      if (at !== bt) return at - bt;
+      return a.createdAt.getTime() - b.createdAt.getTime();
+    });
+
+    const task = candidates[0];
+    task.status = 'processing';
+    task.attempts++;
+    task.updatedAt = new Date();
+    return task;
+  }
+
+  // ── Phase 1: Count pending tasks ────────────────────────────────────
+
+  size(queue?: string): number {
+    const queueName = queue ?? DEFAULT_QUEUE;
+    let count = 0;
+    for (const t of this.tasks.values()) {
+      if (t.queue === queueName && t.status === 'pending') count++;
+    }
+    return count;
+  }
+
+  // ── Phase 2: List queue names ───────────────────────────────────────
+
+  queues(): string[] {
+    return [...this.knownQueues];
+  }
+
+  // ── Phase 5: Complete a task ────────────────────────────────────────
+
+  complete(taskId: string): Task {
+    const task = this.mustGetTask(taskId);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot complete task in '${task.status}' state`);
+    }
+
+    task.status = 'completed';
+    task.progress = 100;
+    task.updatedAt = new Date();
+    this.onTaskFinished(taskId);
+    return task;
+  }
+
+  // ── Phase 5: Fail a task ────────────────────────────────────────────
+
+  fail(taskId: string, error?: string): Task {
+    const task = this.mustGetTask(taskId);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot fail task in '${task.status}' state`);
+    }
+
+    task.error = error;
+    task.failCount++;
+    task.updatedAt = new Date();
+
+    if (this._isShuttingDown) {
+      task.status = 'failed';
+      this.onTaskFinished(taskId);
+      return task;
+    }
+
+    if (task.attempts <= task.maxRetries) {
+      const delay = task.retryDelay * Math.pow(2, task.attempts - 1);
+      task.status = 'pending';
+      task.availableAt = new Date(Date.now() + delay);
+      task.progress = 0;
+      task.progressMessage = undefined;
+    } else {
+      task.status = 'dead-letter';
+    }
+
+    this.onTaskFinished(taskId);
+    return task;
+  }
+
+  // ── Phase 6: Dead letter queue ──────────────────────────────────────
+
+  getDeadLetterQueue(queue?: string): Task[] {
+    const queueName = queue ?? DEFAULT_QUEUE;
+    const result: Task[] = [];
+    for (const t of this.tasks.values()) {
+      if (t.queue === queueName && t.status === 'dead-letter') result.push(t);
+    }
+    return result;
+  }
+
+  requeue(taskId: string): Task {
+    const task = this.mustGetTask(taskId);
+    if (task.status !== 'dead-letter') {
+      throw new Error(`Cannot requeue task in '${task.status}' state`);
+    }
+
+    task.status = 'pending';
+    task.attempts = 0;
+    task.progress = 0;
+    task.progressMessage = undefined;
+    task.error = undefined;
+    task.availableAt = new Date();
+    task.updatedAt = new Date();
+    return task;
+  }
+
+  clearDeadLetterQueue(queue?: string): void {
+    const queueName = queue ?? DEFAULT_QUEUE;
+    for (const [id, t] of this.tasks) {
+      if (t.queue === queueName && t.status === 'dead-letter') {
+        this.tasks.delete(id);
+      }
+    }
+  }
+
+  // ── Phase 7: Dependencies ───────────────────────────────────────────
+
+  getDependencyStatus(taskId: string): { taskId: string; status: TaskStatus }[] {
+    const task = this.mustGetTask(taskId);
+    return task.dependencies.map(depId => {
+      const dep = this.tasks.get(depId);
+      return { taskId: depId, status: dep ? dep.status : ('unknown' as TaskStatus) };
+    });
+  }
+
+  // ── Phase 8: Concurrency control ───────────────────────────────────
+
+  setConcurrency(queue: string, limit: number): void {
+    this.ensureQueueConfig(queue).concurrency = limit;
+  }
+
+  getConcurrency(queue?: string): number {
+    return this.ensureQueueConfig(queue ?? DEFAULT_QUEUE).concurrency;
+  }
+
+  getActiveCount(queue?: string): number {
+    const queueName = queue ?? DEFAULT_QUEUE;
+    let count = 0;
+    for (const t of this.tasks.values()) {
+      if (t.queue === queueName && t.status === 'processing') count++;
+    }
+    return count;
+  }
+
+  // ── Phase 9: Progress tracking ─────────────────────────────────────
+
+  updateProgress(taskId: string, progress: number, message?: string): void {
+    const task = this.mustGetTask(taskId);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot update progress for task in '${task.status}' state`);
+    }
+    if (progress < 0 || progress > 100) {
+      throw new Error(`Invalid progress: ${progress}. Must be between 0 and 100.`);
+    }
+
+    task.progress = progress;
+    task.progressMessage = message;
+    task.updatedAt = new Date();
+
+    const listeners = this.progressListeners.get(taskId);
+    if (listeners) {
+      for (const cb of listeners) {
+        cb(progress, message);
+      }
+    }
+  }
+
+  getProgress(taskId: string): { progress: number; message?: string } {
+    const task = this.mustGetTask(taskId);
+    return { progress: task.progress, message: task.progressMessage };
+  }
+
+  onProgress(taskId: string, callback: ProgressCallback): () => void {
+    let set = this.progressListeners.get(taskId);
+    if (!set) {
+      set = new Set();
+      this.progressListeners.set(taskId, set);
+    }
+    set.add(callback);
+
+    return () => {
+      set!.delete(callback);
+      if (set!.size === 0) this.progressListeners.delete(taskId);
+    };
+  }
+
+  // ── Phase 9: Cancellation ──────────────────────────────────────────
+
+  cancel(taskId: string): Task {
+    const task = this.mustGetTask(taskId);
+    if (task.status !== 'pending' && task.status !== 'processing') {
+      throw new Error(`Cannot cancel task in '${task.status}' state`);
+    }
+
+    const wasProcessing = task.status === 'processing';
+    task.status = 'cancelled';
+    task.updatedAt = new Date();
+
+    if (wasProcessing) {
+      this.onTaskFinished(taskId);
+    }
+
+    return task;
+  }
+
+  // ── Phase 10: Recurring tasks ──────────────────────────────────────
+
+  addSchedule(options: ScheduleOptions): Schedule {
+    if (this.schedules.has(options.id)) {
+      throw new Error(`Schedule '${options.id}' already exists`);
+    }
+
+    const schedule: Schedule = {
+      id: options.id,
+      cron: options.cron,
+      queue: options.queue ?? DEFAULT_QUEUE,
+      data: options.data,
+      priority: options.priority ?? DEFAULT_PRIORITY,
+      maxRetries: options.maxRetries ?? DEFAULT_MAX_RETRIES,
+      retryDelay: options.retryDelay ?? DEFAULT_RETRY_DELAY,
+      lastRun: undefined,
+    };
+
+    this.schedules.set(schedule.id, schedule);
+    return schedule;
+  }
+
+  removeSchedule(id: string): void {
+    if (!this.schedules.has(id)) {
+      throw new Error(`Schedule '${id}' does not exist`);
+    }
+    this.schedules.delete(id);
+  }
+
+  listSchedules(): Schedule[] {
+    return [...this.schedules.values()];
+  }
+
+  tick(now?: Date): Task[] {
+    const currentTime = now ?? new Date();
+    const created: Task[] = [];
+
+    for (const schedule of this.schedules.values()) {
+      if (!this.cronMatches(schedule.cron, currentTime)) continue;
+      if (schedule.lastRun && this.sameMinute(schedule.lastRun, currentTime)) continue;
+
+      const task = this.add({
+        queue: schedule.queue,
+        data: typeof schedule.data === 'object' && schedule.data !== null
+          ? { ...schedule.data as Record<string, unknown> }
+          : schedule.data,
+        priority: schedule.priority,
+        maxRetries: schedule.maxRetries,
+        retryDelay: schedule.retryDelay,
+      });
+
+      schedule.lastRun = currentTime;
+      created.push(task);
+    }
+
+    return created;
+  }
+
+  // ── Phase 11: Middleware pipeline ───────────────────────────────────
+
+  use(queue: string, middleware: MiddlewareFn): void {
+    this.ensureQueueConfig(queue).middleware.push(middleware);
+  }
+
+  async process(queue: string, handler: ProcessHandler): Promise<Task | null> {
+    const queueName = queue ?? DEFAULT_QUEUE;
+    const task = this.take(queueName);
+    if (!task) return null;
+
+    const mw = [...this.ensureQueueConfig(queueName).middleware];
+
+    try {
+      let handlerReached = false;
+
+      const run = async (i: number): Promise<void> => {
+        if (i < mw.length) {
+          await mw[i](task, () => run(i + 1));
+        } else {
+          handlerReached = true;
+          await handler(task);
+        }
+      };
+
+      await run(0);
+
+      if (handlerReached && task.status === 'processing') {
+        this.complete(task.id);
+      }
+    } catch (err) {
+      if (task.status === 'processing') {
+        this.fail(task.id, err instanceof Error ? err.message : String(err));
+      }
+    }
+
+    return task;
+  }
+
+  // ── Phase 12: Graceful shutdown ────────────────────────────────────
+
+  onShutdown(callback: () => void | Promise<void>): void {
+    this.shutdownCallbacks.push(callback);
+  }
+
+  async shutdown(options?: ShutdownOptions): Promise<ShutdownResult> {
+    if (this._shutdownPromise) return this._shutdownPromise;
+
+    this._isShuttingDown = true;
+    this._shutdownStartTime = Date.now();
+    const timeout = options?.timeout ?? 5000;
+
+    for (const cb of this.shutdownCallbacks) {
+      await cb();
+    }
+
+    const processing: Task[] = [];
+    for (const t of this.tasks.values()) {
+      if (t.status === 'processing') processing.push(t);
+    }
+
+    this._shutdownProcessingIds = new Set(processing.map(t => t.id));
+    this._shutdownCompletedCount = 0;
+
+    if (processing.length === 0) {
+      const result: ShutdownResult = {
+        completed: 0,
+        forceCancelled: 0,
+        duration: Date.now() - this._shutdownStartTime,
+      };
+      this._shutdownPromise = Promise.resolve(result);
+      return this._shutdownPromise;
+    }
+
+    this._shutdownPromise = new Promise<ShutdownResult>(resolve => {
+      this._shutdownResolve = resolve;
+
+      this._shutdownTimer = setTimeout(() => {
+        const remaining: Task[] = [];
+        for (const t of this.tasks.values()) {
+          if (t.status === 'processing') remaining.push(t);
+        }
+        for (const t of remaining) {
+          t.status = 'cancelled';
+          t.updatedAt = new Date();
+        }
+        resolve({
+          completed: this._shutdownCompletedCount,
+          forceCancelled: remaining.length,
+          duration: Date.now() - this._shutdownStartTime,
+        });
+      }, timeout);
+    });
+
+    return this._shutdownPromise;
+  }
+
+  // ── Public helpers ─────────────────────────────────────────────────
+
+  getTask(taskId: string): Task {
+    return this.mustGetTask(taskId);
+  }
+
+  hasTask(taskId: string): boolean {
+    return this.tasks.has(taskId);
+  }
+
+  // ── Private helpers ────────────────────────────────────────────────
+
+  private mustGetTask(taskId: string): Task {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task '${taskId}' not found`);
+    return task;
+  }
+
+  private ensureQueueConfig(name: string): QueueConfig {
+    let cfg = this.queueConfigs.get(name);
+    if (!cfg) {
+      cfg = { concurrency: 0, middleware: [] };
+      this.queueConfigs.set(name, cfg);
+    }
+    return cfg;
+  }
+
+  private depsCompleted(task: Task): boolean {
+    for (const depId of task.dependencies) {
+      const dep = this.tasks.get(depId);
+      if (!dep || dep.status !== 'completed') return false;
+    }
+    return true;
+  }
+
+  private checkCircularDeps(newId: string, deps: string[]): void {
+    const visited = new Set<string>();
+    const stack = [...deps];
+
+    while (stack.length > 0) {
+      const cur = stack.pop()!;
+      if (cur === newId) {
+        throw new Error('Circular dependency detected');
+      }
+      if (visited.has(cur)) continue;
+      visited.add(cur);
+
+      const t = this.tasks.get(cur);
+      if (t) {
+        for (const d of t.dependencies) stack.push(d);
+      }
+    }
+  }
+
+  private cronMatches(cron: string, date: Date): boolean {
+    const parts = cron.trim().split(/\s+/);
+    if (parts.length !== 5) return false;
+    return this.fieldMatches(parts[0], date.getMinutes()) &&
+           this.fieldMatches(parts[1], date.getHours());
+  }
+
+  private fieldMatches(field: string, value: number): boolean {
+    if (field === '*') return true;
+    if (field.startsWith('*/')) {
+      const step = parseInt(field.slice(2), 10);
+      return !isNaN(step) && step > 0 && value % step === 0;
+    }
+    return parseInt(field, 10) === value;
+  }
+
+  private sameMinute(a: Date, b: Date): boolean {
+    return (
+      a.getFullYear() === b.getFullYear() &&
+      a.getMonth() === b.getMonth() &&
+      a.getDate() === b.getDate() &&
+      a.getHours() === b.getHours() &&
+      a.getMinutes() === b.getMinutes()
+    );
+  }
+
+  private onTaskFinished(taskId: string): void {
+    if (!this._isShuttingDown || !this._shutdownResolve) return;
+    if (!this._shutdownProcessingIds.has(taskId)) return;
+
+    this._shutdownProcessingIds.delete(taskId);
+    this._shutdownCompletedCount++;
+
+    if (this._shutdownProcessingIds.size === 0) {
+      if (this._shutdownTimer) clearTimeout(this._shutdownTimer);
+      this._shutdownResolve({
+        completed: this._shutdownCompletedCount,
+        forceCancelled: 0,
+        duration: Date.now() - this._shutdownStartTime,
+      });
+    }
+  }
+}
diff --git a/src/types.ts b/src/types.ts
new file mode 100644
index 0000000..e01099f
--- /dev/null
+++ b/src/types.ts
@@ -0,0 +1,67 @@
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'dead-letter' | 'cancelled';
+
+export interface AddTaskOptions {
+  id?: string;
+  queue?: string;
+  data?: unknown;
+  priority?: number;
+  delay?: number;
+  scheduledFor?: Date;
+  maxRetries?: number;
+  retryDelay?: number;
+  dependencies?: string[];
+}
+
+export interface Task {
+  id: string;
+  queue: string;
+  status: TaskStatus;
+  data: unknown;
+  priority: number;
+  createdAt: Date;
+  updatedAt: Date;
+  availableAt: Date;
+  attempts: number;
+  maxRetries: number;
+  retryDelay: number;
+  dependencies: string[];
+  progress: number;
+  progressMessage?: string;
+  error?: string;
+  failCount: number;
+}
+
+export type MiddlewareFn = (task: Task, next: () => Promise<void>) => void | Promise<void>;
+export type ProcessHandler = (task: Task) => void | Promise<void>;
+export type ProgressCallback = (progress: number, message?: string) => void;
+
+export interface ScheduleOptions {
+  id: string;
+  cron: string;
+  queue?: string;
+  data?: unknown;
+  priority?: number;
+  maxRetries?: number;
+  retryDelay?: number;
+}
+
+export interface Schedule {
+  id: string;
+  cron: string;
+  queue: string;
+  data: unknown;
+  priority: number;
+  maxRetries: number;
+  retryDelay: number;
+  lastRun?: Date;
+}
+
+export interface ShutdownOptions {
+  timeout?: number;
+}
+
+export interface ShutdownResult {
+  completed: number;
+  forceCancelled: number;
+  duration: number;
+}
