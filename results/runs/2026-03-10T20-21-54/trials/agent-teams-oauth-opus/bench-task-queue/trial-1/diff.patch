ild.id);\n    tq.fail(child.id, 'err');\n    expect(child.status).toBe('pending'); // retrying\n\n    // Should still be available after retry delay\n    child.availableAt = new Date(Date.now() - 1);\n    const retried = tq.take()!;\n    expect(retried.id).toBe(child.id);\n  });\n\n  it('should handle concurrency + priority', () => {\n    tq.setConcurrency('default', 1);\n    tq.add({ data: 'low', priority: 10 });\n    tq.add({ data: 'high', priority: 1 });\n\n    const t = tq.take()!;\n    expect(t.data).toBe('high');\n    expect(tq.take()).toBeNull(); // concurrency limit\n  });\n\n  it('should handle getTask', () => {\n    const task = tq.add({ data: 'x' });\n    const fetched = tq.getTask(task.id);\n    expect(fetched.id).toBe(task.id);\n  });\n\n  it('should throw for non-existent task', () => {\n    expect(() => tq.getTask('nope')).toThrow();\n  });\n});\n","structuredPatch":[{"oldStart":872,"oldLines":11,"newStart":872,"newLines":11,"lines":["     tq.add({ queue: 'q', data: 'immediate-low', priority: 10 });","     tq.add({ queue: 'q', data: 'immediate-high', priority: 1 });"," ","-    // Priority 1 tasks come first; among them, immediate has earlier availableAt","+    // Priority 1 tasks come first; among them, delayed-high has earlier availableAt","     const t1 = tq.take('q')!;","-    expect(t1.data).toBe('immediate-high');","+    expect(t1.data).toBe('delayed-high');","     const t2 = tq.take('q')!;","-    expect(t2.data).toBe('delayed-high');","+    expect(t2.data).toBe('immediate-high');","     const t3 = tq.take('q')!;","     expect(t3.data).toBe('immediate-low');","   });"]}],"userModified":false,"replaceAll":false},"sourceToolAssistantUUID":"3e13fcf5-f123-4a83-a154-7c0aa7b95884"}
