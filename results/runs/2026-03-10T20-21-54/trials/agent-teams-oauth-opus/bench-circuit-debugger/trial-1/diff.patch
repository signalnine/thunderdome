nal carry -> z(maxBit+1))\n\n  const lastZ = `z${String(maxBit + 1).padStart(2, '0')}`;\n\n  for (const gate of gates) {\n    const out = gate.out;\n    const isZOutput = /^z\\d+$/.test(out);\n    const hasXYInput = isInput(gate.in1) || isInput(gate.in2);\n\n    if (gate.op === 'XOR') {\n      if (hasXYInput) {\n        // XOR of x/y inputs (partial sum). For bit 0, should go to z00.\n        // For other bits, should NOT go to a z-wire (it goes to an intermediate).\n        const bitMatch1 = gate.in1.match(/^[xy](\\d+)$/);\n        const bitMatch2 = gate.in2.match(/^[xy](\\d+)$/);\n        if (bitMatch1 && bitMatch2) {\n          const bit = parseInt(bitMatch1[1], 10);\n          if (bit === 0) {\n            // Should output to z00\n            if (out !== 'z00') {\n              swapped.add(out);\n            }\n          } else {\n            // Should NOT output to z-wire directly\n            if (isZOutput) {\n              swapped.add(out);\n            }\n          }\n        }\n      } else {\n        // XOR of non-x/y inputs: this is a final sum gate, must output to z-wire\n        if (!isZOutput) {\n          swapped.add(out);\n        }\n      }\n    } else if (gate.op === 'AND') {\n      // AND gate should never output to z-wire\n      if (isZOutput) {\n        swapped.add(out);\n      }\n    } else if (gate.op === 'OR') {\n      // OR gate (carry-out) should not output to z-wire, except the final carry\n      if (isZOutput && out !== lastZ) {\n        swapped.add(out);\n      }\n    }\n  }\n\n  // Additional structural checks: verify connectivity\n  // For each XOR of xNN/yNN (partial sum), it should be used as input to:\n  //   1. Another XOR gate (to produce zNN)\n  //   2. An AND gate (propagate carry)\n  // If the partial sum wire isn't used in any XOR gate, something's wrong.\n  for (const gate of gates) {\n    if (gate.op !== 'XOR') continue;\n    const hasXYInput = isInput(gate.in1) && isInput(gate.in2);\n    if (!hasXYInput) continue;\n\n    const bitMatch = gate.in1.match(/^[xy](\\d+)$/);\n    if (!bitMatch) continue;\n    const bit = parseInt(bitMatch[1], 10);\n    if (bit === 0) continue; // bit 0 is a half adder, skip\n\n    const partialSum = gate.out;\n    if (swapped.has(partialSum)) continue; // already flagged\n\n    // The partial sum should be input to a XOR gate\n    const sumGate = findGateWithInput('XOR', partialSum);\n    if (!sumGate) {\n      swapped.add(partialSum);\n    }\n  }\n\n  // For OR gates (carry-out), each should feed into the next bit's XOR and AND gates\n  // If an OR gate's output goes nowhere useful, it might be swapped\n  for (const gate of gates) {\n    if (gate.op !== 'OR') continue;\n    const carryOut = gate.out;\n    if (swapped.has(carryOut)) continue;\n    if (carryOut === lastZ) continue; // final carry to output, OK\n\n    // A carry-out should be used in at least one XOR gate (for the next bit's sum)\n    const xorUser = findGateWithInput('XOR', carryOut);\n    if (!xorUser) {\n      swapped.add(carryOut);\n    }\n  }\n\n  // For AND gates (both generate-carry and propagate-carry),\n  // their outputs should feed into OR gates (except bit 0's AND which is the carry directly)\n  for (const gate of gates) {\n    if (gate.op !== 'AND') continue;\n    const andOut = gate.out;\n    if (swapped.has(andOut)) continue;\n\n    // Check if this is bit 0's carry (x00 AND y00)\n    if (gateHasInputs(gate, 'x00', 'y00')) continue; // bit 0 carry, goes directly to next XOR\n\n    // Other AND outputs should feed into OR gates\n    const orUser = findGateWithInput('OR', andOut);\n    if (!orUser) {\n      swapped.add(andOut);\n    }\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[{"oldStart":59,"oldLines":12,"newStart":59,"newLines":6,"lines":[" export function findSwappedWires(gates: Gate[]): string[] {","   const swapped = new Set<string>();"," ","-  // Build lookup maps","-  const gateByOutput = new Map<string, Gate>();","-  for (const g of gates) {","-    gat