+import { describe, it, expect } from 'vitest';
+import { simulate, findSwappedWires, Gate } from '../src/index.js';
+
+describe('simulate', () => {
+  it('should evaluate AND gate', () => {
+    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });
+    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 0 });
+    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 0 });
+    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });
+  });
+
+  it('should evaluate OR gate', () => {
+    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });
+    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });
+    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });
+    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });
+  });
+
+  it('should evaluate XOR gate', () => {
+    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 0 });
+    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });
+    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });
+    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });
+  });
+
+  it('should handle chained gates in dependency order', () => {
+    const gates: Gate[] = [
+      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },
+      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },
+    ];
+    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({
+      a: 1, b: 1, c: 1, d: 0, e: 1,
+    });
+    expect(simulate(gates, { a: 0, b: 1, d: 0 })).toEqual({
+      a: 0, b: 1, c: 0, d: 0, e: 0,
+    });
+  });
+
+  it('should handle gates listed in reverse dependency order', () => {
+    const gates: Gate[] = [
+      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },
+      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },
+    ];
+    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({
+      a: 1, b: 1, c: 1, d: 0, e: 1,
+    });
+  });
+
+  it('should simulate a half-adder (bit 0)', () => {
+    const gates: Gate[] = [
+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+    ];
+    expect(simulate(gates, { x00: 1, y00: 1 })).toEqual({
+      x00: 1, y00: 1, z00: 0, c00: 1,
+    });
+    expect(simulate(gates, { x00: 1, y00: 0 })).toEqual({
+      x00: 1, y00: 0, z00: 1, c00: 0,
+    });
+  });
+
+  it('should simulate a 4-bit adder correctly', () => {
+    const gates = makeAdder(4);
+    // 15 + 15 = 30 (1111 + 1111 = 11110)
+    const result = simulate(gates, {
+      x00: 1, x01: 1, x02: 1, x03: 1,
+      y00: 1, y01: 1, y02: 1, y03: 1,
+    });
+    expect(result.z00).toBe(0);
+    expect(result.z01).toBe(1);
+    expect(result.z02).toBe(1);
+    expect(result.z03).toBe(1);
+    expect(result.z04).toBe(1);
+
+    // 5 + 3 = 8 (0101 + 0011 = 01000)
+    const result2 = simulate(gates, {
+      x00: 1, x01: 0, x02: 1, x03: 0,
+      y00: 1, y01: 1, y02: 0, y03: 0,
+    });
+    expect(result2.z00).toBe(0);
+    expect(result2.z01).toBe(0);
+    expect(result2.z02).toBe(0);
+    expect(result2.z03).toBe(1);
+    expect(result2.z04).toBe(0);
+  });
+});
+
+// Helper: create a correct N-bit ripple-carry adder
+function makeAdder(bits: number): Gate[] {
+  const gates: Gate[] = [
+    { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+    { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+  ];
+  for (let i = 1; i < bits; i++) {
+    const nn = String(i).padStart(2, '0');
+    const prev = String(i - 1).padStart(2, '0');
+    const isLast = i === bits - 1;
+    const carryOut = isLast
+      ? `z${String(bits).padStart(2, '0')}`
+      : `c${nn}`;
+    gates.push(
+      { op: 'XOR', in1: `x${nn}`, in2: `y${nn}`, out: `t${nn}` },
+      { op: 'XOR', in1: `t${nn}`, in2: `c${prev}`, out: `z${nn}` },
+      { op: 'AND', in1: `x${nn}`, in2: `y${nn}`, out: `a${nn}` },
+      { op: 'AND', in1: `t${nn}`, in2: `c${prev}`, out: `b${nn}` },
+      { op: 'OR', in1: `a${nn}`, in2: `b${nn}`, out: carryOut },
+    );
+  }
+  return gates;
+}
+
+// Helper: swap two gate outputs
+function swapOutputs(gates: Gate[], wire1: string, wire2: string): Gate[] {
+  return gates.map((g) => {
+    if (g.out === wire1) return { ...g, out: wire2 };
+    if (g.out === wire2) return { ...g, out: wire1 };
+    return g;
+  });
+}
+
+describe('findSwappedWires', () => {
+  it('should find swapped z-wires with AND outputs', () => {
+    let gates = makeAdder(8);
+    gates = swapOutputs(gates, 'z01', 'a01');
+    gates = swapOutputs(gates, 'z03', 'a03');
+    gates = swapOutputs(gates, 'z05', 'a05');
+    gates = swapOutputs(gates, 'z07', 'a07');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(['a01', 'a03', 'a05', 'a07', 'z01', 'z03', 'z05', 'z07']);
+  });
+
+  it('should find mixed swap types', () => {
+    let gates = makeAdder(10);
+    // z ↔ AND (sum output with generate carry)
+    gates = swapOutputs(gates, 'z02', 'a02');
+    // z ↔ AND (sum output with propagate carry)
+    gates = swapOutputs(gates, 'z05', 'b05');
+    // AND ↔ OR from different bits (generate carry with carry-out)
+    gates = swapOutputs(gates, 'a08', 'c03');
+    // XOR partial sum ↔ AND from different bit
+    gates = swapOutputs(gates, 't06', 'b04');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(['a02', 'a08', 'b04', 'b05', 'c03', 't06', 'z02', 'z05']);
+  });
+
+  it('should find swaps in a larger circuit', () => {
+    let gates = makeAdder(16);
+    gates = swapOutputs(gates, 'z05', 'a05');
+    gates = swapOutputs(gates, 'z10', 'b10');
+    gates = swapOutputs(gates, 'a03', 'c08');
+    gates = swapOutputs(gates, 'a14', 'c12');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(['a03', 'a05', 'a14', 'b10', 'c08', 'c12', 'z05', 'z10']);
+  });
+
+  it('should work with random wire names', () => {
+    const gates: Gate[] = [
+      // bit 0: half adder
+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'abc' },
+      // bit 1
+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 'def' },
+      { op: 'XOR', in1: 'def', in2: 'abc', out: 'z01' },
+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'ghi' },
+      { op: 'AND', in1: 'def', in2: 'abc', out: 'jkl' },
+      { op: 'OR', in1: 'ghi', in2: 'jkl', out: 'mno' },
+      // bit 2
+      { op: 'XOR', in1: 'x02', in2: 'y02', out: 'pqr' },
+      { op: 'XOR', in1: 'pqr', in2: 'mno', out: 'z02' },
+      { op: 'AND', in1: 'x02', in2: 'y02', out: 'stu' },
+      { op: 'AND', in1: 'pqr', in2: 'mno', out: 'vwx' },
+      { op: 'OR', in1: 'stu', in2: 'vwx', out: 'yza' },
+      // bit 3
+      { op: 'XOR', in1: 'x03', in2: 'y03', out: 'bcd' },
+      { op: 'XOR', in1: 'bcd', in2: 'yza', out: 'z03' },
+      { op: 'AND', in1: 'x03', in2: 'y03', out: 'efg' },
+      { op: 'AND', in1: 'bcd', in2: 'yza', out: 'hij' },
+      { op: 'OR', in1: 'efg', in2: 'hij', out: 'klm' },
+      // bit 4
+      { op: 'XOR', in1: 'x04', in2: 'y04', out: 'nop' },
+      { op: 'XOR', in1: 'nop', in2: 'klm', out: 'z04' },
+      { op: 'AND', in1: 'x04', in2: 'y04', out: 'qrs' },
+      { op: 'AND', in1: 'nop', in2: 'klm', out: 'tuv' },
+      { op: 'OR', in1: 'qrs', in2: 'tuv', out: 'wxy' },
+      // bit 5
+      { op: 'XOR', in1: 'x05', in2: 'y05', out: 'zab' },
+      { op: 'XOR', in1: 'zab', in2: 'wxy', out: 'z05' },
+      { op: 'AND', in1: 'x05', in2: 'y05', out: 'cde' },
+      { op: 'AND', in1: 'zab', in2: 'wxy', out: 'fgh' },
+      { op: 'OR', in1: 'cde', in2: 'fgh', out: 'ijk' },
+      // bit 6
+      { op: 'XOR', in1: 'x06', in2: 'y06', out: 'lmn' },
+      { op: 'XOR', in1: 'lmn', in2: 'ijk', out: 'z06' },
+      { op: 'AND', in1: 'x06', in2: 'y06', out: 'opq' },
+      { op: 'AND', in1: 'lmn', in2: 'ijk', out: 'rst' },
+      { op: 'OR', in1: 'opq', in2: 'rst', out: 'uvw' },
+      // bit 7
+      { op: 'XOR', in1: 'x07', in2: 'y07', out: 'xyz' },
+      { op: 'XOR', in1: 'xyz', in2: 'uvw', out: 'z07' },
+      { op: 'AND', in1: 'x07', in2: 'y07', out: 'aab' },
+      { op: 'AND', in1: 'xyz', in2: 'uvw', out: 'aac' },
+      { op: 'OR', in1: 'aab', in2: 'aac', out: 'z08' },
+    ];
+
+    // Swap 4 pairs with detectable violations:
+    // z01 ↔ ghi (sum XOR output ↔ generate carry AND output)
+    // z03 ↔ efg (sum XOR output ↔ generate carry AND output)
+    // opq ↔ ijk (generate carry ↔ carry-out from different bit)
+    // aac ↔ z07 (propagate carry AND ↔ sum z output)
+    const swapped = gates.map((g) => {
+      if (g.out === 'z01') return { ...g, out: 'ghi' };
+      if (g.out === 'ghi') return { ...g, out: 'z01' };
+      if (g.out === 'z03') return { ...g, out: 'efg' };
+      if (g.out === 'efg') return { ...g, out: 'z03' };
+      if (g.out === 'opq') return { ...g, out: 'ijk' };
+      if (g.out === 'ijk') return { ...g, out: 'opq' };
+      if (g.out === 'aac') return { ...g, out: 'z07' };
+      if (g.out === 'z07') return { ...g, out: 'aac' };
+      return g;
+    });
+
+    const result = findSwappedWires(swapped);
+    expect(result).toEqual(['aac', 'efg', 'ghi', 'ijk', 'opq', 'z01', 'z03', 'z07']);
+  });
+
+  it('should handle 45-bit adder within 5 seconds', () => {
+    let gates = makeAdder(45);
+    gates = swapOutputs(gates, 'z10', 'a10');
+    gates = swapOutputs(gates, 'z20', 'b20');
+    gates = swapOutputs(gates, 'a30', 'c15');
+    gates = swapOutputs(gates, 'z40', 'a40');
+
+    const start = Date.now();
+    const result = findSwappedWires(gates);
+    const elapsed = Date.now() - start;
+
+    expect(result).toEqual(['a10', 'a30', 'a40', 'b20', 'c15', 'z10', 'z20', 'z40']);
+    expect(elapsed).toBeLessThan(5000);
+  });
+
+  it('should handle swap involving bit 0 carry', () => {
+    let gates = makeAdder(8);
+    // Swap bit 0's carry with a generate carry from a different bit
+    // c00 ↔ a05: c00 feeds XOR (correct), a05 feeds OR (correct for AND output)
+    // After swap: c00 position has a05 (feeds OR, not XOR → flagged),
+    //             a05 position has c00 (feeds XOR, not OR → flagged)
+    gates = swapOutputs(gates, 'c00', 'a05');
+    gates = swapOutputs(gates, 'z02', 'b02');
+    gates = swapOutputs(gates, 'z04', 'a04');
+    gates = swapOutputs(gates, 'z06', 'a06');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(['a04', 'a05', 'a06', 'b02', 'c00', 'z02', 'z04', 'z06']);
+  });
+});
