+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+
+  let changed = true;
+  while (changed && remaining.length > 0) {
+    changed = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        let result: number;
+        switch (gate.op) {
+          case 'AND':
+            result = a & b;
+            break;
+          case 'OR':
+            result = a | b;
+            break;
+          case 'XOR':
+            result = a ^ b;
+            break;
+        }
+        wires[gate.out] = result;
+        remaining.splice(i, 1);
+        changed = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+/**
+ * Detect swapped output wires in a ripple-carry adder circuit by checking
+ * structural invariants:
+ *
+ * Correct adder structure for bit i:
+ *   Bit 0 (half adder):
+ *     x00 XOR y00 -> z00
+ *     x00 AND y00 -> carry0
+ *   Bit i > 0 (full adder):
+ *     xNN XOR yNN -> partial_sum     (must feed into XOR and AND)
+ *     partial_sum XOR carry_in -> zNN (must output z-wire)
+ *     xNN AND yNN -> gen_carry       (must feed into OR)
+ *     partial_sum AND carry_in -> prop_carry (must feed into OR)
+ *     gen_carry OR prop_carry -> carry_out   (must feed into XOR, or be last z)
+ *   Last carry -> z(N+1) via OR gate
+ */
+export function findSwappedWires(gates: Gate[]): string[] {
+  const swapped = new Set<string>();
+
+  // Find the number of input bits
+  let maxBit = 0;
+  for (const g of gates) {
+    for (const w of [g.in1, g.in2]) {
+      const m = w.match(/^x(\d+)$/);
+      if (m) {
+        maxBit = Math.max(maxBit, parseInt(m[1], 10));
+      }
+    }
+  }
+  const lastZ = `z${String(maxBit + 1).padStart(2, '0')}`;
+
+  function isInput(wire: string): boolean {
+    return /^[xy]\d+$/.test(wire);
+  }
+
+  function gateHasInputs(gate: Gate, w1: string, w2: string): boolean {
+    return (
+      (gate.in1 === w1 && gate.in2 === w2) ||
+      (gate.in1 === w2 && gate.in2 === w1)
+    );
+  }
+
+  function findGateWithInput(op: string, wire: string): Gate | undefined {
+    return gates.find(
+      (g) => g.op === op && (g.in1 === wire || g.in2 === wire)
+    );
+  }
+
+  // === Pass 1: Check gate output type constraints ===
+  for (const gate of gates) {
+    const out = gate.out;
+    const isZOutput = /^z\d+$/.test(out);
+
+    if (gate.op === 'XOR') {
+      const hasXYInput = isInput(gate.in1) && isInput(gate.in2);
+      if (hasXYInput) {
+        // XOR of x/y inputs: partial sum
+        const bit = parseInt(gate.in1.match(/\d+/)![0], 10);
+        if (bit === 0) {
+          // Bit 0: must output z00
+          if (out !== 'z00') swapped.add(out);
+        } else {
+          // Other bits: partial sum must NOT go to z-wire
+          if (isZOutput) swapped.add(out);
+        }
+      } else {
+        // XOR of intermediates: final sum, must output z-wire (not lastZ)
+        if (!isZOutput) swapped.add(out);
+      }
+    } else if (gate.op === 'AND') {
+      // AND gate should never output z-wire
+      if (isZOutput) swapped.add(out);
+    } else if (gate.op === 'OR') {
+      // OR gate should only output lastZ among z-wires
+      if (isZOutput && out !== lastZ) swapped.add(out);
+    }
+  }
+
+  // === Pass 2: Check connectivity constraints ===
+  for (const gate of gates) {
+    const out = gate.out;
+    if (swapped.has(out)) continue;
+
+    if (gate.op === 'XOR') {
+      const hasXYInput = isInput(gate.in1) && isInput(gate.in2);
+      if (hasXYInput) {
+        const bit = parseInt(gate.in1.match(/\d+/)![0], 10);
+        if (bit === 0) continue; // bit 0 XOR → z00, already checked
+        // Partial sum must be used as input to a XOR gate (for the final sum)
+        if (!findGateWithInput('XOR', out)) swapped.add(out);
+      }
+      // Non-x/y XOR outputs z, already validated in pass 1
+    } else if (gate.op === 'AND') {
+      if (gateHasInputs(gate, 'x00', 'y00')) {
+        // Bit 0's carry must feed into a XOR gate (for bit 1's sum)
+        if (!findGateWithInput('XOR', out)) swapped.add(out);
+      } else {
+        // Other AND outputs must feed into an OR gate
+        if (!findGateWithInput('OR', out)) swapped.add(out);
+      }
+    } else if (gate.op === 'OR') {
+      if (out === lastZ) continue; // last carry → last z, OK
+      // Carry-out must feed into a XOR gate (for next bit's sum)
+      if (!findGateWithInput('XOR', out)) swapped.add(out);
+    }
+  }
+
+  return [...swapped].sort();
+}
