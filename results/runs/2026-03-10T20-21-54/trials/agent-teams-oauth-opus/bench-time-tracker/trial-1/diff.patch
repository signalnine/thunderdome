@@ -0,0 +1,106 @@
+import fs from "node:fs";
+import path from "node:path";
+import type { TimeEntry, TrackerData, DateRangeFilter } from "./types.js";
+
+export class TimeTracker {
+  private filePath: string;
+  private data: TrackerData;
+
+  constructor(filePath: string) {
+    this.filePath = path.resolve(filePath);
+    this.data = this.load();
+  }
+
+  private load(): TrackerData {
+    try {
+      const content = fs.readFileSync(this.filePath, "utf-8");
+      return JSON.parse(content) as TrackerData;
+    } catch {
+      return { entries: [] };
+    }
+  }
+
+  private save(): void {
+    const dir = path.dirname(this.filePath);
+    fs.mkdirSync(dir, { recursive: true });
+    fs.writeFileSync(this.filePath, JSON.stringify(this.data, null, 2), "utf-8");
+  }
+
+  private getRunningEntry(): TimeEntry | undefined {
+    return this.data.entries.find((e) => e.endTime === null);
+  }
+
+  start(taskName: string): TimeEntry {
+    if (!taskName || taskName.trim().length === 0) {
+      throw new Error("Task name cannot be empty");
+    }
+
+    const running = this.getRunningEntry();
+    if (running) {
+      running.endTime = new Date().toISOString();
+    }
+
+    const entry: TimeEntry = {
+      taskName,
+      startTime: new Date().toISOString(),
+      endTime: null,
+    };
+
+    this.data.entries.push(entry);
+    this.save();
+    return entry;
+  }
+
+  stop(): TimeEntry {
+    const running = this.getRunningEntry();
+    if (!running) {
+      throw new Error("No timer is currently running");
+    }
+
+    running.endTime = new Date().toISOString();
+    this.save();
+    return running;
+  }
+
+  getEntries(filter?: DateRangeFilter): TimeEntry[] {
+    if (!filter) {
+      return [...this.data.entries];
+    }
+
+    return this.data.entries.filter((entry) => {
+      const start = new Date(entry.startTime);
+      if (filter.from && start < filter.from) {
+        return false;
+      }
+      if (filter.to && start > filter.to) {
+        return false;
+      }
+      return true;
+    });
+  }
+
+  getSummary(): Record<string, number> {
+    const summary: Record<string, number> = {};
+
+    for (const entry of this.data.entries) {
+      const start = new Date(entry.startTime).getTime();
+      const end = entry.endTime
+        ? new Date(entry.endTime).getTime()
+        : Date.now();
+      const duration = end - start;
+
+      summary[entry.taskName] = (summary[entry.taskName] ?? 0) + duration;
+    }
+
+    return summary;
+  }
+
+  isRunning(): boolean {
+    return this.getRunningEntry() !== undefined;
+  }
+
+  currentTask(): string | null {
+    const running = this.getRunningEntry();
+    return running ? running.taskName : null;
+  }
+}
