eEntry {\n    const running = this.getRunningEntry();\n    if (!running) {\n      throw new Error(\"No timer is currently running\");\n    }\n\n    running.endTime = new Date().toISOString();\n    this.save();\n    return running;\n  }\n\n  getEntries(filter?: DateRangeFilter): TimeEntry[] {\n    if (!filter) {\n      return [...this.data.entries];\n    }\n\n    return this.data.entries.filter((entry) => {\n      const start = new Date(entry.startTime);\n      if (filter.from && start < filter.from) {\n        return false;\n      }\n      if (filter.to && start > filter.to) {\n        return false;\n      }\n      return true;\n    });\n  }\n\n  getSummary(): Record<string, number> {\n    const summary: Record<string, number> = {};\n\n    for (const entry of this.data.entries) {\n      const start = new Date(entry.startTime).getTime();\n      const end = entry.endTime\n        ? new Date(entry.endTime).getTime()\n        : Date.now();\n      const duration = end - start;\n\n      summary[entry.taskName] = (summary[entry.taskName] ?? 0) + duration;\n    }\n\n    return summary;\n  }\n\n  isRunning(): boolean {\n    return this.getRunningEntry() !== undefined;\n  }\n\n  currentTask(): string | null {\n    const running = this.getRunningEntry();\n    return running ? running.taskName : null;\n  }\n}\n","structuredPatch":[],"originalFile":null},"sourceToolAssistantUUID":"3b26d64a-c6f5-4c74-aa03-a16b2069a10b"}
