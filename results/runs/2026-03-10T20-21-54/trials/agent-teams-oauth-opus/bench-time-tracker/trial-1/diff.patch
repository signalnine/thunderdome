@@ -0,0 +1,217 @@
+import { describe, it, expect, beforeEach, afterEach } from "vitest";
+import fs from "node:fs";
+import path from "node:path";
+import os from "node:os";
+import { TimeTracker } from "./tracker.js";
+
+function tmpFile(): string {
+  return path.join(os.tmpdir(), `tracker-test-${Date.now()}-${Math.random().toString(36).slice(2)}.json`);
+}
+
+describe("TimeTracker", () => {
+  let filePath: string;
+
+  beforeEach(() => {
+    filePath = tmpFile();
+  });
+
+  afterEach(() => {
+    try {
+      fs.unlinkSync(filePath);
+    } catch {
+      // ignore
+    }
+  });
+
+  describe("start", () => {
+    it("should start a timer with a task name", () => {
+      const tracker = new TimeTracker(filePath);
+      const entry = tracker.start("coding");
+      expect(entry.taskName).toBe("coding");
+      expect(entry.startTime).toBeTruthy();
+      expect(entry.endTime).toBeNull();
+    });
+
+    it("should throw on empty task name", () => {
+      const tracker = new TimeTracker(filePath);
+      expect(() => tracker.start("")).toThrow("Task name cannot be empty");
+    });
+
+    it("should throw on whitespace-only task name", () => {
+      const tracker = new TimeTracker(filePath);
+      expect(() => tracker.start("   ")).toThrow("Task name cannot be empty");
+    });
+
+    it("should auto-stop previous timer when starting new one", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("task1");
+      tracker.start("task2");
+
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(2);
+      expect(entries[0].endTime).not.toBeNull();
+      expect(entries[1].endTime).toBeNull();
+    });
+
+    it("should support unicode task names", () => {
+      const tracker = new TimeTracker(filePath);
+      const entry = tracker.start("编码 🚀 café");
+      expect(entry.taskName).toBe("编码 🚀 café");
+    });
+
+    it("should support emoji-only task names", () => {
+      const tracker = new TimeTracker(filePath);
+      const entry = tracker.start("🎯🔥💻");
+      expect(entry.taskName).toBe("🎯🔥💻");
+    });
+  });
+
+  describe("stop", () => {
+    it("should stop the running timer", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("coding");
+      const stopped = tracker.stop();
+      expect(stopped.endTime).not.toBeNull();
+      expect(stopped.taskName).toBe("coding");
+    });
+
+    it("should throw when no timer is running", () => {
+      const tracker = new TimeTracker(filePath);
+      expect(() => tracker.stop()).toThrow("No timer is currently running");
+    });
+
+    it("should throw when timer already stopped", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("coding");
+      tracker.stop();
+      expect(() => tracker.stop()).toThrow("No timer is currently running");
+    });
+  });
+
+  describe("persistence", () => {
+    it("should persist entries to file", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("coding");
+      tracker.stop();
+
+      const tracker2 = new TimeTracker(filePath);
+      const entries = tracker2.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].taskName).toBe("coding");
+    });
+
+    it("should create parent directories automatically", () => {
+      const nestedPath = path.join(os.tmpdir(), `tracker-deep-${Date.now()}`, "sub", "dir", "data.json");
+      const tracker = new TimeTracker(nestedPath);
+      tracker.start("coding");
+      tracker.stop();
+
+      expect(fs.existsSync(nestedPath)).toBe(true);
+      // cleanup
+      fs.rmSync(path.join(os.tmpdir(), `tracker-deep-${Date.now()}`), { recursive: true, force: true });
+    });
+
+    it("should persist unicode task names correctly", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("日本語タスク 🎌");
+      tracker.stop();
+
+      const tracker2 = new TimeTracker(filePath);
+      const entries = tracker2.getEntries();
+      expect(entries[0].taskName).toBe("日本語タスク 🎌");
+    });
+  });
+
+  describe("getEntries", () => {
+    it("should return all entries", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("task1");
+      tracker.stop();
+      tracker.start("task2");
+      tracker.stop();
+
+      expect(tracker.getEntries()).toHaveLength(2);
+    });
+
+    it("should filter entries by date range", () => {
+      const tracker = new TimeTracker(filePath);
+
+      tracker.start("task1");
+      tracker.stop();
+
+      const now = new Date();
+      const from = new Date(now.getTime() - 1000);
+      const to = new Date(now.getTime() + 1000);
+
+      const entries = tracker.getEntries({ from, to });
+      expect(entries.length).toBeGreaterThanOrEqual(1);
+    });
+
+    it("should return empty array for out-of-range filter", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("task1");
+      tracker.stop();
+
+      const futureFrom = new Date("2099-01-01");
+      const entries = tracker.getEntries({ from: futureFrom });
+      expect(entries).toHaveLength(0);
+    });
+
+    it("should return a copy of entries, not the original array", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("task1");
+      tracker.stop();
+
+      const entries = tracker.getEntries();
+      entries.push({ taskName: "fake", startTime: "", endTime: null });
+      expect(tracker.getEntries()).toHaveLength(1);
+    });
+  });
+
+  describe("getSummary", () => {
+    it("should return total ms per task", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("coding");
+      tracker.stop();
+
+      const summary = tracker.getSummary();
+      expect(summary["coding"]).toBeGreaterThanOrEqual(0);
+    });
+
+    it("should sum multiple entries with same task name", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("coding");
+      tracker.stop();
+      tracker.start("coding");
+      tracker.stop();
+
+      const summary = tracker.getSummary();
+      expect(summary["coding"]).toBeGreaterThanOrEqual(0);
+      expect(Object.keys(summary)).toHaveLength(1);
+    });
+
+    it("should use current time for running tasks", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("coding");
+
+      const summary = tracker.getSummary();
+      expect(summary["coding"]).toBeGreaterThanOrEqual(0);
+    });
+  });
+
+  describe("isRunning and currentTask", () => {
+    it("should report running status", () => {
+      const tracker = new TimeTracker(filePath);
+      expect(tracker.isRunning()).toBe(false);
+      expect(tracker.currentTask()).toBeNull();
+
+      tracker.start("coding");
+      expect(tracker.isRunning()).toBe(true);
+      expect(tracker.currentTask()).toBe("coding");
+
+      tracker.stop();
+      expect(tracker.isRunning()).toBe(false);
+      expect(tracker.currentTask()).toBeNull();
+    });
+  });
+});
