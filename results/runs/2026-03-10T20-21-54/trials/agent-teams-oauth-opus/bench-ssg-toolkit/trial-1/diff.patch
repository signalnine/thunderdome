ort function createMarkdownExtPlugin(): Plugin {\n  return {\n    name: 'markdown-ext',\n    version: '1.0.0',\n    dependencies: [],\n    hooks: {\n      transformContent(file: ContentFile, _ctx: BuildContext): ContentFile {\n        let content = file.content;\n\n        // Process admonitions before markdown conversion\n        content = processAdmonitions(content);\n\n        // Process footnotes\n        content = processFootnotes(content);\n\n        // Convert markdown to HTML\n        content = marked.parse(content, { async: false }) as string;\n\n        return { ...file, content };\n      },\n    },\n  };\n}\n","structuredPatch":[],"originalFile":null},"sourceToolAssistantUUID":"6823e611-e30d-4faf-9edc-e51e9dd31317"}
