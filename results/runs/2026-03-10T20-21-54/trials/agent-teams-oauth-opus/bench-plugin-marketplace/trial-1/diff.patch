own version', () => {\n    registry.register(makeManifest());\n    expect(registry.getVersion('test-plugin', '9.9.9')).toBeNull();\n  });\n\n  it('should list all plugins', () => {\n    registry.register(makeManifest({ name: 'a', version: '1.0.0' }));\n    registry.register(makeManifest({ name: 'b', version: '1.0.0' }));\n    const list = registry.list();\n    expect(list).toHaveLength(2);\n  });\n\n  it('should search by name', () => {\n    registry.register(makeManifest({ name: 'logger-plugin' }));\n    registry.register(makeManifest({ name: 'http-client' }));\n    const results = registry.search('logger');\n    expect(results).toHaveLength(1);\n    expect(results[0].name).toBe('logger-plugin');\n  });\n\n  it('should search by description', () => {\n    registry.register(makeManifest({ description: 'Handles HTTP requests' }));\n    const results = registry.search('HTTP');\n    expect(results).toHaveLength(1);\n  });\n\n  it('should search by author', () => {\n    registry.register(makeManifest({ author: 'jane-doe' }));\n    const results = registry.search('jane');\n    expect(results).toHaveLength(1);\n  });\n\n  it('should remove a specific version', () => {\n    registry.register(makeManifest({ version: '1.0.0' }));\n    registry.register(makeManifest({ version: '2.0.0' }));\n    const removed = registry.remove('test-plugin', '1.0.0');\n    expect(removed).toBe(true);\n    expect(registry.getVersion('test-plugin', '1.0.0')).toBeNull();\n    expect(registry.getVersion('test-plugin', '2.0.0')).not.toBeNull();\n  });\n\n  it('should return false when removing nonexistent version', () => {\n    expect(registry.remove('nonexistent', '1.0.0')).toBe(false);\n  });\n\n  it('should list versions for a plugin', () => {\n    registry.register(makeManifest({ version: '1.0.0' }));\n    registry.register(makeManifest({ version: '2.0.0' }));\n    registry.register(makeManifest({ version: '1.5.0' }));\n    const versions = registry.listVersions('test-plugin');\n    expect(versions).toHaveLength(3);\n    expect(versions).toContain('1.0.0');\n    expect(versions).toContain('1.5.0');\n    expect(versions).toContain('2.0.0');\n  });\n\n  it('should update a plugin', () => {\n    registry.register(makeManifest());\n    registry.update('test-plugin', '1.0.0', { description: 'Updated!' });\n    const result = registry.getVersion('test-plugin', '1.0.0');\n    expect(result?.description).toBe('Updated!');\n    expect(result?.author).toBe('tester'); // unchanged\n  });\n\n  it('should throw when updating nonexistent plugin', () => {\n    expect(() => registry.update('nonexistent', '1.0.0', {})).toThrow();\n  });\n\n  it('should handle multiple plugins with multiple versions', () => {\n    registry.register(makeManifest({ name: 'a', version: '1.0.0' }));\n    registry.register(makeManifest({ name: 'a', version: '2.0.0' }));\n    registry.register(makeManifest({ name: 'b', version: '1.0.0' }));\n    expect(registry.list()).toHaveLength(3);\n    expect(registry.listVersions('a')).toHaveLength(2);\n    expect(registry.listVersions('b')).toHaveLength(1);\n  });\n});\n","structuredPatch":[],"originalFile":null},"sourceToolAssistantUUID":"762fbfb1-0ab5-4b1c-8e43-b7c893c6364b"}
