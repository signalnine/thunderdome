        [{ name: 'foo', range: '^3.0.0' }],\n          { foo: ['1.0.0', '2.0.0'] },\n        ),\n      ).toThrow(/No version of \"foo\" satisfies/);\n    });\n  });\n\n  describe('satisfies', () => {\n    it('should return true for matching version', () => {\n      expect(resolver.satisfies('1.2.3', '^1.0.0')).toBe(true);\n    });\n\n    it('should return false for non-matching version', () => {\n      expect(resolver.satisfies('2.0.0', '^1.0.0')).toBe(false);\n    });\n  });\n\n  describe('maxSatisfying', () => {\n    it('should return the max version satisfying range', () => {\n      expect(\n        resolver.maxSatisfying(['1.0.0', '1.5.0', '2.0.0'], '^1.0.0'),\n      ).toBe('1.5.0');\n    });\n\n    it('should return null when nothing satisfies', () => {\n      expect(\n        resolver.maxSatisfying(['1.0.0', '2.0.0'], '^3.0.0'),\n      ).toBeNull();\n    });\n  });\n\n  describe('validRange', () => {\n    it('should accept valid semver ranges', () => {\n      expect(resolver.validRange('^1.0.0')).toBe(true);\n      expect(resolver.validRange('~2.1.0')).toBe(true);\n      expect(resolver.validRange('>=1.0.0 <3.0.0')).toBe(true);\n    });\n\n    it('should reject invalid ranges', () => {\n      expect(resolver.validRange('not-a-range')).toBe(false);\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null},"sourceToolAssistantUUID":"9a394e29-6b6f-4d38-b42c-ed07c6294300"}
