@@ -0,0 +1,128 @@
+import type { DependencyNode, DepsService, RegistryService } from './types.js';
+
+export function createDepsService(): DepsService {
+  function buildTreeInner(
+    name: string,
+    registry: RegistryService,
+    visited: Set<string>,
+  ): DependencyNode {
+    const manifest = registry.get(name);
+    if (!manifest) {
+      return { name, version: 'unknown', dependencies: [] };
+    }
+
+    const node: DependencyNode = {
+      name: manifest.name,
+      version: manifest.version,
+      dependencies: [],
+    };
+
+    if (visited.has(name)) {
+      return node;
+    }
+
+    visited.add(name);
+
+    for (const depName of Object.keys(manifest.dependencies)) {
+      node.dependencies.push(buildTreeInner(depName, registry, new Set(visited)));
+    }
+
+    return node;
+  }
+
+  function detectCyclesInner(
+    name: string,
+    registry: RegistryService,
+    path: string[],
+    allCycles: string[][],
+    visited: Set<string>,
+  ): void {
+    const idx = path.indexOf(name);
+    if (idx !== -1) {
+      const cycle = path.slice(idx).concat(name);
+      allCycles.push(cycle);
+      return;
+    }
+
+    if (visited.has(name)) {
+      return;
+    }
+
+    const manifest = registry.get(name);
+    if (!manifest) return;
+
+    path.push(name);
+    visited.add(name);
+
+    for (const depName of Object.keys(manifest.dependencies)) {
+      detectCyclesInner(depName, registry, [...path], allCycles, visited);
+    }
+  }
+
+  function topoSortInner(
+    name: string,
+    registry: RegistryService,
+    visited: Set<string>,
+    result: string[],
+  ): void {
+    if (visited.has(name)) return;
+    visited.add(name);
+
+    const manifest = registry.get(name);
+    if (manifest) {
+      for (const depName of Object.keys(manifest.dependencies)) {
+        topoSortInner(depName, registry, visited, result);
+      }
+    }
+
+    result.push(name);
+  }
+
+  function flattenInner(
+    name: string,
+    registry: RegistryService,
+    collected: Set<string>,
+  ): void {
+    const manifest = registry.get(name);
+    if (!manifest) return;
+
+    for (const depName of Object.keys(manifest.dependencies)) {
+      if (!collected.has(depName)) {
+        collected.add(depName);
+        flattenInner(depName, registry, collected);
+      }
+    }
+  }
+
+  return {
+    buildTree(name: string, registry: RegistryService): DependencyNode {
+      return buildTreeInner(name, registry, new Set());
+    },
+
+    detectCycles(
+      name: string,
+      registry: RegistryService,
+    ): string[][] | null {
+      const allCycles: string[][] = [];
+      detectCyclesInner(name, registry, [], allCycles, new Set());
+      return allCycles.length > 0 ? allCycles : null;
+    },
+
+    topologicalSort(name: string, registry: RegistryService): string[] {
+      const visited = new Set<string>();
+      const result: string[] = [];
+      topoSortInner(name, registry, visited, result);
+      return result;
+    },
+
+    flattenDependencies(name: string, registry: RegistryService): string[] {
+      const collected = new Set<string>();
+      flattenInner(name, registry, collected);
+      return Array.from(collected);
+    },
+
+    hasCircularDependency(name: string, registry: RegistryService): boolean {
+      return this.detectCycles(name, registry) !== null;
+    },
+  };
+}
