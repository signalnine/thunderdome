ew Error('Plugin manifest must have a valid \"version\" field');\n    }\n    if (!manifest.entryPoint || typeof manifest.entryPoint !== 'string') {\n      throw new Error('Plugin manifest must have a valid \"entryPoint\" field');\n    }\n\n    // Register the plugin\n    registry.register(manifest);\n\n    // Resolve dependency versions\n    const depEntries = Object.entries(manifest.dependencies || {});\n    let resolvedDependencies: ResolvedVersion[] = [];\n\n    if (depEntries.length > 0) {\n      const constraints = depEntries.map(([name, range]) => ({ name, range }));\n      const available: Record<string, string[]> = {};\n\n      for (const [name] of depEntries) {\n        available[name] = registry.listVersions(name);\n      }\n\n      resolvedDependencies = resolver.resolve(constraints, available);\n    }\n\n    // Check for circular dependencies\n    if (deps.hasCircularDependency(manifest.name, registry)) {\n      // Remove the plugin since it creates a cycle\n      registry.remove(manifest.name, manifest.version);\n      throw new Error(\n        `Circular dependency detected for plugin \"${manifest.name}\"`,\n      );\n    }\n\n    // Execute the plugin's entry point in sandbox\n    const executionResult = await runner.execute(manifest.entryPoint);\n\n    return {\n      resolvedDependencies,\n      executionResult,\n    };\n  }\n\n  return {\n    registry,\n    resolver,\n    runner,\n    reviews,\n    deps,\n    installPlugin,\n  };\n}\n\nexport { createRegistry } from './registry.js';\nexport { createResolver } from './resolver.js';\nexport { createRunner } from './runner.js';\nexport { createReviewService } from './reviews.js';\nexport { createDepsService } from './deps.js';\n","structuredPatch":[],"originalFile":null},"sourceToolAssistantUUID":"8c3920c7-9551-48b4-88ff-84274ac3adbd"}
