--- /dev/null
+++ b/src/tracker.ts
@@ -0,0 +1,101 @@
+import { loadData, saveData } from "./persistence.js";
+import type { DateRange, TimeEntry, TimeSummary, TimeTrackerData } from "./types.js";
+
+export class TimeTracker {
+  private data: TimeTrackerData;
+  private readonly filePath: string;
+
+  constructor(filePath: string) {
+    this.filePath = filePath;
+    this.data = loadData(filePath);
+  }
+
+  start(task: string): void {
+    if (!task || task.trim().length === 0) {
+      throw new Error("Task name cannot be empty");
+    }
+
+    // Stop the currently running timer if any
+    const running = this.getRunningEntry();
+    if (running) {
+      running.stop = new Date().toISOString();
+    }
+
+    const entry: TimeEntry = {
+      task,
+      start: new Date().toISOString(),
+      stop: null,
+    };
+
+    this.data.entries.push(entry);
+    this.save();
+  }
+
+  stop(): TimeEntry {
+    const running = this.getRunningEntry();
+    if (!running) {
+      throw new Error("No timer is currently running");
+    }
+
+    running.stop = new Date().toISOString();
+    this.save();
+    return { ...running };
+  }
+
+  getEntries(range?: DateRange): TimeEntry[] {
+    if (!range) {
+      return this.data.entries.map((e) => ({ ...e }));
+    }
+
+    return this.data.entries
+      .filter((entry) => {
+        const entryStart = new Date(entry.start);
+        if (range.from && entryStart < range.from) return false;
+        if (range.to && entryStart > range.to) return false;
+        return true;
+      })
+      .map((e) => ({ ...e }));
+  }
+
+  getSummary(range?: DateRange): TimeSummary {
+    const entries = this.getEntries(range);
+    const summary: TimeSummary = {};
+
+    for (const entry of entries) {
+      const start = new Date(entry.start).getTime();
+      const end = entry.stop
+        ? new Date(entry.stop).getTime()
+        : Date.now();
+      const duration = end - start;
+
+      if (summary[entry.task] === undefined) {
+        summary[entry.task] = 0;
+      }
+      summary[entry.task] += duration;
+    }
+
+    return summary;
+  }
+
+  isRunning(): boolean {
+    return this.getRunningEntry() !== null;
+  }
+
+  currentTask(): string | null {
+    const running = this.getRunningEntry();
+    return running ? running.task : null;
+  }
+
+  private getRunningEntry(): TimeEntry | null {
+    for (let i = this.data.entries.length - 1; i >= 0; i--) {
+      if (this.data.entries[i].stop === null) {
+        return this.data.entries[i];
+      }
+    }
+    return null;
+  }
+
+  private save(): void {
+    saveData(this.filePath, this.data);
+  }
+}
