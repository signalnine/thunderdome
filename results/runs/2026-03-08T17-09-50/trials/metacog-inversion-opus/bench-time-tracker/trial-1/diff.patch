@@ -0,0 +1,18 @@
+import * as fs from "node:fs";
+import * as path from "node:path";
+import type { TimeTrackerData } from "./types.js";
+
+export function loadData(filePath: string): TimeTrackerData {
+  try {
+    const raw = fs.readFileSync(filePath, "utf-8");
+    return JSON.parse(raw) as TimeTrackerData;
+  } catch {
+    return { entries: [] };
+  }
+}
+
+export function saveData(filePath: string, data: TimeTrackerData): void {
+  const dir = path.dirname(filePath);
+  fs.mkdirSync(dir, { recursive: true });
+  fs.writeFileSync(filePath, JSON.stringify(data, null, 2), "utf-8");
+}
