@@ -0,0 +1,209 @@
+import { describe, it, expect, beforeEach, afterEach } from "vitest";
+import * as fs from "node:fs";
+import * as path from "node:path";
+import * as os from "node:os";
+import { TimeTracker } from "./tracker.js";
+
+function tmpFile(): string {
+  const dir = fs.mkdtempSync(path.join(os.tmpdir(), "tt-"));
+  return path.join(dir, "data.json");
+}
+
+function cleanup(filePath: string): void {
+  try {
+    fs.rmSync(path.dirname(filePath), { recursive: true, force: true });
+  } catch {
+    // ignore
+  }
+}
+
+describe("TimeTracker", () => {
+  let filePath: string;
+
+  beforeEach(() => {
+    filePath = tmpFile();
+  });
+
+  afterEach(() => {
+    cleanup(filePath);
+  });
+
+  describe("start", () => {
+    it("should start a timer with a task name", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("coding");
+      expect(tracker.isRunning()).toBe(true);
+      expect(tracker.currentTask()).toBe("coding");
+    });
+
+    it("should throw on empty task name", () => {
+      const tracker = new TimeTracker(filePath);
+      expect(() => tracker.start("")).toThrow("Task name cannot be empty");
+    });
+
+    it("should throw on whitespace-only task name", () => {
+      const tracker = new TimeTracker(filePath);
+      expect(() => tracker.start("   ")).toThrow("Task name cannot be empty");
+    });
+
+    it("should auto-stop previous timer when starting a new one", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("task1");
+      tracker.start("task2");
+
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(2);
+      expect(entries[0].stop).not.toBeNull();
+      expect(entries[1].stop).toBeNull();
+      expect(tracker.currentTask()).toBe("task2");
+    });
+
+    it("should support unicode task names", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("日本語タスク");
+      expect(tracker.currentTask()).toBe("日本語タスク");
+    });
+
+    it("should support emoji task names", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("🚀 Launch prep");
+      expect(tracker.currentTask()).toBe("🚀 Launch prep");
+    });
+  });
+
+  describe("stop", () => {
+    it("should stop the running timer", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("coding");
+      const entry = tracker.stop();
+      expect(entry.task).toBe("coding");
+      expect(entry.stop).not.toBeNull();
+      expect(tracker.isRunning()).toBe(false);
+    });
+
+    it("should throw when no timer is running", () => {
+      const tracker = new TimeTracker(filePath);
+      expect(() => tracker.stop()).toThrow("No timer is currently running");
+    });
+  });
+
+  describe("persistence", () => {
+    it("should persist entries to file", () => {
+      const tracker1 = new TimeTracker(filePath);
+      tracker1.start("coding");
+      tracker1.stop();
+
+      const tracker2 = new TimeTracker(filePath);
+      const entries = tracker2.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].task).toBe("coding");
+    });
+
+    it("should create parent directories if they don't exist", () => {
+      const deepPath = path.join(
+        os.tmpdir(),
+        `tt-${Date.now()}`,
+        "a",
+        "b",
+        "c",
+        "data.json"
+      );
+      const tracker = new TimeTracker(deepPath);
+      tracker.start("test");
+      tracker.stop();
+
+      expect(fs.existsSync(deepPath)).toBe(true);
+      fs.rmSync(path.join(os.tmpdir(), `tt-${Date.now()}`), {
+        recursive: true,
+        force: true,
+      });
+    });
+
+    it("should persist unicode task names correctly", () => {
+      const tracker1 = new TimeTracker(filePath);
+      tracker1.start("📝 编写代码");
+      tracker1.stop();
+
+      const tracker2 = new TimeTracker(filePath);
+      const entries = tracker2.getEntries();
+      expect(entries[0].task).toBe("📝 编写代码");
+    });
+  });
+
+  describe("getEntries", () => {
+    it("should return all entries when no range specified", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("task1");
+      tracker.stop();
+      tracker.start("task2");
+      tracker.stop();
+
+      expect(tracker.getEntries()).toHaveLength(2);
+    });
+
+    it("should filter entries by date range", () => {
+      const tracker = new TimeTracker(filePath);
+
+      tracker.start("task1");
+      tracker.stop();
+
+      const now = new Date();
+      const from = new Date(now.getTime() - 1000);
+      const to = new Date(now.getTime() + 1000);
+
+      tracker.start("task2");
+      tracker.stop();
+
+      const filtered = tracker.getEntries({ from, to });
+      expect(filtered.length).toBeGreaterThanOrEqual(1);
+    });
+
+    it("should return copies of entries, not references", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("task1");
+      tracker.stop();
+
+      const entries = tracker.getEntries();
+      entries[0].task = "modified";
+
+      const entriesAgain = tracker.getEntries();
+      expect(entriesAgain[0].task).toBe("task1");
+    });
+  });
+
+  describe("getSummary", () => {
+    it("should sum durations by task name", () => {
+      const tracker = new TimeTracker(filePath);
+
+      tracker.start("coding");
+      tracker.stop();
+      tracker.start("coding");
+      tracker.stop();
+
+      const summary = tracker.getSummary();
+      expect(summary["coding"]).toBeGreaterThanOrEqual(0);
+      expect("coding" in summary).toBe(true);
+    });
+
+    it("should use current time for running tasks", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("coding");
+
+      const summary = tracker.getSummary();
+      expect(summary["coding"]).toBeGreaterThanOrEqual(0);
+    });
+
+    it("should handle multiple different tasks", () => {
+      const tracker = new TimeTracker(filePath);
+
+      tracker.start("coding");
+      tracker.stop();
+      tracker.start("review");
+      tracker.stop();
+
+      const summary = tracker.getSummary();
+      expect("coding" in summary).toBe(true);
+      expect("review" in summary).toBe(true);
+    });
+  });
+});
