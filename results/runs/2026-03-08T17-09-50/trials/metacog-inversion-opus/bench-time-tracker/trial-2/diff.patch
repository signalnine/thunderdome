ker({ filePath: TEST_FILE });\n    tracker.start(\"task1\");\n    tracker.start(\"task2\");\n\n    const entries = tracker.getEntries();\n    expect(entries).toHaveLength(2);\n    expect(entries[0].task).toBe(\"task1\");\n    expect(entries[0].stop).not.toBeNull();\n    expect(entries[1].task).toBe(\"task2\");\n    expect(entries[1].stop).toBeNull();\n  });\n\n  it(\"should throw when starting with empty name\", () => {\n    const tracker = new TimeTracker({ filePath: TEST_FILE });\n    expect(() => tracker.start(\"\")).toThrow(\"Task name cannot be empty\");\n    expect(() => tracker.start(\"   \")).toThrow(\"Task name cannot be empty\");\n  });\n\n  it(\"should throw when stopping with no running timer\", () => {\n    const tracker = new TimeTracker({ filePath: TEST_FILE });\n    expect(() => tracker.stop()).toThrow(\"No timer is currently running\");\n  });\n\n  it(\"should persist data between instances\", () => {\n    const tracker1 = new TimeTracker({ filePath: TEST_FILE });\n    tracker1.start(\"coding\");\n    tracker1.stop();\n\n    const tracker2 = new TimeTracker({ filePath: TEST_FILE });\n    const entries = tracker2.getEntries();\n    expect(entries).toHaveLength(1);\n    expect(entries[0].task).toBe(\"coding\");\n  });\n\n  it(\"should filter entries by date range\", async () => {\n    const tracker = new TimeTracker({ filePath: TEST_FILE });\n\n    tracker.start(\"old-task\");\n    tracker.stop();\n\n    const from = new Date();\n\n    // Small delay to ensure different timestamps\n    await new Promise((r) => setTimeout(r, 10));\n\n    tracker.start(\"new-task\");\n    tracker.stop();\n\n    const filtered = tracker.getEntries({ from });\n    expect(filtered).toHaveLength(1);\n    expect(filtered[0].task).toBe(\"new-task\");\n  });\n\n  it(\"should filter entries with to date\", async () => {\n    const tracker = new TimeTracker({ filePath: TEST_FILE });\n\n    tracker.start(\"first-task\");\n    tracker.stop();\n\n    const to = new Date();\n\n    await new Promise((r) => setTimeout(r, 10));\n\n    tracker.start(\"second-task\");\n    tracker.stop();\n\n    const filtered = tracker.getEntries({ to });\n    expect(filtered).toHaveLength(1);\n    expect(filtered[0].task).toBe(\"first-task\");\n  });\n\n  it(\"should summarize time per task\", () => {\n    const tracker = new TimeTracker({ filePath: TEST_FILE });\n\n    tracker.start(\"coding\");\n    tracker.stop();\n    tracker.start(\"coding\");\n    tracker.stop();\n    tracker.start(\"review\");\n    tracker.stop();\n\n    const summary = tracker.getSummary();\n    expect(summary[\"coding\"]).toBeGreaterThanOrEqual(0);\n    expect(summary[\"review\"]).toBeGreaterThanOrEqual(0);\n    expect(Object.keys(summary)).toHaveLength(2);\n  });\n\n  it(\"should include running task in summary using current time\", () => {\n    const tracker = new TimeTracker({ filePath: TEST_FILE });\n    tracker.start(\"active-task\");\n\n    const summary = tracker.getSummary();\n    expect(summary[\"active-task\"]).toBeGreaterThanOrEqual(0);\n  });\n\n  it(\"should handle unicode task names\", () => {\n    const tracker = new TimeTracker({ filePath: TEST_FILE });\n\n    tracker.start(\"编码工作\");\n    tracker.stop();\n    tracker.start(\"🚀 deployment\");\n    tracker.stop();\n    tracker.start(\"café ☕ break\");\n    tracker.stop();\n\n    const entries = tracker.getEntries();\n    expect(entries[0].task).toBe(\"编码工作\");\n    expect(entries[1].task).toBe(\"🚀 deployment\");\n    expect(entries[2].task).toBe(\"café ☕ break\");\n\n    // Verify persistence\n    const tracker2 = new TimeTracker({ filePath: TEST_FILE });\n    const entries2 = tracker2.getEntries();\n    expect(entries2[0].task).toBe(\"编码工作\");\n    expect(entries2[1].task).toBe(\"🚀 deployment\");\n    expect(entries2[2].task).toBe(\"café ☕ break\");\n  });\n\n  it(\"should return copies of entries, not references\", () => {\n    const tracker = new TimeTracker({ filePath: TEST_FILE });\n    tracker.start(\"task\");\n    t