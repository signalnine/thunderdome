+import { readFileSync, writeFileSync, mkdirSync, existsSync } from "node:fs";
+import { dirname } from "node:path";
+import type { TimeEntry, TimeTrackerOptions, TimeSummary } from "./types.js";
+
+export class TimeTracker {
+  private entries: TimeEntry[] = [];
+  private readonly filePath: string;
+
+  constructor(options: TimeTrackerOptions) {
+    this.filePath = options.filePath;
+    this.load();
+  }
+
+  start(task: string): void {
+    if (!task || task.trim().length === 0) {
+      throw new Error("Task name cannot be empty");
+    }
+
+    // Auto-stop current running timer
+    const running = this.getRunningEntry();
+    if (running) {
+      running.stop = new Date().toISOString();
+    }
+
+    this.entries.push({
+      task,
+      start: new Date().toISOString(),
+      stop: null,
+    });
+
+    this.save();
+  }
+
+  stop(): TimeEntry {
+    const running = this.getRunningEntry();
+    if (!running) {
+      throw new Error("No timer is currently running");
+    }
+
+    running.stop = new Date().toISOString();
+    this.save();
+    return { ...running };
+  }
+
+  getEntries(options?: { from?: Date; to?: Date }): TimeEntry[] {
+    if (!options) {
+      return this.entries.map((e) => ({ ...e }));
+    }
+
+    return this.entries
+      .filter((entry) => {
+        const entryStart = new Date(entry.start);
+        if (options.from && entryStart < options.from) {
+          return false;
+        }
+        if (options.to && entryStart > options.to) {
+          return false;
+        }
+        return true;
+      })
+      .map((e) => ({ ...e }));
+  }
+
+  getSummary(): TimeSummary {
+    const summary: TimeSummary = {};
+    const now = Date.now();
+
+    for (const entry of this.entries) {
+      const start = new Date(entry.start).getTime();
+      const end = entry.stop ? new Date(entry.stop).getTime() : now;
+      const duration = end - start;
+
+      if (summary[entry.task] === undefined) {
+        summary[entry.task] = 0;
+      }
+      summary[entry.task] += duration;
+    }
+
+    return summary;
+  }
+
+  isRunning(): boolean {
+    return this.getRunningEntry() !== null;
+  }
+
+  private getRunningEntry(): TimeEntry | null {
+    for (let i = this.entries.length - 1; i >= 0; i--) {
+      if (this.entries[i].stop === null) {
+        return this.entries[i];
+      }
+    }
+    return null;
+  }
+
+  private load(): void {
+    if (!existsSync(this.filePath)) {
+      this.entries = [];
+      return;
+    }
+
+    try {
+      const data = readFileSync(this.filePath, "utf-8");
+      const parsed: unknown = JSON.parse(data);
+      if (Array.isArray(parsed)) {
+        this.entries = parsed as TimeEntry[];
+      } else {
+        this.entries = [];
+      }
+    } catch {
+      this.entries = [];
+    }
+  }
+
+  private save(): void {
+    const dir = dirname(this.filePath);
+    if (!existsSync(dir)) {
+      mkdirSync(dir, { recursive: true });
+    }
+    writeFileSync(this.filePath, JSON.stringify(this.entries, null, 2), "utf-8");
+  }
+}
