@@ -0,0 +1,105 @@
+import { WebSocketServer, WebSocket } from 'ws';
+import { IncomingMessage, Server as HttpServer } from 'http';
+import { randomUUID } from 'crypto';
+import { DocumentManager } from './document-manager.js';
+import { validateComponents } from './ot.js';
+import { URL } from 'url';
+
+export function setupWebSocket(server: HttpServer, docManager: DocumentManager): WebSocketServer {
+  const wss = new WebSocketServer({ server });
+
+  wss.on('connection', (ws: WebSocket, req: IncomingMessage) => {
+    const clientId = randomUUID();
+
+    // Parse document ID from URL path: /ws/documents/:docId
+    const url = new URL(req.url || '/', `http://${req.headers.host || 'localhost'}`);
+    const pathParts = url.pathname.split('/').filter(Boolean);
+
+    // Expected path: /ws/documents/:docId or /documents/:docId
+    let docId: string | null = null;
+    if (pathParts.length >= 2) {
+      // Support both /ws/documents/:id and /documents/:id
+      if (pathParts[0] === 'ws' && pathParts[1] === 'documents' && pathParts[2]) {
+        docId = pathParts[2];
+      } else if (pathParts[0] === 'documents' && pathParts[1]) {
+        docId = pathParts[1];
+      }
+    }
+
+    if (!docId) {
+      ws.send(JSON.stringify({ type: 'error', message: 'Invalid path. Use /ws/documents/:docId' }));
+      ws.close();
+      return;
+    }
+
+    // Join the document session
+    const state = docManager.joinDocument(docId, clientId, ws);
+    if (!state) {
+      ws.send(JSON.stringify({ type: 'error', message: 'Document not found' }));
+      ws.close();
+      return;
+    }
+
+    // Send initial sync
+    ws.send(JSON.stringify({
+      type: 'sync',
+      content: state.content,
+      version: state.version,
+      clientId,
+    }));
+
+    // Handle incoming messages
+    ws.on('message', (data: Buffer | ArrayBuffer | Buffer[]) => {
+      let message: unknown;
+      try {
+        message = JSON.parse(data.toString());
+      } catch {
+        ws.send(JSON.stringify({ type: 'error', message: 'Invalid JSON' }));
+        return;
+      }
+
+      if (typeof message !== 'object' || message === null) {
+        ws.send(JSON.stringify({ type: 'error', message: 'Message must be an object' }));
+        return;
+      }
+
+      const msg = message as Record<string, unknown>;
+
+      if (msg.type === 'operation') {
+        if (typeof msg.version !== 'number' || !Number.isInteger(msg.version) || msg.version < 0) {
+          ws.send(JSON.stringify({ type: 'error', message: 'Invalid version number' }));
+          return;
+        }
+
+        if (!validateComponents(msg.components)) {
+          ws.send(JSON.stringify({ type: 'error', message: 'Invalid operation components' }));
+          return;
+        }
+
+        const result = docManager.handleOperation(
+          docId!,
+          clientId,
+          msg.version as number,
+          msg.components as import('./ot.js').OTComponent[]
+        );
+
+        if (result.error) {
+          ws.send(JSON.stringify({ type: 'error', message: result.error }));
+        }
+      } else {
+        ws.send(JSON.stringify({ type: 'error', message: `Unknown message type: ${msg.type}` }));
+      }
+    });
+
+    // Handle disconnect
+    ws.on('close', () => {
+      docManager.leaveDocument(docId!, clientId);
+    });
+
+    ws.on('error', () => {
+      docManager.leaveDocument(docId!, clientId);
+    });
+  });
+
+  return wss;
+}
