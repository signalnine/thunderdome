+import { describe, it, expect } from 'vitest';
+import { applyOp, transform, inputLength, outputLength, validateComponents, OTComponent } from '../src/ot.js';
+
+describe('OT module', () => {
+  describe('applyOp', () => {
+    it('should apply insert at beginning', () => {
+      const doc = 'hello';
+      const ops: OTComponent[] = [
+        { type: 'insert', text: 'say ' },
+        { type: 'retain', count: 5 },
+      ];
+      expect(applyOp(doc, ops)).toBe('say hello');
+    });
+
+    it('should apply insert at end', () => {
+      const doc = 'hello';
+      const ops: OTComponent[] = [
+        { type: 'retain', count: 5 },
+        { type: 'insert', text: ' world' },
+      ];
+      expect(applyOp(doc, ops)).toBe('hello world');
+    });
+
+    it('should apply delete', () => {
+      const doc = 'hello world';
+      const ops: OTComponent[] = [
+        { type: 'retain', count: 5 },
+        { type: 'delete', count: 6 },
+      ];
+      expect(applyOp(doc, ops)).toBe('hello');
+    });
+
+    it('should apply insert in middle', () => {
+      const doc = 'helo';
+      const ops: OTComponent[] = [
+        { type: 'retain', count: 2 },
+        { type: 'insert', text: 'l' },
+        { type: 'retain', count: 2 },
+      ];
+      expect(applyOp(doc, ops)).toBe('hello');
+    });
+
+    it('should apply to empty document', () => {
+      expect(applyOp('', [{ type: 'insert', text: 'hi' }])).toBe('hi');
+    });
+
+    it('should throw on length mismatch', () => {
+      expect(() =>
+        applyOp('hello', [{ type: 'retain', count: 3 }])
+      ).toThrow();
+    });
+  });
+
+  describe('inputLength / outputLength', () => {
+    it('should compute lengths correctly', () => {
+      const ops: OTComponent[] = [
+        { type: 'retain', count: 3 },
+        { type: 'insert', text: 'abc' },
+        { type: 'delete', count: 2 },
+      ];
+      expect(inputLength(ops)).toBe(5); // retain 3 + delete 2
+      expect(outputLength(ops)).toBe(6); // retain 3 + insert 3
+    });
+  });
+
+  describe('transform', () => {
+    it('should transform two inserts at same position', () => {
+      // Both clients insert at position 0 in an empty document
+      const a: OTComponent[] = [{ type: 'insert', text: 'a' }];
+      const b: OTComponent[] = [{ type: 'insert', text: 'b' }];
+
+      const [aPrime, bPrime] = transform(a, b);
+
+      const doc = '';
+      const afterA = applyOp(doc, a);
+      const afterAThenBPrime = applyOp(afterA, bPrime);
+
+      const afterB = applyOp(doc, b);
+      const afterBThenAPrime = applyOp(afterB, aPrime);
+
+      // Both paths should converge
+      expect(afterAThenBPrime).toBe(afterBThenAPrime);
+    });
+
+    it('should handle insert vs retain', () => {
+      const doc = 'hello';
+      // Client A inserts at beginning
+      const a: OTComponent[] = [
+        { type: 'insert', text: 'X' },
+        { type: 'retain', count: 5 },
+      ];
+      // Client B inserts at end
+      const b: OTComponent[] = [
+        { type: 'retain', count: 5 },
+        { type: 'insert', text: 'Y' },
+      ];
+
+      const [aPrime, bPrime] = transform(a, b);
+
+      const afterA = applyOp(doc, a);
+      const afterAThenBPrime = applyOp(afterA, bPrime);
+
+      const afterB = applyOp(doc, b);
+      const afterBThenAPrime = applyOp(afterB, aPrime);
+
+      expect(afterAThenBPrime).toBe(afterBThenAPrime);
+      expect(afterAThenBPrime).toBe('XhelloY');
+    });
+
+    it('should handle concurrent deletes of overlapping ranges', () => {
+      const doc = 'abcde';
+      // Client A deletes 'bc' (positions 1-2)
+      const a: OTComponent[] = [
+        { type: 'retain', count: 1 },
+        { type: 'delete', count: 2 },
+        { type: 'retain', count: 2 },
+      ];
+      // Client B deletes 'cd' (positions 2-3)
+      const b: OTComponent[] = [
+        { type: 'retain', count: 2 },
+        { type: 'delete', count: 2 },
+        { type: 'retain', count: 1 },
+      ];
+
+      const [aPrime, bPrime] = transform(a, b);
+
+      const afterA = applyOp(doc, a);
+      const afterAThenBPrime = applyOp(afterA, bPrime);
+
+      const afterB = applyOp(doc, b);
+      const afterBThenAPrime = applyOp(afterB, aPrime);
+
+      expect(afterAThenBPrime).toBe(afterBThenAPrime);
+      expect(afterAThenBPrime).toBe('ae');
+    });
+
+    it('should preserve both inserts in concurrent operations', () => {
+      const doc = 'abc';
+      // Client A inserts 'X' at position 1
+      const a: OTComponent[] = [
+        { type: 'retain', count: 1 },
+        { type: 'insert', text: 'X' },
+        { type: 'retain', count: 2 },
+      ];
+      // Client B inserts 'Y' at position 2
+      const b: OTComponent[] = [
+        { type: 'retain', count: 2 },
+        { type: 'insert', text: 'Y' },
+        { type: 'retain', count: 1 },
+      ];
+
+      const [aPrime, bPrime] = transform(a, b);
+
+      const afterA = applyOp(doc, a);
+      const afterAThenBPrime = applyOp(afterA, bPrime);
+
+      const afterB = applyOp(doc, b);
+      const afterBThenAPrime = applyOp(afterB, aPrime);
+
+      expect(afterAThenBPrime).toBe(afterBThenAPrime);
+      // Both X and Y should be in the result
+      expect(afterAThenBPrime).toContain('X');
+      expect(afterAThenBPrime).toContain('Y');
+    });
+  });
+
+  describe('validateComponents', () => {
+    it('should accept valid components', () => {
+      expect(validateComponents([
+        { type: 'retain', count: 3 },
+        { type: 'insert', text: 'hello' },
+        { type: 'delete', count: 2 },
+      ])).toBe(true);
+    });
+
+    it('should reject invalid types', () => {
+      expect(validateComponents([{ type: 'unknown' }])).toBe(false);
+    });
+
+    it('should reject non-array', () => {
+      expect(validateComponents('not an array')).toBe(false);
+    });
+
+    it('should reject negative counts', () => {
+      expect(validateComponents([{ type: 'retain', count: -1 }])).toBe(false);
+    });
+
+    it('should reject non-integer counts', () => {
+      expect(validateComponents([{ type: 'retain', count: 1.5 }])).toBe(false);
+    });
+  });
+});
