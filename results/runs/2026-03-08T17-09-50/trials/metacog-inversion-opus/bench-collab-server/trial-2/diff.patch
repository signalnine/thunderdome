@@ -0,0 +1,67 @@
+import express from 'express';
+import { createServer, Server as HttpServer } from 'http';
+import { WebSocketServer } from 'ws';
+import { createDatabase, DatabaseLayer } from './db.js';
+import { DocumentManager } from './document-manager.js';
+import { createRouter } from './routes.js';
+import { setupWebSocket } from './websocket.js';
+
+export interface AppInstance {
+  app: express.Express;
+  start(port?: number): Promise<number>;
+  stop(): Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const app = express();
+  app.use(express.json());
+
+  const db: DatabaseLayer = createDatabase(dbPath);
+  const docManager = new DocumentManager(db);
+  const router = createRouter(db, docManager);
+
+  app.use('/api', router);
+
+  const server: HttpServer = createServer(app);
+  let wss: WebSocketServer | null = null;
+
+  return {
+    app,
+
+    start(port: number = 0): Promise<number> {
+      return new Promise((resolve, reject) => {
+        wss = setupWebSocket(server, docManager);
+
+        server.listen(port, () => {
+          const addr = server.address();
+          if (addr && typeof addr === 'object') {
+            resolve(addr.port);
+          } else {
+            reject(new Error('Failed to get server address'));
+          }
+        });
+
+        server.on('error', reject);
+      });
+    },
+
+    stop(): Promise<void> {
+      return new Promise((resolve, reject) => {
+        docManager.closeAll();
+
+        if (wss) {
+          wss.close();
+        }
+
+        server.close((err) => {
+          db.close();
+          if (err) {
+            reject(err);
+          } else {
+            resolve();
+          }
+        });
+      });
+    },
+  };
+}
