+import { describe, it, expect, beforeEach, afterEach } from 'vitest';
+import request from 'supertest';
+import { createApp, AppInstance } from '../src/server.js';
+
+describe('REST API', () => {
+  let appInstance: AppInstance;
+  let port: number;
+
+  beforeEach(async () => {
+    appInstance = createApp();
+    port = await appInstance.start(0);
+  });
+
+  afterEach(async () => {
+    await appInstance.stop();
+  });
+
+  describe('POST /api/documents', () => {
+    it('should create a document', async () => {
+      const res = await request(appInstance.app)
+        .post('/api/documents')
+        .send({ title: 'Test Doc', content: 'Hello world' })
+        .expect(201);
+
+      expect(res.body.id).toBeDefined();
+      expect(res.body.title).toBe('Test Doc');
+      expect(res.body.content).toBe('Hello world');
+    });
+
+    it('should create a document with empty content by default', async () => {
+      const res = await request(appInstance.app)
+        .post('/api/documents')
+        .send({ title: 'Empty Doc' })
+        .expect(201);
+
+      expect(res.body.content).toBe('');
+    });
+
+    it('should reject missing title', async () => {
+      await request(appInstance.app)
+        .post('/api/documents')
+        .send({ content: 'No title' })
+        .expect(400);
+    });
+  });
+
+  describe('GET /api/documents', () => {
+    it('should list documents', async () => {
+      await request(appInstance.app)
+        .post('/api/documents')
+        .send({ title: 'Doc 1' });
+      await request(appInstance.app)
+        .post('/api/documents')
+        .send({ title: 'Doc 2' });
+
+      const res = await request(appInstance.app)
+        .get('/api/documents')
+        .expect(200);
+
+      expect(res.body.length).toBe(2);
+    });
+  });
+
+  describe('GET /api/documents/:id', () => {
+    it('should get a document by id', async () => {
+      const created = await request(appInstance.app)
+        .post('/api/documents')
+        .send({ title: 'My Doc', content: 'content' });
+
+      const res = await request(appInstance.app)
+        .get(`/api/documents/${created.body.id}`)
+        .expect(200);
+
+      expect(res.body.title).toBe('My Doc');
+      expect(res.body.content).toBe('content');
+    });
+
+    it('should return 404 for non-existent document', async () => {
+      await request(appInstance.app)
+        .get('/api/documents/nonexistent')
+        .expect(404);
+    });
+  });
+
+  describe('PUT /api/documents/:id', () => {
+    it('should update a document', async () => {
+      const created = await request(appInstance.app)
+        .post('/api/documents')
+        .send({ title: 'Original', content: 'original content' });
+
+      const res = await request(appInstance.app)
+        .put(`/api/documents/${created.body.id}`)
+        .send({ title: 'Updated', content: 'updated content' })
+        .expect(200);
+
+      expect(res.body.title).toBe('Updated');
+      expect(res.body.content).toBe('updated content');
+    });
+
+    it('should return 404 for non-existent document', async () => {
+      await request(appInstance.app)
+        .put('/api/documents/nonexistent')
+        .send({ title: 'Nope' })
+        .expect(404);
+    });
+  });
+
+  describe('DELETE /api/documents/:id', () => {
+    it('should delete a document', async () => {
+      const created = await request(appInstance.app)
+        .post('/api/documents')
+        .send({ title: 'To Delete' });
+
+      await request(appInstance.app)
+        .delete(`/api/documents/${created.body.id}`)
+        .expect(204);
+
+      await request(appInstance.app)
+        .get(`/api/documents/${created.body.id}`)
+        .expect(404);
+    });
+
+    it('should return 404 for non-existent document', async () => {
+      await request(appInstance.app)
+        .delete('/api/documents/nonexistent')
+        .expect(404);
+    });
+  });
+
+  describe('GET /api/documents/:id/versions', () => {
+    it('should return version history', async () => {
+      const created = await request(appInstance.app)
+        .post('/api/documents')
+        .send({ title: 'Versioned', content: 'v0' });
+
+      await request(appInstance.app)
+        .put(`/api/documents/${created.body.id}`)
+        .send({ content: 'v1' });
+
+      const res = await request(appInstance.app)
+        .get(`/api/documents/${created.body.id}/versions`)
+        .expect(200);
+
+      expect(res.body.length).toBeGreaterThanOrEqual(2);
+    });
+
+    it('should return 404 for non-existent document', async () => {
+      await request(appInstance.app)
+        .get('/api/documents/nonexistent/versions')
+        .expect(404);
+    });
+  });
+});
