@@ -0,0 +1,114 @@
+import Database from 'better-sqlite3';
+import { readFileSync } from 'fs';
+import { randomUUID } from 'crypto';
+import { fileURLToPath } from 'url';
+import { dirname, join } from 'path';
+
+const __filename = fileURLToPath(import.meta.url);
+const __dirname = dirname(__filename);
+
+export interface Document {
+  id: string;
+  title: string;
+  content: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface Version {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operation: string | null;
+  created_at: string;
+}
+
+export function createDatabase(dbPath?: string): DatabaseLayer {
+  return new DatabaseLayer(dbPath);
+}
+
+export class DatabaseLayer {
+  db: Database.Database;
+
+  constructor(dbPath?: string) {
+    this.db = new Database(dbPath || ':memory:');
+    this.db.pragma('journal_mode = WAL');
+    this.db.pragma('foreign_keys = ON');
+    this.init();
+  }
+
+  private init(): void {
+    const schemaPath = join(__dirname, '..', 'schema.sql');
+    const schema = readFileSync(schemaPath, 'utf-8');
+    this.db.exec(schema);
+  }
+
+  createDocument(title: string, content: string = ''): Document {
+    const id = randomUUID();
+    const stmt = this.db.prepare(
+      'INSERT INTO documents (id, title, content) VALUES (?, ?, ?)'
+    );
+    stmt.run(id, title, content);
+
+    // Create initial version
+    this.createVersion(id, 0, content, null);
+
+    return this.getDocument(id)!;
+  }
+
+  getDocument(id: string): Document | undefined {
+    const stmt = this.db.prepare('SELECT * FROM documents WHERE id = ?');
+    return stmt.get(id) as Document | undefined;
+  }
+
+  listDocuments(): Document[] {
+    const stmt = this.db.prepare('SELECT * FROM documents ORDER BY updated_at DESC');
+    return stmt.all() as Document[];
+  }
+
+  updateDocument(id: string, updates: { title?: string; content?: string }): Document | undefined {
+    const doc = this.getDocument(id);
+    if (!doc) return undefined;
+
+    const title = updates.title ?? doc.title;
+    const content = updates.content ?? doc.content;
+    const stmt = this.db.prepare(
+      "UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?"
+    );
+    stmt.run(title, content, id);
+    return this.getDocument(id);
+  }
+
+  deleteDocument(id: string): boolean {
+    const stmt = this.db.prepare('DELETE FROM documents WHERE id = ?');
+    const result = stmt.run(id);
+    return result.changes > 0;
+  }
+
+  createVersion(documentId: string, version: number, content: string, operation: string | null): void {
+    const stmt = this.db.prepare(
+      'INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)'
+    );
+    stmt.run(documentId, version, content, operation);
+  }
+
+  getVersions(documentId: string): Version[] {
+    const stmt = this.db.prepare(
+      'SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC'
+    );
+    return stmt.all(documentId) as Version[];
+  }
+
+  getLatestVersion(documentId: string): number {
+    const stmt = this.db.prepare(
+      'SELECT MAX(version) as max_version FROM versions WHERE document_id = ?'
+    );
+    const result = stmt.get(documentId) as { max_version: number | null };
+    return result.max_version ?? 0;
+  }
+
+  close(): void {
+    this.db.close();
+  }
+}
diff --git a/src/document-manager.ts b/src/document-manager.ts
new file mode 100644
index 0000000..d6bb14f
--- /dev/null
+++ b/src/document-manager.ts
@@ -0,0 +1,222 @@
+import { DatabaseLayer } from './db.js';
+import { OTComponent, applyOp, transform, inputLength, validateComponents } from './ot.js';
+import { WebSocket } from 'ws';
+
+interface ConnectedClient {
+  ws: WebSocket;
+  clientId: string;
+}
+
+interface DocumentSession {
+  docId: string;
+  content: string;
+  version: number;
+  clients: Map<string, ConnectedClient>;
+}
+
+export class DocumentManager {
+  private sessions: Map<string, DocumentSession> = new Map();
+  private db: DatabaseLayer;
+
+  constructor(db: DatabaseLayer) {
+    this.db = db;
+  }
+
+  /**
+   * Join a client to a document session. Creates the session if it doesn't exist.
+   * Returns the current document state.
+   */
+  joinDocument(docId: string, clientId: string, ws: WebSocket): { content: string; version: number } | null {
+    const doc = this.db.getDocument(docId);
+    if (!doc) return null;
+
+    let session = this.sessions.get(docId);
+    if (!session) {
+      const version = this.db.getLatestVersion(docId);
+      session = {
+        docId,
+        content: doc.content,
+        version,
+        clients: new Map(),
+      };
+      this.sessions.set(docId, session);
+    }
+
+    session.clients.set(clientId, { ws, clientId });
+
+    return { content: session.content, version: session.version };
+  }
+
+  /**
+   * Remove a client from a document session.
+   */
+  leaveDocument(docId: string, clientId: string): void {
+    const session = this.sessions.get(docId);
+    if (!session) return;
+
+    session.clients.delete(clientId);
+
+    // Clean up session if no clients remain
+    if (session.clients.size === 0) {
+      this.sessions.delete(docId);
+    }
+  }
+
+  /**
+   * Handle an incoming operation from a client.
+   * Transforms against any concurrent operations and broadcasts to other clients.
+   */
+  handleOperation(
+    docId: string,
+    clientId: string,
+    clientVersion: number,
+    components: OTComponent[]
+  ): { error?: string; version?: number } {
+    const session = this.sessions.get(docId);
+    if (!session) {
+      return { error: 'Document session not found' };
+    }
+
+    // Validate components
+    if (!validateComponents(components)) {
+      return { error: 'Invalid operation components' };
+    }
+
+    // Transform against any operations that happened since the client's version
+    let transformedComponents = components;
+
+    if (clientVersion < session.version) {
+      // Get all versions between clientVersion and current version
+      const versions = this.db.getVersions(docId);
+      const concurrentVersions = versions.filter(
+        (v) => v.version > clientVersion && v.version <= session.version
+      );
+
+      for (const v of concurrentVersions) {
+        if (!v.operation) continue;
+        const serverOp: OTComponent[] = JSON.parse(v.operation);
+        const [transformed] = transform(transformedComponents, serverOp);
+        transformedComponents = transformed;
+      }
+    } else if (clientVersion > session.version) {
+      return { error: `Client version ${clientVersion} is ahead of server version ${session.version}` };
+    }
+
+    // Validate that the operation can be applied to current document
+    const opInputLen = inputLength(transformedComponents);
+    if (opInputLen !== session.content.length) {
+      return {
+        error: `Operation input length (${opInputLen}) does not match document length (${session.content.length})`,
+      };
+    }
+
+    // Apply the operation
+    try {
+      const newContent = applyOp(session.content, transformedComponents);
+      session.version++;
+      session.content = newContent;
+
+      // Persist to database
+      this.db.updateDocument(docId, { content: newContent });
+      this.db.createVersion(
+        docId,
+        session.version,
+        newContent,
+        JSON.stringify(transformedComponents)
+      );
+
+      // Broadcast to all other clients
+      const ackMessage = JSON.stringify({
+        type: 'ack',
+        version: session.version,
+      });
+
+      const broadcastMessage = JSON.stringify({
+        type: 'operation',
+        version: session.version,
+        components: transformedComponents,
+        clientId,
+      });
+
+      for (const [id, client] of session.clients) {
+        if (client.ws.readyState !== WebSocket.OPEN) continue;
+        if (id === clientId) {
+          client.ws.send(ackMessage);
+        } else {
+          client.ws.send(broadcastMessage);
+        }
+      }
+
+      return { version: session.version };
+    } catch (err) {
+      const message = err instanceof Error ? err.message : 'Unknown error applying operation';
+      return { error: message };
+    }
+  }
+
+  /**
+   * Get the current in-memory state of a document session (for testing/debugging).
+   */
+  getSessionState(docId: string): { content: string; version: number; clientCount: number } | null {
+    const session = this.sessions.get(docId);
+    if (!session) return null;
+    return {
+      content: session.content,
+      version: session.version,
+      clientCount: session.clients.size,
+    };
+  }
+
+  /**
+   * Invalidate a session so the next join re-reads from db.
+   * Used when the REST API updates a document directly.
+   */
+  invalidateSession(docId: string): void {
+    const session = this.sessions.get(docId);
+    if (!session) return;
+
+    // Re-read from db
+    const doc = this.db.getDocument(docId);
+    if (!doc) {
+      // Document was deleted
+      // Notify all clients
+      for (const [, client] of session.clients) {
+        if (client.ws.readyState === WebSocket.OPEN) {
+          client.ws.send(JSON.stringify({ type: 'error', message: 'Document was deleted' }));
+          client.ws.close();
+        }
+      }
+      this.sessions.delete(docId);
+      return;
+    }
+
+    session.content = doc.content;
+    session.version = this.db.getLatestVersion(docId);
+
+    // Notify all connected clients of the sync
+    const syncMessage = JSON.stringify({
+      type: 'sync',
+      content: session.content,
+      version: session.version,
+    });
+    for (const [, client] of session.clients) {
+      if (client.ws.readyState === WebSocket.OPEN) {
+        client.ws.send(syncMessage);
+      }
+    }
+  }
+
+  /**
+   * Close all connections and clean up.
+   */
+  closeAll(): void {
+    for (const [, session] of this.sessions) {
+      for (const [, client] of session.clients) {
+        if (client.ws.readyState === WebSocket.OPEN) {
+          client.ws.close();
+        }
+      }
+    }
+    this.sessions.clear();
+  }
+}
diff --git a/src/ot.ts b/src/ot.ts
