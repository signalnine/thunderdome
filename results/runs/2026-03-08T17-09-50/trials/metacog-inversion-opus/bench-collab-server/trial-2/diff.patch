+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01N92zxYbi8B5y2MThJNFiEB","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01XkL2Giz2ZNj4rL8o3YuEjK","name":"Write","input":{"file_path":"/workspace/tests/websocket.test.ts","content":"import { describe, it, expect, beforeEach, afterEach } from 'vitest';\nimport request from 'supertest';\nimport WebSocket from 'ws';\nimport { createApp, AppInstance } from '../src/server.js';\n\nfunction connectWs(port: number, docId: string): Promise<WebSocket> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/${docId}`);\n    ws.on('open', () => resolve(ws));\n    ws.on('error', reject);\n  });\n}\n\nfunction waitForMessage(ws: WebSocket): Promise<Record<string, unknown>> {\n  return new Promise((resolve, reject) => {\n    const timeout = setTimeout(() => reject(new Error('Timeout waiting for message')), 5000);\n    ws.once('message', (data) => {\n      clearTimeout(timeout);\n      resolve(JSON.parse(data.toString()));\n    });\n  });\n}\n\ndescribe('WebSocket collaboration', () => {\n  let appInstance: AppInstance;\n  let port: number;\n\n  beforeEach(async () => {\n    appInstance = createApp();\n    port = await appInstance.start(0);\n  });\n\n  afterEach(async () => {\n    await appInstance.stop();\n  });\n\n  it('should receive sync message on connect', async () => {\n    const doc = await request(appInstance.app)\n      .post('/api/documents')\n      .send({ title: 'WS Test', content: 'hello' });\n\n    const ws = await connectWs(port, doc.body.id);\n    const msg = await waitForMessage(ws);\n\n    expect(msg.type).toBe('sync');\n    expect(msg.content).toBe('hello');\n    expect(msg.version).toBe(0);\n    expect(msg.clientId).toBeDefined();\n\n    ws.close();\n  });\n\n  it('should reject connection for non-existent document', async () => {\n    const ws = await connectWs(port, 'nonexistent');\n    const msg = await waitForMessage(ws);\n\n    expect(msg.type).toBe('error');\n    expect(msg.message).toBe('Document not found');\n\n    ws.close();\n  });\n\n  it('should apply and broadcast operations', async () => {\n    const doc = await request(appInstance.app)\n      .post('/api/documents')\n      .send({ title: 'Collab Test', content: 'hello' });\n\n    const ws1 = await connectWs(port, doc.body.id);\n    const sync1 = await waitForMessage(ws1);\n    const clientId1 = sync1.clientId;\n\n    const ws2 = await connectWs(port, doc.body.id);\n    const sync2 = await waitForMessage(ws2);\n\n    // Client 1 sends an operation: insert ' world' at position 5\n    const opPromise = waitForMessage(ws2); // ws2 should receive the broadcast\n    const ackPromise = waitForMessage(ws1); // ws1 should receive an ack\n\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [\n        { type: 'retain', count: 5 },\n        { type: 'insert', text: ' world' },\n      ],\n    }));\n\n    const [broadcastMsg, ackMsg] = await Promise.all([opPromise, ackPromise]);\n\n    expect(ackMsg.type).toBe('ack');\n    expect(ackMsg.version).toBe(1);\n\n    expect(broadcastMsg.type).toBe('operation');\n    expect(broadcastMsg.version).toBe(1);\n    expect(broadcastMsg.clientId).toBe(clientId1);\n\n    // Verify via REST\n    const updated = await request(appInstance.app)\n      .get(`/api/documents/${doc.body.id}`)\n      .expect(200);\n\n    expect(updated.body.content).toBe('hello world');\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should handle concurrent edits with OT', async () => {\n    const doc = await request(appInstance.app)\n      .post('/api/documents')\n      .send({ title: 'OT Test', content: 'abc' });\n\n    const ws1 = await connectWs(port, doc.body.id);\n    await waitForMessage(ws1); // sync\n\n    const ws2 = await connectWs(port, doc.body.id);\n    await waitForMessage(ws2); // sync\n\n    // Both clients send operations based on version 0\n    // Client 1: insert 'X' at position 0 -> \"Xabc\"\n    // Client 2: insert 'Y' at position 3 -> \"abcY\"\n    // After OT, result should contain both X and Y\n\n    const ws1Ack = waitForMessage(ws1);\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [\n        { type: 'insert', text: 'X' },\n        { type: 'retain', count: 3 },\n      ],\n    }));\n\n    await ws1Ack; // wait for ack before sending ws2's op\n\n    // Now ws2 sends an operation also based on version 0\n    // The server will transform it against ws1's operation\n    const ws2Ack = waitForMessage(ws2);\n    // ws2 also receives the broadcast from ws1\n    const ws2Broadcast = waitForMessage(ws2);\n\n    ws2.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [\n        { type: 'retain', count: 3 },\n        { type: 'insert', text: 'Y' },\n      ],\n    }));\n\n    // ws2 should get the broadcast from ws1's op first (if not already received),\n    // then an ack for its own op\n    // Actually, ws2 already received ws1's broadcast while we waited for ws1's ack\n    // Let's just wait for ws2's ack\n    await ws2Ack;\n\n    // Verify final state\n    const updated = await request(appInstance.app)\n      .get(`/api/documents/${doc.body.id}`)\n      .expect(200);\n\n    expect(updated.body.content).toContain('X');\n    expect(updated.body.content).toContain('Y');\n    expect(updated.body.content).toContain('abc');\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should handle 10 concurrent clients', async () => {\n    const doc = await request(appInstance.app)\n      .post('/api/documents')\n      .send({ title: 'Concurrency Test', content: '' });\n\n    const clients: WebSocket[] = [];\n    const clientIds: string[] = [];\n\n    // Connect 10 clients\n    for (let i = 0; i < 10; i++) {\n      const ws = await connectWs(port, doc.body.id);\n      const sync = await waitForMessage(ws);\n      clients.push(ws);\n      clientIds.push(sync.clientId as string);\n    }\n\n    // Each client inserts a character sequentially\n    for (let i = 0; i < 10; i++) {\n      const currentDoc = await request(appInstance.app)\n        .get(`/api/documents/${doc.body.id}`);\n\n      const currentContent = currentDoc.body.content;\n      const currentVersion = i; // Each operation increments version by 1\n\n      const ackPromise = waitForMessage(clients[i]);\n\n      clients[i].send(JSON.stringify({\n        type: 'operation',\n        version: currentVersion,\n        components: [\n          { type: 'retain', count: currentContent.length },\n          { type: 'insert', text: String(i) },\n        ],\n      }));\n\n      await ackPromise;\n\n      // Drain broadcast messages from other clients\n      for (let j = 0; j < 10; j++) {\n        if (j !== i) {\n          await waitForMessage(clients[j]);\n        }\n      }\n    }\n\n    // Verify final state\n    const finalDoc = await request(appInstance.app)\n      .get(`/api/documents/${doc.body.id}`)\n      .expect(200);\n\n    expect(finalDoc.body.content).toBe('0123456789');\n\n    // Clean up\n    for (const ws of clients) {\n      ws.close();\n    }\n  });\n\n  it('should send error for malformed operations', async () => {\n    const doc = await request(appInstance.app)\n      .post('/api/documents')\n      .send({ title: 'Error Test', content: 'hello' });\n\n    const ws = await connectWs(port, doc.body.id);\n    await waitForMessage(ws); // sync\n\n    // Send invalid JSON\n    ws.send('not json');\n    const errMsg1 = await waitForMessage(ws);\n    expect(errMsg1.type).toBe('error');\n\n    // Send invalid operation\n    ws.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [{ type: 'invalid' }],\n    }));\n    const errMsg2 = await waitForMessage(ws);\n    expect(errMsg2.type).toBe('error');\n\n    ws.close();\n  });\n\n  it('should persist documents across server restarts', async () => {\n    const dbPath = '/tmp/test-collab-' + Date.now() + '.db';\n\n    // Create a document with first server instance\n    const app1 = createApp(dbPath);\n    const port1 = await app1.start(0);\n\n    const doc = await request(app1.app)\n      .post('/api/documents')\n      .send({ title: 'Persistent', content: 'persisted content' });\n\n    const docId = doc.body.id;\n    await app1.stop();\n\n    // Start a new server instance with the same database\n    const app2 = createApp(dbPath);\n    const port2 = await app2.start(0);\n\n    const res = await request(app2.app)\n      .get(`/api/documents/${docId}`)\n      .expect(200);\n\n    expect(res.body.title).toBe('Persistent');\n    expect(res.body.content).toBe('persisted content');\n\n    await app2.stop();\n\n    // Clean up\n    const { unlinkSync } = await import('fs');\n    try { unlinkSync(dbPath); } catch { /* ignore */ }\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1485,"cache_read_input_tokens":38542,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1485},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"a823bdd8-3935-4672-af67-3c36a79916d1","uuid":"7e9eb6a6-1a17-4073-9e88-6594c6a62cde"}
