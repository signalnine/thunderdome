index 0000000..1c9b81e
--- /dev/null
+++ b/src/ot.ts
@@ -0,0 +1,254 @@
+/**
+ * Operational Transformation (OT) module.
+ *
+ * Operations are represented as a list of components that, when applied
+ * sequentially, transform a document from one state to another.
+ *
+ * Component types:
+ *   - retain(n): skip n characters unchanged
+ *   - insert(s): insert string s at current position
+ *   - delete(n): delete n characters at current position
+ *
+ * An operation's "input length" is the sum of retain + delete lengths.
+ * An operation's "output length" is the sum of retain + insert lengths.
+ * For an operation to be valid against a document, its input length must
+ * equal the document length.
+ */
+
+export type OTComponent =
+  | { type: 'retain'; count: number }
+  | { type: 'insert'; text: string }
+  | { type: 'delete'; count: number };
+
+export interface Operation {
+  docId: string;
+  version: number;        // the version this operation was created against
+  components: OTComponent[];
+  clientId?: string;
+}
+
+export function inputLength(op: OTComponent[]): number {
+  let len = 0;
+  for (const c of op) {
+    if (c.type === 'retain') len += c.count;
+    else if (c.type === 'delete') len += c.count;
+  }
+  return len;
+}
+
+export function outputLength(op: OTComponent[]): number {
+  let len = 0;
+  for (const c of op) {
+    if (c.type === 'retain') len += c.count;
+    else if (c.type === 'insert') len += c.text.length;
+  }
+  return len;
+}
+
+/**
+ * Apply an operation to a document string. Returns the new document string.
+ */
+export function applyOp(doc: string, components: OTComponent[]): string {
+  const inLen = inputLength(components);
+  if (inLen !== doc.length) {
+    throw new Error(
+      `Operation input length (${inLen}) does not match document length (${doc.length})`
+    );
+  }
+
+  let result = '';
+  let pos = 0;
+  for (const c of components) {
+    switch (c.type) {
+      case 'retain':
+        result += doc.slice(pos, pos + c.count);
+        pos += c.count;
+        break;
+      case 'insert':
+        result += c.text;
+        break;
+      case 'delete':
+        pos += c.count;
+        break;
+    }
+  }
+  return result;
+}
+
+/**
+ * Transform two concurrent operations a and b (both applied to the same document)
+ * such that apply(apply(doc, a), b') === apply(apply(doc, b), a')
+ *
+ * Returns [a', b'] where a' is a transformed against b and b' is b transformed against a.
+ */
+export function transform(
+  a: OTComponent[],
+  b: OTComponent[]
+): [OTComponent[], OTComponent[]] {
+  const aPrime: OTComponent[] = [];
+  const bPrime: OTComponent[] = [];
+
+  let ai = 0;
+  let bi = 0;
+
+  // Mutable copies of current components being consumed
+  let aComp: OTComponent | null = ai < a.length ? { ...a[ai] } : null;
+  let bComp: OTComponent | null = bi < b.length ? { ...b[bi] } : null;
+
+  const nextA = (): OTComponent | null => {
+    ai++;
+    return ai < a.length ? { ...a[ai] } : null;
+  };
+  const nextB = (): OTComponent | null => {
+    bi++;
+    return bi < b.length ? { ...b[bi] } : null;
+  };
+
+  while (aComp !== null || bComp !== null) {
+    // If a is insert, it goes first (a' keeps the insert, b' retains over it)
+    if (aComp !== null && aComp.type === 'insert') {
+      aPrime.push({ type: 'insert', text: aComp.text });
+      bPrime.push({ type: 'retain', count: aComp.text.length });
+      aComp = nextA();
+      continue;
+    }
+
+    // If b is insert, it goes first (b' keeps the insert, a' retains over it)
+    if (bComp !== null && bComp.type === 'insert') {
+      bPrime.push({ type: 'insert', text: bComp.text });
+      aPrime.push({ type: 'retain', count: bComp.text.length });
+      bComp = nextB();
+      continue;
+    }
+
+    if (aComp === null || bComp === null) {
+      throw new Error('Operations have different base lengths');
+    }
+
+    // Both retain
+    if (aComp.type === 'retain' && bComp.type === 'retain') {
+      const minLen = Math.min(aComp.count, bComp.count);
+      aPrime.push({ type: 'retain', count: minLen });
+      bPrime.push({ type: 'retain', count: minLen });
+      if (aComp.count > bComp.count) {
+        aComp = { type: 'retain', count: aComp.count - bComp.count };
+        bComp = nextB();
+      } else if (aComp.count < bComp.count) {
+        bComp = { type: 'retain', count: bComp.count - aComp.count };
+        aComp = nextA();
+      } else {
+        aComp = nextA();
+        bComp = nextB();
+      }
+      continue;
+    }
+
+    // a deletes, b deletes
+    if (aComp.type === 'delete' && bComp.type === 'delete') {
+      // Both delete the same range - neither needs to appear in the transformed ops
+      if (aComp.count > bComp.count) {
+        aComp = { type: 'delete', count: aComp.count - bComp.count };
+        bComp = nextB();
+      } else if (aComp.count < bComp.count) {
+        bComp = { type: 'delete', count: bComp.count - aComp.count };
+        aComp = nextA();
+      } else {
+        aComp = nextA();
+        bComp = nextB();
+      }
+      continue;
+    }
+
+    // a deletes, b retains
+    if (aComp.type === 'delete' && bComp.type === 'retain') {
+      const minLen = Math.min(aComp.count, bComp.count);
+      aPrime.push({ type: 'delete', count: minLen });
+      // b doesn't produce anything for the deleted range
+      if (aComp.count > bComp.count) {
+        aComp = { type: 'delete', count: aComp.count - bComp.count };
+        bComp = nextB();
+      } else if (aComp.count < bComp.count) {
+        bComp = { type: 'retain', count: bComp.count - aComp.count };
+        aComp = nextA();
+      } else {
+        aComp = nextA();
+        bComp = nextB();
+      }
+      continue;
+    }
+
+    // a retains, b deletes
+    if (aComp.type === 'retain' && bComp.type === 'delete') {
+      const minLen = Math.min(aComp.count, bComp.count);
+      bPrime.push({ type: 'delete', count: minLen });
+      // a doesn't produce anything for the deleted range
+      if (aComp.count > bComp.count) {
+        aComp = { type: 'retain', count: aComp.count - bComp.count };
+        bComp = nextB();
+      } else if (aComp.count < bComp.count) {
+        bComp = { type: 'delete', count: bComp.count - aComp.count };
+        aComp = nextA();
+      } else {
+        aComp = nextA();
+        bComp = nextB();
+      }
+      continue;
+    }
+
+    throw new Error(`Unexpected component types: ${aComp.type}, ${bComp.type}`);
+  }
+
+  return [compact(aPrime), compact(bPrime)];
+}
+
+/**
+ * Compact consecutive same-type components into one.
+ */
+function compact(components: OTComponent[]): OTComponent[] {
+  const result: OTComponent[] = [];
+  for (const c of components) {
+    if (c.type === 'retain' && c.count === 0) continue;
+    if (c.type === 'delete' && c.count === 0) continue;
+    if (c.type === 'insert' && c.text === '') continue;
+
+    const last = result[result.length - 1];
+    if (last && last.type === c.type) {
+      if (last.type === 'retain' && c.type === 'retain') {
+        last.count += c.count;
+      } else if (last.type === 'delete' && c.type === 'delete') {
+        last.count += c.count;
+      } else if (last.type === 'insert' && c.type === 'insert') {
+        last.text += c.text;
+      }
+    } else {
+      result.push({ ...c });
+    }
+  }
+  return result;
+}
+
+/**
+ * Validate an operation's components.
+ */
+export function validateComponents(components: unknown): components is OTComponent[] {
+  if (!Array.isArray(components)) return false;
+  for (const c of components) {
+    if (typeof c !== 'object' || c === null) return false;
+    if (!('type' in c)) return false;
+    const comp = c as Record<string, unknown>;
+    switch (comp.type) {
+      case 'retain':
+        if (typeof comp.count !== 'number' || comp.count < 0 || !Number.isInteger(comp.count)) return false;
+        break;
+      case 'insert':
+        if (typeof comp.text !== 'string') return false;
+        break;
+      case 'delete':
+        if (typeof comp.count !== 'number' || comp.count < 0 || !Number.isInteger(comp.count)) return false;
+        break;
+      default:
+        return false;
+    }
+  }
+  return true;
+}
