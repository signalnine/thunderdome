index 0000000..89a1c20
--- /dev/null
+++ b/src/ot.ts
@@ -0,0 +1,205 @@
+/**
+ * Operational Transform engine.
+ *
+ * Operations are arrays of components. Each component is one of:
+ *   { type: 'insert', position: number, text: string }
+ *   { type: 'delete', position: number, count: number }
+ *
+ * The server maintains a linear version history. Each operation is submitted
+ * against a specific base version. If the base version is behind the server's
+ * current version, the incoming operation is transformed against all
+ * intervening operations before being applied.
+ */
+
+export interface InsertOp {
+  type: 'insert';
+  position: number;
+  text: string;
+}
+
+export interface DeleteOp {
+  type: 'delete';
+  position: number;
+  count: number;
+}
+
+export type Operation = InsertOp | DeleteOp;
+
+/**
+ * Apply a single operation to a document string.
+ * Returns the resulting document.
+ */
+export function applyOperation(doc: string, op: Operation): string {
+  if (op.type === 'insert') {
+    const pos = Math.min(Math.max(0, op.position), doc.length);
+    return doc.slice(0, pos) + op.text + doc.slice(pos);
+  } else {
+    const pos = Math.min(Math.max(0, op.position), doc.length);
+    const end = Math.min(pos + op.count, doc.length);
+    return doc.slice(0, pos) + doc.slice(end);
+  }
+}
+
+/**
+ * Apply a sequence of operations to a document.
+ */
+export function applyOperations(doc: string, ops: Operation[]): string {
+  let result = doc;
+  for (const op of ops) {
+    result = applyOperation(result, op);
+  }
+  return result;
+}
+
+/**
+ * Transform operation `op` against `other` such that applying `other` then
+ * `transform(op, other)` produces the same document as applying `op` then
+ * `transform(other, op)`.
+ *
+ * This is the core OT function: transform(op_a, op_b) where op_b has already
+ * been applied, returns op_a' that achieves the same intent on the new document.
+ *
+ * `winTies` controls the tie-breaking: when true, `op` "wins" ties (its cursor
+ * goes first); when false, `other` wins.
+ */
+export function transformOp(op: Operation, other: Operation, winTies: boolean = false): Operation {
+  if (op.type === 'insert' && other.type === 'insert') {
+    // Both inserts: adjust position of op based on where other inserted.
+    if (op.position < other.position || (op.position === other.position && winTies)) {
+      return { ...op };
+    } else {
+      return { ...op, position: op.position + other.text.length };
+    }
+  }
+
+  if (op.type === 'insert' && other.type === 'delete') {
+    if (op.position <= other.position) {
+      return { ...op };
+    } else if (op.position >= other.position + other.count) {
+      return { ...op, position: op.position - other.count };
+    } else {
+      // Insert is inside the deleted range; move to start of delete
+      return { ...op, position: other.position };
+    }
+  }
+
+  if (op.type === 'delete' && other.type === 'insert') {
+    if (other.position >= op.position + op.count) {
+      return { ...op };
+    } else if (other.position <= op.position) {
+      return { ...op, position: op.position + other.text.length };
+    } else {
+      // The insert is inside our delete range. We need to split: delete before
+      // the insert, skip the inserted text, delete after the insert.
+      // For simplicity, we expand our delete to cover the additional inserted text.
+      // Actually, the correct behavior: the insert happened inside our delete range.
+      // After the insert, our delete range is split. We need to delete
+      // [op.position, other.position) and [other.position + other.text.length, ...)
+      // But since we only return one operation, we handle this by adjusting count.
+      // The inserted text should NOT be deleted (it's new content from the other user).
+      // We keep our delete count the same but shift accordingly.
+      // Split into: delete from op.position with count (other.position - op.position)
+      //   + delete from (other.position + other.text.length) with remaining count
+      // Since our Operation model is a single op, we'll return a modified version.
+      // For a single-op model, we expand count to cover original chars only:
+      // After the insert at other.position with other.text.length chars,
+      // our original range [op.position, op.position+op.count) now maps to
+      // [op.position, other.position) ∪ [other.position+other.text.length, op.position+op.count+other.text.length)
+      // We want to delete exactly our original characters, skipping the inserted text.
+      // This requires two operations. For simplicity in single-op model, we increase count.
+      return { ...op, count: op.count + other.text.length };
+    }
+  }
+
+  if (op.type === 'delete' && other.type === 'delete') {
+    // Both deletes: adjust based on overlap.
+    if (op.position >= other.position + other.count) {
+      // op is entirely after other's range
+      return { ...op, position: op.position - other.count };
+    } else if (op.position + op.count <= other.position) {
+      // op is entirely before other's range
+      return { ...op };
+    } else {
+      // Overlapping deletes
+      const opEnd = op.position + op.count;
+      const otherEnd = other.position + other.count;
+
+      const newPosition = Math.min(op.position, other.position);
+      // Characters we still need to delete = our range minus the overlap
+      const overlapStart = Math.max(op.position, other.position);
+      const overlapEnd = Math.min(opEnd, otherEnd);
+      const overlap = Math.max(0, overlapEnd - overlapStart);
+      const newCount = op.count - overlap;
+
+      if (newCount <= 0) {
+        // Nothing left to delete
+        return { type: 'delete', position: newPosition, count: 0 };
+      }
+
+      // New position is at the position minus what other already removed before us
+      const beforeOp = Math.max(0, Math.min(other.count, op.position - other.position));
+      return { type: 'delete', position: op.position - beforeOp, count: newCount };
+    }
+  }
+
+  // Should never reach here
+  return { ...op } as Operation;
+}
+
+/**
+ * Transform an operation against a list of operations that have already been applied.
+ */
+export function transformOpAgainstOps(op: Operation, others: Operation[]): Operation {
+  let transformed = op;
+  for (const other of others) {
+    transformed = transformOp(transformed, other);
+  }
+  return transformed;
+}
+
+/**
+ * Validate that an operation is well-formed.
+ */
+export function validateOperation(op: unknown): op is Operation {
+  if (typeof op !== 'object' || op === null) return false;
+  const o = op as Record<string, unknown>;
+
+  if (o.type === 'insert') {
+    return (
+      typeof o.position === 'number' &&
+      Number.isInteger(o.position) &&
+      o.position >= 0 &&
+      typeof o.text === 'string' &&
+      o.text.length > 0
+    );
+  }
+
+  if (o.type === 'delete') {
+    return (
+      typeof o.position === 'number' &&
+      Number.isInteger(o.position) &&
+      o.position >= 0 &&
+      typeof o.count === 'number' &&
+      Number.isInteger(o.count) &&
+      o.count > 0
+    );
+  }
+
+  return false;
+}
+
+/**
+ * Validate an operation against the current document content.
+ */
+export function validateOperationAgainstDoc(op: Operation, docLength: number): string | null {
+  if (op.type === 'insert') {
+    if (op.position > docLength) {
+      return `Insert position ${op.position} is beyond document length ${docLength}`;
+    }
+  } else if (op.type === 'delete') {
+    if (op.position + op.count > docLength) {
+      return `Delete range [${op.position}, ${op.position + op.count}) exceeds document length ${docLength}`;
+    }
+  }
+  return null;
+}
