+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01SqveCQpkNmXuLqwVLx4DiR","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Q2sR2bem7UV66xMLNCxvEQ","name":"Write","input":{"file_path":"/workspace/src/collaboration.ts","content":"import { WebSocketServer, WebSocket } from 'ws';\nimport { IncomingMessage } from 'http';\nimport { Server as HttpServer } from 'http';\nimport { DocumentStore } from './database.js';\nimport {\n  Operation,\n  validateOperation,\n  validateOperationAgainstDoc,\n  applyOperation,\n  transformOpAgainstOps,\n} from './ot.js';\n\ninterface ClientConnection {\n  ws: WebSocket;\n  documentId: string;\n  clientId: string;\n}\n\n/**\n * Messages from client to server:\n *   { type: 'operation', operation: Operation, version: number, clientId: string }\n *\n * Messages from server to client:\n *   { type: 'sync', content: string, version: number, documentId: string }\n *   { type: 'operation', operation: Operation, version: number, clientId: string }\n *   { type: 'ack', version: number }\n *   { type: 'error', message: string }\n */\n\nexport class CollaborationServer {\n  private wss: WebSocketServer;\n  private store: DocumentStore;\n  // documentId -> list of clients\n  private rooms: Map<string, ClientConnection[]> = new Map();\n  // documentId -> list of operations (in order, index = version - 1)\n  private operationLog: Map<string, Operation[]> = new Map();\n\n  constructor(server: HttpServer, store: DocumentStore) {\n    this.store = store;\n    this.wss = new WebSocketServer({ server, path: undefined });\n\n    // Handle upgrade manually to extract document ID from path\n    server.on('upgrade', (request: IncomingMessage, socket, head) => {\n      const url = new URL(request.url || '/', `http://${request.headers.host || 'localhost'}`);\n      const match = url.pathname.match(/^\\/ws\\/documents\\/([^/]+)$/);\n\n      if (!match) {\n        socket.write('HTTP/1.1 404 Not Found\\r\\n\\r\\n');\n        socket.destroy();\n        return;\n      }\n\n      const documentId = match[1];\n      const doc = this.store.getDocument(documentId);\n      if (!doc) {\n        socket.write('HTTP/1.1 404 Not Found\\r\\n\\r\\n');\n        socket.destroy();\n        return;\n      }\n\n      this.wss.handleUpgrade(request, socket, head, (ws) => {\n        this.wss.emit('connection', ws, request, documentId);\n      });\n    });\n\n    this.wss.on('connection', (ws: WebSocket, _request: IncomingMessage, documentId: string) => {\n      this.handleConnection(ws, documentId);\n    });\n  }\n\n  private handleConnection(ws: WebSocket, documentId: string): void {\n    const clientId = Math.random().toString(36).substring(2, 10);\n\n    const client: ClientConnection = { ws, documentId, clientId };\n\n    // Add to room\n    if (!this.rooms.has(documentId)) {\n      this.rooms.set(documentId, []);\n    }\n    this.rooms.get(documentId)!.push(client);\n\n    // Initialize operation log for this document if needed\n    if (!this.operationLog.has(documentId)) {\n      // Load existing operations from version history\n      const versions = this.store.getVersionHistory(documentId);\n      const ops = versions.map((v) => JSON.parse(v.operation) as Operation);\n      this.operationLog.set(documentId, ops);\n    }\n\n    // Send sync message with current document state\n    const doc = this.store.getDocument(documentId);\n    if (doc) {\n      this.send(ws, {\n        type: 'sync',\n        content: doc.content,\n        version: doc.version,\n        documentId,\n      });\n    }\n\n    ws.on('message', (data) => {\n      try {\n        const message = JSON.parse(data.toString());\n        this.handleMessage(client, message);\n      } catch {\n        this.send(ws, { type: 'error', message: 'Invalid JSON' });\n      }\n    });\n\n    ws.on('close', () => {\n      this.removeClient(client);\n    });\n\n    ws.on('error', () => {\n      this.removeClient(client);\n    });\n  }\n\n  private handleMessage(client: ClientConnection, message: Record<string, unknown>): void {\n    if (message.type !== 'operation') {\n      this.send(client.ws, { type: 'error', message: `Unknown message type: ${message.type}` });\n      return;\n    }\n\n    const { operation, version } = message;\n\n    // Validate the operation\n    if (!validateOperation(operation)) {\n      this.send(client.ws, { type: 'error', message: 'Invalid operation format' });\n      return;\n    }\n\n    if (typeof version !== 'number' || !Number.isInteger(version) || version < 0) {\n      this.send(client.ws, { type: 'error', message: 'Invalid version number' });\n      return;\n    }\n\n    const doc = this.store.getDocument(client.documentId);\n    if (!doc) {\n      this.send(client.ws, { type: 'error', message: 'Document not found' });\n      return;\n    }\n\n    const opLog = this.operationLog.get(client.documentId) || [];\n    const currentVersion = doc.version;\n\n    if (version > currentVersion) {\n      this.send(client.ws, {\n        type: 'error',\n        message: `Version ${version} is ahead of server version ${currentVersion}`,\n      });\n      return;\n    }\n\n    // Transform the operation against all operations that happened since `version`\n    const concurrentOps = opLog.slice(version);\n    let transformedOp = operation as Operation;\n\n    if (concurrentOps.length > 0) {\n      transformedOp = transformOpAgainstOps(transformedOp, concurrentOps);\n    }\n\n    // Validate the transformed operation against current document\n    const validationError = validateOperationAgainstDoc(transformedOp, doc.content.length);\n    if (validationError) {\n      this.send(client.ws, { type: 'error', message: validationError });\n      return;\n    }\n\n    // Apply the operation\n    const newContent = applyOperation(doc.content, transformedOp);\n    const newVersion = currentVersion + 1;\n\n    // Persist\n    this.store.applyOperation(\n      client.documentId,\n      JSON.stringify(transformedOp),\n      newContent,\n      newVersion\n    );\n\n    // Update operation log\n    opLog.push(transformedOp);\n    this.operationLog.set(client.documentId, opLog);\n\n    // Send ack to the sender\n    this.send(client.ws, { type: 'ack', version: newVersion });\n\n    // Broadcast to other clients in the same room\n    const room = this.rooms.get(client.documentId) || [];\n    for (const other of room) {\n      if (other.ws !== client.ws && other.ws.readyState === WebSocket.OPEN) {\n        this.send(other.ws, {\n          type: 'operation',\n          operation: transformedOp,\n          version: newVersion,\n          clientId: client.clientId,\n        });\n      }\n    }\n  }\n\n  private send(ws: WebSocket, message: Record<string, unknown>): void {\n    if (ws.readyState === WebSocket.OPEN) {\n      ws.send(JSON.stringify(message));\n    }\n  }\n\n  private removeClient(client: ClientConnection): void {\n    const room = this.rooms.get(client.documentId);\n    if (room) {\n      const index = room.indexOf(client);\n      if (index !== -1) {\n        room.splice(index, 1);\n      }\n      if (room.length === 0) {\n        this.rooms.delete(client.documentId);\n        // Keep operation log for consistency; it will be reloaded from DB if needed\n      }\n    }\n  }\n\n  closeAll(): void {\n    for (const [, room] of this.rooms) {\n      for (const client of room) {\n        client.ws.close();\n      }\n    }\n    this.rooms.clear();\n    this.wss.close();\n  }\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":320,"cache_read_input_tokens":26381,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":320},"output_tokens":18,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"fd49472b-8c18-437a-9bc1-673a5fe9afeb","uuid":"07ded302-62cd-4e24-b0e0-136909969995"}
