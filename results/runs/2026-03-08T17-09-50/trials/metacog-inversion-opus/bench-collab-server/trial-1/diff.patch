index 0000000..ff005a9
--- /dev/null
+++ b/src/collaboration.ts
@@ -0,0 +1,232 @@
+import { WebSocketServer, WebSocket } from 'ws';
+import { IncomingMessage } from 'http';
+import { Server as HttpServer } from 'http';
+import { DocumentStore } from './database.js';
+import {
+  Operation,
+  validateOperation,
+  validateOperationAgainstDoc,
+  applyOperation,
+  transformOpAgainstOps,
+} from './ot.js';
+
+interface ClientConnection {
+  ws: WebSocket;
+  documentId: string;
+  clientId: string;
+}
+
+/**
+ * Messages from client to server:
+ *   { type: 'operation', operation: Operation, version: number, clientId: string }
+ *
+ * Messages from server to client:
+ *   { type: 'sync', content: string, version: number, documentId: string }
+ *   { type: 'operation', operation: Operation, version: number, clientId: string }
+ *   { type: 'ack', version: number }
+ *   { type: 'error', message: string }
+ */
+
+export class CollaborationServer {
+  private wss: WebSocketServer;
+  private store: DocumentStore;
+  // documentId -> list of clients
+  private rooms: Map<string, ClientConnection[]> = new Map();
+  // documentId -> list of operations (in order, index = version - 1)
+  private operationLog: Map<string, Operation[]> = new Map();
+
+  constructor(server: HttpServer, store: DocumentStore) {
+    this.store = store;
+    this.wss = new WebSocketServer({ server, path: undefined });
+
+    // Handle upgrade manually to extract document ID from path
+    server.on('upgrade', (request: IncomingMessage, socket, head) => {
+      const url = new URL(request.url || '/', `http://${request.headers.host || 'localhost'}`);
+      const match = url.pathname.match(/^\/ws\/documents\/([^/]+)$/);
+
+      if (!match) {
+        socket.write('HTTP/1.1 404 Not Found\r\n\r\n');
+        socket.destroy();
+        return;
+      }
+
+      const documentId = match[1];
+      const doc = this.store.getDocument(documentId);
+      if (!doc) {
+        socket.write('HTTP/1.1 404 Not Found\r\n\r\n');
+        socket.destroy();
+        return;
+      }
+
+      this.wss.handleUpgrade(request, socket, head, (ws) => {
+        this.wss.emit('connection', ws, request, documentId);
+      });
+    });
+
+    this.wss.on('connection', (ws: WebSocket, _request: IncomingMessage, documentId: string) => {
+      this.handleConnection(ws, documentId);
+    });
+  }
+
+  private handleConnection(ws: WebSocket, documentId: string): void {
+    const clientId = Math.random().toString(36).substring(2, 10);
+
+    const client: ClientConnection = { ws, documentId, clientId };
+
+    // Add to room
+    if (!this.rooms.has(documentId)) {
+      this.rooms.set(documentId, []);
+    }
+    this.rooms.get(documentId)!.push(client);
+
+    // Initialize operation log for this document if needed
+    if (!this.operationLog.has(documentId)) {
+      // Load existing operations from version history
+      const versions = this.store.getVersionHistory(documentId);
+      const ops = versions.map((v) => JSON.parse(v.operation) as Operation);
+      this.operationLog.set(documentId, ops);
+    }
+
+    // Send sync message with current document state
+    const doc = this.store.getDocument(documentId);
+    if (doc) {
+      this.send(ws, {
+        type: 'sync',
+        content: doc.content,
+        version: doc.version,
+        documentId,
+      });
+    }
+
+    ws.on('message', (data) => {
+      try {
+        const message = JSON.parse(data.toString());
+        this.handleMessage(client, message);
+      } catch {
+        this.send(ws, { type: 'error', message: 'Invalid JSON' });
+      }
+    });
+
+    ws.on('close', () => {
+      this.removeClient(client);
+    });
+
+    ws.on('error', () => {
+      this.removeClient(client);
+    });
+  }
+
+  private handleMessage(client: ClientConnection, message: Record<string, unknown>): void {
+    if (message.type !== 'operation') {
+      this.send(client.ws, { type: 'error', message: `Unknown message type: ${message.type}` });
+      return;
+    }
+
+    const { operation, version } = message;
+
+    // Validate the operation
+    if (!validateOperation(operation)) {
+      this.send(client.ws, { type: 'error', message: 'Invalid operation format' });
+      return;
+    }
+
+    if (typeof version !== 'number' || !Number.isInteger(version) || version < 0) {
+      this.send(client.ws, { type: 'error', message: 'Invalid version number' });
+      return;
+    }
+
+    const doc = this.store.getDocument(client.documentId);
+    if (!doc) {
+      this.send(client.ws, { type: 'error', message: 'Document not found' });
+      return;
+    }
+
+    const opLog = this.operationLog.get(client.documentId) || [];
+    const currentVersion = doc.version;
+
+    if (version > currentVersion) {
+      this.send(client.ws, {
+        type: 'error',
+        message: `Version ${version} is ahead of server version ${currentVersion}`,
+      });
+      return;
+    }
+
+    // Transform the operation against all operations that happened since `version`
+    const concurrentOps = opLog.slice(version);
+    let transformedOp = operation as Operation;
+
+    if (concurrentOps.length > 0) {
+      transformedOp = transformOpAgainstOps(transformedOp, concurrentOps);
+    }
+
+    // Validate the transformed operation against current document
+    const validationError = validateOperationAgainstDoc(transformedOp, doc.content.length);
+    if (validationError) {
+      this.send(client.ws, { type: 'error', message: validationError });
+      return;
+    }
+
+    // Apply the operation
+    const newContent = applyOperation(doc.content, transformedOp);
+    const newVersion = currentVersion + 1;
+
+    // Persist
+    this.store.applyOperation(
+      client.documentId,
+      JSON.stringify(transformedOp),
+      newContent,
+      newVersion
+    );
+
+    // Update operation log
+    opLog.push(transformedOp);
+    this.operationLog.set(client.documentId, opLog);
+
+    // Send ack to the sender
+    this.send(client.ws, { type: 'ack', version: newVersion });
+
+    // Broadcast to other clients in the same room
+    const room = this.rooms.get(client.documentId) || [];
+    for (const other of room) {
+      if (other.ws !== client.ws && other.ws.readyState === WebSocket.OPEN) {
+        this.send(other.ws, {
+          type: 'operation',
+          operation: transformedOp,
+          version: newVersion,
+          clientId: client.clientId,
+        });
+      }
+    }
+  }
+
+  private send(ws: WebSocket, message: Record<string, unknown>): void {
+    if (ws.readyState === WebSocket.OPEN) {
+      ws.send(JSON.stringify(message));
+    }
+  }
+
+  private removeClient(client: ClientConnection): void {
+    const room = this.rooms.get(client.documentId);
+    if (room) {
+      const index = room.indexOf(client);
+      if (index !== -1) {
+        room.splice(index, 1);
+      }
+      if (room.length === 0) {
+        this.rooms.delete(client.documentId);
+        // Keep operation log for consistency; it will be reloaded from DB if needed
+      }
+    }
+  }
+
+  closeAll(): void {
+    for (const [, room] of this.rooms) {
+      for (const client of room) {
+        client.ws.close();
+      }
+    }
+    this.rooms.clear();
+    this.wss.close();
+  }
+}
diff --git a/src/database.ts b/src/database.ts
new file mode 100644
index 0000000..2f40566
--- /dev/null
+++ b/src/database.ts
@@ -0,0 +1,143 @@
+import Database from 'better-sqlite3';
+
+export interface DocumentRow {
+  id: string;
+  title: string;
+  content: string;
+  version: number;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface VersionRow {
+  id: number;
+  document_id: string;
+  version: number;
+  operation: string; // JSON-encoded operation
+  content_after: string;
+  created_at: string;
+}
+
+export function createDatabase(dbPath?: string): Database.Database {
+  const db = new Database(dbPath || ':memory:');
+  db.pragma('journal_mode = WAL');
+  db.pragma('foreign_keys = ON');
+
+  db.exec(`
+    CREATE TABLE IF NOT EXISTS documents (
+      id TEXT PRIMARY KEY,
+      title TEXT NOT NULL,
+      content TEXT NOT NULL DEFAULT '',
+      version INTEGER NOT NULL DEFAULT 0,
+      created_at TEXT NOT NULL DEFAULT (datetime('now')),
+      updated_at TEXT NOT NULL DEFAULT (datetime('now'))
+    );
+
+    CREATE TABLE IF NOT EXISTS versions (
+      id INTEGER PRIMARY KEY AUTOINCREMENT,
+      document_id TEXT NOT NULL,
+      version INTEGER NOT NULL,
+      operation TEXT NOT NULL,
+      content_after TEXT NOT NULL,
+      created_at TEXT NOT NULL DEFAULT (datetime('now')),
+      FOREIGN KEY (document_id) REFERENCES documents(id) ON DELETE CASCADE
+    );
+
+    CREATE INDEX IF NOT EXISTS idx_versions_doc_version
+      ON versions(document_id, version);
+  `);
+
+  return db;
+}
+
+export class DocumentStore {
+  private db: Database.Database;
+
+  private stmts: {
+    insert: Database.Statement;
+    getById: Database.Statement;
+    getAll: Database.Statement;
+    update: Database.Statement;
+    updateContent: Database.Statement;
+    delete: Database.Statement;
+    insertVersion: Database.Statement;
+    getVersions: Database.Statement;
+    getVersion: Database.Statement;
+  };
+
+  constructor(db: Database.Database) {
+    this.db = db;
+
+    this.stmts = {
+      insert: db.prepare(
+        `INSERT INTO documents (id, title, content, version) VALUES (?, ?, ?, 0)`
+      ),
+      getById: db.prepare(`SELECT * FROM documents WHERE id = ?`),
+      getAll: db.prepare(`SELECT * FROM documents ORDER BY updated_at DESC`),
+      update: db.prepare(
+        `UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?`
+      ),
+      updateContent: db.prepare(
+        `UPDATE documents SET content = ?, version = ?, updated_at = datetime('now') WHERE id = ?`
+      ),
+      delete: db.prepare(`DELETE FROM documents WHERE id = ?`),
+      insertVersion: db.prepare(
+        `INSERT INTO versions (document_id, version, operation, content_after) VALUES (?, ?, ?, ?)`
+      ),
+      getVersions: db.prepare(
+        `SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC`
+      ),
+      getVersion: db.prepare(
+        `SELECT * FROM versions WHERE document_id = ? AND version = ?`
+      ),
+    };
+  }
+
+  createDocument(id: string, title: string, content: string = ''): DocumentRow {
+    this.stmts.insert.run(id, title, content);
+    return this.stmts.getById.get(id) as DocumentRow;
+  }
+
+  getDocument(id: string): DocumentRow | undefined {
+    return this.stmts.getById.get(id) as DocumentRow | undefined;
+  }
+
+  getAllDocuments(): DocumentRow[] {
+    return this.stmts.getAll.all() as DocumentRow[];
+  }
+
+  updateDocument(id: string, title: string, content: string): DocumentRow | undefined {
+    const result = this.stmts.update.run(title, content, id);
+    if (result.changes === 0) return undefined;
+    return this.stmts.getById.get(id) as DocumentRow;
+  }
+
+  updateContent(id: string, content: string, version: number): void {
+    this.stmts.updateContent.run(content, version, id);
+  }
+
+  deleteDocument(id: string): boolean {
+    const result = this.stmts.delete.run(id);
+    return result.changes > 0;
+  }
+
+  addVersion(documentId: string, version: number, operation: string, contentAfter: string): void {
+    this.stmts.insertVersion.run(documentId, version, operation, contentAfter);
+  }
+
+  getVersionHistory(documentId: string): VersionRow[] {
+    return this.stmts.getVersions.all(documentId) as VersionRow[];
+  }
+
+  getVersionAt(documentId: string, version: number): VersionRow | undefined {
+    return this.stmts.getVersion.get(documentId, version) as VersionRow | undefined;
+  }
+
+  applyOperation(documentId: string, operation: string, newContent: string, newVersion: number): void {
+    const txn = this.db.transaction(() => {
+      this.updateContent(documentId, newContent, newVersion);
+      this.addVersion(documentId, newVersion, operation, newContent);
+    });
+    txn();
+  }
+}
