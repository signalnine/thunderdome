t(id: string, content: string, version: number): void {\n    this.stmts.updateContent.run(content, version, id);\n  }\n\n  deleteDocument(id: string): boolean {\n    const result = this.stmts.delete.run(id);\n    return result.changes > 0;\n  }\n\n  addVersion(documentId: string, version: number, operation: string, contentAfter: string): void {\n    this.stmts.insertVersion.run(documentId, version, operation, contentAfter);\n  }\n\n  getVersionHistory(documentId: string): VersionRow[] {\n    return this.stmts.getVersions.all(documentId) as VersionRow[];\n  }\n\n  getVersionAt(documentId: string, version: number): VersionRow | undefined {\n    return this.stmts.getVersion.get(documentId, version) as VersionRow | undefined;\n  }\n\n  applyOperation(documentId: string, operation: string, newContent: string, newVersion: number): void {\n    const txn = this.db.transaction(() => {\n      this.updateContent(documentId, newContent, newVersion);\n      this.addVersion(documentId, newVersion, operation, newContent);\n    });\n    txn();\n  }\n}\n","structuredPatch":[],"originalFile":null}}
