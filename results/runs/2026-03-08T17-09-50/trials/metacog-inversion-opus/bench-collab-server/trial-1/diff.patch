+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01DH28pKFQ4Y5yCS9VpBcxSm","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01EiLYQRpgSVfUT6U7Xi6Ep3","name":"Write","input":{"file_path":"/workspace/src/database.ts","content":"import Database from 'better-sqlite3';\n\nexport interface DocumentRow {\n  id: string;\n  title: string;\n  content: string;\n  version: number;\n  created_at: string;\n  updated_at: string;\n}\n\nexport interface VersionRow {\n  id: number;\n  document_id: string;\n  version: number;\n  operation: string; // JSON-encoded operation\n  content_after: string;\n  created_at: string;\n}\n\nexport function createDatabase(dbPath?: string): Database.Database {\n  const db = new Database(dbPath || ':memory:');\n  db.pragma('journal_mode = WAL');\n  db.pragma('foreign_keys = ON');\n\n  db.exec(`\n    CREATE TABLE IF NOT EXISTS documents (\n      id TEXT PRIMARY KEY,\n      title TEXT NOT NULL,\n      content TEXT NOT NULL DEFAULT '',\n      version INTEGER NOT NULL DEFAULT 0,\n      created_at TEXT NOT NULL DEFAULT (datetime('now')),\n      updated_at TEXT NOT NULL DEFAULT (datetime('now'))\n    );\n\n    CREATE TABLE IF NOT EXISTS versions (\n      id INTEGER PRIMARY KEY AUTOINCREMENT,\n      document_id TEXT NOT NULL,\n      version INTEGER NOT NULL,\n      operation TEXT NOT NULL,\n      content_after TEXT NOT NULL,\n      created_at TEXT NOT NULL DEFAULT (datetime('now')),\n      FOREIGN KEY (document_id) REFERENCES documents(id) ON DELETE CASCADE\n    );\n\n    CREATE INDEX IF NOT EXISTS idx_versions_doc_version\n      ON versions(document_id, version);\n  `);\n\n  return db;\n}\n\nexport class DocumentStore {\n  private db: Database.Database;\n\n  private stmts: {\n    insert: Database.Statement;\n    getById: Database.Statement;\n    getAll: Database.Statement;\n    update: Database.Statement;\n    updateContent: Database.Statement;\n    delete: Database.Statement;\n    insertVersion: Database.Statement;\n    getVersions: Database.Statement;\n    getVersion: Database.Statement;\n  };\n\n  constructor(db: Database.Database) {\n    this.db = db;\n\n    this.stmts = {\n      insert: db.prepare(\n        `INSERT INTO documents (id, title, content, version) VALUES (?, ?, ?, 0)`\n      ),\n      getById: db.prepare(`SELECT * FROM documents WHERE id = ?`),\n      getAll: db.prepare(`SELECT * FROM documents ORDER BY updated_at DESC`),\n      update: db.prepare(\n        `UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?`\n      ),\n      updateContent: db.prepare(\n        `UPDATE documents SET content = ?, version = ?, updated_at = datetime('now') WHERE id = ?`\n      ),\n      delete: db.prepare(`DELETE FROM documents WHERE id = ?`),\n      insertVersion: db.prepare(\n        `INSERT INTO versions (document_id, version, operation, content_after) VALUES (?, ?, ?, ?)`\n      ),\n      getVersions: db.prepare(\n        `SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC`\n      ),\n      getVersion: db.prepare(\n        `SELECT * FROM versions WHERE document_id = ? AND version = ?`\n      ),\n    };\n  }\n\n  createDocument(id: string, title: string, content: string = ''): DocumentRow {\n    this.stmts.insert.run(id, title, content);\n    return this.stmts.getById.get(id) as DocumentRow;\n  }\n\n  getDocument(id: string): DocumentRow | undefined {\n    return this.stmts.getById.get(id) as DocumentRow | undefined;\n  }\n\n  getAllDocuments(): DocumentRow[] {\n    return this.stmts.getAll.all() as DocumentRow[];\n  }\n\n  updateDocument(id: string, title: string, content: string): DocumentRow | undefined {\n    const result = this.stmts.update.run(title, content, id);\n    if (result.changes === 0) return undefined;\n    return this.stmts.getById.get(id) as DocumentRow;\n  }\n\n  updateContent(id: string, content: string, version: number): void {\n    this.stmts.updateContent.run(content, version, id);\n  }\n\n  deleteDocument(id: string): boolean {\n    const result = this.stmts.delete.run(id);\n    return result.changes > 0;\n  }\n\n  addVersion(documentId: string, version: number, operation: string, contentAfter: string): void {\n    this.stmts.insertVersion.run(documentId, version, operation, contentAfter);\n  }\n\n  getVersionHistory(documentId: string): VersionRow[] {\n    return this.stmts.getVersions.all(documentId) as VersionRow[];\n  }\n\n  getVersionAt(documentId: string, version: number): VersionRow | undefined {\n    return this.stmts.getVersion.get(documentId, version) as VersionRow | undefined;\n  }\n\n  applyOperation(documentId: string, operation: string, newContent: string, newVersion: number): void {\n    const txn = this.db.transaction(() => {\n      this.updateContent(documentId, newContent, newVersion);\n      this.addVersion(documentId, newVersion, operation, newContent);\n    });\n    txn();\n  }\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":320,"cache_read_input_tokens":20772,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":320},"output_tokens":18,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"fd49472b-8c18-437a-9bc1-673a5fe9afeb","uuid":"1538a480-c145-438b-a1bf-9f39291b7dd2"}
