+import { describe, it, expect, beforeEach, afterEach } from 'vitest';
+import request from 'supertest';
+import WebSocket from 'ws';
+import { createApp, AppInstance } from '../server.js';
+
+let app: AppInstance;
+let port: number;
+
+function wsUrl(docId: string): string {
+  return `ws://localhost:${port}/ws/documents/${docId}`;
+}
+
+function connectWs(docId: string): Promise<WebSocket> {
+  return new Promise((resolve, reject) => {
+    const ws = new WebSocket(wsUrl(docId));
+    ws.on('open', () => resolve(ws));
+    ws.on('error', reject);
+  });
+}
+
+function waitForMessage(ws: WebSocket): Promise<Record<string, unknown>> {
+  return new Promise((resolve) => {
+    ws.once('message', (data) => {
+      resolve(JSON.parse(data.toString()));
+    });
+  });
+}
+
+function sendOp(ws: WebSocket, operation: Record<string, unknown>, version: number): void {
+  ws.send(
+    JSON.stringify({
+      type: 'operation',
+      operation,
+      version,
+    })
+  );
+}
+
+describe('REST API', () => {
+  beforeEach(async () => {
+    app = createApp();
+    port = await app.start(0);
+  });
+
+  afterEach(async () => {
+    await app.stop();
+  });
+
+  it('creates a document', async () => {
+    const res = await request(app.app)
+      .post('/api/documents')
+      .send({ title: 'Test Doc', content: 'Hello' })
+      .expect(201);
+
+    expect(res.body.title).toBe('Test Doc');
+    expect(res.body.content).toBe('Hello');
+    expect(res.body.id).toBeDefined();
+    expect(res.body.version).toBe(0);
+  });
+
+  it('lists documents', async () => {
+    await request(app.app).post('/api/documents').send({ title: 'Doc 1' });
+    await request(app.app).post('/api/documents').send({ title: 'Doc 2' });
+
+    const res = await request(app.app).get('/api/documents').expect(200);
+    expect(res.body.length).toBe(2);
+  });
+
+  it('gets a document by id', async () => {
+    const created = await request(app.app).post('/api/documents').send({ title: 'My Doc' });
+    const res = await request(app.app).get(`/api/documents/${created.body.id}`).expect(200);
+    expect(res.body.title).toBe('My Doc');
+  });
+
+  it('returns 404 for missing document', async () => {
+    await request(app.app).get('/api/documents/nonexistent').expect(404);
+  });
+
+  it('updates a document', async () => {
+    const created = await request(app.app)
+      .post('/api/documents')
+      .send({ title: 'Old', content: 'old content' });
+
+    const res = await request(app.app)
+      .put(`/api/documents/${created.body.id}`)
+      .send({ title: 'New', content: 'new content' })
+      .expect(200);
+
+    expect(res.body.title).toBe('New');
+    expect(res.body.content).toBe('new content');
+  });
+
+  it('deletes a document', async () => {
+    const created = await request(app.app).post('/api/documents').send({ title: 'ToDelete' });
+    await request(app.app).delete(`/api/documents/${created.body.id}`).expect(204);
+    await request(app.app).get(`/api/documents/${created.body.id}`).expect(404);
+  });
+
+  it('rejects document creation without title', async () => {
+    await request(app.app).post('/api/documents').send({ content: 'no title' }).expect(400);
+  });
+
+  it('gets version history', async () => {
+    const created = await request(app.app)
+      .post('/api/documents')
+      .send({ title: 'Versioned Doc', content: '' });
+
+    const res = await request(app.app)
+      .get(`/api/documents/${created.body.id}/versions`)
+      .expect(200);
+    expect(res.body).toEqual([]);
+  });
+});
+
+describe('WebSocket Collaboration', () => {
+  beforeEach(async () => {
+    app = createApp();
+    port = await app.start(0);
+  });
+
+  afterEach(async () => {
+    await app.stop();
+  });
+
+  it('sends sync message on connect', async () => {
+    const created = await request(app.app)
+      .post('/api/documents')
+      .send({ title: 'WS Doc', content: 'initial' });
+
+    const ws = await connectWs(created.body.id);
+    const msg = await waitForMessage(ws);
+
+    expect(msg.type).toBe('sync');
+    expect(msg.content).toBe('initial');
+    expect(msg.version).toBe(0);
+
+    ws.close();
+  });
+
+  it('applies an insert operation and acks', async () => {
+    const created = await request(app.app)
+      .post('/api/documents')
+      .send({ title: 'WS Doc', content: 'hello' });
+
+    const ws = await connectWs(created.body.id);
+    await waitForMessage(ws); // sync
+
+    sendOp(ws, { type: 'insert', position: 5, text: ' world' }, 0);
+    const ack = await waitForMessage(ws);
+
+    expect(ack.type).toBe('ack');
+    expect(ack.version).toBe(1);
+
+    // Verify via REST
+    const res = await request(app.app).get(`/api/documents/${created.body.id}`).expect(200);
+    expect(res.body.content).toBe('hello world');
+    expect(res.body.version).toBe(1);
+
+    ws.close();
+  });
+
+  it('broadcasts operations to other clients', async () => {
+    const created = await request(app.app)
+      .post('/api/documents')
+      .send({ title: 'WS Doc', content: 'hello' });
+
+    const ws1 = await connectWs(created.body.id);
+    await waitForMessage(ws1); // sync
+
+    const ws2 = await connectWs(created.body.id);
+    await waitForMessage(ws2); // sync
+
+    const broadcastPromise = waitForMessage(ws2);
+    sendOp(ws1, { type: 'insert', position: 5, text: '!' }, 0);
+    await waitForMessage(ws1); // ack
+
+    const broadcast = await broadcastPromise;
+    expect(broadcast.type).toBe('operation');
+    expect(broadcast.version).toBe(1);
+
+    ws1.close();
+    ws2.close();
+  });
+
+  it('handles concurrent edits with OT', async () => {
+    const created = await request(app.app)
+      .post('/api/documents')
+      .send({ title: 'OT Doc', content: 'hello' });
+
+    const ws1 = await connectWs(created.body.id);
+    await waitForMessage(ws1); // sync
+
+    const ws2 = await connectWs(created.body.id);
+    await waitForMessage(ws2); // sync
+
+    // Both clients send operations based on version 0
+    // Client 1 inserts 'A' at position 0
+    // Client 2 inserts 'B' at position 5
+    sendOp(ws1, { type: 'insert', position: 0, text: 'A' }, 0);
+    const ack1 = await waitForMessage(ws1);
+    expect(ack1.type).toBe('ack');
+    expect(ack1.version).toBe(1);
+
+    // ws2 gets broadcast of client1's op
+    const broadcast1 = await waitForMessage(ws2);
+    expect(broadcast1.type).toBe('operation');
+
+    // Client 2 sends its operation - it was based on version 0, but server is now at 1
+    // The server should transform it
+    sendOp(ws2, { type: 'insert', position: 5, text: 'B' }, 0);
+    const ack2 = await waitForMessage(ws2);
+    expect(ack2.type).toBe('ack');
+    expect(ack2.version).toBe(2);
+
+    // Verify the final document via REST
+    const res = await request(app.app).get(`/api/documents/${created.body.id}`).expect(200);
+    // 'hello' -> 'Ahello' (insert A at 0) -> 'AhelloB' (insert B at 6, transformed from 5+1)
+    expect(res.body.content).toBe('AhelloB');
+    expect(res.body.content).toContain('A');
+    expect(res.body.content).toContain('B');
+
+    ws1.close();
+    ws2.close();
+  });
+
+  it('handles delete operations', async () => {
+    const created = await request(app.app)
+      .post('/api/documents')
+      .send({ title: 'Del Doc', content: 'hello world' });
+
+    const ws = await connectWs(created.body.id);
+    await waitForMessage(ws); // sync
+
+    sendOp(ws, { type: 'delete', position: 5, count: 6 }, 0);
+    const ack = await waitForMessage(ws);
+    expect(ack.type).toBe('ack');
+
+    const res = await request(app.app).get(`/api/documents/${created.body.id}`).expect(200);
+    expect(res.body.content).toBe('hello');
+
+    ws.close();
+  });
+
+  it('rejects invalid operations', async () => {
+    const created = await request(app.app)
+      .post('/api/documents')
+      .send({ title: 'Invalid Doc', content: '' });
+
+    const ws = await connectWs(created.body.id);
+    await waitForMessage(ws); // sync
+
+    ws.send(JSON.stringify({ type: 'operation', operation: { type: 'invalid' }, version: 0 }));
+    const err = await waitForMessage(ws);
+    expect(err.type).toBe('error');
+
+    ws.close();
+  });
+
+  it('rejects invalid JSON', async () => {
+    const created = await request(app.app)
+      .post('/api/documents')
+      .send({ title: 'JSON Doc', content: '' });
+
+    const ws = await connectWs(created.body.id);
+    await waitForMessage(ws); // sync
+
+    ws.send('not json{{{');
+    const err = await waitForMessage(ws);
+    expect(err.type).toBe('error');
+
+    ws.close();
+  });
+
+  it('version history is populated after operations', async () => {
+    const created = await request(app.app)
+      .post('/api/documents')
+      .send({ title: 'History Doc', content: '' });
+
+    const ws = await connectWs(created.body.id);
+    await waitForMessage(ws); // sync
+
+    sendOp(ws, { type: 'insert', position: 0, text: 'hello' }, 0);
+    await waitForMessage(ws); // ack
+
+    sendOp(ws, { type: 'insert', position: 5, text: ' world' }, 1);
+    await waitForMessage(ws); // ack
+
+    const res = await request(app.app)
+      .get(`/api/documents/${created.body.id}/versions`)
+      .expect(200);
+    expect(res.body.length).toBe(2);
+    expect(res.body[0].version).toBe(1);
+    expect(res.body[1].version).toBe(2);
+    expect(res.body[1].content_after).toBe('hello world');
+
+    ws.close();
+  });
+});
+
+describe('Concurrent clients stress test', () => {
+  beforeEach(async () => {
+    app = createApp();
+    port = await app.start(0);
+  });
+
+  afterEach(async () => {
+    await app.stop();
+  });
+
+  it('handles 10 concurrent clients without corruption', async () => {
+    const created = await request(app.app)
+      .post('/api/documents')
+      .send({ title: 'Stress Doc', content: '' });
+
+    const docId = created.body.id;
+    const clientCount = 10;
+    const clients: WebSocket[] = [];
+
+    // Connect all clients
+    for (let i = 0; i < clientCount; i++) {
+      const ws = await connectWs(docId);
+      await waitForMessage(ws); // sync
+      clients.push(ws);
+    }
+
+    // Each client sends one insert operation, all based on version 0
+    // They each insert their index character at position 0
+    const ackPromises: Promise<Record<string, unknown>>[] = [];
+    for (let i = 0; i < clientCount; i++) {
+      // Drain any broadcast messages and find the ack
+      const ackPromise = new Promise<Record<string, unknown>>((resolve) => {
+        const handler = (data: WebSocket.Data) => {
+          const msg = JSON.parse(data.toString());
+          if (msg.type === 'ack') {
+            clients[i].off('message', handler);
+            resolve(msg);
+          }
+        };
+        clients[i].on('message', handler);
+      });
+      ackPromises.push(ackPromise);
+      sendOp(clients[i], { type: 'insert', position: 0, text: String(i) }, 0);
+    }
+
+    // Wait for all acks
+    const acks = await Promise.all(ackPromises);
+    for (const ack of acks) {
+      expect(ack.type).toBe('ack');
+      expect(typeof ack.version).toBe('number');
+    }
+
+    // Wait a bit for all broadcasts to settle
+    await new Promise((resolve) => setTimeout(resolve, 200));
+
+    // Verify document via REST
+    const res = await request(app.app).get(`/api/documents/${docId}`).expect(200);
+    expect(res.body.version).toBe(clientCount);
+    expect(res.body.content.length).toBe(clientCount);
+
+    // Every digit 0-9 should be present
+    for (let i = 0; i < clientCount; i++) {
+      expect(res.body.content).toContain(String(i));
+    }
+
+    // Close all clients
+    for (const ws of clients) {
+      ws.close();
+    }
+  });
+});
+
+describe('Persistence', () => {
+  it('documents survive server restart', async () => {
+    const fs = await import('fs');
+    const os = await import('os');
+    const path = await import('path');
+    const dbPath = path.join(os.tmpdir(), `collab-test-${Date.now()}.db`);
+
+    try {
+      // Start first instance
+      const app1 = createApp(dbPath);
+      const port1 = await app1.start(0);
+
+      const created = await request(app1.app)
+        .post('/api/documents')
+        .send({ title: 'Persistent', content: 'survive' });
+
+      const docId = created.body.id;
+
+      // Make an edit via WS
+      const ws = new WebSocket(`ws://localhost:${port1}/ws/documents/${docId}`);
+      await new Promise<void>((resolve) => ws.on('open', () => resolve()));
+      await waitForMessage(ws); // sync
+
+      sendOp(ws, { type: 'insert', position: 7, text: '!' }, 0);
+      await waitForMessage(ws); // ack
+      ws.close();
+
+      await app1.stop();
+
+      // Start second instance with same database
+      const app2 = createApp(dbPath);
+      await app2.start(0);
+
+      const res = await request(app2.app).get(`/api/documents/${docId}`).expect(200);
+      expect(res.body.content).toBe('survive!');
+      expect(res.body.version).toBe(1);
+
+      // Check version history persisted
+      const versions = await request(app2.app)
+        .get(`/api/documents/${docId}/versions`)
+        .expect(200);
+      expect(versions.body.length).toBe(1);
+
+      await app2.stop();
+    } finally {
+      try {
+        fs.unlinkSync(dbPath);
+        fs.unlinkSync(dbPath + '-wal');
+        fs.unlinkSync(dbPath + '-shm');
+      } catch {
+        // ignore cleanup errors
+      }
+    }
+  });
+});
