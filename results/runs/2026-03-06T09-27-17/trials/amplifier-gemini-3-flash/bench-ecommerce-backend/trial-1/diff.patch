@@ -0,0 +1,48 @@
+import { EventBus } from '../bus.js';
+import { PaymentService, PaymentStatus, Events, PaymentProcessedEvent } from '../types.js';
+
+export interface PaymentOptions {
+  simulation?: 'success' | 'failure' | 'timeout';
+  timeoutMs?: number;
+}
+
+export function createPaymentService(bus: EventBus, options: PaymentOptions = {}): PaymentService {
+  const successfulTransactions = new Set<string>();
+
+  return {
+    async processPayment(orderId: string, _amount: number): Promise<{ status: PaymentStatus; transactionId?: string; error?: string }> {
+      const simulation = options.simulation || 'success';
+      const timeoutMs = options.timeoutMs || 100;
+
+      let result: { status: PaymentStatus; transactionId?: string; error?: string };
+
+      if (simulation === 'timeout') {
+        await new Promise((resolve) => setTimeout(resolve, timeoutMs));
+        result = { status: PaymentStatus.TIMEOUT, error: 'Payment timed out' };
+      } else if (simulation === 'failure') {
+        result = { status: PaymentStatus.FAILED, error: 'Payment failed' };
+      } else {
+        const transactionId = `txn_${Math.random().toString(36).substring(7)}`;
+        successfulTransactions.add(transactionId);
+        result = { status: PaymentStatus.SUCCESS, transactionId };
+      }
+
+      bus.emit(Events.PAYMENT_PROCESSED, {
+        orderId,
+        status: result.status,
+        transactionId: result.transactionId,
+        error: result.error,
+      } as PaymentProcessedEvent);
+
+      return result;
+    },
+
+    async refund(transactionId: string): Promise<boolean> {
+      if (successfulTransactions.has(transactionId)) {
+        successfulTransactions.delete(transactionId);
+        return true;
+      }
+      return false;
+    },
+  };
+}
