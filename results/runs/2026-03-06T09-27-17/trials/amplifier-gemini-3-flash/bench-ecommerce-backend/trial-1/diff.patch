diff --git a/src/analytics/index.ts b/src/analytics/index.ts
new file mode 100644
index 0000000..9614ba1
--- /dev/null
+++ b/src/analytics/index.ts
@@ -0,0 +1,89 @@
+import { EventBus } from '../bus.js';
+import {
+  AnalyticsService,
+  Events,
+  PaymentProcessedEvent,
+  PaymentStatus,
+  OrderCreatedEvent,
+  CartUpdatedEvent,
+  AnalyticsEvent,
+} from '../types.js';
+
+export function createAnalyticsService(bus: EventBus): AnalyticsService {
+  const eventCounts = new Map<string, number>();
+  let totalRevenue = 0;
+  const uniqueCarts = new Set<string>();
+  let totalOrders = 0;
+  const productOrderQuantities = new Map<string, number>();
+  const orderTotals = new Map<string, number>();
+  const cartItems = new Map<string, Array<{ productId: string; quantity: number }>>();
+
+  const trackAnalytics = (event: string, data: Record<string, unknown>) => {
+    bus.emit(Events.ANALYTICS_EVENT, {
+      event,
+      data,
+      timestamp: Date.now(),
+    } as AnalyticsEvent);
+  };
+
+  // Increment event counts for all events
+  const allEvents = Object.values(Events);
+  for (const eventName of allEvents) {
+    const name = eventName as string;
+    bus.on(name, () => {
+      eventCounts.set(name, (eventCounts.get(name) || 0) + 1);
+    });
+  }
+
+  bus.on(Events.CART_UPDATED, (payload: unknown) => {
+    const event = payload as CartUpdatedEvent;
+    uniqueCarts.add(event.cartId);
+    cartItems.set(event.cartId, event.items);
+    trackAnalytics(Events.CART_UPDATED, { cartId: event.cartId, userId: event.userId });
+  });
+
+  bus.on(Events.ORDER_CREATED, (payload: unknown) => {
+    const event = payload as OrderCreatedEvent;
+    totalOrders++;
+    orderTotals.set(event.orderId, event.total);
+    
+    const items = cartItems.get(event.cartId) || [];
+    for (const item of items) {
+      const current = productOrderQuantities.get(item.productId) || 0;
+      productOrderQuantities.set(item.productId, current + item.quantity);
+    }
+    
+    trackAnalytics(Events.ORDER_CREATED, { orderId: event.orderId, userId: event.userId });
+  });
+
+  bus.on(Events.PAYMENT_PROCESSED, (payload: unknown) => {
+    const event = payload as PaymentProcessedEvent;
+    if (event.status === PaymentStatus.SUCCESS) {
+      const amount = orderTotals.get(event.orderId) || 0;
+      totalRevenue += amount;
+    }
+    trackAnalytics(Events.PAYMENT_PROCESSED, { orderId: event.orderId, status: event.status });
+  });
+
+  return {
+    getEventCount(eventType: string): number {
+      return eventCounts.get(eventType) || 0;
+    },
+
+    getRevenue(): number {
+      return totalRevenue;
+    },
+
+    getConversionRate(): number {
+      if (uniqueCarts.size === 0) return 0;
+      return totalOrders / uniqueCarts.size;
+    },
+
+    getTopProducts(limit: number) {
+      return Array.from(productOrderQuantities.entries())
+        .map(([productId, count]) => ({ productId, count }))
+        .sort((a, b) => b.count - a.count)
+        .slice(0, limit);
+    },
+  };
+}
diff --git a/src/cart/index.ts b/src/cart/index.ts
new file mode 100644
index 0000000..696cdc7
--- /dev/null
+++ b/src/cart/index.ts
@@ -0,0 +1,74 @@
+import { EventBus } from '../bus.js';
+import { CartService, Events, CartUpdatedEvent } from '../types.js';
+
+export function createCartService(bus: EventBus): CartService {
+  const carts = new Map<string, { id: string; userId: string; items: Array<{ productId: string; quantity: number }> }>();
+
+  const emitCartUpdated = (cartId: string) => {
+    const cart = carts.get(cartId);
+    if (cart) {
+      bus.emit(Events.CART_UPDATED, {
+        cartId,
+        userId: cart.userId,
+        items: [...cart.items],
+      } as CartUpdatedEvent);
+    }
+  };
+
+  return {
+    createCart(userId: string): string {
+      const cartId = Math.random().toString(36).substring(7);
+      carts.set(cartId, { id: cartId, userId, items: [] });
+      emitCartUpdated(cartId);
+      return cartId;
+    },
+
+    addItem(cartId: string, productId: string, quantity: number): void {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+
+      const existingItem = cart.items.find((item) => item.productId === productId);
+      if (existingItem) {
+        existingItem.quantity += quantity;
+      } else {
+        cart.items.push({ productId, quantity });
+      }
+      emitCartUpdated(cartId);
+    },
+
+    removeItem(cartId: string, productId: string): void {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+
+      cart.items = cart.items.filter((item) => item.productId !== productId);
+      emitCartUpdated(cartId);
+    },
+
+    getCart(cartId: string) {
+      const cart = carts.get(cartId);
+      return cart ? { ...cart, items: [...cart.items] } : null;
+    },
+
+    clearCart(cartId: string): void {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+
+      cart.items = [];
+      emitCartUpdated(cartId);
+    },
+
+    updateQuantity(cartId: string, productId: string, quantity: number): void {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+
+      const item = cart.items.find((i) => i.productId === productId);
+      if (item) {
+        item.quantity = quantity;
+        if (item.quantity <= 0) {
+          cart.items = cart.items.filter((i) => i.productId !== productId);
+        }
+        emitCartUpdated(cartId);
+      }
+    },
+  };
+}
