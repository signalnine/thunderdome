+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WMmbvkptYNcgFFQW8ybruS","type":"tool_result","content":"diff --git a/src/index.test.ts b/src/index.test.ts\nnew file mode 100644\nindex 0000000..8d8842c\n--- /dev/null\n+++ b/src/index.test.ts\n@@ -0,0 +1,333 @@\n+import { describe, test, expect } from 'vitest';\n+import { simulate, findSwappedWires } from './index.js';\n+import type { Gate } from './index.js';\n+\n+describe('simulate', () => {\n+  test('evaluates a single AND gate', () => {\n+    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n+    const inputs = { a: 1, b: 1 };\n+    const result = simulate(gates, inputs);\n+    expect(result.c).toBe(1);\n+    expect(result.a).toBe(1);\n+    expect(result.b).toBe(1);\n+  });\n+\n+  test('AND gate with one zero input produces zero', () => {\n+    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n+    const result = simulate(gates, { a: 1, b: 0 });\n+    expect(result.c).toBe(0);\n+  });\n+\n+  test('evaluates a single OR gate', () => {\n+    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];\n+    const result = simulate(gates, { a: 0, b: 1 });\n+    expect(result.c).toBe(1);\n+  });\n+\n+  test('OR gate with both zero produces zero', () => {\n+    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];\n+    const result = simulate(gates, { a: 0, b: 0 });\n+    expect(result.c).toBe(0);\n+  });\n+\n+  test('evaluates a single XOR gate', () => {\n+    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n+    expect(simulate(gates, { a: 1, b: 0 }).c).toBe(1);\n+    expect(simulate(gates, { a: 1, b: 1 }).c).toBe(0);\n+    expect(simulate(gates, { a: 0, b: 0 }).c).toBe(0);\n+  });\n+\n+  test('handles chained gates in dependency order', () => {\n+    // a AND b -> c, then c OR d -> e\n+    const gates: Gate[] = [\n+      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },  // depends on c, listed first\n+      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n+    ];\n+    const result = simulate(gates, { a: 1, b: 1, d: 0 });\n+    expect(result.c).toBe(1);\n+    expect(result.e).toBe(1);\n+  });\n+\n+  test('simulates a 2-bit adder (0+0=0)', () => {\n+    // Bit 0: half adder\n+    // Bit 1: full adder\n+    // Bit 2: carry out\n+    const gates: Gate[] = [\n+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },\n+    ];\n+    const result = simulate(gates, { x00: 0, y00: 0, x01: 0, y01: 0 });\n+    expect(result.z00).toBe(0);\n+    expect(result.z01).toBe(0);\n+    expect(result.z02).toBe(0);\n+  });\n+\n+  test('simulates a 2-bit adder (3+1=4, i.e. 11+01=100)', () => {\n+    const gates: Gate[] = [\n+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },\n+    ];\n+    // x = 11 (binary) = 3, y = 01 (binary) = 1\n+    const result = simulate(gates, { x00: 1, y00: 1, x01: 1, y01: 0 });\n+    // 3 + 1 = 4 = 100 binary\n+    expect(result.z00).toBe(0);\n+    expect(result.z01).toBe(0);\n+    expect(result.z02).toBe(1);\n+  });\n+\n+  test('returns all wire values including intermediates', () => {\n+    const gates: Gate[] = [\n+      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n+      { op: 'XOR', in1: 'c', in2: 'd', out: 'e' },\n+    ];\n+    const result = simulate(gates, { a: 1, b: 1, d: 0 });\n+    expect(Object.keys(result).sort()).toEqual(['a', 'b', 'c', 'd', 'e']);\n+    expect(result.c).toBe(1);\n+    expect(result.e).toBe(1);\n+  });\n+});\n+\n+// Helper: build a correct N-bit ripple-carry adder circuit\n+function buildAdder(bits: number): Gate[] {\n+  const gates: Gate[] = [];\n+  // Bit 0: half adder\n+  gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });\n+  gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });\n+\n+  for (let i = 1; i < bits; i++) {\n+    const nn = String(i).padStart(2, '0');\n+    const prev = String(i - 1).padStart(2, '0');\n+    gates.push({ op: 'XOR', in1: `x${nn}`, in2: `y${nn}`, out: `t${nn}` });\n+    gates.push({ op: 'XOR', in1: `t${nn}`, in2: `c${prev}`, out: `z${nn}` });\n+    gates.push({ op: 'AND', in1: `x${nn}`, in2: `y${nn}`, out: `a${nn}` });\n+    gates.push({ op: 'AND', in1: `t${nn}`, in2: `c${prev}`, out: `b${nn}` });\n+    gates.push({ op: 'OR', in1: `a${nn}`, in2: `b${nn}`, out: `c${nn}` });\n+  }\n+\n+  // Final carry becomes MSB\n+  const lastCarry = `c${String(bits - 1).padStart(2, '0')}`;\n+  const zMSB = `z${String(bits).padStart(2, '0')}`;\n+  // Rename last carry gate's output to be zMSB\n+  const lastGate = gates[gates.length - 1];\n+  if (lastGate.out === lastCarry) {\n+    lastGate.out = zMSB;\n+  }\n+\n+  return gates;\n+}\n+\n+// Helper: swap the outputs of two gates\n+function swapOutputs(gates: Gate[], out1: string, out2: string): Gate[] {\n+  return gates.map(g => {\n+    if (g.out === out1) return { ...g, out: out2 };\n+    if (g.out === out2) return { ...g, out: out1 };\n+    return g;\n+  });\n+}\n+\n+// Helper: verify adder correctness with simulate\n+function verifyAdder(gates: Gate[], bits: number, x: number, y: number): boolean {\n+  const inputs: Record<string, number> = {};\n+  for (let i = 0; i < bits; i++) {\n+    const nn = String(i).padStart(2, '0');\n+    inputs[`x${nn}`] = (x >> i) & 1;\n+    inputs[`y${nn}`] = (y >> i) & 1;\n+  }\n+  const result = simulate(gates, inputs);\n+  const expected = x + y;\n+  for (let i = 0; i <= bits; i++) {\n+    const nn = String(i).padStart(2, '0');\n+    if ((result[`z${nn}`] ?? 0) !== ((expected >> i) & 1)) return false;\n+  }\n+  return true;\n+}\n+\n+describe('findSwappedWires', () => {\n+  test('finds swapped wires in a 4-bit adder with 4 swaps', () => {\n+    let gates = buildAdder(4);\n+    // Swap 1: z01 and a01\n+    gates = swapOutputs(gates, 'z01', 'a01');\n+    // Swap 2: t02 and b02\n+    gates = swapOutputs(gates, 't02', 'b02');\n+    // Swap 3: z03 and z04 (z output with final carry output)\n+    gates = swapOutputs(gates, 'z03', 'z04');\n+    // Swap 4: c02 and a03 (carry with generate)\n+    gates = swapOutputs(gates, 'c02', 'a03');\n+\n+    const result = findSwappedWires(gates);\n+    expect(result).toEqual(['a01', 'a03', 'b02', 'c02', 't02', 'z01', 'z03', 'z04'].sort());\n+  });\n+\n+  test('returns results sorted alphabetically', () => {\n+    let gates = buildAdder(8);\n+    // 4 swaps in an 8-bit adder\n+    gates = swapOutputs(gates, 'z01', 'a01');\n+    gates = swapOutputs(gates, 'z03', 'c03');\n+    gates = swapOutputs(gates, 't05', 'b05');\n+    gates = swapOutputs(gates, 'z07', 'a07');\n+\n+    const result = findSwappedWires(gates);\n+    expect(result).toEqual([...result].sort());\n+    expect(result.length).toBe(8);\n+    expect(result).toEqual(['a01', 'a07', 'b05', 'c03', 't05', 'z01', 'z03', 'z07'].sort());\n+  });\n+\n+  test('handles a 45-bit adder with swaps', () => {\n+    let gates = buildAdder(45);\n+    // 4 swaps spread across the adder\n+    gates = swapOutputs(gates, 'z10', 'a10');\n+    gates = swapOutputs(gates, 't20', 'c20');\n+    gates = swapOutputs(gates, 'z30', 'b30');\n+    gates = swapOutputs(gates, 'z44', 'a44');\n+\n+    const result = findSwappedWires(gates);\n+    expect(result.length).toBe(8);\n+    expect(result).toEqual(['a10', 'a44', 'b30', 'c20', 't20', 'z10', 'z30', 'z44'].sort());\n+  });\n+\n+  test('handles swaps involving z00 (half adder)', () => {\n+    let gates = buildAdder(8);\n+    // Swap z00 with something else - swap the XOR output with the AND output at bit 0\n+    gates = swapOutputs(gates, 'z00', 'c00');\n+    // Need 3 more swaps\n+    gates = swapOutputs(gates, 'z02', 'a02');\n+    gates = swapOutputs(gates, 't04', 'b04');\n+    gates = swapOutputs(gates, 'z06', 'c06');\n+\n+    const result = findSwappedWires(gates);\n+    expect(result.length).toBe(8);\n+    expect(result).toEqual(['a02', 'b04', 'c00', 'c06', 't04', 'z00', 'z02', 'z06'].sort());\n+  });\n+\n+  test('handles carry-as-z-wire swap (OR output is z-wire)', () => {\n+    let gates = buildAdder(8);\n+    // Swap carry output with a z-wire at a different bit\n+    // c03 (carry from bit 3) swapped with z05 (sum at bit 5)\n+    gates = swapOutputs(gates, 'c03', 'z05');\n+    // 3 more swaps\n+    gates = swapOutputs(gates, 'z01', 'a01');\n+    gates = swapOutputs(gates, 't06', 'b06');\n+    gates = swapOutputs(gates, 'z07', 'a07');\n+\n+    const result = findSwappedWires(gates);\n+    expect(result.length).toBe(8);\n+    expect(result).toEqual(['a01', 'a07', 'b06', 'c03', 't06', 'z01', 'z05', 'z07'].sort());\n+  });\n+\n+  test('handles swap where generate and propagate are mixed', () => {\n+    let gates = buildAdder(10);\n+    // Swap generate with carry\n+    gates = swapOutputs(gates, 'a05', 'c04');\n+    // Swap z-output with partial sum\n+    gates = swapOutputs(gates, 'z03', 't03');\n+    // Swap propagate with z-output\n+    gates = swapOutputs(gates, 'b08', 'z08');\n+    // Swap two non-adjacent wires\n+    gates = swapOutputs(gates, 'z01', 'c01');\n+\n+    const result = findSwappedWires(gates);\n+    expect(result.length).toBe(8);\n+    expect(result).toEqual(['a05', 'b08', 'c01', 'c04', 't03', 'z01', 'z03', 'z08'].sort());\n+  });\n+\n+  test('works with randomized internal wire names', () => {\n+    // Build a 6-bit adder with random internal wire names\n+    const gates: Gate[] =