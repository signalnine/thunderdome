+    expect(result).toEqual(['bbc', 'dde', 'def', 'ffg', 'mno', 'stu', 'z01', 'z04'].sort());
+  });
+
+  test('handles swap involving zFinal (MSB output)', () => {
+    let gates = buildAdder(6);
+    // zFinal for 6-bit adder is z06
+    // Swap z06 with something
+    gates = swapOutputs(gates, 'z06', 'a05');
+    // 3 more swaps
+    gates = swapOutputs(gates, 'z01', 't01');
+    gates = swapOutputs(gates, 'z03', 'b03');
+    gates = swapOutputs(gates, 'c04', 'a04');
+
+    const result = findSwappedWires(gates);
+    expect(result.length).toBe(8);
+    expect(result).toEqual(['a04', 'a05', 'b03', 'c04', 't01', 'z01', 'z03', 'z06'].sort());
+  });
+
+  test('a correct adder with swaps no longer adds correctly', () => {
+    let gates = buildAdder(4);
