) {\n      doSwap(xorTC.out, zN);\n    }\n\n    // Step 3: Find AND(xNN, yNN) -> generate\n    const andXY = findGateByInputs('AND', xN, yN);\n    if (!andXY) continue;\n    const generate = andXY.out;\n\n    // Step 4: Find AND(partialSum, carry) -> propagate\n    const andTC = findGateByInputs('AND', partialSum, carry);\n    if (!andTC) continue;\n    const propagate = andTC.out;\n\n    // Step 5: Find OR(generate, propagate) -> carry out\n    let orGate = findGateByInputs('OR', generate, propagate);\n\n    if (!orGate) {\n      // One of generate or propagate is swapped\n      const orWithGen = findGateByOpAndOneInput('OR', generate);\n      if (orWithGen) {\n        const other = orWithGen.in1 === generate ? orWithGen.in2 : orWithGen.in1;\n        doSwap(propagate, other);\n        orGate = orWithGen;\n      } else {\n        const orWithProp = findGateByOpAndOneInput('OR', propagate);\n        if (orWithProp) {\n          const other = orWithProp.in1 === propagate ? orWithProp.in2 : orWithProp.in1;\n          doSwap(generate, other);\n          orGate = orWithProp;\n        }\n      }\n    }\n\n    if (!orGate) continue;\n    carry = orGate.out;\n\n    // Carry should not be a z-wire unless it's the final output\n    if (carry.startsWith('z') && carry !== zFinal) {\n      // OR gate output is a z-wire — it's swapped with the real carry.\n      // Find the partner: we don't know the real carry name, but we know\n      // that whoever currently outputs carry's z-name should output the carry.\n      // Actually let's just swap it with whatever should be in zN's position.\n      // We'll detect and fix this: the z-wire shouldn't be a carry output.\n      // The other side of this swap will be detected at the bit that z-wire\n      // corresponds to. But we need to fix carry now.\n      // For now, just record the swap. The real carry name... we need to\n      // find it. The gate that SHOULD output this z-wire is some XOR gate\n      // at that bit. That XOR gate currently outputs something else — the\n      // real carry name. We haven't processed that bit yet.\n      // Let's look: if carry = zMM, find XOR(xMM, yMM) — no, that gives\n      // the partial sum, not the final sum.\n      // The gate that should output zMM is the \"partialSum XOR carryIn -> zMM\" gate.\n      // We haven't identified that gate yet.\n      // Simplest: doSwap(carry, ???). We need to find the partner.\n      // Let's try: OR output shouldn't be z-wire. Search the current outputs\n      // for a non-z wire that should be the carry. We don't know the name.\n      // Alternative: just proceed. The next iteration will detect the issue\n      // when it can't find things. Actually no — carry is wrong, so everything breaks.\n      //\n      // Better approach: this z-wire carry is DEFINITELY swapped. Let's note it\n      // and try to find the pair by looking at what the XOR gate for that z-bit outputs.\n      // Actually I don't want to look ahead. Let me just try all OR gates and find\n      // a reasonable carry.\n      // Hmm, let me try a different tactic entirely for this case.\n    }\n  }\n\n  return [...swapped].sort();\n}","originalFile":"export interface Gate {\n  op: 'AND' | 'OR' | 'XOR';\n  in1: string;\n  in2: string;\n  out: string;\n}\n\nexport function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number> {\n  const wires: Record<string, number> = { ...inputs };\n  const remaining = new Set(gates.map((_, i) => i));\n\n  let progress = true;\n  while (remaining.size > 0 && progress) {\n    progress = false;\n    for (const i of remaining) {\n      const g = gates[i];\n      if (wires[g.in1] !== undefined && wires[g.in2] !== undefined) {\n        const a = wires[g.in1];\n        const b = wires[g.in2];\n        if (g.op === 'AND') wires[g.out] = a & b;\n        else if (g.op === 'OR') wires[g.out] = a | b;\n        else wires[g.out] = a ^ b;\n        remaining.delete(i);\n        progress = true;\n      }\n    }\n  }\n\n  return wires;\n}\n\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Work on a mutable copy so we can fix swaps as we find them\n  const mGates = gates.map(g => ({ ...g }));\n\n  // Build lookup maps\n  function rebuildMaps() {\n    const byOut = new Map<string, Gate>();\n    for (const g of mGates) byOut.set(g.out, g);\n    return byOut;\n  }\n\n  function findGate(op: Gate['op'], a: string, b: string): Gate | undefined {\n    for (const g of mGates) {\n      if (g.op === op && ((g.in1 === a && g.in2 === b) || (g.in1 === b && g.in2 === a))) {\n        return g;\n      }\n    }\n    return undefined;\n  }\n\n  // Determine number of input bits\n  let numBits = 0;\n  for (const g of mGates) {\n    for (const w of [g.in1, g.in2, g.out]) {\n      const m = w.match(/^x(\\d+)$/);\n      if (m) numBits = Math.max(numBits, parseInt(m[1]) + 1);\n    }\n  }\n\n  const swapped = new Set<string>();\n\n  function doSwap(a: string, b: string) {\n    swapped.add(a);\n    swapped.add(b);\n    // Fix the gates so subsequent analysis uses corrected wires\n    for (const g of mGates) {\n      if (g.out === a) g.out = b;\n      else if (g.out === b) g.out = a;\n    }\n  }\n\n  let carry = '';\n\n  // Bit 0: half adder\n  //   x00 XOR y00 -> z00\n  //   x00 AND y00 -> carry\n  {\n    const xorGate = findGate('XOR', 'x00', 'y00');\n    const andGate = findGate('AND', 'x00', 'y00');\n    if (!xorGate || !andGate) return [];\n\n    if (xorGate.out !== 'z00') {\n      doSwap(xorGate.out, 'z00');\n    }\n    // After potential swap, andGate.out is the carry\n    carry = andGate.out;\n    // carry should not be z00 (if it is, we already fixed xorGate)\n    if (carry === 'z00') {\n      // andGate output was swapped to be z00, which means original was swapped\n      // This shouldn't happen because we already swapped xorGate to z00\n      // But just in case:\n      carry = andGate.out;\n    }\n  }\n\n  // Bits 1..numBits-1: full adders\n  for (let i = 1; i < numBit