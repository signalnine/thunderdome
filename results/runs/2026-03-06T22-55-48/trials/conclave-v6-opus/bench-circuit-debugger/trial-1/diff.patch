+    gates.push({ op: 'AND', in1: 'x01', in2: 'y01', out: 'def' });
+    gates.push({ op: 'AND', in1: 'abc', in2: 'qrs', out: 'ghi' });
+    gates.push({ op: 'OR', in1: 'def', in2: 'ghi', out: 'jkl' });
