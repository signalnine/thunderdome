53→  let numBits = 0;\n    54→  for (const g of mGates) {\n    55→    for (const w of [g.in1, g.in2, g.out]) {\n    56→      const m = w.match(/^x(\\d+)$/);\n    57→      if (m) numBits = Math.max(numBits, parseInt(m[1]) + 1);\n    58→    }\n    59→  }\n    60→\n    61→  const swapped = new Set<string>();\n    62→\n    63→  function doSwap(a: string, b: string) {\n    64→    swapped.add(a);\n    65→    swapped.add(b);\n    66→    // Fix the gates so subsequent analysis uses corrected wires\n    67→    for (const g of mGates) {\n    68→      if (g.out === a) g.out = b;\n    69→      else if (g.out === b) g.out = a;\n    70→    }\n    71→  }\n    72→\n    73→  let carry = '';\n    74→\n    75→  // Bit 0: half adder\n    76→  //   x00 XOR y00 -> z00\n    77→  //   x00 AND y00 -> carry\n    78→  {\n    79→    const xorGate = findGate('XOR', 'x00', 'y00');\n    80→    const andGate = findGate('AND', 'x00', 'y00');\n    81→    if (!xorGate || !andGate) return [];\n    82→\n    83→    if (xorGate.out !== 'z00') {\n    84→      doSwap(xorGate.out, 'z00');\n    85→    }\n    86→    // After potential swap, andGate.out is the carry\n    87→    carry = andGate.out;\n    88→    // carry should not be z00 (if it is, we already fixed xorGate)\n    89→    if (carry === 'z00') {\n    90→      // andGate output was swapped to be z00, which means original was swapped\n    91→      // This shouldn't happen because we already swapped xorGate to z00\n    92→      // But just in case:\n    93→      carry = andGate.out;\n    94→    }\n    95→  }\n    96→\n    97→  // Bits 1..numBits-1: full adders\n    98→  for (let i = 1; i < numBits; i++) {\n    99→    const nn = String(i).padStart(2, '0');\n   100→    const xN = `x${nn}`;\n   101→    const yN = `y${nn}`;\n   102→    const zN = `z${nn}`;\n   103→    const zFinal = `z${String(numBits).padStart(2, '0')}`;\n   104→\n   105→    // Step 1: xNN XOR yNN -> partialSum\n   106→    const xorXY = findGate('XOR', xN, yN);\n   107→    if (!xorXY) co