n1: 'jjk', in2: 'kkl', out: 'z06' }); // last carry = z06\n+\n+    // Verify it works as an adder first\n+    const inputs: Record<string, number> = {};\n+    for (let b = 0; b < 6; b++) {\n+      const nn = String(b).padStart(2, '0');\n+      inputs[`x${nn}`] = b % 2;\n+      inputs[`y${nn}`] = (b + 1) % 2;\n+    }\n+    const r = simulate(gates, inputs);\n+    // x = 010101 = 21, y = 101010 = 42, sum = 63 = 111111\n+    expect(r.z00).toBe(1);\n+    expect(r.z05).toBe(1);\n+    expect(r.z06).toBe(0);\n+\n+    // Now swap 4 pairs and find them\n+    let swappedGates = swapOutputs(gates, 'z01', 'def');\n+    swappedGates = swapOutputs(swappedGates, 'mno', 'stu');\n+    swappedGates = swapOutputs(swappedGates, 'z04', 'ffg');\n+    swappedGates = swapOutputs(swappedGates, 'dde', 'bbc');\n+\n+    const result = findSwappedWires(swappedGates);\n+    expect(result.length).toBe(8);\n+    expect(result).toEqual(['bbc', 'dde', 'def', 'ffg', 'mno', 'stu', 'z01', 'z04'].sort());\n+  });\n+\n+  test('handles swap involving zFinal (MSB output)', () => {\n+    let gates = buildAdder(6);\n+    // zFinal for 6-bit adder is z06\n+    // Swap z06 with something\n+    gates = swapOutputs(gates, 'z06', 'a05');\n+    // 3 more swaps\n+    gates = swapOutputs(gates, 'z01', 't01');\n+    gates = swapOutputs(gates, 'z03', 'b03');\n+    gates = swapOutputs(gates, 'c04', 'a04');\n+\n+    const result = findSwappedWires(gates);\n+    expect(result.length).toBe(8);\n+    expect(result).toEqual(['a04', 'a05', 'b03', 'c04', 't01', 'z01', 'z03', 'z06'].sort());\n+  });\n+\n+  test('a correct adder with swaps no longer adds correctly', () => {\n+    let gates = buildAdder(4);\n+    // Verify correct adder works\n+    expect(verifyAdder(gates, 4, 7, 8)).toBe(true);\n+\n+    // Apply swaps\n+    gates = swapOutputs(gates, 'z01', 'a01');\n+    gates = swapOutputs(gates, 't02', 'b02');\n+    gates = swapOutputs(gates, 'z03', 'z04');\n+    gates = swapOutputs(gates, 'c02', 'a03');\n+\n+    // Swapped adder should not add correctly for most inputs\n+    expect(verifyAdder(gates, 4, 7, 8)).toBe(false);\n+  });\n+});\ndiff --git a/src/index.ts b/src/index.ts\nnew file mode 100644\nindex 0000000..8fa6de5\n--- /dev/null\n+++ b/src/index.ts\n@@ -0,0 +1,160 @@\n+export interface Gate {\n+  op: 'AND' | 'OR' | 'XOR';\n+  in1: string;\n+  in2: string;\n+  out: string;\n+}\n+\n+export function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number> {\n+  const wires: Record<string, number> = { ...inputs };\n+  const remaining = new Set(gates.map((_, i) => i));\n+\n+  let progress = true;\n+  while (remaining.size > 0 && progress) {\n+    progress = false;\n+    for (const i of remaining) {\n+      const g = gates[i];\n+      if (wires[g.in1] !== undefined && wires[g.in2] !== undefined) {\n+        const a = wires[g.in1];\n+        const b = wires[g.in2];\n+        if (g.op === 'AND') wires[g.out] = a & b;\n+        else if (g.op === 'OR') wires[g.out] = a | b;\n+        else wires[g.out] = a ^ b;\n+        remaining.delete(i);\n+        progress = true;\n+      }\n+    }\n+  }\n+\n+  return wires;\n+}\n+\n+export function findSwappedWires(gates: Gate[]): string[] {\n+  // Trace the expected ripple-carry adder structure bit by bit.\n+  // When a structural violation is found, identify and fix the swap pair\n+  // so subsequent bits can be traced correctly.\n+  const mGates = gates.map(g => ({ ...g }));\n+\n+  function findGate(op: Gate['op'], a: string, b: string): Gate | undefined {\n+    for (const g of mGates) {\n+      if (g.op === op && ((g.in1 === a && g.in2 === b) || (g.in1 === b && g.in2 === a))) {\n+        return g;\n+      }\n+    }\n+    return undefined;\n+  }\n+\n+  function findGateWithInput(op: Gate['op'], input: string, exclude?: Gate): Gate | undefined {\n+    for (const g of mGates) {\n+      if (g === exclude) continue;\n+      if (g.op === op && (g.in1 === input || g.in2 === input)) return g;\n+    }\n+    return undefined;\n+  }\n+\n+  let numBits = 0;\n+  for (const g of mGates) {\n+    for (const w of [g.in1, g.in2, g.out]) {\n+      const m = w.match(/^x(\\d+)$/);\n+      if (m) numBits = Math.max(numBits, parseInt(m[1]) + 1);\n+    }\n+  }\n+\n+  const swapped = new Set<string>();\n+\n+  function doSwap(a: string, b: string) {\n+    swapped.add(a);\n+    swapped.add(b);\n+    for (const g of mGates) {\n+      if (g.out === a) g.out = b;\n+      else if (g.out === b) g.out = a;\n+    }\n+  }\n+\n+  // Bit 0: half adder — XOR(x00,y00)->z00, AND(x00,y00)->carry\n+  const xor0 = findGate('XOR', 'x00', 'y00');\n+  const and0 = findGate('AND', 'x00', 'y00');\n+  if (!xor0 || !and0) return [];\n+\n+  if (xor0.out !== 'z00') {\n+    doSwap(xor0.out, 'z00');\n+  }\n+  let carry = and0.out;\n+\n+  // Bits 1..N-1: full adders\n+  for (let i = 1; i < numBits; i++) {\n+    const nn = String(i).padStart(2, '0');\n+    const xN = `x${nn}`;\n+    const yN = `y${nn}`;\n+    const zN = `z${nn}`;\n+\n+    // 1. XOR(xNN, yNN) -> partialSum\n+    const xorXY = findGate('XOR', xN, yN);\n+    if (!xorXY) continue;\n+    let partialSum = xorXY.out;\n+\n+    // 2. XOR(partialSum, carry) -> zNN\n+    let xorSum = findGate('XOR', partialSum, carry);\n+\n+    if (!xorSum) {\n+      // Try finding XOR that uses carry — partialSum may be swapped\n+      const xorC = findGateWithInput('XOR', carry, xorXY);\n+      if (xorC) {\n+        const other = xorC.in1 === carry ? xorC.in2 : xorC.in1;\n+        doSwap(partialSum, other);\n+        partialSum = xorXY.out;\n+        xorSum = xorC;\n+      } else {\n+        // Try finding XOR that uses partialSum — carry may be swapped\n+        const xorP = findGateWithInput('XOR', partialSum, xorXY);\n+        if (xorP) {\n+          const other = xorP.in1 === partialSum ? xorP.in2 : xorP.in1;\n+          doSwap(carry, other);\n+          carry = other;\n+          xorSum = xorP;\n+        }\n+      }\n+    }\n+\n+    if (!xorSum) continue;\n+\n+    // Validate output is zNN\n+    if (xorSum.out !== zN) {\n+      doSwap(xorSum.out, zN);\n+    }\n+\n+    // 3. AND(xNN, yNN) -> generate\n+    const andXY = findGate('AND', xN, yN);\n+    if (!andXY) continue;\n+    const generate = andXY.out;\n+\n+    // 4. AND(partialSum, carry) -> propagate\n+    const andPC = findGate('AND', partialSum, carry);\n+    if (!andPC) continue;\n+    const propagate = andPC.out;\n+\n+    // 5. OR(generate, propagate) -> carry out\n+    let orGate = findGate('OR', generate, propagate);\n+\n+    if (!orGate) {\n+      const orG = findGateWithInput('OR', generate);\n+      if (orG) {\n+        const other = orG.in1 === generate ? orG.in2 : orG.in1;\n+        doSwap(propagate, other);\n+        orGate = orG;\n+      } else {\n+        const orP = findGateWithInput('OR', propagate);\n+        if (orP) {\n+          const other = orP.in1 === propagate ? orP.in2 : orP.in1;\n+          doSwap(generate, other);\n+          orGate = orP;\n+        }\n+      }\n+    }\n+\n+    if (!orGate) continue;\n+    carry = orGate.out;\n+  }\n+\n+  return [...swapped].sort();\n+}","is_error":false}]},"parent_tool_use_id":null,"session_id":"7c284f5c-1084-480d-b94d-36372ff2426d","uuid":"d478d17f-dd52-459b-b061-17b94d32244b","tool_use_result":{"stdout":"diff --git a/src/index.test.ts b/src/index.test.ts\nnew file mode 100644\nindex 0000000..8d8842c\n--- /dev/null\n+++ b/src/index.test.ts\n@@ -0,0 +1,333 @@\n+import { describe, test, expect } from 'vitest';\n+import { simulate, findSwappedWires } from './index.js';\n+import type { Gate } from './index.js';\n+\n+describe('simulate', () => {\n+  test('evaluates a single AND gate', () => {\n+    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n+    const inputs = { a: 1, b: 1 };\n+    const result = simulate(gates, inputs);\n+    expect(result.c).toBe(1);\n+    expect(result.a).toBe(1);\n+    expect(result.b).toBe(1);\n+  });\n+\n+  test('AND gate with one zero input produces zero', () => {\n+    const gates: Gate[] = 