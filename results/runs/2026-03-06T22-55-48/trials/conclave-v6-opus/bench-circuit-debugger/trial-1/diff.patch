ropagate);\n\n    if (!orGate) {\n      // One of generate or propagate was swapped with something\n      // Find the OR gate that uses at least one of them\n      let found = false;\n      for (const g of mGates) {\n        if (g.op !== 'OR') continue;\n        if (g.in1 === generate || g.in2 === generate) {\n          const other = g.in1 === generate ? g.in2 : g.in1;\n          doSwap(propagate, other);\n          orGate = g;\n          found = true;\n          break;\n        }\n        if (g.in1 === propagate || g.in2 === propagate) {\n          const other = g.in1 === propagate ? g.in2 : g.in1;\n          doSwap(generate, other);\n          orGate = g;\n          found = true;\n          break;\n        }\n      }\n      if (!found) continue;\n    }\n\n    if (!orGate) continue;\n    carry = orGate.out;\n\n    // Carry should not be a z-wire (unless it's the final output zNN+1)\n    if (carry.startsWith('z') && carry !== zFinal) {\n      // The OR gate's output is a z-wire when it shouldn't be\n      // Find what wire should be here: the gate that currently outputs what\n      // we expect the carry to be named. But we don't know the name.\n      // Instead: the z-wire that carry points to means this carry wire was\n      // swapped with some other wire. We need to find what gate should have\n      // produced the z-wire output.\n      // Actually: carry = z## means the OR gate output was swapped with some\n      // other wire. The \"other wire\" is whatever should be the carry.\n      // Since we can't know the carry name, let's find: which gate was supposed\n      // to output carry (i.e., which z-output gate has the wrong output)?\n      // The XOR gate for the z## bit should output z##, but currently some other\n      // gate outputs z##. The real carry name is what that other gate should output.\n      //\n      // Simpler approach: find which non-OR gate currently outputs carry's z-value\n      // No wait — carry IS the z-wire name. So the OR gate outputs