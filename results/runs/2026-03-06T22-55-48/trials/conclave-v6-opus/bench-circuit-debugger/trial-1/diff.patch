n   197→  // - The gate that output 'a' now outputs 'b'\n   198→  // - The gate that output 'b' now outputs 'a'\n   199→  // - Gates that have in1='a' or in2='a' still reference 'a'\n   200→  //   (which now comes from a different gate)\n   201→  // - This is correct! Because in the original (correct) circuit,\n   202→  //   those gates should read from wire 'a'. doSwap restores the\n   203→  //   correct gate to output 'a', so inputs reading 'a' now get\n   204→  //   the right value.\n   205→  //\n   206→  // So doSwap IS correct — it fixes the output names, and since inputs\n   207→  // reference output names, the graph is restored to correct.\n   208→\n   209→  // Let me re-derive carry after the swap.\n   210→  // After doSwap(xor0.out, 'z00') if needed:\n   211→  // - xor0 now outputs 'z00' (correct)\n   212→  // - and0 now outputs whatever it had (if it was 'z00', it got swapped to xor0's old output)\n   213→  let carry = and0.out;\n   214→\n   215→  const zFinal = `z${String(numBits).padStart(2, '0')}`;\n   216→\n   217→  for (let i = 1; i < numBits; i++) {\n   218→    const nn = String(i).padStart(2, '0');\n   219→    const xN = `x${nn}`;\n   220→    const yN = `y${nn}`;\n   221→    const zN = `z${nn}`;\n   222→\n   223→    // Step 1: Find XOR(xNN, yNN) -> partialSum\n   224→    const xorXY = findGateByInputs('XOR', xN, yN);\n   225→    if (!xorXY) continue;\n   226→    let partialSum = xorXY.out;\n   227→\n   228→    // Step 2: Find XOR(partialSum, carry) -> should be zNN\n   229→    let xorTC = findGateByInputs('XOR', partialSum, carry);\n   230→\n   231→    if (!xorTC) {\n   232→      // Either partialSum or carry output name is wrong.\n   233→      // Fallback: find a XOR gate that uses carry as one input\n   234→      const xorWithCarry = findGateByOpAndOneInput('XOR', carry, xorXY);\n   235→      if (xorWithCarry) {\n   236→        // The other input should be partialSum but isn't\n   237→        const otherInput = xorWithCarry.in1 === carry ? xorWith