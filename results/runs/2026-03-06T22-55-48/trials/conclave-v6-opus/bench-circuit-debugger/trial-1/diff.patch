y: number): boolean {\n  const inputs: Record<string, number> = {};\n  for (let i = 0; i < bits; i++) {\n    const nn = String(i).padStart(2, '0');\n    inputs[`x${nn}`] = (x >> i) & 1;\n    inputs[`y${nn}`] = (y >> i) & 1;\n  }\n  const result = simulate(gates, inputs);\n  const expected = x + y;\n  for (let i = 0; i <= bits; i++) {\n    const nn = String(i).padStart(2, '0');\n    if ((result[`z${nn}`] ?? 0) !== ((expected >> i) & 1)) return false;\n  }\n  return true;\n}\n\ndescribe('findSwappedWires', () => {\n  test('finds swapped wires in a 4-bit adder with 4 swaps', () => {\n    let gates = buildAdder(4);\n    // Swap 1: z01 and a01\n    gates = swapOutputs(gates, 'z01', 'a01');\n    // Swap 2: t02 and b02\n    gates = swapOutputs(gates, 't02', 'b02');\n    // Swap 3: z03 and c03\n    gates = swapOutputs(gates, 'z03', 'z04');\n    // Swap 4: a03 and b03\n    gates = swapOutputs(gates, 'a03', 'b03');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a01', 'a03', 'b02', 'b03', 't02', 'z01', 'z03', 'z04'].sort());\n  });\n\n  test('returns results sorted alphabetically', () => {\n    let gates = buildAdder(8);\n    // 4 swaps in an 8-bit adder\n    gates = swapOutputs(gates, 'z01', 'a01');\n    gates = swapOutputs(gates, 'z03', 'c03');\n    gates = swapOutputs(gates, 't05', 'b05');\n    gates = swapOutputs(gates, 'z07', 'a07');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual([...result].sort());\n    expect(result.length).toBe(8);\n    expect(result).toEqual(['a01', 'a07', 'b05', 'c03', 't05', 'z01', 'z03', 'z07'].sort());\n  });\n\n  test('handles a 45-bit adder with swaps', () => {\n    let gates = buildAdder(45);\n    // 4 swaps spread across the adder\n    gates = swapOutputs(gates, 'z10', 'a10');\n    gates = swapOutputs(gates, 't20', 'c20');\n    gates = swapOutputs(gates, 'z30', 'b30');\n    gates = swapOutputs(gates, 'z44', 'a44');\n\n    const result = findSwappedWires(gates);\n    expect(result.lengt