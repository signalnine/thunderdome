toggle and counter puzzle solvers.\n *\n * Both puzzles reduce to solving a system of linear equations over a finite\n * field: GF(2) for toggles, GF(p) for counters. We use Gaussian elimination\n * with back-substitution, enumerating free variables to find the solution\n * with minimum cost (fewest presses) and lexicographic tie-breaking.\n */\n\n// ──────────────────────────────────────────────────────────────────────────\n// Part 1 — Toggle puzzle  (GF(2))\n// ──────────────────────────────────────────────────────────────────────────\n\nexport interface Machine {\n  target: boolean[];\n  buttons: number[][];\n}\n\n/**\n * Solve a toggle puzzle over GF(2).\n *\n * We build the augmented matrix  A|b  where A[i][j] = 1 iff button j\n * toggles light i, and b[i] = target[i].  Then Gaussian-eliminate and\n * enumerate free-variable assignments to minimise the number of presses,\n * breaking ties lexicographically.\n */\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const nLights = target.length;\n  const nButtons = buttons.length;\n\n  // Build augmented matrix (nLights rows × (nButtons+1) cols) over GF(2).\n  // Rows = lights, columns = buttons + 1 augmented column.\n  // A[light][button] = 1 if button toggles that light.\n  const mat: number[][] = [];\n  for (let i = 0; i < nLights; i++) {\n    const row = new Array<number>(nButtons + 1).fill(0);\n    row[nButtons] = target[i] ? 1 : 0;\n    mat.push(row);\n  }\n  for (let j = 0; j < nButtons; j++) {\n    for (const light of buttons[j]) {\n      mat[light][j] = 1;\n    }\n  }\n\n  // Gaussian elimination over GF(2).\n  // pivotCol[r] = column index of the pivot in row r, or -1.\n  const pivotCol: number[] = new Array(nLights).fill(-1);\n  // pivotRow[c] = row containing the pivot for column c, or -1.\n  const pivotRow: number[] = new Array(nButtons).fill(-1);\n\n  let curRow = 0;\n  for (let col = 0; col < nButtons && curRow < nLights; col++) {\n    // Find a pivot row.\n    let pr = -1;\n    for (let r = curRow; r < nLights; r++) {\n      if (mat[r][col]) {\n        pr = r;\n        break;\n      }\n    }\n    if (pr === -1) continue; // free variable\n\n    // Swap rows.\n    [mat[curRow], mat[pr]] = [mat[pr], mat[curRow]];\n    pivotCol[curRow] = col;\n    pivotRow[col] = curRow;\n\n    // Eliminate other rows.\n    for (let r = 0; r < nLights; r++) {\n      if (r !== curRow && mat[r][col]) {\n        for (let c = col; c <= nButtons; c++) {\n          mat[r][c] ^= mat[curRow][c];\n        }\n      }\n    }\n    curRow++;\n  }\n\n  const rank = curRow;\n\n  // Check consistency: any row with all-zero coefficients but nonzero RHS.\n  for (let r = rank; r < nLights; r++) {\n    if (mat[r][nButtons]) return null;\n  }\n\n  // Identify free variables (columns without a pivot).\n  const freeVars: number[] = [];\n  for (let c = 0; c < nButtons; c++) {\n    if (pivotRow[c] === -1) freeVars.push(c);\n  }\n\n  const numFree = freeVars.length;\n\n  // Enumerate all 2^numFree assignments of free variables.\n  // For each assignment, back-substitute to determine pivot variables.\n  // Track the solution with minimum presses, then lex smallest.\n  let bestSol: number[] | null = null;\n  let bestCount = nButtons + 1;\n\n  const totalAssignments = 1 << numFree;\n\n  for (let mask = 0; mask < totalAssignments; mask++) {\n    const sol = new Array<number>(nButtons).fill(0);\n\n    // Assign free variables.\n    for (let f = 0; f < numFree; f++) {\n      sol[freeVars[f]] = (mask >> f) & 1;\n    }\n\n    // Back-substitute for pivot variables.\n    for (let r = rank - 1; r >= 0; r--) {\n      const pc = pivotCol[r];\n      let val = mat[r][nButtons];\n      for (let c = pc + 1; c < nButtons; c++) {\n        val ^= mat[r][c] & sol[c];\n      }\n      sol[pc] = val;\n    }\n\n    // Count presses.\n    let count = 0;\n    for (let c = 0; c < nButtons; c++) count += sol[c];\n\n    if (count < bestCount || (count === bestCount && solIndicesLexSmaller(sol, bestSol!, nButtons))) {\n      bestCount = count;\n      bestSol = sol.slice();\n    }\n  }\n\n  // Build result: indices of pressed buttons, sorted ascending.\n  const result: number[] = [];\n  for (let i = 0; i < nButtons; i++) {\n    if (bestSol![i]) result.push(i);\n  }\n  return result;\n}\n\n/**\n * Compare two solution vectors by their resulting index sets (lex order).\n * For toggle: index set = sorted list of indices where sol[i] = 1.\n * Lex comparison on index sets: compare first differing element.\n * Equivalent to: the solution whose first pressed-button index is smaller wins;\n * if tied, compare next, etc. If one is a prefix of the other, shorter wins.\n * But since counts are equal, lengths are equal.\n */\nfunction solIndicesLexSmaller(a: number[], b: number[], n: number): boolean {\n  // Walk through indices; at each index where they differ,\n  // if a has 1 and b has 0, a's set includes this index but b's doesn't at this position.\n  // For lex comparison of sorted index sets:\n  // - Build both sets and compare element by element.\n  const aSet: number[] = [];\n  const bSet: number[] = [];\n  for (let i = 0; i < n; i++) {\n    if (a[i]) aSet.push(i);\n    if (b[i]) bSet.push(i);\n  }\n  for (let i = 0; i < aSet.length; i++) {\n    if (aSet[i] < bSet[i]) return true;\n    if (aSet[i] > bSet[i]) return false;\n  }\n  return false;\n}\n\n/** Compare two arrays lexicographically (returns true if a < b). */\nfunction lexSmaller(a: number[], b: number[]): boolean {\n  for (let i = 0; i < a.length; i++) {\n    if (a[i] < b[i]) return true;\n    if (a[i] > b[i]) return false;\n  }\n  return false;\n}\n\n// ──────────────────────────────────────────────────────────────────────────\n// Part 2 — Counter puzzle  (GF(p))\n// ──────────────────────────────────────────────────────────────────────────\n\n/**\n * Modular inverse using extended Euclidean algorithm.\n * Requires gcd(a, mod) = 1 (guaranteed when mod is prime and a != 0).\n */\nfunction modInverse(a: number, mod: number): number {\n  a = ((a % mod) + mod) % mod;\n  let [old_r, r] = [a, mod];\n  let [old_s, s] = [1, 0];\n  while (r !== 0) {\n    const q = Math.floor(old_r / r);\n    [old_r, r] = [r, old_r - q * r];\n    [old_s, s] = [s, old_s - q * s];\n  }\n  return ((old_s % mod) + mod) % mod;\n}\n\n/**\n * Solve a counter puzzle over GF(p).\n *\n * Same Gaussian elimination approach as the toggle puzzle, but arithmetic\n * is mod p instead of mod 2.  Free variables are enumerated over 0..p-1,\n * optimising for minimum total presses then lexicographic order.\n */\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number,\n): number[] | null {\n  const nLights = lights.length;\n  const nButtons = buttons.length;\n  const p = modulus;\n\n  // Build augmented matrix over GF(p).\n  const mat: number[][] = [];\n  for (let i = 0; i < nLights; i++) {\n    const row = new Array<number>(nButtons + 1).fill(0);\n    row[nButtons] = lights[i] % p;\n    mat.push(row);\n  }\n  for (let j = 0; j < nButtons; j++) {\n    for (const counter of buttons[j]) {\n      mat[counter][j] = (mat[counter][j] + 1) % p;\n    }\n  }\n\n  // Gaussian elimination over GF(p).\n  const pivotCol: number[] = new Array(nLights).fill(-1);\n  const pivotRow: number[] = new Array(nButtons).fill(-1);\n\n  let curRow = 0;\n  for (let col = 0; col < nButtons && curRow < nLights; col++) {\n    // Find pivot.\n    let pr = -1;\n    for (let r = curRow; r < nLights; r++) {\n      if (mat[r][col] !== 0) {\n        pr = r;\n        break;\n      }\n    }\n    if (pr === -1) continue;\n\n    // Swap.\n    [mat[curRow], mat[pr]] = [mat[pr], mat[curRow]];\n    pivotCol[curRow] = col;\n    pivotRow[col] = curRow;\n\n    // Scale pivot row so that leading entry = 1.\n    const inv = modInverse(mat[curRow][col], p);\n    for (let c = col; c <= nButtons; c++) {\n      mat[curRow][c] = (mat[curRow][c] * inv) % p;\n    }\n\n    // Eliminate other rows.\n    for (let r = 0; r < nLights; r++) {\n      if (r !== curRow && mat[r][col] !== 0) {\n        const factor = mat[r][col];\n        for (let c = col; c <= nButtons; c++) {\n          mat[r][c] = (mat[r][c] - factor * mat[curRow][c] % p + p * p) % p;\n        }\n      }\n    }\n    curRow++;\n  }\n\n  const rank = curRow;\n\n  // Consistency check.\n  for (let r = rank; r < nLights; r++) {\n    if (mat[r][nButtons] !== 0) return null;\n  }\n\n  // Identify free variables.\n  const freeVars: number[] = [];\n  for (let c = 0; c < nButtons; c++) {\n    if (pivotRow[c] === -1) freeVars.push(c);\n  }\n\n  const numFree = freeVars.length;\n\n  // For the toggle case (p=2) with up to 40 free vars, enumeration is up to 2^40 which is\n  // too large. But for the counter puzzle p can be up to 97, so we need a different approach\n  // when numFree is large. However, with 40 buttons and 40 lights, rank is at most 40,\n  // so numFree can be up to 40. We can't enumerate p^40 combinations.\n  //\n  // Strategy: When numFree is small (say ≤ 20 for p=2, or total combinations ≤ ~1M),\n  // enumerate directly. Otherwise, for each free variable independently, we can try\n  // to determine the optimal value greedily since the pivot variables are determined\n  // by the free variables linearly.\n  //\n  // For minimum total presses: sum = sum_of_free_vars + sum_of_pivot_vars.\n  // Each pivot var is a linear function of the free vars mod p:\n  //   x_{pivot_r} = b_r - sum_{free f} A[r][f] * x_f   (mod p)\n  // Total cost = sum_f x_f + sum_r (b_r - sum_f A[r][f] * x_f) mod p.\n  //\n  // This is hard to optimise globally since mod makes it nonlinear.\n  // We'll enumerate when feasible, otherwise use a heuristic for each free var.\n\n  const totalCombinations = Math.pow(p, numFree);\n\n  if (totalCombinations <= 2_000_000 && numFree <= 25) {\n    // Enumerate all combinations of free variables.\n    return enumerateFreeVars(mat, pivotCol, pivotRow, freeVars, rank, nButtons, p);\n  } else {\n    // Too many combinations; use greedy approach per free variable.\n    return greedyFreeVars(mat, pivotCol, pivotRow, freeVars, rank, nButtons, p);\n  }\n}\n\nfunction enumerateFreeVars(\n  mat: number[][],\n  pivotCol: number[],\n  pivotRow: number[],\n  freeVars: number[],\n  rank: number,\n  nButtons: number,\n  p: number,\n): number[] | null {\n  const numFree = freeVars.length;\n  const totalCombinations = Math.pow(p, numFree);\n\n  let bestSol: number[] | null = null;\n  let bestSum = Infinity;\n\n  // Use mixed-radix counter for free variable values.\n  const freeVals = new Array<number>(numFree).fill(0);\n\n  for (let iter = 0; iter < totalCombinations; iter++) {\n    const sol = new Array<number>(nButtons).fill(0);\n\n    // Assign free variables.\n    for (let f = 0; f < numFree; f++) {\n      sol[freeVars[f]] = freeVals[f];\n    }\n\n    // Back-substitute for pivot variables.\n    for (let r = rank - 1; r >= 0; r--) {\n      const pc = pivotCol[r];\n      let val = mat[r][nButtons];\n      for (let c = pc + 1; c < nButtons; c++) {\n        val = (val - mat[r][c] * sol[c] % p + p * p) % p;\n      }\n      sol[pc] = val;\n    }\n\n    // Compute total presses.\n    let total = 0;\n    for (let c = 0; c < nButtons; c++) total += sol[c];\n\n    if (total < bestSum || (total === bestSum && lexSmaller(sol, bestSol!))) {\n      bestSum = total;\n      bestSol = sol.slice();\n    }\n\n    // Increment mixed-radix counter.\n    for (let f = 0; f < numFree; f++) {\n      freeVals[f]++;\n      if (freeVals[f] < p) break;\n      freeVals[f] = 0;\n    }\n  }\n\n  return bestSol;\n}\n\nfunction greedyFreeVars(\n  mat: number[][],\n  pivotCol: number[],\n  pivotRow: number[],\n  freeVars: number[],\n  rank: number,\n  nButtons: number,\n  p: number,\n): number[] {\n  const numFree = freeVars.length;\n\n  // For each free variable, try all p values and pick the one that minimizes\n  // total cost, considering only the pivot variables that depend on it.\n  // This is a greedy approach — not guaranteed optimal for minimum total,\n  // but works well in practice for larger instances.\n\n  // Actually, let's be smarter. Each pivot variable r is:\n  //   x_{pc} = mat[r][nButtons] - sum_{c > pc} mat[r][c] * x_c  (mod p)\n  // The total cost = sum of all x_c.\n  // For each free variable f, changing its value affects the pivot variables\n  // that have nonzero mat[r][f]. We can try all p values per free variable\n  // independently (greedy per variable, left to right for lex order).\n\n  const sol = new Array<number>(nButtons).fill(0);\n\n  // Process free variables from left to right (for lex order).\n  // For each free variable, try all p values and pick the one minimising\n  // the partial cost contribution.\n  for (let fi = numFree - 1; fi >= 0; fi--) {\n    const fCol = freeVars[fi];\n    let bestVal = 0;\n    let bestCost = Infinity;\n\n    for (let v = 0; v < p; v++) {\n      sol[fCol] = v;\n\n      // Compute affected pivot variables and cost.\n      let cost = v; // cost of this free variable itself\n      for (let r = 0; r < rank; r++) {\n        if (mat[r][fCol] !== 0) {\n          const pc = pivotCol[r];\n          let val = mat[r][nButtons];\n          for (let c = pc + 1; c < nButtons; c++) {\n            val = (val - mat[r][c] * sol[c] % p + p * p) % p;\n          }\n          cost += val;\n        }\n      }\n\n      if (cost < bestCost) {\n        bestCost = cost;\n        bestVal = v;\n      }\n    }\n    sol[fCol] = bestVal;\n  }\n\n  // Final back-substitution.\n  for (let r = rank - 1; r >= 0; r--) {\n    const pc = pivotCol[r];\n    let val = mat[r][nButtons];\n    for (let c = pc + 1; c < nButtons; c++) {\n      val = (val - mat[r][c] * sol[c] % p + p * p) % p;\n    }\n    sol[pc] = val;\n  }\n\n  return sol;\n}\n"}}
