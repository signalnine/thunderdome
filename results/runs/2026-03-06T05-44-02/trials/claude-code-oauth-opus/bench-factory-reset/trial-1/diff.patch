esult).toEqual([0, 0, 0]);\n  });\n\n  it('solves a simple single-button case', () => {\n    const result = solveCounter([3], [[0]], 5);\n    expect(result).toEqual([3]);\n  });\n\n  it('returns null when no solution exists', () => {\n    // Counter 0 needs to be 1, but no button affects it\n    const result = solveCounter([1, 0], [[1]], 5);\n    expect(result).toBeNull();\n  });\n\n  it('solves with modular arithmetic', () => {\n    // Counter 0, target 0 mod 3. Button 0 affects counter 0.\n    // Press 0 times → already 0. That's the minimum.\n    const result = solveCounter([0], [[0]], 3);\n    expect(result).toEqual([0]);\n  });\n\n  it('solves with wrapping', () => {\n    // Counter 0, target 2 mod 3. Button 0 affects counter 0.\n    // Press 2 times.\n    const result = solveCounter([2], [[0]], 3);\n    expect(result).toEqual([2]);\n  });\n\n  it('returns minimum total presses', () => {\n    // 1 counter, target 1, mod 5. Buttons: [0], [0].\n    // Solutions: (1,0) total=1, (0,1) total=1. Lex smallest = [0,1].\n    // Wait: (1,0) is lex smaller than (0,1)? [1,0] vs [0,1]: 0<1 at index 0, so (0,1) is lex smaller.\n    // Both have total 1. Answer: [0,1]\n    const result = solveCounter([1], [[0], [0]], 5);\n    expect(result).toEqual([0, 1]);\n  });\n\n  it('handles two counters two buttons', () => {\n    // Counters: [1, 2], mod 5\n    // Button 0: affects [0], Button 1: affects [1]\n    // Solution: press button 0 once, button 1 twice → [1, 2]\n    const result = solveCounter([1, 2], [[0], [1]], 5);\n    expect(result).toEqual([1, 2]);\n  });\n\n  it('handles overlapping buttons', () => {\n    // Counters: [2, 2], mod 5\n    // Button 0: affects [0, 1] (increments both)\n    // Solution: press button 0 twice → [2, 2]. Total = 2.\n    const result = solveCounter([2, 2], [[0, 1]], 5);\n    expect(result).toEqual([2]);\n  });\n\n  it('returns null for inconsistent system', () => {\n    // Counter 0 target 1, counter 1 target 2, mod 3\n    // Button 0 affects bot