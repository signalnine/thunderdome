or each.","-  // For lex smallest with minimum cost, process from last to first","-  // (so earlier variables get lex preference).","+  // Process free variables from last to first for lex preference on earlier vars.","   for (let fi = numFree - 1; fi >= 0; fi--) {","     const fCol = freeVars[fi];","     let bestVal = 0;"]},{"oldStart":801,"oldLines":8,"newStart":469,"newLines":6,"lines":[" ","     for (let v = 0; v < p; v++) {","       sol[fCol] = v;","-","-      // Compute total cost contribution.","       let cost = v;","       for (let r = 0; r < rank; r++) {","         if (mat[r][fCol] !== 0) {"]},{"oldStart":814,"oldLines":7,"newStart":480,"newLines":6,"lines":["           cost += val;","         }","       }","-","       if (cost < bestCost || (cost === bestCost && v < bestVal)) {","         bestCost = cost;","         bestVal = v;"]}],"originalFile":"/**\n * Factory Reset — button-toggle and counter puzzle solvers.\n *\n * Both puzzles reduce to solving a system of linear equations over a finite\n * field: GF(2) for toggles, GF(p) for counters. We use Gaussian elimination\n * with back-substitution, enumerating free variables to find the solution\n * with minimum cost (fewest presses) and lexicographic tie-breaking.\n */\n\n// ──────────────────────────────────────────────────────────────────────────\n// Part 1 — Toggle puzzle  (GF(2))\n// ──────────────────────────────────────────────────────────────────────────\n\nexport interface Machine {\n  target: boolean[];\n  buttons: number[][];\n}\n\n/**\n * Solve a toggle puzzle over GF(2).\n *\n * We build the augmented matrix  A|b  where A[i][j] = 1 iff button j\n * toggles light i, and b[i] = target[i].  Then Gaussian-eliminate and\n * enumerate free-variable assignments to minimise the number of presses,\n * breaking ties lexicographically (on the resulting index set).\n *\n * For large numbers of free variables (>25), we use meet-in-the-middle.\n */\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const nLights = target.length;\n  const nButtons = buttons.length;\n\n  if (nButtons === 0) {\n    // No buttons: target must already be all-off.\n    return target.every(t => !t) ? [] : null;\n  }\n\n  // Build augmented matrix (nLights rows × (nButtons+1) cols) over GF(2).\n  const mat: number[][] = [];\n  for (let i = 0; i < nLights; i++) {\n    const row = new Array<number>(nButtons + 1).fill(0);\n    row[nButtons] = target[i] ? 1 : 0;\n    mat.push(row);\n  }\n  for (let j = 0; j < nButtons; j++) {\n    for (const light of buttons[j]) {\n      mat[light][j] = 1;\n    }\n  }\n\n  // Gaussian elimination over GF(2).\n  const pivotCol: number[] = new Array(nLights).fill(-1);\n  const pivotRow: number[] = new Array(nButtons).fill(-1);\n\n  let curRow = 0;\n  for (let col = 0; col < nButtons && curRow < nLights; col++) {\n    let pr = -1;\n    for (let r = curRow; r < nLights; r++) {\n      if (mat[r][col]) {\n        pr = r;\n        break;\n      }\n    }\n    if (pr === -1) continue;\n\n    [mat[curRow], mat[pr]] = [mat[pr], mat[curRow]];\n    pivotCol[curRow] = col;\n    pivotRow[col] = curRow;\n\n    for (let r = 0; r < nLights; r++) {\n      if (r !== curRow && mat[r][col]) {\n        for (let c = col; c <= nButtons; c++) {\n          mat[r][c] ^= mat[curRow][c];\n        }\n      }\n    }\n    curRow++;\n  }\n\n  const rank = curRow;\n\n  // Check consistency.\n  for (let r = rank; r < nLights; r++) {\n    if (mat[r][nButtons]) return null;\n  }\n\n  // Identify free variables.\n  const freeVars: number[] = [];\n  for (let c = 0; c < nButtons; c++) {\n    if (pivotRow[c] === -1) freeVars.push(c);\n  }\n\n  const numFree = freeVars.length;\n\n  let bestSol: number[] | null;\n\n  if (numFree <= 25) {\n    // Direct enumeration.\n    bestSol = enumerateToggleFree(mat, pivotCol, freeVars, rank, nButtons);\n  } else {\n    // Meet-in-the-middle.\n    bestSol = meetInMiddleToggle(mat, pivotCol, freeVars, rank, nButtons);\n  }\n\n  // Build result: indices of pressed buttons, sorted ascending.\n  const result: number[] = [];\n  for (let i = 0; i < nButtons; i++) {\n    if (bestSol![i]) result.push(i);\n  }\n  return result;\n}\n\nfunction enumerateToggleFree(\n  mat: number[][],\n  pivotCol: number[],\n  freeVars: number[],\n  rank: number,\n  nButtons: number,\n): number[] {\n  const numFree = freeVars.length;\n  const totalAssignments = 1 << numFree;\n\n  let bestSol: number[] | null = null;\n  let bestCount = nButtons + 1;\n\n  for (let mask = 0; mask < totalAssignments; mask++) {\n    const sol = buildToggleSolution(mat, pivotCol, freeVars, rank, nButtons, mask);\n\n    let count = 0;\n    for (let c = 0; c < nButtons; c++) count += sol[c];\n\n    if (count < bestCount || (count === bestCount && solIndicesLexSmaller(sol, bestSol!, nButtons))) {\n      bestCount = count;\n      bestSol = sol;\n    }\n  }\n\n  return bestSol!;\n}\n\nfunction buildToggleSolution(\n  mat: number[][],\n  pivotCol: number[],\n  freeVars: number[],\n  rank: number,\n  nButtons: number,\n  mask: number,\n): number[] {\n  const sol = new Array<number>(nButtons).fill(0);\n  const numFree = freeVars.length;\n\n  for (let f = 0; f < numFree; f++) {\n    sol[freeVars[f]] = (mask >> f) & 1;\n  }\n\n  for (let r = rank - 1; r >= 0; r--) {\n    const pc = pivotCol[r];\n    let val = mat[r][nButtons];\n    for (let c = pc + 1; c < nButtons; c++) {\n      val ^= mat[r][c] & sol[c];\n    }\n    sol[pc] = val;\n  }\n\n  return sol;\n}\n\n/**\n * Meet-in-the-middle for large numbers of free variables.\n *\n * Split free variables into two halves A and B. For each assignment of A,\n * compute the \"signature\" (effect on pivot variables) and store it.\n * Then for each assignment of B, compute what A's signature would need to be,\n * look it up, and find the best combined solution.\n *\n * The signature is: for each pivot row r, the XOR contribution of the\n * free variables to that row. The pivot variable value is:\n *   x_{pc} = mat[r][nButtons] XOR (contribution from other pivot vars)\n *            XOR (contribution from free vars in A) XOR (contribution from free vars in B)\n *\n * After RREF, pivot variables only depend on free variables (not other pivots):\n *   x_{pc_r} = mat[r][nButtons] XOR sum_{f in freeVars} mat[r][f] * x_f\n *\n * So for a given assignment of all free vars, the total cost is determined.\n * We split free vars into A (first half) and B (second half).\n * For a fixed B assignment, the contribution of A to each pivot is a linear\n * function of A's free var assignment. We can precompute for all A.\n *\n * Key: the total number of presses =\n *   popcount(A_free) + popcount(B_free)\n *   + sum_r popcount( mat[r][nButtons] XOR A_contrib[r] XOR B_contrib[r] )\n * where A_contrib[r] = XOR of mat[r][freeA[f]] * a_f, etc.\n *\n * But since each pivot variable is just 0 or 1, the \"popcount\" of a single bit\n * is the bit itself. So total presses = |A_free set| + |B_free set| + number of\n * pivot vars that are 1.\n *\n * Each pivot var = mat[r][nButtons] XOR A_contrib_r XOR B_contrib_r.\n * So pivot var = 1 iff A_contrib_r XOR B_contrib_r = mat[r][nButtons] XOR 1\n *     (no, pivot var value = mat[r][nButtons] XOR A_contrib_r XOR B_contrib_r).\n * Pivot var contributes 1 to cost when it equals 1.\n *\n * Total cost = popcount(maskA) + popcount(maskB) + number of r where\n *   base[r] XOR A_sig[r] XOR B_sig[r] = 1\n * = popcount(maskA) + popcount(maskB) + popcount(base XOR A_sig XOR B_sig)\n *\n * where base, A_sig, B_sig are bit vectors of length rank.\n *\n * So: cost = popcount(maskA) + popcount(maskB) + popcount(base XOR A_sig XOR B_sig)\n *          = popcount(maskA) + popcount(A_sig XOR combined)\n * where combined = base XOR B_sig, and the last term is popcount(A_sig XOR combined).\n * Wait, that's not right. Let me redo:\n *\n * cost = popcount(maskA) + popcount(maskB) + popcount(base XOR A_sig XOR B_sig)\n *\n * For a fixed B, combined = base XOR B_sig is fixed. So:\n * cost = popcount(maskB) + [popcount(maskA) + popcount(A_sig XOR combined)]\n *\n * We want to minimize this. For fixed B (and thus fixed combined and popcount(maskB)),\n * we want to minimize popcount(maskA) + popcount(A_sig XOR combined).\n *\n * If we precompute for all A values a map from A_sig → best (popcount(maskA), maskA),\n * then for each B we look up combined in the map.\n *\n * But that still gives popcount(maskA) + popcount(A_sig XOR combined), and the\n * second term depends on combined which varies per B. So the map entry for A_sig\n * gives us popcount(maskA) but we still need popcount(A_sig XOR combined).\n *\n * Actually for a fixed combined, the total A-contribution is:\n *   popcount(maskA) + popcount(A_sig XOR combined)\n * This depends on both maskA and the relationship between A_sig and combined.\n * We can't separate these easily.\n *\n * Alternative approach: encode each A assignment as (A_sig, popcount(maskA)),\n * group by A_sig, keep the best (smallest popcount, lex smallest maskA) per group.\n * Then for each B, compute combined = base XOR B_sig, and for each possible A_sig\n * in the map, cost = map[A_sig].popcount + popcount(maskB) + popcount(A_sig XOR combined).\n * We'd need to iterate all keys in the map, which could be up to 2^(numFree/2).\n * With numFree up to 40, half is 20, so 2^20 ≈ 1M entries. For each B (also 2^20),\n * iterating all 1M map entries gives 10^12 operations — too slow.\n *\n * Better: since A_sig is a bit vector of length rank (≤ 40), and combined is also\n * a rank-bit vector, we want to find the A_sig that minimizes\n *   map[A_sig].popcount + popcount(A_sig XOR combined).\n * This is still a search over all map entries.\n *\n * With rank ≤ 40 and numFree up to 40, the number of distinct A_sig values is\n * at most min(2^(numFree/2), 2^rank). With rank ≤ 40 and half ≤ 20,\n * there are at most 2^20 ≈ 1M distinct A_sig values.\n *\n * For each B (up to 2^20), we'd iterate up to 1M A_s