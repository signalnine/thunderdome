+/**
+ * Factory Reset — button-toggle and counter puzzle solvers.
+ *
+ * Both puzzles reduce to solving a system of linear equations over a finite
+ * field: GF(2) for toggles, GF(p) for counters. We use Gaussian elimination
+ * with back-substitution, enumerating free variables to find the solution
+ * with minimum cost (fewest presses) and lexicographic tie-breaking.
+ */
+
+// ──────────────────────────────────────────────────────────────────────────
+// Part 1 — Toggle puzzle  (GF(2))
+// ──────────────────────────────────────────────────────────────────────────
+
+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const nLights = target.length;
+  const nButtons = buttons.length;
+
+  if (nButtons === 0) {
+    return target.every(t => !t) ? [] : null;
+  }
+
+  // Build augmented matrix over GF(2): rows=lights, cols=buttons+1.
+  const mat: number[][] = [];
+  for (let i = 0; i < nLights; i++) {
+    const row = new Array<number>(nButtons + 1).fill(0);
+    row[nButtons] = target[i] ? 1 : 0;
+    mat.push(row);
+  }
+  for (let j = 0; j < nButtons; j++) {
+    for (const light of buttons[j]) {
+      mat[light][j] = 1;
+    }
+  }
+
+  // Gaussian elimination over GF(2).
+  const pivotCol: number[] = new Array(nLights).fill(-1);
+  const pivotRow: number[] = new Array(nButtons).fill(-1);
+
+  let curRow = 0;
+  for (let col = 0; col < nButtons && curRow < nLights; col++) {
+    let pr = -1;
+    for (let r = curRow; r < nLights; r++) {
+      if (mat[r][col]) { pr = r; break; }
+    }
+    if (pr === -1) continue;
+
+    [mat[curRow], mat[pr]] = [mat[pr], mat[curRow]];
+    pivotCol[curRow] = col;
+    pivotRow[col] = curRow;
+
+    for (let r = 0; r < nLights; r++) {
+      if (r !== curRow && mat[r][col]) {
+        for (let c = col; c <= nButtons; c++) mat[r][c] ^= mat[curRow][c];
+      }
+    }
+    curRow++;
+  }
+
+  const rank = curRow;
+
+  for (let r = rank; r < nLights; r++) {
+    if (mat[r][nButtons]) return null;
+  }
+
+  const freeVars: number[] = [];
+  for (let c = 0; c < nButtons; c++) {
+    if (pivotRow[c] === -1) freeVars.push(c);
+  }
+
+  const numFree = freeVars.length;
+  let bestSol: number[];
+
+  if (numFree <= 25) {
+    bestSol = enumerateToggleFree(mat, pivotCol, freeVars, rank, nButtons);
+  } else {
+    bestSol = meetInMiddleToggle(mat, pivotCol, freeVars, rank, nButtons);
+  }
+
+  const result: number[] = [];
+  for (let i = 0; i < nButtons; i++) {
+    if (bestSol[i]) result.push(i);
+  }
+  return result;
+}
+
+function enumerateToggleFree(
+  mat: number[][],
+  pivotCol: number[],
+  freeVars: number[],
+  rank: number,
+  nButtons: number,
+): number[] {
+  const numFree = freeVars.length;
+  const total = 1 << numFree;
+
+  let bestSol: number[] | null = null;
+  let bestCount = nButtons + 1;
+
+  for (let mask = 0; mask < total; mask++) {
+    const sol = solveFromFreeToggle(mat, pivotCol, freeVars, rank, nButtons, mask);
+    let count = 0;
+    for (let c = 0; c < nButtons; c++) count += sol[c];
+
+    if (count < bestCount || (count === bestCount && indexSetLexSmaller(sol, bestSol!, nButtons))) {
+      bestCount = count;
+      bestSol = sol;
+    }
+  }
+  return bestSol!;
+}
+
+function solveFromFreeToggle(
+  mat: number[][],
+  pivotCol: number[],
+  freeVars: number[],
+  rank: number,
+  nButtons: number,
+  mask: number,
+): number[] {
+  const sol = new Array<number>(nButtons).fill(0);
+  for (let f = 0; f < freeVars.length; f++) {
+    sol[freeVars[f]] = (mask >> f) & 1;
+  }
+  for (let r = rank - 1; r >= 0; r--) {
+    const pc = pivotCol[r];
+    let val = mat[r][nButtons];
+    for (let c = pc + 1; c < nButtons; c++) val ^= mat[r][c] & sol[c];
+    sol[pc] = val;
+  }
+  return sol;
+}
+
+/**
+ * Meet-in-the-middle for toggle puzzles with many free variables.
+ *
+ * When numFree > 25 and nButtons ≤ 40, rank ≤ 14. We split free vars
+ * into halves, precompute A-half signatures (rank-bit vectors encoding
+ * the XOR contribution to each pivot row), then for each B-half assignment
+ * find the best-matching A-half via a precomputed lookup table.
+ *
+ * Total cost = popcount(maskA) + popcount(maskB) + popcount(baseSig ^ aSig ^ bSig)
+ *
+ * For each B, we want: min over aSig of [aCostTable[aSig] + popcount((baseSig ^ bSig) ^ aSig)]
+ * We precompute this for all 2^rank possible target values.
+ */
+function meetInMiddleToggle(
+  mat: number[][],
+  pivotCol: number[],
+  freeVars: number[],
+  rank: number,
+  nButtons: number,
+): number[] {
+  const numFree = freeVars.length;
+  const halfA = Math.ceil(numFree / 2);
+  const halfB = numFree - halfA;
+  const freeA = freeVars.slice(0, halfA);
+  const freeB = freeVars.slice(halfA);
+
+  // Pack pivot-row base values into a bitmask.
+  let baseSig = 0;
+  for (let r = 0; r < rank; r++) {
+    if (mat[r][nButtons]) baseSig |= (1 << r);
+  }
+
+  // Coefficient bitmasks: for each free var, which pivot rows it contributes to.
+  const coeffA = freeA.map(col => {
+    let m = 0;
+    for (let r = 0; r < rank; r++) if (mat[r][col]) m |= (1 << r);
+    return m;
+  });
+  const coeffB = freeB.map(col => {
+    let m = 0;
+    for (let r = 0; r < rank; r++) if (mat[r][col]) m |= (1 << r);
+    return m;
+  });
+
+  const sigSpace = 1 << rank;
+
+  // Phase 1: enumerate A-half, store best (min cost, best mask) per signature.
+  const aCost = new Int32Array(sigSpace).fill(999);
+  const aMaskArr = new Int32Array(sigSpace);
+
+  const totalA = 1 << halfA;
+  for (let maskA = 0; maskA < totalA; maskA++) {
+    let sig = 0;
+    for (let f = 0; f < halfA; f++) {
+      if ((maskA >> f) & 1) sig ^= coeffA[f];
+    }
+    const cost = popcount(maskA);
+    if (cost < aCost[sig]) {
+      aCost[sig] = cost;
+      aMaskArr[sig] = maskA;
+    } else if (cost === aCost[sig] && maskA < aMaskArr[sig]) {
+      aMaskArr[sig] = maskA;
+    }
+  }
+
+  // Precompute: for each possible target signature t, the best aSig.
+  // bestForTarget[t] = argmin_{s} [ aCost[s] + popcount(t ^ s) ]
+  const bestCostForTarget = new Int32Array(sigSpace).fill(999);
+  const bestSigForTarget = new Int32Array(sigSpace);
+
+  for (let t = 0; t < sigSpace; t++) {
+    for (let s = 0; s < sigSpace; s++) {
+      if (aCost[s] >= 999) continue;
+      const c = aCost[s] + popcount(t ^ s);
+      if (c < bestCostForTarget[t]) {
+        bestCostForTarget[t] = c;
+        bestSigForTarget[t] = s;
+      }
+    }
+  }
+
+  // Phase 2: enumerate B-half, use lookup to find best A match.
+  let bestSol: number[] | null = null;
+  let bestTotal = nButtons + 1;
+
+  const totalB = 1 << halfB;
+  for (let maskB = 0; maskB < totalB; maskB++) {
+    let bSig = 0;
+    for (let f = 0; f < halfB; f++) {
+      if ((maskB >> f) & 1) bSig ^= coeffB[f];
+    }
+    const bCost = popcount(maskB);
+    const targetSig = baseSig ^ bSig;
+
+    const totalCost = bCost + bestCostForTarget[targetSig];
+    if (totalCost < bestTotal) {
+      bestTotal = totalCost;
+      bestSol = reconstructToggle(mat, pivotCol, freeA, freeB,
+        aMaskArr[bestSigForTarget[targetSig]], maskB, rank, nButtons);
+    } else if (totalCost === bestTotal) {
+      const candidate = reconstructToggle(mat, pivotCol, freeA, freeB,
+        aMaskArr[bestSigForTarget[targetSig]], maskB, rank, nButtons);
+      if (indexSetLexSmaller(candidate, bestSol!, nButtons)) {
+        bestSol = candidate;
+      }
+    }
+  }
+
+  return bestSol!;
+}
+
+function reconstructToggle(
+  mat: number[][],
+  pivotCol: number[],
+  freeA: number[],
+  freeB: number[],
+  maskA: number,
+  maskB: number,
+  rank: number,
+  nButtons: number,
+): number[] {
+  const sol = new Array<number>(nButtons).fill(0);
+  for (let f = 0; f < freeA.length; f++) sol[freeA[f]] = (maskA >> f) & 1;
+  for (let f = 0; f < freeB.length; f++) sol[freeB[f]] = (maskB >> f) & 1;
+  for (let r = rank - 1; r >= 0; r--) {
+    const pc = pivotCol[r];
+    let val = mat[r][nButtons];
+    for (let c = pc + 1; c < nButtons; c++) val ^= mat[r][c] & sol[c];
+    sol[pc] = val;
+  }
+  return sol;
+}
+
+function popcount(x: number): number {
+  x = x - ((x >> 1) & 0x55555555);
+  x = (x & 0x33333333) + ((x >> 2) & 0x33333333);
+  return (((x + (x >> 4)) & 0x0F0F0F0F) * 0x01010101) >> 24;
+}
+
+/** Compare two 0/1 solution vectors by their index sets in lex order. */
+function indexSetLexSmaller(a: number[], b: number[], n: number): boolean {
+  const aSet: number[] = [];
+  const bSet: number[] = [];
+  for (let i = 0; i < n; i++) {
+    if (a[i]) aSet.push(i);
+    if (b[i]) bSet.push(i);
+  }
+  const len = Math.min(aSet.length, bSet.length);
+  for (let i = 0; i < len; i++) {
+    if (aSet[i] < bSet[i]) return true;
+    if (aSet[i] > bSet[i]) return false;
+  }
+  return aSet.length < bSet.length;
+}
+
+/** Compare two arrays lexicographically (returns true if a < b). */
+function lexSmaller(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return false;
+}
+
+// ──────────────────────────────────────────────────────────────────────────
+// Part 2 — Counter puzzle  (GF(p))
+// ──────────────────────────────────────────────────────────────────────────
+
+function modInverse(a: number, mod: number): number {
+  a = ((a % mod) + mod) % mod;
+  let [old_r, r] = [a, mod];
+  let [old_s, s] = [1, 0];
+  while (r !== 0) {
+    const q = Math.floor(old_r / r);
+    [old_r, r] = [r, old_r - q * r];
+    [old_s, s] = [s, old_s - q * s];
+  }
+  return ((old_s % mod) + mod) % mod;
+}
+
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number,
+): number[] | null {
+  const nLights = lights.length;
+  const nButtons = buttons.length;
+  const p = modulus;
+
+  if (nButtons === 0) {
+    return lights.every(l => l === 0) ? [] : null;
+  }
+
+  // Build augmented matrix over GF(p).
+  const mat: number[][] = [];
+  for (let i = 0; i < nLights; i++) {
+    const row = new Array<number>(nButtons + 1).fill(0);
+    row[nButtons] = ((lights[i] % p) + p) % p;
+    mat.push(row);
+  }
+  for (let j = 0; j < nButtons; j++) {
+    for (const counter of buttons[j]) {
+      mat[counter][j] = (mat[counter][j] + 1) % p;
+    }
+  }
+
+  // Gaussian elimination over GF(p).
+  const pivotCol: number[] = new Array(nLights).fill(-1);
+  const pivotRow: number[] = new Array(nButtons).fill(-1);
+
+  let curRow = 0;
+  for (let col = 0; col < nButtons && curRow < nLights; col++) {
+    let pr = -1;
+    for (let r = curRow; r < nLights; r++) {
+      if (mat[r][col] !== 0) { pr = r; break; }
+    }
+    if (pr === -1) continue;
+
+    [mat[curRow], mat[pr]] = [mat[pr], mat[curRow]];
+    pivotCol[curRow] = col;
+    pivotRow[col] = curRow;
+
+    const inv = modInverse(mat[curRow][col], p);
+    for (let c = col; c <= nButtons; c++) {
+      mat[curRow][c] = (mat[curRow][c] * inv) % p;
+    }
+
+    for (let r = 0; r < nLights; r++) {
+      if (r !== curRow && mat[r][col] !== 0) {
+        const factor = mat[r][col];
+        for (let c = col; c <= nButtons; c++) {
+          mat[r][c] = ((mat[r][c] - factor * mat[curRow][c]) % p + p) % p;
+        }
+      }
+    }
+    curRow++;
+  }
+
+  const rank = curRow;
+
+  for (let r = rank; r < nLights; r++) {
+    if (mat[r][nButtons] !== 0) return null;
+  }
+
+  const freeVars: number[] = [];
+  for (let c = 0; c < nButtons; c++) {
+    if (pivotRow[c] === -1) freeVars.push(c);
+  }
+
+  const numFree = freeVars.length;
+
+  if (numFree === 0) {
+    const sol = new Array<number>(nButtons).fill(0);
+    for (let r = 0; r < rank; r++) sol[pivotCol[r]] = mat[r][nButtons];
+    return sol;
+  }
+
+  const totalCombinations = Math.pow(p, numFree);
+
+  if (totalCombinations <= 5_000_000) {
+    return enumerateCounterFree(mat, pivotCol, freeVars, rank, nButtons, p);
+  } else {
+    return greedyCounterFree(mat, pivotCol, freeVars, rank, nButtons, p);
+  }
+}
+
+function enumerateCounterFree(
+  mat: number[][],
+  pivotCol: number[],
+  freeVars: number[],
+  rank: number,
+  nButtons: number,
+  p: number,
+): number[] {
+  const numFree = freeVars.length;
+  const totalCombinations = Math.pow(p, numFree);
+
+  let bestSol: number[] | null = null;
+  let bestSum = Infinity;
+
+  const freeVals = new Array<number>(numFree).fill(0);
+
+  for (let iter = 0; iter < totalCombinations; iter++) {
+    const sol = new Array<number>(nButtons).fill(0);
+
+    for (let f = 0; f < numFree; f++) sol[freeVars[f]] = freeVals[f];
+
+    for (let r = rank - 1; r >= 0; r--) {
+      const pc = pivotCol[r];
+      let val = mat[r][nButtons];
+      for (let c = pc + 1; c < nButtons; c++) {
+        val = ((val - mat[r][c] * sol[c]) % p + p) % p;
+      }
+      sol[pc] = val;
+    }
+
+    let total = 0;
+    for (let c = 0; c < nButtons; c++) total += sol[c];
+
+    if (total < bestSum || (total === bestSum && lexSmaller(sol, bestSol!))) {
+      bestSum = total;
+      bestSol = sol.slice();
+    }
+
+    for (let f = 0; f < numFree; f++) {
+      freeVals[f]++;
+      if (freeVals[f] < p) break;
+      freeVals[f] = 0;
+    }
+  }
+
+  return bestSol!;
+}
+
+function greedyCounterFree(
+  mat: number[][],
+  pivotCol: number[],
+  freeVars: number[],
+  rank: number,
+  nButtons: number,
+  p: number,
+): number[] {
+  const numFree = freeVars.length;
+  const sol = new Array<number>(nButtons).fill(0);
+
+  // Process free variables from last to first for lex preference on earlier vars.
+  for (let fi = numFree - 1; fi >= 0; fi--) {
+    const fCol = freeVars[fi];
+    let bestVal = 0;
+    let bestCost = Infinity;
+
+    for (let v = 0; v < p; v++) {
+      sol[fCol] = v;
+      let cost = v;
+      for (let r = 0; r < rank; r++) {
+        if (mat[r][fCol] !== 0) {
+          const pc = pivotCol[r];
+          let val = mat[r][nButtons];
+          for (let c = pc + 1; c < nButtons; c++) {
+            val = ((val - mat[r][c] * sol[c]) % p + p) % p;
+          }
+          cost += val;
+        }
+      }
+      if (cost < bestCost || (cost === bestCost && v < bestVal)) {
+        bestCost = cost;
+        bestVal = v;
+      }
+    }
+    sol[fCol] = bestVal;
+  }
+
+  // Final back-substitution.
+  for (let r = rank - 1; r >= 0; r--) {
+    const pc = pivotCol[r];
+    let val = mat[r][nButtons];
+    for (let c = pc + 1; c < nButtons; c++) {
+      val = ((val - mat[r][c] * sol[c]) % p + p) % p;
+    }
+    sol[pc] = val;
+  }
+
+  return sol;
+}
