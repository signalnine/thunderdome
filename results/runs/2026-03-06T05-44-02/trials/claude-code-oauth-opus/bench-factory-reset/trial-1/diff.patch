ber[], n: number): boolean {\n   149→  // Walk through indices; at each index where they differ,\n   150→  // if a has 1 and b has 0, a's set includes this index but b's doesn't at this position.\n   151→  // For lex comparison of sorted index sets:\n   152→  // - Build both sets and compare element by element.\n   153→  const aSet: number[] = [];\n   154→  const bSet: number[] = [];\n   155→  for (let i = 0; i < n; i++) {\n   156→    if (a[i]) aSet.push(i);\n   157→    if (b[i]) bSet.push(i);\n   158→  }\n   159→  for (let i = 0; i < aSet.length; i++) {\n   160→    if (aSet[i] < bSet[i]) return true;\n   161→    if (aSet[i] > bSet[i]) return false;\n   162→  }\n   163→  return false;\n   164→}\n   165→\n   166→/** Compare two arrays lexicographically (returns true if a < b). */\n   167→function lexSmaller(a: number[], b: number[]): boolean {\n   168→  for (let i = 0; i < a.length; i++) {\n   169→    if (a[i] < b[i]) return true;\n   170→    if (a[i] > b[i]) return false;\n   171→  }\n   172→  return false;\n   173→}\n   174→\n   175→// ──────────────────────────────────────────────────────────────────────────\n   176→// Part 2 — Counter puzzle  (GF(p))\n   177→// ──────────────────────────────────────────────────────────────────────────\n   178→\n   179→/**\n   180→ * Modular inverse using extended Euclidean algorithm.\n   181→ * Requires gcd(a, mod) = 1 (guaranteed when mod is prime and a != 0).\n   182→ */\n   183→function modInverse(a: number, mod: number): number {\n   184→  a = ((a % mod) + mod) % mod;\n   185→  let [old_r, r] = [a, mod];\n   186→  let [old_s, s] = [1, 0];\n   187→  while (r !== 0) {\n   188→    const q = Math.floor(old_r / r);\n   189→    [old_r, r] = [r, old_r - q * r];\n   190→    [old_s, s] = [s, old_s - q * s];\n   191→  }\n   192→  return ((old_s % mod) + mod) % mod;\n   193→}\n   194→\n   195→/**\n   196→ * Solve a counter puzzle over GF(p).\n   197→ *\n   198→ * Same Gaussian elimination approach as the toggle puzzle, but arithmetic\n   199→ * is mod p instead of mod 2.  Free variables are enumerated over 0..p-1,\n   200→ * optimising for minimum total presses then lexicographic order.\n   201→ */\n   202→export function solveCounter(\n   203→  lights: number[],\n   204→  buttons: number[][],\n   205→  modulus: number,\n   206→): number[] | null {\n   207→  const nLights = lights.length;\n   208→  const nButtons = buttons.length;\n   209→  const p = modulus;\n   210→\n   211→  // Build augmented matrix over GF(p).\n   212→  const mat: number[][] = [];\n   213→  for (let i = 0; i < nLights; i++) {\n   214→    const row = new Array<number>(nButtons + 1).fill(0);\n   215→    row[nButtons] = lights[i] % p;\n   216→    mat.push(row);\n   217→  }\n   218→  for (let j = 0; j < nButtons; j++) {\n   219→    for (const counter of buttons[j]) {\n   220→      mat[counter][j] = (mat[counter][j] + 1) % p;\n   221→    }\n   222→  }\n   223→\n   224→  // Gaussian elimination over GF(p).\n   225→  const pivotCol: number[] = new Array(nLights).fill(-1);\n   226→  const pivotRow: number[] = new Array(nButtons).fill(-1);\n   227→\n   228→  let curRow = 0;\n   229→  for (let col = 0; col < nButtons && curRow < nLights; col++) {\n   230→    // Find pivot.\n   231→    let pr = -1;\n   232→    for (let r = curRow; r < nLights; r++) {\n   233→      if (mat[r][col] !== 0) {\n   234→        pr = r;\n   235→        break;\n   236→      }\n   237→    }\n   238→    if (pr === -1) continue;\n   239→\n   240→    // Swap.\n   241→    [mat[curRow], mat[pr]] = [mat[pr], mat[curRow]];\n   242→    pivotCol[curRow] = col;\n   243→    pivotRow[col] = curRow;\n   244→\n   245→    // Scale pivot row so that leading entry = 1.\n   246→    const inv = modInverse(mat[curRow][col], p);\n   247→    for (let c = col; c <= nButtons; c++) {\n   248→      mat[curRow][c] = (mat[curRow][c] * inv) % p;\n   249→    }\n   250→\n   251→    // Eliminate other rows.\n   252→    for (let r = 0; r < nLights; r++) {\n   253→      if (r !== curRow && mat[r]