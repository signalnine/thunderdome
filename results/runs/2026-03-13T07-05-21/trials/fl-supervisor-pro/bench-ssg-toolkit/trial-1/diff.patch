+++ b/src/plugins/search-index.ts
@@ -0,0 +1,29 @@
+import { Plugin, BuildContext } from '../core/types.js';
+
+function stripHtmlTags(html: string): string {
+  return html.replace(/<[^>]*>?/gm, '');
+}
+
+export function createSearchIndexPlugin(): Plugin {
+  return {
+    name: 'search-index',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'syntax-highlight'],
+    hooks: {
+      afterBuild: async (ctx: BuildContext) => {
+        const { files, output } = ctx;
+
+        const searchIndex = files.map(file => {
+          return {
+            slug: file.slug,
+            title: file.title,
+            content: stripHtmlTags(file.content),
+            ...(file.tags && { tags: file.tags }),
+          };
+        });
+
+        output.set('search-index.json', JSON.stringify(searchIndex, null, 2));
+      },
+    },
+  };
+}
