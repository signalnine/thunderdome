diff --git a/src/plugins/rss-feed.ts b/src/plugins/rss-feed.ts
new file mode 100644
index 0000000..9f71fd5
--- /dev/null
+++ b/src/plugins/rss-feed.ts
@@ -0,0 +1,74 @@
+import { Plugin, BuildContext, _ContentFile } from '../core/types.js';
+
+function escapeXml(text: string): string {
+  return text
+    .replace(/&/g, '&amp;')
+    .replace(/</g, '&lt;')
+    .replace(/>/g, '&gt;')
+    .replace(/"/g, '&quot;')
+    .replace(/'/g, '&apos;');
+}
+
+function formatDate(dateString: string | undefined): string {
+  if (!dateString) {
+    return '';
+  }
+  try {
+    const date = new Date(dateString);
+    return date.toUTCString();
+  } catch (e) {
+    console.warn(`Invalid date string for RSS feed: ${dateString}`);
+    return '';
+  }
+}
+
+export function createRssFeedPlugin(): Plugin {
+  return {
+    name: 'rss-feed',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'taxonomy'],
+    hooks: {
+      afterBuild: async (ctx: BuildContext) => {
+        const { config, files, output, data: _data } = ctx;
+
+        const sortedFiles = [...files].sort((a, b) => {
+          const dateA = a.date ? new Date(a.date).getTime() : 0;
+          const dateB = b.date ? new Date(b.date).getTime() : 0;
+          return dateB - dateA; // Newest first
+        });
+
+        let itemsXml = '';
+        for (const file of sortedFiles) {
+          const fileUrl = `${config.baseUrl}/${file.slug}.html`;
+          const categories = file.tags?.map(tag => `<category>${escapeXml(tag)}</category>`).join('') || '';
+
+          itemsXml += `
+            <item>
+              <title>${escapeXml(file.title)}</title>
+              <link>${escapeXml(fileUrl)}</link>
+              <guid>${escapeXml(fileUrl)}</guid>
+              <pubDate>${formatDate(file.date)}</pubDate>
+              <description><![CDATA[${file.content}]]></description>
+              ${categories}
+            </item>
+          `;
+        }
+
+        const rssFeedXml = `<?xml version="1.0" encoding="UTF-8"?>
+          <rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
+          <channel>
+            <title>${escapeXml(config.title)}</title>
+            <link>${escapeXml(config.baseUrl)}</link>
+            <description>A feed of content from ${escapeXml(config.title)}</description>
+            <lastBuildDate>${new Date().toUTCString()}</lastBuildDate>
+            <language>en-us</language>
+            ${itemsXml}
+          </channel>
+          </rss>
+        `;
+
+        output.set('feed.xml', rssFeedXml.trim());
+      },
+    },
+  };
+}
diff --git a/src/plugins/search-index.ts b/src/plugins/search-index.ts
