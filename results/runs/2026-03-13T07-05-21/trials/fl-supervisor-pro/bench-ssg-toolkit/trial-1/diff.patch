@@ -0,0 +1,61 @@
+import { Plugin, BuildContext } from '../core/types.js';
+
+function escapeXml(text: string): string {
+  return text
+    .replace(/&/g, '&amp;')
+    .replace(/</g, '&lt;')
+    .replace(/>/g, '&gt;')
+    .replace(/"/g, '&quot;')
+    .replace(/'/g, '&apos;');
+}
+
+export function createSitemapPlugin(): Plugin {
+  return {
+    name: 'sitemap',
+    version: '1.0.0',
+    dependencies: ['taxonomy', 'rss-feed'],
+    hooks: {
+      afterBuild: async (ctx: BuildContext) => {
+        const { config, output, data } = ctx;
+        const urls: string[] = [];
+
+        // Add all HTML files
+        for (const outputPath of output.keys()) {
+          if (outputPath.endsWith('.html')) {
+            urls.push(`${config.baseUrl}/${outputPath}`);
+          }
+        }
+
+        // Add taxonomy tag pages
+        const taxonomyTags = data.get('taxonomy-tags') as Map<string, unknown> | undefined;
+        if (taxonomyTags) {
+          for (const tag of taxonomyTags.keys()) {
+            urls.push(`${config.baseUrl}/tags/${tag}.html`);
+          }
+        }
+
+        // Add RSS feed
+        if (output.has('feed.xml')) {
+          urls.push(`${config.baseUrl}/feed.xml`);
+        }
+
+        let urlsetXml = '';
+        for (const url of urls) {
+          urlsetXml += `
+            <url>
+              <loc>${escapeXml(url)}</loc>
+            </url>
+          `;
+        }
+
+        const sitemapXml = `<?xml version="1.0" encoding="UTF-8"?>
+          <urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
+          ${urlsetXml}
+          </urlset>
+        `;
+
+        output.set('sitemap.xml', sitemapXml.trim());
+      },
+    },
+  };
+}
diff --git a/src/plugins/syntax-highlight.ts b/src/plugins/syntax-highlight.ts
