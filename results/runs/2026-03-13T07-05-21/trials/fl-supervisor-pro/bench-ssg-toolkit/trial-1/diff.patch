--- /dev/null
+++ b/src/plugins/syntax-highlight.ts
@@ -0,0 +1,38 @@
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createSyntaxHighlightPlugin(): Plugin {
+  return {
+    name: 'syntax-highlight',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      async transformContent(file: ContentFile, _ctx: BuildContext): Promise<ContentFile> {
+        if (!file.content || typeof file.content !== 'string') {
+          return file;
+        }
+
+        // Regex to find <pre><code class="language-xxx">...</code></pre> blocks
+        // Captures:
+        // 1: The opening <pre> tag (e.g., <pre>)
+        // 2: The opening <code class="language-xxx" ...> tag (e.g., <code class="language-javascript">)
+        // 3: The language (e.g., javascript)
+        // 4: Content of the <code> block
+        // 5: The closing </code></pre> tags (e.g., </code></pre>)
+        const codeBlockRegex = /(<pre[^>]*>)\s*(<code class="language-([^"\s]+)"[^>]*>)([\s\S]*?)(<\/code>\s*<\/pre>)/g;
+
+        file.content = file.content.replace(codeBlockRegex, (match, preTag, codeTag, language, codeContent, closingTags) => {
+          // Add 'highlighted' class to the <code> tag
+          const newCodeTag = codeTag.replace(`class="language-${language}"`, `class="language-${language} highlighted"`);
+          
+          // Add data-language attribute to the <pre> tag
+          const newPreTag = preTag.replace('<pre', `<pre data-language="${language}"`);
+
+          // Reconstruct the block
+          return `${newPreTag}${newCodeTag}${codeContent}${closingTags}`;
+        });
+
+        return file;
+      },
+    },
+  };
+}
diff --git a/src/plugins/taxonomy.ts b/src/plugins/taxonomy.ts
