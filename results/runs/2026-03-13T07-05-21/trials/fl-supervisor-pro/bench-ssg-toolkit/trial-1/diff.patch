index 0000000..5f726de
--- /dev/null
+++ b/src/plugins/markdown-ext.ts
@@ -0,0 +1,146 @@
+import { marked, _MarkedExtension, Token, Tokens, TokensList } from 'marked';
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+// Define types for our custom tokens
+interface AdmonitionToken extends Tokens.Generic {
+  type: 'admonition';
+  level: string; // 'note', 'tip', 'warning'
+  text: string;
+  tokens: Token[]; // Changed from Tokens.Token[]
+  raw: string; // Added back
+}
+
+interface FootnoteRefToken extends Tokens.Generic {
+  type: 'footnoteRef';
+  refNum: string;
+  raw: string; // Added back
+}
+
+interface FootnoteDefToken extends Tokens.Generic {
+  type: 'footnoteDef';
+  refNum: string;
+  text: string;
+  raw: string; // Added back
+}
+
+export function createMarkdownExtPlugin(): Plugin {
+  let currentFootnotes: Map<string, string> = new Map();
+
+  const admonitionExtension = {
+    name: 'admonition',
+    level: 'block',
+    start(src: string) {
+      return src.match(/^:::(note|tip|warning)/)?.index;
+    },
+    async tokenizer(src: string, _tokens: TokensList) { // prefixed _tokens
+      const rule = /^:::(note|tip|warning)\s*\\n([\\s\\S]*?)\\n:::(?:\\n|$)/;
+      const match = rule.exec(src);
+      if (match) {
+        const token: AdmonitionToken = {
+          type: 'admonition',
+          raw: match[0],
+          level: match[1],
+          text: match[2].trim(),
+          tokens: [],
+        };
+        // eslint-disable-next-line @typescript-eslint/no-explicit-any
+        token.tokens = await marked.lexer(token.text, { extensions: [admonitionExtension] as any });
+        return token;
+      }
+      return undefined;
+    },
+    async renderer(token: AdmonitionToken) { // Removed object wrapper, added async directly
+      return `<div class="admonition admonition-${token.level}">${await marked.parser(token.tokens)}</div>
+`;
+    },
+  } as any; // eslint-disable-line @typescript-eslint/no-explicit-any
+
+  const footnoteRefExtension = {
+    name: 'footnoteRef',
+    level: 'inline',
+    start(src: string) {
+      return src.match(/\[\^(\d+)\]/)?.index;
+    },
+    tokenizer(src: string, _tokens: TokensList) { // prefixed _tokens
+      const rule = /^\[\^(\d+)\]/;
+      const match = rule.exec(src);
+      if (match) {
+        const refNum = match[1];
+        return {
+          type: 'footnoteRef',
+          raw: match[0],
+          refNum: refNum,
+        };
+      }
+      return undefined;
+    },
+    renderer(token: FootnoteRefToken) { // Removed object wrapper, not async
+      return `<sup><a href="#fn-${token.refNum}">${token.refNum}</a></sup>`;
+    },
+  } as any; // eslint-disable-line @typescript-eslint/no-explicit-any
+
+  const footnoteDefExtension = {
+    name: 'footnoteDef',
+    level: 'block',
+    start(src: string) {
+      return src.match(/^\[\^(\d+)\]:/)?.index;
+    },
+    tokenizer(src: string, _tokens: TokensList) { // prefixed _tokens
+      const rule = /^\[\^(\d+)\]:([\s\S]*?)(?=
+{2,}|
+\[\^\d+\]:|$)/;
+      const match = rule.exec(src);
+      if (match) {
+        const refNum = match[1];
+        const text = match[2].trim();
+        currentFootnotes.set(refNum, text);
+        return {
+          type: 'footnoteDef',
+          raw: match[0],
+          refNum: refNum,
+          text: text,
+        };
+      }
+      return undefined;
+    },
+    renderer(_token: FootnoteDefToken) { // prefixed _token
+      return '';
+    },
+  } as any; // eslint-disable-line @typescript-eslint/no-explicit-any
+
+  marked.use({ extensions: [admonitionExtension, footnoteRefExtension, footnoteDefExtension] as any }); // eslint-disable-line @typescript-eslint/no-explicit-any
+
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      async transformContent(file: ContentFile, _ctx: BuildContext): Promise<ContentFile> { // prefixed _ctx
+        currentFootnotes = new Map();
+
+        if (typeof file.content === 'string' && file.content.trim() !== '' && !file.content.trim().startsWith('<')) {
+          file.content = await marked.parse(file.content);
+
+          if (currentFootnotes.size > 0) {
+            let footnoteHtml = '<section class="footnotes">
+<ol>
+';
+            const sortedFootnotes = Array.from(currentFootnotes.entries()).sort((a, b) => parseInt(a[0]) - parseInt(b[0]));
+
+            for (const [refNum, text] of sortedFootnotes) {
+              const parsedFootnoteText = (await marked.parse(text)).replace(/^<p>|<\/p>
+?$/g, '');
+              footnoteHtml += `<li id="fn-${refNum}">${parsedFootnoteText}</li>
+`;
+            }
+            footnoteHtml += '</ol>
+</section>
+';
+            file.content += footnoteHtml;
+          }
+        }
+        return file;
+      },
+    },
+  } as Plugin;
+}
