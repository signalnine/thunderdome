@@ -0,0 +1,52 @@
+import { Plugin, BuildContext } from '../core/types.js';
+
+interface DevServerConfig {
+  port: number;
+  routes: Array<{ path: string; handler: string }>;
+  assetPaths: string[];
+  searchIndexPath: string;
+}
+
+export function createDevServerPlugin(): Plugin {
+  return {
+    name: 'dev-server',
+    version: '1.0.0',
+    dependencies: ['asset-pipeline', 'search-index'],
+    hooks: {
+      afterBuild: async (ctx: BuildContext) => {
+        const { output, data } = ctx;
+
+        const devServerConfig: DevServerConfig = {
+          port: 3000,
+          routes: [],
+          assetPaths: [],
+          searchIndexPath: '',
+        };
+
+        // Populate assetPaths from asset-manifest
+        const assetManifest = data.get('asset-manifest') as { assets?: string[] } | undefined;
+        if (assetManifest && assetManifest.assets) {
+          devServerConfig.assetPaths = assetManifest.assets;
+          for (const assetPath of assetManifest.assets) {
+            devServerConfig.routes.push({ path: `/${assetPath}`, handler: 'asset' });
+          }
+        }
+
+        // Set searchIndexPath
+        if (output.has('search-index.json')) {
+          devServerConfig.searchIndexPath = '/search-index.json';
+          devServerConfig.routes.push({ path: '/search-index.json', handler: 'static' });
+        }
+
+        // Add content routes for HTML files
+        for (const outputPath of output.keys()) {
+          if (outputPath.endsWith('.html')) {
+            devServerConfig.routes.push({ path: `/${outputPath}`, handler: 'static' });
+          }
+        }
+
+        data.set('dev-server-config', devServerConfig);
+      },
+    },
+  };
+}
