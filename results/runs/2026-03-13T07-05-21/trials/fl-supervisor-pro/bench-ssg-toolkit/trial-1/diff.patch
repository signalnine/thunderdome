+++ b/src/plugins/taxonomy.ts
@@ -0,0 +1,51 @@
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createTaxonomyPlugin(): Plugin {
+  return {
+    name: 'taxonomy',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      async beforeBuild(ctx: BuildContext): Promise<void> {
+        const tagMap = new Map<string, ContentFile[]>();
+
+        for (const file of ctx.files) {
+          const tags = file.tags || []; // Use file.tags directly, default to empty array
+
+          for (const tag of tags) {
+            const normalizedTag = String(tag).toLowerCase(); // Ensure string and normalize case
+            if (!tagMap.has(normalizedTag)) {
+              tagMap.set(normalizedTag, []);
+            }
+            tagMap.get(normalizedTag)?.push(file);
+          }
+        }
+        ctx.data.set('taxonomy-tags', tagMap);
+      },
+
+      async afterBuild(ctx: BuildContext): Promise<void> {
+        const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]>;
+
+        if (!tagMap) {
+          return; // No tags to process
+        }
+
+        for (const [tag, files] of tagMap.entries()) {
+          const tagPagePath = `tags/${tag}.html`;
+          let tagPageContent = `<h1>Tag: ${tag}</h1>
+<ul>
+`;
+          
+          for (const file of files) {
+            // Assuming slug is used to generate file paths, and title for display
+            tagPageContent += `  <li><a href="/${file.slug}.html">${file.title}</a></li>
+`;
+          }
+          tagPageContent += `</ul>
+`;
+          ctx.output.set(tagPagePath, tagPageContent);
+        }
+      },
+    },
+  };
+}
