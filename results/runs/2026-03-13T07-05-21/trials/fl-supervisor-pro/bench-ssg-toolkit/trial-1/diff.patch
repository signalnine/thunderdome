diff --git a/src/plugins/asset-pipeline.ts b/src/plugins/asset-pipeline.ts
new file mode 100644
index 0000000..63e5ee3
--- /dev/null
+++ b/src/plugins/asset-pipeline.ts
@@ -0,0 +1,54 @@
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createAssetPipelinePlugin(): Plugin {
+  return {
+    name: 'asset-pipeline',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      async transformContent(file: ContentFile, ctx: BuildContext): Promise<ContentFile> {
+        if (!file.content || typeof file.content !== 'string') {
+          return file;
+        }
+
+        // Initialize asset manifest if it doesn't exist
+        if (!ctx.data.has('asset-manifest')) {
+          ctx.data.set('asset-manifest', { assets: [] });
+        }
+        const manifest = ctx.data.get('asset-manifest') as { assets: string[] };
+
+        // Helper function to process and rewrite URLs
+        const processUrl = (url: string): string => {
+          // Check if it's a relative URL (starts with ./) and not already rewritten to /assets/
+          if (url.startsWith('./') && !url.startsWith('/assets/')) {
+            const assetName = url.substring(2); // Remove './'
+            if (!manifest.assets.includes(assetName)) { // Add to manifest only if not already present
+              manifest.assets.push(assetName);
+            }
+            return `/assets/${assetName}`;
+          }
+          // Leave absolute URLs and already rewritten URLs unchanged
+          return url;
+        };
+
+        // Regex to find src attributes in img tags
+        // This regex captures the content of the src attribute
+        const imgSrcRegex = /(<img[^>]+src=")([^"]+)("[^>]*>)/g;
+        file.content = file.content.replace(imgSrcRegex, (match, beforeSrc, srcUrl, afterSrc) => {
+          const rewrittenUrl = processUrl(srcUrl);
+          return `${beforeSrc}${rewrittenUrl}${afterSrc}`;
+        });
+
+        // Regex to find href attributes in a tags
+        // This regex captures the content of the href attribute
+        const aHrefRegex = /(<a[^>]+href=")([^"]+)("[^>]*>)/g;
+        file.content = file.content.replace(aHrefRegex, (match, beforeHref, hrefUrl, afterHref) => {
+          const rewrittenUrl = processUrl(hrefUrl);
+          return `${beforeHref}${rewrittenUrl}${afterHref}`;
+        });
+
+        return file;
+      },
+    },
+  };
+}
