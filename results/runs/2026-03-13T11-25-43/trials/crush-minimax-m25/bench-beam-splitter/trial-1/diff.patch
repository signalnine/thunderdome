+type Direction = "down" | "downLeft" | "downRight";
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+const DIRS: Record<Direction, { dr: number; dc: number }> = {
+  down: { dr: 1, dc: 0 },
+  downLeft: { dr: 1, dc: -1 },
+  downRight: { dr: 1, dc: 1 },
+};
+
+function isValid(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+function getNextPos(beam: Beam): { row: number; col: number } {
+  const { dr, dc } = DIRS[beam.dir];
+  return { row: beam.row + dr, col: beam.col + dc };
+}
+
+export function countBeamCells(grid: string[][]): number {
+  if (!grid.length || !grid[0].length) return 0;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const visited = new Set<string>();
+
+  const queue: Beam[] = [];
+
+  for (let c = 0; c < cols; c++) {
+    if (grid[0][c] === "S") {
+      queue.push({ row: 0, col: c, dir: "down" });
+      visited.add(`0,${c}`);
+    }
+  }
+
+  while (queue.length > 0) {
+    const beam = queue.shift()!;
+    const { row, col } = getNextPos(beam);
+
+    if (!isValid(row, col, rows, cols)) continue;
+
+    visited.add(`${row},${col}`);
+
+    const cell = grid[row][col];
+    if (cell === "^") {
+      queue.push({ row, col, dir: "downLeft" });
+      queue.push({ row, col, dir: "downRight" });
+    } else if (cell === "S") {
+      queue.push({ row, col, dir: "down" });
+    } else {
+      queue.push({ row, col, dir: beam.dir });
+    }
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  if (!grid.length || !grid[0].length) return 0n;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+
+  const memo = new Map<string, bigint>();
+
+  function countPathsFrom(r: number, c: number, dir: Direction): bigint {
+    if (!isValid(r, c, rows, cols)) return 1n;
+
+    const key = `${r},${c},${dir}`;
+    if (memo.has(key)) return memo.get(key)!;
+
+    const cell = grid[r][c];
+    let result: bigint;
+
+    if (cell === "^") {
+      const paths1 = countPathsFrom(r + 1, c - 1, "downLeft");
+      const paths2 = countPathsFrom(r + 1, c + 1, "downRight");
+      result = paths1 + paths2;
+    } else {
+      const { dr, dc } = DIRS[dir];
+      result = countPathsFrom(r + dr, c + dc, dir);
+    }
+
+    memo.set(key, result);
+    return result;
+  }
+
+  let totalPaths = 0n;
+  for (let c = 0; c < cols; c++) {
+    if (grid[0][c] === "S") {
+      totalPaths += countPathsFrom(0, c, "down");
+    }
+  }
+
+  return totalPaths;
+}
