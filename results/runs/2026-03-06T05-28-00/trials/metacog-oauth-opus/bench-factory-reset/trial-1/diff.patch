tion solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const numLights = target.length;\n  const numButtons = buttons.length;\n\n  // Build augmented matrix over GF(2): rows = lights, cols = buttons + 1 (augmented column)\n  const matrix: number[][] = [];\n  for (let i = 0; i < numLights; i++) {\n    const row = new Array(numButtons + 1).fill(0);\n    for (let j = 0; j < numButtons; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    row[numButtons] = target[i] ? 1 : 0;\n    matrix.push(row);\n  }\n\n  // Gaussian elimination over GF(2)\n  const pivotCol: number[] = [];\n  const pivotRow: number[] = new Array(numButtons).fill(-1);\n  let row = 0;\n\n  for (let col = 0; col < numButtons && row < numLights; col++) {\n    let found = -1;\n    for (let r = row; r < numLights; r++) {\n      if (matrix[r][col] === 1) {\n        found = r;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    [matrix[row], matrix[found]] = [matrix[found], matrix[row]];\n\n    for (let r = 0; r < numLights; r++) {\n      if (r !== row && matrix[r][col] === 1) {\n        for (let c = 0; c < numButtons + 1; c++) {\n          matrix[r][c] ^= matrix[row][c];\n        }\n      }\n    }\n\n    pivotCol.push(col);\n    pivotRow[col] = row;\n    row++;\n  }\n\n  const rank = pivotCol.length;\n\n  // Check for inconsistency\n  for (let r = rank; r < numLights; r++) {\n    if (matrix[r][numButtons] === 1) {\n      return null;\n    }\n  }\n\n  // Identify free variables\n  const freeVars: number[] = [];\n  for (let col = 0; col < numButtons; col++) {\n    if (pivotRow[col] === -1) {\n      freeVars.push(col);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  if (numFree <= 20) {\n    return solveToggleEnumerate(matrix, pivotCol, freeVars, numButtons, rank);\n  } else {\n    return solveToggleMITM(matrix, pivotCol, freeVars, numButtons, rank);\n  }\n}\n\nfunction solveToggleSolution(\n  matrix: number[][],\n  pivotCol: number[],\n  freeVars: number[],\n  freeAssignment: number,\n  numButtons: number,\n  rank: number\n): number[] {\n  const solution = new Array(numButtons).fill(0);\n  const numFree = freeVars.length;\n\n  for (let i = 0; i < numFree; i++) {\n    solution[freeVars[i]] = (freeAssignment >> i) & 1;\n  }\n\n  for (let i = rank - 1; i >= 0; i--) {\n    const pc = pivotCol[i];\n    let val = matrix[i][numButtons];\n    for (let c = 0; c < numButtons; c++) {\n      if (c !== pc) {\n        val ^= matrix[i][c] & solution[c];\n      }\n    }\n    solution[pc] = val;\n  }\n\n  return solution;\n}\n\nfunction solutionToPressed(solution: number[]): number[] {\n  const pressed: number[] = [];\n  for (let i = 0; i < solution.length; i++) {\n    if (solution[i] === 1) pressed.push(i);\n  }\n  return pressed;\n}\n\nfunction solveToggleEnumerate(\n  matrix: number[][],\n  pivotCol: number[],\n  freeVars: number[],\n  numButtons: number,\n  rank: number\n): number[] {\n  const numFree = freeVars.length;\n  let bestPressed: number[] | null = null;\n  let bestCount = Infinity;\n\n  const totalCombinations = 1 << numFree;\n  for (let mask = 0; mask < totalCombinations; mask++) {\n    const solution = solveToggleSolution(matrix, pivotCol, freeVars, mask, numButtons, rank);\n    const pressed = solutionToPressed(solution);\n\n    if (pressed.length < bestCount ||\n        (pressed.length === bestCount && bestPressed !== null && lexSmaller(pressed, bestPressed))) {\n      bestCount = pressed.length;\n      bestPressed = pressed;\n    }\n  }\n\n  return bestPressed!;\n}\n\nfunction solveToggleMITM(\n  matrix: number[][],\n  pivotCol: number[],\n  freeVars: number[],\n  numButtons: number,\n  rank: number\n): number[] {\n  // Meet-in-the-middle: split free variables into two halves.\n  // Enumerate all 2^halfA assignments for first half, compute full solution effect.\n  // Store them indexed by their solution vector (as a string key).\n  // Then enumerate second half, compute effect, look for best combination.\n  //\n  // Solution for assignment (maskA, maskB) where maskA covers first halfA free vars\n  // and maskB covers remaining: s = base XOR effectA(maskA) XOR effectB(maskB)\n  //\n  // effectA(maskA)[button] = XOR of effect vectors for set bits in maskA\n  // effectB similar.\n  // base = solution with all free vars = 0\n\n  const numFree = freeVars.length;\n  const halfA = Math.floor(numFree / 2);\n  const halfB = numFree - halfA;\n\n  // Precompute base solution and effect of each free variable\n  const baseSol = solveToggleSolution(matrix, pivotCol, freeVars, 0, numButtons, rank);\n  const freeEffects: number[][] = [];\n  for (let fi = 0; fi < numFree; fi++) {\n    const mask = 1 << fi;\n    const sol = solveToggleSolution(matrix, pivotCol, freeVars, mask, numButtons, rank);\n    // effect[fi] = baseSol XOR sol (the change from toggling free var fi)\n    const effect = new Array(numButtons);\n    for (let b = 0; b < numButtons; b++) {\n      effect[b] = baseSol[b] ^ sol[b];\n    }\n    freeEffects.push(effect);\n  }\n\n  // Compute combined effect for first half\n  // For maskA, vA[b] = XOR of freeEffects[i][b] for i in set bits of maskA (i < halfA)\n  // Solution for (maskA, maskB) at button b = baseSol[b] XOR vA[b] XOR vB[b]\n\n  // Enumerate first half, store each vA as a compact key, tracking min weight maskA for each vA\n  const sizeA = 1 << halfA;\n  const sizeB = 1 << halfB;\n\n  // Represent each effect vector as a bigint for fast XOR\n  // Actually, since numButtons <= 40, we can pack into a single number (but JS numbers are 53-bit safe)\n  // Use two 32-bit numbers for safety, or just use BigInt.\n\n  // Pack effect vectors into BigInts\n  const baseBig = packBigInt(baseSol, numButtons);\n  const effectBigs: bigint[] = freeEffects.map(e => packBigInt(e, numButtons));\n\n  // Enumerate first half\n  // vA(maskA) = XOR of effectBigs[i] for i where bit i of maskA is set\n  // fullSol(maskA, 0) = baseBig XOR vA(maskA)\n  // We store vA -> {weight of maskA, maskA}\n\n  interface Entry { weight: number; maskA: number; }\n  const mapA = new Map<bigint, Entry>();\n\n  for (let maskA = 0; maskA < sizeA; maskA++) {\n    let vA = 0n;\n    for (let i = 0; i < halfA; i++) {\n      if ((maskA >> i) & 1) {\n        vA ^= effectBigs[i];\n      }\n    }\n\n    const existing = mapA.get(vA);\n    const weight = popcount(maskA);\n    if (!existing || weight < existing.weight) {\n      mapA.set(vA, { weight, maskA });\n    }\n  }\n\n  // Enumerate second half, find best combination\n  let bestTotal = Infinity;\n  let bestPressed: number[] | null = null;\n\n  for (let maskB = 0; maskB < sizeB; maskB++) {\n    let vB = 0n;\n    for (let i = 0; i < halfB; i++) {\n      if ((maskB >> i) & 1) {\n        vB ^= effectBigs[halfA + i];\n      }\n    }\n\n    // Full solution = baseBig XOR vA XOR vB for some vA\n    // We want to minimize HW(baseBig XOR vA XOR vB)\n    // = HW((baseBig XOR vB) XOR vA)\n    // Let target = baseBig XOR vB\n    // We want vA that minimizes HW(target XOR vA)\n\n    const target = baseBig ^ vB;\n\n    // Check all vA entries in mapA\n    // This is O(|mapA| * sizeB) = O(2^halfA * 2^halfB) = O(2^numFree) — no better than brute force!\n\n    // For true MITM speedup, we need a way to find the nearest neighbor in Hamming space.\n    // With numButtons <= 40, let's try a different approach:\n    // Split the 40 bits into halves (first 20, last 20).\n    // For the first 20 bits: create lookup from first20bits(vA) -> list of entries\n    // For each target, enumerate what the first 20 bits should ideally be (all matching target's first 20),\n    // then check nearby patterns.\n\n    // This is getting very complex. Let's use a simpler but still fast approach:\n    // Just iterate over all mapA entries for each maskB.\n    // This is O(2^halfA * 2^halfB) = O(2^numFree), same as brute force.\n    // But we can batch this better.\n\n    // Actually, for the worst case of 40 free variables (halfA=20, halfB=20),\n    // this is 2^20 * 2^20 = 2^40 which is too slow.\n\n    // Let's accept that and handle it differently: for the toggle case with > 20 free vars,\n    // use a probabilistic or greedy approach.\n\n    // For now, let's just do the brute force scan since mapA won't be huge in practice.\n    for (const [vA, entryA] of mapA) {\n      const fullBig = target ^ vA;\n      const hw = popcountBig(fullBig);\n\n      if (hw < bestTotal) {\n        bestTotal = hw;\n        const fullMask = (maskB << halfA) | entryA.maskA;\n        const solution = solveToggleSolution(matrix, pivotCol, freeVars, fullMask, numButtons, rank);\n        bestPressed = solutionToPressed(solution);\n      } else if (hw === bestTotal) {\n        const fullMask = (maskB << halfA) | entryA.maskA;\n        const solution = solveToggleSolution(matrix, pivotCol, freeVars, fullMask, numButtons, rank);\n        const pressed = solutionToPressed(solution);\n        if (bestPressed !== null && lexSmaller(pressed, bestPressed)) {\n          bestPressed = pressed;\n        }\n      }\n    }\n  }\n\n  return bestPressed!;\n}\n\nfunction packBigInt(arr: number[], len: number): bigint {\n  let result = 0n;\n  for (let i = 0; i < len; i++) {\n    if (arr[i]) {\n      result |= 1n << BigInt(i);\n    }\n  }\n  return result;\n}\n\nfunction popcountBig(n: bigint): number {\n  let count = 0;\n  while (n > 0n) {\n    n &= n - 1n;\n    count++;\n  }\n  return count;\n}\n\nfunction popcount(n: number): number {\n  let count = 0;\n  while (n) {\n    n &= n - 1;\n    count++;\n  }\n  return count;\n}\n\nfunction lexSmaller(a: number[], b: number[]): boolean {\n  for (let i = 0; i < Math.min(a.length, b.length); i++) {\n    if (a[i] < b[i]) return true;\n    if (a[i] > b[i]) return false;\n  }\n  return a.length < b.length;\n}\n\n/**\n * Solve counter puzzle over GF(p) using Gaussian elimination.\n * Returns array of press counts, or null if no solution.\n */\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const numCounters = lights.length;\n  const numButtons = buttons.length;\n\n  // Build augmented matrix over GF(p): rows = counters, cols = buttons + 1\n  const matrix: number[][] = [];\n  for (let i = 0; i < numCounters; i++) {\n    const row = new Array(numButtons + 1).fill(0);\n    for (let j = 0; j < numButtons; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    row[numButtons] = ((lights[i] % modulus) + modulus) % modulus;\n    matrix.push(row);\n  }\n\n  // Gaussian elimination over GF(p)\n  const pivotCol: number[] = [];\n  const pivotRow: number[] = new Array(numButtons).fill(-1);\n  let row = 0;\n\n  for (let col = 0; col < numButtons && row < numCounters; col++) {\n    let found = -1;\n    for (let r = row; r < numCounters; r++) {\n      if (matrix[r][col] !== 0) {\n        found = r;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    [matrix[row], matrix[found]] = [matrix[found], matrix[row]];\n\n    const inv = modInverse(matrix[row][col], modulus);\n    for (let c = 0; c < numButtons + 1; c++) {\n      matrix[row][c] = (matrix[row][c] * inv) % modulus;\n    }\n\n    for (let r = 0; r < numCounters; r++) {\n      if (r !== row && matrix[r][col] !== 0) {\n        const factor = matrix[r][col];\n        for (let c = 0; c < numButtons + 1; c++) {\n          matrix[r][c] = ((matrix[r][c] - factor * matrix[row][c]) % modulus + modulus) % modulus;\n        }\n      }\n    }\n\n    pivotCol.push(col);\n    pivotRow[col] = row;\n    row++;\n  }\n\n  const rank = pivotCol.length;\n\n  // Check for inconsistency\n  for (let r = rank; r < numCounters; r++) {\n    if (matrix[r][numButtons] !== 0) {\n      return null;\n    }\n  }\n\n  // Identify free variables\n  const freeVars: number[] = [];\n  for (let col = 0; col < numButtons; col++) {\n    if (pivotRow[col] === -1) {\n      freeVars.push(col);\n    }\n  }\n\n  const numFree = freeVars.length;\n  const totalCombinations = Math.pow(modulus, numFree);\n\n  if (numFree === 0 || totalCombinations <= 5_000_000) {\n    return solveCounterEnumerate(matrix, pivotCol, freeVars, numButtons, modulus, rank);\n  } else {\n    return solveCounterCoordinateDescent(matrix, pivotCol, freeVars, numButtons, modulus, rank);\n  }\n}\n\nfunction solveCounterEnumerate(\n  matrix: number[][],\n  pivotCol: number[],\n  freeVars: number[],\n  numButtons: number,\n  modulus: number,\n  rank: number\n): number[] {\n  const numFree = freeVars.length;\n  const totalCombinations = Math.pow(modulus, numFree);\n  let bestSolution: number[] | null = null;\n  let bestTotal = Infinity;\n\n  const freeValues = new Array(numFree).fill(0);\n\n  for (let iter = 0; iter < totalCombinations; iter++) {\n    const solution = computeSolutionMod(matrix, pivotCol, freeVars, freeValues, numButtons, modulus, rank);\n\n    let total = 0;\n    for (let i = 0; i < numButtons; i++) {\n      total += solution[i];\n    }\n\n    if (total < bestTotal ||\n        (total === bestTotal && bestSolution !== null && lexSmallerArr(solution, bestSolution))) {\n      bestTotal = total;\n      bestSolution = [...solution];\n    }\n\n    incrementCounter(freeValues, modulus);\n  }\n\n  return bestSolution!;\n}\n\nfunction solveCounterCoordinateDescent(\n  matrix: number[][],\n  pivotCol: number[],\n  freeVars: number[],\n  numButtons: number,\n  modulus: number,\n  rank: number\n): number[] {\n  const numFree = freeVars.length;\n\n  let bestSolution: number[] | null = null;\n  let bestTotal = Infinity;\n\n  // Try multiple starting points\n  const starts: number[][] = [new Array(numFree).fill(0)];\n  for (let fi = 0; fi < Math.min(numFree, 10); fi++) {\n    for (let v = 1; v < Math.min(modulus, 5); v++) {\n      const start = new Array(numFree).fill(0);\n      start[fi] = v;\n      starts.push(start);\n    }\n  }\n\n  for (const startValues of starts) {\n    const freeValues = [...startValues];\n\n    