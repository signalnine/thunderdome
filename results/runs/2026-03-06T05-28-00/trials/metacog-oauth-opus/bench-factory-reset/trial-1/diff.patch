+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter } from './index.js';
+
+function verifyToggle(target: boolean[], buttons: number[][], pressed: number[]): boolean {
+  const state = new Array(target.length).fill(false);
+  for (const b of pressed) {
+    for (const light of buttons[b]) {
+      state[light] = !state[light];
+    }
+  }
+  return state.every((s, i) => s === target[i]);
+}
+
+function verifyCounter(target: number[], buttons: number[][], presses: number[], modulus: number): boolean {
+  const state = new Array(target.length).fill(0);
+  for (let b = 0; b < buttons.length; b++) {
+    for (const counter of buttons[b]) {
+      state[counter] = (state[counter] + presses[b]) % modulus;
+    }
+  }
+  return state.every((s, i) => s === target[i]);
+}
+
+describe('solveToggle', () => {
+  it('should return null for impossible configuration', () => {
+    // From TASK.md example: target [T,T,F,T] with buttons [0,1],[1,2,3],[0,3] has no solution
+    const result = solveToggle({
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]]
+    });
+    expect(result).toBeNull();
+  });
+
+  it('should return empty array when target is all off', () => {
+    const result = solveToggle({
+      target: [false, false, false],
+      buttons: [[0, 1], [1, 2]]
+    });
+    expect(result).toEqual([]);
+  });
+
+  it('should solve simple single-button case', () => {
+    const result = solveToggle({
+      target: [true, true],
+      buttons: [[0, 1]]
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('should find minimum button presses', () => {
+    // 3 lights, target all on
+    // Button 0: [0,1,2] — toggles all
+    // Button 1: [0]
+    // Button 2: [1]
+    // Button 3: [2]
+    // Pressing button 0 alone gives [T,T,T] = 1 press
+    // Pressing 1,2,3 also gives [T,T,T] = 3 presses
+    const result = solveToggle({
+      target: [true, true, true],
+      buttons: [[0, 1, 2], [0], [1], [2]]
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('should return lexicographically smallest when tied', () => {
+    // 2 lights, target [T, F]
+    // Button 0: [0]
+    // Button 1: [0]
+    // Both are single-press solutions, pick [0] (lex smallest)
+    const result = solveToggle({
+      target: [true, false],
+      buttons: [[0], [0]]
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('should handle case where all buttons needed', () => {
+    // 3 lights, each button toggles exactly one light
+    const result = solveToggle({
+      target: [true, true, true],
+      buttons: [[0], [1], [2]]
+    });
+    expect(result).toEqual([0, 1, 2]);
+  });
+
+  it('should handle overlapping buttons', () => {
+    // 4 lights, target: [T, F, T, F]
+    // Button 0: [0, 2]
+    // Solution: press button 0
+    const result = solveToggle({
+      target: [true, false, true, false],
+      buttons: [[0, 2], [1, 3], [0, 1]]
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('should handle 40x40 toggle system within time', () => {
+    // 40 lights, 40 buttons — each button toggles 2-4 lights (full rank expected)
+    const n = 40;
+    const buttons: number[][] = [];
+    for (let i = 0; i < n; i++) {
+      buttons.push([i, (i + 1) % n]);
+    }
+    const target = new Array(n).fill(true);
+    const start = Date.now();
+    const result = solveToggle({ target, buttons });
+    const elapsed = Date.now() - start;
+    expect(elapsed).toBeLessThan(5000);
+    if (result !== null) {
+      expect(verifyToggle(target, buttons, result)).toBe(true);
+    }
+  });
+
+  it('should produce valid solution for larger case', () => {
+    const buttons = [
+      [0, 1, 2], [3, 4, 5], [6, 7, 8], [0, 3, 6],
+      [1, 4, 7], [2, 5, 8], [0, 4, 8], [2, 4, 6],
+      [0, 9], [1, 9]
+    ];
+    const target = [true, true, true, true, false, true, true, true, true, false];
+    const result = solveToggle({ target, buttons });
+    if (result !== null) {
+      expect(verifyToggle(target, buttons, result)).toBe(true);
+    }
+  });
+});
+
+describe('solveCounter', () => {
+  it('should return null for impossible configuration', () => {
+    // Counter 0 needs value 1, but no button affects it
+    const result = solveCounter([1, 0], [[1]], 2);
+    expect(result).toBeNull();
+  });
+
+  it('should return all zeros when target is all zero', () => {
+    const result = solveCounter([0, 0], [[0, 1], [0]], 3);
+    expect(result).toEqual([0, 0]);
+  });
+
+  it('should solve simple single-button case', () => {
+    // One counter, target = 3, button increments it, mod 5
+    const result = solveCounter([3], [[0]], 5);
+    expect(result).toEqual([3]);
+  });
+
+  it('should use modular arithmetic', () => {
+    // Counter target = 2, mod 3
+    // Button 0 affects counter 0
+    // Press 2 times
+    const result = solveCounter([2], [[0]], 3);
+    expect(result).toEqual([2]);
+  });
+
+  it('should find minimum total presses', () => {
+    // 2 counters, target [1, 1], mod 3
+    // Button 0: affects [0, 1] — press once to get both to 1
+    // Button 1: affects [0]
+    // Button 2: affects [1]
+    // Min is pressing button 0 once (total = 1) vs button 1 + button 2 (total = 2)
+    const result = solveCounter([1, 1], [[0, 1], [0], [1]], 3);
+    expect(result).toEqual([1, 0, 0]);
+  });
+
+  it('should return lex smallest when tied on total', () => {
+    // 1 counter, target = 1, mod 3
+    // Button 0: [0]
+    // Button 1: [0]
+    // Both pressing once gives total 1, lex smallest is [0, 1]
+    const result = solveCounter([1], [[0], [0]], 3);
+    expect(result).toEqual([0, 1]);
+  });
+
+  it('should handle larger modulus', () => {
+    // mod 7, single counter target = 5
+    const result = solveCounter([5], [[0]], 7);
+    expect(result).toEqual([5]);
+  });
+
+  it('should handle 40x40 counter system with large modulus', () => {
+    const n = 40;
+    const modulus = 97;
+    const buttons: number[][] = [];
+    for (let i = 0; i < n; i++) {
+      buttons.push([i, (i + 1) % n]);
+    }
+    const targets = new Array(n).fill(0).map((_, i) => (i * 7 + 3) % modulus);
+    const start = Date.now();
+    const result = solveCounter(targets, buttons, modulus);
+    const elapsed = Date.now() - start;
+    expect(elapsed).toBeLessThan(5000);
+    if (result !== null) {
+      expect(verifyCounter(targets, buttons, result, modulus)).toBe(true);
+    }
+  });
+
+  it('should handle 20x20 counter system', () => {
+    // 20 counters, 20 buttons, each button affects 2-3 counters
+    const numCounters = 20;
+    const numButtons = 20;
+    const modulus = 5;
+    const buttons: number[][] = [];
+    for (let i = 0; i < numButtons; i++) {
+      buttons.push([i % numCounters, (i + 1) % numCounters]);
+    }
+    const targets = new Array(numCounters).fill(1);
+    const result = solveCounter(targets, buttons, modulus);
+    if (result !== null) {
+      expect(verifyCounter(targets, buttons, result, modulus)).toBe(true);
+    }
+  });
+
+  it('should produce valid solution for larger counter case', () => {
+    const targets = [3, 1, 4, 1, 5];
+    const buttons = [
+      [0, 1], [1, 2], [2, 3], [3, 4], [0, 4],
+      [0, 2, 4], [1, 3]
+    ];
+    const modulus = 7;
+    const result = solveCounter(targets, buttons, modulus);
+    if (result !== null) {
+      expect(verifyCounter(targets, buttons, result, modulus)).toBe(true);
+      expect(result.length).toBe(buttons.length);
+      expect(result.every(v => v >= 0 && v < modulus)).toBe(true);
+    }
+  });
+});
