0→        let bestVal = savedVal;\n   651→        let bestLocalTotal = currentTotal;\n   652→        let bestLocalSol = currentSolution;\n   653→\n   654→        for (let v = 0; v < modulus; v++) {\n   655→          if (v === savedVal) continue;\n   656→          freeValues[fi] = v;\n   657→          const sol = computeSolutionMod(matrix, pivotCol, freeVars, freeValues, numButtons, modulus, rank);\n   658→          const total = sol.reduce((a, b) => a + b, 0);\n   659→          if (total < bestLocalTotal || (total === bestLocalTotal && lexSmallerArr(sol, bestLocalSol))) {\n   660→            bestLocalTotal = total;\n   661→            bestVal = v;\n   662→            bestLocalSol = sol;\n   663→          }\n   664→        }\n   665→\n   666→        freeValues[fi] = bestVal;\n   667→        if (bestLocalTotal < currentTotal || (bestLocalTotal === currentTotal && lexSmallerArr(bestLocalSol, currentSolution))) {\n   668→          currentTotal = bestLocalTotal;\n   669→          currentSolution = bestLocalSol;\n   670→          improved = true;\n   671→        }\n   672→      }\n   673→    }\n   674→\n   675→    if (currentTotal < bestTotal || (currentTotal === bestTotal && bestSolution !== null && lexSmallerArr(currentSolution, bestSolution))) {\n   676→      bestTotal = currentTotal;\n   677→      bestSolution = currentSolution;\n   678→    }\n   679→  }\n   680→\n   681→  return bestSolution!;\n   682→}\n   683→\n   684→function computeSolutionMod(\n   685→  matrix: number[][],\n   686→  pivotCol: number[],\n   687→  freeVars: number[],\n   688→  freeValues: number[],\n   689→  numButtons: number,\n   690→  modulus: number,\n   691→  rank: number\n   692→): number[] {\n   693→  const solution = new Array(numButtons).fill(0);\n   694→\n   695→  for (let i = 0; i < freeVars.length; i++) {\n   696→    solution[freeVars[i]] = freeValues[i];\n   697→  }\n   698→\n   699→  for (let i = rank - 1; i >= 0; i--) {\n   700→    const pc = pivotCol[i];\n   701→    let val = matri