ocalTotal = total;\n            bestVal = v;\n            bestLocalSol = sol;\n          }\n        }\n\n        freeValues[fi] = bestVal;\n        if (bestLocalTotal < currentTotal || (bestLocalTotal === currentTotal && lexSmallerArr(bestLocalSol, currentSolution))) {\n          currentTotal = bestLocalTotal;\n          currentSolution = bestLocalSol;\n          improved = true;\n        }\n      }\n    }\n\n    if (currentTotal < bestTotal || (currentTotal === bestTotal && bestSolution !== null && lexSmallerArr(currentSolution, bestSolution))) {\n      bestTotal = currentTotal;\n      bestSolution = currentSolution;\n    }\n  }\n\n  return bestSolution!;\n}\n\nfunction computeSolutionMod(\n  matrix: number[][],\n  pivotCol: number[],\n  freeVars: number[],\n  freeValues: number[],\n  numButtons: number,\n  modulus: number,\n  rank: number\n): number[] {\n  const solution = new Array(numButtons).fill(0);\n\n  for (let i = 0; i < freeVars.length; i++) {\n    solution[freeVars[i]] = freeValues[i];\n  }\n\n  for (let i = rank - 1; i >= 0; i--) {\n    const pc = pivotCol[i];\n    let val = matrix[i][numButtons];\n    for (let c = 0; c < numButtons; c++) {\n      if (c !== pc) {\n        val = ((val - matrix[i][c] * solution[c]) % modulus + modulus) % modulus;\n      }\n    }\n    solution[pc] = val;\n  }\n\n  return solution;\n}\n\nfunction incrementCounter(counter: number[], base: number): void {\n  for (let i = 0; i < counter.length; i++) {\n    counter[i]++;\n    if (counter[i] < base) return;\n    counter[i] = 0;\n  }\n}\n\nfunction lexSmallerArr(a: number[], b: number[]): boolean {\n  for (let i = 0; i < a.length; i++) {\n    if (a[i] < b[i]) return true;\n    if (a[i] > b[i]) return false;\n  }\n  return false;\n}\n\nfunction modInverse(a: number, p: number): number {\n  a = ((a % p) + p) % p;\n  return modPow(a, p - 2, p);\n}\n\nfunction modPow(base: number, exp: number, mod: number): number {\n  let result = 1;\n  base = base % mod;\n  while (exp > 0) {\n    if