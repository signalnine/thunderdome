s":11,"lines":[" ): number[] {","   const numFree = freeVars.length;"," ","-  // Try multiple starting points","   let bestSolution: number[] | null = null;","   let bestTotal = Infinity;"," ","-  // Start from all-zeros","+  // Try multiple starting points","   const starts: number[][] = [new Array(numFree).fill(0)];","-","-  // Also try starting from each free var at each value (random restarts)","   for (let fi = 0; fi < Math.min(numFree, 10); fi++) {","     for (let v = 1; v < Math.min(modulus, 5); v++) {","       const start = new Array(numFree).fill(0);"]}],"originalFile":"interface Machine {\n  target: boolean[];\n  buttons: number[][];\n}\n\n/**\n * Solve toggle puzzle over GF(2) using Gaussian elimination.\n * Returns minimum set of button indices (sorted ascending), or null if no solution.\n */\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const numLights = target.length;\n  const numButtons = buttons.length;\n\n  // Build augmented matrix over GF(2): rows = lights, cols = buttons + 1 (augmented column)\n  const matrix: number[][] = [];\n  for (let i = 0; i < numLights; i++) {\n    const row = new Array(numButtons + 1).fill(0);\n    for (let j = 0; j < numButtons; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    row[numButtons] = target[i] ? 1 : 0;\n    matrix.push(row);\n  }\n\n  // Gaussian elimination over GF(2)\n  const pivotCol: number[] = [];\n  const pivotRow: number[] = new Array(numButtons).fill(-1);\n  let row = 0;\n\n  for (let col = 0; col < numButtons && row < numLights; col++) {\n    let found = -1;\n    for (let r = row; r < numLights; r++) {\n      if (matrix[r][col] === 1) {\n        found = r;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    [matrix[row], matrix[found]] = [matrix[found], matrix[row]];\n\n    for (let r = 0; r < numLights; r++) {\n      if (r !== row && matrix[r][col] === 1) {\n        for (let c = 0; c < numButtons + 1; c++) {\n          matrix[r][c] ^= matrix[row][c];\n        }\n      }\n    }\n\n    pivotCol.push(col);\n    pivotRow[col] = row;\n    row++;\n  }\n\n  const rank = pivotCol.length;\n\n  // Check for inconsistency\n  for (let r = rank; r < numLights; r++) {\n    if (matrix[r][numButtons] === 1) {\n      return null;\n    }\n  }\n\n  // Identify free variables\n  const freeVars: number[] = [];\n  for (let col = 0; col < numButtons; col++) {\n    if (pivotRow[col] === -1) {\n      freeVars.push(col);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  if (numFree <= 20) {\n    // Direct enumeration\n    return solveToggleEnumerate(matrix, pivotCol, freeVars, numButtons, rank);\n  } else {\n    // Meet in the middle for large free variable count\n    return solveToggleMITM(matrix, pivotCol, pivotRow, freeVars, numButtons, rank);\n  }\n}\n\nfunction solveToggleEnumerate(\n  matrix: number[][],\n  pivotCol: number[],\n  freeVars: number[],\n  numButtons: number,\n  rank: number\n): number[] {\n  const numFree = freeVars.length;\n  let bestSolution: number[] | null = null;\n  let bestCount = Infinity;\n\n  const totalCombinations = 1 << numFree;\n  for (let mask = 0; mask < totalCombinations; mask++) {\n    const solution = new Array(numButtons).fill(0);\n\n    for (let i = 0; i < numFree; i++) {\n      solution[freeVars[i]] = (mask >> i) & 1;\n    }\n\n    for (let i = rank - 1; i >= 0; i--) {\n      const pc = pivotCol[i];\n      let val = matrix[i][numButtons];\n      for (let c = 0; c < numButtons; c++) {\n        if (c !== pc) {\n          val ^= matrix[i][c] & solution[c];\n        }\n      }\n      solution[pc] = val;\n    }\n\n    const pressed: number[] = [];\n    for (let i = 0; i < numButtons; i++) {\n      if (solution[i] === 1) pressed.push(i);\n    }\n\n    if (pressed.length < bestCount ||\n        (pressed.length === bestCount && bestSolution !== null && lexSmaller(pressed, bestSolution))) {\n      bestCount = pressed.length;\n      bestSolution = pressed;\n    }\n  }\n\n  return bestSolution!;\n}\n\nfunction solveToggleMITM(\n  matrix: number[][],\n  pivotCol: number[],\n  _pivotRow: number[],\n  freeVars: number[],\n  numButtons: number,\n  rank: number\n): number[] {\n  // Meet in the middle: split free variables into two halves.\n  // For each half, compute the \"effect\" on pivot variables and the weight.\n  // Then combine the two halves to find the minimum total weight.\n\n  const numFree = freeVars.length;\n  const halfA = Math.floor(numFree / 2);\n  const halfB = numFree - halfA;\n\n  // For each pivot variable i, we need: pivot[i] = base[i] XOR (sum of matrix[i][freeVars[j]] * free[j])\n  // where base[i] = matrix[i][numButtons]\n\n  // Precompute: for each free var, which pivot vars does it affect?\n  // Effect of free vars on pivot vars can be represented as a bitmask over pivot vars.\n\n  // Compute base solution (all free = 0)\n  const baseSolution = new Array(numButtons).fill(0);\n  for (let i = rank - 1; i >= 0; i--) {\n    baseSolution[pivotCol[i]] = matrix[i][numButtons];\n  }\n\n  // For each free variable, compute which pivot variables it flips\n  const freeEffectOnPivots: number[][] = []; // for each free var, list of pivot indices it affects\n  for (let fi = 0; fi < numFree; fi++) {\n    const fv = freeVars[fi];\n    const affected: number[] = [];\n    for (let i = 0; i < rank; i++) {\n      if (matrix[i][fv] === 1) {\n        affected.push(i);\n      }\n    }\n    freeEffectOnPivots.push(affected);\n  }\n\n  // Compute weight of a solution given free var assignments\n  // Weight = number of 1s in the solution\n  // Each free var set to 1 adds 1 to weight\n  // Each pivot var is base XOR effects of set free vars\n\n  // For MITM, we compute partial effects from each half\n  // and then combine. But the \"weight\" function is complex (Hamming weight).\n\n  // Alternative approach for MITM:\n  // Represent effect of first half as a vector, store in map.\n  // For each assignment of second half, compute what we need from first half\n  // and look up in map.\n\n  // Actually, for GF(2) with up to 40 free vars, we can use a different approach:\n  // Use the fact that we want minimum Hamming weight solution.\n  // Represent each solution as a vector and use meet-in-the-middle on weights.\n\n  // Simpler MITM: enumerate first half (2^20 max), for each compute the\n  // resulting partial state. Then enumerate second half and combine.\n\n  // State: for each pivot var, we track if it's been flipped from base.\n  // Use BigInt as bitmask for pivot var flips.\n\n  const freeVarsA = freeVars.slice(0, halfA);\n  const freeVarsB = freeVars.slice(halfA);\n\n  // For first half: map from pivot-flip-state -> {minWeight, bestMask}\n  // pivot-flip-state: which pivot vars have been flipped\n  // We want to find: for each pivot state from A, the minimum weight assignment\n\n  type HalfEntry = { weight: number; freeAssignment: number; pivotFlips: string };\n\n  // Build map for first half\n  const mapA = new Map<string, HalfEntry[]>();\n  const sizeA = 1 << halfA;\n\n  for (let mask = 0; mask < sizeA; mask++) {\n    // Compute pivot flips and weight contribution\n    let weight = popcount(mask); // weight from free vars themselves\n    const pivotFlipList: number[] = [];\n\n    for (let i = 0; i < halfA; i++) {\n      if ((mask >> i) & 1) {\n        for (const pi of freeEffectOnPivots[i]) {\n          pivotFlipList.push(pi);\n        }\n      }\n    }\n\n    // Convert pivot flips to a state (XOR - each pivot var flipped odd times)\n    const pivotFlipState = new Uint8Array(rank);\n    for (const pi of pivotFlipList) {\n      pivotFlipState[pi] ^= 1;\n    }\n\n    const key = pivotFlipState.join('');\n\n    const entry: HalfEntry = { weight, freeAssignment: mask, pivotFlips: key };\n    const existing = mapA.get(key);\n    if (existing) {\n      existing.push(entry);\n    } else {\n      mapA.set(key, [entry]);\n    }\n  }\n\n  // For each key in mapA, keep only the minimum weight entry (and lex smallest among ties)\n  const bestMapA = new Map<string, HalfEntry>();\n  for (const [key, entries] of mapA) {\n    let best = entries[0];\n    for (let i = 1; i < entries.length; i++) {\n      if (entries[i].weight < best.weight) {\n        best = entries[i];\n      }\n    }\n    bestMapA.set(key, best);\n  }\n\n  // Enumerate second half and combine\n  const sizeB = 1 << halfB;\n  let bestTotal = Infinity;\n  let bestSolution: number[] | null = null;\n\n  for (let maskB = 0; maskB < sizeB; maskB++) {\n    let weightB = popcount(maskB);\n    const pivotFlipListB: number[] = [];\n\n    for (let i = 0; i < halfB; i++) {\n      if ((maskB >> i) & 1) {\n        for (const pi of freeEffectOnPivots[halfA + i]) {\n          pivotFlipListB.push(pi);\n        }\n      }\n    }\n\n    const pivotFlipStateB = new Uint8Array(rank);\n    for (const pi of pivotFlipListB) {\n      pivotFlipStateB[pi] ^= 1;\n    }\n\n    // We need the combined pivot state to result in minimum total weight\n    // Combined pivot flips = stateA XOR stateB\n    // Final pivot var i = base[i] XOR combinedFlip[i]\n    // Weight from pivots = number of pivot vars that are 1\n\n    // For each possible stateA, total pivot weight depends on stateA XOR stateB\n    // We want to minimize: weightA + weightB + pivotWeight(stateA XOR stateB)\n    // where pivotWeight = count of pivot vars that are 1 after flipping\n\n    // Base pivot weight = number of pivot vars that are 1 in base solution\n    // Flipping a pivot var toggles its contribution\n\n    // For minimum total weight, we'd need to try all stateA entries.\n    // But that defeats the purpose of MITM.\n\n    // Better approach: compute what stateA we NEED to achieve minimum pivot weight.\n    // For each pivot var, we want it to be 0 (contributes 0 to weight).\n    // So we want: base[i] XOR stateA[i] XOR stateB[i] = 0\n    //          => stateA[i] = base[i] XOR stateB[i]\n\n    // The \"ideal\" stateA is determined. Look it up in the map.\n    // But it might not exist. We need to handle that.\n\n    // Compute ideal stateA\n    const idealStateA = new Uint8Array(rank);\n    for (let i = 0; i < rank; i++) {\n      idealStateA[i] = baseSolution[pivotCol[i]] ^ pivotFlipStateB[i];\n    }\n    const idealKey = idealStateA.join('');\n\n    // Also compute weight for \"close\" matches? For exact MITM, we'd only check exact match.\n    // But the optimal solution might not zero out all pivots. It depends on the trade-off\n    // between free var weight and pivot weight.\n\n    // For a complete solution, we need to consider all possible stateA entries.\n    // But that's what we're trying to avoid.\n\n    // Compromise: check ideal match and also scan through all entries.\n    // Since mapA has at most 2^20 entries, scanning is expensive for 2^20 * 2^20 = 2^40.\n\n    // Better MITM strategy: group by pivot weight contribution.\n    // For each maskB, compute the pivot base contribution with stateB applied.\n    // Then we want stateA to flip as many \"1\" pivots to \"0\" as possible.\n\n    // Actually, let me use a different MITM approach:\n    // Just check the ideal stateA (which makes all pivots 0):\n\n    const entryA = bestMapA.get(idealKey);\n    if (entryA) {\n      const totalWeight = entryA.weight + weightB; // pivots all 0\n      if (totalWeight < bestTotal) {\n        bestTotal = totalWeight;\n        bestSolution = reconstructToggleSolution(\n          entryA.freeAssignment, maskB, freeVarsA, freeVarsB,\n          matrix, pivotCol, numButtons, rank\n        );\n      } else if (totalWeight === bestTotal && bestSolution !== null) {\n        const candidate = reconstructToggleSolution(\n          entryA.freeAssignment, maskB, freeVarsA, freeVarsB,\n          matrix, pivotCol, numButtons, rank\n        );\n        if (lexSmaller(candidate, bestSolution)) {\n          bestSolution = candidate;\n        }\n      }\n    }\n\n    // Also check: what if some pivots are 1? Then stateA differs from ideal.\n    // For each bit difference from ideal, we pay +1 for pivot but might save on free var weight.\n    // This makes the search harder. Let's also check a few nearby states.\n\n    // For correctness, also check all entries in mapA against this maskB\n    // (this is O(|mapA| * sizeB) which could be large)\n    // Only do this if map is small enough\n    if (bestMapA.size <= 100000) {\n      const pivotBaseWithB = new Uint8Array(rank);\n      for (let i = 0; i < rank; i++) {\n        pivotBaseWithB[i] = baseSolution[pivotCol[i]] ^ pivotFlipStateB[i];\n      }\n\n      for (const [key, entryACandidate] of bestMapA) {\n        // Compute pivot weight with this combo\n        let pivotWeight = 0;\n        for (let i = 0; i < rank; i++) {\n          const stateAi = parseInt(key[i]);\n          pivotWeight += pivotBaseWithB[i] ^ stateAi;\n        }\n\n        const totalWeight = entryACandidate.weight + weightB + pivotWeight;\n        if (totalWeight < bestTotal) {\n          bestTotal = totalWeight;\n          bestSolution = reconstructToggleSolution(\n            entryACandidate.freeAssignment, maskB, freeVarsA, freeVarsB,\n            matrix, pivotCol, numButtons, rank\n          );\n        } else if (totalWeight === bestTotal && bestSolution !== null) {\n          const candidate = reconstructToggleSolution(\n            entryACandidate.freeAssignment, maskB, freeVarsA, freeVarsB,\n            matrix, pivotCol, numButtons, rank\n          );\n          if (lexSmaller(candidate, bestSolution)) {\n            bestSolution = candidate;\n          }\n        }\n      }\n    }\n  }\n\n  return bestSolution!;\n}\n\nfunction reconstructToggleSolution(\n  maskA: number, maskB: number,\n  freeVarsA: number[], freeVarsB: number[],\n  matrix: number[][], pivotCol: number[],\n  numButtons: number, rank: number\n): number[] {\n  const solution = new Array(numButtons).fill(0);\n\n  for (let i = 0; i < freeVarsA.length; i++) {\n    solution[freeVarsA[i]] = (maskA >> i) & 1;\n  }\n  for (let i = 0; i < freeVarsB.length; i++) {\n    solution[freeVarsB[i]] = (maskB >> i) & 1;\n  }\n\n  for (let i = rank - 1; i >= 0; i--) {\n    const pc = pivotCol[i];\n    let val = matrix[i][numButtons];\n    for (let c = 0; c < numButtons; c++) {\n      if (c !== pc) {\n        val ^= matrix[i][c] & solution[c];\n      }\n    }\n    solution[pc] = val;\n  }\n\n  const pressed: number[] = [];\n  for (let i = 0; i < numButtons; i++) {\n    if (solution[i] === 1) pressed.push(i);\n  }\n  return pressed;\n}\n\nfunction popcount(n: number): number {\n  let count = 0;\n  while (n) {\n    count += n & 1;\n    n >>= 1;\n  }\n  return count;\n}\n\nfunction lexSmaller(a: number[], b: number[]): boolean {\n  for (let i = 0; i < Math.min(a.length, b.length); i++) {\n    if (a[i] < b[i]) return true;\n    if (a[i] > b[i]) return false;\n  }\n  return a.length < b.length;\n}\n\n/**\n * Solve counter puzzle over GF(p) using Gaussian elimination.\n * Returns array of press counts, or null if no solution.\n */\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const numCounters = lights.length;\n  const numButtons = buttons.length;\n\n  // Build augmented matrix over GF(p): rows = counters, cols = buttons + 1\n  const matrix: number[][] = [];\n  for (let i = 0; i < numCounters; i++) {\n    const row = new Array(numButtons + 1).fill(0);\n    for (let j = 0; j < numButtons; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    row[numButtons] = ((lights[i] % modulus) + modulus) % modulus;\n    matrix.push(row);\n  }\n\n  // Gaussian elimination over GF(p)\n  const pivotCol: number[] = [];\n  const pivotRow: number[] = new Array(numButtons).fill(-1);\n  let row = 0;\n\n  for (let col = 0; col < numButtons && row < numCounters; col++) {\n    let found = -1;\n    for (let r = row; r < numCounters; r++) {\n      if (matrix[r][col] !== 0) {\n    