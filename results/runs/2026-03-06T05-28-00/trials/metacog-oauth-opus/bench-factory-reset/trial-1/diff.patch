[][],\n   558→  pivotCol: number[],\n   559→  freeVars: number[],\n   560→  numButtons: number,\n   561→  modulus: number,\n   562→  rank: number\n   563→): number[] {\n   564→  // Meet-in-the-middle approach for counter puzzle over GF(p).\n   565→  // Split free variables into two halves.\n   566→  const numFree = freeVars.length;\n   567→  const halfA = Math.min(Math.floor(numFree / 2), 4); // keep first half small\n   568→  const halfB = numFree - halfA;\n   569→\n   570→  const freeVarsA = freeVars.slice(0, halfA);\n   571→  const freeVarsB = freeVars.slice(halfA);\n   572→\n   573→  const sizeA = Math.pow(modulus, halfA);\n   574→  const sizeB = Math.pow(modulus, halfB);\n   575→\n   576→  // If second half is still too large, fall back to coordinate descent\n   577→  if (sizeB > 5_000_000) {\n   578→    return solveCounterCoordinateDescent(matrix, pivotCol, freeVars, numButtons, modulus, rank);\n   579→  }\n   580→\n   581→  // For first half, compute partial effect on each pivot variable\n   582→  // pivot[i] = (base[i] - sum_j(coeff[i][j] * free[j])) mod p\n   583→  // Split into contribution from A and B:\n   584→  // pivot[i] = (base[i] - sumA - sumB) mod p\n   585→\n   586→  // Precompute coefficients for each half\n   587→  // For pivot row i, coefficient of free var j is matrix[i][freeVars[j]]\n   588→\n   589→  // For half A: enumerate all assignments, compute the partial contribution\n   590→  // partialA[i] = sum over A of (matrix[i][freeVarsA[j]] * freeValuesA[j]) mod p\n   591→  // Store: map from (partialA vector) -> best (weightA, freeAssignmentA)\n   592→\n   593→  // For half B: enumerate, compute partialB, then for the \"matching\" partialA, combine.\n   594→\n   595→  // The \"match\" condition: for minimum total weight, we'd need\n   596→  // pivot[i] = (base[i] - partialA[i] - partialB[i]) mod p\n   597→  // to be small (sum of pivots contributes to total weight)\n   598→\n   599→  // This is harder than the GF(2) case because we can't just