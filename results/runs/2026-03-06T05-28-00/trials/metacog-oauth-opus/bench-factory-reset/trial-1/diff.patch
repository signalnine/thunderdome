(numFree).fill(0)];\n\n  // Also try starting from each free var at each value (random restarts)\n  for (let fi = 0; fi < Math.min(numFree, 10); fi++) {\n    for (let v = 1; v < Math.min(modulus, 5); v++) {\n      const start = new Array(numFree).fill(0);\n      start[fi] = v;\n      starts.push(start);\n    }\n  }\n\n  for (const startValues of starts) {\n    const freeValues = [...startValues];\n\n    let currentSolution = computeSolutionMod(matrix, pivotCol, freeVars, freeValues, numButtons, modulus, rank);\n    let currentTotal = currentSolution.reduce((a, b) => a + b, 0);\n\n    let improved = true;\n    while (improved) {\n      improved = false;\n      for (let fi = 0; fi < numFree; fi++) {\n        const savedVal = freeValues[fi];\n        let bestVal = savedVal;\n        let bestLocalTotal = currentTotal;\n        let bestLocalSol = currentSolution;\n\n        for (let v = 0; v < modulus; v++) {\n          if (v === savedVal) continue;\n          freeValues[fi] = v;\n          const sol = computeSolutionMod(matrix, pivotCol, freeVars, freeValues, numButtons, modulus, rank);\n          const total = sol.reduce((a, b) => a + b, 0);\n          if (total < bestLocalTotal || (total === bestLocalTotal && lexSmallerArr(sol, bestLocalSol))) {\n            bestLocalTotal = total;\n            bestVal = v;\n            bestLocalSol = sol;\n          }\n        }\n\n        freeValues[fi] = bestVal;\n        if (bestLocalTotal < currentTotal || (bestLocalTotal === currentTotal && lexSmallerArr(bestLocalSol, currentSolution))) {\n          currentTotal = bestLocalTotal;\n          currentSolution = bestLocalSol;\n          improved = true;\n        }\n      }\n    }\n\n    if (currentTotal < bestTotal || (currentTotal === bestTotal && bestSolution !== null && lexSmallerArr(currentSolution, bestSolution))) {\n      bestTotal = currentTotal;\n      bestSolution = currentSolution;\n    }\n  }\n\n  return bestSolution!;\n}\n\nfunction computeSolutionMod(\n  matrix: number[