@@ -0,0 +1,504 @@
+interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+/**
+ * Solve toggle puzzle over GF(2) using Gaussian elimination.
+ * Returns minimum set of button indices (sorted ascending), or null if no solution.
+ */
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const numLights = target.length;
+  const numButtons = buttons.length;
+
+  // Build augmented matrix over GF(2): rows = lights, cols = buttons + 1 (augmented column)
+  const matrix: number[][] = [];
+  for (let i = 0; i < numLights; i++) {
+    const row = new Array(numButtons + 1).fill(0);
+    for (let j = 0; j < numButtons; j++) {
+      if (buttons[j].includes(i)) {
+        row[j] = 1;
+      }
+    }
+    row[numButtons] = target[i] ? 1 : 0;
+    matrix.push(row);
+  }
+
+  // Gaussian elimination over GF(2) to reduced row echelon form
+  const pivotCol: number[] = [];
+  const pivotRow: number[] = new Array(numButtons).fill(-1);
+  let row = 0;
+
+  for (let col = 0; col < numButtons && row < numLights; col++) {
+    let found = -1;
+    for (let r = row; r < numLights; r++) {
+      if (matrix[r][col] === 1) {
+        found = r;
+        break;
+      }
+    }
+    if (found === -1) continue;
+
+    [matrix[row], matrix[found]] = [matrix[found], matrix[row]];
+
+    for (let r = 0; r < numLights; r++) {
+      if (r !== row && matrix[r][col] === 1) {
+        for (let c = 0; c < numButtons + 1; c++) {
+          matrix[r][c] ^= matrix[row][c];
+        }
+      }
+    }
+
+    pivotCol.push(col);
+    pivotRow[col] = row;
+    row++;
+  }
+
+  const rank = pivotCol.length;
+
+  // Check for inconsistency
+  for (let r = rank; r < numLights; r++) {
+    if (matrix[r][numButtons] === 1) {
+      return null;
+    }
+  }
+
+  // Identify free variables
+  const freeVars: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (pivotRow[col] === -1) {
+      freeVars.push(col);
+    }
+  }
+
+  const numFree = freeVars.length;
+
+  if (numFree <= 24) {
+    return solveToggleEnumerate(matrix, pivotCol, freeVars, numButtons, rank);
+  } else {
+    // For very large number of free variables, use branch-and-bound
+    return solveToggleBranchBound(matrix, pivotCol, freeVars, numButtons, rank);
+  }
+}
+
+function solveToggleSolution(
+  matrix: number[][],
+  pivotCol: number[],
+  freeVars: number[],
+  freeAssignment: number,
+  numButtons: number,
+  rank: number
+): number[] {
+  const solution = new Array(numButtons).fill(0);
+  const numFree = freeVars.length;
+
+  for (let i = 0; i < numFree; i++) {
+    solution[freeVars[i]] = (freeAssignment >> i) & 1;
+  }
+
+  for (let i = rank - 1; i >= 0; i--) {
+    const pc = pivotCol[i];
+    let val = matrix[i][numButtons];
+    for (let c = 0; c < numButtons; c++) {
+      if (c !== pc) {
+        val ^= matrix[i][c] & solution[c];
+      }
+    }
+    solution[pc] = val;
+  }
+
+  return solution;
+}
+
+function solutionToPressed(solution: number[]): number[] {
+  const pressed: number[] = [];
+  for (let i = 0; i < solution.length; i++) {
+    if (solution[i] === 1) pressed.push(i);
+  }
+  return pressed;
+}
+
+function solveToggleEnumerate(
+  matrix: number[][],
+  pivotCol: number[],
+  freeVars: number[],
+  numButtons: number,
+  rank: number
+): number[] {
+  const numFree = freeVars.length;
+  let bestPressed: number[] | null = null;
+  let bestCount = Infinity;
+
+  const totalCombinations = 1 << numFree;
+  for (let mask = 0; mask < totalCombinations; mask++) {
+    const solution = solveToggleSolution(matrix, pivotCol, freeVars, mask, numButtons, rank);
+    const pressed = solutionToPressed(solution);
+
+    if (pressed.length < bestCount ||
+        (pressed.length === bestCount && bestPressed !== null && lexSmaller(pressed, bestPressed))) {
+      bestCount = pressed.length;
+      bestPressed = pressed;
+    }
+  }
+
+  return bestPressed!;
+}
+
+function solveToggleBranchBound(
+  matrix: number[][],
+  pivotCol: number[],
+  freeVars: number[],
+  numButtons: number,
+  rank: number
+): number[] {
+  // Branch and bound over free variable assignments.
+  // For each partial assignment, compute a lower bound on the Hamming weight.
+
+  const numFree = freeVars.length;
+
+  // Precompute: base solution (all free vars = 0) and effect vectors
+  const baseSol = solveToggleSolution(matrix, pivotCol, freeVars, 0, numButtons, rank);
+
+  // Effect of each free variable on the full solution
+  // Compute directly to avoid 1 << fi overflow for fi >= 32
+  const effects: number[][] = [];
+  for (let fi = 0; fi < numFree; fi++) {
+    const solution = new Array(numButtons).fill(0);
+    solution[freeVars[fi]] = 1;
+
+    for (let i = rank - 1; i >= 0; i--) {
+      const pc = pivotCol[i];
+      let val = matrix[i][numButtons];
+      for (let c = 0; c < numButtons; c++) {
+        if (c !== pc) {
+          val ^= matrix[i][c] & solution[c];
+        }
+      }
+      solution[pc] = val;
+    }
+
+    const eff = new Array(numButtons);
+    for (let b = 0; b < numButtons; b++) {
+      eff[b] = baseSol[b] ^ solution[b];
+    }
+    effects.push(eff);
+  }
+
+  let bestCount = Infinity;
+  let bestPressed: number[] | null = null;
+
+  // Start with base solution (all free vars = 0)
+  const basePressed = solutionToPressed(baseSol);
+  bestCount = basePressed.length;
+  bestPressed = basePressed;
+
+  // Simple DFS with pruning
+  function dfs(fi: number, currentSol: number[], currentWeight: number): void {
+    if (fi === numFree) {
+      const pressed = solutionToPressed(currentSol);
+      if (pressed.length < bestCount ||
+          (pressed.length === bestCount && bestPressed !== null && lexSmaller(pressed, bestPressed))) {
+        bestCount = pressed.length;
+        bestPressed = pressed;
+      }
+      return;
+    }
+
+    // Lower bound: current weight can only change by the remaining free vars
+    // Each remaining free var can change weight by at most its effect's weight
+    // But this is a loose bound. At minimum, current non-zero entries stay unless flipped.
+    if (currentWeight >= bestCount + numFree - fi) {
+      // Even if all remaining free vars reduce weight, can't beat best
+      // (This is a very loose bound)
+    }
+
+    // Try not setting this free var (keep 0)
+    if (currentWeight < bestCount || (currentWeight === bestCount)) {
+      dfs(fi + 1, currentSol, currentWeight);
+    }
+
+    // Try setting this free var (set to 1)
+    const newSol = [...currentSol];
+    let newWeight = 0;
+    for (let b = 0; b < numButtons; b++) {
+      newSol[b] ^= effects[fi][b];
+      if (newSol[b]) newWeight++;
+    }
+
+    if (newWeight < bestCount || (newWeight === bestCount)) {
+      dfs(fi + 1, newSol, newWeight);
+    }
+  }
+
+  let initialWeight = 0;
+  for (let b = 0; b < numButtons; b++) {
+    if (baseSol[b]) initialWeight++;
+  }
+
+  dfs(0, [...baseSol], initialWeight);
+
+  return bestPressed!;
+}
+
+function lexSmaller(a: number[], b: number[]): boolean {
+  for (let i = 0; i < Math.min(a.length, b.length); i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return a.length < b.length;
+}
+
+/**
+ * Solve counter puzzle over GF(p) using Gaussian elimination.
+ * Returns array of press counts, or null if no solution.
+ */
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numCounters = lights.length;
+  const numButtons = buttons.length;
+
+  // Build augmented matrix over GF(p): rows = counters, cols = buttons + 1
+  const matrix: number[][] = [];
+  for (let i = 0; i < numCounters; i++) {
+    const row = new Array(numButtons + 1).fill(0);
+    for (let j = 0; j < numButtons; j++) {
+      if (buttons[j].includes(i)) {
+        row[j] = 1;
+      }
+    }
+    row[numButtons] = ((lights[i] % modulus) + modulus) % modulus;
+    matrix.push(row);
+  }
+
+  // Gaussian elimination over GF(p)
+  const pivotCol: number[] = [];
+  const pivotRow: number[] = new Array(numButtons).fill(-1);
+  let row = 0;
+
+  for (let col = 0; col < numButtons && row < numCounters; col++) {
+    let found = -1;
+    for (let r = row; r < numCounters; r++) {
+      if (matrix[r][col] !== 0) {
+        found = r;
+        break;
+      }
+    }
+    if (found === -1) continue;
+
+    [matrix[row], matrix[found]] = [matrix[found], matrix[row]];
+
+    const inv = modInverse(matrix[row][col], modulus);
+    for (let c = 0; c < numButtons + 1; c++) {
+      matrix[row][c] = (matrix[row][c] * inv) % modulus;
+    }
+
+    for (let r = 0; r < numCounters; r++) {
+      if (r !== row && matrix[r][col] !== 0) {
+        const factor = matrix[r][col];
+        for (let c = 0; c < numButtons + 1; c++) {
+          matrix[r][c] = ((matrix[r][c] - factor * matrix[row][c]) % modulus + modulus) % modulus;
+        }
+      }
+    }
+
+    pivotCol.push(col);
+    pivotRow[col] = row;
+    row++;
+  }
+
+  const rank = pivotCol.length;
+
+  // Check for inconsistency
+  for (let r = rank; r < numCounters; r++) {
+    if (matrix[r][numButtons] !== 0) {
+      return null;
+    }
+  }
+
+  // Identify free variables
+  const freeVars: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (pivotRow[col] === -1) {
+      freeVars.push(col);
+    }
+  }
+
+  const numFree = freeVars.length;
+  const totalCombinations = Math.pow(modulus, numFree);
+
+  if (numFree === 0 || totalCombinations <= 5_000_000) {
+    return solveCounterEnumerate(matrix, pivotCol, freeVars, numButtons, modulus, rank);
+  } else {
+    return solveCounterCoordinateDescent(matrix, pivotCol, freeVars, numButtons, modulus, rank);
+  }
+}
+
+function solveCounterEnumerate(
+  matrix: number[][],
+  pivotCol: number[],
+  freeVars: number[],
+  numButtons: number,
+  modulus: number,
+  rank: number
+): number[] {
+  const numFree = freeVars.length;
+  const totalCombinations = Math.pow(modulus, numFree);
+  let bestSolution: number[] | null = null;
+  let bestTotal = Infinity;
+
+  const freeValues = new Array(numFree).fill(0);
+
+  for (let iter = 0; iter < totalCombinations; iter++) {
+    const solution = computeSolutionMod(matrix, pivotCol, freeVars, freeValues, numButtons, modulus, rank);
+
+    let total = 0;
+    for (let i = 0; i < numButtons; i++) {
+      total += solution[i];
+    }
+
+    if (total < bestTotal ||
+        (total === bestTotal && bestSolution !== null && lexSmallerArr(solution, bestSolution))) {
+      bestTotal = total;
+      bestSolution = [...solution];
+    }
+
+    incrementCounter(freeValues, modulus);
+  }
+
+  return bestSolution!;
+}
+
+function solveCounterCoordinateDescent(
+  matrix: number[][],
+  pivotCol: number[],
+  freeVars: number[],
+  numButtons: number,
+  modulus: number,
+  rank: number
+): number[] {
+  const numFree = freeVars.length;
+
+  let bestSolution: number[] | null = null;
+  let bestTotal = Infinity;
+
+  // Try all starting points where one free var is set to each possible value
+  const starts: number[][] = [new Array(numFree).fill(0)];
+  for (let fi = 0; fi < numFree; fi++) {
+    for (let v = 1; v < modulus; v++) {
+      const start = new Array(numFree).fill(0);
+      start[fi] = v;
+      starts.push(start);
+    }
+  }
+
+  for (const startValues of starts) {
+    const freeValues = [...startValues];
+
+    let currentSolution = computeSolutionMod(matrix, pivotCol, freeVars, freeValues, numButtons, modulus, rank);
+    let currentTotal = currentSolution.reduce((a, b) => a + b, 0);
+
+    let improved = true;
+    while (improved) {
+      improved = false;
+      for (let fi = 0; fi < numFree; fi++) {
+        const savedVal = freeValues[fi];
+        let bestVal = savedVal;
+        let bestLocalTotal = currentTotal;
+        let bestLocalSol = currentSolution;
+
+        for (let v = 0; v < modulus; v++) {
+          if (v === savedVal) continue;
+          freeValues[fi] = v;
+          const sol = computeSolutionMod(matrix, pivotCol, freeVars, freeValues, numButtons, modulus, rank);
+          const total = sol.reduce((a, b) => a + b, 0);
+          if (total < bestLocalTotal || (total === bestLocalTotal && lexSmallerArr(sol, bestLocalSol))) {
+            bestLocalTotal = total;
+            bestVal = v;
+            bestLocalSol = sol;
+          }
+        }
+
+        freeValues[fi] = bestVal;
+        if (bestLocalTotal < currentTotal || (bestLocalTotal === currentTotal && lexSmallerArr(bestLocalSol, currentSolution))) {
+          currentTotal = bestLocalTotal;
+          currentSolution = bestLocalSol;
+          improved = true;
+        }
+      }
+    }
+
+    if (currentTotal < bestTotal || (currentTotal === bestTotal && bestSolution !== null && lexSmallerArr(currentSolution, bestSolution))) {
+      bestTotal = currentTotal;
+      bestSolution = currentSolution;
+    }
+  }
+
+  return bestSolution!;
+}
+
+function computeSolutionMod(
+  matrix: number[][],
+  pivotCol: number[],
+  freeVars: number[],
+  freeValues: number[],
+  numButtons: number,
+  modulus: number,
+  rank: number
+): number[] {
+  const solution = new Array(numButtons).fill(0);
+
+  for (let i = 0; i < freeVars.length; i++) {
+    solution[freeVars[i]] = freeValues[i];
+  }
+
+  for (let i = rank - 1; i >= 0; i--) {
+    const pc = pivotCol[i];
+    let val = matrix[i][numButtons];
+    for (let c = 0; c < numButtons; c++) {
+      if (c !== pc) {
+        val = ((val - matrix[i][c] * solution[c]) % modulus + modulus) % modulus;
+      }
+    }
+    solution[pc] = val;
+  }
+
+  return solution;
+}
+
+function incrementCounter(counter: number[], base: number): void {
+  for (let i = 0; i < counter.length; i++) {
+    counter[i]++;
+    if (counter[i] < base) return;
+    counter[i] = 0;
+  }
+}
+
+function lexSmallerArr(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return false;
+}
+
+function modInverse(a: number, p: number): number {
+  a = ((a % p) + p) % p;
+  return modPow(a, p - 2, p);
+}
+
+function modPow(base: number, exp: number, mod: number): number {
+  let result = 1;
+  base = base % mod;
+  while (exp > 0) {
+    if (exp & 1) {
+      result = (result * base) % mod;
+    }
+    exp >>= 1;
+    base = (base * base) % mod;
+  }
+  return result;
+}
