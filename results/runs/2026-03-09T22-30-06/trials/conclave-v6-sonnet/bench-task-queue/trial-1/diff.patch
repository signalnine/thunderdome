+{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_011mjNaeE489sHdDXK376rSo","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01XUEMF3zEKkDNcaDFtkyUDS","name":"Write","input":{"file_path":"/workspace/src/task-queue.test.ts","content":"import { describe, it, expect, vi, beforeEach } from 'vitest';\nimport { TaskQueueSystem } from './TaskQueueSystem.js';\n\ndescribe('Phase 1: Basic FIFO Queue', () => {\n  let system: TaskQueueSystem;\n\n  beforeEach(() => {\n    system = new TaskQueueSystem();\n  });\n\n  it('adds a task and returns a task object with id, status, createdAt', () => {\n    const task = system.addTask({ msg: 'hello' });\n    expect(task.id).toBeTruthy();\n    expect(task.status).toBe('pending');\n    expect(task.createdAt).toBeInstanceOf(Date);\n    expect(task.payload).toEqual({ msg: 'hello' });\n  });\n\n  it('task ids are unique', () => {\n    const t1 = system.addTask('a');\n    const t2 = system.addTask('b');\n    expect(t1.id).not.toBe(t2.id);\n  });\n\n  it('getNextTask returns tasks in FIFO order', () => {\n    const t1 = system.addTask('first');\n    const t2 = system.addTask('second');\n    const t3 = system.addTask('third');\n\n    expect(system.getNextTask()?.id).toBe(t1.id);\n    expect(system.getNextTask()?.id).toBe(t2.id);\n    expect(system.getNextTask()?.id).toBe(t3.id);\n  });\n\n  it('getNextTask transitions task to processing', () => {\n    system.addTask('a');\n    const task = system.getNextTask();\n    expect(task?.status).toBe('processing');\n  });\n\n  it('getNextTask returns null when queue is empty', () => {\n    expect(system.getNextTask()).toBeNull();\n  });\n\n  it('getPendingCount returns correct count', () => {\n    system.addTask('a');\n    system.addTask('b');\n    expect(system.getPendingCount()).toBe(2);\n    system.getNextTask();\n    expect(system.getPendingCount()).toBe(1);\n  });\n});\n\ndescribe('Phase 2: Named Queues', () => {\n  let system: TaskQueueSystem;\n\n  beforeEach(() => {\n    system = new TaskQueueSystem();\n  });\n\n  it('tasks go to the default queue when no name given', () => {\n    system.addTask('default-task');\n    expect(system.listQueues()).toContain('default');\n  });\n\n  it('tasks go to named queues', () => {\n    system.addTask('a', { queue: 'emails' });\n    system.addTask('b', { queue: 'reports' });\n    expect(system.listQueues()).toContain('emails');\n    expect(system.listQueues()).toContain('reports');\n  });\n\n  it('named queues are independent', () => {\n    const t1 = system.addTask('emails-task', { queue: 'emails' });\n    system.addTask('reports-task', { queue: 'reports' });\n\n    const next = system.getNextTask('emails');\n    expect(next?.id).toBe(t1.id);\n    expect(system.getNextTask('reports')?.payload).toBe('reports-task');\n  });\n\n  it('retrieving from non-existent queue returns null', () => {\n    expect(system.getNextTask('no-such-queue')).toBeNull();\n  });\n\n  it('getPendingCount from non-existent queue returns 0', () => {\n    expect(system.getPendingCount('no-such-queue')).toBe(0);\n  });\n\n  it('queues are created implicitly when a task is first added', () => {\n    expect(system.listQueues()).toHaveLength(0);\n    system.addTask('a', { queue: 'newqueue' });\n    expect(system.listQueues()).toContain('newqueue');\n  });\n});\n\ndescribe('Phase 3: Priority', () => {\n  let system: TaskQueueSystem;\n\n  beforeEach(() => {\n    system = new TaskQueueSystem();\n  });\n\n  it('higher-priority tasks (lower number) come first', () => {\n    system.addTask('low', { priority: 8 });\n    system.addTask('high', { priority: 2 });\n    system.addTask('mid', { priority: 5 });\n\n    expect(system.getNextTask()?.payload).toBe('high');\n    expect(system.getNextTask()?.payload).toBe('mid');\n    expect(system.getNextTask()?.payload).toBe('low');\n  });\n\n  it('same-priority tasks are in FIFO order', () => {\n    system.addTask('first', { priority: 3 });\n    system.addTask('second', { priority: 3 });\n    system.addTask('third', { priority: 3 });\n\n    expect(system.getNextTask()?.payload).toBe('first');\n    expect(system.getNextTask()?.payload).toBe('second');\n    expect(system.getNextTask()?.payload).toBe('third');\n  });\n\n  it('default priority is 5', () => {\n    const task = system.addTask('default-priority');\n    expect(task.priority).toBe(5);\n  });\n\n  it('rejects invalid priority values', () => {\n    expect(() => system.addTask('bad', { priority: 0 })).toThrow();\n    expect(() => system.addTask('bad', { priority: 11 })).toThrow();\n    expect(() => system.addTask('bad', { priority: -1 })).toThrow();\n  });\n\n  it('task object exposes priority', () => {\n    const task = system.addTask('a', { priority: 7 });\n    expect(task.priority).toBe(7);\n  });\n});\n\ndescribe('Phase 4: Delayed Tasks', () => {\n  let system: TaskQueueSystem;\n\n  beforeEach(() => {\n    system = new TaskQueueSystem();\n    vi.useFakeTimers();\n  });\n\n  it('delayed tasks are not returned before their time', () => {\n    system.addTask('delayed', { delay: 5000 });\n    expect(system.getNextTask()).toBeNull();\n  });\n\n  it('delayed tasks become available after the delay', () => {\n    system.addTask('delayed', { delay: 1000 });\n    vi.advanceTimersByTime(1000);\n    const task = system.getNextTask();\n    expect(task?.payload).toBe('delayed');\n  });\n\n  it('non-delayed tasks are preferred over delayed tasks', () => {\n    system.addTask('delayed', { delay: 0 }); // added first but 0ms delay pushes availableAt slightly to future at same time\n    // Let's be explicit: add an immediate task second\n    const t1 = system.addTask('immediate');\n    vi.advanceTimersByTime(100);\n    system.addTask('delayed2', { delay: 5000 });\n\n    // immediate should come first\n    expect(system.getNextTask()?.id).toBe(t1.id);\n  });\n\n  it('availableAt field is set on task', () => {\n    const now = Date.now();\n    const task = system.addTask('delayed', { delay: 2000 });\n    expect(task.availableAt.getTime()).toBeGreaterThanOrEqual(now + 2000 - 50);\n  });\n\n  it('tasks can be scheduled at a specific future time', () => {\n    const future = new Date(Date.now() + 10000);\n    system.addTask('specific', { availableAt: future });\n    expect(system.getNextTask()).toBeNull();\n    vi.advanceTimersByTime(10001);\n    expect(system.getNextTask()?.payload).toBe('specific');\n  });\n\n  it('available delayed tasks are ordered by availableAt, then priority, then FIFO', () => {\n    const now = Date.now();\n    // Two tasks become available at the same time\n    const t1 = system.addTask('a', { availableAt: new Date(now + 1000), priority: 3 });\n    const t2 = system.addTask('b', { availableAt: new Date(now + 1000), priority: 1 });\n    vi.advanceTimersByTime(1001);\n\n    expect(system.getNextTask()?.id).toBe(t2.id); // priority 1 first\n    expect(system.getNextTask()?.id).toBe(t1.id); // priority 3 second\n  });\n});\n\ndescribe('Phase 5: Retry with Backoff', () => {\n  let system: TaskQueueSystem;\n\n  beforeEach(() => {\n    system = new TaskQueueSystem();\n    vi.useFakeTimers();\n  });\n\n  it('completeTask marks task as completed', () => {\n    system.addTask('a');\n    const t = system.getNextTask()!;\n    const completed = system.completeTask(t.id);\n    expect(completed.status).toBe('completed');\n  });\n\n  it('failTask with retries remaining schedules retry with backoff', () => {\n    system.addTask('a', { retry: { maxRetries: 3, baseDelay: 1000 } });\n    const t = system.getNextTask()!;\n    expect(t.attempts).toBe(1);\n\n    system.failTask(t.id, 'oops');\n    const retriedTask = system.getTask(t.id)!;\n    expect(retriedTask.status).toBe('pending');\n    // backoff = 1000 * 2^(1-1) = 1000ms\n    expect(retriedTask.availableAt.getTime()).toBeGreaterThanOrEqual(Date.now() + 900);\n  });\n\n  it('exponential backoff increases per attempt', () => {\n    system.addTask('a', { retry: { maxRetries: 3, baseDelay: 1000 } });\n\n    // Attempt 1\n    const t1 = system.getNextTask()!;\n    system.failTask(t1.id, 'fail');\n    vi.advanceTimersByTime(1001);\n\n    // Attempt 2\n    const t2 = system.getNextTask()!;\n    expect(t2.attempts).toBe(2);\n    system.failTask(t2.id, 'fail again');\n    // backoff = 1000 * 2^(2-1) = 2000ms\n    const task = system.getTask(t2.id)!;\n    expect(task.availableAt.getTime()).toBeGreaterThanOrEqual(Date.now() + 1900);\n  });\n\n  it('after max retries, task is in failed state', () => {\n    system.addTask('a', { retry: { maxRetries: 1, baseDelay: 100 } });\n\n    const t = system.getNextTask()!;\n    system.failTask(t.id, 'fail');\n    vi.advanceTimersByTime(200);\n\n    const t2 = system.getNextTask()!;\n    system.failTask(t2.id, 'fail again');\n\n    const finalTask = system.getDeadLetterTasks()[0];\n    expect(finalTask.status).toBe('failed');\n  });\n\n  it('retried tasks keep original queue and priority', () => {\n    system.addTask('a', { queue: 'myqueue', priority: 2, retry: { maxRetries: 2, baseDelay: 100 } });\n    const t = system.getNextTask('myqueue')!;\n    system.failTask(t.id, 'err');\n    vi.advanceTimersByTime(200);\n\n    const retried = system.getNextTask('myqueue')!;\n    expect(retried.queueName).toBe('myqueue');\n    expect(retried.priority).toBe(2);\n  });\n\n  it('tracks attempt count', () => {\n    system.addTask('a', { retry: { maxRetries: 3, baseDelay: 100 } });\n    const t1 = system.getNextTask()!;\n    expect(t1.attempts).toBe(1);\n    system.failTask(t1.id);\n    vi.advanceTimersByTime(200);\n\n    const t2 = system.getNextTask()!;\n    expect(t2.attempts).toBe(2);\n  });\n});\n\ndescribe('Phase 6: Dead Letter Queue', () => {\n  let system: TaskQueueSystem;\n\n  beforeEach(() => {\n    system = new TaskQueueSystem();\n    vi.useFakeTimers();\n  });\n\n  it('exhausted tasks move to dead letter queue', () => {\n    system.addTask('a', { retry: { maxRetries: 0 } });\n    const t = system.getNextTask()!;\n    system.failTask(t.id, 'permanent fail');\n\n    const dlq = system.getDeadLetterTasks();\n    expect(dlq).toHaveLength(1);\n    expect(dlq[0].status).toBe('failed');\n  });\n\n  it('dead-lettered tasks retain error info', () => {\n    system.addTask('a', { retry: { maxRetries: 0 } });\n    const t = system.getNextTask()!;\n    system.failTask(t.id, 'my error');\n\n    const dlq = system.getDeadLetterTasks();\n    expect(dlq[0].error).toBe('my error');\n  });\n\n  it('can requeue a dead-lettered task for fresh retries', () => {\n    system.addTask('a', { retry: { maxRetries: 0 } });\n    const t = system.getNextTask()!;\n    system.failTask(t.id, 'fail');\n\n    system.requeueDeadLetterTask(t.id);\n    const dlq = system.getDeadLetterTasks();\n    expect(dlq).toHaveLength(0);\n\n    // Task should be processable again\n    const retried = system.getNextTask()!;\n    expect(retried.id).toBe(t.id);\n    expect(retried.attempts).toBe(1);\n  });\n\n  it('clearDeadLetterQueue removes all dead-lettered tasks', () => {\n    system.addTask('a', { retry: { maxRetries: 0 } });\n    system.addTask('b', { retry: { maxRetries: 0 } });\n    system.failTask(system.getNextTask()!.id, 'f');\n    system.failTask(system.getNextTask()!.id, 'f');\n\n    system.clearDeadLetterQueue();\n    expect(system.getDeadLetterTasks()).toHaveLength(0);\n  });\n\n  it('each named queue has its own DLQ', () => {\n    system.addTask('a', { queue: 'q1', retry: { maxRetries: 0 } });\n    system.addTask('b', { queue: 'q2', retry: { maxRetries: 0 } });\n    system.failTask(system.getNextTask('q1')!.id, 'f');\n    system.failTask(system.getNextTask('q2')!.id, 'f');\n\n    expect(system.getDeadLetterTasks('q1')).toHaveLength(1);\n    expect(system.getDeadLetterTasks('q2')).toHaveLength(1);\n    system.clearDeadLetterQueue('q1');\n    expect(system.getDeadLetterTasks('q1')).toHaveLength(0);\n    expect(system.getDeadLetterTasks('q2')).toHaveLength(1);\n  });\n});\n\ndescribe('Phase 7: Task Dependencies', () => {\n  let system: TaskQueueSystem;\n\n  beforeEach(() => {\n    system = new TaskQueueSystem();\n  });\n\n  it('blocked task is not returned until dependency completes', () => {\n    const dep = system.addTask('dependency');\n    const dependent = system.addTask('dependent', { dependencies: [dep.id] });\n\n    expect(dependent.status).toBe('blocked');\n    expect(system.getNextTask()?.id).toBe(dep.id); // Only dep is available\n\n    // Nothing else available yet\n    expect(system.getNextTask()).toBeNull();\n\n    system.completeTask(dep.id);\n    const next = system.getNextTask()!;\n    expect(next.id).toBe(dependent.id);\n  });\n\n  it('rejects non-existent dependency', () => {\n    expect(() =>\n      system.addTask('a', { dependencies: ['nonexistent-id'] })\n    ).toThrow();\n  });\n\n  it('detects circular dependencies', () => {\n    const t1 = system.addTask('a');\n    const t2 = system.addTask('b', { dependencies: [t1.id] });\n    // t3 depends on t2, which depends on t1 — if t1 depended on t3 it would be circular\n    // We can only check at creation time for new tasks\n    expect(() =>\n      system.addTask('c', { dependencies: [t2.id, t1.id] })\n    ).not.toThrow(); // Not circular\n\n    // Create a chain that includes t2 which has t1 as dep\n    // Then try to make t1 depend on this new task — but we can't modify existing tasks\n    // Test direct circular: create situation where we pass an id that would create cycle\n    const tA = system.addTask('tA');\n    const tB = system.addTask('tB', { dependencies: [tA.id] });\n    // Can we make something that depends on tB and is also depended on by tA?\n    // tA is already created, we can only test at addTask time\n    // Simulate: a task that would create a loop by depending on something\n    // that depends on it... since we can't modify tA, we test detection works\n    // for chains:\n    const tC = system.addTask('tC', { dependencies: [tB.id] });\n    expect(tC.status).toBe('blocked');\n  });\n\n  it('failed dependency does NOT auto-fail dependents', () => {\n    const dep = system.addTask('dep');\n    const dependent = system.addTask('child', { dependencies: [dep.id] });\n\n    system.getNextTask(); // picks up dep\n    system.failTask(dep.id, 'err');\n\n    // dependent should still be blocked (not failed)\n    const t = system.getTask(dependent.id)!;\n    expect(t.status).toBe('blocked');\n  });\n\n  it('getDependencyStatus shows dependency statuses', () => {\n    const t1 = system.addTask('first');\n    const t2 = system.addTask('second', { dependencies: [t1.id] });\n\n    const status = system.getDependencyStatus(t2.id);\n    expect(status.dependencies[0].id).toBe(t1.id);\n    expect(status.dependencies[0].status).toBe('pending');\n    expect(status.allComplete).toBe(false);\n\n    system.completeTask(system.getNextTask()!.id);\n    const status2 = system.getDependencyStatus(t2.id);\n    expect(status2.allComplete).toBe(true);\n  });\n\n  it('task with multiple dependencies waits for all', () => {\n    const d1 = system.addTask('dep1');\n    const d2 = system.addTask('dep2');\n    system.addTask('child', { dependencies: [d1.id, d2.id] });\n\n    system.completeTask(system.getNextTask()!.id); // complete d1\n    // d2 not done yet, child still blocked\n    const child = system.getTask(system.listQueues().length > 0 ? '' : '')\n    // Get all tasks\n    const allTasks = [system.getNextTask(), system.getNextTask()];\n    // should have d2 available, child still blocked\n    const d2task = allTasks.find(t => t?.payload === 'dep2');\n    expect(d2task).toBeTruthy();\n    system.completeTask(d2task!.id);\n\n    // Now child should be unblocked\n    const childTask = system.getNextTask()!;\n    expect(childTask.payload).toBe('child');\n  });\n});\n\ndescribe('Phase 8: Concurrency Control', () => {\n  let system: TaskQueueSystem;\n\n  beforeEach(() => {\n    system = new TaskQueueSystem();\n  });\n\n  it('returns null when concurrency limit reached', () => {\n    system.addTask('a');\n    system.addTask('b');\n    system.addTask('c');\n\n    system.setConcurrencyLimit('default', 2);\n\n    system.getNextTask(); // slot 1\n    system.getNextTask(); // slot 2\n    expect(system.getNextTask()).toBeNull(); // limit hit\n  });\n\n  it('completing a task frees a concurrency slot', () => {\n    system.addTask('a');\n    system.addTask('b');\n    system.addTask('c');\n    system.setConcurrencyLimit('default', 1);\n\n    const t1 = system.getNextTask()!;\n    expect(system.getNextTask()).toBeNull();\n\n    system.completeTask(t1.id);\n    expect(system.getNextTask()).not.toBeNull();\n  });\n\n  it('failing a task frees a concurrency slot', () => {\n    system.addTask('a', { retry: { maxRetries: 0 } });\n    system.addTask('b');\n    system.setConcurrencyLimit('default', 1);\n\n    const t1 = system.getNextTask()!;\n    expect(system.getNextTask()).toBeNull();\n\n    system.failTask(t1.id, 'err');\n    expect(system.getNextTask()).not.toBeNull();\n  });\n\n  it('default is no concurrency limit', () => {\n    for (let i = 0; i < 100; i++) system.addTask(i);\n    for (let i = 0; i < 100; i++) {\n      expect(system.getNextTask()).not.toBeNull();\n    }\n  });\n\n  it('getConcurrencyLimit and getActiveCount work', () => {\n    system.setConcurrencyLimit('default', 5);\n    expect(system.getConcurrencyLimit('default')).toBe(5);\n\n    system.addTask('a');\n    system.getNextTask();\n    expect(system.getActiveCount('default')).toBe(1);\n  });\n\n  it('highest priority task is chosen within concurrency limit', () => {\n    system.addTask('low', { priority: 8 });\n    system.addTask('high', { priority: 1 });\n    system.setConcurrencyLimit('default', 1);\n\n    const t = system.getNextTask()!;\n    expect(t.payload).toBe('high');\n  });\n});\n\ndescribe('Phase 9: Progress & Cancellation', () => {\n  let system: TaskQueueSystem;\n\n  beforeEach(() => {\n    system = new TaskQueueSystem();\n    vi.useFakeTimers();\n  });\n\n  it('can update and query progress', () => {\n    system.addTask('a');\n    const t = system.getNextTask()!;\n\n    system.updateProgress(t.id, 50, 'halfway');\n    const p = system.getProgress(t.id);\n    expect(p.progress).toBe(50);\n    expect(p.message).toBe('halfway');\n  });\n\n  it('progress listeners receive updates', () => {\n    system.addTask('a');\n    const t = system.getNextTask()!;\n    const updates: number[] = [];\n    system.subscribeProgress(t.id, (u) => updates.push(u.progress));\n\n    system.updateProgress(t.id, 25);\n    system.updateProgress(t.id, 75);\n    expect(updates).toEqual([25, 75]);\n  });\n\n  it('unsubscribe stops receiving updates', () => {\n    system.addTask('a');\n    const t = system.getNextTask()!;\n    const updates: number[] = [];\n    const unsub = system.subscribeProgress(t.id, (u) => updates.push(u.progress));\n\n    system.updateProgress(t.id, 25);\n    unsub();\n    system.updateProgress(t.id, 75);\n    expect(updates).toEqual([25]);\n  });\n\n  it('rejects invalid progress values', () => {\n    system.addTask('a');\n    const t = system.getNextTask()!;\n    expect(() => system.updateProgress(t.id, 101)).toThrow();\n    expect(() => system.updateProgress(t.id, -1)).toThrow();\n  });\n\n  it('cancels a pending task', () => {\n    const t = system.addTask('a');\n    system.cancelTask(t.id);\n    expect(system.getTask(t.id)?.status).toBe('cancelled');\n    expect(system.getNextTask()).toBeNull();\n  });\n\n  it('cancels a processing task', () => {\n    system.addTask('a');\n    const t = system.getNextTask()!;\n    system.cancelTask(t.id);\n    expect(system.getTask(t.id)?.status).toBe('cancelled');\n  });\n\n  it('cancelled tasks are never retried', () => {\n    system.addTask('a', { retry: { maxRetries: 3, baseDelay: 100 } });\n    const t = system.getNextTask()!;\n    system.cancelTask(t.id);\n    vi.advanceTimersByTime(1000);\n    expect(system.getNextTask()).toBeNull();\n  });\n});\n\ndescribe('Phase 10: Recurring Tasks', () => {\n  let system: TaskQueueSystem;\n\n  beforeEach(() => {\n    system = new TaskQueueSystem();\n    vi.useFakeTimers();\n  });\n\n  it('creates and lists schedules', () => {\n    const schedule = system.createSchedule('*/5 * * * *', 'default', { type: 'report' });\n    expect(schedule.id).toBeTruthy();\n    expect(system.listSchedules()).toHaveLength(1);\n  });\n\n  it('removes a schedule', () => {\n    const s = system.createSchedule('*/5 * * * *', 'default', {});\n    system.removeSchedule(s.id);\n    expect(system.listSchedules()).toHaveLength(0);\n  });\n\n  it('tick enqueues tasks for due schedules', () => {\n    const now = new Date(2024, 0, 1, 12, 0, 0);\n    system.createSchedule('*/5 * * * *', 'default', { report: true });\n\n    const enqueued = system.tick(now);\n    expect(enqueued).toHaveLength(1);\n    expect(system.getPendingCount()).toBe(1);\n  });\n\n  it('tick does not enqueue before interval elapses', () => {\n    const now = new Date(2024, 0, 1, 12, 0, 0);\n    system.createSchedule('*/5 * * * *', 'default', {});\n    system.tick(now); // first tick — enqueues\n\n    const soon = new Date(now.getTime() + 2 * 60 * 1000); // 2 min later\n    const enqueued = system.tick(soon);\n    expect(enqueued).toHaveLength(0);\n  });\n\n  it('tick enqueues after interval elapses', () => {\n    const now = new Date(2024, 0, 1, 12, 0, 0);\n    system.createSchedule('*/5 * * * *', 'default', {});\n    system.tick(now);\n\n    const later = new Date(now.getTime() + 5 * 60 * 1000 + 1000); // 5min 1sec later\n    const enqueued = system.tick(later);\n    expect(enqueued).toHaveLength(1);\n  });\n\n  it('removed schedule does not enqueue', () => {\n    const now = new Date(2024, 0, 1, 12, 0, 0);\n    const s = system.createSchedule('*/5 * * * *', 'default', {});\n    system.removeSchedule(s.id);\n    const enqueued = system.tick(now);\n    expect(enqueued).toHaveLength(0);\n  });\n\n  it('supports hourly cron: 0 * * * *', () => {\n    const now = new Date(2024, 0, 1, 12, 0, 0); // on the hour\n    system.createSchedule('0 * * * *', 'default', {});\n    const enqueued = system.tick(now);\n    expect(enqueued).toHaveLength(1);\n  });\n\n  it('supports daily cron: 0 0 * * *', () => {\n    const now = new Date(2024, 0, 1, 0, 0, 0); // midnight\n    system.createSchedule('0 0 * * *', 'default', {});\n    const enqueued = system.tick(now);\n    expect(enqueued).toHaveLength(1);\n  });\n\n  it('enqueued recurring tasks are regular tasks subject to queue rules', () => {\n    const now = new Date(2024, 0, 1, 12, 0, 0);\n    system.createSchedule('*/5 * * * *', 'default', { job: 'cleanup' });\n    system.tick(now);\n\n    const task = system.getNextTask()!;\n    expect(task.payload).toEqual({ job: 'cleanup' });\n  });\n});\n\ndescribe('Phase 11: Middleware Pipeline', () => {\n  let system: TaskQueueSystem;\n\n  beforeEach(() => {\n    system = new TaskQueueSystem();\n  });\n\n  it('runs middleware in order before handler', async () => {\n    const order: string[] = [];\n\n    system.use('default', async (task, next) => {\n      order.push('mw1-before');\n      await next();\n      order.push('mw1-after');\n    });\n\n    system.use('default', async (task, next) => {\n      order.push('mw2-before');\n      await next();\n      order.push('mw2-after');\n    });\n\n    system.setHandler('default', async () => {\n      order.push('handler');\n    });\n\n    system.addTask('a');\n    const t = system.getNextTask()!;\n    await system.processTask(t);\n\n    expect(order).toEqual(['mw1-before', 'mw2-before', 'handler', 'mw2-after', 'mw1-after']);\n  });\n\n  it('middleware can skip handler by not calling next', async () => {\n    const handlerCalled = vi.fn();\n\n    system.use('default', async (_task, _next) => {\n      // Intentionally not calling next\n    });\n\n    system.setHandler('default', handlerCalled);\n\n    system.addTask('a');\n    const t = system.getNextTask()!;\n    await system.processTask(t);\n    expect(handlerCalled).not.toHaveBeenCalled();\n  });\n\n  it('middleware can modify the task', async () => {\n    let seenPayload: unknown;\n\n    system.use('default', async (task, next) => {\n      (task.payload as Record<string, unknown>).extra = 'injected';\n      await next();\n    });\n\n    system.setHandler('default', async (task) => {\n      seenPayload = task.payload;\n    });\n\n    system.addTask({ value: 42 });\n    const t = system.getNextTask()!;\n    await system.processTask(t);\n\n    expect((seenPayload as Record<string, unknown>).extra).toBe('injected');\n  });\n\n  it('middleware error marks task as failed', async () => {\n    system.use('default', async (_task, _next) => {\n      throw new Error('middleware exploded');\n    });\n\n    system.addTask('a', { retry: { maxRetries: 0 } });\n    const t = system.getNextTask()!;\n\n    await expect(system.processTask(t)).rejects.toThrow('middleware exploded');\n    const dlq = system.getDeadLetterTasks();\n    expect(dlq[0].error).toBe('middleware exploded');\n  });\n\n  it('each queue has its own middleware stack', async () => {\n    const q1calls: string[] = [];\n    const q2calls: string[] = [];\n\n    system.use('q1', async (_task, next) => { q1calls.push('q1-mw'); await next(); });\n    system.use('q2', async (_task, next) => { q2calls.push('q2-mw'); await next(); });\n\n    system.addTask('a', { queue: 'q1' });\n    system.addTask('b', { queue: 'q2' });\n\n    await system.processTask(system.getNextTask('q1')!);\n    await system.processTask(system.getNextTask('q2')!);\n\n    expect(q1calls).toEqual(['q1-mw']);\n    expect(q2calls).toEqual(['q2-mw']);\n  });\n});\n\ndescribe('Phase 12: Graceful Shutdown', () => {\n  let system: TaskQueueSystem;\n\n  beforeEach(() => {\n    system = new TaskQueueSystem();\n    vi.useFakeTimers();\n  });\n\n  it('rejects new tasks after shutdown initiated', async () => {\n    const shutdownPromise = system.shutdown();\n    expect(() => system.addTask('a')).toThrow();\n    await shutdownPromise;\n  });\n\n  it('completes immediately if no tasks processing', async () => {\n    const result = await system.shutdown();\n    expect(result.completed).toBe(0);\n    expect(result.forceCancelled).toBe(0);\n    expect(result.durationMs).toBeGreaterThanOrEqual(0);\n  });\n\n  it('waits for processing tasks to complete', async () => {\n    system.addTask('a');\n    const t = system.getNextTask()!;\n\n    const shutdownPromise = system.shutdown();\n\n    // Complete the task after shutdown started\n    system.completeTask(t.id);\n    vi.advanceTimersByTime(100);\n\n    const result = await shutdownPromise;\n    expect(result.completed).toBe(1);\n  });\n\n  it('force-cancels tasks that do not complete within timeout', async () => {\n    system.addTask('a');\n    system.getNextTask()!; // starts processing but we never complete it\n\n    const shutdownPromise = system.shutdown({ timeout: 50 });\n    vi.advanceTimersByTime(100);\n\n    const result = await shutdownPromise;\n    expect(result.forceCancelled).toBe(1);\n  });\n\n  it('runs shutdown callbacks', async () => {\n    const cb = vi.fn();\n    system.onShutdown(cb);\n    await system.shutdown();\n    expect(cb).toHaveBeenCalledTimes(1);\n  });\n\n  it('calling shutdown multiple times returns same result', async () => {\n    const r1 = await system.shutdown();\n    const r2 = await system.shutdown();\n    expect(r1).toBe(r2);\n  });\n\n  it('shutdown result includes duration', async () => {\n    const result = await system.shutdown();\n    expect(typeof result.durationMs).toBe('number');\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":359,"cache_read_input_tokens":37785,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":359},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"9fdf3cb0-a31b-443c-80cc-10b087bdbae1","uuid":"a39ba690-d4b5-481c-9545-b403c643de63"}
