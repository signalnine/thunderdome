diff --git a/src/TaskQueueSystem.ts b/src/TaskQueueSystem.ts
new file mode 100644
index 0000000..07afe51
--- /dev/null
+++ b/src/TaskQueueSystem.ts
@@ -0,0 +1,375 @@
+import {
+  Task,
+  TaskOptions,
+  Schedule,
+  MiddlewareFn,
+  HandlerFn,
+  ShutdownResult,
+  ShutdownOptions,
+  ShutdownCallback,
+  ProgressListener,
+} from './types.js';
+import { Queue, findTaskGlobal, DEFAULT_QUEUE } from './queue.js';
+import { generateId, generateScheduleId, isCronDue } from './utils.js';
+
+export class TaskQueueSystem {
+  private queues: Map<string, Queue> = new Map();
+  private schedules: Map<string, Schedule> = new Map();
+  private isShuttingDown = false;
+  private shutdownResult: ShutdownResult | null = null;
+  private shutdownCallbacks: ShutdownCallback[] = [];
+
+  // ─── Queue management ─────────────────────────────────────────────────────
+
+  private getOrCreateQueue(name: string): Queue {
+    if (!this.queues.has(name)) {
+      this.queues.set(name, new Queue(name));
+    }
+    return this.queues.get(name)!;
+  }
+
+  private requireQueue(name: string): Queue {
+    const queue = this.queues.get(name);
+    if (!queue) {
+      throw new Error(`Queue '${name}' does not exist`);
+    }
+    return queue;
+  }
+
+  listQueues(): string[] {
+    return Array.from(this.queues.keys());
+  }
+
+  // ─── Phase 1 & 2: Add/retrieve tasks ─────────────────────────────────────
+
+  addTask<T>(payload: T, options: TaskOptions & { queue?: string } = {}): Task<T> {
+    if (this.isShuttingDown) {
+      throw new Error('System is shutting down. No new tasks accepted.');
+    }
+
+    const queueName = options.queue ?? DEFAULT_QUEUE;
+    const queue = this.getOrCreateQueue(queueName);
+
+    // Phase 7: Validate dependencies
+    const deps = options.dependencies ?? [];
+    for (const depId of deps) {
+      const dep = findTaskGlobal(depId, this.queues);
+      if (!dep) {
+        throw new Error(`Dependency task '${depId}' does not exist`);
+      }
+    }
+
+    // Phase 7: Circular dependency detection
+    if (deps.length > 0) {
+      this.checkCircularDependencies(deps, new Set());
+    }
+
+    return queue.addTask<T>(payload, options);
+  }
+
+  getNextTask(queueName: string = DEFAULT_QUEUE): Task | null {
+    const queue = this.queues.get(queueName);
+    if (!queue) return null;
+    return queue.getNextTask();
+  }
+
+  getPendingCount(queueName: string = DEFAULT_QUEUE): number {
+    const queue = this.queues.get(queueName);
+    if (!queue) return 0;
+    return queue.getPendingCount();
+  }
+
+  getTask(taskId: string): Task | undefined {
+    return findTaskGlobal(taskId, this.queues);
+  }
+
+  // ─── Phase 5: Complete / fail ─────────────────────────────────────────────
+
+  completeTask(taskId: string): Task {
+    const { queue } = this.requireTaskAndQueue(taskId);
+    const updated = queue.completeTask(taskId);
+
+    // Phase 7: Unblock dependents when a task completes
+    queue.checkAndUnblockTasks(taskId, this.queues);
+
+    return updated;
+  }
+
+  failTask(taskId: string, error?: string): Task {
+    const { queue } = this.requireTaskAndQueue(taskId);
+    return queue.failTask(taskId, error);
+  }
+
+  // ─── Phase 6: Dead letter queue ───────────────────────────────────────────
+
+  getDeadLetterTasks(queueName: string = DEFAULT_QUEUE): Task[] {
+    const queue = this.queues.get(queueName);
+    if (!queue) return [];
+    return queue.getDeadLetterTasks();
+  }
+
+  requeueDeadLetterTask(taskId: string, queueName: string = DEFAULT_QUEUE): Task {
+    const queue = this.requireQueue(queueName);
+    return queue.requeueDeadLetterTask(taskId);
+  }
+
+  clearDeadLetterQueue(queueName: string = DEFAULT_QUEUE): void {
+    const queue = this.queues.get(queueName);
+    if (queue) queue.clearDeadLetterQueue();
+  }
+
+  // ─── Phase 7: Dependency inspection ──────────────────────────────────────
+
+  getDependencyStatus(taskId: string): {
+    taskId: string;
+    dependencies: Array<{ id: string; status: string }>;
+    allComplete: boolean;
+  } {
+    const task = findTaskGlobal(taskId, this.queues);
+    if (!task) throw new Error(`Task '${taskId}' not found`);
+
+    const deps = task.dependencies.map((depId) => {
+      const dep = findTaskGlobal(depId, this.queues);
+      return { id: depId, status: dep?.status ?? 'not_found' };
+    });
+
+    const allComplete = deps.every((d) => d.status === 'completed');
+    return { taskId, dependencies: deps, allComplete };
+  }
+
+  private checkCircularDependencies(depIds: string[], visited: Set<string>): void {
+    for (const depId of depIds) {
+      if (visited.has(depId)) {
+        throw new Error(`Circular dependency detected involving task '${depId}'`);
+      }
+      const dep = findTaskGlobal(depId, this.queues);
+      if (!dep) continue;
+      if (dep.dependencies.length > 0) {
+        const newVisited = new Set(visited);
+        newVisited.add(depId);
+        this.checkCircularDependencies(dep.dependencies, newVisited);
+      }
+    }
+  }
+
+  // ─── Phase 8: Concurrency ─────────────────────────────────────────────────
+
+  setConcurrencyLimit(queueName: string, limit: number | null): void {
+    this.getOrCreateQueue(queueName).setConcurrencyLimit(limit);
+  }
+
+  getConcurrencyLimit(queueName: string): number | null {
+    return this.queues.get(queueName)?.getConcurrencyLimit() ?? null;
+  }
+
+  getActiveCount(queueName: string): number {
+    return this.queues.get(queueName)?.getActiveCount() ?? 0;
+  }
+
+  // ─── Phase 9: Progress & cancellation ────────────────────────────────────
+
+  updateProgress(taskId: string, progress: number, message?: string): void {
+    const { queue } = this.requireTaskAndQueue(taskId);
+    queue.updateProgress(taskId, progress, message);
+  }
+
+  getProgress(taskId: string): { progress: number; message?: string } {
+    const task = findTaskGlobal(taskId, this.queues);
+    if (!task) throw new Error(`Task '${taskId}' not found`);
+    return { progress: task.progress, message: task.progressMessage };
+  }
+
+  subscribeProgress(taskId: string, listener: ProgressListener): () => void {
+    const { queue } = this.requireTaskAndQueue(taskId);
+    return queue.subscribeProgress(taskId, listener);
+  }
+
+  cancelTask(taskId: string): Task {
+    const { queue } = this.requireTaskAndQueue(taskId);
+    return queue.cancelTask(taskId);
+  }
+
+  // ─── Phase 10: Recurring tasks / schedules ────────────────────────────────
+
+  createSchedule(cronExpression: string, queueName: string, payload: unknown): Schedule {
+    const id = generateScheduleId();
+    const schedule: Schedule = {
+      id,
+      cronExpression,
+      queueName,
+      payload,
+    };
+    this.schedules.set(id, schedule);
+    return schedule;
+  }
+
+  removeSchedule(scheduleId: string): void {
+    this.schedules.delete(scheduleId);
+  }
+
+  listSchedules(): Schedule[] {
+    return Array.from(this.schedules.values());
+  }
+
+  /**
+   * Evaluate all schedules and enqueue tasks for any that are due.
+   * Pass `now` for testing determinism.
+   */
+  tick(now: Date = new Date()): Task[] {
+    const enqueued: Task[] = [];
+    for (const schedule of this.schedules.values()) {
+      if (isCronDue(schedule.cronExpression, schedule.lastRun, now)) {
+        try {
+          const task = this.addTask(schedule.payload, { queue: schedule.queueName });
+          schedule.lastRun = now;
+          enqueued.push(task);
+        } catch {
+          // If system is shutting down, skip silently
+        }
+      }
+    }
+    return enqueued;
+  }
+
+  // ─── Phase 11: Middleware ─────────────────────────────────────────────────
+
+  use(queueName: string, fn: MiddlewareFn): void {
+    this.getOrCreateQueue(queueName).use(fn);
+  }
+
+  setHandler<T>(queueName: string, fn: HandlerFn<T>): void {
+    this.getOrCreateQueue(queueName).setHandler(fn as HandlerFn);
+  }
+
+  /**
+   * Process a task through the middleware pipeline and then the handler.
+   * The caller is responsible for getting the task via getNextTask() first.
+   */
+  async processTask(task: Task): Promise<void> {
+    const queue = this.queues.get(task.queueName);
+    if (!queue) throw new Error(`Queue '${task.queueName}' not found`);
+
+    const middlewares = [...queue.middleware];
+    const handler = queue.getHandler();
+
+    let index = 0;
+    const next = async (): Promise<void> => {
+      if (index < middlewares.length) {
+        const mw = middlewares[index++];
+        await mw(task, next);
+      } else if (handler) {
+        await handler(task);
+      }
+    };
+
+    try {
+      await next();
+    } catch (err) {
+      // Middleware or handler threw — mark task as failed
+      const errMsg = err instanceof Error ? err.message : String(err);
+      // Find the queue for the task and fail it
+      this.failTask(task.id, errMsg);
+      throw err;
+    }
+  }
+
+  // ─── Phase 12: Graceful shutdown ──────────────────────────────────────────
+
+  onShutdown(callback: ShutdownCallback): void {
+    this.shutdownCallbacks.push(callback);
+  }
+
+  async shutdown(options: ShutdownOptions = {}): Promise<ShutdownResult> {
+    // Idempotent
+    if (this.shutdownResult) return this.shutdownResult;
+
+    const startTime = Date.now();
+    this.isShuttingDown = true;
+
+    // Run shutdown callbacks
+    for (const cb of this.shutdownCallbacks) {
+      await cb();
+    }
+
+    const timeout = options.timeout;
+    let completed = 0;
+    let forceCancelled = 0;
+
+    // Gather all processing tasks
+    const processingTasks = this.getAllProcessingTasks();
+
+    if (processingTasks.length === 0) {
+      // Nothing to wait for
+      const durationMs = Date.now() - startTime;
+      this.shutdownResult = { completed: 0, forceCancelled: 0, durationMs };
+      return this.shutdownResult;
+    }
+
+    // Wait for processing tasks to complete (poll)
+    const deadline = timeout != null ? startTime + timeout : null;
+
+    const waitForTasks = new Promise<void>((resolve) => {
+      const check = () => {
+        const stillProcessing = this.getAllProcessingTasks();
+        if (stillProcessing.length === 0) {
+          resolve();
+          return;
+        }
+        if (deadline !== null && Date.now() >= deadline) {
+          resolve();
+          return;
+        }
+        setTimeout(check, 10);
+      };
+      check();
+    });
+
+    await waitForTasks;
+
+    // Count outcomes
+    const finalProcessing = this.getAllProcessingTasks();
+    for (const task of finalProcessing) {
+      // Force-cancel remaining
+      const queue = this.queues.get(task.queueName);
+      if (queue) {
+        queue.forceCancel(task.id);
+        forceCancelled++;
+      }
+    }
+
+    // Count completed (tasks that finished during shutdown)
+    for (const task of processingTasks) {
+      const current = findTaskGlobal(task.id, this.queues);
+      if (current?.status === 'completed') completed++;
+    }
+
+    const durationMs = Date.now() - startTime;
+    this.shutdownResult = { completed, forceCancelled, durationMs };
+    return this.shutdownResult;
+  }
+
+  private getAllProcessingTasks(): Task[] {
+    const result: Task[] = [];
+    for (const queue of this.queues.values()) {
+      result.push(...queue.getProcessingTasks());
+    }
+    return result;
+  }
+
+  // ─── Helpers ──────────────────────────────────────────────────────────────
+
+  private requireTaskAndQueue(taskId: string): { queue: Queue; task: Task } {
+    for (const queue of this.queues.values()) {
+      const task = queue.getTask(taskId);
+      if (task) return { queue, task };
+    }
+    throw new Error(`Task '${taskId}' not found`);
+  }
+
+  /**
+   * Generate a unique task ID (for external testing convenience)
+   */
+  generateId(): string {
+    return generateId();
+  }
+}
