+// Core types for the task queue system
+
+export type TaskStatus =
+  | 'pending'
+  | 'processing'
+  | 'completed'
+  | 'failed'
+  | 'cancelled'
+  | 'blocked'; // waiting on dependencies
+
+export interface RetryConfig {
+  maxRetries: number;
+  baseDelay: number; // ms
+}
+
+export interface TaskOptions {
+  priority?: number; // 1 (highest) to 10 (lowest), default 5
+  delay?: number; // ms from now
+  availableAt?: Date; // absolute time
+  retry?: Partial<RetryConfig>;
+  dependencies?: string[]; // task IDs that must complete first
+}
+
+export interface Task<T = unknown> {
+  id: string;
+  queueName: string;
+  payload: T;
+  status: TaskStatus;
+  priority: number;
+  createdAt: Date;
+  availableAt: Date; // when it becomes eligible for processing
+  attempts: number;
+  maxRetries: number;
+  baseDelay: number;
+  dependencies: string[];
+  progress: number; // 0-100
+  progressMessage?: string;
+  error?: string;
+  completedAt?: Date;
+  deadLetteredAt?: Date;
+}
+
+export interface QueueStats {
+  name: string;
+  pending: number;
+  processing: number;
+  blocked: number;
+  concurrencyLimit: number | null;
+  activeCount: number;
+}
+
+export interface ProgressUpdate {
+  taskId: string;
+  progress: number;
+  message?: string;
+}
+
+export type ProgressListener = (update: ProgressUpdate) => void;
+
+export interface Schedule {
+  id: string;
+  cronExpression: string;
+  queueName: string;
+  payload: unknown;
+  lastRun?: Date;
+}
+
+export type MiddlewareFn = (
+  task: Task,
+  next: () => Promise<void>
+) => Promise<void>;
+
+export type HandlerFn<T = unknown> = (task: Task<T>) => Promise<void>;
+
+export interface ShutdownResult {
+  completed: number;
+  forceCancelled: number;
+  durationMs: number;
+}
+
+export interface ShutdownOptions {
+  timeout?: number; // ms, default: unlimited wait
+}
+
+export type ShutdownCallback = () => void | Promise<void>;
