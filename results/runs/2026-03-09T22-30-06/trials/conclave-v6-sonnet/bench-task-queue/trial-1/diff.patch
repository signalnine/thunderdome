+// Utility functions
+
+let counter = 0;
+
+export function generateId(): string {
+  counter++;
+  return `task-${Date.now()}-${counter}-${Math.random().toString(36).slice(2, 9)}`;
+}
+
+export function generateScheduleId(): string {
+  counter++;
+  return `schedule-${Date.now()}-${counter}`;
+}
+
+/**
+ * Parse a simple cron expression subset:
+ *   * /N * * * *  -> every N minutes
+ *   0 * * * *    -> every hour on the hour
+ *   0 0 * * *    -> every day at midnight
+ *
+ * Returns the next Date after `after` when the cron fires.
+ */
+export function getNextCronTime(expression: string, after: Date): Date {
+  const parts = expression.trim().split(/\s+/);
+  if (parts.length !== 5) {
+    throw new Error(`Invalid cron expression: ${expression}`);
+  }
+
+  const [minutePart, hourPart] = parts;
+
+  // */N pattern: every N minutes
+  const everyNMatch = minutePart.match(/^\*\/(\d+)$/);
+  if (everyNMatch && hourPart === '*') {
+    const n = parseInt(everyNMatch[1], 10);
+    if (n <= 0) throw new Error(`Invalid cron interval: ${expression}`);
+    const nextMs = after.getTime() + n * 60 * 1000;
+    return new Date(nextMs);
+  }
+
+  // 0 * * * * : every hour on the hour
+  if (minutePart === '0' && hourPart === '*') {
+    const next = new Date(after);
+    next.setMinutes(0, 0, 0);
+    next.setHours(next.getHours() + 1);
+    return next;
+  }
+
+  // 0 0 * * * : every day at midnight
+  if (minutePart === '0' && hourPart === '0') {
+    const next = new Date(after);
+    next.setHours(0, 0, 0, 0);
+    next.setDate(next.getDate() + 1);
+    return next;
+  }
+
+  throw new Error(`Unsupported cron expression: ${expression}`);
+}
+
+export function isCronDue(expression: string, lastRun: Date | undefined, now: Date): boolean {
+  const parts = expression.trim().split(/\s+/);
+  if (parts.length !== 5) return false;
+
+  const [minutePart, hourPart] = parts;
+
+  if (!lastRun) {
+    // Never run — check if current time matches schedule
+    const everyNMatch = minutePart.match(/^\*\/(\d+)$/);
+    if (everyNMatch && hourPart === '*') {
+      // Due immediately on first check
+      return true;
+    }
+    if (minutePart === '0' && hourPart === '*') {
+      return now.getMinutes() === 0;
+    }
+    if (minutePart === '0' && hourPart === '0') {
+      return now.getHours() === 0 && now.getMinutes() === 0;
+    }
+    return false;
+  }
+
+  // Check if the next fire time is <= now
+  const nextTime = getNextCronTime(expression, lastRun);
+  return nextTime <= now;
+}
