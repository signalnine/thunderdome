his.progressListeners.get(taskId)!.add(listener);\n    return () => {\n      this.progressListeners.get(taskId)?.delete(listener);\n    };\n  }\n\n  // ─── Concurrency ──────────────────────────────────────────────────────────\n\n  setConcurrencyLimit(limit: number | null): void {\n    this.concurrencyLimit = limit;\n  }\n\n  getConcurrencyLimit(): number | null {\n    return this.concurrencyLimit;\n  }\n\n  getActiveCount(): number {\n    return this.activeCount;\n  }\n\n  // ─── Middleware ───────────────────────────────────────────────────────────\n\n  use(fn: MiddlewareFn): void {\n    this.middleware.push(fn);\n  }\n\n  setHandler(fn: HandlerFn): void {\n    this.handler = fn;\n  }\n\n  getHandler(): HandlerFn | null {\n    return this.handler;\n  }\n\n  // ─── Query ────────────────────────────────────────────────────────────────\n\n  getTask(taskId: string): Task | undefined {\n    return this.tasks.get(taskId) ?? this.deadLetterTasks.get(taskId);\n  }\n\n  getPendingCount(): number {\n    const now = new Date();\n    let count = 0;\n    for (const task of this.tasks.values()) {\n      if (task.status === 'pending' && task.availableAt <= now) count++;\n    }\n    return count;\n  }\n\n  getAllTasks(): Task[] {\n    return Array.from(this.tasks.values());\n  }\n\n  getProcessingTasks(): Task[] {\n    return Array.from(this.tasks.values()).filter((t) => t.status === 'processing');\n  }\n\n  // ─── Shutdown helpers ─────────────────────────────────────────────────────\n\n  forceCancel(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (task && task.status === 'processing') {\n      task.status = 'cancelled';\n      this.activeCount = Math.max(0, this.activeCount - 1);\n    }\n  }\n\n  // ─── Private helpers ──────────────────────────────────────────────────────\n\n  private requireTask(taskId: string): Task {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task ${taskId} not found in queue ${this.name}`)