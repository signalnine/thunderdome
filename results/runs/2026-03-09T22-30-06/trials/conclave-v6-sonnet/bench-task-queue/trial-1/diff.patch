+import {
+  Task,
+  TaskStatus,
+  TaskOptions,
+  ProgressListener,
+  MiddlewareFn,
+  HandlerFn,
+} from './types.js';
+import { generateId } from './utils.js';
+
+const DEFAULT_QUEUE = 'default';
+const DEFAULT_PRIORITY = 5;
+const DEFAULT_MAX_RETRIES = 3;
+const DEFAULT_BASE_DELAY = 1000;
+
+export class Queue {
+  readonly name: string;
+  private tasks: Map<string, Task> = new Map();
+  private deadLetterTasks: Map<string, Task> = new Map();
+  private concurrencyLimit: number | null = null;
+  private activeCount = 0;
+  private progressListeners: Map<string, Set<ProgressListener>> = new Map();
+  readonly middleware: MiddlewareFn[] = [];
+  private handler: HandlerFn | null = null;
+
+  constructor(name: string) {
+    this.name = name;
+  }
+
+  // ─── Task creation ────────────────────────────────────────────────────────
+
+  addTask<T>(payload: T, options: TaskOptions = {}): Task<T> {
+    const priority = options.priority ?? DEFAULT_PRIORITY;
+    if (priority < 1 || priority > 10) {
+      throw new Error(`Priority must be between 1 and 10, got ${priority}`);
+    }
+
+    const now = new Date();
+    let availableAt: Date;
+
+    if (options.availableAt) {
+      availableAt = options.availableAt;
+    } else if (options.delay != null) {
+      availableAt = new Date(now.getTime() + options.delay);
+    } else {
+      availableAt = now;
+    }
+
+    // Validate dependencies exist in global task registry (checked in TaskQueueSystem)
+    const dependencies = options.dependencies ?? [];
+
+    const task: Task<T> = {
+      id: generateId(),
+      queueName: this.name,
+      payload,
+      status: dependencies.length > 0 ? 'blocked' : 'pending',
+      priority,
+      createdAt: now,
+      availableAt,
+      attempts: 0,
+      maxRetries: options.retry?.maxRetries ?? DEFAULT_MAX_RETRIES,
+      baseDelay: options.retry?.baseDelay ?? DEFAULT_BASE_DELAY,
+      dependencies,
+      progress: 0,
+    };
+
+    this.tasks.set(task.id, task);
+    return task;
+  }
+
+  // ─── Retrieval ────────────────────────────────────────────────────────────
+
+  getNextTask(): Task | null {
+    if (this.concurrencyLimit !== null && this.activeCount >= this.concurrencyLimit) {
+      return null;
+    }
+
+    const now = new Date();
+    let best: Task | null = null;
+
+    for (const task of this.tasks.values()) {
+      if (task.status !== 'pending') continue;
+      if (task.availableAt > now) continue;
+
+      if (!best) {
+        best = task;
+        continue;
+      }
+
+      // Sort: priority asc (1 = highest), then availableAt asc, then createdAt asc
+      if (task.priority < best.priority) {
+        best = task;
+      } else if (task.priority === best.priority) {
+        if (task.availableAt < best.availableAt) {
+          best = task;
+        } else if (task.availableAt.getTime() === best.availableAt.getTime()) {
+          if (task.createdAt < best.createdAt) {
+            best = task;
+          }
+        }
+      }
+    }
+
+    if (best) {
+      best.status = 'processing';
+      best.attempts++;
+      this.activeCount++;
+    }
+
+    return best;
+  }
+
+  // ─── Status management ────────────────────────────────────────────────────
+
+  completeTask(taskId: string): Task {
+    const task = this.requireTask(taskId);
+    this.requireStatus(task, 'processing');
+    task.status = 'completed';
+    task.completedAt = new Date();
+    this.activeCount = Math.max(0, this.activeCount - 1);
+    return task;
+  }
+
+  failTask(taskId: string, error?: string): Task {
+    const task = this.requireTask(taskId);
+    this.requireStatus(task, 'processing');
+    this.activeCount = Math.max(0, this.activeCount - 1);
+
+    if (error !== undefined) {
+      task.error = error;
+    }
+
+    if (task.attempts < task.maxRetries + 1 && task.attempts <= task.maxRetries) {
+      // Has retries remaining: schedule retry with exponential backoff
+      const backoffDelay = task.baseDelay * Math.pow(2, task.attempts - 1);
+      task.status = 'pending';
+      task.availableAt = new Date(Date.now() + backoffDelay);
+      // Reset progress for retry
+      task.progress = 0;
+      task.progressMessage = undefined;
+    } else {
+      // No retries left
+      task.status = 'failed';
+      this.moveToDeadLetter(task);
+    }
+
+    return task;
+  }
+
+  private moveToDeadLetter(task: Task): void {
+    task.deadLetteredAt = new Date();
+    this.tasks.delete(task.id);
+    this.deadLetterTasks.set(task.id, task);
+  }
+
+  cancelTask(taskId: string): Task {
+    const task = this.requireTask(taskId);
+    if (task.status !== 'pending' && task.status !== 'processing' && task.status !== 'blocked') {
+      throw new Error(`Cannot cancel task ${taskId} with status ${task.status}`);
+    }
+    if (task.status === 'processing') {
+      this.activeCount = Math.max(0, this.activeCount - 1);
+    }
+    task.status = 'cancelled';
+    // Clear progress listeners
+    this.progressListeners.delete(taskId);
+    return task;
+  }
+
+  // ─── Dead letter queue ────────────────────────────────────────────────────
+
+  getDeadLetterTasks(): Task[] {
+    return Array.from(this.deadLetterTasks.values());
+  }
+
+  requeueDeadLetterTask(taskId: string): Task {
+    const task = this.deadLetterTasks.get(taskId);
+    if (!task) {
+      throw new Error(`Dead letter task ${taskId} not found in queue ${this.name}`);
+    }
+    // Fresh round of retries
+    task.status = 'pending';
+    task.attempts = 0;
+    task.availableAt = new Date();
+    task.deadLetteredAt = undefined;
+    task.error = undefined;
+    this.deadLetterTasks.delete(taskId);
+    this.tasks.set(taskId, task);
+    return task;
+  }
+
+  clearDeadLetterQueue(): void {
+    this.deadLetterTasks.clear();
+  }
+
+  // ─── Dependencies ─────────────────────────────────────────────────────────
+
+  /**
+   * Called when a task completes, to unblock dependents.
+   * Returns IDs of tasks that became unblocked.
+   */
+  checkAndUnblockTasks(completedTaskId: string, allQueues: Map<string, Queue>): string[] {
+    const unblocked: string[] = [];
+
+    for (const queue of allQueues.values()) {
+      for (const task of queue.tasks.values()) {
+        if (task.status !== 'blocked') continue;
+        if (!task.dependencies.includes(completedTaskId)) continue;
+
+        // Check if all dependencies are complete
+        const allDone = task.dependencies.every((depId) => {
+          const dep = findTaskGlobal(depId, allQueues);
+          return dep?.status === 'completed';
+        });
+
+        if (allDone) {
+          task.status = 'pending';
+          task.availableAt = new Date(); // available now
+          unblocked.push(task.id);
+        }
+      }
+    }
+
+    return unblocked;
+  }
+
+  // ─── Progress ─────────────────────────────────────────────────────────────
+
+  updateProgress(taskId: string, progress: number, message?: string): void {
+    const task = this.requireTask(taskId);
+    if (task.status !== 'processing') {
+      throw new Error(`Task ${taskId} is not processing (status: ${task.status})`);
+    }
+    if (progress < 0 || progress > 100) {
+      throw new Error(`Progress must be between 0 and 100, got ${progress}`);
+    }
+    task.progress = progress;
+    task.progressMessage = message;
+
+    const listeners = this.progressListeners.get(taskId);
+    if (listeners) {
+      for (const listener of listeners) {
+        listener({ taskId, progress, message });
+      }
+    }
+  }
+
+  subscribeProgress(taskId: string, listener: ProgressListener): () => void {
+    if (!this.progressListeners.has(taskId)) {
+      this.progressListeners.set(taskId, new Set());
+    }
+    this.progressListeners.get(taskId)!.add(listener);
+    return () => {
+      this.progressListeners.get(taskId)?.delete(listener);
+    };
+  }
+
+  // ─── Concurrency ──────────────────────────────────────────────────────────
+
+  setConcurrencyLimit(limit: number | null): void {
+    this.concurrencyLimit = limit;
+  }
+
+  getConcurrencyLimit(): number | null {
+    return this.concurrencyLimit;
+  }
+
+  getActiveCount(): number {
+    return this.activeCount;
+  }
+
+  // ─── Middleware ───────────────────────────────────────────────────────────
+
+  use(fn: MiddlewareFn): void {
+    this.middleware.push(fn);
+  }
+
+  setHandler(fn: HandlerFn): void {
+    this.handler = fn;
+  }
+
+  getHandler(): HandlerFn | null {
+    return this.handler;
+  }
+
+  // ─── Query ────────────────────────────────────────────────────────────────
+
+  getTask(taskId: string): Task | undefined {
+    return this.tasks.get(taskId) ?? this.deadLetterTasks.get(taskId);
+  }
+
+  getPendingCount(): number {
+    const now = new Date();
+    let count = 0;
+    for (const task of this.tasks.values()) {
+      if (task.status === 'pending' && task.availableAt <= now) count++;
+    }
+    return count;
+  }
+
+  getAllTasks(): Task[] {
+    return Array.from(this.tasks.values());
+  }
+
+  getProcessingTasks(): Task[] {
+    return Array.from(this.tasks.values()).filter((t) => t.status === 'processing');
+  }
+
+  // ─── Shutdown helpers ─────────────────────────────────────────────────────
+
+  forceCancel(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (task && task.status === 'processing') {
+      task.status = 'cancelled';
+      this.activeCount = Math.max(0, this.activeCount - 1);
+    }
+  }
+
+  // ─── Private helpers ──────────────────────────────────────────────────────
+
+  private requireTask(taskId: string): Task {
+    const task = this.tasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task ${taskId} not found in queue ${this.name}`);
+    }
+    return task;
+  }
+
+  private requireStatus(task: Task, expected: TaskStatus): void {
+    if (task.status !== expected) {
+      throw new Error(
+        `Task ${task.id} expected status '${expected}', got '${task.status}'`
+      );
+    }
+  }
+}
+
+export function findTaskGlobal(taskId: string, allQueues: Map<string, Queue>): Task | undefined {
+  for (const queue of allQueues.values()) {
+    const task = queue.getTask(taskId);
+    if (task) return task;
+  }
+  return undefined;
+}
+
+export { DEFAULT_QUEUE };
