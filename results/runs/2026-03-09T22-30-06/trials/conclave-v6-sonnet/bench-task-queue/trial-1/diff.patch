 now,\n      availableAt,\n      attempts: 0,\n      maxRetries: options.retry?.maxRetries ?? DEFAULT_MAX_RETRIES,\n      baseDelay: options.retry?.baseDelay ?? DEFAULT_BASE_DELAY,\n      dependencies,\n      progress: 0,\n    };\n\n    this.tasks.set(task.id, task);\n    return task;\n  }\n\n  // ─── Retrieval ────────────────────────────────────────────────────────────\n\n  getNextTask(): Task | null {\n    if (this.concurrencyLimit !== null && this.activeCount >= this.concurrencyLimit) {\n      return null;\n    }\n\n    const now = new Date();\n    let best: Task | null = null;\n\n    for (const task of this.tasks.values()) {\n      if (task.status !== 'pending') continue;\n      if (task.availableAt > now) continue;\n\n      if (!best) {\n        best = task;\n        continue;\n      }\n\n      // Sort: priority asc (1 = highest), then availableAt asc, then createdAt asc\n      if (task.priority < best.priority) {\n        best = task;\n      } else if (task.priority === best.priority) {\n        if (task.availableAt < best.availableAt) {\n          best = task;\n        } else if (task.availableAt.getTime() === best.availableAt.getTime()) {\n          if (task.createdAt < best.createdAt) {\n            best = task;\n          }\n        }\n      }\n    }\n\n    if (best) {\n      best.status = 'processing';\n      best.attempts++;\n      this.activeCount++;\n    }\n\n    return best;\n  }\n\n  // ─── Status management ────────────────────────────────────────────────────\n\n  completeTask(taskId: string): Task {\n    const task = this.requireTask(taskId);\n    this.requireStatus(task, 'processing');\n    task.status = 'completed';\n    task.completedAt = new Date();\n    this.activeCount = Math.max(0, this.activeCount - 1);\n    return task;\n  }\n\n  failTask(taskId: string, error?: string): Task {\n    const task = this.requireTask(taskId);\n    this.requireStatus(task, 'processing');\n    this.activeCount = Math.max(0, this.activeCount - 1);\n\n    if (error !== undefined) {\n      task.error = error;\n    }\n\n    if (task.attempts < task.maxRetries + 1 && task.attempts <= task.maxRetries) {\n      // Has retries remaining: schedule retry with exponential backoff\n      const backoffDelay = task.baseDelay * Math.pow(2, task.attempts - 1);\n      task.status = 'pending';\n      task.availableAt = new Date(Date.now() + backoffDelay);\n      // Reset progress for retry\n      task.progress = 0;\n      task.progressMessage = undefined;\n    } else {\n      // No retries left\n      task.status = 'failed';\n      this.moveToDeadLetter(task);\n    }\n\n    return task;\n  }\n\n  private moveToDeadLetter(task: Task): void {\n    task.deadLetteredAt = new Date();\n    this.tasks.delete(task.id);\n    this.deadLetterTasks.set(task.id, task);\n  }\n\n  cancelTask(taskId: string): Task {\n    const task = this.requireTask(taskId);\n    if (task.status !== 'pending' && task.status !== 'processing' && task.status !== 'blocked') {\n      throw new Error(`Cannot cancel task ${taskId} with status ${task.status}`);\n    }\n    if (task.status === 'processing') {\n      this.activeCount = Math.max(0, this.activeCount - 1);\n    }\n    task.status = 'cancelled';\n    // Clear progress listeners\n    this.progressListeners.delete(taskId);\n    return task;\n  }\n\n  // ─── Dead letter queue ────────────────────────────────────────────────────\n\n  getDeadLetterTasks(): Task[] {\n    return Array.from(this.deadLetterTasks.values());\n  }\n\n  requeueDeadLetterTask(taskId: string): Task {\n    const task = this.deadLetterTasks.get(taskId);\n    if (!task) {\n      throw new Error(`Dead letter task ${taskId} not found in queue ${this.name}`);\n    }\n    // Fresh round of retries\n    task.status = 'pending';\n    task.attempts = 0;\n    task.availableAt = new Date();\n    task.deadLetteredAt = undefined;\n    task.error = undefined;\n    this.deadLetterTasks.delete(taskId);\n    this.tasks.set(taskId, task);\n    return task;\n  }\n\n  cl