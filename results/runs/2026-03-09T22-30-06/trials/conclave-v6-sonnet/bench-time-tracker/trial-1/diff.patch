+++ b/src/tracker.test.ts
@@ -0,0 +1,254 @@
+import { describe, it, expect, beforeEach, afterEach } from 'vitest';
+import { mkdirSync, rmSync, existsSync } from 'node:fs';
+import { join } from 'node:path';
+import { tmpdir } from 'node:os';
+import { TimeTracker } from './tracker.js';
+
+function makeTmpDir(): string {
+  const dir = join(tmpdir(), `tracker-test-${Date.now()}-${Math.random().toString(36).slice(2)}`);
+  mkdirSync(dir, { recursive: true });
+  return dir;
+}
+
+describe('TimeTracker', () => {
+  let tmpDir: string;
+  let dataFile: string;
+  let tracker: TimeTracker;
+
+  beforeEach(() => {
+    tmpDir = makeTmpDir();
+    dataFile = join(tmpDir, 'time-entries.json');
+    tracker = new TimeTracker(dataFile);
+  });
+
+  afterEach(() => {
+    rmSync(tmpDir, { recursive: true, force: true });
+  });
+
+  // --- Error handling ---
+
+  it('throws when starting a timer with an empty name', () => {
+    expect(() => tracker.start('')).toThrow();
+  });
+
+  it('throws when starting a timer with a whitespace-only name', () => {
+    expect(() => tracker.start('   ')).toThrow();
+  });
+
+  it('throws when stopping with no running timer', () => {
+    expect(() => tracker.stop()).toThrow();
+  });
+
+  // --- Start and stop ---
+
+  it('starts a timer and records a running entry', () => {
+    tracker.start('coding');
+    const entries = tracker.getEntries();
+    expect(entries).toHaveLength(1);
+    expect(entries[0].name).toBe('coding');
+    expect(entries[0].startedAt).toBeInstanceOf(Date);
+    expect(entries[0].stoppedAt).toBeNull();
+  });
+
