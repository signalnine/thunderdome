).toHaveLength(1);\n    expect(entries[0].stoppedAt).toBeInstanceOf(Date);\n  });\n\n  it('auto-stops previous timer when starting a new one', () => {\n    tracker.start('task-a');\n    tracker.start('task-b');\n    const entries = tracker.getEntries();\n    expect(entries).toHaveLength(2);\n    expect(entries[0].name).toBe('task-a');\n    expect(entries[0].stoppedAt).toBeInstanceOf(Date);\n    expect(entries[1].name).toBe('task-b');\n    expect(entries[1].stoppedAt).toBeNull();\n  });\n\n  it('records correct start time (within a few seconds)', () => {\n    const before = Date.now();\n    tracker.start('coding');\n    const after = Date.now();\n    const entry = tracker.getEntries()[0];\n    expect(entry.startedAt.getTime()).toBeGreaterThanOrEqual(before);\n    expect(entry.startedAt.getTime()).toBeLessThanOrEqual(after);\n  });\n\n  // --- Persistence ---\n\n  it('creates the data file automatically', () => {\n    tracker.start('coding');\n    expect(existsSync(dataFile)).toBe(true);\n  });\n\n  it('creates parent directories automatically', () => {\n    const nestedFile = join(tmpDir, 'a', 'b', 'c', 'data.json');\n    const t = new TimeTracker(nestedFile);\n    t.start('task');\n    expect(existsSync(nestedFile)).toBe(true);\n  });\n\n  it('persists entries across tracker instances', () => {\n    tracker.start('session-1');\n    tracker.stop();\n\n    const tracker2 = new TimeTracker(dataFile);\n    const entries = tracker2.getEntries();\n    expect(entries).toHaveLength(1);\n    expect(entries[0].name).toBe('session-1');\n  });\n\n  it('preserves running timer across instances', () => {\n    tracker.start('ongoing');\n\n    const tracker2 = new TimeTracker(dataFile);\n    const entries = tracker2.getEntries();\n    expect(entries).toHaveLength(1);\n    expect(entries[0].stoppedAt).toBeNull();\n  });\n\n  // --- Querying by date range ---\n\n  it('returns all entries when no filter given', () => {\n    tracker.start('a');\n    tracker.stop();\n    tracker.start('b');\n    tracker.stop();\n    expect(tracker.getEntries()).toHaveLength(2);\n  });\n\n  it('filters entries by start of range (from)', () => {\n    const past = new Date(Date.now() - 10_000);\n    const future = new Date(Date.now() + 10_000);\n\n    tracker.start('old');\n    tracker.stop();\n    tracker.start('new');\n    tracker.stop();\n\n    // All entries started now, filter from 1 hour ago => all included\n    const all = tracker.getEntries({ from: past });\n    expect(all).toHaveLength(2);\n\n    // Filter from future => none\n    const none = tracker.getEntries({ from: future });\n    expect(none).toHaveLength(0);\n  });\n\n  it('filters entries by end of range (to)', () => {\n    const past = new Date(Date.now() - 10_000);\n    const future = new Date(Date.now() + 10_000);\n\n    tracker.start('task');\n    tracker.stop();\n\n    // All entries started now, filter to future => included\n    const included = tracker.getEntries({ to: future });\n    expect(included).toHaveLength(1);\n\n    // Filter to past => excluded\n    const excluded = tracker.getEntries({ to: past });\n    expect(excluded).toHaveLength(0);\n  });\n\n  it('filters entries by both from and to', () => {\n    tracker.start('task');\n    tracker.stop();\n\n    const from = new Date(Date.now() - 5_000);\n    const to = new Date(Date.now() + 5_000);\n    const result = tracker.getEntries({ from, to });\n    expect(result).toHaveLength(1);\n  });\n\n  // --- Summarizing time ---\n\n  it('returns zero entries summary when no tasks recorded', () => {\n    expect(tracker.getSummary()).toEqual({});\n  });\n\n  it('returns total time per task name in ms', () => {\n    const before = Date.now();\n    tracker.start('writing');\n    tracker.stop();\n    const after = Date.now();\n\n    const summary = tracker.getSummary();\n    expect(typeof summary['writing']).toBe('number');\n    expect(summary['writing']).toBeGreaterThanOrEqual(0);\n    expect(summary['writing']).toBeLessThanOrEqual(after - before + 100);\n  });\n\n  it('sums multiple entries with the same task name', () => {\n    tracker.start('writing');\n    tracker.stop();\n    tracker.start('writing');\n    tracker.stop();\n\n    const summary = tracker.getSummary();\n    expect(summary['writing']).toBeGreaterThanOrEqual(0);\n    // Two separate entries both contribute\n    const entries = tracker.getEntries();\n    const manual = entries.reduce((acc, e) => {\n      const dur = (e.stoppedAt?.getTime() ?? Date.now()) - e.startedAt.getTime();\n      return acc + dur;\n    }, 0);\n    expect(summary['writing']).toBe(manual);\n  });\n\n  it('uses current time for running tasks in summary', () => {\n    tracker.start('running');\n    // Don't stop - it's still running\n\n    const before = Date.now();\n    const summary = tracker.getSummary();\n    const after = Date.now();\n\n    expect(summary['running']).toBeGreaterThanOrEqual(0);\n    // Duration is bounded by how long since we started\n    expect(summary['running']).toBeLessThanOrEqual(after - before + 200);\n  });\n\n  it('keeps separate totals for different task names', () => {\n    tracker.start('coding');\n    tracker.stop();\n    tracker.start('meetings');\n    tracker.stop();\n\n    const summary = tracker.getSummary();\n    expect(typeof summary['coding']).toBe('number');\n    expect(typeof summary['meetings']).toBe('number');\n    expect(Object.keys(summary)).toHaveLength(2);\n  });\n\n  // --- Unicode support ---\n\n  it('handles unicode task names', () => {\n    tracker.start('日本語タスク');\n    tracker.stop();\n    const entries = tracker.getEntries();\n    expect(entries[0].name).toBe('日本語タスク');\n  });\n\n  it('handles emoji task names', () => {\n    tracker.start('🚀 rocket launch');\n    tracker.stop();\n    const summary = tracker.getSummary();\n    expect(typeof summary['🚀 rocket launch']).toBe('number');\n  });\n\n  it('handles combined emoji and unicode in summary', () => {\n    tracker.start('📝 写作');\n    tracker.stop();\n    tracker.start(