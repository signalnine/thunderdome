index 0000000..0e6fdb9
--- /dev/null
+++ b/src/tracker.ts
@@ -0,0 +1,92 @@
+import { readFileSync, writeFileSync, mkdirSync, existsSync } from 'node:fs';
+import { dirname } from 'node:path';
+
+export interface TimeEntry {
+  name: string;
+  startedAt: Date;
+  stoppedAt: Date | null;
+}
+
+interface SerializedEntry {
+  name: string;
+  startedAt: string;
+  stoppedAt: string | null;
+}
+
+interface GetEntriesOptions {
+  from?: Date;
+  to?: Date;
+}
+
+export class TimeTracker {
+  private filePath: string;
+  private entries: TimeEntry[];
+
+  constructor(filePath: string) {
+    this.filePath = filePath;
+    this.entries = this.load();
+  }
+
+  start(name: string): void {
+    if (!name.trim()) {
+      throw new Error('Task name must not be empty');
+    }
+    // Auto-stop any running timer
+    const running = this.entries.find(e => e.stoppedAt === null);
+    if (running) {
+      running.stoppedAt = new Date();
+    }
+    this.entries.push({ name, startedAt: new Date(), stoppedAt: null });
+    this.save();
+  }
+
+  stop(): void {
+    const running = this.entries.find(e => e.stoppedAt === null);
+    if (!running) {
+      throw new Error('No timer is currently running');
+    }
+    running.stoppedAt = new Date();
+    this.save();
+  }
+
+  getEntries(options?: GetEntriesOptions): TimeEntry[] {
+    const { from, to } = options ?? {};
+    return this.entries.filter(e => {
+      if (from && e.startedAt < from) return false;
+      if (to && e.startedAt > to) return false;
+      return true;
+    });
+  }
+
+  getSummary(): Record<string, number> {
+    const summary: Record<string, number> = {};
+    for (const entry of this.entries) {
+      const end = entry.stoppedAt?.getTime() ?? Date.now();
+      const duration = end - entry.startedAt.getTime();
+      summary[entry.name] = (summary[entry.name] ?? 0) + duration;
+    }
+    return summary;
+  }
+
+  private load(): TimeEntry[] {
+    if (!existsSync(this.filePath)) return [];
+    const raw = readFileSync(this.filePath, 'utf-8');
+    const serialized: SerializedEntry[] = JSON.parse(raw) as SerializedEntry[];
+    return serialized.map(e => ({
+      name: e.name,
+      startedAt: new Date(e.startedAt),
+      stoppedAt: e.stoppedAt ? new Date(e.stoppedAt) : null,
+    }));
+  }
+
+  private save(): void {
+    const dir = dirname(this.filePath);
+    mkdirSync(dir, { recursive: true });
+    const serialized: SerializedEntry[] = this.entries.map(e => ({
+      name: e.name,
+      startedAt: e.startedAt.toISOString(),
+      stoppedAt: e.stoppedAt ? e.stoppedAt.toISOString() : null,
+    }));
+    writeFileSync(this.filePath, JSON.stringify(serialized, null, 2), 'utf-8');
+  }
+}
