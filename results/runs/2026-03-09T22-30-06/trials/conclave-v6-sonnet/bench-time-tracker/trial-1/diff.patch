IT\",\n+      \"dependencies\": {\n+        \"emoji-regex\": \"^8.0.0\",\n+        \"is-fullwidth-code-point\": \"^3.0.0\",\n+        \"strip-ansi\": \"^6.0.1\"\n+      },\n+      \"engines\": {\n+        \"node\": \">=8\"\n+      }\n+    },\n+    \"node_modules/wrap-ansi/node_modules/ansi-regex\": {\n+      \"version\": \"6.2.2\",\n+      \"resolved\": \"https://registry.npmjs.org/ansi-regex/-/ansi-regex-6.2.2.tgz\",\n+      \"integrity\": \"sha512-Bq3SmSpyFHaWjPk8If9yc6svM8c56dB5BAtW4Qbw5jHTwwXXcTLoRMkpDJp6VL0XzlWaCHTXrkFURMYmD0sLqg==\",\n+      \"dev\": true,\n+      \"license\": \"MIT\",\n+      \"engines\": {\n+        \"node\": \">=12\"\n+      },\n+      \"funding\": {\n+        \"url\": \"https://github.com/chalk/ansi-regex?sponsor=1\"\n+      }\n+    },\n+    \"node_modules/wrap-ansi/node_modules/ansi-styles\": {\n+      \"version\": \"6.2.3\",\n+      \"resolved\": \"https://registry.npmjs.org/ansi-styles/-/ansi-styles-6.2.3.tgz\",\n+      \"integrity\": \"sha512-4Dj6M28JB+oAH8kFkTLUo+a2jwOFkuqb3yucU0CANcRRUbxS0cP0nZYCGjcc3BNXwRIsUVmDGgzawme7zvJHvg==\",\n+      \"dev\": true,\n+      \"license\": \"MIT\",\n+      \"engines\": {\n+        \"node\": \">=12\"\n+      },\n+      \"funding\": {\n+        \"url\": \"https://github.com/chalk/ansi-styles?sponsor=1\"\n+      }\n+    },\n+    \"node_modules/wrap-ansi/node_modules/strip-ansi\": {\n+      \"version\": \"7.2.0\",\n+      \"resolved\": \"https://registry.npmjs.org/strip-ansi/-/strip-ansi-7.2.0.tgz\",\n+      \"integrity\": \"sha512-yDPMNjp4WyfYBkHnjIRLfca1i6KMyGCtsVgoKe/z1+6vukgaENdgGBZt+ZmKPc4gavvEZ5OgHfHdrazhgNyG7w==\",\n+      \"dev\": true,\n+      \"license\": \"MIT\",\n+      \"dependencies\": {\n+        \"ansi-regex\": \"^6.2.2\"\n+      },\n+      \"engines\": {\n+        \"node\": \">=12\"\n+      },\n+      \"funding\": {\n+        \"url\": \"https://github.com/chalk/strip-ansi?sponsor=1\"\n+      }\n+    },\n     \"node_modules/wrappy\": {\n       \"version\": \"1.0.2\",\n       \"resolved\": \"https://registry.npmjs.org/wrappy/-/wrappy-1.0.2.tgz\",\ndiff --git a/src/index.ts b/src/index.ts\nnew file mode 100644\nindex 0000000..55b2b2c\n--- /dev/null\n+++ b/src/index.ts\n@@ -0,0 +1,2 @@\n+export { TimeTracker } from './tracker.js';\n+export type { TimeEntry } from './tracker.js';\ndiff --git a/src/tracker.test.ts b/src/tracker.test.ts\nnew file mode 100644\nindex 0000000..e62670b\n--- /dev/null\n+++ b/src/tracker.test.ts\n@@ -0,0 +1,254 @@\n+import { describe, it, expect, beforeEach, afterEach } from 'vitest';\n+import { mkdirSync, rmSync, existsSync } from 'node:fs';\n+import { join } from 'node:path';\n+import { tmpdir } from 'node:os';\n+import { TimeTracker } from './tracker.js';\n+\n+function makeTmpDir(): string {\n+  const dir = join(tmpdir(), `tracker-test-${Date.now()}-${Math.random().toString(36).slice(2)}`);\n+  mkdirSync(dir, { recursive: true });\n+  return dir;\n+}\n+\n+describe('TimeTracker', () => {\n+  let tmpDir: string;\n+  let dataFile: string;\n+  let tracker: TimeTracker;\n+\n+  beforeEach(() => {\n+    tmpDir = makeTmpDir();\n+    dataFile = join(tmpDir, 'time-entries.json');\n+    tracker = new TimeTracker(dataFile);\n+  });\n+\n+  afterEach(() => {\n+    rmSync(tmpDir, { recursive: true, force: true });\n+  });\n+\n+  // --- Error handling ---\n+\n+  it('throws when starting a timer with an empty name', () => {\n+    expect(() => tracker.start('')).toThrow();\n+  });\n+\n+  it('throws when starting a timer with a whitespace-only name', () => {\n+    expect(() => tracker.start('   ')).toThrow();\n+  });\n+\n+  it('throws when stopping with no running timer', () => {\n+    expect(() => tracker.stop()).toThrow();\n+  });\n+\n+  // --- Start and stop ---\n+\n+  it('starts a timer and records a running entry', () => {\n+    tracker.start('coding');\n+    const entries = tracker.getEntries();\n+    expect(entries).toHaveLength(1);\n+    expect(entries[0].name).toBe('coding');\n+    expect(entries[0].startedAt).toBeInstanceOf(Date);\n+    expect(entries[0].stoppedAt).toBeNull();\n+  });\n+\n+  it('stops a running timer and records stop time', () => {\n+    tracker.start('coding');\n+    tracker.stop();\n+    const entries = tracker.getEntries();\n+    expect(entries).toHaveLength(1);\n+    expect(entries[0].stoppedAt).toBeInstanceOf(Date);\n+  });\n+\n+  it('auto-stops previous timer when starting a new one', () => {\n+    tracker.start('task-a');\n+    tracker.start('task-b');\n+    const entries = tracker.getEntries();\n+    expect(entries).toHaveLength(2);\n+    expect(entries[0].name).toBe('task-a');\n+    expect(entries[0].stoppedAt).toBeInstanceOf(Date);\n+    expect(entries[1].name).toBe('task-b');\n+    expect(entries[1].stoppedAt).toBeNull();\n+  });\n+\n+  it('records correct start time (within a few seconds)', () => {\n+    const before = Date.now();\n+    tracker.start('coding');\n+    const after = Date.now();\n+    const entry = tracker.getEntries()[0];\n+    expect(entry.startedAt.getTime()).toBeGreaterThanOrEqual(before);\n+    expect(entry.startedAt.getTime()).toBeLessThanOrEqual(after);\n+  });\n+\n+  // --- Persistence ---\n+\n+  it('creates the data file automatically', () => {\n+    tracker.start('coding');\n+    expect(existsSync(dataFile)).toBe(true);\n+  });\n+\n+  it('creates parent directories automatically', () => {\n+    const nestedFile = join(tmpDir, 'a', 'b', 'c', 'data.json');\n+    const t = new TimeTracker(nestedFile);\n+    t.start('task');\n+    expect(existsSync(nestedFile)).toBe(true);\n+  });\n+\n+  it('persists entries across tracker instances', () => {\n+    tracker.start('session-1');\n+    tracker.stop();\n+\n+    const tracker2 = new TimeTracker(dataFile);\n+    const entries = tracker2.getEntries();\n+    expect(entries).toHaveLength(1);\n+    expect(entries[0].name).toBe('session-1');\n+  });\n+\n+  it('preserves running timer across instances', () => {\n+    tracker.start('ongoing');\n+\n+    const tracker2 = new TimeTracker(dataFile);\n+    const entries = tracker2.getEntries();\n+    expect(entries).toHaveLength(1);\n+    expect(entries[0].stoppedAt).toBeNull();\n+  });\n+\n+  // --- Querying by date range ---\n+\n+  it('returns all entries when no filter given', () => {\n+    tracker.start('a');\n+    tracker.stop();\n+    tracker.start('b');\n+    tracker.stop();\n+    expect(tracker.getEntries()).toHaveLength(2);\n+  });\n+\n+  it('filters entries by start of range (from)', () => {\n+    const past = new Date(Date.now() - 10_000);\n+    const future = new Date(Date.now() + 10_000);\n+\n+    tracker.start('old');\n+    tracker.stop();\n+    tracker.start('new');\n+    tracker.stop();\n+\n+    // All entries started now, filter from 1 hour ago => all included\n+    const all = tracker.getEntries({ from: past });\n+    expect(all).toHaveLength(2);\n+\n+    // Filter from future => none\n+    const none = tracker.getEntries({ from: future });\n+    expect(none).toHaveLength(0);\n+  });\n+\n+  it('filters entries by end of range (to)', () => {\n+    const past = new Date(Date.now() - 10_000);\n+    const future = new Date(Date.now() + 10_000);\n+\n+    tracker.start('task');\n+    tracker.stop();\n+\n+    // All entries started now, filter to future => included\n+    const included = tracker.getEntries({ to: future });\n+    expect(included).toHaveLength(1);\n+\n+    // Filter to past => excluded\n+    const excluded = tracker.getEntries({ to: past });\n+    expect(excluded).toHaveLength(0);\n+  });\n+\n+  it('filters entries by both from and to', () => {\n+    tracker.start('task');\n+    tracker.stop();\n+\n+    const from = new Date(Date.now() - 5_000);\n+    const to = new Date(Date.now() + 5_000);\n+    const result = tracker.getEntries({ from, to });\n+    expect(result).toHaveLength(1);\n+  });\n+\n+  // --- Summarizing time ---\n+\n+  it('returns zero entries summary when no tasks recorded', () => {\n+    expect(tracker.getSummary()).toEqual({});\n+  });\n+\n+  it('returns total time per task name in m