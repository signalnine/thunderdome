+import { describe, it, expect, beforeEach } from 'vitest';
+import { createReviewService } from './index.js';
+
+describe('ReviewService', () => {
+  let reviews: ReturnType<typeof createReviewService>;
+
+  beforeEach(() => {
+    reviews = createReviewService();
+  });
+
+  describe('addReview', () => {
+    it('adds a review and returns it with id, createdAt, and flagged=false', () => {
+      const review = reviews.addReview({
+        pluginName: 'my-plugin',
+        pluginVersion: '1.0.0',
+        userId: 'user1',
+        rating: 5,
+        comment: 'Great plugin!',
+      });
+      expect(review.id).toBeGreaterThan(0);
+      expect(review.pluginName).toBe('my-plugin');
+      expect(review.pluginVersion).toBe('1.0.0');
+      expect(review.userId).toBe('user1');
+      expect(review.rating).toBe(5);
+      expect(review.comment).toBe('Great plugin!');
+      expect(review.flagged).toBe(false);
+      expect(typeof review.createdAt).toBe('string');
+    });
+
+    it('assigns unique ids to each review', () => {
+      const r1 = reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 4, comment: 'good' });
+      const r2 = reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: 'ok' });
+      expect(r1.id).not.toBe(r2.id);
+    });
+  });
+
+  describe('getReviews', () => {
+    it('returns reviews for a plugin', () => {
+      reviews.addReview({ pluginName: 'plugin-a', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'A' });
+      reviews.addReview({ pluginName: 'plugin-b', pluginVersion: '1.0.0', userId: 'u1', rating: 3, comment: 'B' });
+      const result = reviews.getReviews('plugin-a');
+      expect(result).toHaveLength(1);
+      expect(result[0].pluginName).toBe('plugin-a');
+    });
+
+    it('returns empty array for plugin with no reviews', () => {
+      expect(reviews.getReviews('nonexistent')).toEqual([]);
+    });
+  });
+
+  describe('getAverageRating', () => {
+    it('computes average rating for a plugin', () => {
+      reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 4, comment: '' });
+      reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u2', rating: 2, comment: '' });
+      expect(reviews.getAverageRating('p')).toBe(3);
+    });
+
+    it('excludes flagged reviews from average', () => {
+      const r1 = reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });
+      reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u2', rating: 1, comment: 'spam' });
+      reviews.flagReview(r1.id + 1); // flag the second review (id = r1.id+1 in sequential IDs)
+      // Actually flag r1's id+1 might be wrong. Let's flag explicitly
+      const all = reviews.getReviews('p');
+      const spamReview = all.find((r) => r.comment === 'spam')!;
+      reviews.flagReview(spamReview.id);
+      expect(reviews.getAverageRating('p')).toBe(5);
+    });
+
+    it('returns 0 for plugin with no reviews', () => {
+      expect(reviews.getAverageRating('nonexistent')).toBe(0);
+    });
+
+    it('returns 0 when all reviews are flagged', () => {
+      const r = reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });
+      reviews.flagReview(r.id);
+      expect(reviews.getAverageRating('p')).toBe(0);
+    });
+  });
+
+  describe('flagReview', () => {
+    it('flags a review', () => {
+      const r = reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 3, comment: '' });
+      reviews.flagReview(r.id);
+      const flagged = reviews.getFlaggedReviews();
+      expect(flagged.some((rev) => rev.id === r.id)).toBe(true);
+    });
+  });
+
+  describe('getFlaggedReviews', () => {
+    it('returns all flagged reviews', () => {
+      const r1 = reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 1, comment: 'spam' });
+      reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u2', rating: 5, comment: 'great' });
+      reviews.flagReview(r1.id);
+      const flagged = reviews.getFlaggedReviews();
+      expect(flagged).toHaveLength(1);
+      expect(flagged[0].id).toBe(r1.id);
+    });
+
+    it('returns empty array when no reviews are flagged', () => {
+      reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });
+      expect(reviews.getFlaggedReviews()).toHaveLength(0);
+    });
+  });
+
+  describe('removeReview', () => {
+    it('removes an existing review', () => {
+      const r = reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 4, comment: '' });
+      expect(reviews.removeReview(r.id)).toBe(true);
+      expect(reviews.getReviews('p')).toHaveLength(0);
+    });
+
+    it('returns false for nonexistent review', () => {
+      expect(reviews.removeReview(9999)).toBe(false);
+    });
+  });
+
+  describe('getReviewsByUser', () => {
+    it('returns all reviews by a specific user', () => {
+      reviews.addReview({ pluginName: 'plugin-a', pluginVersion: '1.0.0', userId: 'alice', rating: 5, comment: '' });
+      reviews.addReview({ pluginName: 'plugin-b', pluginVersion: '1.0.0', userId: 'alice', rating: 3, comment: '' });
+      reviews.addReview({ pluginName: 'plugin-a', pluginVersion: '1.0.0', userId: 'bob', rating: 4, comment: '' });
+      const aliceReviews = reviews.getReviewsByUser('alice');
+      expect(aliceReviews).toHaveLength(2);
+      expect(aliceReviews.every((r) => r.userId === 'alice')).toBe(true);
+    });
+
+    it('returns empty array for user with no reviews', () => {
+      expect(reviews.getReviewsByUser('nobody')).toEqual([]);
+    });
+  });
+
+  describe('getReviewCount', () => {
+    it('returns the count of reviews for a plugin', () => {
+      reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });
+      reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u2', rating: 4, comment: '' });
+      expect(reviews.getReviewCount('p')).toBe(2);
+    });
+
+    it('returns 0 for plugin with no reviews', () => {
+      expect(reviews.getReviewCount('nonexistent')).toBe(0);
+    });
+  });
+});
