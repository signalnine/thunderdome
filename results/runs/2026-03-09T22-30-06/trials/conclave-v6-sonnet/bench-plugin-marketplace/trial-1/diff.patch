+import { describe, it, expect } from 'vitest';
+import { createRunner } from './index.js';
+
+describe('RunnerService', () => {
+  const runner = createRunner();
+
+  describe('execute', () => {
+    it('executes simple code and returns success', async () => {
+      const result = await runner.execute('1 + 1');
+      expect(result.success).toBe(true);
+      expect(result.output).toBe(2);
+      expect(result.duration).toBeGreaterThanOrEqual(0);
+      expect(result.memoryUsed).toBeGreaterThanOrEqual(0);
+      expect(result.error).toBeUndefined();
+    });
+
+    it('captures return value as output', async () => {
+      const result = await runner.execute('"hello world"');
+      expect(result.success).toBe(true);
+      expect(result.output).toBe('hello world');
+    });
+
+    it('returns failure on code that throws', async () => {
+      const result = await runner.execute('throw new Error("oops")');
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('oops');
+    });
+
+    it('returns failure on syntax error', async () => {
+      const result = await runner.execute('this is not valid js !!!');
+      expect(result.success).toBe(false);
+      expect(result.error).toBeDefined();
+    });
+
+    it('passes context variables into the sandbox', async () => {
+      const result = await runner.execute('x + y', { x: 3, y: 4 });
+      expect(result.success).toBe(true);
+      expect(result.output).toBe(7);
+    });
+
+    it('sandbox is isolated from host globals', async () => {
+      const result = await runner.execute('typeof process');
+      // process should not be available unless we pass it
+      expect(result.output).toBe('undefined');
+    });
+
+    it('includes duration in result', async () => {
+      const result = await runner.execute('42');
+      expect(typeof result.duration).toBe('number');
+      expect(result.duration).toBeGreaterThanOrEqual(0);
+    });
+  });
+
+  describe('executeWithTimeout', () => {
+    it('executes fast code within timeout', async () => {
+      const result = await runner.executeWithTimeout('1 + 1', 5000);
+      expect(result.success).toBe(true);
+      expect(result.output).toBe(2);
+    });
+
+    it('times out runaway code', async () => {
+      // Infinite loop — should be killed by timeout
+      const result = await runner.executeWithTimeout(
+        'let i = 0; while(true) { i++; }',
+        100
+      );
+      expect(result.success).toBe(false);
+      expect(result.error).toMatch(/timeout/i);
+    }, 10000);
+
+    it('passes context with timeout', async () => {
+      const result = await runner.executeWithTimeout('value * 2', 1000, { value: 21 });
+      expect(result.success).toBe(true);
+      expect(result.output).toBe(42);
+    });
+  });
+});
