diff --git a/src/registry/index.ts b/src/registry/index.ts
new file mode 100644
index 0000000..fe6084e
--- /dev/null
+++ b/src/registry/index.ts
@@ -0,0 +1,96 @@
+import Database from 'better-sqlite3';
+import type { PluginManifest, RegistryService } from '../types.js';
+
+export function createRegistry(dbPath = ':memory:'): RegistryService {
+  const db = new Database(dbPath);
+
+  db.exec(`
+    CREATE TABLE IF NOT EXISTS plugins (
+      name TEXT NOT NULL,
+      version TEXT NOT NULL,
+      manifest TEXT NOT NULL,
+      PRIMARY KEY (name, version)
+    )
+  `);
+
+  return {
+    register(manifest: PluginManifest): void {
+      const stmt = db.prepare(
+        'INSERT OR REPLACE INTO plugins (name, version, manifest) VALUES (?, ?, ?)'
+      );
+      stmt.run(manifest.name, manifest.version, JSON.stringify(manifest));
+    },
+
+    get(name: string): PluginManifest | null {
+      // Return the highest semver version
+      const rows = db
+        .prepare('SELECT manifest FROM plugins WHERE name = ?')
+        .all(name) as { manifest: string }[];
+      if (rows.length === 0) return null;
+      // Sort by version descending, return first
+      const manifests = rows.map((r) => JSON.parse(r.manifest) as PluginManifest);
+      manifests.sort((a, b) => {
+        const [aMaj, aMin, aPatch] = a.version.split('.').map(Number);
+        const [bMaj, bMin, bPatch] = b.version.split('.').map(Number);
+        if (aMaj !== bMaj) return bMaj - aMaj;
+        if (aMin !== bMin) return bMin - aMin;
+        return bPatch - aPatch;
+      });
+      return manifests[0];
+    },
+
+    getVersion(name: string, version: string): PluginManifest | null {
+      const row = db
+        .prepare('SELECT manifest FROM plugins WHERE name = ? AND version = ?')
+        .get(name, version) as { manifest: string } | undefined;
+      if (!row) return null;
+      return JSON.parse(row.manifest) as PluginManifest;
+    },
+
+    list(): PluginManifest[] {
+      const rows = db
+        .prepare('SELECT manifest FROM plugins')
+        .all() as { manifest: string }[];
+      return rows.map((r) => JSON.parse(r.manifest) as PluginManifest);
+    },
+
+    search(query: string): PluginManifest[] {
+      const lower = query.toLowerCase();
+      const rows = db
+        .prepare('SELECT manifest FROM plugins')
+        .all() as { manifest: string }[];
+      const manifests = rows.map((r) => JSON.parse(r.manifest) as PluginManifest);
+      return manifests.filter(
+        (m) =>
+          m.name.toLowerCase().includes(lower) ||
+          m.description.toLowerCase().includes(lower) ||
+          m.author.toLowerCase().includes(lower)
+      );
+    },
+
+    remove(name: string, version: string): boolean {
+      const result = db
+        .prepare('DELETE FROM plugins WHERE name = ? AND version = ?')
+        .run(name, version);
+      return result.changes > 0;
+    },
+
+    listVersions(name: string): string[] {
+      const rows = db
+        .prepare('SELECT version FROM plugins WHERE name = ?')
+        .all(name) as { version: string }[];
+      return rows.map((r) => r.version);
+    },
+
+    update(name: string, version: string, updates: Partial<PluginManifest>): void {
+      const existing = this.getVersion(name, version);
+      if (!existing) throw new Error(`Plugin ${name}@${version} not found`);
+      const updated = { ...existing, ...updates };
+      db.prepare('UPDATE plugins SET manifest = ? WHERE name = ? AND version = ?').run(
+        JSON.stringify(updated),
+        name,
+        version
+      );
+    },
+  };
+}
diff --git a/src/registry/registry.test.ts b/src/registry/registry.test.ts
new file mode 100644
index 0000000..818f316
--- /dev/null
+++ b/src/registry/registry.test.ts
@@ -0,0 +1,109 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { createRegistry } from './index.js';
+import type { PluginManifest } from '../types.js';
+
+const makeManifest = (overrides: Partial<PluginManifest> = {}): PluginManifest => ({
+  name: 'test-plugin',
+  version: '1.0.0',
+  description: 'A test plugin',
+  author: 'tester',
+  dependencies: {},
+  entryPoint: 'index.js',
+  permissions: [],
+  ...overrides,
+});
+
+describe('PluginRegistry', () => {
+  let registry: ReturnType<typeof createRegistry>;
+
+  beforeEach(() => {
+    registry = createRegistry();
+  });
+
+  it('registers a plugin and retrieves it by name', () => {
+    const manifest = makeManifest();
+    registry.register(manifest);
+    const found = registry.get('test-plugin');
+    expect(found).not.toBeNull();
+    expect(found?.name).toBe('test-plugin');
+  });
+
+  it('returns null for unknown plugin', () => {
+    expect(registry.get('nonexistent')).toBeNull();
+  });
+
+  it('retrieves a plugin by name and version', () => {
+    const manifest = makeManifest({ version: '2.0.0' });
+    registry.register(manifest);
+    const found = registry.getVersion('test-plugin', '2.0.0');
+    expect(found?.version).toBe('2.0.0');
+  });
+
+  it('returns null for unknown version', () => {
+    const manifest = makeManifest({ version: '1.0.0' });
+    registry.register(manifest);
+    expect(registry.getVersion('test-plugin', '9.9.9')).toBeNull();
+  });
+
+  it('lists all registered plugins', () => {
+    registry.register(makeManifest({ name: 'plugin-a', version: '1.0.0' }));
+    registry.register(makeManifest({ name: 'plugin-b', version: '1.0.0' }));
+    const all = registry.list();
+    expect(all.length).toBe(2);
+  });
+
+  it('supports multiple versions of same plugin', () => {
+    registry.register(makeManifest({ version: '1.0.0' }));
+    registry.register(makeManifest({ version: '2.0.0' }));
+    const versions = registry.listVersions('test-plugin');
+    expect(versions).toContain('1.0.0');
+    expect(versions).toContain('2.0.0');
+  });
+
+  it('get returns the latest version when multiple exist', () => {
+    registry.register(makeManifest({ version: '1.0.0' }));
+    registry.register(makeManifest({ version: '2.0.0' }));
+    const found = registry.get('test-plugin');
+    expect(found).not.toBeNull();
+  });
+
+  it('searches plugins by name', () => {
+    registry.register(makeManifest({ name: 'auth-plugin', version: '1.0.0' }));
+    registry.register(makeManifest({ name: 'logger-plugin', version: '1.0.0' }));
+    const results = registry.search('auth');
+    expect(results.length).toBe(1);
+    expect(results[0].name).toBe('auth-plugin');
+  });
+
+  it('searches plugins by description', () => {
+    registry.register(makeManifest({ name: 'auth-plugin', description: 'handles authentication', version: '1.0.0' }));
+    registry.register(makeManifest({ name: 'logger-plugin', description: 'logs events', version: '1.0.0' }));
+    const results = registry.search('authentication');
+    expect(results.length).toBe(1);
+    expect(results[0].name).toBe('auth-plugin');
+  });
+
+  it('removes a specific version', () => {
+    registry.register(makeManifest({ version: '1.0.0' }));
+    registry.register(makeManifest({ version: '2.0.0' }));
+    const removed = registry.remove('test-plugin', '1.0.0');
+    expect(removed).toBe(true);
+    expect(registry.getVersion('test-plugin', '1.0.0')).toBeNull();
+    expect(registry.getVersion('test-plugin', '2.0.0')).not.toBeNull();
+  });
+
+  it('returns false when removing nonexistent version', () => {
+    expect(registry.remove('test-plugin', '1.0.0')).toBe(false);
+  });
+
+  it('updates plugin fields', () => {
+    registry.register(makeManifest({ version: '1.0.0' }));
+    registry.update('test-plugin', '1.0.0', { description: 'updated desc' });
+    const found = registry.getVersion('test-plugin', '1.0.0');
+    expect(found?.description).toBe('updated desc');
+  });
+
+  it('listVersions returns empty array for unknown plugin', () => {
+    expect(registry.listVersions('nonexistent')).toEqual([]);
+  });
+});
