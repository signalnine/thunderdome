@@ -0,0 +1,109 @@
+import { describe, it, expect } from 'vitest';
+import { createResolver } from './index.js';
+
+describe('ResolverService', () => {
+  const resolver = createResolver();
+
+  describe('satisfies', () => {
+    it('returns true when version satisfies range', () => {
+      expect(resolver.satisfies('1.2.3', '^1.0.0')).toBe(true);
+    });
+
+    it('returns false when version does not satisfy range', () => {
+      expect(resolver.satisfies('2.0.0', '^1.0.0')).toBe(false);
+    });
+
+    it('handles exact version ranges', () => {
+      expect(resolver.satisfies('1.0.0', '1.0.0')).toBe(true);
+      expect(resolver.satisfies('1.0.1', '1.0.0')).toBe(false);
+    });
+
+    it('handles tilde ranges', () => {
+      expect(resolver.satisfies('1.2.9', '~1.2.0')).toBe(true);
+      expect(resolver.satisfies('1.3.0', '~1.2.0')).toBe(false);
+    });
+  });
+
+  describe('maxSatisfying', () => {
+    it('returns the highest version satisfying the range', () => {
+      const result = resolver.maxSatisfying(['1.0.0', '1.5.0', '2.0.0'], '^1.0.0');
+      expect(result).toBe('1.5.0');
+    });
+
+    it('returns null when no version satisfies', () => {
+      const result = resolver.maxSatisfying(['2.0.0', '3.0.0'], '^1.0.0');
+      expect(result).toBeNull();
+    });
+
+    it('returns null for empty array', () => {
+      expect(resolver.maxSatisfying([], '^1.0.0')).toBeNull();
+    });
+  });
+
+  describe('validRange', () => {
+    it('returns true for valid semver ranges', () => {
+      expect(resolver.validRange('^1.0.0')).toBe(true);
+      expect(resolver.validRange('~1.2.3')).toBe(true);
+      expect(resolver.validRange('>=1.0.0 <2.0.0')).toBe(true);
+      expect(resolver.validRange('*')).toBe(true);
+    });
+
+    it('returns false for invalid ranges', () => {
+      expect(resolver.validRange('not-a-range')).toBe(false);
+    });
+  });
+
+  describe('resolve', () => {
+    it('resolves a single constraint to a concrete version', () => {
+      const results = resolver.resolve(
+        [{ name: 'lodash', range: '^4.0.0' }],
+        { lodash: ['4.0.0', '4.17.21', '5.0.0'] }
+      );
+      expect(results).toHaveLength(1);
+      expect(results[0].name).toBe('lodash');
+      expect(results[0].version).toBe('4.17.21');
+      expect(results[0].satisfies).toBe('^4.0.0');
+    });
+
+    it('resolves multiple constraints', () => {
+      const results = resolver.resolve(
+        [
+          { name: 'lodash', range: '^4.0.0' },
+          { name: 'express', range: '^4.18.0' },
+        ],
+        {
+          lodash: ['4.17.21'],
+          express: ['4.18.2', '5.0.0'],
+        }
+      );
+      expect(results).toHaveLength(2);
+      const lodash = results.find((r) => r.name === 'lodash');
+      const express = results.find((r) => r.name === 'express');
+      expect(lodash?.version).toBe('4.17.21');
+      expect(express?.version).toBe('4.18.2');
+    });
+
+    it('throws when constraint cannot be resolved', () => {
+      expect(() =>
+        resolver.resolve(
+          [{ name: 'missing', range: '^1.0.0' }],
+          {}
+        )
+      ).toThrow();
+    });
+
+    it('throws when no available version satisfies constraint', () => {
+      expect(() =>
+        resolver.resolve(
+          [{ name: 'pkg', range: '^3.0.0' }],
+          { pkg: ['1.0.0', '2.0.0'] }
