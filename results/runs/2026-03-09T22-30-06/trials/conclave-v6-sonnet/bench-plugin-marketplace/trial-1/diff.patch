g, unknown> = {}\n    ): Promise<SandboxResult> {\n      const startTime = process.hrtime.bigint();\n      const startMemory = process.memoryUsage().heapUsed;\n\n      const wrappedCode = `(function() { return (${code}); })()`;\n      const sandbox = vm.createContext({ ...context });\n\n      let output: unknown;\n      try {\n        output = vm.runInContext(wrappedCode, sandbox, { timeout: timeoutMs });\n      } catch (err) {\n        // Try plain execution if expression wrap fails\n        try {\n          output = vm.runInContext(code, sandbox, { timeout: timeoutMs });\n        } catch (err2) {\n          const endTime = process.hrtime.bigint();\n          const endMemory = process.memoryUsage().heapUsed;\n          const errMsg =\n            err2 instanceof Error ? err2.message : String(err2);\n          const isTimeout =\n            errMsg.includes('Script execution timed out') ||\n            errMsg.toLowerCase().includes('timeout');\n          return {\n            success: false,\n            output: null,\n            duration: Number(endTime - startTime) / 1_000_000,\n            memoryUsed: Math.max(0, endMemory - startMemory),\n            error: isTimeout ? `Execution timeout after ${timeoutMs}ms` : errMsg,\n          };\n        }\n      }\n\n      const endTime = process.hrtime.bigint();\n      const endMemory = process.memoryUsage().heapUsed;\n\n      return {\n        success: true,\n        output,\n        duration: Number(endTime - startTime) / 1_000_000,\n        memoryUsed: Math.max(0, endMemory - startMemory),\n      };\n    },\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":492,"cache_read_input_tokens":38506,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":492},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"3d959c6e-c120-4253-a