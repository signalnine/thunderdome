@@ -0,0 +1,103 @@
+import vm from 'node:vm';
+import type { RunnerService, SandboxResult } from '../types.js';
+
+function runInSandbox(
+  code: string,
+  context: Record<string, unknown>
+): SandboxResult {
+  const startTime = process.hrtime.bigint();
+  const startMemory = process.memoryUsage().heapUsed;
+
+  // Wrap code so the last expression value is returned
+  const wrappedCode = `(function() { return (${code}); })()`;
+
+  const sandbox = vm.createContext({ ...context });
+
+  let output: unknown;
+  try {
+    output = vm.runInContext(wrappedCode, sandbox);
+  } catch (_err) {
+    // If expression wrapping fails (e.g. statements), try plain execution
+    try {
+      output = vm.runInContext(code, sandbox);
+    } catch (err2) {
+      const endTime = process.hrtime.bigint();
+      const endMemory = process.memoryUsage().heapUsed;
+      return {
+        success: false,
+        output: null,
+        duration: Number(endTime - startTime) / 1_000_000,
+        memoryUsed: Math.max(0, endMemory - startMemory),
+        error: err2 instanceof Error ? err2.message : String(err2),
+      };
+    }
+  }
+
+  const endTime = process.hrtime.bigint();
+  const endMemory = process.memoryUsage().heapUsed;
+
+  return {
+    success: true,
+    output,
+    duration: Number(endTime - startTime) / 1_000_000,
+    memoryUsed: Math.max(0, endMemory - startMemory),
+  };
+}
+
+export function createRunner(): RunnerService {
+  return {
+    async execute(
+      code: string,
+      context: Record<string, unknown> = {}
+    ): Promise<SandboxResult> {
+      return runInSandbox(code, context);
+    },
+
+    async executeWithTimeout(
+      code: string,
+      timeoutMs: number,
+      context: Record<string, unknown> = {}
+    ): Promise<SandboxResult> {
+      const startTime = process.hrtime.bigint();
+      const startMemory = process.memoryUsage().heapUsed;
+
+      const wrappedCode = `(function() { return (${code}); })()`;
+      const sandbox = vm.createContext({ ...context });
+
+      let output: unknown;
+      try {
+        output = vm.runInContext(wrappedCode, sandbox, { timeout: timeoutMs });
+      } catch (err) {
+        // Try plain execution if expression wrap fails
+        try {
+          output = vm.runInContext(code, sandbox, { timeout: timeoutMs });
+        } catch (err2) {
+          const endTime = process.hrtime.bigint();
+          const endMemory = process.memoryUsage().heapUsed;
+          const errMsg =
+            err2 instanceof Error ? err2.message : String(err2);
+          const isTimeout =
+            errMsg.includes('Script execution timed out') ||
+            errMsg.toLowerCase().includes('timeout');
+          return {
+            success: false,
+            output: null,
+            duration: Number(endTime - startTime) / 1_000_000,
+            memoryUsed: Math.max(0, endMemory - startMemory),
+            error: isTimeout ? `Execution timeout after ${timeoutMs}ms` : errMsg,
+          };
+        }
+      }
+
+      const endTime = process.hrtime.bigint();
+      const endMemory = process.memoryUsage().heapUsed;
+
+      return {
+        success: true,
+        output,
+        duration: Number(endTime - startTime) / 1_000_000,
+        memoryUsed: Math.max(0, endMemory - startMemory),
+      };
+    },
+  };
+}
