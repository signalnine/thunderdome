 from 'fs';\nimport { join, resolve } from 'path';\n\nconst ROOT_DIR = resolve(import.meta.dirname, '..');\n\nfunction getAllTsFiles(dir: string): string[] {\n  const results: string[] = [];\n  const entries = readdirSync(dir, { withFileTypes: true });\n  for (const entry of entries) {\n    const fullPath = join(dir, entry.name);\n    if (entry.name === 'node_modules' || entry.name === 'dist') continue;\n    if (entry.isDirectory()) {\n      results.push(...getAllTsFiles(fullPath));\n    } else if (entry.name.endsWith('.ts') && !entry.name.endsWith('.d.ts')) {\n      results.push(fullPath);\n    }\n  }\n  return results;\n}\n\nfunction getAllFiles(dir: string): string[] {\n  const results: string[] = [];\n  const entries = readdirSync(dir, { withFileTypes: true });\n  for (const entry of entries) {\n    const fullPath = join(dir, entry.name);\n    if (entry.name === 'node_modules' || entry.name === 'dist' || entry.name === '.git') continue;\n    if (entry.isDirectory()) {\n      results.push(...getAllFiles(fullPath));\n    } else {\n      results.push(fullPath);\n    }\n  }\n  return results;\n}\n\ndescribe('Structural Validations', () => {\n  it('has no circular dependencies', () => {\n    // Use madge to detect circular imports\n    // madge exits with code 0 when no circulars are found, code 1 when found\n    let stdout = '';\n    let exitCode = 0;\n    try {\n      stdout = execSync(\n        'npx madge --circular --extensions ts packages/',\n        { cwd: ROOT_DIR, encoding: 'utf-8', timeout: 30000, stdio: ['pipe', 'pipe', 'pipe'] }\n      );\n    } catch (err) {\n      const error = err as { stdout?: string; stderr?: string; status?: number };\n      stdout = error.stdout || '';\n      exitCode = error.status || 1;\n    }\n\n    if (exitCode !== 0) {\n      throw new Error(`Circular dependencies found:\\n${stdout}`);\n    }\n  });\n\n  it('has no merge conflict markers in any TypeScript file', () => {\n    const tsFiles = getAllTsFiles(join(ROOT_DIR, 'packages'));\n    const filesWithMarkers: string[] = [];\n\n    for (const file of tsFiles) {\n      const content = readFileSync(file, 'utf-8');\n      if (\n        content.includes('<<<<<<<') ||\n        content.includes('>>>>>>>') ||\n        content.includes('=======\\n')\n      ) {\n        filesWithMarkers.push(file.replace(ROOT_DIR + '/', ''));\n      }\n    }\n\n    expect(filesWithMarkers).toEqual([]);\n  });\n\n  it('has no .env files with secrets', () => {\n    const allFiles = getAllFiles(ROOT_DIR);\n    const envFiles = allFiles.filter((f) => {\n      const name = f.split('/').pop() || '';\n      return name === '.env' || name.match(/^\\.env\\./);\n    });\n\n    const envFilesWithSecrets: string[] = [];\n    for (const envFile of envFiles) {\n      const content = readFileSync(envFile, 'utf-8');\n      if (\n        content.includes('PASSWORD') ||\n        content.includes('SECRET') ||\n        content.includes('TOKEN') ||\n        content.includes('API_KEY')\n      ) {\n        envFilesWithSecrets.push(envFile.replace(ROOT_DIR + '/', ''));\n      }\n    }\n\n    expect(envFilesWithSecrets).toEqual([]);\n  });\n\n  it('all packages build successfully', () => {\n    try {\n      execSync('npx tsc -b --force', {\n        cwd: ROOT_DIR,\n        encoding: 'utf-8',\n        timeout: 60000,\n      });\n    } catch (err) {\n      const error = err as { stdout?: string; stderr?: string };\n      throw new Error(\n        `Build failed:\\n${error.stdout || ''}${error.stderr || ''}`\n      );\n    }\n  });\n\n  it('TypeScript strict mode is enabled in all packages', () => {\n    const packages = ['core', 'api', 'worker'];\n\n    for (const pkg of packages) {\n      const tsconfigPath = join(ROOT_DIR, 'packages', pkg, 'tsconfig.json');\n      expect(existsSync(tsconfigPath), `${pkg}/tsconfig.json must exist`).toBe(\n        true\n      );\n\n      const tsconfig = JSON.parse(readFileSync(tsconfigPath, 'utf-8'));\n      expect(\n        tsconfig.compilerOptions?.strict