+
+```typescript
+// src/routes/export.ts
+import { Router, Response } from 'express';
+import { AuthRequest, EventRow, DashboardRow, WidgetRow } from '../types.js';
+import { requireAuth } from '../middleware/auth.js';
+
+const router = Router();
+
+function toCSV(rows: Record<string, unknown>[]): string {
+  if (rows.length === 0) return '';
+  const headers = Object.keys(rows[0]);
+  const lines = [headers.join(',')];
+  for (const row of rows) {
+    lines.push(headers.map(h => {
+      const v = row[h];
+      const str = v === null || v === undefined ? '' : String(v);
+      return str.includes(',') || str.includes('"') || str.includes('\n')
+        ? `"${str.replace(/"/g, '""')}"` : str;
+    }).join(','));
+  }
+  return lines.join('\n');
+}
+
+// GET /api/export/events?format=json|csv
+router.get('/events', requireAuth, (req: AuthRequest, res: Response): void => {
+  const format = (req.query.format as string) ?? 'json';
+  const tenantId = req.user!.tenant_id;
+  const rows = req.db.prepare('SELECT * FROM events WHERE tenant_id = ? ORDER BY timestamp DESC')
+    .all(tenantId) as EventRow[];
+
+  const data = rows.map(r => ({ ...r, properties: JSON.parse(r.properties) }));
+
+  if (format === 'csv') {
+    const flatRows = rows.map(r => ({ ...r }));
+    res.setHeader('Content-Type', 'text/csv');
+    res.setHeader('Content-Disposition', 'attachment; filename="events.csv"');
+    res.send(toCSV(flatRows as Record<string, unknown>[]));
+    return;
+  }
+  res.json(data);
+});
+
+// GET /api/export/dashboards/:id?format=json|csv
+router.get('/dashboards/:id', requireAuth, (req: AuthRequest, res: Response): void => {
+  const format = (req.query.format as string) ?? 'json';
+  const dashboard = req.db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')
+    .get(req.params.id, req.user!.tenant_id) as DashboardRow | undefined;
+  if (!dashboard) {
+    res.status(404).json({ error: 'Dashboard not found' });
+    return;
+  }
+  const widgets = req.db.prepare('SELECT * FROM widgets WHERE dashboard_id = ?')
+    .all(dashboard.id) as WidgetRow[];
+
+  if (format === 'csv') {
+    res.setHeader('Content-Type', 'text/csv');
+    res.setHeader('Content-Disposition', `attachment; filename="dashboard-${dashboard.id}.csv"`);
+    res.send(toCSV(widgets as unknown as Record<string, unknown>[]));
+    return;
+  }
+  res.json({
+    ...dashboard,
+    config: JSON.parse(dashboard.config),
+    widgets: widgets.map(w => ({ ...w, config: JSON.parse(w.config) })),
+  });
+});
+
+export default router;
+```
