+import { Router, Response } from 'express';
+import { v4 as uuidv4 } from 'uuid';
+import { AuthRequest } from '../types.js';
+import { requireAuth } from '../middleware/auth.js';
+
+const router = Router();
+
+interface EventInput {
+  name?: string;
+  properties?: Record<string, unknown>;
+  timestamp?: string;
+}
+
+function insertEvent(req: AuthRequest, event: EventInput): { id: string } | null {
+  if (!event.name) return null;
+  const id = uuidv4();
+  const tenantId = req.user!.tenant_id;
+  const userId = req.user!.id;
+  const properties = JSON.stringify(event.properties ?? {});
+  const timestamp = event.timestamp ?? new Date().toISOString();
+  req.db
+    .prepare(
+      'INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id) VALUES (?, ?, ?, ?, ?, ?)'
+    )
+    .run(id, tenantId, event.name, properties, timestamp, userId);
+  return { id };
+}
+
+// POST /api/events — single event
+router.post('/', requireAuth, (req: AuthRequest, res: Response): void => {
+  const event = req.body as EventInput;
+  const result = insertEvent(req, event);
+  if (!result) {
+    res.status(400).json({ error: 'event name required' });
+    return;
+  }
+  res.status(201).json(result);
+});
+
+// POST /api/events/batch — multiple events
+router.post('/batch', requireAuth, (req: AuthRequest, res: Response): void => {
+  const { events } = req.body as { events?: EventInput[] };
+  if (!Array.isArray(events) || events.length === 0) {
+    res.status(400).json({ error: 'events array required' });
+    return;
+  }
+
+  const insertMany = req.db.transaction((evts: EventInput[]) => {
+    return evts.map((e) => insertEvent(req, e)).filter(Boolean);
+  });
+
+  const results = insertMany(events) as { id: string }[];
+  res.status(201).json({ inserted: results.length, ids: results.map((r) => r.id) });
+});
+
+export default router;
