+```typescript
+// src/routes/query.ts
+import { Router, Response } from 'express';
+import { AuthRequest } from '../types.js';
+import { requireAuth } from '../middleware/auth.js';
+
+const router = Router();
+
+// POST /api/query/count
+// Body: { eventName: string, filters?: Record<string, string> }
+router.post('/count', requireAuth, (req: AuthRequest, res: Response): void => {
+  const { eventName, filters } = req.body as { eventName?: string; filters?: Record<string, string> };
+  if (!eventName) {
+    res.status(400).json({ error: 'eventName required' });
+    return;
+  }
+  const tenantId = req.user!.tenant_id;
+  let sql = 'SELECT COUNT(*) as count FROM events WHERE tenant_id = ? AND name = ?';
+  const params: unknown[] = [tenantId, eventName];
+
+  if (filters) {
+    for (const [key, value] of Object.entries(filters)) {
+      sql += ` AND json_extract(properties, '$.${key}') = ?`;
+      params.push(value);
+    }
+  }
+
+  const row = req.db.prepare(sql).get(...params as [unknown, ...unknown[]]) as { count: number };
+  res.json({ count: row.count });
+});
+
+// POST /api/query/timeseries
+// Body: { eventName: string, interval: 'hour'|'day'|'week'|'month', startDate?: string, endDate?: string }
+router.post('/timeseries', requireAuth, (req: AuthRequest, res: Response): void => {
+  const { eventName, interval = 'day', startDate, endDate } = req.body as {
+    eventName?: string; interval?: string; startDate?: string; endDate?: string;
+  };
+  if (!eventName) {
+    res.status(400).json({ error: 'eventName required' });
+    return;
+  }
+
+  const formatMap: Record<string, string> = {
+    hour: '%Y-%m-%d %H:00',
+    day: '%Y-%m-%d',
+    week: '%Y-%W',
+    month: '%Y-%m',
+  };
+  const fmt = formatMap[interval] ?? '%Y-%m-%d';
+  const tenantId = req.user!.tenant_id;
+  const params: unknown[] = [tenantId, eventName];
+  let sql = `SELECT strftime('${fmt}', timestamp) as bucket, COUNT(*) as count
+             FROM events WHERE tenant_id = ? AND name = ?`;
+  if (startDate) { sql += ' AND timestamp >= ?'; params.push(startDate); }
+  if (endDate) { sql += ' AND timestamp <= ?'; params.push(endDate); }
+  sql += ' GROUP BY bucket ORDER BY bucket';
+
+  const rows = req.db.prepare(sql).all(...params as [unknown, ...unknown[]]) as { bucket: string; count: number }[];
+  res.json({ data: rows });
+});
+
+// POST /api/query/breakdown
+// Body: { eventName: string, property: string, filters?: Record<string, string> }
+router.post('/breakdown', requireAuth, (req: AuthRequest, res: Response): void => {
+  const { eventName, property, filters } = req.body as {
+    eventName?: string; property?: string; filters?: Record<string, string>;
+  };
+  if (!eventName || !property) {
+    res.status(400).json({ error: 'eventName and property required' });
+    return;
+  }
+  const tenantId = req.user!.tenant_id;
+  const params: unknown[] = [tenantId, eventName];
+  let sql = `SELECT json_extract(properties, '$.${property}') as value, COUNT(*) as count
+             FROM events WHERE tenant_id = ? AND name = ?`;
+  if (filters) {
+    for (const [key, value] of Object.entries(filters)) {
+      sql += ` AND json_extract(properties, '$.${key}') = ?`;
+      params.push(value);
+    }
+  }
+  sql += ' GROUP BY value ORDER BY count DESC';
+
+  const rows = req.db.prepare(sql).all(...params as [unknown, ...unknown[]]) as { value: string; count: number }[];
+  res.json({ data: rows });
+});
+
+export default router;
+```
