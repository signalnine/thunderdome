+    return;
+  }
+  const { type, config = {}, position_x = 0, position_y = 0, width = 1, height = 1 } = req.body as {
+    type?: string; config?: Record<string, unknown>; position_x?: number; position_y?: number; width?: number; height?: number;
+  };
+  const validTypes = ['counter', 'timeseries', 'breakdown', 'funnel'];
+  if (!type || !validTypes.includes(type)) {
+    res.status(400).json({ error: 'valid type required' });
+    return;
+  }
+  const id = uuidv4();
+  req.db.prepare(
+    'INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)'
+  ).run(id, req.params.id, type, JSON.stringify(config), position_x, position_y, width, height);
+  res.status(201).json({ id, dashboardId: req.params.id, type, config, position_x, position_y, width, height });
+});
+
+export default router;
+```
