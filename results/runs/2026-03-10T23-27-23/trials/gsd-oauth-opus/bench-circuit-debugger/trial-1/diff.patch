  break;\n          case 'OR':\n            wires[gate.out] = a | b;\n            break;\n          case 'XOR':\n            wires[gate.out] = a ^ b;\n            break;\n        }\n        remaining.splice(i, 1);\n        changed = true;\n      }\n    }\n  }\n\n  return wires;\n}\n\n/**\n * Find the 8 wires involved in 4 swap pairs in a broken ripple-carry adder circuit.\n * Uses structural analysis of the adder pattern to detect violations.\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Build lookup structures\n  const gateByOut = new Map<string, Gate>();\n  for (const g of gates) {\n    gateByOut.set(g.out, g);\n  }\n\n  // Find the number of input bits N\n  let n = 0;\n  for (const g of gates) {\n    for (const wire of [g.in1, g.in2, g.out]) {\n      if (wire.startsWith('x') || wire.startsWith('y')) {\n        const num = parseInt(wire.slice(1), 10);\n        if (num + 1 > n) n = num + 1;\n      }\n    }\n  }\n\n  const finalZ = `z${String(n).padStart(2, '0')}`;\n\n  // Helper: check if a wire is an x or y input\n  function isXY(wire: string): boolean {\n    return wire.startsWith('x') || wire.startsWith('y');\n  }\n\n  // Helper: check if a gate has x/y inputs\n  function hasXYInputs(gate: Gate): boolean {\n    return (isXY(gate.in1) || isXY(gate.in2));\n  }\n\n  // Helper: check if both inputs are x/y (same bit)\n  function isBit0XY(gate: Gate): boolean {\n    return (isXY(gate.in1) && isXY(gate.in2));\n  }\n\n  // Structural rules for a correct ripple-carry adder:\n  //\n  // Rule 1: z-outputs (except z00 and finalZ) must be produced by XOR gates\n  //         whose inputs are NOT both x/y (they are the \"output XOR\" = t XOR carry_in)\n  //\n  // Rule 2: XOR gates that are NOT input-XOR (i.e., don't have x/y inputs)\n  //         must output to a z-wire. (They're the output XOR of each bit.)\n  //\n  // Rule 3: AND gates with x/y inputs (generate gates) should feed into OR gates.\n  //         Their output should be used as an input to an OR gate.\n  //\n  // Rule 4: XOR gates with x/y inputs (partial sum / t-wires) should feed into\n  //         another XOR gate and another AND gate (the output XOR and propagate AND).\n  //\n  // Rule 5: The finalZ wire should be produced by an OR gate (the last carry).\n\n  const swapped = new Set<string>();\n\n  // Build a map of \"where is each wire used as input\"\n  const usedAsInput = new Map<string, Gate[]>();\n  for (const g of gates) {\n    if (!usedAsInput.has(g.in1)) usedAsInput.set(g.in1, []);\n    usedAsInput.get(g.in1)!.push(g);\n    if (!usedAsInput.has(g.in2)) usedAsInput.set(g.in2, []);\n    usedAsInput.get(g.in2)!.push(g);\n  }\n\n  for (const gate of gates) {\n    const out = gate.out;\n\n    // Skip bit 0 gates (half adder) - they follow slightly different rules\n    if (isBit0XY(gate) && out === 'z00') continue;\n    if (isBit0XY(gate) && gate.op === 'AND') continue;\n\n    // Rule 1: z-outputs (except z00 and finalZ) must come from non-input XOR\n    if (out.startsWith('z') && out !== 'z00' && out !== finalZ) {\n      if (gate.op !== 'XOR') {\n        swapped.add(out);\n      } else if (hasXYInputs(gate)) {\n        // A z-wire from an input XOR is wrong (should be output XOR)\n        swapped.add(out);\n      }\n    }\n\n    // Rule 5: finalZ must come from an OR gate (last carry out)\n    if (out === finalZ) {\n      if (gate.op !== 'OR') {\n        swapped.add(out);\n      }\n    }\n\n    // Rule 2: Non-input XOR gates must output to z-wires\n    if (gate.op === 'XOR' && !hasXYInputs(gate)) {\n      if (!out.startsWith('z')) {\n        swapped.add(out);\n      }\n    }\n\n    // Rule 3: Input AND gates (generate) must feed into an OR gate\n    if (gate.op === 'AND' && hasXYInputs(gate) && !isBit0XY(gate)) {\n      // This is wrong - isBit0XY checks both are XY, but hasXYInputs checks at least one\n      // For generate gates: both inputs are x/y of the same bit\n      // Actually, \"input AND\" means both inputs are x/y\n    }\n\n    /