+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+/**
+ * Simulate the circuit: given gates and initial wire values, compute all wire values.
+ * Gates are processed in dependency order (topological sort).
+ */
+export function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+  let changed = true;
+
+  while (remaining.length > 0 && changed) {
+    changed = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        switch (gate.op) {
+          case 'AND':
+            wires[gate.out] = a & b;
+            break;
+          case 'OR':
+            wires[gate.out] = a | b;
+            break;
+          case 'XOR':
+            wires[gate.out] = a ^ b;
+            break;
+        }
+        remaining.splice(i, 1);
+        changed = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+/**
+ * Find the 8 wires involved in 4 swap pairs in a broken ripple-carry adder circuit.
+ * Uses structural analysis of the adder pattern to detect violations.
+ *
+ * In a correct ripple-carry adder (bits 1..N-1), each bit has 5 gates:
+ *   - Input XOR:  xNN XOR yNN -> t  (partial sum)
+ *   - Output XOR: t XOR carry_in -> zNN (final sum)
+ *   - Input AND:  xNN AND yNN -> a  (generate carry)
+ *   - Prop AND:   t AND carry_in -> b (propagate carry)
+ *   - Carry OR:   a OR b -> c  (carry out)
+ *
+ * Bit 0 is a half adder:
+ *   - x00 XOR y00 -> z00
+ *   - x00 AND y00 -> c00
+ *
+ * The last carry becomes finalZ (= z[N]).
+ *
+ * Structural rules:
+ * 1. z-wires (except z00, finalZ) must be produced by non-input XOR gates.
+ * 2. Non-input XOR gates must output to z-wires.
+ * 3. Input XOR gates (partial sums, not z00) must feed into both a XOR and an AND.
+ * 4. Input AND gates (generate, not bit0) must feed into an OR gate.
+ * 5. Non-input AND gates (propagate) must feed into an OR gate.
+ * 6. OR gates (carry) must either be finalZ, or feed into both a XOR and an AND.
+ * 7. finalZ must be produced by an OR gate.
+ */
+export function findSwappedWires(gates: Gate[]): string[] {
+  // Find the number of input bits N
+  let n = 0;
+  for (const g of gates) {
+    for (const wire of [g.in1, g.in2, g.out]) {
+      if (wire.startsWith('x') || wire.startsWith('y')) {
+        const num = parseInt(wire.slice(1), 10);
+        if (num + 1 > n) n = num + 1;
+      }
+    }
+  }
+
+  const finalZ = `z${String(n).padStart(2, '0')}`;
+
+  function isXY(wire: string): boolean {
+    return wire.startsWith('x') || wire.startsWith('y');
+  }
+
+  // "Both inputs are x/y" means this gate directly operates on register inputs
+  function bothInputsXY(gate: Gate): boolean {
+    return isXY(gate.in1) && isXY(gate.in2);
+  }
+
+  // Build a map of "where is each wire used as input"
+  const consumers = new Map<string, Gate[]>();
+  for (const g of gates) {
+    if (!consumers.has(g.in1)) consumers.set(g.in1, []);
+    consumers.get(g.in1)!.push(g);
+    if (!consumers.has(g.in2)) consumers.set(g.in2, []);
+    consumers.get(g.in2)!.push(g);
+  }
+
+  function feedsInto(wire: string, op: Gate['op']): boolean {
+    return (consumers.get(wire) || []).some(g => g.op === op);
+  }
+
+  const swapped = new Set<string>();
+
+  for (const gate of gates) {
+    const out = gate.out;
+    const isInputGate = bothInputsXY(gate);
+
+    // Identify bit-0 half-adder gates — these are special
+    if (isInputGate && gate.op === 'XOR' && out === 'z00') continue;
+    if (isInputGate && gate.op === 'AND') {
+      // Bit-0 carry: x00 AND y00 -> c00
+      // In a correct circuit, c00 should feed into XOR and AND of bit 1.
+      // But if it's bit 0 specifically (checking the wire names)
+      const in1Num = parseInt(gate.in1.slice(1), 10);
+      if (in1Num === 0) {
+        // Bit 0 carry — should feed into XOR and AND (like any carry), unless it IS finalZ
+        // For n=1, c00 would be z01 (finalZ), but n>=4 in practice
+        // Just skip the bit-0 AND — it has relaxed rules
+        continue;
+      }
+    }
+
+    // Rule 1 + 7: Check what produces z-wires
+    if (out.startsWith('z') && out !== 'z00') {
+      if (out === finalZ) {
+        // finalZ must come from OR
+        if (gate.op !== 'OR') {
+          swapped.add(out);
+        }
+      } else {
+        // Other z-wires must come from non-input XOR
+        if (gate.op !== 'XOR') {
+          swapped.add(out);
+        } else if (isInputGate) {
+          // Input XOR outputting to z (but not z00) is wrong
+          swapped.add(out);
+        }
+      }
+    }
+
+    // Rule 2: Non-input XOR must output to z-wire
+    if (gate.op === 'XOR' && !isInputGate && !out.startsWith('z')) {
+      swapped.add(out);
+    }
+
+    // Rule 3: Input XOR (partial sum) that doesn't output z00 must feed into XOR and AND
+    if (gate.op === 'XOR' && isInputGate && out !== 'z00') {
+      if (!feedsInto(out, 'XOR') || !feedsInto(out, 'AND')) {
+        swapped.add(out);
+      }
+    }
+
+    // Rule 4: Input AND (generate carry, not bit 0) must feed into OR
+    if (gate.op === 'AND' && isInputGate) {
+      if (!feedsInto(out, 'OR')) {
+        swapped.add(out);
+      }
+    }
+
+    // Rule 5: Non-input AND (propagate carry) must feed into OR
+    if (gate.op === 'AND' && !isInputGate) {
+      if (!feedsInto(out, 'OR')) {
+        swapped.add(out);
+      }
+    }
+
+    // Rule 6: OR gate (carry out) must be finalZ, or feed into XOR and AND
+    if (gate.op === 'OR' && out !== finalZ) {
+      if (!feedsInto(out, 'XOR') || !feedsInto(out, 'AND')) {
+        swapped.add(out);
+      }
+    }
+  }
+
+  return [...swapped].sort();
+}
