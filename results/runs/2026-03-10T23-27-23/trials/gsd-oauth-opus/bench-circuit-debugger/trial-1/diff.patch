+/**
+ * Discovery layer for the circuit debugger implementation.
+ *
+ * Dynamically imports from ../src/ and tries to find simulate and
+ * findSwappedWires functions regardless of how the implementor exported them.
+ */
+
+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export interface CircuitAPI {
+  simulate: (gates: Gate[], inputs: Record<string, number>) => Record<string, number>;
+  findSwappedWires: (gates: Gate[]) => string[];
+}
+
+const SIMULATE_ALIASES = ['simulate', 'evaluate', 'run', 'runCircuit', 'exec', 'execute', 'process', 'compute'];
+const FIND_SWAPS_ALIASES = [
+  'findSwappedWires', 'findSwaps', 'detectSwaps', 'diagnose',
+  'findSwapped', 'detectSwappedWires', 'findBrokenWires', 'solve',
+  'debug', 'debugCircuit', 'repair', 'analyze',
+];
+
+function findFunction(obj: any, aliases: string[]): ((...args: any[]) => any) | null {
+  for (const name of aliases) {
+    if (typeof obj[name] === 'function') return obj[name].bind(obj);
+  }
+  return null;
+}
+
+async function tryImport(): Promise<any> {
+  const paths = [
+    '../src/index.js',
+    '../src/circuit.js',
+    '../src/solver.js',
+    '../src/debugger.js',
+    '../src/index.ts',
+    '../src/circuit.ts',
+    '../src/solver.ts',
+    '../src/debugger.ts',
+  ];
+  for (const p of paths) {
+    try {
+      return await import(p);
+    } catch {
+      // try next
+    }
+  }
+  throw new Error('Could not import circuit debugger from any of: ' + paths.join(', '));
+}
+
+function extractFromObject(obj: any): { sim: Function | null; swaps: Function | null } {
+  return {
+    sim: findFunction(obj, SIMULATE_ALIASES),
+    swaps: findFunction(obj, FIND_SWAPS_ALIASES),
+  };
+}
+
+export async function discover(): Promise<CircuitAPI> {
+  const mod = await tryImport();
+
+  // 1. Direct named exports
+  let { sim, swaps } = extractFromObject(mod);
+  if (sim && swaps) return { simulate: sim as any, findSwappedWires: swaps as any };
+
+  // 2. Class exports: CircuitDebugger, Circuit, Solver
+  const classNames = [
+    'CircuitDebugger', 'Circuit', 'Solver', 'CircuitSolver',
+    'Debugger', 'WireDebugger', 'AdderDebugger',
+  ];
+  for (const name of classNames) {
+    if (mod[name] && typeof mod[name] === 'function') {
+      try {
+        const instance = new mod[name]();
+        const result = extractFromObject(instance);
+        if (result.sim && result.swaps) {
+          return { simulate: result.sim as any, findSwappedWires: result.swaps as any };
+        }
+      } catch {
+        // try next
+      }
+    }
+  }
+
+  // 3. Factory functions
+  const factoryNames = [
+    'createSolver', 'createDebugger', 'create', 'createCircuit',
+    'createCircuitDebugger', 'makeDebugger', 'makeSolver',
+  ];
+  for (const name of factoryNames) {
+    if (typeof mod[name] === 'function') {
+      try {
+        const instance = mod[name]();
+        const result = extractFromObject(instance);
+        if (result.sim && result.swaps) {
+          return { simulate: result.sim as any, findSwappedWires: result.swaps as any };
+        }
+      } catch {
+        // try next
+      }
+    }
+  }
+
+  // 4. Default export
+  const def = mod.default;
+  if (def) {
+    if (typeof def === 'function') {
+      // Could be a class
+      try {
+        const instance = new def();
+        const result = extractFromObject(instance);
+        if (result.sim && result.swaps) {
+          return { simulate: result.sim as any, findSwappedWires: result.swaps as any };
+        }
+      } catch {
+        // Not a class, try as factory
+        try {
+          const instance = def();
+          const result = extractFromObject(instance);
+          if (result.sim && result.swaps) {
+            return { simulate: result.sim as any, findSwappedWires: result.swaps as any };
+          }
+        } catch {
+          // skip
+        }
+      }
+    } else if (typeof def === 'object') {
+      const result = extractFromObject(def);
+      if (result.sim && result.swaps) {
+        return { simulate: result.sim as any, findSwappedWires: result.swaps as any };
+      }
+    }
+  }
+
+  // 5. Partial: maybe simulate is named export but swaps is on a class
+  if (!sim) sim = findFunction(mod, SIMULATE_ALIASES);
+  if (!swaps) swaps = findFunction(mod, FIND_SWAPS_ALIASES);
+
+  // Try finding missing ones from any exported object
+  for (const key of Object.keys(mod)) {
+    const val = mod[key];
+    if (val && typeof val === 'object') {
+      if (!sim) sim = findFunction(val, SIMULATE_ALIASES);
+      if (!swaps) swaps = findFunction(val, FIND_SWAPS_ALIASES);
+    }
+  }
+
+  if (!sim) throw new Error('Could not find simulate function. Tried: ' + SIMULATE_ALIASES.join(', '));
+  if (!swaps) throw new Error('Could not find findSwappedWires function. Tried: ' + FIND_SWAPS_ALIASES.join(', '));
+
+  return { simulate: sim as any, findSwappedWires: swaps as any };
+}
