+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01D11dSRNPi8zv89dz4GuKed","type":"tool_result","content":"     1→/**\n     2→ * Authentication routes.\n     3→ */\n     4→\n     5→import { Router, type Request, type Response } from 'express';\n     6→import { validateCreateUser, registerUser, type Role } from '@monorepo/core';\n     7→\n     8→export const authRouter = Router();\n     9→\n    10→// Simple registration (public)\n    11→authRouter.post('/register', (req: Request, res: Response) => {\n    12→  try {\n    13→    const validation = validateCreateUser({\n    14→      ...req.body,\n    15→      role: 'user', // Force 'user' role for self-registration\n    16→    });\n    17→\n    18→    if (!validation.success) {\n    19→      res.status(400).json({ errors: validation.errors });\n    20→      return;\n    21→    }\n    22→\n    23→    const user = registerUser({\n    24→      name: req.body.name,\n    25→      email: req.body.email,\n    26→      role: 'user' as Role,\n    27→    });\n    28→\n    29→    res.status(201).json({\n    30→      user,\n    31→      token: `mock-token-${user.id}`, // Simplified for benchmark\n    32→    });\n    33→  } catch (err) {\n    34→    if (err instanceof Error && err.message.includes('UNIQUE')) {\n    35→      res.status(409).json({ error: 'Email already registered' });\n    36→      return;\n    37→    }\n    38→    res.status(500).json({ error: 'Registration failed' });\n    39→  }\n    40→});\n    41→\n    42→// Simple login (mock)\n    43→authRouter.post('/login', (req: Request, res: Response) => {\n    44→  try {\n    45→    const { email } = req.body as { email?: string };\n    46→    if (!email) {\n    47→      res.status(400).json({ error: 'Email is required' });\n    48→      return;\n    49→    }\n    50→\n    51→    // In a real app, we'd verify credentials\n    52→    res.json({\n    53→      token: `mock-token-for-${email}`,\n    54→      message: 'Login successful',\n    55→    });\n    56→  } catch (err) {\n    57→    res.status(500).json({ error: 'Login failed' });\n    58→  }\n    59→});\n    60→\n    61→// Token validation (mock)\n    62→authRouter.get('/verify', (req: Request, res: Response) => {\n    63→  const token = req.headers['authorization']?.replace('Bearer ', '');\n    64→  if (!token) {\n    65→    res.status(401).json({ error: 'No token provided' });\n    66→    return;\n    67→  }\n    68→\n    69→  // Simplified: any token with correct format is valid\n    70→  if (token.startsWith('mock-token-')) {\n    71→    res.json({ valid: true, token });\n    72→  } else {\n    73→    res.status(401).json({ valid: false, error: 'Invalid token' });\n    74→  }\n    75→});\n    76→"}]},"parent_tool_use_id":null,"session_id":"08743fa2-11ac-45b9-b89d-d329b9558d1c","uuid":"57445594-e83e-4568-9b53-870ddbf44e66","tool_use_result":{"type":"text","file":{"filePath":"/workspace/packages/api/src/routes/auth.ts","content":"/**\n * Authentication routes.\n */\n\nimport { Router, type Request, type Response } from 'express';\nimport { validateCreateUser, registerUser, type Role } from '@monorepo/core';\n\nexport const authRouter = Router();\n\n// Simple registration (public)\nauthRouter.post('/register', (req: Request, res: Response) => {\n  try {\n    const validation = validateCreateUser({\n      ...req.body,\n      role: 'user', // Force 'user' role for self-registration\n    });\n\n    if (!validation.success) {\n      res.status(400).json({ errors: validation.errors });\n      return;\n    }\n\n    const user = registerUser({\n      name: req.body.name,\n      email: req.body.email,\n      role: 'user' as Role,\n    });\n\n    res.status(201).json({\n      user,\n      token: `mock-token-${user.id}`, // Simplified for benchmark\n    });\n  } catch (err) {\n    if (err instanceof Error && err.message.includes('UNIQUE')) {\n      res.status(409).json({ error: 'Email already registered' });\n      return;\n    }\n    res.status(500).json({ error: 'Registration failed' });\n  }\n});\n\n// Simple login (mock)\nauthRouter.post('/login', (req: Request, res: Response) => {\n  try {\n    const { email } = req.body as { email?: string };\n    if (!email) {\n      res.status(400).json({ error: 'Email is required' });\n      return;\n    }\n\n    // In a real app, we'd verify credentials\n    res.json({\n      token: `mock-token-for-${email}`,\n      message: 'Login successful',\n    });\n  } catch (err) {\n    res.status(500).json({ error: 'Login failed' });\n  }\n});\n\n// Token validation (mock)\nauthRouter.get('/verify', (req: Request, res: Response) => {\n  const token = req.headers['authorization']?.replace('Bearer ', '');\n  if (!token) {\n    res.status(401).json({ error: 'No token provided' });\n    return;\n  }\n\n  // Simplified: any token with correct format is valid\n  if (token.startsWith('mock-token-')) {\n    res.json({ valid: true, token });\n  } else {\n    res.status(401).json({ valid: false, error: 'Invalid token' });\n  }\n});\n","numLines":76,"startLine":1,"totalLines":76}}}
