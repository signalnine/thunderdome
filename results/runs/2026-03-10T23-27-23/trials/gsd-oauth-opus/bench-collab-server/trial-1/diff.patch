   } else if (pathParts.length === 1) {\n        // /docId directly\n        docId = pathParts[0];\n      }\n\n      if (!docId) {\n        socket.destroy();\n        return;\n      }\n\n      // Check document exists\n      const doc = this.store.getDocument(docId);\n      if (!doc) {\n        socket.write('HTTP/1.1 404 Not Found\\r\\n\\r\\n');\n        socket.destroy();\n        return;\n      }\n\n      this.wss.handleUpgrade(request, socket, head, (ws) => {\n        this.wss.emit('connection', ws, request, docId);\n      });\n    });\n\n    this.wss.on('connection', (ws: WebSocket, _request: IncomingMessage, docId: string) => {\n      this.handleConnection(ws, docId);\n    });\n  }\n\n  private getDocumentState(docId: string): DocumentState {\n    if (!this.documentStates.has(docId)) {\n      const doc = this.store.getDocument(docId);\n      if (!doc) throw new Error(`Document ${docId} not found`);\n\n      const version = this.store.getLatestVersion(docId);\n      this.documentStates.set(docId, {\n        version,\n        content: doc.content,\n        pendingOps: [],\n      });\n    }\n    return this.documentStates.get(docId)!;\n  }\n\n  private handleConnection(ws: WebSocket, docId: string): void {\n    const connectionId = randomUUID();\n\n    const clientInfo: ClientInfo = { ws, connectionId, docId };\n    this.clients.set(connectionId, clientInfo);\n\n    if (!this.documentClients.has(docId)) {\n      this.documentClients.set(docId, new Set());\n    }\n    this.documentClients.get(docId)!.add(connectionId);\n\n    // Track in database\n    this.store.addConnection(connectionId, docId);\n\n    // Send sync message with current state\n    const state = this.getDocumentState(docId);\n    this.send(ws, {\n      type: 'sync',\n      docId,\n      content: state.content,\n      version: state.version,\n    });\n\n    // Notify other clients\n    this.broadcastToOthers(docId, connectionId, {\n      type: 'client_joined',\n      clientId: connectionId,\n    });\n\n    ws.on('message', (data) => {\n      try {\n        const message = JSON.parse(data.toString()) as WsMessage;\n        this.handleMessage(connectionId, message);\n      } catch (err) {\n        this.send(ws, {\n          type: 'error',\n          message: err instanceof Error ? err.message : 'Invalid message',\n        });\n      }\n    });\n\n    ws.on('close', () => {\n      this.handleDisconnect(connectionId);\n    });\n\n    ws.on('error', () => {\n      this.handleDisconnect(connectionId);\n    });\n  }\n\n  private handleMessage(connectionId: string, message: WsMessage): void {\n    const client = this.clients.get(connectionId);\n    if (!client) return;\n\n    switch (message.type) {\n      case 'operation':\n        this.handleOperation(connectionId, message);\n        break;\n      default:\n        this.send(client.ws, {\n          type: 'error',\n          message: `Unknown message type: ${message.type}`,\n        });\n    }\n  }\n\n  private handleOperation(connectionId: string, message: WsMessage): void {\n    const client = this.clients.get(connectionId);\n    if (!client) return;\n\n    const { docId } = client;\n    const state = this.getDocumentState(docId);\n\n    const clientVersion = message.version as number;\n    let operation = message.operation as Operation;\n\n    if (typeof clientVersion !== 'number' || !Number.isInteger(clientVersion)) {\n      this.send(client.ws, {\n        type: 'error',\n        message: 'Invalid version number',\n      });\n      return;\n    }\n\n    if (!Array.isArray(operation)) {\n      this.send(client.ws, {\n        type: 'error',\n        message: 'Invalid operation: must be an array',\n      });\n      return;\n    }\n\n    // Validate operation components\n    for (const c of operation) {\n      if (typeof c !== 'number' && typeof c !== 'string') {\n        this.send(client.ws, {\n          type: 'error',\n          message: `Invalid operation component type: ${typeof c}`,\n        });\n        return;\