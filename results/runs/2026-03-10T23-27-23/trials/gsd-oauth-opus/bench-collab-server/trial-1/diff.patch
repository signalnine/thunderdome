+describe('Error Handling', () => {
+  let ctx: TestContext;
+
+  beforeEach(async () => {
+    ctx = await setupServer();
+  });
+
+  afterEach(async () => {
+    await teardownServer(ctx);
+  });
+
+  it('should reject operation with invalid version', async () => {
+    const doc = await createDocument(ctx.baseUrl, 'Invalid Version', 'test');
+    const ws = await connectWs(ctx.wsUrl, doc.id);
+    await waitForMessage(ws, 'sync');
+
+    ws.send(JSON.stringify({
+      type: 'operation',
+      version: 999,
+      operation: [4, '!'],
+    }));
+
+    const err = await waitForMessage(ws, 'error');
+    expect(err.type).toBe('error');
+    expect(typeof err.message).toBe('string');
+
+    await closeWs(ws);
+  });
+
+  it('should reject operation with wrong document length', async () => {
+    const doc = await createDocument(ctx.baseUrl, 'Wrong Length', 'test');
+    const ws = await connectWs(ctx.wsUrl, doc.id);
+    await waitForMessage(ws, 'sync');
+
+    // Operation expects document of length 10, but doc is length 4
+    ws.send(JSON.stringify({
+      type: 'operation',
+      version: 0,
+      operation: [10, '!'],
+    }));
+
+    const err = await waitForMessage(ws, 'error');
+    expect(err.type).toBe('error');
+
+    await closeWs(ws);
+  });
+
+  it('should reject malformed JSON messages', async () => {
+    const doc = await createDocument(ctx.baseUrl, 'Malformed', 'test');
+    const ws = await connectWs(ctx.wsUrl, doc.id);
+    await waitForMessage(ws, 'sync');
+
+    ws.send('this is not json');
+
+    const err = await waitForMessage(ws, 'error');
+    expect(err.type).toBe('error');
+
+    await closeWs(ws);
+  });
+
+  it('should reject unknown message types', async () => {
+    const doc = await createDocument(ctx.baseUrl, 'Unknown Type', 'test');
+    const ws = await connectWs(ctx.wsUrl, doc.id);
+    await waitForMessage(ws, 'sync');
+
+    ws.send(JSON.stringify({ type: 'unknown_type' }));
+
+    const err = await waitForMessage(ws, 'error');
+    expect(err.type).toBe('error');
+
+    await closeWs(ws);
+  });
+
+  it('should reject operation with invalid component types', async () => {
+    const doc = await createDocument(ctx.baseUrl, 'Invalid Components', 'test');
+    const ws = await connectWs(ctx.wsUrl, doc.id);
+    await waitForMessage(ws, 'sync');
+
+    ws.send(JSON.stringify({
+      type: 'operation',
+      version: 0,
+      operation: [{ invalid: true }],
+    }));
+
+    const err = await waitForMessage(ws, 'error');
+    expect(err.type).toBe('error');
+
+    await closeWs(ws);
+  });
+});
