index 0000000..eaa1c67
--- /dev/null
+++ b/tests/two-client-convergence.test.ts
@@ -0,0 +1,268 @@
+import { describe, it, expect, beforeEach, afterEach } from 'vitest';
+import {
+  TestContext,
+  setupServer,
+  teardownServer,
+  createDocument,
+  connectWs,
+  waitForMessage,
+  sendOp,
+  closeWs,
+  delay,
+} from './helpers.js';
+
+describe('Two-Client Convergence', () => {
+  let ctx: TestContext;
+
+  beforeEach(async () => {
+    ctx = await setupServer();
+  });
+
+  afterEach(async () => {
+    await teardownServer(ctx);
+  });
+
+  it('should broadcast operations to other clients', async () => {
+    const doc = await createDocument(ctx.baseUrl, 'Broadcast Test', 'hello');
+    const ws1 = await connectWs(ctx.wsUrl, doc.id);
+    const sync1 = await waitForMessage(ws1, 'sync');
+
+    const ws2 = await connectWs(ctx.wsUrl, doc.id);
+    await waitForMessage(ws2, 'sync');
+    // Drain join notification on ws1
+    await waitForMessage(ws1, 'client_joined');
+
+    // Client 1 inserts " world"
+    sendOp(ws1, sync1.version as number, [5, ' world']);
+    await waitForMessage(ws1, 'ack');
+
+    // Client 2 should receive the operation
+    const opMsg = await waitForMessage(ws2, 'operation');
+    expect(opMsg.type).toBe('operation');
+    expect(opMsg.operation).toBeDefined();
+
+    await closeWs(ws1);
+    await closeWs(ws2);
+  });
+
+  it('should handle concurrent inserts at different positions', async () => {
+    const doc = await createDocument(ctx.baseUrl, 'Concurrent Insert', 'ac');
+    const ws1 = await connectWs(ctx.wsUrl, doc.id);
+    const sync1 = await waitForMessage(ws1, 'sync');
+
+    const ws2 = await connectWs(ctx.wsUrl, doc.id);
+    const sync2 = await waitForMessage(ws2, 'sync');
+    await waitForMessage(ws1, 'client_joined');
+
+    const version = sync1.version as number;
+    expect(version).toBe(sync2.version as number);
+
+    // Client 1 inserts "b" at position 1: "abc"
+    sendOp(ws1, version, [1, 'b', 1]);
+
+    // Client 2 inserts "d" at position 2: "acd"
+    sendOp(ws2, version, [2, 'd']);
+
+    // Wait for acks
+    await waitForMessage(ws1, 'ack');
+    await waitForMessage(ws2, 'ack');
+
+    // Drain any remaining messages
+    await delay(200);
+
+    // Both should converge
+    const res = await fetch(`${ctx.baseUrl}/api/documents/${doc.id}`);
+    const final = await res.json();
+    // Both insertions should be present
+    expect(final.content).toContain('b');
+    expect(final.content).toContain('d');
+    expect(final.content.length).toBe(4); // "a" + "b" + "c" + "d"
+
+    await closeWs(ws1);
+    await closeWs(ws2);
+  });
+
+  it('should handle concurrent inserts at same position', async () => {
+    const doc = await createDocument(ctx.baseUrl, 'Same Position', 'hello');
+    const ws1 = await connectWs(ctx.wsUrl, doc.id);
+    const sync1 = await waitForMessage(ws1, 'sync');
+
+    const ws2 = await connectWs(ctx.wsUrl, doc.id);
+    const sync2 = await waitForMessage(ws2, 'sync');
+    await waitForMessage(ws1, 'client_joined');
+
+    const version = sync1.version as number;
+    expect(version).toBe(sync2.version as number);
+
+    // Both insert at position 5
+    sendOp(ws1, version, [5, ' AAA']);
+    sendOp(ws2, version, [5, ' BBB']);
+
+    await waitForMessage(ws1, 'ack');
+    await waitForMessage(ws2, 'ack');
+
+    await delay(200);
+
+    const res = await fetch(`${ctx.baseUrl}/api/documents/${doc.id}`);
+    const final = await res.json();
+    // Both insertions should be preserved
+    expect(final.content).toContain('AAA');
+    expect(final.content).toContain('BBB');
+    expect(final.content).toContain('hello');
+
+    await closeWs(ws1);
+    await closeWs(ws2);
+  });
+
+  it('should converge when one client inserts and another deletes', async () => {
+    const doc = await createDocument(ctx.baseUrl, 'Insert Delete', 'hello world');
+    const ws1 = await connectWs(ctx.wsUrl, doc.id);
+    const sync1 = await waitForMessage(ws1, 'sync');
+
+    const ws2 = await connectWs(ctx.wsUrl, doc.id);
+    const sync2 = await waitForMessage(ws2, 'sync');
+    await waitForMessage(ws1, 'client_joined');
+
+    const version = sync1.version as number;
+    expect(version).toBe(sync2.version as number);
+
+    // Client 1 inserts "!" at end
+    sendOp(ws1, version, [11, '!']);
+
+    // Client 2 deletes "hello " (6 chars)
+    sendOp(ws2, version, [-6, 5]);
+
+    await waitForMessage(ws1, 'ack');
+    await waitForMessage(ws2, 'ack');
+
+    await delay(200);
+
+    const res = await fetch(`${ctx.baseUrl}/api/documents/${doc.id}`);
+    const final = await res.json();
+    // Should have "world" with "!" somewhere
+    expect(final.content).toContain('world');
+    expect(final.content).toContain('!');
+
+    await closeWs(ws1);
+    await closeWs(ws2);
+  });
+
+  it('should handle rapid sequential edits from both clients', async () => {
+    const doc = await createDocument(ctx.baseUrl, 'Rapid Edits', '');
+    const ws1 = await connectWs(ctx.wsUrl, doc.id);
+    const sync1 = await waitForMessage(ws1, 'sync');
+
+    const ws2 = await connectWs(ctx.wsUrl, doc.id);
+    await waitForMessage(ws2, 'sync');
+    await waitForMessage(ws1, 'client_joined');
+
+    let version1 = sync1.version as number;
+
+    // Client 1 does multiple sequential edits
+    sendOp(ws1, version1, ['a']);
+    const ack1 = await waitForMessage(ws1, 'ack');
+    version1 = ack1.version as number;
+
+    sendOp(ws1, version1, [1, 'b']);
+    const ack2 = await waitForMessage(ws1, 'ack');
+    version1 = ack2.version as number;
+
+    sendOp(ws1, version1, [2, 'c']);
+    await waitForMessage(ws1, 'ack');
+
+    await delay(200);
+
+    const res = await fetch(`${ctx.baseUrl}/api/documents/${doc.id}`);
+    const final = await res.json();
+    expect(final.content).toBe('abc');
+
+    await closeWs(ws1);
+    await closeWs(ws2);
+  });
+
+  it('should maintain version numbers correctly across clients', async () => {
+    const doc = await createDocument(ctx.baseUrl, 'Version Sync', 'test');
+    const ws1 = await connectWs(ctx.wsUrl, doc.id);
+    const sync1 = await waitForMessage(ws1, 'sync');
+
+    const ws2 = await connectWs(ctx.wsUrl, doc.id);
+    const sync2 = await waitForMessage(ws2, 'sync');
+    await waitForMessage(ws1, 'client_joined');
+
+    expect(sync1.version).toBe(sync2.version);
+
+    // Client 1 edits
+    sendOp(ws1, sync1.version as number, [4, '!']);
+    const ack = await waitForMessage(ws1, 'ack');
+
+    // Client 2 should receive op with incremented version
+    const opMsg = await waitForMessage(ws2, 'operation');
+    expect(opMsg.version).toBe(ack.version);
+
+    await closeWs(ws1);
+    await closeWs(ws2);
+  });
+
+  it('should preserve all content from both clients after concurrent edits', async () => {
+    const doc = await createDocument(ctx.baseUrl, 'Preserve All', 'X');
+    const ws1 = await connectWs(ctx.wsUrl, doc.id);
+    const sync1 = await waitForMessage(ws1, 'sync');
+
+    const ws2 = await connectWs(ctx.wsUrl, doc.id);
