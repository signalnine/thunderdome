ore: DocumentStore) {\n    this.store = store;\n    this.wss = new WebSocketServer({ noServer: true });\n\n    server.on('upgrade', (request, socket, head) => {\n      const url = new URL(request.url || '/', `http://${request.headers.host || 'localhost'}`);\n      const pathParts = url.pathname.split('/').filter(Boolean);\n\n      let docId: string | null = null;\n\n      if (pathParts.length === 2 && pathParts[0] === 'documents') {\n        docId = pathParts[1];\n      } else if (pathParts.length === 3 && pathParts[0] === 'ws' && pathParts[1] === 'documents') {\n        docId = pathParts[2];\n      } else if (pathParts.length === 1) {\n        docId = pathParts[0];\n      }\n\n      if (!docId) {\n        socket.write('HTTP/1.1 400 Bad Request\\r\\n\\r\\n');\n        socket.destroy();\n        return;\n      }\n\n      const doc = this.store.getDocument(docId);\n      if (!doc) {\n        socket.write('HTTP/1.1 404 Not Found\\r\\n\\r\\n');\n        socket.destroy();\n        return;\n      }\n\n      this.wss.handleUpgrade(request, socket, head, (ws) => {\n        this.handleConnection(ws, docId!);\n      });\n    });\n  }\n\n  private getDocumentState(docId: string): DocumentState {\n    if (!this.documentStates.has(docId)) {\n      const doc = this.store.getDocument(docId);\n      if (!doc) throw new Error(`Document ${docId} not found`);\n\n      const version = this.store.getLatestVersion(docId);\n      this.documentStates.set(docId, {\n        version,\n        content: doc.content,\n        pendingOps: [],\n      });\n    }\n    return this.documentStates.get(docId)!;\n  }\n\n  private handleConnection(ws: WebSocket, docId: string): void {\n    const connectionId = randomUUID();\n\n    const clientInfo: ClientInfo = { ws, connectionId, docId };\n    this.clients.set(connectionId, clientInfo);\n\n    if (!this.documentClients.has(docId)) {\n      this.documentClients.set(docId, new Set());\n    }\n    this.documentClients.get(docId)!.add(connectionId);\n\n    this.store.addConnection(connectionId, docId);\n\n    const state = this.getDocumentState(docId);\n    this.send(ws, {\n      type: 'sync',\n      docId,\n      content: state.content,\n      version: state.version,\n    });\n\n    this.broadcastToOthers(docId, connectionId, {\n      type: 'client_joined',\n      clientId: connectionId,\n    });\n\n    ws.on('message', (data) => {\n      try {\n        const message = JSON.parse(data.toString()) as WsMessage;\n        this.handleMessage(connectionId, message);\n      } catch (err) {\n        this.send(ws, {\n          type: 'error',\n          message: err instanceof Error ? err.message : 'Invalid message',\n        });\n      }\n    });\n\n    ws.on('close', () => {\n      this.handleDisconnect(connectionId);\n    });\n\n    ws.on('error', () => {\n      this.handleDisconnect(connectionId);\n    });\n  }\n\n  private handleMessage(connectionId: string, message: WsMessage): void {\n    const client = this.clients.get(connectionId);\n    if (!client) return;\n\n    switch (message.type) {\n      case 'operation':\n        this.handleOperation(connectionId, message);\n        break;\n      default:\n        this.send(client.ws, {\n          type: 'error',\n          message: `Unknown message type: ${message.type}`,\n        });\n    }\n  }\n\n  private handleOperation(connectionId: string, message: WsMessage): void {\n    const client = this.clients.get(connectionId);\n    if (!client) return;\n\n    const { docId } = client;\n    const state = this.getDocumentState(docId);\n\n    const clientVersion = message.version as number;\n    let operation = message.operation as Operation;\n\n    if (typeof clientVersion !== 'number' || !Number.isInteger(clientVersion)) {\n      this.send(client.ws, {\n        type: 'error',\n        message: 'Invalid version number',\n      });\n      return;\n    }\n\n    if (!Array.isArray(operation)) {\n      this.send(client.ws, {\n        type: 'error',\n        message: 'Invalid operation: must be an array',\n      });\n      return;\n    }\n\n    for (const c of operation) {\n      if (typeof c !== 'number' && typeof c !== 'string') {\n        this.send(client.ws, {\n          type: 'error',\n          message: `Invalid operation component type: ${typeof c}`,\n        });\n        return;\n      }\n    }\n\n    if (clientVersion < 0 || clientVersion > state.version) {\n      this.send(client.ws, {\n        type: 'error',\n        message: `Invalid version: ${clientVersion}. Current version is ${state.version}`,\n      });\n      return;\n    }\n\n    // Transform against all operations that happened since client's version\n    const serverOps = state.pendingOps.filter(op => op.version > clientVersion);\n\n    for (const serverOp of serverOps) {\n      const [transformedClient] = transform(operation, serverOp.operation);\n      operation = transformedClient;\n    }\n\n    // Validate the transformed operation against current document\n    const validationError = validate(operation, state.content.length);\n    if (validationError) {\n      this.send(client.ws, {\n        type: 'error',\n        message: `Invalid operation: ${validationError}`,\n      });\n      return;\n    }\n\n    try {\n      const newContent = apply(state.content, operation);\n      state.version++;\n      state.content = newContent;\n      state.pendingOps.push({ version: state.version, operation });\n\n      if (state.pendingOps.length > 1000) {\n        state.pendingOps = state.pendingOps.slice(-500);\n      }\n\n      this.store.updateDocumentContent(docId, newContent);\n      this.store.addVersion(docId, state.version, newContent, JSON.stringify(operation));\n\n      this.send(client.ws, {\n        type: 'ack',\n        version: state.version,\n      });\n\n      this.broadcastToOthers(docId, connectionId, {\n        type: 'operation',\n        version: state.version,\n        operation,\n        clientId: connectionId,\n      });\n    } catch (err) {\n      this.send(client.ws, {\n        type: 'error',\n        message: err instanceof Error ? err.message : 'Failed to apply operation',\n      });\n    }\n  }\n\n  private handleDisconnect(connectionId: string): void {\n    const client = this.clients.get(connectionId);\n    if (!client) return;\n\n    const { docId } = client;\n\n    this.clients.delete(connectionId);\n    this.documentClients.get(docId)?.delete(connectionId);\n\n    if (this.documentClients.get(docId)?.size === 0) {\n      this.documentClients.delete(docId);\n    }\n\n    this.store.removeConnection(connectionId);\n\n    this.broadcastToOthers(docId, connectionId, {\n      type: 'client_left',\n      clientId: connectionId,\n    });\n  }\n\n  private send(ws: WebSocket, message: WsMessage): void {\n    if (ws.readyState === WebSocket.OPEN) {\n      ws.send(JSON.stringify(message));\n    }\n  }\n\n  private broadcastToOthers(docId: string, excludeConnectionId: string, message: WsMessage): void {\n    const clients = this.documentClients.get(docId);\n    if (!clients) return;\n\n    for (const connId of clients) {\n      if (connId === excludeConnectionId) continue;\n      const client = this.clients.get(connId);\n      if (client) {\n        this.send(client.ws, message);\n      }\n    }\n  }\n\n  closeAll(): void {\n    for (const [, client] of this.clients) {\n      client.ws.close();\n    }\n    this.clients.clear();\n    this.documentClients.clear();\n    this.documentStates.clear();\n    this.store.clearConnections();\n    this.wss.close();\n  }\n\n  getClientCount(docId?: string): number {\n    if (docId) {\n      return this.documentClients.get(docId)?.size ?? 0;\n    }\n    return this.clients.size;\n  }\n}\n","structuredPatch":[{"oldStart":1,"oldLines":5,"newStart":1,"newLines":4,"lines":[" import { WebSocketServer, WebSocket } from 'ws';","-import { IncomingMessage } from 'http';"," import { Server as HttpServer } from 'http';"," import { DocumentStore } from './db.js';"," import { Operation, transform, appl