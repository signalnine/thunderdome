@@ -0,0 +1,67 @@
+import express from 'express';
+import { createServer, Server as HttpServer } from 'http';
+import { createDatabase, DocumentStore } from './db.js';
+import { createRouter } from './routes.js';
+import { CollaborationServer } from './ws.js';
+
+export interface AppInstance {
+  app: express.Express;
+  start: (port?: number) => Promise<number>;
+  stop: () => Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db = createDatabase(dbPath || ':memory:');
+  const store = new DocumentStore(db);
+  const app = express();
+
+  app.use(express.json());
+
+  const router = createRouter(store);
+  app.use('/api', router);
+  // Also mount at root for convenience
+  app.use(router);
+
+  let server: HttpServer | null = null;
+  let collabServer: CollaborationServer | null = null;
+
+  return {
+    app,
+
+    start: async (port?: number): Promise<number> => {
+      return new Promise((resolve) => {
+        server = createServer(app);
+        collabServer = new CollaborationServer(server, store);
+
+        server.listen(port ?? 0, () => {
+          const addr = server!.address();
+          const actualPort = typeof addr === 'object' && addr ? addr.port : port ?? 0;
+          resolve(actualPort);
+        });
+      });
+    },
+
+    stop: async (): Promise<void> => {
+      return new Promise((resolve, reject) => {
+        if (collabServer) {
+          collabServer.closeAll();
+          collabServer = null;
+        }
+
+        if (server) {
+          server.close((err) => {
+            if (err) reject(err);
+            else {
+              store.close();
+              resolve();
+            }
+          });
+          server = null;
+        } else {
+          store.close();
+          resolve();
+        }
+      });
+    },
+  };
+}
