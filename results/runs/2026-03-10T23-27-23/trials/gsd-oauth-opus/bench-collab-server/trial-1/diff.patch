--- /dev/null
+++ b/tests/ws-lifecycle.test.ts
@@ -0,0 +1,128 @@
+import { describe, it, expect, beforeEach, afterEach } from 'vitest';
+import WebSocket from 'ws';
+import {
+  TestContext,
+  setupServer,
+  teardownServer,
+  createDocument,
+  connectWs,
+  waitForMessage,
+  closeWs,
+  delay,
+} from './helpers.js';
+
+describe('WebSocket Lifecycle', () => {
+  let ctx: TestContext;
+
+  beforeEach(async () => {
+    ctx = await setupServer();
+  });
+
+  afterEach(async () => {
+    await teardownServer(ctx);
+  });
+
+  it('should connect to a document via WebSocket', async () => {
+    const doc = await createDocument(ctx.baseUrl, 'WS Test', 'hello');
+    const ws = await connectWs(ctx.wsUrl, doc.id);
+    expect(ws.readyState).toBe(WebSocket.OPEN);
+    await closeWs(ws);
+  });
+
+  it('should receive sync message on connection', async () => {
+    const doc = await createDocument(ctx.baseUrl, 'Sync Test', 'sync content');
+    const ws = await connectWs(ctx.wsUrl, doc.id);
+    const msg = await waitForMessage(ws, 'sync');
+    expect(msg.type).toBe('sync');
+    expect(msg.content).toBe('sync content');
+    expect(typeof msg.version).toBe('number');
+    await closeWs(ws);
+  });
+
+  it('should receive correct document content in sync', async () => {
+    const doc = await createDocument(ctx.baseUrl, 'Content Sync', 'test content here');
+    const ws = await connectWs(ctx.wsUrl, doc.id);
+    const msg = await waitForMessage(ws, 'sync');
+    expect(msg.content).toBe('test content here');
+    expect(msg.docId).toBe(doc.id);
+    await closeWs(ws);
+  });
+
+  it('should notify when another client joins', async () => {
+    const doc = await createDocument(ctx.baseUrl, 'Join Test');
+    const ws1 = await connectWs(ctx.wsUrl, doc.id);
+    await waitForMessage(ws1, 'sync');
+
+    const ws2 = await connectWs(ctx.wsUrl, doc.id);
+    await waitForMessage(ws2, 'sync');
+
+    const joinMsg = await waitForMessage(ws1, 'client_joined');
+    expect(joinMsg.type).toBe('client_joined');
+    expect(joinMsg.clientId).toBeDefined();
+
+    await closeWs(ws1);
+    await closeWs(ws2);
+  });
+
+  it('should notify when a client leaves', async () => {
+    const doc = await createDocument(ctx.baseUrl, 'Leave Test');
+    const ws1 = await connectWs(ctx.wsUrl, doc.id);
+    await waitForMessage(ws1, 'sync');
+
+    const ws2 = await connectWs(ctx.wsUrl, doc.id);
+    await waitForMessage(ws2, 'sync');
+
+    // Drain join notification
+    await waitForMessage(ws1, 'client_joined');
+
+    await closeWs(ws2);
+    const leftMsg = await waitForMessage(ws1, 'client_left');
+    expect(leftMsg.type).toBe('client_left');
+
+    await closeWs(ws1);
+  });
+
+  it('should handle multiple clients on same document', async () => {
+    const doc = await createDocument(ctx.baseUrl, 'Multi Client');
+    const clients: WebSocket[] = [];
+
+    for (let i = 0; i < 3; i++) {
+      const ws = await connectWs(ctx.wsUrl, doc.id);
+      await waitForMessage(ws, 'sync');
+      clients.push(ws);
+    }
+
+    expect(clients.length).toBe(3);
+    for (const ws of clients) {
+      expect(ws.readyState).toBe(WebSocket.OPEN);
+    }
+
+    for (const ws of clients) {
+      await closeWs(ws);
+    }
+  });
+
+  it('should reject connection to non-existent document', async () => {
+    const ws = new WebSocket(`${ctx.wsUrl}/documents/nonexistent-id`);
+    await new Promise<void>((resolve) => {
+      ws.on('error', () => resolve());
+      ws.on('close', () => resolve());
+    });
+    expect(ws.readyState).not.toBe(WebSocket.OPEN);
+  });
+
+  it('should handle clean disconnect', async () => {
+    const doc = await createDocument(ctx.baseUrl, 'Disconnect Test');
+    const ws = await connectWs(ctx.wsUrl, doc.id);
+    await waitForMessage(ws, 'sync');
+
+    await closeWs(ws);
+    await delay(100);
+
+    // Server should still work after client disconnect
+    const ws2 = await connectWs(ctx.wsUrl, doc.id);
+    const msg = await waitForMessage(ws2, 'sync');
+    expect(msg.type).toBe('sync');
+    await closeWs(ws2);
+  });
+});
