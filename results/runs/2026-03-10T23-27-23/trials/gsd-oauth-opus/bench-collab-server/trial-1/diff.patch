+import { describe, it, expect, beforeEach, afterEach } from 'vitest';
+import {
+  TestContext,
+  setupServer,
+  teardownServer,
+  createDocument,
+  connectWs,
+  waitForMessage,
+  sendOp,
+  closeWs,
+} from './helpers.js';
+
+describe('Single Client Editing', () => {
+  let ctx: TestContext;
+
+  beforeEach(async () => {
+    ctx = await setupServer();
+  });
+
+  afterEach(async () => {
+    await teardownServer(ctx);
+  });
+
+  it('should insert text at the beginning', async () => {
+    const doc = await createDocument(ctx.baseUrl, 'Insert Test', 'world');
+    const ws = await connectWs(ctx.wsUrl, doc.id);
+    const sync = await waitForMessage(ws, 'sync');
+
+    // Insert "hello " at position 0
+    sendOp(ws, sync.version as number, ['hello ', 5]);
+    const ack = await waitForMessage(ws, 'ack');
+    expect(ack.type).toBe('ack');
+
+    // Verify via REST
+    const res = await fetch(`${ctx.baseUrl}/api/documents/${doc.id}`);
+    const updated = await res.json();
+    expect(updated.content).toBe('hello world');
+
+    await closeWs(ws);
+  });
+
+  it('should insert text at the end', async () => {
+    const doc = await createDocument(ctx.baseUrl, 'Append Test', 'hello');
+    const ws = await connectWs(ctx.wsUrl, doc.id);
+    const sync = await waitForMessage(ws, 'sync');
+
+    // Insert " world" at position 5
+    sendOp(ws, sync.version as number, [5, ' world']);
+    const ack = await waitForMessage(ws, 'ack');
+    expect(ack.type).toBe('ack');
+
+    const res = await fetch(`${ctx.baseUrl}/api/documents/${doc.id}`);
+    const updated = await res.json();
+    expect(updated.content).toBe('hello world');
+
+    await closeWs(ws);
+  });
+
+  it('should delete text', async () => {
+    const doc = await createDocument(ctx.baseUrl, 'Delete Test', 'hello world');
+    const ws = await connectWs(ctx.wsUrl, doc.id);
+    const sync = await waitForMessage(ws, 'sync');
+
+    // Delete "hello " (6 chars from position 0)
+    sendOp(ws, sync.version as number, [-6, 5]);
+    const ack = await waitForMessage(ws, 'ack');
+    expect(ack.type).toBe('ack');
+
+    const res = await fetch(`${ctx.baseUrl}/api/documents/${doc.id}`);
+    const updated = await res.json();
+    expect(updated.content).toBe('world');
+
+    await closeWs(ws);
+  });
+
+  it('should handle multiple sequential operations', async () => {
+    const doc = await createDocument(ctx.baseUrl, 'Sequential Test', '');
+    const ws = await connectWs(ctx.wsUrl, doc.id);
+    const sync = await waitForMessage(ws, 'sync');
+    let version = sync.version as number;
+
+    // Insert "abc"
+    sendOp(ws, version, ['abc']);
+    const ack1 = await waitForMessage(ws, 'ack');
+    version = ack1.version as number;
+
+    // Insert "def" at end
+    sendOp(ws, version, [3, 'def']);
+    const ack2 = await waitForMessage(ws, 'ack');
+    version = ack2.version as number;
+
+    // Insert "123" in middle (position 3)
+    sendOp(ws, version, [3, '123', 3]);
+    await waitForMessage(ws, 'ack');
+
+    const res = await fetch(`${ctx.baseUrl}/api/documents/${doc.id}`);
+    const updated = await res.json();
+    expect(updated.content).toBe('abc123def');
+
+    await closeWs(ws);
+  });
+
+  it('should update version history with each operation', async () => {
+    const doc = await createDocument(ctx.baseUrl, 'Version Test', 'start');
+    const ws = await connectWs(ctx.wsUrl, doc.id);
+    const sync = await waitForMessage(ws, 'sync');
+
+    sendOp(ws, sync.version as number, [5, ' end']);
+    await waitForMessage(ws, 'ack');
+
+    const res = await fetch(`${ctx.baseUrl}/api/documents/${doc.id}/versions`);
+    const versions = await res.json();
+    expect(versions.length).toBeGreaterThanOrEqual(2);
+
+    await closeWs(ws);
+  });
+
+  it('should handle insert in the middle of text', async () => {
+    const doc = await createDocument(ctx.baseUrl, 'Middle Insert', 'helloworld');
+    const ws = await connectWs(ctx.wsUrl, doc.id);
+    const sync = await waitForMessage(ws, 'sync');
+
+    // Insert " " at position 5
+    sendOp(ws, sync.version as number, [5, ' ', 5]);
+    const ack = await waitForMessage(ws, 'ack');
+    expect(ack.type).toBe('ack');
+
+    const res = await fetch(`${ctx.baseUrl}/api/documents/${doc.id}`);
+    const updated = await res.json();
+    expect(updated.content).toBe('hello world');
+
+    await closeWs(ws);
+  });
+});
diff --git a/tests/stress-test.test.ts b/tests/stress-test.test.ts
new file mode 100644
index 0000000..f1cb347
--- /dev/null
+++ b/tests/stress-test.test.ts
@@ -0,0 +1,189 @@
+import { describe, it, expect, beforeEach, afterEach } from 'vitest';
+import WebSocket from 'ws';
+import {
+  TestContext,
+  setupServer,
+  teardownServer,
+  createDocument,
+  connectWs,
+  waitForMessage,
+  sendOp,
+  closeWs,
+  delay,
+} from './helpers.js';
+
+describe('Stress Test', () => {
+  let ctx: TestContext;
+
+  beforeEach(async () => {
+    ctx = await setupServer();
+  });
+
+  afterEach(async () => {
+    await teardownServer(ctx);
+  });
+
+  it('should handle 10 concurrent clients connecting', async () => {
+    const doc = await createDocument(ctx.baseUrl, 'Stress Connect', 'start');
+    const clients: WebSocket[] = [];
+
+    for (let i = 0; i < 10; i++) {
+      const ws = await connectWs(ctx.wsUrl, doc.id);
+      await waitForMessage(ws, 'sync');
+      clients.push(ws);
+    }
+
+    expect(clients.length).toBe(10);
+    for (const ws of clients) {
+      expect(ws.readyState).toBe(WebSocket.OPEN);
+    }
+
+    for (const ws of clients) {
+      await closeWs(ws);
+    }
+  });
+
+  it('should handle 10 clients editing sequentially', async () => {
+    const doc = await createDocument(ctx.baseUrl, 'Stress Sequential', '');
+    const clients: Array<{ ws: WebSocket; version: number }> = [];
+
+    // Connect all clients
+    for (let i = 0; i < 10; i++) {
+      const ws = await connectWs(ctx.wsUrl, doc.id);
+      const sync = await waitForMessage(ws, 'sync');
+      clients.push({ ws, version: sync.version as number });
+    }
+
+    // Each client inserts a character
+    for (let i = 0; i < 10; i++) {
+      const client = clients[i];
+      const char = String.fromCharCode(65 + i); // A, B, C, ...
+      const currentDoc = await fetch(`${ctx.baseUrl}/api/documents/${doc.id}`);
+      const docState = await currentDoc.json();
+      const docLen = docState.content.length;
+
+      // Get latest version
+      const latestVersion = client.version;
+      sendOp(client.ws, latestVersion, docLen > 0 ? [docLen, char] : [char]);
+      const ack = await waitForMessage(client.ws, 'ack');
+      client.version = ack.version as number;
+
+      // Update other clients' versions
+      for (let j = 0; j < 10; j++) {
+        if (j !== i) {
+          // Drain the operation message
+          try {
+            const msg = await waitForMessage(clients[j].ws, 'operation', 2000);
+            clients[j].version = msg.version as number;
+          } catch {
+            // may have already been drained
+          }
+        }
+      }
+    }
+
+    await delay(300);
+
+    const res = await fetch(`${ctx.baseUrl}/api/documents/${doc.id}`);
+    const final = await res.json();
+    expect(final.content.length).toBe(10);
+
+    for (const client of clients) {
+      await closeWs(client.ws);
+    }
+  });
+
+  it('should handle concurrent edits from 10 clients without corruption', async () => {
+    const doc = await createDocument(ctx.baseUrl, 'Stress Concurrent', 'base');
+    const clients: WebSocket[] = [];
+
+    // Connect all clients
+    for (let i = 0; i < 10; i++) {
+      const ws = await connectWs(ctx.wsUrl, doc.id);
+      const sync = await waitForMessage(ws, 'sync');
+      expect(sync.content).toBe('base');
+      clients.push(ws);
+    }
+
+    // All clients concurrently insert at end, all based on version 0
+    for (let i = 0; i < 10; i++) {
+      const char = String(i);
+      sendOp(clients[i], 0, [4, char]);
+    }
+
+    // Wait for all acks
+    for (let i = 0; i < 10; i++) {
+      await waitForMessage(clients[i], 'ack');
+    }
+
+    await delay(500);
+
+    // Verify document is not corrupted
+    const res = await fetch(`${ctx.baseUrl}/api/documents/${doc.id}`);
+    const final = await res.json();
+
+    // Content should contain "base" and all 10 digits
+    expect(final.content).toContain('base');
+    for (let i = 0; i < 10; i++) {
+      expect(final.content).toContain(String(i));
+    }
+    expect(final.content.length).toBe(14); // "base" + 10 chars
+
+    for (const ws of clients) {
+      await closeWs(ws);
+    }
+  });
+
+  it('should maintain document integrity under load', async () => {
+    const doc = await createDocument(ctx.baseUrl, 'Integrity Test', '');
+    const ws = await connectWs(ctx.wsUrl, doc.id);
+    const sync = await waitForMessage(ws, 'sync');
+    let version = sync.version as number;
+
+    // Rapidly insert 50 characters
+    for (let i = 0; i < 50; i++) {
+      sendOp(ws, version, [i, 'x']);
+      const ack = await waitForMessage(ws, 'ack');
+      version = ack.version as number;
+    }
+
+    const res = await fetch(`${ctx.baseUrl}/api/documents/${doc.id}`);
+    const final = await res.json();
+    expect(final.content).toBe('x'.repeat(50));
+
+    await closeWs(ws);
+  });
+
+  it('should not crash when clients disconnect during edits', async () => {
+    const doc = await createDocument(ctx.baseUrl, 'Disconnect Stress', 'stable');
+    const clients: WebSocket[] = [];
+
+    // Connect 10 clients
+    for (let i = 0; i < 10; i++) {
+      const ws = await connectWs(ctx.wsUrl, doc.id);
+      await waitForMessage(ws, 'sync');
+      clients.push(ws);
+    }
+
+    // Disconnect half
+    for (let i = 0; i < 5; i++) {
+      await closeWs(clients[i]);
+    }
+
+    await delay(200);
+
+    // Remaining clients should still work
+    const remaining = clients[5];
+    sendOp(remaining, 0, [6, '!']);
+    const ack = await waitForMessage(remaining, 'ack');
+    expect(ack.type).toBe('ack');
+
+    const res = await fetch(`${ctx.baseUrl}/api/documents/${doc.id}`);
+    const final = await res.json();
+    expect(final.content).toBe('stable!');
+
+    for (let i = 5; i < 10; i++) {
+      await closeWs(clients[i]);
+    }
+  });
+});
diff --git a/tests/two-client-convergence.test.ts b/tests/two-client-convergence.test.ts
