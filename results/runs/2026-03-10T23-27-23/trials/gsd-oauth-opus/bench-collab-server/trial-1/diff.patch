@@ -0,0 +1,414 @@
+/**
+ * Operational Transform (OT) engine for collaborative text editing.
+ *
+ * Operations are arrays of components:
+ * - number > 0: retain N characters
+ * - string: insert the string at current position
+ * - number < 0: delete |N| characters
+ *
+ * The total "input length" of an operation (sum of retains + |deletes|) must
+ * equal the length of the document it's applied to.
+ */
+
+export type OpComponent = number | string;
+export type Operation = OpComponent[];
+
+export interface ClientOperation {
+  type: 'operation';
+  docId: string;
+  version: number;
+  operation: Operation;
+}
+
+/**
+ * Compute the input length of an operation (the document length it expects).
+ */
+export function inputLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) len += c;        // retain
+      else if (c < 0) len += -c;  // delete
+    }
+    // inserts don't consume input
+  }
+  return len;
+}
+
+/**
+ * Compute the output length of an operation (the document length after applying).
+ */
+export function outputLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) len += c;        // retain
+      // delete produces nothing
+    } else {
+      len += c.length;            // insert
+    }
+  }
+  return len;
+}
+
+/**
+ * Normalize an operation by merging adjacent components of the same type
+ * and removing no-ops.
+ */
+export function normalize(op: Operation): Operation {
+  const result: Operation = [];
+  for (const c of op) {
+    if (typeof c === 'number' && c === 0) continue;
+    if (typeof c === 'string' && c === '') continue;
+
+    if (result.length > 0) {
+      const last = result[result.length - 1];
+      if (typeof c === 'number' && typeof last === 'number') {
+        // Both retains or both deletes - merge if same sign
+        if ((c > 0 && last > 0) || (c < 0 && last < 0)) {
+          result[result.length - 1] = last + c;
+          continue;
+        }
+      } else if (typeof c === 'string' && typeof last === 'string') {
+        result[result.length - 1] = last + c;
+        continue;
+      }
+    }
+    result.push(c);
+  }
+  return result;
+}
+
+/**
+ * Apply an operation to a document string, returning the new document.
+ */
+export function apply(doc: string, op: Operation): string {
+  const docLen = doc.length;
+  const expectedLen = inputLength(op);
+  if (expectedLen !== docLen) {
+    throw new Error(
+      `Operation input length (${expectedLen}) does not match document length (${docLen})`
+    );
+  }
+
+  let result = '';
+  let pos = 0;
+
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) {
+        // retain
+        result += doc.slice(pos, pos + c);
+        pos += c;
+      } else if (c < 0) {
+        // delete
+        pos += -c;
+      }
+    } else {
+      // insert
+      result += c;
+    }
+  }
+
+  return result;
+}
+
+/**
+ * Iterator helper for stepping through operation components.
+ */
+class OpIterator {
+  private op: Operation;
+  private index: number = 0;
+  private offset: number = 0;
+
+  constructor(op: Operation) {
+    this.op = op;
+  }
+
+  hasNext(): boolean {
+    return this.index < this.op.length;
+  }
+
+  /**
+   * Take up to `n` units from the current component.
+   * For retain/delete, `n` is the number of characters.
+   * For insert, `n` is the number of characters of the inserted text.
+   */
+  take(n: number): OpComponent {
+    if (!this.hasNext()) return 0; // retain 0
+
+    const c = this.op[this.index];
+
+    if (typeof c === 'string') {
+      // Insert component
+      const remaining = c.length - this.offset;
+      if (n >= remaining) {
+        const result = c.slice(this.offset);
+        this.index++;
+        this.offset = 0;
+        return result;
+      } else {
+        const result = c.slice(this.offset, this.offset + n);
+        this.offset += n;
+        return result;
+      }
+    } else {
+      // Retain (positive) or delete (negative)
+      const abs = Math.abs(c);
+      const remaining = abs - this.offset;
+      const sign = c > 0 ? 1 : -1;
+
+      if (n >= remaining) {
+        this.index++;
+        this.offset = 0;
+        return remaining * sign;
+      } else {
+        this.offset += n;
+        return n * sign;
+      }
+    }
+  }
+
+  /**
+   * Peek at the current component type.
+   * Returns 'retain', 'insert', or 'delete'.
+   */
+  peekType(): 'retain' | 'insert' | 'delete' | 'end' {
+    if (!this.hasNext()) return 'end';
+    const c = this.op[this.index];
+    if (typeof c === 'string') return 'insert';
+    if (c > 0) return 'retain';
+    if (c < 0) return 'delete';
+    return 'end';
+  }
+
+  /**
+   * Get the remaining length of the current component.
+   */
+  peekLength(): number {
+    if (!this.hasNext()) return Infinity;
+    const c = this.op[this.index];
+    if (typeof c === 'string') return c.length - this.offset;
+    return Math.abs(c) - this.offset;
+  }
+}
+
+/**
+ * Transform two concurrent operations so they can be applied sequentially.
+ *
+ * Given operations A and B that both apply to the same document state,
+ * returns [A', B'] such that:
+ *   apply(apply(doc, A), B') === apply(apply(doc, B), A')
+ *
+ * @param op1 - First operation
+ * @param op2 - Second operation
+ * @returns [op1', op2'] - Transformed operations
+ */
+export function transform(op1: Operation, op2: Operation): [Operation, Operation] {
+  const iter1 = new OpIterator(op1);
+  const iter2 = new OpIterator(op2);
+
+  const result1: Operation = [];
+  const result2: Operation = [];
+
+  while (iter1.hasNext() || iter2.hasNext()) {
+    const type1 = iter1.peekType();
+    const type2 = iter2.peekType();
+
+    // If op1 has an insert, it goes first (priority to op1)
+    if (type1 === 'insert') {
+      const comp = iter1.take(iter1.peekLength());
+      result1.push(comp);
+      // op2' must retain over op1's insert
+      if (typeof comp === 'string') {
+        result2.push(comp.length);
+      }
+      continue;
+    }
+
+    // If op2 has an insert, it goes next
+    if (type2 === 'insert') {
+      const comp = iter2.take(iter2.peekLength());
+      result2.push(comp);
+      // op1' must retain over op2's insert
+      if (typeof comp === 'string') {
+        result1.push(comp.length);
+      }
+      continue;
+    }
+
+    // Both are done
+    if (type1 === 'end' && type2 === 'end') break;
+
+    // Both retain
+    if (type1 === 'retain' && type2 === 'retain') {
+      const len = Math.min(iter1.peekLength(), iter2.peekLength());
+      result1.push(iter1.take(len) as number);
+      result2.push(iter2.take(len) as number);
+      continue;
+    }
+
+    // op1 deletes, op2 retains
+    if (type1 === 'delete' && type2 === 'retain') {
+      const len = Math.min(iter1.peekLength(), iter2.peekLength());
+      result1.push(iter1.take(len) as number); // delete in op1'
+      iter2.take(len); // skip in op2'
+      continue;
+    }
+
+    // op1 retains, op2 deletes
+    if (type1 === 'retain' && type2 === 'delete') {
+      const len = Math.min(iter1.peekLength(), iter2.peekLength());
+      iter1.take(len); // skip in op1'
+      result2.push(iter2.take(len) as number); // delete in op2'
+      continue;
+    }
+
+    // Both delete the same region
+    if (type1 === 'delete' && type2 === 'delete') {
+      const len = Math.min(iter1.peekLength(), iter2.peekLength());
+      iter1.take(len);
+      iter2.take(len);
+      continue;
+    }
+
+    // Either side is done
+    if (type1 === 'end') {
+      const len = iter2.peekLength();
+      const comp = iter2.take(len);
+      result2.push(comp);
+      if (typeof comp === 'number' && comp > 0) {
+        result1.push(comp);
+      } else if (typeof comp === 'string') {
+        result1.push(comp.length);
+      }
+      continue;
+    }
+
+    if (type2 === 'end') {
+      const len = iter1.peekLength();
+      const comp = iter1.take(len);
+      result1.push(comp);
+      if (typeof comp === 'number' && comp > 0) {
+        result2.push(comp);
+      } else if (typeof comp === 'string') {
+        result2.push(comp.length);
+      }
+      continue;
+    }
+  }
+
+  return [normalize(result1), normalize(result2)];
+}
+
+/**
+ * Compose two sequential operations into one.
+ * compose(a, b) returns op such that apply(doc, op) === apply(apply(doc, a), b)
+ */
+export function compose(op1: Operation, op2: Operation): Operation {
+  const iter1 = new OpIterator(op1);
+  const iter2 = new OpIterator(op2);
+  const result: Operation = [];
+
+  while (iter1.hasNext() || iter2.hasNext()) {
+    const type1 = iter1.peekType();
+    const type2 = iter2.peekType();
+
+    // op1 delete
+    if (type1 === 'delete') {
+      result.push(iter1.take(iter1.peekLength()));
+      continue;
+    }
+
+    // op2 insert
+    if (type2 === 'insert') {
+      result.push(iter2.take(iter2.peekLength()));
+      continue;
+    }
+
+    if (type1 === 'end' && type2 === 'end') break;
+
+    // op1 retain, op2 retain
+    if (type1 === 'retain' && type2 === 'retain') {
+      const len = Math.min(iter1.peekLength(), iter2.peekLength());
+      result.push(iter1.take(len) as number);
+      iter2.take(len);
+      continue;
+    }
+
+    // op1 insert, op2 retain
+    if (type1 === 'insert' && type2 === 'retain') {
+      const len = Math.min(iter1.peekLength(), iter2.peekLength());
+      result.push(iter1.take(len));
+      iter2.take(len);
+      continue;
+    }
+
+    // op1 retain, op2 delete
+    if (type1 === 'retain' && type2 === 'delete') {
+      const len = Math.min(iter1.peekLength(), iter2.peekLength());
+      result.push(iter2.take(len) as number);
+      iter1.take(len);
+      continue;
+    }
+
+    // op1 insert, op2 delete
+    if (type1 === 'insert' && type2 === 'delete') {
+      const len = Math.min(iter1.peekLength(), iter2.peekLength());
+      iter1.take(len);
+      iter2.take(len);
+      continue;
+    }
+
+    break;
+  }
+
+  return normalize(result);
+}
+
+/**
+ * Create an insert operation at a given position in a document of given length.
+ */
+export function makeInsert(pos: number, text: string, docLen: number): Operation {
+  const op: Operation = [];
+  if (pos > 0) op.push(pos);
+  op.push(text);
+  if (docLen - pos > 0) op.push(docLen - pos);
+  return normalize(op);
+}
+
+/**
+ * Create a delete operation at a given position in a document of given length.
+ */
+export function makeDelete(pos: number, count: number, docLen: number): Operation {
+  const op: Operation = [];
+  if (pos > 0) op.push(pos);
+  op.push(-count);
+  if (docLen - pos - count > 0) op.push(docLen - pos - count);
+  return normalize(op);
+}
+
+/**
+ * Validate that an operation is well-formed for a document of the given length.
+ */
+export function validate(op: Operation, docLen: number): string | null {
+  if (!Array.isArray(op)) return 'Operation must be an array';
+
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (!Number.isInteger(c)) return 'Numeric components must be integers';
+      if (c === 0) continue; // no-op, but valid
+    } else if (typeof c === 'string') {
+      // valid insert
+    } else {
+      return `Invalid component type: ${typeof c}`;
+    }
+  }
+
+  const inLen = inputLength(op);
+  if (inLen !== docLen) {
+    return `Operation input length (${inLen}) does not match document length (${docLen})`;
+  }
+
+  return null;
+}
