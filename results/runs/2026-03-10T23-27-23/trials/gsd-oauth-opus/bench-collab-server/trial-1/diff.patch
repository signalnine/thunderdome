new file mode 100644
index 0000000..894d993
--- /dev/null
+++ b/tests/helpers.ts
@@ -0,0 +1,146 @@
+import WebSocket from 'ws';
+import { createApp, AppInstance } from '../src/server.js';
+
+export interface TestContext {
+  app: AppInstance;
+  port: number;
+  baseUrl: string;
+  wsUrl: string;
+}
+
+export async function setupServer(dbPath?: string): Promise<TestContext> {
+  const app = createApp(dbPath);
+  const port = await app.start(0);
+  return {
+    app,
+    port,
+    baseUrl: `http://localhost:${port}`,
+    wsUrl: `ws://localhost:${port}`,
+  };
+}
+
+export async function teardownServer(ctx: TestContext): Promise<void> {
+  await ctx.app.stop();
+}
+
+export async function createDocument(
+  baseUrl: string,
+  title: string,
+  content: string = ''
+): Promise<{ id: string; title: string; content: string; created_at: string; updated_at: string }> {
+  const res = await fetch(`${baseUrl}/api/documents`, {
+    method: 'POST',
+    headers: { 'Content-Type': 'application/json' },
+    body: JSON.stringify({ title, content }),
+  });
+  return res.json();
+}
+
+// Message queue symbol to attach to WebSocket instances
+const MSG_QUEUE = Symbol('msgQueue');
+const MSG_WAITERS = Symbol('msgWaiters');
+
+interface QueuedMessage {
+  data: Record<string, unknown>;
+}
+
+interface MessageWaiter {
+  type?: string;
+  resolve: (msg: Record<string, unknown>) => void;
+  reject: (err: Error) => void;
+  timer: ReturnType<typeof setTimeout>;
+}
+
+function setupMessageQueue(ws: WebSocket): void {
+  const queue: QueuedMessage[] = [];
+  const waiters: MessageWaiter[] = [];
+
+  (ws as unknown as Record<symbol, unknown>)[MSG_QUEUE] = queue;
+  (ws as unknown as Record<symbol, unknown>)[MSG_WAITERS] = waiters;
+
+  ws.on('message', (data: WebSocket.Data) => {
+    const msg = JSON.parse(data.toString());
+
+    // Check if any waiter matches
+    for (let i = 0; i < waiters.length; i++) {
+      const waiter = waiters[i];
+      if (!waiter.type || msg.type === waiter.type) {
+        clearTimeout(waiter.timer);
+        waiters.splice(i, 1);
+        waiter.resolve(msg);
+        return;
+      }
+    }
+
+    // No matching waiter, queue the message
+    queue.push({ data: msg });
+  });
+}
+
+export function connectWs(
+  wsUrl: string,
+  docId: string
+): Promise<WebSocket> {
+  return new Promise((resolve, reject) => {
+    const ws = new WebSocket(`${wsUrl}/documents/${docId}`);
+    setupMessageQueue(ws);
+    ws.on('open', () => resolve(ws));
+    ws.on('error', (err) => reject(err));
+  });
+}
+
+export function waitForMessage(
+  ws: WebSocket,
+  type?: string,
+  timeout: number = 5000
+): Promise<Record<string, unknown>> {
+  const queue = (ws as unknown as Record<symbol, QueuedMessage[]>)[MSG_QUEUE] || [];
+  const waiters = (ws as unknown as Record<symbol, MessageWaiter[]>)[MSG_WAITERS] || [];
+
+  // Check queued messages first
+  for (let i = 0; i < queue.length; i++) {
+    const msg = queue[i].data;
+    if (!type || msg.type === type) {
+      queue.splice(i, 1);
+      return Promise.resolve(msg);
+    }
+  }
+
+  // No match in queue, wait for future message
+  return new Promise((resolve, reject) => {
+    const timer = setTimeout(() => {
+      const idx = waiters.findIndex(w => w.timer === timer);
+      if (idx !== -1) waiters.splice(idx, 1);
+      reject(new Error(`Timed out waiting for message${type ? ` of type "${type}"` : ''}`));
+    }, timeout);
+
+    waiters.push({ type, resolve, reject, timer });
+  });
+}
+
+export function sendOp(
+  ws: WebSocket,
+  version: number,
+  operation: (number | string)[]
+): void {
+  ws.send(JSON.stringify({
+    type: 'operation',
+    version,
+    operation,
+  }));
+}
+
+export async function closeWs(ws: WebSocket): Promise<void> {
+  return new Promise((resolve) => {
+    if (ws.readyState === WebSocket.CLOSED || ws.readyState === WebSocket.CLOSING) {
+      resolve();
+      return;
+    }
+    ws.on('close', () => resolve());
+    ws.close();
+  });
+}
+
+export function delay(ms: number): Promise<void> {
+  return new Promise((resolve) => setTimeout(resolve, ms));
+}
