cies ──────────────────────────────────────\n   372→\n   373→  getDependencyStatus(taskId: string): { taskId: string; status: TaskStatus; resolved: boolean }[] {\n   374→    const task = this.tasks.get(taskId);\n   375→    if (!task) {\n   376→      throw new Error(`Task not found: ${taskId}`);\n   377→    }\n   378→\n   379→    return task.dependencies.map(depId => {\n   380→      const dep = this.tasks.get(depId);\n   381→      if (!dep) {\n   382→        return { taskId: depId, status: 'failed' as TaskStatus, resolved: false };\n   383→      }\n   384→      return {\n   385→        taskId: depId,\n   386→        status: dep.status,\n   387→        resolved: dep.status === 'completed',\n   388→      };\n   389→    });\n   390→  }\n   391→\n   392→  // ── Phase 8: Concurrency Control ────────────────────────────────────\n   393→\n   394→  setConcurrency(queueName: string, limit: number): void {\n   395→    const qs = this.getQueueState(queueName);\n   396→    qs.concurrencyLimit = limit;\n   397→  }\n   398→\n   399→  getConcurrency(queueName?: string): { limit: number; active: number } {\n   400→    const name = queueName ?? TaskQueue.DEFAULT_QUEUE;\n   401→    const qs = this.getQueueState(name);\n   402→    return { limit: qs.concurrencyLimit, active: qs.activeCount };\n   403→  }\n   404→\n   405→  // ── Phase 9: Progress Tracking and Cancellation ─────────────────────\n   406→\n   407→  updateProgress(taskId: string, progress: number, message?: string): void {\n   408→    const task = this.tasks.get(taskId);\n   409→    if (!task) {\n   410→      throw new Error(`Task not found: ${taskId}`);\n   411→    }\n   412→    if (task.status !== 'processing') {\n   413→      throw new Error(`Task ${taskId} is not in processing state`);\n   414→    }\n   415→\n   416→    task.progress = Math.min(100, Math.max(0, progress));\n   417→    task.progressMessage = message;\n   418→\n   419→    // Notify listeners\n   420→    const listeners = this.progressListeners.get(taskId);\n   421→    if (listeners) {\n   422→      for (const listener of listeners) {\n   423→        listener(task.progress, message);\n   424→      }\n   425→    }\n   426→  }\n   427→\n   428→  getProgress(taskId: string): { progress: number; message?: string } {\n   429→    const task = this.tasks.get(taskId);\n   430→    if (!task) {\n   431→      throw new Error(`Task not found: ${taskId}`);\n   432→    }\n   433→    return { progress: task.progress, message: task.progressMessage };\n   434→  }\n   435→\n   436→  onProgress(taskId: string, listener: ProgressListener): () => void {\n   437→    let listeners = this.progressListeners.get(taskId);\n   438→    if (!listeners) {\n   439→      listeners = new Set();\n   440→      this.progressListeners.set(taskId, listeners);\n   441→    }\n   442→    listeners.add(listener);\n   443→\n   444→    // Return unsubscribe function\n   445→    return () => {\n   446→      listeners!.delete(listener);\n   447→      if (listeners!.size === 0) {\n   448→        this.progressListeners.delete(taskId);\n   449→      }\n   450→    };\n   451→  }\n   452→\n   453→  cancel(taskId: string): void {\n   454→    const task = this.tasks.get(taskId);\n   455→    if (!task) {\n   456→      throw new Error(`Task not found: ${taskId}`);\n   457→    }\n   458→    if (task.status !== 'pending' && task.status !== 'processing') {\n   459→      throw new Error(`Task ${taskId} cannot be cancelled (current: ${task.status})`);\n   460→    }\n   461→\n   462→    const wasPending = task.status === 'pending';\n   463→    task.status = 'cancelled';\n   464→\n   465→    // Free concurrency slot if was processing\n   466→    if (!wasPending) {\n   467→      const qs = this.getQueueState(task.queue);\n   468→      qs.activeCount = Math.max(0, qs.activeCount - 1);\n   469→    }\n   470→  }\n   471→\n   472→  // ── Phase 10: Recurring Tasks (Cron) ────────────────────────────────\n   473→\n   474→  addSchedule(cron: string, payload: unknown, options: ScheduleOptions = {}): Schedule {\n   475→    if (this.isShutdown) {\n   476→      throw new Error('Queue is shut down. Cannot add schedules.');\n   477→    }\n   478→\n   479→    const schedule: Schedule = {\n   480→      id: options.id ?? randomUUID(),\n   481→      cron,\n   482→      payload,\n   483→      queue: options.queue ?? TaskQueue.DEFAULT_QUEUE,\n   484→      options,\n   485→      lastRun: null,\n   486→      createdAt: new Date(),\n   487→    };\n   488→\n   489→    this.schedules.set(schedule.id, schedule);\n   490→    return schedule;\n   491→  }\n   492→\n   493→  removeSchedule(scheduleId: string): void {\n   494→    if (!this.schedules.has(scheduleId)) {\n   495→      throw new Error(`Schedule not found: ${scheduleId}`);\n   496→    }\n   497→    this.schedules.delete(scheduleId);\n   498→  }\n   499→\n   500→  getSchedules(): Schedule[] {\n   501→    return Array.from(this.schedules.values());\n   502→  }\n   503→\n   504→  tick(now?: Date): Task[] {\n   505→    const currentTime = now ?? new Date();\n   506→    const enqueued: Task[] = [];\n   507→\n   508→    for (const schedule of this.schedules.values()) {\n   509→      if (this.shouldRunSchedule(schedule, currentTime)) {\n   510→        const task = this.enqueue(schedule.payload, {\n   511→          queue: schedule.queue,\n   512→          priority: schedule.options.priority,\n   513→          maxRetries: schedule.options.maxRetries,\n   514→          backoffDelay: schedule.options.backoffDelay,\n   515→        });\n   516→        enqueued.push(task);\n   517→        schedule.lastRun = currentTime;\n   518→      }\n   519→    }\n   520→\n   521→    return enqueued;\n   522→  }\n   523→\n   524→  private shouldRunSchedule(schedule: Schedule, now: Date): boolean {\n   525→    const { cron, lastRun } = schedule;\n   526→    const parts = cron.split(/\\s+/);\n   527→    if (parts.length !== 5) return false;\n   528→\n   529→    const [minutePart, hourPart, dayOfMonthPart, monthPart, dayOfWeekPart] = parts;\n   530→\n   531→    const currentMinute = now.getMinutes();\n   532→    const currentHour = now.getHours();\n   533→\n   534→    // Check month\n   535→    if (monthPart !== '*') return false;\n   536→    // Check day of week\n   537→    if (dayOfWeekPart !== '*') return false;\n   538→    // Check day of month\n   539→    if (dayOfMonthPart !== '*') {\n   540→      if (parseInt(dayOfMonthPart) !== now.getDate()) return false;\n   541→    }\n   542→\n   543→    // Check if cron matches current time\n   544→    let minuteMatch = false;\n   545→    let hourMatch = false;\n   546→\n   547→    // Parse minute\n   548→    if (minutePart === '*') {\n   549→      minuteMatch = true;\n   550→    } else if (minutePart.startsWith('*/')) {\n   551→      const interval = parseInt(minutePart.slice(2));\n   552→      minuteMatch = currentMinute % interval === 0;\n   553→    } else {\n   554→      minuteMatch = parseInt(minutePart) === currentMinute;\n   555→    }\n   556→\n   557→    // Parse hour\n   558→    if (hourPart === '*') {\n   559→      hourMatch = true;\n   560→    } else if (hourPart.startsWith('*/')) {\n   561→      const interval = parseInt(hourPart.slice(2));\n   562→      hourMatch = currentHour % interval === 0;\n   563→    } else {\n   564→      hourMatch = parseInt(hourPart) === currentHour;\n   565→    }\n   566→\n   567→    if (!minuteMatch || !hourMatch) return false;\n   568→\n   569→    // Check if we already ran this schedule at this time slot\n   570→    if (lastRun) {\n   571→      const lastRunMinute = lastRun.getMinutes();\n   572→      const lastRunHour = lastRun.getHours();\n   573→      const lastRunDate = lastRun.toDateString();\n   574→      const nowDate = now.toDateString();\n   575→\n   576→      if (lastRunDate === nowDate && lastRunHour === currentHour && lastRunMinute === currentMinute) {\n   577→        return false;\n   578→      }\n   579→    }\n   580→\n   581→    return true;\n   582→  }\n   583→\n   584→  // ── Phase 11: Middleware Pipeline ────────────────────────────────────\n   585→\n   586→  use(queueName: string, middleware: MiddlewareFn): void {\n   587→    const qs = this.getQueueState(queueName);\n   588→    qs.middleware.push(middleware);\n   589→  }\n   590→\n   591→  process(queueName: string, processor: ProcessorFn): void {\n   592→    const qs = this.getQueueState(queueName);\n   593→    qs.processor = processor;\n   594→  }\n   595→\n   596→  async processNext(queueName?: string): Promise<Task | null> {\n   597→    const name = queueName ?? TaskQueue.DEFAULT_QUEUE;\n   598→    const task = this.dequeue(name);\n   599→    if (!task) return null;\n   600→\n   601→    const qs = this.getQueueState(name);\n   602→\n   603→    try {\n   604→      await this.runMiddlewarePipeline(task, qs.middleware, qs.processor);\n   605→      if (task.status === 'processing') {\n   606→        this.complete(task.id);\n   607→      }\n   608→    } catch (err) {\n   609→      if (task.status === 'processing') {\n   610→        this.fail(task.id, err instanceof Error ? err.message : String(err));\n   611→      }\n   612→    }\n   613→\n   614→    return task;\n   615→  }\n   616→\n   617→  private async runMiddlewarePipeline(\n   618→    task: Task,\n   619→    middlewares: MiddlewareFn[],\n   620→    processor: ProcessorFn | null,\n   621→  ): Promise<void> {\n   622→    let index = 0;\n   623→\n   624→    const next = async (): Promise<void> => {\n   625→      if (index < middlewares.length) {\n   626→        const mw = middlewares[index++];\n   627→        await mw(task, next);\n   628→      } else if (processor) {\n   629→        await processor(task);\n   630→      }\n   631→    };\n   632→\n   633→    await next();\n   634→  }\n   635→\n   636→  // ── Phase 12: Graceful Shutdown ──────────────────────────────────────\n   637→\n   638→  onShutdown(callback: ShutdownCallback): void {\n   639→    this.shutdownCallbacks.push(callback);\n   640→  }\n   641→\n   642→  async shutdown(timeout: number = 30000): Promise<ShutdownSummary> {\n   643→    if (this.shutdownPromise) {\n   644→      return this.shutdownPromise;\n   645→    }\n   646→\n   647→    this.isShutdown = true;\n   648→    this.shutdownPromise = this.performShutdown(timeout);\n   649→    return this.shutdownPromise;\n   650→  }\n   651→\n   652→  private async performShutdown(timeout: number): Promise<ShutdownSummary> {\n   653→    const startTime = Date.now();\n   654→\n   655→    // Run shutdown callbacks\n   656→    for (const cb of this.shutdownCallbacks) {\n   657→      await cb();\n   658→    }\n   659→\n   660→    // Find all processing tasks\n   661→    const processingTasks: Task[] = [];\n   662→    for (const task of this.tasks.values()) {\n   663→      if (task.status === 'processing') {\n   664→        processingTasks.push(task);\n   665→      }\n   666→    }\n   667→\n   668→    if (processingTasks.length === 0) {\n   669→      return {\n   670→        completed: 0,\n   671→        forceCancelled: 0,\n   672→        duration: Date.now() - startTime,\n   673→      };\n   674→    }\n   675→\n   676→    // Wait for processing tasks to complete (up to timeout)\n   677→    let completed = 0;\n   678→    let forceCancelled = 0;\n   679→\n   680→    await Promise.race([\n   681→      this.waitForProcessingTasks(processingTasks),\n   682→      new Promise<'timeout'>(resolve => setTimeout(() => resolve('timeout'), timeout)),\n   683→    ]);\n   684→\n   685→    // Count completed tasks\n   686→    for (const task of processingTasks) {\n   687→      if (task.status === 'completed' || task.status === 'failed') {\n   688→        completed++;\n   689→      } else if (task.status === 'processing') {\n   690→        // Force cancel\n   691→        task.status = 'cancelled';\n   692→        const qs = this.getQueueState(task.queue);\n   693→        qs.activeCount = Math.max(0, qs.activeCount - 1);\n   694→        forceCancelled++;\n   695→      }\n   696→    }\n   697→\n   698→    return {\n   699→      completed,\n   700→      forceCancelled,\n   701→      duration: Date.now() - startTime,\n   702→    };\n   703→  }\n   704→\n   705→  private async waitForProcessingTasks(tasks: Task[]): Promise<void> {\n   706→    // Poll until all processing tasks are done\n   707→    while (tasks.some(t => t.status === 'processing')) {\n   708→      await new Promise(resolve => setTimeout(resolve, 10));\n   709→    }\n   710→  }\n   711→\n   712→  // ── Utility ─────────────────────────────────────────────────────────\n   713→\n   714→  getTask(taskId: string): Task | undefined {\n   715→    return this.tasks.get(taskId);\n   716→  }\n   717→}\n   718→"}]},"parent_tool_use_id":null,"session_id":"9ffff21e-55a2-42c3-9982-0a1b8673eedf","uuid":"c3d5f03f-614e-4d1d-99cc-0b28a4ea8bc4","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/index.ts","content":"import { randomUUID } from 'node:crypto';\n\n// ── Types ──────────────────────────────────────────────────────────────\n\nexport type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';\n\nexport interface TaskOptions {\n  queue?: string;\n  priority?: number;\n  delay?: number;\n  runAt?: Date;\n  maxRetries?: number;\n  backoffDelay?: number;\n  dependencies?: string[];\n}\n\nexport interface Task<T = unknown> {\n  id: string;\n  payload: T;\n  status: TaskStatus;\n  createdAt: Date;\n  priority: number;\n  queue: string;\n  availableAt: Date;\n  attempt: number;\n  maxRetries: number;\n  backoffDelay: number;\n  error?: string;\n  failCount: number;\n  dependencies: string[];\n  progress: number;\n  progressMessage?: string;\n  metadata: Record<string, unknown>;\n}\n\nexport interface ScheduleOptions {\n  id?: string;\n  queue?: string;\n  priority?: number;\n  maxRetries?: number;\n  backoffDelay?: number;\n}\n\nexport interface Schedule {\n  id: string;\n  cron: string;\n  payload: unknown;\n  queue: string;\n  options: ScheduleOptions;\n  lastRun: Date | null;\n  createdAt: Date;\n}\n\nexport type MiddlewareFn = (task: Task, next: () => Promise<void>) => Promise<void> | void;\nexport type ProcessorFn = (task: Task) => Promise<void> | void;\nexport type ProgressListener = (progress: number, message?: string) => void;\nexport type ShutdownCallback = () => Promise<void> | void;\n\nexport interface ShutdownSummary {\n  completed: number;\n  forceCancelled: number;\n  duration: number;\n}\n\ninterface QueueState {\n  concurrencyLimit: number;\n  activeCount: number;\n  middleware: MiddlewareFn[];\n  processor: ProcessorFn | null;\n}\n\n// ── TaskQueue ──────────────────────────────────────────────────────────\n\nexport class TaskQueue {\n  private tasks: Map<string, Task> = new Map();\n  private queues: Map<string, QueueState> = new Map();\n  private dlq: Map<string, Task[]> = new Map();\n  private schedules: Map<string, Schedule> = new Map();\n  private progressListeners: Map<string, Set<ProgressListener>> = new Map();\n  private shutdownCallbacks: ShutdownCallback[] = [];\n  private isShutdown = false;\n  private shutdownPromise: Promise<ShutdownSummary> | null = null;\n\n  private static readonly DEFAULT_QUEUE = 'default';\n\n  // ── Helpers ──────────────────────────────────────────────────────────\n\n  private getQueueState(name: string): QueueState {\n    let qs = this.queues.get(name);\n    if (!qs) {\n      qs = {\n        concurrencyLimit: 0,  // 0 means unlimited\n        activeCount: 0,\n        middleware: [],\n        processor: null,\n      };\n      this.queues.set(name, qs);\n    }\n    return qs;\n  }\n\n  private ensureQueueExists(name: string): void {\n    if (!this.queues.has(name)) {\n      this.getQueueState(name);\n    }\n  }\n\n  private detectCycles(dependencies: string[]): void {\n    // Build a reverse lookup: for the new task's dependencies, check if any\n    // dependency can reach another dependency through transitive deps.\n    // This detects the case where adding this task would create an indirect cycle.\n    const visited = new Set<string>();\n\n    const visit = (taskId: string, ancestors: Set<string>): void => {\n      if (ancestors.has(taskId)) {\n        throw new Error('Circular dependency detected');\n      }\n      if (visited.has(taskId)) return;\n      visited.add(taskId);\n\n      const task = this.tasks.get(taskId);\n      if (!task) return;\n\n      ancestors.add(taskId);\n      for (const depId of task.dependencies) {\n        visit(depId, ancestors);\n      }\n      ancestors.delete(taskId);\n    };\n\n    for (const depId of dependencies) {\n      visit(depId, new Set(dependencies));\n    }\n  }\n\n  // ── Phase 1: Basic FIFO Queue ────────────────────────────────────────\n\n  enqueue<T = unknown>(payload: T, options: TaskOptions = {}): Task<T> {\n    if (this.isShutdown) {\n      throw new Error('Queue is shut down. Cannot add new tasks.');\n    }\n\n    const queueName = options.queue ?? TaskQueue.DEFAULT_QUEUE;\n\n    // Validate priority (Phase 3)\n    const priority = options.priority ?? 5;\n    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    }\n\n    // Compute availableAt (Phase 4)\n    let availableAt = new Date();\n    if (options.runAt) {\n      availableAt = options.runAt;\n    } else if (options.delay != null && options.delay > 0) {\n      availableAt = new Date(Date.now() + options.delay);\n    }\n\n    // Validate dependencies (Phase 7)\n    const dependencies = options.dependencies ?? [];\n    for (const depId of dependencies) {\n      if (!this.tasks.has(depId)) {\n        throw new Error(`Dependency task not found: ${depId}`);\n      }\n    }\n\n    // Circular dependency detection (Phase 7)\n    // Check if any dependency has a transitive dependency that would create a cycle.\n    // Since the new task doesn't exist yet, we check if any dependency transitively\n    // depends on any other dependency (which would be a problem