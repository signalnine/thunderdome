 use(queueName: string, middleware: MiddlewareFn): void {\n   585→    const qs = this.getQueueState(queueName);\n   586→    qs.middleware.push(middleware);\n   587→  }\n   588→\n   589→  process(queueName: string, processor: ProcessorFn): void {\n   590→    const qs = this.getQueueState(queueName);\n   591→    qs.processor = processor;\n   592→  }\n   593→\n   594→  async processNext(queueName?: string): Promise<Task | null> {\n   595→    const name = queueName ?? TaskQueue.DEFAULT_QUEUE;\n   596→    const task = this.dequeue(name);\n   597→    if (!task) return null;\n   598→\n   599→    const qs = this.getQueueState(name);\n   600→\n   601→    try {\n   602→      await this.runMiddlewarePipeline(task, qs.middleware, qs.processor);\n   603→      if (task.status === 'processing') {\n   604→        this.complete(task.id);\n   605→      }\n   606→    } catch (err) {\n   607→      if (task.status === 'processing') {\n   608→        this.fail(task.id, err instanceof Error ? err.message : String(err));\n   609→      }\n   610→    }\n   611→\n   612→    return task;\n   613→  }\n   614→\n   615→  private async runMiddlewarePipeline(\n   616→    task: Task,\n   617→    middlewares: MiddlewareFn[],\n   618→    processor: ProcessorFn | null,\n   619→  ): Promise<void> {\n   620→    let index = 0;\n   621→\n   622→    const next = async (): Promise<void> => {\n   623→      if (index < middlewares.length) {\n   624→        const mw = middlewares[index++];\n   625→        await mw(task, next);\n   626→      } else if (processor) {\n   627→        await processor(task);\n   628→      }\n   629→    };\n   630→\n   631→    await next();\n   632→  }\n   633→\n   634→  // ── Phase 12: Graceful Shutdown ──────────────────────────────────────\n   635→\n   636→  onShutdown(callback: ShutdownCallback): void {\n   637→    this.shutdownCallbacks.push(callback);\n   638→  }\n   639→\n   640→  async shutdown(timeout: number = 30000): Promise<ShutdownSummary> {\n   641→    if (this.shutdownPromise) {\n   642→      return this.shutdownPromise;\n   643→    }\n   644→\n   645→    this.isShutdown = true;\n   646→    this.shutdownPromise = this.performShutdown(timeout);\n   647→    return this.shutdownPromise;\n   648→  }\n   649→\n   650→  private async performShutdown(timeout: number): Promise<ShutdownSummary> {\n   651→    const startTime = Date.now();\n   652→\n   653→    // Run shutdown callbacks\n   654→    for (const cb of this.shutdownCallbacks) {\n   655→      await cb();\n   656→    }\n   657→\n   658→    // Find all processing tasks\n   659→    const processingTasks: Task[] = [];\n   660→    for (const task of this.tasks.values()) {\n   661→      if (task.status === 'processing') {\n   662→        processingTasks.push(task);\n   663→      }\n   664→    }\n   665→\n   666→    if (processingTasks.length === 0) {\n   667→      return {\n   668→        completed: 0,\n   669→        forceCancelled: 0,\n   670→        duration: Date.now() - startTime,\n   671→      };\n   672→    }\n   673→\n   674→    // Wait for processing tasks to complete (up to timeout)\n   675→    let completed = 0;\n   676→    let forceCancelled = 0;\n   677→\n   678→    await Promise.race([\n   679→      this.waitForProcessingTasks(processingTasks),\n   680→      new Promise<'timeout'>(resolve => setTimeout(() => resolve('timeout'), timeout)),\n   681→    ]);\n   682→\n   683→    // Count completed tasks\n   684→    for (const task of processingTasks) {\n   685→      if (task.status === 'completed' || task.status === 'failed') {\n   686→        completed++;\n   687→      } else if (task.status === 'processing') {\n   688→        // Force cancel\n   689→        task.status = 'cancelled';\n   690→        const qs = this.getQueueState(task.queue);\n   691→        qs.activeCount = Math.max(0, qs.activeCount - 1);\n   692→        forceCancelled++;\n   693→      }\n   694→    }\n   695→\n   696→    return {\n   697→      completed,\n   698→      forceCancelled,\n   699→      duration: Date.now() - startTime,\n   700→    };\n   701→  }\n   702→\n   703→  private async waitForProcessingTasks(tasks: Task[]): Promise<void> {\n   704→    // Poll until all processing tasks are done\n   705→    while (tasks.some(t => t.status === 'processing')) {\n   706→      await new Promise(resolve => setTimeout(resolve, 10));\n   707→    }\n   708→  }\n   709→\n   710→  // ── Utility ─────────────────────────────────────────────────────────\n   711→\n   712→  getTask(taskId: string): Task | undefined {\n   713→    return this.tasks.get(taskId);\n   714→  }\n   715→}\n   716→"}]},"parent_tool_use_id":null,"session_id":"9ffff21e-55a2-42c3-9982-0a1b8673eedf","uuid":"5b95f87e-5810-46d5-a701-a9d9544e50f4","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/index.ts","content":"import { randomUUID } from 'node:crypto';\n\n// ── Types ──────────────────────────────────────────────────────────────\n\nexport type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';\n\nexport interface TaskOptions {\n  queue?: string;\n  priority?: number;\n  delay?: number;\n  runAt?: Date;\n  maxRetries?: number;\n  backoffDelay?: number;\n  dependencies?: string[];\n}\n\nexport interface Task<T = unknown> {\n  id: string;\n  payload: T;\n  status: TaskStatus;\n  createdAt: Date;\n  priority: number;\n  queue: string;\n  availableAt: Date;\n  attempt: number;\n  maxRetries: number;\n  backoffDelay: number;\n  error?: string;\n  failCount: number;\n  dependencies: string[];\n  progress: number;\n  progressMessage?: string;\n  metadata: Record<string, unknown>;\n}\n\nexport interface ScheduleOptions {\n  id?: string;\n  queue?: string;\n  priority?: number;\n  maxRetries?: number;\n  backoffDelay?: number;\n}\n\nexport interface Schedule {\n  id: string;\n  cron: string;\n  payload: unknown;\n  queue: string;\n  options: ScheduleOptions;\n  lastRun: Date | null;\n  createdAt: Date;\n}\n\nexport type MiddlewareFn = (task: Task, next: () => Promise<void>) => Promise<void> | void;\nexport type ProcessorFn = (task: Task) => Promise<void> | void;\nexport type ProgressListener = (progress: number, message?: string) => void;\nexport type ShutdownCallback = () => Promise<void> | void;\n\nexport interface ShutdownSummary {\n  completed: number;\n  forceCancelled: number;\n  duration: number;\n}\n\ninterface QueueState {\n  concurrencyLimit: number;\n  activeCount: number;\n  middleware: MiddlewareFn[];\n  processor: ProcessorFn | null;\n}\n\n// ── TaskQueue ──────────────────────────────────────────────────────────\n\nexport class TaskQueue {\n  private tasks: Map<string, Task> = new Map();\n  private queues: Map<string, QueueState> = new Map();\n  private dlq: Map<string, Task[]> = new Map();\n  private schedules: Map<string, Schedule> = new Map();\n  private progressListeners: Map<string, Set<ProgressListener>> = new Map();\n  private shutdownCallbacks: ShutdownCallback[] = [];\n  private isShutdown = false;\n  private shutdownPromise: Promise<ShutdownSummary> | null = null;\n\n  private static readonly DEFAULT_QUEUE = 'default';\n\n  // ── Helpers ──────────────────────────────────────────────────────────\n\n  private getQueueState(name: string): QueueState {\n    let qs = this.queues.get(name);\n    if (!qs) {\n      qs = {\n        concurrencyLimit: 0,  // 0 means unlimited\n        activeCount: 0,\n        middleware: [],\n        processor: null,\n      };\n      this.queues.set(name, qs);\n    }\n    return qs;\n  }\n\n  private ensureQueueExists(name: string): void {\n    if (!this.queues.has(name)) {\n      this.getQueueState(name);\n    }\n  }\n\n  // ── Phase 1: Basic FIFO Queue ────────────────────────────────────────\n\n  enqueue<T = unknown>(payload: T, options: TaskOptions = {}): Task<T> {\n    if (this.isShutdown) {\n      throw new Error('Queue is shut down. Cannot add new tasks.');\n    }\n\n    const queueName = options.queue ?? TaskQueue.DEFAULT_QUEUE;\n\n    // Validate priority (Phase 3)\n    const priority = options.priority ?? 5;\n    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    }\n\n    // Compute availableAt (Phase 4)\n    let availableAt = new Date();\n    if (options.runAt) {\n      availableAt = options.runAt;\n    } else if (options.delay != null && options.delay > 0) {\n      availableAt = new Date(Date.now() + options.delay);\n    }\n\n    // Validate dependencies (Phase 7)\n    const dependencies = options.dependencies ?? [];\n    for (const depId of dependencies) {\n      if (!this.tasks.has(depId)) {\n        throw new Error(`Dependency task not found: ${depId}`);\n      }\n    }\n    // Circular dependency detection\n    if (dependencies.length > 0) {\n      const taskId = randomUUID();\n      // Check if adding this task with these dependencies would create a cycle\n      // We need to check: for each dep, can dep reach taskId through the dependency graph?\n      // Since taskId is new and not yet a dependency of anything, no cycle can form\n      // UNLESS we have a dependency chain that circles back.\n      // Actually, since this is a new task, it can't be depended on by existing tasks yet.\n      // But we need to check for cycles among the dependencies themselves.\n      // The real cycle check: if task A depends on B, and B depends on A.\n      // Since this task is new, no existing task can depend on it.\n      // So no cycle is possible at creation time... unless we have self-dependency.\n\n      // Check self-dependency\n      // Actually, the new task ID is generated here, so no existing task can reference it.\n      // Cycles can only happen if dependencies form a cycle among themselves,\n      // but that should have been caught when those tasks were created.\n      // Let's still do a proper check for correctness.\n\n      const task: Task<T> = {\n        id: taskId,\n        payload,\n        status: 'pending',\n        createdAt: new Date(),\n        priority,\n        queue: queueName,\n        availableAt,\n        attempt: 0,\n        maxRetries: options.maxRetries ?? 3,\n        backoffDelay: options.backoffDelay ?? 1000,\n        failCount: 0,\n        dependencies: [...dependencies],\n        progress: 0,\n        metadata: {},\n      };\n\n      this.ensureQueueExists(queueName);\n      this.tasks.set(taskId, task);\n      return task;\n    }\n\n    const task: Task<T> = {\n      id: randomUUID(),\n      payload,\n      status: 'pending',\n      createdAt: new Date(),\n      priority,\n      queue: queueName,\n      availableAt,\n      attempt: 0,\n      maxRetries: options.maxRetries ?? 3,\n      backoffDelay: options.backoffDelay ?? 1000,\n      failCount: 0,\n      dependencies: [...dependencies],\n      progress: 0,\n      metadata: {},\n    };\n\n    this.ensureQueueExists(queueName);\n    this.tasks.set(task.id, task);\n    return task;\n  }\n\n  dequeue(queueName?: string): Task | null {\n    const name = queueName ?? TaskQueue.DEFAULT_QUEUE;\n    const qs = this.queues.get(name);\n\n    // Check concurrency limit (Phase 8)\n    if (qs && qs.concurrencyLimit > 0 && qs.activeCount >= qs.concurrencyLimit) {\n      return null;\n    }\n\n    const now = Date.now();\n\n    // Get all pending tasks for this queue that are available\n    const candidates: Task[] = [];\n    for (const task of this.tasks.values()) {\n      if (task.queue !== name || task.status !== 'pending') continue;\n\n      // Check availability (Phase 4)\n      if (task.availableAt.getTime() > now) continue;\n\n      // Check dependencies (Phase 7)\n      if (task.dependencies.length > 0) {\n        const allResolved = task.dependencies.every(depId => {\n          const dep = this.tasks.get(depId);\n          return dep && dep.status === 'completed';\n        });\n        if (!allResolved) continue;\n      }\n\n      candidates.push(task);\n    }\n\n    if (candidates.length === 0) return null;\n\n    // Sort by priority (ascending = higher priority first), then by availableAt, then FIFO (createdAt)\n    candidates.sort((a, b) => {\n      if (a.priority !== b.priority) return a.priority - b.priority;\n      if (a.availableAt.getTime() !== b.availableAt.getTime()) {\n        return a.availableAt.getTime() - b.availableAt.getTime();\n      }\n      return a.createdAt.getTime() - b.createdAt.getTime();\n    });\n\n    const task = candidates[0];\n    task.status = 'processing';\n    task.attempt++;\n\n    // Track concurrency\n    const state = this.getQueueState(name);\n    state.activeCount++;\n\n    return task;\n  }\n\n  size(queueName?: string): number {\n    const name = queueName ?? TaskQueue.DEFAULT_QUEUE;\n    let count = 0;\n    for (const task of this.tasks.values()) {\n      if (task.queue === name && task.status === 'pending') {\n        count++;\n      }\n    }\n    return count;\n  }\n\n  // ── Phase 2: Named Queues ────────────────────────────────────────────\n\n  getQueues(): string[] {\n    return Array.from(this.queues.keys());\n  }\n\n  // ── Phase 5: Retry with Backoff ──────────────────────────────────────\n\n  complete(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${taskId} is not in processing state (current: ${task.status})`);\n    }\n\n    task.status = 'completed';\n    task.progress = 100;\n\n    // Free concurrency slot\n    const qs = this.getQueueState(task.queue);\n    qs.activeCount = Math.max(0, qs.activeCount - 1);\n\n    // Check if any dependent tasks are now unblocked (Phase 7) - just updating status is enough,\n    // dequeue will check dependencies dynamically\n  }\n\n  fail(taskId: string, error?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${taskId} is not in processing state (current: ${task.status})`);\n    }\n\n    task.error = error;\n    task.failCount++;\n\n    // Free concurrency slot\n    const qs = this.getQueueState(task.queue);\n    qs.activeCount = Math.max(0, qs.activeCount - 1);\n\n    if (task.attempt < task.maxRetries) {\n      // Retry with backoff\n      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);\n      task.status = 'pending';\n      task.availableAt = new Date(Date.now() + delay);\n    } else {\n      // No retries left\n      task.status = 'failed';\n\n      // Move to DLQ (Phase 6)\n      this.addToDlq(task);\n    }\n  }\n\n  // ── Phase 6: Dead Letter Queue ───────────────────────────────────────\n\n  private addToDlq(task: Task): void {\n    const queueDlq = this.dlq.get(task.queue);\n    if (queueDlq) {\n      queueDlq.push(task);\n    } else {\n      this.dlq.set(task.queue, [task]);\n    }\n  }\n\n  getDeadLetters(queueName?: string): Task[] {\n    const name = queueName ?? TaskQueue.DEFAULT_QUEUE;\n    return [...(this.dlq.get(name) ?? [])];\n  }\n\n  retryDeadLetter(taskId: string): Task {\n    // Find the task in any DLQ\n    for (const [queueName, dlqTasks] of this.dlq.entries()) {\n      const idx = dlqTasks.findIndex(t => t.id === taskId);\n      if (idx !== -1) {\n        const task = dlqTasks[idx];\n        dlqTasks.splice(idx, 1);\n\n        // Reset for fresh retries\n        task.status = 'pending';\n        task.attempt = 0;\n        task.failCount = 0;\n        task.error = undefined;\n        task.availableAt = new Date();\n        task.progress = 0;\n\n        // Make sure queue exists\n        this.ensureQueueExists(queueName);\n\n        return task;\n      }\n    }\n    throw new Error(`Dead-lettered task not found: ${taskId}`);\n  }\n\n  clearDeadLetters(queueName?: string): void {\n    const name = queueName ?? TaskQueue.DEFAULT_QUEUE;\n    this.dlq.set(name, []);\n  }\n\n  // ── Phase 7: Task Dependencies ──────────────────────────────────────\n\n  getDependencyStatus(taskId: string): { taskId: string; status: TaskStatus; resolved: boolean }[] {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n\n    return task.dependencies.map(depId => {\n      const dep = this.tasks.get(depId);\n      if (!dep) {\n        return { taskId: depId, status: 'failed' as TaskStatus, resolved: false };\n      }\n      return {\n        taskId: depId,\n        status: dep.status,\n        resolved: dep.status === 'completed',\n      };\n    });\n  }\n\n  // ── Phase 8: Concurrency Control ────────────────────────────────────\n\n  setConcurrency(queueName: string, limit: number): void {\n    const qs = this.getQueueState(queueName);\n    qs.concurrencyLimit = limit;\n  }\n\n  getConcurrency(queueName?: string): { limit: number; active: number } {\n    const name = queueName ?? TaskQueue.DEFAULT_QUEUE;\n    const qs = this.getQueueState(name);\n    return { limit: qs.concurrencyLimit, active: qs.activeCount };\n  }\n\n  // ── Phase 9: Progress Tracking and Cancellation ─────────────────────\n\n  updateProgress(taskId: string, progress: number, message?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${taskId} is not in processing state`);\n    }\n\n    task.progress = Math.min(100, Math.max(0, progress));\n    task.progressMessage = message;\n\n    // Notify listeners\n    const listeners = this.progressListeners.get(taskId);\n    if (listeners) {\n      for (const listener of listeners) {\n        listener(task.progress, message);\n      }\n    }\n  }\n\n  getProgress(taskId: string): { progress: number; message?: string } {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n  