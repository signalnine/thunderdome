downSummary {\n    60→  completed: number;\n    61→  forceCancelled: number;\n    62→  duration: number;\n    63→}\n    64→\n    65→interface QueueState {\n    66→  concurrencyLimit: number;\n    67→  activeCount: number;\n    68→  middleware: MiddlewareFn[];\n    69→  processor: ProcessorFn | null;\n    70→}\n    71→\n    72→// ── TaskQueue ──────────────────────────────────────────────────────────\n    73→\n    74→export class TaskQueue {\n    75→  private tasks: Map<string, Task> = new Map();\n    76→  private queues: Map<string, QueueState> = new Map();\n    77→  private dlq: Map<string, Task[]> = new Map();\n    78→  private schedules: Map<string, Schedule> = new Map();\n    79→  private progressListeners: Map<string, Set<ProgressListener>> = new Map();\n    80→  private shutdownCallbacks: ShutdownCallback[] = [];\n    81→  private isShutdown = false;\n    82→  private shutdownPromise: Promise<ShutdownSummary> | null = null;\n    83→\n    84→  private static readonly DEFAULT_QUEUE = 'default';\n    85→\n    86→  // ── Helpers ──────────────────────────────────────────────────────────\n    87→\n    88→  private getQueueState(name: string): QueueState {\n    89→    let qs = this.queues.get(name);\n    90→    if (!qs) {\n    91→      qs = {\n    92→        concurrencyLimit: 0,  // 0 means unlimited\n    93→        activeCount: 0,\n    94→        middleware: [],\n    95→        processor: null,\n    96→      };\n    97→      this.queues.set(name, qs);\n    98→    }\n    99→    return qs;\n   100→  }\n   101→\n   102→  private ensureQueueExists(name: string): void {\n   103→    if (!this.queues.has(name)) {\n   104→      this.getQueueState(name);\n   105→    }\n   106→  }\n   107→\n   108→  // ── Phase 1: Basic FIFO Queue ────────────────────────────────────────\n   109→\n   110→  enqueue<T = unknown>(payload: T, options: TaskOptions = {}): Task<T> {\n   111→    if (this.isShutdown) {\n   112→      throw new Error('Queue is shut down. Cannot add new tasks.');\n   113→    }\n   114→\n   115→    const queueName = options.queue ?? TaskQueue.DEFAULT_QUEUE;\n   116→\n   117→    // Validate priority (Phase 3)\n   118→    const priority = options.priority ?? 5;\n   119→    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n   120→      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n   121→    }\n   122→\n   123→    // Compute availableAt (Phase 4)\n   124→    let availableAt = new Date();\n   125→    if (options.runAt) {\n   126→      availableAt = options.runAt;\n   127→    } else if (options.delay != null && options.delay > 0) {\n   128→      availableAt = new Date(Date.now() + options.delay);\n   129→    }\n   130→\n   131→    // Validate dependencies (Phase 7)\n   132→    const dependencies = options.dependencies ?? [];\n   133→    for (const depId of dependencies) {\n   134→      if (!this.tasks.has(depId)) {\n   135→        throw new Error(`Dependency task not found: ${depId}`);\n   136→      }\n   137→    }\n   138→    // Circular dependency detection\n   139→    if (dependencies.length > 0) {\n   140→      const taskId = randomUUID();\n   141→      // Check if adding this task with these dependencies would create a cycle\n   142→      // We need to check: for each dep, can dep reach taskId through the dependency graph?\n   143→      // Since taskId is new and not yet a dependency of anything, no cycle can form\n   144→      // UNLESS we have a dependency chain that circles back.\n   145→      // Actually, since this is a new task, it can't be depended on by existing tasks yet.\n   146→      // But we need to check for cycles among the dependencies themselves.\n   147→      // The real cycle check: if task A depends on B, and B depends on A.\n   148→      // Since this task is new, no existing task can depend on it.\n   149→      // So no cycle is possible at creation time... unless we have self-dependency.\n   150→\n   151→      // Check self-dependency\n   152→      // Actually, the new task ID is generated here, so no existing task can reference it.\n   153→      // Cycles can only happen if dependencies form a cycle among themselves,\n   154→      // but that should have been caught when those tasks were created.\n   155→      // Let's still do a proper check for correctness.\n   156→\n   157→      const task: Task<T> = {\n   158→        id: taskId,\n   159→        payload,\n   160→        status: 'pending',\n   161→        createdAt: new Date(),\n   162→        priority,\n   163→        queue: queueName,\n   164→        availableAt,\n   165→        attempt: 0,\n   166→        maxRetries: options.maxRetries ?? 3,\n   167→        backoffDelay: options.backoffDelay ?? 1000,\n   168→        failCount: 0,\n   169→        dependencies: [...dependencies],\n   170→        progress: 0,\n   171→        metadata: {},\n   172→      };\n   173→\n   174→      this.ensureQueueExists(queueName);\n   175→      this.tasks.set(taskId, task);\n   176→      return task;\n   177→    }\n   178→\n   179→    const task: Task<T> = {\n   180→      id: randomUUID(),\n   181→      payload,\n   182→      status: 'pending',\n   183→      createdAt: new Date(),\n   184→      priority,\n   185→      queue: queueName,\n   186→      availableAt,\n   187→      attempt: 0,\n   188→      maxRetries: options.maxRetries ?? 3,\n   189→      backoffDelay: options.backoffDelay ?? 1000,\n   190→      failCount: 0,\n   191→      dependencies: [...dependencies],\n   192→      progress: 0,\n   193→      metadata: {},\n   194→    };\n   195→\n   196→    this.ensureQueueExists(queueName);\n   197→    this.tasks.set(task.id, task);\n   198→    return task;\n   199→  }\n   200→\n   201→  dequeue(queueName?: string): Task | null {\n   202→    const name = queueName ?? TaskQueue.DEFAULT_QUEUE;\n   203→    const qs = this.queues.get(name);\n   204→\n   205→    // Check concurrency limit (Phase 8)\n   206→    if (qs && qs.concurrencyLimit > 0 && qs.activeCount >= qs.concurrencyLimit) {\n   207→      return null;\n   208→    }\n   209→\n   210→    const now = Date.now();\n   211→\n   212→    // Get all pending tasks for this queue that are available\n   213→    const candidates: Task[] = [];\n   214→    for (const task of this.tasks.values()) {\n   215→      if (task.queue !== name || task.status !== 'pending') continue;\n   216→\n   217→      // Check availability (Phase 4)\n   218→      if (task.availableAt.getTime() > now) continue;\n   219→\n   220→      // Check dependencies (Phase 7)\n   221→      if (task.dependencies.length > 0) {\n   222→        const allResolved = task.dependencies.every(depId => {\n   223→          const dep = this.tasks.get(depId);\n   224→          return dep && dep.status === 'completed';\n   225→        });\n   226→        if (!allResolved) continue;\n   227→      }\n   228→\n   229→      candidates.push(task);\n   230→    }\n   231→\n   232→    if (candidates.length === 0) return null;\n   233→\n   234→    // Sort by priority (ascending = higher priority first), then by availableAt, then FIFO (createdAt)\n   235→    candidates.sort((a, b) => {\n   236→      if (a.priority !== b.priority) return a.priority - b.priority;\n   237→      if (a.availableAt.getTime() !== b.availableAt.getTime()) {\n   238→        return a.availableAt.getTime() - b.availableAt.getTime();\n   239→      }\n   240→      return a.createdAt.getTime() - b.createdAt.getTime();\n   241→    });\n   242→\n   243→    const task = candidates[0];\n   244→    task.status = 'processing';\n   245→    task.attempt++;\n   246→\n   247→    // Track concurrency\n   248→    const state = this.getQueueState(name);\n   249→    state.activeCount++;\n   250→\n   251→    return task;\n   252→  }\n   253→\n   254→  size(queueName?: string): number {\n   255→    const name = queueName ?? TaskQueue.DEFAULT_QUEUE;\n   256→    let count = 0;\n   257→    for (const task of this.tasks.values()) {\n   258→      if (task.queue === name && task.status === 'pending') {\n   259→        count++;\n   260→      }\n   261→    }\n   262→    return count;\n   263→  }\n   264→\n   265→  // ── Phase 2: Named Queues ────────────────────────────────────────────\n   266→\n   267→  getQueues(): string[] {\n   268→    return Array.from(this.queues.keys());\n   269→  }\n   270→\n   271→  // ── Phase 5: Retry with Backoff ──────────────────────────────────────\n   272→\n   273→  complete(taskId: string): void {\n   274→    const task = this.tasks.get(taskId);\n   275→    if (!task) {\n   276→      throw new Error(`Task not found: ${taskId}`);\n   277→    }\n   278→    if (task.status !== 'processing') {\n   279→      throw new Error(`Task ${taskId} is not in processing state (current: ${task.status})`);\n   280→    }\n   281→\n   282→    task.status = 'completed';\n   283→    task.progress = 100;\n   284→\n   285→    // Free concurrency slot\n   286→    const qs = this.getQueueState(task.queue);\n   287→    qs.activeCount = Math.max(0, qs.activeCount - 1);\n   288→\n   289→    // Check if any dependent tasks are now unblocked (Phase 7) - just updating status is enough,\n   290→    // dequeue will check dependencies dynamically\n   291→  }\n   292→\n   293→  fail(taskId: string, error?: string): void {\n   294→    const task = this.tasks.get(taskId);\n   295→    if (!task) {\n   296→      throw new Error(`Task not found: ${taskId}`);\n   297→    }\n   298→    if (task.status !== 'processing') {\n   299→      throw new Error(`Task ${taskId} is not in processing state (current: ${task.status})`);\n   300→    }\n   301→\n   302→    task.error = error;\n   303→    task.failCount++;\n   304→\n   305→    // Free concurrency slot\n   306→    const qs = this.getQueueState(task.queue);\n   307→    qs.activeCount = Math.max(0, qs.activeCount - 1);\n   308→\n   309→    if (task.attempt < task.maxRetries) {\n   310→      // Retry with backoff\n   311→      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);\n   312→      task.status = 'pending'