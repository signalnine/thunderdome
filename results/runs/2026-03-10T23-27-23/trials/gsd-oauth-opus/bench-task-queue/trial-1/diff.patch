tered task not found: ${taskId}`);\n   326→  }\n   327→\n   328→  clearDeadLetters(queueName?: string): void {\n   329→    const name = queueName ?? TaskQueue.DEFAULT_QUEUE;\n   330→    this.dlq.set(name, []);\n   331→  }\n   332→\n   333→  // ── Phase 7: Task Dependencies ──────────────────────────────────────\n   334→\n   335→  getDependencyStatus(taskId: string): { taskId: string; status: TaskStatus; resolved: boolean }[] {\n   336→    const task = this.tasks.get(taskId);\n   337→    if (!task) {\n   338→      throw new Error(`Task not found: ${taskId}`);\n   339→    }\n   340→\n   341→    return task.dependencies.map(depId => {\n   342→      const dep = this.tasks.get(depId);\n   343→      if (!dep) {\n   344→        return { taskId: depId, status: 'failed' as TaskStatus, resolved: false };\n   345→      }\n   346→      return {\n   347→        taskId: depId,\n   348→        status: dep.status,\n   349→        resolved: dep.status === 'completed',\n   350→      };\n   351→    });\n   352→  }\n   353→\n   354→  // ── Phase 8: Concurrency Control ────────────────────────────────────\n   355→\n   356→  setConcurrency(queueName: string, limit: number): void {\n   357→    const qs = this.getQueueState(queueName);\n   358→    qs.concurrencyLimit = limit;\n   359→  }\n   360→\n   361→  getConcurrency(queueName?: string): { limit: number; active: number } {\n   362→    const name = queueName ?? TaskQueue.DEFAULT_QUEUE;\n   363→    const qs = this.getQueueState(name);\n   364→    return { limit: qs.concurrencyLimit, active: qs.activeCount };\n   365→  }\n   366→\n   367→  // ── Phase 9: Progress Tracking and Cancellation ─────────────────────\n   368→\n   369→  updateProgress(taskId: string, progress: number, message?: string): void {\n   370→    const task = this.tasks.get(taskId);\n   371→    if (!task) {\n   372→      throw new Error(`Task not found: ${taskId}`);\n   373→    }\n   374→    if (task.status !== 'processing') {\n   375→      throw new Error(`Task ${taskId