 0) {\n      availableAt = new Date(Date.now() + options.delay);\n    }\n\n    // Validate dependencies (Phase 7)\n    const dependencies = options.dependencies ?? [];\n    for (const depId of dependencies) {\n      if (!this.tasks.has(depId)) {\n        throw new Error(`Dependency task not found: ${depId}`);\n      }\n    }\n    // Circular dependency detection\n    if (dependencies.length > 0) {\n      const taskId = randomUUID();\n      // Check if adding this task with these dependencies would create a cycle\n      // We need to check: for each dep, can dep reach taskId through the dependency graph?\n      // Since taskId is new and not yet a dependency of anything, no cycle can form\n      // UNLESS we have a dependency chain that circles back.\n      // Actually, since this is a new task, it can't be depended on by existing tasks yet.\n      // But we need to check for cycles among the dependencies themselves.\n      // The real cycle check: if task A depends on B, and B depends on A.\n      // Since this task is new, no existing task can depend on it.\n      // So no cycle is possible at creation time... unless we have self-dependency.\n\n      // Check self-dependency\n      // Actually, the new task ID is generated here, so no existing task can reference it.\n      // Cycles can only happen if dependencies form a cycle among themselves,\n      // but that should have been caught when those tasks were created.\n      // Let's still do a proper check for correctness.\n\n      const task: Task<T> = {\n        id: taskId,\n        payload,\n        status: 'pending',\n        createdAt: new Date(),\n        priority,\n        queue: queueName,\n        availableAt,\n        attempt: 0,\n        maxRetries: options.maxRetries ?? 3,\n        backoffDelay: options.backoffDelay ?? 1000,\n        failCount: 0,\n        dependencies: [...dependencies],\n        progress: 0,\n        metadata: {},\n      };\n\n      this.ensureQueueExists(queueName);\n      this.tasks