ependencyStatus(taskId: string): { taskId: string; status: TaskStatus; resolved: boolean }[] {\n   372→    const task = this.tasks.get(taskId);\n   373→    if (!task) {\n   374→      throw new Error(`Task not found: ${taskId}`);\n   375→    }\n   376→\n   377→    return task.dependencies.map(depId => {\n   378→      const dep = this.tasks.get(depId);\n   379→      if (!dep) {\n   380→        return { taskId: depId, status: 'failed' as TaskStatus, resolved: false };\n   381→      }\n   382→      return {\n   383→        taskId: depId,\n   384→        status: dep.status,\n   385→        resolved: dep.status === 'completed',\n   386→      };\n   387→    });\n   388→  }\n   389→\n   390→  // ── Phase 8: Concurrency Control ────────────────────────────────────\n   391→\n   392→  setConcurrency(queueName: string, limit: number): void {\n   393→    const qs = this.getQueueState(queueName);\n   394→    qs.concurrencyLimit = limit;\n   395→  }\n   396→\n   397→  getConcurrency(queueName?: string): { limit: number; active: number } {\n   398→    const name = queueName ?? TaskQueue.DEFAULT_QUEUE;\n   399→    const qs = this.getQueueState(name);\n   400→    return { limit: qs.concurrencyLimit, active: qs.activeCount };\n   401→  }\n   402→\n   403→  // ── Phase 9: Progress Tracking and Cancellation ─────────────────────\n   404→\n   405→  updateProgress(taskId: string, progress: number, message?: string): void {\n   406→    const task = this.tasks.get(taskId);\n   407→    if (!task) {\n   408→      throw new Error(`Task not found: ${taskId}`);\n   409→    }\n   410→    if (task.status !== 'processing') {\n   411→      throw new Error(`Task ${taskId} is not in processing state`);\n   412→    }\n   413→\n   414→    task.progress = Math.min(100, Math.max(0, progress));\n   415→    task.progressMessage = message;\n   416→\n   417→    // Notify listeners\n   418→    const listeners = this.progressListeners.get(taskId);\n   419→    if (listeners) {\n   420→      for (const listener of listeners) {\n   421→        listener(task.progress, message);\n   422→      }\n   423→    }\n   424→  }\n   425→\n   426→  getProgress(taskId: string): { progress: number; message?: string } {\n   427→    const task = this.tasks.get(taskId);\n   428→    if (!task) {\n   429→      throw new Error(`Task not found: ${taskId}`);\n   430→    }\n   431→    return { progress: task.progress, message: task.progressMessage };\n   432→  }\n   433→\n   434→  onProgress(taskId: string, listener: ProgressListener): () => void {\n   435→    let listeners = this.progressListeners.get(taskId);\n   436→    if (!listeners) {\n   437→      listeners = new Set();\n   438→      this.progressListeners.set(taskId, listeners);\n   439→    }\n   440→    listeners.add(listener);\n   441→\n   442→    // Return unsubscribe function\n   443→    return () => {\n   444→      listeners!.delete(listener);\n   445→      if (listeners!.size === 0) {\n   446→        this.progressListeners.delete(taskId);\n   447→      }\n   448→    };\n   449→  }\n   450→\n   451→  cancel(taskId: string): void {\n   452→    const task = this.tasks.get(taskId);\n   453→    if (!task) {\n   454→      throw new Error(`Task not found: ${taskId}`);\n   455→    }\n   456→    if (task.status !== 'pending' && task.status !== 'processing') {\n   457→      throw new Error(`Task ${taskId} cannot be cancelled (current: ${task.status})`);\n   458→    }\n   459→\n   460→    const wasPending = task.status === 'pending';\n   461→    task.status = 'cancelled';\n   462→\n   463→    // Free concurrency slot if was processing\n   464→    if (!wasPending) {\n   465→      const qs = this.getQueueState(task.queue);\n   466→      qs.activeCount = Math.max(0, qs.activeCount - 1);\n   467→    }\n   468→  }\n   469→\n   470→  // ── Phase 10: Recurring Tasks (Cron) ────────────────────────────────\n   471→\n   472→  addSchedule(cron: string, payload: unknown, options: ScheduleOptions = {}): Schedule {\n   473→    if (this.isShutdown) {\n   474→      throw new Error('Queue is shut down. Cannot add schedules.');\n   475→    }\n   476→\n   477→    const schedule: Schedule = {\n   478→      id: options.id ?? randomUUID(),\n   479→      cron,\n   480→      payload,\n   481→      queue: options.queue ?? TaskQueue.DEFAULT_QUEUE,\n   482→      options,\n   483→      lastRun: null,\n   484→      createdAt: new Date(),\n   485→    };\n   486→\n   487→    this.schedules.set(schedule.id, schedule);\n   488→    return schedule;\n   489→  }\n   490→\n   491→  removeSchedule(scheduleId: string): void {\n   492→    if (!this.schedules.has(scheduleId)) {\n   493→      throw new Error(`Schedule not found: ${scheduleId}`);\n   494→    }\n   495→    this.schedules.delete(scheduleId);\n   496→  }\n   497→\n   498→  getSchedules(): Schedule[] {\n   499→    return Array.from(this.schedules.values());\n   500→  }\n   501→\n   502→  tick(now?: Date): Task[] {\n   503→    const currentTime = now ?? new Date();\n   504→    const enqueued: Task[] = [];\n   505→\n   506→    for (const schedule of this.schedules.values()) {\n   507→      if (this.shouldRunSchedule(schedule, currentTime)) {\n   508→        const task = this.enqueue(schedule.payload, {\n   509→          queue: schedule.queue,\n   510→          priority: schedule.options.priority,\n   511→          maxRetries: schedule.options.maxRetries,\n   512→          backoffDelay: schedule.options.backoffDelay,\n   513→        });\n   514→        enqueued.push(task);\n   515→        schedule.lastRun = currentTime;\n   516→      }\n   517→    }\n   518→\n   519→    return enqueued;\n   520→  }\n   521→\n   522→  private shouldRunSchedule(schedule: Schedule, now: Date): boolean {\n   523→    const { cron, lastRun } = schedule;\n   524→    const parts = cron.split(/\\s+/);\n   525→    if (parts.length !== 5) return false;\n   526→\n   527→    const [minutePart, hourPart, dayOfMonthPart, monthPart, dayOfWeekPart] = parts;\n   528→\n   529→    const currentMinute = now.getMinutes();\n 