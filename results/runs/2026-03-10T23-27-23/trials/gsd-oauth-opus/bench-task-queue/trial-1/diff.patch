 queue?: string;\n  priority?: number;\n  maxRetries?: number;\n  backoffDelay?: number;\n}\n\nexport interface Schedule {\n  id: string;\n  cron: string;\n  payload: unknown;\n  queue: string;\n  options: ScheduleOptions;\n  lastRun: Date | null;\n  createdAt: Date;\n}\n\nexport type MiddlewareFn = (task: Task, next: () => Promise<void>) => Promise<void> | void;\nexport type ProcessorFn = (task: Task) => Promise<void> | void;\nexport type ProgressListener = (progress: number, message?: string) => void;\nexport type ShutdownCallback = () => Promise<void> | void;\n\nexport interface ShutdownSummary {\n  completed: number;\n  forceCancelled: number;\n  duration: number;\n}\n\ninterface QueueState {\n  concurrencyLimit: number;\n  activeCount: number;\n  middleware: MiddlewareFn[];\n  processor: ProcessorFn | null;\n}\n\n// ── TaskQueue ──────────────────────────────────────────────────────────\n\nexport class TaskQueue {\n  private tasks: Map<string, Task> = new Map();\n  private queues: Map<string, QueueState> = new Map();\n  private dlq: Map<string, Task[]> = new Map();\n  private schedules: Map<string, Schedule> = new Map();\n  private progressListeners: Map<string, Set<ProgressListener>> = new Map();\n  private shutdownCallbacks: ShutdownCallback[] = [];\n  private isShutdown = false;\n  private shutdownPromise: Promise<ShutdownSummary> | null = null;\n\n  private static readonly DEFAULT_QUEUE = 'default';\n\n  // ── Helpers ──────────────────────────────────────────────────────────\n\n  private getQueueState(name: string): QueueState {\n    let qs = this.queues.get(name);\n    if (!qs) {\n      qs = {\n        concurrencyLimit: 0,  // 0 means unlimited\n        activeCount: 0,\n        middleware: [],\n        processor: null,\n      };\n      this.queues.set(name, qs);\n    }\n    return qs;\n  }\n\n  private ensureQueueExists(name: string): void {\n    if (!this.queues.has(name)) {\n      this.getQueueState(name);\n    }\n  }\n\n  // ── Phase 1: Basic FIFO Queue ────────────────────────────────────────\n\n  enqueue<T = unknown>(payload: T, options: TaskOptions = {}): Task<T> {\n    if (this.isShutdown) {\n      throw new Error('Queue is shut down. Cannot add new tasks.');\n    }\n\n    const queueName = options.queue ?? TaskQueue.DEFAULT_QUEUE;\n\n    // Validate priority (Phase 3)\n    const priority = options.priority ?? 5;\n    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    }\n\n    // Compute availableAt (Phase 4)\n    let availableAt = new Date();\n    if (options.runAt) {\n      availableAt = options.runAt;\n    } else if (options.delay != null && options.delay > 0) {\n      availableAt = new Date(Date.now() + options.delay);\n    }\n\n    // Validate dependencies (Phase 7)\n    const dependencies = options.dependencies ?? [];\n    for (const depId of dependencies) {\n      if (!this.tasks.has(depId)) {\n        throw new Error(`Dependency task not found: ${depId}`);\n      }\n    }\n\n    const task: Task<T> = {\n      id: randomUUID(),\n      payload,\n      status: 'pending',\n      createdAt: new Date(),\n      priority,\n      queue: queueName,\n      availableAt,\n      attempt: 0,\n      maxRetries: options.maxRetries ?? 3,\n      backoffDelay: options.backoffDelay ?? 1000,\n      failCount: 0,\n      dependencies: [...dependencies],\n      progress: 0,\n      metadata: {},\n    };\n\n    this.ensureQueueExists(queueName);\n    this.tasks.set(task.id, task);\n    return task;\n  }\n\n  dequeue(queueName?: string): Task | null {\n    const name = queueName ?? TaskQueue.DEFAULT_QUEUE;\n    const qs = this.queues.get(name);\n\n    // Check concurrency limit (Phase 8)\n    if (qs && qs.concurrencyLimit > 0 && qs.activeCount >= qs.concurrencyLimit) {\n      return null;\n    }\n\n    const now = Date.now();\n\n    // Get all pending tasks for this queue that are available\n    const candidates: Task[] = [];\n    for (const task of this.tasks.values()) {\n      if (task.queue !== name || task.status !== 'pending') continue;\n\n      // Check availability (Phase 4)\n      if (task.availableAt.getTime() > now) continue;\n\n      // Check dependencies (Phase 7)\n      if (task.dependencies.length > 0) {\n        const allResolved = task.dependencies.every(depId => {\n          const dep = this.tasks.get(depId);\n          return dep && dep.status === 'completed';\n        });\n        if (!allResolved) continue;\n      }\n\n      candidates.push(task);\n    }\n\n    if (candidates.length === 0) return null;\n\n    // Sort by priority (ascending = higher priority first), then by availableAt, then FIFO (createdAt)\n    candidates.sort((a, b) => {\n      if (a.priority !== b.priority) return a.priority - b.priority;\n      if (a.availableAt.getTime() !== b.availableAt.getTime()) {\n        return a.availableAt.getTime() - b.availableAt.getTime();\n      }\n      return a.createdAt.getTime() - b.createdAt.getTime();\n    });\n\n    const task = candidates[0];\n    task.status = 'processing';\n    task.attempt++;\n\n    // Track concurrency\n    const state = this.getQueueState(name);\n    state.activeCount++;\n\n    return task;\n  }\n\n  size(queueName?: string): number {\n    const name = queueName ?? TaskQueue.DEFAULT_QUEUE;\n    let count = 0;\n    for (const task of this.tasks.values()) {\n      if (task.queue === name && task.status === 'pending') {\n        count++;\n      }\n    }\n    return count;\n  }\n\n  // ── Phase 2: Named Queues ────────────────────────────────────────────\n\n  getQueues(): string[] {\n    return Array.from(this.queues.keys());\n  }\n\n  // ── Phase 5: Retry with Backoff ──────────────────────────────────────\n\n  complete(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${taskId} is not in processing state (current: ${task.status})`);\n    }\n\n    task.status = 'completed';\n    task.progress = 100;\n\n    // Free concurrency slot\n    const qs = this.getQueueState(task.queue);\n    qs.activeCount = Math.max(0, qs.activeCount - 1);\n\n    // Check if any dependent tasks are now unblocked (Phase 7) - just updating status is enough,\n    // dequeue will check dependencies dynamically\n  }\n\n  fail(taskId: string, error?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${taskId} is not in processing state (current: ${task.status})`);\n    }\n\n    task.error = error;\n    task.failCount++;\n\n    // Free concurrency slot\n    const qs = this.getQueueState(task.queue);\n    qs.activeCount = Math.max(0, qs.activeCount - 1);\n\n    // attempt tracks how many times the task has been tried (incremented on dequeue)\n    // maxRetries is the number of *retries* allowed (re-attempts after a failure)\n    // So total allowed attempts = 1 (initial) + maxRetries\n    if (task.attempt <= task.maxRetries) {\n      // Retry with backoff\n      const retryNumber = task.attempt; // this is the Nth retry (1-based)\n      const delay = task.backoffDelay * Math.pow(2, retryNumber - 1);\n      task.status = 'pending';\n      task.availableAt = new Date(Date.now() + delay);\n    } else {\n      // No retries left\n      task.status = 'failed';\n\n      // Move to DLQ (Phase 6)\n      this.addToDlq(task);\n    }\n  }\n\n  // ── Phase 6: Dead Letter Queue ───────────────────────────────────────\n\n  private addToDlq(task: Task): void {\n    const queueDlq = this.dlq.get(task.queue);\n    if (queueDlq) {\n      queueDlq.push(task);\n    } else {\n      this.dlq.set(task.queue, [task]);\n    }\n  }\n\n  getDeadLetters(queueName?: string): Task[] {\n    const name = queueName ?? TaskQueue.DEFAULT_QUEUE;\n    return [...(this.dlq.get(name) ?? [])];\n  }\n\n  retryDeadLetter(taskId: string): Task {\n    // Find the task in any DLQ\n    for (const [queueName, dlqTasks] of this.dlq.entries()) {\n      const idx = dlqTasks.findIndex(t => t.id === taskId);\n      if (idx !== -1) {\n        const task = dlqTasks[idx];\n        dlqTasks.splice(idx, 1);\n\n        // Reset for fresh retries\n        task.status = 'pending';\n        task.attempt = 0;\n        task.failCount = 0;\n        task.error = undefined;\n        task.availableAt = new Date();\n        task.progress = 0;\n\n        // Make sure queue exists\n        this.ensureQueueExists(queueName);\n\n        return task;\n      }\n    }\n    throw new Error(`Dead-lettered task not found: ${taskId}`);\n  }\n\n  clearDeadLetters(queueName?: string): void {\n    const name = queueName ?? TaskQueue.DEFAULT_QUEUE;\n    this.dlq.set(name, []);\n  }\n\n  // ── Phase 7: Task Dependencies ──────────────────────────────────────\n\n  getDependencyStatus(taskId: string): { taskId: string; status: TaskStatus; resolved: boolean }[] {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n\n    return task.dependencies.map(depId => {\n      const dep = this.tasks.get(depId);\n      if (!dep) {\n        return { taskId: depId, status: 'failed' as TaskStatus, resolved: false };\n      }\n      return {\n        taskId: depId,\n        status: dep.status,\n        resolved: dep.status === 'completed',\n      };\n    });\n  }\n\n  // ── Phase 8: Concurrency Control ────────────────────────────────────\n\n  setConcurrency(queueName: string, limit: number): void {\n    const qs = this.getQueueState(queueName);\n    qs.concurrencyLimit = limit;\n  }\n\n  getConcurrency(queueName?: string): { limit: number; active: number } {\n    const name = queueName ?? TaskQueue.DEFAULT_QUEUE;\n    const qs = this.getQueueState(name);\n    return { limit: qs.concurrencyLimit, active: qs.activeCount };\n  }\n\n  // ── Phase 9: Progress Tracking and Cancellation ─────────────────────\n\n  updateProgress(taskId: string, progress: number, message?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${taskId} is not in processing state`);\n    }\n\n    task.progress = Math.min(100, Math.max(0, progress));\n    task.progressMessage = message;\n\n    // Notify listeners\n    const listeners = this.progressListeners.get(taskId);\n    if (listeners) {\n      for (const listener of listeners) {\n        listener(task.progress, message);\n      }\n    }\n  }\n\n  getProgress(taskId: string): { progress: number; message?: string } {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    return { progress: task.progress, message: task.progressMessage };\n  }\n\n  onProgress(taskId: string, listener: ProgressListener): () => void {\n    let listeners = this.progressListeners.get(taskId);\n    if (!listeners) {\n      listeners = new Set();\n      this.progressListeners.set(taskId, listeners);\n    }\n    listeners.add(listener);\n\n    // Return unsubscribe function\n    return () => {\n      listeners!.delete(listener);\n      if (listeners!.size === 0) {\n        this.progressListeners.delete(taskId);\n      }\n    };\n  }\n\n  cancel(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'pending' && task.status !== 'processing') {\n      throw new Error(`Task ${taskId} cannot be cancelled (current: ${task.status})`);\n    }\n\n    const wasPending = task.status === 'pending';\n    task.status = 'cancelled';\n\n    // Free concurrency slot if was processing\n    if (!wasPending) {\n      const qs = this.getQueueState(task.queue);\n      qs.activeCount = Math.max(0, qs.activeCount - 1);\n    }\n  }\n\n  // ── Phase 10: Recurring Tasks (Cron) ────────────────────────────────\n\n  addSchedule(cron: string, payload: unknown, options: ScheduleOptions = {}): Schedule {\n    if (this.isShutdown) {\n      throw new Error('Queue is shut down. Cannot add schedules.');\n    }\n\n    const schedule: Schedule = {\n      id: options.id ?? randomUUID(),\n      cron,\n      payload,\n      queue: options.queue ?? TaskQueue.DEFAULT_QUEUE,\n      options,\n      lastRun: null,\n      createdAt: new Date(),\n    };\n\n    this.schedules.set(schedule.id, schedule);\n    return schedule;\n  }\n\n  removeSchedule(scheduleId: string): void {\n    if (!this.schedules.has(scheduleId)) {\n      throw new Error(`Schedule not found: ${scheduleId}`);\n    }\n    this.schedules.delete(scheduleId);\n  }\n\n  getSchedules(): Schedule[] {\n    return Array.from(this.schedules.values());\n  }\n\n  tick(now?: Date): Task[] {\n    const currentTime = now ?? new Date();\n    const enqueued: Task[] = [];\n\n    for (const schedule of this.schedules.values()) {\n      if (this.shouldRunSchedule(schedule, currentTime)) {\n        const task = this.enqueue(schedule.payload, {\n          queue: schedule.queue,\n          priority: schedule.options.priority,\n          maxRetries: schedule.options.maxRetries,\n          backoffDelay: schedule.options.backoffDelay,\n        });\n        enqueued.push(task);\n        schedule.lastRun = currentTime;\n      }\n    }\n\n    return enqueued;\n  }\n\n  private shouldRunSchedule(schedule: Schedule, now: Date): boolean {\n    const { cron, lastRun } = schedule;\n    const parts = cron.split(/\\s+/);\n    if (parts.length !== 5) return false;\n\n    const [minutePart, hourPart, dayOfMonthPart, monthPart, dayOfWeekPart] = parts;\n\n    const currentMinute = now.getMinutes();\n    const currentHour = now.getHours();\n\n    // Check month\n    if (monthPart !== '*') return false;\n    // Check day of week\n    if (dayOfWeekPart !== '*') return false;\n    // Check day of month\n    if (dayOfMonthPart !== '*') {\n      if (parseInt(dayOfMonthPart) !== now.getDate()) return false;\n    }\n\n    // Check if cron matches current time\n    let minuteMatch = false;\n    let hourMatch = false;\n\n    // Parse minute\n    if (minutePart === '*') {\n      minuteMatch = true;\n    } else if (minutePart.startsWith('*/')) {\n      const interval = parseInt(minutePart.slice(2));\n      minuteMatch = currentMinute % interval === 0;\n    } else {\n      minuteMatch = parseInt(minutePart) === currentMinute;\n    }\n\n    // Parse hour\n    if (hourPart === '*') {\n      hourMatch = true;\n    } else if (hourPart.startsWith('*/')) {\n      const interval = parseInt(hourPart.slice(2));\n      hourMatch = currentHour % interval === 0;\n    } else {\n      hourMatch = parseInt(hourPart) === currentHour;\n    }\n\n    if (!minuteMatch || !hourMatch) return false;\n\n    // Check if we already ran this schedule at this time slot\n    if (lastRun) {\n      const lastRunMinute = lastRun.getMinutes();\n      const lastRunHour = lastRun.getHours();\n      const lastRunDate = lastRun.toDateString();\n      const nowDate = now.toDateString();\n\n      if (lastRunDate === nowDate && lastRunHour === currentHour && lastRunMinute === currentMinute) {\n        return false;\n      }\n    }\n\n    return true;\n  }\n\n  // ── Phase 11: Middleware Pipeline ────────────────────────────────────\n\n  use(queueName: string, middleware: MiddlewareFn): void {\n    const qs = this.getQueueState(queueName);\n    qs.middleware.push(middleware);\n  }\n\n  process(queueName: string, processor: ProcessorFn): void {\n    const qs = this.getQueueState(queueName);\n    qs.processor = processor;\n  }\n\n  async processNext(queueName?: string): Promise<Task | null> {\n    const name = queueName ?? TaskQueue.DEFAULT_QUEUE;\n    const task = this.dequeue(name);\n    if (!task) return null;\n\n    const qs = this.getQueueState(name);\n\n    try {\n      await this.runMiddlewarePipeline(task, qs.middleware, qs.processor);\n      if (task.status === 'processing') {\n        this.complete(task.id);\n      }\n    } catch (err) {\n      if (task.status === 'processing') {\n        this.fail(task.id, err instanceof Error ? err.message : String(err));\n      }\n    }\n\n    return task;\n  }\n\n  private async runMiddlewarePipeline(\n    task: Task,\n    middlewares: MiddlewareFn[],\n    processor: ProcessorFn | null,\n  ): Promise<void> {\n    let index = 0;\n\n    const next = async (): Promise<void> => {\n      if (index < middlewares.length) {\n        const mw = middlewares[index++];\n        await mw(task, next);\n      } else if (processor) {\n        await processor(task);\n      }\n    };\n\n    await next();\n  }\n\n  // ── Phase 12: Graceful Shutdown ──────────────────────────────────────\n\n  onShutdown(callback: ShutdownCallback): void {\n    this.shutdownCallbacks.push(callback);\n  }\n\n  async shutdown(timeout: number = 30000): Promise<ShutdownSummary> {\n    if (this.shutdownPromise) {\n      return this.shutdownPromise;\n    }\n\n    this.isShutdown = true;\n    this.shutdownPromise = this.performShutdown(timeout);\n    return this.shutdownPromise;\n  }\n\n  private async performShutdown(timeout: number): Promise<ShutdownSummary> {\n    const startTime = Date.now();\n\n    // Run shutdown callbacks\n    for (const cb of this.shutdownCallbacks) {\n      await cb();\n    }\n\n    // Find all processing tasks\n    const processingTasks: Task[] = [];\n    for (const task of this.tasks.values()) {\n      if (task.status === 'processing') {\n        processingTasks.push(task);\n      }\n    }\n\n    if (processingTasks.length === 0) {\n      return {\n        completed: 0,\n        forceCancelled: 0,\n        duration: Date.now() - startTime,\n      };\n    }\n\n    // Wait for processing tasks to complete (up to timeout)\n    let completed = 0;\n    let forceCancelled = 0;\n\n    await Promise.race([\n      this.waitForProcessingTasks(processingTasks),\n      new Promise<'timeout'>(resolve => setTimeout(() => resolve('timeout'), timeout)),\n    ]);\n\n    // Count completed tasks\n    for (const task of processingTasks) {\n      if (task.status === 'completed' || task.status === 'failed') {\n        completed++;\n      } else if (task.status === 'processing') {\n        // Force cancel\n        task.status = 'cancelled';\n        const qs = this.getQueueState(task.queue);\n        qs.activeCount = Math.max(0, qs.activeCount - 1);\n        forceCancelled++;\n      }\n    }\n\n    return {\n      completed,\n      forceCancelled,\n      duration: Date.now() - startTime,\n    };\n  }\n\n  private async waitForProcessingTasks(tasks: Task[]): Promise<void> {\n    // Poll until all processing tasks are done\n    while (tasks.some(t => t.status === 'processing')) {\n      await new Promise(resolve => setTimeout(resolve, 10));\n    }\n  }\n\n  // ── Utility ─────────────────────────────────────────────────────────\n\n  getTask(taskId: string): Task | undefined {\n    return this.tasks.get(taskId);\n  }\n}\n","numLines":680,"startLine":1,"totalLines":680}}}
