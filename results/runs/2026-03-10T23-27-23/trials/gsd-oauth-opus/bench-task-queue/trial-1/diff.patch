dule, now: Date): boolean {\n   487→    const { cron, lastRun } = schedule;\n   488→    const parts = cron.split(/\\s+/);\n   489→    if (parts.length !== 5) return false;\n   490→\n   491→    const [minutePart, hourPart, dayOfMonthPart, monthPart, dayOfWeekPart] = parts;\n   492→\n   493→    const currentMinute = now.getMinutes();\n   494→    const currentHour = now.getHours();\n   495→\n   496→    // Check month\n   497→    if (monthPart !== '*') return false;\n   498→    // Check day of week\n   499→    if (dayOfWeekPart !== '*') return false;\n   500→    // Check day of month\n   501→    if (dayOfMonthPart !== '*') {\n   502→      if (parseInt(dayOfMonthPart) !== now.getDate()) return false;\n   503→    }\n   504→\n   505→    // Check if cron matches current time\n   506→    let minuteMatch = false;\n   507→    let hourMatch = false;\n   508→\n   509→    // Parse minute\n   510→    if (minutePart === '*') {\n   511→      minuteMatch = true;\n   512→    } else if (minutePart.startsWith('*/')) {\n   513→      const interval = parseInt(minutePart.slice(2));\n   514→      minuteMatch = currentMinute % interval === 0;\n   515→    } else {\n   516→      minuteMatch = parseInt(minutePart) === currentMinute;\n   517→    }\n   518→\n   519→    // Parse hour\n   520→    if (hourPart === '*') {\n   521→      hourMatch = true;\n   522→    } else if (hourPart.startsWith('*/')) {\n   523→      const interval = parseInt(hourPart.slice(2));\n   524→      hourMatch = currentHour % interval === 0;\n   525→    } else {\n   526→      hourMatch = parseInt(hourPart) === currentHour;\n   527→    }\n   528→\n   529→    if (!minuteMatch || !hourMatch) return false;\n   530→\n   531→    // Check if we already ran this schedule at this time slot\n   532→    if (lastRun) {\n   533→      const lastRunMinute = lastRun.getMinutes();\n   534→      const lastRunHour = lastRun.getHours();\n   535→      const lastRunDate = lastRun.toDateString();\n   536→      const nowDate = now.toDateString();\