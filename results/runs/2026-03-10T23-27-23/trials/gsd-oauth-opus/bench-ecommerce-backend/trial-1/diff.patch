edEvent;\n    const userId = orderUserMap.get(event.orderId);\n    if (userId) {\n      addNotification(userId, 'payment', `Payment for order ${event.orderId}: ${event.status}`);\n    }\n  });\n\n  return {\n    subscribe(userId: string): void {\n      subscribers.add(userId);\n    },\n\n    getNotifications(userId: string): Array<{ type: string; message: string; timestamp: number }> {\n      return (notifications.get(userId) ?? []).map(n => ({ ...n }));\n    },\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":418,"cache_read_input_tokens":22751,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":418},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"f85ffdd7-4bc1-462a-94c4-aaf618e86282","uuid":"f857aa51-7c60-4dbe-af2b-061bd41a6ed8"}
