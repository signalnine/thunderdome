+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_015nd6pKkUkE9ANqUmhqdQSR","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_019iMkk94ETtM76MeucYosCR","name":"Write","input":{"file_path":"/workspace/tests/services.test.ts","content":"import { describe, it, expect, beforeEach } from 'vitest';\nimport { EventBus } from '../src/bus.js';\nimport { Events, OrderStatus, PaymentStatus } from '../src/types.js';\nimport { createCatalogService } from '../src/catalog/index.js';\nimport { createInventoryService } from '../src/inventory/index.js';\nimport { createCartService } from '../src/cart/index.js';\nimport { createPricingService } from '../src/pricing/index.js';\nimport { createOrderService } from '../src/orders/index.js';\nimport { createPaymentService } from '../src/payment/index.js';\nimport { createNotificationService } from '../src/notifications/index.js';\nimport { createAnalyticsService } from '../src/analytics/index.js';\n\ndescribe('CatalogService', () => {\n  let bus: EventBus;\n  let catalog: ReturnType<typeof createCatalogService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    catalog = createCatalogService(bus);\n  });\n\n  it('creates a product and returns an id', () => {\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    expect(id).toBeTruthy();\n  });\n\n  it('retrieves a product by id', () => {\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    const product = catalog.getProduct(id);\n    expect(product).toEqual({ id, name: 'Widget', price: 9.99, category: 'gadgets' });\n  });\n\n  it('returns null for unknown product', () => {\n    expect(catalog.getProduct('no-such-id')).toBeNull();\n  });\n\n  it('lists all products', () => {\n    catalog.createProduct('A', 1, 'cat1');\n    catalog.createProduct('B', 2, 'cat2');\n    expect(catalog.listProducts()).toHaveLength(2);\n  });\n\n  it('lists products by category', () => {\n    catalog.createProduct('A', 1, 'cat1');\n    catalog.createProduct('B', 2, 'cat2');\n    catalog.createProduct('C', 3, 'cat1');\n    expect(catalog.listProducts('cat1')).toHaveLength(2);\n  });\n\n  it('searches products by name', () => {\n    catalog.createProduct('Blue Widget', 1, 'gadgets');\n    catalog.createProduct('Red Gizmo', 2, 'gadgets');\n    const results = catalog.searchProducts('widget');\n    expect(results).toHaveLength(1);\n    expect(results[0].name).toBe('Blue Widget');\n  });\n\n  it('searches products by category', () => {\n    catalog.createProduct('A', 1, 'electronics');\n    catalog.createProduct('B', 2, 'books');\n    const results = catalog.searchProducts('electron');\n    expect(results).toHaveLength(1);\n  });\n\n  it('updates a product', () => {\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    catalog.updateProduct(id, { price: 14.99, name: 'Super Widget' });\n    const product = catalog.getProduct(id);\n    expect(product!.price).toBe(14.99);\n    expect(product!.name).toBe('Super Widget');\n  });\n\n  it('removes a product', () => {\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    expect(catalog.removeProduct(id)).toBe(true);\n    expect(catalog.getProduct(id)).toBeNull();\n    expect(catalog.removeProduct('nonexistent')).toBe(false);\n  });\n\n  it('emits product:created event', async () => {\n    catalog.createProduct('Widget', 9.99, 'gadgets');\n    const log = bus.getLog();\n    const productEvents = log.filter(e => e.event === Events.PRODUCT_CREATED);\n    expect(productEvents).toHaveLength(1);\n  });\n});\n\ndescribe('InventoryService', () => {\n  let bus: EventBus;\n  let inventory: ReturnType<typeof createInventoryService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    inventory = createInventoryService(bus);\n  });\n\n  it('sets and gets stock', () => {\n    inventory.setStock('p1', 100);\n    expect(inventory.getStock('p1')).toBe(100);\n  });\n\n  it('returns 0 for unknown product', () => {\n    expect(inventory.getStock('unknown')).toBe(0);\n  });\n\n  it('reserves stock successfully', () => {\n    inventory.setStock('p1', 10);\n    expect(inventory.reserve('p1', 5)).toBe(true);\n    expect(inventory.getStock('p1')).toBe(5);\n  });\n\n  it('fails to reserve more than available', () => {\n    inventory.setStock('p1', 3);\n    expect(inventory.reserve('p1', 5)).toBe(false);\n  });\n\n  it('releases reserved stock', () => {\n    inventory.setStock('p1', 10);\n    inventory.reserve('p1', 5);\n    inventory.release('p1', 3);\n    expect(inventory.getStock('p1')).toBe(8);\n  });\n\n  it('detects low stock', async () => {\n    let alertFired = false;\n    bus.on(Events.LOW_STOCK_ALERT, () => { alertFired = true; });\n    inventory.setLowStockThreshold('p1', 5);\n    inventory.setStock('p1', 3);\n    // Need to wait for async emit\n    await new Promise(r => setTimeout(r, 10));\n    expect(alertFired).toBe(true);\n  });\n});\n\ndescribe('CartService', () => {\n  let bus: EventBus;\n  let cart: ReturnType<typeof createCartService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    cart = createCartService(bus);\n  });\n\n  it('creates a cart', () => {\n    const id = cart.createCart('user1');\n    expect(id).toBeTruthy();\n    const c = cart.getCart(id);\n    expect(c).not.toBeNull();\n    expect(c!.userId).toBe('user1');\n    expect(c!.items).toEqual([]);\n  });\n\n  it('adds items to cart', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    const c = cart.getCart(id)!;\n    expect(c.items).toHaveLength(1);\n    expect(c.items[0]).toEqual({ productId: 'p1', quantity: 2 });\n  });\n\n  it('consolidates same product', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p1', 3);\n    const c = cart.getCart(id)!;\n    expect(c.items).toHaveLength(1);\n    expect(c.items[0].quantity).toBe(5);\n  });\n\n  it('removes items from cart', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p2', 1);\n    cart.removeItem(id, 'p1');\n    const c = cart.getCart(id)!;\n    expect(c.items).toHaveLength(1);\n    expect(c.items[0].productId).toBe('p2');\n  });\n\n  it('clears a cart', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.clearCart(id);\n    const c = cart.getCart(id)!;\n    expect(c.items).toEqual([]);\n  });\n\n  it('updates quantity', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.updateQuantity(id, 'p1', 10);\n    const c = cart.getCart(id)!;\n    expect(c.items[0].quantity).toBe(10);\n  });\n\n  it('returns null for unknown cart', () => {\n    expect(cart.getCart('unknown')).toBeNull();\n  });\n});\n\ndescribe('PricingService', () => {\n  let bus: EventBus;\n  let pricing: ReturnType<typeof createPricingService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    pricing = createPricingService(bus);\n  });\n\n  it('calculates total with tax', () => {\n    const result = pricing.calculateTotal([\n      { productId: 'p1', quantity: 2, price: 10 },\n    ]);\n    expect(result.subtotal).toBe(20);\n    expect(result.discount).toBe(0);\n    expect(result.tax).toBe(2);\n    expect(result.total).toBe(22);\n  });\n\n  it('applies discount code before tax', () => {\n    pricing.addDiscountCode('SAVE10', 10);\n    const result = pricing.calculateTotal([\n      { productId: 'p1', quantity: 1, price: 100 },\n    ], 'SAVE10');\n    expect(result.subtotal).toBe(100);\n    expect(result.discount).toBe(10);\n    expect(result.tax).toBe(9); // 90 * 0.10\n    expect(result.total).toBe(99);\n  });\n\n  it('tracks product prices from events', async () => {\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'W', price: 25, category: 'c' });\n    expect(pricing.getPrice('p1')).toBe(25);\n  });\n\n  it('returns 0 for unknown product price', () => {\n    expect(pricing.getPrice('unknown')).toBe(0);\n  });\n});\n\ndescribe('OrderService', () => {\n  let bus: EventBus;\n  let orders: ReturnType<typeof createOrderService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    orders = createOrderService(bus);\n  });\n\n  it('creates an order in pending state', () => {\n    const id = orders.createOrder('user1', 'cart1', 100);\n    const order = orders.getOrder(id);\n    expect(order).not.toBeNull();\n    expect(order!.status).toBe(OrderStatus.PENDING);\n    expect(order!.total).toBe(100);\n  });\n\n  it('updates order status', () => {\n    const id = orders.createOrder('user1', 'cart1', 100);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.CONFIRMED);\n  });\n\n  it('emits status changed event with previous status', async () => {\n    const id = orders.createOrder('user1', 'cart1', 100);\n    // Wait for async emit\n    await new Promise(r => setTimeout(r, 10));\n    orders.updateStatus(id, OrderStatus.SHIPPED);\n    await new Promise(r => setTimeout(r, 10));\n    const log = bus.getLog();\n    const statusEvents = log.filter(e => e.event === Events.ORDER_STATUS_CHANGED);\n    expect(statusEvents).toHaveLength(1);\n    const payload = statusEvents[0].payload as { previousStatus: string; status: string };\n    expect(payload.previousStatus).toBe(OrderStatus.PENDING);\n    expect(payload.status).toBe(OrderStatus.SHIPPED);\n  });\n\n  it('cancels an order', () => {\n    const id = orders.createOrder('user1', 'cart1', 100);\n    orders.updateStatus(id, OrderStatus.CANCELLED);\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.CANCELLED);\n  });\n\n  it('lists orders for a user', () => {\n    orders.createOrder('user1', 'cart1', 100);\n    orders.createOrder('user1', 'cart2', 200);\n    orders.createOrder('user2', 'cart3', 50);\n    expect(orders.listOrders('user1')).toHaveLength(2);\n    expect(orders.listOrders('user2')).toHaveLength(1);\n  });\n\n  it('returns null for unknown order', () => {\n    expect(orders.getOrder('unknown')).toBeNull();\n  });\n});\n\ndescribe('PaymentService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('processes a successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.SUCCESS);\n    expect(result.transactionId).toBeTruthy();\n  });\n\n  it('simulates payment failure', async () => {\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.FAILED);\n    expect(result.error).toBeTruthy();\n  });\n\n  it('simulates payment timeout', async () => {\n    const payment = createPaymentService(bus, { simulateTimeout: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.TIMEOUT);\n    expect(result.error).toBeTruthy();\n  });\n\n  it('refunds a successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    const refunded = await payment.refund(result.transactionId!);\n    expect(refunded).toBe(true);\n  });\n\n  it('fails to refund invalid transaction', async () => {\n    const payment = createPaymentService(bus);\n    const refunded = await payment.refund('bogus');\n    expect(refunded).toBe(false);\n  });\n\n  it('emits payment processed event', async () => {\n    const payment = createPaymentService(bus);\n    await payment.processPayment('order1', 100);\n    const log = bus.getLog();\n    const paymentEvents = log.filter(e => e.event === Events.PAYMENT_PROCESSED);\n    expect(paymentEvents).toHaveLength(1);\n  });\n});\n\ndescribe('NotificationService', () => {\n  let bus: EventBus;\n  let notifications: ReturnType<typeof createNotificationService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    notifications = createNotificationService(bus);\n  });\n\n  it('subscribes a user and receives order notifications', async () => {\n    notifications.subscribe('user1');\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThanOrEqual(1);\n    expect(notifs[0].type).toBe('order_created');\n  });\n\n  it('does not notify unsubscribed users', async () => {\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs).toHaveLength(0);\n  });\n\n  it('receives order status change notifications', async () => {\n    notifications.subscribe('user1');\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.ORDER_STATUS_CHANGED, { orderId: 'o1', status: 'shipped', previousStatus: 'pending' });\n    const notifs = notifications.getNotifications('user1');\n    const statusNotif = notifs.find(n => n.type === 'order_status');\n    expect(statusNotif).toBeTruthy();\n  });\n\n  it('receives payment notifications', async () => {\n    notifications.subscribe('user1');\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: 'success', transactionId: 'tx1' });\n    const notifs = notifications.getNotifications('user1');\n    const paymentNotif = notifs.find(n => n.type === 'payment');\n    expect(paymentNotif).toBeTruthy();\n  });\n});\n\ndescribe('AnalyticsService', () => {\n  let bus: EventBus;\n  let analytics: ReturnType<typeof createAnalyticsService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    analytics = createAnalyticsService(bus);\n  });\n\n  it('counts events', async () => {\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'A', price: 10, category: 'c' });\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p2', name: 'B', price: 20, category: 'c' });\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n  });\n\n  it('tracks revenue from successful payments', async () => {\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 'tx1' });\n    expect(analytics.getRevenue()).toBe(100);\n  });\n\n  it('does not count failed payment as revenue', async () => {\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.FAILED });\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  it('calculates conversion rate', async () => {\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [] });\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c2', userId: 'u2', items: [] });\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    expect(analytics.getConversionRate()).toBe(0.5); // 1 order / 2 carts\n  });\n\n  it('returns 0 conversion rate with no carts', () => {\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n\n  it('tracks top products', async () => {\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [{ productId: 'p1', quantity: 3 }, { productId: 'p2', quantity: 1 }] });\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    const top = analytics.getTopProducts(2);\n    expect(top).toHaveLength(2);\n    expect(top[0].productId).toBe('p1');\n    expect(top[0].count).toBe(3);\n    expect(top[1].productId).toBe('p2');\n    expect(top[1].count).toBe(1);\n  });\n});\n\ndescribe('Integration: full e-commerce flow', () => {\n  it('completes an end-to-end purchase flow', async () => {\n    const bus = new EventBus();\n\n    // Create all services\n    const catalog = createCatalogService(bus);\n    const inventory = createInventoryService(bus);\n    const cartService = createCartService(bus);\n    const pricing = createPricingService(bus);\n    const orderService = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    const notifications = createNotificationService(bus);\n    const analytics = createAnalyticsService(bus);\n\n    // Subscribe user to notifications\n    notifications.subscribe('user1');\n\n    // Create products\n    const productId = catalog.createProduct('Laptop', 999.99, 'electronics');\n    // Wait for async event processing\n    await new Promise(r => setTimeout(r, 10));\n\n    // Set inventory\n    inventory.setStock(productId, 50);\n    inventory.setLowStockThreshold(productId, 5);\n\n    // Create cart and add items\n    const cartId = cartService.createCart('user1');\n    cartService.addItem(cartId, productId, 2);\n\n    // Get prices\n    const price = pricing.getPrice(productId);\n    expect(price).toBe(999.99);\n\n    // Calculate total\n    const cart = cartService.getCart(cartId)!;\n    const items = cart.items.map(i => ({ ...i, price: pricing.getPrice(i.productId) }));\n    const totals = pricing.calculateTotal(items);\n    expect(totals.subtotal).toBe(1999.98);\n    expect(totals.tax).toBeCloseTo(199.998, 1);\n\n    // Reserve inventory\n    expect(inventory.reserve(productId, 2)).toBe(true);\n    expect(inventory.getStock(productId)).toBe(48);\n\n    // Create order\n    const orderId = orderService.createOrder('user1', cartId, totals.total);\n    await new Promise(r => setTimeout(r, 10));\n\n    // Process payment\n    const paymentResult = await payment.processPayment(orderId, totals.total);\n    expect(paymentResult.status).toBe(PaymentStatus.SUCCESS);\n\n    // Update order status\n    orderService.updateStatus(orderId, OrderStatus.CONFIRMED);\n    await new Promise(r => setTimeout(r, 10));\n\n    // Check notifications\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThanOrEqual(2); // order created + payment + status change\n\n    // Check analytics\n    expect(analytics.getRevenue()).toBe(totals.total);\n    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBe(1);\n    expect(analytics.getConversionRate()).toBe(1); // 1 order / 1 cart\n\n    const topProducts = analytics.getTopProducts(5);\n    expect(topProducts).toHaveLength(1);\n    expect(topProducts[0].productId).toBe(productId);\n    expect(topProducts[0].count).toBe(2);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":103,"cache_read_input_tokens":32684,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":103},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"f85ffdd7-4bc1-462a-94c4-aaf618e86282","uuid":"8da7fca4-2302-4471-9246-22f2d58a6eed"}
+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019iMkk94ETtM76MeucYosCR","type":"tool_result","content":"File created successfully at: /workspace/tests/services.test.ts"}]},"parent_tool_use_id":null,"session_id":"f85ffdd7-4bc1-462a-94c4-aaf618e86282","uuid":"9ce7a334-16af-48e9-8dd7-7b77f4b42ea8","tool_use_result":{"type":"create","filePath":"/workspace/tests/services.test.ts","content":"import { describe, it, expect, beforeEach } from 'vitest';\nimport { EventBus } from '../src/bus.js';\nimport { Events, OrderStatus, PaymentStatus } from '../src/types.js';\nimport { createCatalogService } from '../src/catalog/index.js';\nimport { createInventoryService } from '../src/inventory/index.js';\nimport { createCartService } from '../src/cart/index.js';\nimport { createPricingService } from '../src/pricing/index.js';\nimport { createOrderService } from '../src/orders/index.js';\nimport { createPaymentService } from '../src/payment/index.js';\nimport { createNotificationService } from '../src/notifications/index.js';\nimport { createAnalyticsService } from '../src/analytics/index.js';\n\ndescribe('CatalogService', () => {\n  let bus: EventBus;\n  let catalog: ReturnType<typeof createCatalogService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    catalog = createCatalogService(bus);\n  });\n\n  it('creates a product and returns an id', () => {\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    expect(id).toBeTruthy();\n  });\n\n  it('retrieves a product by id', () => {\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    const product = catalog.getProduct(id);\n    expect(product).toEqual({ id, name: 'Widget', price: 9.99, category: 'gadgets' });\n  });\n\n  it('returns null for unknown product', () => {\n    expect(catalog.getProduct('no-such-id')).toBeNull();\n  });\n\n  it('lists all products', () => {\n    catalog.createProduct('A', 1, 'cat1');\n    catalog.createProduct('B', 2, 'cat2');\n    expect(catalog.listProducts()).toHaveLength(2);\n  });\n\n  it('lists products by category', () => {\n    catalog.createProduct('A', 1, 'cat1');\n    catalog.createProduct('B', 2, 'cat2');\n    catalog.createProduct('C', 3, 'cat1');\n    expect(catalog.listProducts('cat1')).toHaveLength(2);\n  });\n\n  it('searches products by name', () => {\n    catalog.createProduct('Blue Widget', 1, 'gadgets');\n    catalog.createProduct('Red Gizmo', 2, 'gadgets');\n    const results = catalog.searchProducts('widget');\n    expect(results).toHaveLength(1);\n    expect(results[0].name).toBe('Blue Widget');\n  });\n\n  it('searches products by category', () => {\n    catalog.createProduct('A', 1, 'electronics');\n    catalog.createProduct('B', 2, 'books');\n    const results = catalog.searchProducts('electron');\n    expect(results).toHaveLength(1);\n  });\n\n  it('updates a product', () => {\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    catalog.updateProduct(id, { price: 14.99, name: 'Super Widget' });\n    const product = catalog.getProduct(id);\n    expect(product!.price).toBe(14.99);\n    expect(product!.name).toBe('Super Widget');\n  });\n\n  it('removes a product', () => {\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    expect(catalog.removeProduct(id)).toBe(true);\n    expect(catalog.getProduct(id)).toBeNull();\n    expect(catalog.removeProduct('nonexistent')).toBe(false);\n  });\n\n  it('emits product:created event', async () => {\n    catalog.createProduct('Widget', 9.99, 'gadgets');\n    const log = bus.getLog();\n    const productEvents = log.filter(e => e.event === Events.PRODUCT_CREATED);\n    expect(productEvents).toHaveLength(1);\n  });\n});\n\ndescribe('InventoryService', () => {\n  let bus: EventBus;\n  let inventory: ReturnType<typeof createInventoryService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    inventory = createInventoryService(bus);\n  });\n\n  it('sets and gets stock', () => {\n    inventory.setStock('p1', 100);\n    expect(inventory.getStock('p1')).toBe(100);\n  });\n\n  it('returns 0 for unknown product', () => {\n    expect(inventory.getStock('unknown')).toBe(0);\n  });\n\n  it('reserves stock successfully', () => {\n    inventory.setStock('p1', 10);\n    expect(inventory.reserve('p1', 5)).toBe(true);\n    expect(inventory.getStock('p1')).toBe(5);\n  });\n\n  it('fails to reserve more than available', () => {\n    inventory.setStock('p1', 3);\n    expect(inventory.reserve('p1', 5)).toBe(false);\n  });\n\n  it('releases reserved stock', () => {\n    inventory.setStock('p1', 10);\n    inventory.reserve('p1', 5);\n    inventory.release('p1', 3);\n    expect(inventory.getStock('p1')).toBe(8);\n  });\n\n  it('detects low stock', async () => {\n    let alertFired = false;\n    bus.on(Events.LOW_STOCK_ALERT, () => { alertFired = true; });\n    inventory.setLowStockThreshold('p1', 5);\n    inventory.setStock('p1', 3);\n    // Need to wait for async emit\n    await new Promise(r => setTimeout(r, 10));\n    expect(alertFired).toBe(true);\n  });\n});\n\ndescribe('CartService', () => {\n  let bus: EventBus;\n  let cart: ReturnType<typeof createCartService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    cart = createCartService(bus);\n  });\n\n  it('creates a cart', () => {\n    const id = cart.createCart('user1');\n    expect(id).toBeTruthy();\n    const c = cart.getCart(id);\n    expect(c).not.toBeNull();\n    expect(c!.userId).toBe('user1');\n    expect(c!.items).toEqual([]);\n  });\n\n  it('adds items to cart', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    const c = cart.getCart(id)!;\n    expect(c.items).toHaveLength(1);\n    expect(c.items[0]).toEqual({ productId: 'p1', quantity: 2 });\n  });\n\n  it('consolidates same product', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p1', 3);\n    const c = cart.getCart(id)!;\n    expect(c.items).toHaveLength(1);\n    expect(c.items[0].quantity).toBe(5);\n  });\n\n  it('removes items from cart', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p2', 1);\n    cart.removeItem(id, 'p1');\n    const c = cart.getCart(id)!;\n    expect(c.items).toHaveLength(1);\n    expect(c.items[0].productId).toBe('p2');\n  });\n\n  it('clears a cart', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.clearCart(id);\n    const c = cart.getCart(id)!;\n    expect(c.items).toEqual([]);\n  });\n\n  it('updates quantity', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.updateQuantity(id, 'p1', 10);\n    const c = cart.getCart(id)!;\n    expect(c.items[0].quantity).toBe(10);\n  });\n\n  it('returns null for unknown cart', () => {\n    expect(cart.getCart('unknown')).toBeNull();\n  });\n});\n\ndescribe('PricingService', () => {\n  let bus: EventBus;\n  let pricing: ReturnType<typeof createPricingService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    pricing = createPricingService(bus);\n  });\n\n  it('calculates total with tax', () => {\n    const result = pricing.calculateTotal([\n      { productId: 'p1', quantity: 2, price: 10 },\n    ]);\n    expect(result.subtotal).toBe(20);\n    expect(result.discount).toBe(0);\n    expect(result.tax).toBe(2);\n    expect(result.total).toBe(22);\n  });\n\n  it('applies discount code before tax', () => {\n    pricing.addDiscountCode('SAVE10', 10);\n    const result = pricing.calculateTotal([\n      { productId: 'p1', quantity: 1, price: 100 },\n    ], 'SAVE10');\n    expect(result.subtotal).toBe(100);\n    expect(result.discount).toBe(10);\n    expect(result.tax).toBe(9); // 90 * 0.10\n    expect(result.total).toBe(99);\n  });\n\n  it('tracks product prices from events', async () => {\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'W', price: 25, category: 'c' });\n    expect(pricing.getPrice('p1')).toBe(25);\n  });\n\n  it('returns 0 for unknown product price', () => {\n    expect(pricing.getPrice('unknown')).toBe(0);\n  });\n});\n\ndescribe('OrderService', () => {\n  let bus: EventBus;\n  let orders: ReturnType<typeof createOrderService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    orders = createOrderService(bus);\n  });\n\n  it('creates an order in pending state', () => {\n    const id = orders.createOrder('user1', 'cart1', 100);\n    const order = orders.getOrder(id);\n    expect(order).not.toBeNull();\n    expect(order!.status).toBe(OrderStatus.PENDING);\n    expect(order!.total).toBe(100);\n  });\n\n  it('updates order status', () => {\n    const id = orders.createOrder('user1', 'cart1', 100);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.CONFIRMED);\n  });\n\n  it('emits status changed event with previous status', async () => {\n    const id = orders.createOrder('user1', 'cart1', 100);\n    // Wait for async emit\n    await new Promise(r => setTimeout(r, 10));\n    orders.updateStatus(id, OrderStatus.SHIPPED);\n    await new Promise(r => setTimeout(r, 10));\n    const log = bus.getLog();\n    const statusEvents = log.filter(e => e.event === Events.ORDER_STATUS_CHANGED);\n    expect(statusEvents).toHaveLength(1);\n    const payload = statusEvents[0].payload as { previousStatus: string; status: string };\n    expect(payload.previousStatus).toBe(OrderStatus.PENDING);\n    expect(payload.status).toBe(OrderStatus.SHIPPED);\n  });\n\n  it('cancels an order', () => {\n    const id = orders.createOrder('user1', 'cart1', 100);\n    orders.updateStatus(id, OrderStatus.CANCELLED);\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.CANCELLED);\n  });\n\n  it('lists orders for a user', () => {\n    orders.createOrder('user1', 'cart1', 100);\n    orders.createOrder('user1', 'cart2', 200);\n    orders.createOrder('user2', 'cart3', 50);\n    expect(orders.listOrders('user1')).toHaveLength(2);\n    expect(orders.listOrders('user2')).toHaveLength(1);\n  });\n\n  it('returns null for unknown order', () => {\n    expect(orders.getOrder('unknown')).toBeNull();\n  });\n});\n\ndescribe('PaymentService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('processes a successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.SUCCESS);\n    expect(result.transactionId).toBeTruthy();\n  });\n\n  it('simulates payment failure', async () => {\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.FAILED);\n    expect(result.error).toBeTruthy();\n  });\n\n  it('simulates payment timeout', async () => {\n    const payment = createPaymentService(bus, { simulateTimeout: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.TIMEOUT);\n    expect(result.error).toBeTruthy();\n  });\n\n  it('refunds a successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    const refunded = await payment.refund(result.transactionId!);\n    expect(refunded).toBe(true);\n  });\n\n  it('fails to refund invalid transaction', async () => {\n    const payment = createPaymentService(bus);\n    const refunded = await payment.refund('bogus');\n    expect(refunded).toBe(false);\n  });\n\n  it('emits payment processed event', async () => {\n    const payment = createPaymentService(bus);\n    await payment.processPayment('order1', 100);\n    const log = bus.getLog();\n    const paymentEvents = log.filter(e => e.event === Events.PAYMENT_PROCESSED);\n    expect(paymentEvents).toHaveLength(1);\n  });\n});\n\ndescribe('NotificationS