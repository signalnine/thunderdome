+export interface Event {
+  id: string;
+  name: string;
+  duration: number;
+  attendees?: number;
+  prerequisites?: string[];
+  preferredRoom?: string;
+}
+
+export interface Room {
+  id: string;
+  name: string;
+  capacity: number;
+}
+
+export interface ScheduleOptions {
+  startTime: number;
+  endTime: number;
+  gap?: number;
+}
+
+export interface Assignment {
+  eventId: string;
+  roomId: string;
+  startTime: number;
+  endTime: number;
+}
+
+export interface ScheduleResult {
+  assignments: Assignment[];
+  unscheduled: string[];
+}
+
+/**
+ * Detect cycles in the prerequisite graph using DFS.
+ * Throws an error if a cycle is found.
+ */
+function detectCycles(events: Event[]): void {
+  const eventIds = new Set(events.map(e => e.id));
+  const WHITE = 0, GRAY = 1, BLACK = 2;
+  const color = new Map<string, number>();
+
+  for (const e of events) {
+    color.set(e.id, WHITE);
+  }
+
+  function dfs(id: string, path: string[]): void {
+    color.set(id, GRAY);
+    const event = events.find(e => e.id === id);
+    if (!event) return;
+
+    for (const prereq of event.prerequisites ?? []) {
+      if (prereq === id) {
+        throw new Error(`Cycle detected: event "${id}" has a self-reference`);
+      }
+      if (!eventIds.has(prereq)) continue;
+      const c = color.get(prereq);
+      if (c === GRAY) {
+        throw new Error(`Cycle detected in prerequisites: ${[...path, id, prereq].join(' -> ')}`);
+      }
+      if (c === WHITE) {
+        dfs(prereq, [...path, id]);
+      }
+    }
+    color.set(id, BLACK);
+  }
+
+  for (const e of events) {
+    if (color.get(e.id) === WHITE) {
+      dfs(e.id, []);
+    }
+  }
+}
+
+/**
+ * Topological sort of events based on prerequisites.
+ * Returns event IDs in an order where prerequisites come first.
+ */
+function topologicalSort(events: Event[]): string[] {
+  const eventIds = new Set(events.map(e => e.id));
+  const inDegree = new Map<string, number>();
+  const adjacency = new Map<string, string[]>();
+
+  for (const e of events) {
+    inDegree.set(e.id, 0);
+    adjacency.set(e.id, []);
+  }
+
+  for (const e of events) {
+    for (const prereq of e.prerequisites ?? []) {
+      if (eventIds.has(prereq)) {
+        adjacency.get(prereq)!.push(e.id);
+        inDegree.set(e.id, (inDegree.get(e.id) ?? 0) + 1);
+      }
+    }
+  }
+
+  const queue: string[] = [];
+  for (const [id, deg] of inDegree) {
+    if (deg === 0) queue.push(id);
+  }
+
+  const sorted: string[] = [];
+  while (queue.length > 0) {
+    const id = queue.shift()!;
+    sorted.push(id);
+    for (const dep of adjacency.get(id) ?? []) {
+      const newDeg = (inDegree.get(dep) ?? 1) - 1;
+      inDegree.set(dep, newDeg);
+      if (newDeg === 0) queue.push(dep);
+    }
+  }
+
+  return sorted;
+}
+
+/**
+ * Find the earliest start time for an event in a given room,
+ * considering room occupancy and prerequisite completion times.
+ */
+function findEarliestStart(
+  event: Event,
+  roomId: string,
+  assignments: Assignment[],
+  gap: number,
+  windowStart: number,
+  windowEnd: number,
+  prereqEndTimes: Map<string, number>
+): number | null {
+  const duration = event.duration;
+
+  // Calculate the earliest possible start based on prerequisites
+  let earliest = windowStart;
+  for (const prereq of event.prerequisites ?? []) {
+    const prereqEnd = prereqEndTimes.get(prereq);
+    if (prereqEnd !== undefined) {
+      earliest = Math.max(earliest, prereqEnd + gap);
+    }
+  }
+
+  // Check if the event can even fit in the window
+  if (earliest + duration > windowEnd) return null;
+
+  // Get all assignments in this room, sorted by start time
+  const roomAssignments = assignments
+    .filter(a => a.roomId === roomId)
+    .sort((a, b) => a.startTime - b.startTime);
+
+  // Find the earliest slot in this room
+  let candidateStart = earliest;
+
+  for (const existing of roomAssignments) {
+    const existingEnd = existing.endTime;
+    const existingStart = existing.startTime;
+
+    // If our candidate fits before this existing event (with gap)
+    if (candidateStart + duration + gap <= existingStart) {
+      return candidateStart;
+    }
+
+    // Move candidate past this existing event (with gap)
+    if (candidateStart < existingEnd + gap) {
+      candidateStart = existingEnd + gap;
+    }
+  }
+
+  // Check if we can fit after all existing events
+  if (candidateStart + duration <= windowEnd) {
+    return candidateStart;
+  }
+
+  return null;
+}
+
+/**
+ * Schedule events using backtracking to maximize scheduled events.
+ */
+export function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {
+  const gap = options.gap ?? 15;
+  const windowStart = options.startTime;
+  const windowEnd = options.endTime;
+
+  // Detect cycles first
+  detectCycles(events);
+
+  // Get topological order
+  const sortedIds = topologicalSort(events);
+  const eventMap = new Map(events.map(e => [e.id, e]));
+
+  // Filter to only events that exist in our event list
+  const eventsInOrder = sortedIds.map(id => eventMap.get(id)!);
+
+  // Build a map of which rooms can fit which events (capacity check)
+  const compatibleRooms = new Map<string, Room[]>();
+  for (const event of eventsInOrder) {
+    const attendees = event.attendees ?? 1;
+    const compatible = rooms.filter(r => r.capacity >= attendees);
+    // Sort: preferred room first, then by capacity (smaller first to leave big rooms for big events)
+    compatible.sort((a, b) => {
+      if (event.preferredRoom === a.id && event.preferredRoom !== b.id) return -1;
+      if (event.preferredRoom === b.id && event.preferredRoom !== a.id) return 1;
+      return a.capacity - b.capacity;
+    });
+    compatibleRooms.set(event.id, compatible);
+  }
+
+  // Use a greedy approach with backtracking for optimization
+  // First, try greedy assignment
+  const assignments: Assignment[] = [];
+  const prereqEndTimes = new Map<string, number>();
+  const unscheduled: string[] = [];
+
+  // Greedy pass: try to assign each event in topological order
+  for (const event of eventsInOrder) {
+    const compatible = compatibleRooms.get(event.id) ?? [];
+    let assigned = false;
+
+    for (const room of compatible) {
+      const start = findEarliestStart(event, room.id, assignments, gap, windowStart, windowEnd, prereqEndTimes);
+      if (start !== null) {
+        assignments.push({
+          eventId: event.id,
+          roomId: room.id,
+          startTime: start,
+          endTime: start + event.duration,
+        });
+        prereqEndTimes.set(event.id, start + event.duration);
+        assigned = true;
+        break;
+      }
+    }
+
+    if (!assigned) {
+      unscheduled.push(event.id);
+    }
+  }
+
+  // If everything got scheduled, return immediately
+  if (unscheduled.length === 0) {
+    return { assignments, unscheduled };
+  }
+
+  // Otherwise, try harder with backtracking/optimization
+  // Use a more sophisticated approach: try different orderings within topological constraints
+  const bestResult = optimizeSchedule(eventsInOrder, rooms, compatibleRooms, gap, windowStart, windowEnd);
+
+  if (bestResult.assignments.length > assignments.length) {
+    return bestResult;
+  }
+
+  return { assignments, unscheduled };
+}
+
+/**
+ * Build dependency levels for topological ordering constraints.
+ * Events at the same level have no dependency relationships between them
+ * and can be reordered freely.
+ */
+function buildDependencyLevels(events: Event[]): string[][] {
+  const eventIdSet = new Set(events.map(e => e.id));
+  const inDegree = new Map<string, number>();
+  const adjacency = new Map<string, string[]>();
+
+  for (const e of events) {
+    inDegree.set(e.id, 0);
+    adjacency.set(e.id, []);
+  }
+
+  for (const e of events) {
+    for (const prereq of e.prerequisites ?? []) {
+      if (eventIdSet.has(prereq)) {
+        adjacency.get(prereq)!.push(e.id);
+        inDegree.set(e.id, (inDegree.get(e.id) ?? 0) + 1);
+      }
+    }
+  }
+
+  const levels: string[][] = [];
+  const remaining = new Map(inDegree);
+
+  while (remaining.size > 0) {
+    const level: string[] = [];
+    for (const [id, deg] of remaining) {
+      if (deg === 0) level.push(id);
+    }
+    if (level.length === 0) break;
+
+    levels.push(level);
+    for (const id of level) {
+      remaining.delete(id);
+      for (const dep of adjacency.get(id) ?? []) {
+        if (remaining.has(dep)) {
+          remaining.set(dep, (remaining.get(dep) ?? 1) - 1);
+        }
+      }
+    }
+  }
+
+  return levels;
+}
+
+/**
+ * Optimize schedule by trying different valid orderings and room assignments.
+ */
+function optimizeSchedule(
+  events: Event[],
+  rooms: Room[],
+  compatibleRooms: Map<string, Room[]>,
+  gap: number,
+  windowStart: number,
+  windowEnd: number
+): ScheduleResult {
+  const eventMap = new Map(events.map(e => [e.id, e]));
+  const levels = buildDependencyLevels(events);
+
+  let bestAssignments: Assignment[] = [];
+  let bestUnscheduled: string[] = events.map(e => e.id);
+
+  // Try multiple permutations of events within each level
+  // Sort strategies within levels
+  const sortStrategies: ((a: Event, b: Event) => number)[] = [
+    // Longest duration first (harder to place)
+    (a, b) => b.duration - a.duration,
+    // Most attendees first (harder to place - fewer rooms)
+    (a, b) => (b.attendees ?? 1) - (a.attendees ?? 1),
+    // Fewest compatible rooms first (most constrained)
+    (a, b) => (compatibleRooms.get(a.id)?.length ?? 0) - (compatibleRooms.get(b.id)?.length ?? 0),
+    // Combined: most constrained first
+    (a, b) => {
+      const aScore = (compatibleRooms.get(a.id)?.length ?? 0) * 1000 - (a.attendees ?? 1) * 10 - a.duration;
+      const bScore = (compatibleRooms.get(b.id)?.length ?? 0) * 1000 - (b.attendees ?? 1) * 10 - b.duration;
+      return aScore - bScore;
+    },
+    // Shortest duration first
+    (a, b) => a.duration - b.duration,
+    // Has preferred room first
+    (a, b) => {
+      const aHasPref = a.preferredRoom ? 0 : 1;
+      const bHasPref = b.preferredRoom ? 0 : 1;
+      return aHasPref - bHasPref || b.duration - a.duration;
+    },
+  ];
+
+  for (const strategy of sortStrategies) {
+    const orderedIds: string[] = [];
+    for (const level of levels) {
+      const levelEvents = level.map(id => eventMap.get(id)!);
+      levelEvents.sort(strategy);
+      orderedIds.push(...levelEvents.map(e => e.id));
+    }
+
+    const result = trySchedule(orderedIds, eventMap, rooms, compatibleRooms, gap, windowStart, windowEnd);
+
+    if (result.assignments.length > bestAssignments.length) {
+      bestAssignments = result.assignments;
+      bestUnscheduled = result.unscheduled;
+      if (bestUnscheduled.length === 0) break;
+    }
+  }
+
+  // If we still have unscheduled events, try backtracking with the best order found so far
+  if (bestUnscheduled.length > 0 && events.length <= 20) {
+    const result = backtrackSchedule(events, rooms, compatibleRooms, gap, windowStart, windowEnd, levels, eventMap);
+    if (result.assignments.length > bestAssignments.length) {
+      bestAssignments = result.assignments;
+      bestUnscheduled = result.unscheduled;
+    }
+  }
+
+  return { assignments: bestAssignments, unscheduled: bestUnscheduled };
+}
+
+/**
+ * Try scheduling events in the given order.
+ */
+function trySchedule(
+  orderedIds: string[],
+  eventMap: Map<string, Event>,
+  rooms: Room[],
+  compatibleRooms: Map<string, Room[]>,
+  gap: number,
+  windowStart: number,
+  windowEnd: number
+): ScheduleResult {
+  const assignments: Assignment[] = [];
+  const prereqEndTimes = new Map<string, number>();
+  const unscheduled: string[] = [];
+
+  for (const id of orderedIds) {
+    const event = eventMap.get(id)!;
+    const compatible = compatibleRooms.get(id) ?? [];
+    let assigned = false;
+
+    for (const room of compatible) {
+      const start = findEarliestStart(event, room.id, assignments, gap, windowStart, windowEnd, prereqEndTimes);
+      if (start !== null) {
+        assignments.push({
+          eventId: event.id,
+          roomId: room.id,
+          startTime: start,
+          endTime: start + event.duration,
+        });
+        prereqEndTimes.set(event.id, start + event.duration);
+        assigned = true;
+        break;
+      }
+    }
+
+    if (!assigned) {
+      unscheduled.push(id);
+    }
+  }
+
+  return { assignments, unscheduled };
+}
+
+/**
+ * Backtracking scheduler that tries different room assignments to maximize scheduled events.
+ */
+function backtrackSchedule(
+  events: Event[],
+  rooms: Room[],
+  compatibleRooms: Map<string, Room[]>,
+  gap: number,
+  windowStart: number,
+  windowEnd: number,
+  levels: string[][],
+  eventMap: Map<string, Event>
+): ScheduleResult {
+  // Flatten levels maintaining topological order, sorted by most constrained first within levels
+  const orderedIds: string[] = [];
+  for (const level of levels) {
+    const sorted = [...level].sort((a, b) => {
+      const aRooms = compatibleRooms.get(a)?.length ?? 0;
+      const bRooms = compatibleRooms.get(b)?.length ?? 0;
+      if (aRooms !== bRooms) return aRooms - bRooms;
+      const aEvent = eventMap.get(a)!;
+      const bEvent = eventMap.get(b)!;
+      return bEvent.duration - aEvent.duration;
+    });
+    orderedIds.push(...sorted);
+  }
+
+  let bestAssignments: Assignment[] = [];
+  let bestCount = 0;
+
+  function backtrack(
+    index: number,
+    currentAssignments: Assignment[],
+    prereqEndTimes: Map<string, number>,
+    scheduledCount: number
+  ): boolean {
+    // If we've scheduled everything, we're done
+    if (scheduledCount === events.length) {
+      bestAssignments = [...currentAssignments];
+      bestCount = scheduledCount;
+      return true;
+    }
+
+    // If we've processed all events, record best
+    if (index >= orderedIds.length) {
+      if (scheduledCount > bestCount) {
+        bestAssignments = [...currentAssignments];
+        bestCount = scheduledCount;
+      }
+      return false;
+    }
+
+    // Pruning: even if we schedule all remaining events, can we beat best?
+    const remaining = orderedIds.length - index;
+    if (scheduledCount + remaining <= bestCount) {
+      return false;
+    }
+
+    const id = orderedIds[index];
+    const event = eventMap.get(id)!;
+    const compatible = compatibleRooms.get(id) ?? [];
+
+    // Try each compatible room
+    for (const room of compatible) {
+      const start = findEarliestStart(event, room.id, currentAssignments, gap, windowStart, windowEnd, prereqEndTimes);
+      if (start !== null) {
+        const assignment: Assignment = {
+          eventId: id,
+          roomId: room.id,
+          startTime: start,
+          endTime: start + event.duration,
+        };
+        currentAssignments.push(assignment);
+        prereqEndTimes.set(id, start + event.duration);
+
+        if (backtrack(index + 1, currentAssignments, prereqEndTimes, scheduledCount + 1)) {
+          return true;
+        }
+
+        currentAssignments.pop();
+        prereqEndTimes.delete(id);
+      }
+    }
+
+    // Try skipping this event
+    if (backtrack(index + 1, currentAssignments, prereqEndTimes, scheduledCount)) {
+      return true;
+    }
+
+    return false;
+  }
+
+  backtrack(0, [], new Map(), 0);
+
+  const scheduledIds = new Set(bestAssignments.map(a => a.eventId));
+  const unscheduled = events.filter(e => !scheduledIds.has(e.id)).map(e => e.id);
+
+  return { assignments: bestAssignments, unscheduled };
+}
