  }\n      if (c === WHITE) {\n        dfs(prereq, [...path, id]);\n      }\n    }\n    color.set(id, BLACK);\n  }\n\n  for (const e of events) {\n    if (color.get(e.id) === WHITE) {\n      dfs(e.id, []);\n    }\n  }\n}\n\n/**\n * Topological sort of events based on prerequisites.\n * Returns event IDs in an order where prerequisites come first.\n */\nfunction topologicalSort(events: Event[]): string[] {\n  const eventIds = new Set(events.map(e => e.id));\n  const inDegree = new Map<string, number>();\n  const adjacency = new Map<string, string[]>();\n\n  for (const e of events) {\n    inDegree.set(e.id, 0);\n    adjacency.set(e.id, []);\n  }\n\n  for (const e of events) {\n    for (const prereq of e.prerequisites ?? []) {\n      if (eventIds.has(prereq)) {\n        adjacency.get(prereq)!.push(e.id);\n        inDegree.set(e.id, (inDegree.get(e.id) ?? 0) + 1);\n      }\n    }\n  }\n\n  const queue: string[] = [];\n  for (const [id, deg] of inDegree) {\n    if (deg === 0) queue.push(id);\n  }\n\n  const sorted: string[] = [];\n  while (queue.length > 0) {\n    const id = queue.shift()!;\n    sorted.push(id);\n    for (const dep of adjacency.get(id) ?? []) {\n      const newDeg = (inDegree.get(dep) ?? 1) - 1;\n      inDegree.set(dep, newDeg);\n      if (newDeg === 0) queue.push(dep);\n    }\n  }\n\n  return sorted;\n}\n\n/**\n * Find the earliest start time for an event in a given room,\n * considering room occupancy and prerequisite completion times.\n */\nfunction findEarliestStart(\n  event: Event,\n  roomId: string,\n  assignments: Assignment[],\n  gap: number,\n  windowStart: number,\n  windowEnd: number,\n  prereqEndTimes: Map<string, number>\n): number | null {\n  const attendees = event.attendees ?? 1;\n  const duration = event.duration;\n\n  // Calculate the earliest possible start based on prerequisites\n  let earliest = windowStart;\n  for (const prereq of event.prerequisites ?? []) {\n    const prereqEnd = prereqEndTimes.get(prereq);\n    if (prereqEnd !==