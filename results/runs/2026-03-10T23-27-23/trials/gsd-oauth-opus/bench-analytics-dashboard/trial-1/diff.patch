@@ -0,0 +1,135 @@
+import { Router, Request, Response } from "express";
+import Database from "better-sqlite3";
+import { authenticate } from "../auth.js";
+
+export function createQueryRouter(db: Database.Database): Router {
+  const router = Router();
+
+  router.use(authenticate);
+
+  // Count query
+  router.post("/count", (req: Request, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { eventName, startDate, endDate, filters } = req.body;
+
+    let sql = "SELECT COUNT(*) as count FROM events WHERE tenant_id = ?";
+    const params: (string | number)[] = [tenantId];
+
+    if (eventName) {
+      sql += " AND name = ?";
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value as string);
+      }
+    }
+
+    const result = db.prepare(sql).get(...params) as { count: number };
+
+    res.json({ count: result.count });
+  });
+
+  // Timeseries query
+  router.post("/timeseries", (req: Request, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { eventName, startDate, endDate, interval, filters } = req.body;
+
+    if (!eventName) {
+      res.status(400).json({ error: "eventName is required" });
+      return;
+    }
+
+    // Default: group by day
+    const bucket = interval === "hour"
+      ? "strftime('%Y-%m-%dT%H:00:00', timestamp)"
+      : interval === "month"
+        ? "strftime('%Y-%m-01', timestamp)"
+        : "strftime('%Y-%m-%d', timestamp)";
+
+    let sql = `SELECT ${bucket} as bucket, COUNT(*) as count FROM events WHERE tenant_id = ? AND name = ?`;
+    const params: (string | number)[] = [tenantId, eventName];
+
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value as string);
+      }
+    }
+
+    sql += ` GROUP BY bucket ORDER BY bucket ASC`;
+
+    const rows = db.prepare(sql).all(...params) as Array<{ bucket: string; count: number }>;
+
+    res.json({
+      timeseries: rows.map((r) => ({ date: r.bucket, count: r.count })),
+    });
+  });
+
+  // Breakdown query
+  router.post("/breakdown", (req: Request, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { eventName, property, startDate, endDate, filters, limit } = req.body;
+
+    if (!eventName || !property) {
+      res.status(400).json({ error: "eventName and property are required" });
+      return;
+    }
+
+    let sql = `SELECT json_extract(properties, ?) as value, COUNT(*) as count FROM events WHERE tenant_id = ? AND name = ?`;
+    const params: (string | number)[] = [`$.${property}`, tenantId, eventName];
+
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value as string);
+      }
+    }
+
+    sql += " GROUP BY value ORDER BY count DESC";
+
+    const queryLimit = limit ? parseInt(String(limit), 10) : 100;
+    sql += " LIMIT ?";
+    params.push(queryLimit);
+
+    const rows = db.prepare(sql).all(...params) as Array<{ value: string | null; count: number }>;
+
+    res.json({
+      breakdown: rows.map((r) => ({ value: r.value, count: r.count })),
+    });
+  });
+
+  return router;
+}
