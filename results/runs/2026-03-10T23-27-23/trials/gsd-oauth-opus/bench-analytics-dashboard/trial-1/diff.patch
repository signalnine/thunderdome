+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TdFZWRYtcBYqu8rTnSSFVN","type":"tool_result","content":"The file /workspace/tests/app.test.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"67ab9deb-549e-49cc-8fa4-04f988117772","uuid":"2f597f40-4aa3-4b3a-9ace-9a04c97ffc89","tool_use_result":{"filePath":"/workspace/tests/app.test.ts","oldString":"import { createApp } from \"./app.js\";\nimport { createDatabase } from \"./db.js\";","newString":"import { createApp } from \"../src/app.js\";\nimport { createDatabase } from \"../src/db.js\";","originalFile":"import { describe, it, expect, beforeAll } from \"vitest\";\nimport request from \"supertest\";\nimport { createApp } from \"./app.js\";\nimport { createDatabase } from \"./db.js\";\nimport type { Express } from \"express\";\nimport type Database from \"better-sqlite3\";\n\nlet app: Express;\nlet db: Database.Database;\n\nbeforeAll(() => {\n  db = createDatabase(\":memory:\");\n  app = createApp(db);\n});\n\ndescribe(\"Health\", () => {\n  it(\"GET /health returns ok\", async () => {\n    const res = await request(app).get(\"/health\");\n    expect(res.status).toBe(200);\n    expect(res.body.status).toBe(\"ok\");\n  });\n});\n\ndescribe(\"User Management\", () => {\n  let token: string;\n  let userId: string;\n\n  it(\"registers a new user\", async () => {\n    const res = await request(app).post(\"/api/users/register\").send({\n      email: \"admin@acme.com\",\n      password: \"password123\",\n      tenantId: \"tenant-acme\",\n      role: \"admin\",\n    });\n    expect(res.status).toBe(201);\n    expect(res.body.user.email).toBe(\"admin@acme.com\");\n    expect(res.body.user.tenantId).toBe(\"tenant-acme\");\n    expect(res.body.user.role).toBe(\"admin\");\n    expect(res.body.token).toBeTruthy();\n    token = res.body.token;\n    userId = res.body.user.id;\n  });\n\n  it(\"rejects duplicate email\", async () => {\n    const res = await request(app).post(\"/api/users/register\").send({\n      email: \"admin@acme.com\",\n      password: \"password123\",\n      tenantId: \"tenant-acme\",\n    });\n    expect(res.status).toBe(409);\n  });\n\n  it(\"logs in with correct credentials\", async () => {\n    const res = await request(app).post(\"/api/users/login\").send({\n      email: \"admin@acme.com\",\n      password: \"password123\",\n    });\n    expect(res.status).toBe(200);\n    expect(res.body.token).toBeTruthy();\n    token = res.body.token;\n  });\n\n  it(\"rejects invalid credentials\", async () => {\n    const res = await request(app).post(\"/api/users/login\").send({\n      email: \"admin@acme.com\",\n      password: \"wrong\",\n    });\n    expect(res.status).toBe(401);\n  });\n\n  it(\"gets user profile\", async () => {\n    const res = await request(app)\n      .get(\"/api/users/me\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.email).toBe(\"admin@acme.com\");\n    expect(res.body.role).toBe(\"admin\");\n  });\n\n  it(\"returns 401 without token\", async () => {\n    const res = await request(app).get(\"/api/users/me\");\n    expect(res.status).toBe(401);\n  });\n\n  it(\"updates user role\", async () => {\n    // Create a viewer first\n    const regRes = await request(app).post(\"/api/users/register\").send({\n      email: \"viewer@acme.com\",\n      password: \"password123\",\n      tenantId: \"tenant-acme\",\n      role: \"viewer\",\n    });\n    const viewerId = regRes.body.user.id;\n\n    const res = await request(app)\n      .put(`/api/users/${viewerId}/role`)\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ role: \"editor\" });\n    expect(res.status).toBe(200);\n    expect(res.body.role).toBe(\"editor\");\n  });\n\n  it(\"prevents cross-tenant role change\", async () => {\n    const otherRes = await request(app).post(\"/api/users/register\").send({\n      email: \"other@other.com\",\n      password: \"password123\",\n      tenantId: \"tenant-other\",\n    });\n    const otherId = otherRes.body.user.id;\n\n    const res = await request(app)\n      .put(`/api/users/${otherId}/role`)\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ role: \"admin\" });\n    expect(res.status).toBe(403);\n  });\n});\n\ndescribe(\"Event Ingestion\", () => {\n  let token: string;\n\n  beforeAll(async () => {\n    const res = await request(app).post(\"/api/users/register\").send({\n      email: \"events@acme.com\",\n      password: \"password123\",\n      tenantId: \"tenant-events\",\n    });\n    token = res.body.token;\n  });\n\n  it(\"requires authentication\", async () => {\n    const res = await request(app).post(\"/api/events\").send({ name: \"page_view\" });\n    expect(res.status).toBe(401);\n  });\n\n  it(\"ingests a single event\", async () => {\n    const res = await request(app)\n      .post(\"/api/events\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({\n        name: \"page_view\",\n        properties: { url: \"/home\", browser: \"Chrome\" },\n        timestamp: \"2024-01-15T10:00:00Z\",\n      });\n    expect(res.status).toBe(201);\n    expect(res.body.name).toBe(\"page_view\");\n  });\n\n  it(\"ingests batch events\", async () => {\n    const res = await request(app)\n      .post(\"/api/events/batch\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({\n        events: [\n          { name: \"page_view\", properties: { url: \"/about\" }, timestamp: \"2024-01-15T11:00:00Z\" },\n          { name: \"page_view\", properties: { url: \"/contact\" }, timestamp: \"2024-01-16T10:00:00Z\" },\n          { name: \"click\", properties: { button: \"signup\" }, timestamp: \"2024-01-16T11:00:00Z\" },\n        ],\n      });\n    expect(res.status).toBe(201);\n    expect(res.body.inserted).toBe(3);\n  });\n\n  it(\"lists events\", async () => {\n    const res = await request(app)\n      .get(\"/api/events\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.events.length).toBe(4);\n  });\n\n  it(\"lists events with name filter\", async () => {\n    const res = await request(app)\n      .get(\"/api/events?name=click\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.events.length).toBe(1);\n  });\n});\n\ndescribe(\"Query Engine\", () => {\n  let token: string;\n\n  beforeAll(async () => {\n    const res = await request(app).post(\"/api/users/register\").send({\n      email: \"query@acme.com\",\n      password: \"password123\",\n      tenantId: \"tenant-query\",\n    });\n    token = res.body.token;\n\n    // Ingest events for queries\n    await request(app)\n      .post(\"/api/events/batch\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({\n        events: [\n          { name: \"page_view\", properties: { url: \"/home\" }, timestamp: \"2024-01-15T10:00:00Z\" },\n          { name: \"page_view\", properties: { url: \"/home\" }, timestamp: \"2024-01-15T11:00:00Z\" },\n          { name: \"page_view\", properties: { url: \"/about\" }, timestamp: \"2024-01-16T10:00:00Z\" },\n          { name: \"click\", properties: { button: \"signup\" }, timestamp: \"2024-01-16T12:00:00Z\" },\n        ],\n      });\n  });\n\n  it(\"requires authentication\", async () => {\n    const res = await request(app).post(\"/api/queries/count\").send({ eventName: \"page_view\" });\n    expect(res.status).toBe(401);\n  });\n\n  it(\"counts events\", async () => {\n    const res = await request(app)\n      .post(\"/api/queries/count\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ eventName: \"page_view\" });\n    expect(res.status).toBe(200);\n    expect(res.body.count).toBe(3);\n  });\n\n  it(\"counts events with date range\", async () => {\n    const res = await request(app)\n      .post(\"/api/queries/count\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({\n        eventName: \"page_view\",\n        startDate: \"2024-01-15T00:00:00Z\",\n        endDate: \"2024-01-15T23:59:59Z\",\n      });\n    expect(res.status).toBe(200);\n    expect(res.body.count).toBe(2);\n  });\n\n  it(\"returns timeseries data\", async () => {\n    const res = await request(app)\n      .post(\"/api/queries/timeseries\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ eventName: \"page_view\", interval: \"day\" });\n    expect(res.status).toBe(200);\n    expect(res.body.timeseries.length).toBe(2);\n    expect(res.body.timeseries[0].count).toBe(2);\n    expect(res.body.timeseries[1].count).toBe(1);\n  });\n\n  it(\"returns breakdown data\", async () => {\n    const res = await request(app)\n      .post(\"/api/queries/breakdown\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ eventName: \"page_view\", property: \"url\" });\n    expect(res.status).toBe(200);\n    expect(res.body.breakdown.length).toBe(2);\n    expect(res.body.breakdown[0].value).toBe(\"/home\");\n    expect(res.body.breakdown[0].count).toBe(2);\n  });\n\n  it(\"respects tenant isolation on count\", async () => {\n    // Register user in different tenant\n    const otherRes = await request(app).post(\"/api/users/register\").send({\n      email: \"other-query@other.com\",\n      password: \"password123\",\n      tenantId: \"tenant-other-query\",\n    });\n    const otherToken = otherRes.body.token;\n\n    const res = await request(app)\n      .post(\"/api/queries/count\")\n      .set(\"Authorization\", `Bearer ${otherToken}`)\n      .send({ eventName: \"page_view\" });\n    expect(res.status).toBe(200);\n    expect(res.body.count).toBe(0);\n  });\n});\n\ndescribe(\"Dashboard CRUD\", () => {\n  let token: string;\n  let dashboardId: string;\n\n  beforeAll(async () => {\n    const res = await request(app).post(\"/api/users/register\").send({\n      email: \"dash@acme.com\",\n      password: \"password123\",\n      tenantId: \"tenant-dash\",\n    });\n    token = res.body.token;\n  });\n\n  it(\"requires authentication\", async () => {\n    const res = await request(app).post(\"/api/dashboards\").send({ name: \"Test\" });\n    expect(res.status).toBe(401);\n  });\n\n  it(\"creates a dashboard\", async () => {\n    const res = await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Main Dashboard\", config: { theme: \"dark\" } });\n    expect(res.status).toBe(201);\n    expect(res.body.name).toBe(\"Main Dashboard\");\n    dashboardId = res.body.id;\n  });\n\n  it(\"lists dashboards\", async () => {\n    const res = await request(app)\n      .get(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.dashboards.length).toBe(1);\n  });\n\n  it(\"gets a single dashboard\", async () => {\n    const res = await request(app)\n      .get(`/api/dashboards/${dashboardId}`)\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.name).toBe(\"Main Dashboard\");\n  });\n\n  it(\"updates a dashboard\", async () => {\n    const res = await request(app)\n      .put(`/api/dashboards/${dashboardId}`)\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Updated Dashboard\" });\n    expect(res.status).toBe(200);\n    expect(res.body.name).toBe(\"Updated Dashboard\");\n  });\n\n  it(\"deletes a dashboard\", async () => {\n    const res = await request(app)\n      .delete(`/api/dashboards/${dashboardId}`)\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(204);\n\n    const getRes = await request(app)\n      .get(`/api/dashboards/${dashboardId}`)\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(getRes.status).toBe(404);\n  });\n\n  it(\"respects tenant isolation\", async () => {\n    // Create dashboard in one tenant\n    const createRes = await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Tenant Dash\" });\n    const id = createRes.body.id;\n\n    // Try to access from other tenant\n    const otherRes = await request(app).post(\"/api/users/register\").send({\n      email: \"dash-other@other.com\",\n      password: \"password123\",\n      tenantId: \"tenant-dash-other\",\n    });\n    const otherToken = otherRes.body.token;\n\n    const getRes = await request(app)\n      .get(`/api/dashboards/${id}`)\n      .set(\"Authorization\", `Bearer ${otherToken}`);\n    expect(getRes.status).toBe(404);\n  });\n});\n\ndescribe(\"Data Export\", () => {\n  let token: string;\n  let dashboardId: string;\n\n  beforeAll(async () => {\n    const res = await request(app).post(\"/api/users/register\").send({\n      email: \"export@acme.com\",\n      password: \"password123\",\n      tenantId: \"tenant-export\",\n    });\n    token = res.body.token;\n\n    // Ingest some events\n    await request(app)\n      .post(\"/api/events/batch\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({\n        events: [\n          { name: \"page_view\", properties: { url: \"/home\" }, timestamp: \"2024-01-15T10:00:00Z\" },\n          { name: \"click\", properties: { button: \"signup\" }, timestamp: \"2024-01-16T10:00:00Z\" },\n        ],\n      });\n\n    // Create a dashboard\n    const dashRes = await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Export Dash\" });\n    dashboardId = dashRes.body.id;\n  });\n\n  it(\"requires authentication for events export\", async () => {\n    const res = await request(app).get(\"/api/export/events/json\");\n    expect(res.status).toBe(401);\n  });\n\n  it(\"exports events as JSON\", async () => {\n    const res = await request(app)\n      .get(\"/api/export/events/json\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.events.length).toBe(2);\n  });\n\n  it(\"exports events as CSV\", async () => {\n    const res = await request(app)\n      .get(\"/api/export/events/csv\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n    expect(res.text).toContain(\"id,name,properties,timestamp\");\n  });\n\n  it(\"exports dashboard as JSON\", async () => {\n    const res = await request(app)\n      .get(`/api/export/dashboards/${dashboardId}/json`)\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.dashboard.name).toBe(\"Export Dash\");\n  });\n\n  it(\"exports dashboard as CSV\", async () => {\n    const res = await request(app)\n      .get(`/api/export/dashboards/${dashboardId}/csv`)\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n  });\n\n  it(\"returns 404 for non-existent dashboard export\", async () => {\n    const res = await request(app)\n      .get(\"/api/export/dashboards/nonexistent/json\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(404);\n  });\n});\n","structuredPatch":[{"oldStart":1,"oldLines":7,"newStart":1,"newLines":7,"lines":[" import { describe, it, expect, beforeAll } from \"vitest\";"," import request from \"supertest\";","-import { createApp } from \"./app.js\";","-import { createDatabase } from \"./db.js\";","+import { createApp } from \"../src/app.js\";","+import { createDatabase } from \"../src/db.js\";"," import type { Express } from \"express\";"," import type Database from \"better-sqlite3\";"," "]}],"userModified":false,"replaceAll":false}}
