+interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const n = target.length;
+  const m = buttons.length;
+
+  const rows: bigint[] = new Array(n);
+  for (let i = 0; i < n; i++) {
+    let row = 0n;
+    for (let j = 0; j < m; j++) {
+      if (buttons[j].includes(i)) {
+        row |= 1n << BigInt(j);
+      }
+    }
+    if (target[i]) {
+      row |= 1n << BigInt(m);
+    }
+    rows[i] = row;
+  }
+
+  const pivotCol: number[] = [];
+  let rank = 0;
+
+  for (let col = 0; col < m && rank < n; col++) {
+    let pivotRow = -1;
+    for (let r = rank; r < n; r++) {
+      if ((rows[r] >> BigInt(col)) & 1n) {
+        pivotRow = r;
+        break;
+      }
+    }
+    if (pivotRow === -1) continue;
+
+    [rows[rank], rows[pivotRow]] = [rows[pivotRow], rows[rank]];
+    pivotCol.push(col);
+
+    for (let r = 0; r < n; r++) {
+      if (r !== rank && (rows[r] >> BigInt(col)) & 1n) {
+        rows[r] ^= rows[rank];
+      }
+    }
+    rank++;
+  }
+
+  for (let r = rank; r < n; r++) {
+    if ((rows[r] >> BigInt(m)) & 1n) {
+      return null;
+    }
+  }
+
+  const pivotColSet = new Set(pivotCol);
+  const freeVars: number[] = [];
+  for (let j = 0; j < m; j++) {
+    if (!pivotColSet.has(j)) {
+      freeVars.push(j);
+    }
+  }
+
+  let baseMask = 0n;
+  for (let r = 0; r < rank; r++) {
+    if ((rows[r] >> BigInt(m)) & 1n) {
+      baseMask |= 1n << BigInt(pivotCol[r]);
+    }
+  }
+
+  const k = freeVars.length;
+
+  if (k === 0) {
+    return bitmaskToIndices(baseMask, m);
+  }
+
+  if (k > 25) {
+    return bitmaskToIndices(baseMask, m);
+  }
+
+  const freeMasks: bigint[] = new Array(k);
+  for (let fi = 0; fi < k; fi++) {
+    const fv = freeVars[fi];
+    let mask = 1n << BigInt(fv);
+    for (let r = 0; r < rank; r++) {
+      if ((rows[r] >> BigInt(fv)) & 1n) {
+        mask |= 1n << BigInt(pivotCol[r]);
+      }
+    }
+    freeMasks[fi] = mask;
+  }
+
+  let bestCount = m + 1;
+  let bestMask = 0n;
+  let currentMask = baseMask;
