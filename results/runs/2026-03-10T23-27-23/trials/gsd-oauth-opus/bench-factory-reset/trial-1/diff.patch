lf that when XORed gives minimum popcount.\n  // But XOR popcount doesn't decompose...\n  //\n  // Practical approach: since this is a benchmark with up to 40 buttons/lights,\n  // and rank is usually close to min(m,n), k is usually small.\n  // Let's just handle up to k=25 with direct enum and hope k>25 doesn't occur.\n  // If it does, fall back to the naive approach which will be slow.\n\n  let bestCount = m + 1;\n  let bestMask = 0n;\n\n  for (let comboB = 0; comboB < (1 << halfB); comboB++) {\n    let deltaB = 0n;\n    for (let fi = 0; fi < halfB; fi++) {\n      if (comboB & (1 << fi)) {\n        deltaB ^= freeMasks[halfA + fi];\n      }\n    }\n\n    for (const entry of firstHalf) {\n      const solMask = entry.solMask ^ deltaB;\n      const count = popcount(solMask, m);\n      if (count < bestCount || (count === bestCount && compareMasks(solMask, bestMask, m) < 0)) {\n        bestCount = count;\n        bestMask = solMask;\n      }\n    }\n  }\n\n  return bitmaskToIndices(bestMask, m);\n}\n\nfunction popcount(mask: bigint, maxBits: number): number {\n  let count = 0;\n  let m = mask;\n  for (let i = 0; i < maxBits && m > 0n; i++) {\n    if (m & 1n) count++;\n    m >>= 1n;\n  }\n  return count;\n}\n\nfunction compareMasks(a: bigint, b: bigint, maxBits: number): number {\n  // Compare the indices sets lexicographically\n  // The set with the first differing bit at a lower position is \"smaller\" if that bit is in a but not b\n  // Actually for lex order of index sets:\n  //   {0,2} < {0,3} < {1,2} etc.\n  // This corresponds to comparing the sorted arrays element by element.\n  // With bitmasks, the lex-smallest set is determined by the first position where they differ:\n  // if a has a 1 and b has 0 at that position, a's set includes that index but b's doesn't.\n  // For lex comparison of sets: {0,2} vs {0,3}: differ at pos 2 (a has it), so a < b.\n  // {0,2} vs {1}: differ at pos 0 (a has it), and a has fewer... wait, sizes might differ.\n  //\n  // For sets o