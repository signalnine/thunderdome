% p;\n    matrix.push(row);\n  }\n\n  // Gaussian elimination over GF(p)\n  const pivotCol: number[] = [];\n  let rank = 0;\n\n  for (let col = 0; col < m && rank < n; col++) {\n    let pivotRow = -1;\n    for (let r = rank; r < n; r++) {\n      if (matrix[r][col] !== 0) {\n        pivotRow = r;\n        break;\n      }\n    }\n    if (pivotRow === -1) continue;\n\n    [matrix[rank], matrix[pivotRow]] = [matrix[pivotRow], matrix[rank]];\n    pivotCol.push(col);\n\n    const inv = modInverse(matrix[rank][col], p);\n    for (let c = 0; c <= m; c++) {\n      matrix[rank][c] = (matrix[rank][c] * inv) % p;\n    }\n\n    for (let r = 0; r < n; r++) {\n      if (r !== rank && matrix[r][col] !== 0) {\n        const factor = matrix[r][col];\n        for (let c = 0; c <= m; c++) {\n          matrix[r][c] = ((matrix[r][c] - factor * matrix[rank][c]) % p + p) % p;\n        }\n      }\n    }\n    rank++;\n  }\n\n  // Check for inconsistency\n  for (let r = rank; r < n; r++) {\n    if (matrix[r][m] !== 0) {\n      return null;\n    }\n  }\n\n  // Identify free variables\n  const pivotColSet = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let j = 0; j < m; j++) {\n    if (!pivotColSet.has(j)) {\n      freeVars.push(j);\n    }\n  }\n\n  // Base solution (free vars = 0)\n  const basePivotVals = new Array(rank);\n  const baseSol = new Array(m).fill(0);\n  for (let r = 0; r < rank; r++) {\n    basePivotVals[r] = matrix[r][m];\n    baseSol[pivotCol[r]] = matrix[r][m];\n  }\n\n  const k = freeVars.length;\n\n  if (k === 0) {\n    return baseSol;\n  }\n\n  // For each free variable fi, compute its effect on each pivot variable\n  // freeCoeff[fi][r] = (p - matrix[r][freeVars[fi]]) % p\n  // This is the coefficient: pivotVal[r] = (basePivotVals[r] + sum_fi(freeValues[fi] * freeCoeff[fi][r])) % p\n  const freeCoeff: number[][] = [];\n  for (let fi = 0; fi < k; fi++) {\n    const fv = freeVars[fi];\n    const coeffs = new Array(rank);\n    for (let r = 0; r < rank; r++) {\n  