ow = -1;\n    for (let r = rank; r < n; r++) {\n      if ((rows[r] >> BigInt(col)) & 1n) {\n        pivotRow = r;\n        break;\n      }\n    }\n    if (pivotRow === -1) continue;\n\n    [rows[rank], rows[pivotRow]] = [rows[pivotRow], rows[rank]];\n    pivotCol.push(col);\n\n    for (let r = 0; r < n; r++) {\n      if (r !== rank && (rows[r] >> BigInt(col)) & 1n) {\n        rows[r] ^= rows[rank];\n      }\n    }\n    rank++;\n  }\n\n  for (let r = rank; r < n; r++) {\n    if ((rows[r] >> BigInt(m)) & 1n) {\n      return null;\n    }\n  }\n\n  const pivotColSet = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let j = 0; j < m; j++) {\n    if (!pivotColSet.has(j)) {\n      freeVars.push(j);\n    }\n  }\n\n  let baseMask = 0n;\n  for (let r = 0; r < rank; r++) {\n    if ((rows[r] >> BigInt(m)) & 1n) {\n      baseMask |= 1n << BigInt(pivotCol[r]);\n    }\n  }\n\n  const k = freeVars.length;\n\n  if (k === 0) {\n    return bitmaskToIndices(baseMask, m);\n  }\n\n  if (k > 25) {\n    return bitmaskToIndices(baseMask, m);\n  }\n\n  const freeMasks: bigint[] = new Array(k);\n  for (let fi = 0; fi < k; fi++) {\n    const fv = freeVars[fi];\n    let mask = 1n << BigInt(fv);\n    for (let r = 0; r < rank; r++) {\n      if ((rows[r] >> BigInt(fv)) & 1n) {\n        mask |= 1n << BigInt(pivotCol[r]);\n      }\n    }\n    freeMasks[fi] = mask;\n  }\n\n  let bestCount = m + 1;\n  let bestMask = 0n;\n  let currentMask = baseMask;\n\n  const baseCount = popcountBig(baseMask);\n  if (baseCount < bestCount || (baseCount === bestCount && compareMaskLex(baseMask, bestMask) < 0)) {\n    bestCount = baseCount;\n    bestMask = baseMask;\n  }\n\n  const limit = 1 << k;\n  for (let combo = 1; combo < limit; combo++) {\n    const bit = combo & (-combo);\n    let fi = 0;\n    let tmp = bit;\n    while (tmp > 1) { fi++; tmp >>= 1; }\n\n    currentMask ^= freeMasks[fi];\n    const count = popcountBig(currentMask);\n    if (count < bestCount || (count === bestCount && compareMaskLex