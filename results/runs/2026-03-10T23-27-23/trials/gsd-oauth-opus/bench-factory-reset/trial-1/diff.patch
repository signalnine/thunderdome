+    for (let v0 = 0; v0 < p; v0++) {
+      const base0 = v0 * rank;
+      for (let v1 = 0; v1 < p; v1++) {
+        const base1 = v1 * rank;
+        const cBase = (v0 * p + v1) * rank;
+        for (let r = 0; r < rank; r++) {
+          combinedDelta[cBase + r] = (dvf0[base0 + r] + dvf1[base1 + r]) % p;
+        }
+      }
+    }
+
+    const outerDeltas = new Int32Array(rank);
+    const currentFreeValues = new Int32Array(k);
+
+    const inner2 = (outerFreeSum: number): void => {
+      // For each (v0, v1) combination
+      for (let v0 = 0; v0 < p; v0++) {
+        const partialSum = outerFreeSum + v0;
+        if (partialSum > bestTotal) break;
+
+        for (let v1 = 0; v1 < p; v1++) {
+          const freeSum = partialSum + v1;
+          if (freeSum > bestTotal) break;
+
+          let total = freeSum;
+          const cBase = (v0 * p + v1) * rank;
+          for (let r = 0; r < rank; r++) {
+            total += pivotContrib[r][(outerDeltas[r] + combinedDelta[cBase + r]) % p];
+          }
+
+          if (total < bestTotal) {
+            bestTotal = total;
+            currentFreeValues[0] = v0;
+            currentFreeValues[1] = v1;
+            bestFreeValues.set(currentFreeValues);
+            for (let r = 0; r < rank; r++) {
+              bestPivotDeltas[r] = (outerDeltas[r] + combinedDelta[cBase + r]) % p;
+            }
+          } else if (total === bestTotal) {
+            currentFreeValues[0] = v0;
+            currentFreeValues[1] = v1;
+            let better = false;
+            for (let j = 0; j < m; j++) {
+              let a: number, b: number;
+              const vt = varType[j];
+              if (vt === 1) {
+                const r = varIdx[j];
+                a = pivotContrib[r][(outerDeltas[r] + combinedDelta[cBase + r]) % p];
+                b = pivotContrib[r][bestPivotDeltas[r]];
+              } else if (vt === 2) {
+                a = currentFreeValues[varIdx[j]];
+                b = bestFreeValues[varIdx[j]];
+              } else {
+                continue;
+              }
+              if (a < b) { better = true; break; }
+              if (a > b) break;
+            }
+            if (better) {
+              bestFreeValues.set(currentFreeValues);
+              for (let r = 0; r < rank; r++) {
+                bestPivotDeltas[r] = (outerDeltas[r] + combinedDelta[cBase + r]) % p;
+              }
+            }
+          }
+        }
+      }
+    }
+
+    const outerEnum = (fi: number, outerFreeSum: number): void => {
+      if (fi === 1) {
+        inner2(outerFreeSum);
+        return;
+      }
+      if (outerFreeSum > bestTotal) return;
+
+      const dvf = deltaByVar[fi];
+      const saved = new Int32Array(rank);
+      saved.set(outerDeltas);
+
+      for (let v = 0; v < p; v++) {
+        currentFreeValues[fi] = v;
+        const vBase = v * rank;
+        for (let r = 0; r < rank; r++) {
+          outerDeltas[r] = (saved[r] + dvf[vBase + r]) % p;
+        }
+        outerEnum(fi - 1, outerFreeSum + v);
+      }
+      outerDeltas.set(saved);
+    }
+
+    if (k === 2) {
+      inner2(0);
+    } else {
+      outerEnum(k - 1, 0);
+    }
+  } else {
+    // k === 1
+    const dvf0 = deltaByVar[0];
+    for (let v = 0; v < p; v++) {
+      const freeSum = v;
+      if (freeSum > bestTotal) break;
+
+      let total = freeSum;
+      const base = v * rank;
+      for (let r = 0; r < rank; r++) {
+        total += pivotContrib[r][dvf0[base + r]];
+      }
+
+      if (total < bestTotal) {
+        bestTotal = total;
+        bestFreeValues[0] = v;
+        for (let r = 0; r < rank; r++) {
+          bestPivotDeltas[r] = dvf0[base + r];
+        }
+      } else if (total === bestTotal) {
+        // Lex check
+        const tmpFree = new Int32Array([v]);
+        let better = false;
+        for (let j = 0; j < m; j++) {
+          let a: number, b: number;
+          const vt = varType[j];
+          if (vt === 1) {
+            const r = varIdx[j];
+            a = pivotContrib[r][dvf0[v * rank + r]];
+            b = pivotContrib[r][bestPivotDeltas[r]];
+          } else if (vt === 2) {
+            a = tmpFree[varIdx[j]];
+            b = bestFreeValues[varIdx[j]];
+          } else {
+            continue;
+          }
+          if (a < b) { better = true; break; }
+          if (a > b) break;
+        }
+        if (better) {
+          bestFreeValues[0] = v;
+          for (let r = 0; r < rank; r++) {
+            bestPivotDeltas[r] = dvf0[base + r];
+          }
+        }
+      }
+    }
+  }
+
+  // Build final solution
+  const result = new Array(m).fill(0);
+  for (let fi = 0; fi < k; fi++) {
+    result[freeVars[fi]] = bestFreeValues[fi];
+  }
+  for (let r = 0; r < rank; r++) {
+    result[pivotCol[r]] = pivotContrib[r][bestPivotDeltas[r]];
+  }
+  return result;
+}
+
+function modInverse(a: number, p: number): number {
+  return modPow(((a % p) + p) % p, p - 2, p);
+}
+
+function modPow(base: number, exp: number, mod: number): number {
+  let result = 1;
+  base = base % mod;
+  while (exp > 0) {
+    if (exp & 1) result = (result * base) % mod;
+    exp >>= 1;
+    base = (base * base) % mod;
+  }
+  return result;
+}
