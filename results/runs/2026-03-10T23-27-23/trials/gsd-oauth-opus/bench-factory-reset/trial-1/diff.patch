] = freeCoeff[fi][r]\n  const coeffFlat = new Int32Array(k * rank);\n  for (let fi = 0; fi < k; fi++) {\n    for (let r = 0; r < rank; r++) {\n      coeffFlat[fi * rank + r] = freeCoeff[fi][r];\n    }\n  }\n\n  // For each free variable fi and value v, precompute the resulting pivot values\n  // when only that one free var is set. This helps us do incremental updates.\n\n  // Approach: iterate with nested loops for the innermost variable.\n  // For the outer free vars, precompute their combined delta.\n  // Then the inner loop just adds one more variable's contribution.\n\n  // Precompute for each free var fi and value v: the delta vector\n  // deltaByVar[fi][v][r] = (v * freeCoeff[fi][r]) % p\n  // Total memory: k * p * rank ≈ 4 * 97 * 40 = 15520 entries, fine.\n  const deltaByVar: number[][][] = [];\n  for (let fi = 0; fi < k; fi++) {\n    const byVal: number[][] = [];\n    for (let v = 0; v < p; v++) {\n      const deltas = new Array(rank);\n      for (let r = 0; r < rank; r++) {\n        deltas[r] = (v * freeCoeff[fi][r]) % p;\n      }\n      byVal.push(deltas);\n    }\n    deltaByVar.push(byVal);\n  }\n\n  // Precompute the pivot sum for each pivot row's possible value\n  // pivotSum for a given set of deltas = sum over r of (basePivotVals[r] + totalDelta[r]) % p\n\n  let bestTotal = Infinity;\n  const bestFreeValues = new Array(k).fill(0);\n\n  // Initialize with all free vars = 0\n  {\n    let total = 0;\n    for (let r = 0; r < rank; r++) total += basePivotVals[r];\n    bestTotal = total;\n  }\n\n  // Recursive enumeration with partial delta tracking\n  const currentDeltas = new Array(rank).fill(0);\n  const freeValues = new Array(k).fill(0);\n\n  function enumerateOpt(fi: number, freeSum: number): void {\n    if (fi === k) {\n      // Compute pivot contribution\n      let total = freeSum;\n      for (let r = 0; r < rank; r++) {\n        total += (basePivotVals[r] + currentDeltas[r]) % p;\n      }\n\n      if (total < bestTotal) {\n        bestTotal = total;