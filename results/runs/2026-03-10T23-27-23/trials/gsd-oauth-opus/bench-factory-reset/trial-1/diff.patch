 {\n  const { target, buttons } = machine;\n  const n = target.length;    // number of lights (equations)\n  const m = buttons.length;   // number of buttons (variables)\n\n  // Build augmented matrix [A | b] where rows=lights, cols=buttons+1\n  // A[i][j] = 1 if button j toggles light i\n  // b[i] = target[i] ? 1 : 0\n  // We use bitmask representation: each row is a bigint with m+1 bits\n\n  const rows: bigint[] = new Array(n);\n  for (let i = 0; i < n; i++) {\n    let row = 0n;\n    for (let j = 0; j < m; j++) {\n      if (buttons[j].includes(i)) {\n        row |= 1n << BigInt(j);\n      }\n    }\n    if (target[i]) {\n      row |= 1n << BigInt(m); // augmented bit\n    }\n    rows[i] = row;\n  }\n\n  // Gaussian elimination over GF(2)\n  // Track which column is the pivot for each row\n  const pivotCol: number[] = new Array(n).fill(-1);\n  let rank = 0;\n\n  for (let col = 0; col < m && rank < n; col++) {\n    // Find pivot row\n    let pivotRow = -1;\n    for (let r = rank; r < n; r++) {\n      if ((rows[r] >> BigInt(col)) & 1n) {\n        pivotRow = r;\n        break;\n      }\n    }\n    if (pivotRow === -1) continue;\n\n    // Swap rows\n    [rows[rank], rows[pivotRow]] = [rows[pivotRow], rows[rank]];\n    pivotCol[rank] = col;\n\n    // Eliminate this column from all other rows\n    for (let r = 0; r < n; r++) {\n      if (r !== rank && (rows[r] >> BigInt(col)) & 1n) {\n        rows[r] ^= rows[rank];\n      }\n    }\n    rank++;\n  }\n\n  // Check for inconsistency: any row with all-zero LHS but nonzero RHS\n  for (let r = rank; r < n; r++) {\n    if ((rows[r] >> BigInt(m)) & 1n) {\n      return null; // no solution\n    }\n  }\n\n  // Extract particular solution and identify free variables\n  const pivotCols = new Set<number>();\n  const solution = new Array(m).fill(0);\n\n  for (let r = 0; r < rank; r++) {\n    const col = pivotCol[r];\n    pivotCols.add(col);\n    solution[col] = Number((rows[r] >> BigInt(m)) & 1n);\n  }\n\n  // Free variables are columns not in pivotCols\n  const freeVars: number[] = [];\n  for (let j = 0; j < m; j++) {\n    if (!pivotCols.has(j)) {\n      freeVars.push(j);\n    }\n  }\n\n  // If no free variables, the solution is unique\n  if (freeVars.length === 0) {\n    const result: number[] = [];\n    for (let j = 0; j < m; j++) {\n      if (solution[j]) result.push(j);\n    }\n    return result;\n  }\n\n  // With free variables, we need to enumerate all 2^k combinations\n  // to find the one with minimum presses, then lex smallest.\n  // k can be up to ~40 in theory, but rank ≤ 40 and m ≤ 40,\n  // so freeVars.length = m - rank. If this is large we need a smarter approach.\n  // For up to ~20 free variables, brute force is fine (2^20 = ~1M).\n  // For larger, we use meet-in-the-middle.\n\n  // Build dependency: for each pivot row r with pivot column c,\n  // solution[c] = b[r] XOR sum of (free vars in that row)\n  // So we need to know which free vars appear in each pivot row.\n\n  // pivotRowForCol[col] = row index where col is the pivot\n  const pivotRowForCol = new Map<number, number>();\n  for (let r = 0; r < rank; r++) {\n    pivotRowForCol.set(pivotCol[r], r);\n  }\n\n  // For each free variable, compute which pivot variables it affects\n  // freeEffect[f] = set of pivot columns that are affected when free var f is toggled\n  const freeEffect: number[][] = new Array(freeVars.length);\n  for (let fi = 0; fi < freeVars.length; fi++) {\n    const fv = freeVars[fi];\n    const affected: number[] = [];\n    for (let r = 0; r < rank; r++) {\n      if ((rows[r] >> BigInt(fv)) & 1n) {\n        affected.push(pivotCol[r]);\n      }\n    }\n    freeEffect[fi] = affected;\n  }\n\n  // Base solution (all free vars = 0)\n  const baseSol = new Array(m).fill(0);\n  for (let r = 0; r < rank; r++) {\n    baseSol[pivotCol[r]] = Number((rows[r] >> BigInt(m)) & 1n);\n  }\n\n  const k = freeVars.length;\n\n  if (k <= 22) {\n    // Direct enumeration\n    let bestPresses = m + 1;\n    let bestIndices: number[] | null = null;\n\n    for (let mask = 0; mask < (1 << k); mask++) {\n      const sol = baseSol.slice();\n      // Apply free variable assignments\n      for (let fi = 0; fi < k; fi++) {\n        if (mask & (1 << fi)) {\n          sol[freeVars[fi]] = 1;\n          for (const pc of freeEffect[fi]) {\n            sol[pc] ^= 1;\n          }\n        }\n      }\n\n      let presses = 0;\n      for (let j = 0; j < m; j++) {\n        presses += sol[j];\n      }\n\n      if (presses < bestPresses) {\n        bestPresses = presses;\n        const indices: number[] = [];\n        for (let j = 0; j < m; j++) {\n          if (sol[j]) indices.push(j);\n        }\n        bestIndices = indices;\n      } else if (presses === bestPresses) {\n        // Check lex order\n        const indices: number[] = [];\n        for (let j = 0; j < m; j++) {\n          if (sol[j]) indices.push(j);\n        }\n        if (bestIndices && lexSmaller(indices, bestIndices)) {\n          bestIndices = indices;\n        }\n      }\n    }\n\n    return bestIndices;\n  } else {\n    // Meet in the middle for large k\n    return meetInTheMiddleToggle(baseSol, freeVars, freeEffect, m);\n  }\n}\n\nfunction lexSmaller(a: number[], b: number[]): boolean {\n  const len = Math.max(a.length, b.length);\n  for (let i = 0; i < len; i++) {\n    const va = i < a.length ? a[i] : Infinity;\n    const vb = i < b.length ? b[i] : Infinity;\n    if (va < vb) return true;\n    if (va > vb) return false;\n  }\n  return false;\n}\n\nfunction meetInTheMiddleToggle(\n  baseSol: number[],\n  freeVars: number[],\n  freeEffect: number[][],\n  m: number\n): number[] | null {\n  const k = freeVars.length;\n  const halfA = Math.floor(k / 2);\n  const halfB = k - halfA;\n\n  // For each half, compute the XOR delta and count change from base solution\n  // We represent solution state as a bitmask of which variables are set\n\n  // Convert baseSol to a bigint bitmask\n  let baseMask = 0n;\n  for (let j = 0; j < m; j++) {\n    if (b