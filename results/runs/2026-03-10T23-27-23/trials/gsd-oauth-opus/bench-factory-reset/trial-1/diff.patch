ion with minimum number of 1s (minimum presses),\n * and among those, the lexicographically smallest set of indices.\n */\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const n = target.length;    // number of lights (equations)\n  const m = buttons.length;   // number of buttons (variables)\n\n  // Build augmented matrix [A | b] where rows=lights, cols=buttons+1\n  // A[i][j] = 1 if button j toggles light i\n  // b[i] = target[i] ? 1 : 0\n  // We use bitmask representation: each row is a bigint with m+1 bits\n\n  const rows: bigint[] = new Array(n);\n  for (let i = 0; i < n; i++) {\n    let row = 0n;\n    for (let j = 0; j < m; j++) {\n      if (buttons[j].includes(i)) {\n        row |= 1n << BigInt(j);\n      }\n    }\n    if (target[i]) {\n      row |= 1n << BigInt(m); // augmented bit\n    }\n    rows[i] = row;\n  }\n\n  // Gaussian elimination over GF(2)\n  // Track which column is the pivot for each row\n  const pivotCol: number[] = new Array(n).fill(-1);\n  let rank = 0;\n\n  for (let col = 0; col < m && rank < n; col++) {\n    // Find pivot row\n    let pivotRow = -1;\n    for (let r = rank; r < n; r++) {\n      if ((rows[r] >> BigInt(col)) & 1n) {\n        pivotRow = r;\n        break;\n      }\n    }\n    if (pivotRow === -1) continue;\n\n    // Swap rows\n    [rows[rank], rows[pivotRow]] = [rows[pivotRow], rows[rank]];\n    pivotCol[rank] = col;\n\n    // Eliminate this column from all other rows\n    for (let r = 0; r < n; r++) {\n      if (r !== rank && (rows[r] >> BigInt(col)) & 1n) {\n        rows[r] ^= rows[rank];\n      }\n    }\n    rank++;\n  }\n\n  // Check for inconsistency: any row with all-zero LHS but nonzero RHS\n  for (let r = rank; r < n; r++) {\n    if ((rows[r] >> BigInt(m)) & 1n) {\n      return null; // no solution\n    }\n  }\n\n  // Extract particular solution and identify free variables\n  const pivotCols = new Set<number>();\n  const solution = new Array(m).fill(0);\n\n  for (let r = 0; r < rank; r++) {\n    const col = pivotCol[r];\n    pivotCols.add(col);\n    solution[col] = Number((rows[r] >> BigInt(m)) & 1n);\n  }\n\n  // Free variables are columns not in pivotCols\n  const freeVars: number[] = [];\n  for (let j = 0; j < m; j++) {\n    if (!pivotCols.has(j)) {\n      freeVars.push(j);\n    }\n  }\n\n  // If no free variables, the solution is unique\n  if (freeVars.length === 0) {\n    const result: number[] = [];\n    for (let j = 0; j < m; j++) {\n      if (solution[j]) result.push(j);\n    }\n    return result;\n  }\n\n  // With free variables, we need to enumerate all 2^k combinations\n  // to find the one with minimum presses, then lex smallest.\n  // k can be up to ~40 in theory, but rank ≤ 40 and m ≤ 40,\n  // so freeVars.length = m - rank. If this is large we need a smarter approach.\n  // For up to ~20 free variables, brute force is fine (2^20 = ~1M).\n  // For larger, we use meet-in-the-middle.\n\n  // Build dependency: for each pivot row r with pivot column c,\n  // solution[c] = b[r] XOR sum of (free vars in that row)\n  // So we need to know which free vars appear in each pivot row.\n\n  // pivotRowForCol[col] = row index where col is the pivot\n  const pivotRowForCol = new Map<number, number>();\n  for (let r = 0; r < rank; r++) {\n    pivotRowForCol.set(pivotCol[r], r);\n  }\n\n  // For each free variable, compute which pivot variables it affects\n  // freeEffect[f] = set of pivot columns that are affected when free var f is toggled\n  const freeEffect: number[][] = new Array(freeVars.length);\n  for (let fi = 0; fi < freeVars.length; fi++) {\n    const fv = freeVars[fi];\n    const affected: number[] = [];\n    for (let r = 0; r < rank; r++) {\n      if ((rows[r] >> BigInt(fv)) & 1n) {\n        affected.push(pivotCol[r]);\n      }\n    }\n    freeEffect[fi] = affected;\n  }\n\n  // Base solution (all free vars = 0)\n  const baseSol = new Array(m).fill(0);\n  for (let r = 0; r < rank; r++) {\n    baseSol[pivotCol[r]] = Number((rows[r] >> BigInt(m)) & 1n);\n  }\n\n  const k = freeVars.length;\n\n  if (k <= 22) {\n    // Direct enumeration\n    let bestPresses = m + 1;\n    let bestIndices: number[] | null = null;\n\n    for (let mask = 0; mask < (1 << k); mask++) {\n      const sol = baseSol.slice();\n      // Apply free variable assignments\n      for (let fi = 0; fi < k; fi++) {\n        if (mask & (1 << fi)) {\n          sol[freeVars[fi]] = 1;\n          for (const pc of freeEffect[fi]) {\n            sol[pc] ^= 1;\n          }\n        }\n      }\n\n      let presses = 0;\n      for (let j = 0; j < m; j++) {\n        presses += sol[j];\n      }\n\n      if (presses < bestPresses) {\n        bestPresses = presses;\n        const indices: number[] = [];\n        for (let j = 0; j < m; j++) {\n          if (sol[j]) indices.push(j);\n        }\n        bestIndices = indices;\n      } else if (presses === bestPresses) {\n        // Check lex order\n        const indices: number[] = [];\n        for (let j = 0; j < m; j++) {\n          if (sol[j]) indices.push(j);\n        }\n        if (bestIndices && lexSmaller(indices, bestIndices)) {\n          bestIndices = indices;\n        }\n      }\n    }\n\n    return bestIndices;\n  } else {\n    // Meet in the middle for large k\n    return meetInTheMiddleToggle(baseSol, freeVars, freeEffect, m);\n  }\n}\n\nfunction lexSmaller(a: number[], b: number[]): boolean {\n  const len = Math.max(a.length, b.length);\n  for (let i = 0; i < len; i++) {\n    const va = i < a.length ? a[i] : Infinity;\n    const vb = i < b.length ? b[i] : Infinity;\n    if (va < vb) return true;\n    if (va > vb) return false;\n  }\n  return false;\n}\n\nfunction meetInTheMiddleToggle(\n  baseSol: number[],\n  freeVars: number[],\n  freeEffect: number[][],\n  m: number\n): number[] | null {\n  const k = freeVars.length;\n  const halfA = Math.floor(k / 2);\n  const halfB = k - halfA;\n\n  // For each half, compute the XOR delta and count change from base solution\n  // We represent solution state as a bitmask of which variables are set\n\n  // Convert baseSol to a bigint bitmask\n  let baseMask = 0n;\n  for (let j = 0; j < m; j++) {\n    if (baseSol[j]) baseMask |= 1n << BigInt(j);\n  }\n\n  // Precompute: for each free variable, compute the XOR mask it applies to the solution\n  const freeMask: bigint[] = new Array(k);\n  for (let fi = 0; fi < k; fi++) {\n    let mask = 1n << BigInt(freeVars[fi]); // toggle the free var itself\n    for (const pc of freeEffect[fi]) {\n      mask |= 1n << BigInt(pc); // toggle affected pivot vars\n    }\n    freeMask[fi] = mask;\n  }\n\n  // First half: enumerate all 2^halfA combinations\n  // Store: Map from solution mask -> {presses, freeAssignment}\n  // We want minimum presses overall, so store the delta mask\n\n  type HalfEntry = { deltaMask: bigint; presses: number; indices: number[] };\n\n  // For the first half, compute all possible delta masks\n  const firstHalf = new Map<string, HalfEntry>();\n\n  for (let mask = 0; mask < (1 << halfA); mask++) {\n    let delta = 0n;\n    for (let fi = 0; fi < halfA; fi++) {\n      if (mask & (1 << fi)) {\n        delta ^= freeMask[fi];\n      }\n    }\n\n    const solMask = baseMask ^ delta;\n    let presses = 0;\n    const indices: number[] = [];\n    for (let j = 0; j < m; j++) {\n      if ((solMask >> BigInt(j)) & 1n) {\n        presses++;\n        indices.push(j);\n      }\n    }\n\n    // We need to combine with second half, so store delta\n    const key = delta.toString();\n    const existing = firstHalf.get(key);\n    if (!existing || presses < existing.presses ||\n        (presses === existing.presses && lexSmaller(indices, existing.indices))) {\n      firstHalf.set(key, { deltaMask: delta, presses, indices });\n    }\n  }\n\n  // Second half: enumerate and combine\n  let bestPresses = m + 1;\n  let bestIndices: number[] | null = null;\n\n  for (let mask = 0; mask < (1 << halfB); mask++) {\n    let delta = 0n;\n    for (let fi = 0; fi < halfB; fi++) {\n      if (mask & (1 << fi)) {\n        delta ^= freeMask[halfA + fi];\n      }\n    }\n\n    // The combined solution mask = baseMask ^ deltaA ^ deltaB\n    // We want to find deltaA from first half that, combined with deltaB,\n    // gives minimum presses.\n    // Combined mask = baseMask ^ deltaA ^ delta\n    // We need to try all first-half entries (can't hash-match for min presses)\n\n    // This is O(2^halfA * 2^halfB) = O(2^k) which doesn't help.\n    // For meet-in-the-middle to work, we need a different approach.\n\n    // Actually for this problem with up to 40 vars, rank is at most 40,\n    // so free vars = m - rank ≤ 40 - 0 = 40. But in practice rank is usually\n    // close to min(m, n) so free vars should be small.\n\n    // Let's just do the combination directly since we stored all first-half entries\n    for (const [, entry] of firstHalf) {\n      const combinedMask = baseMask ^ entry.deltaMask ^ delta;\n      let presses = 0;\n      const indices: number[] = [];\n      for (let j = 0; j < m; j++) {\n        if ((combinedMask >> BigInt(j)) & 1n) {\n          presses++;\n          indices.push(j);\n        }\n      }\n      if (presses < bestPresses ||\n          (presses === bestPresses && bestIndices && lexSmaller(indices, bestIndices))) {\n        bestPresses = presses;\n        bestIndices = indices;\n      }\n    }\n  }\n\n  return bestIndices;\n}\n\n/**\n * Solve counter puzzle over GF(p) using Gaussian elimination.\n * System: for each counter i: sum of x_j (for buttons j affecting counter i) ≡ target[i] (mod p)\n * where x_j ∈ {0, ..., p-1} is the number of times button j is pressed.\n */\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const n = lights.length;    // number of counters (equations)\n  const m = buttons.length;   // number of buttons (variables)\n  const p = modulus;\n\n  // Build augmented matrix [A | b] over GF(p)\n  // A[i][j] = 1 if button j affects counter i, else 0\n  // b[i] = lights[i]\n  const matrix: number[][] = [];\n  for (let i = 0; i < n; i++) {\n    const row = new Array(m + 1).fill(0);\n    for (let j = 0; j < m; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    row[m] = lights[i] % p;\n    matrix.push(row);\n  }\n\n  // Modular inverse using Fermat's little theorem (p is prime)\n  function modInverse(a: number, mod: number): number {\n    return modPow(((a % mod) + mod) % mod, mod - 2, mod);\n  }\n\n  function modPow(base: number, exp: number, mod: number): number {\n    let result = 1;\n    base = base % mod;\n    while (exp > 0) {\n      if (exp & 1) result = (result * base) % mod;\n      exp >>= 1;\n      base = (base * base) % mod;\n    }\n    return result;\n  }\n\n  // Gaussian elimination over GF(p)\n  const pivotCol: number[] = [];\n  let rank = 0;\n\n  for (let col = 0; col < m && rank < n; col++) {\n    // Find pivot row\n    let pivotRow = -1;\n    for (let r = rank; r < n; r++) {\n      if (matrix[r][col] !== 0) {\n        pivotRow = r;\n        break;\n      }\n    }\n    if (pivotRow === -1) continue;\n\n    // Swap rows\n    [matrix[rank], matrix[pivotRow]] = [matrix[pivotRow], matrix[rank]];\n    pivotCol.push(col);\n\n    // Scale pivot row so that pivot element = 1\n    const inv = modInverse(matrix[rank][col], p);\n    for (let c = 0; c <= m; c++) {\n      matrix[rank][c] = (matrix[rank][c] * inv) % p;\n    }\n\n    // Eliminate this column from all other rows\n    for (let r = 0; r < n; r++) {\n      if (r !== rank && matrix[r][col] !== 0) {\n        const factor = matrix[r][col];\n        for (let c = 0; c <= m; c++) {\n          matrix[r][c] = ((matrix[r][c] - factor * matrix[rank][c]) % p + p) % p;\n        }\n      }\n    }\n    rank++;\n  }\n\n  // Check for inconsistency\n  for (let r = rank; r < n; r++) {\n    if (matrix[r][m] !== 0) {\n      return null;\n    }\n  }\n\n  // Identify pivot and free variables\n  const pivotColSet = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let j = 0; j < m; j++) {\n    if (!pivotColSet.has(j)) {\n      freeVars.push(j);\n    }\n  }\n\n  // Map from pivot column to its row\n  const colToRow = new Map<number, number>();\n  for (let r = 0; r < rank; r++) {\n    colToRow.set(pivotCol[r], r);\n  }\n\n  // Base solution (all free vars = 0)\n  const baseSol = new Array(m).fill(0);\n  for (let r = 0; r < rank; r++) {\n    baseSol[pivotCol[r]] = matrix[r][m];\n  }\n\n  const k = freeVars.length;\n\n  if (k === 0) {\n    // Unique solution\n    return baseSol;\n  }\n\n  // For each free variable, compute its effect on pivot variables\n  // When free var freeVars[fi] is set to value v, for pivot var at col c (row r):\n  //   sol[c] = baseSol[c] - v * matrix[r][freeVars[fi]] (mod p)\n  // The coefficient of free var fi on pivot var at row r is -matrix[r][freeVars[fi]] mod p\n  const freeCoeff: number[][] = new Array(k); // freeCoeff[fi][r] = coefficient\n  for (let fi = 0; fi < k; fi++) {\n    const fv = freeVars[fi];\n    freeCoeff[fi] = new Array(rank);\n    for (let r = 0; r < rank; r++) {\n      freeCoeff[fi][r] = (((-matrix[r][fv]) % p) + p) % p;\n    }\n  }\n\n  // We need to find free var values (each 0..p-1) that minimize total presses\n  // and break ties lexicographically.\n  // Total possibilities: p^k which can be huge.\n\n  if (k <= 1 || (k === 2 && p <= 97) || (k <= 3 && p <= 10) || Math.pow(p, k) <= 500000) {\n    // Direct enumeration\n    return enumerateCounterSolutions(baseSol, freeVars, freeCoeff, pivotCol, rank, m, p, k);\n  } else {\n    // Meet in the middle\n    return meetInTheMiddleCounter(baseSol, freeVars, freeCoeff, pivotCol, rank, m, p, k);\n  }\n}\n\nfunction enumerateCounterSolutions(\n  baseSol: number[],\n  freeVars: number[],\n  freeCoeff: number[][],\n  pivotCol: number[],\n  rank: number,\n  m: number,\n  p: number,\n  k: number\n): number[] | null {\n  let bestTotal = Infinity;\n  let bestSol: number[] | null =