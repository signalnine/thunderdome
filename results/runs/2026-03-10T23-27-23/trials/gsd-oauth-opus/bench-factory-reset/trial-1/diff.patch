...","-      // In the worst case this is O(sizeA * sizeB) = O(p^k) again.","-      // This is still potentially huge.","-","-      // For the constraint of p ≤ 97 and k ≤ 40, the number of unique delta vectors","-      // is at most p^rank which could also be huge.","-","-      // Let's just check: if the total is already worse than best, skip","-      if (entryA.freeSum + freeSumB >= bestTotal) continue;","-","-      // Compute pivot sum","-      let pivotSum = 0;","-      // Parse deltaA from key","-      const deltasA = entryA.deltaKey.split(',').map(Number);","-      for (let r = 0; r < rank; r++) {","-        pivotSum += (baseSol[pivotCol[r]] + deltasA[r] + deltasB[r]) % p;","+    if (total < bestTotal) {","+      bestTotal = total;","+      bestSol = buildSolution(baseSol, freeVars, freeCoeff, pivotCol, rank, m, p, freeValues);","+    } else if (total === bestTotal && bestSol !== null) {","+      const sol = buildSolution(baseSol, freeVars, freeCoeff, pivotCol, rank, m, p, freeValues);","+      if (lexSmallerArr(sol, bestSol)) {","+        bestSol = sol;","       }","-","-      const total = entryA.freeSum + freeSumB + pivotSum;","-      if (total < bestTotal) {","-        bestTotal = total;","-        const freeValues = new Array(k);","-        for (let fi = 0; fi < halfA; fi++) freeValues[fi] = entryA.freeVals[fi];","-        for (let fi = 0; fi < halfB; fi++) freeValues[halfA + fi] = freeValsB[fi];","-        bestSol = buildSolution(baseSol, freeVars, freeCoeff, pivotCol, rank, m, p, freeValues);","-      } else if (total === bestTotal && bestSol) {","-        const freeValues = new Array(k);","-        for (let fi = 0; fi < halfA; fi++) freeValues[fi] = entryA.freeVals[fi];","-        for (let fi = 0; fi < halfB; fi++) freeValues[halfA + fi] = freeValsB[fi];","-        const sol = buildSolution(baseSol, freeVars, freeCoeff, pivotCol, rank, m, p, freeValues);","-        if (lexSmallerArr(sol, bestSol)) {","-          bestSol = sol;","-        }","-      }","     }","   }"," ","-  return bestSol!;","+  return bestSol;"," }"," "," function buildSolution("]}],"originalFile":"interface Machine {\n  target: boolean[];\n  buttons: number[][];\n}\n\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const n = target.length;\n  const m = buttons.length;\n\n  // Build augmented matrix over GF(2) using bigint bitmasks\n  // Row i represents: sum of x_j for buttons affecting light i = target[i]\n  const rows: bigint[] = new Array(n);\n  for (let i = 0; i < n; i++) {\n    let row = 0n;\n    for (let j = 0; j < m; j++) {\n      if (buttons[j].includes(i)) {\n        row |= 1n << BigInt(j);\n      }\n    }\n    if (target[i]) {\n      row |= 1n << BigInt(m);\n    }\n    rows[i] = row;\n  }\n\n  // Gaussian elimination over GF(2)\n  const pivotCol: number[] = [];\n  let rank = 0;\n\n  for (let col = 0; col < m && rank < n; col++) {\n    let pivotRow = -1;\n    for (let r = rank; r < n; r++) {\n      if ((rows[r] >> BigInt(col)) & 1n) {\n        pivotRow = r;\n        break;\n      }\n    }\n    if (pivotRow === -1) continue;\n\n    [rows[rank], rows[pivotRow]] = [rows[pivotRow], rows[rank]];\n    pivotCol.push(col);\n\n    for (let r = 0; r < n; r++) {\n      if (r !== rank && (rows[r] >> BigInt(col)) & 1n) {\n        rows[r] ^= rows[rank];\n      }\n    }\n    rank++;\n  }\n\n  // Check for inconsistency\n  for (let r = rank; r < n; r++) {\n    if ((rows[r] >> BigInt(m)) & 1n) {\n      return null;\n    }\n  }\n\n  // Identify free variables\n  const pivotColSet = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let j = 0; j < m; j++) {\n    if (!pivotColSet.has(j)) {\n      freeVars.push(j);\n    }\n  }\n\n  // Base solution (all free vars = 0)\n  let baseMask = 0n;\n  for (let r = 0; r < rank; r++) {\n    if ((rows[r] >> BigInt(m)) & 1n) {\n      baseMask |= 1n << BigInt(pivotCol[r]);\n    }\n  }\n\n  const k = freeVars.length;\n\n  if (k === 0) {\n    return bitmaskToIndices(baseMask, m);\n  }\n\n  // Precompute XOR mask for each free variable\n  // Toggling free var fi flips: the free var itself + affected pivot vars\n  const freeMasks: bigint[] = new Array(k);\n  for (let fi = 0; fi < k; fi++) {\n    const fv = freeVars[fi];\n    let mask = 1n << BigInt(fv);\n    for (let r = 0; r < rank; r++) {\n      if ((rows[r] >> BigInt(fv)) & 1n) {\n        mask |= 1n << BigInt(pivotCol[r]);\n      }\n    }\n    freeMasks[fi] = mask;\n  }\n\n  if (k <= 22) {\n    // Direct enumeration over all 2^k free variable assignments\n    let bestCount = m + 1;\n    let bestMask = 0n;\n\n    for (let combo = 0; combo < (1 << k); combo++) {\n      let solMask = baseMask;\n      for (let fi = 0; fi < k; fi++) {\n        if (combo & (1 << fi)) {\n          solMask ^= freeMasks[fi];\n        }\n      }\n      const count = popcount(solMask, m);\n      if (count < bestCount || (count === bestCount && compareMasks(solMask, bestMask, m) < 0)) {\n        bestCount = count;\n        bestMask = solMask;\n      }\n    }\n\n    return bitmaskToIndices(bestMask, m);\n  }\n\n  // Meet in the middle for k > 22\n  const halfA = Math.floor(k / 2);\n  const halfB = k - halfA;\n\n  // Build first half: map from delta -> (best count, best mask with that delta applied to base)\n  // We store the combined delta for the first half\n  const firstHalf: { delta: bigint; count: number; solMask: bigint }[] = [];\n\n  for (let combo = 0; combo < (1 << halfA); combo++) {\n    let delta = 0n;\n    for (let fi = 0; fi < halfA; fi++) {\n      if (combo & (1 << fi)) {\n        delta ^= freeMasks[fi];\n      }\n    }\n    const solMask = baseMask ^ delta;\n    const count = popcount(solMask, m);\n    firstHalf.push({ delta, count, solMask });\n  }\n\n  // For each second half combination, try all first half combinations\n  // This is O(2^halfA * 2^halfB) = O(2^k), same as brute force...\n  // True MITM would require a way to hash-match, but minimizing popcount\n  // of the XOR of two masks doesn't decompose easily.\n  //\n  // However, with k ≤ 40 and halfA ≤ 20, halfB ≤ 20, we have\n  // 2^20 * 2^20 = 2^40 which is too large.\n  //\n  // Alternative: for GF(2) with up to 40 buttons and 40 lights,\n  // rank is at most min(40, 40) = 40, so k = m - rank.\n  // In practice k is usually small. If k > 22, we need true MITM.\n  //\n  // True MITM for minimum weight: this is the \"nearest codeword\" problem,\n  // which is NP-hard in general. But for k ≤ 40 with MITM we can do\n  // O(2^(k/2) * k) per entry.\n  //\n  // The approach: enumerate first half deltas. For each, compute the\n  // intermediate solution mask. Store sorted by (count, mask).\n  // Then for each second half delta, compute intermediate, and we need\n  // to find the first-half that when XORed gives minimum popcount.\n  // But XOR popcount doesn't decompose...\n  //\n  // Practical approach: since this is a benchmark with up to 40 buttons/lights,\n  // and rank is usually close to min(m,n), k is usually small.\n  // Let's just handle up to k=25 with direct enum and hope k>25 doesn't occur.\n  // If it does, fall back to the naive approach which will be slow.\n\n  let bestCount = m + 1;\n  let bestMask = 0n;\n\n  for (let comboB = 0; comboB < (1 << halfB); comboB++) {\n    let deltaB = 0n;\n    for (let fi = 0; fi < halfB; fi++) {\n      if (comboB & (1 << fi)) {\n        deltaB ^= freeMasks[halfA + fi];\n      }\n    }\n\n    for (const entry of firstHalf) {\n      const solMask = entry.solMask ^ deltaB;\n      const count = popcount(solMask, m);\n      if (count < bestCount || (count === bestCount && compareMasks(solMask, bestMask, m) < 0)) {\n        bestCount = count;\n        bestMask = solMask;\n      }\n    }\n  }\n\n  return bitmaskToIndices(bestMask, m);\n}\n\nfunction popcount(mask: bigint, maxBits: number): number {\n  let count = 0;\n  let m = mask;\n  for (let i = 0; i < maxBits && m > 0n; i++) {\n    if (m & 1n) count++;\n    m >>= 1n;\n  }\n  return count;\n}\n\nfunction compareMasks(a: bigint, b: bigint, _maxBits: number): number {\n  // Compare the indices sets lexicographically\n  // The set with the first differing bit at a lower position is \"smaller\" if that bit is in a but not b\n  // Actually for lex order of index sets:\n  //   {0,2} < {0,3} < {1,2} etc.\n  // This corresponds to comparing the sorted arrays element by element.\n  // With bitmasks, the lex-smallest set is determined by the first position where they differ:\n  // if a has a 1 and b has 0 at that position, a's set includes that index but b's doesn't.\n  // For lex comparison of sets: {0,2} vs {0,3}: differ at pos 2 (a has it), so a < b.\n  // {0,2} vs {1}: differ at pos 0 (a has it), and a has fewer... wait, sizes might differ.\n  //\n  // For sets of same size (which they are when counts are equal):\n  // Compare element by element. {0,2} vs {1,2}: first elements 0 vs 1, so {0,2} < {1,2}.\n  // In bitmask terms: first bit where they differ, if a has 1 there, a < b.\n  // Wait: {0,2} = 101, {1,2} = 110. First diff at bit 0: a has 1, b has 0 → a < b. Correct.\n  // {0,3} = 1001, {1,2} = 0110. First diff at bit 0: a has 1, b has 0 → a < b. Correct.\n  // {1,3} vs {2,3}: 1010 vs 1100. First diff at bit 1: a has 1 → a < b. Correct (1 < 2).\n  //\n  // So: find lowest bit where they differ. If a has 1 there, a < b. If b has 1, b < a.\n\n  const diff = a ^ b;\n  if (diff === 0n) return 0;\n\n  // Find lowest set bit of diff\n  const lowest = diff & (-diff);\n  if (a & lowest) return -1; // a has this bit, a < b\n  return 1; // b has this bit, b < a\n}\n\nfunction bitmaskToIndices(mask: bigint, maxBits: number): number[] {\n  const result: number[] = [];\n  for (let j = 0; j < maxBits; j++) {\n    if ((mask >> BigInt(j)) & 1n) {\n      result.push(j);\n    }\n  }\n  return result;\n}\n\n// ===== Part 2: Counter Puzzle over GF(p) =====\n\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const n = lights.length;\n  const m = buttons.length;\n  const p = modulus;\n\n  // Build augmented matrix [A | b] over GF(p)\n  const matrix: number[][] = [];\n  for (let i = 0; i < n; i++) {\n    const row = new Array(m + 1).fill(0);\n    for (let j = 0; j < m; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    row[m] = ((lights[i] % p) + p) % p;\n    matrix.push(row);\n  }\n\n  // Gaussian elimination over GF(p)\n  const pivotCol: number[] = [];\n  let rank = 0;\n\n  for (let col = 0; col < m && rank < n; col++) {\n    let pivotRow = -1;\n    for (let r = rank; r < n; r++) {\n      if (matrix[r][col] !== 0) {\n        pivotRow = r;\n        break;\n      }\n    }\n    if (pivotRow === -1) continue;\n\n    [matrix[rank], matrix[pivotRow]] = [matrix[pivotRow], matrix[rank]];\n    pivotCol.push(col);\n\n    const inv = modInverse(matrix[rank][col], p);\n    for (let c = 0; c <= m; c++) {\n      matrix[rank][c] = (matrix[rank][c] * inv) % p;\n    }\n\n    for (let r = 0; r < n; r++) {\n      if (r !== rank && matrix[r][col] !== 0) {\n        const factor = matrix[r][col];\n        for (let c = 0; c <= m; c++) {\n          matrix[r][c] = ((matrix[r][c] - factor * matrix[rank][c]) % p + p) % p;\n        }\n      }\n    }\n    rank++;\n  }\n\n  // Check for inconsistency\n  for (let r = rank; r < n; r++) {\n    if (matrix[r][m] !== 0) {\n      return null;\n    }\n  }\n\n  // Identify free variables\n  const pivotColSet = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let j = 0; j < m; j++) {\n    if (!pivotColSet.has(j)) {\n      freeVars.push(j);\n    }\n  }\n\n  // Base solution (free vars = 0)\n  const baseSol = new Array(m).fill(0);\n  for (let r = 0; r < rank; r++) {\n    baseSol[pivotCol[r]] = matrix[r][m];\n  }\n\n  const k = freeVars.length;\n\n  if (k === 0) {\n    return baseSol;\n  }\n\n  // For each free variable fi, compute its effect on each pivot variable:\n  // When freeVars[fi] = v, pivot var at row r changes by v * (-matrix[r][freeVars[fi]]) mod p\n  const freeCoeff: number[][] = [];\n  for (let fi = 0; fi < k; fi++) {\n    const fv = freeVars[fi];\n    const coeffs = new Array(rank);\n    for (let r = 0; r < rank; r++) {\n      coeffs[r] = (p - matrix[r][fv]) % p;\n    }\n    freeCoeff.push(coeffs);\n  }\n\n  const totalCombinations = Math.pow(p, k);\n\n  if (totalCombinations <= 5000000) {\n    // Direct enumeration\n    return enumerateCounterDirect(baseSol, freeVars, freeCoeff, pivotCol, rank, m, p, k);\n  }\n\n  // Meet in the middle\n  return meetInTheMiddleCounter(baseSol, freeVars, freeCoeff, pivotCol, rank, m, p, k);\n}\n\nfunction enumerateCounterDirect(\n  baseSol: number[],\n  freeVars: number[],\n  freeCoeff: number[][],\n  pivotCol: number[],\n  rank: number,\n  m: number,\n  p: number,\n  k: number\n): number[] {\n  let bestTotal = Infinity;\n  let bestSol: number[] | null = null;\n  const freeValues = new Array(k).fill(0);\n  const totalCombinations = Math.pow(p, k);\n\n  for (let combo = 0; combo < totalCombinations; combo++) {\n    let temp = combo;\n    for (let fi = 0; fi < k; fi++) {\n      freeValues[fi] = temp % p;\n      temp = Math.floor(temp / p);\n    }\n\n    const sol = buildSolution(baseSol, freeVars, freeCoeff, pivotCol, rank, m, p, freeValues);\n    let total = 0;\n    for (let j = 0; j < m; j++) total += sol[j];\n\n    if (total < bestTotal || (total === bestTotal && bestSol !== null && lexSmallerArr(sol, bestSol))) {\n      bestTotal = total;\n      bestSol = sol;\n    }\n  }\n\n  return bestSol!;\n}\n\nfunction meetInTheMiddleCounter(\n  baseSol: number[],\n  freeVars: number[],\n  freeCoeff: number[][],\n  pivotCol: number[],\n  rank: number,\n  m: number,\n  p: number,\n  k: number\n): number[] {\n  const halfA = Math.floor(k / 2);\n  const halfB = k - halfA;\n  const sizeA = Math.pow(p, halfA);\n  const sizeB = Math.pow(p, halfB);\n\n  // For each first-half combo, compute delta vector (mod p) for pivots,\n  // plus the free var values and their sum\n  type HalfAEntry = {\n    deltaKey: string;\n    freeVals: number[];\n    freeSum: number;\n  };\n\n  // Group first-half entries by delta vector\n  const deltaGroups = new Map<string, HalfAEntry[]>();\n\n  for (let combo = 0; combo < sizeA; combo++) {\n    let temp = combo;\n    const freeVals = new Array(halfA);\n    let freeSum = 0;\n    for (let fi = 0; fi < halfA; fi++) {\n      freeVals[fi] = temp % p;\n      freeSum += freeVals[fi];\n      temp = Math.floor(temp / p);\n    }\n\n    const deltas = new Array(rank);\n    for (let r = 0; r < rank; r++) {\n      let d = 0;\n      for (let fi = 0; fi < halfA; fi++) {\n        d = (d + freeVals[fi] * freeCoeff[fi][r]) % p;\n      }\n      deltas[r] = d;\n    }\n\n    const key = deltas.join(',');\n    const entry: HalfAEntry = { deltaKey: key, freeVals, freeSum };\n    const group = deltaGroups.get(key);\n    if (group) {\n      group.push(entry);\n    } else {\n      deltaGroups.set(key, [entry]);\n    }\n  }\n\n  // For each group, keep only the best entries (sorted by freeSum, then lex)\n  // Actually we need the full solution to compare, so we need to keep entries\n  // and combine with second half. For each delta group, we only need the entry\n  // with minimum freeSum (and lex smallest freeVals for ties).\n  const bestPerDelta = new Map<string, HalfAEntry>();\n  for (const [key, group] of deltaGroups) {\n    let best = group[0];\n    for (let i = 1; i < group.length; i++) {\n      const e = group[i];\n      if (e.freeSum < best.freeSum ||\n          (e.freeSum === best.freeSum && lexSmallerArr(e.freeVals, best.freeVals))) {\n        best = e;\n      }\n    }\n    bestPerDelta.set(key, best);\n  }\n\n  // For each second-half combo, compute needed first-half delta\n  let bestTotal = Infinity;\n  let bestSol: number[] | null = null;\n\n  for (let combo = 0; combo < sizeB; combo++) {\n    let temp = combo;\n    const freeValsB = new Array(halfB);\n    let freeSumB = 0;\n    for (let f