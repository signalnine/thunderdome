\n   585→  // For each combination of first half, compute contribution to pivot vars\n   586→  // Store as map from \"pivot deltas\" -> best (total, freeValues) for that configuration\n   587→\n   588→  // The key insight: the total presses = sum of all variable values.\n   589→  // Each pivot var value depends linearly on the free vars.\n   590→  // We need to find the combination that minimizes the total.\n   591→\n   592→  // For meet in the middle, we compute all first-half contributions to pivots,\n   593→  // then for each second-half, find the best first-half partner.\n   594→\n   595→  // Pivot var r value = baseSol[pivotCol[r]] + sum_fi(freeValues[fi] * freeCoeff[fi][r]) mod p\n   596→  // Let's split: delta_r = sum over first_half + sum over second_half\n   597→\n   598→  // For each first-half combo, record the delta vector and the free var values + their sum\n   599→  type Entry = { deltas: number[]; freeVals: number[]; totalFreeA: number };\n   600→\n   601→  const firstHalfEntries: Entry[] = [];\n   602→  const totalA = Math.pow(p, halfA);\n   603→\n   604→  for (let combo = 0; combo < totalA; combo++) {\n   605→    let temp = combo;\n   606→    const freeVals = new Array(halfA);\n   607→    let totalFreeA = 0;\n   608→    for (let fi = 0; fi < halfA; fi++) {\n   609→      freeVals[fi] = temp % p;\n   610→      totalFreeA += freeVals[fi];\n   611→      temp = Math.floor(temp / p);\n   612→    }\n   613→\n   614→    const deltas = new Array(rank).fill(0);\n   615→    for (let r = 0; r < rank; r++) {\n   616→      for (let fi = 0; fi < halfA; fi++) {\n   617→        deltas[r] = (deltas[r] + freeVals[fi] * freeCoeff[fi][r]) % p;\n   618→      }\n   619→    }\n   620→\n   621→    firstHalfEntries.push({ deltas, freeVals, totalFreeA });\n   622→  }\n   623→\n   624→  // Group first-half entries by their delta vectors for efficient lookup\n   625→  const deltaMap = new Map<string, Entry[]>();\n   626→  for (const entry of firstHalfEntries) {\n   627→    const key = entry.deltas.join(',');\n   628→    const list = deltaMap.get(key) ?? [];\n   629→    list.push(entry);\n   630→    deltaMap.set(key, list);\n   631→  }\n   632→\n   633→  // For each second-half combo, compute required first-half deltas for each possible total\n   634→  let bestTotal = Infinity;\n   635→  let bestSol: number[] | null = null;\n   636→\n   637→  const totalB = Math.pow(p, halfB);\n   638→\n   639→  for (let combo = 0; combo < totalB; combo++) {\n   640→    let temp = combo;\n   641→    const freeValsB = new Array(halfB);\n   642→    let totalFreeB = 0;\n   643→    for (let fi = 0; fi < halfB; fi++) {\n   644→      freeValsB[fi] = temp % p;\n   645→      totalFreeB += freeValsB[fi];\n   646→      temp = Math.floor(temp / p);\n   647→    }\n   648→\n   649→    const deltasB = new Array(rank).fill(0);\n   650→    for (let r = 0; r < rank; r++) {\n   651→      for (let fi = 0; fi < halfB; fi++) {\n   652→        deltasB[r] = (deltasB[r] + freeValsB[fi] * freeCoeff[halfA + fi][r]) % p;\n   653→      }\n   654→    }\n   655→\n   656→    // For each first-half entry, compute total and check\n   657→    // We can't efficiently hash-match for minimum, so we'd need to iterate\n   658→    // This is still O(p^halfA * p^halfB) = O(p^k), same as brute force\n   659→    //\n   660→    // Better approach: for each second-half combo, compute the full pivot values\n   661→    // and their contribution to total, then find the first-half that gives minimum\n   662→    // additional contribution.\n   663→    //\n   664→    // Actually, let me take a different approach. For p^k <= some reasonable limit,\n   665→    // just enumerate directly. For larger cases, we may need a smarter algorithm.\n   666→    // In practice, with m,n ≤ 40 and p ≤ 97, rank is at most 40, so k = m - rank.\n   667→    // If m = 40 and rank = 38, k = 2, p^k = 97^2 = 9409 - easy.\n   668→    // If rank = 37, k = 3, p^k = 97^3 ≈ 900K - still manageable.\n   669→    // Worst case: rank = 0, 