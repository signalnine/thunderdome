+    currentMask ^= freeMasks[fi];
+    const count = popcountBig(currentMask);
+    if (count < bestCount || (count === bestCount && compareMaskLex(currentMask, bestMask) < 0)) {
+      bestCount = count;
+      bestMask = currentMask;
+    }
+  }
+
+  return bitmaskToIndices(bestMask, m);
+}
+
+function popcountBig(n: bigint): number {
+  let count = 0;
+  let v = n;
+  while (v > 0n) {
+    v &= v - 1n;
+    count++;
+  }
+  return count;
