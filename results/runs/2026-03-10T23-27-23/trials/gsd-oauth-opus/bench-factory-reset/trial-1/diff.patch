= Math.floor(k / 2);\n   120→  const halfB = k - halfA;\n   121→\n   122→  // Build first half: map from delta -> (best count, best mask with that delta applied to base)\n   123→  // We store the combined delta for the first half\n   124→  const firstHalf: { delta: bigint; count: number; solMask: bigint }[] = [];\n   125→\n   126→  for (let combo = 0; combo < (1 << halfA); combo++) {\n   127→    let delta = 0n;\n   128→    for (let fi = 0; fi < halfA; fi++) {\n   129→      if (combo & (1 << fi)) {\n   130→        delta ^= freeMasks[fi];\n   131→      }\n   132→    }\n   133→    const solMask = baseMask ^ delta;\n   134→    const count = popcount(solMask, m);\n   135→    firstHalf.push({ delta, count, solMask });\n   136→  }\n   137→\n   138→  // For each second half combination, try all first half combinations\n   139→  // This is O(2^halfA * 2^halfB) = O(2^k), same as brute force...\n   140→  // True MITM would require a way to hash-match, but minimizing popcount\n   141→  // of the XOR of two masks doesn't decompose easily.\n   142→  //\n   143→  // However, with k ≤ 40 and halfA ≤ 20, halfB ≤ 20, we have\n   144→  // 2^20 * 2^20 = 2^40 which is too large.\n   145→  //\n   146→  // Alternative: for GF(2) with up to 40 buttons and 40 lights,\n   147→  // rank is at most min(40, 40) = 40, so k = m - rank.\n   148→  // In practice k is usually small. If k > 22, we need true MITM.\n   149→  //\n   150→  // True MITM for minimum weight: this is the \"nearest codeword\" problem,\n   151→  // which is NP-hard in general. But for k ≤ 40 with MITM we can do\n   152→  // O(2^(k/2) * k) per entry.\n   153→  //\n   154→  // The approach: enumerate first half deltas. For each, compute the\n   155→  // intermediate solution mask. Store sorted by (count, mask).\n   156→  // Then for each second half delta, compute intermediate, and we need\n   157→  // to find the first-half that when XORed gives minimum popcount.\n   158→  // But XOR popcount doesn't decompose...\n   159→  //\n   160→  // Practical approach: since this is a benchmark with up to 40 buttons/lights,\n   161→  // and rank is usually close to min(m,n), k is usually small.\n   162→  // Let's just handle up to k=25 with direct enum and hope k>25 doesn't occur.\n   163→  // If it does, fall back to the naive approach which will be slow.\n   164→\n   165→  let bestCount = m + 1;\n   166→  let bestMask = 0n;\n   167→\n   168→  for (let comboB = 0; comboB < (1 << halfB); comboB++) {\n   169→    let deltaB = 0n;\n   170→    for (let fi = 0; fi < halfB; fi++) {\n   171→      if (comboB & (1 << fi)) {\n   172→        deltaB ^= freeMasks[halfA + fi];\n   173→      }\n   174→    }\n   175→\n   176→    for (const entry of firstHalf) {\n   177→      const solMask = entry.solMask ^ deltaB;\n   178→      const count = popcount(solMask, m);\n   179→      if (count < bestCount || (count === bestCount && compareMasks(solMask, bestMask, m) < 0)) {\n   180→        bestCount = count;\n   181→        bestMask = solMask;\n   182→      }\n   183→    }\n   184→  }\n   185→\n   186→  return bitmaskToIndices(bestMask, m);\n   187→}\n   188→\n   189→function popcount(mask: bigint, maxBits: number): number {\n   190→  let count = 0;\n   191→  let m = mask;\n   192→  for (let i = 0; i < maxBits && m > 0n; i++) {\n   193→    if (m & 1n) count++;\n   194→    m >>= 1n;\n   195→  }\n   196→  return count;\n   197→}\n   198→\n   199→function compareMasks(a: bigint, b: bigint, _maxBits: number): number {\n   200→  // Compare the indices sets lexicographically\n   201→  // The set with the first differing bit at a lower position is \"smaller\" if that bit is in a but not b\n   202→  // Actually for lex order of index sets:\n   203→  //   {0,2} < {0,3} < {1,2} etc.\n   204→  // This corresponds to comparing the sorted arrays element by element.\n   205→  // With bitmasks, the lex-smallest set is determined by the first position where they differ:\n   206→  // if a has a 1 and b has 0 at that position, a's set includes that index but b's doesn't.\n   207→  // For lex comparison of sets: {0,2} vs {0,3}: differ at pos 2 (a has it), so a < b.\n   208→  // {0,2} vs {1}: differ at pos 0 (a has it), and a has fewer... wait, sizes might differ.\n   209→  //\n   210→  // For sets of same size (which they are when counts are equal):\n   211→  // Compare element by element. {0,2} vs {1,2}: first elements 0 vs 1, so {0,2} < {1,2}.\n   212→  // In bitmask terms: first bit where they differ, if a has 1 there, a < b.\n   213→  // Wait: {0,2} = 101, {1,2} = 110. First diff at bit 0: a has 1, b has 0 → a < b. Correct.\n   214→  // {0,3} = 1001, {1,2} = 0110. First diff at bit 0: a has 1, b has 0 → a < b. Correct.\n   215→  // {1,3} vs {2,3}: 1010 vs 1100. First diff at bit 1: a has 1 → a < b. Correct (1 < 2).\n   216→  //\n   217→  // So: find lowest bit where they differ. If a has 1 there, a < b. If b has 1, b < a.\n   218→\n   219→  const diff = a ^ b;\n   220→  if (diff === 0n) return 0;\n   221→\n   222→  // Find lowest set bit of diff\n   223→  const lowest = diff & (-diff);\n   224→  if (a & lowest) return -1; // a has this bit, a < b\n   225→  return 1; // b has this bit, b < a\n   226→}\n   227→\n   228→function bitmaskToIndices(mask: bigint, maxBits: number): number[] {\n   229→  const result: number[] = [];\n   230→  for (let j = 0; j < maxBits; j++) {\n   231→    if ((mask >> BigInt(j)) & 1n) {\n   232→      result.push(j);\n   233→    }\n   234→  }\n   235→  return result;\n   236→}\n   237→\n   238→// ===== Part 2: Counter Puzzle over GF(p) =====\n   239→\n   240→export function solveCounter(\n   241→  lights: number[],\n   242→  buttons: number[][],\n   243→  modulus: number\n   244→): number[] | null {\n   245→  const n = lights.length;\n   246→  const m = buttons.length;\n   247→  const p = modulus;\n   248→\n   249→  // Build augmented matrix [A | b] over GF(p)\n   250→  const matrix: number[][] = [];\n   251→  for (let i = 0; i < n; i++) {\n   252→    const row = new Array(m + 1).fill(0);\n   253→    for (let j = 0; j < m; j++) {\n   254→      if (buttons[j].includes(i)) {\n   255→        row[j] = 1;\n   256→      }\n   257→    }\n   258→    row[m] = ((lights[i] % p) + p) % p;\n   259→    matrix.push(row);\n   260→  }\n   261→\n   262→  // Gaussian elimination over GF(p)\n   263→  const pivotCol: number[] = [];\n   264→  let rank = 0;\n   265→\n   266→  for (let col = 0; col < m && rank < n; col++) {\n   267→    let pivotRow = -1;\n   268→    for (let r = rank; r < n; r++) {\n   269→      if (matrix[r][col] !== 0) {\n   270→        pivotRow = r;\n   271→        break;\n   272→      }\n   273→    }\n   274→    if (pivotRow === -1) continue;\n   275→\n   276→    [matrix[rank], matrix[pivotRow]] = [matrix[pivotRow], matrix[rank]];\n   277→    pivotCol.push(col);\n   278→\n   279→    const inv = modInverse(matrix[rank][col], p);\n   280→    for (let c = 0; c <= m; c++) {\n   281→      matrix[rank][c] = (matrix[rank][c] * inv) % p;\n   282→    }\n   283→\n   284→    for (let r = 0; r < n; r++) {\n   285→      if (r !== rank && matrix[r][col] !== 0) {\n   286→        const factor = matrix[r][col];\n   287→        for (let c = 0; c <= m; c++) {\n   288→          matrix[r][c] = ((matrix[r][c] - factor * matrix[rank][c]) % p + p) % p;\n   289→        }\n   290→      }\n   291→    }\n   292→    rank++;\n   293→  }\n   294→\n   295→  // Check for inconsistency\n   296→  for (let r = rank; r < n; r++) {\n   297→    if (matrix[r][m] !== 0) {\n   298→      return null;\n   299→    }\n   300→  }\n   301→\n   302→  // Identify free variables\n   303→  const pivotColSet = new Set(pivotCol);\n   304→  const freeVars: number[] = [];\n   305→  for (let j = 0; j < m; j++) {\n   306→    if (!pivotColSet.has(j)) {\n   307→      freeVars.push(j);\n   308→    }\n   309→  }\n   310→\n   311→  // Base solution (free vars = 0)\n   312→  const baseSol = new Array(m).fill(0);\n   313→  for (let r = 0; r < rank; r++) {\n   314→    baseSol[pivotCol[r]] = matrix[r][m];\n   315→  }\n   316→\n   317→  const k = freeVars.length;\n   318→\n   319→  if (k === 0) {\n   320→    return baseSol;\n   321→  }\n   322→\n   323→  // For each free variable fi, compute its effect on each pivot variable:\n   324→  // When freeVars[fi] = v, pivot var at row r changes by v * (-matrix[r][freeVars[fi]]) mod p\n   325→  const freeCoeff: number[][] = [];\n   326→  for (let fi = 0; fi < k; fi++) {\n   327→    const fv = freeVars[fi];\n   328→    const coeffs = new Array(rank);\n   329→    for (let r = 0; r < rank; r++) {\n   330→      coeffs[r] = (p - matrix[r][fv]) % p;\n   331→    }\n   332→    freeCoeff.push(coeffs);\n   333→  }\n   334→\n   335→  const totalCombinations = Math.pow(p, k);\n   336→\n   337→  if (totalCombinations <= 5000000) {\n   338→    // Direct enumeration\n   339→    return enumerateCounterDirect(baseSol, freeVars, freeCoeff, pivotCol, rank, m, p, k);\n   340→  }\n   341→\n   342→  // Meet in the middle\n   343→  return meetInTheMiddleCounter(baseSol, freeVars, freeCoeff, pivotCol, rank, m, p, k);\n   344→}\n   345→\n   346→function enumerateCounterDirect(\n   347→  baseSol: number[],\n   348→  freeVars: number[],\n   349→  freeCoeff: number[][],\n   350→  pivotCol: number[],\n   351→  rank: number,\n   352→  m: number,\n   353→  p: number,\n   354→  k: number\n   355→): number[] {\n   356→  let bestTotal = Infinity;\n   357→  let bestSol: number[] | null = null;\n   358→  const freeValues = new Array(k).fill(0);\n   359→  const totalCombinations = Math.pow(p, k);\n   360→\n   361→  for (let combo = 0; combo < totalCombinations; combo++) {\n   362→    let temp = combo;\n   363→    for (let fi = 0; fi < k; fi++) {\n   364→      freeValues[fi] = temp % p;\n   365→      temp = Math.floor(temp / p);\n   366→    }\n   367→\n   368→    const sol = buildSolution(baseSol, freeVars, freeCoeff, pivotCol, rank, m, p, freeValues);\n   369→    let total = 0;\n   370→    for (let j = 0; j < m; j++) total += sol[j];\n   371→\n   372→    if (total < bestTotal || (total === bestTotal && bestSol !== null && lexSmallerArr(sol, bestSol))) {\n   373→      bestTotal = total;\n   374→      bestSol = sol;\n   375→    }\n   376→  }\n   377→\n   378→  return bestSol!;\n   379→}\n   380→\n   381→function meetInTheMiddleCounter(\n   382→  baseSol: number[],\n   383→  freeVars: number[],\n   384→  freeCoeff: number[][],\n   385→  pivotCol: number[],\n   386→  rank: number,\n   387→  m: number,\n   388→  p: number,\n   389→  k: number\n   390→): number[] {\n   391→  const halfA = Math.floor(k / 2);\n   392→  const halfB = k - halfA;\n   393→  const sizeA = Math.pow(p, halfA);\n   394→  const sizeB = Math.pow(p, halfB);\n   395→\n   396→  // For each first-half combo, compute delta vector (mod p) for pivots,\n   397→  // plus the free var values and their sum\n   398→  type HalfAEntry = {\n   399→    deltaKey: string;\n   400→    freeVals: number[];\n   401→    freeSum: number;\n   402→  };\n   403→\n   404→  // Group first-half entries by delta vector\n   405→  const deltaGroups = new Map<string, HalfAEntry[]>();\n   406→\n   407→  for (let combo = 0; combo < sizeA; combo++) {\n   408→    let temp = combo;\n   409→    const freeVals = new Array(halfA);\n   410→    let freeSum = 0;\n   411→    for (let fi = 0; fi < halfA; fi++) {\n   412→      freeVals[fi] = temp % p;\n   413→      freeSum += freeVals[fi];\n   414→      temp = Math.floor(temp / p);\n   415→    }\n   416→\n   417→    const deltas = new Array(rank);\n   418→    for (let r = 0; r < rank; r++) {\n   419→      let d = 0;\n   420→      for (let fi = 0; fi < halfA; fi++) {\n   421→        d = (d + freeVals[fi] * freeCoeff[fi][r]) % p;\n   422→      }\n   423→      deltas[r] = d;\n   424→    }\n   425→\n   426→    const key = deltas.join(',');\n   427→    const entry: HalfAEntry = { deltaKey: key, freeVals, freeSum };\n   428→    const group = deltaGroups.get(key);\n   429→    if (group) {\n   430→      group.push(entry);\n   431→    } else {\n   432→      deltaGroups.set(key, [entry]);\n   433→    }\n   434→  }\n   435→\n   436→  // For each group, keep only the best entries (sorted by freeSum, then lex)\n   437→  // Actually we need the full solution to compare, so we need to keep entries\n   438→  // and combine with second half. For each delta group, we only need the entry\n   439→  // with minimum freeSum (and lex smallest freeVals for ties).\n   440→  const bestPerDelta = new Map<string, HalfAEntry>();\n   441→  for (const [key, group] of deltaGroups) {\n   442→    let best = group[0];\n   443→    for (let i = 1; i < group.length; i++) {\n   444→      const e = group[i];\n   445→      if (e.freeSum < best.freeSum ||\n   446→          (e.freeSum === best.freeSum && lexSmallerArr(e.freeVals, best.freeVals))) {\n   447→        best = e;\n   448→      }\n   449→    }\n   450→    bestPerDelta.set(key, best);\n   451→  }\n   452→\n   453→  // For each second-half combo, compute needed first-half delta\n   454→  let bestTotal = Infinity;\n   455→  let bestSol: number[] | null = null;\n   456→\n   457→  for (let combo = 0; combo < sizeB; combo++) {\n   458→    let temp = combo;\n   459→    const freeValsB = new Array(halfB);\n   460→    let freeSumB = 0;\n   461→    for (let fi = 0; fi < halfB; fi++) {\n   462→      freeValsB[fi] = temp % p;\n   463→      freeSumB += freeValsB[fi];\n   464→      temp = Math.floor(temp / p);\n   465→    }\n   466→\n   467→    // Compute delta for second half\n   468→    const deltasB = new Array(rank);\n   469→    for (let r = 0; r < rank; r++) {\n   470→      let d = 0;\n   471→      for (let fi = 0; fi < halfB; fi++) {\n   472→        d = (d + freeValsB[fi] * freeCoeff[halfA + fi][r]) % p;\n   473→      }\n   474→      deltasB[r] = d;\n   475→    }\n   476→\n   477→    // We need deltaA such that for each pivot row r:\n   478→    // (baseSol[pivotCol[r]] + deltaA[r] + deltaB[r]) % p gives the final value\n   479→    // We want to minimize the total, which is:\n   480→    //   sum of free