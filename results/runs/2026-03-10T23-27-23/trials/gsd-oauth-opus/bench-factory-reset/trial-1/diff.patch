+    bestCount = baseCount;
+    bestMask = baseMask;
+  }
+
+  const limit = 1 << k;
+  for (let combo = 1; combo < limit; combo++) {
+    const bit = combo & (-combo);
+    let fi = 0;
+    let tmp = bit;
+    while (tmp > 1) { fi++; tmp >>= 1; }
