presses', () => {\n    // Two buttons that both toggle light 0\n    // Target: light 0 on\n    // Button 0: [0], Button 1: [0]\n    // Pressing either one works (1 press each), so return [0] (lex smallest)\n    const result = solveToggle({\n      target: [true],\n      buttons: [[0], [0]],\n    });\n    expect(result).toEqual([0]);\n    expect(result!.length).toBe(1);\n  });\n\n  it('should return lex smallest for ties', () => {\n    // 3 lights, 3 buttons, each toggles one light\n    // Target: all on\n    const result = solveToggle({\n      target: [true, true, true],\n      buttons: [[0], [1], [2]],\n    });\n    expect(result).toEqual([0, 1, 2]);\n  });\n\n  it('should handle overlapping buttons', () => {\n    // 2 lights, 3 buttons\n    // b0: [0], b1: [1], b2: [0, 1]\n    // Target: [true, true]\n    // Options: {0,1} (2 presses), {2} ... wait b2 toggles both, giving [T,T]. That's 1 press.\n    const result = solveToggle({\n      target: [true, true],\n      buttons: [[0], [1], [0, 1]],\n    });\n    expect(result).toEqual([2]);\n  });\n\n  it('should handle no buttons', () => {\n    const result = solveToggle({\n      target: [true],\n      buttons: [],\n    });\n    expect(result).toBeNull();\n  });\n\n  it('should handle no buttons with all-off target', () => {\n    const result = solveToggle({\n      target: [false, false],\n      buttons: [],\n    });\n    expect(result).toEqual([]);\n  });\n\n  it('should handle impossible case', () => {\n    // 2 lights, 1 button that toggles both\n    // Target: [true, false] - impossible since button toggles both\n    const result = solveToggle({\n      target: [true, false],\n      buttons: [[0, 1]],\n    });\n    expect(result).toBeNull();\n  });\n\n  it('should handle medium-sized problem', () => {\n    // 10 lights, identity buttons (button i toggles light i)\n    const n = 10;\n    const target = new Array(n).fill(true);\n    const buttons = Array.from({ length: n }, (_, i) => [i]);\n    const result = solveToggl