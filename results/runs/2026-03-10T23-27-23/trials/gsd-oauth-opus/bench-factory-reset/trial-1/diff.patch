+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter } from '../src/index.js';
+
+// Helper to verify a toggle solution
+function verifyToggle(target: boolean[], buttons: number[][], pressed: number[]): boolean {
+  const n = target.length;
+  const state = new Array(n).fill(false);
+  for (const b of pressed) {
+    for (const light of buttons[b]) {
+      state[light] = !state[light];
+    }
+  }
+  for (let i = 0; i < n; i++) {
+    if (state[i] !== target[i]) return false;
+  }
+  return true;
+}
+
+// Helper to verify a counter solution
+function verifyCounter(lights: number[], buttons: number[][], modulus: number, presses: number[]): boolean {
+  const n = lights.length;
+  const state = new Array(n).fill(0);
+  for (let j = 0; j < buttons.length; j++) {
+    for (const counter of buttons[j]) {
+      state[counter] = (state[counter] + presses[j]) % modulus;
+    }
+  }
+  for (let i = 0; i < n; i++) {
+    if (state[i] !== lights[i]) return false;
+  }
+  return true;
+}
+
