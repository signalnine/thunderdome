+type Direction = 'down' | 'down-left' | 'down-right';
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+function nextPosition(row: number, col: number, dir: Direction): [number, number] {
+  switch (dir) {
+    case 'down':       return [row + 1, col];
+    case 'down-left':  return [row + 1, col - 1];
+    case 'down-right': return [row + 1, col + 1];
+  }
+}
+
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  if (rows === 0) return 0;
+  const cols = grid[0].length;
+
+  // Find source
+  let sourceCol = -1;
+  for (let c = 0; c < cols; c++) {
+    if (grid[0][c] === 'S') {
+      sourceCol = c;
+      break;
+    }
+  }
+  if (sourceCol === -1) return 0;
+
+  const visited = new Set<string>();
+  visited.add(`${0},${sourceCol}`);
+
+  // BFS/simulation with beams
+  const beams: Beam[] = [{ row: 0, col: sourceCol, dir: 'down' }];
+
+  while (beams.length > 0) {
+    const nextBeams: Beam[] = [];
+    for (const beam of beams) {
+      const [nr, nc] = nextPosition(beam.row, beam.col, beam.dir);
+      if (!inBounds(nr, nc, rows, cols)) continue;
+
+      visited.add(`${nr},${nc}`);
+
+      if (grid[nr][nc] === '^') {
+        // Split into down-left and down-right
+        nextBeams.push({ row: nr, col: nc, dir: 'down-left' });
+        nextBeams.push({ row: nr, col: nc, dir: 'down-right' });
+      } else {
+        // Continue in same direction
+        nextBeams.push({ row: nr, col: nc, dir: beam.dir });
+      }
+    }
+    beams.length = 0;
+    beams.push(...nextBeams);
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  if (rows === 0) return 0n;
+  const cols = grid[0].length;
+
+  // Find source
+  let sourceCol = -1;
+  for (let c = 0; c < cols; c++) {
+    if (grid[0][c] === 'S') {
+      sourceCol = c;
+      break;
+    }
+  }
+  if (sourceCol === -1) return 0n;
+
+  // We track beams as (row, col, direction) with a count of how many paths
+  // reach that state. This avoids enumerating individual paths.
+  // Map key: "row,col,dir" -> number of paths reaching this state
+  type BeamState = { row: number; col: number; dir: Direction; count: bigint };
+
+  let beams: BeamState[] = [{ row: 0, col: sourceCol, dir: 'down', count: 1n }];
+  let totalPaths = 0n;
+
+  while (beams.length > 0) {
+    // Merge beams with same state
+    const stateMap = new Map<string, bigint>();
+    const nextBeams: BeamState[] = [];
+
+    for (const beam of beams) {
+      const [nr, nc] = nextPosition(beam.row, beam.col, beam.dir);
+      if (!inBounds(nr, nc, rows, cols)) {
+        // Beam exits grid - counts as a completed path
+        totalPaths += beam.count;
+        continue;
+      }
+
+      if (grid[nr][nc] === '^') {
+        // Split: each path becomes two paths
+        for (const newDir of ['down-left', 'down-right'] as Direction[]) {
+          const key = `${nr},${nc},${newDir}`;
+          stateMap.set(key, (stateMap.get(key) ?? 0n) + beam.count);
+        }
+      } else {
+        const key = `${nr},${nc},${beam.dir}`;
+        stateMap.set(key, (stateMap.get(key) ?? 0n) + beam.count);
+      }
+    }
+
+    for (const [key, count] of stateMap) {
+      const parts = key.split(',');
+      nextBeams.push({
+        row: parseInt(parts[0]),
+        col: parseInt(parts[1]),
+        dir: parts[2] as Direction,
+        count,
+      });
+    }
+
+    beams = nextBeams;
+  }
+
+  return totalPaths;
+}
