+// src/payment/index.ts
+import { EventBus } from "../bus.js";
+import { PaymentService, Events, PaymentProcessedEvent, PaymentStatus } from "../types.js";
+
+export interface PaymentOptions {
+  successRate?: number; // 0-1 probability of success
+  delayMs?: number; // simulated processing time
+  timeoutRate?: number; // probability of timeout
+}
+
+export function createPaymentService(bus: EventBus, options?: PaymentOptions): PaymentService {
+  const opts = {
+    successRate: options?.successRate ?? 1.0,
+    delayMs: options?.delayMs ?? 0,
+    timeoutRate: options?.timeoutRate ?? 0,
+  };
+
+  function simulate(): Promise<PaymentStatus> {
+    return new Promise((resolve) => {
+      setTimeout(() => {
+        const rand = Math.random();
+        if (rand < opts.timeoutRate) {
+          resolve(PaymentStatus.TIMEOUT);
+        } else if (rand < opts.timeoutRate + opts.successRate) {
+          resolve(PaymentStatus.SUCCESS);
+        } else {
+          resolve(PaymentStatus.FAILED);
+        }
+      }, opts.delayMs);
+    });
+  }
+
+  return {
+    async processPayment(orderId: string, amount: number) {
+      const status = await simulate();
+      const transactionId = status === PaymentStatus.SUCCESS ? `tx_${Math.random().toString(36).substring(2)}` : undefined;
+      const error = status === PaymentStatus.FAILED ? "Payment failed" : status === PaymentStatus.TIMEOUT ? "Payment timeout" : undefined;
+      const payload: PaymentProcessedEvent = { orderId, status, transactionId, error };
+      void bus.emit(Events.PAYMENT_PROCESSED, payload);
+      return { status, transactionId, error };
+    },
+    async refund(transactionId: string) {
+      // Simplified: always succeed refund after optional delay
+      if (opts.delayMs) {
+        await new Promise((r) => setTimeout(r, opts.delayMs));
+      }
+      return true;
+    },
+  };
+}
