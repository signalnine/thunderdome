+// src/inventory/index.ts
+import { EventBus } from "../bus.js";
+import { InventoryService, Events, InventoryUpdatedEvent, LowStockAlertEvent } from "../types.js";
+
+export function createInventoryService(bus: EventBus): InventoryService {
+  const stock = new Map<string, number>();
+  const thresholds = new Map<string, number>();
+
+  function emitUpdate(productId: string) {
+    const quantity = stock.get(productId) ?? 0;
+    const payload: InventoryUpdatedEvent = { productId, quantity };
+    void bus.emit(Events.INVENTORY_UPDATED, payload);
+    const threshold = thresholds.get(productId);
+    if (threshold !== undefined && quantity < threshold) {
+      const alert: LowStockAlertEvent = {
+        productId,
+        currentQuantity: quantity,
+        threshold,
+      };
+      void bus.emit(Events.LOW_STOCK_ALERT, alert);
+    }
+  }
+
+  return {
+    setStock(productId: string, quantity: number) {
+      stock.set(productId, quantity);
+      emitUpdate(productId);
+    },
+    getStock(productId: string) {
+      return stock.get(productId) ?? 0;
+    },
+    reserve(productId: string, quantity: number) {
+      const available = stock.get(productId) ?? 0;
+      if (available < quantity) return false;
+      stock.set(productId, available - quantity);
+      emitUpdate(productId);
+      return true;
+    },
+    release(productId: string, quantity: number) {
+      const current = stock.get(productId) ?? 0;
+      stock.set(productId, current + quantity);
+      emitUpdate(productId);
+    },
+    setLowStockThreshold(productId: string, threshold: number) {
+      thresholds.set(productId, threshold);
+      // Check immediately after setting threshold
+      const qty = stock.get(productId) ?? 0;
+      if (qty < threshold) {
+        const alert: LowStockAlertEvent = {
+          productId,
+          currentQuantity: qty,
+          threshold,
+        };
+        void bus.emit(Events.LOW_STOCK_ALERT, alert);
+      }
+    },
+  };
+}
