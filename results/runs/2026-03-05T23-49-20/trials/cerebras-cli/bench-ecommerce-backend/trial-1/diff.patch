+{"type":"tool_use","timestamp":1772754843695,"sessionID":"ses_33f93e73bffev1Vyb81nkvEIQn","part":{"id":"prt_cc06c3753001uXDBzFL91o1A14","sessionID":"ses_33f93e73bffev1Vyb81nkvEIQn","messageID":"msg_cc06c3581002ms15epGkTdPaPz","type":"tool","callID":"a5b308e13","tool":"write","state":{"status":"completed","input":{"filePath":"/workspace/src/pricing/index.ts","content":"// src/pricing/index.ts\nimport { EventBus } from \"../bus.js\";\nimport { PricingService, Events, PriceCalculatedEvent } from \"../types.js\";\n\nexport function createPricingService(bus: EventBus): PricingService {\n  const priceMap = new Map<string, number>(); // productId -> price\n  const discountCodes = new Map<string, number>(); // code -> percentage (0-100)\n  const TAX_RATE = 0.10; // 10%\n\n  // Listen for product creation to store price\n  const productCreatedHandler = (payload: unknown) => {\n    const p = payload as { productId: string; price: number };\n    if (p && typeof p.productId === \"string\" && typeof p.price === \"number\") {\n      priceMap.set(p.productId, p.price);\n    }\n  };\n  bus.on(Events.PRODUCT_CREATED, productCreatedHandler);\n\n  return {\n    calculateTotal(items, discountCode) {\n      // Calculate subtotal based on known prices\n      let subtotal = 0;\n      for (const item of items) {\n        const unitPrice = priceMap.get(item.productId) ?? item.price ?? 0;\n        subtotal += unitPrice * item.quantity;\n      }\n      let discount = 0;\n      if (discountCode && discountCodes.has(discountCode)) {\n        const perc = discountCodes.get(discountCode)! / 100;\n        discount = subtotal * perc;\n      }\n      const afterDiscount = subtotal - discount;\n      const tax = afterDiscount * TAX_RATE;\n      const total = afterDiscount + tax;\n      const evt: PriceCalculatedEvent = {\n        cartId: \"\", // not known here; caller may attach later\n        subtotal,\n        discount,\n        tax,\n        total,\n      };\n      void bus.emit(Events.PRICE_CALCULATED, evt);\n      return { subtotal, discount, tax, total };\n    },\n    addDiscountCode(code, percentage) {\n      discountCodes.set(code, percentage);\n    },\n    getPrice(productId) {\n      return priceMap.get(productId) ?? 0;\n    },\n  };\n}\n"},"output":"Wrote file successfully.","title":"src/pricing/index.ts","metadata":{"diagnostics":{},"filepath":"/workspace/src/pricing/index.ts","exists":false,"truncated":false},"time":{"start":1772754843687,"end":1772754843694}}}}
