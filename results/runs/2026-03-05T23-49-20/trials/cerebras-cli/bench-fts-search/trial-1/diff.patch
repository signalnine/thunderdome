);\n\n\n\n  // Suggest endpoint\n  router.get('/notes/search/suggest', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const q = (req.query.q as string) ?? '';\n      if (!q || q.trim() === '') {\n        throw new ValidationError('Query parameter q is required');\n      }\n      const prefix = q.trim().replace(/\"/g, ''); // remove quotes if any\n      // Use prefix search on FTS5\n      const stmt = db.prepare(`\n        SELECT DISTINCT notes.id, notes.title\n        FROM notes_fts\n        JOIN notes ON notes.id = notes_fts.rowid\n        WHERE notes_fts MATCH ?\n        LIMIT 5\n      `);\n      const rows = stmt.all(`${prefix}*`) as any[];\n      const results = rows.map(row => ({ id: row.id, title: row.title }));\n      res.json({ results });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // --- Search Endpoints ---\n  // Search endpoint (GET /notes/search)\n  router.get('/notes/search', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const q = (req.query.q as string) ?? '';\n      if (!q || q.trim() === '') {\n        throw new ValidationError('Query parameter q is required');\n      }\n      const page = parseInt((req.query.page as string) ?? '1');\n      const perPage = 20;\n      const offset = (page - 1) * perPage;\n\n      // Total count of matching rows\n      const countStmt = db.prepare(`SELECT COUNT(*) as count FROM notes_fts WHERE notes_fts MATCH ?`);\n      const total = countStmt.get(q).count as number;\n\n      // Perform full-text search with ranking and snippet highlighting\n      const stmt = db.prepare(`\n        SELECT notes.id, notes.title,\n          snippet(notes_fts, -1, '<mark>', '</mark>', '...', 10) AS snippet,\n          bm25(notes_fts) AS rank\n        FROM notes_fts\n        JOIN notes ON notes.id = notes_fts.rowid\n        WHERE notes_fts MATCH ?\n        ORDER BY rank\n        LIMIT ? OFFSET ?\n      `);\n      const rows = stmt.all(q, perPage, offset) as any[];\n\n    