ate: '2024-03-15',\n47:       subtotal: 200,\n48:       discount_rate: 0.1,\n49:       tax_rate: 0.08,\n50:       total: 194.40,\n51:       status: 'sent',\n52:     });\n53:     const invoice = getInvoiceById(db, id);\n54:     expect(invoice).toBeDefined();\n55:     expect(invoice!.customer_id).toBe('cust-1');\n56:     expect(invoice!.subtotal).toBe(200);\n57:   });\n58: \n59:   it('returns undefined for non-existent invoice', () => {\n60:     const invoice = getInvoiceById(db, 999);\n61:     expect(invoice).toBeUndefined();\n62:   });\n63: \n64:   it('creates an invoice with line items', () => {\n65:     const id = createInvoice(db, {\n66:       customer_id: 'cust-2',\n67:       date: '2024-04-01',\n68:       subtotal: 250,\n69:       discount_rate: 0,\n70:       tax_rate: 0.05,\n71:       total: 262.50,\n72:       status: 'draft',\n73:       line_items: [\n74:         { description: 'Widget A', quantity: 5, unit_price: 30 },\n75:         { description: 'Widget B', quantity: 2, unit_price: 50 },\n76:       ],\n77:     });\n78:     const invoice = getInvoiceById(db, id);\n79:     expect(invoice!.line_items).toHaveLength(2);\n80:     expect(invoice!.line_items[0].description).toBe('Widget A');\n81:   });\n82: \n83:   it('lists invoices by customer', () => {\n84:     createInvoice(db, {\n85:       customer_id: 'cust-A',\n86:       date: '2024-01-10',\n87:       subtotal: 100, discount_rate: 0, tax_rate: 0, total: 100, status: 'paid',\n88:     });\n89:     createInvoice(db, {\n90:       customer_id: 'cust-B',\n91:       date: '2024-01-12',\n92:       subtotal: 200, discount_rate: 0, tax_rate: 0, total: 200, status: 'paid',\n93:     });\n94:     createInvoice(db, {\n95:       customer_id: 'cust-A',\n96:       date: '2024-02-05',\n97:       subtotal: 150, discount_rate: 0, tax_rate: 0, total: 150, status: 'draft',\n98:     });\n99: \n100:     const invoices = getInvoicesByCustomer(db, 'cust-A');\n101:     expect(invoices).toHaveLength(2);\n102:     expect(invoices.every(inv => inv.customer_id === 'cust-A')).toBe(true);\n103:   });\n104: \n105:   it('returns invoices sorted by date', () => {\n106:     createInvoice(db, {\n107:       customer_id: 'cust-1',\n108:       date: '2024-03-15',\n109:       subtotal: 100, discount_rate: 0, tax_rate: 0, total: 100, status: 'draft',\n110:     });\n111:     createInvoice(db, {\n112:       customer_id: 'cust-1',\n113:       date: '2024-01-10',\n114:       subtotal: 200, discount_rate: 0, tax_rate: 0, total: 200, status: 'draft',\n115:     });\n116:     createInvoice(db, {\n117:       customer_id: 'cust-1',\n118:       date: '2024-02-20',\n119:       subtotal: 150, discount_rate: 0, tax_rate: 0, total: 150, status: 'draft',\n120:     });\n121: \n122:     const invoices = getInvoicesByDateRange(db, '2024-01-01', '2024-12-31');\n123:     expect(invoices[0].date).toBe('2024-01-10');\n124:     expect(invoices[1].date).toBe('2024-02-20');\n125:     expect(invoices[2].date).toBe('2024-03-15');\n126:   });\n127: \n128:   it('stores invoice status correctly', () => {\n129:     const id = createInvoice(db, {\n130:       customer_id: 'cust-1',\n131:       date: '2024-06-01',\n132:       subtotal: 500, discount_rate: 0.05, tax_rate: 0.1, total: 522.50,\n133:       status: 'paid',\n134:     });\n135:     const invoice = getInvoiceById(db, id);\n136:     expect(invoice!.status).toBe('paid');\n137:   });\n138: \n139:   it('calculates subtotal from line items', () => {\n140:     const items = [\n141:       { description: 'Item A', quantity: 3, unit_price: 10 },\n142:       { description: 'Item B', quantity: 1, unit_price: 25.50 },\n143:       { description: 'Item C', quantity: 2, unit_price: 7.25 },\n144:     ];\n145:     expect(calculateSubtotal(items)).toBe(70);\n146:   });\n147: });\n148: \n149: // ‚îÄ‚îÄ‚îÄ Billing Calculations (8 tests) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\n150: \n151: describe('Billing Calculations', () => {\n152:   it('calculate