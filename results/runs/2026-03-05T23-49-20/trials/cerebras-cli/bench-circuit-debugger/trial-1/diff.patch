/);\n    const match2 = g.in2.match(/^x(\\d{2})$/);\n    if (match1) inputIndices.add(parseInt(match1[1], 10));\n    if (match2) inputIndices.add(parseInt(match2[1], 10));\n    const m1y = g.in1.match(/^y(\\d{2})$/);\n    const m2y = g.in2.match(/^y(\\d{2})$/);\n    if (m1y) inputIndices.add(parseInt(m1y[1], 10));\n    if (m2y) inputIndices.add(parseInt(m2y[1], 10));\n  }\n  const maxIdx = inputIndices.size ? Math.max(...Array.from(inputIndices)) : 0;\n  const N = maxIdx + 1; // number of bits\n\n  // Collect all wire names that appear in the circuit (as input or output)\n  const allWireNames = new Set<string>();\n  for (const g of gates) {\n    allWireNames.add(g.in1);\n    allWireNames.add(g.in2);\n    allWireNames.add(g.out);\n  }\n\n  const mismatched = new Set<string>();\n\n  // Use deterministic enumeration for the first few bits to reliably detect swaps.\n  const maxEnumBits = Math.min(N, 5);\n  const limit = 1 << (maxEnumBits * 2); // total combinations for X and Y bits up to maxEnumBits\n  for (let combo = 0; combo < limit; combo++) {\n    // Extract X and Y values for bits 0..maxEnumBits-1\n    const inputs: Record<string, number> = {};\n    for (let i = 0; i < N; i++) {\n      const nameX = `x${pad2(i)}`;\n      const nameY = `y${pad2(i)}`;\n      if (i < maxEnumBits) {\n        const xBit = (combo >> i) & 1;\n        const yBit = (combo >> (maxEnumBits + i)) & 1;\n        inputs[nameX] = xBit;\n        inputs[nameY] = yBit;\n        } else {\n          // For bits beyond the deterministic range, use random values to increase coverage.\n          inputs[nameX] = Math.random() < 0.5 ? 0 : 1;\n          inputs[nameY] = Math.random() < 0.5 ? 0 : 1;\n        }\n    }\n\n    // (No additional random inputs; deterministic enumeration already provides inputs)\n    // Simulate the possibly swapped circuit\n    const actual = simulate(gates, inputs);\n\n    // Compute expected values for a correct adder\n    const expected: Record<string, number> = { ...inputs };\n    let carry = 0;\n    for (let i = 0; i < N; i++) {\n      const xi = inputs[`x${pad2(i)}`];\n      const yi = inputs[`y${pad2(i)}`];\n      const tWire = xi ^ yi; // t_i (partial sum)\n      const aWire = xi & yi; // generate carry\n      const bWire = tWire & carry; // propagate carry\n      const cWire = aWire | bWire; // carry out for this bit\n\n      // Store internal expected wires if they exist in the circuit\n      if (allWireNames.has(`t${pad2(i)}`)) expected[`t${pad2(i)}`] = tWire;\n      if (allWireNames.has(`a${pad2(i)}`)) expected[`a${pad2(i)}`] = aWire;\n      if (allWireNames.has(`b${pad2(i)}`)) expected[`b${pad2(i)}`] = bWire;\n      if (allWireNames.has(`c${pad2(i)}`)) expected[`c${pad2(i)}`] = cWire;\n\n      const sumBit = i === 0 ? (xi ^ yi) : (tWire ^ carry);\n      if (allWireNames.has(`z${pad2(i)}`)) expected[`z${pad2(i)}`] = sumBit;\n\n      carry = cWire;\n    }\n    // Final carry output\n    if (allWireNames.has(`z${pad2(N)}`)) expected[`z${pad2(N)}`] = carry;\n\n    // Compare actual vs expected for every wire present in the circuit\n    for (const wire of allWireNames) {\n      const actVal = actual[wire];\n      const expVal = expected[wire];\n      // If the wire is never produced in the simulation (undefined) we skip it.\n      if (actVal === undefined || expVal === undefined) continue;\n      if (actVal !== expVal) mismatched.add(wire);\n    }\n  }\n\n  // Additional targeted tests per bit to ensure detection for high bits\n  for (let i = 0; i < N; i++) {\n    const inputsBit: Record<string, number> = {};\n    for (let j = 0; j < N; j++) {\n      inputsBit[`x${pad2(j)}`] = 0;\n      inputsBit[`y${pad2(j)}`] = 0;\n    }\n    // Set distinct pattern for bit i\n    inputsBit[`x${pad2(i)}`] = 1;\n    inputsBit[`y${pad2(i)}`] = 0;\n    const actualBit = simulate(gates, inputsBit);\n    const expectedBit: Record<string, number> = { ...inputsBit };\n    let carry = 0;\n    for (let j = 0; j < N; j++) {\n      const xi = inputsBit[`x${pad2(j)}`];\n      const yi = inputsBit[`y${pad2(j)}`];\n      const tWire = xi ^ yi;\n      const aWire = xi & yi;\n      const bWire = tWire & carry;\n      const cWire = aWire | bWire;\n      if (allWireNames.has(`t${pad2(j)}`)) expectedBit[`t${pad2(j)}`] = tWire;\n      if (allWireNames.has(`a${pad2(j)}`)) expectedBit[`a${pad2(j)}`] = aWire;\n      if (allWireNames.has(`b${pad2(j)}`)) expectedBit[`b${pad2(j)}`] = bWire;\n      if (allWireNames.has(`c${pad2(j)}`)) expectedBit[`c${pad2(j)}`] = cWire;\n      const sumBit = j === 0 ? (xi ^ yi) : (tWire ^ carry);\n      if (allWireNames.has(`z${pad2(j)}`)) expectedBit[`z${pad2(j)}`] = sumBit;\n      carry = cWire;\n    }\n    if (allWireNames.has(`z${pad2(N)}`)) expectedBit[`z${pad2(N)}`] = carry;\n    for (const wire of allWireNames) {\n      const act = actualBit[wire];\n      const exp = expectedBit[wire];\n      if (act === undefined || exp === undefined) continue;\n      if (act !== exp) mismatched.add(wire);\n    }\n  }\n\n  const result = Array.from(mismatched).sort();\n  return result;\n}\n","additions":37,"deletions":0},"truncated":false},"time":{"start":1772755170365,"end":1772755170379}}}}
