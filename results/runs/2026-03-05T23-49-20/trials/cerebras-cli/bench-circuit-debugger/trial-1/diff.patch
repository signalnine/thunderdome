(i)}`] = bWire;\n      if (allWireNames.has(`c${pad2(i)}`)) expected[`c${pad2(i)}`] = cWire;\n\n      const sumBit = i === 0 ? (xi ^ yi) : (tWire ^ carry);\n      if (allWireNames.has(`z${pad2(i)}`)) expected[`z${pad2(i)}`] = sumBit;\n\n      carry = cWire;\n    }\n    // Final carry output\n    if (allWireNames.has(`z${pad2(N)}`)) expected[`z${pad2(N)}`] = carry;\n\n    // Compare actual vs expected for every wire present in the circuit\n    for (const wire of allWireNames) {\n      const actVal = actual[wire];\n      const expVal = expected[wire];\n      // If the wire is never produced in the simulation (undefined) we skip it.\n      if (actVal === undefined || expVal === undefined) continue;\n      if (actVal !== expVal) mismatched.add(wire);\n    }\n  }\n\n  const result = Array.from(mismatched).sort();\n  return result;\n}\n","after":"// src/index.ts\n\nexport interface Gate {\n  op: 'AND' | 'OR' | 'XOR';\n  in1: string; // input wire name\n  in2: string; // input wire name\n  out: string; // output wire name\n}\n\n/**\n * Simulate a combinational circuit defined by gates.\n * @param gates Array of Gate objects describing the circuit.\n * @param inputs Mapping of wire name to its initial value (0 or 1).\n * @returns Mapping of every wire (including inputs, intermediate, and outputs) to its final value.\n */\nexport function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number> {\n  const values: Record<string, number> = { ...inputs };\n  // Clone gates array to allow removal as we process\n  const remaining = gates.slice();\n  let progress = true;\n  while (remaining.length && progress) {\n    progress = false;\n    for (let i = remaining.length - 1; i >= 0; i--) {\n      const g = remaining[i];\n      if (g.in1 in values && g.in2 in values) {\n        const a = values[g.in1];\n        const b = values[g.in2];\n        let out: number;\n        switch (g.op) {\n          case 'AND':\n            out = a & b;\n            break;\n     