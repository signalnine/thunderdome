+import { solveToggle, solveCounter, Machine } from './index.js';
+
+describe('solveToggle', () => {
+  test('example with no solution', () => {
+    const machine: Machine = {
+      target: [true, true, false, true],
+      buttons: [
+        [0, 1],
+        [1, 2, 3],
+        [0, 3],
+      ],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+  test('simple solvable', () => {
+    const machine: Machine = {
+      target: [true, false, false],
+      buttons: [[0], [1], [0, 1, 2]],
+    };
+    // Press button 0 and 2 toggles lights 0 and (0,1,2) => result [false,true,true]? Actually compute manually.
+    const result = solveToggle(machine);
+    // verify result produces target
+    const n = machine.target.length;
+    const state = new Array(n).fill(false);
+    if (result) {
+      for (const idx of result) {
+        for (const light of machine.buttons[idx]) {
+          state[light] = !state[light];
+        }
+      }
+    }
+    expect(state).toEqual(machine.target);
+  });
+});
+
+describe('solveCounter', () => {
+  test('simple mod 5', () => {
+    const lights = [2, 1];
+    const buttons = [[0], [1], [0, 1]]; // button2 increments both
+    const modulus = 5;
+    const result = solveCounter(lights, buttons, modulus);
+    expect(result).not.toBeNull();
+    if (result) {
+      const n = lights.length;
+      const state = new Array(n).fill(0);
+      for (let i = 0; i < buttons.length; i++) {
+        const times = result[i];
+        for (const idx of buttons[i]) {
+          state[idx] = (state[idx] + times) % modulus;
+        }
+      }
+      expect(state).toEqual(lights);
+    }
+  });
+});
