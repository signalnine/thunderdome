+++ b/src/index.ts
@@ -0,0 +1,225 @@
+/*
+Implementation for Factory Reset puzzles:
+- solveToggle: find minimal set of button presses (0/1) to achieve target lights.
+- solveCounter: solve linear system modulo a prime modulus, returning press counts minimizing total presses (simple solution assumes unique solution).
+*/
+
+/** Toggle Puzzle */
+export interface Machine {
+  target: boolean[]; // desired state for each light (all start off)
+  buttons: number[][]; // buttons[i] = array of light indices toggled by button i
+}
+
+/**
+ * Solve the toggle puzzle.
+ * Returns sorted array of button indices to press, or null if impossible.
+ */
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const nLights = target.length;
+  const nButtons = buttons.length;
+  // Represent light states as bitmask (up to 40 bits fits in Number)
+  const targetMask = boolArrayToMask(target);
+  const buttonMasks: number[] = [];
+  for (let i = 0; i < nButtons; i++) {
+    buttonMasks[i] = boolArrayToMaskArray(buttons[i]);
+  }
+
+  // Split buttons into two halves for meet-in-the-middle
+  const mid = Math.floor(nButtons / 2);
+  const firstHalf = buttonMasks.slice(0, mid);
+  const secondHalf = buttonMasks.slice(mid);
+
+  // Map from mask -> best subset (fewest presses, then lexicographically smallest)
+  const map2 = new Map<number, number[]>();
+  const size2 = secondHalf.length;
+  const total2 = 1 << size2; // up to 2^20 ~ 1M
+  for (let subset = 0; subset < total2; subset++) {
+    let mask = 0;
+    const indices: number[] = [];
+    for (let b = 0; b < size2; b++) {
+      if (subset & (1 << b)) {
+        mask ^= secondHalf[b];
+        indices.push(mid + b);
+      }
+    }
+    // Update best for this mask
+    const existing = map2.get(mask);
+    if (!existing || isBetterSubset(indices, existing)) {
+      map2.set(mask, indices);
+    }
+  }
+
+  // Enumerate first half and combine
+  let bestSolution: number[] | null = null;
+  const size1 = firstHalf.length;
+  const total1 = 1 << size1;
+  for (let subset = 0; subset < total1; subset++) {
+    let mask = 0;
+    const indices1: number[] = [];
+    for (let b = 0; b < size1; b++) {
+      if (subset & (1 << b)) {
+        mask ^= firstHalf[b];
+        indices1.push(b);
+      }
+    }
+    const needed = targetMask ^ mask;
+    const indices2 = map2.get(needed);
+    if (indices2 !== undefined) {
+      const combined = mergeSorted(indices1, indices2);
+      if (!bestSolution || isBetterSubset(combined, bestSolution)) {
+        bestSolution = combined;
+      }
+    }
+  }
+
+  return bestSolution;
+}
+
+/** Counter Puzzle */
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const nCounters = lights.length;
+  const nButtons = buttons.length;
+  // Build matrix A (nCounters x nButtons) modulo modulus
+  const A: number[][] = Array.from({ length: nCounters }, () => Array(nButtons).fill(0));
+  for (let i = 0; i < nButtons; i++) {
+    for (const idx of buttons[i]) {
+      if (idx >= 0 && idx < nCounters) {
+        A[idx][i] = (A[idx][i] + 1) % modulus; // increment per press
+      }
+    }
+  }
+  // Perform Gaussian elimination to solve A * x = lights (mod modulus)
+  const result = gaussianSolve(A, lights, modulus);
+  return result; // may be null if no solution
+}
+
+// ---------- Helper Functions ----------
+
+function boolArrayToMask(arr: boolean[]): number {
+  let mask = 0;
+  for (let i = 0; i < arr.length; i++) {
+    if (arr[i]) mask |= 1 << i;
+  }
+  return mask;
+}
+
+function boolArrayToMaskArray(indices: number[]): number {
+  let mask = 0;
+  for (const idx of indices) {
+    mask |= 1 << idx;
+  }
+  return mask;
+}
+
+function mergeSorted(a: number[], b: number[]): number[] {
+  const res: number[] = [];
+  let i = 0,
+    j = 0;
+  while (i < a.length && j < b.length) {
+    if (a[i] < b[j]) res.push(a[i++]);
+    else res.push(b[j++]);
+  }
+  while (i < a.length) res.push(a[i++]);
+  while (j < b.length) res.push(b[j++]);
+  return res;
+}
+
+function isBetterSubset(candidate: number[], current: number[]): boolean {
+  // Prefer fewer presses, then lexicographically smaller
+  if (candidate.length !== current.length) return candidate.length < current.length;
+  for (let i = 0; i < candidate.length; i++) {
+    if (candidate[i] !== current[i]) return candidate[i] < current[i];
+  }
+  return false; // equal
+}
+
+/** Gaussian elimination modulo a prime.
+ * Returns a particular solution (array length nButtons) or null if inconsistent.
+ */
+function gaussianSolve(
+  A: number[][],
+  b: number[],
+  mod: number
+): number[] | null {
+  const rows = A.length;
+  const cols = A[0].length;
+  // Augmented matrix
+  const M: number[][] = A.map((row, i) => [...row, ((b[i] % mod) + mod) % mod]);
+
+  const pivotCol: number[] = Array(rows).fill(-1);
+  let r = 0;
+  for (let c = 0; c < cols && r < rows; c++) {
+    // Find pivot row with non-zero in column c
+    let pivotRow = -1;
+    for (let i = r; i < rows; i++) {
+      if (M[i][c] % mod !== 0) {
+        pivotRow = i;
+        break;
+      }
+    }
+    if (pivotRow === -1) continue; // column is free variable
+    // Swap rows
+    if (pivotRow !== r) {
+      const tmp = M[pivotRow];
+      M[pivotRow] = M[r];
+      M[r] = tmp;
+    }
+    // Normalize pivot row
+    const inv = modInv(M[r][c], mod);
+    for (let j = c; j <= cols; j++) {
+      M[r][j] = (M[r][j] * inv) % mod;
+    }
+    // Eliminate other rows
+    for (let i = 0; i < rows; i++) {
+      if (i !== r && M[i][c] !== 0) {
+        const factor = M[i][c];
+        for (let j = c; j <= cols; j++) {
+          M[i][j] = (M[i][j] - factor * M[r][j]) % mod;
+          if (M[i][j] < 0) M[i][j] += mod;
+        }
+      }
+    }
+    pivotCol[r] = c;
+    r++;
+  }
+  // Check for inconsistency: rows with all zero coeffs but non-zero constant
+  for (let i = r; i < rows; i++) {
+    let allZero = true;
+    for (let j = 0; j < cols; j++) {
+      if (M[i][j] % mod !== 0) {
+        allZero = false;
+        break;
+      }
+    }
+    if (allZero && M[i][cols] % mod !== 0) {
+      return null; // no solution
+    }
+  }
+  // Back substitution to get a particular solution (free vars = 0)
+  const solution = Array(cols).fill(0);
+  for (let i = 0; i < r; i++) {
+    const c = pivotCol[i];
+    solution[c] = M[i][cols] % mod;
+  }
+  // Note: This provides one solution; not necessarily minimal total presses.
+  return solution;
+}
+
+// Compute modular inverse using extended Euclidean (mod is prime)
+function modInv(a: number, mod: number): number {
+  let [t, newT] = [0, 1];
+  let [r, newR] = [mod, ((a % mod) + mod) % mod];
+  while (newR !== 0) {
+    const quotient = Math.floor(r / newR);
+    [t, newT] = [newT, t - quotient * newT];
+    [r, newR] = [newR, r - quotient * newR];
+  }
+  if (r > 1) throw new Error('a is not invertible');
+  if (t < 0) t += mod;
+  return t;
+}
