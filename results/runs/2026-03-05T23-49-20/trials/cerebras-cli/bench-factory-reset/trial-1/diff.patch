l(lights);\n    }\n  });\n});\n"},"output":"Wrote file successfully.","title":"src/factory-reset.test.ts","metadata":{"diagnostics":{},"filepath":"/workspace/src/factory-reset.test.ts","exists":false,"truncated":false},"time":{"start":1772755251879,"end":1772755251887}}}}
