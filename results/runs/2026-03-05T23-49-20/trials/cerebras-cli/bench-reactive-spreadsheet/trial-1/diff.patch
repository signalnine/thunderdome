+/**
+ * Simple recursive‑descent parser for spreadsheet formulas.
+ * Supports numbers, strings (double‑quoted), booleans, cell references, ranges, arithmetic,
+ * comparison operators, parentheses, and function calls.
+ */
+
+import { isCellRef, expandRange, unquote } from './utils';
+
+/** AST node definitions */
+export type ASTNode =
+  | { type: 'Number'; value: number }
+  | { type: 'String'; value: string }
+  | { type: 'Boolean'; value: boolean }
+  | { type: 'Cell'; ref: string }
+  | { type: 'Range'; start: string; end: string }
+  | { type: 'BinaryOp'; operator: string; left: ASTNode; right: ASTNode }
+  | { type: 'Function'; name: string; args: ASTNode[] };
+
+/** Token types */
+type Token =
+  | { type: 'Number'; value: number }
+  | { type: 'String'; value: string }
+  | { type: 'Identifier'; value: string }
+  | { type: 'Operator'; value: string }
+  | { type: 'Paren'; value: '(' | ')' }
+  | { type: 'Comma' }
+  | { type: 'Colon' };
+
+/** Lexical analysis */
+function tokenize(input: string): Token[] {
+  const tokens: Token[] = [];
+  let i = 0;
+  const len = input.length;
+  const isWhite = (c: string) => /\s/.test(c);
+  while (i < len) {
+    const ch = input[i];
+    if (isWhite(ch)) {
+      i++;
+      continue;
+    }
+    // Number (integer or float)
+    if (/[0-9]/.test(ch) || (ch === '.' && i + 1 < len && /[0-9]/.test(input[i + 1]))) {
+      let numStr = '';
+      while (i < len && /[0-9.]/.test(input[i])) {
+        numStr += input[i++];
+      }
+      tokens.push({ type: 'Number', value: parseFloat(numStr) });
+      continue;
+    }
+    // String literal "..."
+    if (ch === '"') {
+      let str = '';
+      i++; // skip opening quote
+      while (i < len && input[i] !== '"') {
+        // support escaped quote \"
+        if (input[i] === '\\' && i + 1 < len && input[i + 1] === '"') {
+          str += '"';
+          i += 2;
+        } else {
+          str += input[i++];
+        }
+      }
+      i++; // skip closing quote
+      tokens.push({ type: 'String', value: str });
+      continue;
+    }
+    // Identifier (function name or cell reference) – letters followed by optional digits
+    if (/[A-Za-z]/.test(ch)) {
+      let id = '';
+      while (i < len && /[A-Za-z0-9]/.test(input[i])) {
+        id += input[i++];
+      }
+      tokens.push({ type: 'Identifier', value: id.toUpperCase() });
+      continue;
+    }
+    // Operators and punctuation
+    const twoChar = input.substr(i, 2);
+    if (['>=', '<=', '<>'].includes(twoChar)) {
+      tokens.push({ type: 'Operator', value: twoChar });
+      i += 2;
+      continue;
+    }
+    if (['+', '-', '*', '/', '>', '<', '=', '(', ')', ','].includes(ch)) {
+      if (ch === '(' || ch === ')') {
+        tokens.push({ type: 'Paren', value: ch as '(' | ')' });
+      } else if (ch === ',') {
+        tokens.push({ type: 'Comma' });
+      } else {
+        tokens.push({ type: 'Operator', value: ch });
+      }
+      i++;
+      continue;
+    }
+    if (ch === ':') {
+      tokens.push({ type: 'Colon' });
+      i++;
+      continue;
+    }
+    throw new Error(`Unexpected character '${ch}' at position ${i}`);
+  }
+  return tokens;
+}
+
+/** Parser class implementing precedence climbing */
+class Parser {
+  private tokens: Token[];
+  private pos = 0;
+  constructor(tokens: Token[]) {
+    this.tokens = tokens;
+  }
+  private peek(): Token | null {
+    return this.tokens[this.pos] ?? null;
+  }
+  private consume(): Token {
+    const t = this.tokens[this.pos];
+    this.pos++;
+    return t;
+  }
+  private match(type: Token['type'], value?: any): boolean {
+    const t = this.peek();
+    if (!t) return false;
+    if (t.type !== type) return false;
+    if (value !== undefined && (t as any).value !== value) return false;
+    return true;
+  }
+
+  public parseExpression(): ASTNode {
+    return this.parseComparison();
+  }
+
+  // Comparison operators have lowest precedence
+  private parseComparison(): ASTNode {
+    let node = this.parseAddSub();
+    while (this.match('Operator')) {
+      const op = (this.peek() as any).value;
+      if (!['>', '<', '>=', '<=', '=', '<>'].includes(op)) break;
+      this.consume();
+      const right = this.parseAddSub();
+      node = { type: 'BinaryOp', operator: op, left: node, right };
+    }
+    return node;
+  }
+
+  private parseAddSub(): ASTNode {
+    let node = this.parseMulDiv();
+    while (this.match('Operator', '+') || this.match('Operator', '-')) {
+      const op = (this.consume() as any).value;
+      const right = this.parseMulDiv();
+      node = { type: 'BinaryOp', operator: op, left: node, right };
+    }
+    return node;
+  }
+
+  private parseMulDiv(): ASTNode {
+    let node = this.parseUnary();
+    while (this.match('Operator', '*') || this.match('Operator', '/')) {
+      const op = (this.consume() as any).value;
+      const right = this.parseUnary();
+      node = { type: 'BinaryOp', operator: op, left: node, right };
+    }
+    return node;
+  }
+
+  private parseUnary(): ASTNode {
+    if (this.match('Operator', '+') || this.match('Operator', '-')) {
+      const op = (this.consume() as any).value;
+      const expr = this.parseUnary();
+      // Represent unary minus as binary 0 - expr
+      if (op === '-') {
+        return { type: 'BinaryOp', operator: '-', left: { type: 'Number', value: 0 }, right: expr };
+      }
+      return expr; // unary plus does nothing
+    }
+    return this.parsePrimary();
+  }
+
+  private parsePrimary(): ASTNode {
+    const token = this.peek();
+    if (!token) throw new Error('Unexpected end of input');
+    // Parenthesized expression
+    if (token.type === 'Paren' && token.value === '(') {
+      this.consume(); // '('
+      const expr = this.parseExpression();
+      if (!this.match('Paren', ')')) throw new Error('Missing closing parenthesis');
+      this.consume();
+      return expr;
+    }
+    // Number literal
+    if (token.type === 'Number') {
+      this.consume();
+      return { type: 'Number', value: token.value };
+    }
+    // String literal
+    if (token.type === 'String') {
+      this.consume();
+      return { type: 'String', value: token.value };
+    }
+    // Identifier – could be boolean, cell ref, function, or range
+    if (token.type === 'Identifier') {
+      const id = token.value;
+      this.consume();
+      // Boolean literals
+      if (id === 'TRUE') return { type: 'Boolean', value: true };
+      if (id === 'FALSE') return { type: 'Boolean', value: false };
+      // Peek ahead for '(' → function call
+      if (this.match('Paren', '(')) {
+        this.consume(); // '('
+        const args: ASTNode[] = [];
+        if (!this.match('Paren', ')')) {
+          while (true) {
+            args.push(this.parseExpression());
+            if (this.match('Comma')) {
+              this.consume();
+              continue;
+            }
+            break;
+          }
+        }
+        if (!this.match('Paren', ')')) throw new Error('Missing closing parenthesis for function');
+        this.consume();
+        return { type: 'Function', name: id, args };
+      }
+      // Range detection – if next token is ':' then another identifier
+      if (this.match('Colon')) {
+        this.consume(); // ':'
+        const next = this.peek();
+        if (!next || next.type !== 'Identifier') throw new Error('Invalid range syntax');
+        const endId = (this.consume() as any).value;
+        return { type: 'Range', start: id, end: endId };
+      }
+      // Otherwise treat as cell reference
+      if (isCellRef(id)) {
+        return { type: 'Cell', ref: id };
+      }
+      // Fallback – treat unknown identifier as cell (will error later)
+      return { type: 'Cell', ref: id };
+    }
+    throw new Error(`Unexpected token ${JSON.stringify(token)}`);
+  }
+}
+
+/** Public parse function – input without leading '=' */
+export function parseFormula(formula: string): ASTNode {
+  const tokens = tokenize(formula);
+  const parser = new Parser(tokens);
+  const ast = parser.parseExpression();
+  if (parser.peek() !== null) {
+    throw new Error('Unexpected token after end of expression');
+  }
+  return ast;
+}
