new file mode 100644
index 0000000..83899e1
--- /dev/null
+++ b/src/Evaluator.ts
@@ -0,0 +1,79 @@
+/**
+ * Evaluator walks the AST and computes a value using the Spreadsheet's cell getter.
+ */
+import { ASTNode } from './Parser';
+import { functionsMap } from './functions';
+import { expandRange, isCellRef, toDisplay } from './utils';
+
+/** Interface that Spreadsheet must implement for evaluator to fetch values */
+export interface ValueProvider {
+  getCellValue(ref: string): any; // returns computed value or null
+}
+
+export function evaluate(ast: ASTNode, provider: ValueProvider): any {
+  switch (ast.type) {
+    case 'Number':
+      return ast.value;
+    case 'String':
+      return ast.value;
+    case 'Boolean':
+      return ast.value;
+    case 'Cell': {
+      return provider.getCellValue(ast.ref);
+    }
+    case 'Range': {
+      // Return array of values for each cell in range
+      const refs = expandRange(`${ast.start}:${ast.end}`);
+      return refs.map(r => provider.getCellValue(r));
+    }
+    case 'BinaryOp': {
+      const left = evaluate(ast.left, provider);
+      const right = evaluate(ast.right, provider);
+      switch (ast.operator) {
+        case '+':
+          return (left ?? 0) + (right ?? 0);
+        case '-':
+          return (left ?? 0) - (right ?? 0);
+        case '*':
+          return (left ?? 0) * (right ?? 0);
+        case '/':
+          return (right === 0) ? NaN : (left ?? 0) / (right ?? 0);
+        case '>':
+          return left > right;
+        case '<':
+          return left < right;
+        case '>=':
+          return left >= right;
+        case '<=':
+          return left <= right;
+        case '=':
+          return left === right;
+        case '<>':
+          return left !== right;
+        default:
+          throw new Error(`Unsupported operator ${ast.operator}`);
+      }
+    }
+    case 'Function': {
+      const fn = functionsMap[ast.name];
+      if (!fn) throw new Error(`Unknown function ${ast.name}`);
+      // Evaluate args; if argument is a range node, evaluator returns array of values.
+      const evaluatedArgs = ast.args.map(arg => {
+        const val = evaluate(arg, provider);
+        // flatten range arrays into individual arguments (spread)
+        if (Array.isArray(val)) return val;
+        return val;
+      });
+      // functionsMap expects flat list; spread arrays
+      const flat: any[] = [];
+      for (const a of evaluatedArgs) {
+        if (Array.isArray(a)) flat.push(...a);
+        else flat.push(a);
+      }
+      return fn(...flat);
+    }
+    default:
+      const _exhaustiveCheck: never = ast;
+      return _exhaustiveCheck;
+  }
+}
