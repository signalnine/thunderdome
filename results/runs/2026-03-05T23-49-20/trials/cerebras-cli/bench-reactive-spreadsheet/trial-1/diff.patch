+{"type":"tool_use","timestamp":1772755111173,"sessionID":"ses_33f8feb1dffeT17saeJkljdm3R","part":{"id":"prt_cc0704b990016Klk8Qa05uvD5O","sessionID":"ses_33f8feb1dffeT17saeJkljdm3R","messageID":"msg_cc0704827002o15djq341TYxUw","type":"tool","callID":"387fefdc4","tool":"write","state":{"status":"completed","input":{"filePath":"/workspace/src/DependencyGraph.ts","content":"/**\n * Simple directed dependency graph for spreadsheet cells.\n * Provides methods to add/remove edges and compute recompute order.\n */\n\nexport class DependencyGraph {\n  // map from a cell to set of cells that depend on it (outgoing edges from key to each dependent)\n  private dependents: Map<string, Set<string>> = new Map();\n  // map from a cell to set of cells it depends on (incoming edges)\n  private dependencies: Map<string, Set<string>> = new Map();\n\n  /** Add dependencies for a cell based on new list of sources */\n  addDependencies(cell: string, sources: Set<string>) {\n    // Remove existing edges first\n    this.removeAllDependencies(cell);\n    // Add new edges\n    for (const src of sources) {\n      // cycle detection before adding\n      if (this.wouldCreateCycle(src, cell)) {\n        throw new Error(`Circular dependency detected when adding ${cell} depends on ${src}`);\n      }\n      // update dependents map\n      if (!this.dependents.has(src)) this.dependents.set(src, new Set());\n      this.dependents.get(src)!.add(cell);\n      // update dependencies map\n      if (!this.dependencies.has(cell)) this.dependencies.set(cell, new Set());\n      this.dependencies.get(cell)!.add(src);\n    }\n  }\n\n  /** Remove all dependencies for a cell (used when updating formula) */\n  removeAllDependencies(cell: string) {\n    const current = this.dependencies.get(cell);\n    if (!current) return;\n    for (const src of current) {\n      const depSet = this.dependents.get(src);\n      if (depSet) depSet.delete(cell);\n      if (depSet && depSet.size === 0) this.dependents.delete(src);\n    }\n    this.dependencies.delete(cell);\n  }\n\n  /** Get all cells that (directly or indirectly) depend on the given cell */\n  getTransitiveDependents(start: string): Set<string> {\n    const visited = new Set<string>();\n    const stack = [start];\n    while (stack.length) {\n      const cur = stack.pop()!;\n      const deps = this.dependents.get(cur);\n      if (!deps) continue;\n      for (const d of deps) {\n        if (!visited.has(d)) {\n          visited.add(d);\n          stack.push(d);\n        }\n      }\n    }\n    return visited;\n  }\n\n  /** Detect if adding edge src -> dest would create a cycle */\n  private wouldCreateCycle(src: string, dest: string): boolean {\n    if (src === dest) return true;\n    // If dest can reach src via existing dependents, adding src->dest creates a cycle.\n    const reachable = this.getTransitiveDependents(dest);\n    return reachable.has(src);\n  }\n}\n","encoding":"utf-8"},"output":"Wrote file successfully.","title":"src/DependencyGraph.ts","metadata":{"diagnostics":{},"filepath":"/workspace/src/DependencyGraph.ts","exists":false,"truncated":false},"time":{"start":1772755111168,"end":1772755111173}}}}
