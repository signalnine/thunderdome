+/**
+ * Built‑in spreadsheet functions.
+ * Each function receives evaluated arguments (already converted to JS values).
+ */
+import { isNumeric } from './utils';
+
+type Value = any; // number|string|boolean|null
+
+export const functionsMap: Record<string, (...args: Value[]) => Value> = {
+  SUM(...args: Value[]) {
+    let sum = 0;
+    for (const v of args) {
+      if (isNumeric(v)) sum += v;
+    }
+    return sum;
+  },
+  AVERAGE(...args: Value[]) {
+    let sum = 0;
+    let count = 0;
+    for (const v of args) {
+      if (isNumeric(v)) {
+        sum += v;
+        count++;
+      }
+    }
+    return count === 0 ? 0 : sum / count;
+  },
+  MIN(...args: Value[]) {
+    const nums = args.filter(isNumeric);
+    return nums.length ? Math.min(...nums) : 0;
+  },
+  MAX(...args: Value[]) {
+    const nums = args.filter(isNumeric);
+    return nums.length ? Math.max(...nums) : 0;
+  },
+  COUNT(...args: Value[]) {
+    return args.filter(isNumeric).length;
+  },
+  IF(cond: Value, trueVal: Value, falseVal: Value) {
+    // treat truthy per JS rules, except empty string and null are falsy
+    return cond ? trueVal : falseVal;
+  },
+};
