+/**
+ * Utility functions for cell reference parsing and range handling.
+ */
+
+/** Convert a column label (e.g., 'A', 'Z', 'AA') to zero‑based index */
+export function colLabelToIndex(label: string): number {
+  let index = 0;
+  for (let i = 0; i < label.length; i++) {
+    const charCode = label.charCodeAt(i) - 64; // 'A' -> 1
+    index = index * 26 + charCode;
+  }
+  return index - 1; // zero based
+}
+
+/** Convert zero‑based column index to label */
+export function indexToColLabel(index: number): string {
+  let label = '';
+  let n = index + 1; // 1‑based
+  while (n > 0) {
+    const rem = (n - 1) % 26;
+    label = String.fromCharCode(65 + rem) + label;
+    n = Math.floor((n - 1) / 26);
+  }
+  return label;
+}
+
+/** Parse a cell reference like 'B12' into {col: number, row: number} (zero‑based) */
+export function parseCellRef(ref: string): { col: number; row: number } {
+  const match = /^([A-Z]+)(\d+)$/.exec(ref.toUpperCase());
+  if (!match) throw new Error(`Invalid cell reference: ${ref}`);
+  const col = colLabelToIndex(match[1]);
+  const row = parseInt(match[2], 10) - 1; // zero based
+  return { col, row };
+}
+
+/** Convert zero‑based col,row back to cell reference string */
+export function cellCoordToRef(col: number, row: number): string {
+  return `${indexToColLabel(col)}${row + 1}`;
+}
+
+/** Expand a range like 'A1:C3' into an array of cell references */
+export function expandRange(range: string): string[] {
+  const [start, end] = range.split(':');
+  if (!end) return [range]; // not a range
+  const { col: startCol, row: startRow } = parseCellRef(start);
+  const { col: endCol, row: endRow } = parseCellRef(end);
+  const cells: string[] = [];
+  for (let c = Math.min(startCol, endCol); c <= Math.max(startCol, endCol); c++) {
+    for (let r = Math.min(startRow, endRow); r <= Math.max(startRow, endRow); r++) {
+      cells.push(cellCoordToRef(c, r));
+    }
+  }
+  return cells;
+}
+
+/** Check if a string is a valid cell reference */
+export function isCellRef(str: string): boolean {
+  return /^[A-Z]+\d+$/.test(str.toUpperCase());
+}
+
+/** Strip surrounding double quotes from a string literal */
+export function unquote(str: string): string {
+  if (str.length >= 2 && str[0] === '"' && str[str.length - 1] === '"') {
+    return str.slice(1, -1);
+  }
+  return str;
+}
+
+/** Determine if a value is numeric */
+export function isNumeric(val: any): boolean {
+  return typeof val === 'number' && !Number.isNaN(val);
+}
+
+/** Convert various primitive types to string for display */
+export function toDisplay(val: any): string {
+  if (val === null || val === undefined) return '';
+  if (typeof val === 'boolean') return val ? 'TRUE' : 'FALSE';
+  return String(val);
+}
