+{"type":"tool_use","timestamp":1772755109903,"sessionID":"ses_33f8feb1dffeT17saeJkljdm3R","part":{"id":"prt_cc0704765001kQQZYPGktO4fNx","sessionID":"ses_33f8feb1dffeT17saeJkljdm3R","messageID":"msg_cc07043ff0027BelEilDlI0U4I","type":"tool","callID":"b983706c9","tool":"write","state":{"status":"completed","input":{"filePath":"/workspace/src/functions.ts","content":"/**\n * Built‑in spreadsheet functions.\n * Each function receives evaluated arguments (already converted to JS values).\n */\nimport { isNumeric } from './utils';\n\ntype Value = any; // number|string|boolean|null\n\nexport const functionsMap: Record<string, (...args: Value[]) => Value> = {\n  SUM(...args: Value[]) {\n    let sum = 0;\n    for (const v of args) {\n      if (isNumeric(v)) sum += v;\n    }\n    return sum;\n  },\n  AVERAGE(...args: Value[]) {\n    let sum = 0;\n    let count = 0;\n    for (const v of args) {\n      if (isNumeric(v)) {\n        sum += v;\n        count++;\n      }\n    }\n    return count === 0 ? 0 : sum / count;\n  },\n  MIN(...args: Value[]) {\n    const nums = args.filter(isNumeric);\n    return nums.length ? Math.min(...nums) : 0;\n  },\n  MAX(...args: Value[]) {\n    const nums = args.filter(isNumeric);\n    return nums.length ? Math.max(...nums) : 0;\n  },\n  COUNT(...args: Value[]) {\n    return args.filter(isNumeric).length;\n  },\n  IF(cond: Value, trueVal: Value, falseVal: Value) {\n    // treat truthy per JS rules, except empty string and null are falsy\n    return cond ? trueVal : falseVal;\n  },\n};\n","encoding":"utf-8"},"output":"Wrote file successfully.","title":"src/functions.ts","metadata":{"diagnostics":{},"filepath":"/workspace/src/functions.ts","exists":false,"truncated":false},"time":{"start":1772755109893,"end":1772755109902}}}}
