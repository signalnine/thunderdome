+/**
+ * Main Spreadsheet class implementing reactive updates, parsing, evaluation, and circular detection.
+ */
+import { parseFormula, ASTNode } from './Parser';
+import { evaluate, ValueProvider } from './Evaluator';
+import { DependencyGraph } from './DependencyGraph';
+import { isCellRef, expandRange, toDisplay } from './utils';
+
+export class Spreadsheet implements ValueProvider {
+  // raw input values (string formulas prefixed with '=', otherwise literal)
+  private rawValues: Map<string, string | number | boolean> = new Map();
+  // computed values after evaluation
+  private computed: Map<string, any> = new Map();
+  private graph = new DependencyGraph();
+
+  /** Set a cell's raw value or formula */
+  set(cell: string, value: string | number | boolean): void {
+    const cellRef = cell.toUpperCase();
+    if (!isCellRef(cellRef)) throw new Error(`Invalid cell reference ${cell}`);
+    // Store raw value
+    this.rawValues.set(cellRef, value);
+    // Parse dependencies if formula
+    const deps = new Set<string>();
+    let ast: ASTNode | null = null;
+    if (typeof value === 'string' && value.startsWith('=')) {
+      const formulaBody = value.substring(1);
+      ast = parseFormula(formulaBody);
+      // collect dependencies from AST
+      this.collectDependencies(ast, deps);
+    }
+    // Update dependency graph (will throw on circular)
+    this.graph.addDependencies(cellRef, deps);
+    // Recompute this cell and its dependents
+    this.recompute(cellRef);
+  }
+
+  /** Get computed value (null for empty) */
+  get(cell: string): any {
+    const key = cell.toUpperCase();
+    if (!this.computed.has(key)) return null;
+    return this.computed.get(key);
+  }
+
+  /** Return display string */
+  getDisplay(cell: string): string {
+    const val = this.get(cell);
+    return toDisplay(val);
+  }
+
+  /** Return map of all non‑empty computed cells */
+  getCells(): Map<string, any> {
+    const result = new Map<string, any>();
+    for (const [k, v] of this.computed.entries()) {
+      if (v !== null && v !== undefined) result.set(k, v);
+    }
+    return result;
+  }
+
+  /** ValueProvider implementation */
+  getCellValue(ref: string): any {
+    const upper = ref.toUpperCase();
+    // If not computed yet, treat as empty (null)
+    if (!this.computed.has(upper)) return null;
+    return this.computed.get(upper);
+  }
+
+  /** Recompute a cell and all downstream dependents in topological order */
+  private recompute(startCell: string) {
+    // Determine order via BFS from dependencies using topological sort approach.
+    const toRecompute = new Set<string>([startCell, ...this.graph.getTransitiveDependents(startCell)]);
+    // Simple approach: repeatedly evaluate cells whose dependencies are satisfied.
+    // We'll perform a topo sort using Kahn's algorithm.
+    const indegree = new Map<string, number>();
+    // indegree counts only dependencies that are also scheduled for recompute
+    for (const cell of toRecompute) {
+      const depsAll = this.graph._dependencies.get(cell) ?? new Set();
+      const deps = new Set([...depsAll].filter(d => toRecompute.has(d)));
+      indegree.set(cell, deps.size);
+    }
+    const queue: string[] = [];
+    for (const [cell, deg] of indegree.entries()) {
+      if (deg === 0) queue.push(cell);
+    }
+    while (queue.length) {
+      const cur = queue.shift()!;
+      // Evaluate cur
+      const raw = this.rawValues.get(cur);
+      let result: any = null;
+      if (raw !== undefined) {
+        if (typeof raw === 'string' && raw.startsWith('=')) {
+          const ast = parseFormula(raw.substring(1));
+          result = evaluate(ast, this);
+        } else {
+          result = raw;
+        }
+      }
+      this.computed.set(cur, result);
+      // Decrease indegree of dependents within toRecompute
+      const dependents = this.graph._dependents.get(cur);
+      if (dependents) {
+        for (const dep of dependents) {
+          if (!indegree.has(dep)) continue; // not scheduled
+          const deg = indegree.get(dep)! - 1;
+          indegree.set(dep, deg);
+          if (deg === 0) queue.push(dep);
+        }
+      }
+    }
+    // Any remaining cells with indegree >0 indicate a cycle (should not happen due to detection)
+    for (const [cell, deg] of indegree.entries()) {
+      if (deg > 0) {
+        this.computed.set(cell, new Error('Circular dependency'));
+      }
+    }
+
+
+  }
+
+  /** Recursively collect cell references and range cells from AST */
+  private collectDependencies(node: ASTNode, deps: Set<string>) {
+    switch (node.type) {
+      case 'Cell':
+        deps.add(node.ref.toUpperCase());
+        break;
+      case 'Range':
+        for (const ref of expandRange(`${node.start}:${node.end}`)) {
+          deps.add(ref.toUpperCase());
+        }
+        break;
+      case 'BinaryOp':
+        this.collectDependencies(node.left, deps);
+        this.collectDependencies(node.right, deps);
+        break;
+      case 'Function':
+        for (const arg of node.args) this.collectDependencies(arg, deps);
+        break;
+      case 'Number':
+      case 'String':
+      case 'Boolean':
+        // no dependencies
+        break;
+      default:
+        const _exhaustiveCheck: never = node;
+        break;
+    }
+  }
+}
