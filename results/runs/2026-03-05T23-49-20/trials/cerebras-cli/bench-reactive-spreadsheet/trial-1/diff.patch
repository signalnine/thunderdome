+import { describe, it, expect, beforeEach } from 'vitest';
+import { Spreadsheet } from '../src/index';
+
+let sheet: Spreadsheet;
+
+beforeEach(() => {
+  sheet = new Spreadsheet();
+});
+
+describe('Basic value handling', () => {
+  it('stores numbers', () => {
+    sheet.set('A1', 42);
+    expect(sheet.get('A1')).toBe(42);
+    expect(sheet.getDisplay('A1')).toBe('42');
+  });
+  it('stores strings', () => {
+    sheet.set('B1', 'hello');
+    expect(sheet.get('B1')).toBe('hello');
+    expect(sheet.getDisplay('B1')).toBe('hello');
+  });
+  it('stores booleans', () => {
+    sheet.set('C1', true);
+    expect(sheet.get('C1')).toBe(true);
+    expect(sheet.getDisplay('C1')).toBe('TRUE');
+  });
+});
+
+describe('Formula evaluation', () => {
+  it('simple arithmetic', () => {
+    sheet.set('A1', 10);
+    sheet.set('A2', '=A1+5');
+    expect(sheet.get('A2')).toBe(15);
+    sheet.set('A1', 20);
+    expect(sheet.get('A2')).toBe(25);
+  });
+  it('parentheses and precedence', () => {
+    sheet.set('A1', 2);
+    sheet.set('A2', '= (A1 + 3) * 4');
+    expect(sheet.get('A2')).toBe(20);
+  });
+  it('comparison and IF', () => {
+    sheet.set('A1', 5);
+    sheet.set('B1', '=IF(A1>3, "big", "small")');
+    expect(sheet.get('B1')).toBe('big');
+    sheet.set('A1', 2);
+    expect(sheet.get('B1')).toBe('small');
+  });
+});
+
+describe('Built‑in functions', () => {
+  it('SUM and range', () => {
+    sheet.set('A1', 1);
+    sheet.set('A2', 2);
+    sheet.set('A3', 3);
+    sheet.set('B1', '=SUM(A1:A3)');
+    expect(sheet.get('B1')).toBe(6);
+  });
+  it('AVERAGE', () => {
+    sheet.set('A1', 2);
+    sheet.set('A2', 4);
+    sheet.set('B1', '=AVERAGE(A1:A2)');
+    expect(sheet.get('B1')).toBe(3);
+  });
+  it('MIN and MAX', () => {
+    sheet.set('A1', 10);
+    sheet.set('A2', 5);
+    sheet.set('A3', 8);
+    sheet.set('B1', '=MIN(A1:A3)');
+    sheet.set('B2', '=MAX(A1:A3)');
+    expect(sheet.get('B1')).toBe(5);
+    expect(sheet.get('B2')).toBe(10);
+  });
+  it('COUNT', () => {
+    sheet.set('A1', 1);
+    sheet.set('A2', 'text');
+    sheet.set('A3', 3);
+    sheet.set('B1', '=COUNT(A1:A3)');
+    expect(sheet.get('B1')).toBe(2);
+  });
+});
+
+describe('Circular reference detection', () => {
+  it('detects direct cycle', () => {
+    sheet.set('A1', '=B1');
+    expect(() => sheet.set('B1', '=A1')).toThrow(/Circular dependency/);
+  });
+  it('detects indirect cycle', () => {
+    sheet.set('A1', '=B1');
+    sheet.set('B1', '=C1');
+    expect(() => sheet.set('C1', '=A1')).toThrow(/Circular dependency/);
+  });
+});
