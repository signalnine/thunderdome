+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueueManager } from '../src/TaskQueueManager';
+
+describe('Phase 2: Named Queues', () => {
+  let manager: TaskQueueManager;
+
+  beforeEach(() => {
+    manager = new TaskQueueManager();
+  });
+
+  it('should use default queue when no name provided', () => {
+    const task = manager.addTask('default');
+    expect(manager.pendingCount()).toBe(1);
+    const next = manager.getNextTask();
+    expect(next?.payload).toBe('default');
+  });
+
+  it('should create and use named queues independently', () => {
+    const q1 = 'queueA';
+    const q2 = 'queueB';
+    manager.addTask('taskA1', q1);
+    manager.addTask('taskA2', q1);
+    manager.addTask('taskB1', q2);
+
+    // Ensure counts per queue
+    expect(manager.pendingCount(q1)).toBe(2);
+    expect(manager.pendingCount(q2)).toBe(1);
+    expect(manager.pendingCount()).toBe(0); // default queue unchanged
+
+    // Retrieve from q1 in FIFO order
+    const nextA = manager.getNextTask(q1);
+    expect(nextA?.payload).toBe('taskA1');
+    expect(manager.pendingCount(q1)).toBe(1);
+
+    const nextB = manager.getNextTask(q2);
+    expect(nextB?.payload).toBe('taskB1');
+    expect(manager.pendingCount(q2)).toBe(0);
+
+    // After processing remaining, empty queues return null
+    manager.getNextTask(q1); // process second task
+    expect(manager.getNextTask(q1)).toBeNull();
+  });
+
+  it('should list all queue names', () => {
+    manager.addTask('x', 'alpha');
+    manager.addTask('y', 'beta');
+    const names = manager.listQueues().sort();
+    expect(names).toEqual(['alpha', 'beta', 'default'].sort());
+  });
+
+  it('should return null for non-existent queue', () => {
+    expect(manager.getNextTask('ghost')).toBeNull();
+  });
+});
