+{"type":"tool_use","timestamp":1772754677944,"sessionID":"ses_33f96b1a8ffe2XNJFbSkALkDeg","part":{"id":"prt_cc069b01e001M03SdIfTEyBamZ","sessionID":"ses_33f96b1a8ffe2XNJFbSkALkDeg","messageID":"msg_cc069ae5e002LocAz2Mm3HQ5qr","type":"tool","callID":"5376a7755","tool":"write","state":{"status":"completed","input":{"filePath":"/workspace/src/Queue.ts","content":"// src/Queue.ts\nimport { Task, createTask, TaskStatus } from './Task';\n\n/** Simple FIFO queue for tasks. Supports basic operations for Phase 1. */\nexport class Queue {\n  /** Internal storage of tasks in insertion order */\n  private tasks: Task[] = [];\n\n  /** Add a new task with given payload. Returns the created Task */\n  add<T>(payload: T): Task<T> {\n    const task = createTask(payload);\n    this.tasks.push(task);\n    return task;\n  }\n\n  /** Retrieve the next pending task, marking it as processing. */\n  getNext(): Task | null {\n    const idx = this.tasks.findIndex((t) => t.status === 'pending');\n    if (idx === -1) return null;\n    const task = this.tasks[idx];\n    task.status = 'processing' as TaskStatus;\n    task.startedAt = new Date();\n    return task;\n  }\n\n  /** Mark a task as completed (optional utility for later phases) */\n  complete(taskId: string): boolean {\n    const task = this.tasks.find((t) => t.id === taskId);\n    if (!task) return false;\n    task.status = 'completed';\n    task.finishedAt = new Date();\n    return true;\n  }\n\n  /** Return number of pending tasks */\n  pendingCount(): number {\n    return this.tasks.filter((t) => t.status === 'pending').length;\n  }\n\n  /** Return total tasks in queue */\n  length(): number {\n    return this.tasks.length;\n  }\n}\n","overwrite":true},"output":"Wrote file successfully.","title":"src/Queue.ts","metadata":{"diagnostics":{},"filepath":"/workspace/src/Queue.ts","exists":false,"truncated":false},"time":{"start":1772754677938,"end":1772754677943}}}}
