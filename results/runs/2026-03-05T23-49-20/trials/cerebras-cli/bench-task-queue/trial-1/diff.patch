@@ -0,0 +1,33 @@
+// src/Task.ts
+
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';
+
+export interface Task<T = unknown> {
+  /** Unique identifier for the task */
+  id: string;
+  /** Payload data associated with the task */
+  payload: T;
+  /** Current status of the task */
+  status: TaskStatus;
+  /** Timestamp when the task was created */
+  createdAt: Date;
+  /** Timestamp when the task started processing (optional) */
+  startedAt?: Date;
+  /** Timestamp when the task finished (optional) */
+  finishedAt?: Date;
+}
+
+/** Factory function to create a new task */
+export function createTask<T>(payload: T): Task<T> {
+  const id = typeof crypto !== 'undefined' && typeof crypto.randomUUID === 'function'
+    ? crypto.randomUUID()
+    : // fallback for environments without crypto.randomUUID
+      `${Date.now()}-${Math.random().toString(36).substring(2, 9)}`;
+
+  return {
+    id,
+    payload,
+    status: 'pending',
+    createdAt: new Date(),
+  };
+}
