@@ -0,0 +1,59 @@
+// src/TaskQueueManager.ts
+import { Queue } from './Queue.js';
+import { Task } from './Task.js';
+
+/** Manager for handling multiple queues (named queues). For Phase 1 we only need a default queue. */
+export class TaskQueueManager {
+  private queues: Map<string, Queue> = new Map();
+  private readonly defaultQueueName = 'default';
+
+  constructor() {
+    // Ensure default queue exists
+    this.getOrCreateQueue(this.defaultQueueName);
+  }
+
+  private getOrCreateQueue(name: string): Queue {
+    let q = this.queues.get(name);
+    if (!q) {
+      q = new Queue();
+      this.queues.set(name, q);
+    }
+    return q;
+  }
+
+  /** Add a task to a specific queue (or default). */
+  addTask<T>(payload: T, queueName?: string): Task<T> {
+    const name = queueName ?? this.defaultQueueName;
+    const queue = this.getOrCreateQueue(name);
+    return queue.add(payload);
+  }
+
+  /** Retrieve next task from a specific queue (or default). */
+  getNextTask(queueName?: string): Task | null {
+    const name = queueName ?? this.defaultQueueName;
+    const queue = this.queues.get(name);
+    if (!queue) return null;
+    return queue.getNext();
+  }
+
+  /** Get pending count for a queue (or default). */
+  pendingCount(queueName?: string): number {
+    const name = queueName ?? this.defaultQueueName;
+    const queue = this.queues.get(name);
+    if (!queue) return 0;
+    return queue.pendingCount();
+  }
+
+  /** Get total length of a queue (or default). */
+  queueLength(queueName?: string): number {
+    const name = queueName ?? this.defaultQueueName;
+    const queue = this.queues.get(name);
+    if (!queue) return 0;
+    return queue.length();
+  }
+
+  /** List all queue names present */
+  listQueues(): string[] {
+    return Array.from(this.queues.keys());
+  }
+}
