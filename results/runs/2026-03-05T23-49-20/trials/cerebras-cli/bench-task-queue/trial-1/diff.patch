+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueueManager } from '../src/TaskQueueManager';
+
+describe('Phase 1: Basic FIFO Queue', () => {
+  let manager: TaskQueueManager;
+
+  beforeEach(() => {
+    manager = new TaskQueueManager();
+  });
+
+  it('should add tasks and retrieve them in FIFO order', () => {
+    const payloads = ['first', 'second', 'third'];
+    const tasks = payloads.map((p) => manager.addTask(p));
+
+    // Ensure tasks have unique IDs and pending status
+    tasks.forEach((t) => {
+      expect(t.id).toBeTruthy();
+      expect(t.status).toBe('pending');
+    });
+
+    // Retrieve tasks one by one
+    for (let i = 0; i < payloads.length; i++) {
+      const next = manager.getNextTask();
+      expect(next).not.toBeNull();
+      expect(next!.payload).toBe(payloads[i]);
+      expect(next!.status).toBe('processing');
+    }
+
+    // No more tasks
+    expect(manager.getNextTask()).toBeNull();
+  });
+
+  it('should report correct pending count', () => {
+    expect(manager.pendingCount()).toBe(0);
+    manager.addTask('a');
+    manager.addTask('b');
+    expect(manager.pendingCount()).toBe(2);
+    manager.getNextTask(); // processes first task
+    expect(manager.pendingCount()).toBe(1);
+  });
+
+  it('should report correct queue length', () => {
+    expect(manager.queueLength()).toBe(0);
+    manager.addTask(1);
+    manager.addTask(2);
+    expect(manager.queueLength()).toBe(2);
+  });
+});
