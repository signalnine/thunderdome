@@ -0,0 +1,34 @@
+// syntax-highlight plugin: adds language classes and data-language attributes to code blocks
+/**
+ * Implements the Plugin interface.
+ */
+export function createSyntaxHighlightPlugin() {
+  const name = 'syntax-highlight';
+  const version = '1.0.0';
+  const dependencies = [];
+
+  // regex to match <pre><code class="language-xyz">...</code></pre>
+  const codeBlockRegex = /<pre>(\s*)<code\s+class="(language-([^"]+))"(.*?)>([\s\S]*?)<\/code>\s*<\/pre>/gi;
+
+  return {
+    name,
+    version,
+    dependencies,
+    hooks: {
+      async transformContent(file) {
+        let content = file.content;
+        // Replace each code block
+        content = content.replace(codeBlockRegex, (match, preSpace, fullClass, lang, restAttrs, inner) => {
+          // Add highlighted class
+          const newClass = `${fullClass} highlighted`;
+          // Build new code tag
+          const codeTag = `<code class="${newClass}"${restAttrs}>${inner}</code>`;
+          // Add data-language attribute to pre
+          const preTag = `<pre data-language="${lang}">`;
+          return `${preTag}\n${codeTag}\n</pre>`;
+        });
+        return { ...file, content };
+      },
+    },
+  };
+}
