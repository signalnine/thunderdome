@@ -0,0 +1,47 @@
+// markdown-ext plugin: converts markdown to HTML with footnotes and admonitions
+import MarkdownIt from 'markdown-it';
+import footnote from 'markdown-it-footnote';
+import container from 'markdown-it-container';
+
+/**
+ * Plugin interface implementation for markdown extensions.
+ */
+export function createMarkdownExtPlugin() {
+  const name = 'markdown-ext';
+  const version = '1.0.0';
+  const dependencies = [];
+
+  // Helper to create a container renderer that outputs the required classes
+  function makeContainer(name) {
+    return container(name, {
+      render(tokens, idx) {
+        const token = tokens[idx];
+        if (token.nesting === 1) {
+          // opening tag
+          return `<div class="admonition admonition-${name}">\n`;
+        } else {
+          // closing tag
+          return '</div>\n';
+        }
+      },
+    });
+  }
+
+  const md = new MarkdownIt({ html: true })
+    .use(footnote)
+    .use(makeContainer('note'))
+    .use(makeContainer('warning'))
+    .use(makeContainer('tip'));
+
+  return {
+    name,
+    version,
+    dependencies,
+    hooks: {
+      async transformContent(file) {
+        const rendered = md.render(file.content);
+        return { ...file, content: rendered };
+      },
+    },
+  };
+}
