+{"type":"tool_use","timestamp":1772754802807,"sessionID":"ses_33f948db9ffeLbyb0ZTTzhDrSq","part":{"id":"prt_cc06b9702001HM3bOsvYI276aL","sessionID":"ses_33f948db9ffeLbyb0ZTTzhDrSq","messageID":"msg_cc06b940a001w4Tlfru1BiR5vT","type":"tool","callID":"fb8e593b9","tool":"write","state":{"status":"completed","input":{"filePath":"/workspace/src/routes/auth.ts","content":"import { Router, Request, Response } from 'express';\nimport { getDb } from '../db';\nimport { hashPassword, verifyPassword } from '../utils/password';\nimport jwt from 'jsonwebtoken';\nimport { generateUuid } from '../utils/uuid';\n\nconst router = Router();\n\nconst JWT_SECRET = process.env.JWT_SECRET || 'default_secret';\n\n// Register a new user\nrouter.post('/register', (req: Request, res: Response) => {\n  const { email, password, tenantId, role } = req.body;\n  if (!email || !password || !tenantId) {\n    return res.status(400).json({ error: 'email, password, and tenantId required' });\n  }\n  const db = getDb();\n  // Check if email already exists within tenant (email unique globally per schema)\n  const existing = db.prepare('SELECT id FROM users WHERE email = ?').get(email);\n  if (existing) {\n    return res.status(409).json({ error: 'User already exists' });\n  }\n  const passwordHash = hashPassword(password);\n  const id = generateUuid();\n  const userRole = role && ['admin', 'editor', 'viewer'].includes(role) ? role : 'viewer';\n  db.prepare(`INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)`)\n    .run(id, email, passwordHash, tenantId, userRole);\n  return res.status(201).json({ id, email, tenantId, role: userRole });\n});\n\n// Login\nrouter.post('/login', (req: Request, res: Response) => {\n  const { email, password } = req.body;\n  if (!email || !password) {\n    return res.status(400).json({ error: 'email and password required' });\n  }\n  const db = getDb();\n  const user = db.prepare('SELECT id, password_hash, tenant_id, role FROM users WHERE email = ?').get(email);\n  if (!user) {\n    return res.status(401).json({ error: 'Invalid credentials' });\n  }\n  const valid = verifyPassword(password, user.password_hash);\n  if (!valid) {\n    return res.status(401).json({ error: 'Invalid credentials' });\n  }\n  const token = jwt.sign({ sub: user.id }, JWT_SECRET, { expiresIn: '7d' });\n  return res.json({ token });\n});\n\n// Get profile (protected)\nrouter.get('/profile', (req: any, res: Response) => {\n  const user = req.user; // set by auth middleware\n  if (!user) {\n    return res.status(401).json({ error: 'Unauthenticated' });\n  }\n  const db = getDb();\n  const row = db.prepare('SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?').get(user.id);\n  if (!row) {\n    return res.status(404).json({ error: 'User not found' });\n  }\n  return res.json({ id: row.id, email: row.email, tenantId: row.tenant_id, role: row.role, createdAt: row.created_at });\n});\n\n// Admin change role of a user within same tenant\nrouter.post('/change-role', (req: any, res: Response) => {\n  const { targetUserId, newRole } = req.body;\n  const requester = req.user;\n  if (!requester) return res.status(401).json({ error: 'Unauthenticated' });\n  if (requester.role !== 'admin') return res.status(403).json({ error: 'Admin role required' });\n  if (!['admin', 'editor', 'viewer'].includes(newRole)) {\n    return res.status(400).json({ error: 'Invalid role' });\n  }\n  const db = getDb();\n  // Ensure target user belongs to same tenant\n  const target = db.prepare('SELECT tenant_id FROM users WHERE id = ?').get(targetUserId);\n  if (!target) return res.status(404).json({ error: 'Target user not found' });\n  if (target.tenant_id !== requester.tenantId) {\n    return res.status(403).json({ error: 'Cannot modify user from different tenant' });\n  }\n  db.prepare('UPDATE users SET role = ? WHERE id = ?').run(newRole, targetUserId);\n  return res.json({ success: true });\n});\n\nexport default router;\n","encoding":"utf-8"}