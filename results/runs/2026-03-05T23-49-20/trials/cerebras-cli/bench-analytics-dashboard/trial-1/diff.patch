+{"type":"tool_use","timestamp":1772754801644,"sessionID":"ses_33f948db9ffeLbyb0ZTTzhDrSq","part":{"id":"prt_cc06b9355001TCBNUvOkQGAigh","sessionID":"ses_33f948db9ffeLbyb0ZTTzhDrSq","messageID":"msg_cc06b91e6002R87EG9bybkb9Ur","type":"tool","callID":"5b75403b1","tool":"write","state":{"status":"completed","input":{"filePath":"/workspace/src/middleware/auth.ts","content":"import { Request, Response, NextFunction } from 'express';\nimport jwt from 'jsonwebtoken';\nimport { getDb } from '../db';\n\nexport interface AuthenticatedRequest extends Request {\n  user?: {\n    id: string;\n    tenantId: string;\n    role: string;\n  };\n}\n\nconst JWT_SECRET = process.env.JWT_SECRET || 'default_secret';\n\nexport const authMiddleware = (req: AuthenticatedRequest, res: Response, next: NextFunction) => {\n  const authHeader = req.headers.authorization;\n  if (!authHeader || !authHeader.startsWith('Bearer ')) {\n    return res.status(401).json({ error: 'Missing Authorization header' });\n  }\n  const token = authHeader.slice(7);\n  try {\n    const payload = jwt.verify(token, JWT_SECRET) as any;\n    // Verify user exists and belongs to tenant\n    const db = getDb();\n    const row = db.prepare('SELECT id, tenant_id, role FROM users WHERE id = ?').get(payload.sub);\n    if (!row) {\n      return res.status(401).json({ error: 'Invalid token user' });\n    }\n    req.user = {\n      id: row.id,\n      tenantId: row.tenant_id,\n      role: row.role,\n    };\n    next();\n  } catch (err) {\n    return res.status(401).json({ error: 'Invalid token' });\n  }\n};\n","encoding":"utf-8"},"output":"Wrote file successfully.","title":"src/middleware/auth.ts","metadata":{"diagnostics":{},"filepath":"/workspace/src/middleware/auth.ts","exists":false,"truncated":false},"time":{"start":1772754801636,"end":1772754801643}}}}
