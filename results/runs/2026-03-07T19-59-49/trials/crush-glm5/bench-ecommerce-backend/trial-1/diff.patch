diff --git a/src/analytics/index.ts b/src/analytics/index.ts
new file mode 100644
index 0000000..8fb9df1
--- /dev/null
+++ b/src/analytics/index.ts
@@ -0,0 +1,124 @@
+import { EventBus } from '../bus.js';
+import {
+  AnalyticsService,
+  Events,
+  CartUpdatedEvent,
+  OrderCreatedEvent,
+  PaymentProcessedEvent,
+  PaymentStatus,
+  AnalyticsEvent,
+} from '../types.js';
+
+export function createAnalyticsService(bus: EventBus): AnalyticsService {
+  const eventCounts = new Map<string, number>();
+  const orderTotals = new Map<string, number>();
+  const cartIds = new Set<string>();
+  const orderIds = new Set<string>();
+  const productCounts = new Map<string, number>();
+  const cartItems = new Map<string, Array<{ productId: string; quantity: number }>>();
+  const successfulPayments = new Set<string>();
+
+  const trackEvent = (event: string) => {
+    const count = eventCounts.get(event) || 0;
+    eventCounts.set(event, count + 1);
+  };
+
+  bus.on(Events.PRODUCT_CREATED, (payload: unknown) => {
+    trackEvent(Events.PRODUCT_CREATED);
+    bus.emit(Events.ANALYTICS_EVENT, {
+      event: Events.PRODUCT_CREATED,
+      data: payload as Record<string, unknown>,
+      timestamp: Date.now(),
+    } as AnalyticsEvent);
+  });
+
+  bus.on(Events.INVENTORY_UPDATED, (_payload: unknown) => {
+    trackEvent(Events.INVENTORY_UPDATED);
+  });
+
+  bus.on(Events.LOW_STOCK_ALERT, (_payload: unknown) => {
+    trackEvent(Events.LOW_STOCK_ALERT);
+  });
+
+  bus.on(Events.CART_UPDATED, (payload: unknown) => {
+    trackEvent(Events.CART_UPDATED);
+    const event = payload as CartUpdatedEvent;
+    cartIds.add(event.cartId);
+    cartItems.set(event.cartId, event.items);
+  });
+
+  bus.on(Events.PRICE_CALCULATED, (_payload: unknown) => {
+    trackEvent(Events.PRICE_CALCULATED);
+  });
+
+  bus.on(Events.ORDER_CREATED, (payload: unknown) => {
+    trackEvent(Events.ORDER_CREATED);
+    const event = payload as OrderCreatedEvent;
+    orderIds.add(event.orderId);
+    orderTotals.set(event.orderId, event.total);
+
+    const items = cartItems.get(event.cartId);
+    if (items) {
+      for (const item of items) {
+        const count = productCounts.get(item.productId) || 0;
+        productCounts.set(item.productId, count + item.quantity);
+      }
+    }
+
+    bus.emit(Events.ANALYTICS_EVENT, {
+      event: Events.ORDER_CREATED,
+      data: payload as Record<string, unknown>,
+      timestamp: Date.now(),
+    } as AnalyticsEvent);
+  });
+
+  bus.on(Events.ORDER_STATUS_CHANGED, (_payload: unknown) => {
+    trackEvent(Events.ORDER_STATUS_CHANGED);
+  });
+
+  bus.on(Events.PAYMENT_PROCESSED, (payload: unknown) => {
+    trackEvent(Events.PAYMENT_PROCESSED);
+    const event = payload as PaymentProcessedEvent;
+    if (event.status === PaymentStatus.SUCCESS) {
+      successfulPayments.add(event.orderId);
+      bus.emit(Events.ANALYTICS_EVENT, {
+        event: Events.PAYMENT_PROCESSED,
+        data: payload as Record<string, unknown>,
+        timestamp: Date.now(),
+      } as AnalyticsEvent);
+    }
+  });
+
+  bus.on(Events.NOTIFICATION_SENT, (_payload: unknown) => {
+    trackEvent(Events.NOTIFICATION_SENT);
+  });
+
+  return {
+    getEventCount(eventType: string): number {
+      return eventCounts.get(eventType) || 0;
+    },
+
+    getRevenue(): number {
+      let revenue = 0;
+      for (const orderId of successfulPayments) {
+        const total = orderTotals.get(orderId);
+        if (total !== undefined) {
+          revenue += total;
+        }
+      }
+      return revenue;
+    },
+
+    getConversionRate(): number {
+      if (cartIds.size === 0) return 0;
+      return orderIds.size / cartIds.size;
+    },
+
+    getTopProducts(limit: number): Array<{ productId: string; count: number }> {
+      const sorted = Array.from(productCounts.entries())
+        .map(([productId, count]) => ({ productId, count }))
+        .sort((a, b) => b.count - a.count);
+      return sorted.slice(0, limit);
+    },
+  };
+}
