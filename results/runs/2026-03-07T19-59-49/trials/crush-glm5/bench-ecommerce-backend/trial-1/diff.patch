+import { EventBus } from '../bus.js';
+import { PaymentService, PaymentStatus, Events, PaymentProcessedEvent } from '../types.js';
+
+export interface PaymentServiceOptions {
+  simulateFailure?: boolean;
+  simulateTimeout?: boolean;
+}
+
+export function createPaymentService(bus: EventBus, options?: PaymentServiceOptions): PaymentService {
+  const transactions = new Map<string, { orderId: string; amount: number; status: PaymentStatus; refunded: boolean }>();
+
+  return {
+    async processPayment(
+      orderId: string,
+      amount: number
+    ): Promise<{ status: PaymentStatus; transactionId?: string; error?: string }> {
+      if (options?.simulateTimeout) {
+        const txId = `tx_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`;
+        transactions.set(txId, { orderId, amount, status: PaymentStatus.TIMEOUT, refunded: false });
+        await bus.emit(Events.PAYMENT_PROCESSED, {
+          orderId,
+          status: PaymentStatus.TIMEOUT,
+          transactionId: txId,
+          error: 'Payment timeout',
+        } as PaymentProcessedEvent);
+        return { status: PaymentStatus.TIMEOUT, transactionId: txId, error: 'Payment timeout' };
+      }
+
+      if (options?.simulateFailure) {
+        const txId = `tx_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`;
+        transactions.set(txId, { orderId, amount, status: PaymentStatus.FAILED, refunded: false });
+        await bus.emit(Events.PAYMENT_PROCESSED, {
+          orderId,
+          status: PaymentStatus.FAILED,
+          transactionId: txId,
+          error: 'Payment declined',
+        } as PaymentProcessedEvent);
+        return { status: PaymentStatus.FAILED, transactionId: txId, error: 'Payment declined' };
+      }
+
+      const txId = `tx_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`;
+      transactions.set(txId, { orderId, amount, status: PaymentStatus.SUCCESS, refunded: false });
+      await bus.emit(Events.PAYMENT_PROCESSED, {
+        orderId,
+        status: PaymentStatus.SUCCESS,
+        transactionId: txId,
+      } as PaymentProcessedEvent);
+      return { status: PaymentStatus.SUCCESS, transactionId: txId };
+    },
+
+    async refund(transactionId: string): Promise<boolean> {
+      const tx = transactions.get(transactionId);
+      if (!tx || tx.status !== PaymentStatus.SUCCESS || tx.refunded) {
+        return false;
+      }
+      tx.refunded = true;
+      return true;
+    },
+  };
+}
