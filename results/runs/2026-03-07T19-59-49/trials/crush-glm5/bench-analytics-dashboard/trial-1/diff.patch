+++ b/src/query/router.ts
@@ -0,0 +1,245 @@
+import express from 'express';
+import { getDb } from '../db.js';
+import { createError } from '../errors.js';
+import { authMiddleware } from '../auth.js';
+
+const router = express.Router();
+
+interface CountBody {
+  event_name?: string;
+  start?: string;
+  end?: string;
+}
+
+interface TimeseriesBody {
+  event_name?: string;
+  bucket?: string;
+  start?: string;
+  end?: string;
+}
+
+interface BreakdownBody {
+  event_name?: string;
+  property_key?: string;
+  start?: string;
+  end?: string;
+}
+
+interface FunnelBody {
+  steps?: string[];
+  start?: string;
+  end?: string;
+}
+
+router.post('/count', authMiddleware, (req: express.Request<object, object, CountBody>, res, next) => {
+  try {
+    const { event_name, start, end } = req.body;
+
+    if (!event_name) {
+      return next(createError('event_name is required', 400, 'VALIDATION_ERROR'));
+    }
+
+    const db = getDb();
+    const tenantId = req.user!.tenantId;
+
+    let query = 'SELECT COUNT(*) as count FROM events WHERE tenant_id = ? AND name = ?';
+    const params: (string | null)[] = [tenantId, event_name];
+
+    if (start) {
+      query += ' AND timestamp >= ?';
+      params.push(start);
+    }
+    if (end) {
+      query += ' AND timestamp <= ?';
+      params.push(end);
+    }
+
+    const result = db.prepare(query).get(...params) as { count: number };
+
+    res.json({ count: result.count });
+  } catch (err) {
+    next(err);
+  }
+});
+
+router.post('/timeseries', authMiddleware, (req: express.Request<object, object, TimeseriesBody>, res, next) => {
+  try {
+    const { event_name, bucket = 'day', start, end } = req.body;
+
+    if (!event_name) {
+      return next(createError('event_name is required', 400, 'VALIDATION_ERROR'));
+    }
+
+    const db = getDb();
+    const tenantId = req.user!.tenantId;
+
+    let dateFormat: string;
+    switch (bucket) {
+      case 'hour':
+        dateFormat = '%Y-%m-%dT%H:00:00Z';
+        break;
+      case 'day':
+        dateFormat = '%Y-%m-%dT00:00:00Z';
+        break;
+      case 'week':
+        dateFormat = '%Y-%W';
+        break;
+      case 'month':
+        dateFormat = '%Y-%m-01T00:00:00Z';
+        break;
+      default:
+        dateFormat = '%Y-%m-%dT00:00:00Z';
+    }
+
+    let query = `
+      SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count
+      FROM events
+      WHERE tenant_id = ? AND name = ?
+    `;
+    const params: (string | null)[] = [tenantId, event_name];
+
+    if (start) {
+      query += ' AND timestamp >= ?';
+      params.push(start);
+    }
+    if (end) {
+      query += ' AND timestamp <= ?';
+      params.push(end);
+    }
+
+    query += " GROUP BY bucket ORDER BY bucket";
+
+    const results = db.prepare(query).all(...params) as Array<{ bucket: string; count: number }>;
+
+    res.json({ data: results });
+  } catch (err) {
+    next(err);
+  }
+});
+
+router.post('/breakdown', authMiddleware, (req: express.Request<object, object, BreakdownBody>, res, next) => {
+  try {
+    const { event_name, property_key, start, end } = req.body;
+
+    if (!event_name) {
+      return next(createError('event_name is required', 400, 'VALIDATION_ERROR'));
+    }
+    if (!property_key) {
+      return next(createError('property_key is required', 400, 'VALIDATION_ERROR'));
+    }
+
+    const db = getDb();
+    const tenantId = req.user!.tenantId;
+
+    let query = `
+      SELECT properties, COUNT(*) as count
+      FROM events
+      WHERE tenant_id = ? AND name = ?
+    `;
+    const params: (string | null)[] = [tenantId, event_name];
+
+    if (start) {
+      query += ' AND timestamp >= ?';
+      params.push(start);
+    }
+    if (end) {
+      query += ' AND timestamp <= ?';
+      params.push(end);
+    }
+
+    query += ' GROUP BY properties';
+
+    const results = db.prepare(query).all(...params) as Array<{ properties: string; count: number }>;
+
+    const breakdown: Array<{ property_value: string; count: number }> = [];
+    const valueCounts = new Map<string, number>();
+
+    for (const row of results) {
+      try {
+        const props = JSON.parse(row.properties) as Record<string, unknown>;
+        const value = props[property_key];
+        const valueStr = value !== undefined ? String(value) : '(none)';
+        valueCounts.set(valueStr, (valueCounts.get(valueStr) || 0) + row.count);
+      } catch {
+        valueCounts.set('(none)', (valueCounts.get('(none)') || 0) + row.count);
+      }
+    }
+
+    for (const [property_value, count] of valueCounts) {
+      breakdown.push({ property_value, count });
+    }
+
+    breakdown.sort((a, b) => b.count - a.count);
+
+    res.json({ data: breakdown });
+  } catch (err) {
+    next(err);
+  }
+});
+
+router.post('/funnel', authMiddleware, (req: express.Request<object, object, FunnelBody>, res, next) => {
+  try {
+    const { steps, start, end } = req.body;
+
+    if (!steps || !Array.isArray(steps) || steps.length === 0) {
+      return next(createError('steps array is required', 400, 'VALIDATION_ERROR'));
+    }
+
+    const db = getDb();
+    const tenantId = req.user!.tenantId;
+
+    const stepResults: Array<{ step: string; count: number }> = [];
+
+    for (let i = 0; i < steps.length; i++) {
+      const stepName = steps[i];
+
+      let query = `
+        SELECT COUNT(DISTINCT session_id) as count
+        FROM events
+        WHERE tenant_id = ? AND name = ?
+      `;
+      const params: (string | null)[] = [tenantId, stepName];
+
+      if (start) {
+        query += ' AND timestamp >= ?';
+        params.push(start);
+      }
+      if (end) {
+        query += ' AND timestamp <= ?';
+        params.push(end);
+      }
+
+      if (i > 0) {
+        const prevStep = steps[i - 1];
+        query = `
+          SELECT COUNT(DISTINCT e1.session_id) as count
+          FROM events e1
+          INNER JOIN events e2 ON e1.session_id = e2.session_id
+          WHERE e1.tenant_id = ? AND e1.name = ?
+            AND e2.tenant_id = ? AND e2.name = ?
+            AND e1.timestamp >= e2.timestamp
+        `;
+        const newParams: (string | null)[] = [tenantId, stepName, tenantId, prevStep];
+        if (start) {
+          query += ' AND e1.timestamp >= ? AND e2.timestamp >= ?';
+          newParams.push(start, start);
+        }
+        if (end) {
+          query += ' AND e1.timestamp <= ? AND e2.timestamp <= ?';
+          newParams.push(end, end);
+        }
+        const result = db.prepare(query).get(...newParams) as { count: number };
+        stepResults.push({ step: stepName, count: result.count });
+      } else {
+        const result = db.prepare(query).get(...params) as { count: number };
+        stepResults.push({ step: stepName, count: result.count });
+      }
+    }
+
+    res.json({ steps: stepResults });
+  } catch (err) {
+    next(err);
+  }
+});
+
+export default router;
