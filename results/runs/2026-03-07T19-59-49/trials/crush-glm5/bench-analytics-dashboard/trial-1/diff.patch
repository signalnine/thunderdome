+import { authMiddleware } from '../auth.js';
+
+const router = express.Router();
+
+interface EventBody {
+  name?: string;
+  properties?: Record<string, unknown>;
+  timestamp?: string;
+  user_id?: string;
+  session_id?: string;
+}
+
+interface BatchBody {
+  events?: EventBody[];
+}
+
+router.post('/', authMiddleware, (req: express.Request<object, object, EventBody>, res, next) => {
+  try {
+    const { name, properties = {}, timestamp, user_id, session_id } = req.body;
+
+    if (!name) {
+      return next(createError('Event name is required', 400, 'VALIDATION_ERROR'));
+    }
+
+    const db = getDb();
+    const id = uuidv4();
+    const tenantId = req.user!.tenantId;
+    const ts = timestamp || new Date().toISOString();
+
+    db.prepare(
+      'INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)'
+    ).run(id, tenantId, name, JSON.stringify(properties), ts, user_id || null, session_id || null);
+
+    res.status(201).json({
+      id,
+      tenant_id: tenantId,
+      name,
+      properties,
+      timestamp: ts,
+      user_id: user_id || null,
+      session_id: session_id || null,
+    });
+  } catch (err) {
+    next(err);
+  }
+});
+
+router.post('/batch', authMiddleware, (req: express.Request<object, object, BatchBody>, res, next) => {
+  try {
+    const { events } = req.body;
+
+    if (!events || !Array.isArray(events) || events.length === 0) {
+      return next(createError('Events array is required and must not be empty', 400, 'VALIDATION_ERROR'));
+    }
+
+    const db = getDb();
+    const tenantId = req.user!.tenantId;
+    const insertedEvents: Array<{
+      id: string;
+      tenant_id: string;
+      name: string;
+      properties: Record<string, unknown>;
+      timestamp: string;
+    }> = [];
+
+    const insert = db.prepare(
+      'INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)'
+    );
+
+    const insertMany = db.transaction((eventList: EventBody[]) => {
+      for (const event of eventList) {
+        const { name, properties = {}, timestamp, user_id, session_id } = event;
+
+        if (!name) {
+          throw createError('Event name is required', 400, 'VALIDATION_ERROR');
+        }
+
+        const id = uuidv4();
+        const ts = timestamp || new Date().toISOString();
+
+        insert.run(id, tenantId, name, JSON.stringify(properties), ts, user_id || null, session_id || null);
+
+        insertedEvents.push({
+          id,
+          tenant_id: tenantId,
+          name,
+          properties,
+          timestamp: ts,
+        });
+      }
+    });
+
+    insertMany(events);
+
+    res.status(201).json({
+      inserted: insertedEvents.length,
+      events: insertedEvents,
+    });
+  } catch (err) {
+    next(err);
+  }
+});
+
+export default router;
