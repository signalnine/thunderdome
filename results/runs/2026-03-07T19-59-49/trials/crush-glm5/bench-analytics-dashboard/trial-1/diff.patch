+import express from 'express';
+import { getDb } from '../db.js';
+import { createError } from '../errors.js';
+import { authMiddleware } from '../auth.js';
+
+const router = express.Router();
+
+router.get('/events', authMiddleware, (req, res, next) => {
+  try {
+    const format = req.query.format as string | undefined;
+
+    if (!format || !['json', 'csv'].includes(format)) {
+      return next(createError('Invalid format. Use json or csv', 400, 'VALIDATION_ERROR'));
+    }
+
+    const db = getDb();
+    const tenantId = req.user!.tenantId;
+
+    const events = db.prepare(
+      'SELECT id, tenant_id, name, properties, timestamp, user_id, session_id FROM events WHERE tenant_id = ? ORDER BY timestamp DESC'
+    ).all(tenantId) as Array<{
+      id: string;
+      tenant_id: string;
+      name: string;
+      properties: string;
+      timestamp: string;
+      user_id: string | null;
+      session_id: string | null;
+    }>;
+
+    const parsedEvents = events.map((e) => ({
+      ...e,
+      properties: JSON.parse(e.properties),
+    }));
+
+    if (format === 'json') {
+      return res.json(parsedEvents);
+    }
+
+    const csvHeaders = 'id,tenant_id,name,properties,timestamp,user_id,session_id';
+    const csvRows = parsedEvents.map((e) =>
+      [
+        e.id,
+        e.tenant_id,
+        e.name,
+        `"${JSON.stringify(e.properties).replace(/"/g, '""')}"`,
+        e.timestamp,
+        e.user_id || '',
+        e.session_id || '',
+      ].join(',')
+    );
+
+    const csv = [csvHeaders, ...csvRows].join('\n');
+
+    res.setHeader('Content-Type', 'text/csv');
+    res.setHeader('Content-Disposition', 'attachment; filename=events.csv');
+    res.send(csv);
+  } catch (err) {
+    next(err);
+  }
+});
+
+router.get('/dashboard/:id', authMiddleware, (req, res, next) => {
+  try {
+    const { id } = req.params;
+    const db = getDb();
+    const tenantId = req.user!.tenantId;
+
+    const dashboard = db.prepare(
+      'SELECT id, tenant_id, name, owner_id, config, created_at, updated_at FROM dashboards WHERE id = ? AND tenant_id = ?'
+    ).get(id, tenantId) as {
+      id: string;
+      tenant_id: string;
+      name: string;
+      owner_id: string;
+      config: string;
+      created_at: string;
+      updated_at: string;
+    } | undefined;
+
+    if (!dashboard) {
+      return next(createError('Dashboard not found', 404, 'NOT_FOUND'));
+    }
+
+    const widgets = db.prepare(
+      'SELECT id, dashboard_id, type, config, position_x, position_y, width, height FROM widgets WHERE dashboard_id = ?'
+    ).all(id) as Array<{
+      id: string;
+      dashboard_id: string;
+      type: string;
+      config: string;
+      position_x: number;
+      position_y: number;
+      width: number;
+      height: number;
+    }>;
+
+    res.json({
+      dashboard: {
+        ...dashboard,
+        config: JSON.parse(dashboard.config),
+      },
+      widgets: widgets.map((w) => ({
+        ...w,
+        config: JSON.parse(w.config),
+      })),
+    });
+  } catch (err) {
+    next(err);
+  }
+});
+
+export default router;
