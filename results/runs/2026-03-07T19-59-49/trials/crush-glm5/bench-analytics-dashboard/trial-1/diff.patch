+import express from 'express';
+import { v4 as uuidv4 } from 'uuid';
+import { getDb } from '../db.js';
+import { createError } from '../errors.js';
+import { authMiddleware } from '../auth.js';
+
+const router = express.Router();
+
+interface CreateDashboardBody {
+  name?: string;
+  config?: Record<string, unknown>;
+}
+
+interface UpdateDashboardBody {
+  name?: string;
+  config?: Record<string, unknown>;
+}
+
+interface CreateWidgetBody {
+  type?: string;
+  config?: Record<string, unknown>;
+  position_x?: number;
+  position_y?: number;
+  width?: number;
+  height?: number;
+}
+
+router.post('/', authMiddleware, (req: express.Request<object, object, CreateDashboardBody>, res, next) => {
+  try {
+    const { name, config = {} } = req.body;
+
+    if (!name) {
+      return next(createError('Dashboard name is required', 400, 'VALIDATION_ERROR'));
+    }
+
+    const db = getDb();
+    const id = uuidv4();
+    const tenantId = req.user!.tenantId;
+    const ownerId = req.user!.id;
+    const now = new Date().toISOString();
+
+    db.prepare(
+      'INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)'
+    ).run(id, tenantId, name, ownerId, JSON.stringify(config), now, now);
+
+    res.status(201).json({
+      id,
+      tenant_id: tenantId,
+      name,
+      owner_id: ownerId,
+      config,
+      created_at: now,
+      updated_at: now,
+    });
+  } catch (err) {
+    next(err);
+  }
+});
+
+router.get('/', authMiddleware, (req, res, next) => {
+  try {
+    const db = getDb();
+    const tenantId = req.user!.tenantId;
+
+    const dashboards = db.prepare(
+      'SELECT id, tenant_id, name, owner_id, config, created_at, updated_at FROM dashboards WHERE tenant_id = ?'
+    ).all(tenantId) as Array<{
+      id: string;
+      tenant_id: string;
+      name: string;
+      owner_id: string;
+      config: string;
+      created_at: string;
+      updated_at: string;
+    }>;
+
+    res.json(
+      dashboards.map((d) => ({
+        ...d,
+        config: JSON.parse(d.config),
+      }))
+    );
+  } catch (err) {
+    next(err);
+  }
+});
+
+router.get('/:id', authMiddleware, (req, res, next) => {
+  try {
+    const { id } = req.params;
+    const db = getDb();
+    const tenantId = req.user!.tenantId;
+
+    const dashboard = db.prepare(
+      'SELECT id, tenant_id, name, owner_id, config, created_at, updated_at FROM dashboards WHERE id = ? AND tenant_id = ?'
+    ).get(id, tenantId) as {
+      id: string;
+      tenant_id: string;
+      name: string;
+      owner_id: string;
+      config: string;
+      created_at: string;
+      updated_at: string;
+    } | undefined;
+
+    if (!dashboard) {
+      return next(createError('Dashboard not found', 404, 'NOT_FOUND'));
+    }
+
+    const widgets = db.prepare(
+      'SELECT id, dashboard_id, type, config, position_x, position_y, width, height FROM widgets WHERE dashboard_id = ?'
+    ).all(id) as Array<{
+      id: string;
+      dashboard_id: string;
+      type: string;
+      config: string;
+      position_x: number;
+      position_y: number;
+      width: number;
+      height: number;
+    }>;
+
+    res.json({
+      ...dashboard,
+      config: JSON.parse(dashboard.config),
+      widgets: widgets.map((w) => ({
+        ...w,
+        config: JSON.parse(w.config),
+      })),
+    });
+  } catch (err) {
+    next(err);
+  }
+});
+
+router.patch('/:id', authMiddleware, (req: express.Request<{ id: string }, object, UpdateDashboardBody>, res, next) => {
+  try {
+    const { id } = req.params;
+    const { name, config } = req.body;
+
+    const db = getDb();
+    const tenantId = req.user!.tenantId;
+
+    const existing = db.prepare(
+      'SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?'
+    ).get(id, tenantId);
+
+    if (!existing) {
+      return next(createError('Dashboard not found', 404, 'NOT_FOUND'));
+    }
+
+    const now = new Date().toISOString();
+    const updates: string[] = ['updated_at = ?'];
+    const params: (string | null)[] = [now];
+
+    if (name !== undefined) {
+      updates.push('name = ?');
+      params.push(name);
+    }
+    if (config !== undefined) {
+      updates.push('config = ?');
+      params.push(JSON.stringify(config));
+    }
+
+    params.push(id);
+    params.push(tenantId);
+
+    db.prepare(
+      `UPDATE dashboards SET ${updates.join(', ')} WHERE id = ? AND tenant_id = ?`
+    ).run(...params);
+
+    const updated = db.prepare(
+      'SELECT id, tenant_id, name, owner_id, config, created_at, updated_at FROM dashboards WHERE id = ?'
+    ).get(id) as {
+      id: string;
+      tenant_id: string;
+      name: string;
+      owner_id: string;
+      config: string;
+      created_at: string;
+      updated_at: string;
+    };
+
+    res.json({
+      ...updated,
+      config: JSON.parse(updated.config),
+    });
+  } catch (err) {
+    next(err);
+  }
+});
+
+router.delete('/:id', authMiddleware, (req, res, next) => {
+  try {
+    const { id } = req.params;
+    const db = getDb();
+    const tenantId = req.user!.tenantId;
+
+    const existing = db.prepare(
+      'SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?'
+    ).get(id, tenantId);
+
+    if (!existing) {
+      return next(createError('Dashboard not found', 404, 'NOT_FOUND'));
+    }
+
+    db.prepare('DELETE FROM dashboards WHERE id = ?').run(id);
+
+    res.status(204).send();
+  } catch (err) {
+    next(err);
+  }
+});
+
+router.post('/:id/widgets', authMiddleware, (req: express.Request<{ id: string }, object, CreateWidgetBody>, res, next) => {
+  try {
+    const { id: dashboardId } = req.params;
+    const { type, config = {}, position_x = 0, position_y = 0, width = 1, height = 1 } = req.body;
+
+    const validTypes = ['counter', 'timeseries', 'breakdown', 'funnel'];
+    if (!type || !validTypes.includes(type)) {
+      return next(createError('Invalid widget type', 400, 'VALIDATION_ERROR'));
+    }
+
+    const db = getDb();
+    const tenantId = req.user!.tenantId;
+
+    const dashboard = db.prepare(
+      'SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?'
+    ).get(dashboardId, tenantId);
+
+    if (!dashboard) {
+      return next(createError('Dashboard not found', 404, 'NOT_FOUND'));
+    }
+
+    const widgetId = uuidv4();
+
+    db.prepare(
+      'INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)'
+    ).run(widgetId, dashboardId, type, JSON.stringify(config), position_x, position_y, width, height);
+
+    res.status(201).json({
+      id: widgetId,
+      dashboard_id: dashboardId,
+      type,
+      config,
+      position_x,
+      position_y,
+      width,
+      height,
+    });
+  } catch (err) {
+    next(err);
+  }
+});
+
+router.delete('/:dashboardId/widgets/:widgetId', authMiddleware, (req, res, next) => {
+  try {
+    const { dashboardId, widgetId } = req.params;
+    const db = getDb();
+    const tenantId = req.user!.tenantId;
+
+    const dashboard = db.prepare(
+      'SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?'
+    ).get(dashboardId, tenantId);
+
+    if (!dashboard) {
+      return next(createError('Dashboard not found', 404, 'NOT_FOUND'));
+    }
+
+    const result = db.prepare('DELETE FROM widgets WHERE id = ? AND dashboard_id = ?').run(widgetId, dashboardId);
+
+    if (result.changes === 0) {
+      return next(createError('Widget not found', 404, 'NOT_FOUND'));
+    }
+
+    res.status(204).send();
+  } catch (err) {
+    next(err);
+  }
+});
+
+export default router;
