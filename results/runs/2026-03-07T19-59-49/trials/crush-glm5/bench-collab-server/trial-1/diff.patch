@@ -0,0 +1,65 @@
+import express from 'express';
+import { createServer } from 'http';
+import type { Server as HttpServer } from 'http';
+import { createDatabase, clearConnections, type Db } from './db.js';
+import { createRouter } from './routes.js';
+import { CollabWebSocketServer } from './ws.js';
+
+export interface AppInstance {
+  app: express.Application;
+  server: HttpServer;
+  wss: CollabWebSocketServer;
+  db: Db;
+  start: (port?: number) => Promise<number>;
+  stop: () => Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db = createDatabase(dbPath);
+  
+  clearConnections(db);
+
+  const app = express();
+  app.use(express.json());
+
+  const router = createRouter(db);
+  app.use('/', router);
+
+  const server = createServer(app);
+  const wss = new CollabWebSocketServer(server, db);
+
+  let actualPort: number;
+
+  const start = (port = 0): Promise<number> => {
+    return new Promise((resolve, reject) => {
+      server.listen(port, () => {
+        const address = server.address();
+        if (address && typeof address === 'object') {
+          actualPort = address.port;
+          resolve(actualPort);
+        } else {
+          reject(new Error('Failed to get server port'));
+        }
+      });
+    });
+  };
+
+  const stop = (): Promise<void> => {
+    return new Promise((resolve) => {
+      wss.close();
+      server.close(() => {
+        db.close();
+        resolve();
+      });
+    });
+  };
+
+  return {
+    app,
+    server,
+    wss,
+    db,
+    start,
+    stop,
+  };
+}
diff --git a/src/ws.ts b/src/ws.ts
new file mode 100644
index 0000000..270c993
--- /dev/null
+++ b/src/ws.ts
@@ -0,0 +1,213 @@
+import { WebSocketServer, WebSocket } from 'ws';
+import type { Server } from 'http';
+import { randomUUID } from 'crypto';
+import type { Db } from './db.js';
+import type { Operation } from './models.js';
+import { validateOperation, applyOperation, transformAgainst } from './ot.js';
+
+interface DocumentState {
+  content: string;
+  version: number;
+  pendingOps: Operation[];
+}
+
+interface ClientInfo {
+  docId: string;
+  ws: WebSocket;
+  connectionId: string;
+}
+
+export class CollabWebSocketServer {
+  private wss: WebSocketServer;
+  private db: Db;
+  private rooms: Map<string, Set<WebSocket>> = new Map();
+  private docStates: Map<string, DocumentState> = new Map();
+  private clients: Map<WebSocket, ClientInfo> = new Map();
+
+  constructor(server: Server, db: Db) {
+    this.db = db;
+    this.wss = new WebSocketServer({ server });
+    this.setupHandlers();
+  }
+
+  private setupHandlers(): void {
+    this.wss.on('connection', (ws, req) => {
+      const docId = req.url?.slice(1);
+      if (!docId) {
+        ws.send(JSON.stringify({ type: 'error', message: 'Document ID required' }));
+        ws.close();
+        return;
+      }
+
+      const doc = this.db.prepare('SELECT * FROM documents WHERE id = ?').get(docId);
+      if (!doc) {
+        ws.send(JSON.stringify({ type: 'error', message: 'Document not found' }));
+        ws.close();
+        return;
+      }
+
+      const connectionId = randomUUID();
+      this.db.prepare(`
+        INSERT INTO active_connections (id, document_id, connected_at)
+        VALUES (?, ?, ?)
+      `).run(connectionId, docId, new Date().toISOString());
+
+      const docState = this.getDocState(docId);
+      this.clients.set(ws, { docId, ws, connectionId });
+
+      if (!this.rooms.has(docId)) {
+        this.rooms.set(docId, new Set());
+      }
+      this.rooms.get(docId)!.add(ws);
+
+      ws.send(JSON.stringify({
+        type: 'sync',
+        content: docState.content,
+        version: docState.version,
+      }));
+
+      ws.on('message', (data) => {
+        this.handleMessage(ws, data);
+      });
+
+      ws.on('close', () => {
+        this.handleDisconnect(ws);
+      });
+
+      ws.on('error', () => {
+        this.handleDisconnect(ws);
+      });
+    });
+  }
+
+  private getDocState(docId: string): DocumentState {
+    if (!this.docStates.has(docId)) {
+      const doc = this.db.prepare('SELECT content FROM documents WHERE id = ?').get(docId) as { content: string } | undefined;
+      const versions = this.db.prepare(`
+        SELECT MAX(version) as maxVersion FROM versions WHERE document_id = ?
+      `).get(docId) as { maxVersion: number | null };
+
+      this.docStates.set(docId, {
+        content: doc?.content || '',
+        version: versions?.maxVersion ?? 0,
+        pendingOps: [],
+      });
+    }
+    return this.docStates.get(docId)!;
+  }
+
+  private handleMessage(ws: WebSocket, data: unknown): void {
+    const clientInfo = this.clients.get(ws);
+    if (!clientInfo) return;
+
+    let msg: Record<string, unknown>;
+    try {
+      msg = JSON.parse((data as Buffer).toString());
+    } catch {
+      ws.send(JSON.stringify({ type: 'error', message: 'Invalid JSON' }));
+      return;
+    }
+
+    if (msg.type !== 'operation') {
+      ws.send(JSON.stringify({ type: 'error', message: 'Unknown message type' }));
+      return;
+    }
+
+    const operation = msg.operation as Operation;
+    const clientVersion = msg.version as number | undefined;
+
+    if (operation.type !== 'insert' && operation.type !== 'delete') {
+      ws.send(JSON.stringify({ type: 'error', message: 'Invalid operation type' }));
+      return;
+    }
+
+    const docState = this.getDocState(clientInfo.docId);
+
+    if (!validateOperation(operation, docState.content.length)) {
+      ws.send(JSON.stringify({ type: 'error', message: 'Invalid operation' }));
+      return;
+    }
+
+    let transformedOp = operation;
+    if (clientVersion !== undefined && clientVersion < docState.version) {
+      const fromIndex = clientVersion - (docState.version - docState.pendingOps.length);
+      if (fromIndex >= 0 && fromIndex < docState.pendingOps.length) {
+        transformedOp = transformAgainst(operation, docState.pendingOps, fromIndex);
+      }
+    }
+
+    if (!validateOperation(transformedOp, docState.content.length)) {
+      ws.send(JSON.stringify({ type: 'error', message: 'Transformed operation is invalid' }));
+      return;
+    }
+
+    const newContent = applyOperation(docState.content, transformedOp);
+    const newVersion = docState.version + 1;
+
+    docState.content = newContent;
+    docState.version = newVersion;
+    docState.pendingOps.push(transformedOp);
+
+    if (docState.pendingOps.length > 100) {
+      docState.pendingOps = docState.pendingOps.slice(-50);
+    }
+
+    const now = new Date().toISOString();
+    this.db.prepare(`
+      UPDATE documents SET content = ?, updated_at = ? WHERE id = ?
+    `).run(newContent, now, clientInfo.docId);
+
+    this.db.prepare(`
+      INSERT INTO versions (document_id, version, content, operation, created_at)
+      VALUES (?, ?, ?, ?, ?)
+    `).run(clientInfo.docId, newVersion, newContent, JSON.stringify(transformedOp), now);
+
+    ws.send(JSON.stringify({
+      type: 'ack',
+      version: newVersion,
+    }));
+
+    this.broadcast(clientInfo.docId, {
+      type: 'operation',
+      operation: transformedOp,
+      version: newVersion,
+    }, ws);
+  }
+
+  private broadcast(docId: string, msg: Record<string, unknown>, exclude?: WebSocket): void {
+    const room = this.rooms.get(docId);
+    if (!room) return;
+
+    const msgStr = JSON.stringify(msg);
+    for (const client of room) {
+      if (client !== exclude && client.readyState === WebSocket.OPEN) {
+        client.send(msgStr);
+      }
+    }
+  }
+
+  private handleDisconnect(ws: WebSocket): void {
+    const clientInfo = this.clients.get(ws);
+    if (clientInfo) {
+      this.db.prepare('DELETE FROM active_connections WHERE id = ?').run(clientInfo.connectionId);
+
+      const room = this.rooms.get(clientInfo.docId);
+      if (room) {
+        room.delete(ws);
+        if (room.size === 0) {
+          this.rooms.delete(clientInfo.docId);
+          this.docStates.delete(clientInfo.docId);
+        }
+      }
+
+      this.clients.delete(ws);
+    }
+  }
+
+  close(): void {
+    for (const [ws] of this.clients) {
+      ws.close();
+    }
+    this.wss.close();
+  }
+}
