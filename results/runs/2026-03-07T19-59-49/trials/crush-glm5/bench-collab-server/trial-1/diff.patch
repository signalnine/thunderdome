+++ b/src/ot.ts
@@ -0,0 +1,80 @@
+import type { Operation, InsertOperation, DeleteOperation } from './models.js';
+
+export function validateOperation(op: Operation, contentLength: number): boolean {
+  if (op.type === 'insert') {
+    return op.position >= 0 && op.position <= contentLength && typeof op.text === 'string';
+  } else if (op.type === 'delete') {
+    return (
+      op.position >= 0 &&
+      op.count > 0 &&
+      op.position + op.count <= contentLength &&
+      typeof op.count === 'number'
+    );
+  }
+  return false;
+}
+
+export function applyOperation(content: string, op: Operation): string {
+  if (op.type === 'insert') {
+    return content.slice(0, op.position) + op.text + content.slice(op.position);
+  } else if (op.type === 'delete') {
+    return content.slice(0, op.position) + content.slice(op.position + op.count);
+  }
+  return content;
+}
+
+export function transformOperation(op1: Operation, op2: Operation): Operation {
+  if (op1.type === 'insert') {
+    if (op2.type === 'insert') {
+      if (op2.position <= op1.position) {
+        return { ...op1, position: op1.position + op2.text.length };
+      }
+      return op1;
+    } else {
+      if (op2.position + op2.count <= op1.position) {
+        return { ...op1, position: op1.position - op2.count };
+      } else if (op2.position < op1.position) {
+        return { ...op1, position: op2.position };
+      }
+      return op1;
+    }
+  } else {
+    if (op2.type === 'insert') {
+      if (op2.position <= op1.position) {
+        return { ...op1, position: op1.position + op2.text.length };
+      } else if (op2.position < op1.position + op1.count) {
+        const overlapStart = op2.position - op1.position;
+        const remainingAfterInsert = op1.count - overlapStart;
+        return { ...op1, count: op1.count + op2.text.length };
+      }
+      return op1;
+    } else {
+      if (op2.position + op2.count <= op1.position) {
+        return { ...op1, position: op1.position - op2.count };
+      } else if (op1.position + op1.count <= op2.position) {
+        return op1;
+      } else {
+        const startBefore = Math.max(0, op2.position - op1.position);
+        const endAfter = Math.max(0, (op1.position + op1.count) - (op2.position + op2.count));
+        const newCount = startBefore + endAfter;
+        if (newCount <= 0) {
+          return { ...op1, position: op2.position, count: 0 };
+        }
+        const newPosition = Math.min(op1.position, op2.position);
+        return { ...op1, position: newPosition, count: newCount };
+      }
+    }
+  }
+}
+
+export function transformAgainst(
+  op: Operation,
+  pendingOps: Operation[],
+  fromIndex: number
+): Operation {
+  let transformed = op;
+  for (let i = fromIndex; i < pendingOps.length; i++) {
+    transformed = transformOperation(transformed, pendingOps[i]);
+  }
+  return transformed;
+}
