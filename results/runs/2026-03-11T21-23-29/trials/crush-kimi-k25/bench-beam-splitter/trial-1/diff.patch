index 0000000..648966c
--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,128 @@
+type Direction = 'down' | 'down-left' | 'down-right';
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+const DIRECTION_DELTA: Record<Direction, [number, number]> = {
+  down: [1, 0],
+  'down-left': [1, -1],
+  'down-right': [1, 1],
+};
+
+/**
+ * Find the source position 'S' in the grid
+ */
+function findSource(grid: string[][]): [number, number] {
+  const cols = grid[0]?.length || 0;
+  for (let col = 0; col < cols; col++) {
+    if (grid[0][col] === 'S') {
+      return [0, col];
+    }
+  }
+  throw new Error('Source S not found in top row');
+}
+
+/**
+ * Check if a position is within grid bounds
+ */
+function isInBounds(grid: string[][], row: number, col: number): boolean {
+  return row >= 0 && row < grid.length && col >= 0 && col < grid[0].length;
+}
+
+/**
+ * Count the number of distinct cells visited by any beam
+ */
+export function countBeamCells(grid: string[][]): number {
+  if (grid.length === 0 || grid[0].length === 0) {
+    return 0;
+  }
+
+  const [startRow, startCol] = findSource(grid);
+  const visited = new Set<string>();
+  const queue: Beam[] = [{ row: startRow, col: startCol, dir: 'down' }];
+
+  while (queue.length > 0) {
+    const { row, col, dir } = queue.pop()!;
+
+    // Mark current cell as visited
+    visited.add(`${row},${col}`);
+
+    const cell = grid[row][col];
+
+    if (cell === '^') {
+      // Splitter: create two new beams going down-left and down-right
+      const newDirections: Direction[] = ['down-left', 'down-right'];
+      for (const newDir of newDirections) {
+        const [dRow, dCol] = DIRECTION_DELTA[newDir];
+        const newRow = row + dRow;
+        const newCol = col + dCol;
+        if (isInBounds(grid, newRow, newCol)) {
+          queue.push({ row: newRow, col: newCol, dir: newDir });
+        }
+      }
+    } else {
+      // Empty cell or source: continue in same direction
+      const [dRow, dCol] = DIRECTION_DELTA[dir];
+      const newRow = row + dRow;
+      const newCol = col + dCol;
+      if (isInBounds(grid, newRow, newCol)) {
+        queue.push({ row: newRow, col: newCol, dir });
+      }
+    }
+  }
+
+  return visited.size;
+}
+
+/**
+ * Count the total number of distinct source-to-exit paths through the grid
+ * Uses memoization to avoid enumerating all paths
+ */
+export function countBeamPaths(grid: string[][]): bigint {
+  if (grid.length === 0 || grid[0].length === 0) {
+    return 0n;
+  }
+
+  // Memoization cache: key = "row,col,dir", value = number of paths from this state to exit
+  const memo = new Map<string, bigint>();
+
+  function getKey(row: number, col: number, dir: Direction): string {
+    return `${row},${col},${dir}`;
+  }
+
+  function countPaths(row: number, col: number, dir: Direction): bigint {
+    // If we're out of bounds, we've exited the grid - that's one complete path
+    if (!isInBounds(grid, row, col)) {
+      return 1n;
+    }
+
+    const key = getKey(row, col, dir);
+    if (memo.has(key)) {
+      return memo.get(key)!;
+    }
+
+    const cell = grid[row][col];
+    let result: bigint;
+
+    if (cell === '^') {
+      // Splitter: sum paths from both split directions
+      const [dlRow, dlCol] = DIRECTION_DELTA['down-left'];
+      const [drRow, drCol] = DIRECTION_DELTA['down-right'];
+      result = countPaths(row + dlRow, col + dlCol, 'down-left') +
+               countPaths(row + drRow, col + drCol, 'down-right');
+    } else {
+      // Empty cell or source: continue in same direction
+      const [dRow, dCol] = DIRECTION_DELTA[dir];
+      result = countPaths(row + dRow, col + dCol, dir);
+    }
+
+    memo.set(key, result);
+    return result;
+  }
+
+  const [startRow, startCol] = findSource(grid);
+  return countPaths(startRow, startCol, 'down');
+}
