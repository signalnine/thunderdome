r (const event of events) {\n        if (!event.name) continue;\n        const id = uuidv4();\n        const eventTimestamp = event.timestamp || new Date().toISOString();\n        const eventProperties = event.properties ? JSON.stringify(event.properties) : \"{}\";\n\n        insertStmt.run(\n          id,\n          req.user!.tenantId,\n          event.name,\n          eventProperties,\n          eventTimestamp,\n          req.user!.userId,\n          event.sessionId || null\n        );\n        results.push({ id, name: event.name });\n      }\n    });\n\n    insertAll();\n\n    res.status(201).json({ inserted: results.length, events: results });\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":731,"cache_read_input_tokens":26171,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":731},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"146f361a-1a1f-482e-81fa-0467bedf0b3c","uuid":"83d9613f-95e1-4b92-8dcd-8ff173060242"}
