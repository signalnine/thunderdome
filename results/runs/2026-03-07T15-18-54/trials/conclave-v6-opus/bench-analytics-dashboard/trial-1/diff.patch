shboards/:id returns a specific dashboard\", async () => {\n      // Create a dashboard first to get a reliable ID\n      const create = await request(app)\n        .post(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ name: \"Test Dashboard\" });\n      const id = create.body.id;\n\n      const res = await request(app)\n        .get(`/dashboards/${id}`)\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe(\"Test Dashboard\");\n    });\n\n    it(\"GET /dashboards/:id returns 404 for nonexistent\", async () => {\n      const res = await request(app)\n        .get(\"/dashboards/nonexistent-id\")\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(res.status).toBe(404);\n    });\n\n    it(\"PUT /dashboards/:id updates a dashboard\", async () => {\n      const create = await request(app)\n        .post(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ name: \"Old Name\" });\n      const id = create.body.id;\n\n      const res = await request(app)\n        .put(`/dashboards/${id}`)\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ name: \"New Name\" });\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe(\"New Name\");\n    });\n\n    it(\"DELETE /dashboards/:id deletes a dashboard\", async () => {\n      const create = await request(app)\n        .post(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ name: \"To Delete\" });\n      const id = create.body.id;\n\n      const res = await request(app)\n        .delete(`/dashboards/${id}`)\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(res.status).toBe(204);\n\n      const get = await request(app)\n        .get(`/dashboards/${id}`)\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(get.status).toBe(404);\n    });\n\n    it(\"POST /dashboards requires auth\", async () => {\n      const res = await request(app).post(\"/dashboards\").send({ name: \"test\" });\n      expect(res.status).toBe(401);\n    });\n  });\n\n  describe(\"Data Export\", () => {\n    it(\"GET /export/events/json exports events as JSON\", async () => {\n      const res = await request(app)\n        .get(\"/export/events/json\")\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(res.status).toBe(200);\n      expect(res.body.events).toBeDefined();\n      expect(res.body.events.length).toBeGreaterThanOrEqual(1);\n    });\n\n    it(\"GET /export/events/json filters by eventName\", async () => {\n      const res = await request(app)\n        .get(\"/export/events/json?eventName=click\")\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(res.status).toBe(200);\n      expect(res.body.events.every((e: { name: string }) => e.name === \"click\")).toBe(true);\n    });\n\n    it(\"GET /export/events/csv exports events as CSV\", async () => {\n      const res = await request(app)\n        .get(\"/export/events/csv\")\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(res.status).toBe(200);\n      expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n      expect(res.text).toContain(\"id,name,properties\");\n    });\n\n    it(\"GET /export/dashboards/:id/json exports dashboard as JSON\", async () => {\n      const create = await request(app)\n        .post(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ name: \"Export Test Dashboard\" });\n      const id = create.body.id;\n\n      const res = await request(app)\n        .get(`/export/dashboards/${id}/json`)\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(res.status).toBe(200);\n      expect(res.body.dashboard).toBeDefined();\n      expect(res.body.dashboard.name).toBe(\"Export Test Dashboard\");\n    });\n\n    it(\"GET /export/dashboards/:id/csv exports dashboard as CSV\", async () => {\n      const create = await request(app)\n        .post(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ name: \"Export CSV Dashboard\" });\n      const id = create.body.id;\n\n      const res = await request(app)\n        .get(`/export/dashboards/${id}/csv`)\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(res.status).toBe(200);\n      expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n    });\n\n    it(\"GET /export/dashboards/:id/json returns 404 for other tenant\", async () => {\n      const create = await request(app)\n        .post(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ name: \"Private Dashboard\" });\n      const id = create.body.id;\n\n      const t2 = await request(app).post(\"/auth/register\").send({\n        email: `export-test-${Date.now()}@tenant2.com`,\n        password: \"password123\",\n        tenantId: \"tenant-2\",\n      });\n\n      const res = await request(app)\n        .get(`/export/dashboards/${id}/json`)\n        .set(\"Authorization\", `Bearer ${t2.body.token}`);\n      expect(res.status).toBe(404);\n    });\n\n    it(\"GET /export/events/json requires auth\", async () => {\n      const res = await request(app).get(\"/export/events/json\");\n      expect(res.status).toBe(401);\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
