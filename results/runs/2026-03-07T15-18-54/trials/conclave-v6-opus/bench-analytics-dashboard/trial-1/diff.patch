+import express from "express";
+import { initializeDatabase } from "./db.js";
+import { createUserRoutes } from "./routes/users.js";
+import { createEventRoutes } from "./routes/events.js";
+import { createQueryRoutes } from "./routes/queries.js";
+import { createDashboardRoutes } from "./routes/dashboards.js";
+import { createExportRoutes } from "./routes/export.js";
+
+export function createApp(dbPath?: string) {
+  const app = express();
+  const db = initializeDatabase(dbPath);
+
+  app.use(express.json());
+
+  // User management routes
+  app.use("/auth", createUserRoutes(db));
+
+  // Event ingestion routes
+  app.use("/events", createEventRoutes(db));
+
+  // Query engine routes
+  app.use("/query", createQueryRoutes(db));
+
+  // Dashboard routes
+  app.use("/dashboards", createDashboardRoutes(db));
+
+  // Export routes
+  app.use("/export", createExportRoutes(db));
+
+  // Health check
+  app.get("/health", (_req, res) => {
+    res.json({ status: "ok" });
+  });
+
+  return app;
+}
