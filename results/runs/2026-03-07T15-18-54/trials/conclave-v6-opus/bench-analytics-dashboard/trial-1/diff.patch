 request(app).get(\"/health\");\n      expect(res.status).toBe(200);\n      expect(res.body.status).toBe(\"ok\");\n    });\n  });\n\n  describe(\"User Management\", () => {\n    it(\"POST /auth/register creates a new user\", async () => {\n      const res = await request(app).post(\"/auth/register\").send({\n        email: \"admin@tenant1.com\",\n        password: \"password123\",\n        tenantId: \"tenant-1\",\n        role: \"admin\",\n      });\n      expect(res.status).toBe(201);\n      expect(res.body.email).toBe(\"admin@tenant1.com\");\n      expect(res.body.role).toBe(\"admin\");\n      expect(res.body.token).toBeDefined();\n      adminToken = res.body.token;\n      adminUserId = res.body.id;\n    });\n\n    it(\"POST /auth/register rejects duplicate email\", async () => {\n      const res = await request(app).post(\"/auth/register\").send({\n        email: \"admin@tenant1.com\",\n        password: \"password123\",\n        tenantId: \"tenant-1\",\n      });\n      expect(res.status).toBe(409);\n    });\n\n    it(\"POST /auth/register creates a viewer user\", async () => {\n      const res = await request(app).post(\"/auth/register\").send({\n        email: \"viewer@tenant1.com\",\n        password: \"password123\",\n        tenantId: \"tenant-1\",\n      });\n      expect(res.status).toBe(201);\n      expect(res.body.role).toBe(\"viewer\");\n      viewerToken = res.body.token;\n      viewerUserId = res.body.id;\n    });\n\n    it(\"POST /auth/register validates required fields\", async () => {\n      const res = await request(app).post(\"/auth/register\").send({ email: \"x@x.com\" });\n      expect(res.status).toBe(400);\n    });\n\n    it(\"POST /auth/login returns a token\", async () => {\n      const res = await request(app).post(\"/auth/login\").send({\n        email: \"admin@tenant1.com\",\n        password: \"password123\",\n      });\n      expect(res.status).toBe(200);\n      expect(res.body.token).toBeDefined();\n      expect(res.body.user.email).toBe(\"admin@tenant1.com\");\n    });\n\n    it(\"POST /auth/login rejects bad credentials\", async () => {\n      const res = await request(app).post(\"/auth/login\").send({\n        email: \"admin@tenant1.com\",\n        password: \"wrong\",\n      });\n      expect(res.status).toBe(401);\n    });\n\n    it(\"GET /auth/profile returns user profile\", async () => {\n      const res = await request(app)\n        .get(\"/auth/profile\")\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(res.status).toBe(200);\n      expect(res.body.email).toBe(\"admin@tenant1.com\");\n      expect(res.body.tenantId).toBe(\"tenant-1\");\n    });\n\n    it(\"GET /auth/profile returns 401 without auth\", async () => {\n      const res = await request(app).get(\"/auth/profile\");\n      expect(res.status).toBe(401);\n    });\n\n    it(\"PUT /auth/users/:userId/role allows admin to change role\", async () => {\n      const res = await request(app)\n        .put(`/auth/users/${viewerUserId}/role`)\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ role: \"editor\" });\n      expect(res.status).toBe(200);\n      expect(res.body.role).toBe(\"editor\");\n    });\n\n    it(\"PUT /auth/users/:userId/role rejects non-admin\", async () => {\n      const res = await request(app)\n        .put(`/auth/users/${adminUserId}/role`)\n        .set(\"Authorization\", `Bearer ${viewerToken}`)\n        .send({ role: \"admin\" });\n      expect(res.status).toBe(403);\n    });\n  });\n\n  describe(\"Event Ingestion\", () => {\n    it(\"POST /events creates a single event\", async () => {\n      const res = await request(app)\n        .post(\"/events\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({\n          name: \"page_view\",\n          properties: { url: \"/home\", browser: \"chrome\" },\n          timestamp: \"2024-01-15T10:00:00Z\",\n        });\n      expect(res.status).toBe(201);\n      expect(res.body.name).toBe(\"page_view\");\n      expect(res.body.id).toBeDefined();\n    });\n\n    it(\"POST /events requires auth\", async () => {\n      const res = await request(app).post(\"/events\").send({ name: \"test\" });\n      expect(res.status).toBe(401);\n    });\n\n    it(\"POST /events requires event name\", async () => {\n      const res = await request(app)\n        .post(\"/events\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({});\n      expect(res.status).toBe(400);\n    });\n\n    it(\"POST /events/batch ingests multiple events\", async () => {\n      const res = await request(app)\n        .post(\"/events/batch\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({\n          events: [\n            { name: \"page_view\", properties: { url: \"/about\" }, timestamp: \"2024-01-15T11:00:00Z\" },\n            { name: \"page_view\", properties: { url: \"/contact\" }, timestamp: \"2024-01-16T09:00:00Z\" },\n            { name: \"click\", properties: { button: \"signup\" }, timestamp: \"2024-01-16T10:00:00Z\" },\n          ],\n        });\n      expect(res.status).toBe(201);\n      expect(res.body.inserted).toBe(3);\n    });\n\n    it(\"POST /events/batch rejects empty batch\", async () => {\n      const res = await request(app)\n        .post(\"/events/batch\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ events: [] });\n      expect(res.status).toBe(400);\n    });\n  });\n\n  describe(\"Query Engine\", () => {\n    it(\"POST /query/count counts all events\", async () => {\n      const res = await request(app)\n        .post(\"/query/count\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({});\n      expect(res.status).toBe(200);\n      expect(res.body.count).toBe(4);\n    });\n\n    it(\"POST /query/count counts filtered events\", async () => {\n      const res = await request(app)\n        .post(\"/query/count\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ eventName: \"page_view\" });\n      expect(res.status).toBe(200);\n      expect(res.body.count).toBe(3);\n    });\n\n    it(\"POST /query/count filters by date range\", async () => {\n      const res = await request(app)\n        .post(\"/query/count\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({\n          eventName: \"page_view\",\n          startDate: \"2024-01-15T00:00:00Z\",\n          endDate: \"2024-01-15T23:59:59Z\",\n        });\n      expect(res.status).toBe(200);\n      expect(res.body.count).toBe(2);\n    });\n\n    it(\"POST /query/count filters by properties\", async () => {\n      const res = await request(app)\n        .post(\"/query/count\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({\n          eventName: \"page_view\",\n          filters: { url: \"/home\" },\n        });\n      expect(res.status).toBe(200);\n      expect(res.body.count).toBe(1);\n    });\n\n    it(\"POST /query/timeseries returns buckets\", async () => {\n      const res = await request(app)\n        .post(\"/query/timeseries\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({\n          eventName: \"page_view\",\n          interval: \"day\",\n        });\n      expect(res.status).toBe(200);\n      expect(res.body.timeseries).toBeDefined();\n      expect(res.body.timeseries.length).toBeGreaterThanOrEqual(1);\n    });\n\n    it(\"POST /query/timeseries requires eventName\", async () => {\n      const res = await request(app)\n        .post(\"/query/timeseries\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({});\n      expect(res.status).toBe(400);\n    });\n\n    it(\"POST /query/breakdown returns grouped counts\", async () => {\n      const res = await request(app)\n        .post(\"/query/breakdown\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({\n          eventName: \"page_view\",\n          property: \"url\",\n        });\n      expect(res.status).toBe(200);\n      expect(res.body.breakdown).toBeDefined();\n      expect(res.body.breakdown.length).toBeGreaterThanOrEqual(1);\n    });\n\n    it(\"POST /query/breakdown requires eventName and property\", async () => {\n      const res = await request(app)\n        .post(\"/query/breakdown\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ eventName: \"page_view\" });\n      expect(res.status).toBe(400);\n    });\n\n    it(\"POST /query/count requires auth\", async () => {\n      const res = await request(app).post(\"/query/count\").send({});\n      expect(res.status).toBe(401);\n    });\n  });\n\n  describe(\"Tenant Isolation\", () => {\n    let tenant2Token: string;\n\n    beforeEach(async () => {\n      // Register a user in a different tenant if not already done\n      const reg = await request(app).post(\"/auth/register\").send({\n        email: `user-${Date.now()}@tenant2.com`,\n        password: \"password123\",\n        tenantId: \"tenant-2\",\n      });\n      tenant2Token = reg.body.token;\n    });\n\n    it(\"tenant-2 cannot see tenant-1 events\", async () => {\n      const res = await request(app)\n        .post(\"/query/count\")\n        .set(\"Authorization\", `Bearer ${tenant2Token}`)\n        .send({});\n      expect(res.status).toBe(200);\n      expect(res.body.count).toBe(0);\n    });\n\n    it(\"tenant-2 cannot see tenant-1 dashboards\", async () => {\n      // First create a dashboard in tenant-1\n      await request(app)\n        .post(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ name: \"Tenant 1 Dashboard\" });\n\n      const res = await request(app)\n        .get(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${tenant2Token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.dashboards.length).toBe(0);\n    });\n  });\n\n  describe(\"Dashboard CRUD\", () => {\n    let dashboardId: string;\n\n    it(\"POST /dashboards creates a dashboard\", async () => {\n      const res = await request(app)\n        .post(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({\n          name: \"Main Dashboard\",\n          config: { layout: \"grid\" },\n        });\n      expect(res.status).toBe(201);\n      expect(res.body.name).toBe(\"Main Dashboard\");\n      expect(res.body.id).toBeDefined();\n      dashboardId = res.body.id;\n    });\n\n    it(\"POST /dashboards requires name\", async () => {\n      const res = await request(app)\n        .post(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({});\n      expect(res.status).toBe(400);\n    });\n\n    it(\"GET /dashboards lists tenant dashboards\", async () => {\n      const res = await request(app)\n        .get(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(res.status).toBe(200);\n      expect(res.body.dashboards).toBeDefined();\n      expect(res.body.dashboards.length).toBeGreaterThanOrEqual(1);\n    });\n\n    it(\"GET /dashboards/:id returns a specific dashboard\", async () => {\n      // Create a dashboard first to get a reliable ID\n      const create = await request(app)\n        .post(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ name: \"Test Dashboard\" });\n      const id = create.body.id;\n\n      const res = await request(app)\n        .get(`/dashboards/${id}`)\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe(\"Test Dashboard\");\n    });\n\n    it(\"GET /dashboards/:id returns 404 for nonexistent\", async () => {\n      const res = await request(app)\n        .get(\"/dashboards/nonexistent-id\")\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(res.status).toBe(404);\n    });\n\n    it(\"PUT /dashboards/:id updates a dashboard\", async () => {\n      const create = await request(app)\n        .post(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ name: \"Old Name\" });\n      const id = create.body.id;\n\n      const res = await request(app)\n        .put(`/dashboards/${id}`)\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ name: \"New Name\" });\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe(\"New Name\");\n    });\n\n    it(\"DELETE /dashboards/:id deletes a dashboard\", async () => {\n      const create = await request(app)\n        .post(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ name: \"To Delete\" });\n      const id = create.body.id;\n\n      const res = await request(app)\n        .delete(`/dashboards/${id}`)\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(res.status).toBe(204);\n\n      const get = await request(app)\n        .get(`/dashboards/${id}`)\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(get.status).toBe(404);\n    });\n\n    it(\"POST /dashboards requires auth\", async () => {\n      const res = await request(app).post(\"/dashboards\").send({ name: \"test\" });\n      expect(res.status).toBe(401);\n    });\n  });\n\n  describe(\"Data Export\", () => {\n    it(\"GET /export/events/json exports events as JSON\", async () => {\n      const res = await request(app)\n        .get(\"/export/events/json\")\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(res.status).toBe(200);\n      expect(res.body.events).toBeDefined();\n      expect(res.body.events.length).toBeGreaterThanOrEqual(1);\n    });\n\n    it(\"GET /export/events/json filters by eventName\", async () => {\n      const res = await request(app)\n        .get(\"/export/events/json?eventName=click\")\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(res.status).toBe(200);\n      expect(res.body.events.every((e: { name: string }) => e.name === \"click\")).toBe(true);\n    });\n\n    it(\"GET /export/events/csv exports events as CSV\", async () => {\n      const res = await request(app)\n        .get(\"/export/events/csv\")\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(res.status).toBe(200);\n      expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n      expect(res.text).toContain(\"id,name,properties\");\n    });\n\n    it(\"GET /export/dashboards/:id/json exports dashboard as JSON\", async () => {\n      const create = await request(app)\n        .post(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ name: \"Export Test Dashboard\" });\n      const id = create.body.id;\n\n      const res = await request(app)\n        .get(`/export/dashboards/${id}/json`)\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(res.status).toBe(200);\n      expect(res.body.dashboard).toBeDefined();\n      expect(res.body.dashboard.name).toBe(\"Export Test Dashboard\");\n    });\n\n    it(\"GET /export/dashboards/:id/csv exports dashboard as CSV\", async () => {\n      const create = await request(app)\n        .post(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ name: \"Export CSV Dashboard\" });\n      const id = create.body.id;\n\n      const res = await request(app)\n        .get(`/export/dashboards/${id}/csv`)\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(res.status).toBe(200);\n      expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n    });\n\n    it(\"GET /export/dashboards/:id/json returns 404 for other tenant\", async () => {\n      const create = await request(app)\n        .post(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ name: \"Private Dashboard\" });\n      const id = create.body.id;\n\n      const t2 = await request(app).post(\"/auth/register\").send({\n        email: `export-test-${Date.now()}@tenant2.com`,\n        password: \"password123\",\n        tenantId: \"tenant-2\",\n      });\n\n      const res = await request(app)\n        .get(`/export/dashboards/${id}/json`)\n        .set(\"Authorization\", `Bearer ${t2.body.token}`);\n      expect(res.status).toBe(404);\n    });\n\n    it(\"GET /export/events/json requires auth\", async () => {\n      const res = await request(app).get(\"/export/events/json\");\n      expect(res.status).toBe(401);\n    });\n  });\n});\n","structuredPatch":[{"oldStart":296,"oldLines":8,"newStart":296,"newLines":6,"lines":["   });"," ","   describe(\"Dashboard CRUD\", () => {","-    let dashboardId: string;","-","     it(\"POST /dashboards creates a dashboard\", async () => {","       const res = await request(app)","         .post(\"/dashboards\")"]},{"oldStart":309,"oldLines":7,"newStart":307,"newLines":6,"lines":["       expect(res.status).toBe(201);","       expect(res.body.name).toBe(\"Main Dashboard\");","       expect(res.body.id).toBeDefined();","-      dashboardId = res.body.id;","     });"," ","     it(\"POST /dashboards requires name\", async () => {"]}],"userModified":false,"replaceAll":false}}
