+import Database from "better-sqlite3";
+import fs from "node:fs";
+import path from "node:path";
+
+export function initializeDatabase(dbPath: string = ":memory:"): Database.Database {
+  const db = new Database(dbPath);
+  db.pragma("journal_mode = WAL");
+  db.pragma("foreign_keys = ON");
+
+  const schemaPath = path.resolve(__dirname, "..", "schema.sql");
+  let schema: string;
+  if (fs.existsSync(schemaPath)) {
+    schema = fs.readFileSync(schemaPath, "utf-8");
+  } else {
+    // Fallback for when running from project root
+    const altPath = path.resolve(process.cwd(), "schema.sql");
+    schema = fs.readFileSync(altPath, "utf-8");
+  }
+  db.exec(schema);
+
+  return db;
+}
