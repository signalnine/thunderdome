+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KiyvZJQKMmxpbWnd91quhQ","type":"tool_result","content":"     1→import express from 'express';\n     2→import http from 'http';\n     3→import { WebSocketServer, WebSocket } from 'ws';\n     4→import crypto from 'crypto';\n     5→import { createDb, type Db } from './db.js';\n     6→import { createRouter } from './routes.js';\n     7→import { apply, transform, type Operation } from './ot.js';\n     8→\n     9→interface ClientConnection {\n    10→  ws: WebSocket;\n    11→  clientId: string;\n    12→  documentId: string;\n    13→}\n    14→\n    15→interface WsMessage {\n    16→  type: string;\n    17→  op?: Operation;\n    18→  baseVersion?: number;\n    19→}\n    20→\n    21→export function createApp(dbPath?: string) {\n    22→  const app = express();\n    23→  const db: Db = createDb(dbPath);\n    24→\n    25→  app.use(createRouter(db));\n    26→\n    27→  const httpServer = http.createServer(app);\n    28→  const wss = new WebSocketServer({ noServer: true });\n    29→\n    30→  // Map from documentId -> set of client connections\n    31→  const rooms = new Map<string, Set<ClientConnection>>();\n    32→\n    33→  httpServer.on('upgrade', (req, socket, head) => {\n    34→    const url = new URL(req.url || '', `http://${req.headers.host}`);\n    35→    const match = url.pathname.match(/^\\/ws\\/documents\\/([^/]+)$/);\n    36→\n    37→    if (!match) {\n    38→      socket.destroy();\n    39→      return;\n    40→    }\n    41→\n    42→    const documentId = match[1];\n    43→    const doc = db.getDocument(documentId);\n    44→    if (!doc) {\n    45→      socket.write('HTTP/1.1 404 Not Found\\r\\n\\r\\n');\n    46→      socket.destroy();\n    47→      return;\n    48→    }\n    49→\n    50→    wss.handleUpgrade(req, socket, head, (ws) => {\n    51→      wss.emit('connection', ws, req, documentId);\n    52→    });\n    53→  });\n    54→\n    55→  wss.on('connection', (ws: WebSocket, _req: http.IncomingMessage, documentId: string) => {\n    56→    const clientId = crypto.randomUUID();\n    57→    const conn: ClientConnection = { ws, clientId, documentId };\n    58→\n    59→    if (!rooms.has(documentId)) {\n    60→      rooms.set(documentId, new Set());\n    61→    }\n    62→    rooms.get(documentId)!.add(conn);\n    63→\n    64→    // Send initial sync\n    65→    const doc = db.getDocument(documentId);\n    66→    const version = db.getCurrentVersion(documentId);\n    67→    if (doc) {\n    68→      ws.send(JSON.stringify({\n    69→        type: 'sync',\n    70→        content: doc.content,\n    71→        version,\n    72→        clientId,\n    73→      }));\n    74→    }\n    75→\n    76→    ws.on('message', (data) => {\n    77→      try {\n    78→        const msg: WsMessage = JSON.parse(data.toString());\n    79→        handleMessage(conn, msg);\n    80→      } catch (err) {\n    81→        ws.send(JSON.stringify({\n    82→          type: 'error',\n    83→          message: err instanceof Error ? err.message : 'Invalid message',\n    84→        }));\n    85→      }\n    86→    });\n    87→\n    88→    ws.on('close', () => {\n    89→      const room = rooms.get(documentId);\n    90→      if (room) {\n    91→        room.delete(conn);\n    92→        if (room.size === 0) {\n    93→          rooms.delete(documentId);\n    94→        }\n    95→      }\n    96→    });\n    97→  });\n    98→\n    99→  function handleMessage(conn: ClientConnection, msg: WsMessage): void {\n   100→    if (msg.type !== 'operation') {\n   101→      conn.ws.send(JSON.stringify({ type: 'error', message: `Unknown message type: ${msg.type}` }));\n   102→      return;\n   103→    }\n   104→\n   105→    if (!msg.op || typeof msg.baseVersion !== 'number') {\n   106→      conn.ws.send(JSON.stringify({ type: 'error', message: 'Operation requires op and baseVersion' }));\n   107→      return;\n   108→    }\n   109→\n   110→    if (!isValidOperation(msg.op)) {\n   111→      conn.ws.send(JSON.stringify({ type: 'error', message: 'Invalid operation format' }));\n   112→      return;\n   113→    }\n   114→\n   115→    const { documentId } = conn;\n   116→    const doc = db.getDocument(documentId);\n   117→    if (!doc) {\n   118→      conn.ws.send(JSON.stringify({ type: 'error', message: 'Document not found' }));\n   119→      return;\n   120→    }\n   121→\n   122→    const currentVersion = db.getCurrentVersion(documentId);\n   123→\n   124→    // Get all operations that have been applied since the client's base version\n   125→    let transformedOp = msg.op;\n   126→    if (msg.baseVersion < currentVersion) {\n   127→      const concurrentOps = db.getOperationsSince(documentId, msg.baseVersion);\n   128→      for (const concurrentOp of concurrentOps) {\n   129→        const [transformed] = transform(transformedOp, concurrentOp.operation);\n   130→        transformedOp = transformed;\n   131→      }\n   132→    }\n   133→\n   134→    // Apply the transformed operation\n   135→    try {\n   136→      const newContent = apply(doc.content, transformedOp);\n   137→      const newVersion = currentVersion + 1;\n   138→\n   139→      db.addVersion(documentId, newVersion, newContent, transformedOp);\n   140→\n   141→      // Send ack to the sender\n   142→      conn.ws.send(JSON.stringify({\n   143→        type: 'ack',\n   144→        version: newVersion,\n   145→      }));\n   146→\n   147→      // Broadcast to other clients\n   148→      const room = rooms.get(documentId);\n   149→      if (room) {\n   150→        for (const other of room) {\n   151→          if (other !== conn && other.ws.readyState === WebSocket.OPEN) {\n   152→            other.ws.send(JSON.stringify({\n   153→              type: 'operation',\n   154→              op: transformedOp,\n   155→              version: newVersion,\n   156→              clientId: conn.clientId,\n   157→            }));\n   158→          }\n   159→        }\n   160→      }\n   161→    } catch (err) {\n   162→      conn.ws.send(JSON.stringify({\n   163→        type: 'error',\n   164→        message: err instanceof Error ? err.message : 'Failed to apply operation',\n   165→      }));\n   166→    }\n   167→  }\n   168→\n   169→  function isValidOperation(op: unknown): op is Operation {\n   170→    if (!op || typeof op !== 'object') return false;\n   171→    const o = op as Record<string, unknown>;\n   172→    if (o.type === 'insert') {\n   173→      return typeof o.position === 'number' && typeof o.text === 'string' && o.position >= 0;\n   174→    }\n   175→    if (o.type === 'delete') {\n   176→      return typeof o.position === 'number' && typeof o.count === 'number' && o.position >= 0 && o.count >= 0;\n   177→    }\n   178→    return false;\n   179→  }\n   180→\n   181→  return {\n   182→    app: httpServer,\n   183→\n   184→    async start(port = 0): Promise<number> {\n   185→      return new Promise<number>((resolve) => {\n   186→        httpServer.listen(port, () => {\n   187→          const addr = httpServer.address();\n   188→          const actualPort = typeof addr === 'object' && addr ? addr.port : port;\n   189→          resolve(actualPort);\n   190→        });\n   191→      });\n   192→    },\n   193→\n   194→    async stop(): Promise<void> {\n   195→      // Close all WebSocket connections\n   196→      for (const [, room] of rooms) {\n   197→        for (const conn of room) {\n   198→          conn.ws.close();\n   199→        }\n   200→      }\n   201→      rooms.clear();\n   202→      wss.close();\n   203→      db.close();\n   204→      return new Promise<void>((resolve, reject) => {\n   205→        httpServer.close((err) => {\n   206→          if (err) reject(err);\n   207→          else resolve();\n   208→        });\n   209→      });\n   210→    },\n   211→\n   212→    db,\n   213→  };\n   214→}\n   215→"}]},"parent_tool_use_id":"toolu_01AfRR4bPX37GoFVgNgZvm83","session_id":"ee43e690-08e9-4cbd-87ba-bf103b9279c3","uuid":"e5f255c4-25c1-4411-ad7f-b61f132340af"}
