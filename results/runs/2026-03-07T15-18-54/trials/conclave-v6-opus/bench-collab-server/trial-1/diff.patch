t s.stop();\n}, 10000);\n\ntest('ws applies insert and sends ack', async () => {\n  const s = createApp();\n  const p = await s.start(0);\n  const doc = await httpReq(p, 'POST', '/documents', { title: 'T', content: 'Hello' });\n  const ws = await openWs(p, doc.id as string);\n  await nextMsg(ws); // sync\n  const ackP = nextMsg(ws);\n  ws.send(JSON.stringify({ type: 'operation', op: { type: 'insert', position: 5, text: ' World' }, baseVersion: 1 }));\n  const ack = await ackP;\n  expect(ack.type).toBe('ack');\n  expect(ack.version).toBe(2);\n  const fetched = await httpReq(p, 'GET', `/documents/${doc.id}`);\n  expect(fetched.content).toBe('Hello World');\n  ws.close();\n  await s.stop();\n}, 10000);\n\ntest('ws applies delete operation', async () => {\n  const s = createApp();\n  const p = await s.start(0);\n  const doc = await httpReq(p, 'POST', '/documents', { title: 'T', content: 'Hello World' });\n  const ws = await openWs(p, doc.id as string);\n  await nextMsg(ws);\n  const ackP = nextMsg(ws);\n  ws.send(JSON.stringify({ type: 'operation', op: { type: 'delete', position: 5, count: 6 }, baseVersion: 1 }));\n  const ack = await ackP;\n  expect(ack.type).toBe('ack');\n  expect(ack.version).toBe(2);\n  const fetched = await httpReq(p, 'GET', `/documents/${doc.id}`);\n  expect(fetched.content).toBe('Hello');\n  ws.close();\n  await s.stop();\n}, 10000);\n\ntest('ws broadcasts to other clients', async () => {\n  const s = createApp();\n  const p = await s.start(0);\n  const doc = await httpReq(p, 'POST', '/documents', { title: 'T', content: 'AB' });\n  const ws1 = await openWs(p, doc.id as string);\n  const ws2 = await openWs(p, doc.id as string);\n  await nextMsg(ws1);\n  await nextMsg(ws2);\n  const bcastP = nextMsg(ws2);\n  ws1.send(JSON.stringify({ type: 'operation', op: { type: 'insert', position: 2, text: 'C' }, baseVersion: 1 }));\n  const ack = await nextMsg(ws1);\n  expect(ack.type).toBe('ack');\n  const bcast = await bcastP;\n  expect(bcast.type).toBe('operation');\n  expect(bcast.version).toBe(2);\n  ws1.close();\n  ws2.close();\n  await s.stop();\n}, 10000);\n\ntest('ws error on bad json', async () => {\n  const s = createApp();\n  const p = await s.start(0);\n  const doc = await httpReq(p, 'POST', '/documents', { title: 'T', content: 'c' });\n  const ws = await openWs(p, doc.id as string);\n  await nextMsg(ws);\n  const ep = nextMsg(ws);\n  ws.send('bad json {{{');\n  const e = await ep;\n  expect(e.type).toBe('error');\n  ws.close();\n  await s.stop();\n}, 10000);\n\ntest('ws error on missing baseVersion', async () => {\n  const s = createApp();\n  const p = await s.start(0);\n  const doc = await httpReq(p, 'POST', '/documents', { title: 'T', content: 'c' });\n  const ws = await openWs(p, doc.id as string);\n  await nextMsg(ws);\n  const ep = nextMsg(ws);\n  ws.send(JSON.stringify({ type: 'operation', op: { type: 'insert', position: 0, text: 'x' } }));\n  const e = await ep;\n  expect(e.type).toBe('error');\n  ws.close();\n  await s.stop();\n}, 10000);\n\ntest('ws error on unknown type', async () => {\n  const s = createApp();\n  const p = await s.start(0);\n  const doc = await httpReq(p, 'POST', '/documents', { title: 'T', content: 'c' });\n  const ws = await openWs(p, doc.id as string);\n  await nextMsg(ws);\n  const ep = nextMsg(ws);\n  ws.send(JSON.stringify({ type: 'unknown' }));\n  const e = await ep;\n  expect(e.type).toBe('error');\n  ws.close();\n  await s.stop();\n}, 10000);\n\ntest('ws error on negative position', async () => {\n  const s = createApp();\n  const p = await s.start(0);\n  const doc = await httpReq(p, 'POST', '/documents', { title: 'T', content: 'c' });\n  const ws = await openWs(p, doc.id as string);\n  await nextMsg(ws);\n  const ep = nextMsg(ws);\n  ws.send(JSON.stringify({ type: 'operation', op: { type: 'insert', position: -1, text: 'x' }, baseVersion: 1 }));\n  const e = await ep;\n  expect(e.type).toBe('error');\n  ws.close();\n  await s.stop();\n}, 10000);\n\ntest('ws concurrent edits converge via OT', async () => {\n  const s = createApp();\n  const p = await s.start(0);\n  const doc = await httpReq(p, 'POST', '/documents', { title: 'OT', content: 'abc' });\n  const ws1 = await openWs(p, doc.id as string);\n  const ws2 = await openWs(p, doc.id as string);\n  await nextMsg(ws1); // sync v1\n  await nextMsg(ws2); // sync v1\n\n  // Both based on v1: ws1 inserts 'X' at 1, ws2 inserts 'Y' at 2\n  const ack1P = nextMsg(ws1);\n  ws1.send(JSON.stringify({ type: 'operation', op: { type: 'insert', position: 1, text: 'X' }, baseVersion: 1 }));\n  await ack1P;\n\n  // ws2 sends based on v1 (hasn't seen ws1's op yet)\n  const ack2P = nextMsg(ws2);\n  // Consume ws2's broadcast of ws1's op first\n  await nextMsg(ws2);\n  ws2.send(JSON.stringify({ type: 'operation', op: { type: 'insert', position: 2, text: 'Y' }, baseVersion: 1 }));\n  await ack2P;\n\n  const final = await httpReq(p, 'GET', `/documents/${doc.id}`);\n  // Both inserts must be present; exact position depends on OT transform\n  const content = final.content as string;\n  expect(content).toContain('X');\n  expect(content).toContain('Y');\n  expect(content).toContain('a');\n  expect(content).toContain('b');\n  expect(content).toContain('c');\n  expect(content.length).toBe(5); // abc + X + Y\n\n  ws1.close();\n  ws2.close();\n  await s.stop();\n}, 10000);\n","structuredPatch":[{"oldStart":25,"oldLines":44,"newStart":25,"newLines":189,"lines":["   });"," }"," ","-test('ws A', async () => {","+function openWs(port: number, docId: string): Promise<WebSocket> {","+  return new Promise((resolve, reject) => {","+    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/${docId}`);","+    ws.on('open', () => resolve(ws));","+    ws.on('error', reject);","+  });","+}","+","+function nextMsg(ws: WebSocket): Promise<Record<string, unknown>> {","+  return new Promise((resolve, reject) => {","+    const t = setTimeout(() => reject(new Error('msg timeout')), 5000);","+    ws.once('message', (d) => { 