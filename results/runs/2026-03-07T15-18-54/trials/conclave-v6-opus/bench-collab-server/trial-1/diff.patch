 if (queue && queue.length > 0) { clearTimeout(t); resolve(queue.shift()!); }\n      else setTimeout(check, 10);\n    };\n    setTimeout(check, 10);\n  });\n}\n\nfunction closeWs(ws: WebSocket): Promise<void> {\n  return new Promise((resolve) => {\n    if (ws.readyState === WebSocket.CLOSED) { msgQueues.delete(ws); resolve(); return; }\n    ws.on('close', () => { msgQueues.delete(ws); resolve(); });\n    ws.close();\n  });\n}\n\ntest('OT convergence with concurrent edits', async () => {\n  const s = createApp();\n  const p = await s.start(0);\n\n  const doc = await httpReq(p, 'POST', '/documents', { title: 'OT', content: 'abc' });\n  const ws1 = await openWs(p, doc.id as string);\n  const ws2 = await openWs(p, doc.id as string);\n  await nextMsg(ws1); // consume sync\n  await nextMsg(ws2); // consume sync\n  ws1.send(JSON.stringify({ type: 'operation', op: { type: 'insert', position: 1, text: 'X' }, baseVersion: 1 }));\n  await nextMsg(ws1); // ack\n  await nextMsg(ws2); // broadcast\n  ws2.send(JSON.stringify({ type: 'operation', op: { type: 'insert', position: 2, text: 'Y' }, baseVersion: 1 }));\n  await nextMsg(ws2); // ack\n  const final = await httpReq(p, 'GET', `/documents/${doc.id}`);\n  const content = final.content as string;\n  expect(content).toContain('X');\n  expect(content).toContain('Y');\n  expect(content.length).toBe(5);\n  await closeWs(ws1);\n  await closeWs(ws2);\n\n  await s.stop();\n}, 10000);\n\ntest('10 concurrent clients', async () => {\n  const s = createApp();\n  const p = await s.start(0);\n\n  const doc = await httpReq(p, 'POST', '/documents', { title: 'Concurrent', content: '' });\n  const docId = doc.id as string;\n  const clients: WebSocket[] = [];\n  for (let i = 0; i < 10; i++) {\n    const ws = await openWs(p, docId);\n    await nextMsg(ws); // consume sync\n    clients.push(ws);\n  }\n  for (let i = 0; i < 10; i++) {\n    clients[i].send(JSON.stringify({\n      type: 'operation',\n      op: { type: 'insert', position: i, text: String(i) },\n      baseVersion: i + 1,\n    }));\n    expect((await nextMsg(clients[i])).type).toBe('ack');\n    for (let j = 0; j < 10; j++) {\n      if (j !== i) await nextMsg(clients[j]);\n    }\n  }\n  const finalDoc = await httpReq(p, 'GET', `/documents/${docId}`);\n  const finalContent = finalDoc.content as string;\n  expect(finalContent.length).toBe(10);\n  for (let i = 0; i < 10; i++) {\n    expect(finalContent).toContain(String(i));\n  }\n  for (const ws of clients) await closeWs(ws);\n\n  await s.stop();\n}, 30000);\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":178,"cache_read_input_tokens":45874,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":178},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01AfRR4bPX37GoFVgNgZvm83","session_id":"ee43e690-08e9-4cbd-87ba-bf103b9279c3","uuid":"8b28af0e-a40d-4113-877e-3c4856ef664e"}
