+++ b/src/ot.test.ts
@@ -0,0 +1,174 @@
+import { describe, it, expect } from 'vitest';
+import { apply, transform, type Operation } from './ot.js';
+
+describe('OT apply', () => {
+  it('applies insert operation', () => {
+    const doc = 'hello';
+    const op: Operation = { type: 'insert', position: 5, text: ' world' };
+    expect(apply(doc, op)).toBe('hello world');
+  });
+
+  it('applies insert at beginning', () => {
+    const doc = 'world';
+    const op: Operation = { type: 'insert', position: 0, text: 'hello ' };
+    expect(apply(doc, op)).toBe('hello world');
+  });
+
+  it('applies delete operation', () => {
+    const doc = 'hello world';
+    const op: Operation = { type: 'delete', position: 5, count: 6 };
+    expect(apply(doc, op)).toBe('hello');
+  });
+
+  it('applies delete at beginning', () => {
+    const doc = 'hello world';
+    const op: Operation = { type: 'delete', position: 0, count: 6 };
+    expect(apply(doc, op)).toBe('world');
+  });
+
+  it('rejects insert with position out of bounds', () => {
+    const doc = 'hello';
+    const op: Operation = { type: 'insert', position: 10, text: ' world' };
+    expect(() => apply(doc, op)).toThrow();
+  });
+
+  it('rejects delete with range out of bounds', () => {
+    const doc = 'hello';
+    const op: Operation = { type: 'delete', position: 3, count: 5 };
+    expect(() => apply(doc, op)).toThrow();
+  });
+
+  it('rejects negative position', () => {
+    const doc = 'hello';
+    const op: Operation = { type: 'insert', position: -1, text: 'x' };
+    expect(() => apply(doc, op)).toThrow();
+  });
+});
+
+describe('OT transform', () => {
+  // Two concurrent inserts at different positions
+  it('transforms two inserts where A is before B', () => {
+    const a: Operation = { type: 'insert', position: 2, text: 'X' };
+    const b: Operation = { type: 'insert', position: 5, text: 'Y' };
+    const [aPrime, bPrime] = transform(a, b);
+    // A is before B, so B' position shifts right by A's length
+    // A' stays the same since B is after A
+    expect(aPrime).toEqual({ type: 'insert', position: 2, text: 'X' });
+    expect(bPrime).toEqual({ type: 'insert', position: 6, text: 'Y' });
+  });
+
+  it('transforms two inserts where B is before A', () => {
+    const a: Operation = { type: 'insert', position: 5, text: 'X' };
+    const b: Operation = { type: 'insert', position: 2, text: 'Y' };
+    const [aPrime, bPrime] = transform(a, b);
+    expect(aPrime).toEqual({ type: 'insert', position: 6, text: 'X' });
+    expect(bPrime).toEqual({ type: 'insert', position: 2, text: 'Y' });
+  });
+
+  it('transforms two inserts at same position (A wins tiebreak)', () => {
+    const a: Operation = { type: 'insert', position: 3, text: 'X' };
+    const b: Operation = { type: 'insert', position: 3, text: 'Y' };
+    const [aPrime, bPrime] = transform(a, b);
+    // A goes first (tiebreak), B shifts right
+    expect(aPrime).toEqual({ type: 'insert', position: 3, text: 'X' });
+    expect(bPrime).toEqual({ type: 'insert', position: 4, text: 'Y' });
+  });
+
+  // Insert vs Delete
+  it('transforms insert before delete', () => {
+    const a: Operation = { type: 'insert', position: 2, text: 'XY' };
+    const b: Operation = { type: 'delete', position: 5, count: 3 };
+    const [aPrime, bPrime] = transform(a, b);
+    expect(aPrime).toEqual({ type: 'insert', position: 2, text: 'XY' });
+    expect(bPrime).toEqual({ type: 'delete', position: 7, count: 3 });
+  });
+
+  it('transforms insert after delete', () => {
+    const a: Operation = { type: 'insert', position: 5, text: 'X' };
+    const b: Operation = { type: 'delete', position: 2, count: 2 };
+    const [aPrime, bPrime] = transform(a, b);
+    expect(aPrime).toEqual({ type: 'insert', position: 3, text: 'X' });
+    expect(bPrime).toEqual({ type: 'delete', position: 2, count: 2 });
+  });
+
+  it('transforms insert inside delete region', () => {
+    const a: Operation = { type: 'insert', position: 4, text: 'X' };
+    const b: Operation = { type: 'delete', position: 2, count: 5 };
+    const [aPrime, bPrime] = transform(a, b);
+    // Insert gets moved to start of delete region
+    expect(aPrime).toEqual({ type: 'insert', position: 2, text: 'X' });
+    // Delete must split around the inserted text
+    expect(bPrime).toEqual({ type: 'delete', position: 3, count: 5 });
+  });
+
+  // Delete vs Insert
+  it('transforms delete before insert', () => {
+    const a: Operation = { type: 'delete', position: 2, count: 3 };
+    const b: Operation = { type: 'insert', position: 8, text: 'X' };
+    const [aPrime, bPrime] = transform(a, b);
+    expect(aPrime).toEqual({ type: 'delete', position: 2, count: 3 });
+    expect(bPrime).toEqual({ type: 'insert', position: 5, text: 'X' });
+  });
+
+  // Two deletes
+  it('transforms two non-overlapping deletes (A before B)', () => {
+    const a: Operation = { type: 'delete', position: 1, count: 2 };
+    const b: Operation = { type: 'delete', position: 5, count: 2 };
+    const [aPrime, bPrime] = transform(a, b);
+    expect(aPrime).toEqual({ type: 'delete', position: 1, count: 2 });
+    expect(bPrime).toEqual({ type: 'delete', position: 3, count: 2 });
+  });
+
+  it('transforms two identical deletes (both become no-ops)', () => {
+    const a: Operation = { type: 'delete', position: 2, count: 3 };
+    const b: Operation = { type: 'delete', position: 2, count: 3 };
+    const [aPrime, bPrime] = transform(a, b);
+    expect(aPrime).toEqual({ type: 'delete', position: 2, count: 0 });
+    expect(bPrime).toEqual({ type: 'delete', position: 2, count: 0 });
+  });
+
+  it('transforms overlapping deletes', () => {
+    // A deletes positions 2-4, B deletes positions 3-6
+    const a: Operation = { type: 'delete', position: 2, count: 3 };
+    const b: Operation = { type: 'delete', position: 3, count: 4 };
+    const [aPrime, bPrime] = transform(a, b);
+    // A' only deletes the part of A not already deleted by B: positions 2-2 (1 char)
+    expect(aPrime).toEqual({ type: 'delete', position: 2, count: 1 });
+    // B' only deletes the part of B not already deleted by A: positions 5-6 shifted left
+    expect(bPrime).toEqual({ type: 'delete', position: 2, count: 2 });
+  });
+
+  // Convergence property: apply(apply(doc, A), B') == apply(apply(doc, B), A')
+  it('converges for concurrent inserts', () => {
+    const doc = 'hello world';
+    const a: Operation = { type: 'insert', position: 5, text: ' beautiful' };
+    const b: Operation = { type: 'insert', position: 5, text: ' big' };
+    const [aPrime, bPrime] = transform(a, b);
+
+    const resultAB = apply(apply(doc, a), bPrime);
+    const resultBA = apply(apply(doc, b), aPrime);
+    expect(resultAB).toBe(resultBA);
+  });
+
+  it('converges for insert and delete', () => {
+    const doc = 'hello world';
+    const a: Operation = { type: 'insert', position: 5, text: '!' };
+    const b: Operation = { type: 'delete', position: 6, count: 5 };
+    const [aPrime, bPrime] = transform(a, b);
+
+    const resultAB = apply(apply(doc, a), bPrime);
+    const resultBA = apply(apply(doc, b), aPrime);
+    expect(resultAB).toBe(resultBA);
+  });
+
+  it('converges for two deletes', () => {
+    const doc = 'hello world';
+    const a: Operation = { type: 'delete', position: 0, count: 5 };
+    const b: Operation = { type: 'delete', position: 6, count: 5 };
+    const [aPrime, bPrime] = transform(a, b);
+
+    const resultAB = apply(apply(doc, a), bPrime);
+    const resultBA = apply(apply(doc, b), aPrime);
+    expect(resultAB).toBe(resultBA);
+  });
+});
