tent, docId);\n+    },\n+\n+    close(): void {\n+      db.close();\n+    },\n+  };\n+}\ndiff --git a/src/ot.ts b/src/ot.ts\nnew file mode 100644\nindex 0000000..3cc0fc4\n--- /dev/null\n+++ b/src/ot.ts\n@@ -0,0 +1,134 @@\n+export interface InsertOp {\n+  type: 'insert';\n+  position: number;\n+  text: string;\n+}\n+\n+export interface DeleteOp {\n+  type: 'delete';\n+  position: number;\n+  count: number;\n+}\n+\n+export type Operation = InsertOp | DeleteOp;\n+\n+export function apply(doc: string, op: Operation): string {\n+  if (op.position < 0) {\n+    throw new Error(`Invalid position: ${op.position}`);\n+  }\n+\n+  if (op.type === 'insert') {\n+    if (op.position > doc.length) {\n+      throw new Error(`Insert position ${op.position} out of bounds for document of length ${doc.length}`);\n+    }\n+    return doc.slice(0, op.position) + op.text + doc.slice(op.position);\n+  }\n+\n+  // delete\n+  if (op.count < 0) {\n+    throw new Error(`Invalid delete count: ${op.count}`);\n+  }\n+  if (op.position + op.count > doc.length) {\n+    throw new Error(`Delete range [${op.position}, ${op.position + op.count}) out of bounds for document of length ${doc.length}`);\n+  }\n+  if (op.count === 0) return doc;\n+  return doc.slice(0, op.position) + doc.slice(op.position + op.count);\n+}\n+\n+export function transform(a: Operation, b: Operation): [Operation, Operation] {\n+  if (a.type === 'insert' && b.type === 'insert') {\n+    return transformInsertInsert(a, b);\n+  }\n+  if (a.type === 'insert' && b.type === 'delete') {\n+    return transformInsertDelete(a, b);\n+  }\n+  if (a.type === 'delete' && b.type === 'insert') {\n+    const [bPrime, aPrime] = transformInsertDelete(b, a);\n+    return [aPrime, bPrime];\n+  }\n+  // both deletes\n+  return transformDeleteDelete(a as DeleteOp, b as DeleteOp);\n+}\n+\n+function transformInsertInsert(a: InsertOp, b: InsertOp): [Operation, Operation] {\n+  if (a.position < b.position || (a.position === b.position)) {\n+    // A goes first (tiebreak: A wins at same position)\n+    return [\n+      { ...a },\n+      { ...b, position: b.position + a.text.length },\n+    ];\n+  }\n+  // B is before A\n+  return [\n+    { ...a, position: a.position + b.text.length },\n+    { ...b },\n+  ];\n+}\n+\n+function transformInsertDelete(ins: InsertOp, del: DeleteOp): [Operation, Operation] {\n+  const delEnd = del.position + del.count;\n+\n+  if (ins.position <= del.position) {\n+    // Insert is before or at delete start — shift delete right\n+    return [\n+      { ...ins },\n+      { ...del, position: del.position + ins.text.length },\n+    ];\n+  }\n+\n+  if (ins.position >= delEnd) {\n+    // Insert is after delete — shift insert left\n+    return [\n+      { ...ins, position: ins.position - del.count },\n+      { ...del },\n+    ];\n+  }\n+\n+  // Insert is inside the delete region\n+  // Move insert to the start of the delete region\n+  // The delete still removes the same characters but must account for the inserted text\n+  return [\n+    { ...ins, position: del.position },\n+    { ...del, position: del.position + ins.text.length, count: del.count },\n+  ];\n+}\n+\n+function transformDeleteDelete(a: DeleteOp, b: DeleteOp): [Operation, Operation] {\n+  const aEnd = a.position + a.count;\n+  const bEnd = b.position + b.count;\n+\n+  // No overlap: A is entirely before B\n+  if (aEnd <= b.position) {\n+    return [\n+      { ...a },\n+      { ...b, position: b.position - a.count },\n+    ];\n+  }\n+\n+  // No overlap: B is entirely before A\n+  if (bEnd <= a.position) {\n+    return [\n+      { ...a, position: a.position - b.count },\n+      { ...b },\n+    ];\n+  }\n+\n+  // Overlapping deletes — compute the non-overlapping parts\n+  const overlapStart = Math.max(a.position, b.position);\n+  const overlapEnd = Math.min(aEnd, bEnd);\n+  const overlapCount = overlapEnd - overlapStart;\n+\n+  // A' deletes only the part of A not covered by B\n+  const aRemainingCount = a.count - overlapCount;\n+  // B' de