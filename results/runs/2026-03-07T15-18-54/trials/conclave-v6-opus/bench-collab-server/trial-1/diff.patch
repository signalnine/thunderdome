tpReq(port, 'POST', '/documents', { title: 'T', content: 'c' });","-    const ws = await connectWs(port, res.body.id as string);","-    await waitMsg(ws);","-    const errP = waitMsg(ws);","-    ws.send(JSON.stringify({ type: 'operation', op: { type: 'insert', position: 0, text: 'x' } }));","-    const err = await errP;","-    expect(err.type).toBe('error');","-    ws.close();","-  });","-}, 10000);","-","-test('ws rejects unknown message type', async () => {","-  await withServer(async (port) => {","-    const res = await httpReq(port, 'POST', '/documents', { title: 'T', content: 'c' });","-    const ws = await connectWs(port, res.body.id as string);","-    await waitMsg(ws);","-    const errP = waitMsg(ws);","-    ws.send(JSON.stringify({ type: 'unknown' }));","-    const err = await errP;","-    expect(err.type).toBe('error');","-    ws.close();","-  });","-}, 10000);","-","-test('ws rejects invalid operation negative position', async () => {","-  await withServer(async (port) => {","-    const res = await httpReq(port, 'POST', '/documents', { title: 'T', content: 'c' });","-    const ws = await connectWs(port, res.body.id as string);","-    await waitMsg(ws);","-    const errP = waitMsg(ws);","-    ws.send(JSON.stringify({ type: 'operation', op: { type: 'insert', position: -1, text: 'x' }, baseVersion: 1 }));","-    const err = await errP;","-    expect(err.type).toBe('error');","-    ws.close();","-  });","-}, 10000);"]}],"originalFile":"import { test, expect } from 'vitest';\nimport { createApp } from './server.js';\nimport WebSocket from 'ws';\nimport http from 'http';\n\nfunction httpReq(port: number, method: string, path: string, body?: unknown): Promise<{ status: number; body: Record<string, unknown> }> {\n  return new Promise((resolve, reject) => {\n    const data = body ? JSON.stringify(body) : undefined;\n    const headers: Record<string, string> = {};\n    if (data) {\n      headers['Content-Type'] = 'application/json';\n      headers['Content-Length'] = String(Buffer.byteLength(data));\n    }\n    const req = http.request({ hostname: 'localhost', port, path, method, headers }, (res) => {\n      let raw = '';\n      res.on('data', (d: Buffer) => raw += d);\n      res.on('end', () => {\n        try { resolve({ status: res.statusCode!, body: raw ? JSON.parse(raw) : {} }); }\n        catch { resolve({ status: res.statusCode!, body: {} }); }\n      });\n    });\n    req.on('error', reject);\n    if (data) req.write(data);\n    req.end();\n  });\n}\n\nfunction connectWs(port: number, docId: string): Promise<WebSocket> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/${docId}`);\n    ws.on('open', () => resolve(ws));\n    ws.on('error', reject);\n  });\n}\n\nfunction waitMsg(ws: WebSocket, ms = 5000): Promise<Record<string, unknown>> {\n  return new Promise((resolve, reject) => {\n    const t = setTimeout(() => reject(new Error('waitMsg timeout')), ms);\n    ws.once('message', (d) => { clearTimeout(t); resolve(JSON.parse(d.toString())); });\n  });\n}\n\nasync function withServer(fn: (port: number, server: ReturnType<typeof createApp>) => Promise<void>) {\n  const server = createApp();\n  const port = await server.start(0);\n  try { await fn(port, server); }\n  finally { await server.stop(); }\n}\n\ntest('ws sends sync message on connect', async () => {\n  await withServer(async (port) => {\n    const res = await httpReq(port, 'POST', '/documents', { title: 'T', content: 'Hello WS' });\n    const doc = res.body;\n    const ws = await connectWs(port, doc.id as string);\n    const msg = await waitMsg(ws);\n    expect(msg.type).toBe('sync');\n    expect(msg.content).toBe('Hello WS');\n    expect(msg.version).toBe(1);\n    expect(msg.clientId).toBeDefined();\n    ws.close();\n  });\n}, 10000);\n\ntest('ws rejects connection to non-existent document', async () => {\n  await withServer(async (port) => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/nonexistent`);\n    const code = await new Promise<number>((resolve) => {\n      ws.on('close', (c) => resolve(c));\n      ws.on('error', () => { /* expected */ });\n    });\n    expect(code).toBeDefined();\n  });\n}, 10000);\n\ntest('ws applies insert operation and sends ack', async () => {\n  await withServer(async (port) => {\n    const res = await httpReq(port, 'POST', '/documents', { title: 'T', content: 'Hello' });\n    const doc = res.body;\n    const ws = await connectWs(port, doc.id as string);\n    await waitMsg(ws); // sync\n\n    const ackP = waitMsg(ws);\n    ws.send(JSON.stringify({ type: 'operation', op: { type: 'insert', position: 5, text: ' World' }, baseVersion: 1 }));\n    const ack = await ackP;\n    expect(ack.type).toBe('ack');\n    expect(ack.version).toBe(2);\n\n    const fetched = await httpReq(port, 'GET', `/documents/${doc.id}`);\n    expect(fetched.body.content).toBe('Hello World');\n    ws.close();\n  });\n}, 10000);\n\ntest('ws applies delete operation', async () => {\n  await withServer(async (port) => {\n    const res = await httpReq(port, 'POST', '/documents', { title: 'T', content: 'Hello World' });\n    const doc = res.body;\n    const ws = await connectWs(port, doc.id as string);\n    await waitMsg(ws);\n\n    const ackP = waitMsg(ws);\n    ws.send(JSON.stringify({ type: 'operation', op: { type: 'delete', position: 5, count: 6 }, baseVersion: 1 }));\n    const ack = await ackP;\n    expect(ack.type).toBe('ack');\n    expect(ack.version).toBe(2);\n\n    const fetched = await httpReq(port, 'GET', `/documents/${doc.id}`);\n    expect(fetched.body.content).toBe('Hello');\n    ws.close();\n  });\n}, 10000);\n\ntest('ws broadcasts operations to other clients', async () => {\n  await withServer(async (port) => {\n    const res = await httpReq(port, 'POST', '/documents', { title: 'T', content: 'AB' });\n    const doc = res.body;\n    const ws1 = await connectWs(port, doc.id as string);\n    const ws2 = await connectWs(port, doc.id as string);\n    await waitMsg(ws1);\n    await waitMsg(ws2);\n\n    const broadcastP = waitMsg(ws2);\n    ws1.send(JSON.stringify({ type: 'operation', op: { type: 'insert', position: 2, text: 'C' }, baseVersion: 1 }));\n    const ack = await waitMsg(ws1);\n    expect(ack.type).toBe('ack');\n\n    const broadcast = await broadcastP;\n    expect(broadcast.type).toBe('operation');\n    expect(broadcast.version).toBe(2);\n    ws1.close();\n    ws2.close();\n  });\n}, 10000);\n\ntest('ws rejects invalid message format', async () => {\n  await withServer(async (port) => {\n    const res = await httpReq(port, 'POST', '/documents', { title: 'T', content: 'c' });\n    const ws = await connectWs(port, res.body.id as string);\n    await waitMsg(ws);\n    const errP = waitMsg(ws);\n    ws.send('not json {{{');\n    const err = await errP;\n    expect(err.type).toBe('error');\n    ws.close();\n  });\n}, 10000);\n\ntest('ws rejects operation without baseVersion', async () => {\n  await withServer(async (port) => {\n    const res = await httpReq(port, 'POST', '/documents', { title: 'T', content: 'c' });\n    const ws = await connectWs(port, res.body.id as string);\n    await waitMsg(ws);\n    const errP = waitMsg(ws);\n    ws.send(JSON.stringify({ type: 'operation', op: { type: 'insert', position: 0, text: 'x' } }));\n    const err = await errP;\n    expect(err.type).toBe('error');\n    ws.close();\n  });\n}, 10000);\n\ntest('ws rejects unknown message type', async () => {\n  await withServer(async (port) => {\n    const res = await httpReq(port, 'POST', '/documents', { title: 'T', content: 'c' });\n    const ws = await connectWs(port, res.body.id as string);\n    await waitMsg(ws);\n    const errP = waitMsg(ws);\n    ws.send(JSON.stringify({ type: 'unknown' }));\n    const err = await errP;\n    expect(err.type).toBe('error');\n    ws.close();\n  });\n}, 10000);\n\ntest('ws rejects invalid operation negative position', async () => {\n  await withServer(async (port) => {\n    const res = await httpReq(port, 'POST', '/documents', { title: 'T', content: 'c' });\n    const ws = await connectWs(port, res.body.id as string);\n    await waitMsg(ws);\n    const errP = waitMsg(ws);\n    ws.send(JSON.stringify({ type: 'operation', op: { type: 'insert', position: -1, text: 'x' }, baseVersion: 1 }));\n    const err = await errP;\n    expect(err.type).toBe('error');\n    ws.close();\n  });\n}, 10000);\n"}}
