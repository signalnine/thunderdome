+import { createApp } from './server.js';
+
+const TEST_DB = '/tmp/test-routes-db.sqlite';
+
+describe('REST API', () => {
+  let server: ReturnType<typeof createApp>;
+
+  beforeAll(async () => {
+    server = createApp(TEST_DB);
+    await server.start(0);
+  });
+
+  afterAll(async () => {
+    await server.stop();
+    const fs = await import('fs');
+    if (fs.existsSync(TEST_DB)) fs.unlinkSync(TEST_DB);
+  });
+
+  describe('POST /documents', () => {
+    it('creates a document with title and content', async () => {
+      const res = await request(server.app)
+        .post('/documents')
+        .send({ title: 'My Doc', content: 'Hello' })
+        .expect(201);
+
+      expect(res.body.id).toBeDefined();
+      expect(res.body.title).toBe('My Doc');
+      expect(res.body.content).toBe('Hello');
+    });
+
+    it('creates a document with just title', async () => {
+      const res = await request(server.app)
+        .post('/documents')
+        .send({ title: 'Empty Doc' })
+        .expect(201);
+
+      expect(res.body.content).toBe('');
+    });
+
+    it('rejects missing title', async () => {
+      await request(server.app)
+        .post('/documents')
+        .send({ content: 'no title' })
+        .expect(400);
+    });
+  });
+
+  describe('GET /documents', () => {
+    it('lists documents', async () => {
+      const res = await request(server.app)
+        .get('/documents')
+        .expect(200);
+
+      expect(Array.isArray(res.body)).toBe(true);
+      expect(res.body.length).toBeGreaterThan(0);
+    });
+  });
+
+  describe('GET /documents/:id', () => {
+    it('retrieves a document by id', async () => {
+      const created = await request(server.app)
+        .post('/documents')
+        .send({ title: 'Fetch Me', content: 'content' });
+
+      const res = await request(server.app)
+        .get(`/documents/${created.body.id}`)
+        .expect(200);
+
+      expect(res.body.title).toBe('Fetch Me');
+    });
+
+    it('returns 404 for non-existent document', async () => {
+      await request(server.app)
+        .get('/documents/nonexistent')
+        .expect(404);
+    });
+  });
+
+  describe('PUT /documents/:id', () => {
+    it('updates a document', async () => {
+      const created = await request(server.app)
+        .post('/documents')
+        .send({ title: 'Original', content: 'original' });
+
+      const res = await request(server.app)
+        .put(`/documents/${created.body.id}`)
+        .send({ title: 'Updated', content: 'updated' })
+        .expect(200);
+
+      expect(res.body.title).toBe('Updated');
+      expect(res.body.content).toBe('updated');
+    });
+
+    it('returns 404 for non-existent document', async () => {
+      await request(server.app)
+        .put('/documents/nonexistent')
+        .send({ title: 'X' })
+        .expect(404);
