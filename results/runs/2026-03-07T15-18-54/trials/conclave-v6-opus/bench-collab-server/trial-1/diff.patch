+++ b/src/server.ts
@@ -0,0 +1,214 @@
+import express from 'express';
+import http from 'http';
+import { WebSocketServer, WebSocket } from 'ws';
+import crypto from 'crypto';
+import { createDb, type Db } from './db.js';
+import { createRouter } from './routes.js';
+import { apply, transform, type Operation } from './ot.js';
+
+interface ClientConnection {
+  ws: WebSocket;
+  clientId: string;
+  documentId: string;
+}
+
+interface WsMessage {
+  type: string;
+  op?: Operation;
+  baseVersion?: number;
+}
+
+export function createApp(dbPath?: string) {
+  const app = express();
+  const db: Db = createDb(dbPath);
+
+  app.use(createRouter(db));
+
+  const httpServer = http.createServer(app);
+  const wss = new WebSocketServer({ noServer: true });
+
+  // Map from documentId -> set of client connections
+  const rooms = new Map<string, Set<ClientConnection>>();
+
+  httpServer.on('upgrade', (req, socket, head) => {
+    const url = new URL(req.url || '', `http://${req.headers.host}`);
+    const match = url.pathname.match(/^\/ws\/documents\/([^/]+)$/);
+
+    if (!match) {
+      socket.destroy();
+      return;
+    }
+
+    const documentId = match[1];
+    const doc = db.getDocument(documentId);
+    if (!doc) {
+      socket.write('HTTP/1.1 404 Not Found\r\n\r\n');
+      socket.destroy();
+      return;
+    }
+
+    wss.handleUpgrade(req, socket, head, (ws) => {
+      wss.emit('connection', ws, req, documentId);
+    });
+  });
+
+  wss.on('connection', (ws: WebSocket, _req: http.IncomingMessage, documentId: string) => {
+    const clientId = crypto.randomUUID();
+    const conn: ClientConnection = { ws, clientId, documentId };
+
+    if (!rooms.has(documentId)) {
+      rooms.set(documentId, new Set());
+    }
+    rooms.get(documentId)!.add(conn);
+
+    // Send initial sync
+    const doc = db.getDocument(documentId);
+    const version = db.getCurrentVersion(documentId);
+    if (doc) {
+      ws.send(JSON.stringify({
+        type: 'sync',
+        content: doc.content,
+        version,
+        clientId,
+      }));
+    }
+
+    ws.on('message', (data) => {
+      try {
+        const msg: WsMessage = JSON.parse(data.toString());
+        handleMessage(conn, msg);
+      } catch (err) {
+        ws.send(JSON.stringify({
+          type: 'error',
+          message: err instanceof Error ? err.message : 'Invalid message',
+        }));
+      }
+    });
+
+    ws.on('close', () => {
+      const room = rooms.get(documentId);
+      if (room) {
+        room.delete(conn);
+        if (room.size === 0) {
+          rooms.delete(documentId);
+        }
+      }
+    });
+  });
+
+  function handleMessage(conn: ClientConnection, msg: WsMessage): void {
+    if (msg.type !== 'operation') {
+      conn.ws.send(JSON.stringify({ type: 'error', message: `Unknown message type: ${msg.type}` }));
+      return;
+    }
+
+    if (!msg.op || typeof msg.baseVersion !== 'number') {
+      conn.ws.send(JSON.stringify({ type: 'error', message: 'Operation requires op and baseVersion' }));
+      return;
+    }
+
+    if (!isValidOperation(msg.op)) {
+      conn.ws.send(JSON.stringify({ type: 'error', message: 'Invalid operation format' }));
+      return;
+    }
+
+    const { documentId } = conn;
+    const doc = db.getDocument(documentId);
+    if (!doc) {
+      conn.ws.send(JSON.stringify({ type: 'error', message: 'Document not found' }));
+      return;
+    }
+
+    const currentVersion = db.getCurrentVersion(documentId);
+
+    // Get all operations that have been applied since the client's base version
+    let transformedOp = msg.op;
+    if (msg.baseVersion < currentVersion) {
+      const concurrentOps = db.getOperationsSince(documentId, msg.baseVersion);
+      for (const concurrentOp of concurrentOps) {
+        const [transformed] = transform(transformedOp, concurrentOp.operation);
+        transformedOp = transformed;
+      }
+    }
+
+    // Apply the transformed operation
+    try {
+      const newContent = apply(doc.content, transformedOp);
+      const newVersion = currentVersion + 1;
+
+      db.addVersion(documentId, newVersion, newContent, transformedOp);
+
+      // Send ack to the sender
+      conn.ws.send(JSON.stringify({
+        type: 'ack',
+        version: newVersion,
+      }));
+
+      // Broadcast to other clients
+      const room = rooms.get(documentId);
+      if (room) {
+        for (const other of room) {
+          if (other !== conn && other.ws.readyState === WebSocket.OPEN) {
+            other.ws.send(JSON.stringify({
+              type: 'operation',
+              op: transformedOp,
+              version: newVersion,
+              clientId: conn.clientId,
+            }));
+          }
+        }
+      }
+    } catch (err) {
+      conn.ws.send(JSON.stringify({
+        type: 'error',
+        message: err instanceof Error ? err.message : 'Failed to apply operation',
+      }));
+    }
+  }
+
+  function isValidOperation(op: unknown): op is Operation {
+    if (!op || typeof op !== 'object') return false;
+    const o = op as Record<string, unknown>;
+    if (o.type === 'insert') {
+      return typeof o.position === 'number' && typeof o.text === 'string' && o.position >= 0;
+    }
+    if (o.type === 'delete') {
+      return typeof o.position === 'number' && typeof o.count === 'number' && o.position >= 0 && o.count >= 0;
+    }
+    return false;
+  }
+
+  return {
+    app: httpServer,
+
+    async start(port = 0): Promise<number> {
+      return new Promise<number>((resolve) => {
+        httpServer.listen(port, () => {
+          const addr = httpServer.address();
+          const actualPort = typeof addr === 'object' && addr ? addr.port : port;
+          resolve(actualPort);
+        });
+      });
+    },
+
+    async stop(): Promise<void> {
+      // Close all WebSocket connections
+      for (const [, room] of rooms) {
+        for (const conn of room) {
+          conn.ws.close();
+        }
+      }
+      rooms.clear();
+      wss.close();
+      db.close();
+      return new Promise<void>((resolve, reject) => {
+        httpServer.close((err) => {
+          if (err) reject(err);
+          else resolve();
+        });
+      });
+    },
+
+    db,
+  };
+}
