or.type).toBe('error');","-      ws.close();","-    } finally {","-      await server.stop();","-    }","-  });","-});","+  await server.stop();","+}, 10000);"]}],"originalFile":"import { describe, it, expect } from 'vitest';\nimport WebSocket from 'ws';\nimport http from 'http';\nimport { createApp } from './server.js';\n\nfunction httpRequest(port: number, method: string, urlPath: string, body?: unknown): Promise<{ status: number; body: Record<string, unknown> }> {\n  return new Promise((resolve, reject) => {\n    const data = body ? JSON.stringify(body) : undefined;\n    const headers: Record<string, string> = {};\n    if (data) {\n      headers['Content-Type'] = 'application/json';\n      headers['Content-Length'] = String(Buffer.byteLength(data));\n    }\n    const req = http.request({\n      hostname: 'localhost', port, path: urlPath, method, headers,\n    }, (res) => {\n      let raw = '';\n      res.on('data', (d: Buffer) => raw += d);\n      res.on('end', () => {\n        try {\n          resolve({ status: res.statusCode!, body: raw ? JSON.parse(raw) : {} });\n        } catch {\n          resolve({ status: res.statusCode!, body: {} });\n        }\n      });\n    });\n    req.on('error', reject);\n    if (data) req.write(data);\n    req.end();\n  });\n}\n\nfunction connectWs(port: number, docId: string): Promise<WebSocket> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/${docId}`);\n    ws.on('open', () => resolve(ws));\n    ws.on('error', reject);\n  });\n}\n\nfunction waitForMessage(ws: WebSocket, timeoutMs = 5000): Promise<Record<string, unknown>> {\n  return new Promise((resolve, reject) => {\n    const timer = setTimeout(() => reject(new Error('waitForMessage timed out')), timeoutMs);\n    ws.once('message', (data) => {\n      clearTimeout(timer);\n      resolve(JSON.parse(data.toString()));\n    });\n  });\n}\n\ndescribe('WebSocket collaboration', () => {\n  it('sends sync message on connect', async () => {\n    const server = createApp();\n    const port = await server.start(0);\n    try {\n      const res = await httpRequest(port, 'POST', '/documents', { title: 'WS Test', content: 'Hello WS' });\n      const doc = res.body;\n      const ws = await connectWs(port, doc.id as string);\n      const msg = await waitForMessage(ws);\n      expect(msg.type).toBe('sync');\n      expect(msg.content).toBe('Hello WS');\n      expect(msg.version).toBe(1);\n      expect(msg.clientId).toBeDefined();\n      ws.close();\n    } finally {\n      await server.stop();\n    }\n  });\n\n  it('rejects connection to non-existent document', async () => {\n    const server = createApp();\n    const port = await server.start(0);\n    try {\n      const ws = new WebSocket(`ws://localhost:${port}/ws/documents/nonexistent`);\n      const closed = new Promise<number>((resolve) => {\n        ws.on('close', (code) => resolve(code));\n        ws.on('error', () => { /* expected */ });\n      });\n      const code = await closed;\n      expect(code).toBeDefined();\n    } finally {\n      await server.stop();\n    }\n  });\n\n  it('applies an insert operation and sends ack', async () => {\n    const server = createApp();\n    const port = await server.start(0);\n    try {\n      const res = await httpRequest(port, 'POST', '/documents', { title: 'Op Test', content: 'Hello' });\n      const doc = res.body;\n      const ws = await connectWs(port, doc.id as string);\n      const sync = await waitForMessage(ws);\n      expect(sync.type).toBe('sync');\n\n      const ackPromise = waitForMessage(ws);\n      ws.send(JSON.stringify({\n        type: 'operation',\n        op: { type: 'insert', position: 5, text: ' World' },\n        baseVersion: 1,\n      }));\n\n      const ack = await ackPromise;\n      expect(ack.type).toBe('ack');\n      expect(ack.version).toBe(2);\n\n      const fetched = await httpRequest(port, 'GET', `/documents/${doc.id}`);\n      expect(fetched.body.content).toBe('Hello World');\n      ws.close();\n    } finally {\n      await server.stop();\n    }\n  });\n\n  it('applies a delete operation', async () => {\n    const server = createApp();\n    const port = await server.start(0);\n    try {\n      const res = await httpRequest(port, 'POST', '/documents', { title: 'Del Test', content: 'Hello World' });\n      const doc = res.body;\n      const ws = await connectWs(port, doc.id as string);\n      await waitForMessage(ws);\n\n      const ackPromise = waitForMessage(ws);\n      ws.send(JSON.stringify({\n        type: 'operation',\n        op: { type: 'delete', position: 5, count: 6 },\n        baseVersion: 1,\n      }));\n\n      const ack = await ackPromise;\n      expect(ack.type).toBe('ack');\n      expect(ack.version).toBe(2);\n\n      const fetched = await httpRequest(port, 'GET', `/documents/${doc.id}`);\n      expect(fetched.body.content).toBe('Hello');\n      ws.close();\n    } finally {\n      await server.stop();\n    }\n  });\n\n  it('broadcasts operations to other clients', async () => {\n    const server = createApp();\n    const port = await server.start(0);\n    try {\n      const res = await httpRequest(port, 'POST', '/documents', { title: 'Broadcast', content: 'AB' });\n      const doc = res.body;\n      const ws1 = await connectWs(port, doc.id as string);\n      const ws2 = await connectWs(port, doc.id as string);\n\n      await waitForMessage(ws1);\n      await waitForMessage(ws2);\n\n      const broadcastPromise = waitForMessage(ws2);\n      ws1.send(JSON.stringify({\n        type: 'operation',\n        op: { type: 'insert', position: 2, text: 'C' },\n        baseVersion: 1,\n      }));\n\n      const ack = await waitForMessage(ws1);\n      expect(ack.type).toBe('ack');\n\n      const broadcast = await broadcastPromise;\n      expect(broadcast.type).toBe('operation');\n      expect(broadcast.version).toBe(2);\n\n      ws1.close();\n      ws2.close();\n    } finally {\n      await server.stop();\n    }\n  });\n\n  it('rejects invalid message format', async () => {\n    const server = createApp();\n    const port = await server.start(0);\n    try {\n      const res = await httpRequest(port, 'POST', '/documents', { title: 'Err1', content: 'c' });\n      const doc = res.body;\n      const ws = await connectWs(port, doc.id as string);\n      await waitForMessage(ws);\n\n      const errorPromise = waitForMessage(ws);\n      ws.send('not json at all {{{');\n\n      const error = await errorPromise;\n      expect(error.type).toBe('error');\n      ws.close();\n    } finally {\n      await server.stop();\n    }\n  });\n\n  it('rejects operation without baseVersion', async () => {\n    const server = createApp();\n    const port = await server.start(0);\n    try {\n      const res = await httpRequest(port, 'POST', '/documents', { title: 'Err2', content: 'c' });\n      const doc = res.body;\n      const ws = await connectWs(port, doc.id as string);\n      await waitForMessage(ws);\n\n      const errorPromise = waitForMessage(ws);\n      ws.send(JSON.stringify({\n        type: 'operation',\n        op: { type: 'insert', position: 0, text: 'x' },\n      }));\n\n      const error = await errorPromise;\n      expect(error.type).toBe('error');\n      ws.close();\n    } finally {\n      await server.stop();\n    }\n  });\n\n  it('rejects unknown message type', async () => {\n    const server = createApp();\n    const port = await server.start(0);\n    try {\n      const res = await httpRequest(port, 'POST', '/documents', { title: 'Err3', content: 'c' });\n      const doc = res.body;\n      const ws = await connectWs(port, doc.id as string);\n      await waitForMessage(ws);\n\n      const errorPromise = waitForMessage(ws);\n      ws.send(JSON.stringify({ type: 'unknown' }));\n\n      const error = await errorPromise;\n      expect(error.type).toBe('error');\n      ws.close();\n    } finally {\n      await server.stop();\n    }\n  });\n\n  it('rejects invalid operation (negative position)', async () => {\n    const server = createApp();\n    const port = await server.start(0);\n    try {\n      const res = await httpRequest(port, 'POST', '/documents', { title: 'Err4', content: 'c' });\n      const doc = res.body;\n      const ws = await connectWs(port, doc.id as string);\n      await waitForMessage(ws);\n\n      const errorPromise = waitForMessage(ws);\n      ws.send(JSON.stringify({\n        type: 'operation',\n        op: { type: 'insert', position: -1, text: 'x' },\n        baseVersion: 1,\n      }));\n\n      const error = await errorPromise;\n      expect(error.type).toBe('error');\n      ws.close();\n    } finally {\n      await server.stop();\n    }\n  });\n});\n"}}
