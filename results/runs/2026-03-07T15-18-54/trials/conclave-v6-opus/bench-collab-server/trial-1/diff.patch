y: Record<string, unknown> }> {\n  return new Promise((resolve, reject) => {\n    const data = body ? JSON.stringify(body) : undefined;\n    const headers: Record<string, string> = {};\n    if (data) {\n      headers['Content-Type'] = 'application/json';\n      headers['Content-Length'] = String(Buffer.byteLength(data));\n    }\n    const req = http.request({ hostname: 'localhost', port, path, method, headers }, (res) => {\n      let raw = '';\n      res.on('data', (d: Buffer) => raw += d);\n      res.on('end', () => {\n        try { resolve({ status: res.statusCode!, body: raw ? JSON.parse(raw) : {} }); }\n        catch { resolve({ status: res.statusCode!, body: {} }); }\n      });\n    });\n    req.on('error', reject);\n    if (data) req.write(data);\n    req.end();\n  });\n}\n\ntest('ws test 1', async () => {\n  const server = createApp();\n  const port = await server.start(0);\n\n  const res = await httpReq(port, 'POST', '/documents', { title: 'T', content: 'hello' });\n  const doc = res.body;\n\n  const result = await new Promise<string>((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/${doc.id}`);\n    const t = setTimeout(() => { ws.close(); reject(new Error('timeout')); }, 5000);\n    ws.on('message', (d) => { clearTimeout(t); ws.close(); resolve(d.toString()); });\n    ws.on('error', (e) => { clearTimeout(t); reject(e); });\n  });\n\n  expect(JSON.parse(result).type).toBe('sync');\n  await server.stop();\n}, 10000);\n\ntest('ws test 2', async () => {\n  const server = createApp();\n  const port = await server.start(0);\n\n  const res = await httpReq(port, 'POST', '/documents', { title: 'T', content: 'world' });\n  const doc = res.body;\n\n  const result = await new Promise<string>((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/${doc.id}`);\n    const t = setTimeout(() => { ws.close(); reject(new Error('timeout')); }, 5000);\n    ws.on('message', (d) => { clearTimeout(t); ws.close(); resolve(d.toString()); });\n    ws.on('error', (e) => { clearTimeout(t); reject(e); });\n  });\n\n  expect(JSON.parse(result).type).toBe('sync');\n  await server.stop();\n}, 10000);\n"}}
