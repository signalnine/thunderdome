+++ b/src/db.test.ts
@@ -0,0 +1,128 @@
+import { describe, it, expect, beforeEach, afterEach } from 'vitest';
+import { createDb, type Db } from './db.js';
+import fs from 'fs';
+
+const TEST_DB = '/tmp/test-collab-db.sqlite';
+
+describe('Database layer', () => {
+  let db: Db;
+
+  beforeEach(() => {
+    if (fs.existsSync(TEST_DB)) fs.unlinkSync(TEST_DB);
+    db = createDb(TEST_DB);
+  });
+
+  afterEach(() => {
+    db.close();
+    if (fs.existsSync(TEST_DB)) fs.unlinkSync(TEST_DB);
+  });
+
+  describe('documents CRUD', () => {
+    it('creates a document and retrieves it', () => {
+      const doc = db.createDocument('Test Title', 'Hello');
+      expect(doc.id).toBeDefined();
+      expect(doc.title).toBe('Test Title');
+      expect(doc.content).toBe('Hello');
+
+      const retrieved = db.getDocument(doc.id);
+      expect(retrieved).toBeDefined();
+      expect(retrieved!.title).toBe('Test Title');
+      expect(retrieved!.content).toBe('Hello');
+    });
+
+    it('creates a document with empty content by default', () => {
+      const doc = db.createDocument('Empty Doc');
+      expect(doc.content).toBe('');
+    });
+
+    it('lists all documents', () => {
+      db.createDocument('Doc 1', 'Content 1');
+      db.createDocument('Doc 2', 'Content 2');
+      const docs = db.listDocuments();
+      expect(docs).toHaveLength(2);
+    });
+
+    it('updates a document', () => {
+      const doc = db.createDocument('Old Title', 'Old Content');
+      const updated = db.updateDocument(doc.id, { title: 'New Title', content: 'New Content' });
+      expect(updated).toBeDefined();
+      expect(updated!.title).toBe('New Title');
+      expect(updated!.content).toBe('New Content');
+    });
+
+    it('updates only title', () => {
+      const doc = db.createDocument('Title', 'Content');
+      const updated = db.updateDocument(doc.id, { title: 'New Title' });
+      expect(updated!.title).toBe('New Title');
+      expect(updated!.content).toBe('Content');
+    });
+
+    it('deletes a document', () => {
+      const doc = db.createDocument('To Delete', 'Delete me');
+      const deleted = db.deleteDocument(doc.id);
+      expect(deleted).toBe(true);
+      expect(db.getDocument(doc.id)).toBeUndefined();
+    });
+
+    it('returns false when deleting non-existent document', () => {
+      expect(db.deleteDocument('nonexistent')).toBe(false);
+    });
+
+    it('returns undefined for non-existent document', () => {
+      expect(db.getDocument('nonexistent')).toBeUndefined();
+    });
+  });
+
+  describe('version history', () => {
+    it('creates initial version on document creation', () => {
+      const doc = db.createDocument('Doc', 'Initial');
+      const versions = db.getVersions(doc.id);
+      expect(versions).toHaveLength(1);
+      expect(versions[0].version).toBe(1);
+      expect(versions[0].content).toBe('Initial');
+    });
+
+    it('adds a version when content changes', () => {
+      const doc = db.createDocument('Doc', 'v1');
+      db.addVersion(doc.id, 2, 'v2', { type: 'insert', position: 2, text: ' edited' });
+      const versions = db.getVersions(doc.id);
+      expect(versions).toHaveLength(2);
+      expect(versions[1].version).toBe(2);
+      expect(versions[1].content).toBe('v2');
+    });
+
+    it('retrieves operations since a given version', () => {
+      const doc = db.createDocument('Doc', 'v1');
+      db.addVersion(doc.id, 2, 'v1X', { type: 'insert', position: 2, text: 'X' });
+      db.addVersion(doc.id, 3, 'v1XY', { type: 'insert', position: 3, text: 'Y' });
+      const ops = db.getOperationsSince(doc.id, 1);
+      expect(ops).toHaveLength(2);
+      expect(ops[0].version).toBe(2);
+      expect(ops[1].version).toBe(3);
+    });
+
+    it('returns current version number', () => {
+      const doc = db.createDocument('Doc', 'v1');
+      expect(db.getCurrentVersion(doc.id)).toBe(1);
+      db.addVersion(doc.id, 2, 'v2', { type: 'insert', position: 0, text: 'x' });
+      expect(db.getCurrentVersion(doc.id)).toBe(2);
+    });
+  });
+
+  describe('persistence', () => {
+    it('data survives close and reopen', () => {
+      const doc = db.createDocument('Persistent', 'Survives restart');
+      db.close();
+
+      const db2 = createDb(TEST_DB);
+      const retrieved = db2.getDocument(doc.id);
+      expect(retrieved).toBeDefined();
+      expect(retrieved!.title).toBe('Persistent');
+      expect(retrieved!.content).toBe('Survives restart');
+      db2.close();
+
+      // Reopen for afterEach cleanup
+      db = createDb(TEST_DB);
+    });
+  });
+});
diff --git a/src/db.ts b/src/db.ts
new file mode 100644
index 0000000..2d019c2
--- /dev/null
+++ b/src/db.ts
@@ -0,0 +1,155 @@
+import Database from 'better-sqlite3';
+import crypto from 'crypto';
+import { fileURLToPath } from 'url';
+import fs from 'fs';
+import path from 'path';
+import type { Operation } from './ot.js';
+
+export interface Document {
+  id: string;
+  title: string;
+  content: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface Version {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operation: string | null;
+  created_at: string;
+}
+
+export interface VersionWithOp {
+  version: number;
+  operation: Operation;
+}
+
+export interface Db {
+  createDocument(title: string, content?: string): Document;
+  getDocument(id: string): Document | undefined;
+  listDocuments(): Document[];
+  updateDocument(id: string, updates: { title?: string; content?: string }): Document | undefined;
+  deleteDocument(id: string): boolean;
+  addVersion(docId: string, version: number, content: string, operation: Operation): void;
+  getVersions(docId: string): Version[];
+  getOperationsSince(docId: string, sinceVersion: number): VersionWithOp[];
+  getCurrentVersion(docId: string): number;
+  updateDocumentContent(docId: string, content: string): void;
+  close(): void;
+}
+
+export function createDb(dbPath?: string): Db {
+  const resolvedPath = dbPath || ':memory:';
+  const db = new Database(resolvedPath);
+
+  db.pragma('journal_mode = WAL');
+  db.pragma('foreign_keys = ON');
+
+  // Initialize schema
+  const currentDir = path.dirname(fileURLToPath(import.meta.url));
+  const schemaPath = path.join(currentDir, '..', 'schema.sql');
+  if (fs.existsSync(schemaPath)) {
+    const schema = fs.readFileSync(schemaPath, 'utf-8');
+    db.exec(schema);
+  } else {
+    // Inline fallback schema
+    db.exec(`
+      CREATE TABLE IF NOT EXISTS documents (
+        id TEXT PRIMARY KEY,
+        title TEXT NOT NULL,
+        content TEXT NOT NULL DEFAULT '',
+        created_at TEXT NOT NULL DEFAULT (datetime('now')),
+        updated_at TEXT NOT NULL DEFAULT (datetime('now'))
+      );
+      CREATE TABLE IF NOT EXISTS versions (
+        id INTEGER PRIMARY KEY AUTOINCREMENT,
+        document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
+        version INTEGER NOT NULL,
+        content TEXT NOT NULL,
+        operation TEXT,
+        created_at TEXT NOT NULL DEFAULT (datetime('now')),
+        UNIQUE(document_id, version)
+      );
+    `);
+  }
+
+  const stmts = {
+    insertDoc: db.prepare('INSERT INTO documents (id, title, content) VALUES (?, ?, ?)'),
+    getDoc: db.prepare('SELECT * FROM documents WHERE id = ?'),
+    listDocs: db.prepare('SELECT * FROM documents ORDER BY created_at DESC'),
+    updateDoc: db.prepare('UPDATE documents SET title = ?, content = ?, updated_at = datetime(\'now\') WHERE id = ?'),
+    deleteDoc: db.prepare('DELETE FROM documents WHERE id = ?'),
+    insertVersion: db.prepare('INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)'),
+    getVersions: db.prepare('SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC'),
+    getOpsSince: db.prepare('SELECT version, operation FROM versions WHERE document_id = ? AND version > ? ORDER BY version ASC'),
+    getMaxVersion: db.prepare('SELECT MAX(version) as max_version FROM versions WHERE document_id = ?'),
+    updateContent: db.prepare('UPDATE documents SET content = ?, updated_at = datetime(\'now\') WHERE id = ?'),
+  };
+
+  return {
+    createDocument(title: string, content = ''): Document {
+      const id = crypto.randomUUID();
+      stmts.insertDoc.run(id, title, content);
+      // Create initial version
+      stmts.insertVersion.run(id, 1, content, null);
+      return stmts.getDoc.get(id) as Document;
+    },
+
+    getDocument(id: string): Document | undefined {
+      return stmts.getDoc.get(id) as Document | undefined;
+    },
+
+    listDocuments(): Document[] {
+      return stmts.listDocs.all() as Document[];
+    },
+
+    updateDocument(id: string, updates: { title?: string; content?: string }): Document | undefined {
+      const existing = stmts.getDoc.get(id) as Document | undefined;
+      if (!existing) return undefined;
+      const newTitle = updates.title ?? existing.title;
+      const newContent = updates.content ?? existing.content;
+      stmts.updateDoc.run(newTitle, newContent, id);
+      return stmts.getDoc.get(id) as Document;
+    },
+
+    deleteDocument(id: string): boolean {
+      const result = stmts.deleteDoc.run(id);
+      return result.changes > 0;
+    },
+
+    addVersion(docId: string, version: number, content: string, operation: Operation): void {
+      stmts.insertVersion.run(docId, version, content, JSON.stringify(operation));
+      stmts.updateContent.run(content, docId);
+    },
+
+    getVersions(docId: string): Version[] {
+      return stmts.getVersions.all(docId) as Version[];
+    },
+
+    getOperationsSince(docId: string, sinceVersion: number): VersionWithOp[] {
+      const rows = stmts.getOpsSince.all(docId, sinceVersion) as Array<{ version: number; operation: string }>;
+      return rows
+        .filter(r => r.operation !== null)
+        .map(r => ({
+          version: r.version,
+          operation: JSON.parse(r.operation) as Operation,
+        }));
+    },
+
+    getCurrentVersion(docId: string): number {
+      const row = stmts.getMaxVersion.get(docId) as { max_version: number | null };
+      return row.max_version ?? 0;
+    },
+
+    updateDocumentContent(docId: string, content: string): void {
+      stmts.updateContent.run(content, docId);
+    },
+
+    close(): void {
+      db.close();
+    },
+  };
+}
