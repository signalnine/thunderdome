ait server.stop();\n    }\n  });\n\n  it('rejects invalid operation (negative position)', async () => {\n    const server = createApp();\n    const port = await server.start(0);\n    try {\n      const res = await httpRequest(port, 'POST', '/documents', { title: 'Err4', content: 'c' });\n      const doc = res.body;\n      const ws = await connectWs(port, doc.id as string);\n      await waitForMessage(ws);\n\n      const errorPromise = waitForMessage(ws);\n      ws.send(JSON.stringify({\n        type: 'operation',\n        op: { type: 'insert', position: -1, text: 'x' },\n        baseVersion: 1,\n      }));\n\n      const error = await errorPromise;\n      expect(error.type).toBe('error');\n      ws.close();\n    } finally {\n      await server.stop();\n    }\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":612,"cache_read_input_tokens":81224,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":612},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"ee43e690-08e9-4cbd-87ba-bf103b9279c3","uuid":"a774183c-373e-43f6-bea7-ef985616bf5e"}
