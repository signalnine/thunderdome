Buffer.byteLength(data));\n    }\n    const req = http.request({ hostname: 'localhost', port, path, method, headers }, (res) => {\n      let raw = '';\n      res.on('data', (d: Buffer) => raw += d);\n      res.on('end', () => {\n        try { resolve(raw ? JSON.parse(raw) : {}); }\n        catch { resolve({}); }\n      });\n    });\n    req.on('error', reject);\n    if (data) req.write(data);\n    req.end();\n  });\n}\n\nfunction openWs(port: number, docId: string): Promise<WebSocket> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/${docId}`);\n    ws.on('open', () => resolve(ws));\n    ws.on('error', reject);\n  });\n}\n\nfunction nextMsg(ws: WebSocket): Promise<Record<string, unknown>> {\n  return new Promise((resolve, reject) => {\n    const t = setTimeout(() => reject(new Error('msg timeout')), 5000);\n    ws.once('message', (d) => { clearTimeout(t); resolve(JSON.parse(d.toString())); });\n  });\n}\n\ntest('ws sends sync message on connect', async () => {\n  const s = createApp();\n  const p = await s.start(0);\n  const doc = await httpReq(p, 'POST', '/documents', { title: 'T', content: 'Hello WS' });\n  const ws = await openWs(p, doc.id as string);\n  const msg = await nextMsg(ws);\n  expect(msg.type).toBe('sync');\n  expect(msg.content).toBe('Hello WS');\n  expect(msg.version).toBe(1);\n  expect(msg.clientId).toBeDefined();\n  ws.close();\n  await s.stop();\n}, 10000);\n\ntest('ws rejects non-existent doc', async () => {\n  const s = createApp();\n  const p = await s.start(0);\n  const ws = new WebSocket(`ws://localhost:${p}/ws/documents/nonexistent`);\n  const code = await new Promise<number>((resolve) => {\n    ws.on('close', (c) => resolve(c));\n    ws.on('error', () => {});\n  });\n  expect(code).toBeDefined();\n  await s.stop();\n}, 10000);\n\ntest('ws applies insert and sends ack', async () => {\n  const s = createApp();\n  const p = await s.start(0);\n  const doc = await httpReq(p, 'POST'