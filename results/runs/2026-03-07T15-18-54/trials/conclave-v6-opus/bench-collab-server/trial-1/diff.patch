onst s = createApp();\n  const p = await s.start(0);\n\n  const doc = await httpReq(p, 'POST', '/documents', { title: 'T1', content: 'Hello WS' });\n  const ws = await openWs(p, doc.id as string);\n  const syncMsg = await nextMsg(ws);\n  expect(syncMsg.type).toBe('sync');\n  expect(syncMsg.content).toBe('Hello WS');\n  expect(syncMsg.version).toBe(1);\n  expect(syncMsg.clientId).toBeDefined();\n  await closeWs(ws);\n\n  await s.stop();\n}, 10000);\n\ntest('reject non-existent doc', async () => {\n  const s = createApp();\n  const p = await s.start(0);\n\n  const wsBad = new WebSocket(`ws://localhost:${p}/ws/documents/nonexistent`);\n  await new Promise<void>((resolve) => {\n    wsBad.on('close', () => resolve());\n    wsBad.on('error', () => {});\n  });\n\n  await s.stop();\n}, 10000);\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":359,"cache_read_input_tokens":23318,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":359},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01AfRR4bPX37GoFVgNgZvm83","session_id":"ee43e690-08e9-4cbd-87ba-bf103b9279c3","uuid":"7239d662-a30b-48d4-b57a-df22113b4e4b"}
