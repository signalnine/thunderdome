h?: string): Db {\n  const resolvedPath = dbPath || ':memory:';\n  const db = new Database(resolvedPath);\n\n  db.pragma('journal_mode = WAL');\n  db.pragma('foreign_keys = ON');\n\n  // Read and execute schema\n  const schemaPath = path.join(import.meta.dirname, '..', 'schema.sql');\n  if (fs.existsSync(schemaPath)) {\n    const schema = fs.readFileSync(schemaPath, 'utf-8');\n    db.exec(schema);\n  }\n\n  const stmts = {\n    insertDoc: db.prepare('INSERT INTO documents (id, title, content) VALUES (?, ?, ?)'),\n    getDoc: db.prepare('SELECT * FROM documents WHERE id = ?'),\n    listDocs: db.prepare('SELECT * FROM documents ORDER BY created_at DESC'),\n    updateDoc: db.prepare('UPDATE documents SET title = ?, content = ?, updated_at = datetime(\\'now\\') WHERE id = ?'),\n    deleteDoc: db.prepare('DELETE FROM documents WHERE id = ?'),\n    insertVersion: db.prepare('INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)'),\n    getVersions: db.prepare('SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC'),\n    getOpsSince: db.prepare('SELECT version, operation FROM versions WHERE document_id = ? AND version > ? ORDER BY version ASC'),\n    getMaxVersion: db.prepare('SELECT MAX(version) as max_version FROM versions WHERE document_id = ?'),\n    updateContent: db.prepare('UPDATE documents SET content = ?, updated_at = datetime(\\'now\\') WHERE id = ?'),\n  };\n\n  return {\n    createDocument(title: string, content = ''): Document {\n      const id = crypto.randomUUID();\n      stmts.insertDoc.run(id, title, content);\n      // Create initial version\n      stmts.insertVersion.run(id, 1, content, null);\n      return stmts.getDoc.get(id) as Document;\n    },\n\n    getDocument(id: string): Document | undefined {\n      return stmts.getDoc.get(id) as Document | undefined;\n    },\n\n    listDocuments(): Document[] {\n      return stmts.listDocs.all() as Document[];\n    },\n\n    updateDocument(id: string, updates: { title?: string; content?: string }): Document | undefined {\n      const existing = stmts.getDoc.get(id) as Document | undefined;\n      if (!existing) return undefined;\n      const newTitle = updates.title ?? existing.title;\n      const newContent = updates.content ?? existing.content;\n      stmts.updateDoc.run(newTitle, newContent, id);\n      return stmts.getDoc.get(id) as Document;\n    },\n\n    deleteDocument(id: string): boolean {\n      const result = stmts.deleteDoc.run(id);\n      return result.changes > 0;\n    },\n\n    addVersion(docId: string, version: number, content: string, operation: Operation): void {\n      stmts.insertVersion.run(docId, version, content, JSON.stringify(operation));\n      stmts.updateContent.run(content, docId);\n    },\n\n    getVersions(docId: string): Version[] {\n      return stmts.getVersions.all(docId) as Version[];\n    },\n\n    getOperationsSince(docId: string, sinceVersion: number): VersionWithOp[] {\n      const rows = stmts.getOpsSince.all(docId, sinceVersion) as Array<{ version: number; operation: string }>;\n      return rows\n        .filter(r => r.operation !== null)\n        .map(r => ({\n          version: r.version,\n          operation: JSON.parse(r.operation) as Operation,\n        }));\n    },\n\n    getCurrentVersion(docId: string): number {\n      const row = stmts.getMaxVersion.get(docId) as { max_version: number | null };\n      return row.max_version ?? 0;\n    },\n\n    updateDocumentContent(docId: string, content: string): void {\n      stmts.updateContent.run(content, docId);\n    },\n\n    close(): void {\n      db.close();\n    },\n  };\n}\n","structuredPatch":[{"oldStart":1,"oldLines":5,"newStart":1,"newLines":6,"lines":[" import Database from 'better-sqlite3';"," import crypto from 'crypto';","+import { fileURLToPath } from 'url';"," import fs from 'fs';"," import path from 'path';"," import type { Operation } from './ot.js';"]}],"userModified":false,"replaceAll":false}}
