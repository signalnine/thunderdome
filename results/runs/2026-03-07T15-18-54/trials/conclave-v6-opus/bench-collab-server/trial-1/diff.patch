nt');\n+    });\n+\n+    it('updates only title', () => {\n+      const doc = db.createDocument('Title', 'Content');\n+      const updated = db.updateDocument(doc.id, { title: 'New Title' });\n+      expect(updated!.title).toBe('New Title');\n+      expect(updated!.content).toBe('Content');\n+    });\n+\n+    it('deletes a document', () => {\n+      const doc = db.createDocument('To Delete', 'Delete me');\n+      const deleted = db.deleteDocument(doc.id);\n+      expect(deleted).toBe(true);\n+      expect(db.getDocument(doc.id)).toBeUndefined();\n+    });\n+\n+    it('returns false when deleting non-existent document', () => {\n+      expect(db.deleteDocument('nonexistent')).toBe(false);\n+    });\n+\n+    it('returns undefined for non-existent document', () => {\n+      expect(db.getDocument('nonexistent')).toBeUndefined();\n+    });\n+  });\n+\n+  describe('version history', () => {\n+    it('creates initial version on document creation', () => {\n+      const doc = db.createDocument('Doc', 'Initial');\n+      const versions = db.getVersions(doc.id);\n+      expect(versions).toHaveLength(1);\n+      expect(versions[0].version).toBe(1);\n+      expect(versions[0].content).toBe('Initial');\n+    });\n+\n+    it('adds a version when content changes', () => {\n+      const doc = db.createDocument('Doc', 'v1');\n+      db.addVersion(doc.id, 2, 'v2', { type: 'insert', position: 2, text: ' edited' });\n+      const versions = db.getVersions(doc.id);\n+      expect(versions).toHaveLength(2);\n+      expect(versions[1].version).toBe(2);\n+      expect(versions[1].content).toBe('v2');\n+    });\n+\n+    it('retrieves operations since a given version', () => {\n+      const doc = db.createDocument('Doc', 'v1');\n+      db.addVersion(doc.id, 2, 'v1X', { type: 'insert', position: 2, text: 'X' });\n+      db.addVersion(doc.id, 3, 'v1XY', { type: 'insert', position: 3, text: 'Y' });\n+      const ops = db.getOperationsSince(doc.id, 1);\n+      expect(ops).toHaveLength(2);\n+      expect(ops[0].version).toBe(2);\n+      expect(ops[1].version).toBe(3);\n+    });\n+\n+    it('returns current version number', () => {\n+      const doc = db.createDocument('Doc', 'v1');\n+      expect(db.getCurrentVersion(doc.id)).toBe(1);\n+      db.addVersion(doc.id, 2, 'v2', { type: 'insert', position: 0, text: 'x' });\n+      expect(db.getCurrentVersion(doc.id)).toBe(2);\n+    });\n+  });\n+\n+  describe('persistence', () => {\n+    it('data survives close and reopen', () => {\n+      const doc = db.createDocument('Persistent', 'Survives restart');\n+      db.close();\n+\n+      const db2 = createDb(TEST_DB);\n+      const retrieved = db2.getDocument(doc.id);\n+      expect(retrieved).toBeDefined();\n+      expect(retrieved!.title).toBe('Persistent');\n+      expect(retrieved!.content).toBe('Survives restart');\n+      db2.close();\n+\n+      // Reopen for afterEach cleanup\n+      db = createDb(TEST_DB);\n+    });\n+  });\n+});\ndiff --git a/src/ot.test.ts b/src/ot.test.ts\nnew file mode 100644\nindex 0000000..8179c17\n--- /dev/null\n+++ b/src/ot.test.ts\n@@ -0,0 +1,174 @@\n+import { describe, it, expect } from 'vitest';\n+import { apply, transform, type Operation } from './ot.js';\n+\n+describe('OT apply', () => {\n+  it('applies insert operation', () => {\n+    const doc = 'hello';\n+    const op: Operation = { type: 'insert', position: 5, text: ' world' };\n+    expect(apply(doc, op)).toBe('hello world');\n+  });\n+\n+  it('applies insert at beginning', () => {\n+    const doc = 'world';\n+    const op: Operation = { type: 'insert', position: 0, text: 'hello ' };\n+    expect(apply(doc, op)).toBe('hello world');\n+  });\n+\n+  it('applies delete operation', () => {\n+    const doc = 'hello world';\n+    const op: Operation = { type: 'delete', position: 5, count: 6 };\n+    expect(apply(doc, op)).toBe('hello');\n+  });\n+\n+  it('applies delete at beginning', () => {\n+    const doc = 'hello world';\n+    const op: Operation = { type: 'delete', position: 