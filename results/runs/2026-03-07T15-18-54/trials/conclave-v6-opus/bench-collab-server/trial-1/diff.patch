t('websocket collaboration full lifecycle', async () => {\n  const s = createApp();\n  const p = await s.start(0);\n\n  // 1. Sync on connect\n  const doc1 = await httpReq(p, 'POST', '/documents', { title: 'T1', content: 'Hello WS' });\n  const ws1 = await openWs(p, doc1.id as string);\n  const syncMsg = await nextMsg(ws1);\n  expect(syncMsg.type).toBe('sync');\n  expect(syncMsg.content).toBe('Hello WS');\n  expect(syncMsg.version).toBe(1);\n  expect(syncMsg.clientId).toBeDefined();\n  await closeWs(ws1);\n\n  // 2. Non-existent document rejection\n  const wsBad = new WebSocket(`ws://localhost:${p}/ws/documents/nonexistent`);\n  await new Promise<void>((resolve) => {\n    wsBad.on('close', () => resolve());\n    wsBad.on('error', () => {});\n  });\n\n  // 3. Insert operation with ack\n  const doc2 = await httpReq(p, 'POST', '/documents', { title: 'T2', content: 'Hello' });\n  const ws2 = await openWs(p, doc2.id as string);\n  await nextMsg(ws2);\n  const ackP1 = nextMsg(ws2);\n  ws2.send(JSON.stringify({ type: 'operation', op: { type: 'insert', position: 5, text: ' World' }, baseVersion: 1 }));\n  const ack1 = await ackP1;\n  expect(ack1.type).toBe('ack');\n  expect(ack1.version).toBe(2);\n  const fetched1 = await httpReq(p, 'GET', `/documents/${doc2.id}`);\n  expect(fetched1.content).toBe('Hello World');\n  await closeWs(ws2);\n\n  // 4. Delete operation\n  const doc3 = await httpReq(p, 'POST', '/documents', { title: 'T3', content: 'Hello World' });\n  const ws3 = await openWs(p, doc3.id as string);\n  await nextMsg(ws3);\n  const ackP2 = nextMsg(ws3);\n  ws3.send(JSON.stringify({ type: 'operation', op: { type: 'delete', position: 5, count: 6 }, baseVersion: 1 }));\n  const ack2 = await ackP2;\n  expect(ack2.type).toBe('ack');\n  expect(ack2.version).toBe(2);\n  const fetched2 = await httpReq(p, 'GET', `/documents/${doc3.id}`);\n  expect(fetched2.content).toBe('Hello');\n  await closeWs(ws3);\n\n  // 5. Broadcast to other clients\n  const doc4 = await httpReq(p, 'POST', '/documents', { title: 'T4', content: 'AB' });\n  const ws4a = await openWs(p, doc4.id as string);\n  const ws4b = await openWs(p, doc4.id as string);\n  await nextMsg(ws4a);\n  await nextMsg(ws4b);\n  const bcastP = nextMsg(ws4b);\n  ws4a.send(JSON.stringify({ type: 'operation', op: { type: 'insert', position: 2, text: 'C' }, baseVersion: 1 }));\n  const ack3 = await nextMsg(ws4a);\n  expect(ack3.type).toBe('ack');\n  const bcast = await bcastP;\n  expect(bcast.type).toBe('operation');\n  expect(bcast.version).toBe(2);\n  await closeWs(ws4a);\n  await closeWs(ws4b);\n\n  // 6. Error: bad json\n  const doc5 = await httpReq(p, 'POST', '/documents', { title: 'T5', content: 'c' });\n  const ws5 = await openWs(p, doc5.id as string);\n  await nextMsg(ws5);\n  const errP1 = nextMsg(ws5);\n  ws5.send('bad json {{{');\n  expect((await errP1).type).toBe('error');\n  await closeWs(ws5);\n\n  // 7. Error: missing baseVersion\n  const doc6 = await httpReq(p, 'POST', '/documents', { title: 'T6', content: 'c' });\n  const ws6 = await openWs(p, doc6.id as string);\n  await nextMsg(ws6);\n  const errP2 = nextMsg(ws6);\n  ws6.send(JSON.stringify({ type: 'operation', op: { type: 'insert', position: 0, text: 'x' } }));\n  expect((await errP2).type).toBe('error');\n  await closeWs(ws6);\n\n  // 8. Error: unknown type\n  const doc7 = await httpReq(p, 'POST', '/documents', { title: 'T7', content: 'c' });\n  const ws7 = await openWs(p, doc7.id as string);\n  await nextMsg(ws7);\n  const errP3 = nextMsg(ws7);\n  ws7.send(JSON.stringify({ type: 'unknown' }));\n  expect((await errP3).type).toBe('error');\n  await closeWs(ws7);\n\n  // 9. Error: negative position\n  const doc8 = await httpReq(p, 'POST', '/documents', { title: 'T8', content: 'c' });\n  const ws8 = await openWs(p, doc8.id as string);\n  await nextMsg(ws8);\n  const errP4 = nextMsg(ws8);\n  ws8.send(JSON.stringify({ type: 'operation', op: { type: 'insert', position: -1, text: 'x' }, baseVersion: 1 }));\n  expect((await errP4).type).toBe('error');\n  await closeWs(ws8);\n\n  // 10. OT convergence\n  const doc9 = await httpReq(p, 'POST', '/documents', { title: 'OT', content: 'abc' });\n  const ws9a = await openWs(p, doc9.id as string);\n  const ws9b = await openWs(p, doc9.id as string);\n  await nextMsg(ws9a);\n  await nextMsg(ws9b);\n  const ackP9a = nextMsg(ws9a);\n  ws9a.send(JSON.stringify({ type: 'operation', op: { type: 'insert', position: 1, text: 'X' }, baseVersion: 1 }));\n  await ackP9a;\n  await nextMsg(ws9b);\n  const ackP9b = nextMsg(ws9b);\n  ws9b.send(JSON.stringify({ type: 'operation', op: { type: 'insert', position: 2, text: 'Y' }, baseVersion: 1 }));\n  await ackP9b;\n  const final = await httpReq(p, 'GET', `/documents/${doc9.id}`);\n  const content = final.content as string;\n  expect(content).toContain('X');\n  expect(content).toContain('Y');\n  expect(content.length).toBe(5);\n  await closeWs(ws9a);\n  await closeWs(ws9b);\n\n  // 11. Ten concurrent clients\n  const doc10 = await httpReq(p, 'POST', '/documents', { title: 'Concurrent', content: '' });\n  const docId = doc10.id as string;\n  const clients: WebSocket[] = [];\n  for (let i = 0; i < 10; i++) {\n    const ws = await openWs(p, docId);\n    await nextMsg(ws);\n    clients.push(ws);\n  }\n  for (let i = 0; i < 10; i++) {\n    const ackP = nextMsg(clients[i]);\n    clients[i].send(JSON.stringify({\n      type: 'operation',\n      op: { type: 'insert', position: i, text: String(i) },\n      baseVersion: i + 1,\n    }));\n    expect((await ackP).type).toBe('ack');\n    for (let j = 0; j < 10; j++) {\n      if (j !== i) await nextMsg(clients[j]);\n    }\n  }\n  const finalDoc = await httpReq(p, 'GET', `/documents/${docId}`);\n  const finalContent = finalDoc.content as string;\n  expect(finalContent.length).toBe(10);\n  for (let i = 0; i < 10; i++) {\n    expect(finalContent).toContain(String(i));\n  }\n  for (const ws of clients) await closeWs(ws);\n\n  await s.stop();\n}, 30000);\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":406,"cache_read_input_tokens":154256,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":406},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"ee43e690-08e9-4cbd-87ba-bf103b9279c3","uuid":"bda7829c-1497-46cc-9694-625157cc61c2"}
