+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TCkALa8i4hsjkVUsjQLKyd","type":"tool_result","content":"     1→import Database from 'better-sqlite3';\n     2→import crypto from 'crypto';\n     3→import { fileURLToPath } from 'url';\n     4→import fs from 'fs';\n     5→import path from 'path';\n     6→import type { Operation } from './ot.js';\n     7→\n     8→export interface Document {\n     9→  id: string;\n    10→  title: string;\n    11→  content: string;\n    12→  created_at: string;\n    13→  updated_at: string;\n    14→}\n    15→\n    16→export interface Version {\n    17→  id: number;\n    18→  document_id: string;\n    19→  version: number;\n    20→  content: string;\n    21→  operation: string | null;\n    22→  created_at: string;\n    23→}\n    24→\n    25→export interface VersionWithOp {\n    26→  version: number;\n    27→  operation: Operation;\n    28→}\n    29→\n    30→export interface Db {\n    31→  createDocument(title: string, content?: string): Document;\n    32→  getDocument(id: string): Document | undefined;\n    33→  listDocuments(): Document[];\n    34→  updateDocument(id: string, updates: { title?: string; content?: string }): Document | undefined;\n    35→  deleteDocument(id: string): boolean;\n    36→  addVersion(docId: string, version: number, content: string, operation: Operation): void;\n    37→  getVersions(docId: string): Version[];\n    38→  getOperationsSince(docId: string, sinceVersion: number): VersionWithOp[];\n    39→  getCurrentVersion(docId: string): number;\n    40→  updateDocumentContent(docId: string, content: string): void;\n    41→  close(): void;\n    42→}\n    43→\n    44→export function createDb(dbPath?: string): Db {\n    45→  const resolvedPath = dbPath || ':memory:';\n    46→  const db = new Database(resolvedPath);\n    47→\n    48→  db.pragma('journal_mode = WAL');\n    49→  db.pragma('foreign_keys = ON');\n    50→\n    51→  // Initialize schema\n    52→  const currentDir = path.dirname(fileURLToPath(import.meta.url));\n    53→  const schemaPath = path.join(currentDir, '..', 'schema.sql');\n    54→  if (fs.existsSync(schemaPath)) {\n    55→    const schema = fs.readFileSync(schemaPath, 'utf-8');\n    56→    db.exec(schema);\n    57→  } else {\n    58→    // Inline fallback schema\n    59→    db.exec(`\n    60→      CREATE TABLE IF NOT EXISTS documents (\n    61→        id TEXT PRIMARY KEY,\n    62→        title TEXT NOT NULL,\n    63→        content TEXT NOT NULL DEFAULT '',\n    64→        created_at TEXT NOT NULL DEFAULT (datetime('now')),\n    65→        updated_at TEXT NOT NULL DEFAULT (datetime('now'))\n    66→      );\n    67→      CREATE TABLE IF NOT EXISTS versions (\n    68→        id INTEGER PRIMARY KEY AUTOINCREMENT,\n    69→        document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,\n    70→        version INTEGER NOT NULL,\n    71→        content TEXT NOT NULL,\n    72→        operation TEXT,\n    73→        created_at TEXT NOT NULL DEFAULT (datetime('now')),\n    74→        UNIQUE(document_id, version)\n    75→      );\n    76→    `);\n    77→  }\n    78→\n    79→  const stmts = {\n    80→    insertDoc: db.prepare('INSERT INTO documents (id, title, content) VALUES (?, ?, ?)'),\n    81→    getDoc: db.prepare('SELECT * FROM documents WHERE id = ?'),\n    82→    listDocs: db.prepare('SELECT * FROM documents ORDER BY created_at DESC'),\n    83→    updateDoc: db.prepare('UPDATE documents SET title = ?, content = ?, updated_at = datetime(\\'now\\') WHERE id = ?'),\n    84→    deleteDoc: db.prepare('DELETE FROM documents WHERE id = ?'),\n    85→    insertVersion: db.prepare('INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)'),\n    86→    getVersions: db.prepare('SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC'),\n    87→    getOpsSince: db.prepare('SELECT version, operation FROM versions WHERE document_id = ? AND version > ? ORDER BY version ASC'),\n    88→    getMaxVersion: db.prepare('SELECT MAX(version) as max_version FROM versions WHERE document_id = ?'),\n    89→    updateContent: db.prepare('UPDATE documents SET content = ?, updated_at = datetime(\\'now\\') WHERE id = ?'),\n    90→  };\n    91→\n    92→  return {\n    93→    createDocument(title: string, content = ''): Document {\n    94→      const id = crypto.randomUUID();\n    95→      stmts.insertDoc.run(id, title, content);\n    96→      // Create initial version\n    97→      stmts.insertVersion.run(id, 1, content, null);\n    98→      return stmts.getDoc.get(id) as Document;\n    99→    },\n   100→\n   101→    getDocument(id: string): Document | undefined {\n   102→      return stmts.getDoc.get(id) as Document | undefined;\n   103→    },\n   104→\n   105→    listDocuments(): Document[] {\n   106→      return stmts.listDocs.all() as Document[];\n   107→    },\n   108→\n   109→    updateDocument(id: string, updates: { title?: string; content?: string }): Document | undefined {\n   110→      const existing = stmts.getDoc.get(id) as Document | undefined;\n   111→      if (!existing) return undefined;\n   112→      const newTitle = updates.title ?? existing.title;\n   113→      const newContent = updates.content ?? existing.content;\n   114→      stmts.updateDoc.run(newTitle, newContent, id);\n   115→      return stmts.getDoc.get(id) as Document;\n   116→    },\n   117→\n   118→    deleteDocument(id: string): boolean {\n   119→      const result = stmts.deleteDoc.run(id);\n   120→      return result.changes > 0;\n   121→    },\n   122→\n   123→    addVersion(docId: string, version: number, content: string, operation: Operation): void {\n   124→      stmts.insertVersion.run(docId, version, content, JSON.stringify(operation));\n   125→      stmts.updateContent.run(content, docId);\n   126→    },\n   127→\n   128→    getVersions(docId: string): Version[] {\n   129→      return stmts.getVersions.all(docId) as Version[];\n   130→    },\n   131→\n   132→    getOperationsSince(docId: string, sinceVersion: number): VersionWithOp[] {\n   133→      const rows = stmts.getOpsSince.all(docId, sinceVersion) as Array<{ version: number; operation: string }>;\n   134→      return rows\n   135→        .filter(r => r.operation !== null)\n   136→        .map(r => ({\n   137→          version: r.version,\n   138→          operation: JSON.parse(r.operation) as Operation,\n   139→        }));\n   140→    },\n   141→\n   142→    getCurrentVersion(docId: string): number {\n   143→      const row = stmts.getMaxVersion.get(docId) as { max_version: number | null };\n   144→      return row.max_version ?? 0;\n   145→    },\n   146→\n   147→    updateDocumentContent(docId: string, content: string): void {\n   148→      stmts.updateContent.run(content, docId);\n   149→    },\n   150→\n   151→    close(): void {\n   152→      db.close();\n   153→    },\n   154→  };\n   155→}\n   156→"}]},"parent_tool_use_id":"toolu_01AfRR4bPX37GoFVgNgZvm83","session_id":"ee43e690-08e9-4cbd-87ba-bf103b9279c3","uuid":"ecae11b8-ef50-4f88-a8ae-2cba181d6b59"}
