+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01CTnnQpHgmsDQM9J6ucCcXV","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_013fQbeLemGUWBP5EMYfZGsX","name":"Write","input":{"file_path":"/workspace/src/ws-broadcast.test.ts","content":"import { test, expect } from 'vitest';\nimport { createApp } from './server.js';\nimport WebSocket from 'ws';\nimport http from 'http';\n\nfunction httpReq(port: number, method: string, path: string, body?: unknown): Promise<Record<string, unknown>> {\n  return new Promise((resolve, reject) => {\n    const data = body ? JSON.stringify(body) : undefined;\n    const headers: Record<string, string> = {};\n    if (data) { headers['Content-Type'] = 'application/json'; headers['Content-Length'] = String(Buffer.byteLength(data)); }\n    const req = http.request({ hostname: 'localhost', port, path, method, headers }, (res) => {\n      let raw = '';\n      res.on('data', (d: Buffer) => raw += d);\n      res.on('end', () => { try { resolve(raw ? JSON.parse(raw) : {}); } catch { resolve({}); } });\n    });\n    req.on('error', reject);\n    if (data) req.write(data);\n    req.end();\n  });\n}\n\nconst msgQueues = new Map<WebSocket, Record<string, unknown>[]>();\n\nfunction openWs(port: number, docId: string): Promise<WebSocket> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/${docId}`);\n    const queue: Record<string, unknown>[] = [];\n    msgQueues.set(ws, queue);\n    ws.on('message', (d) => { queue.push(JSON.parse(d.toString())); });\n    ws.on('open', () => resolve(ws));\n    ws.on('error', reject);\n  });\n}\n\nfunction nextMsg(ws: WebSocket): Promise<Record<string, unknown>> {\n  return new Promise((resolve, reject) => {\n    const queue = msgQueues.get(ws);\n    if (queue && queue.length > 0) { resolve(queue.shift()!); return; }\n    const t = setTimeout(() => reject(new Error('msg timeout')), 5000);\n    const check = () => {\n      if (queue && queue.length > 0) { clearTimeout(t); resolve(queue.shift()!); }\n      else setTimeout(check, 10);\n    };\n    setTimeout(check, 10);\n  });\n}\n\nfunction closeWs(ws: WebSocket): Promise<void> {\n  return new Promise((resolve) => {\n    if (ws.readyState === WebSocket.CLOSED) { msgQueues.delete(ws); resolve(); return; }\n    ws.on('close', () => { msgQueues.delete(ws); resolve(); });\n    ws.close();\n  });\n}\n\ntest('broadcast to other clients', async () => {\n  const s = createApp();\n  const p = await s.start(0);\n\n  const doc = await httpReq(p, 'POST', '/documents', { title: 'T4', content: 'AB' });\n  const ws1 = await openWs(p, doc.id as string);\n  const ws2 = await openWs(p, doc.id as string);\n  await nextMsg(ws1); // consume sync\n  await nextMsg(ws2); // consume sync\n  ws1.send(JSON.stringify({ type: 'operation', op: { type: 'insert', position: 2, text: 'C' }, baseVersion: 1 }));\n  const ack = await nextMsg(ws1);\n  expect(ack.type).toBe('ack');\n  const bcast = await nextMsg(ws2);\n  expect(bcast.type).toBe('operation');\n  expect(bcast.version).toBe(2);\n  await closeWs(ws1);\n  await closeWs(ws2);\n\n  await s.stop();\n}, 10000);\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":178,"cache_read_input_tokens":45874,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":178},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01AfRR4bPX37GoFVgNgZvm83","session_id":"ee43e690-08e9-4cbd-87ba-bf103b9279c3","uuid":"74924c20-5f32-41cf-9372-f9feaa947c74"}
