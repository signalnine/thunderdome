of callbacks\n    52→  private progressListeners = new Map<string, Set<(percent: number, message?: string) => void>>();\n    53→  // recurring schedules\n    54→  private schedules = new Map<string, Schedule>();\n    55→  // middleware per queue\n    56→  private middlewares = new Map<string, Array<(task: Task, next: () => void) => void>>();\n    57→  // handler per queue\n    58→  private handlers = new Map<string, (task: Task) => void>();\n    59→  // shutdown state\n    60→  private isShutdown = false;\n    61→  private shutdownResult: ShutdownResult | null = null;\n    62→  private shutdownCallbacks: Array<() => void> = [];\n    63→  private shutdownResolvers: Array<() => void> = [];\n    64→\n    65→  add(payload: unknown, options: TaskOptions = {}): Task {\n    66→    if (this.isShutdown) {\n    67→      throw new Error('System is shut down. Cannot add new tasks.');\n    68→    }\n    69→    const priority = options.priority ?? 5;\n    70→    if (!Number.isInteger(priority) || priority < 1 || priority > 10) {\n    71→      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    72→    }\n    73→\n    74→    const deps = options.dependencies ?? [];\n    75→\n    76→    // Validate dependencies exist\n    77→    for (const depId of deps) {\n    78→      if (!this.tasks.has(depId)) {\n    79→        throw new Error(`Dependency not found: ${depId}`);\n    80→      }\n    81→    }\n    82→\n    83→    const queue = options.queue ?? DEFAULT_QUEUE;\n    84→    const now = new Date();\n    85→\n    86→    let availableAt = now;\n    87→    if (options.availableAt) {\n    88→      availableAt = options.availableAt;\n    89→    } else if (options.delay != null && options.delay > 0) {\n    90→      availableAt = new Date(now.getTime() + options.delay);\n    91→    }\n    92→\n    93→    const task: InternalTask = {\n    94→      id: randomUUID(),\n    95→      payload,\n    96→      status: 'pending',\n    97→      createdAt: now,\n    98→      queue,\n    99→      priority,\n   100→      availableAt,\n   101→      attempts: 0,\n   102→      maxRetries: options.maxRetries ?? 3,\n   103→      backoffDelay: options.backoffDelay ?? 1000,\n   104→      progress: 0,\n   105→      dependencies: [...deps],\n   106→    };\n   107→\n   108→    // Check for circular dependencies\n   109→    if (deps.length > 0) {\n   110→      this.detectCycle(task.id, deps);\n   111→    }\n   112→\n   113→    this.tasks.set(task.id, task);\n   114→\n   115→    // Track unresolved dependencies\n   116→    const unresolved = new Set<string>();\n   117→    for (const depId of deps) {\n   118→      const depTask = this.tasks.get(depId)!;\n   119→      if (depTask.status !== 'completed') {\n   120→        unresolved.add(depId);\n   121→        if (!this.dependents.has(depId)) {\n   122→          this.dependents.set(depId, new Set());\n   123→        }\n   124→        this.dependents.get(depId)!.add(task.id);\n   125→      }\n   126→    }\n   127→    if (unresolved.size > 0) {\n   128→      this.unresolvedDeps.set(task.id, unresolved);\n   129→    }\n   130→\n   131→    if (!this.queues.has(queue)) {\n   132→      this.queues.set(queue, []);\n   133→    }\n   134→    this.insertSorted(this.queues.get(queue)!, task);\n   135→\n   136→    return this.toPublicTask(task);\n   137→  }\n   138→\n   139→  process(queueName?: string): Task | null {\n   140→    const queue = queueName ?? DEFAULT_QUEUE;\n   141→    const pending = this.queues.get(queue);\n   142→    if (!pending) return null;\n   143→\n   144→    // Check concurrency limit\n   145→    const limit = this.concurrencyLimits.get(queue) ?? 0;\n   146→    const active = this.activeCounts.get(queue) ?? 0;\n   147→    if (limit > 0 && active >= limit) return null;\n   148→\n   149→    const now = Date.now();\n   150→    for (let i = 0; i < pending.length; i++) {\n   151→      const task = pending[i];\n   152→      if (\n   153→        task.status === 'pending' &&\n   154→      