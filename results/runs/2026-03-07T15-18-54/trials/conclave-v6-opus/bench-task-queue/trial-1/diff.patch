+import { describe, test, expect, beforeEach } from 'vitest';
+import { TaskQueueSystem } from '../src/index.js';
+
+describe('Phase 2: Named Queues', () => {
+  let tq: TaskQueueSystem;
+
+  beforeEach(() => {
+    tq = new TaskQueueSystem();
+  });
+
+  test('tasks added to a specific named queue', () => {
+    const task = tq.add('job', { queue: 'emails' });
+    expect(task.queue).toBe('emails');
+  });
+
+  test('default queue is used when no name is given', () => {
+    const task = tq.add('job');
+    expect(task.queue).toBe('default');
+  });
+
+  test('named queues are independent', () => {
+    tq.add('email-job', { queue: 'emails' });
+    tq.add('sms-job', { queue: 'sms' });
+
+    const emailTask = tq.process('emails');
+    expect(emailTask!.payload).toBe('email-job');
+
+    const smsTask = tq.process('sms');
+    expect(smsTask!.payload).toBe('sms-job');
+  });
+
+  test('retrieving from one queue does not affect another', () => {
+    tq.add('email1', { queue: 'emails' });
+    tq.add('email2', { queue: 'emails' });
+    tq.add('sms1', { queue: 'sms' });
+
+    tq.process('emails'); // takes email1
+
+    expect(tq.size('emails')).toBe(1);
+    expect(tq.size('sms')).toBe(1);
+  });
+
+  test('queues are created implicitly on first add', () => {
+    expect(tq.getQueueNames()).toEqual([]);
+
+    tq.add('job', { queue: 'newqueue' });
+    expect(tq.getQueueNames()).toContain('newqueue');
+  });
+
+  test('getQueueNames lists all existing queues', () => {
+    tq.add('a', { queue: 'alpha' });
+    tq.add('b', { queue: 'beta' });
+    tq.add('c'); // default queue
+
+    const names = tq.getQueueNames();
+    expect(names).toContain('alpha');
+    expect(names).toContain('beta');
+    expect(names).toContain('default');
+    expect(names.length).toBe(3);
+  });
+
+  test('process from non-existent queue returns null', () => {
+    expect(tq.process('nonexistent')).toBeNull();
+  });
+
+  test('process from empty queue returns null', () => {
+    tq.add('job', { queue: 'myqueue' });
+    tq.process('myqueue'); // process the only task
+
+    expect(tq.process('myqueue')).toBeNull();
+  });
+
+  test('backward compatible - omitting queue name uses default', () => {
+    tq.add('default-job');
+    const task = tq.process();
+    expect(task!.payload).toBe('default-job');
+    expect(task!.queue).toBe('default');
+  });
+
+  test('size works per queue', () => {
+    tq.add('a', { queue: 'q1' });
+    tq.add('b', { queue: 'q1' });
+    tq.add('c', { queue: 'q2' });
+
+    expect(tq.size('q1')).toBe(2);
+    expect(tq.size('q2')).toBe(1);
+    expect(tq.size('q3')).toBe(0);
+  });
+});
