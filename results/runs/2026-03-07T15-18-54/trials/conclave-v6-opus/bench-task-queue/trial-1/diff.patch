+import { describe, test, expect, beforeEach } from 'vitest';
+import { TaskQueueSystem } from '../src/index.js';
+
+describe('Phase 3: Priority', () => {
+  let tq: TaskQueueSystem;
+
+  beforeEach(() => {
+    tq = new TaskQueueSystem();
+  });
+
+  test('default priority is 5', () => {
+    const task = tq.add('job');
+    expect(task.priority).toBe(5);
+  });
+
+  test('tasks can be assigned a priority level', () => {
+    const task = tq.add('urgent', { priority: 1 });
+    expect(task.priority).toBe(1);
+  });
+
+  test('higher-priority tasks (lower number) are returned first', () => {
+    tq.add('low', { priority: 10 });
+    tq.add('high', { priority: 1 });
+    tq.add('medium', { priority: 5 });
+
+    expect(tq.process()!.payload).toBe('high');
+    expect(tq.process()!.payload).toBe('medium');
+    expect(tq.process()!.payload).toBe('low');
+  });
+
+  test('same priority tasks are returned in FIFO order', () => {
+    tq.add('first', { priority: 3 });
+    tq.add('second', { priority: 3 });
+    tq.add('third', { priority: 3 });
+
+    expect(tq.process()!.payload).toBe('first');
+    expect(tq.process()!.payload).toBe('second');
+    expect(tq.process()!.payload).toBe('third');
+  });
+
+  test('invalid priority below 1 throws error', () => {
+    expect(() => tq.add('job', { priority: 0 })).toThrow();
+  });
+
+  test('invalid priority above 10 throws error', () => {
+    expect(() => tq.add('job', { priority: 11 })).toThrow();
+  });
+
+  test('invalid non-integer priority throws error', () => {
+    expect(() => tq.add('job', { priority: 2.5 })).toThrow();
+  });
+
+  test('priority operates per queue', () => {
+    tq.add('q1-low', { queue: 'q1', priority: 10 });
+    tq.add('q1-high', { queue: 'q1', priority: 1 });
+    tq.add('q2-low', { queue: 'q2', priority: 10 });
+    tq.add('q2-high', { queue: 'q2', priority: 1 });
+
+    expect(tq.process('q1')!.payload).toBe('q1-high');
+    expect(tq.process('q2')!.payload).toBe('q2-high');
+    expect(tq.process('q1')!.payload).toBe('q1-low');
+    expect(tq.process('q2')!.payload).toBe('q2-low');
+  });
+
+  test('task object exposes its priority', () => {
+    const task = tq.add('job', { priority: 7 });
+    const retrieved = tq.getTask(task.id);
+    expect(retrieved!.priority).toBe(7);
+  });
+});
