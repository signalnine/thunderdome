ob', { maxRetries: 3, backoffDelay: 1000 });\n\n    // First attempt\n    let task = tq.process()!;\n    tq.fail(task.id, 'error');\n    // Backoff: 1000 * 2^0 = 1000ms\n    vi.advanceTimersByTime(999);\n    expect(tq.process()).toBeNull();\n    vi.advanceTimersByTime(2);\n    task = tq.process()!;\n    expect(task.attempts).toBe(1);\n\n    // Second failure\n    tq.fail(task.id, 'error');\n    // Backoff: 1000 * 2^1 = 2000ms\n    vi.advanceTimersByTime(1999);\n    expect(tq.process()).toBeNull();\n    vi.advanceTimersByTime(2);\n    task = tq.process()!;\n    expect(task.attempts).toBe(2);\n\n    // Third failure\n    tq.fail(task.id, 'error');\n    // Backoff: 1000 * 2^2 = 4000ms\n    vi.advanceTimersByTime(3999);\n    expect(tq.process()).toBeNull();\n    vi.advanceTimersByTime(2);\n    task = tq.process()!;\n    expect(task.attempts).toBe(3);\n  });\n\n  test('default maxRetries is 3', () => {\n    const task = tq.add('job');\n    expect(task.maxRetries).toBe(3);\n  });\n\n  test('default backoffDelay is 1000ms', () => {\n    const task = tq.add('job');\n    expect(task.backoffDelay).toBe(1000);\n  });\n\n  test('maxRetries is configurable per task', () => {\n    const task = tq.add('job', { maxRetries: 5 });\n    expect(task.maxRetries).toBe(5);\n  });\n\n  test('task tracks attempt count', () => {\n    tq.add('job', { maxRetries: 2, backoffDelay: 100 });\n    let task = tq.process()!;\n    expect(task.attempts).toBe(0);\n\n    tq.fail(task.id, 'err');\n    vi.advanceTimersByTime(101);\n\n    task = tq.process()!;\n    expect(task.attempts).toBe(1);\n  });\n\n  test('retried tasks keep original queue and priority', () => {\n    tq.add('job', { queue: 'myqueue', priority: 2, maxRetries: 1, backoffDelay: 100 });\n    let task = tq.process('myqueue')!;\n    tq.fail(task.id, 'err');\n\n    vi.advanceTimersByTime(101);\n    task = tq.process('myqueue')!;\n    expect(task.queue).toBe('myqueue');\n    expect(task.priority).toBe(2);\n  });\n\n  test('task remains failed when all retries exhausted', () => {\n    tq.add('job', { maxRetries: 1, backoffDelay: 100 });\n\n    // First attempt\n    let task = tq.process()!;\n    tq.fail(task.id, 'err1');\n\n    // Second attempt (first retry)\n    vi.advanceTimersByTime(101);\n    task = tq.process()!;\n    tq.fail(task.id, 'err2');\n\n    // No more retries\n    const final = tq.getTask(task.id)!;\n    expect(final.status).toBe('failed');\n    expect(final.error).toBe('err2');\n  });\n\n  test('complete on non-processing task throws', () => {\n    const task = tq.add('job');\n    expect(() => tq.complete(task.id)).toThrow();\n  });\n\n  test('fail on non-processing task throws', () => {\n    const task = tq.add('job');\n    expect(() => tq.fail(task.id, 'err')).toThrow();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":653,"cache_read_input_tokens":53492,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":653},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"41a2633b-441a-43ad-b989-10aed8aa6cfb","uuid":"041dc4ad-3c1a-461a-93ad-834c57ad22ca"}
