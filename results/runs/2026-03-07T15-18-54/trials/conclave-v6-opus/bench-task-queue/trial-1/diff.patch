@@ -0,0 +1,553 @@
+import { randomUUID } from 'node:crypto';
+import type { Task, TaskOptions, TaskStatus } from './types.js';
+import { parseCron, matchesCron, type CronMatch } from './cron.js';
+
+interface Schedule {
+  id: string;
+  cron: CronMatch;
+  cronExpr: string;
+  queueName: string;
+  payload: unknown;
+  lastRun: Date | null;
+}
+
+interface ShutdownResult {
+  completed: number;
+  forceCancelled: number;
+  elapsed: number;
+}
+
+interface InternalTask {
+  id: string;
+  payload: unknown;
+  status: TaskStatus;
+  createdAt: Date;
+  queue: string;
+  priority: number;
+  availableAt: Date;
+  attempts: number;
+  maxRetries: number;
+  backoffDelay: number;
+  error?: string;
+  progress: number;
+  progressMessage?: string;
+  dependencies: string[];
+}
+
+const DEFAULT_QUEUE = 'default';
+
+export class TaskQueueSystem {
+  private tasks = new Map<string, InternalTask>();
+  private queues = new Map<string, InternalTask[]>();
+  private deadLetterQueues = new Map<string, InternalTask[]>();
+  // dependency tracking: taskId -> set of task IDs that depend on it
+  private dependents = new Map<string, Set<string>>();
+  // taskId -> set of dependency IDs not yet completed
+  private unresolvedDeps = new Map<string, Set<string>>();
+  // concurrency: queueName -> limit (0 = unlimited)
+  private concurrencyLimits = new Map<string, number>();
+  // queueName -> count of currently processing tasks
+  private activeCounts = new Map<string, number>();
+  // progress listeners: taskId -> set of callbacks
+  private progressListeners = new Map<string, Set<(percent: number, message?: string) => void>>();
+  // recurring schedules
+  private schedules = new Map<string, Schedule>();
+  // middleware per queue
+  private middlewares = new Map<string, Array<(task: Task, next: () => void) => void>>();
+  // handler per queue
+  private handlers = new Map<string, (task: Task) => void>();
+  // shutdown state
+  private isShutdown = false;
+  private shutdownResult: ShutdownResult | null = null;
+  private shutdownCallbacks: Array<() => void> = [];
+  private shutdownResolvers: Array<() => void> = [];
+
+  add(payload: unknown, options: TaskOptions = {}): Task {
+    if (this.isShutdown) {
+      throw new Error('System is shut down. Cannot add new tasks.');
+    }
+    const priority = options.priority ?? 5;
+    if (!Number.isInteger(priority) || priority < 1 || priority > 10) {
+      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);
+    }
+
+    const deps = options.dependencies ?? [];
+
+    // Validate dependencies exist
+    for (const depId of deps) {
+      if (!this.tasks.has(depId)) {
+        throw new Error(`Dependency not found: ${depId}`);
+      }
+    }
+
+    const queue = options.queue ?? DEFAULT_QUEUE;
+    const now = new Date();
+
+    let availableAt = now;
+    if (options.availableAt) {
+      availableAt = options.availableAt;
+    } else if (options.delay != null && options.delay > 0) {
+      availableAt = new Date(now.getTime() + options.delay);
+    }
+
+    const task: InternalTask = {
+      id: randomUUID(),
+      payload,
+      status: 'pending',
+      createdAt: now,
+      queue,
+      priority,
+      availableAt,
+      attempts: 0,
+      maxRetries: options.maxRetries ?? 3,
+      backoffDelay: options.backoffDelay ?? 1000,
+      progress: 0,
+      dependencies: [...deps],
+    };
+
+    // Check for circular dependencies
+    if (deps.length > 0) {
+      this.detectCycle(task.id, deps);
+    }
+
+    this.tasks.set(task.id, task);
+
+    // Track unresolved dependencies
+    const unresolved = new Set<string>();
+    for (const depId of deps) {
+      const depTask = this.tasks.get(depId)!;
+      if (depTask.status !== 'completed') {
+        unresolved.add(depId);
+        if (!this.dependents.has(depId)) {
+          this.dependents.set(depId, new Set());
+        }
+        this.dependents.get(depId)!.add(task.id);
+      }
+    }
+    if (unresolved.size > 0) {
+      this.unresolvedDeps.set(task.id, unresolved);
+    }
+
+    if (!this.queues.has(queue)) {
+      this.queues.set(queue, []);
+    }
+    this.insertSorted(this.queues.get(queue)!, task);
+
+    return this.toPublicTask(task);
+  }
+
+  process(queueName?: string): Task | null {
+    const queue = queueName ?? DEFAULT_QUEUE;
+    const pending = this.queues.get(queue);
+    if (!pending) return null;
+
+    // Check concurrency limit
+    const limit = this.concurrencyLimits.get(queue) ?? 0;
+    const active = this.activeCounts.get(queue) ?? 0;
+    if (limit > 0 && active >= limit) return null;
+
+    const now = Date.now();
+    for (let i = 0; i < pending.length; i++) {
+      const task = pending[i];
+      if (
+        task.status === 'pending' &&
+        task.availableAt.getTime() <= now &&
+        !this.unresolvedDeps.has(task.id)
+      ) {
+        task.status = 'processing';
+        this.activeCounts.set(queue, (this.activeCounts.get(queue) ?? 0) + 1);
+        return this.toPublicTask(task);
+      }
+    }
+
+    return null;
+  }
+
+  size(queueName?: string): number {
+    const queue = queueName ?? DEFAULT_QUEUE;
+    const pending = this.queues.get(queue);
+    if (!pending) return 0;
+    const now = Date.now();
+    return pending.filter(
+      t => t.status === 'pending' &&
+        t.availableAt.getTime() <= now &&
+        !this.unresolvedDeps.has(t.id)
+    ).length;
+  }
+
+  complete(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot complete task in ${task.status} state`);
+    }
+    task.status = 'completed';
+    this.activeCounts.set(task.queue, (this.activeCounts.get(task.queue) ?? 1) - 1);
+
+    // Resolve dependencies
+    const deps = this.dependents.get(taskId);
+    if (deps) {
+      for (const dependentId of deps) {
+        const unresolved = this.unresolvedDeps.get(dependentId);
+        if (unresolved) {
+          unresolved.delete(taskId);
+          if (unresolved.size === 0) {
+            this.unresolvedDeps.delete(dependentId);
+          }
+        }
+      }
+      this.dependents.delete(taskId);
+    }
+
+    this.notifyShutdownResolvers();
+  }
+
+  fail(taskId: string, error?: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot fail task in ${task.status} state`);
+    }
+    task.attempts++;
+    task.error = error;
+    this.activeCounts.set(task.queue, (this.activeCounts.get(task.queue) ?? 1) - 1);
+
+    if (task.attempts <= task.maxRetries) {
+      const delay = task.backoffDelay * Math.pow(2, task.attempts - 1);
+      task.status = 'pending';
+      task.availableAt = new Date(Date.now() + delay);
+
+      const queueList = this.queues.get(task.queue)!;
+      const idx = queueList.indexOf(task);
+      if (idx !== -1) queueList.splice(idx, 1);
+      this.insertSorted(queueList, task);
+    } else {
+      task.status = 'failed';
+      if (!this.deadLetterQueues.has(task.queue)) {
+        this.deadLetterQueues.set(task.queue, []);
+      }
+      this.deadLetterQueues.get(task.queue)!.push(task);
+    }
+
+    this.notifyShutdownResolvers();
+  }
+
+  getDeadLetterTasks(queueName?: string): Task[] {
+    const queue = queueName ?? DEFAULT_QUEUE;
+    const dlq = this.deadLetterQueues.get(queue);
+    if (!dlq) return [];
+    return dlq.map(t => this.toPublicTask(t));
+  }
+
+  requeue(taskId: string): Task {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'failed') {
+      throw new Error(`Cannot requeue task in ${task.status} state`);
+    }
+
+    const dlq = this.deadLetterQueues.get(task.queue);
+    if (dlq) {
+      const idx = dlq.indexOf(task);
+      if (idx !== -1) dlq.splice(idx, 1);
+    }
+
+    task.status = 'pending';
+    task.attempts = 0;
+    task.error = undefined;
+    task.availableAt = new Date();
+
+    const queueList = this.queues.get(task.queue)!;
+    this.insertSorted(queueList, task);
+
+    return this.toPublicTask(task);
+  }
+
+  clearDeadLetterQueue(queueName?: string): void {
+    const queue = queueName ?? DEFAULT_QUEUE;
+    const dlq = this.deadLetterQueues.get(queue);
+    if (dlq) {
+      for (const task of dlq) {
+        this.tasks.delete(task.id);
+      }
+      dlq.length = 0;
+    }
+  }
+
+  updateProgress(taskId: string, percent: number, message?: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    task.progress = percent;
+    task.progressMessage = message;
+
+    const listeners = this.progressListeners.get(taskId);
+    if (listeners) {
+      for (const listener of listeners) {
+        listener(percent, message);
+      }
+    }
+  }
+
+  onProgress(taskId: string, callback: (percent: number, message?: string) => void): () => void {
+    if (!this.progressListeners.has(taskId)) {
+      this.progressListeners.set(taskId, new Set());
+    }
+    this.progressListeners.get(taskId)!.add(callback);
+
+    return () => {
+      const listeners = this.progressListeners.get(taskId);
+      if (listeners) {
+        listeners.delete(callback);
+      }
+    };
+  }
+
+  cancel(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'pending' && task.status !== 'processing') {
+      throw new Error(`Cannot cancel task in ${task.status} state`);
+    }
+
+    const wasProcessing = task.status === 'processing';
+    task.status = 'cancelled';
+
+    if (wasProcessing) {
+      this.activeCounts.set(task.queue, (this.activeCounts.get(task.queue) ?? 1) - 1);
+    }
+  }
+
+  setConcurrency(queueName: string, limit: number): void {
+    this.concurrencyLimits.set(queueName, limit);
+  }
+
+  getConcurrency(queueName?: string): { limit: number; active: number } {
+    const queue = queueName ?? DEFAULT_QUEUE;
+    return {
+      limit: this.concurrencyLimits.get(queue) ?? 0,
+      active: this.activeCounts.get(queue) ?? 0,
+    };
+  }
+
+  addSchedule(id: string, cronExpr: string, queueName: string, payload: unknown): void {
+    const cron = parseCron(cronExpr);
+    this.schedules.set(id, {
+      id,
+      cron,
+      cronExpr,
+      queueName,
+      payload,
+      lastRun: null,
+    });
+  }
+
+  removeSchedule(id: string): void {
+    this.schedules.delete(id);
+  }
+
+  getSchedules(): { id: string; cronExpr: string; queueName: string }[] {
+    return [...this.schedules.values()].map(s => ({
+      id: s.id,
+      cronExpr: s.cronExpr,
+      queueName: s.queueName,
+    }));
+  }
+
+  tick(): Task[] {
+    const now = new Date();
+    const created: Task[] = [];
+
+    for (const schedule of this.schedules.values()) {
+      if (matchesCron(schedule.cron, now)) {
+        // Check if already ran for this minute
+        if (schedule.lastRun) {
+          const lastMinute = Math.floor(schedule.lastRun.getTime() / 60000);
+          const currentMinute = Math.floor(now.getTime() / 60000);
+          if (lastMinute === currentMinute) continue;
+        }
+
+        schedule.lastRun = now;
+        const task = this.add(schedule.payload, { queue: schedule.queueName });
+        created.push(task);
+      }
+    }
+
+    return created;
+  }
+
+  use(queueName: string, middleware: (task: Task, next: () => void) => void): void {
+    if (!this.middlewares.has(queueName)) {
+      this.middlewares.set(queueName, []);
+    }
+    this.middlewares.get(queueName)!.push(middleware);
+  }
+
+  setHandler(queueName: string, handler: (task: Task) => void): void {
+    this.handlers.set(queueName, handler);
+  }
+
+  processTask(taskId: string): void {
+    const internal = this.tasks.get(taskId);
+    if (!internal) throw new Error(`Task not found: ${taskId}`);
+    if (internal.status !== 'processing') {
+      throw new Error(`Cannot process task in ${internal.status} state`);
+    }
+
+    const task = this.toPublicTask(internal);
+    // Use internal payload reference so middleware mutations are visible
+    const mutableTask = { ...task, payload: internal.payload };
+    const middlewareList = this.middlewares.get(internal.queue) ?? [];
+    const handler = this.handlers.get(internal.queue);
+
+    let idx = 0;
+    const next = (): void => {
+      if (idx < middlewareList.length) {
+        const mw = middlewareList[idx++];
+        mw(mutableTask, next);
+      } else if (handler) {
+        handler(mutableTask);
+      }
+    };
+
+    try {
+      next();
+    } catch (err) {
+      this.fail(taskId, err instanceof Error ? err.message : String(err));
+    }
+  }
+
+  getQueueNames(): string[] {
+    return [...this.queues.keys()];
+  }
+
+  onShutdown(callback: () => void): void {
+    this.shutdownCallbacks.push(callback);
+  }
+
+  async shutdown(options?: { timeout?: number }): Promise<ShutdownResult> {
+    if (this.shutdownResult) return this.shutdownResult;
+
+    this.isShutdown = true;
+    const startTime = Date.now();
+    const timeout = options?.timeout ?? 30000;
+
+    // Run shutdown callbacks
+    for (const cb of this.shutdownCallbacks) {
+      cb();
+    }
+
+    // Count active tasks
+    const getActiveTaskCount = (): number => {
+      let count = 0;
+      for (const task of this.tasks.values()) {
+        if (task.status === 'processing') count++;
+      }
+      return count;
+    };
+
+    let completedCount = 0;
+
+    // If there are active tasks, wait for them or timeout
+    if (getActiveTaskCount() > 0) {
+      await new Promise<void>((resolve) => {
+        const checkDone = (): void => {
+          if (getActiveTaskCount() === 0) {
+            resolve();
+          }
+        };
+
+        // Register resolver for complete/fail notifications
+        this.shutdownResolvers.push(checkDone);
+
+        // Set timeout
+        setTimeout(() => {
+          resolve();
+        }, timeout);
+
+        // Check immediately in case already done
+        checkDone();
+      });
+    }
+
+    // Count completed tasks during shutdown
+    for (const task of this.tasks.values()) {
+      if (task.status === 'completed') completedCount++;
+    }
+
+    // Force-cancel remaining processing tasks
+    let forceCancelled = 0;
+    for (const task of this.tasks.values()) {
+      if (task.status === 'processing') {
+        task.status = 'cancelled';
+        this.activeCounts.set(task.queue, (this.activeCounts.get(task.queue) ?? 1) - 1);
+        forceCancelled++;
+      }
+    }
+
+    this.shutdownResult = {
+      completed: completedCount,
+      forceCancelled,
+      elapsed: Date.now() - startTime,
+    };
+
+    return this.shutdownResult;
+  }
+
+  getTask(taskId: string): Task | null {
+    const task = this.tasks.get(taskId);
+    return task ? this.toPublicTask(task) : null;
+  }
+
+  private notifyShutdownResolvers(): void {
+    for (const resolver of this.shutdownResolvers) {
+      resolver();
+    }
+  }
+
+  private detectCycle(_newTaskId: string, _deps: string[]): void {
+    // Since new tasks don't exist in the graph yet, no existing task
+    // can depend on them, so cycles can't form at creation time.
+    // This is a structural no-op for the current append-only dependency model.
+  }
+
+  private compareTasks(a: InternalTask, b: InternalTask): number {
+    if (a.priority !== b.priority) return a.priority - b.priority;
+    const aTime = a.availableAt.getTime();
+    const bTime = b.availableAt.getTime();
+    if (aTime !== bTime) return aTime - bTime;
+    return a.createdAt.getTime() - b.createdAt.getTime();
+  }
+
+  private insertSorted(list: InternalTask[], task: InternalTask): void {
+    let lo = 0;
+    let hi = list.length;
+    while (lo < hi) {
+      const mid = (lo + hi) >>> 1;
+      if (this.compareTasks(list[mid], task) <= 0) {
+        lo = mid + 1;
+      } else {
+        hi = mid;
+      }
+    }
+    list.splice(lo, 0, task);
+  }
+
+  private toPublicTask(t: InternalTask): Task {
+    return {
+      id: t.id,
+      payload: t.payload,
+      status: t.status,
+      createdAt: t.createdAt,
+      queue: t.queue,
+      priority: t.priority,
+      availableAt: t.availableAt,
+      attempts: t.attempts,
+      maxRetries: t.maxRetries,
+      backoffDelay: t.backoffDelay,
+      error: t.error,
+      progress: t.progress,
+      progressMessage: t.progressMessage,
+      dependencies: [...t.dependencies],
+    };
+  }
+}
