+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01G9wDSbJjrKEk93MdE4Mng7","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01GccYq6m88qQBLqWVjAnRCn","name":"Write","input":{"file_path":"/workspace/tests/phase06-dlq.test.ts","content":"import { describe, test, expect, beforeEach, vi } from 'vitest';\nimport { TaskQueueSystem } from '../src/index.js';\n\ndescribe('Phase 6: Dead Letter Queue', () => {\n  let tq: TaskQueueSystem;\n\n  beforeEach(() => {\n    tq = new TaskQueueSystem();\n    vi.useFakeTimers();\n  });\n\n  test('task moved to DLQ when all retries exhausted', () => {\n    tq.add('job', { maxRetries: 0 });\n    const task = tq.process()!;\n    tq.fail(task.id, 'permanent error');\n\n    const dlq = tq.getDeadLetterTasks();\n    expect(dlq).toHaveLength(1);\n    expect(dlq[0].id).toBe(task.id);\n    expect(dlq[0].error).toBe('permanent error');\n  });\n\n  test('DLQ tasks retain error information and failure count', () => {\n    tq.add('job', { maxRetries: 1, backoffDelay: 100 });\n\n    let task = tq.process()!;\n    tq.fail(task.id, 'error1');\n\n    vi.advanceTimersByTime(101);\n    task = tq.process()!;\n    tq.fail(task.id, 'error2');\n\n    const dlq = tq.getDeadLetterTasks();\n    expect(dlq).toHaveLength(1);\n    expect(dlq[0].error).toBe('error2');\n    expect(dlq[0].attempts).toBe(2);\n  });\n\n  test('view dead-lettered tasks for a specific queue', () => {\n    tq.add('q1-job', { queue: 'q1', maxRetries: 0 });\n    tq.add('q2-job', { queue: 'q2', maxRetries: 0 });\n\n    tq.fail(tq.process('q1')!.id, 'err');\n    tq.fail(tq.process('q2')!.id, 'err');\n\n    expect(tq.getDeadLetterTasks('q1')).toHaveLength(1);\n    expect(tq.getDeadLetterTasks('q1')[0].payload).toBe('q1-job');\n    expect(tq.getDeadLetterTasks('q2')).toHaveLength(1);\n  });\n\n  test('requeue moves dead-lettered task back to original queue', () => {\n    tq.add('job', { maxRetries: 0 });\n    const task = tq.process()!;\n    tq.fail(task.id, 'err');\n\n    expect(tq.getDeadLetterTasks()).toHaveLength(1);\n\n    const requeued = tq.requeue(task.id);\n    expect(requeued.status).toBe('pending');\n    expect(requeued.attempts).toBe(0);\n\n    expect(tq.getDeadLetterTasks()).toHaveLength(0);\n\n    const processed = tq.process();\n    expect(processed).not.toBeNull();\n    expect(processed!.id).toBe(task.id);\n  });\n\n  test('clear all dead-lettered tasks for a queue', () => {\n    tq.add('job1', { maxRetries: 0 });\n    tq.add('job2', { maxRetries: 0 });\n\n    tq.fail(tq.process()!.id, 'err');\n    tq.fail(tq.process()!.id, 'err');\n\n    expect(tq.getDeadLetterTasks()).toHaveLength(2);\n\n    tq.clearDeadLetterQueue();\n    expect(tq.getDeadLetterTasks()).toHaveLength(0);\n  });\n\n  test('each named queue has its own independent DLQ', () => {\n    tq.add('q1-job', { queue: 'q1', maxRetries: 0 });\n    tq.add('q2-job', { queue: 'q2', maxRetries: 0 });\n\n    tq.fail(tq.process('q1')!.id, 'err');\n    tq.fail(tq.process('q2')!.id, 'err');\n\n    tq.clearDeadLetterQueue('q1');\n    expect(tq.getDeadLetterTasks('q1')).toHaveLength(0);\n    expect(tq.getDeadLetterTasks('q2')).toHaveLength(1);\n  });\n\n  test('getDeadLetterTasks returns empty array for queue with no DLQ entries', () => {\n    expect(tq.getDeadLetterTasks('nonexistent')).toEqual([]);\n  });\n\n  test('requeue non-DLQ task throws error', () => {\n    const task = tq.add('job');\n    expect(() => tq.requeue(task.id)).toThrow();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":610,"cache_read_input_tokens":60371,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":610},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"41a2633b-441a-43ad-b989-10aed8aa6cfb","uuid":"d1a85734-7b61-4f38-bbee-559eb8f75044"}
