@@ -0,0 +1,90 @@
+import { describe, test, expect, beforeEach, vi } from 'vitest';
+import { TaskQueueSystem } from '../src/index.js';
+
+describe('Phase 4: Delayed and Scheduled Tasks', () => {
+  let tq: TaskQueueSystem;
+
+  beforeEach(() => {
+    tq = new TaskQueueSystem();
+    vi.useFakeTimers();
+  });
+
+  test('task can be given a delay in milliseconds', () => {
+    const task = tq.add('delayed', { delay: 5000 });
+    expect(task.availableAt.getTime()).toBeGreaterThan(Date.now() - 1);
+  });
+
+  test('delayed task is not returned before its availability time', () => {
+    tq.add('delayed', { delay: 5000 });
+    expect(tq.process()).toBeNull();
+  });
+
+  test('delayed task is returned after its availability time', () => {
+    tq.add('delayed', { delay: 5000 });
+    vi.advanceTimersByTime(5001);
+    const task = tq.process();
+    expect(task).not.toBeNull();
+    expect(task!.payload).toBe('delayed');
+  });
+
+  test('task can be given a specific future availableAt date', () => {
+    const future = new Date(Date.now() + 10000);
+    const task = tq.add('scheduled', { availableAt: future });
+    expect(task.availableAt.getTime()).toBe(future.getTime());
+  });
+
+  test('non-delayed tasks are preferred over not-yet-available delayed tasks', () => {
+    tq.add('delayed', { delay: 5000 });
+    tq.add('immediate');
+
+    const task = tq.process();
+    expect(task!.payload).toBe('immediate');
+  });
+
+  test('multiple delayed tasks ordered by availability time', () => {
+    tq.add('later', { delay: 10000 });
+    tq.add('sooner', { delay: 2000 });
+
+    vi.advanceTimersByTime(10001);
+
+    expect(tq.process()!.payload).toBe('sooner');
+    expect(tq.process()!.payload).toBe('later');
+  });
+
+  test('delayed tasks with same availability ordered by priority then FIFO', () => {
+    tq.add('low-priority', { delay: 5000, priority: 10 });
+    tq.add('high-priority', { delay: 5000, priority: 1 });
+
+    vi.advanceTimersByTime(5001);
+
+    expect(tq.process()!.payload).toBe('high-priority');
+    expect(tq.process()!.payload).toBe('low-priority');
+  });
+
+  test('task object indicates when it becomes available', () => {
+    const task = tq.add('delayed', { delay: 3000 });
+    const retrieved = tq.getTask(task.id);
+    expect(retrieved!.availableAt).toBeInstanceOf(Date);
+    expect(retrieved!.availableAt.getTime()).toBeGreaterThan(task.createdAt.getTime());
+  });
+
+  test('delays work with named queues', () => {
+    tq.add('delayed', { queue: 'myqueue', delay: 5000 });
+    expect(tq.process('myqueue')).toBeNull();
+
+    vi.advanceTimersByTime(5001);
+    const task = tq.process('myqueue');
+    expect(task!.payload).toBe('delayed');
+  });
+
+  test('size does not count unavailable delayed tasks', () => {
+    tq.add('delayed', { delay: 5000 });
+    tq.add('immediate');
+
+    // size should count pending tasks that are available
+    expect(tq.size()).toBe(1);
+
+    vi.advanceTimersByTime(5001);
+    expect(tq.size()).toBe(2);
+  });
+});
diff --git a/tests/phase05-retry.test.ts b/tests/phase05-retry.test.ts
new file mode 100644
index 0000000..7f560af
--- /dev/null
+++ b/tests/phase05-retry.test.ts
@@ -0,0 +1,148 @@
+import { describe, test, expect, beforeEach, vi } from 'vitest';
+import { TaskQueueSystem } from '../src/index.js';
+
+describe('Phase 5: Retry with Backoff', () => {
+  let tq: TaskQueueSystem;
+
+  beforeEach(() => {
+    tq = new TaskQueueSystem();
+    vi.useFakeTimers();
+  });
+
+  test('complete marks a processing task as completed', () => {
+    const added = tq.add('job');
+    const task = tq.process()!;
+    tq.complete(task.id);
+
+    const updated = tq.getTask(task.id)!;
+    expect(updated.status).toBe('completed');
+  });
+
+  test('fail marks a processing task as failed when no retries remain', () => {
+    const added = tq.add('job', { maxRetries: 0 });
+    const task = tq.process()!;
+    tq.fail(task.id, 'something went wrong');
+
+    const updated = tq.getTask(task.id)!;
+    expect(updated.status).toBe('failed');
+    expect(updated.error).toBe('something went wrong');
+  });
+
+  test('failed task with retries remaining is re-added with delay', () => {
+    const added = tq.add('job', { maxRetries: 3, backoffDelay: 1000 });
+    const task = tq.process()!;
+    tq.fail(task.id, 'error');
+
+    // Task should be pending again but delayed
+    const updated = tq.getTask(task.id)!;
+    expect(updated.status).toBe('pending');
+    expect(updated.attempts).toBe(1);
+
+    // Should not be available immediately
+    expect(tq.process()).toBeNull();
+
+    // After backoff delay (1000ms for first retry)
+    vi.advanceTimersByTime(1001);
+    const retried = tq.process();
+    expect(retried).not.toBeNull();
+    expect(retried!.id).toBe(task.id);
+  });
+
+  test('backoff follows exponential pattern: baseDelay * 2^(attempt-1)', () => {
+    const added = tq.add('job', { maxRetries: 3, backoffDelay: 1000 });
+
+    // First attempt
+    let task = tq.process()!;
+    tq.fail(task.id, 'error');
+    // Backoff: 1000 * 2^0 = 1000ms
+    vi.advanceTimersByTime(999);
+    expect(tq.process()).toBeNull();
+    vi.advanceTimersByTime(2);
+    task = tq.process()!;
+    expect(task.attempts).toBe(1);
+
+    // Second failure
+    tq.fail(task.id, 'error');
+    // Backoff: 1000 * 2^1 = 2000ms
+    vi.advanceTimersByTime(1999);
+    expect(tq.process()).toBeNull();
+    vi.advanceTimersByTime(2);
+    task = tq.process()!;
+    expect(task.attempts).toBe(2);
+
+    // Third failure
+    tq.fail(task.id, 'error');
+    // Backoff: 1000 * 2^2 = 4000ms
+    vi.advanceTimersByTime(3999);
+    expect(tq.process()).toBeNull();
+    vi.advanceTimersByTime(2);
+    task = tq.process()!;
+    expect(task.attempts).toBe(3);
+  });
+
+  test('default maxRetries is 3', () => {
+    const task = tq.add('job');
+    expect(task.maxRetries).toBe(3);
+  });
+
+  test('default backoffDelay is 1000ms', () => {
+    const task = tq.add('job');
+    expect(task.backoffDelay).toBe(1000);
+  });
+
+  test('maxRetries is configurable per task', () => {
+    const task = tq.add('job', { maxRetries: 5 });
+    expect(task.maxRetries).toBe(5);
+  });
+
+  test('task tracks attempt count', () => {
+    tq.add('job', { maxRetries: 2, backoffDelay: 100 });
+    let task = tq.process()!;
+    expect(task.attempts).toBe(0);
+
+    tq.fail(task.id, 'err');
+    vi.advanceTimersByTime(101);
+
+    task = tq.process()!;
+    expect(task.attempts).toBe(1);
+  });
+
+  test('retried tasks keep original queue and priority', () => {
+    tq.add('job', { queue: 'myqueue', priority: 2, maxRetries: 1, backoffDelay: 100 });
+    let task = tq.process('myqueue')!;
+    tq.fail(task.id, 'err');
+
+    vi.advanceTimersByTime(101);
+    task = tq.process('myqueue')!;
+    expect(task.queue).toBe('myqueue');
+    expect(task.priority).toBe(2);
+  });
+
+  test('task remains failed when all retries exhausted', () => {
+    tq.add('job', { maxRetries: 1, backoffDelay: 100 });
+
+    // First attempt
+    let task = tq.process()!;
+    tq.fail(task.id, 'err1');
+
+    // Second attempt (first retry)
+    vi.advanceTimersByTime(101);
+    task = tq.process()!;
+    tq.fail(task.id, 'err2');
+
+    // No more retries
+    const final = tq.getTask(task.id)!;
+    expect(final.status).toBe('failed');
+    expect(final.error).toBe('err2');
+  });
+
+  test('complete on non-processing task throws', () => {
+    const task = tq.add('job');
+    expect(() => tq.complete(task.id)).toThrow();
+  });
+
+  test('fail on non-processing task throws', () => {
+    const task = tq.add('job');
+    expect(() => tq.fail(task.id, 'err')).toThrow();
+  });
+});
