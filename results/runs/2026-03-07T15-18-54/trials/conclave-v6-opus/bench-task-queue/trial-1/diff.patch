+export interface CronMatch {
+  minute: (m: number) => boolean;
+  hour: (h: number) => boolean;
+}
+
+export function parseCron(expr: string): CronMatch {
+  const parts = expr.split(/\s+/);
+  if (parts.length !== 5) {
+    throw new Error(`Invalid cron expression: ${expr}`);
+  }
+
+  const [minutePart, hourPart] = parts;
+
+  return {
+    minute: parseField(minutePart),
+    hour: parseField(hourPart),
+  };
+}
+
+function parseField(field: string): (value: number) => boolean {
+  if (field === '*') {
+    return () => true;
+  }
+
+  // */N pattern
+  const stepMatch = field.match(/^\*\/(\d+)$/);
+  if (stepMatch) {
+    const step = parseInt(stepMatch[1], 10);
+    return (value: number) => value % step === 0;
+  }
+
+  // Exact number
+  const num = parseInt(field, 10);
+  if (!isNaN(num)) {
+    return (value: number) => value === num;
+  }
+
+  throw new Error(`Unsupported cron field: ${field}`);
+}
+
+export function matchesCron(cron: CronMatch, date: Date): boolean {
+  return cron.minute(date.getUTCMinutes()) && cron.hour(date.getUTCHours());
+}
