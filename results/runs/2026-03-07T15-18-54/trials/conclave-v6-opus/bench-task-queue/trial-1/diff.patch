+import { describe, test, expect, beforeEach, vi } from 'vitest';
+import { TaskQueueSystem } from '../src/index.js';
+
+describe('Phase 12: Graceful Shutdown', () => {
+  let tq: TaskQueueSystem;
+
+  beforeEach(() => {
+    tq = new TaskQueueSystem();
+    vi.useFakeTimers();
+  });
+
+  test('shutdown rejects new tasks', async () => {
+    const result = await tq.shutdown();
+    expect(() => tq.add('job')).toThrow();
+  });
+
+  test('shutdown waits for processing tasks to complete', async () => {
+    tq.add('job');
+    const task = tq.process()!;
+
+    const shutdownPromise = tq.shutdown({ timeout: 5000 });
+
+    // Complete the task while shutdown is waiting
+    tq.complete(task.id);
+
+    const result = await shutdownPromise;
+    expect(result.completed).toBe(1);
+    expect(result.forceCancelled).toBe(0);
+  });
+
+  test('shutdown force-cancels tasks exceeding timeout', async () => {
+    tq.add('slow-job');
+    tq.process(); // start processing but don't complete
+
+    const shutdownPromise = tq.shutdown({ timeout: 100 });
+
+    vi.advanceTimersByTime(101);
+
+    const result = await shutdownPromise;
+
+    expect(result.forceCancelled).toBe(1);
+  });
+
+  test('shutdown callbacks are called during shutdown', async () => {
+    const calls: string[] = [];
+    tq.onShutdown(() => { calls.push('callback1'); });
+    tq.onShutdown(() => { calls.push('callback2'); });
+
+    await tq.shutdown();
+
+    expect(calls).toContain('callback1');
+    expect(calls).toContain('callback2');
+  });
+
+  test('shutdown produces summary with counts and duration', async () => {
+    tq.add('job1');
+    tq.add('job2');
+    const t1 = tq.process()!;
+    tq.complete(t1.id);
+    const t2 = tq.process()!;
+    tq.complete(t2.id);
+
+    const result = await tq.shutdown();
+    expect(typeof result.completed).toBe('number');
+    expect(typeof result.forceCancelled).toBe('number');
+    expect(typeof result.elapsed).toBe('number');
+  });
+
+  test('calling shutdown multiple times returns same result', async () => {
+    const result1 = await tq.shutdown();
+    const result2 = await tq.shutdown();
+
+    expect(result1).toEqual(result2);
+  });
+
+  test('shutdown completes immediately when no tasks processing', async () => {
+    const result = await tq.shutdown();
+
+    expect(result.completed).toBe(0);
+    expect(result.forceCancelled).toBe(0);
+    expect(result.elapsed).toBeGreaterThanOrEqual(0);
+  });
+
+  test('shutdown with timeout force-cancels remaining tasks', async () => {
+    tq.add('job1');
+    tq.add('job2');
+    tq.process(); // processing but won't complete
+    tq.process(); // processing but won't complete
+
+    // Use a real timer approach - advance time, then resolve
+    const shutdownPromise = tq.shutdown({ timeout: 50 });
+    vi.advanceTimersByTime(51);
+
+    const result = await shutdownPromise;
+    expect(result.forceCancelled).toBe(2);
+  });
+});
