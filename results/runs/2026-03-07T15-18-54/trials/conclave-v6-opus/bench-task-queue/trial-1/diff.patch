t task = this.tasks.get(taskId);\n    return task ? this.toPublicTask(task) : null;\n  }\n\n  private compareTasks(a: InternalTask, b: InternalTask): number {\n    // Sort by: priority ASC, availableAt ASC, createdAt ASC\n    if (a.priority !== b.priority) return a.priority - b.priority;\n    const aTime = a.availableAt.getTime();\n    const bTime = b.availableAt.getTime();\n    if (aTime !== bTime) return aTime - bTime;\n    return a.createdAt.getTime() - b.createdAt.getTime();\n  }\n\n  private insertSorted(list: InternalTask[], task: InternalTask): void {\n    let lo = 0;\n    let hi = list.length;\n    while (lo < hi) {\n      const mid = (lo + hi) >>> 1;\n      if (this.compareTasks(list[mid], task) <= 0) {\n        lo = mid + 1;\n      } else {\n        hi = mid;\n      }\n    }\n    list.splice(lo, 0, task);\n  }\n\n  private toPublicTask(t: InternalTask): Task {\n    return {\n      id: t.id,\n      payload: t.payload,\n      status: t.status,\n      createdAt: t.createdAt,\n      queue: t.queue,\n      priority: t.priority,\n      availableAt: t.availableAt,\n      attempts: t.attempts,\n      maxRetries: t.maxRetries,\n      backoffDelay: t.backoffDelay,\n      error: t.error,\n      progress: t.progress,\n      progressMessage: t.progressMessage,\n      dependencies: [...t.dependencies],\n    };\n  }\n}\n","structuredPatch":[{"oldStart":122,"oldLines":9,"newStart":122,"newLines":58,"lines":["       this.insertSorted(queueList, task);","     } else {","       task.status = 'failed';","+      // Move to dead letter queue","+      if (!this.deadLetterQueues.has(task.queue)) {","+        this.deadLetterQueues.set(task.queue, []);","+      }","+      this.deadLetterQueues.get(task.queue)!.push(task);","     }","   }"," ","+  getDeadLetterTasks(queueName?: string): Task[] {","+    const queue = queueName ?? DEFAULT_QUEUE;","+    const dlq = this.deadLetterQueues.get(queue);","+    if (!dlq) return [];","+    return dlq.map(t => this.toPublicTask(t));","+  }","+