+++ b/tests/phase10-recurring.test.ts
@@ -0,0 +1,122 @@
+import { describe, test, expect, beforeEach, vi } from 'vitest';
+import { TaskQueueSystem } from '../src/index.js';
+
+describe('Phase 10: Recurring Tasks', () => {
+  let tq: TaskQueueSystem;
+
+  beforeEach(() => {
+    tq = new TaskQueueSystem();
+    vi.useFakeTimers();
+  });
+
+  test('create a schedule with cron expression', () => {
+    tq.addSchedule('cleanup', '*/5 * * * *', 'default', { type: 'cleanup' });
+    const schedules = tq.getSchedules();
+    expect(schedules).toHaveLength(1);
+    expect(schedules[0].id).toBe('cleanup');
+  });
+
+  test('tick enqueues tasks when schedule is due', () => {
+    // Set time to minute boundary
+    vi.setSystemTime(new Date('2026-01-01T00:00:00Z'));
+
+    tq.addSchedule('every5', '*/5 * * * *', 'default', { type: 'recurring' });
+
+    // Advance to 5 minutes later
+    vi.setSystemTime(new Date('2026-01-01T00:05:00Z'));
+    const created = tq.tick();
+
+    expect(created.length).toBeGreaterThanOrEqual(1);
+    expect(created[0].payload).toEqual({ type: 'recurring' });
+  });
+
+  test('tick does not enqueue when schedule not due', () => {
+    vi.setSystemTime(new Date('2026-01-01T00:00:00Z'));
+    tq.addSchedule('every5', '*/5 * * * *', 'default', { type: 'recurring' });
+
+    // Advance only 2 minutes
+    vi.setSystemTime(new Date('2026-01-01T00:02:00Z'));
+    const created = tq.tick();
+    expect(created).toHaveLength(0);
+  });
+
+  test('every hour on the hour', () => {
+    vi.setSystemTime(new Date('2026-01-01T00:00:00Z'));
+    tq.addSchedule('hourly', '0 * * * *', 'default', { type: 'hourly' });
+
+    // At 00:30 - not due
+    vi.setSystemTime(new Date('2026-01-01T00:30:00Z'));
+    expect(tq.tick()).toHaveLength(0);
+
+    // At 01:00 - due
+    vi.setSystemTime(new Date('2026-01-01T01:00:00Z'));
+    const created = tq.tick();
+    expect(created).toHaveLength(1);
+  });
+
+  test('every day at midnight', () => {
+    vi.setSystemTime(new Date('2026-01-01T00:00:00Z'));
+    tq.addSchedule('daily', '0 0 * * *', 'default', { type: 'daily' });
+
+    // At noon - not due
+    vi.setSystemTime(new Date('2026-01-01T12:00:00Z'));
+    expect(tq.tick()).toHaveLength(0);
+
+    // Next midnight
+    vi.setSystemTime(new Date('2026-01-02T00:00:00Z'));
+    const created = tq.tick();
+    expect(created).toHaveLength(1);
+  });
+
+  test('remove a schedule stops future occurrences', () => {
+    vi.setSystemTime(new Date('2026-01-01T00:00:00Z'));
+    tq.addSchedule('every5', '*/5 * * * *', 'default', { type: 'recurring' });
+
+    tq.removeSchedule('every5');
+
+    vi.setSystemTime(new Date('2026-01-01T00:05:00Z'));
+    const created = tq.tick();
+    expect(created).toHaveLength(0);
+    expect(tq.getSchedules()).toHaveLength(0);
+  });
+
+  test('list active schedules', () => {
+    tq.addSchedule('s1', '*/5 * * * *', 'default', { type: 'a' });
+    tq.addSchedule('s2', '0 * * * *', 'emails', { type: 'b' });
+
+    const schedules = tq.getSchedules();
+    expect(schedules).toHaveLength(2);
+  });
+
+  test('recurring tasks are regular tasks subject to queue rules', () => {
+    vi.setSystemTime(new Date('2026-01-01T00:00:00Z'));
+    tq.addSchedule('job', '*/5 * * * *', 'default', { type: 'recurring' });
+
+    vi.setSystemTime(new Date('2026-01-01T00:05:00Z'));
+    tq.tick();
+
+    const task = tq.process();
+    expect(task).not.toBeNull();
+    expect(task!.payload).toEqual({ type: 'recurring' });
+  });
+
+  test('tick does not double-enqueue for same time period', () => {
+    vi.setSystemTime(new Date('2026-01-01T00:00:00Z'));
+    tq.addSchedule('every5', '*/5 * * * *', 'default', { type: 'recurring' });
+
+    vi.setSystemTime(new Date('2026-01-01T00:05:00Z'));
+    tq.tick();
+    const second = tq.tick(); // same time, should not enqueue again
+    expect(second).toHaveLength(0);
+  });
+
+  test('multiple schedules can fire at the same tick', () => {
+    vi.setSystemTime(new Date('2026-01-01T00:00:00Z'));
+    tq.addSchedule('s1', '*/5 * * * *', 'default', { type: 'a' });
+    tq.addSchedule('s2', '*/5 * * * *', 'default', { type: 'b' });
+
+    vi.setSystemTime(new Date('2026-01-01T00:05:00Z'));
+    const created = tq.tick();
+    expect(created).toHaveLength(2);
+  });
+});
diff --git a/tests/phase11-middleware.test.ts b/tests/phase11-middleware.test.ts
new file mode 100644
index 0000000..f8e6694
--- /dev/null
+++ b/tests/phase11-middleware.test.ts
@@ -0,0 +1,166 @@
+import { describe, test, expect, beforeEach } from 'vitest';
+import { TaskQueueSystem } from '../src/index.js';
+
+describe('Phase 11: Middleware Pipeline', () => {
+  let tq: TaskQueueSystem;
+
+  beforeEach(() => {
+    tq = new TaskQueueSystem();
+  });
+
+  test('middleware receives task and next function', () => {
+    const calls: string[] = [];
+
+    tq.use('default', (task, next) => {
+      calls.push('middleware');
+      return next();
+    });
+
+    tq.setHandler('default', (task) => {
+      calls.push('handler');
+    });
+
+    tq.add('job');
+    const task = tq.process()!;
+    tq.processTask(task.id);
+
+    expect(calls).toEqual(['middleware', 'handler']);
+  });
+
+  test('middleware runs in registration order', () => {
+    const order: number[] = [];
+
+    tq.use('default', (_task, next) => {
+      order.push(1);
+      return next();
+    });
+
+    tq.use('default', (_task, next) => {
+      order.push(2);
+      return next();
+    });
+
+    tq.use('default', (_task, next) => {
+      order.push(3);
+      return next();
+    });
+
+    tq.setHandler('default', () => {
+      order.push(4);
+    });
+
+    tq.add('job');
+    const task = tq.process()!;
+    tq.processTask(task.id);
+
+    expect(order).toEqual([1, 2, 3, 4]);
+  });
+
+  test('middleware not calling next skips task processing', () => {
+    const calls: string[] = [];
+
+    tq.use('default', (_task, _next) => {
+      calls.push('middleware');
+      // Not calling next!
+    });
+
+    tq.setHandler('default', () => {
+      calls.push('handler');
+    });
+
+    tq.add('job');
+    const task = tq.process()!;
+    tq.processTask(task.id);
+
+    expect(calls).toEqual(['middleware']);
+  });
+
+  test('middleware can modify the task payload', () => {
+    tq.use('default', (task, next) => {
+      (task.payload as Record<string, unknown>).enriched = true;
+      return next();
+    });
+
+    let receivedPayload: unknown;
+    tq.setHandler('default', (task) => {
+      receivedPayload = task.payload;
+    });
+
+    tq.add({ data: 'test' });
+    const task = tq.process()!;
+    tq.processTask(task.id);
+
+    expect(receivedPayload).toEqual({ data: 'test', enriched: true });
+  });
+
+  test('middleware throwing marks task as failed', () => {
+    tq.use('default', () => {
+      throw new Error('middleware error');
+    });
+
+    tq.add('job', { maxRetries: 0 });
+    const task = tq.process()!;
+    tq.processTask(task.id);
+
+    const updated = tq.getTask(task.id)!;
+    expect(updated.status).toBe('failed');
+    expect(updated.error).toBe('middleware error');
+  });
+
+  test('each queue has its own middleware stack', () => {
+    const calls: string[] = [];
+
+    tq.use('q1', (_task, next) => {
+      calls.push('q1-middleware');
+      return next();
+    });
+
+    tq.use('q2', (_task, next) => {
+      calls.push('q2-middleware');
+      return next();
+    });
+
+    tq.setHandler('q1', () => { calls.push('q1-handler'); });
+    tq.setHandler('q2', () => { calls.push('q2-handler'); });
+
+    tq.add('job1', { queue: 'q1' });
+    tq.add('job2', { queue: 'q2' });
+
+    const t1 = tq.process('q1')!;
+    tq.processTask(t1.id);
+
+    const t2 = tq.process('q2')!;
+    tq.processTask(t2.id);
+
+    expect(calls).toEqual(['q1-middleware', 'q1-handler', 'q2-middleware', 'q2-handler']);
+  });
+
+  test('processTask without handler just runs middleware', () => {
+    const calls: string[] = [];
+
+    tq.use('default', (_task, next) => {
+      calls.push('middleware');
+      return next();
+    });
+
+    tq.add('job');
+    const task = tq.process()!;
+    tq.processTask(task.id);
+
+    expect(calls).toEqual(['middleware']);
+  });
+
+  test('handler error marks task as failed', () => {
+    tq.setHandler('default', () => {
+      throw new Error('handler error');
+    });
+
+    tq.add('job', { maxRetries: 0 });
+    const task = tq.process()!;
+    tq.processTask(task.id);
+
+    const updated = tq.getTask(task.id)!;
+    expect(updated.status).toBe('failed');
+    expect(updated.error).toBe('handler error');
+  });
+});
