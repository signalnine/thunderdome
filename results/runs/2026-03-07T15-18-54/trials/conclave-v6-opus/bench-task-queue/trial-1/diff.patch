+  id: string;
+  payload: unknown;
+  status: TaskStatus;
+  createdAt: Date;
+  queue: string;
+  priority: number;
+  availableAt: Date;
+  attempts: number;
+  maxRetries: number;
+  backoffDelay: number;
+  error?: string;
+  progress: number;
+  progressMessage?: string;
+  dependencies: string[];
+}
