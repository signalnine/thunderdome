oBe('later');\n  });\n\n  test('delayed tasks with same availability ordered by priority then FIFO', () => {\n    tq.add('low-priority', { delay: 5000, priority: 10 });\n    tq.add('high-priority', { delay: 5000, priority: 1 });\n\n    vi.advanceTimersByTime(5001);\n\n    expect(tq.process()!.payload).toBe('high-priority');\n    expect(tq.process()!.payload).toBe('low-priority');\n  });\n\n  test('task object indicates when it becomes available', () => {\n    const task = tq.add('delayed', { delay: 3000 });\n    const retrieved = tq.getTask(task.id);\n    expect(retrieved!.availableAt).toBeInstanceOf(Date);\n    expect(retrieved!.availableAt.getTime()).toBeGreaterThan(task.createdAt.getTime());\n  });\n\n  test('delays work with named queues', () => {\n    tq.add('delayed', { queue: 'myqueue', delay: 5000 });\n    expect(tq.process('myqueue')).toBeNull();\n\n    vi.advanceTimersByTime(5001);\n    const task = tq.process('myqueue');\n    expect(task!.payload).toBe('delayed');\n  });\n\n  test('size does not count unavailable delayed tasks', () => {\n    tq.add('delayed', { delay: 5000 });\n    tq.add('immediate');\n\n    // size should count pending tasks that are available\n    expect(tq.size()).toBe(1);\n\n    vi.advanceTimersByTime(5001);\n    expect(tq.size()).toBe(2);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":600,"cache_read_input_tokens":47084,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":600},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"41a2633b-441a-43ad-b989-10aed8aa6cfb","uuid":"b8a46074-92cc-4d3d-99d6-6c262106f119"}
