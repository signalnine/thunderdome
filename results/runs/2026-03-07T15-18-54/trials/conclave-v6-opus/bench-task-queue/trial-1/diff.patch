+describe('Phase 1: Basic FIFO Queue', () => {
+  let tq: TaskQueueSystem;
+
+  beforeEach(() => {
+    tq = new TaskQueueSystem();
+  });
+
+  test('add returns a task object with id, status, and createdAt', () => {
+    const task = tq.add({ type: 'email', to: 'user@example.com' });
+
+    expect(task.id).toBeDefined();
+    expect(typeof task.id).toBe('string');
+    expect(task.id.length).toBeGreaterThan(0);
+    expect(task.status).toBe('pending');
+    expect(task.createdAt).toBeInstanceOf(Date);
+    expect(task.payload).toEqual({ type: 'email', to: 'user@example.com' });
+  });
+
+  test('each task gets a unique identifier', () => {
+    const task1 = tq.add('payload1');
+    const task2 = tq.add('payload2');
+    const task3 = tq.add('payload3');
+
+    const ids = new Set([task1.id, task2.id, task3.id]);
+    expect(ids.size).toBe(3);
+  });
+
+  test('process returns the oldest pending task in FIFO order', () => {
+    tq.add('first');
+    tq.add('second');
+    tq.add('third');
+
+    const task = tq.process();
+    expect(task).not.toBeNull();
+    expect(task!.payload).toBe('first');
+  });
+
+  test('process transitions task to processing state', () => {
+    tq.add('work');
+
+    const task = tq.process();
+    expect(task!.status).toBe('processing');
+  });
+
+  test('process returns null when queue is empty', () => {
+    const task = tq.process();
+    expect(task).toBeNull();
+  });
+
+  test('process returns tasks in insertion order (FIFO)', () => {
+    tq.add('A');
+    tq.add('B');
+    tq.add('C');
+
+    expect(tq.process()!.payload).toBe('A');
+    expect(tq.process()!.payload).toBe('B');
+    expect(tq.process()!.payload).toBe('C');
+    expect(tq.process()).toBeNull();
+  });
+
+  test('size returns number of pending tasks', () => {
+    expect(tq.size()).toBe(0);
+
+    tq.add('one');
+    tq.add('two');
+    expect(tq.size()).toBe(2);
+
+    tq.process(); // moves one to processing
+    expect(tq.size()).toBe(1);
+  });
+
+  test('getTask retrieves a task by id', () => {
+    const added = tq.add('find-me');
+    const found = tq.getTask(added.id);
+
+    expect(found).not.toBeNull();
+    expect(found!.id).toBe(added.id);
+    expect(found!.payload).toBe('find-me');
+  });
+
+  test('getTask returns null for unknown id', () => {
+    expect(tq.getTask('nonexistent')).toBeNull();
+  });
+
+  test('processing a task does not return it again', () => {
+    tq.add('only-once');
+
+    const first = tq.process();
+    expect(first).not.toBeNull();
+
+    const second = tq.process();
+    expect(second).toBeNull();
+  });
+});
