 IDs that depend on it\n  private dependents = new Map<string, Set<string>>();\n  // taskId -> set of dependency IDs not yet completed\n  private unresolvedDeps = new Map<string, Set<string>>();\n  // concurrency: queueName -> limit (0 = unlimited)\n  private concurrencyLimits = new Map<string, number>();\n  // queueName -> count of currently processing tasks\n  private activeCounts = new Map<string, number>();\n  // progress listeners: taskId -> set of callbacks\n  private progressListeners = new Map<string, Set<(percent: number, message?: string) => void>>();\n  // recurring schedules\n  private schedules = new Map<string, Schedule>();\n  // middleware per queue\n  private middlewares = new Map<string, Array<(task: Task, next: () => void) => void>>();\n  // handler per queue\n  private handlers = new Map<string, (task: Task) => void>();\n  // shutdown state\n  private isShutdown = false;\n  private shutdownResult: ShutdownResult | null = null;\n  private shutdownCallbacks: Array<() => void> = [];\n  private shutdownResolvers: Array<() => void> = [];\n\n  add(payload: unknown, options: TaskOptions = {}): Task {\n    if (this.isShutdown) {\n      throw new Error('System is shut down. Cannot add new tasks.');\n    }\n    const priority = options.priority ?? 5;\n    if (!Number.isInteger(priority) || priority < 1 || priority > 10) {\n      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    }\n\n    const deps = options.dependencies ?? [];\n\n    // Validate dependencies exist\n    for (const depId of deps) {\n      if (!this.tasks.has(depId)) {\n        throw new Error(`Dependency not found: ${depId}`);\n      }\n    }\n\n    const queue = options.queue ?? DEFAULT_QUEUE;\n    const now = new Date();\n\n    let availableAt = now;\n    if (options.availableAt) {\n      availableAt = options.availableAt;\n    } else if (options.delay != null && options.delay > 0) {\n      availableAt = new Date(now.getTime() + options.delay);\n    }\n\n    const task: InternalTask = {\n      id: randomUUID(),\n      payload,\n      status: 'pending',\n      createdAt: now,\n      queue,\n      priority,\n      availableAt,\n      attempts: 0,\n      maxRetries: options.maxRetries ?? 3,\n      backoffDelay: options.backoffDelay ?? 1000,\n      progress: 0,\n      dependencies: [...deps],\n    };\n\n    // Check for circular dependencies\n    if (deps.length > 0) {\n      this.detectCycle(task.id, deps);\n    }\n\n    this.tasks.set(task.id, task);\n\n    // Track unresolved dependencies\n    const unresolved = new Set<string>();\n    for (const depId of deps) {\n      const depTask = this.tasks.get(depId)!;\n      if (depTask.status !== 'completed') {\n        unresolved.add(depId);\n        if (!this.dependents.has(depId)) {\n          this.dependents.set(depId, new Set());\n        }\n        this.dependents.get(depId)!.add(task.id);\n      }\n    }\n    if (unresolved.size > 0) {\n      this.unresolvedDeps.set(task.id, unresolved);\n    }\n\n    if (!this.queues.has(queue)) {\n      this.queues.set(queue, []);\n    }\n    this.insertSorted(this.queues.get(queue)!, task);\n\n    return this.toPublicTask(task);\n  }\n\n  process(queueName?: string): Task | null {\n    const queue = queueName ?? DEFAULT_QUEUE;\n    const pending = this.queues.get(queue);\n    if (!pending) return null;\n\n    // Check concurrency limit\n    const limit = this.concurrencyLimits.get(queue) ?? 0;\n    const active = this.activeCounts.get(queue) ?? 0;\n    if (limit > 0 && active >= limit) return null;\n\n    const now = Date.now();\n    for (let i = 0; i < pending.length; i++) {\n      const task = pending[i];\n      if (\n        task.status === 'pending' &&\n        task.availableAt.getTime() <= now &&\n        !this.unresolvedDeps.has(task.id)\n      ) {\n        task.status = 'processing';\n        this.activeCounts.set(queue, (this.activeCounts.get(queue) ?? 0) + 1);\n        return this.toPublicTask(task);\n      }\n    }\n\n    return null;\n  }\n\n  size(queueName?: string): number {\n    const queue = queueName ?? DEFAULT_QUEUE;\n    const pending = this.queues.get(queue);\n    if (!pending) return 0;\n    const now = Date.now();\n    return pending.filter(\n      t => t.status === 'pending' &&\n        t.availableAt.getTime() <= now &&\n        !this.unresolvedDeps.has(t.id)\n    ).length;\n  }\n\n  complete(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot complete task in ${task.status} state`);\n    }\n    task.status = 'completed';\n    this.activeCounts.set(task.queue, (this.activeCounts.get(task.queue) ?? 1) - 1);\n\n    // Resolve dependencies\n    const deps = this.dependents.get(taskId);\n    if (deps) {\n      for (const dependentId of deps) {\n        const unresolved = this.unresolvedDeps.get(dependentId);\n        if (unresolved) {\n          unresolved.delete(taskId);\n          if (unresolved.size === 0) {\n            this.unresolvedDeps.delete(dependentId);\n          }\n        }\n      }\n      this.dependents.delete(taskId);\n    }\n\n    this.notifyShutdownResolvers();\n  }\n\n  fail(taskId: string, error?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot fail task in ${task.status} state`);\n    }\n    task.attempts++;\n    task.error = error;\n    this.activeCounts.set(task.queue, (this.activeCounts.get(task.queue) ?? 1) - 1);\n\n    if (task.attempts <= task.maxRetries) {\n      const delay = task.backoffDelay * Math.pow(2, task.attempts - 1);\n      task.status = 'pending';\n      task.availableAt = new Date(Date.now() + delay);\n\n      const queueList = this.queues.get(task.queue)!;\n      const idx = queueList.indexOf(task);\n      if (idx !== -1) queueList.splice