new Error(`Task not found: ${taskId}`);\n   208→    if (task.status !== 'processing') {\n   209→      throw new Error(`Cannot fail task in ${task.status} state`);\n   210→    }\n   211→    task.attempts++;\n   212→    task.error = error;\n   213→    this.activeCounts.set(task.queue, (this.activeCounts.get(task.queue) ?? 1) - 1);\n   214→\n   215→    if (task.attempts <= task.maxRetries) {\n   216→      const delay = task.backoffDelay * Math.pow(2, task.attempts - 1);\n   217→      task.status = 'pending';\n   218→      task.availableAt = new Date(Date.now() + delay);\n   219→\n   220→      const queueList = this.queues.get(task.queue)!;\n   221→      const idx = queueList.indexOf(task);\n   222→      if (idx !== -1) queueList.splice(idx, 1);\n   223→      this.insertSorted(queueList, task);\n   224→    } else {\n   225→      task.status = 'failed';\n   226→      if (!this.deadLetterQueues.has(task.queue)) {\n   227→        this.deadLetterQueues.set(task.queue, []);\n   228→      }\n   229→      this.deadLetterQueues.get(task.queue)!.push(task);\n   230→    }\n   231→\n   232→    this.notifyShutdownResolvers();\n   233→  }\n   234→\n   235→  getDeadLetterTasks(queueName?: string): Task[] {\n   236→    const queue = queueName ?? DEFAULT_QUEUE;\n   237→    const dlq = this.deadLetterQueues.get(queue);\n   238→    if (!dlq) return [];\n   239→    return dlq.map(t => this.toPublicTask(t));\n   240→  }\n   241→\n   242→  requeue(taskId: string): Task {\n   243→    const task = this.tasks.get(taskId);\n   244→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   245→    if (task.status !== 'failed') {\n   246→      throw new Error(`Cannot requeue task in ${task.status} state`);\n   247→    }\n   248→\n   249→    const dlq = this.deadLetterQueues.get(task.queue);\n   250→    if (dlq) {\n   251→      const idx = dlq.indexOf(task);\n   252→      if (idx !== -1) dlq.splice(idx, 1);\n   253→    }\n   254→\n   255→    task.status = 'pending';\n   256→    task.attempts