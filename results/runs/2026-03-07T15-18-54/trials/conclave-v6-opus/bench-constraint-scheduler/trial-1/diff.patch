+++ b/src/scheduler.ts
@@ -0,0 +1,287 @@
+import { Event, Room, ScheduleOptions, Assignment, ScheduleResult } from './types.js';
+
+/**
+ * Topological sort using Kahn's algorithm. Throws on cycles.
+ * Returns event IDs in valid prerequisite order.
+ */
+function topologicalSort(events: Event[]): string[] {
+  const inDegree = new Map<string, number>();
+  const adjacency = new Map<string, string[]>();
+  const eventMap = new Map<string, Event>();
+
+  for (const event of events) {
+    eventMap.set(event.id, event);
+    inDegree.set(event.id, 0);
+    adjacency.set(event.id, []);
+  }
+
+  for (const event of events) {
+    if (event.prerequisites) {
+      for (const prereq of event.prerequisites) {
+        if (prereq === event.id) {
+          throw new Error(`Cycle detected: event "${event.id}" has a self-referencing prerequisite`);
+        }
+        if (eventMap.has(prereq)) {
+          adjacency.get(prereq)!.push(event.id);
+          inDegree.set(event.id, inDegree.get(event.id)! + 1);
+        }
+      }
+    }
+  }
+
+  const queue: string[] = [];
+  for (const [id, degree] of inDegree) {
+    if (degree === 0) {
+      queue.push(id);
+    }
+  }
+
+  const sorted: string[] = [];
+  while (queue.length > 0) {
+    const current = queue.shift()!;
+    sorted.push(current);
+    for (const neighbor of adjacency.get(current)!) {
+      const newDegree = inDegree.get(neighbor)! - 1;
+      inDegree.set(neighbor, newDegree);
+      if (newDegree === 0) {
+        queue.push(neighbor);
+      }
+    }
+  }
+
+  if (sorted.length !== events.length) {
+    throw new Error('Cycle detected in prerequisite graph');
+  }
+
+  return sorted;
+}
+
+/**
+ * Compute topological depth (level) for each event.
+ * Events with no prerequisites have depth 0.
+ * Events depending on depth-N events have depth N+1.
+ */
+function computeTopoDepth(events: Event[], eventMap: Map<string, Event>): Map<string, number> {
+  const depth = new Map<string, number>();
+
+  function getDepth(id: string): number {
+    if (depth.has(id)) return depth.get(id)!;
+    const event = eventMap.get(id);
+    if (!event || !event.prerequisites || event.prerequisites.length === 0) {
+      depth.set(id, 0);
+      return 0;
+    }
+    let maxPrereqDepth = -1;
+    for (const prereqId of event.prerequisites) {
+      if (eventMap.has(prereqId)) {
+        maxPrereqDepth = Math.max(maxPrereqDepth, getDepth(prereqId));
+      }
+    }
+    const d = maxPrereqDepth + 1;
+    depth.set(id, d);
+    return d;
+  }
+
+  for (const event of events) {
+    getDepth(event.id);
+  }
+
+  return depth;
+}
+
+/**
+ * Find the earliest valid start time for an event in a given room.
+ */
+function findEarliestStart(
+  event: Event,
+  room: Room,
+  existingAssignments: Assignment[],
+  options: ScheduleOptions,
+  gap: number,
+  assignmentMap: Map<string, Assignment>
+): number | null {
+  const attendees = event.attendees ?? 1;
+  if (attendees > room.capacity) {
+    return null;
+  }
+
+  let earliest = options.startTime;
+  if (event.prerequisites) {
+    for (const prereqId of event.prerequisites) {
+      const prereqAssignment = assignmentMap.get(prereqId);
+      if (prereqAssignment) {
+        earliest = Math.max(earliest, prereqAssignment.endTime + gap);
+      }
+    }
+  }
+
+  const duration = event.duration;
+
+  if (earliest + duration > options.endTime) {
+    return null;
+  }
+
+  const roomAssignments = existingAssignments
+    .filter(a => a.roomId === room.id)
+    .sort((a, b) => a.startTime - b.startTime);
+
+  if (roomAssignments.length === 0) {
+    return earliest;
+  }
+
+  // Try to fit before the first assignment
+  if (earliest + duration + gap <= roomAssignments[0].startTime) {
+    return earliest;
+  }
+  // Edge case: no gap needed if fitting exactly at earliest before first event
+  if (gap === 0 && earliest + duration <= roomAssignments[0].startTime) {
+    return earliest;
+  }
+
+  // Try to fit after each existing assignment
+  for (let i = 0; i < roomAssignments.length; i++) {
+    const slotStart = Math.max(earliest, roomAssignments[i].endTime + gap);
+    const nextStart = i + 1 < roomAssignments.length
+      ? roomAssignments[i + 1].startTime
+      : options.endTime;
+
+    const neededEnd = i + 1 < roomAssignments.length
+      ? slotStart + duration + gap
+      : slotStart + duration;
+
+    if (neededEnd <= nextStart && slotStart + duration <= options.endTime) {
+      return slotStart;
+    }
+  }
+
+  return null;
+}
+
+/**
+ * Attempt to greedily schedule events in the given order.
+ */
+function greedySchedule(
+  schedulingOrder: string[],
+  eventMap: Map<string, Event>,
+  rooms: Room[],
+  options: ScheduleOptions,
+  gap: number
+): { assignments: Assignment[]; assignmentMap: Map<string, Assignment>; unscheduled: string[] } {
+  const assignments: Assignment[] = [];
+  const assignmentMap = new Map<string, Assignment>();
+  const unscheduled: string[] = [];
+
+  for (const eventId of schedulingOrder) {
+    const event = eventMap.get(eventId)!;
+    const attendees = event.attendees ?? 1;
+
+    const eligibleRooms = rooms
+      .filter(r => r.capacity >= attendees)
+      .sort((a, b) => {
+        if (event.preferredRoom) {
+          if (a.id === event.preferredRoom && b.id !== event.preferredRoom) return -1;
+          if (b.id === event.preferredRoom && a.id !== event.preferredRoom) return 1;
+        }
+        return a.capacity - b.capacity;
+      });
+
+    let bestStart: number | null = null;
+    let bestRoom: Room | null = null;
+
+    for (const room of eligibleRooms) {
+      const start = findEarliestStart(event, room, assignments, options, gap, assignmentMap);
+      if (start !== null) {
+        if (bestStart === null || start < bestStart ||
+            (start === bestStart && event.preferredRoom === room.id)) {
+          bestStart = start;
+          bestRoom = room;
+          if (event.preferredRoom === room.id) break;
+        }
+      }
+    }
+
+    if (bestStart !== null && bestRoom !== null) {
+      const assignment: Assignment = {
+        eventId,
+        roomId: bestRoom.id,
+        startTime: bestStart,
+        endTime: bestStart + event.duration,
+      };
+      assignments.push(assignment);
+      assignmentMap.set(eventId, assignment);
+    } else {
+      unscheduled.push(eventId);
+    }
+  }
+
+  return { assignments, assignmentMap, unscheduled };
+}
+
+export function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {
+  const gap = options.gap ?? 15;
+
+  // Cycle detection and topological sort
+  const sortedIds = topologicalSort(events);
+
+  const eventMap = new Map<string, Event>();
+  for (const event of events) {
+    eventMap.set(event.id, event);
+  }
+
+  const eligibleRoomCount = new Map<string, number>();
+  for (const event of events) {
+    const attendees = event.attendees ?? 1;
+    const count = rooms.filter(r => r.capacity >= attendees).length;
+    eligibleRoomCount.set(event.id, count);
+  }
+
+  const topoDepth = computeTopoDepth(events, eventMap);
+
+  // Generate multiple scheduling orderings and pick the best result.
+  // All orderings must respect prerequisite order (lower depth first).
+  const orderings: string[][] = [];
+
+  // Strategy 1: Most constrained first, then shortest duration (maximizes count)
+  orderings.push([...sortedIds].sort((a, b) => {
+    const depthA = topoDepth.get(a)!;
+    const depthB = topoDepth.get(b)!;
+    if (depthA !== depthB) return depthA - depthB;
+    const eligA = eligibleRoomCount.get(a)!;
+    const eligB = eligibleRoomCount.get(b)!;
+    if (eligA !== eligB) return eligA - eligB;
+    return eventMap.get(a)!.duration - eventMap.get(b)!.duration;
+  }));
+
+  // Strategy 2: Most constrained first, then longest duration
+  orderings.push([...sortedIds].sort((a, b) => {
+    const depthA = topoDepth.get(a)!;
+    const depthB = topoDepth.get(b)!;
+    if (depthA !== depthB) return depthA - depthB;
+    const eligA = eligibleRoomCount.get(a)!;
+    const eligB = eligibleRoomCount.get(b)!;
+    if (eligA !== eligB) return eligA - eligB;
+    return eventMap.get(b)!.duration - eventMap.get(a)!.duration;
+  }));
+
+  // Strategy 3: Shortest duration first (global, respecting topo)
+  orderings.push([...sortedIds].sort((a, b) => {
+    const depthA = topoDepth.get(a)!;
+    const depthB = topoDepth.get(b)!;
+    if (depthA !== depthB) return depthA - depthB;
+    return eventMap.get(a)!.duration - eventMap.get(b)!.duration;
+  }));
+
+  let bestResult = greedySchedule(orderings[0], eventMap, rooms, options, gap);
+
+  for (let i = 1; i < orderings.length; i++) {
+    const result = greedySchedule(orderings[i], eventMap, rooms, options, gap);
+    if (result.assignments.length > bestResult.assignments.length) {
+      bestResult = result;
+    }
+  }
+
+  return {
+    assignments: bestResult.assignments,
+    unscheduled: bestResult.unscheduled,
+  };
+}
