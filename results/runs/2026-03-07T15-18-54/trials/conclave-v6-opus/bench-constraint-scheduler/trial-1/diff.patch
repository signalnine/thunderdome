+\n+describe('single event scheduling', () => {\n+  it('schedules a single event into a room', () => {\n+    const events: Event[] = [\n+      { id: 'e1', name: 'Event 1', duration: 60, attendees: 5 },\n+    ];\n+    const result = schedule(events, rooms, defaultOptions);\n+    expect(result.assignments).toHaveLength(1);\n+    expect(result.unscheduled).toHaveLength(0);\n+    expect(result.assignments[0].eventId).toBe('e1');\n+    expect(result.assignments[0].startTime).toBeGreaterThanOrEqual(540);\n+    expect(result.assignments[0].endTime).toBe(result.assignments[0].startTime + 60);\n+  });\n+});\n+\n+describe('capacity constraints', () => {\n+  it('rejects event that exceeds all room capacities', () => {\n+    const events: Event[] = [\n+      { id: 'e1', name: 'Big Event', duration: 60, attendees: 100 },\n+    ];\n+    const result = schedule(events, rooms, defaultOptions);\n+    expect(result.assignments).toHaveLength(0);\n+    expect(result.unscheduled).toContain('e1');\n+  });\n+\n+  it('assigns event to room with sufficient capacity', () => {\n+    const events: Event[] = [\n+      { id: 'e1', name: 'Medium Event', duration: 60, attendees: 15 },\n+    ];\n+    const result = schedule(events, rooms, defaultOptions);\n+    expect(result.assignments).toHaveLength(1);\n+    // Only room-b has capacity 20, so it must go there\n+    expect(result.assignments[0].roomId).toBe('room-b');\n+  });\n+});\n+\n+describe('prerequisite ordering', () => {\n+  it('schedules B after A when B depends on A', () => {\n+    const events: Event[] = [\n+      { id: 'a', name: 'Event A', duration: 60, attendees: 5 },\n+      { id: 'b', name: 'Event B', duration: 60, attendees: 5, prerequisites: ['a'] },\n+    ];\n+    const result = schedule(events, rooms, defaultOptions);\n+    expect(result.assignments).toHaveLength(2);\n+    const assignA = result.assignments.find(a => a.eventId === 'a')!;\n+    const assignB = result.assignments.find(a => a.eventId === 'b')!;\n+    expect(assignB