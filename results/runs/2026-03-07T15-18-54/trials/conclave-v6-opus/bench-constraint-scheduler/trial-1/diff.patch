+describe('cycle detection', () => {
+  it('throws on self-referencing prerequisite', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['e1'] },
+    ];
+    expect(() => schedule(events, rooms, defaultOptions)).toThrow();
+  });
+
+  it('throws on mutual prerequisite cycle', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['e2'] },
+      { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },
+    ];
+    expect(() => schedule(events, rooms, defaultOptions)).toThrow();
+  });
+
+  it('throws on longer cycle (A->B->C->A)', () => {
+    const events: Event[] = [
+      { id: 'a', name: 'A', duration: 30, prerequisites: ['c'] },
+      { id: 'b', name: 'B', duration: 30, prerequisites: ['a'] },
+      { id: 'c', name: 'C', duration: 30, prerequisites: ['b'] },
+    ];
+    expect(() => schedule(events, rooms, defaultOptions)).toThrow();
+  });
+});
+
+describe('single event scheduling', () => {
+  it('schedules a single event into a room', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60, attendees: 5 },
+    ];
+    const result = schedule(events, rooms, defaultOptions);
+    expect(result.assignments).toHaveLength(1);
+    expect(result.unscheduled).toHaveLength(0);
+    expect(result.assignments[0].eventId).toBe('e1');
+    expect(result.assignments[0].startTime).toBeGreaterThanOrEqual(540);
+    expect(result.assignments[0].endTime).toBe(result.assignments[0].startTime + 60);
+  });
+});
