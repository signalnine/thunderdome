+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01K4wbeG5fqKNYxa17jnbesk","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01PTssDUn5ho9TDyyjodXy9a","name":"Write","input":{"file_path":"/workspace/src/scheduler.test.ts","content":"import { describe, it, expect } from 'vitest';\nimport { schedule } from './scheduler.js';\nimport { Event, Room, ScheduleOptions } from './types.js';\n\nconst defaultOptions: ScheduleOptions = {\n  startTime: 540,  // 9:00 AM\n  endTime: 1020,   // 5:00 PM\n};\n\nconst rooms: Room[] = [\n  { id: 'room-a', name: 'Room A', capacity: 10 },\n  { id: 'room-b', name: 'Room B', capacity: 20 },\n];\n\ndescribe('cycle detection', () => {\n  it('throws on self-referencing prerequisite', () => {\n    const events: Event[] = [\n      { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['e1'] },\n    ];\n    expect(() => schedule(events, rooms, defaultOptions)).toThrow();\n  });\n\n  it('throws on mutual prerequisite cycle', () => {\n    const events: Event[] = [\n      { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['e2'] },\n      { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },\n    ];\n    expect(() => schedule(events, rooms, defaultOptions)).toThrow();\n  });\n\n  it('throws on longer cycle (A->B->C->A)', () => {\n    const events: Event[] = [\n      { id: 'a', name: 'A', duration: 30, prerequisites: ['c'] },\n      { id: 'b', name: 'B', duration: 30, prerequisites: ['a'] },\n      { id: 'c', name: 'C', duration: 30, prerequisites: ['b'] },\n    ];\n    expect(() => schedule(events, rooms, defaultOptions)).toThrow();\n  });\n});\n\ndescribe('single event scheduling', () => {\n  it('schedules a single event into a room', () => {\n    const events: Event[] = [\n      { id: 'e1', name: 'Event 1', duration: 60, attendees: 5 },\n    ];\n    const result = schedule(events, rooms, defaultOptions);\n    expect(result.assignments).toHaveLength(1);\n    expect(result.unscheduled).toHaveLength(0);\n    expect(result.assignments[0].eventId).toBe('e1');\n    expect(result.assignments[0].startTime).toBeGreaterThanOrEqual(540);\n    expect(result.assignments[0].endTime).toBe(result.assignments[0].startTime + 60);\n  });\n});\n\ndescribe('capacity constraints', () => {\n  it('rejects event that exceeds all room capacities', () => {\n    const events: Event[] = [\n      { id: 'e1', name: 'Big Event', duration: 60, attendees: 100 },\n    ];\n    const result = schedule(events, rooms, defaultOptions);\n    expect(result.assignments).toHaveLength(0);\n    expect(result.unscheduled).toContain('e1');\n  });\n\n  it('assigns event to room with sufficient capacity', () => {\n    const events: Event[] = [\n      { id: 'e1', name: 'Medium Event', duration: 60, attendees: 15 },\n    ];\n    const result = schedule(events, rooms, defaultOptions);\n    expect(result.assignments).toHaveLength(1);\n    // Only room-b has capacity 20, so it must go there\n    expect(result.assignments[0].roomId).toBe('room-b');\n  });\n});\n\ndescribe('prerequisite ordering', () => {\n  it('schedules B after A when B depends on A', () => {\n    const events: Event[] = [\n      { id: 'a', name: 'Event A', duration: 60, attendees: 5 },\n      { id: 'b', name: 'Event B', duration: 60, attendees: 5, prerequisites: ['a'] },\n    ];\n    const result = schedule(events, rooms, defaultOptions);\n    expect(result.assignments).toHaveLength(2);\n    const assignA = result.assignments.find(a => a.eventId === 'a')!;\n    const assignB = result.assignments.find(a => a.eventId === 'b')!;\n    expect(assignB.startTime).toBeGreaterThanOrEqual(assignA.endTime);\n  });\n});\n\ndescribe('gap enforcement', () => {\n  it('enforces gap between events in the same room', () => {\n    // Use only 1 room so both events go to the same room\n    const singleRoom: Room[] = [{ id: 'room-a', name: 'Room A', capacity: 10 }];\n    const events: Event[] = [\n      { id: 'e1', name: 'Event 1', duration: 60, attendees: 5 },\n      { id: 'e2', name: 'Event 2', duration: 60, attendees: 5 },\n    ];\n    const result = schedule(events, singleRoom, { ...defaultOptions, gap: 30 });\n    expect(result.assignments).toHaveLength(2);\n    const sorted = [...result.assignments].sort((a, b) => a.startTime - b.startTime);\n    // Second event must start at least 30 minutes after first ends\n    expect(sorted[1].startTime).toBeGreaterThanOrEqual(sorted[0].endTime + 30);\n  });\n\n  it('uses default gap of 15 minutes', () => {\n    const singleRoom: Room[] = [{ id: 'room-a', name: 'Room A', capacity: 10 }];\n    const events: Event[] = [\n      { id: 'e1', name: 'Event 1', duration: 60, attendees: 5 },\n      { id: 'e2', name: 'Event 2', duration: 60, attendees: 5 },\n    ];\n    const result = schedule(events, singleRoom, defaultOptions);\n    expect(result.assignments).toHaveLength(2);\n    const sorted = [...result.assignments].sort((a, b) => a.startTime - b.startTime);\n    expect(sorted[1].startTime).toBeGreaterThanOrEqual(sorted[0].endTime + 15);\n  });\n});\n\ndescribe('time window boundaries', () => {\n  it('does not schedule events outside the time window', () => {\n    const events: Event[] = [\n      { id: 'e1', name: 'Event 1', duration: 60, attendees: 5 },\n    ];\n    // Very narrow window: only 30 minutes available, event needs 60\n    const result = schedule(events, rooms, { startTime: 540, endTime: 570 });\n    expect(result.assignments).toHaveLength(0);\n    expect(result.unscheduled).toContain('e1');\n  });\n\n  it('schedules event that exactly fits the window', () => {\n    const events: Event[] = [\n      { id: 'e1', name: 'Event 1', duration: 60, attendees: 5 },\n    ];\n    const result = schedule(events, rooms, { startTime: 540, endTime: 600 });\n    expect(result.assignments).toHaveLength(1);\n    expect(result.assignments[0].startTime).toBe(540);\n    expect(result.assignments[0].endTime).toBe(600);\n  });\n});\n\ndescribe('preferred room', () => {\n  it('honors preferred room when possible', () => {\n    const events: Event[] = [\n      { id: 'e1', name: 'Event 1', duration: 60, attendees: 5, preferredRoom: 'room-b' },\n    ];\n    const result = schedule(events, rooms, defaultOptions);\n    expect(result.assignments).toHaveLength(1);\n    expect(result.assignments[0].roomId).toBe('room-b');\n  });\n\n  it('overrides preferred room when capacity insufficient', () => {\n    const smallAndBig: Room[] = [\n      { id: 'small', name: 'Small', capacity: 5 },\n      { id: 'big', name: 'Big', capacity: 50 },\n    ];\n    const events: Event[] = [\n      { id: 'e1', name: 'Event 1', duration: 60, attendees: 20, preferredRoom: 'small' },\n    ];\n    const result = schedule(events, smallAndBig, defaultOptions);\n    expect(result.assignments).toHaveLength(1);\n    expect(result.assignments[0].roomId).toBe('big');\n  });\n\n  it('overrides preferred room when time slot unavailable', () => {\n    const singleCapRoom: Room[] = [\n      { id: 'room-a', name: 'Room A', capacity: 10 },\n      { id: 'room-b', name: 'Room B', capacity: 10 },\n    ];\n    const events: Event[] = [\n      { id: 'e1', name: 'Event 1', duration: 420, attendees: 5, preferredRoom: 'room-a' },\n      { id: 'e2', name: 'Event 2', duration: 420, attendees: 5, preferredRoom: 'room-a' },\n    ];\n    // Window is 540-1020 = 480 min. Each event 420 min + 15 gap = 855 min needed.\n    // Only one fits in room-a, other must go to room-b.\n    const result = schedule(events, singleCapRoom, defaultOptions);\n    expect(result.assignments).toHaveLength(2);\n    const roomIds = result.assignments.map(a => a.roomId).sort();\n    expect(roomIds).toEqual(['room-a', 'room-b']);\n  });\n});\n\ndescribe('default values', () => {\n  it('defaults attendees to 1 when not specified', () => {\n    const tinyRoom: Room[] = [{ id: 'tiny', name: 'Tiny', capacity: 1 }];\n    const events: Event[] = [\n      { id: 'e1', name: 'Solo Event', duration: 30 },\n    ];\n    const result = schedule(events, tinyRoom, defaultOptions);\n    expect(result.assignments).toHaveLength(1);\n  });\n});\n\ndescribe('prerequisite gap enforcement', () => {\n  it('enforces gap between prerequisite end and dependent start', () => {\n    const events: Event[] = [\n      { id: 'a', name: 'A', duration: 60, attendees: 5 },\n      { id: 'b', name: 'B', duration: 60, attendees: 5, prerequisites: ['a'] },\n    ];\n    const result = schedule(events, rooms, { ...defaultOptions, gap: 30 });\n    expect(result.assignments).toHaveLength(2);\n    const assignA = result.assignments.find(a => a.eventId === 'a')!;\n    const assignB = result.assignments.find(a => a.eventId === 'b')!;\n    expect(assignB.startTime).toBeGreaterThanOrEqual(assignA.endTime + 30);\n  });\n});\n\ndescribe('maximization', () => {\n  it('prefers scheduling more events over fewer', () => {\n    // 1 room, window 540-720 (180 min), gap=0\n    // If we schedule the 120-min event, only 1 fits.\n    // If we schedule the two 60-min events, 2 fit.\n    // Scheduler should choose 2 events over 1.\n    const singleRoom: Room[] = [{ id: 'r', name: 'R', capacity: 10 }];\n    const events: Event[] = [\n      { id: 'big', name: 'Big', duration: 120, attendees: 5 },\n      { id: 'small1', name: 'Small 1', duration: 60, attendees: 5 },\n      { id: 'small2', name: 'Small 2', duration: 60, attendees: 5 },\n    ];\n    const result = schedule(events, singleRoom, { startTime: 540, endTime: 720, gap: 0 });\n    // Should schedule at least 2 events\n    expect(result.assignments.length).toBeGreaterThanOrEqual(2);\n  });\n\n  it('maximizes events in a tight multi-room scenario', () => {\n    // 2 rooms capacity 10 each, window 540-660 (120 min), gap=0\n    // 5 events of 60 min each. Max 4 can fit (2 per room).\n    const twoRooms: Room[] = [\n      { id: 'r1', name: 'R1', capacity: 10 },\n      { id: 'r2', name: 'R2', capacity: 10 },\n    ];\n    const events: Event[] = [\n      { id: 'e1', name: 'E1', duration: 60, attendees: 5 },\n      { id: 'e2', name: 'E2', duration: 60, attendees: 5 },\n      { id: 'e3', name: 'E3', duration: 60, attendees: 5 },\n      { id: 'e4', name: 'E4', duration: 60, attendees: 5 },\n      { id: 'e5', name: 'E5', duration: 60, attendees: 5 },\n    ];\n    const result = schedule(events, twoRooms, { startTime: 540, endTime: 660, gap: 0 });\n    expect(result.assignments.length).toBe(4);\n    expect(result.unscheduled.length).toBe(1);\n  });\n});\n\ndescribe('complex scenario', () => {\n  it('handles mixed constraints: prerequisites, capacity, preferences, gaps', () => {\n    const mixedRooms: Room[] = [\n      { id: 'small', name: 'Small', capacity: 5 },\n      { id: 'medium', name: 'Medium', capacity: 15 },\n      { id: 'large', name: 'Large', capacity: 50 },\n    ];\n    const events: Event[] = [\n      { id: 'keynote', name: 'Keynote', duration: 90, attendees: 40, preferredRoom: 'large' },\n      { id: 'workshop', name: 'Workshop', duration: 120, attendees: 10, prerequisites: ['keynote'] },\n      { id: 'breakout', name: 'Breakout', duration: 60, attendees: 4, preferredRoom: 'small' },\n      { id: 'panel', name: 'Panel', duration: 60, attendees: 12, prerequisites: ['keynote'] },\n    ];\n    const result = schedule(events, mixedRooms, defaultOptions);\n\n    // All should be schedulable\n    expect(result.assignments).toHaveLength(4);\n    expect(result.unscheduled).toHaveLength(0);\n\n    const keynote = result.assignments.find(a => a.eventId === 'keynote')!;\n    const workshop = result.assignments.find(a => a.eventId === 'workshop')!;\n    const panel = result.assignments.find(a => a.eventId === 'panel')!;\n    const breakout = result.assignments.find(a => a.eventId === 'breakout')!;\n\n    // Keynote must be in large room (only one with capacity >= 40)\n    expect(keynote.roomId).toBe('large');\n\n    // Workshop and panel must start after keynote ends (+ gap)\n    expect(workshop.startTime).toBeGreaterThanOrEqual(keynote.endTime + 15);\n    expect(panel.startTime).toBeGreaterThanOrEqual(keynote.endTime + 15);\n\n    // Breakout should be in small room (preferred, fits)\n    expect(breakout.roomId).toBe('small');\n\n    // All within time window\n    for (const a of result.assignments) {\n      expect(a.startTime).toBeGreaterThanOrEqual(540);\n      expect(a.endTime).toBeLessThanOrEqual(1020);\n    }\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":640,"cache_read_input_tokens":29545,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":640},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"19d32348-d71b-4c21-a504-e0597227717d","uuid":"5b6ba4a2-fcc1-4df5-8b80-5ccc20a6b1d9"}
