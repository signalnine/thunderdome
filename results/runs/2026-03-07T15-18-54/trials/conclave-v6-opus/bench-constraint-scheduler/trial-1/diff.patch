+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01C9gYCNamqQpdLu6DG2u7nB","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01XyeJNNZ3jJTVsN5KxjDWmM","name":"Write","input":{"file_path":"/workspace/src/scheduler.ts","content":"import { Event, Room, ScheduleOptions, Assignment, ScheduleResult } from './types.js';\n\n/**\n * Topological sort using Kahn's algorithm. Throws on cycles.\n * Returns event IDs in valid prerequisite order.\n */\nfunction topologicalSort(events: Event[]): string[] {\n  const inDegree = new Map<string, number>();\n  const adjacency = new Map<string, string[]>();\n  const eventMap = new Map<string, Event>();\n\n  for (const event of events) {\n    eventMap.set(event.id, event);\n    inDegree.set(event.id, 0);\n    adjacency.set(event.id, []);\n  }\n\n  for (const event of events) {\n    if (event.prerequisites) {\n      for (const prereq of event.prerequisites) {\n        if (prereq === event.id) {\n          throw new Error(`Cycle detected: event \"${event.id}\" has a self-referencing prerequisite`);\n        }\n        if (eventMap.has(prereq)) {\n          adjacency.get(prereq)!.push(event.id);\n          inDegree.set(event.id, inDegree.get(event.id)! + 1);\n        }\n      }\n    }\n  }\n\n  const queue: string[] = [];\n  for (const [id, degree] of inDegree) {\n    if (degree === 0) {\n      queue.push(id);\n    }\n  }\n\n  const sorted: string[] = [];\n  while (queue.length > 0) {\n    const current = queue.shift()!;\n    sorted.push(current);\n    for (const neighbor of adjacency.get(current)!) {\n      const newDegree = inDegree.get(neighbor)! - 1;\n      inDegree.set(neighbor, newDegree);\n      if (newDegree === 0) {\n        queue.push(neighbor);\n      }\n    }\n  }\n\n  if (sorted.length !== events.length) {\n    throw new Error('Cycle detected in prerequisite graph');\n  }\n\n  return sorted;\n}\n\n/**\n * Compute topological depth (level) for each event.\n * Events with no prerequisites have depth 0.\n * Events depending on depth-N events have depth N+1.\n */\nfunction computeTopoDepth(events: Event[], eventMap: Map<string, Event>): Map<string, number> {\n  const depth = new Map<string, number>();\n\n  function getDepth(id: string): number {\n    if (depth.has(id)) return depth.get(id)!;\n    const event = eventMap.get(id);\n    if (!event || !event.prerequisites || event.prerequisites.length === 0) {\n      depth.set(id, 0);\n      return 0;\n    }\n    let maxPrereqDepth = -1;\n    for (const prereqId of event.prerequisites) {\n      if (eventMap.has(prereqId)) {\n        maxPrereqDepth = Math.max(maxPrereqDepth, getDepth(prereqId));\n      }\n    }\n    const d = maxPrereqDepth + 1;\n    depth.set(id, d);\n    return d;\n  }\n\n  for (const event of events) {\n    getDepth(event.id);\n  }\n\n  return depth;\n}\n\n/**\n * Find the earliest valid start time for an event in a given room.\n */\nfunction findEarliestStart(\n  event: Event,\n  room: Room,\n  existingAssignments: Assignment[],\n  options: ScheduleOptions,\n  gap: number,\n  assignmentMap: Map<string, Assignment>\n): number | null {\n  const attendees = event.attendees ?? 1;\n  if (attendees > room.capacity) {\n    return null;\n  }\n\n  let earliest = options.startTime;\n  if (event.prerequisites) {\n    for (const prereqId of event.prerequisites) {\n      const prereqAssignment = assignmentMap.get(prereqId);\n      if (prereqAssignment) {\n        earliest = Math.max(earliest, prereqAssignment.endTime + gap);\n      }\n    }\n  }\n\n  const duration = event.duration;\n\n  if (earliest + duration > options.endTime) {\n    return null;\n  }\n\n  const roomAssignments = existingAssignments\n    .filter(a => a.roomId === room.id)\n    .sort((a, b) => a.startTime - b.startTime);\n\n  if (roomAssignments.length === 0) {\n    return earliest;\n  }\n\n  // Try to fit before the first assignment\n  if (earliest + duration + gap <= roomAssignments[0].startTime) {\n    return earliest;\n  }