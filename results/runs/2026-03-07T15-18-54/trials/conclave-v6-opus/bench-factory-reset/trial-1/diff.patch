+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const n = target.length;
+  const m = buttons.length;
+
+  if (n === 0) return [];
+  if (m === 0) return target.some(t => t) ? null : [];
+
+  // Build augmented matrix [A | b] over GF(2)
+  const matrix: Uint8Array[] = [];
+  for (let i = 0; i < n; i++) {
+    const row = new Uint8Array(m + 1);
+    for (let j = 0; j < m; j++) {
+      if (buttons[j].includes(i)) row[j] = 1;
+    }
+    row[m] = target[i] ? 1 : 0;
+    matrix.push(row);
+  }
+
+  // Gaussian elimination (RREF) over GF(2)
+  const pivotCols: number[] = [];
+  let curRow = 0;
+  for (let col = 0; col < m && curRow < n; col++) {
+    let pr = -1;
+    for (let r = curRow; r < n; r++) {
+      if (matrix[r][col]) { pr = r; break; }
+    }
+    if (pr === -1) continue;
+    [matrix[curRow], matrix[pr]] = [matrix[pr], matrix[curRow]];
+    for (let r = 0; r < n; r++) {
+      if (r !== curRow && matrix[r][col]) {
+        for (let c = 0; c <= m; c++) matrix[r][c] ^= matrix[curRow][c];
+      }
+    }
+    pivotCols.push(col);
+    curRow++;
+  }
+
+  const rank = pivotCols.length;
+
+  for (let r = rank; r < n; r++) {
+    if (matrix[r][m]) return null;
+  }
+
+  const pivotSet = new Set(pivotCols);
+  const freeVars: number[] = [];
+  for (let j = 0; j < m; j++) {
+    if (!pivotSet.has(j)) freeVars.push(j);
+  }
+  const numFree = freeVars.length;
+
+  const pivotFreeCoeffs: Uint8Array[] = [];
+  const pivotTargets = new Uint8Array(rank);
+  for (let r = 0; r < rank; r++) {
+    const coeffs = new Uint8Array(numFree);
+    for (let fi = 0; fi < numFree; fi++) coeffs[fi] = matrix[r][freeVars[fi]];
+    pivotFreeCoeffs.push(coeffs);
+    pivotTargets[r] = matrix[r][m];
+  }
+
+  if (numFree === 0) {
+    const pressed: number[] = [];
+    for (let r = 0; r < rank; r++) {
+      if (pivotTargets[r]) pressed.push(pivotCols[r]);
+    }
+    return pressed;
+  }
+
+  if (numFree <= 25) {
+    return grayCodeEnumGF2(pivotCols, freeVars, pivotFreeCoeffs, pivotTargets, m, rank, numFree);
+  }
+
+  return meetInMiddleGF2(pivotCols, freeVars, pivotFreeCoeffs, pivotTargets, m, rank, numFree);
+}
+
+function grayCodeEnumGF2(
+  pivotCols: number[],
+  freeVars: number[],
+  pivotFreeCoeffs: Uint8Array[],
+  pivotTargets: Uint8Array,
+  _m: number,
+  rank: number,
+  numFree: number
+): number[] {
+  const freeState = new Uint8Array(numFree);
+  const pivotState = new Uint8Array(rank);
+  for (let r = 0; r < rank; r++) pivotState[r] = pivotTargets[r];
+
+  let pressCount = 0;
+  for (let r = 0; r < rank; r++) {
+    if (pivotState[r]) pressCount++;
+  }
+
+  let bestPressed = collectPressed(pivotCols, freeVars, pivotState, freeState, rank, numFree);
+  let bestCount = pressCount;
+
+  const total = 1 << numFree;
+  for (let i = 1; i < total; i++) {
+    const flipBit = ctz(i);
+
+    if (freeState[flipBit]) {
+      freeState[flipBit] = 0;
+      pressCount--;
+    } else {
+      freeState[flipBit] = 1;
+      pressCount++;
+    }
+
+    for (let r = 0; r < rank; r++) {
+      if (pivotFreeCoeffs[r][flipBit]) {
+        if (pivotState[r]) { pivotState[r] = 0; pressCount--; }
+        else { pivotState[r] = 1; pressCount++; }
+      }
+    }
+
+    if (pressCount < bestCount) {
+      bestCount = pressCount;
+      bestPressed = collectPressed(pivotCols, freeVars, pivotState, freeState, rank, numFree);
+    } else if (pressCount === bestCount) {
+      const current = collectPressed(pivotCols, freeVars, pivotState, freeState, rank, numFree);
+      if (lexSmallerArr(current, bestPressed)) {
+        bestPressed = current;
+      }
+    }
+  }
+
+  return bestPressed;
+}
+
+function meetInMiddleGF2(
+  pivotCols: number[],
+  freeVars: number[],
+  pivotFreeCoeffs: Uint8Array[],
+  pivotTargets: Uint8Array,
+  m: number,
+  rank: number,
+  numFree: number
+): number[] {
+  const halfA = Math.ceil(numFree / 2);
+  const halfB = numFree - halfA;
+
+  const freeEffect: number[] = [];
+  for (let fi = 0; fi < numFree; fi++) {
+    let e = 0;
+    for (let r = 0; r < rank; r++) {
+      if (pivotFreeCoeffs[r][fi]) e |= (1 << r);
+    }
+    freeEffect.push(e);
+  }
+
+  let targetSig = 0;
+  for (let r = 0; r < rank; r++) {
+    if (pivotTargets[r]) targetSig |= (1 << r);
+  }
+
+  interface Entry {
+    freeWeight: number;
+    freeIndices: number[];
+  }
+  const sizeA = 1 << halfA;
+  const mapA = new Map<number, Entry>();
+
+  for (let mask = 0; mask < sizeA; mask++) {
+    let sig = 0;
+    const indices: number[] = [];
+    for (let i = 0; i < halfA; i++) {
+      if (mask & (1 << i)) {
+        sig ^= freeEffect[i];
+        indices.push(freeVars[i]);
+      }
+    }
+    const entry: Entry = { freeWeight: indices.length, freeIndices: indices };
+    const existing = mapA.get(sig);
+    if (!existing || entry.freeWeight < existing.freeWeight ||
+        (entry.freeWeight === existing.freeWeight && lexSmallerArr(entry.freeIndices, existing.freeIndices))) {
+      mapA.set(sig, entry);
+    }
+  }
+
+  const mapAEntries: [number, Entry][] = [...mapA.entries()];
+
+  let bestPressed: number[] | null = null;
+  let bestCount = m + 1;
+
+  const sizeB = 1 << halfB;
+  for (let mask = 0; mask < sizeB; mask++) {
+    let sigB = 0;
+    const indicesB: number[] = [];
+    for (let i = 0; i < halfB; i++) {
+      if (mask & (1 << i)) {
+        sigB ^= freeEffect[halfA + i];
+        indicesB.push(freeVars[halfA + i]);
+      }
+    }
+    const freeWeightB = indicesB.length;
+    const adjustedTarget = targetSig ^ sigB;
+
+    for (let e = 0; e < mapAEntries.length; e++) {
+      const [sigA, entryA] = mapAEntries[e];
+      const combinedSig = adjustedTarget ^ sigA;
+      const pivotWeight = popcount32(combinedSig);
+      const totalWeight = entryA.freeWeight + freeWeightB + pivotWeight;
+
+      if (totalWeight < bestCount) {
+        bestCount = totalWeight;
+        bestPressed = buildFullSolution(pivotCols, entryA.freeIndices, indicesB, combinedSig, rank);
+      } else if (totalWeight === bestCount) {
+        const current = buildFullSolution(pivotCols, entryA.freeIndices, indicesB, combinedSig, rank);
+        if (lexSmallerArr(current, bestPressed!)) {
+          bestPressed = current;
+        }
+      }
+    }
+  }
+
+  return bestPressed!;
+}
+
+function buildFullSolution(
+  pivotCols: number[],
+  freeIndicesA: number[],
+  freeIndicesB: number[],
+  pivotSig: number,
+  rank: number
+): number[] {
+  const all: number[] = [];
+  for (const idx of freeIndicesA) all.push(idx);
+  for (const idx of freeIndicesB) all.push(idx);
+  for (let r = 0; r < rank; r++) {
+    if (pivotSig & (1 << r)) all.push(pivotCols[r]);
+  }
+  all.sort((a, b) => a - b);
+  return all;
+}
+
+function popcount32(x: number): number {
+  x = x - ((x >> 1) & 0x55555555);
+  x = (x & 0x33333333) + ((x >> 2) & 0x33333333);
+  return (((x + (x >> 4)) & 0x0f0f0f0f) * 0x01010101) >> 24;
+}
+
+function collectPressed(
+  pivotCols: number[],
+  freeVars: number[],
+  pivotState: Uint8Array,
+  freeState: Uint8Array,
+  rank: number,
+  numFree: number
+): number[] {
+  const pressed: number[] = [];
+  let pi = 0, fi = 0;
+  while (pi < rank || fi < numFree) {
+    const pv = pi < rank ? pivotCols[pi] : Infinity;
+    const fv = fi < numFree ? freeVars[fi] : Infinity;
+    if (pv < fv) {
+      if (pivotState[pi]) pressed.push(pv);
+      pi++;
+    } else {
+      if (freeState[fi]) pressed.push(fv);
+      fi++;
+    }
+  }
+  return pressed;
+}
+
+function ctz(x: number): number {
+  if (x === 0) return 32;
+  let count = 0;
+  while ((x & 1) === 0) { count++; x >>= 1; }
+  return count;
+}
+
+function lexSmallerArr(a: number[], b: number[]): boolean {
+  const len = Math.min(a.length, b.length);
+  for (let i = 0; i < len; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return a.length < b.length;
+}
+
+// --- GF(p) Gaussian elimination for solveCounter ---
+
+function modPow(base: number, exp: number, p: number): number {
+  let result = 1;
+  base = ((base % p) + p) % p;
+  while (exp > 0) {
+    if (exp & 1) result = (result * base) % p;
+    exp >>= 1;
+    base = (base * base) % p;
+  }
+  return result;
+}
+
+function modInverse(a: number, p: number): number {
+  return modPow(a, p - 2, p);
+}
+
+function mod(a: number, p: number): number {
+  return ((a % p) + p) % p;
+}
+
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const n = lights.length;
+  const m = buttons.length;
+  const p = modulus;
+
+  if (n === 0) return new Array(m).fill(0);
+  if (m === 0) return lights.some(v => v % p !== 0) ? null : [];
+
+  // Build augmented matrix [A | b] over GF(p)
+  const matrix: number[][] = [];
+  for (let i = 0; i < n; i++) {
+    const row = new Array(m + 1).fill(0);
+    for (let j = 0; j < m; j++) {
+      if (buttons[j].includes(i)) row[j] = 1;
+    }
+    row[m] = mod(lights[i], p);
+    matrix.push(row);
+  }
+
+  // Gaussian elimination (RREF) over GF(p)
+  const pivotCols: number[] = [];
+  let curRow = 0;
+  for (let col = 0; col < m && curRow < n; col++) {
+    let pr = -1;
+    for (let r = curRow; r < n; r++) {
+      if (matrix[r][col] !== 0) { pr = r; break; }
+    }
+    if (pr === -1) continue;
+    [matrix[curRow], matrix[pr]] = [matrix[pr], matrix[curRow]];
+
+    const inv = modInverse(matrix[curRow][col], p);
+    for (let c = 0; c <= m; c++) {
+      matrix[curRow][c] = mod(matrix[curRow][c] * inv, p);
+    }
+
+    for (let r = 0; r < n; r++) {
+      if (r !== curRow && matrix[r][col] !== 0) {
+        const factor = matrix[r][col];
+        for (let c = 0; c <= m; c++) {
+          matrix[r][c] = mod(matrix[r][c] - factor * matrix[curRow][c], p);
+        }
+      }
+    }
+
+    pivotCols.push(col);
+    curRow++;
+  }
+
+  const rank = pivotCols.length;
+
+  for (let r = rank; r < n; r++) {
+    if (matrix[r][m] !== 0) return null;
+  }
+
+  const pivotSet = new Set(pivotCols);
+  const freeVars: number[] = [];
+  for (let j = 0; j < m; j++) {
+    if (!pivotSet.has(j)) freeVars.push(j);
+  }
+  const numFree = freeVars.length;
+
+  const pivotFreeCoeffs: number[][] = [];
+  const pivotTargets: number[] = [];
+  for (let r = 0; r < rank; r++) {
+    const coeffs: number[] = [];
+    for (let fi = 0; fi < numFree; fi++) {
+      coeffs.push(matrix[r][freeVars[fi]]);
+    }
+    pivotFreeCoeffs.push(coeffs);
+    pivotTargets.push(matrix[r][m]);
+  }
+
+  if (numFree === 0) {
+    const result = new Array(m).fill(0);
+    for (let r = 0; r < rank; r++) {
+      result[pivotCols[r]] = pivotTargets[r];
+    }
+    return result;
+  }
+
+  // Check if direct enumeration is feasible (p^numFree <= threshold)
+  let totalCombos = 1;
+  let feasible = true;
+  for (let i = 0; i < numFree; i++) {
+    totalCombos *= p;
+    if (totalCombos > 5e7) { feasible = false; break; }
+  }
+
+  if (feasible) {
+    return enumerateFreeVarsGFp(pivotCols, freeVars, pivotFreeCoeffs, pivotTargets, m, rank, numFree, p);
+  }
+
+  return meetInMiddleGFp(pivotCols, freeVars, pivotFreeCoeffs, pivotTargets, m, rank, numFree, p);
+}
+
+function enumerateFreeVarsGFp(
+  pivotCols: number[],
+  freeVars: number[],
+  pivotFreeCoeffs: number[][],
+  pivotTargets: number[],
+  m: number,
+  rank: number,
+  numFree: number,
+  p: number
+): number[] {
+  const freeVals = new Int32Array(numFree);
+  const pivotVals = new Int32Array(rank);
+  let freeSum = 0;
+  let pivotSum = 0;
+
+  for (let r = 0; r < rank; r++) {
+    pivotVals[r] = pivotTargets[r];
+    pivotSum += pivotVals[r];
+  }
+
+  let bestResult = buildResultGFp(pivotCols, freeVars, pivotVals, freeVals, m, rank, numFree);
+  let bestTotal = freeSum + pivotSum;
+
+  let totalCombinations = 1;
+  for (let i = 0; i < numFree; i++) {
+    totalCombinations *= p;
+    if (totalCombinations > 2e9) { totalCombinations = 2e9; break; }
+  }
+
+  for (let iter = 1; iter < totalCombinations; iter++) {
+    for (let fi = numFree - 1; fi >= 0; fi--) {
+      freeVals[fi]++;
+      freeSum++;
+
+      for (let r = 0; r < rank; r++) {
+        if (pivotFreeCoeffs[r][fi] !== 0) {
+          const oldPV = pivotVals[r];
+          pivotVals[r] = (oldPV - pivotFreeCoeffs[r][fi] + p) % p;
+          pivotSum += pivotVals[r] - oldPV;
+        }
+      }
+
+      if (freeVals[fi] < p) break;
+
+      // Wrap: freeVals went from p-1 to p; reset to 0
+      // The +1 mod p on the free val correctly propagates to pivot updates above
+      freeVals[fi] = 0;
+      freeSum -= p;
+
+      if (fi === 0) break;
+    }
+
+    const total = freeSum + pivotSum;
+    if (total < bestTotal) {
+      bestTotal = total;
+      bestResult = buildResultGFp(pivotCols, freeVars, pivotVals, freeVals, m, rank, numFree);
+    } else if (total === bestTotal) {
+      const current = buildResultGFp(pivotCols, freeVars, pivotVals, freeVals, m, rank, numFree);
+      if (lexSmallerArr(current, bestResult)) {
+        bestResult = current;
+      }
+    }
+  }
+
+  return bestResult;
+}
+
+function buildResultGFp(
+  pivotCols: number[],
+  freeVars: number[],
+  pivotVals: Int32Array,
+  freeVals: Int32Array,
+  m: number,
+  rank: number,
+  numFree: number
+): number[] {
+  const result = new Array(m).fill(0);
+  for (let r = 0; r < rank; r++) result[pivotCols[r]] = pivotVals[r];
+  for (let fi = 0; fi < numFree; fi++) result[freeVars[fi]] = freeVals[fi];
+  return result;
+}
+
+function meetInMiddleGFp(
+  pivotCols: number[],
+  freeVars: number[],
+  pivotFreeCoeffs: number[][],
+  pivotTargets: number[],
+  m: number,
+  rank: number,
+  numFree: number,
+  p: number
+): number[] {
+  const halfA = Math.floor(numFree / 2);
+  const halfB = numFree - halfA;
+
+  interface HalfEntry {
+    freeSum: number;
+    freeVals: number[];
+    effect: number[];
+  }
+
+  const mapA = new Map<string, HalfEntry>();
+
+  // Enumerate half A assignments, storing best per effect vector
+  const valsA = new Array(halfA).fill(0);
+  const effectA = new Array(rank).fill(0);
+
+  const storeA = () => {
+    const key = effectA.join(',');
+    const freeSum = valsA.reduce((s: number, v: number) => s + v, 0);
+    const existing = mapA.get(key);
+    if (!existing || freeSum < existing.freeSum ||
+        (freeSum === existing.freeSum && lexSmallerArr(valsA, existing.freeVals))) {
+      mapA.set(key, { freeSum, freeVals: [...valsA], effect: [...effectA] });
+    }
+  };
+
+  storeA();
+  let totalHalfA = 1;
+  for (let i = 0; i < halfA; i++) totalHalfA *= p;
+
+  for (let iter = 1; iter < totalHalfA; iter++) {
+    for (let fi = halfA - 1; fi >= 0; fi--) {
+      valsA[fi]++;
+      for (let r = 0; r < rank; r++) {
+        effectA[r] = (effectA[r] + pivotFreeCoeffs[r][fi]) % p;
+      }
+      if (valsA[fi] < p) break;
+      valsA[fi] = 0;
+      if (fi === 0) break;
+    }
+    storeA();
+  }
+
+  // Enumerate half B, combine with best half A entries
+  let bestResult: number[] | null = null;
+  let bestTotal = Infinity;
+
+  const valsB = new Array(halfB).fill(0);
+  const effectB = new Array(rank).fill(0);
+
+  const processB = () => {
+    const freeSumB = valsB.reduce((s: number, v: number) => s + v, 0);
+
+    for (const [, entryA] of mapA) {
+      let pivotSum = 0;
+      const pivotVals: number[] = [];
+      for (let r = 0; r < rank; r++) {
+        const pv = ((pivotTargets[r] - entryA.effect[r] - effectB[r]) % p + p) % p;
+        pivotVals.push(pv);
+        pivotSum += pv;
+      }
+
+      const total = entryA.freeSum + freeSumB + pivotSum;
+
+      if (total <= bestTotal) {
+        const result = new Array(m).fill(0);
+        for (let r = 0; r < rank; r++) result[pivotCols[r]] = pivotVals[r];
+        for (let i = 0; i < halfA; i++) result[freeVars[i]] = entryA.freeVals[i];
+        for (let i = 0; i < halfB; i++) result[freeVars[halfA + i]] = valsB[i];
+
+        if (total < bestTotal || lexSmallerArr(result, bestResult!)) {
+          bestTotal = total;
+          bestResult = result;
+        }
+      }
+    }
+  };
+
+  processB();
+
+  let totalHalfB = 1;
+  for (let i = 0; i < halfB; i++) totalHalfB *= p;
+
+  for (let iter = 1; iter < totalHalfB; iter++) {
+    for (let fi = halfB - 1; fi >= 0; fi--) {
+      valsB[fi]++;
+      for (let r = 0; r < rank; r++) {
+        effectB[r] = (effectB[r] + pivotFreeCoeffs[r][halfA + fi]) % p;
+      }
+      if (valsB[fi] < p) break;
+      valsB[fi] = 0;
+      if (fi === 0) break;
+    }
+    processB();
+  }
+
+  return bestResult!;
+}
