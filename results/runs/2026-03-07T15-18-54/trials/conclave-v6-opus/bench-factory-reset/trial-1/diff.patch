eToggle ---\n\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const n = target.length; // number of lights\n  const m = buttons.length; // number of buttons\n\n  if (n === 0) return [];\n  if (m === 0) return target.some(t => t) ? null : [];\n\n  // Build augmented matrix [A | b] over GF(2)\n  // Rows = lights, Columns = buttons + 1 (augmented)\n  // A[i][j] = 1 if button j toggles light i\n  // b[i] = target[i]\n  const matrix: Uint8Array[] = [];\n  for (let i = 0; i < n; i++) {\n    const row = new Uint8Array(m + 1);\n    for (let j = 0; j < m; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    row[m] = target[i] ? 1 : 0;\n    matrix.push(row);\n  }\n\n  // Gaussian elimination with full pivoting (RREF) over GF(2)\n  const pivotCols: number[] = [];\n  let curRow = 0;\n  for (let col = 0; col < m && curRow < n; col++) {\n    let pr = -1;\n    for (let r = curRow; r < n; r++) {\n      if (matrix[r][col] === 1) { pr = r; break; }\n    }\n    if (pr === -1) continue;\n\n    [matrix[curRow], matrix[pr]] = [matrix[pr], matrix[curRow]];\n\n    for (let r = 0; r < n; r++) {\n      if (r !== curRow && matrix[r][col] === 1) {\n        for (let c = 0; c <= m; c++) {\n          matrix[r][c] ^= matrix[curRow][c];\n        }\n      }\n    }\n\n    pivotCols.push(col);\n    curRow++;\n  }\n\n  const rank = pivotCols.length;\n\n  // Check for inconsistency\n  for (let r = rank; r < n; r++) {\n    if (matrix[r][m] === 1) return null;\n  }\n\n  // Identify free variables\n  const pivotSet = new Set(pivotCols);\n  const freeVars: number[] = [];\n  for (let j = 0; j < m; j++) {\n    if (!pivotSet.has(j)) freeVars.push(j);\n  }\n\n  const numFree = freeVars.length;\n\n  // Precompute: for each pivot row r, which free variables appear in that row?\n  // After RREF, matrix[r] has 1 at pivotCols[r] and possibly at free variable columns.\n  // pivotVal[r] = matrix[r][m] XOR (sum over free vars fi: matrix[r][freeVars[fi]] * x[fi])\n  // We store the free-variable coefficients for each pivot row.\n  const pivotFreeCoeffs: Uint8Array[] = [];\n  const pivotTargets: Uint8Array = new Uint8Array(rank);\n  for (let r = 0; r < rank; r++) {\n    const coeffs = new Uint8Array(numFree);\n    for (let fi = 0; fi < numFree; fi++) {\n      coeffs[fi] = matrix[r][freeVars[fi]];\n    }\n    pivotFreeCoeffs.push(coeffs);\n    pivotTargets[r] = matrix[r][m];\n  }\n\n  if (numFree <= 20) {\n    return enumerateFreeVarsGF2(pivotCols, freeVars, pivotFreeCoeffs, pivotTargets, m, rank, numFree);\n  }\n\n  return meetInMiddleGF2(pivotCols, freeVars, pivotFreeCoeffs, pivotTargets, m, rank, numFree);\n}\n\nfunction enumerateFreeVarsGF2(\n  pivotCols: number[],\n  freeVars: number[],\n  pivotFreeCoeffs: Uint8Array[],\n  pivotTargets: Uint8Array,\n  m: number,\n  rank: number,\n  numFree: number\n): number[] {\n  let bestPressed: number[] | null = null;\n  let bestCount = m + 1;\n\n  const total = 1 << numFree;\n  for (let mask = 0; mask < total; mask++) {\n    const pressed: number[] = [];\n\n    // Free variable presses\n    for (let fi = 0; fi < numFree; fi++) {\n      if (mask & (1 << fi)) {\n        pressed.push(freeVars[fi]);\n      }\n    }\n\n    // Pivot variable presses (back-substitute)\n    for (let r = 0; r < rank; r++) {\n      let val = pivotTargets[r];\n      for (let fi = 0; fi < numFree; fi++) {\n        if ((mask & (1 << fi)) && pivotFreeCoeffs[r][fi]) {\n          val ^= 1;\n        }\n      }\n      if (val === 1) {\n        pressed.push(pivotCols[r]);\n      }\n    }\n\n    pressed.sort((a, b) => a - b);\n    const count = pressed.length;\n\n    if (count < bestCount || (count === bestCount && lexSmallerArr(pressed, bestPressed!))) {\n      bestCount = count;\n      bestPressed = pressed;\n    }\n  }\n\n  return bestPressed!;\n}\n\nfunction meetInMiddleGF2(\n  pivotCols: number[],\n  freeVars: number[],\n  pivotFreeCoeffs: Uint8Array[],\n  pivotTargets: Uint8Arr