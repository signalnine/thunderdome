+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter } from './index.js';
+
+describe('solveToggle', () => {
+  it('returns empty array when target is all off', () => {
+    const result = solveToggle({
+      target: [false, false, false],
+      buttons: [[0, 1], [1, 2]],
+    });
+    expect(result).toEqual([]);
+  });
+
+  it('returns single button when it exactly matches target', () => {
+    const result = solveToggle({
+      target: [true, true, false],
+      buttons: [[0, 1]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('returns null when no solution exists (example from TASK.md)', () => {
+    // target [T, T, F, T], buttons: {0,1}, {1,2,3}, {0,3}
+    // System has no solution (verified in task description)
+    const result = solveToggle({
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]],
+    });
+    expect(result).toBeNull();
+  });
+
+  it('returns minimum number of button presses', () => {
+    // Light 0 needs to be on. Button 0 toggles [0], Button 1 toggles [0].
+    // Both work with 1 press, but button 0 is lex smallest.
+    const result = solveToggle({
+      target: [true],
+      buttons: [[0], [0]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('returns lexicographically smallest when tied on press count', () => {
+    // 2 lights, target [true, true]
+    // Button 0: toggles [0, 1] -> solution [0] (1 press)
+    // Button 1: toggles [0], Button 2: toggles [1] -> solution [1,2] (2 presses)
+    // Minimum is [0]
+    const result = solveToggle({
+      target: [true, true],
+      buttons: [[0, 1], [0], [1]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('handles multiple buttons needed', () => {
+    // 3 lights, target [true, false, true]
+    // Button 0: [0, 1], Button 1: [1, 2]
+    // Press both: light 0=on, light 1=on^on=off, light 2=on => [T, F, T] ✓
+    const result = solveToggle({
+      target: [true, false, true],
+      buttons: [[0, 1], [1, 2]],
+    });
+    expect(result).toEqual([0, 1]);
+  });
+
+  it('handles case with no buttons and non-trivial target', () => {
+    const result = solveToggle({
+      target: [true],
+      buttons: [],
+    });
+    expect(result).toBeNull();
+  });
+
+  it('handles case with no lights', () => {
+    const result = solveToggle({
+      target: [],
+      buttons: [],
+    });
+    expect(result).toEqual([]);
+  });
+
+  it('prefers fewer presses over lex order', () => {
+    // 2 lights, target [true, true]
+    // Button 0: [0], Button 1: [1], Button 2: [0, 1]
+    // Solutions: [0, 1] (2 presses) or [2] (1 press)
+    // Minimum presses wins: [2]
+    const result = solveToggle({
+      target: [true, true],
+      buttons: [[0], [1], [0, 1]],
+    });
+    expect(result).toEqual([2]);
+  });
+
+  it('handles large identity-like system', () => {
+    // 20 lights, each button toggles exactly one light, target all on
+    const n = 20;
+    const target = Array(n).fill(true);
+    const buttons = Array.from({ length: n }, (_, i) => [i]);
+    const result = solveToggle({ target, buttons });
+    expect(result).toEqual(Array.from({ length: n }, (_, i) => i));
+  });
+
+  it('handles redundant buttons correctly', () => {
+    // Target: [true, false]
+    // Button 0: [0], Button 1: [0, 1], Button 2: [1]
+    // Solution with 1 press: [0]. Solution with 2 presses: [1, 2].
+    // Minimum: [0]
+    const result = solveToggle({
+      target: [true, false],
+      buttons: [[0], [0, 1], [1]],
+    });
+    expect(result).toEqual([0]);
+  });
+});
+
+describe('solveCounter', () => {
+  it('returns all zeros when target is all zero', () => {
+    const result = solveCounter([0, 0, 0], [[0, 1], [1, 2]], 5);
+    expect(result).toEqual([0, 0]);
+  });
+
+  it('returns single button press for simple target', () => {
+    // 1 counter, target = 3 mod 5
+    // Button 0 increments counter 0. Press 3 times.
+    const result = solveCounter([3], [[0]], 5);
+    expect(result).toEqual([3]);
+  });
+
+  it('returns null when no solution exists', () => {
+    // 2 counters, both buttons increment both counters
+    // target [1, 2] mod 3: button 0 adds [1,1], button 1 adds [1,1]
+    // Any combo gives [a+b, a+b] mod 3, can't get [1, 2]
+    const result = solveCounter([1, 2], [[0, 1], [0, 1]], 3);
+    expect(result).toBeNull();
+  });
+
+  it('handles identity-like system', () => {
+    // 3 counters, 3 buttons, each button increments one counter
+    // target [2, 3, 1] mod 5
+    const result = solveCounter([2, 3, 1], [[0], [1], [2]], 5);
+    expect(result).toEqual([2, 3, 1]);
+  });
+
+  it('minimizes total presses', () => {
+    // 1 counter, target = 1 mod 5
+    // Button 0 increments counter 0. Press 1 time.
+    // But also: pressing 6 times = 1 mod 5 (but max is 4)
+    const result = solveCounter([1], [[0]], 5);
+    expect(result).toEqual([1]);
+  });
+
+  it('prefers lower total presses using modular inverse', () => {
+    // 1 counter, target = 4 mod 5
+    // Button 0 increments counter 0. Press 4 times.
+    // That's 4 presses. Alternatively... no other button.
+    const result = solveCounter([4], [[0]], 5);
+    expect(result).toEqual([4]);
+  });
+
+  it('handles multiple buttons affecting same counter', () => {
+    // 1 counter, target = 1 mod 3
+    // Button 0: [0], Button 1: [0]
+    // Solutions: (1,0)=1 press, (0,1)=1 press, (2,2)=4 presses
+    // Min total = 1, lex smallest = [0, 1] (button 1 pressed once) wait...
+    // result[0]=1, result[1]=0 gives total 1, array [1, 0]
+    // result[0]=0, result[1]=1 gives total 1, array [0, 1]
+    // Lex smallest: [0, 1] < [1, 0]
+    const result = solveCounter([1], [[0], [0]], 3);
+    expect(result).toEqual([0, 1]);
+  });
+
+  it('handles system with 2 counters and 2 buttons', () => {
+    // Counter 0 target=1, Counter 1 target=2, mod 3
+    // Button 0: [0] (increments counter 0)
+    // Button 1: [1] (increments counter 1)
+    // Solution: press button 0 once, button 1 twice = [1, 2]
+    const result = solveCounter([1, 2], [[0], [1]], 3);
+    expect(result).toEqual([1, 2]);
+  });
+
+  it('handles overlapping buttons', () => {
+    // 2 counters, target [1, 1] mod 3
+    // Button 0: [0, 1] increments both
+    // Solution: press once = [1], total = 1
+    const result = solveCounter([1, 1], [[0, 1]], 3);
+    expect(result).toEqual([1]);
+  });
+
+  it('returns null with no buttons and non-zero target', () => {
+    const result = solveCounter([1], [], 3);
+    expect(result).toBeNull();
+  });
+
+  it('returns empty array with no counters', () => {
+    const result = solveCounter([], [], 3);
+    expect(result).toEqual([]);
+  });
+
+  it('handles modulus 2 (binary)', () => {
+    // Equivalent to toggle: 2 counters, target [1, 0]
+    // Button 0: [0, 1], Button 1: [1]
+    // Press button 0 once and button 1 once: counter 0 = 1, counter 1 = 1+1 = 0 mod 2
+    const result = solveCounter([1, 0], [[0, 1], [1]], 2);
+    expect(result).toEqual([1, 1]);
+  });
+
+  it('handles larger modulus', () => {
+    // 1 counter, target = 5 mod 7
+    // Button 0: [0], press 5 times
+    const result = solveCounter([5], [[0]], 7);
+    expect(result).toEqual([5]);
+  });
+
+  it('finds solution with minimum total when free variables exist', () => {
+    // 1 counter, target = 0 mod 5
+    // Button 0: [0], Button 1: [0]
+    // All zeros is optimal (total = 0)
+    const result = solveCounter([0], [[0], [0]], 5);
+    expect(result).toEqual([0, 0]);
+  });
+});
