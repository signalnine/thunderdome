iling zeros of i","+    const flipBit = ctz(i);","+","+    // Toggle this free variable","+    if (freeState[flipBit]) {","+      freeState[flipBit] = 0;","+      pressCount--;","+    } else {","+      freeState[flipBit] = 1;","+      pressCount++;","+    }","+","+    // Update pivot states affected by this free variable","     for (let r = 0; r < rank; r++) {","-      const tv = (targetSig >> r) & 1;","-      const fv = (combinedFreeSig >> r) & 1;","-      if (tv ^ fv) {","-        pivotBits |= (1 << pivotCol[r]);","+      if (pivotFreeCoeffs[r][flipBit]) {","+        if (pivotState[r]) {","+          pivotState[r] = 0;","+          pressCount--;","+        } else {","+          pivotState[r] = 1;","+          pressCount++;","+        }","       }","     }"," ","-    const fullSolution = totalFreeBits | pivotBits;","-    const totalWeight = popcount(fullSolution);","-","-    if (totalWeight < bestWeight ||","-        (totalWeight === bestWeight && lexCompareSolutions(fullSolution, bestSolution, numButtons) < 0)) {","-      bestWeight = totalWeight;","-      bestSolution = fullSolution;","+    if (pressCount < bestCount) {","+      bestCount = pressCount;","+      bestPressed = collectPressed(pivotCols, freeVars, pivotState, freeState, rank, numFree);","+    } else if (pressCount === bestCount) {","+      const current = collectPressed(pivotCols, freeVars, pivotState, freeState, rank, numFree);","+      if (lexSmallerArr(current, bestPressed!)) {","+        bestPressed = current;","+      }","     }","   }"," ","-  return bestSolution === -1 ? [] : solutionToIndices(bestSolution, numButtons);","+  return bestPressed!;"," }"," ","-function lexCompareBitmasks(a: number, b: number, numBits: number): number {","-  for (let j = 0; j < numBits; j++) {","-    const bitA = (a >> j) & 1;","-    const bitB = (b >> j) & 1;","-    if (bitA && !bitB) return -1;","-    if (!bitA && bitB) return 1;","+function collectPressed(","+  pivotCols: number[],","+  freeVars: number[],","+  pivotState: Uint8Array,","+  freeState: Uint8Array,","+  rank: number,","+  numFree: number","+): number[] {","+  const pressed: number[] = [];","+  // Merge pivot and free indices in sorted order","+  let pi = 0, fi = 0;","+  while (pi < rank || fi < numFree) {","+    const pv = pi < rank ? pivotCols[pi] : Infinity;","+    const fv = fi < numFree ? freeVars[fi] : Infinity;","+    if (pv < fv) {","+      if (pivotState[pi]) pressed.push(pv);","+      pi++;","+    } else {","+      if (freeState[fi]) pressed.push(fv);","+      fi++;","+    }","   }","-  return 0;","+  return pressed;"," }"," ","-function lexSmaller(a: number[], b: number[]): boolean {","+function ctz(x: number): number {","+  if (x === 0) return 32;","+  let count = 0;","+  while ((x & 1) === 0) {","+    count++;","+    x >>= 1;","+  }","+  return count;","+}","+","+function lexSmallerArr(a: number[], b: number[]): boolean {","   const len = Math.min(a.length, b.length);","   for (let i = 0; i < len; i++) {","     if (a[i] < b[i]) return true;"]}],"originalFile":"export interface Machine {\n  target: boolean[];\n  buttons: number[][];\n}\n\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const numLights = target.length;\n  const numButtons = buttons.length;\n\n  if (numLights === 0) return [];\n  if (numButtons === 0) {\n    return target.some(t => t) ? null : [];\n  }\n\n  // Build augmented matrix over GF(2) using bitmasks\n  // Each row represents a light equation. Bit j = 1 means button j appears.\n  // Bit numButtons = augmented column (target value).\n  const matrix: number[] = new Array(numLights);\n  for (let i = 0; i < numLights; i++) {\n    let row = 0;\n    for (let j = 0; j < numButtons; j++) {\n      if (buttons[j].includes(i)) {\n        row |= (1 << j);\n      }\n    }\n    if (target[i]) {\n      row |= (1 << numButtons);\n    }\n    matrix[i] = row;\n  }\n\n  // Gaussian elimination over GF(2)\n  const pivotCol: number[] = [];\n  let pivotRow = 0;\n  for (let col = 0; col < numButtons && pivotRow < numLights; col++) {\n    // Find row with 1 in this column\n    let found = -1;\n    for (let r = pivotRow; r < numLights; r++) {\n      if (matrix[r] & (1 << col)) {\n        found = r;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    // Swap\n    [matrix[pivotRow], matrix[found]] = [matrix[found], matrix[pivotRow]];\n\n    // Eliminate\n    for (let r = 0; r < numLights; r++) {\n      if (r !== pivotRow && (matrix[r] & (1 << col))) {\n        matrix[r] ^= matrix[pivotRow];\n      }\n    }\n\n    pivotCol.push(col);\n    pivotRow++;\n  }\n\n  const rank = pivotCol.length;\n\n  // Check inconsistency\n  const augBit = 1 << numButtons;\n  for (let r = rank; r < numLights; r++) {\n    if (matrix[r] & augBit) {\n      return null;\n    }\n  }\n\n  // Find free variables\n  const pivotSet = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let j = 0; j < numButtons; j++) {\n    if (!pivotSet.has(j)) {\n      freeVars.push(j);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  // For each assignment of free variables, compute the full solution\n  // and find minimum weight, then lexicographically smallest\n  if (numFree <= 20) {\n    return enumerateFreeVars(matrix, pivotCol, freeVars, numButtons, rank);\n  }\n\n  // Meet in the middle for large free variable count\n  return meetInTheMiddle(matrix, pivotCol, freeVars, numButtons, rank);\n}\n\nfunction computeSolution(\n  matrix: number[],\n  pivotCol: number[],\n  freeVars: number[],\n  freeAssignment: number,\n  numButtons: number,\n  rank: number\n): number {\n  let solution = 0;\n  const augBit = 1 << numButtons;\n\n  // Set free variables\n  for (let i = 0; i < freeVars.length; i++) {\n    if (freeAssignment & (1 << i)) {\n      solution |= (1 << freeVars[i]);\n    }\n  }\n\n  // Back-substitute pivot variables\n  for (let r = rank - 1; r >= 0; r--) {\n    const pc = pivotCol[r];\n    // Value = augmente