n [];\n  if (m === 0) return target.some(t => t) ? null : [];\n\n  // Build augmented matrix [A | b] over GF(2)\n  // Rows = lights, Columns = buttons + 1 (augmented)\n  // A[i][j] = 1 if button j toggles light i\n  // b[i] = target[i]\n  const matrix: Uint8Array[] = [];\n  for (let i = 0; i < n; i++) {\n    const row = new Uint8Array(m + 1);\n    for (let j = 0; j < m; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    row[m] = target[i] ? 1 : 0;\n    matrix.push(row);\n  }\n\n  // Gaussian elimination with full pivoting (RREF) over GF(2)\n  const pivotCols: number[] = [];\n  let curRow = 0;\n  for (let col = 0; col < m && curRow < n; col++) {\n    let pr = -1;\n    for (let r = curRow; r < n; r++) {\n      if (matrix[r][col] === 1) { pr = r; break; }\n    }\n    if (pr === -1) continue;\n\n    [matrix[curRow], matrix[pr]] = [matrix[pr], matrix[curRow]];\n\n    for (let r = 0; r < n; r++) {\n      if (r !== curRow && matrix[r][col] === 1) {\n        for (let c = 0; c <= m; c++) {\n          matrix[r][c] ^= matrix[curRow][c];\n        }\n      }\n    }\n\n    pivotCols.push(col);\n    curRow++;\n  }\n\n  const rank = pivotCols.length;\n\n  // Check for inconsistency\n  for (let r = rank; r < n; r++) {\n    if (matrix[r][m] === 1) return null;\n  }\n\n  // Identify free variables\n  const pivotSet = new Set(pivotCols);\n  const freeVars: number[] = [];\n  for (let j = 0; j < m; j++) {\n    if (!pivotSet.has(j)) freeVars.push(j);\n  }\n\n  const numFree = freeVars.length;\n\n  // Precompute: for each pivot row r, which free variables appear in that row?\n  // After RREF, matrix[r] has 1 at pivotCols[r] and possibly at free variable columns.\n  // pivotVal[r] = matrix[r][m] XOR (sum over free vars fi: matrix[r][freeVars[fi]] * x[fi])\n  // We store the free-variable coefficients for each pivot row.\n  const pivotFreeCoeffs: Uint8Array[] = [];\n  const pivotTargets: Uint8Array = new Uint8Array(rank);\n  for (let r = 0; r < rank; r++) {\n    const coeffs = new Uint8Array(numFree);\n    for (let fi = 0; fi < numFree; fi++) {\n      coeffs[fi] = matrix[r][freeVars[fi]];\n    }\n    pivotFreeCoeffs.push(coeffs);\n    pivotTargets[r] = matrix[r][m];\n  }\n\n  if (numFree <= 20) {\n    return enumerateFreeVarsGF2(pivotCols, freeVars, pivotFreeCoeffs, pivotTargets, m, rank, numFree);\n  }\n\n  return meetInMiddleGF2(pivotCols, freeVars, pivotFreeCoeffs, pivotTargets, m, rank, numFree);\n}\n\nfunction enumerateFreeVarsGF2(\n  pivotCols: number[],\n  freeVars: number[],\n  pivotFreeCoeffs: Uint8Array[],\n  pivotTargets: Uint8Array,\n  m: number,\n  rank: number,\n  numFree: number\n): number[] {\n  let bestPressed: number[] | null = null;\n  let bestCount = m + 1;\n\n  const total = 1 << numFree;\n  for (let mask = 0; mask < total; mask++) {\n    const pressed: number[] = [];\n\n    // Free variable presses\n    for (let fi = 0; fi < numFree; fi++) {\n      if (mask & (1 << fi)) {\n        pressed.push(freeVars[fi]);\n      }\n    }\n\n    // Pivot variable presses (back-substitute)\n    for (let r = 0; r < rank; r++) {\n      let val = pivotTargets[r];\n      for (let fi = 0; fi < numFree; fi++) {\n        if ((mask & (1 << fi)) && pivotFreeCoeffs[r][fi]) {\n          val ^= 1;\n        }\n      }\n      if (val === 1) {\n        pressed.push(pivotCols[r]);\n      }\n    }\n\n    pressed.sort((a, b) => a - b);\n    const count = pressed.length;\n\n    if (count < bestCount || (count === bestCount && lexSmallerArr(pressed, bestPressed!))) {\n      bestCount = count;\n      bestPressed = pressed;\n    }\n  }\n\n  return bestPressed!;\n}\n\nfunction meetInMiddleGF2(\n  pivotCols: number[],\n  freeVars: number[],\n  pivotFreeCoeffs: Uint8Array[],\n  pivotTargets: Uint8Array,\n  m: number,\n  rank: number,\n  numFree: number\n): number[] {\n  // Split free variables into two halves\n  const halfA = Math.min(20, Math.floor(numFree / 2));\n  const halfB = numFree - halfA;\n\n  // For each free variable fi, compute its \"effect\" on pivot rows as a bitmask over rank bits.\n  // effect[fi] has bit r set if pivotFreeCoeffs[r][fi] = 1\n  const effect: number[] = new Array(numFree);\n  for (let fi = 0; fi < numFree; fi++) {\n    let e = 0;\n    for (let r = 0; r < rank; r++) {\n      if (pivotFreeCoeffs[r][fi]) {\n        e |= (1 << r);\n      }\n    }\n    effect[fi] = e;\n  }\n\n  // Target effect: bitmask of pivotTargets\n  let targetEffect = 0;\n  for (let r = 0; r < rank; r++) {\n    if (pivotTargets[r]) {\n      targetEffect |= (1 << r);\n    }\n  }\n\n  // Enumerate half A: for each assignment, compute signature (effect on pivot rows)\n  // and the list of free variable indices pressed.\n  // Group by signature, keeping only the best (min presses, lex smallest).\n  interface HalfEntry {\n    freeCount: number;\n    freeIndices: number[];\n    sig: number;\n  }\n\n  const sizeA = 1 << halfA;\n  const mapA = new Map<number, HalfEntry>();\n\n  for (let maskA = 0; maskA < sizeA; maskA++) {\n    let sig = 0;\n    const freeIndices: number[] = [];\n    for (let i = 0; i < halfA; i++) {\n      if (maskA & (1 << i)) {\n        sig ^= effect[i];\n        freeIndices.push(freeVars[i]);\n      }\n    }\n\n    const existing = mapA.get(sig);\n    const entry: HalfEntry = { freeCount: freeIndices.length, freeIndices, sig };\n    if (!existing || entry.freeCount < existing.freeCount ||\n        (entry.freeCount === existing.freeCount && lexSmallerArr(entry.freeIndices, existing.freeIndices))) {\n      mapA.set(sig, entry);\n    }\n  }\n\n  // Enumerate half B and combine with best half A\n  let bestPressed: number[] | null = null;\n  let bestCount = m + 1;\n\n  const sizeB = 1 << halfB;\n  for (let maskB = 0; maskB < sizeB; maskB++) {\n    let sigB = 0;\n    const freeBIndices: number[] = [];\n    for (let i = 0; i < halfB; i++) {\n      if (maskB & (1 << i)) {\n        sigB ^= effect[halfA + i];\n        freeBIndices.push(freeVars[halfA + i]);\n      }\n    }\n\n    // For a valid combination, the combined effect on pivots determines which pivots are pressed.\n    // pivotVal[r] = pivotTarget[r] XOR (bit r of (sigA XOR sigB))\n    // We need to find the sigA that minimizes total weight.\n    // But we can't just pick one sigA - different sigA values lead to different pivot weights.\n\n    // For each possible sigA (from mapA), compute total weight and pick the best.\n    // This would be O(sizeA * sizeB) which defeats the purpose.\n\n    // Better approach: we need to enumerate over all possible pivot-weight contributions.\n    // For a given sigB, we want to find the sigA from mapA that minimizes:\n    //   freeCountA + freeCountB + pivotWeight(sigA ^ sigB)\n    // where pivotWeight(combinedSig) = popcount(targetEffect ^ combinedSig)\n    //   (because pivotVal[r] = 1 iff targetEffect bit r != combinedSig bit r)\n\n    // So total = freeCountA + freeCountB + popcount(targetEffect ^ sigA ^ sigB)\n    // = freeCountA + popcount(targetEffect ^ sigB ^ sigA) + freeCountB\n\n    // Let adjustedTarget = targetEffect ^ sigB\n    // total = freeCountA + popcount(adjustedTarget ^ sigA) + freeCountB\n\n    // We want to minimize freeCountA + popcount(adjustedTarget ^ sigA) over all sigA in mapA.\n    // This is a lookup problem. We can't easily precompute this for all possible adjustedTargets.\n\n    // However, since rank <= 40 and we're using bitmasks of rank bits, there are at most 2^rank\n    // possible signatures. For rank <= 20, we can precompute.\n    // For rank > 20... we'd need another approach.\n\n    // For now, let's iterate over all entries in mapA (at most 2^halfA entries, but we deduplicated\n    // to at most 2^rank entries). Since rank <= 40 and halfA <= 20, mapA has at most 2^20 entries.\n    // With halfB also <= 20, this gives 2^20 * 2^20 = 2^40 which is too slow.\n\n    // Alternative: precompute for each signature, the best freeCountA.\n    // Then for each maskB, compute adjustedTarget = targetEffect ^ sigB,\n    // and we need 