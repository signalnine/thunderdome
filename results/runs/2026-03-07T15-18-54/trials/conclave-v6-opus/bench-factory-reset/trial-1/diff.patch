hts; r++) {\n    if (matrix[r] & augBit) {\n      return null;\n    }\n  }\n\n  // Find free variables\n  const pivotSet = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let j = 0; j < numButtons; j++) {\n    if (!pivotSet.has(j)) {\n      freeVars.push(j);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  // For each assignment of free variables, compute the full solution\n  // and find minimum weight, then lexicographically smallest\n  if (numFree <= 20) {\n    return enumerateFreeVars(matrix, pivotCol, freeVars, numButtons, rank);\n  }\n\n  // Meet in the middle for large free variable count\n  return meetInTheMiddle(matrix, pivotCol, freeVars, numButtons, rank);\n}\n\nfunction computeSolution(\n  matrix: number[],\n  pivotCol: number[],\n  freeVars: number[],\n  freeAssignment: number,\n  numButtons: number,\n  rank: number\n): number {\n  let solution = 0;\n  const augBit = 1 << numButtons;\n\n  // Set free variables\n  for (let i = 0; i < freeVars.length; i++) {\n    if (freeAssignment & (1 << i)) {\n      solution |= (1 << freeVars[i]);\n    }\n  }\n\n  // Back-substitute pivot variables\n  for (let r = rank - 1; r >= 0; r--) {\n    const pc = pivotCol[r];\n    // Value = augmented bit XOR dot product of row with solution (excluding pivot column)\n    const rowWithoutPivot = matrix[r] & ~(1 << pc) & ~augBit;\n    const targetBit = (matrix[r] & augBit) ? 1 : 0;\n    const dotProduct = popcount(rowWithoutPivot & solution) & 1;\n    if (targetBit ^ dotProduct) {\n      solution |= (1 << pc);\n    }\n  }\n\n  return solution;\n}\n\nfunction solutionToIndices(solution: number, numButtons: number): number[] {\n  const indices: number[] = [];\n  for (let j = 0; j < numButtons; j++) {\n    if (solution & (1 << j)) {\n      indices.push(j);\n    }\n  }\n  return indices;\n}\n\nfunction popcount(x: number): number {\n  x = x - ((x >> 1) & 0x55555555);\n  x = (x & 0x33333333) + ((x >> 2) & 0x33333333);\n  return (((x + (x >> 4)) & 0x0f0f0f0f) * 0x0101