y the best entry (min weight, then lex smallest freeBits)\n  for (const [sig, entries] of mapA) {\n    entries.sort((a, b) => {\n      if (a.weight !== b.weight) return a.weight - b.weight;\n      // Lex compare on freeBits\n      return lexCompareBitmasks(a.freeBits, b.freeBits, numButtons);\n    });\n    mapA.set(sig, [entries[0]]);\n  }\n\n  let bestSolution = -1;\n  let bestWeight = numButtons + 1;\n\n  // Enumerate half B\n  const sizeB = 1 << halfB;\n  for (let maskB = 0; maskB < sizeB; maskB++) {\n    let sigB = 0;\n    let freeBitsB = 0;\n    let freeWeightB = 0;\n    for (let i = 0; i < halfB; i++) {\n      if (maskB & (1 << i)) {\n        sigB ^= freeEffect[halfA + i];\n        freeBitsB |= (1 << freeVars[halfA + i]);\n        freeWeightB++;\n      }\n    }\n\n    // We need sigA XOR sigB = targetSig, so sigA = targetSig XOR sigB\n    const neededSigA = targetSig ^ sigB;\n    const entries = mapA.get(neededSigA);\n    if (!entries) continue;\n\n    const bestA = entries[0];\n    const totalFreeBits = bestA.freeBits | freeBitsB;\n\n    // Compute pivot bits from the combined signature\n    const combinedSig = neededSigA ^ sigB; // = targetSig, but let's compute pivot values\n    // Actually: each pivot var = target XOR contribution = (targetSig bit r) XOR (combined free contribution bit r)\n    // Combined free contribution = neededSigA XOR sigB... no.\n    // pivotVal[r] = target[r] XOR (sum of free var contributions)\n    // The sum of free var contributions for row r = bit r of (sigA XOR sigB)\n    // So pivotVal[r] = (targetSig >> r & 1) XOR ((neededSigA ^ sigB) >> r & 1)\n    // But neededSigA = targetSig ^ sigB, so neededSigA ^ sigB = targetSig ^ sigB ^ sigB = targetSig\n    // So pivotVal[r] = (targetSig >> r & 1) XOR (targetSig >> r & 1) = 0 ???\n    // That can't be right. Let me re-derive.\n\n    // pivotVal[r] = target[r] XOR dot(row[r], freeVarSolution)\n    // dot(row[r], freeVarSolution) = XOR of (matrix[r] & freeVars[i]) for i where freeVars[