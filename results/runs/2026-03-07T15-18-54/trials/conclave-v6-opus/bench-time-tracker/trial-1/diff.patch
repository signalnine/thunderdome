hrow();\n    });\n\n    test('starting a new timer auto-stops the previous one', () => {\n      tracker.start('task-a');\n      tracker.start('task-b');\n      const entries = tracker.getEntries();\n      expect(entries).toHaveLength(2);\n      expect(entries[0].endTime).not.toBeNull();\n      expect(entries[1].endTime).toBeNull();\n      expect(entries[1].taskName).toBe('task-b');\n    });\n  });\n\n  describe('stopping timers', () => {\n    test('stop sets endTime on the running entry', () => {\n      tracker.start('coding');\n      tracker.stop();\n      const entries = tracker.getEntries();\n      expect(entries).toHaveLength(1);\n      expect(entries[0].endTime).not.toBeNull();\n      expect(new Date(entries[0].endTime!).getTime()).not.toBeNaN();\n    });\n\n    test('stop when nothing is running throws an error', () => {\n      expect(() => tracker.stop()).toThrow();\n    });\n\n    test('stopping twice throws on second call', () => {\n      tracker.start('coding');\n      tracker.stop();\n      expect(() => tracker.stop()).toThrow();\n    });\n  });\n\n  describe('persistence', () => {\n    test('entries survive across instances', () => {\n      tracker.start('coding');\n      tracker.stop();\n\n      const tracker2 = new TimeTracker(filePath);\n      const entries = tracker2.getEntries();\n      expect(entries).toHaveLength(1);\n      expect(entries[0].taskName).toBe('coding');\n      expect(entries[0].endTime).not.toBeNull();\n    });\n\n    test('creates parent directories if they do not exist', () => {\n      const nestedPath = path.join(tmpDir, 'a', 'b', 'c', 'data.json');\n      const t = new TimeTracker(nestedPath);\n      t.start('test');\n      t.stop();\n\n      expect(fs.existsSync(nestedPath)).toBe(true);\n      const t2 = new TimeTracker(nestedPath);\n      expect(t2.getEntries()).toHaveLength(1);\n    });\n\n    test('data is saved as valid JSON', () => {\n      tracker.start('coding');\n      tracker.stop();\n\n      const raw = fs.readFileSync(filePath, 'utf-8');\n      const data = JSON.parse(raw);\n      expect(Array.isArray(data)).toBe(true);\n      expect(data[0].taskName).toBe('coding');\n    });\n  });\n\n  describe('querying entries', () => {\n    test('getEntries returns all entries', () => {\n      tracker.start('a');\n      tracker.stop();\n      tracker.start('b');\n      tracker.stop();\n      tracker.start('c');\n      tracker.stop();\n\n      expect(tracker.getEntries()).toHaveLength(3);\n    });\n\n    test('getEntries filters by from date', () => {\n      // Create entries with known times\n      tracker.start('old-task');\n      tracker.stop();\n\n      const entries = tracker.getEntries();\n      const entryTime = new Date(entries[0].startTime);\n\n      // Filter with a date after the entry\n      const futureDate = new Date(entryTime.getTime() + 60000);\n      const filtered = tracker.getEntries({ from: futureDate });\n      expect(filtered).toHaveLength(0);\n\n      // Filter with a date before the entry\n      const pastDate = new Date(entryTime.getTime() - 60000);\n      const filtered2 = tracker.getEntries({ from: pastDate });\n      expect(filtered2).toHaveLength(1);\n    });\n\n    test('getEntries filters by to date', () => {\n      tracker.start('task');\n      tracker.stop();\n\n      const entries = tracker.getEntries();\n      const entryTime = new Date(entries[0].startTime);\n\n      // Filter with a date before the entry\n      const pastDate = new Date(entryTime.getTime() - 60000);\n      const filtered = tracker.getEntries({ to: pastDate });\n      expect(filtered).toHaveLength(0);\n\n      // Filter with a date after the entry\n      const futureDate = new Date(entryTime.getTime() + 60000);\n      const filtered2 = tracker.getEntries({ to: futureDate });\n      expect(filtered2).toHaveLength(1);\n    });\n\n    test('getEntries filters by both from and to', () => {\n      tracker.start('task');\n      tracker.stop();\n\n      const entries = tracker.getEntries();\n      const entryTime = new Date(entries[0].startTime);\n\n      const from = new Date(entryTime.getTime() - 60000);\n      const to = new Date(entryTime.getTime() + 60000);\n      expect(tracker.getEntries({ from, to })).toHaveLength(1);\n\n      // Narrow window that excludes the entry\n      const narrowFrom = new Date(entryTime.getTime() + 10000);\n      const narrowTo = new Date(entryTime.getTime() + 20000);\n      expect(tracker.getEntries({ from: narrowFrom, to: narrowTo })).toHaveLength(0);\n    });\n  });\n\n  describe('summarizing time', () => {\n    test('getSummary returns total ms per task name', () => {\n      // We'll manipulate entries directly for precise control\n      tracker.start('coding');\n      tracker.stop();\n      tracker.start('review');\n      tracker.stop();\n\n      const summary = tracker.getSummary();\n      expect(summary).toHaveProperty('coding');\n      expect(summary).toHaveProperty('review');\n      expect(typeof summary['coding']).toBe('number');\n      expect(summary['coding']).toBeGreaterThanOrEqual(0);\n    });\n\n    test('getSummary sums multiple entries with the same task name', () => {\n      tracker.start('coding');\n      tracker.stop();\n      tracker.start('coding');\n      tracker.stop();\n\n      const entries = tracker.getEntries();\n      const expected =\n        (new Date(entries[0].endTime!).getTime() - new Date(entries[0].startTime).getTime()) +\n        (new Date(entries[1].endTime!).getTime() - new Date(entries[1].startTime).getTime());\n\n      const summary = tracker.getSummary();\n      expect(summary['coding']).toBe(expected);\n    });\n\n    test('getSummary uses current time for running tasks', () => {\n      tracker.start('coding');\n      // Do not stop — still running\n\n      const before = Date.now();\n      const summary = tracker.getSummary();\n      const after = Date.now();\n\n      const entries = tracker.getEntries();\n      const startMs = new Date(entries[0].startTime).getTime();\n\n      expect(summary['coding']).toBeGreaterThanOrEqual(before - startMs);\n      expect(summary['coding']).toBeLessThanOrEqual(after - startMs);\n    });\n  });\n\n  describe('unicode support', () => {\n    test('supports emoji in task names', () => {\n      tracker.start('🚀 deploy');\n      tracker.stop();\n\n      const entries = tracker.getEntries();\n      expect(entries[0].taskName).toBe('🚀 deploy');\n    });\n\n    test('supports CJK characters in task names', () => {\n      tracker.start('日本語タスク');\n      tracker.stop();\n\n      const entries = tracker.getEntries();\n      expect(entries[0].taskName).toBe('日本語タスク');\n    });\n\n    test('unicode task names persist correctly', () => {\n      tracker.start('café ☕ break');\n      tracker.stop();\n\n      const tracker2 = new TimeTracker(filePath);\n      const entries = tracker2.getEntries();\n      expect(entries[0].taskName).toBe('café ☕ break');\n    });\n\n    test('summary works with unicode task names', () => {\n      tracker.start('🎯 focus');\n      tracker.stop();\n      tracker.start('🎯 focus');\n      tracker.stop();\n\n      const summary = tracker.getSummary();\n      expect(summary).toHaveProperty('🎯 focus');\n    });\n  });\n});\n","structuredPatch":[{"oldStart":3,"oldLines":7,"newStart":3,"newLines":6,"lines":[" import * as path from 'node:path';"," import * as os from 'node:os';"," import { TimeTracker } from './tracker.js';","-import type { TimeEntry } from './types.js';"," "," function makeTmpDir(): string {","   return fs.mkdtempSync(path.join(os.tmpdir(), 'time-tracker-test-'));"]}],"userModified":false,"replaceAll":false}}
