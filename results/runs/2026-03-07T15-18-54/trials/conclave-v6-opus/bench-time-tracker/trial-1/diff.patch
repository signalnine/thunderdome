+++ b/src/tracker.test.ts
@@ -0,0 +1,260 @@
+import { describe, test, expect, beforeEach, afterEach } from 'vitest';
+import * as fs from 'node:fs';
+import * as path from 'node:path';
+import * as os from 'node:os';
+import { TimeTracker } from './tracker.js';
+
+function makeTmpDir(): string {
+  return fs.mkdtempSync(path.join(os.tmpdir(), 'time-tracker-test-'));
+}
+
+describe('TimeTracker', () => {
+  let tmpDir: string;
+  let filePath: string;
+  let tracker: TimeTracker;
+
+  beforeEach(() => {
+    tmpDir = makeTmpDir();
+    filePath = path.join(tmpDir, 'data.json');
+    tracker = new TimeTracker(filePath);
+  });
+
+  afterEach(() => {
+    fs.rmSync(tmpDir, { recursive: true, force: true });
+  });
+
+  describe('starting timers', () => {
+    test('start creates a new entry with task name and start time', () => {
+      tracker.start('coding');
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].taskName).toBe('coding');
+      expect(entries[0].startTime).toBeTypeOf('string');
+      expect(new Date(entries[0].startTime).getTime()).not.toBeNaN();
+      expect(entries[0].endTime).toBeNull();
+    });
+
+    test('start with empty name throws an error', () => {
+      expect(() => tracker.start('')).toThrow();
+    });
+
+    test('start with whitespace-only name throws an error', () => {
+      expect(() => tracker.start('   ')).toThrow();
+    });
+
