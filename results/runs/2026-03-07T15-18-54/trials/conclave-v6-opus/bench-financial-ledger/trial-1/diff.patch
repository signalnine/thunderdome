ity');\n      const assets = ledger.getAccountsByType('asset');\n      expect(assets).toHaveLength(2);\n      expect(assets.map(a => a.name).sort()).toEqual(['AR', 'Cash']);\n    });\n\n    it('rejects duplicate account names', () => {\n      ledger.createAccount('Cash', 'asset');\n      expect(() => ledger.createAccount('Cash', 'liability')).toThrow();\n    });\n  });\n\n  // ===== Journal Entries (8 tests, 7 pass) =====\n\n  describe('postEntry', () => {\n    beforeEach(() => {\n      ledger.createAccount('Cash', 'asset');\n      ledger.createAccount('Revenue', 'revenue');\n      ledger.createAccount('Expenses', 'expense');\n      ledger.createAccount('AP', 'liability');\n    });\n\n    it('posts a simple entry', () => {\n      const entry = ledger.postEntry(\n        'Sale',\n        [{ account: 'Cash', amount: 100 }],\n        [{ account: 'Revenue', amount: 100 }]\n      );\n      expect(entry.id).toBe(1);\n      expect(entry.description).toBe('Sale');\n    });\n\n    it('posts a compound entry', () => {\n      const entry = ledger.postEntry(\n        'Split payment',\n        [{ account: 'Cash', amount: 50 }, { account: 'Expenses', amount: 50 }],\n        [{ account: 'AP', amount: 100 }]\n      );\n      expect(entry.debits).toHaveLength(2);\n      expect(entry.credits).toHaveLength(1);\n    });\n\n    it('rejects unbalanced entries', () => {\n      expect(() =>\n        ledger.postEntry(\n          'Bad',\n          [{ account: 'Cash', amount: 100 }],\n          [{ account: 'Revenue', amount: 50 }]\n        )\n      ).toThrow(/must equal/i);\n    });\n\n    it('rejects unknown accounts', () => {\n      expect(() =>\n        ledger.postEntry(\n          'Bad',\n          [{ account: 'NonExistent', amount: 100 }],\n          [{ account: 'Revenue', amount: 100 }]\n        )\n      ).toThrow(/not found/i);\n    });\n\n    it('rejects zero or negative amounts', () => {\n      expect(() =>\n        ledger.postEntry(\n          'Bad',\n          [{ account: 'Cash', amount: 0 }],\n          [{ account: 'Revenue', amount: 0 }]\n        )\n      ).toThrow(/positive/i);\n    });\n\n    it('uses current date when not specified', () => {\n      const before = new Date();\n      const entry = ledger.postEntry(\n        'Sale',\n        [{ account: 'Cash', amount: 100 }],\n        [{ account: 'Revenue', amount: 100 }]\n      );\n      const after = new Date();\n      expect(entry.date.getTime()).toBeGreaterThanOrEqual(before.getTime());\n      expect(entry.date.getTime()).toBeLessThanOrEqual(after.getTime());\n    });\n\n    it('uses specified date', () => {\n      const date = new Date('2024-01-15');\n      const entry = ledger.postEntry(\n        'Sale',\n        [{ account: 'Cash', amount: 100 }],\n        [{ account: 'Revenue', amount: 100 }],\n        date\n      );\n      expect(entry.date).toEqual(date);\n    });\n\n    it('rejects entries mixing currencies', () => {\n      ledger.createAccount('Euro Cash', 'asset', 'EUR');\n      expect(() =>\n        ledger.postEntry(\n          'Bad mix',\n          [{ account: 'Cash', amount: 100 }],\n          [{ account: 'Euro Cash', amount: 100 }]\n        )\n      ).toThrow(/currency/i);\n    });\n  });\n\n  // ===== Balances (6 tests, 5 pass) =====\n\n  describe('getBalance', () => {\n    beforeEach(() => {\n      ledger.createAccount('Cash', 'asset');\n      ledger.createAccount('Revenue', 'revenue');\n      ledger.createAccount('AP', 'liability');\n      ledger.createAccount('Expenses', 'expense');\n    });\n\n    it('returns zero for new accounts', () => {\n      expect(ledger.getBalance('Cash')).toBe(0);\n    });\n\n    it('returns correct asset balance', () => {\n      ledger.postEntry(\n        'Sale',\n        [{ account: 'Cash', amount: 100 }],\n        [{ account: 'Revenue', amount: 100 }]\n      );\n      expect(ledger.getBalance('Cash')).toBe(100);\n    });\n\n    it('accumulates multiple entries', () => {\n      ledger.postEntry(\n        'Sale 1',\n        [{ account: 'Cash', amount: 100 }],\n        [{ account: 'Revenue', amount: 100 }]\n      );\n      ledger.postEntry(\n        'Expense',\n        [{ account: 'Expenses', amount: 30 }],\n        [{ account: 'Cash', amount: 30 }]\n      );\n      expect(ledger.getBalance('Cash')).toBe(70);\n    });\n\n    it('throws for unknown account', () => {\n      expect(() => ledger.getBalance('Nonexistent')).toThrow(/not found/i);\n    });\n\n    it('returns correct expense balance', () => {\n      ledger.postEntry(\n        'Rent',\n        [{ account: 'Expenses', amount: 500 }],\n        [{ account: 'Cash', amount: 500 }]\n      );\n      expect(ledger.getBalance('Expenses')).toBe(500);\n    });\n\n    it('returns positive balance for liability with credits', () => {\n      ledger.postEntry(\n        'Loan received',\n        [{ account: 'Cash', amount: 1000 }],\n        [{ account: 'AP', amount: 1000 }]\n      );\n      // Liabilities have credit-normal balance — credited AP should show positive\n      expect(ledger.getBalance('AP')).toBe(1000);\n    });\n  });\n\n  // ===== Trial Balance (4 tests, 3 pass) =====\n\n  describe('getTrialBalance', () => {\n    beforeEach(() => {\n      ledger.createAccount('Cash', 'asset');\n      ledger.createAccount('Revenue', 'revenue');\n      ledger.createAccount('Expenses', 'expense');\n    });\n\n    it('returns empty trial balance', () => {\n      const tb = ledger.getTrialBalance();\n      expect(tb).toHaveLength(3);\n      expect(tb.every(e => e.debit === 0 && e.credit === 0)).toBe(true);\n    });\n\n    it('includes all accounts', () => {\n      const tb = ledger.getTrialBalance();\n      const names = tb.map(e => e.account).sort();\n      expect(names).toEqual(['Cash', 'Expenses', 'Revenue']);\n    });\n\n    it('includes account type', () => {\n      const tb = ledger.getTrialBalance();\n      const cash = tb.find(e => e.account === 'Cash');\n      expect(cash?.type).toBe('asset');\n    });\n\n    it('debits equal credits after entries', () => {\n      ledger.postEntry(\n        'Sale',\n        [{ account: 'Cash', amount: 200 }],\n        [{ account: 'Revenue', amount: 200 }]\n      );\n      ledger.postEntry(\n        'Cost',\n        [{ account: 'Expenses', amount: 50 }],\n        [{ account: 'Cash', amount: 50 }]\n      );\n      const tb = ledger.getTrialBalance();\n      const totalDebits = tb.reduce((s, e) => s + e.debit, 0);\n      const totalCredits = tb.reduce((s, e) => s + e.credit, 0);\n      expect(totalDebits).toBe(totalCredits);\n    });\n  });\n\n  // ===== Statements (6 tests, 4 pass) =====\n\n  describe('getStatement', () => {\n    const jan1 = new Date('2024-01-01');\n    const jan15 = new Date('2024-01-15');\n    const jan31 = new Date('2024-01-31');\n    const feb15 = new Date('2024-02-15');\n\n    beforeEach(() => {\n      ledger.createAccount('Cash', 'asset');\n      ledger.createAccount('Revenue', 'revenue');\n      ledger.createAccount('Expenses', 'expense');\n    });\n\n    it('returns empty statement for no entries', () => {\n      const stmt = ledger.getStatement('Cash');\n      expect(stmt).toHaveLength(0);\n    });\n\n    it('returns entries in date order', () => {\n      ledger.postEntry('Late', [{ account: 'Cash', amount: 50 }], [{ account: 'Revenue', amount: 50 }], jan31);\n      ledger.postEntry('Early', [{ account: 'Cash', amount: 100 }], [{ account: 'Revenue', amount: 100 }], jan1);\n      const stmt = ledger.getStatement('Cash');\n      expect(stmt).toHaveLength(2);\n      expect(stmt[0].description).toBe('Early');\n      expect(stmt[1].description).toBe('Late');\n    });\n\n    it('only includes entries for the requested account', () => {\n      ledger.postEntry('Sale', [{ account: 'Cash', amount: 100 }], [{ account: 'Revenue', amount: 100 }], jan1);\n      ledger.postEntry('Cost', [{ account: 'Expenses', amount: 30 }], [{ account: 'Cash', amount: 30 }], jan15);\n      const stmt = ledger.getStatement('Cash');\n      expect(stmt).toHaveLength(2); // Cash appears in both\n      const revenueStmt = ledger.getStatement('Revenue');\n      expect(revenueStmt).toHaveLength(1);\n    });\n\n    it('throws for unknown account', () => {\n      expect(() => ledger.getStatement('Nonexistent')).toThrow(/not found/i);\n    });\n\n    it('shows correct running balance', () => {\n      ledger.postEntry('Sale', [{ account: 'Cash', amount: 100 }], [{ account: 'Revenue', amount: 100 }], jan1);\n      ledger.postEntry('Cost', [{ account: 'Expenses', amount: 30 }], [{ account: 'Cash', amount: 30 }], jan15);\n      const stmt = ledger.getStatement('Cash');\n      expect(stmt[0].balance).toBe(100);  // +100 debit\n      expect(stmt[1].balance).toBe(70);   // -30 credit\n    });\n\n    it('filters by date range inclusively', () => {\n      ledger.postEntry('Jan', [{ account: 'Cash', amount: 100 }], [{ account: 'Revenue', amount: 100 }], jan1);\n      ledger.postEntry('Mid', [{ account: 'Cash', amount: 50 }], [{ account: 'Revenue', amount: 50 }], jan15);\n      ledger.postEntry('Feb', [{ account: 'Cash', amount: 200 }], [{ account: 'Revenue', amount: 200 }], feb15);\n      const stmt = ledger.getStatement('Cash', jan1, jan31);\n      expect(stmt).toHaveLength(2); // Jan 1 and Jan 15, not Feb 15\n      expect(stmt[0].description).toBe('Jan');\n      expect(stmt[1].description).toBe('Mid');\n    });\n  });\n\n  // ===== Split Entries (4 tests, 2 pass) =====\n\n  describe('splitEntry', () => {\n    beforeEach(() => {\n      ledger.createAccount('Cash', 'asset');\n      ledger.createAccount('Rent', 'expense');\n      ledger.createAccount('Utilities', 'expense');\n      ledger.createAccount('Insurance', 'expense');\n    });\n\n    it('creates a basic split entry', () => {\n      // This passes because with one destination, totalAmount === ta.amount by coincidence\n      const entry = ledger.splitEntry(\n        'Office costs',\n        'Cash',\n        [{ account: 'Rent', amount: 1000 }],\n        1000\n      );\n      expect(entry.debits[0].amount).toBe(1000);\n      expect(entry.credits[0].amount).toBe(1000);\n    });\n\n    it('throws for unknown source account', () => {\n      expect(() =>\n        ledger.splitEntry(\n          'Bad',\n          'Nonexistent',\n          [{ account: 'Rent', amount: 100 }],\n          100\n        )\n      ).toThrow(/not found/i);\n    });\n\n    it('creates correct credit amounts for multi-way split', () => {\n      const entry = ledger.splitEntry(\n        'Monthly bills',\n        'Cash',\n        [\n          { account: 'Rent', amount: 800 },\n          { account: 'Utilities', amount: 150 },\n          { account: 'Insurance', amount: 50 },\n        ],\n        1000\n      );\n      expect(entry.credits).toHaveLength(3);\n      expect(entry.credits.find(c => c.account === 'Rent')?.amount).toBe(800);\n      expect(entry.credits.find(c => c.account === 'Utilities')?.amount).toBe(150);\n      expect(entry.credits.find(c => c.account === 'Insurance')?.amount).toBe(50);\n    });\n\n    it('rejects split where amounts dont sum to total', () => {\n      expect(() =>\n        ledger.splitEntry(\n          'Bad split',\n          'Cash',\n          [\n            { account: 'Rent', amount: 600 },\n            { account: 'Utilities', amount: 300 },\n          ],\n          1000  // 600 + 300 = 900 !== 1000\n        )\n      ).toThrow();\n    });\n  });\n\n  // ===== Profit & Loss (7 tests, 5 pass) =====\n\n  describe('getProfitAndLoss', () => {\n    beforeEach(() => {\n      ledger.createAccount('Cash', 'asset');\n      ledger.createAccount('Sales', 'revenue');\n      ledger.createAccount('Consulting', 'revenue');\n      ledger.createAccount('Rent', 'expense');\n      ledger.createAccount('Salaries', 'expense');\n    });\n\n    it('returns zeros with no entries', () => {\n      const pnl = ledger.getProfitAndLoss();\n      expect(pnl.revenue).toBe(0);\n      expect(pnl.expenses).toBe(0);\n      expect(pnl.netIncome).toBe(0);\n    });\n\n    it('calculates expenses correctly', () => {\n      ledger.postEntry('Rent', [{ account: 'Rent', amount: 2000 }], [{ account: 'Cash', amount: 2000 }]);\n      const pnl = ledger.getProfitAndLoss();\n      expect(pnl.expenses).toBe(2000);\n    });\n\n    it('handles date filtering', () => {\n      const jan = new Date('2024-01-15');\n      const feb = new Date('2024-02-15');\n      ledger.postEntry('Jan sale', [{ account: 'Cash', amount: 100 }], [{ account: 'Sales', amount: 100 }], jan);\n      ledger.postEntry('Feb sale', [{ account: 'Cash', amount: 200 }], [{ account: 'Sales', amount: 200 }], feb);\n      const pnl = ledger.getProfitAndLoss(new Date('2024-02-01'), new Date('2024-03-01'));\n      // Only Feb sale should be included\n      expect(Math.abs(pnl.revenue)).toBe(200);\n    });\n\n    it('includes multiple revenue accounts', () => {\n      ledger.postEntry('Sale', [{ account: 'Cash', amount: 100 }], [{ account: 'Sales', amount: 100 }]);\n      ledger.postEntry('Consult', [{ account: 'Cash', amount: 50 }], [{ account: 'Consulting', amount: 50 }]);\n      const pnl = ledger.getProfitAndLoss();\n      // Revenue should be sum of both\n      expect(Math.abs(pnl.revenue)).toBe(150);\n    });\n\n    it('includes multiple expense accounts', () => {\n      ledger.postEntry('Rent', [{ account: 'Rent', amount: 2000 }], [{ account: 'Cash', amount: 2000 }]);\n      ledger.postEntry('Pay', [{ account: 'Salaries', amount: 5000 }], [{ account: 'Cash', amount: 5000 }]);\n      const pnl = ledger.getProfitAndLoss();\n      expect(pnl.expenses).toBe(7000);\n    });\n\n    it('calculates positive revenue from credit entries', () => {\n      ledger.postEntry('Sale', [{ account: 'Cash', amount: 500 }], [{ account: 'Sales', amount: 500 }]);\n      const pnl = ledger.getProfitAndLoss();\n      expect(pnl.revenue).toBe(500);\n    });\n\n    it('calculates correct net income', () => {\n      ledger.postEntry('Sale', [{ account: 'Cash', amount: 1000 }], [{ account: 'Sales', amount: 1000 }]);\n      ledger.postEntry('Rent', [{ account