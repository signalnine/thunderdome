+type Direction = 0 | 1 | 2; // 0=down, 1=down-left, 2=down-right
+
+function findSource(grid: string[][]): number {
+  for (let c = 0; c < grid[0].length; c++) {
+    if (grid[0][c] === 'S') return c;
+  }
+  throw new Error('No source found');
+}
+
+function beamKey(col: number, dir: Direction): number {
+  return col * 3 + dir;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const sCol = findSource(grid);
+  const visited = new Set<number>();
+  visited.add(sCol); // row 0, col sCol encoded as row * cols + col
+
+  // Active beams: Map from beamKey(col, dir) -> true
+  // Process row by row, advancing all beams simultaneously
+  let activeBeams = new Map<number, true>();
+  activeBeams.set(beamKey(sCol, 0), true); // down from source
+
+  for (let row = 0; row < rows && activeBeams.size > 0; row++) {
+    const nextBeams = new Map<number, true>();
+
+    for (const key of activeBeams.keys()) {
+      const dir = (key % 3) as Direction;
+      const col = (key - dir) / 3;
+
+      // Advance beam
+      const nextRow = row + 1;
+      let nextCol: number;
+      if (dir === 0) nextCol = col;
+      else if (dir === 1) nextCol = col - 1;
+      else nextCol = col + 1;
+
+      if (nextRow >= rows || nextCol < 0 || nextCol >= cols) continue;
+
+      visited.add(nextRow * cols + nextCol);
+      const cell = grid[nextRow][nextCol];
+
+      if (cell === '^') {
+        nextBeams.set(beamKey(nextCol, 1), true); // down-left
+        nextBeams.set(beamKey(nextCol, 2), true); // down-right
+      } else {
+        nextBeams.set(beamKey(nextCol, dir), true);
+      }
+    }
+
+    activeBeams = nextBeams;
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const sCol = findSource(grid);
+
+  let totalPaths = 0n;
+
+  // Active beams: Map from beamKey(col, dir) -> pathCount
+  let activeBeams = new Map<number, bigint>();
+  activeBeams.set(beamKey(sCol, 0), 1n); // down from source, 1 path
+
+  for (let row = 0; row < rows && activeBeams.size > 0; row++) {
+    const nextBeams = new Map<number, bigint>();
+
+    for (const [key, pathCount] of activeBeams) {
+      const dir = (key % 3) as Direction;
+      const col = (key - dir) / 3;
+
+      // Advance beam
+      const nextRow = row + 1;
+      let nextCol: number;
+      if (dir === 0) nextCol = col;
+      else if (dir === 1) nextCol = col - 1;
+      else nextCol = col + 1;
+
+      if (nextRow >= rows || nextCol < 0 || nextCol >= cols) {
+        totalPaths += pathCount;
+        continue;
+      }
+
+      const cell = grid[nextRow][nextCol];
+
+      if (cell === '^') {
+        const keyL = beamKey(nextCol, 1);
+        const keyR = beamKey(nextCol, 2);
+        nextBeams.set(keyL, (nextBeams.get(keyL) ?? 0n) + pathCount);
+        nextBeams.set(keyR, (nextBeams.get(keyR) ?? 0n) + pathCount);
+      } else {
+        const k = beamKey(nextCol, dir);
+        nextBeams.set(k, (nextBeams.get(k) ?? 0n) + pathCount);
+      }
+    }
+
+    activeBeams = nextBeams;
+  }
+
+  return totalPaths;
+}
