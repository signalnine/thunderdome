+import type { ASTNode } from './types.js';
+
+// Token types
+interface Token {
+  type: 'number' | 'string' | 'boolean' | 'cellref' | 'op' | 'lparen' | 'rparen' | 'comma' | 'colon' | 'ident';
+  value: string;
+}
+
+function tokenize(input: string): Token[] {
+  const tokens: Token[] = [];
+  let i = 0;
+
+  while (i < input.length) {
+    // Skip whitespace
+    if (input[i] === ' ' || input[i] === '\t') {
+      i++;
+      continue;
+    }
+
+    // String literal
+    if (input[i] === '"') {
+      let str = '';
+      i++; // skip opening quote
+      while (i < input.length && input[i] !== '"') {
+        str += input[i];
+        i++;
+      }
+      i++; // skip closing quote
+      tokens.push({ type: 'string', value: str });
+      continue;
+    }
+
+    // Number
+    if (input[i] >= '0' && input[i] <= '9') {
+      let num = '';
+      while (i < input.length && ((input[i] >= '0' && input[i] <= '9') || input[i] === '.')) {
+        num += input[i];
+        i++;
+      }
+      tokens.push({ type: 'number', value: num });
+      continue;
+    }
+
+    // Identifiers, cell references, booleans, and function names
+    if ((input[i] >= 'A' && input[i] <= 'Z') || (input[i] >= 'a' && input[i] <= 'z')) {
+      let ident = '';
+      while (i < input.length && (
+        (input[i] >= 'A' && input[i] <= 'Z') ||
+        (input[i] >= 'a' && input[i] <= 'z') ||
+        (input[i] >= '0' && input[i] <= '9')
+      )) {
+        ident += input[i];
+        i++;
+      }
+
+      // Check for boolean
+      if (ident.toLowerCase() === 'true') {
+        tokens.push({ type: 'boolean', value: 'true' });
+      } else if (ident.toLowerCase() === 'false') {
+        tokens.push({ type: 'boolean', value: 'false' });
+      } else if (/^[A-Za-z]+\d+$/.test(ident)) {
+        // Cell reference (letters followed by digits)
+        tokens.push({ type: 'cellref', value: ident.toUpperCase() });
+      } else {
+        // Function name or other identifier
+        tokens.push({ type: 'ident', value: ident.toUpperCase() });
+      }
+      continue;
+    }
+
+    // Two-character operators
+    if (i + 1 < input.length) {
+      const twoChar = input[i] + input[i + 1];
+      if (twoChar === '<>' || twoChar === '<=' || twoChar === '>=') {
+        tokens.push({ type: 'op', value: twoChar });
+        i += 2;
+        continue;
+      }
+    }
+
+    // Single character tokens
+    if (input[i] === '(') {
+      tokens.push({ type: 'lparen', value: '(' });
+      i++;
+    } else if (input[i] === ')') {
+      tokens.push({ type: 'rparen', value: ')' });
+      i++;
+    } else if (input[i] === ',') {
+      tokens.push({ type: 'comma', value: ',' });
+      i++;
+    } else if (input[i] === ':') {
+      tokens.push({ type: 'colon', value: ':' });
+      i++;
+    } else if ('+-*/><'.includes(input[i])) {
+      tokens.push({ type: 'op', value: input[i] });
+      i++;
+    } else if (input[i] === '=') {
+      tokens.push({ type: 'op', value: '=' });
+      i++;
+    } else {
+      throw new Error(`Unexpected character: ${input[i]}`);
+    }
+  }
+
+  return tokens;
+}
+
+class Parser {
+  private tokens: Token[];
+  private pos: number;
+
+  constructor(tokens: Token[]) {
+    this.tokens = tokens;
+    this.pos = 0;
+  }
+
+  private peek(): Token | undefined {
+    return this.tokens[this.pos];
+  }
+
+  private advance(): Token {
+    const token = this.tokens[this.pos];
+    this.pos++;
+    return token;
+  }
+
+  private expect(type: Token['type']): Token {
+    const token = this.peek();
+    if (!token || token.type !== type) {
+      throw new Error(`Expected ${type}, got ${token?.type ?? 'EOF'}`);
+    }
+    return this.advance();
+  }
+
+  parse(): ASTNode {
+    const node = this.parseComparison();
+    return node;
+  }
+
+  private parseComparison(): ASTNode {
+    let left = this.parseAddition();
+
+    while (this.peek()?.type === 'op' && ['>', '<', '>=', '<=', '=', '<>'].includes(this.peek()!.value)) {
+      const op = this.advance().value;
+      const right = this.parseAddition();
+      left = { type: 'binary', op, left, right };
+    }
+
+    return left;
+  }
+
+  private parseAddition(): ASTNode {
+    let left = this.parseMultiplication();
+
+    while (this.peek()?.type === 'op' && (this.peek()!.value === '+' || this.peek()!.value === '-')) {
+      const op = this.advance().value;
+      const right = this.parseMultiplication();
+      left = { type: 'binary', op, left, right };
+    }
+
+    return left;
+  }
+
+  private parseMultiplication(): ASTNode {
+    let left = this.parseUnary();
+
+    while (this.peek()?.type === 'op' && (this.peek()!.value === '*' || this.peek()!.value === '/')) {
+      const op = this.advance().value;
+      const right = this.parseUnary();
+      left = { type: 'binary', op, left, right };
+    }
+
+    return left;
+  }
+
+  private parseUnary(): ASTNode {
+    if (this.peek()?.type === 'op' && this.peek()!.value === '-') {
+      this.advance();
+      const operand = this.parseUnary();
+      return { type: 'unary', op: '-', operand };
+    }
+    return this.parsePrimary();
+  }
+
+  private parsePrimary(): ASTNode {
+    const token = this.peek();
+
+    if (!token) {
+      throw new Error('Unexpected end of expression');
+    }
+
+    // Number literal
+    if (token.type === 'number') {
+      this.advance();
+      return { type: 'number', value: parseFloat(token.value) };
+    }
+
+    // String literal
+    if (token.type === 'string') {
+      this.advance();
+      return { type: 'string', value: token.value };
+    }
+
+    // Boolean literal
+    if (token.type === 'boolean') {
+      this.advance();
+      return { type: 'boolean', value: token.value === 'true' };
+    }
+
+    // Cell reference (may be start of range if followed by colon)
+    if (token.type === 'cellref') {
+      this.advance();
+      if (this.peek()?.type === 'colon') {
+        this.advance(); // consume colon
+        const endToken = this.expect('cellref');
+        return { type: 'range', start: token.value, end: endToken.value };
+      }
+      return { type: 'cellref', ref: token.value };
+    }
+
+    // Function call
+    if (token.type === 'ident') {
+      this.advance();
+      this.expect('lparen');
+      const args: ASTNode[] = [];
+
+      if (this.peek()?.type !== 'rparen') {
+        args.push(this.parseComparison());
+        while (this.peek()?.type === 'comma') {
+          this.advance(); // consume comma
+          args.push(this.parseComparison());
+        }
+      }
+
+      this.expect('rparen');
+      return { type: 'function', name: token.value, args };
+    }
+
+    // Parenthesized expression
+    if (token.type === 'lparen') {
+      this.advance();
+      const node = this.parseComparison();
+      this.expect('rparen');
+      return node;
+    }
+
+    throw new Error(`Unexpected token: ${token.type} (${token.value})`);
+  }
+}
+
+export function parse(input: string): ASTNode {
+  const tokens = tokenize(input);
+  const parser = new Parser(tokens);
+  return parser.parse();
+}
