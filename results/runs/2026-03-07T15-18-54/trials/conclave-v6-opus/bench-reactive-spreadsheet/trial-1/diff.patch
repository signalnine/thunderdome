+++ b/src/index.ts
@@ -0,0 +1,383 @@
+import type { ASTNode, CellValue } from './types.js';
+import { parse } from './parser.js';
+import { expandRange } from './utils.js';
+
+interface CellData {
+  raw: string | number | boolean;
+  formula: ASTNode | null;
+  value: CellValue;
+}
+
+export class Spreadsheet {
+  private cells: Map<string, CellData> = new Map();
+  // cell -> set of cells it depends on
+  private dependencies: Map<string, Set<string>> = new Map();
+  // cell -> set of cells that depend on it
+  private dependents: Map<string, Set<string>> = new Map();
+
+  set(cell: string, value: string | number | boolean): void {
+    const key = cell.toUpperCase();
+
+    // Save old state for rollback
+    const oldDeps = this.dependencies.get(key);
+
+    let formula: ASTNode | null = null;
+    let newDeps = new Set<string>();
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      formula = parse(value.substring(1));
+      newDeps = this.extractDependencies(formula);
+    }
+
+    // Update dependency graph
+    this.removeDependencies(key);
+    this.dependencies.set(key, newDeps);
+    for (const dep of newDeps) {
+      if (!this.dependents.has(dep)) {
+        this.dependents.set(dep, new Set());
+      }
+      this.dependents.get(dep)!.add(key);
+    }
+
+    // Check for circular references
+    if (this.hasCycle(key)) {
+      // Rollback
+      this.removeDependencies(key);
+      if (oldDeps) {
+        this.dependencies.set(key, oldDeps);
+        for (const dep of oldDeps) {
+          if (!this.dependents.has(dep)) {
+            this.dependents.set(dep, new Set());
+          }
+          this.dependents.get(dep)!.add(key);
+        }
+      } else {
+        this.dependencies.delete(key);
+      }
+      throw new Error(`Circular reference detected for cell ${key}`);
+    }
+
+    // Evaluate the cell
+    const computedValue = formula ? this.evaluate(formula) : this.coerceRawValue(value);
+
+    this.cells.set(key, {
+      raw: value,
+      formula,
+      value: computedValue,
+    });
+
+    // Reactively update dependents
+    this.recalculateDependents(key);
+  }
+
+  get(cell: string): string | number | boolean | null {
+    const key = cell.toUpperCase();
+    const data = this.cells.get(key);
+    if (!data) return null;
+    return data.value;
+  }
+
+  getDisplay(cell: string): string {
+    const value = this.get(cell);
+    if (value === null) return '';
+    if (typeof value === 'boolean') return value ? 'TRUE' : 'FALSE';
+    return String(value);
+  }
+
+  getCells(): Map<string, CellValue> {
+    const result = new Map<string, CellValue>();
+    for (const [key, data] of this.cells) {
+      result.set(key, data.value);
+    }
+    return result;
+  }
+
+  private coerceRawValue(value: string | number | boolean): CellValue {
+    if (typeof value === 'number' || typeof value === 'boolean') {
+      return value;
+    }
+    // Plain string (non-formula)
+    return value;
+  }
+
+  private extractDependencies(node: ASTNode): Set<string> {
+    const deps = new Set<string>();
+
+    switch (node.type) {
+      case 'cellref':
+        deps.add(node.ref);
+        break;
+      case 'range': {
+        const cells = expandRange(node.start, node.end);
+        for (const c of cells) {
+          deps.add(c);
+        }
+        break;
+      }
+      case 'binary':
+        for (const d of this.extractDependencies(node.left)) deps.add(d);
+        for (const d of this.extractDependencies(node.right)) deps.add(d);
+        break;
+      case 'unary':
+        for (const d of this.extractDependencies(node.operand)) deps.add(d);
+        break;
+      case 'function':
+        for (const arg of node.args) {
+          for (const d of this.extractDependencies(arg)) deps.add(d);
+        }
+        break;
+    }
+
+    return deps;
+  }
+
+  private removeDependencies(key: string): void {
+    const oldDeps = this.dependencies.get(key);
+    if (oldDeps) {
+      for (const dep of oldDeps) {
+        this.dependents.get(dep)?.delete(key);
+      }
+      this.dependencies.delete(key);
+    }
+  }
+
+  private hasCycle(startCell: string): boolean {
+    const visited = new Set<string>();
+    const stack = [startCell];
+
+    while (stack.length > 0) {
+      const current = stack.pop()!;
+      const deps = this.dependencies.get(current);
+      if (!deps) continue;
+
+      for (const dep of deps) {
+        if (dep === startCell) return true;
+        if (!visited.has(dep)) {
+          visited.add(dep);
+          stack.push(dep);
+        }
+      }
+    }
+
+    return false;
+  }
+
+  private recalculateDependents(changedCell: string): void {
+    // Collect all transitive dependents
+    const order = this.topologicalSortDependents(changedCell);
+
+    for (const cellKey of order) {
+      const data = this.cells.get(cellKey);
+      if (data?.formula) {
+        data.value = this.evaluate(data.formula);
+      }
+    }
+  }
+
+  private topologicalSortDependents(startCell: string): string[] {
+    // BFS to find all transitive dependents
+    const allDependents = new Set<string>();
+    const queue = [startCell];
+
+    while (queue.length > 0) {
+      const current = queue.shift()!;
+      const deps = this.dependents.get(current);
+      if (!deps) continue;
+
+      for (const dep of deps) {
+        if (!allDependents.has(dep)) {
+          allDependents.add(dep);
+          queue.push(dep);
+        }
+      }
+    }
+
+    // Topological sort using Kahn's algorithm
+    // Calculate in-degree for each dependent (only counting edges within the dependent set)
+    const inDegree = new Map<string, number>();
+    for (const cell of allDependents) {
+      inDegree.set(cell, 0);
+    }
+
+    for (const cell of allDependents) {
+      const deps = this.dependencies.get(cell);
+      if (deps) {
+        for (const dep of deps) {
+          if (allDependents.has(dep)) {
+            inDegree.set(cell, (inDegree.get(cell) ?? 0) + 1);
+          }
+        }
+      }
+    }
+
+    const sorted: string[] = [];
+    const ready: string[] = [];
+
+    for (const [cell, degree] of inDegree) {
+      if (degree === 0) {
+        ready.push(cell);
+      }
+    }
+
+    while (ready.length > 0) {
+      const current = ready.shift()!;
+      sorted.push(current);
+
+      const deps = this.dependents.get(current);
+      if (deps) {
+        for (const dep of deps) {
+          if (allDependents.has(dep)) {
+            const newDegree = (inDegree.get(dep) ?? 0) - 1;
+            inDegree.set(dep, newDegree);
+            if (newDegree === 0) {
+              ready.push(dep);
+            }
+          }
+        }
+      }
+    }
+
+    return sorted;
+  }
+
+  private evaluate(node: ASTNode): CellValue {
+    switch (node.type) {
+      case 'number':
+        return node.value;
+      case 'string':
+        return node.value;
+      case 'boolean':
+        return node.value;
+      case 'cellref': {
+        const val = this.get(node.ref);
+        return val;
+      }
+      case 'binary':
+        return this.evaluateBinary(node.op, node.left, node.right);
+      case 'unary':
+        return this.evaluateUnary(node.op, node.operand);
+      case 'function':
+        return this.evaluateFunction(node.name, node.args);
+      case 'range':
+        throw new Error('Range cannot be evaluated as a standalone expression');
+    }
+  }
+
+  private evaluateBinary(op: string, left: ASTNode, right: ASTNode): CellValue {
+    const l = this.evaluate(left);
+    const r = this.evaluate(right);
+
+    // For arithmetic operations, coerce null to 0
+    const numL = typeof l === 'number' ? l : (l === null ? 0 : Number(l));
+    const numR = typeof r === 'number' ? r : (r === null ? 0 : Number(r));
+
+    switch (op) {
+      case '+': return numL + numR;
+      case '-': return numL - numR;
+      case '*': return numL * numR;
+      case '/': return numL / numR;
+      case '>': return numL > numR;
+      case '<': return numL < numR;
+      case '>=': return numL >= numR;
+      case '<=': return numL <= numR;
+      case '=': return l === r;
+      case '<>': return l !== r;
+      default:
+        throw new Error(`Unknown operator: ${op}`);
+    }
+  }
+
+  private evaluateUnary(op: string, operand: ASTNode): CellValue {
+    const val = this.evaluate(operand);
+    const num = typeof val === 'number' ? val : (val === null ? 0 : Number(val));
+
+    switch (op) {
+      case '-': return -num;
+      default:
+        throw new Error(`Unknown unary operator: ${op}`);
+    }
+  }
+
+  private evaluateFunction(name: string, args: ASTNode[]): CellValue {
+    switch (name) {
+      case 'SUM': return this.evalAggregate(args, (values) => {
+        return values.reduce((sum, v) => sum + v, 0);
+      });
+      case 'AVERAGE': return this.evalAggregate(args, (values) => {
+        if (values.length === 0) return 0;
+        return values.reduce((sum, v) => sum + v, 0) / values.length;
+      });
+      case 'MIN': return this.evalAggregate(args, (values) => {
+        if (values.length === 0) return 0;
+        return Math.min(...values);
+      });
+      case 'MAX': return this.evalAggregate(args, (values) => {
+        if (values.length === 0) return 0;
+        return Math.max(...values);
+      });
+      case 'COUNT': return this.evalCount(args);
+      case 'IF': return this.evalIf(args);
+      default:
+        throw new Error(`Unknown function: ${name}`);
+    }
+  }
+
+  private evalAggregate(args: ASTNode[], fn: (values: number[]) => number): number {
+    const values: number[] = [];
+
+    for (const arg of args) {
+      if (arg.type === 'range') {
+        const cells = expandRange(arg.start, arg.end);
+        for (const cellRef of cells) {
+          const val = this.get(cellRef);
+          if (typeof val === 'number') {
+            values.push(val);
+          }
+        }
+      } else {
+        const val = this.evaluate(arg);
+        if (typeof val === 'number') {
+          values.push(val);
+        }
+      }
+    }
+
+    return fn(values);
+  }
+
+  private evalCount(args: ASTNode[]): number {
+    let count = 0;
+
+    for (const arg of args) {
+      if (arg.type === 'range') {
+        const cells = expandRange(arg.start, arg.end);
+        for (const cellRef of cells) {
+          const val = this.get(cellRef);
+          if (typeof val === 'number') {
+            count++;
+          }
+        }
+      } else {
+        const val = this.evaluate(arg);
+        if (typeof val === 'number') {
+          count++;
+        }
+      }
+    }
+
+    return count;
+  }
+
+  private evalIf(args: ASTNode[]): CellValue {
+    if (args.length !== 3) {
+      throw new Error('IF requires exactly 3 arguments');
+    }
+
+    const condition = this.evaluate(args[0]);
+    if (condition) {
+      return this.evaluate(args[1]);
+    } else {
+      return this.evaluate(args[2]);
+    }
+  }
+}
