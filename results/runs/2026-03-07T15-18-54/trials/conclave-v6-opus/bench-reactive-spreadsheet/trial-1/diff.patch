+import { describe, test, expect } from 'vitest';
+import { parse } from './parser.js';
+
+describe('parser', () => {
+  describe('literals', () => {
+    test('parses integer numbers', () => {
+      expect(parse('42')).toEqual({ type: 'number', value: 42 });
+    });
+
+    test('parses decimal numbers', () => {
+      expect(parse('3.14')).toEqual({ type: 'number', value: 3.14 });
+    });
+
+    test('parses string literals', () => {
+      expect(parse('"hello"')).toEqual({ type: 'string', value: 'hello' });
+    });
+
+    test('parses boolean true', () => {
+      expect(parse('true')).toEqual({ type: 'boolean', value: true });
+    });
+
+    test('parses boolean false', () => {
+      expect(parse('false')).toEqual({ type: 'boolean', value: false });
+    });
+  });
+
+  describe('cell references', () => {
+    test('parses simple cell reference', () => {
+      expect(parse('A1')).toEqual({ type: 'cellref', ref: 'A1' });
+    });
+
+    test('parses multi-letter cell reference', () => {
+      expect(parse('AA10')).toEqual({ type: 'cellref', ref: 'AA10' });
+    });
+  });
+
+  describe('arithmetic', () => {
+    test('parses addition', () => {
+      const result = parse('A1+B1');
+      expect(result).toEqual({
+        type: 'binary',
+        op: '+',
+        left: { type: 'cellref', ref: 'A1' },
+        right: { type: 'cellref', ref: 'B1' },
+      });
+    });
+
+    test('parses subtraction', () => {
+      const result = parse('A1-B1');
+      expect(result).toEqual({
+        type: 'binary',
+        op: '-',
+        left: { type: 'cellref', ref: 'A1' },
+        right: { type: 'cellref', ref: 'B1' },
+      });
+    });
+
+    test('parses multiplication', () => {
+      const result = parse('A1*B1');
+      expect(result).toEqual({
+        type: 'binary',
+        op: '*',
+        left: { type: 'cellref', ref: 'A1' },
+        right: { type: 'cellref', ref: 'B1' },
+      });
+    });
+
+    test('parses division', () => {
+      const result = parse('A1/B1');
+      expect(result).toEqual({
+        type: 'binary',
+        op: '/',
+        left: { type: 'cellref', ref: 'A1' },
+        right: { type: 'cellref', ref: 'B1' },
+      });
+    });
+
+    test('respects operator precedence (* before +)', () => {
+      const result = parse('A1+B1*C1');
+      expect(result).toEqual({
+        type: 'binary',
+        op: '+',
+        left: { type: 'cellref', ref: 'A1' },
+        right: {
+          type: 'binary',
+          op: '*',
+          left: { type: 'cellref', ref: 'B1' },
+          right: { type: 'cellref', ref: 'C1' },
+        },
+      });
+    });
+
+    test('respects parentheses', () => {
+      const result = parse('(A1+B1)*2');
+      expect(result).toEqual({
+        type: 'binary',
+        op: '*',
+        left: {
+          type: 'binary',
+          op: '+',
+          left: { type: 'cellref', ref: 'A1' },
+          right: { type: 'cellref', ref: 'B1' },
+        },
+        right: { type: 'number', value: 2 },
+      });
+    });
+
+    test('parses unary negation', () => {
+      const result = parse('-A1');
+      expect(result).toEqual({
+        type: 'unary',
+        op: '-',
+        operand: { type: 'cellref', ref: 'A1' },
+      });
+    });
+  });
+
+  describe('comparisons', () => {
+    test('parses greater than', () => {
+      const result = parse('A1>30');
+      expect(result).toEqual({
+        type: 'binary',
+        op: '>',
+        left: { type: 'cellref', ref: 'A1' },
+        right: { type: 'number', value: 30 },
+      });
+    });
+
+    test('parses less than or equal', () => {
+      const result = parse('A1<=B1');
+      expect(result).toEqual({
+        type: 'binary',
+        op: '<=',
+        left: { type: 'cellref', ref: 'A1' },
+        right: { type: 'cellref', ref: 'B1' },
+      });
+    });
+
+    test('parses not equal', () => {
+      const result = parse('A1<>B1');
+      expect(result).toEqual({
+        type: 'binary',
+        op: '<>',
+        left: { type: 'cellref', ref: 'A1' },
+        right: { type: 'cellref', ref: 'B1' },
+      });
+    });
+
+    test('parses equality with =', () => {
+      const result = parse('A1=B1');
+      expect(result).toEqual({
+        type: 'binary',
+        op: '=',
+        left: { type: 'cellref', ref: 'A1' },
+        right: { type: 'cellref', ref: 'B1' },
+      });
+    });
+  });
+
+  describe('functions', () => {
+    test('parses SUM with range', () => {
+      const result = parse('SUM(A1:A5)');
+      expect(result).toEqual({
+        type: 'function',
+        name: 'SUM',
+        args: [{ type: 'range', start: 'A1', end: 'A5' }],
+      });
+    });
+
+    test('parses AVERAGE with range', () => {
+      const result = parse('AVERAGE(A1:A5)');
+      expect(result).toEqual({
+        type: 'function',
+        name: 'AVERAGE',
+        args: [{ type: 'range', start: 'A1', end: 'A5' }],
+      });
+    });
+
+    test('parses IF with three arguments', () => {
+      const result = parse('IF(A1>30,"big","small")');
+      expect(result).toEqual({
+        type: 'function',
+        name: 'IF',
+        args: [
+          {
+            type: 'binary',
+            op: '>',
+            left: { type: 'cellref', ref: 'A1' },
+            right: { type: 'number', value: 30 },
+          },
+          { type: 'string', value: 'big' },
+          { type: 'string', value: 'small' },
+        ],
+      });
+    });
+
+    test('parses nested functions', () => {
+      const result = parse('SUM(A1:A3)+MAX(B1:B3)');
+      expect(result).toEqual({
+        type: 'binary',
+        op: '+',
+        left: {
+          type: 'function',
+          name: 'SUM',
+          args: [{ type: 'range', start: 'A1', end: 'A3' }],
+        },
+        right: {
+          type: 'function',
+          name: 'MAX',
+          args: [{ type: 'range', start: 'B1', end: 'B3' }],
+        },
+      });
+    });
+  });
+
+  describe('complex expressions', () => {
+    test('parses IF with arithmetic condition', () => {
+      const result = parse('IF(A1+B1>100,"over","under")');
+      expect(result.type).toBe('function');
+      if (result.type === 'function') {
+        expect(result.name).toBe('IF');
+        expect(result.args).toHaveLength(3);
+      }
+    });
+
+    test('parses number with spaces', () => {
+      const result = parse(' 42 ');
+      expect(result).toEqual({ type: 'number', value: 42 });
+    });
+  });
+});
