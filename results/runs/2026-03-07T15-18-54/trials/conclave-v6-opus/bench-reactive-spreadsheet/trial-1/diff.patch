+export interface CellCoord {
+  col: number;
+  row: number;
+}
+
+export function columnToNumber(col: string): number {
+  let result = 0;
+  for (let i = 0; i < col.length; i++) {
+    result = result * 26 + (col.charCodeAt(i) - 64);
+  }
+  return result;
+}
+
+export function numberToColumn(num: number): string {
+  let result = '';
+  while (num > 0) {
+    const remainder = (num - 1) % 26;
+    result = String.fromCharCode(65 + remainder) + result;
+    num = Math.floor((num - 1) / 26);
+  }
+  return result;
+}
+
+export function parseCell(ref: string): CellCoord {
+  const upper = ref.toUpperCase();
+  const match = upper.match(/^([A-Z]+)(\d+)$/);
+  if (!match) {
+    throw new Error(`Invalid cell reference: ${ref}`);
+  }
+  return {
+    col: columnToNumber(match[1]),
+    row: parseInt(match[2], 10),
+  };
+}
+
+export function expandRange(start: string, end: string): string[] {
+  const s = parseCell(start);
+  const e = parseCell(end);
+  const cells: string[] = [];
+
+  for (let col = s.col; col <= e.col; col++) {
+    for (let row = s.row; row <= e.row; row++) {
+      cells.push(numberToColumn(col) + row);
+    }
+  }
+
+  return cells;
+}
