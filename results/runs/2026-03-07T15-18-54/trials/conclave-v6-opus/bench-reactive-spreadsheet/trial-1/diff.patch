+import { describe, test, expect } from 'vitest';
+import { parseCell, columnToNumber, numberToColumn, expandRange } from './utils.js';
+
+describe('columnToNumber', () => {
+  test('converts single letter columns', () => {
+    expect(columnToNumber('A')).toBe(1);
+    expect(columnToNumber('B')).toBe(2);
+    expect(columnToNumber('Z')).toBe(26);
+  });
+
+  test('converts multi-letter columns', () => {
+    expect(columnToNumber('AA')).toBe(27);
+    expect(columnToNumber('AB')).toBe(28);
+    expect(columnToNumber('AZ')).toBe(52);
+    expect(columnToNumber('BA')).toBe(53);
+  });
+});
+
+describe('numberToColumn', () => {
+  test('converts numbers to single letter columns', () => {
+    expect(numberToColumn(1)).toBe('A');
+    expect(numberToColumn(2)).toBe('B');
+    expect(numberToColumn(26)).toBe('Z');
+  });
+
+  test('converts numbers to multi-letter columns', () => {
+    expect(numberToColumn(27)).toBe('AA');
+    expect(numberToColumn(28)).toBe('AB');
+    expect(numberToColumn(52)).toBe('AZ');
+    expect(numberToColumn(53)).toBe('BA');
+  });
+});
+
+describe('parseCell', () => {
+  test('parses simple cell references', () => {
+    expect(parseCell('A1')).toEqual({ col: 1, row: 1 });
+    expect(parseCell('B2')).toEqual({ col: 2, row: 2 });
+    expect(parseCell('Z100')).toEqual({ col: 26, row: 100 });
+  });
+
+  test('parses multi-letter column references', () => {
+    expect(parseCell('AA1')).toEqual({ col: 27, row: 1 });
+    expect(parseCell('AB5')).toEqual({ col: 28, row: 5 });
+  });
+
+  test('is case-insensitive', () => {
+    expect(parseCell('a1')).toEqual({ col: 1, row: 1 });
+    expect(parseCell('aa1')).toEqual({ col: 27, row: 1 });
+  });
+});
+
+describe('expandRange', () => {
+  test('expands a single column range', () => {
+    const cells = expandRange('A1', 'A3');
+    expect(cells).toEqual(['A1', 'A2', 'A3']);
+  });
+
+  test('expands a single row range', () => {
+    const cells = expandRange('A1', 'C1');
+    expect(cells).toEqual(['A1', 'B1', 'C1']);
+  });
+
+  test('expands a block range', () => {
+    const cells = expandRange('A1', 'B2');
+    expect(cells).toEqual(['A1', 'A2', 'B1', 'B2']);
+  });
+
+  test('expands a larger block range', () => {
+    const cells = expandRange('A1', 'C3');
+    expect(cells).toEqual([
+      'A1', 'A2', 'A3',
+      'B1', 'B2', 'B3',
+      'C1', 'C2', 'C3',
+    ]);
+  });
+
+  test('handles single cell range', () => {
+    const cells = expandRange('B2', 'B2');
+    expect(cells).toEqual(['B2']);
+  });
+});
