  1→/**\\n     2→ * Simple job scheduler for background tasks.\\n     3→ */\\n     4→\\n     5→export interface JobDefinition {\\n     6→  name: string;\\n     7→  handler: () => Promise<void> | void;\\n     8→  intervalMs: number;\\n     9→  timer?: ReturnType<typeof setInterval>;\\n    10→  lastRun?: Date;\\n    11→  runCount: number;\\n    12→  errors: string[];\\n    13→}\\n    14→\\n    15→export class Scheduler {\\n    16→  private jobs: Map<string, JobDefinition> = new Map();\\n    17→  private running = false;\\n    18→\\n    19→  register(\\n    20→    name: string,\\n    21→    handler: () => Promise<void> | void,\\n    22→    intervalMs: number\\n    23→  ): void {\\n    24→    this.jobs.set(name, {\\n    25→      name,\\n    26→      handler,\\n    27→      intervalMs,\\n    28→      runCount: 0,\\n    29→      errors: [],\\n    30→    });\\n    31→  }\\n    32→\\n    33→  start(): void {\\n    34→    if (this.running) return;\\n    35→    this.running = true;\\n    36→\\n    37→    for (const [, job] of this.jobs) {\\n    38→      job.timer = setInterval(async () => {\\n    39→        try {\\n    40→          await job.handler();\\n    41→          job.lastRun = new Date();\\n    42→          job.runCount++;\\n    43→        } catch (err) {\\n    44→          job.errors.push(\\n    45→            err instanceof Error ? err.message : String(err)\\n    46→          );\\n    47→        }\\n    48→      }, job.intervalMs);\\n    49→    }\\n    50→  }\\n    51→\\n    52→  stop(): void {\\n    53→    if (!this.running) return;\\n    54→    this.running = false;\\n    55→\\n    56→    for (const [, job] of this.jobs) {\\n    57→      if (job.timer) {\\n    58→        clearInterval(job.timer);\\n    59→        job.timer = undefined;\\n    60→      }\\n    61→    }\\n    62→  }\\n    63→\\n    64→  async runOnce(name: string): Promise<void> {\\n    65→    const job = this.jobs.get(name);\\n    66→    if (!job) {\\n    67→      throw new Error(`Job '${name}' not found`);\\n    68→    }\\n    69→\\n    70→    await job.handler();\\n    71→    job.lastRun = new Date();\\n    72→    job.runCount++;\\n    73→  }\\n    74→\\n    75→  getStatus(): Array<{\\n    76→    name: string;\\n    77→    lastRun: Date | undefined;\\n    78→    runCount: number;\\n    79→    errorCount: number;\\n    80→  }> {\\n    81→    return Array.from(this.jobs.values()).map((job) => ({\\n    82→      name: job.name,\\n    83→      lastRun: job.lastRun,\\n    84→      runCount: job.runCount,\\n    85→      errorCount: job.errors.length,\\n    86→    }));\\n    87→  }\\n    88→\\n    89→  isRunning(): boolean {\\n    90→    return this.running;\\n    91→  }\\n    92→}\\n    93→\"}]},\"parent_tool_use_id\":\"toolu_0189stNSv58PJAhPpbMyviTu\",\"session_id\":\"032fb280-3e51-4b14-ae7f-5993a23b6409\",\"uuid\":\"deb0d25d-d4d5-499a-9cb7-0b3a1380a91d\"}\n+{\"type\":\"assistant\",\"message\":{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01QP6SwyDtV3voNTvCm1DXRj\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01SAEnFyQsPdHB616ZcH2GC1\",\"name\":\"Read\",\"input\":{\"file_path\":\"/workspace/packages/worker/src/jobs/sync.ts\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":5,\"cache_creation_input_tokens\":2398,\"cache_read_input_tokens\":24868,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":2398},\"output_tokens\":3,\"service_tier\":\"standard\",\"inference_geo\":\"not_available\"},\"context_management\":null},\"parent_tool_use_id\":\"toolu_0189stNSv58PJAhPpbMyviTu\",\"session_id\":\"032fb280-3e51-4b14-ae7f-5993a23b6409\",\"uuid\":\"c40908c6-b8d0-4a0c-9950-008dd726fbe9\"}\n+{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01SAEnFyQsPdHB616ZcH2GC1\",\"type\":\"tool_result\",\"content\":\"     1→/**\\n     2→ * Data sync job.\\n     3→ * Syncs external user data into the local database.\\n     4→ */\\n     5→\\n     6→import {\\n     7→  createUser,\\n     8→  getUserById,\\n     9→  getAllUsers,\\n    10→  type CreateUserInput,\\n    11→} from '@monorepo/core';\\n    12→\\n    13→interface ExternalUser {\\n    14→  name: string;\\n    15→  email: string;\\n    16→  role: 'admin' | 'user' | 'viewer';\\n    17→}\\n    18→\\n    19→// Simulated external data source\\n    20→function fetchExternalUsers(): ExternalUser[] {\\n    21→  return [\\n    22→    { name: 'External User 1', email: 'ext1@example.com', role: 'user' },\\n    23→    { name: 'External User 2', email: 'ext2@example.com', role: 'viewer' },\\n    24→  ];\\n    25→}\\n    26→\\n    27→export async function syncJob(): Promise<void> {\\n    28→  const externalUsers = fetchExternalUsers();\\n    29→  const existingUsers = getAllUsers();\\n    30→  const existingEmails = new Set(existingUsers.map((u) => u.email));\\n    31→\\n    32→  let synced = 0;\\n    33→  let skipped = 0;\\n    34→\\n    35→  for (const extUser of externalUsers) {\\n    36→    if (existingEmails.has(extUser.email)) {\\n    37→      skipped++;\\n    38→      continue;\\n    39→    }\\n    40→\\n    41→    const input: CreateUserInput = {\\n    42→      name: extUser.name,\\n    43→      email: extUser.email,\\n    44→      role: extUser.role,\\n    45→    };\\n    46→\\n    47→    try {\\n    48→      const newUser = createUser(input);\\n    49→      if (newUser.id) {\\n    50→        synced++;\\n    51→      }\\n    52→    } catch (err) {\\n    53→      console.error(`Failed to sync user ${extUser.email}:`, err);\\n    54→    }\\n    55→  }\\n    56→\\n    57→  console.log(`Sync complete: ${synced} synced, ${skipped} skipped`);\\n    58→}\\n    59→\\n    60→export async function syncSingleUser(userId: number): Promise<boolean> {\\n    61→  const user = getUserById(userId);\\n    62→  if (!user) {\\n    63→    console.error(`User ${userId} not found for sync`);\\n    64→    return false;\\n    65→  }\\n    66→\\n    67→  // In a real app, we'd sync to an external service here\\n    68→  console.log(`Synced user ${user.name} (${user.email})`);\\n    69→  return true;\\n    70→}\\n    71→\"}]},\"parent_tool_use_id\":\"toolu_0189stNSv58PJAhPpbMyviTu\",\"session_id\":\"032fb280-3e51-4b14-ae7f-5993a23b6409\",\"uuid\":\"ec22dd69-382c-40cb-802c-2834e22350e5\"}\n+{\"type\":\"assistant\",\"message\":{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01QP6SwyDtV3voNTvCm1DXRj\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01KrAjLW2jJU8RFcytuk193x\",\"name\":\"Read\",\"input\":{\"file_path\":\"/workspace/packages/worker/src/jobs/cleanup.ts\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":5,\"cache_creation_input_tokens\":2398,\"cache_read_input_tokens\":24868,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":2398},\"output_tokens\":3,\"service_tier\":\"standard\",\"inference_geo\":\"not_available\"},\"context_management\":null},\"parent_tool_use_id\":\"toolu_0189stNSv58PJAhPpbMyviTu\",\"session_id\":\"032fb280-3e51-4b14-ae7f-5993a23b6409\",\"uuid\":\"a0f78e1c-6833-4352-b46c-8568a89c2018\"}\n+{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01KrAjLW2jJU8RFcytuk193x\",\"type\":\"tool_result\",\"content\":\"     1→/**\\n     2→ * Cleanup job.\\n     3→ * Removes stale data and performs maintenance tasks.\\n     4→ */\\n     5→\\n     6→import { getAllUsers } from '@monorepo/core';\\n     7→\\n     8→export interface CleanupResult {\\n     9→  staleRecords: number;\\n    10→  cleanedUp: number;\\n    11→  duration: number;\\n    12→}\\n    13→\\n    14→export async function cleanupJob(): Promise<CleanupResult> {\\n    15→  const startTime = Date.now();\\n    16→\\n    17→  // Get all users to check for stale records\\n    18→  const users = getAllUsers();\\n    19→\\n    20→  let staleRecords = 0;\\n    21→  let cleanedUp = 0;\\n    22→\\n    23→  for (const user of users) {\\n    24→    const createdDate = new Date(user.createdAt);\\n    25→    const now = new Date();\\n    26→    const daysSinceCreation =\\n    27→      (now.getTime() - createdDate.getTime()) / (1000 * 60 * 60 * 24);\\n    28→\\n    29→    // Mark records older than 365 days as stale (simulation)\\n    30→    if (daysSinceCreation > 365) {\\n    31→      staleRecords++;\\n    32→      // In a real app, we'd archive or delete\\n    33→      cleanedUp++;\\n    34→    }\\n    35→  }\\n    36→\\n    37→  const duration = Date.now() - startTime;\\n    38→\\n    39→  console.log(\\n    40→    `Cleanup complete: ${staleRecords} stale, ${cleanedUp} cleaned in ${duration}ms`\\n    41→  );\\n    42→\\n    43→  return { staleRecords, cleanedUp, duration };\\n    44→}\\n    45→\\n    46→export function getCleanupThresholdDays(): number {\\n    47→  return 365;\\n    48→}\\n    49→\"}]},\"parent_tool_use_id\":\"toolu_0189stNSv58PJAhPpbMyviTu\",\"session_id\":\"032fb280-3e51-4b14-ae7f-5993a23b6409\",\"uuid\":\"c90a0548-5086-486d-aa4c-7d7100c8f2ae\"}\n+{\"type\":\"assistant\",\"message\":{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01JMq2eLpd7zE5Ei89J4kSML\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01P4RTt34RwYpuuZcbX4uKMN\",\"name\":\"Read\",\"input\":{\"file_path\":\"/workspace/packages/worker/tests/scheduler.test.ts\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":5,\"cache_creation_input_tokens\":3018,\"cache_read_input_tokens\":27266,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":3018},\"output_tokens\":1,\"service_tier\":\"standard\",\"inference_geo\":\"not_available\"},\"context_management\":null},\"parent_tool_use_id\":\"toolu_0189stNSv58PJAhPpbMyviTu\",\"session_id\":\"032fb280-3e51-4b14-ae7f-5993a23b6409\",\"uuid\":\"f4492f47-0730-48b9-b2c7-29b30