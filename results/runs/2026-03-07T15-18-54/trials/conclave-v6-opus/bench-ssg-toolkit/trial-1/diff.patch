.title}</title>\n<link>${ctx.config.baseUrl}</link>\n<description>${ctx.config.title} RSS Feed</description>\n${items}\n</channel>\n</rss>`;\n\n        ctx.output.set('feed.xml', feed);\n      },\n    },\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":457,"cache_read_input_tokens":49604,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":457},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"408b5760-427c-4717-bfe5-b758b0f78635","uuid":"1dd31673-781f-4616-b721-e2be21e945e8"}
