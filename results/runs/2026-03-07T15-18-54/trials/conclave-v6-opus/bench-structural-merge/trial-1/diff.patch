t does not exist', () => {\n      expect(() => store.update('nonexistent', { name: 'Bob' })).toThrow();\n    });\n\n    test('update throws if document was deleted', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.delete('doc1');\n      expect(() => store.update('doc1', { name: 'Bob' })).toThrow();\n    });\n\n    test('delete removes a document', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.delete('doc1');\n      expect(() => store.get('doc1')).toThrow();\n    });\n\n    test('delete throws if document does not exist', () => {\n      expect(() => store.delete('nonexistent')).toThrow();\n    });\n\n    test('delete throws if document already deleted', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.delete('doc1');\n      expect(() => store.delete('doc1')).toThrow();\n    });\n  });\n\n  describe('Version History', () => {\n    test('create generates a version', () => {\n      store.create('doc1', { name: 'Alice' });\n      const history = store.getHistory('doc1');\n      expect(history).toHaveLength(1);\n      expect(history[0].content).toEqual({ name: 'Alice' });\n      expect(typeof history[0].id).toBe('string');\n      expect(typeof history[0].timestamp).toBe('number');\n    });\n\n    test('update generates additional versions', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.update('doc1', { name: 'Bob' });\n      store.update('doc1', { name: 'Charlie' });\n      const history = store.getHistory('doc1');\n      expect(history).toHaveLength(3);\n      expect(history[0].content).toEqual({ name: 'Alice' });\n      expect(history[1].content).toEqual({ name: 'Bob' });\n      expect(history[2].content).toEqual({ name: 'Charlie' });\n    });\n\n    test('getHistory returns versions in chronological order', () => {\n      store.create('doc1', { name: 'v1' });\n      store.update('doc1', { name: 'v2' });\n      store.update('doc1', { name: 'v3' });\n      const history = store.getHistory('doc1');\n      for (let i = 1; i < history.length; i++) {\n        expect(history[i].timestamp).toBeGreaterThanOrEqual(history[i - 1].timestamp);\n      }\n    });\n\n    test('getVersion returns content at a specific version', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.update('doc1', { name: 'Bob' });\n      const history = store.getHistory('doc1');\n      expect(store.getVersion('doc1', history[0].id)).toEqual({ name: 'Alice' });\n      expect(store.getVersion('doc1', history[1].id)).toEqual({ name: 'Bob' });\n    });\n\n    test('getVersion returns a deep clone', () => {\n      store.create('doc1', { nested: { x: 1 } });\n      const history = store.getHistory('doc1');\n      const v = store.getVersion('doc1', history[0].id) as { nested: { x: number } };\n      v.nested.x = 999;\n      const v2 = store.getVersion('doc1', history[0].id) as { nested: { x: number } };\n      expect(v2.nested.x).toBe(1);\n    });\n\n    test('getHistory returns deep clones of version content', () => {\n      store.create('doc1', { nested: { x: 1 } });\n      const history = store.getHistory('doc1');\n      (history[0].content as { nested: { x: number } }).nested.x = 999;\n      const history2 = store.getHistory('doc1');\n      expect((history2[0].content as { nested: { x: number } }).nested.x).toBe(1);\n    });\n  });\n\n  describe('Branching', () => {\n    test('default branch is main', () => {\n      expect(store.getBranch()).toBe('main');\n    });\n\n    test('listBranches returns all branches', () => {\n      expect(store.listBranches()).toEqual(['main']);\n      store.createBranch('feature');\n      expect(store.listBranches().sort()).toEqual(['feature', 'main']);\n    });\n\n    test('createBranch creates a new branch from current branch', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      expect(store.get('doc1')).toEqual({ name: 'Alice' });\n    });\n\n    test('createBranch from a specified branch', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'Bob' });\n      store.switchBranch('main');\n      store.createBranch('feature2', 'feature');\n      store.switchBranch('feature2');\n      expect(store.get('doc1')).toEqual({ name: 'Bob' });\n    });\n\n    test('switchBranch changes the active branch', () => {\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      expect(store.getBranch()).toBe('feature');\n    });\n\n    test('switchBranch throws for nonexistent branch', () => {\n      expect(() => store.switchBranch('nonexistent')).toThrow();\n    });\n\n    test('changes on one branch are not visible on other branches', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'Bob' });\n      store.switchBranch('main');\n      expect(store.get('doc1')).toEqual({ name: 'Alice' });\n    });\n\n    test('documents created on a branch are not visible on other branches', () => {\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.create('doc1', { name: 'Alice' });\n      store.switchBranch('main');\n      expect(() => store.get('doc1')).toThrow();\n    });\n\n    test('documents deleted on a branch are still visible on other branches', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.delete('doc1');\n      store.switchBranch('main');\n      expect(store.get('doc1')).toEqual({ name: 'Alice' });\n    });\n\n    test('createBranch throws if branch already exists', () => {\n      store.createBranch('feature');\n      expect(() => store.createBranch('feature')).toThrow();\n    });\n  });\n\n  describe('Merging', () => {\n    test('merge with no changes is a no-op', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n      const result = store.merge('feature');\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toEqual([]);\n      expect(store.get('doc1')).toEqual({ name: 'Alice' });\n    });\n\n    test('merge applies changes from source branch', () => {\n      store.create('doc1', { name: 'Alice', age: 30 });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'Bob', age: 30 });\n      store.switchBranch('main');\n      const result = store.merge('feature');\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toEqual([]);\n      expect(store.get('doc1')).toEqual({ name: 'Bob', age: 30 });\n    });\n\n    test('merge applies changes from current branch while keeping source changes', () => {\n      store.create('doc1', { name: 'Alice', age: 30 });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'Bob', age: 30 });\n      store.switchBranch('main');\n      store.update('doc1', { name: 'Alice', age: 31 });\n      const result = store.merge('feature');\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toEqual([]);\n      expect(store.get('doc1')).toEqual({ name: 'Bob', age: 31 });\n    });\n\n    test('merge detects conflicts when both sides change same field differently', () => {\n      store.create('doc1', { name: 'Alice', age: 30 });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'Bob', age: 30 });\n      store.switchBranch('main');\n      store.update('doc1', { name: 'Charlie', age: 30 });\n      const result = store.merge('feature');\n      expect(result.applied).toBe(false);\n      expect(result.conflicts).toHaveLength(1);\n      expect(result.conflicts[0]).toEqual({\n        documentId: 'doc1',\n        path: 'name',\n        base: 'Alice',\n        ours: 'Charlie',\n        theirs: 'Bob',\n      });\n      // Current branch unchanged\n      expect(store.get('doc1')).toEqual({ name: 'Charlie', age: 30 });\n    });\n\n    test('merge with conflicts shows merged result favoring ours', () => {\n      store.create('doc1', { name: 'Alice', age: 30 });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'Bob', age: 30 });\n      store.switchBranch('main');\n      store.update('doc1', { name: 'Charlie', age: 30 });\n      const result = store.merge('feature');\n      expect(result.merged['doc1']).toEqual({ name: 'Charlie', age: 30 });\n    });\n\n    test('no conflict when both sides change same field to same value', () => {\n      store.create('doc1', { name: 'Alice', age: 30 });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'Bob', age: 30 });\n      store.switchBranch('main');\n      store.update('doc1', { name: 'Bob', age: 30 });\n      const result = store.merge('feature');\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toEqual([]);\n      expect(store.get('doc1')).toEqual({ name: 'Bob', age: 30 });\n    });\n\n    test('merge handles nested field changes', () => {\n      store.create('doc1', { user: { name: 'Alice', address: { city: 'NYC', zip: '10001' } } });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { user: { name: 'Alice', address: { city: 'LA', zip: '10001' } } });\n      store.switchBranch('main');\n      store.update('doc1', { user: { name: 'Alice', address: { city: 'NYC', zip: '90001' } } });\n      const result = store.merge('feature');\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toEqual([]);\n      expect(store.get('doc1')).toEqual({\n        user: { name: 'Alice', address: { city: 'LA', zip: '90001' } },\n      });\n    })