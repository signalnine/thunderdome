tring, unknown> | undefined,\n  ours: Record<string, unknown>,\n  theirs: Record<string, unknown>,\n  documentId: string,\n  pathPrefix: string,\n): { merged: Record<string, unknown>; conflicts: Conflict[] } {\n  const baseObj: Record<string, unknown> = base ?? {};\n  const allKeys = new Set([\n    ...Object.keys(baseObj),\n    ...Object.keys(ours),\n    ...Object.keys(theirs),\n  ]);\n\n  const merged: Record<string, unknown> = {};\n  const conflicts: Conflict[] = [];\n\n  for (const key of allKeys) {\n    const baseVal = baseObj[key];\n    const oursVal = ours[key];\n    const theirsVal = theirs[key];\n    const currentPath = pathPrefix ? `${pathPrefix}.${key}` : key;\n\n    const oursChanged = !deepEqual(baseVal, oursVal);\n    const theirsChanged = !deepEqual(baseVal, theirsVal);\n\n    if (!oursChanged && !theirsChanged) {\n      // Neither changed - keep base value\n      if (key in baseObj) {\n        merged[key] = clone(baseVal);\n      } else if (key in ours) {\n        merged[key] = clone(oursVal);\n      }\n    } else if (oursChanged && !theirsChanged) {\n      // Only ours changed\n      if (key in ours) {\n        merged[key] = clone(oursVal);\n      }\n      // If key was removed by ours, don't include it\n    } else if (!oursChanged && theirsChanged) {\n      // Only theirs changed\n      if (key in theirs) {\n        merged[key] = clone(theirsVal);\n      }\n      // If key was removed by theirs, don't include it\n    } else {\n      // Both changed\n      if (deepEqual(oursVal, theirsVal)) {\n        // Both changed to the same value\n        if (key in ours) {\n          merged[key] = clone(oursVal);\n        }\n      } else if (\n        isPlainObject(oursVal) &&\n        isPlainObject(theirsVal) &&\n        isPlainObject(baseVal)\n      ) {\n        // Both are objects, recurse\n        const sub = threeWayMerge(\n          baseVal as Record<string, unknown>,\n          oursVal as Record<string, unknown>,\n          theirsVal as Record<string, un