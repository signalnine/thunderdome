mestamp: number;\n  content: object;\n}\n\nexport interface MergeResult {\n  merged: Record<string, object>;\n  conflicts: Conflict[];\n  applied: boolean;\n}\n\nexport interface Conflict {\n  documentId: string;\n  path: string;\n  base: unknown;\n  ours: unknown;\n  theirs: unknown;\n}\n\ninterface DocumentRecord {\n  content: object;\n  versions: Version[];\n  deleted: boolean;\n}\n\ntype BranchState = Map<string, DocumentRecord>;\n\ninterface BranchPoint {\n  fromBranch: string;\n  snapshot: Map<string, { content: object; deleted: boolean }>;\n}\n\nfunction clone<T>(value: T): T {\n  return structuredClone(value);\n}\n\nfunction isPlainObject(value: unknown): value is Record<string, unknown> {\n  return value !== null && typeof value === 'object' && !Array.isArray(value);\n}\n\nfunction deepEqual(a: unknown, b: unknown): boolean {\n  if (a === b) return true;\n  if (a === null || b === null) return a === b;\n  if (typeof a !== typeof b) return false;\n  if (Array.isArray(a) && Array.isArray(b)) {\n    if (a.length !== b.length) return false;\n    return a.every((val, i) => deepEqual(val, b[i]));\n  }\n  if (isPlainObject(a) && isPlainObject(b)) {\n    const keysA = Object.keys(a);\n    const keysB = Object.keys(b);\n    if (keysA.length !== keysB.length) return false;\n    return keysA.every((key) => key in b && deepEqual(a[key], b[key]));\n  }\n  return false;\n}\n\nfunction threeWayMerge(\n  base: Record<string, unknown> | undefined,\n  ours: Record<string, unknown>,\n  theirs: Record<string, unknown>,\n  documentId: string,\n  pathPrefix: string,\n): { merged: Record<string, unknown>; conflicts: Conflict[] } {\n  const baseObj: Record<string, unknown> = base ?? {};\n  const allKeys = new Set([\n    ...Object.keys(baseObj),\n    ...Object.keys(ours),\n    ...Object.keys(theirs),\n  ]);\n\n  const merged: Record<string, unknown> = {};\n  const conflicts: Conflict[] = [];\n\n  for (const key of allKeys) {\n    const baseVal = baseObj[key];\n    const oursVal = ours[key];\n    const theirsVal = theirs[key];\n    const currentPath = pathPrefix ? `${pathPrefix}.${key}` : key;\n\n    const oursChanged = !deepEqual(baseVal, oursVal);\n    const theirsChanged = !deepEqual(baseVal, theirsVal);\n\n    if (!oursChanged && !theirsChanged) {\n      // Neither changed - keep base value\n      if (key in baseObj) {\n        merged[key] = clone(baseVal);\n      } else if (key in ours) {\n        merged[key] = clone(oursVal);\n      }\n    } else if (oursChanged && !theirsChanged) {\n      // Only ours changed\n      if (key in ours) {\n        merged[key] = clone(oursVal);\n      }\n      // If key was removed by ours, don't include it\n    } else if (!oursChanged && theirsChanged) {\n      // Only theirs changed\n      if (key in theirs) {\n        merged[key] = clone(theirsVal);\n      }\n      // If key was removed by theirs, don't include it\n    } else {\n      // Both changed\n      if (deepEqual(oursVal, theirsVal)) {\n        // Both changed to the same value\n        if (key in ours) {\n          merged[key] = clone(oursVal);\n        }\n      } else if (\n        isPlainObject(oursVal) &&\n        isPlainObject(theirsVal) &&\n        isPlainObject(baseVal)\n      ) {\n        // Both are objects, recurse\n        const sub = threeWayMerge(\n          baseVal as Record<string, unknown>,\n          oursVal as Record<string, unknown>,\n          theirsVal as Record<string, unknown>,\n          documentId,\n          currentPath,\n        );\n        merged[key] = sub.merged;\n        conflicts.push(...sub.conflicts);\n      } else {\n        // Conflict - favor ours\n        conflicts.push({\n          documentId,\n          path: currentPath,\n          base: baseVal,\n          ours: oursVal,\n          theirs: theirsVal,\n        });\n        // Favor ours in merged result\n        if (key in ours) {\n          merged[key] = clone(oursVal);\n        }\n      }\n    }\n  }\n\n  return { merged, conflicts };\n}\n\nfunction cloneBranchState(state: BranchState): BranchState {\n  const newState: BranchState = new Map();\n  for (const [id, record] of state) {\n    newState.set(id, {\n      content: clone(record.content),\n      versions: record.versions.map((v) => ({\n        id: v.id,\n        timestamp: v.timestamp,\n        content: clone(v.content),\n      })),\n      deleted: record.deleted,\n    });\n  }\n  return newState;\n}\n\nfunction snapshotBranch(\n  state: BranchState,\n): Map<string, { content: object; deleted: boolean }> {\n  const snapshot = new Map<string, { content: object; deleted: boolean }>();\n  for (const [id, record] of state) {\n    snapshot.set(id, {\n      content: clone(record.content),\n      deleted: record.deleted,\n    });\n  }\n  return snapshot;\n}\n\nexport class DocumentStore {\n  private branches: Map<string, BranchState> = new Map();\n  private currentBranch: string = 'main';\n  private branchPoints: Map<string, BranchPoint> = new Map();\n  private versionCounter: number = 0;\n\n  private generateVersionId(): string {\n    return `v_${++this.versionCounter}_${Date.now()}`;\n  }\n\n  constructor() {\n    this.branches.set('main', new Map());\n  }\n\n  private getCurrentState(): BranchState {\n    return this.branches.get(this.currentBranch)!;\n  }\n\n  // Document CRUD\n\n  create(id: string, content: object): void {\n    const state = this.getCurrentState();\n    const existing = state.get(id);\n    if (existing && !existing.deleted) {\n      throw new Error(`Document \"${id}\" already exists`);\n    }\n    const version: Version = {\n      id: this.generateVersionId(),\n      timestamp: Date.now(),\n      content: clone(content),\n    };\n    state.set(id, {\n      content: clone(content),\n      versions: [version],\n      deleted: false,\n    });\n  }\n\n  get(id: string): object {\n    const state = this.getCurrentState();\n    const record = state.get(id);\n    if (!record || record.deleted) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    return clone(record.content);\n  }\n\n  update(id: string, content: object): void {\n    const state = this.getCurrentState();\n    const record = state.get(id);\n    if (!record || record.deleted) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    const version: Version = {\n      id: this.generateVersionId(),\n      timestamp: Date.now(),\n      content: clone(content),\n    };\n    record.content = clone(content);\n    record.versions.push(version);\n  }\n\n  delete(id: string): void {\n    const state = this.getCurrentState();\n    const record = state.get(id);\n    if (!record || record.deleted) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    record.deleted = true;\n  }\n\n  // Version History\n\n  getHistory(id: string): Version[] {\n    const state = this.getCurrentState();\n    const record = state.get(id);\n    if (!record) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    return record.versions.map((v) => ({\n      id: v.id,\n      timestamp: v.timestamp,\n      content: clone(v.content),\n    }));\n  }\n\n  getVersion(id: string, versionId: string): object {\n    const state = this.getCurrentState();\n    const record = state.get(id);\n    if (!record) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    const version = record.versions.find((v) => v.id === versionId);\n    if (!version) {\n      throw new Error(`Version \"${versionId}\" not found for document \"${id}\"`);\n    }\n    return clone(version.content);\n  }\n\n  // Branching\n\n  createBranch(name: string, fromBranch?: string): void {\n    if (this.branches.has(name)) {\n      throw new Error(`Branch \"${name}\" already exists`);\n    }\n    const sourceBranch = fromBranch ?? this.currentBranch;\n    const sourceState = this.branches.get(sourceBranch);\n    if (!sourceState) {\n      throw new Error(`Branch \"${sourceBranch}\" not found`);\n    }\n    const newState = cloneBranchState(sourceState);\n    this.branches.set(name, newState);\n    this.branchPoints.set(name, {\n      fromBranch: sourceBranch,\n      snapshot: snapshotBranch(sourceState),\n    });\n  }\n\n  switchBranch(name: string): void {\n    if (!this.branches.has(name)) {\n      throw new Error(`Branch \"${name}\" not found`);\n    }\n    this.currentBranch = name;\n  }\n\n  getBranch(): string {\n    return this.currentBranch;\n  }\n\n  listBranches(): string[] {\n    return Array.from(this.branches.keys());\n  }\n\n  // Merging\n\n  merge(sourceBranch: string): MergeResult {\n    const sourceState = this.branches.get(sourceBranch);\n    if (!sourceState) {\n      throw new Error(`Branch \"${sourceBranch}\" not found`);\n    }\n\n    const currentState = this.getCurrentState();\n\n    // Find common ancestor\n    const branchPoint = this.branchPoints.get(sourceBranch);\n    const baseSnapshot = branchPoint?.fromBranch === this.currentBranch\n      ? branchPoint.snapshot\n      : this.findCommonAncestor(sourceBranch);\n\n    // Collect all document IDs across base, ours, theirs\n    const allDocIds = new Set<string>();\n    if (baseSnapshot) {\n      for (const id of baseSnapshot.keys()) allDocIds.add(id);\n    }\n    for (const id of currentState.keys()) allDocIds.add(id);\n    for (const id of sourceState.keys()) allDocIds.add(id);\n\n    const merged: Record<string, object> = {};\n    const conflicts: Conflict[] = [];\n    const changes: Array<{ id: string; content: object | null }> = [];\n\n    for (const docId of allDocIds) {\n      const baseEntry = baseSnapshot?.get(docId);\n      const oursRecord = currentState.get(docId);\n      const theirsRecord = sourceState.get(docId);\n\n      const baseExists = baseEntry ? !baseEntry.deleted : false;\n      const oursExists = oursRecord ? !oursRecord.deleted : false;\n      const theirsExists = theirsRecord ? !theirsRecord.deleted : false;\n\n      const baseContent = baseExists && baseEntry ? baseEntry.content : undefined;\n      const oursContent = oursExists && oursRecord ? oursRecord.content : undefined;\n      const theirsContent = theirsExists && theirsRecord ? theirsRecord.content : undefined;\n\n      // Determine what changed\n      const oursChangedExistence = baseExists !== oursExists;\n      const theirsChangedExistence = baseExists !== theirsExists;\n      const oursChangedContent = baseExists && oursExists && !deepEqual(baseContent, oursContent);\n      const theirsChangedContent = baseExists && theirsExists && !deepEqual(baseContent, theirsContent);\n\n      if (!baseExists && !oursExists && theirsExists) {\n        // Created only on source\n        merged[docId] = clone(theirsContent!);\n        changes.push({ id: docId, content: clone(theirsContent!) });\n      } else if (!baseExists && oursExists && !theirsExists) {\n        // Created only on current - already there, include in merged\n        merged[docId] = clone(oursContent!);\n      } else if (!baseExists && oursExists && theirsExists) {\n        // Created on both sides - merge contents\n        const result = threeWayMerge(\n          undefined,\n          oursContent as Record<string, unknown>,\n          theirsContent as Record<string, unknown>,\n          docId,\n          '',\n        );\n        merged[docId] = result.merged;\n        conflicts.push(...result.conflicts);\n        if (result.conflicts.length === 0) {\n          changes.push({ id: docId, content: clone(result.merged) });\n        }\n      } else if (baseExists && !oursExists && !theirsExists) {\n        // Both deleted - no-op\n      } else if (baseExists && oursExists && !theirsExists) {\n        if (oursChangedContent) {\n          // Ours changed, theirs deleted - conflict situation\n          // For simplicity, theirs wins (deleted)\n          // Actually per spec: if deleted on one side, unchanged on other: delete\n          // But if ours changed AND theirs deleted, that's ambiguous\n          // The spec says \"If only one side changed a field, take that change\"\n          // Deletion is a document-level change. Let's handle this as: theirs deleted, ours didn't delete\n          // If ours is unchanged from base, delete. If ours changed, it's complicated.\n          // For safety, delete if ours unchanged, otherwise keep ours\n          changes.push({ id: docId, content: null }); // delete\n        } else {\n          // Ours unchanged, theirs deleted\n          changes.push({ id: docId, content: null }); // delete\n        }\n      } else if (baseExists && !oursExists && theirsExists) {\n        if (theirsChangedContent) {\n          // Ours deleted, theirs changed - keep deleted (ours wins)\n          // No change needed, already deleted on our side\n        } else {\n          // Ours deleted, theirs unchanged - keep deleted\n        }\n      } else if (baseExists && oursExists && theirsExists) {\n        // Both exist - check for content changes\n        if (!oursChangedContent && !theirsChangedContent) {\n          // No changes - fast forward\n          if (!oursChangedExistence && !theirsChangedExistence) {\n            // Completely unchanged\n            continue;\n          }\n        }\n\n        if (oursChangedContent && !theirsChangedContent) {\n          // Only ours changed - keep ours (already there)\n          merged[docId] = clone(oursContent!);\n        } else if (!oursChangedContent && theirsChangedContent) {\n          // Only theirs changed - take theirs\n          merged[docId] = clone(theirsContent!);\n          changes.push({ id: docId, content: clone(theirsContent!) });\n        } else if (oursChangedContent && theirsChangedContent) {\n          // Both changed - three-way merge\n          const result = threeWayMerge(\n            baseContent as Record<string, unknown>,\n            oursContent as Record<string, unknown>,\n            theirsContent as Record<string, unknown>,\n            docId,\n            '',\n          );\n          merged[docId] = result.merged;\n          conflicts.push(...result.conflicts);\n          if (result.conflicts.length === 0) {\n            changes.push({ id: docId, content: clone(result.merged) });\n          }\n        } else {\n          // Neither changed content\n          merged[docId] = clone(oursContent!);\n        }\n      }\n    }\n\n    const applied = conflicts.length === 0;\n\n    if (applied) {\n      // Apply changes to current branch\n      for (const change of changes) {\n        if (change.content === null) {\n          // Delete\n          const record = currentState.get(change.id);\n          if (record) {\n            record.deleted = true;\n          }\n        } else {\n          const record = currentState.get(change.id);\n          if (record) {\n            // Update existing\n            const version: Version = {\n              id: this.generateVersionId(),\n              timestamp: Date.now(),\n              content: clone(change.content),\n            };\n            record.content = clone(change.content);\n            record.versions.push(version);\n          } else {\n            // Create new\n            const version: Version = {\n              id: this.generateVersionId(),\n              timestamp: Date.now(),\n              content: clone(change.content),\n            };\n            currentState.set(change.id, {\n              content: clone(change.content),\n              versions: [version],\n              deleted: false,\n            });\n          }\n        }\n      }\n    }\n\n    return { merged, conflicts, applied };\n  }\n\n  private findCommonAncestor(\n    sourceBranch: string,\n  ): Map<string, { content: object; deleted: boolean }> | undefined {\n    // Check if the source branched from us\n    const bp = this.branchPoints.get(sourceBranch);\n    if (bp && bp.fromBranch === this.currentBranch) {\n      return bp.snapshot;\n    }\n    // Check if we branched from the source\n    const ourBp = this.branchPoints.get(this.currentBranch);\n    if (ourBp && ourBp.fromBranch === sourceBranch) {\n      return ourBp.snapshot;\n    }\n    // Check if both branched from the same parent\n    if (bp && ourBp && bp.fromBranch === ourBp.fromBranch) {\n      // Use the earlier snapshot - approximate common ancestor\n      return bp.snapshot;\n    }\n    // Fallback: empty base (treat everything as new)\n    return new Map();\n  }\n}\n","structuredPatch":[{"oldStart":376,"oldLines":27,"newStart":376,"newLines":10,"lines":["       } else if (baseExists && !oursExists && !theirsExists) {","         // Both deleted - no-op","       } else if (baseExists && oursExists && !theirsExists) {","-        if (oursChangedContent) {","-          // Ours changed, theirs deleted - conflict situation","-          // For simplicity, theirs wins (deleted)","-          // Actually per spec: if deleted on one side, unchanged on other: delete","-          // But if ours changed AND theirs deleted, that's ambiguous","-          // The spec says \"If only one side changed a field, take that change\"","-          // Deletion is a document-level change. Let's handle this as: theirs deleted, ours didn't delete","-          // If ours is unchanged from base, delete. If ours changed, it's complicated.","-          // For safety, delete if ours unchanged, otherwise keep ours","-          changes.push({ id: docId, content: null }); // delete","-        } else {","-          // Ours unchanged, theirs deleted","-          changes.push({ id: docId, content: null }); // delete","-        }","+        // Theirs deleted the document","+        changes.push({ id: docId, content: null });","       } else if (baseExists && !oursExists && theirsExists) {","-        if (theirsChangedContent) {","-          // Ours deleted, theirs changed - keep deleted (ours wins)","-          // No change needed, already deleted on our side","-        } else {","-          // Ours deleted, theirs unchanged - keep deleted","-        }","+        // Ours deleted the document - already deleted on our side","