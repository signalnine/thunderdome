+export interface Version {
+  id: string;
+  timestamp: number;
+  content: object;
+}
+
+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+export interface Conflict {
+  documentId: string;
+  path: string;
+  base: unknown;
+  ours: unknown;
+  theirs: unknown;
+}
+
+interface DocumentRecord {
+  content: object;
+  versions: Version[];
+  deleted: boolean;
+}
+
+type BranchState = Map<string, DocumentRecord>;
+
+interface BranchPoint {
+  fromBranch: string;
+  snapshot: Map<string, { content: object; deleted: boolean }>;
+}
+
+function clone<T>(value: T): T {
+  return structuredClone(value);
+}
+
+function isPlainObject(value: unknown): value is Record<string, unknown> {
+  return value !== null && typeof value === 'object' && !Array.isArray(value);
+}
+
+function deepEqual(a: unknown, b: unknown): boolean {
+  if (a === b) return true;
+  if (a === null || b === null) return a === b;
+  if (typeof a !== typeof b) return false;
+  if (Array.isArray(a) && Array.isArray(b)) {
+    if (a.length !== b.length) return false;
+    return a.every((val, i) => deepEqual(val, b[i]));
+  }
+  if (isPlainObject(a) && isPlainObject(b)) {
+    const keysA = Object.keys(a);
+    const keysB = Object.keys(b);
+    if (keysA.length !== keysB.length) return false;
+    return keysA.every((key) => key in b && deepEqual(a[key], b[key]));
+  }
+  return false;
+}
+
+function threeWayMerge(
+  base: Record<string, unknown> | undefined,
+  ours: Record<string, unknown>,
+  theirs: Record<string, unknown>,
+  documentId: string,
+  pathPrefix: string,
+): { merged: Record<string, unknown>; conflicts: Conflict[] } {
+  const baseObj: Record<string, unknown> = base ?? {};
+  const allKeys = new Set([
+    ...Object.keys(baseObj),
+    ...Object.keys(ours),
+    ...Object.keys(theirs),
+  ]);
+
+  const merged: Record<string, unknown> = {};
+  const conflicts: Conflict[] = [];
+
+  for (const key of allKeys) {
+    const baseVal = baseObj[key];
+    const oursVal = ours[key];
+    const theirsVal = theirs[key];
+    const currentPath = pathPrefix ? `${pathPrefix}.${key}` : key;
+
+    const oursChanged = !deepEqual(baseVal, oursVal);
+    const theirsChanged = !deepEqual(baseVal, theirsVal);
+
+    if (!oursChanged && !theirsChanged) {
+      // Neither changed - keep base value
+      if (key in baseObj) {
+        merged[key] = clone(baseVal);
+      } else if (key in ours) {
+        merged[key] = clone(oursVal);
+      }
+    } else if (oursChanged && !theirsChanged) {
+      // Only ours changed
+      if (key in ours) {
+        merged[key] = clone(oursVal);
+      }
+      // If key was removed by ours, don't include it
+    } else if (!oursChanged && theirsChanged) {
+      // Only theirs changed
+      if (key in theirs) {
+        merged[key] = clone(theirsVal);
+      }
+      // If key was removed by theirs, don't include it
+    } else {
+      // Both changed
+      if (deepEqual(oursVal, theirsVal)) {
+        // Both changed to the same value
+        if (key in ours) {
+          merged[key] = clone(oursVal);
+        }
+      } else if (
+        isPlainObject(oursVal) &&
+        isPlainObject(theirsVal) &&
+        isPlainObject(baseVal)
+      ) {
+        // Both are objects, recurse
+        const sub = threeWayMerge(
+          baseVal as Record<string, unknown>,
+          oursVal as Record<string, unknown>,
+          theirsVal as Record<string, unknown>,
+          documentId,
+          currentPath,
+        );
+        merged[key] = sub.merged;
+        conflicts.push(...sub.conflicts);
+      } else {
+        // Conflict - favor ours
+        conflicts.push({
+          documentId,
+          path: currentPath,
+          base: baseVal,
+          ours: oursVal,
+          theirs: theirsVal,
+        });
+        // Favor ours in merged result
+        if (key in ours) {
+          merged[key] = clone(oursVal);
+        }
+      }
+    }
+  }
+
+  return { merged, conflicts };
+}
+
+function cloneBranchState(state: BranchState): BranchState {
+  const newState: BranchState = new Map();
+  for (const [id, record] of state) {
+    newState.set(id, {
+      content: clone(record.content),
+      versions: record.versions.map((v) => ({
+        id: v.id,
+        timestamp: v.timestamp,
+        content: clone(v.content),
+      })),
+      deleted: record.deleted,
+    });
+  }
+  return newState;
+}
+
+function snapshotBranch(
+  state: BranchState,
+): Map<string, { content: object; deleted: boolean }> {
+  const snapshot = new Map<string, { content: object; deleted: boolean }>();
+  for (const [id, record] of state) {
+    snapshot.set(id, {
+      content: clone(record.content),
+      deleted: record.deleted,
+    });
+  }
+  return snapshot;
+}
+
