+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SQpzfiCBggXNJqKExu7Cc6","type":"tool_result","content":"diff --git a/src/index.test.ts b/src/index.test.ts\nnew file mode 100644\nindex 0000000..1677639\n--- /dev/null\n+++ b/src/index.test.ts\n@@ -0,0 +1,296 @@\n+import { describe, it, expect } from 'vitest';\n+import { simulate, findSwappedWires, Gate } from './index.js';\n+\n+describe('simulate', () => {\n+  it('applies AND gate correctly', () => {\n+    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n+    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });\n+    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 0 });\n+    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 0 });\n+    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n+  });\n+\n+  it('applies OR gate correctly', () => {\n+    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];\n+    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });\n+    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n+    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });\n+    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n+  });\n+\n+  it('applies XOR gate correctly', () => {\n+    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n+    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 0 });\n+    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n+    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });\n+    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n+  });\n+\n+  it('handles dependency chains', () => {\n+    // a AND b -> c, c OR d -> e\n+    const gates: Gate[] = [\n+      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },\n+      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n+    ];\n+    const result = simulate(gates, { a: 1, b: 1, d: 0 });\n+    expect(result).toEqual({ a: 1, b: 1, c: 1, d: 0, e: 1 });\n+  });\n+\n+  it('handles multi-level dependency chains', () => {\n+    // a XOR b -> t, t AND c -> d, d OR e -> f\n+    const gates: Gate[] = [\n+      { op: 'OR', in1: 'd', in2: 'e', out: 'f' },\n+      { op: 'AND', in1: 't', in2: 'c', out: 'd' },\n+      { op: 'XOR', in1: 'a', in2: 'b', out: 't' },\n+    ];\n+    const result = simulate(gates, { a: 1, b: 0, c: 1, e: 0 });\n+    expect(result).toEqual({ a: 1, b: 0, c: 1, e: 0, t: 1, d: 1, f: 1 });\n+  });\n+\n+  it('simulates a correct 2-bit adder (0+0)', () => {\n+    // Bit 0: half adder\n+    // x00 XOR y00 -> z00\n+    // x00 AND y00 -> c00\n+    // Bit 1: full adder\n+    // x01 XOR y01 -> t01\n+    // t01 XOR c00 -> z01\n+    // x01 AND y01 -> a01\n+    // t01 AND c00 -> b01\n+    // a01 OR b01 -> c01 (= z02)\n+    const gates: Gate[] = [\n+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },\n+    ];\n+\n+    // 0 + 0 = 0\n+    const r0 = simulate(gates, { x00: 0, x01: 0, y00: 0, y01: 0 });\n+    expect(r0.z00).toBe(0);\n+    expect(r0.z01).toBe(0);\n+    expect(r0.z02).toBe(0);\n+  });\n+\n+  it('simulates a correct 2-bit adder (3+3=6)', () => {\n+    const gates: Gate[] = [\n+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },\n+    ];\n+\n+    // 3 + 3 = 6 (binary: 11 + 11 = 110)\n+    const r = simulate(gates, { x00: 1, x01: 1, y00: 1, y01: 1 });\n+    expect(r.z00).toBe(0);\n+    expect(r.z01).toBe(1);\n+    expect(r.z02).toBe(1);\n+  });\n+\n+  it('simulates a correct 2-bit adder (2+1=3)', () => {\n+    const gates: Gate[] = [\n+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },\n+    ];\n+\n+    // 2 + 1 = 3 (binary: 10 + 01 = 011)\n+    const r = simulate(gates, { x00: 0, x01: 1, y00: 1, y01: 0 });\n+    expect(r.z00).toBe(1);\n+    expect(r.z01).toBe(1);\n+    expect(r.z02).toBe(0);\n+  });\n+});\n+\n+describe('findSwappedWires', () => {\n+  // Helper: build a correct N-bit adder circuit\n+  function buildCorrectAdder(n: number): Gate[] {\n+    const gates: Gate[] = [];\n+    // Bit 0: half adder\n+    gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });\n+    gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });\n+\n+    for (let i = 1; i < n; i++) {\n+      const bit = String(i).padStart(2, '0');\n+      const prevBit = String(i - 1).padStart(2, '0');\n+      gates.push({ op: 'XOR', in1: `x${bit}`, in2: `y${bit}`, out: `t${bit}` });\n+      gates.push({ op: 'XOR', in1: `t${bit}`, in2: `c${prevBit}`, out: `z${bit}` });\n+      gates.push({ op: 'AND', in1: `x${bit}`, in2: `y${bit}`, out: `a${bit}` });\n+      gates.push({ op: 'AND', in1: `t${bit}`, in2: `c${prevBit}`, out: `b${bit}` });\n+      gates.push({ op: 'OR', in1: `a${bit}`, in2: `b${bit}`, out: `c${bit}` });\n+    }\n+\n+    // Final carry -> MSB of z\n+    const lastBit = String(n - 1).padStart(2, '0');\n+    const zMsb = `z${String(n).padStart(2, '0')}`;\n+    // The last carry is the final output bit - we model this as an OR with itself\n+    // Actually in the spec example c03 -> z04. We can model as: c(n-1) OR c(n-1) -> z(n)\n+    // But that's a weird gate. Let's use XOR with a zero wire approach.\n+    // Actually, looking at the spec: \"c03 -> z04\" is just a wire rename. Let's model\n+    // it as an OR gate: c_last OR dummy_zero -> z_msb, where dummy_zero = x00 AND (NOT x00)\n+    // Simpler: let's just add a trivial OR gate\n+    // Actually the simplest representation is: the last carry c(n-1) feeds directly to z(n)\n+    // We need a gate for this. Use XOR with 0: but we don't have a constant 0 wire.\n+    // The problem says \"c03 -> z04\" which is a direct wire, not a gate.\n+    // For findSwappedWires, we only care about gates. The final carry-to-z is a special case.\n+    // Let's represent it as an OR gate with both inputs being the carry:\n+    gates.push({ op: 'OR', in1: `c${lastBit}`, in2: `c${lastBit}`, out: zMsb });\n+\n+    return gates;\n+  }\n+\n+  // Helper: swap two gate outputs\n+  function swapOutputs(gates: Gate[], wire1: string, wire2: string): Gate[] {\n+    return gates.map(g => {\n+      if (g.out === wire1) return { ...g, out: wire2 };\n+      if (g.out === wire2) return { ...g, out: wire1 };\n+      return g;\n+    });\n+  }\n+\n+  it('detects swapped wires in a small 4-bit adder', () => {\n+    let gates = buildCorrectAdder(4);\n+\n+    // Swap 4 pairs of outputs\n+    gates = swapOutputs(gates, 'z01', 'a01');\n+    gates = swapOutputs(gates, 'z02', 't02');\n+    gates = swapOutputs(gates, 'b03', 'c03');\n+    gates = swapOutputs(gates, 'z00', 'c00');\n+\n+    const result = findSwappedWires(gates);\n+    expect(result).toEqual(['a01', 'b03', 'c00', 'c03', 't02', 'z00', 'z01', 'z02']);\n+  });\n+\n+  it('detects different swap patterns in a 6-bit adder', () => {\n+    let gates = buildCorrectAdder(6);\n+\n+    // Swap 4 pairs\n+    gates = swapOutputs(gates, 'z03', 'a03');\n+    gates = swapOutputs(gates, 't04', 'c04');\n+    gates = swapOutputs(gates, 'z01', 'b01');\n+    gates = swapOutputs(gates, 'a05', 'z05');\n+\n+    const result = findSwappedWires(gates);\n+    expect(result).toEqual(['a03', 'a05', 'b01', 'c04', 't04', 'z01', 'z03', 'z05']);\n+  });\n+\n+  it('returns sorted wire names', () => {\n+    let gates = buildCorrectAdder(4);\n+    gates = swapOutputs(gates, 'z01', 'a01');\n+    gates = swapOutputs(gates, 'z02', 't02');\n+    gates = swapOutputs(gates, 'b03', 'c03');\n+    gates = swapOutputs(gates, 'z00', 'c00');\n+\n+    const result = findSwappedWires(gates);\n+    const sorted = [...result].sort();\n+    expect(result).toEqual(sorted);\n+  });\n+\n+  it('handles a 10-bit adder with swaps', () => {\n+    let gates = buildCorrectAdder(10);\n+\n+    gates = swapOutputs(gates, 'z02', 't02');\n+    gates = swapOutputs(gates, 'a05', 'c05');\n+    gates = swapOutputs(gates, 'z07', 'b07');\n+    gates = swapOutputs(gates, 't09', 'z09');\n+\n+    const result = findSwappedWires(gates);\n+    expect(result).toEqual(['a05', 'b07', 'c05', 't02', 't09', 'z02', 'z07', 'z09']);\n+  });\n+\n+  it('handles random wire names in a 6-bit adder', () => {\n+    // Build adder with random internal wire names\n+    const gates: Gate[] = [];\n+    // Use random 3-letter names for internal wires\n+    const names = ['abc', 'def', 'ghi', 'jkl', 'mno', 'pqr', 'stu', 'vwx',\n+      'aab', 'bbc', 'ccd', 'dde', 'eef', 'ffg', 'ggh', 'hhi',\n+      'iij', 'jjk', 'kkl', 'llm', 'mmn', 'nno', 'oop', 'ppq', 'qqr'];\n+    let ni = 0;\n+\n+    // Bit 0: half adder\n+    gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });\n+    const c00 = names[ni++]; // abc\n+    gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: c00 });\n+\n+    const carries: string[] = [c00];\n+    for (let i = 1; i < 6; i++) {\n+      const bit = String(i).padStart(2, '0');\n+      const t = names[ni++];\n+      const a = names[ni++];\n+      const b = names[ni++];\n+      const c = names[ni++];\n+\n+      gates.push({ op: 'XOR', in1: `x${bit}`, in2: `y${bit}`, out: t });\n+      gates.push({ op: 'XOR', in1: t, in2: carries[i - 1], out: `z${bit}` });\n+      gates.push({ op: 'AND', in1: `x${bit}`, in2: `y${bit}`, out: a });\n+      gates.push({ op: 'AND', in1: t, in2: carries[i - 1], out: b });\n+      gates.push({ op: 'OR', in1: a, in2: b, out: c });\n+      carries.push(c);\n+    }\n+    gates.push({ op: 'OR', in1: carries[5], in2: carries[5], out: 'z06' });\n+\n+    // Now swap 4 pairs\n+    // Swap z01 with the partial sum of bit 1 (names[1] = 'def')\n+    let swappedGates = gates.map(g => ({ ...g }));\n+    const swap = (w1: string, w2: string) => {\n+      swappedGates = swappedGates.map(g => {\n+        if (g.out === w1) return { ...g, out: w2 };\n+        if (g.out === w2) return { ...g, out: w1 };\n+        return g;\n+      });\n+    };\n+\n+    // Swap z02 with partial sum of bit 2\n+    swap('z02', names[5]); // z02 <-> ghi\n+    // Swap generate of bit 3 with carry of bit 3\n+    swap(names[10], names[12]); // ccd <-> eef\n+    // Swap z04 with propagate of bit 4\n+    swap('z04', names[15]); // z04 <-> hhi\n+    // Swap z00 with carry of bit 0\n+    swap('z00', c00); // z00 <-> abc\n+\n+    const result = findSwappedWires(swappedGates);\n+    expect(result).toEqual([c00, names[5], names[10], names[12], names[15], 'z00', 'z02', 'z04'].sort());\n+  });\n+\n+  it('handles carry-output swapped with internal wire', () => {\n+    let gates = buildCorrectAdder(6);\n+\n+    // Swap carry output of bit 2 (c02) with partial sum of bit 4 (t04)\n+    gates = swapOutputs(gates, 'c02', 't04');\n+    // Swap z01 with a01\n+    gates = swapOutputs(gates, 'z01', 'a01');\n+    // Swap z03 with b03\n+    gates = swapOutputs(gates, 'z03', 'b03');\n+    // Swap z05 with a05\n+    gates = swapOutputs(gates, 'z05', 'a05');\n+\n+    const result = findSwappedWires(gates);\n+    expect(result).toEqual(['a01', 'a05', 'b03', 'c02', 't04', 'z01', 'z03', 'z05']);\n+  });\n+\n+  it('handles a 45-bit adder with swaps within 5 seconds', () => {\n+    let gates = buildCorrectAdder(45);\n+\n+    gates = swapOutputs(gates, 'z10', 'a10');\n+    gates = swapOutputs(gates, 't20', 'c20');\n+    gates = swapOutputs(gates, 'b30', 'z30');\n+    gates = swapOutputs(gates, 'z44', 'a44');\n+\n+    const start = Date.now();\n+    const result = findSwappedWires(gates);\n+    const elapsed = Date.now() - start;\n+\n+    expect(result).toEqual(['a10', 'a44', 'b30', 'c20', 't20', 'z10', 'z30', 'z44']);\n+    expect(elapsed).toBeLessThan(5000);\n+  });\n+});\ndiff --git a/src/index.ts b/src/index.ts\nnew file mode 100644\nindex 0000000..40aa3e8\n--- /dev/null\n+++ b/src/index.ts\n@@ -0,0 +1,218 @@\n+export interface Gate {\n+  op: 'AND' | 'OR' | 'XOR';\n+  in1: string;\n+  in2: string;\n+  out: string;\n+}\n+\n+export function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number> {\n+  const wires: Record<string, number> = { ...inputs };\n+  const remaining = new Set(gates.map((_, i) => i));\n+\n+  while (remaining.size > 0) {\n+    let progress = false;\n+    for (const i of remaining) {\n+      const g = gates[i];\n+      if (wires[g.in1] !== undefined && wires[g.in2] !== undefined) {\n+        const a = wires[g.in1];\n+        const b = wires[g.in2];\n+        if (g.op === 'AND') wires[g.out] = a & b;\n+        else if (g.op === 'OR') wires[g.out] = a | b;\n+        else wires[g.out] = a ^ b;\n+        remaining.delete(i);\n+        progress = true;\n+      }\n+    }\n+    if (!progress) break;\n+  }\n+\n+  return wires;\n+}\n+\n+export function findSwappedWires(gates: Gate[]): string[] {\n+  // Work on a deep copy to avoid mutating caller's data\n+  const g = gates.map(gate => ({ ...gate }));\n+  const swapped: Set<string> = new Set();\n+\n+  // Build index: output wire -> gate\n+  const outMap = new Map<string, Gate>();\n+  for (const gate of g) outMap.set(gate.out, gate);\n+\n+  function findGate(op: Gate['op'], a: string, b: string): Gate | undefined {\n+    return g.find(gate =>\n+      gate.op === op && ((gate.in1 === a && gate.in2 === b) || (gate.in1 === b && gate.in2 === a))\n+    );\n+  }\n+\n+  function doSwap(actual: string, expected: string): void {\n+    if (actual === expected) return;\n+    swapped.add(actual);\n+    swapped.add(expected);\n+    const gateA = outMap.get(actual);\n+    const gateB = outMap.get(expected);\n+    if (gateA) {\n+      gateA.out = expected;\n+      outMap.delete(actual);\n+      outMap.set(expected, gateA);\n+    }\n+    if (gateB) {\n+      gateB.out = actual;\n+      outMap.delete(expected);\n+      outMap.set(actual, gateB);\n+    }\n+  }\n+\n+  // Determine number of input bits\n+  const xBits = g\n+    .flatMap(gate => [gate.in1, gate.in2])\n+    .filter(w => w.startsWith('x'))\n+    .map(w => parseInt(w.slice(1)))\n+    .reduce((max, n) => Math.max(max, n), -1) + 1;\n+\n+  let carry = '';\n+\n+  for (let i = 0; i < xBits; i++) {\n+    const bit = String(i).padStart(2, '0');\n+    const xWire = `x${bit}`;\n+    const yWire = `y${bit}`;\n+    const zWire = `z${bit}`;\n+\n+    if (i === 0) {\n+      // Half adder: x00 XOR y00 -> z00, x00 AND y00 -> carry\n+      const xorGate = findGate('XOR', xWire, yWire);\n+      if (xorGate && xorGate.out !== zWire) {\n+        doSwap(xorGate.out, zWire);\n+      }\n+      const andGate = findGate('AND', xWire, yWire);\n+      if (andGate) carry = andGate.out;\n+    } else {\n+      // Full adder for bit i:\n+      // 1. partialSum = xNN XOR yNN\n+      // 2. zNN = partialSum XOR carry_in\n+      // 3. generate = xNN AND yNN\n+      // 4. propagate = partialSum AND carry_in\n+      // 5. carry_out = generate OR propagate\n+\n+      const partialSumGate = findGate('XOR', xWire, yWire);\n+      if (!partialSumGate) continue;\n+      let partialSum = partialSumGate.out;\n+\n+      // Find the sum gate: XOR with partialSum and carry\n+      let sumGate = findGate('XOR', partialSum, carry);\n+\n+      if (!sumGate) {\n+        // We can't find XOR(partialSum, carry). One or both are wrong.\n+        // Strategy: use the zWire gate as anchor when possible.\n+\n+        const zGate = outMap.get(zWire);\n+\n+        if (zGate && zGate.op === 'XOR') {\n+          // z-output has an XOR gate — this is likely the correct sum gate.\n+          // Check which inputs it has.\n+          const hasPS = zGate.in1 === partialSum || zGate.in2 === partialSum;\n+          const hasCarry = zGate.in1 === carry || zGate.in2 === carry;\n+\n+          if (hasPS && !hasCarry) {\n+            // partialSum is correct, carry is wrong\n+            const correctCarry = zGate.in1 === partialSum ? zGate.in2 : zGate.in1;\n+            doSwap(carry, correctCarry);\n+            carry = correctCarry;\n+            sumGate = zGate;\n+          } else if (hasCarry && !hasPS) {\n+            // carry is correct, partialSum is wrong\n+            const correctPS = zGate.in1 === carry ? zGate.in2 : zGate.in1;\n+            doSwap(partialSum, correctPS);\n+            partialSum = correctPS;\n+            sumGate = zGate;\n+          } else if (!hasPS && !hasCarry) {\n+            // Neither matches — both partialSum and carry are wrong.\n+            // This shouldn't happen with only 4 swap pairs.\n+            // Fall through to other strategies.\n+          }\n+          // If both hasPS && hasCarry, that means sumGate would have been found above.\n+        }\n+\n+        if (!sumGate) {\n+          // z-output is NOT an XOR gate (z-output wire itself might be swapped)\n+          // OR z-gate didn't help.\n+          // Find the actual sum gate by looking for an XOR with partialSum as input.\n+          // partialSum comes directly from xNN XOR yNN so is reliable\n+          // UNLESS partialSum itself is the swapped wire.\n+          const xorWithPS = g.filter(gate =>\n+            gate.op === 'XOR' && gate !== partialSumGate &&\n+            (gate.in1 === partialSum || gate.in2 === partialSum)\n+          );\n+\n+          if (xorWithPS.length === 1) {\n+            sumGate = xorWithPS[0];\n+            const otherInput = sumGate.in1 === partialSum ? sumGate.in2 : sumGate.in1;\n+            if (otherInput !== carry) {\n+              doSwap(carry, otherInput);\n+              carry = otherInput;\n+            }\n+          } else {\n+            // Try finding XOR with carry as input (partialSum might be swapped)\n+            const xorWithCarry = g.filter(gate =>\n+              gate.op === 'XOR' && gate !== partialSumGate &&\n+              (gate.in1 === carry || gate.in2 === carry)\n+            );\n+            if (xorWithCarry.length === 1) {\n+              sumGate = xorWithCarry[0];\n+              const correctPS = sumGate.in1 === carry ? sumGate.in2 : sumGate.in1;\n+              if (correctPS !== partialSum) {\n+                doSwap(partialSum, correctPS);\n+                partialSum = correctPS;\n+              }\n+            }\n+          }\n+        }\n+      }\n+\n+      // The sum gate output should be zNN\n+      if (sumGate && sumGate.out !== zWire) {\n+        doSwap(sumGate.out, zWire);\n+      }\n+\n+      // Generate carry: xNN AND yNN\n+      const genGate = findGate('AND', xWire, yWire);\n+      if (!genGate) continue;\n+      const generate = genGate.out;\n+\n+      // Propagate carry: partialSum AND carry_in\n+      const propGate = findGate('AND', partialSum, carry);\n+      if (!propGate) continue;\n+      const propagate = propGate.out;\n+\n+      // Carry out: generate OR propagate\n+      let carryGate = findGate('OR', generate, propagate);\n+      if (carryGate) {\n+        carry = carryGate.out;\n+      } else {\n+        // One of generate or propagate output wires is swapped.\n+        // Find OR gate that has one of them as input.\n+        const orCandidates = g.filter(gate =>\n+          gate.op === 'OR' &&\n+          (gate.in1 === generate || gate.in2 === generate ||\n