+describe('findSwappedWires', () => {
+  // Helper: build a correct N-bit adder circuit
+  function buildCorrectAdder(n: number): Gate[] {
+    const gates: Gate[] = [];
+    // Bit 0: half adder
+    gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });
+    gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });
+
+    for (let i = 1; i < n; i++) {
+      const bit = String(i).padStart(2, '0');
+      const prevBit = String(i - 1).padStart(2, '0');
+      gates.push({ op: 'XOR', in1: `x${bit}`, in2: `y${bit}`, out: `t${bit}` });
+      gates.push({ op: 'XOR', in1: `t${bit}`, in2: `c${prevBit}`, out: `z${bit}` });
+      gates.push({ op: 'AND', in1: `x${bit}`, in2: `y${bit}`, out: `a${bit}` });
+      gates.push({ op: 'AND', in1: `t${bit}`, in2: `c${prevBit}`, out: `b${bit}` });
+      gates.push({ op: 'OR', in1: `a${bit}`, in2: `b${bit}`, out: `c${bit}` });
+    }
+
+    // Final carry -> MSB of z
+    const lastBit = String(n - 1).padStart(2, '0');
+    const zMsb = `z${String(n).padStart(2, '0')}`;
+    // The last carry is the final output bit - we model this as an OR with itself
+    // Actually in the spec example c03 -> z04. We can model as: c(n-1) OR c(n-1) -> z(n)
+    // But that's a weird gate. Let's use XOR with a zero wire approach.
+    // Actually, looking at the spec: "c03 -> z04" is just a wire rename. Let's model
+    // it as an OR gate: c_last OR dummy_zero -> z_msb, where dummy_zero = x00 AND (NOT x00)
+    // Simpler: let's just add a trivial OR gate
+    // Actually the simplest representation is: the last carry c(n-1) feeds directly to z(n)
+    // We need a gate for this. Use XOR with 0: but we don't have a constant 0 wire.
+    // The problem says "c03 -> z04" which is a direct wire, not a gate.
+    // For findSwappedWires, we only care about gates. The final carry-to-z is a special case.
+    // Let's represent it as an OR gate with both inputs being the carry:
+    gates.push({ op: 'OR', in1: `c${lastBit}`, in2: `c${lastBit}`, out: zMsb });
+
+    return gates;
+  }
+
+  // Helper: swap two gate outputs
+  function swapOutputs(gates: Gate[], wire1: string, wire2: string): Gate[] {
+    return gates.map(g => {
+      if (g.out === wire1) return { ...g, out: wire2 };
+      if (g.out === wire2) return { ...g, out: wire1 };
+      return g;
+    });
+  }
+
+  it('detects swapped wires in a small 4-bit adder', () => {
+    let gates = buildCorrectAdder(4);
+
+    // Swap 4 pairs of outputs
+    gates = swapOutputs(gates, 'z01', 'a01');
+    gates = swapOutputs(gates, 'z02', 't02');
+    gates = swapOutputs(gates, 'b03', 'c03');
+    gates = swapOutputs(gates, 'z00', 'c00');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(['a01', 'b03', 'c00', 'c03', 't02', 'z00', 'z01', 'z02']);
+  });
+
+  it('detects different swap patterns in a 6-bit adder', () => {
+    let gates = buildCorrectAdder(6);
+
+    // Swap 4 pairs
+    gates = swapOutputs(gates, 'z03', 'a03');
+    gates = swapOutputs(gates, 't04', 'c04');
+    gates = swapOutputs(gates, 'z01', 'b01');
+    gates = swapOutputs(gates, 'a05', 'z05');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(['a03', 'a05', 'b01', 'c04', 't04', 'z01', 'z03', 'z05']);
+  });
+
+  it('returns sorted wire names', () => {
+    let gates = buildCorrectAdder(4);
+    gates = swapOutputs(gates, 'z01', 'a01');
+    gates = swapOutputs(gates, 'z02', 't02');
+    gates = swapOutputs(gates, 'b03', 'c03');
+    gates = swapOutputs(gates, 'z00', 'c00');
+
+    const result = findSwappedWires(gates);
+    const sorted = [...result].sort();
+    expect(result).toEqual(sorted);
+  });
+
+  it('handles a 10-bit adder with swaps', () => {
+    let gates = buildCorrectAdder(10);
+
+    gates = swapOutputs(gates, 'z02', 't02');
+    gates = swapOutputs(gates, 'a05', 'c05');
+    gates = swapOutputs(gates, 'z07', 'b07');
+    gates = swapOutputs(gates, 't09', 'z09');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(['a05', 'b07', 'c05', 't02', 't09', 'z02', 'z07', 'z09']);
+  });
+
+  it('handles random wire names in a 6-bit adder', () => {
+    // Build adder with random internal wire names
+    const gates: Gate[] = [];
+    // Use random 3-letter names for internal wires
+    const names = ['abc', 'def', 'ghi', 'jkl', 'mno', 'pqr', 'stu', 'vwx',
+      'aab', 'bbc', 'ccd', 'dde', 'eef', 'ffg', 'ggh', 'hhi',
+      'iij', 'jjk', 'kkl', 'llm', 'mmn', 'nno', 'oop', 'ppq', 'qqr'];
+    let ni = 0;
+
+    // Bit 0: half adder
+    gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });
+    const c00 = names[ni++]; // abc
+    gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: c00 });
+
+    const carries: string[] = [c00];
+    for (let i = 1; i < 6; i++) {
+      const bit = String(i).padStart(2, '0');
+      const t = names[ni++];
+      const a = names[ni++];
+      const b = names[ni++];
+      const c = names[ni++];
+
+      gates.push({ op: 'XOR', in1: `x${bit}`, in2: `y${bit}`, out: t });
+      gates.push({ op: 'XOR', in1: t, in2: carries[i - 1], out: `z${bit}` });
+      gates.push({ op: 'AND', in1: `x${bit}`, in2: `y${bit}`, out: a });
+      gates.push({ op: 'AND', in1: t, in2: carries[i - 1], out: b });
+      gates.push({ op: 'OR', in1: a, in2: b, out: c });
+      carries.push(c);
+    }
+    gates.push({ op: 'OR', in1: carries[5], in2: carries[5], out: 'z06' });
+
+    // Now swap 4 pairs
+    // Swap z01 with the partial sum of bit 1 (names[1] = 'def')
+    let swappedGates = gates.map(g => ({ ...g }));
+    const swap = (w1: string, w2: string) => {
+      swappedGates = swappedGates.map(g => {
+        if (g.out === w1) return { ...g, out: w2 };
+        if (g.out === w2) return { ...g, out: w1 };
+        return g;
+      });
+    };
+
+    // Swap z02 with partial sum of bit 2
+    swap('z02', names[5]); // z02 <-> ghi
+    // Swap generate of bit 3 with carry of bit 3
+    swap(names[10], names[12]); // ccd <-> eef
+    // Swap z04 with propagate of bit 4
+    swap('z04', names[15]); // z04 <-> hhi
+    // Swap z00 with carry of bit 0
+    swap('z00', c00); // z00 <-> abc
+
+    const result = findSwappedWires(swappedGates);
+    expect(result).toEqual([c00, names[5], names[10], names[12], names[15], 'z00', 'z02', 'z04'].sort());
+  });
+
+  it('handles carry-output swapped with internal wire', () => {
+    let gates = buildCorrectAdder(6);
+
+    // Swap carry output of bit 2 (c02) with partial sum of bit 4 (t04)
+    gates = swapOutputs(gates, 'c02', 't04');
+    // Swap z01 with a01
+    gates = swapOutputs(gates, 'z01', 'a01');
+    // Swap z03 with b03
+    gates = swapOutputs(gates, 'z03', 'b03');
+    // Swap z05 with a05
+    gates = swapOutputs(gates, 'z05', 'a05');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(['a01', 'a05', 'b03', 'c02', 't04', 'z01', 'z03', 'z05']);
+  });
+
+  it('handles a 45-bit adder with swaps within 5 seconds', () => {
+    let gates = buildCorrectAdder(45);
+
+    gates = swapOutputs(gates, 'z10', 'a10');
+    gates = swapOutputs(gates, 't20', 'c20');
+    gates = swapOutputs(gates, 'b30', 'z30');
+    gates = swapOutputs(gates, 'z44', 'a44');
+
+    const start = Date.now();
+    const result = findSwappedWires(gates);
+    const elapsed = Date.now() - start;
+
+    expect(result).toEqual(['a10', 'a44', 'b30', 'c20', 't20', 'z10', 'z30', 'z44']);
+    expect(elapsed).toBeLessThan(5000);
+  });
+});
