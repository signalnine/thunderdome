  describe('getVersion', () => {\n    it('returns a specific version of a plugin', () => {\n      registry.register(makeManifest({ version: '1.0.0' }));\n      registry.register(makeManifest({ version: '2.0.0' }));\n      const result = registry.getVersion('test-plugin', '1.0.0');\n      expect(result?.version).toBe('1.0.0');\n    });\n\n    it('returns null for non-existent version', () => {\n      registry.register(makeManifest({ version: '1.0.0' }));\n      expect(registry.getVersion('test-plugin', '3.0.0')).toBeNull();\n    });\n\n    it('returns null for non-existent plugin name', () => {\n      expect(registry.getVersion('nonexistent', '1.0.0')).toBeNull();\n    });\n  });\n\n  describe('list', () => {\n    it('returns all registered manifests', () => {\n      registry.register(makeManifest({ name: 'plugin-a', version: '1.0.0' }));\n      registry.register(makeManifest({ name: 'plugin-b', version: '1.0.0' }));\n      const all = registry.list();\n      expect(all).toHaveLength(2);\n      expect(all.map(p => p.name)).toContain('plugin-a');\n      expect(all.map(p => p.name)).toContain('plugin-b');\n    });\n\n    it('returns empty array when no plugins registered', () => {\n      expect(registry.list()).toEqual([]);\n    });\n\n    it('returns latest version for each plugin', () => {\n      registry.register(makeManifest({ name: 'plugin-a', version: '1.0.0' }));\n      registry.register(makeManifest({ name: 'plugin-a', version: '2.0.0' }));\n      const all = registry.list();\n      expect(all).toHaveLength(1);\n      expect(all[0].version).toBe('2.0.0');\n    });\n  });\n\n  describe('search', () => {\n    it('finds plugins by name substring', () => {\n      registry.register(makeManifest({ name: 'auth-plugin' }));\n      registry.register(makeManifest({ name: 'data-plugin' }));\n      const results = registry.search('auth');\n      expect(results).toHaveLength(1);\n      expect(results[0].name).toBe('auth-plugin');\n    });\n\n    it('finds plugins by description substring', () => {\n      registry.register(makeManifest({ name: 'my-plugin', description: 'Handles authentication' }));\n      const results = registry.search('authentication');\n      expect(results).toHaveLength(1);\n    });\n\n    it('is case-insensitive', () => {\n      registry.register(makeManifest({ name: 'Auth-Plugin' }));\n      const results = registry.search('auth');\n      expect(results).toHaveLength(1);\n    });\n\n    it('returns empty array for no matches', () => {\n      registry.register(makeManifest({ name: 'my-plugin' }));\n      expect(registry.search('nonexistent')).toEqual([]);\n    });\n  });\n\n  describe('remove', () => {\n    it('removes a specific version', () => {\n      registry.register(makeManifest({ version: '1.0.0' }));\n      registry.register(makeManifest({ version: '2.0.0' }));\n      const removed = registry.remove('test-plugin', '1.0.0');\n      expect(removed).toBe(true);\n      expect(registry.getVersion('test-plugin', '1.0.0')).toBeNull();\n      expect(registry.getVersion('test-plugin', '2.0.0')).not.toBeNull();\n    });\n\n    it('returns false for non-existent plugin', () => {\n      expect(registry.remove('nonexistent', '1.0.0')).toBe(false);\n    });\n\n    it('returns false for non-existent version', () => {\n      registry.register(makeManifest({ version: '1.0.0' }));\n      expect(registry.remove('test-plugin', '9.9.9')).toBe(false);\n    });\n  });\n\n  describe('listVersions', () => {\n    it('returns all versions of a plugin', () => {\n      registry.register(makeManifest({ version: '1.0.0' }));\n      registry.register(makeManifest({ version: '2.0.0' }));\n      registry.register(makeManifest({ version: '1.5.0' }));\n      const versions = registry.listVersions('test-plugin');\n      expect(versions).toHaveLength(3);\n      expect(versions).toContain('1.0.0');\n      expect(versions).toContain('1.5.0');\n      expect(versions).toContain('2.0.0');\n    });\n\n    it('returns empty array for non-existent plugin', () => {\n      expect(registry.listVersions('nonexistent')).toEqual([]);\n    });\n  });\n\n  describe('update', () => {\n    it('updates a plugin manifest partially', () => {\n      registry.register(makeManifest({ version: '1.0.0', description: 'old' }));\n      registry.update('test-plugin', '1.0.0', { description: 'new' });\n      const updated = registry.getVersion('test-plugin', '1.0.0');\n      expect(updated?.description).toBe('new');\n    });\n\n    it('throws for non-existent plugin', () => {\n      expect(() => registry.update('nonexistent', '1.0.0', { description: 'x' })).toThrow();\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":332,"cache_read_input_tokens":28913,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":332},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"317a320e-f69c-41f4-82f8-3366e9d2c6c5","uuid":"d3e4938c-819e-4f90-a9e0-a4042334cd8d"}
