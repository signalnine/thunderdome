@@ -0,0 +1,148 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { createDepsService } from './index.js';
+import { createRegistry } from '../registry/index.js';
+import type { DepsService, RegistryService, PluginManifest } from '../types.js';
+
+function makeManifest(name: string, version: string, deps: Record<string, string> = {}): PluginManifest {
+  return {
+    name,
+    version,
+    description: `${name} plugin`,
+    author: 'tester',
+    dependencies: deps,
+    entryPoint: 'result = true',
+    permissions: [],
+  };
+}
+
+describe('DepsService', () => {
+  let deps: DepsService;
+  let registry: RegistryService;
+
+  beforeEach(() => {
+    deps = createDepsService();
+    registry = createRegistry();
+  });
+
+  describe('buildTree', () => {
+    it('builds a tree for a plugin with no dependencies', () => {
+      registry.register(makeManifest('root', '1.0.0'));
+      const tree = deps.buildTree('root', registry);
+      expect(tree.name).toBe('root');
+      expect(tree.version).toBe('1.0.0');
+      expect(tree.dependencies).toEqual([]);
+    });
+
+    it('builds a tree with nested dependencies', () => {
+      registry.register(makeManifest('app', '1.0.0', { lib: '^1.0.0' }));
+      registry.register(makeManifest('lib', '1.0.0', { util: '^1.0.0' }));
+      registry.register(makeManifest('util', '1.0.0'));
+      const tree = deps.buildTree('app', registry);
+      expect(tree.name).toBe('app');
+      expect(tree.dependencies).toHaveLength(1);
+      expect(tree.dependencies[0].name).toBe('lib');
+      expect(tree.dependencies[0].dependencies).toHaveLength(1);
+      expect(tree.dependencies[0].dependencies[0].name).toBe('util');
+    });
+  });
+
+  describe('detectCycles', () => {
+    it('returns null for acyclic dependency graph', () => {
+      registry.register(makeManifest('a', '1.0.0', { b: '^1.0.0' }));
+      registry.register(makeManifest('b', '1.0.0'));
+      expect(deps.detectCycles('a', registry)).toBeNull();
+    });
+
+    it('detects direct circular dependencies', () => {
+      registry.register(makeManifest('a', '1.0.0', { b: '^1.0.0' }));
+      registry.register(makeManifest('b', '1.0.0', { a: '^1.0.0' }));
+      const cycles = deps.detectCycles('a', registry);
+      expect(cycles).not.toBeNull();
+      expect(cycles!.length).toBeGreaterThan(0);
+    });
+
+    it('detects indirect circular dependencies', () => {
+      registry.register(makeManifest('a', '1.0.0', { b: '^1.0.0' }));
+      registry.register(makeManifest('b', '1.0.0', { c: '^1.0.0' }));
+      registry.register(makeManifest('c', '1.0.0', { a: '^1.0.0' }));
+      const cycles = deps.detectCycles('a', registry);
+      expect(cycles).not.toBeNull();
+      expect(cycles!.length).toBeGreaterThan(0);
+    });
+  });
+
+  describe('hasCircularDependency', () => {
+    it('returns false for acyclic graph', () => {
+      registry.register(makeManifest('a', '1.0.0', { b: '^1.0.0' }));
+      registry.register(makeManifest('b', '1.0.0'));
+      expect(deps.hasCircularDependency('a', registry)).toBe(false);
+    });
+
+    it('returns true for circular graph', () => {
+      registry.register(makeManifest('a', '1.0.0', { b: '^1.0.0' }));
+      registry.register(makeManifest('b', '1.0.0', { a: '^1.0.0' }));
+      expect(deps.hasCircularDependency('a', registry)).toBe(true);
+    });
+  });
+
+  describe('topologicalSort', () => {
+    it('returns correct order for linear dependency chain', () => {
+      registry.register(makeManifest('a', '1.0.0', { b: '^1.0.0' }));
+      registry.register(makeManifest('b', '1.0.0', { c: '^1.0.0' }));
+      registry.register(makeManifest('c', '1.0.0'));
+      const sorted = deps.topologicalSort('a', registry);
+      expect(sorted.indexOf('c')).toBeLessThan(sorted.indexOf('b'));
+      expect(sorted.indexOf('b')).toBeLessThan(sorted.indexOf('a'));
+    });
+
+    it('returns single-element array for plugin with no deps', () => {
+      registry.register(makeManifest('solo', '1.0.0'));
+      expect(deps.topologicalSort('solo', registry)).toEqual(['solo']);
+    });
+
+    it('handles diamond dependencies', () => {
+      registry.register(makeManifest('app', '1.0.0', { left: '^1.0.0', right: '^1.0.0' }));
+      registry.register(makeManifest('left', '1.0.0', { base: '^1.0.0' }));
+      registry.register(makeManifest('right', '1.0.0', { base: '^1.0.0' }));
+      registry.register(makeManifest('base', '1.0.0'));
+      const sorted = deps.topologicalSort('app', registry);
+      expect(sorted.indexOf('base')).toBeLessThan(sorted.indexOf('left'));
+      expect(sorted.indexOf('base')).toBeLessThan(sorted.indexOf('right'));
+      expect(sorted.indexOf('left')).toBeLessThan(sorted.indexOf('app'));
+      expect(sorted.indexOf('right')).toBeLessThan(sorted.indexOf('app'));
+    });
+  });
+
+  describe('flattenDependencies', () => {
+    it('returns all transitive dependencies', () => {
+      registry.register(makeManifest('a', '1.0.0', { b: '^1.0.0' }));
+      registry.register(makeManifest('b', '1.0.0', { c: '^1.0.0' }));
+      registry.register(makeManifest('c', '1.0.0'));
+      const flat = deps.flattenDependencies('a', registry);
+      expect(flat).toContain('b');
+      expect(flat).toContain('c');
+    });
+
+    it('does not include the root plugin', () => {
+      registry.register(makeManifest('a', '1.0.0', { b: '^1.0.0' }));
+      registry.register(makeManifest('b', '1.0.0'));
+      const flat = deps.flattenDependencies('a', registry);
+      expect(flat).not.toContain('a');
+    });
+
+    it('returns empty array for plugin with no deps', () => {
+      registry.register(makeManifest('solo', '1.0.0'));
+      expect(deps.flattenDependencies('solo', registry)).toEqual([]);
+    });
+
+    it('deduplicates shared dependencies', () => {
+      registry.register(makeManifest('app', '1.0.0', { left: '^1.0.0', right: '^1.0.0' }));
+      registry.register(makeManifest('left', '1.0.0', { shared: '^1.0.0' }));
+      registry.register(makeManifest('right', '1.0.0', { shared: '^1.0.0' }));
+      registry.register(makeManifest('shared', '1.0.0'));
+      const flat = deps.flattenDependencies('app', registry);
+      const sharedCount = flat.filter(d => d === 'shared').length;
+      expect(sharedCount).toBe(1);
+    });
+  });
+});
