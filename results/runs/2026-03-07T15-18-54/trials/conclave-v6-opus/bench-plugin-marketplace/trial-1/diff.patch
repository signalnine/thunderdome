ync () => {\n+      const result = await runner.execute('result = typeof require');\n+      expect(result.success).toBe(true);\n+      expect(result.output).toBe('undefined');\n+    });\n+\n+    it('handles syntax errors', async () => {\n+      const result = await runner.execute('function {{{');\n+      expect(result.success).toBe(false);\n+      expect(result.error).toBeDefined();\n+    });\n+\n+    it('returns undefined output when no result is set', async () => {\n+      const result = await runner.execute('const x = 5');\n+      expect(result.success).toBe(true);\n+      expect(result.output).toBeUndefined();\n+    });\n+  });\n+\n+  describe('executeWithTimeout', () => {\n+    it('executes code within timeout', async () => {\n+      const result = await runner.executeWithTimeout('result = 42', 1000);\n+      expect(result.success).toBe(true);\n+      expect(result.output).toBe(42);\n+    });\n+\n+    it('times out on long-running code', async () => {\n+      const result = await runner.executeWithTimeout('while(true) {}', 100);\n+      expect(result.success).toBe(false);\n+      expect(result.error).toBeDefined();\n+    });\n+\n+    it('passes context with timeout', async () => {\n+      const result = await runner.executeWithTimeout('result = name', 1000, { name: 'test' });\n+      expect(result.success).toBe(true);\n+      expect(result.output).toBe('test');\n+    });\n+  });\n+});\ndiff --git a/src/runner/index.ts b/src/runner/index.ts\nnew file mode 100644\nindex 0000000..68b73b7\n--- /dev/null\n+++ b/src/runner/index.ts\n@@ -0,0 +1,54 @@\n+import * as vm from 'node:vm';\n+import type { RunnerService, SandboxResult } from '../types.js';\n+\n+export function createRunner(): RunnerService {\n+  function run(code: string, timeoutMs?: number, context?: Record<string, unknown>): SandboxResult {\n+    const sandbox: Record<string, unknown> = {\n+      result: undefined,\n+      ...context,\n+    };\n+\n+    vm.createContext(sandbox);\n+\n+    const startTime = p