+import { describe, it, expect, beforeEach } from 'vitest';
+import { createMarketplace } from './index.js';
+
+function makeManifest(overrides: Record<string, unknown> = {}) {
+  return {
+    name: 'test-plugin',
+    version: '1.0.0',
+    description: 'A test plugin',
+    author: 'tester',
+    dependencies: {},
+    entryPoint: 'result = 42',
+    permissions: [],
+    ...overrides,
+  };
+}
+
+describe('createMarketplace', () => {
+  let marketplace: ReturnType<typeof createMarketplace>;
+
+  beforeEach(() => {
+    marketplace = createMarketplace();
+  });
+
+  it('exposes registry, resolver, runner, reviews, and deps services', () => {
+    expect(marketplace.registry).toBeDefined();
+    expect(marketplace.resolver).toBeDefined();
+    expect(marketplace.runner).toBeDefined();
+    expect(marketplace.reviews).toBeDefined();
+    expect(marketplace.deps).toBeDefined();
+  });
+
+  describe('installPlugin', () => {
+    it('installs a simple plugin with no dependencies', async () => {
+      const result = await marketplace.installPlugin(makeManifest());
+      expect(result.sandboxResult.success).toBe(true);
+      expect(result.sandboxResult.output).toBe(42);
+      expect(result.resolvedDependencies).toEqual([]);
+    });
+
+    it('registers the plugin in the registry during install', async () => {
+      await marketplace.installPlugin(makeManifest());
+      const plugin = marketplace.registry.get('test-plugin');
+      expect(plugin).not.toBeNull();
+      expect(plugin?.version).toBe('1.0.0');
+    });
+
+    it('resolves dependencies during install', async () => {
+      // Register dependencies first
+      marketplace.registry.register(makeManifest({
+        name: 'dep-a',
+        version: '1.0.0',
+        entryPoint: 'result = "a"',
+      }));
+      marketplace.registry.register(makeManifest({
+        name: 'dep-a',
+        version: '2.0.0',
+        entryPoint: 'result = "a2"',
+      }));
+
+      const result = await marketplace.installPlugin(makeManifest({
+        name: 'my-app',
+        dependencies: { 'dep-a': '^1.0.0' },
+      }));
+
+      expect(result.resolvedDependencies).toHaveLength(1);
+      expect(result.resolvedDependencies[0].name).toBe('dep-a');
+      expect(result.resolvedDependencies[0].version).toBe('1.0.0');
+    });
+
+    it('rejects plugins with circular dependencies', async () => {
+      marketplace.registry.register(makeManifest({
+        name: 'cycle-b',
+        version: '1.0.0',
+        dependencies: { 'cycle-a': '^1.0.0' },
+      }));
+
+      await expect(
+        marketplace.installPlugin(makeManifest({
+          name: 'cycle-a',
+          version: '1.0.0',
+          dependencies: { 'cycle-b': '^1.0.0' },
+        }))
+      ).rejects.toThrow(/circular/i);
+    });
+
+    it('rejects manifest missing name', async () => {
+      await expect(
+        marketplace.installPlugin(makeManifest({ name: '' }))
+      ).rejects.toThrow();
+    });
+
+    it('rejects manifest missing version', async () => {
+      await expect(
+        marketplace.installPlugin(makeManifest({ version: '' }))
+      ).rejects.toThrow();
+    });
+
+    it('rejects manifest missing entryPoint', async () => {
+      await expect(
+        marketplace.installPlugin(makeManifest({ entryPoint: '' }))
+      ).rejects.toThrow();
+    });
+
+    it('handles sandbox execution errors gracefully', async () => {
+      const result = await marketplace.installPlugin(makeManifest({
+        entryPoint: 'throw new Error("plugin crash")',
+      }));
+      expect(result.sandboxResult.success).toBe(false);
+      expect(result.sandboxResult.error).toContain('plugin crash');
+    });
+
+    it('executes entryPoint code in sandbox', async () => {
+      const result = await marketplace.installPlugin(makeManifest({
+        entryPoint: 'result = "hello world"',
+      }));
+      expect(result.sandboxResult.success).toBe(true);
+      expect(result.sandboxResult.output).toBe('hello world');
+    });
+  });
+});
