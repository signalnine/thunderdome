n sandbox', async () => {\n      const result = await marketplace.installPlugin(makeManifest({\n        entryPoint: 'result = \"hello world\"',\n      }));\n      expect(result.sandboxResult.success).toBe(true);\n      expect(result.sandboxResult.output).toBe('hello world');\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":346,"cache_read_input_tokens":45993,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":346},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"317a320e-f69c-41f4-82f8-3366e9d2c6c5","uuid":"668be963-d0e8-4ed1-87e8-9ac1148f508b"}
