    for (const s of shares) {\n            if (s.resourceType === 'folder' && s.resourceId === folderId && s.userId === userId) {\n              best = best ? higherRole(best, s.role) : s.role;\n            }\n          }\n          folderId = folder.parentId;\n        }\n      }\n    }\n\n    // For folders, also check parent folder shares (walk up)\n    if (resourceType === 'folder') {\n      const folder = folders.get(resourceId);\n      if (folder) {\n        let parentId: string | null = folder.parentId;\n        while (parentId) {\n          const parent = folders.get(parentId);\n          if (!parent) break;\n          if (parent.ownerId === userId) {\n            best = best ? higherRole(best, 'owner') : 'owner';\n          }\n          for (const s of shares) {\n            if (s.resourceType === 'folder' && s.resourceId === parentId && s.userId === userId) {\n              best = best ? higherRole(best, s.role) : s.role;\n            }\n          }\n          parentId = parent.parentId;\n        }\n      }\n    }\n\n    return best;\n  }\n\n  function requireRole(userId: string, resourceType: 'folder' | 'document', resourceId: string, minRole: Role): Role | null {\n    const role = getEffectiveRole(userId, resourceType, resourceId);\n    if (!role) return null;\n    if (ROLE_LEVEL[role] >= ROLE_LEVEL[minRole]) return role;\n    return null;\n  }\n\n  function logActivity(action: string, userId: string, resourceType: 'folder' | 'document', resourceId: string, details?: string): void {\n    activityLog.push({\n      id: uid(),\n      action,\n      userId,\n      resourceType,\n      resourceId,\n      details: details ?? null,\n      timestamp: new Date().toISOString(),\n    });\n  }\n\n  // ---------- Auth routes ----------\n\n  app.post('/auth/register', (req: Request, res: Response) => {\n    const { username, password } = req.body;\n    if (!username || typeof username !== 'string') {\n      res.status(400).json({ error: 'Username is required' });\n      return;\n    }\n    if (!password || typeof password !== 'string') {\n      res.status(400).json({ error: 'Password is required' });\n      return;\n    }\n    if (usernameIndex.has(username)) {\n      res.status(409).json({ error: 'Username already taken' });\n      return;\n    }\n    const id = uid();\n    const user: User = {\n      id,\n      username,\n      passwordHash: hashPassword(password),\n      createdAt: new Date().toISOString(),\n    };\n    users.set(id, user);\n    usernameIndex.set(username, id);\n    res.status(201).json({ id: user.id, username: user.username });\n  });\n\n  app.post('/auth/login', (req: Request, res: Response) => {\n    const { username, password } = req.body;\n    const userId = usernameIndex.get(username);\n    if (!userId) {\n      res.status(401).json({ error: 'Invalid credentials' });\n      return;\n    }\n    const user = users.get(userId)!;\n    if (user.passwordHash !== hashPassword(password)) {\n      res.status(401).json({ error: 'Invalid credentials' });\n      return;\n    }\n    const token = crypto.randomBytes(32).toString('hex');\n    tokens.set(token, userId);\n    res.json({ token });\n  });\n\n  // ---------- Folder routes ----------\n\n  app.post('/folders', requireAuth, (req: AuthRequest, res: Response) => {\n    const { name, parentId } = req.body;\n    if (!name || typeof name !== 'string') {\n      res.status(400).json({ error: 'Folder name is required' });\n      return;\n    }\n    if (parentId !== undefined && parentId !== null) {\n      if (!folders.has(parentId)) {\n        res.status(404).json({ error: 'Parent folder not found' });\n        return;\n      }\n      const role = requireRole(req.userId!, 'folder', parentId, 'editor');\n      if (!role) {\n        res.status(403).json({ error: 'Access denied' });\n        return;\n      }\n    }\n    const id = uid();\n    const now = new Date().toISOString();\n    const folder: Folder = {\n      id,\n      name,\n      parentId: parentId ?? null,\n  