ken}`)\n        .send({ name: 'Child', parentId: parent.body.id });\n\n      expect(res.status).toBe(201);\n      expect(res.body.parentId).toBe(parent.body.id);\n    });\n\n    it('rejects missing name', async () => {\n      const res = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({});\n\n      expect(res.status).toBe(400);\n    });\n\n    it('rejects nonexistent parent folder', async () => {\n      const res = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Child', parentId: 'nonexistent' });\n\n      expect(res.status).toBe(404);\n    });\n\n    it('requires authentication', async () => {\n      const res = await request(app)\n        .post('/folders')\n        .send({ name: 'Folder' });\n\n      expect(res.status).toBe(401);\n    });\n  });\n\n  describe('GET /folders/:id', () => {\n    it('returns folder with children and documents', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Root' });\n\n      const child = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Child', parentId: folder.body.id });\n\n      const res = await request(app)\n        .get(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe('Root');\n      expect(res.body.children).toHaveLength(1);\n      expect(res.body.children[0].id).toBe(child.body.id);\n    });\n\n    it('returns 404 for nonexistent folder', async () => {\n      const res = await request(app)\n        .get('/folders/nonexistent')\n        .set('Authorization', `Bearer ${token}`);\n\n      expect(res.status).toBe(404);\n    });\n  });\n\n  describe('PUT /folders/:id', () => {\n    it('updates folder name', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Old Name' });\n\n      const res = await request(app)\n        .put(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'New Name' });\n\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe('New Name');\n    });\n\n    it('returns 404 for nonexistent folder', async () => {\n      const res = await request(app)\n        .put('/folders/nonexistent')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'New Name' });\n\n      expect(res.status).toBe(404);\n    });\n  });\n\n  describe('DELETE /folders/:id', () => {\n    it('deletes a folder', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'To Delete' });\n\n      const res = await request(app)\n        .delete(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n\n      expect(res.status).toBe(204);\n\n      const getRes = await request(app)\n        .get(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n\n      expect(getRes.status).toBe(404);\n    });\n\n    it('returns 404 for nonexistent folder', async () => {\n      const res = await request(app)\n        .delete('/folders/nonexistent')\n        .set('Authorization', `Bearer ${token}`);\n\n      expect(res.status).toBe(404);\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":527,"cache_read_input_tokens":45140,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":527},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"139119ac-2358-47de-bf5f-afc4a602d926","uui