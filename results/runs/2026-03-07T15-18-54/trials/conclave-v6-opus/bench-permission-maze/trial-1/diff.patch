@@ -0,0 +1,506 @@
+import express, { Request, Response, NextFunction } from 'express';
+import crypto from 'node:crypto';
+
+// ---------- Types ----------
+
+interface User {
+  id: string;
+  username: string;
+  passwordHash: string;
+  createdAt: string;
+}
+
+interface Folder {
+  id: string;
+  name: string;
+  parentId: string | null;
+  ownerId: string;
+  createdAt: string;
+  updatedAt: string;
+}
+
+interface Document {
+  id: string;
+  title: string;
+  content: string;
+  folderId: string;
+  ownerId: string;
+  createdAt: string;
+  updatedAt: string;
+}
+
+type Role = 'viewer' | 'editor' | 'owner';
+
+interface Share {
+  id: string;
+  resourceType: 'folder' | 'document';
+  resourceId: string;
+  userId: string;
+  role: Role;
+  createdAt: string;
+}
+
+interface ActivityEntry {
+  id: string;
+  action: string;
+  userId: string;
+  resourceType: 'folder' | 'document';
+  resourceId: string;
+  details: string | null;
+  timestamp: string;
+}
+
+// Extend Express Request
+interface AuthRequest extends Request {
+  userId?: string;
+}
+
+// ---------- Helpers ----------
+
+function uid(): string {
+  return crypto.randomUUID();
+}
+
+function hashPassword(password: string): string {
+  return crypto.createHash('sha256').update(password).digest('hex');
+}
+
+const ROLE_LEVEL: Record<Role, number> = { viewer: 1, editor: 2, owner: 3 };
+
+function higherRole(a: Role, b: Role): Role {
+  return ROLE_LEVEL[a] >= ROLE_LEVEL[b] ? a : b;
+}
+
+// ---------- App factory ----------
+
+export function createApp(): express.Express {
+  const app = express();
+  app.use(express.json());
+
+  // In-memory stores
+  const users = new Map<string, User>();
+  const usernameIndex = new Map<string, string>(); // username → userId
+  const tokens = new Map<string, string>(); // token → userId
+  const folders = new Map<string, Folder>();
+  const documents = new Map<string, Document>();
+  const shares: Share[] = [];
+  const activityLog: ActivityEntry[] = [];
+
+  // ---------- Auth middleware ----------
+
+  function requireAuth(req: AuthRequest, res: Response, next: NextFunction): void {
+    const header = req.headers.authorization;
+    if (!header || !header.startsWith('Bearer ')) {
+      res.status(401).json({ error: 'Authentication required' });
+      return;
+    }
+    const token = header.slice(7);
+    const userId = tokens.get(token);
+    if (!userId) {
+      res.status(401).json({ error: 'Invalid token' });
+      return;
+    }
+    req.userId = userId;
+    next();
+  }
+
+  // ---------- Permission helpers ----------
+
+  function getEffectiveRole(userId: string, resourceType: 'folder' | 'document', resourceId: string): Role | null {
+    // Check ownership
+    if (resourceType === 'folder') {
+      const folder = folders.get(resourceId);
+      if (folder && folder.ownerId === userId) return 'owner';
+    } else {
+      const doc = documents.get(resourceId);
+      if (doc && doc.ownerId === userId) return 'owner';
+    }
+
+    let best: Role | null = null;
+
+    // Direct shares on this resource
+    for (const s of shares) {
+      if (s.resourceType === resourceType && s.resourceId === resourceId && s.userId === userId) {
+        best = best ? higherRole(best, s.role) : s.role;
+      }
+    }
+
+    // For documents, also check folder shares (walk up the hierarchy)
+    if (resourceType === 'document') {
+      const doc = documents.get(resourceId);
+      if (doc) {
+        let folderId: string | null = doc.folderId;
+        while (folderId) {
+          const folder = folders.get(folderId);
+          if (!folder) break;
+          if (folder.ownerId === userId) {
+            best = best ? higherRole(best, 'owner') : 'owner';
+          }
+          for (const s of shares) {
+            if (s.resourceType === 'folder' && s.resourceId === folderId && s.userId === userId) {
+              best = best ? higherRole(best, s.role) : s.role;
+            }
+          }
+          folderId = folder.parentId;
+        }
+      }
+    }
+
+    // For folders, also check parent folder shares (walk up)
+    if (resourceType === 'folder') {
+      const folder = folders.get(resourceId);
+      if (folder) {
+        let parentId: string | null = folder.parentId;
+        while (parentId) {
+          const parent = folders.get(parentId);
+          if (!parent) break;
+          if (parent.ownerId === userId) {
+            best = best ? higherRole(best, 'owner') : 'owner';
+          }
+          for (const s of shares) {
+            if (s.resourceType === 'folder' && s.resourceId === parentId && s.userId === userId) {
+              best = best ? higherRole(best, s.role) : s.role;
+            }
+          }
+          parentId = parent.parentId;
+        }
+      }
+    }
+
+    return best;
+  }
+
+  function requireRole(userId: string, resourceType: 'folder' | 'document', resourceId: string, minRole: Role): Role | null {
+    const role = getEffectiveRole(userId, resourceType, resourceId);
+    if (!role) return null;
+    if (ROLE_LEVEL[role] >= ROLE_LEVEL[minRole]) return role;
+    return null;
+  }
+
+  function logActivity(action: string, userId: string, resourceType: 'folder' | 'document', resourceId: string, details?: string): void {
+    activityLog.push({
+      id: uid(),
+      action,
+      userId,
+      resourceType,
+      resourceId,
+      details: details ?? null,
+      timestamp: new Date().toISOString(),
+    });
+  }
+
+  // ---------- Auth routes ----------
+
+  app.post('/auth/register', (req: Request, res: Response) => {
+    const { username, password } = req.body;
+    if (!username || typeof username !== 'string') {
+      res.status(400).json({ error: 'Username is required' });
+      return;
+    }
+    if (!password || typeof password !== 'string') {
+      res.status(400).json({ error: 'Password is required' });
+      return;
+    }
+    if (usernameIndex.has(username)) {
+      res.status(409).json({ error: 'Username already taken' });
+      return;
+    }
+    const id = uid();
+    const user: User = {
+      id,
+      username,
+      passwordHash: hashPassword(password),
+      createdAt: new Date().toISOString(),
+    };
+    users.set(id, user);
+    usernameIndex.set(username, id);
+    res.status(201).json({ id: user.id, username: user.username });
+  });
+
+  app.post('/auth/login', (req: Request, res: Response) => {
+    const { username, password } = req.body;
+    const userId = usernameIndex.get(username);
+    if (!userId) {
+      res.status(401).json({ error: 'Invalid credentials' });
+      return;
+    }
+    const user = users.get(userId)!;
+    if (user.passwordHash !== hashPassword(password)) {
+      res.status(401).json({ error: 'Invalid credentials' });
+      return;
+    }
+    const token = crypto.randomBytes(32).toString('hex');
+    tokens.set(token, userId);
+    res.json({ token });
+  });
+
+  // ---------- Folder routes ----------
+
+  app.post('/folders', requireAuth, (req: AuthRequest, res: Response) => {
+    const { name, parentId } = req.body;
+    if (!name || typeof name !== 'string') {
+      res.status(400).json({ error: 'Folder name is required' });
+      return;
+    }
+    if (parentId !== undefined && parentId !== null) {
+      if (!folders.has(parentId)) {
+        res.status(404).json({ error: 'Parent folder not found' });
+        return;
+      }
+      const role = requireRole(req.userId!, 'folder', parentId, 'editor');
+      if (!role) {
+        res.status(403).json({ error: 'Access denied' });
+        return;
+      }
+    }
+    const id = uid();
+    const now = new Date().toISOString();
+    const folder: Folder = {
+      id,
+      name,
+      parentId: parentId ?? null,
+      ownerId: req.userId!,
+      createdAt: now,
+      updatedAt: now,
+    };
+    folders.set(id, folder);
+    logActivity('folder_created', req.userId!, 'folder', id);
+    res.status(201).json(folder);
+  });
+
+  app.get('/folders/:id', requireAuth, (req: AuthRequest, res: Response) => {
+    const folder = folders.get(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+    const role = requireRole(req.userId!, 'folder', folder.id, 'viewer');
+    if (!role) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+    // Include children
+    const children: Folder[] = [];
+    for (const f of folders.values()) {
+      if (f.parentId === folder.id) children.push(f);
+    }
+    const docs: Document[] = [];
+    for (const d of documents.values()) {
+      if (d.folderId === folder.id) docs.push(d);
+    }
+    res.json({ ...folder, children, documents: docs });
+  });
+
+  app.put('/folders/:id', requireAuth, (req: AuthRequest, res: Response) => {
+    const folder = folders.get(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+    const role = requireRole(req.userId!, 'folder', folder.id, 'editor');
+    if (!role) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+    if (req.body.name !== undefined) folder.name = req.body.name;
+    if (req.body.parentId !== undefined) folder.parentId = req.body.parentId;
+    folder.updatedAt = new Date().toISOString();
+    res.json(folder);
+  });
+
+  app.delete('/folders/:id', requireAuth, (req: AuthRequest, res: Response) => {
+    const folder = folders.get(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+    const role = requireRole(req.userId!, 'folder', folder.id, 'owner');
+    if (!role) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+    folders.delete(folder.id);
+    logActivity('folder_deleted', req.userId!, 'folder', folder.id);
+    res.status(204).send();
+  });
+
+  // ---------- Document routes ----------
+
+  app.post('/documents', requireAuth, (req: AuthRequest, res: Response) => {
+    const { title, content, folderId } = req.body;
+    if (!title || typeof title !== 'string') {
+      res.status(400).json({ error: 'Document title is required' });
+      return;
+    }
+    if (content === undefined || typeof content !== 'string') {
+      res.status(400).json({ error: 'Document content is required' });
+      return;
+    }
+    if (!folderId || !folders.has(folderId)) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+    const folderRole = requireRole(req.userId!, 'folder', folderId, 'editor');
+    if (!folderRole) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+    const id = uid();
+    const now = new Date().toISOString();
+    const doc: Document = {
+      id,
+      title,
+      content,
+      folderId,
+      ownerId: req.userId!,
+      createdAt: now,
+      updatedAt: now,
+    };
+    documents.set(id, doc);
+    logActivity('document_created', req.userId!, 'document', id);
+    res.status(201).json(doc);
+  });
+
+  app.get('/documents/:id', requireAuth, (req: AuthRequest, res: Response) => {
+    const doc = documents.get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    const role = requireRole(req.userId!, 'document', doc.id, 'viewer');
+    if (!role) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+    res.json(doc);
+  });
+
+  app.put('/documents/:id', requireAuth, (req: AuthRequest, res: Response) => {
+    const doc = documents.get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    const role = requireRole(req.userId!, 'document', doc.id, 'editor');
+    if (!role) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+    if (req.body.title !== undefined) doc.title = req.body.title;
+    if (req.body.content !== undefined) doc.content = req.body.content;
+    doc.updatedAt = new Date().toISOString();
+    logActivity('document_updated', req.userId!, 'document', doc.id);
+    res.json(doc);
+  });
+
+  app.delete('/documents/:id', requireAuth, (req: AuthRequest, res: Response) => {
+    const doc = documents.get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    const role = requireRole(req.userId!, 'document', doc.id, 'owner');
+    if (!role) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+    documents.delete(doc.id);
+    logActivity('document_deleted', req.userId!, 'document', doc.id);
+    res.status(204).send();
+  });
+
+  // ---------- Share routes ----------
+
+  app.post('/folders/:id/share', requireAuth, (req: AuthRequest, res: Response) => {
+    const folder = folders.get(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+    const callerRole = requireRole(req.userId!, 'folder', folder.id, 'editor');
+    if (!callerRole) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+    const { userId, role } = req.body;
+    if (!userId || !role) {
+      res.status(400).json({ error: 'userId and role are required' });
+      return;
+    }
+    if (!users.has(userId)) {
+      res.status(404).json({ error: 'User not found' });
+      return;
+    }
+    const validRoles: Role[] = ['viewer', 'editor', 'owner'];
+    if (!validRoles.includes(role)) {
+      res.status(400).json({ error: 'Invalid role' });
+      return;
+    }
+    // Only owners can assign owner role
+    if (role === 'owner' && ROLE_LEVEL[callerRole] < ROLE_LEVEL['owner']) {
+      res.status(403).json({ error: 'Only owners can assign owner role' });
+      return;
+    }
+    const share: Share = {
+      id: uid(),
+      resourceType: 'folder',
+      resourceId: folder.id,
+      userId,
+      role,
+      createdAt: new Date().toISOString(),
+    };
+    shares.push(share);
+    logActivity('folder_shared', req.userId!, 'folder', folder.id, `Shared with user ${userId} as ${role}`);
+    res.status(201).json(share);
+  });
+
+  app.post('/documents/:id/share', requireAuth, (req: AuthRequest, res: Response) => {
+    const doc = documents.get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    const callerRole = requireRole(req.userId!, 'document', doc.id, 'editor');
+    if (!callerRole) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+    const { userId, role } = req.body;
+    if (!userId || !role) {
+      res.status(400).json({ error: 'userId and role are required' });
+      return;
+    }
+    if (!users.has(userId)) {
+      res.status(404).json({ error: 'User not found' });
+      return;
+    }
+    const validRoles: Role[] = ['viewer', 'editor', 'owner'];
+    if (!validRoles.includes(role)) {
+      res.status(400).json({ error: 'Invalid role' });
+      return;
+    }
+    if (role === 'owner' && ROLE_LEVEL[callerRole] < ROLE_LEVEL['owner']) {
+      res.status(403).json({ error: 'Only owners can assign owner role' });
+      return;
+    }
+    const share: Share = {
+      id: uid(),
+      resourceType: 'document',
+      resourceId: doc.id,
+      userId,
+      role,
+      createdAt: new Date().toISOString(),
+    };
+    shares.push(share);
+    logActivity('document_shared', req.userId!, 'document', doc.id, `Shared with user ${userId} as ${role}`);
+    res.status(201).json(share);
+  });
+
+  // ---------- Activity log route ----------
+
+  app.get('/activity', requireAuth, (_req: AuthRequest, res: Response) => {
+    res.json(activityLog);
+  });
+
+  return app;
+}
