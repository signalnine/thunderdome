+  });
+
+  test('setStock sets the stock level and emits inventory:updated', () => {
+    inventory.setStock('p1', 100);
+    expect(inventory.getStock('p1')).toBe(100);
+    const log = bus.getLog();
+    const event = log.find(e => e.event === Events.INVENTORY_UPDATED);
+    expect(event).toBeDefined();
+    expect(event!.payload).toEqual({ productId: 'p1', quantity: 100 });
