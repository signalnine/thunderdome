+\n+  test('removeItem removes a product from the cart', () => {\n+    const id = cart.createCart('user1');\n+    cart.addItem(id, 'p1', 2);\n+    cart.addItem(id, 'p2', 1);\n+    cart.removeItem(id, 'p1');\n+    const c = cart.getCart(id);\n+    expect(c!.items).toEqual([{ productId: 'p2', quantity: 1 }]);\n+  });\n+\n+  test('updateQuantity changes quantity for a product', () => {\n+    const id = cart.createCart('user1');\n+    cart.addItem(id, 'p1', 2);\n+    cart.updateQuantity(id, 'p1', 5);\n+    const c = cart.getCart(id);\n+    expect(c!.items).toEqual([{ productId: 'p1', quantity: 5 }]);\n+  });\n+\n+  test('clearCart removes all items', () => {\n+    const id = cart.createCart('user1');\n+    cart.addItem(id, 'p1', 2);\n+    cart.addItem(id, 'p2', 1);\n+    cart.clearCart(id);\n+    const c = cart.getCart(id);\n+    expect(c!.items).toEqual([]);\n+  });\n+});\ndiff --git a/src/cart/index.ts b/src/cart/index.ts\nnew file mode 100644\nindex 0000000..4d2707b\n--- /dev/null\n+++ b/src/cart/index.ts\n@@ -0,0 +1,81 @@\n+import { v4 as uuidv4 } from 'uuid';\n+import { EventBus } from '../bus.js';\n+import { Events, type CartService, type CartUpdatedEvent } from '../types.js';\n+\n+interface CartItem {\n+  productId: string;\n+  quantity: number;\n+}\n+\n+interface Cart {\n+  id: string;\n+  userId: string;\n+  items: CartItem[];\n+}\n+\n+export function createCartService(bus: EventBus): CartService {\n+  const carts = new Map<string, Cart>();\n+\n+  function emitCartUpdated(cart: Cart): void {\n+    const payload: CartUpdatedEvent = {\n+      cartId: cart.id,\n+      userId: cart.userId,\n+      items: cart.items.map(i => ({ ...i })),\n+    };\n+    bus.emit(Events.CART_UPDATED, payload);\n+  }\n+\n+  return {\n+    createCart(userId: string): string {\n+      const id = uuidv4();\n+      carts.set(id, { id, userId, items: [] });\n+      return id;\n+    },\n+\n+    addItem(cartId: string, productId: string, quantity: number): void {\n+      const cart = carts.get(cartId);\n+      if (!cart) return;\n+      const existing = cart.items.find(i => i.productId === productId);\n+      if (existing) {\n+        existing.quantity += quantity;\n+      } else {\n+        cart.items.push({ productId, quantity });\n+      }\n+      emitCartUpdated(cart);\n+    },\n+\n+    removeItem(cartId: string, productId: string): void {\n+      const cart = carts.get(cartId);\n+      if (!cart) return;\n+      cart.items = cart.items.filter(i => i.productId !== productId);\n+      emitCartUpdated(cart);\n+    },\n+\n+    getCart(cartId: string) {\n+      const cart = carts.get(cartId);\n+      if (!cart) return null;\n+      return {\n+        id: cart.id,\n+        userId: cart.userId,\n+        items: cart.items.map(i => ({ ...i })),\n+      };\n+    },\n+\n+    clearCart(cartId: string): void {\n+      const cart = carts.get(cartId);\n+      if (!cart) return;\n+      cart.items = [];\n+      emitCartUpdated(cart);\n+    },\n+\n+    updateQuantity(cartId: string, productId: string, quantity: number): void {\n+      const cart = carts.get(cartId);\n+      if (!cart) return;\n+      const item = cart.items.find(i => i.productId === productId);\n+      if (item) {\n+        item.quantity = quantity;\n+        emitCartUpdated(cart);\n+      }\n+    },\n+  };\n+}\ndiff --git a/src/catalog/index.test.ts b/src/catalog/index.test.ts\nnew file mode 100644\nindex 0000000..ec28e6a\n--- /dev/null\n+++ b/src/catalog/index.test.ts\n@@ -0,0 +1,89 @@\n+import { describe, test, expect, beforeEach } from 'vitest';\n+import { EventBus } from '../bus.js';\n+import { Events } from '../types.js';\n+import { createCatalogService } from './index.js';\n+\n+describe('CatalogService', () => {\n+  let bus: EventBus;\n+  let catalog: ReturnType<typeof createCatalogService>;\n+\n+  beforeEach(() => {\n+    bus = new EventBus();\n+    catalog = createCatalogService(bus);\n+  });\n+\n+  test('createProduct returns a product id', () => {\n+    const id = catalog.createProduct