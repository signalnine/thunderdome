tics.getTopProducts(2);\n    expect(top[0].productId).toBe('p1');\n    expect(top[0].count).toBe(5);\n    expect(top[1].productId).toBe('p2');\n    expect(top[1].count).toBe(1);\n  });","originalFile":"import { describe, test, expect, beforeEach } from 'vitest';\nimport { EventBus } from '../bus.js';\nimport { Events, PaymentStatus, OrderStatus } from '../types.js';\nimport { createAnalyticsService } from './index.js';\n\ndescribe('AnalyticsService', () => {\n  let bus: EventBus;\n  let analytics: ReturnType<typeof createAnalyticsService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    analytics = createAnalyticsService(bus);\n  });\n\n  test('getEventCount returns 0 for unseen event type', () => {\n    expect(analytics.getEventCount('nonexistent')).toBe(0);\n  });\n\n  test('getEventCount tracks events by type', async () => {\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o2', userId: 'u2', cartId: 'c2', total: 200 });\n    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBe(2);\n  });\n\n  test('getRevenue tracks revenue from successful payments', async () => {\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 'tx1' });\n    // Need to know amount - analytics listens for order:created to get totals\n    expect(analytics.getRevenue()).toBe(0); // No order created yet, so revenue from payment events alone\n\n    // Let's test the proper flow: create order, then payment\n  });\n\n  test('getRevenue sums totals of orders with successful payments', async () => {\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o2', userId: 'u2', cartId: 'c2', total: 200 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 'tx1' });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o2', status: PaymentStatus.SUCCESS, transactionId: 'tx2' });\n    expect(analytics.getRevenue()).toBe(300);\n  });\n\n  test('getRevenue does not include failed payments', async () => {\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.FAILED, error: 'declined' });\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  test('getConversionRate returns orders / unique carts', async () => {\n    // 2 carts created (via cart:updated events with unique cartIds)\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [] });\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c2', userId: 'u2', items: [] });\n    // 1 order\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    expect(analytics.getConversionRate()).toBeCloseTo(0.5);\n  });\n\n  test('getConversionRate returns 0 when no carts', () => {\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n\n  test('getTopProducts ranks products by order quantity', async () => {\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o2', userId: 'u2', cartId: 'c2', total: 200 });\n\n    // Analytics needs cart info to know product quantities in orders\n    // We'll use cart:updated events to track cart contents\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [{ productId: 'p1', quantity: 3 }, { productId: 'p2', quantity: 1 }] });\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c2', userId: 'u2', items: [{ productId: 'p1', quantity: 2 }] });\n\n    // Orders use these carts\n    const top = analytics.getTopProducts(2);\n    expect(top[0].productId).toBe('p1');\n    expect(top[0].count).toBe(5);\n    expect(top[1].productId).toBe('p2');\n    expect(top[1].count).toBe(1);\n  });\n\n  test('getTopProducts respects limit', async () => {\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [\n      { productId: 'p1', quantity: 5 },\n      { productId: 'p2', quantity: 3 },\n      { productId: 'p3', quantity: 1 },\n    ]});\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    const top = analytics.getTopProducts(2);\n    expect(top).toHaveLength(2);\n  });\n\n  test('tracks all event types for getEventCount', async () => {\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'Widget', price: 10, category: 'gadgets' });\n    await bus.emit(Events.INVENTORY_UPDATED, { productId: 'p1', quantity: 100 });\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [] });\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(1);\n    expect(analytics.getEventCount(Events.INVENTORY_UPDATED)).toBe(1);\n    expect(analytics.getEventCount(Events.CART_UPDATED)).toBe(1);\n  });\n});\n","structuredPatch":[{"oldStart":58,"oldLines":15,"newStart":58,"newLines":13,"lines":["   });"," ","   test('getTopProducts ranks products by order quantity', async () => {","-    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });","-    await bus.emit(Events.ORDER_CREATED, { orderId: 'o2', userId: 'u2', cartId: 'c2', total: 200 });","-","-    // Analytics needs cart info to know product quantities in orders","-    // We'll use cart:updated events to track cart contents","+    // Cart contents are tracked before orders are created (natural flow)","     await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [{ productId: 'p1', quantity: 3 }, { productId: 'p2', quantity: 1 }] });","     await bus.emit(Events.CART_UPDATED, { cartId: 'c2', userId: 'u2', items: [{ productId: 'p1', quantity: 2 }] });"," ","-    // Orders use these carts","+    await 