Id: 'u2', cartId: 'c2', total: 200 });\n+    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 'tx1' });\n+    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o2', status: PaymentStatus.SUCCESS, transactionId: 'tx2' });\n+    expect(analytics.getRevenue()).toBe(300);\n+  });\n+\n+  test('getRevenue does not include failed payments', async () => {\n+    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n+    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.FAILED, error: 'declined' });\n+    expect(analytics.getRevenue()).toBe(0);\n+  });\n+\n+  test('getConversionRate returns orders / unique carts', async () => {\n+    // 2 carts created (via cart:updated events with unique cartIds)\n+    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [] });\n+    await bus.emit(Events.CART_UPDATED, { cartId: 'c2', userId: 'u2', items: [] });\n+    // 1 order\n+    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n+    expect(analytics.getConversionRate()).toBeCloseTo(0.5);\n+  });\n+\n+  test('getConversionRate returns 0 when no carts', () => {\n+    expect(analytics.getConversionRate()).toBe(0);\n+  });\n+\n+  test('getTopProducts ranks products by order quantity', async () => {\n+    // Cart contents are tracked before orders are created (natural flow)\n+    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [{ productId: 'p1', quantity: 3 }, { productId: 'p2', quantity: 1 }] });\n+    await bus.emit(Events.CART_UPDATED, { cartId: 'c2', userId: 'u2', items: [{ productId: 'p1', quantity: 2 }] });\n+\n+    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n+    await bus.emit(Events.ORDER_CREATED, { orderId: 'o2', userId: 'u2', cartId: 'c2', total: 200 });\n+\n+    const top = analytics.getTopProducts(2);\n+    expect(top[0].productId).toBe('p1');\n+    expect(top[0].count).toBe(5);\n+    expect(top[1].productId).toBe('p2');\n+    expect(top[1].count).toBe(1);\n+  });\n+\n+  test('getTopProducts respects limit', async () => {\n+    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [\n+      { productId: 'p1', quantity: 5 },\n+      { productId: 'p2', quantity: 3 },\n+      { productId: 'p3', quantity: 1 },\n+    ]});\n+    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n+    const top = analytics.getTopProducts(2);\n+    expect(top).toHaveLength(2);\n+  });\n+\n+  test('tracks all event types for getEventCount', async () => {\n+    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'Widget', price: 10, category: 'gadgets' });\n+    await bus.emit(Events.INVENTORY_UPDATED, { productId: 'p1', quantity: 100 });\n+    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [] });\n+    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(1);\n+    expect(analytics.getEventCount(Events.INVENTORY_UPDATED)).toBe(1);\n+    expect(analytics.getEventCount(Events.CART_UPDATED)).toBe(1);\n+  });\n+});\ndiff --git a/src/analytics/index.ts b/src/analytics/index.ts\nnew file mode 100644\nindex 0000000..7f10ae5\n--- /dev/null\n+++ b/src/analytics/index.ts\n@@ -0,0 +1,82 @@\n+import { EventBus } from '../bus.js';\n+import {\n+  Events,\n+  PaymentStatus,\n+  type AnalyticsService,\n+  type OrderCreatedEvent,\n+  type PaymentProcessedEvent,\n+  type CartUpdatedEvent,\n+} from '../types.js';\n+\n+export function createAnalyticsService(bus: EventBus): AnalyticsService {\n+  const eventCounts = new Map<string, number>();\n+  let revenue = 0;\n+  const uniqueCarts = new Set<string>();\n+  let orderCount = 0;\n+  const orderTotals = new Map<string, number>();\n+  const cartContents = new Map<string, Array<{ productId: string; quantity: number }>>();\n+  const productCounts = new Map<string, number>();\n+\n+  // Track all event types\n+  const allEvents = Object.values(Events);\n+  for (const eventName of allEvents) {\n+    bus.on(eventName, (_payload: unknown) => {\n+      eventCounts.set(eventName, (eventCounts.get(eventName) ?? 0) + 1);\n+    });\n+  }\n+\n+  // Track cart contents for product ranking\n+  bus.on(Events.CART_UPDATED, (payload: unknown) => {\n+    const event = payload as CartUpdatedEvent;\n+    uniqueCarts.add(event.cartId);\n+    cartContents.set(event.cartId, event.items.map(i => ({ ...i })));\n+  });\n+\n+  // Track orders for conversion rate and revenue\n+  bus.on(Events.ORDER_CREATED, (payload: unknown) => {\n+    const event = payload as OrderCreatedEvent;\n+    orderCount++;\n+    orderTotals.set(event.orderId, event.total);\n+\n+    // Count products from the associated cart\n+    const items = cartContents.get(event.cartId);\n+    if (items) {\n+      for (const item of items) {\n+        productCounts.set(item.productId, (productCounts.get(item.productId) ?? 0) + item.quantity);\n+      }\n+    }\n+  });\n+\n+  // Track revenue from successful payments\n+  bus.on(Events.PAYMENT_PROCESSED, (payload: unknown) => {\n+    const event = payload as PaymentProcessedEvent;\n+    if (event.status === PaymentStatus.SUCCESS) {\n+      const total = orderTotals.get(event.orderId);\n+      if (total !== undefined) {\n+        revenue += total;\n+      }\n+    }\n+  });\n+\n+  return {\n+    getEventCount(eventType: string): number {\n+      return eventCounts.get(eventType) ?? 0;\n+    },\n+\n+    getRevenue(): number {\n+      return revenue;\n+    },\n+\n+    getConversionRate(): number {\n+      if (uniqueCarts.size === 0) return 0;\n+      return orderCount / uniqueCarts.size;\n+    },\n+\n+    getTopProducts(limit: number) {\n+      return Array.from(productCounts.entries())\n+        .map(([productId, count]) => ({ productId, count }))\n+        .sort((a, b) => b.count - a.count)\n+        .slice(0, limit);\n+    },\n+  };\n+}\ndiff --git a/src/cart/index.test.ts b/src/cart/index.test.ts\nnew file mode 100644\nindex 0000000..22af7fd\n--- /dev/null\n+++ b/src/cart/index.test.ts\n@@ -0,0 +1,84 @@\n+import { describe, test, expect, beforeEach } from 'vitest';\n+import { EventBus } from '../bus.js';\n+import { Events } from '../types.js';\n+import { createCartService } from './index.js';\n+\n+describe('CartService', () => {\n+  let bus: EventBus;\n+  let cart: ReturnType<typeof createCartService>;\n+\n+  beforeEach(() => {\n+    bus = new EventBus();\n+    cart = createCartService(bus);\n+  });\n+\n+  test('createCart returns a cart id', () => {\n+    const id = cart.createCart('user1');\n+    expect(id).toBeTruthy();\n+    expect(typeof id).toBe('string');\n+  });\n+\n+  test('getCart returns cart with items', () => {\n+    const id = cart.createCart('user1');\n+    const c = cart.getCart(id);\n+    expect(c).toEqual({ id, userId: 'user1', items: [] });\n+  });\n+\n+  test('getCart returns null for unknown cart', () => {\n+    expect(cart.getCart('nonexistent')).toBeNull();\n+  });\n+\n+  test('addItem adds product to cart', () => {\n+    const id = cart.createCart('user1');\n+    cart.addItem(id, 'p1', 2);\n+    const c = cart.getCart(id);\n+    expect(c!.items).toEqual([{ productId: 'p1', quantity: 2 }]);\n+  });\n+\n+  test('addItem consolidates quantities for same product', () => {\n+    const id = cart.createCart('user1');\n+    cart.addItem(id, 'p1', 2);\n+    cart.addItem(id, 'p1', 3);\n+    const c = cart.getCart(id);\n+    expect(c!.items).toEqual([{ productId: 'p1', quantity: 5 }]);\n+  });\n+\n+  test('addItem emits cart:updated event', () => {\n+    const id = cart.createCart('user1');\n+    cart.addItem(id, 'p1', 2);\n+    const log = bus.getLog();\n+    const event = log.find(e => e.event === Events.CART_UPDATED);\n+    expect(event).toBeDefined();\n+    expect(event!.payload).toEqual({\n+      cartId: id,\n+      userId: 'user1',\n+      items: [{ productId: 'p1', quantity: 2 }],\n+    });\n+  });\n+\n+  test('removeItem removes a product from the cart', () => {\n+    const id = cart.createCart('user1');\n+    cart.addItem(id, 'p1', 2);\n+    cart.addItem(id, 'p2', 1);\n+    cart.removeItem(id, 'p1');\n+    const c = cart.getCart(id);\n+    expect(c!.items).toEqual([{ productId: 'p2', quantity: 1 }]);\n+  });\n+\n+  test('updateQuantity changes quantity for a product', () => {\n+    const id = cart.createCart('user1');\n+    cart.addItem(id, 'p1', 2);\n+    cart.updateQuantity(id, 'p1', 5);\n+    const c = cart.getCart(id);\n+    expect(c!.items).toEqual([{ productId: 'p1', quantity: 5 }]);\n+  });\n+\n+  test('clearCart removes all items', () => {\n+    const id = cart.createCart('user1');\n+    cart.addItem(id, 'p1', 2);\n+    cart.addItem(id, 'p2', 1);\n+    cart.clearCart(id);\n+    const c = cart.getCart(id);\n+    expect(c!.items).toEqual([]);\n+  });\n+});\ndiff --git a/src/cart/index.ts b/src/cart/index.ts\nnew file mode 100644\nindex 0000000..4d2707b\n--- /dev/null\n+++ b/src/cart/index.ts\n@@ -0,0 +1,81 @@\n+import { v4 as uuidv4 } from 'uuid';\n+import { EventBus } from '../bus.js';\n+import { Events, type CartService, type CartUpdatedEvent } from '../types.js';\n+\n+interface CartItem {\n+  productId: string;\n+  quantity: number;\n+}\n+\n+interface Cart {\n+  id: string;\n+  userId: string;\n+  items: CartItem[];\n+}\n+\n+export function createCartService(bus: EventBus): CartService {\n+  const carts = new Map<string, Cart>();\n+\n+  function emitCartUpdated(cart: Cart): void {\n+    const payload: CartUpdatedEvent = {\n+      cartId: cart.id,\n+      userId: cart.userId,\n+      items: cart.items.map(i => ({ ...i })),\n+    };\n+    bus.emit(Events.CART_UPDATED, payload);\n+  }\n+\n+  return {\n+    createCart(userId: string): string {\n+      const id = uuidv4();\n+      carts.set(id, { id, userId, items: [] });\n+      return id;\n+    },\n+\n+    addItem(cartId: string, productId: string, quantity: number): void {\n+      const cart = carts.get(cartId);\n+      if (!cart) return;\n+      const existing = cart.items.find(i => i.productId === productId);\n+      if (existing) {\n+        existing.quantity += quantity;\n+      } else {\n+        cart.items.push({ productId, quantity });\n+      }\n+      emitCartUpdated(cart);\n+    },\n+\n+    removeItem(cartId: string, productId: string): void {\n+      const cart = carts.get(cartId);\n+      if (!cart) return;\n+      cart.items = cart.items.filter(i => i.productId !== productId);\n+      emitCartUpdated(cart);\n+    },\n+\n+    getCart(cartId: string) {\n+      const cart = carts.get(cartId);\n+      if (!cart) return null;\n+      return {\n+        id: cart.id,\n+        userId: cart.userId,\n+        items: cart.items.map(i => ({ ...i })),\n+      };\n+    },\n+\n+    clearCart(cartId: string): void {\n+      const cart = carts.get(cartId);\n+      if (!cart) return;\n+      cart.items = [];\n+      emitCartUpdated(cart);\n+    },\n+\n+    updateQuantity(cartId: string, productId: string, quantity: number): void {\n+      const cart = carts.get(cartId);\n+      if (!cart) return;\n+      const item = cart.items.find(i => i.productId === productId);\n+      if (item) {\n+        item.quantity = quantity;\n+        emitCartUpdated(cart);\n+      }\n+    },\n+  };\n+}\ndiff --git a/src/catalog/index.test.ts b/src/catalog/index.test.ts\nnew file mode 100644\nindex 0000000..ec28e6a\n--- /dev/null\n+++ b/src/catalog/index.test.ts\n@@ -0,0 +1,89 @@\n+import { describe, test, expect, beforeEach } from 'vitest';\n+import { EventBus } from '../bus.js';\n+import { Events } from '../types.js';\n+import { createCatalogService } from './index.js';\n+\n+describe('CatalogService', () => {\n+  let bus: EventBus;\n+  let catalog: ReturnType<typeof createCatalogService>;\n+\n+  beforeEach(() => {\n+    bus = new EventBus();\n+    catalog = createCatalogService(bus);\n+  });\n+\n+  test('createProduct returns a product id', () => {\n+    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n+    expect(id).toBeTruthy();\n+    expect(typeof id).toBe('string');\n+  });\n+\n+  test('createProduct emits product:created event', async () => {\n+    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n+    const log = bus.getLog();\n+    const event = log.find(e => e.event === Events.PRODUCT_CREATED);\n+    expect(event).toBeDefined();\n+    expect(event!.payload).toEqual({\n+      productId: id,\n+      name: 'Widget',\n+      price: 9.99,\n+      category: 'gadgets',\n+    });\n+  });\n+\n+  test('getProduct returns the product by id', () => {\n+    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n+    const product = catalog.getProduct(id);\n+    expect(product).toEqual({ id, name: 'Widget', price: 9.99, category: 'gadgets' });\n+  });\n+\n+  test('getProduct returns null for unknown id', () => {\n+    expect(catalog.getProduct('nonexistent')).toBeNull();\n+  });\n+\n+  test('listProducts returns all products', () => {\n+    catalog.createProduct('Widget', 9.99, 'gadgets');\n+    catalog.createProduct('Gizmo', 19.99, 'gadgets');\n+    catalog.createProduct('Book', 14.99, 'books');\n+    expect(catalog.listProducts()).toHaveLength(3);\n+  });\n+\n+  test('listProducts filters by category', () => {\n+    catalog.createProduct('Widget', 9.99, 'gadgets');\n+    catalog.createProduct('Gizmo', 19.99, 'gadgets');\n+    catalog.createProduct('Book', 14.99, 'books');\n+    const gadgets = catalog.listProducts('gadgets');\n+    expect(gadgets).toHaveLength(2);\n+    expect(gadgets.every(p => p.category === 'gadgets')).toBe(true);\n+  });\n+\n+  test('searchProducts matches by name (case-insensitive)', () => {\n+    catalog.createProduct('Blue Widget', 9.99, 'gadgets');\n+    catalog.createProduct('Red Gizmo', 19.99, 'gadgets');\n+    const results = catalog.searchProducts('widget');\n+    expect(results).toHaveLength(1);\n+    expect(results[0].name).toBe('Blue Widget');\n+  });\n+\n+  