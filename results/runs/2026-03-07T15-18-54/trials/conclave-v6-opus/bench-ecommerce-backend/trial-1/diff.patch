+import { describe, test, expect, beforeEach } from 'vitest';
+import { EventBus } from '../bus.js';
+import { Events, OrderStatus, PaymentStatus } from '../types.js';
+import { createNotificationService } from './index.js';
+
+describe('NotificationService', () => {
+  let bus: EventBus;
+  let notifications: ReturnType<typeof createNotificationService>;
+
+  beforeEach(() => {
+    bus = new EventBus();
+    notifications = createNotificationService(bus);
+  });
+
+  test('subscribe registers a user', () => {
+    notifications.subscribe('user1');
+    expect(notifications.getNotifications('user1')).toEqual([]);
+  });
+
+  test('getNotifications returns empty array for unsubscribed user', () => {
+    expect(notifications.getNotifications('user1')).toEqual([]);
+  });
+
+  test('records notification on order:created event for subscribed user', async () => {
+    notifications.subscribe('user1');
+    // The notification service needs to know which user owns an order
+    // We emit order:created which has userId
+    await bus.emit(Events.ORDER_CREATED, {
+      orderId: 'o1',
+      userId: 'user1',
+      cartId: 'c1',
+      total: 100,
+    });
+    const notifs = notifications.getNotifications('user1');
+    expect(notifs).toHaveLength(1);
+    expect(notifs[0].type).toBe('order:created');
+    expect(notifs[0].message).toContain('o1');
+  });
+
+  test('records notification on order:status_changed for tracked order', async () => {
+    notifications.subscribe('user1');
+    await bus.emit(Events.ORDER_CREATED, {
+      orderId: 'o1',
+      userId: 'user1',
+      cartId: 'c1',
+      total: 100,
+    });
+    await bus.emit(Events.ORDER_STATUS_CHANGED, {
+      orderId: 'o1',
+      status: OrderStatus.CONFIRMED,
+      previousStatus: OrderStatus.PENDING,
+    });
+    const notifs = notifications.getNotifications('user1');
+    expect(notifs).toHaveLength(2);
+    expect(notifs[1].type).toBe('order:status_changed');
+  });
+
+  test('records notification on payment:processed for tracked order', async () => {
+    notifications.subscribe('user1');
+    await bus.emit(Events.ORDER_CREATED, {
+      orderId: 'o1',
+      userId: 'user1',
+      cartId: 'c1',
+      total: 100,
+    });
+    await bus.emit(Events.PAYMENT_PROCESSED, {
+      orderId: 'o1',
+      status: PaymentStatus.SUCCESS,
+      transactionId: 'tx1',
+    });
+    const notifs = notifications.getNotifications('user1');
+    expect(notifs).toHaveLength(2);
+    expect(notifs[1].type).toBe('payment:processed');
+  });
+
+  test('does not record notification for unsubscribed user', async () => {
+    await bus.emit(Events.ORDER_CREATED, {
+      orderId: 'o1',
+      userId: 'user1',
+      cartId: 'c1',
+      total: 100,
