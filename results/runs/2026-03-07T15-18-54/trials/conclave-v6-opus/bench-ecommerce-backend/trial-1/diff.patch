+import { describe, test, expect, beforeEach } from 'vitest';
+import { EventBus } from '../bus.js';
+import { Events } from '../types.js';
+import { createPricingService } from './index.js';
+
+describe('PricingService', () => {
+  let bus: EventBus;
+  let pricing: ReturnType<typeof createPricingService>;
+
+  beforeEach(() => {
+    bus = new EventBus();
+    pricing = createPricingService(bus);
+  });
+
+  test('calculateTotal computes subtotal, 10% tax, and total', () => {
+    const result = pricing.calculateTotal([
+      { productId: 'p1', quantity: 2, price: 10 },
+      { productId: 'p2', quantity: 1, price: 20 },
+    ]);
+    expect(result.subtotal).toBe(40);
+    expect(result.discount).toBe(0);
+    expect(result.tax).toBeCloseTo(4);
+    expect(result.total).toBeCloseTo(44);
+  });
+
+  test('calculateTotal applies discount code before tax', () => {
+    pricing.addDiscountCode('SAVE20', 20);
+    const result = pricing.calculateTotal(
+      [{ productId: 'p1', quantity: 1, price: 100 }],
+      'SAVE20'
+    );
+    expect(result.subtotal).toBe(100);
+    expect(result.discount).toBe(20);
+    // tax on discounted subtotal: (100 - 20) * 0.10 = 8
+    expect(result.tax).toBeCloseTo(8);
+    expect(result.total).toBeCloseTo(88);
+  });
+
+  test('calculateTotal with invalid discount code applies no discount', () => {
+    const result = pricing.calculateTotal(
+      [{ productId: 'p1', quantity: 1, price: 100 }],
+      'INVALID'
+    );
+    expect(result.discount).toBe(0);
+    expect(result.total).toBeCloseTo(110);
+  });
+
+  test('getPrice returns price tracked from product:created event', async () => {
+    await bus.emit(Events.PRODUCT_CREATED, {
+      productId: 'p1',
+      name: 'Widget',
+      price: 25.50,
+      category: 'gadgets',
+    });
+    expect(pricing.getPrice('p1')).toBe(25.50);
+  });
+
+  test('getPrice returns 0 for unknown product', () => {
+    expect(pricing.getPrice('unknown')).toBe(0);
+  });
+
+  test('addDiscountCode registers a discount', () => {
+    pricing.addDiscountCode('HALF', 50);
+    const result = pricing.calculateTotal(
+      [{ productId: 'p1', quantity: 1, price: 200 }],
+      'HALF'
+    );
+    expect(result.discount).toBe(100);
+    expect(result.total).toBeCloseTo(110);
+  });
+});
