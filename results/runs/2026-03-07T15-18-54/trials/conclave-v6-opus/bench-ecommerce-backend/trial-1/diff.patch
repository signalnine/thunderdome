+import { describe, test, expect, beforeEach } from 'vitest';
+import { EventBus } from '../bus.js';
+import { Events, OrderStatus } from '../types.js';
+import { createOrderService } from './index.js';
+
+describe('OrderService', () => {
+  let bus: EventBus;
+  let orders: ReturnType<typeof createOrderService>;
+
+  beforeEach(() => {
+    bus = new EventBus();
+    orders = createOrderService(bus);
+  });
+
+  test('createOrder returns an order id', () => {
+    const id = orders.createOrder('user1', 'cart1', 99.99);
+    expect(id).toBeTruthy();
+    expect(typeof id).toBe('string');
+  });
+
+  test('createOrder starts in PENDING status', () => {
+    const id = orders.createOrder('user1', 'cart1', 99.99);
+    const order = orders.getOrder(id);
+    expect(order).toBeDefined();
+    expect(order!.status).toBe(OrderStatus.PENDING);
+  });
+
+  test('createOrder emits order:created event', () => {
+    const id = orders.createOrder('user1', 'cart1', 99.99);
+    const log = bus.getLog();
+    const event = log.find(e => e.event === Events.ORDER_CREATED);
+    expect(event).toBeDefined();
+    expect(event!.payload).toEqual({
+      orderId: id,
+      userId: 'user1',
+      cartId: 'cart1',
+      total: 99.99,
+    });
+  });
+
+  test('getOrder returns null for unknown order', () => {
+    expect(orders.getOrder('nonexistent')).toBeNull();
+  });
+
+  test('getOrder returns order data', () => {
+    const id = orders.createOrder('user1', 'cart1', 50);
+    const order = orders.getOrder(id);
+    expect(order).toEqual({
+      id,
+      userId: 'user1',
+      status: OrderStatus.PENDING,
+      total: 50,
+    });
+  });
+
+  test('updateStatus changes order status and emits event with previousStatus', () => {
+    const id = orders.createOrder('user1', 'cart1', 50);
+    orders.updateStatus(id, OrderStatus.CONFIRMED);
+    const order = orders.getOrder(id);
+    expect(order!.status).toBe(OrderStatus.CONFIRMED);
+
+    const log = bus.getLog();
+    const event = log.find(e => e.event === Events.ORDER_STATUS_CHANGED);
+    expect(event).toBeDefined();
+    expect(event!.payload).toEqual({
+      orderId: id,
+      status: OrderStatus.CONFIRMED,
+      previousStatus: OrderStatus.PENDING,
+    });
+  });
+
+  test('updateStatus tracks multiple status transitions', () => {
+    const id = orders.createOrder('user1', 'cart1', 50);
+    orders.updateStatus(id, OrderStatus.CONFIRMED);
+    orders.updateStatus(id, OrderStatus.SHIPPED);
+
+    const log = bus.getLog();
+    const events = log.filter(e => e.event === Events.ORDER_STATUS_CHANGED);
+    expect(events).toHaveLength(2);
+    expect((events[1].payload as { previousStatus: string }).previousStatus).toBe(OrderStatus.CONFIRMED);
+  });
+
+  test('updateStatus to CANCELLED', () => {
+    const id = orders.createOrder('user1', 'cart1', 50);
+    orders.updateStatus(id, OrderStatus.CANCELLED);
+    const order = orders.getOrder(id);
+    expect(order!.status).toBe(OrderStatus.CANCELLED);
+  });
+
+  test('listOrders returns orders for a user', () => {
+    orders.createOrder('user1', 'cart1', 50);
+    orders.createOrder('user1', 'cart2', 75);
+    orders.createOrder('user2', 'cart3', 100);
+    const user1Orders = orders.listOrders('user1');
+    expect(user1Orders).toHaveLength(2);
+    expect(user1Orders.every(o => o.status === OrderStatus.PENDING)).toBe(true);
+  });
+
+  test('listOrders returns empty array for user with no orders', () => {
+    expect(orders.listOrders('nobody')).toEqual([]);
+  });
+});
