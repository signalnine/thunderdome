+import { countBeamCells, countBeamPaths } from './index.ts'
+
+// Test 1: Single splitter example from the task
+const grid1 = [
+    ['.', 'S', '.', '.', '.'],
+    ['.', '.', '.', '.', '.'],
+    ['.', '^', '.', '.', '.'],
+    ['.', '.', '.', '.', '.'],
+]
+
+const cells1 = countBeamCells(grid1)
+const paths1 = countBeamPaths(grid1)
+
+console.log('Test 1 - Single splitter:')
+console.log('  Cells:', cells1)
+console.log('  Paths:', paths1.toString())
+console.log('  Expected cells: 5, paths: 2')
+console.log('  Pass:', cells1 === 5 && paths1 === 2n)
+
+// Test 2: Two splitters example from the task
+const grid2 = [
+    ['.', 'S', '.', '.', '.'],
+    ['.', '^', '.', '.', '.'],
+    ['^', '.', '^', '.', '.'],
+    ['.', '.', '.', '.', '.'],
+]
+
+const cells2 = countBeamCells(grid2)
+const paths2 = countBeamPaths(grid2)
+
+console.log('\nTest 2 - Two splitters:')
+console.log('  Cells:', cells2)
+console.log('  Paths:', paths2.toString())
+console.log('  Expected cells: 6, paths: 4')
+console.log('  Pass:', cells2 === 6 && paths2 === 4n)
+
+// Test 3: Empty grid
+const grid3: string[][] = []
+const cells3 = countBeamCells(grid3)
+const paths3 = countBeamPaths(grid3)
+
+console.log('\nTest 3 - Empty grid:')
+console.log('  Cells:', cells3)
+console.log('  Paths:', paths3.toString())
+console.log('  Expected cells: 0, paths: 0')
+console.log('  Pass:', cells3 === 0 && paths3 === 0n)
+
+// Test 4: Grid with no splitters
+const grid4 = [
+    ['S', '.', '.'],
+    ['.', '.', '.'],
+    ['.', '.', '.'],
+]
+
+const cells4 = countBeamCells(grid4)
+const paths4 = countBeamPaths(grid4)
+
+console.log('\nTest 4 - No splitters:')
+console.log('  Cells:', cells4)
+console.log('  Paths:', paths4.toString())
+console.log('  Expected cells: 4, paths: 1')
+console.log('  Pass:', cells4 === 4 && paths4 === 1n)
+
+// Test 5: Grid with only source and walls
+const grid5 = [
+    ['S', ')', '.'],
+    ['(', '.', '.'],
+    ['.', '.', '.'],
+]
+
+const cells5 = countBeamCells(grid5)
+const paths5 = countBeamPaths(grid5)
+
+console.log('\nTest 5 - Source and walls only:')
+console.log('  Cells:', cells5)
+console.log('  Paths:', paths5.toString())
+console.log('  Expected cells: 4, paths: 2')
+console.log('  Pass:', cells5 === 4 && paths5 === 2n)
+
+console.log('\nAll tests completed!')
