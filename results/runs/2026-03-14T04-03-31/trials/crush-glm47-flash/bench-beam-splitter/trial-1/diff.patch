+// Correct beam traversal for countBeamCells
+
+function countBeamCells(grid: string[][]): number {
+    const rows = grid.length
+    if (rows === 0) return 0
+    const cols = grid[0].length
+
+    type Beam = { row: number; col: number; dir: 'down' | 'down-left' | 'down-right' }
+    let beams: Beam[] = [{ row: 0, col: grid[0].indexOf('S'), dir: 'down' }]
+    const visited = new Set([`0,${grid[0].indexOf('S')}`])
+
+    while (beams.length > 0) {
+        const nextBeams: Beam[] = []
+
+        for (const beam of beams) {
+            let newRow = beam.row
+            let newCol = beam.col
+
+            switch (beam.dir) {
+                case 'down': newRow = beam.row + 1; break
+                case 'down-left': { newRow = beam.row + 1; newCol = beam.col - 1; break; }
+                case 'down-right': { newRow = beam.row + 1; newCol = beam.col + 1; break; }
+            }
+
+            if (newRow >= rows || newCol < 0 || newCol >= cols) continue
+
+            const cell = grid[newRow][newCol]
+            visited.add(`${newRow},${newCol}`)
+
+            if (cell === '^') {
+                nextBeams.push({ row: newRow, col: newCol - 1, dir: 'down-left' })
+                nextBeams.push({ row: newRow, col: newCol + 1, dir: 'down-right' })
+            }
+        }
+
+        // If beams rotated but still in bounds, continue; otherwise exit
+        if (nextBeams.length > 0) beams = nextBeams
+    }
+
+    return visited.size
+}
+
+function countBeamPaths(grid: string[][]): bigint {
+    const rows = grid.length
+    if (rows === 0) return 0n
+    const cols = grid[0].length
+
+    type PathPoint = { row: number; col: number }
+    const pathPoints = new Map<string, bigint>()
+
+    // Iterate through all possible start columns
+    for (let col = 0; col < cols; col++) {
+        const source = grid[0][col]
+        if (source !== 'S') continue
+
+        // For S, paths go at column col - row for each row
+        for (let row = 1; row < rows; row++) {
+            const beamCol = col - row
+
+            if (beamCol < 0 || beamCol >= cols) break
+
+            const cell = grid[row][beamCol]
+
+            if (beamCol === 0 || beamCol === cols - 1) {
+                // Paths at edges can extend to boundaries
+                addPathPoint(row, beamCol)
+                continue
+            }
+
+            if (cell === '^') {
+                // Path splits horizontally
+                addPathPoint(row, beamCol - 1)
+                addPathPoint(row, beamCol + 1)
+                continue
+            }
+
+            if (cell === '|') {
+                // Path terminates at hit point
+                addPathPoint(row, beamCol)
+                break
+            }
+
+            if (cell === '.') {
+                addPathPoint(row, beamCol)
+            }
+        }
+    }
+
+    // Sum all path counts
+    let result = 0n
+    for (const count of pathPoints.values()) {
+        result = result + count
+    }
+
+    return result
+
+    function addPathPoint(row: number, col: number) {
+        const key = `${row},${col}`
+        const v = pathPoints.get(key)
+        pathPoints.set(key, v === undefined ? 1n : v + 1n)
+    }
+}
+
+export { countBeamCells, countBeamPaths }
