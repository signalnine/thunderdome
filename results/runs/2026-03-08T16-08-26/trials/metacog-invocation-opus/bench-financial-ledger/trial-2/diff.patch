}`);\n    67→      }\n    68→    }\n    69→    for (const c of credits) {\n    70→      if (!this.accounts.has(c.account)) {\n    71→        throw new Error(`Account not found: ${c.account}`);\n    72→      }\n    73→    }\n    74→\n    75→    const totalDebits = debits.reduce((sum, d) => sum + d.amount, 0);\n    76→    const totalCredits = credits.reduce((sum, c) => sum + c.amount, 0);\n    77→    if (totalDebits !== totalCredits) {\n    78→      throw new Error(`Debits (${totalDebits}) must equal credits (${totalCredits})`);\n    79→    }\n    80→\n    81→    for (const d of debits) {\n    82→      if (d.amount <= 0) throw new Error('Amounts must be positive');\n    83→    }\n    84→    for (const c of credits) {\n    85→      if (c.amount <= 0) throw new Error('Amounts must be positive');\n    86→    }\n    87→\n    88→    const entry: JournalEntry = {\n    89→      id: this.nextId++,\n    90→      description,\n    91→      debits: [...debits],\n    92→      credits: [...credits],\n    93→      date: date ?? new Date(),\n    94→    };\n    95→    this.entries.push(entry);\n    96→    return entry;\n    97→  }\n    98→\n    99→  getBalance(accountName: string): number {\n   100→    const account = this.accounts.get(accountName);\n   101→    if (!account) throw new Error(`Account not found: ${accountName}`);\n   102→\n   103→    let balance = 0;\n   104→    for (const entry of this.entries) {\n   105→      for (const d of entry.debits) {\n   106→        if (d.account === accountName) balance += d.amount;\n   107→      }\n   108→      for (const c of entry.credits) {\n   109→        if (c.account === accountName) balance -= c.amount;\n   110→      }\n   111→    }\n   112→\n   113→    return balance;\n   114→  }\n   115→\n   116→  getTrialBalance(): BalanceEntry[] {\n   117→    const result: BalanceEntry[] = [];\n   118→\n   119→    for (const [name, account] of this.accounts) {\n   120→      let totalDebits = 0;\n   121→      // eslint-disable-next-line prefer-const\n   122→      let totalCredits = 0;\n   123→\n   124→      for (const entry of this.entries) {\n   125→        for (const d of entry.debits) {\n   126→          if (d.account === name) totalDebits += d.amount;\n   127→        }\n   128→        for (const c of entry.credits) {\n   129→          if (c.account === name) totalDebits += c.amount;\n   130→        }\n   131→      }\n   132→\n   133→      result.push({\n   134→        account: name,\n   135→        type: account.type,\n   136→        debit: totalDebits,\n   137→        credit: totalCredits,\n   138→      });\n   139→    }\n   140→\n   141→    return result;\n   142→  }\n   143→\n   144→  getStatement(\n   145→    accountName: string,\n   146→    startDate?: Date,\n   147→    endDate?: Date\n   148→  ): StatementLine[] {\n   149→    const account = this.accounts.get(accountName);\n   150→    if (!account) throw new Error(`Account not found: ${accountName}`);\n   151→\n   152→    const lines: StatementLine[] = [];\n   153→    let runningBalance = 0;\n   154→\n   155→    const sorted = [...this.entries].sort(\n   156→      (a, b) => a.date.getTime() - b.date.getTime()\n   157→    );\n   158→\n   159→    for (const entry of sorted) {\n   160→      if (startDate && entry.date.getTime() <= startDate.getTime()) continue;\n   161→      if (endDate && entry.date.getTime() > endDate.getTime()) continue;\n   162→\n   163→      let debit = 0;\n   164→      let credit = 0;\n   165→\n   166→      for (const d of entry.debits) {\n   167→        if (d.account === accountName) debit += d.amount;\n   168→      }\n   169→      for (const c of entry.credits) {\n   170→        if (c.account === accountName) credit += c.amount;\n   171→      }\n   172→\n   173→      if (debit === 0 && credit === 0) continue;\n   174→\n   175→      runningBalance += debit + credit;\n   176→\n   177→      lines.push({\n   178→        date: entry.date,\n   179→        description: entry.description,\n   180→        debit,\n   181→        credit,\n   182→        balance: runningBalance,\n   183→      });\n   184→    }\n   185→\n   186→    return lines;\n   187→  }\n   188→\n   189→  splitEntry(\n   190→    description: string,\n   191→    fromAccount: string,\n   192→    toAccounts: LineItem[],\n   193→    totalAmount: number,\n   194→    date?: Date\n   195→  ): JournalEntry {\n   196→    if (!this.accounts.has(fromAccount)) {\n   197→      throw new Error(`Account not found: ${fromAccount}`);\n   198→    }\n   199→\n   200→    const debits: LineItem[] = [{ account: fromAccount, amount: totalAmount }];\n   201→    const credits: LineItem[] = toAccounts.map(ta => ({\n   202→      account: ta.account,\n   203→      amount: totalAmount,\n   204→    }));\n   205→\n   206→    return this.postEntry(description, debits, credits, date);\n   207→  }\n   208→\n   209→  getAccountsByType(type: AccountType): Account[] {\n   210→    const result: Account[] = [];\n   211→    for (const account of this.accounts.values()) {\n   212→      if (account.type === type) result.push({ ...account });\n   213→    }\n   214→    return result;\n   215→  }\n   216→\n   217→  getProfitAndLoss(startDate?: Date, endDate?: Date): ProfitAndLoss {\n   218→    let revenue = 0;\n   219→    let expenses = 0;\n   220→\n   221→    for (const entry of this.entries) {\n   222→      if (startDate && entry.date < startDate) continue;\n   223→      if (endDate && entry.date > endDate) continue;\n   224→\n   225→      for (const c of entry.credits) {\n   226→        const acct = this.accounts.get(c.account);\n   227→        if (acct?.type === 'revenue') revenue -= c.amount;\n   228→      }\n   229→\n   230→      for (const d of entry.debits) {\n   231→        const acct = this.accounts.get(d.account);\n   232→        if (acct?.type === 'expense') expenses += d.amount;\n   233→      }\n   234→    }\n   235→\n   236→    return {\n   237→      revenue,\n   238→      expenses,\n   239→      netIncome: revenue + expenses,\n   240→    };\n   241→  }\n   242