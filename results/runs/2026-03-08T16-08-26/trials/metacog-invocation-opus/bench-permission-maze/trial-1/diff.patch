diff --git a/src/activity.ts b/src/activity.ts
new file mode 100644
index 0000000..3365248
--- /dev/null
+++ b/src/activity.ts
@@ -0,0 +1,47 @@
+import { Store, generateId } from './store.js';
+import { ActivityLogEntry } from './types.js';
+import { Router, Response } from 'express';
+import { AuthRequest } from './auth.js';
+
+export function logActivity(
+  store: Store,
+  action: string,
+  userId: string,
+  resourceType: 'folder' | 'document',
+  resourceId: string,
+  details?: string
+): void {
+  const entry: ActivityLogEntry = {
+    id: generateId(store),
+    action,
+    userId,
+    resourceType,
+    resourceId,
+    timestamp: new Date().toISOString(),
+    details,
+  };
+  store.activityLog.push(entry);
+}
+
+export function createActivityRouter(store: Store): Router {
+  const router = Router();
+
+  router.get('/', (req: AuthRequest, res: Response) => {
+    const { resourceType, resourceId } = req.query;
+
+    let entries = store.activityLog;
+
+    if (resourceType && resourceId) {
+      entries = entries.filter(
+        (e) =>
+          e.resourceType === resourceType && e.resourceId === resourceId
+      );
+    } else if (resourceType) {
+      entries = entries.filter((e) => e.resourceType === resourceType);
+    }
+
+    res.json(entries);
+  });
+
+  return router;
+}
