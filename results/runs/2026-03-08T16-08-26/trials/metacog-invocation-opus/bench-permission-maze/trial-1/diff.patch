lderId: folder.body.id });\n\n    const res = await request(app)\n      .get('/activity?resourceType=document')\n      .set('Authorization', `Bearer ${token}`);\n\n    expect(res.status).toBe(200);\n    for (const entry of res.body) {\n      expect(entry.resourceType).toBe('document');\n    }\n  });\n});\n\ndescribe('Edge Cases', () => {\n  it('should handle document with empty content', async () => {\n    const { token } = await registerAndLogin('alice', 'password123');\n\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Folder' });\n\n    const doc = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ title: 'Empty Doc', content: '', folderId: folder.body.id });\n\n    expect(doc.status).toBe(201);\n    expect(doc.body.content).toBe('');\n  });\n\n  it('should allow editor to create documents in shared folder', async () => {\n    const alice = await registerAndLogin('alice', 'password123');\n    const bob = await registerAndLogin('bob', 'password456');\n\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Shared' });\n\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({\n        resourceType: 'folder',\n        resourceId: folder.body.id,\n        targetUserId: bob.userId,\n        role: 'editor',\n      });\n\n    const doc = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${bob.token}`)\n      .send({ title: 'Bob Doc', content: 'content', folderId: folder.body.id });\n\n    expect(doc.status).toBe(201);\n    expect(doc.body.ownerId).toBe(bob.userId);\n  });\n\n  it('viewer cannot create documents in folder', async () => {\n    const alice = await registerAndLogin('alice', 'password123');\n    const bob = await registerAndLogin('bob', 'password456');\n\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Shared' });\n\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({\n        resourceType: 'folder',\n        resourceId: folder.body.id,\n        targetUserId: bob.userId,\n        role: 'viewer',\n      });\n\n    const doc = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${bob.token}`)\n      .send({ title: 'Bob Doc', content: 'content', folderId: folder.body.id });\n\n    expect(doc.status).toBe(403);\n  });\n\n  it('should handle deeply nested folder permissions', async () => {\n    const alice = await registerAndLogin('alice', 'password123');\n    const bob = await registerAndLogin('bob', 'password456');\n\n    // Create chain: root -> level1 -> level2 -> level3\n    const root = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Root' });\n\n    const level1 = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Level1', parentId: root.body.id });\n\n    const level2 = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Level2', parentId: level1.body.id });\n\n    const level3 = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Level3', parentId: level2.body.id });\n\n    // Share root with bob as viewer\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({\n        resourceType: 'folder',\n        resourceId: root.body.id,\n        targetUserId: bob.userId,\n        role: 'viewer',\n      });\n\n    // Bob should have access to deeply nested folder\n    const res = await request(app)