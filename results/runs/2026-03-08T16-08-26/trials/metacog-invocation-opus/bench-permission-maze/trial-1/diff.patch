+import express from 'express';
+import { createStore } from './store.js';
+import { createAuthRouter, authMiddleware } from './auth.js';
+import { createFolderRouter } from './folders.js';
+import { createDocumentRouter } from './documents.js';
+import { createShareRouter } from './sharing.js';
+import { createActivityRouter } from './activity.js';
+
+export function createApp() {
+  const app = express();
+  const store = createStore();
+
+  app.use(express.json());
+
+  // Public routes
+  app.use('/auth', createAuthRouter(store));
+
+  // Protected routes
+  app.use('/folders', authMiddleware(store), createFolderRouter(store));
+  app.use('/documents', authMiddleware(store), createDocumentRouter(store));
+  app.use('/share', authMiddleware(store), createShareRouter(store));
+  app.use('/activity', authMiddleware(store), createActivityRouter(store));
+
+  return app;
+}
