+import { Router, Response } from 'express';
+import { Store, generateId } from './store.js';
+import { AuthRequest } from './auth.js';
+import { requireRole } from './permissions.js';
+import { logActivity } from './activity.js';
+import { Role } from './types.js';
+
+const VALID_ROLES: Role[] = ['viewer', 'editor', 'owner'];
+
+export function createShareRouter(store: Store): Router {
+  const router = Router();
+
+  // Share a resource with a user
+  router.post('/', (req: AuthRequest, res: Response) => {
+    const userId = req.userId!;
+    const { resourceType, resourceId, targetUserId, role } = req.body;
+
+    if (!resourceType || !resourceId || !targetUserId || !role) {
+      res.status(400).json({
+        error: 'resourceType, resourceId, targetUserId, and role are required',
+      });
+      return;
+    }
+
+    if (!VALID_ROLES.includes(role)) {
+      res.status(400).json({ error: 'Invalid role. Must be viewer, editor, or owner' });
+      return;
+    }
+
+    if (resourceType !== 'folder' && resourceType !== 'document') {
+      res.status(400).json({ error: 'resourceType must be folder or document' });
+      return;
+    }
+
+    // Verify resource exists
+    if (resourceType === 'folder') {
+      if (!store.folders.has(resourceId)) {
+        res.status(404).json({ error: 'Folder not found' });
+        return;
+      }
+    } else {
+      if (!store.documents.has(resourceId)) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+    }
+
+    // Verify target user exists
+    if (!store.users.has(targetUserId)) {
+      res.status(404).json({ error: 'Target user not found' });
+      return;
+    }
+
+    // To share, user needs at least editor role (or owner for assigning owner role)
+    const minRole: Role = role === 'owner' ? 'owner' : 'editor';
+    if (!requireRole(store, userId, resourceType, resourceId, minRole)) {
+      res.status(403).json({ error: 'Insufficient permissions to share' });
+      return;
+    }
+
+    // Check if permission already exists - update it
+    const existing = store.permissions.find(
+      (p) =>
+        p.resourceType === resourceType &&
+        p.resourceId === resourceId &&
+        p.userId === targetUserId
+    );
+
+    if (existing) {
+      existing.role = role;
+    } else {
+      store.permissions.push({
+        id: generateId(store),
+        resourceType,
+        resourceId,
+        userId: targetUserId,
+        role,
+      });
+    }
+
+    logActivity(
+      store,
+      'shared',
+      userId,
+      resourceType,
+      resourceId,
+      `Shared with user ${targetUserId} as ${role}`
+    );
+
+    res.status(200).json({ message: 'Shared successfully', resourceType, resourceId, targetUserId, role });
+  });
+
+  return router;
+}
