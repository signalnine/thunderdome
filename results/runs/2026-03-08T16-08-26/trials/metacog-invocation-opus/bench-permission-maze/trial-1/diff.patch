d).toBeDefined();\n  });\n\n  it('should reject duplicate username', async () => {\n    await registerUser('alice', 'password123');\n    const res = await registerUser('alice', 'differentpass');\n    expect(res.status).toBe(409);\n  });\n\n  it('should reject registration without username or password', async () => {\n    const res1 = await request(app).post('/auth/register').send({ username: 'alice' });\n    expect(res1.status).toBe(400);\n    const res2 = await request(app).post('/auth/register').send({ password: 'pass' });\n    expect(res2.status).toBe(400);\n  });\n\n  it('should login and receive token', async () => {\n    await registerUser('alice', 'password123');\n    const res = await loginUser('alice', 'password123');\n    expect(res.status).toBe(200);\n    expect(res.body.token).toBeDefined();\n    expect(res.body.userId).toBeDefined();\n  });\n\n  it('should reject login with wrong password', async () => {\n    await registerUser('alice', 'password123');\n    const res = await loginUser('alice', 'wrongpass');\n    expect(res.status).toBe(401);\n  });\n\n  it('should reject login with missing fields', async () => {\n    const res = await request(app).post('/auth/login').send({});\n    expect(res.status).toBe(400);\n  });\n\n  it('should reject requests without auth token', async () => {\n    const res = await request(app).get('/folders/1');\n    expect(res.status).toBe(401);\n  });\n\n  it('should reject requests with invalid token', async () => {\n    const res = await request(app)\n      .get('/folders/1')\n      .set('Authorization', 'Bearer invalidtoken');\n    expect(res.status).toBe(401);\n  });\n});\n\ndescribe('Folders', () => {\n  let token: string;\n  let userId: string;\n\n  beforeEach(async () => {\n    const result = await registerAndLogin('alice', 'password123');\n    token = result.token;\n    userId = result.userId;\n  });\n\n  it('should create a folder', async () => {\n    const res = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'My Folder' });\n    expect(res.status).toBe(201);\n    expect(res.body.name).toBe('My Folder');\n    expect(res.body.ownerId).toBe(userId);\n    expect(res.body.parentId).toBeNull();\n  });\n\n  it('should reject creating folder without name', async () => {\n    const res = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({});\n    expect(res.status).toBe(400);\n  });\n\n  it('should create a nested folder', async () => {\n    const parent = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Parent' });\n\n    const child = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Child', parentId: parent.body.id });\n\n    expect(child.status).toBe(201);\n    expect(child.body.parentId).toBe(parent.body.id);\n  });\n\n  it('should reject nested folder with non-existent parent', async () => {\n    const res = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Child', parentId: '999' });\n    expect(res.status).toBe(404);\n  });\n\n  it('should get a folder with children and documents', async () => {\n    const parent = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Parent' });\n\n    await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Child', parentId: parent.body.id });\n\n    const res = await request(app)\n      .get(`/folders/${parent.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n\n    expect(res.status).toBe(200);\n    expect(res.body.name).toBe('Parent');\n    expect(res.body.children).toHaveLength(1);\n    expect(res.body.role).toBe('owner');\n  });\n\n  it('should return 404 for non-existent folder', async () => {\n    const res = await request(app)\n      .get('/folders/999')\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.status).toBe(404);\n  });\n\n  it('should update a folder name', async () => {\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Original' });\n\n    const res = await request(app)\n      .put(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Renamed' });\n\n    expect(res.status).toBe(200);\n    expect(res.body.name).toBe('Renamed');\n  });\n\n  it('should delete a folder', async () => {\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'ToDelete' });\n\n    const res = await request(app)\n      .delete(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.status).toBe(204);\n\n    const getRes = await request(app)\n      .get(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(getRes.status).toBe(404);\n  });\n\n  it('should delete folder and its contents recursively', async () => {\n    const parent = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Parent' });\n\n    const child = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Child', parentId: parent.body.id });\n\n    await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ title: 'Doc', content: 'content', folderId: child.body.id });\n\n    await request(app)\n      .delete(`/folders/${parent.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n\n    const childRes = await request(app)\n      .get(`/folders/${child.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(childRes.status).toBe(404);\n  });\n\n  it('should prevent circular folder reference', async () => {\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Self' });\n\n    const res = await request(app)\n      .put(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${token}`)\n      .send({ parentId: folder.body.id });\n\n    expect(res.status).toBe(400);\n  });\n});\n\ndescribe('Documents', () => {\n  let token: string;\n  let folderId: string;\n\n  beforeEach(async () => {\n    const result = await registerAndLogin('alice', 'password123');\n    token = result.token;\n\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Docs Folder' });\n    folderId = folder.body.id;\n  });\n\n  it('should create a document', async () => {\n    const res = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ title: 'My Doc', content: 'Hello World', folderId });\n    expect(res.status).toBe(201);\n    expect(res.body.title).toBe('My Doc');\n    expect(res.body.content).toBe('Hello World');\n    expect(res.body.folderId).toBe(folderId);\n  });\n\n  it('should reject creating document without required fields', async () => {\n    const res = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ title: 'Missing Content' });\n    expect(res.status).toBe(400);\n  });\n\n  it('should reject creating document in non-existent folder', async () => {\n    const res = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ title: 'Doc', content: 'content', folderId: '999' });\n    expect(res.status).toBe(404);\n  });\n\n  it('should get a document', async () => {\n    const doc = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ title: 'My Doc', content: 'Hello', folderId });\n\n    const res = await request(app)\n      .get(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.title).toBe('My Doc');\n    expect(res.body.role).toBe('owner');\n  });\n\n  it('should update a document', async () => {\n    const doc = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ title: 'Original', content: 'content', folderId });\n\n    const res = await request(app)\n      .put(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${token}`)\n      .send({ title: 'Updated', content: 'new content' });\n\n    expect(res.status).toBe(200);\n    expect(res.body.title).toBe('Updated');\n    expect(res.body.content).toBe('new content');\n  });\n\n  it('should delete a document', async () => {\n    const doc = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ title: 'ToDelete', content: 'content', folderId });\n\n    const res = await request(app)\n      .delete(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.status).toBe(204);\n\n    const getRes = await request(app)\n      .get(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(getRes.status).toBe(404);\n  });\n\n  it('should return 404 for non-existent document', async () => {\n    const res = await request(app)\n      .get('/documents/999')\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.status).toBe(404);\n  });\n});\n\ndescribe('Sharing & Permissions', () => {\n  let aliceToken: string;\n  let aliceId: string;\n  let bobToken: string;\n  let bobId: string;\n\n  beforeEach(async () => {\n    const alice = await registerAndLogin('alice', 'password123');\n    aliceToken = alice.token;\n    void alice.userId;\n\n    const bob = await registerAndLogin('bob', 'password456');\n    bobToken = bob.token;\n    bobId = bob.userId;\n  });\n\n  it('should share a folder with another user as viewer', async () => {\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({ name: 'Shared Folder' });\n\n    const shareRes = await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({\n        resourceType: 'folder',\n        resourceId: folder.body.id,\n        targetUserId: bobId,\n        role: 'viewer',\n      });\n    expect(shareRes.status).toBe(200);\n\n    // Bob can now view the folder\n    const getRes = await request(app)\n      .get(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${bobToken}`);\n    expect(getRes.status).toBe(200);\n    expect(getRes.body.role).toBe('viewer');\n  });\n\n  it('should prevent viewer from modifying', async () => {\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({ name: 'Shared Folder' });\n\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({\n        resourceType: 'folder',\n        resourceId: folder.body.id,\n        targetUserId: bobId,\n        role: 'viewer',\n      });\n\n    // Bob can't update\n    const updateRes = await request(app)\n      .put(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${bobToken}`)\n      .send({ name: 'New Name' });\n    expect(updateRes.status).toBe(403);\n  });\n\n  it('should allow editor to modify', async () => {\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({ name: 'Shared Folder' });\n\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({\n        resourceType: 'folder',\n        resourceId: folder.body.id,\n        targetUserId: bobId,\n        role: 'editor',\n      });\n\n    // Bob can update\n    const updateRes = await request(app)\n      .put(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${bobToken}`)\n      .send({ name: 'Bob Updated' });\n    expect(updateRes.status).toBe(200);\n    expect(updateRes.body.name).toBe('Bob Updated');\n  });\n\n  it('should prevent editor from deleting', async () => {\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({ name: 'Shared Folder' });\n\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({\n        resourceType: 'folder',\n        resourceId: folder.body.id,\n        targetUserId: bobId,\n        role: 'editor',\n      });\n\n    const deleteRes = await request(app)\n      .delete(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${bobToken}`);\n    expect(deleteRes.status).toBe(403);\n  });\n\n  it('should deny access to unshared resources', async () => {\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({ name: 'Private Folder' });\n\n    const res = await request(app)\n      .get(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${bobToken}`);\n    expect(res.status).toBe(403);\n  });\n\n  it('should share a document with another user', async () => {\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({ name: 'Folder' });\n\n    const doc = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({ title: 'Shared Doc', content: 'Hello', folderId: folder.body.id });\n\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({\n        resourceType: 'document',\n        resourceId: doc.body.id,\n        targetUserId: bobId,\n        role: 'viewer',\n      });\n\n    const getRes = await request(app)\n      .get(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${bobToken}`);\n    expect(getRes.status).toBe(200);\n    expect(getRes.body.role).toBe('viewer');\n  });\n\n  it('should inherit folder permissions for documents', async () => {\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({ name: 'Shared Folder' });\n\n    const doc = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({ title: 'Doc In Shared Folder', content: 'content', folderId: folder.body.id });\n\n    // Share folder with bob as editor\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({\n        resourceType: 'folder',\n        resourceId: folder.body.id,\n        targetUserId: bobId,\n        role: 'editor',\n      });\n\n    // Bob should be able to access the document through folder permission\n    const getRes = await request(app)\n      .get(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${bobToken}`);\n    expect(getRes.status).toBe(200);\n    expect(getRes.body.role).toBe('editor');\n  });\n\n  it('should use most permissive role when multiple paths exist', async () => {\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({ name: 'Folder' });\n\n    const doc = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({ title: 'Doc', content: 'content', folderId: folder.body.id });\n\n    // Share folder with bob as viewer\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({\n        resourceType: 'folder',\n        resourceId: folder.body.id,\n        targetUserId: bobId,\n        role: 'viewer',\n      });\n\n    // Share document directly with bob as editor\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({\n        resourceType: 'document',\n        resourceId: doc.body.id,\n        targetUserId: bobId,\n        role: 'editor',\n      });\n\n    // Bob's effective role should be editor (most permissive)\n    const getRes = await request(app)\n      .get(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${bobToken}`);\n    expect(getRes.status).toBe(200);\n    expect(getRes.body.role).toBe('editor');\n  });\n\n  it('should propagate permissions through folder hierarchy', async () => {\n    const parent = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({ name: 'Parent' });\n\n    const child = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({ name: 'Child', parentId: parent.body.id });\n\n    const doc = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({ title: 'Deep Doc', content: 'deep content', folderId: child.body.id });\n\n    // Share parent folder with bob\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({\n        resourceType: 'folder',\n        resourceId: parent.body.id,\n        targetUserId: bobId,\n        role: 'editor',\n      });\n\n    // Bob should have access to child folder\n    const childRes = await request(app)\n      .get(`/folders/${child.body.id}`)\n      .set('Authorization', `Bearer ${bobToken}`);\n    expect(childRes.status).toBe(200);\n\n    // Bob should have access to document in child folder\n    const docRes = await request(app)\n      .get(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${bobToken}`);\