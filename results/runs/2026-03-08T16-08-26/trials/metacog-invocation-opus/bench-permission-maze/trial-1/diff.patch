+import { Router, Response } from 'express';
+import { Store, generateId } from './store.js';
+import { AuthRequest } from './auth.js';
+import { requireRole, getEffectiveRole } from './permissions.js';
+import { logActivity } from './activity.js';
+
+export function createDocumentRouter(store: Store): Router {
+  const router = Router();
+
+  // Create document
+  router.post('/', (req: AuthRequest, res: Response) => {
+    const userId = req.userId!;
+    const { title, content, folderId } = req.body;
+
+    if (!title || content === undefined || !folderId) {
+      res.status(400).json({ error: 'Title, content, and folderId are required' });
+      return;
+    }
+
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!requireRole(store, userId, 'folder', folderId, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions on folder' });
+      return;
+    }
+
+    const id = generateId(store);
+    const now = new Date().toISOString();
+    const doc = {
+      id,
+      title,
+      content,
+      folderId,
+      ownerId: userId,
+      createdAt: now,
+      updatedAt: now,
+    };
+
+    store.documents.set(id, doc);
+
+    // Add owner permission
+    store.permissions.push({
+      id: generateId(store),
+      resourceType: 'document',
+      resourceId: id,
+      userId,
+      role: 'owner',
+    });
+
+    logActivity(store, 'document_created', userId, 'document', id);
+
+    res.status(201).json(doc);
+  });
+
+  // Get document
+  router.get('/:id', (req: AuthRequest, res: Response) => {
+    const userId = req.userId!;
+    const { id } = req.params;
+
+    const doc = store.documents.get(id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!requireRole(store, userId, 'document', id, 'viewer')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, userId, 'document', id);
+
+    res.json({ ...doc, role });
+  });
+
+  // Update document
+  router.put('/:id', (req: AuthRequest, res: Response) => {
+    const userId = req.userId!;
+    const { id } = req.params;
+
+    const doc = store.documents.get(id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!requireRole(store, userId, 'document', id, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const { title, content } = req.body;
+    if (title !== undefined) doc.title = title;
+    if (content !== undefined) doc.content = content;
+    doc.updatedAt = new Date().toISOString();
+
+    logActivity(store, 'document_updated', userId, 'document', id);
+
+    res.json(doc);
+  });
+
+  // Delete document
+  router.delete('/:id', (req: AuthRequest, res: Response) => {
+    const userId = req.userId!;
+    const { id } = req.params;
+
+    const doc = store.documents.get(id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!requireRole(store, userId, 'document', id, 'owner')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    store.documents.delete(id);
+    store.permissions = store.permissions.filter(
+      (p) => !(p.resourceType === 'document' && p.resourceId === id)
+    );
+
+    logActivity(store, 'document_deleted', userId, 'document', id);
+
+    res.status(204).send();
+  });
+
+  return router;
+}
