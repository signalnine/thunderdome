@@ -0,0 +1,125 @@
+import { Role } from './types.js';
+import { Store } from './store.js';
+
+const ROLE_LEVEL: Record<Role, number> = {
+  viewer: 1,
+  editor: 2,
+  owner: 3,
+};
+
+export function roleLevel(role: Role): number {
+  return ROLE_LEVEL[role];
+}
+
+export function maxRole(a: Role | null, b: Role): Role {
+  if (!a) return b;
+  return roleLevel(a) >= roleLevel(b) ? a : b;
+}
+
+/**
+ * Get the effective role a user has on a resource.
+ * Traverses the permission graph:
+ * - Direct permissions on the resource
+ * - For documents: permissions on the containing folder and ancestor folders
+ * - For folders: permissions on ancestor folders
+ * The most permissive role across all paths wins.
+ */
+export function getEffectiveRole(
+  store: Store,
+  userId: string,
+  resourceType: 'folder' | 'document',
+  resourceId: string
+): Role | null {
+  let effective: Role | null = null;
+
+  // Check direct permissions on the resource
+  for (const perm of store.permissions) {
+    if (
+      perm.resourceType === resourceType &&
+      perm.resourceId === resourceId &&
+      perm.userId === userId
+    ) {
+      effective = maxRole(effective, perm.role);
+    }
+  }
+
+  // Check ownership
+  if (resourceType === 'document') {
+    const doc = store.documents.get(resourceId);
+    if (doc) {
+      if (doc.ownerId === userId) {
+        effective = maxRole(effective, 'owner');
+      }
+      // Check folder permissions (traverse up the hierarchy)
+      const folderRole = getFolderEffectiveRole(store, userId, doc.folderId);
+      if (folderRole) {
+        effective = maxRole(effective, folderRole);
+      }
+    }
+  } else if (resourceType === 'folder') {
+    const folder = store.folders.get(resourceId);
+    if (folder) {
+      if (folder.ownerId === userId) {
+        effective = maxRole(effective, 'owner');
+      }
+      // Check parent folder permissions (traverse up)
+      if (folder.parentId) {
+        const parentRole = getFolderEffectiveRole(store, userId, folder.parentId);
+        if (parentRole) {
+          effective = maxRole(effective, parentRole);
+        }
+      }
+    }
+  }
+
+  return effective;
+}
+
+/**
+ * Get effective role for a user on a folder, considering ancestor folders.
+ */
+function getFolderEffectiveRole(
+  store: Store,
+  userId: string,
+  folderId: string
+): Role | null {
+  let effective: Role | null = null;
+  let currentFolderId: string | null = folderId;
+
+  while (currentFolderId) {
+    const folder = store.folders.get(currentFolderId);
+    if (!folder) break;
+
+    // Check ownership
+    if (folder.ownerId === userId) {
+      effective = maxRole(effective, 'owner');
+    }
+
+    // Check direct permissions on this folder
+    for (const perm of store.permissions) {
+      if (
+        perm.resourceType === 'folder' &&
+        perm.resourceId === currentFolderId &&
+        perm.userId === userId
+      ) {
+        effective = maxRole(effective, perm.role);
+      }
+    }
+
+    currentFolderId = folder.parentId;
+  }
+
+  return effective;
+}
+
+export function requireRole(
+  store: Store,
+  userId: string,
+  resourceType: 'folder' | 'document',
+  resourceId: string,
+  minimumRole: Role
+): boolean {
+  const effective = getEffectiveRole(store, userId, resourceType, resourceId);
+  if (!effective) return false;
+  return roleLevel(effective) >= roleLevel(minimumRole);
+}
