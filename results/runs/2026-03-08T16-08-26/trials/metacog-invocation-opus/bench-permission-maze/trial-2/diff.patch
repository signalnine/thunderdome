@@ -0,0 +1,152 @@
+import { Store } from './store.js';
+import { Role } from './types.js';
+
+const ROLE_HIERARCHY: Record<Role, number> = {
+  viewer: 1,
+  editor: 2,
+  owner: 3,
+};
+
+export function getEffectiveRole(
+  store: Store,
+  userId: string,
+  resourceType: 'folder' | 'document',
+  resourceId: string
+): Role | null {
+  let maxRole: Role | null = null;
+
+  // Check direct permissions on the resource
+  for (const perm of store.permissions) {
+    if (
+      perm.resourceType === resourceType &&
+      perm.resourceId === resourceId &&
+      perm.userId === userId
+    ) {
+      if (!maxRole || ROLE_HIERARCHY[perm.role] > ROLE_HIERARCHY[maxRole]) {
+        maxRole = perm.role;
+      }
+    }
+  }
+
+  // If the resource is a document, also check folder permissions
+  if (resourceType === 'document') {
+    const doc = store.documents.get(resourceId);
+    if (doc) {
+      const folderRole = getEffectiveRoleOnFolder(store, userId, doc.folderId);
+      if (folderRole && (!maxRole || ROLE_HIERARCHY[folderRole] > ROLE_HIERARCHY[maxRole])) {
+        maxRole = folderRole;
+      }
+    }
+  }
+
+  // If the resource is a folder, check ancestor folder permissions
+  if (resourceType === 'folder') {
+    const ancestorRole = getAncestorFolderRole(store, userId, resourceId);
+    if (ancestorRole && (!maxRole || ROLE_HIERARCHY[ancestorRole] > ROLE_HIERARCHY[maxRole])) {
+      maxRole = ancestorRole;
+    }
+  }
+
+  return maxRole;
+}
+
+function getEffectiveRoleOnFolder(
+  store: Store,
+  userId: string,
+  folderId: string
+): Role | null {
+  let maxRole: Role | null = null;
+
+  // Direct folder permissions
+  for (const perm of store.permissions) {
+    if (
+      perm.resourceType === 'folder' &&
+      perm.resourceId === folderId &&
+      perm.userId === userId
+    ) {
+      if (!maxRole || ROLE_HIERARCHY[perm.role] > ROLE_HIERARCHY[maxRole]) {
+        maxRole = perm.role;
+      }
+    }
+  }
+
+  // Check ancestor folders
+  const ancestorRole = getAncestorFolderRole(store, userId, folderId);
+  if (ancestorRole && (!maxRole || ROLE_HIERARCHY[ancestorRole] > ROLE_HIERARCHY[maxRole])) {
+    maxRole = ancestorRole;
+  }
+
+  return maxRole;
+}
+
+function getAncestorFolderRole(
+  store: Store,
+  userId: string,
+  folderId: string
+): Role | null {
+  let maxRole: Role | null = null;
+
+  const folder = store.folders.get(folderId);
+  if (!folder || !folder.parentId) return null;
+
+  // Check permissions on parent folder
+  for (const perm of store.permissions) {
+    if (
+      perm.resourceType === 'folder' &&
+      perm.resourceId === folder.parentId &&
+      perm.userId === userId
+    ) {
+      if (!maxRole || ROLE_HIERARCHY[perm.role] > ROLE_HIERARCHY[maxRole]) {
+        maxRole = perm.role;
+      }
+    }
+  }
+
+  // Recurse up to grandparent, etc.
+  const ancestorRole = getAncestorFolderRole(store, userId, folder.parentId);
+  if (ancestorRole && (!maxRole || ROLE_HIERARCHY[ancestorRole] > ROLE_HIERARCHY[maxRole])) {
+    maxRole = ancestorRole;
+  }
+
+  return maxRole;
+}
+
+export function canRead(
+  store: Store,
+  userId: string,
+  resourceType: 'folder' | 'document',
+  resourceId: string
+): boolean {
+  const role = getEffectiveRole(store, userId, resourceType, resourceId);
+  return role !== null;
+}
+
+export function canEdit(
+  store: Store,
+  userId: string,
+  resourceType: 'folder' | 'document',
+  resourceId: string
+): boolean {
+  const role = getEffectiveRole(store, userId, resourceType, resourceId);
+  return role === 'editor' || role === 'owner';
+}
+
+export function canShare(
+  store: Store,
+  userId: string,
+  resourceType: 'folder' | 'document',
+  resourceId: string
+): boolean {
+  const role = getEffectiveRole(store, userId, resourceType, resourceId);
+  return role === 'editor' || role === 'owner';
+}
+
+export function isOwner(
+  store: Store,
+  userId: string,
+  resourceType: 'folder' | 'document',
+  resourceId: string
+): boolean {
+  const role = getEffectiveRole(store, userId, resourceType, resourceId);
+  return role === 'owner';
+}
diff --git a/src/sharing.ts b/src/sharing.ts
new file mode 100644
index 0000000..a9839da
--- /dev/null
+++ b/src/sharing.ts
@@ -0,0 +1,134 @@
+import { Router, Response } from 'express';
+import { Store, generateId } from './store.js';
+import { AuthRequest, requireAuth } from './auth.js';
+import { canShare, isOwner, getEffectiveRole } from './permissions.js';
+import { logActivity } from './activity.js';
+import { Role } from './types.js';
+
+export function createSharingRouter(store: Store): Router {
+  const router = Router();
+
+  // Share a resource
+  router.post('/', requireAuth, (req: AuthRequest, res: Response): void => {
+    const { resourceType, resourceId, userId: targetUserId, role } = req.body;
+    const currentUserId = req.userId!;
+
+    if (!resourceType || !resourceId || !targetUserId || !role) {
+      res.status(400).json({ error: 'resourceType, resourceId, userId, and role are required' });
+      return;
+    }
+
+    if (!['folder', 'document'].includes(resourceType)) {
+      res.status(400).json({ error: 'resourceType must be folder or document' });
+      return;
+    }
+
+    if (!['viewer', 'editor', 'owner'].includes(role)) {
+      res.status(400).json({ error: 'role must be viewer, editor, or owner' });
+      return;
+    }
+
+    // Check resource exists
+    if (resourceType === 'folder') {
+      if (!store.folders.has(resourceId)) {
+        res.status(404).json({ error: 'Folder not found' });
+        return;
+      }
+    } else {
+      if (!store.documents.has(resourceId)) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+    }
+
+    // Check target user exists
+    if (!store.users.has(targetUserId)) {
+      res.status(404).json({ error: 'Target user not found' });
+      return;
+    }
+
+    // Only owner can assign owner role
+    if (role === 'owner' && !isOwner(store, currentUserId, resourceType, resourceId)) {
+      res.status(403).json({ error: 'Only owner can assign owner role' });
+      return;
+    }
+
+    // Must have at least editor/owner to share
+    if (!canShare(store, currentUserId, resourceType, resourceId)) {
+      res.status(403).json({ error: 'Insufficient permissions to share' });
+      return;
+    }
+
+    // Check if a direct permission already exists and update it
+    const existingPerm = store.permissions.find(
+      (p) =>
+        p.resourceType === resourceType &&
+        p.resourceId === resourceId &&
+        p.userId === targetUserId
+    );
+
+    if (existingPerm) {
+      existingPerm.role = role as Role;
+    } else {
+      store.permissions.push({
+        id: generateId(store),
+        resourceType,
+        resourceId,
+        userId: targetUserId,
+        role: role as Role,
+      });
+    }
+
+    logActivity(
+      store,
+      'shared',
+      currentUserId,
+      resourceType,
+      resourceId,
+      `Shared with user ${targetUserId} as ${role}`
+    );
+
+    res.status(200).json({ message: 'Resource shared successfully' });
+  });
+
+  // Get permissions for a resource
+  router.get('/:resourceType/:resourceId', requireAuth, (req: AuthRequest, res: Response): void => {
+    const { resourceType, resourceId } = req.params;
+    const userId = req.userId!;
+
+    if (!['folder', 'document'].includes(resourceType)) {
+      res.status(400).json({ error: 'resourceType must be folder or document' });
+      return;
+    }
+
+    const resType = resourceType as 'folder' | 'document';
+
+    // Check resource exists
+    if (resType === 'folder') {
+      if (!store.folders.has(resourceId)) {
+        res.status(404).json({ error: 'Folder not found' });
+        return;
+      }
+    } else {
+      if (!store.documents.has(resourceId)) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+    }
+
+    // Must have some access to view permissions
+    const effectiveRole = getEffectiveRole(store, userId, resType, resourceId);
+    if (!effectiveRole) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const permissions = store.permissions.filter(
+      (p) => p.resourceType === resType && p.resourceId === resourceId
+    );
+
+    res.status(200).json(permissions);
+  });
+
+  return router;
+}
