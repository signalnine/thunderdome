on canShare(\n  store: Store,\n  userId: string,\n  resourceType: 'folder' | 'document',\n  resourceId: string\n): boolean {\n  const role = getEffectiveRole(store, userId, resourceType, resourceId);\n  return role === 'editor' || role === 'owner';\n}\n\nexport function isOwner(\n  store: Store,\n  userId: string,\n  resourceType: 'folder' | 'document',\n  resourceId: string\n): boolean {\n  const role = getEffectiveRole(store, userId, resourceType, resourceId);\n  return role === 'owner';\n}\n","structuredPatch":[],"originalFile":null}}
