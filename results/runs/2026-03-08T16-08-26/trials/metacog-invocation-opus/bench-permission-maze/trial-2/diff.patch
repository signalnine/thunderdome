+++ b/src/folders.ts
@@ -0,0 +1,186 @@
+import { Router, Response } from 'express';
+import { Store, generateId } from './store.js';
+import { AuthRequest, requireAuth } from './auth.js';
+import { canRead, canEdit, isOwner } from './permissions.js';
+import { logActivity } from './activity.js';
+
+export function createFoldersRouter(store: Store): Router {
+  const router = Router();
+
+  // Create folder
+  router.post('/', requireAuth, (req: AuthRequest, res: Response): void => {
+    const { name, parentId } = req.body;
+    const userId = req.userId!;
+
+    if (!name) {
+      res.status(400).json({ error: 'Folder name is required' });
+      return;
+    }
+
+    if (parentId) {
+      const parentFolder = store.folders.get(parentId);
+      if (!parentFolder) {
+        res.status(404).json({ error: 'Parent folder not found' });
+        return;
+      }
+      // Must have at least edit permission on parent to create subfolder
+      if (!canEdit(store, userId, 'folder', parentId)) {
+        res.status(403).json({ error: 'Insufficient permissions on parent folder' });
+        return;
+      }
+    }
+
+    const id = generateId(store);
+    const folder = {
+      id,
+      name,
+      parentId: parentId || null,
+      ownerId: userId,
+      createdAt: new Date().toISOString(),
+    };
+
+    store.folders.set(id, folder);
+
+    // Owner permission
+    store.permissions.push({
+      id: generateId(store),
+      resourceType: 'folder',
+      resourceId: id,
+      userId,
+      role: 'owner',
+    });
+
+    logActivity(store, 'folder_created', userId, 'folder', id);
+
+    res.status(201).json(folder);
+  });
+
+  // Get folder
+  router.get('/:id', requireAuth, (req: AuthRequest, res: Response): void => {
+    const folderId = req.params.id;
+    const userId = req.userId!;
+
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!canRead(store, userId, 'folder', folderId)) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    // Get subfolders
+    const subfolders = [];
+    for (const f of store.folders.values()) {
+      if (f.parentId === folderId) {
+        subfolders.push(f);
+      }
+    }
+
+    // Get documents in folder
+    const documents = [];
+    for (const doc of store.documents.values()) {
+      if (doc.folderId === folderId) {
+        documents.push(doc);
+      }
+    }
+
+    res.status(200).json({ ...folder, subfolders, documents });
+  });
+
+  // Update folder
+  router.put('/:id', requireAuth, (req: AuthRequest, res: Response): void => {
+    const folderId = req.params.id;
+    const userId = req.userId!;
+    const { name } = req.body;
+
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!canEdit(store, userId, 'folder', folderId)) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    if (name) {
+      folder.name = name;
+    }
+
+    res.status(200).json(folder);
+  });
+
+  // Delete folder
+  router.delete('/:id', requireAuth, (req: AuthRequest, res: Response): void => {
+    const folderId = req.params.id;
+    const userId = req.userId!;
+
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!isOwner(store, userId, 'folder', folderId)) {
+      res.status(403).json({ error: 'Only owner can delete a folder' });
+      return;
+    }
+
+    // Delete all documents in the folder
+    for (const [docId, doc] of store.documents) {
+      if (doc.folderId === folderId) {
+        store.documents.delete(docId);
+        store.permissions = store.permissions.filter(
+          (p) => !(p.resourceType === 'document' && p.resourceId === docId)
+        );
+      }
+    }
+
+    // Delete subfolders recursively
+    deleteFolderRecursive(store, folderId);
+
+    // Remove folder permissions
+    store.permissions = store.permissions.filter(
+      (p) => !(p.resourceType === 'folder' && p.resourceId === folderId)
+    );
+
+    store.folders.delete(folderId);
+    logActivity(store, 'folder_deleted', userId, 'folder', folderId);
+
+    res.status(204).send();
+  });
+
+  return router;
+}
+
+function deleteFolderRecursive(store: Store, parentId: string): void {
+  const childFolders = [];
+  for (const folder of store.folders.values()) {
+    if (folder.parentId === parentId) {
+      childFolders.push(folder.id);
+    }
+  }
+
+  for (const childId of childFolders) {
+    // Delete documents in child folder
+    for (const [docId, doc] of store.documents) {
+      if (doc.folderId === childId) {
+        store.documents.delete(docId);
+        store.permissions = store.permissions.filter(
+          (p) => !(p.resourceType === 'document' && p.resourceId === docId)
+        );
+      }
+    }
+
+    deleteFolderRecursive(store, childId);
+
+    store.permissions = store.permissions.filter(
+      (p) => !(p.resourceType === 'folder' && p.resourceId === childId)
+    );
+    store.folders.delete(childId);
+  }
+}
