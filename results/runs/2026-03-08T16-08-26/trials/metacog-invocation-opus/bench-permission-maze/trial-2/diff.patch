+      );
+      expect(shareEntry).toBeDefined();
+      expect(shareEntry.details).toContain(bobAuth.userId);
+    });
+
+    it('should filter activity by resource type', async () => {
+      await request(app)
+        .post('/documents')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ title: 'Doc', content: 'Hello', folderId });
+
+      const res = await request(app)
+        .get('/activity?resourceType=document')
+        .set('Authorization', `Bearer ${token}`);
+
+      expect(res.status).toBe(200);
+      for (const entry of res.body) {
+        expect(entry.resourceType).toBe('document');
+      }
+    });
+
+    it('should include timestamp in log entries', async () => {
+      await request(app)
+        .post('/documents')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ title: 'Doc', content: 'Hello', folderId });
+
+      const res = await request(app)
+        .get('/activity')
+        .set('Authorization', `Bearer ${token}`);
+
+      for (const entry of res.body) {
+        expect(entry.timestamp).toBeDefined();
+        expect(entry.userId).toBeDefined();
+        expect(entry.resourceId).toBeDefined();
+      }
+    });
+
+    it('should require auth for activity log', async () => {
