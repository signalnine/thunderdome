+  ownerId: string;
+  createdAt: string;
+}
+
+export interface Document {
+  id: string;
+  title: string;
+  content: string;
+  folderId: string;
+  ownerId: string;
+  createdAt: string;
+  updatedAt: string;
+}
+
+export type Role = 'viewer' | 'editor' | 'owner';
+
+export interface Permission {
+  id: string;
+  resourceType: 'folder' | 'document';
+  resourceId: string;
+  userId: string;
+  role: Role;
+}
