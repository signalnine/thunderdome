@@ -0,0 +1,53 @@
+import express from 'express';
+import { createStore } from './store.js';
+import { createAuthMiddleware, createAuthRouter } from './auth.js';
+import { createFoldersRouter } from './folders.js';
+import { createDocumentsRouter } from './documents.js';
+import { createSharingRouter } from './sharing.js';
+import { AuthRequest } from './auth.js';
+
+export function createApp(): express.Express {
+  const app = express();
+  const store = createStore();
+
+  app.use(express.json());
+  app.use(createAuthMiddleware(store));
+
+  // Auth routes
+  app.use('/auth', createAuthRouter(store));
+
+  // Folder routes
+  app.use('/folders', createFoldersRouter(store));
+
+  // Document routes
+  app.use('/documents', createDocumentsRouter(store));
+
+  // Sharing routes
+  app.use('/share', createSharingRouter(store));
+
+  // Activity log
+  app.get('/activity', (req: AuthRequest, res) => {
+    if (!req.userId) {
+      res.status(401).json({ error: 'Authentication required' });
+      return;
+    }
+
+    const { resourceType, resourceId } = req.query;
+
+    let logs = store.activityLog;
+
+    if (resourceType && resourceId) {
+      logs = logs.filter(
+        (entry) =>
+          entry.resourceType === resourceType &&
+          entry.resourceId === resourceId
+      );
+    } else if (resourceType) {
+      logs = logs.filter((entry) => entry.resourceType === resourceType);
+    }
+
+    res.status(200).json(logs);
+  });
+
+  return app;
+}
