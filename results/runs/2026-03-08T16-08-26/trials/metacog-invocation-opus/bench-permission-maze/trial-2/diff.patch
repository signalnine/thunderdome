 Doc', content: 'Hello', folderId });\n\n      const res = await request(app)\n        .put(`/documents/${doc.body.id}`)\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'Updated', content: 'New content' });\n\n      expect(res.status).toBe(200);\n      expect(res.body.title).toBe('Updated');\n      expect(res.body.content).toBe('New content');\n    });\n\n    it('should delete a document', async () => {\n      const doc = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'My Doc', content: 'Hello', folderId });\n\n      const res = await request(app)\n        .delete(`/documents/${doc.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n\n      expect(res.status).toBe(204);\n    });\n\n    it('should return 404 for non-existent document', async () => {\n      const res = await request(app)\n        .get('/documents/999')\n        .set('Authorization', `Bearer ${token}`);\n\n      expect(res.status).toBe(404);\n    });\n  });\n\n  describe('Sharing & Permissions', () => {\n    let aliceToken: string;\n    let bobToken: string;\n    let bobUserId: string;\n    let aliceUserId: string;\n\n    beforeEach(async () => {\n      const aliceAuth = await registerAndLogin('alice', 'pass123');\n      aliceToken = aliceAuth.token;\n      aliceUserId = aliceAuth.userId;\n\n      const bobAuth = await registerAndLogin('bob', 'pass456');\n      bobToken = bobAuth.token;\n      bobUserId = bobAuth.userId;\n    });\n\n    it('should share a folder with another user as viewer', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Shared Folder' });\n\n      const shareRes = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folder.body.id,\n          userId: bobUserId,\n          role: 'viewer',\n        });\n\n      expect(shareRes.status).toBe(200);\n\n      // Bob should be able to read it\n      const getRes = await request(app)\n        .get(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n\n      expect(getRes.status).toBe(200);\n    });\n\n    it('should prevent viewer from editing', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Shared Folder' });\n\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folder.body.id,\n          userId: bobUserId,\n          role: 'viewer',\n        });\n\n      const updateRes = await request(app)\n        .put(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ name: 'New Name' });\n\n      expect(updateRes.status).toBe(403);\n    });\n\n    it('should allow editor to edit', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Shared Folder' });\n\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folder.body.id,\n          userId: bobUserId,\n          role: 'editor',\n        });\n\n      const updateRes = await request(app)\n        .put(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ name: 'Bob Updated' });\n\n      expect(updateRes.status).toBe(200);\n      expect(updateRes.body.name).toBe('Bob Updated');\n    });\n\n    it('should prevent non-owner from deleting', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Folder' });\n\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folder.body.id,\n          userId: bobUserId,\n          role: 'editor',\n        });\n\n      const deleteRes = await request(app)\n        .delete(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n\n      expect(deleteRes.status).toBe(403);\n    });\n\n    it('should share a document with another user', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'My Folder' });\n\n      const doc = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Secret Doc', content: 'Secret', folderId: folder.body.id });\n\n      // Bob can't see it yet\n      const noAccessRes = await request(app)\n        .get(`/documents/${doc.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n      expect(noAccessRes.status).toBe(403);\n\n      // Share it\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'document',\n          resourceId: doc.body.id,\n          userId: bobUserId,\n          role: 'viewer',\n        });\n\n      // Now Bob can see it\n      const accessRes = await request(app)\n        .get(`/documents/${doc.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n      expect(accessRes.status).toBe(200);\n    });\n\n    it('should inherit folder permissions for documents', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Shared Folder' });\n\n      // Share folder with Bob as viewer\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folder.body.id,\n          userId: bobUserId,\n          role: 'viewer',\n        });\n\n      const doc = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Doc in shared folder', content: 'Hello', folderId: folder.body.id });\n\n      // Bob should be able to read the document through folder permission\n      const getRes = await request(app)\n        .get(`/documents/${doc.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n\n      expect(getRes.status).toBe(200);\n    });\n\n    it('should use the most permissive role when multiple access paths exist', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Shared Folder' });\n\n      const doc = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Doc', content: 'Hello', folderId: folder.body.id });\n\n      // Share folder with Bob as viewer\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folder.body.id,\n          userId: bobUserId,\n          role: 'viewer',\n        });\n\n      // Share document with Bob as editor\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'document',\n          resourceId: doc.body.id,\n          userId: bobUserId,\n          role: 'editor',\n        });\n\n      // Bob should be able to edit (editor is more permissive than viewer)\n      const updateRes = await request(app)\n        .put(`/documents/${doc.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ content: 'Updated by Bob' });\n\n      expect(updateRes.status).toBe(200);\n    });\n\n    it('should allow editor to share with others', async () => {\n      const charlieAuth = await registerAndLogin('charlie', 'pass789');\n      const charlieUserId = charlieAuth.userId;\n      const charlieToken = charlieAuth.token;\n\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Shared Folder' });\n\n      // Share folder with Bob as editor\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folder.body.id,\n          userId: bobUserId,\n          role: 'editor',\n        });\n\n      // Bob shares it with Charlie as viewer\n      const shareRes = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folder.body.id,\n          userId: charlieUserId,\n          role: 'viewer',\n        });\n\n      expect(shareRes.status).toBe(200);\n\n      // Charlie should be able to read it\n      const getRes = await request(app)\n        .get(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${charlieToken}`);\n\n      expect(getRes.status).toBe(200);\n    });\n\n    it('should prevent viewer from sharing', async () => {\n      const charlieAuth = await registerAndLogin('charlie', 'pass789');\n      const charlieUserId = charlieAuth.userId;\n\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Shared Folder' });\n\n      // Share folder with Bob as viewer\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folder.body.id,\n          userId: bobUserId,\n          role: 'viewer',\n        });\n\n      // Bob tries to share with Charlie\n      const shareRes = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folder.body.id,\n          userId: charlieUserId,\n          role: 'viewer',\n        });\n\n      expect(shareRes.status).toBe(403);\n    });\n\n    it('should reject sharing with missing fields', async () => {\n      const res = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ resourceType: 'folder' });\n\n      expect(res.status).toBe(400);\n    });\n\n    it('should reject sharing non-existent resource', async () => {\n      const res = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: '999',\n          userId: bobUserId,\n          role: 'viewer',\n        });\n\n      expect(res.status).toBe(404);\n    });\n\n    it('should reject sharing with non-existent user', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Folder' });\n\n      const res = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folder.body.id,\n          userId: '999',\n          role: 'viewer',\n        });\n\n      expect(res.status).toBe(404);\n    });\n\n    it('should only allow owner to assign owner role', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Folder' });\n\n      // Share with Bob as editor\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folder.body.id,\n          userId: bobUserId,\n          role: 'editor',\n        });\n\n      const charlieAuth = await registerAndLogin('charlie', 'pass789');\n\n      // Bob (editor) tries to assign owner role to Charlie\n      const res = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folder.body.id,\n          userId: charlieAuth.userId,\n          role: 'owner',\n        });\n\n      expect(res.status).toBe(403);\n    });\n\n    it('should get permissions for a resource', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Folder' });\n\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folder.body.id,\n          userId: bobUserId,\n          role: 'viewer',\n        });\n\n      const res = await request(app)\n        .get(`/share/folder/${folder.body.id}`)\n        .set('Authorization', `Bearer ${aliceToken}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body.length).toBe(2); // Alice (owner) + Bob (viewer)\n    });\n\n    it('should update existing permission when sharing again', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Folder' });\n\n      // Share with Bob as viewer\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folder.body.id,\n          userId: bobUserId,\n          role: 'viewer',\n        });\n\n      // Share again as editor\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folder.body.id,\n          userId: bobUserId,\n          role: 'editor',\n        });\n\n      // Bob should now be able to edit\n      const updateRes = await request(app)\n        .put(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ name: 'Bob Edited' });\n\n      expect(updateRes.status).toBe(200);\n    });\n\n    it('should inherit nested folder permissions', async () => {\n      const parent = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Parent' });\n\n      const child = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Child', parentId: parent.body.id });\n\n      // Share parent folder with Bob as editor\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: parent.body.id,\n          userId: bobUserId,\n          role: 'editor',\n        });\n\n      // Bob should be able to access child folder through parent permission\n      const getRes = await request(app)\n        .get(`/folders/${child.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n\n      expect(getRes.status).toBe(200);\n\n      // Bob should be able to edit child folder\n      const updateRes = await request(app)\n        .put(`/folders/${child.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ name: 'Updated by Bob' });\n\n      expect(updateRes.status).toBe(200);\n    });\n\n    it('should prevent unauthorized access to folders', async (