@@ -0,0 +1,86 @@
+import { Request, Response, NextFunction, Router } from 'express';
+import { Store, generateId } from './store.js';
+import crypto from 'crypto';
+
+export interface AuthRequest extends Request {
+  userId?: string;
+}
+
+export function createAuthMiddleware(store: Store) {
+  return (req: AuthRequest, _res: Response, next: NextFunction): void => {
+    const authHeader = req.headers.authorization;
+    if (authHeader && authHeader.startsWith('Bearer ')) {
+      const token = authHeader.slice(7);
+      for (const user of store.users.values()) {
+        if (user.token === token) {
+          req.userId = user.id;
+          break;
+        }
+      }
+    }
+    next();
+  };
+}
+
+export function requireAuth(req: AuthRequest, res: Response, next: NextFunction): void {
+  if (!req.userId) {
+    res.status(401).json({ error: 'Authentication required' });
+    return;
+  }
+  next();
+}
+
+export function createAuthRouter(store: Store): Router {
+  const router = Router();
+
+  router.post('/register', (req: Request, res: Response): void => {
+    const { username, password } = req.body;
+
+    if (!username || !password) {
+      res.status(400).json({ error: 'Username and password are required' });
+      return;
+    }
+
+    for (const user of store.users.values()) {
+      if (user.username === username) {
+        res.status(409).json({ error: 'Username already exists' });
+        return;
+      }
+    }
+
+    const id = generateId(store);
+    const user = { id, username, password };
+    store.users.set(id, user);
+
+    res.status(201).json({ id, username });
+  });
+
+  router.post('/login', (req: Request, res: Response): void => {
+    const { username, password } = req.body;
+
+    if (!username || !password) {
+      res.status(400).json({ error: 'Username and password are required' });
+      return;
+    }
+
+    let foundUser = null;
+    for (const user of store.users.values()) {
+      if (user.username === username && user.password === password) {
+        foundUser = user;
+        break;
+      }
+    }
+
+    if (!foundUser) {
+      res.status(401).json({ error: 'Invalid credentials' });
+      return;
+    }
+
+    const token = crypto.randomBytes(32).toString('hex');
+    foundUser.token = token;
+
+    res.status(200).json({ token, userId: foundUser.id });
+  });
+
+  return router;
+}
diff --git a/src/documents.ts b/src/documents.ts
new file mode 100644
index 0000000..57b760a
