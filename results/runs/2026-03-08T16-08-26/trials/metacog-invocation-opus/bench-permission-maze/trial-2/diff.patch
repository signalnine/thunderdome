diff --git a/src/activity.ts b/src/activity.ts
new file mode 100644
index 0000000..cca285e
--- /dev/null
+++ b/src/activity.ts
@@ -0,0 +1,22 @@
+import { Store, generateId } from './store.js';
+import { ActivityLogEntry } from './types.js';
+
+export function logActivity(
+  store: Store,
+  action: string,
+  userId: string,
+  resourceType: 'folder' | 'document',
+  resourceId: string,
+  details?: string
+): void {
+  const entry: ActivityLogEntry = {
+    id: generateId(store),
+    action,
+    userId,
+    resourceType,
+    resourceId,
+    timestamp: new Date().toISOString(),
+    details,
+  };
+  store.activityLog.push(entry);
+}
diff --git a/src/app.test.ts b/src/app.test.ts
new file mode 100644
index 0000000..59f7020
--- /dev/null
+++ b/src/app.test.ts
@@ -0,0 +1,948 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import request from 'supertest';
+import { createApp } from './app.js';
+import type { Express } from 'express';
+
+describe('Document Management API', () => {
+  let app: Express;
+
+  beforeEach(() => {
+    app = createApp();
+  });
+
+  // Helper to register a user and get their token
+  async function registerAndLogin(username: string, password: string) {
+    await request(app)
+      .post('/auth/register')
+      .send({ username, password });
+
+    const loginRes = await request(app)
+      .post('/auth/login')
+      .send({ username, password });
+
+    return loginRes.body;
+  }
+
+  describe('Auth', () => {
+    it('should register a new user', async () => {
+      const res = await request(app)
+        .post('/auth/register')
+        .send({ username: 'alice', password: 'pass123' });
+
+      expect(res.status).toBe(201);
+      expect(res.body.username).toBe('alice');
+      expect(res.body.id).toBeDefined();
+    });
+
+    it('should reject duplicate username', async () => {
+      await request(app)
+        .post('/auth/register')
+        .send({ username: 'alice', password: 'pass123' });
+
+      const res = await request(app)
+        .post('/auth/register')
+        .send({ username: 'alice', password: 'pass456' });
+
+      expect(res.status).toBe(409);
+    });
+
+    it('should reject registration with missing fields', async () => {
+      const res = await request(app)
+        .post('/auth/register')
+        .send({ username: 'alice' });
+
+      expect(res.status).toBe(400);
+    });
+
+    it('should login and return token', async () => {
+      await request(app)
+        .post('/auth/register')
+        .send({ username: 'alice', password: 'pass123' });
+
+      const res = await request(app)
+        .post('/auth/login')
+        .send({ username: 'alice', password: 'pass123' });
+
+      expect(res.status).toBe(200);
+      expect(res.body.token).toBeDefined();
+      expect(res.body.userId).toBeDefined();
+    });
+
+    it('should reject login with wrong password', async () => {
+      await request(app)
+        .post('/auth/register')
+        .send({ username: 'alice', password: 'pass123' });
+
+      const res = await request(app)
+        .post('/auth/login')
+        .send({ username: 'alice', password: 'wrong' });
+
+      expect(res.status).toBe(401);
+    });
+
+    it('should reject login with missing fields', async () => {
+      const res = await request(app)
+        .post('/auth/login')
+        .send({ username: 'alice' });
+
+      expect(res.status).toBe(400);
+    });
+
+    it('should require auth for protected routes', async () => {
+      const res = await request(app).get('/folders/1');
+      expect(res.status).toBe(401);
+    });
+  });
+
+  describe('Folders', () => {
+    let token: string;
+
+    beforeEach(async () => {
+      const auth = await registerAndLogin('alice', 'pass123');
+      token = auth.token;
+    });
+
+    it('should create a folder', async () => {
+      const res = await request(app)
+        .post('/folders')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'My Folder' });
+
+      expect(res.status).toBe(201);
+      expect(res.body.name).toBe('My Folder');
+      expect(res.body.id).toBeDefined();
+      expect(res.body.parentId).toBeNull();
+    });
+
+    it('should create a nested folder', async () => {
+      const parent = await request(app)
+        .post('/folders')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'Parent' });
+
+      const child = await request(app)
+        .post('/folders')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'Child', parentId: parent.body.id });
+
+      expect(child.status).toBe(201);
+      expect(child.body.parentId).toBe(parent.body.id);
+    });
+
+    it('should reject creating a folder without a name', async () => {
+      const res = await request(app)
+        .post('/folders')
+        .set('Authorization', `Bearer ${token}`)
+        .send({});
+
+      expect(res.status).toBe(400);
+    });
+
+    it('should get a folder with its contents', async () => {
+      const folder = await request(app)
+        .post('/folders')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'Root' });
+
+      const res = await request(app)
+        .get(`/folders/${folder.body.id}`)
+        .set('Authorization', `Bearer ${token}`);
+
+      expect(res.status).toBe(200);
+      expect(res.body.name).toBe('Root');
+      expect(res.body.subfolders).toEqual([]);
+      expect(res.body.documents).toEqual([]);
+    });
+
+    it('should return 404 for non-existent folder', async () => {
+      const res = await request(app)
+        .get('/folders/999')
+        .set('Authorization', `Bearer ${token}`);
+
+      expect(res.status).toBe(404);
+    });
+
+    it('should update a folder name', async () => {
+      const folder = await request(app)
+        .post('/folders')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'Old Name' });
