  }\n  });\n\n  // POST /notes - Create note\n  router.post('/notes', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const input = req.body as NoteInput;\n\n      if (!input.title || input.title.trim() === '') {\n        throw new ValidationError('Title is required');\n      }\n      if (!input.body || input.body.trim() === '') {\n        throw new ValidationError('Body is required');\n      }\n\n      const tags = input.tags ? JSON.stringify(input.tags) : '[]';\n      const stmt = db.prepare(`\n        INSERT INTO notes (title, body, tags) VALUES (?, ?, ?)\n      `);\n      const result = stmt.run(input.title, input.body, tags);\n\n      const note = db.prepare('SELECT * FROM notes WHERE id = ?').get(result.lastInsertRowid) as Note;\n      res.status(201).json({ note });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // PUT /notes/:id - Update note\n  router.put('/notes/:id', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const id = parseInt(req.params.id);\n      const existing = db.prepare('SELECT * FROM notes WHERE id = ?').get(id) as Note | undefined;\n\n      if (!existing) {\n        throw new NotFoundError('Note not found');\n      }\n\n      const input = req.body as Partial<NoteInput>;\n      const title = input.title ?? existing.title;\n      const body = input.body ?? existing.body;\n      const tags = input.tags ? JSON.stringify(input.tags) : existing.tags;\n\n      const stmt = db.prepare(`\n        UPDATE notes SET title = ?, body = ?, tags = ?, updated_at = datetime('now')\n        WHERE id = ?\n      `);\n      stmt.run(title, body, tags, id);\n\n      const note = db.prepare('SELECT * FROM notes WHERE id = ?').get(id) as Note;\n      res.json({ note });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // DELETE /notes/:id - Delete note\n  router.delete('/notes/:id', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const id = parseInt(req.params.id);\n      const existing = db.prepare('SELECT * FROM notes WHERE id = ?').get(id) as Note | undefined;\n\n      if (!existing) {\n        throw new NotFoundError('Note not found');\n      }\n\n      db.prepare('DELETE FROM notes WHERE id = ?').run(id);\n      res.status(204).send();\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  return router;\n}\n","structuredPatch":[{"oldStart":1,"oldLines":11,"newStart":1,"newLines":106,"lines":[" import { Router, Request, Response, NextFunction } from 'express';"," import Database from 'better-sqlite3';","-import { Note, NoteInput } from './models.js';","+import { Note, NoteInput, SearchResult, SuggestResult } from './models.js';"," import { NotFoundError, ValidationError } from './errors.js';"," ","+function sanitizeFtsQuery(query: string): string {","+  // Remove FTS5 special characters that could cause syntax errors","+  // Keep quoted phrases intact, strip other special chars","+  return query.replace(/[^\\w\\s\"*-]/g, ' ').trim();","+}","+"," export function createRoutes(db: Database.Database): Router {","   const router = Router();"," ","+  // GET /notes/search/suggest - Autocomplete suggestions","+  router.get('/notes/search/suggest', (req: Request, res: Response, next: NextFunction) => {","+    try {","+      const q = req.query.q as string | undefined;","+      if (!q || q.trim() === '') {","+        throw new ValidationError('Query parameter q is required');","+      }","+","+      const sanitized = sanitizeFtsQuery(q.trim());","+      if (!sanitized) {","+        res.json({ results: [] });","+        return;","+      }","+","+      // Use prefix matching for autocomplete","+      const prefixQuery = sanitized.split(/\\s+/).map(term => `\"${term}\"*`).join(' ');","+","+      const stmt = db.prepare(`","+        SELECT notes.id, notes.title","+        FROM notes_fts","+        JOIN notes ON notes.id = notes_fts.rowid","+        WHERE notes_fts MATCH ?","+        ORDER BY bm25(notes_fts)","+        LIMIT 5","+      `);","+","+      const results = stmt.all(prefixQuery) as SuggestResult[];","+      res.json({ results });","+    } catch (err) {","+      next(err);","+    }","+  });","+","+  // GET /notes/search - Full-text search","+  router.get('/notes/search', (req: Request, res: Response, next: NextFunction) => {","+    try {","+      const q = req.query.q as string | undefined;","+      if (!q || q.trim() === '') {","+        throw new ValidationError('Query parameter q is required');","+      }","+","+      const page = Math.max(1, parseInt(req.query.page as string) || 1);","+      const perPage = 20;","+      const offset = (page - 1) * perPage;","+","+      const sanitized = sanitizeFtsQuery(q.trim());","+      if (!sanitized) {","+        res.json({ results: [], total: 0, page, perPage });","+        return;","+      }","+","+      // Build FTS query: keep quoted phrases, add prefix matching for unquoted terms","+      let ftsQuery = sanitized;","+","+      // If there's no quoted phrase, wrap individual terms for safety","+      if (!ftsQuery.includes('\"')) {","+        ftsQuery = sanitized.split(/\\s+/).filter(Boolean).map(term => `\"${term}\"`).join(' ');","+      }","+","+      // Count total results","+      const countStmt = db.prepare(`","+        SELECT COUNT(*) as total","+        FROM notes_fts","+        WHERE notes_fts MATCH ?","+      `);","+      const { total } = countStmt.get(ftsQuery) as { total: number };","+","+      // Get paginated results with snippets and ranking","+      const searchStmt = db.prepare(`","+        SELECT","+          notes.id,","+          notes.title,","+          snippet(notes_fts, -1, '<mark>', '</mark>', '...', 32) as snippet,","+          bm25(notes_fts) as rank","+        FROM notes_fts","+        JOIN notes ON notes.id = notes_fts.rowid","+        WHERE notes_fts MATCH ?","+        ORDER BY bm25(notes_fts)","+        LIMIT ? OFFSET ?","+      `);","+","+      const results = searchStmt.all(ftsQuery, perPage, offset) as SearchResult[];","+","+      res.json({ results, total, page, perPage });","+    } catch (err) {","+      next(err);","+    }","+  });","+","   // GET /notes - List all notes (with optional tag filter)","   router.get('/notes', (req: Request, res: Response, next: NextFunction) => {","     try {"]}],"userModified":false,"replaceAll":false}}
