+// ============================================================
+// Types
+// ============================================================
+
+type CellValue = string | number | boolean | null;
+
+interface CellData {
+  raw: string | number | boolean;
+  formula: Formula | null;
+  value: CellValue;
+  dependsOn: Set<string>;  // cells this cell reads from
+  dependents: Set<string>; // cells that read from this cell
+}
+
+// ============================================================
+// AST Node Types
+// ============================================================
+
+type Formula =
+  | { type: 'number'; value: number }
+  | { type: 'string'; value: string }
+  | { type: 'boolean'; value: boolean }
+  | { type: 'cellref'; ref: string }
+  | { type: 'range'; start: string; end: string }
+  | { type: 'binop'; op: string; left: Formula; right: Formula }
+  | { type: 'unary'; op: string; operand: Formula }
+  | { type: 'func'; name: string; args: Formula[] };
+
+// ============================================================
+// Cell Reference Utilities
+// ============================================================
+
+function normalizeRef(ref: string): string {
+  return ref.toUpperCase();
+}
+
+function parseRef(ref: string): { col: string; row: number } {
+  const match = ref.match(/^([A-Z]+)(\d+)$/);
+  if (!match) throw new Error(`Invalid cell reference: ${ref}`);
+  return { col: match[1], row: parseInt(match[2], 10) };
+}
+
+function colToIndex(col: string): number {
+  let index = 0;
+  for (let i = 0; i < col.length; i++) {
+    index = index * 26 + (col.charCodeAt(i) - 64);
+  }
+  return index;
+}
+
+function indexToCol(index: number): string {
+  let col = '';
+  while (index > 0) {
+    const rem = (index - 1) % 26;
+    col = String.fromCharCode(65 + rem) + col;
+    index = Math.floor((index - 1) / 26);
+  }
+  return col;
+}
+
+function expandRange(start: string, end: string): string[] {
+  const s = parseRef(start);
+  const e = parseRef(end);
+  const startCol = colToIndex(s.col);
+  const endCol = colToIndex(e.col);
+  const startRow = s.row;
+  const endRow = e.row;
+
+  const minCol = Math.min(startCol, endCol);
+  const maxCol = Math.max(startCol, endCol);
+  const minRow = Math.min(startRow, endRow);
+  const maxRow = Math.max(startRow, endRow);
+
+  const cells: string[] = [];
+  for (let c = minCol; c <= maxCol; c++) {
+    for (let r = minRow; r <= maxRow; r++) {
+      cells.push(indexToCol(c) + r);
+    }
+  }
+  return cells;
+}
+
+// ============================================================
+// Tokenizer
+// ============================================================
+
+interface Token {
+  type: 'number' | 'string' | 'boolean' | 'cellref' | 'op' | 'paren' | 'comma' | 'colon' | 'func' | 'compare';
+  value: string;
+}
+
+function tokenize(input: string): Token[] {
+  const tokens: Token[] = [];
+  let i = 0;
+
+  while (i < input.length) {
+    const ch = input[i];
+
+    if (ch === ' ' || ch === '\t') {
+      i++;
+      continue;
+    }
+
+    // String literal
+    if (ch === '"') {
+      let str = '';
+      i++; // skip opening quote
+      while (i < input.length && input[i] !== '"') {
+        str += input[i];
+        i++;
+      }
+      if (i < input.length) i++; // skip closing quote
+      tokens.push({ type: 'string', value: str });
+      continue;
+    }
+
+    // Two-character comparison operators
+    if (i + 1 < input.length) {
+      const two = input[i] + input[i + 1];
+      if (two === '>=' || two === '<=' || two === '<>') {
+        tokens.push({ type: 'compare', value: two });
+        i += 2;
+        continue;
+      }
+    }
+
+    // Single-character comparison operators
+    if (ch === '>' || ch === '<') {
+      tokens.push({ type: 'compare', value: ch });
+      i++;
+      continue;
+    }
+
+    // Equals as comparison (only when not at start)
+    if (ch === '=' && tokens.length > 0) {
+      tokens.push({ type: 'compare', value: '=' });
+      i++;
+      continue;
+    }
+
+    // Number
+    if ((ch >= '0' && ch <= '9') || (ch === '.' && i + 1 < input.length && input[i + 1] >= '0' && input[i + 1] <= '9')) {
+      let num = '';
+      while (i < input.length && ((input[i] >= '0' && input[i] <= '9') || input[i] === '.')) {
+        num += input[i];
+        i++;
+      }
+      tokens.push({ type: 'number', value: num });
+      continue;
+    }
+
+    // Identifiers: cell refs, function names, booleans
+    if ((ch >= 'A' && ch <= 'Z') || (ch >= 'a' && ch <= 'z')) {
+      let ident = '';
+      while (i < input.length && ((input[i] >= 'A' && input[i] <= 'Z') || (input[i] >= 'a' && input[i] <= 'z') || (input[i] >= '0' && input[i] <= '9'))) {
+        ident += input[i];
+        i++;
+      }
+
+      const upper = ident.toUpperCase();
+
+      // Boolean
+      if (upper === 'TRUE' || upper === 'FALSE') {
+        tokens.push({ type: 'boolean', value: upper });
+        continue;
+      }
+
+      // Function call (identifier followed by '(')
+      if (i < input.length && input[i] === '(') {
+        tokens.push({ type: 'func', value: upper });
+        continue;
+      }
+
+      // Cell reference (letters followed by digits)
+      if (/^[A-Z]+\d+$/i.test(ident)) {
+        tokens.push({ type: 'cellref', value: upper });
+        continue;
+      }
+
+      // Treat as cell reference anyway (for partial refs in ranges, etc.)
+      tokens.push({ type: 'cellref', value: upper });
+      continue;
+    }
+
+    // Operators
+    if (ch === '+' || ch === '-' || ch === '*' || ch === '/') {
+      tokens.push({ type: 'op', value: ch });
+      i++;
+      continue;
+    }
+
+    // Parentheses
+    if (ch === '(' || ch === ')') {
+      tokens.push({ type: 'paren', value: ch });
+      i++;
+      continue;
+    }
+
+    // Comma
+    if (ch === ',') {
+      tokens.push({ type: 'comma', value: ch });
+      i++;
+      continue;
+    }
+
+    // Colon (for ranges)
+    if (ch === ':') {
+      tokens.push({ type: 'colon', value: ch });
+      i++;
+      continue;
+    }
+
+    // Skip unknown characters
+    i++;
+  }
+
+  return tokens;
+}
+
+// ============================================================
+// Parser (recursive descent)
+// ============================================================
+
+function parseFormula(input: string): Formula {
+  const tokens = tokenize(input);
+  let pos = 0;
+
+  function peek(): Token | undefined {
+    return tokens[pos];
+  }
+
+  function consume(): Token {
+    return tokens[pos++];
+  }
+
+  function parseExpression(): Formula {
+    return parseComparison();
+  }
+
+  function parseComparison(): Formula {
+    let left = parseAddSub();
+
+    while (peek() && peek()!.type === 'compare') {
+      const op = consume().value;
+      const right = parseAddSub();
+      left = { type: 'binop', op, left, right };
+    }
+
+    return left;
+  }
+
+  function parseAddSub(): Formula {
+    let left = parseMulDiv();
+
+    while (peek() && peek()!.type === 'op' && (peek()!.value === '+' || peek()!.value === '-')) {
+      const op = consume().value;
+      const right = parseMulDiv();
+      left = { type: 'binop', op, left, right };
+    }
+
+    return left;
+  }
+
+  function parseMulDiv(): Formula {
+    let left = parseUnary();
+
+    while (peek() && peek()!.type === 'op' && (peek()!.value === '*' || peek()!.value === '/')) {
+      const op = consume().value;
+      const right = parseUnary();
+      left = { type: 'binop', op, left, right };
+    }
+
+    return left;
+  }
+
+  function parseUnary(): Formula {
+    if (peek() && peek()!.type === 'op' && (peek()!.value === '-' || peek()!.value === '+')) {
+      const op = consume().value;
+      const operand = parseUnary();
+      return { type: 'unary', op, operand };
+    }
+    return parsePrimary();
+  }
+
+  function parsePrimary(): Formula {
+    const token = peek();
+    if (!token) throw new Error('Unexpected end of formula');
+
+    // Number
+    if (token.type === 'number') {
+      consume();
+      return { type: 'number', value: parseFloat(token.value) };
+    }
+
+    // String
+    if (token.type === 'string') {
+      consume();
+      return { type: 'string', value: token.value };
+    }
+
+    // Boolean
+    if (token.type === 'boolean') {
+      consume();
+      return { type: 'boolean', value: token.value === 'TRUE' };
+    }
+
+    // Function call
+    if (token.type === 'func') {
+      const name = consume().value;
+      consume(); // '('
+      const args: Formula[] = [];
+
+      if (peek() && peek()!.value !== ')') {
+        args.push(parseExpression());
+        while (peek() && peek()!.type === 'comma') {
+          consume(); // ','
+          args.push(parseExpression());
+        }
+      }
+
+      if (peek() && peek()!.value === ')') {
+        consume(); // ')'
+      }
+      return { type: 'func', name, args };
+    }
+
+    // Cell reference (possibly part of a range)
+    if (token.type === 'cellref') {
+      const ref = consume().value;
+
+      // Check for range operator ':'
+      if (peek() && peek()!.type === 'colon') {
+        consume(); // ':'
+        const endToken = consume();
+        return { type: 'range', start: ref, end: endToken.value };
+      }
+
+      return { type: 'cellref', ref };
+    }
+
+    // Parenthesized expression
+    if (token.type === 'paren' && token.value === '(') {
+      consume(); // '('
+      const expr = parseExpression();
+      if (peek() && peek()!.value === ')') {
+        consume(); // ')'
+      }
+      return expr;
+    }
+
+    throw new Error(`Unexpected token: ${token.value}`);
+  }
+
+  const result = parseExpression();
+  return result;
+}
+
+// ============================================================
+// Extract cell dependencies from a formula AST
+// ============================================================
+
+function extractDeps(formula: Formula): Set<string> {
+  const deps = new Set<string>();
+
+  function walk(node: Formula): void {
+    switch (node.type) {
+      case 'cellref':
+        deps.add(node.ref);
+        break;
+      case 'range':
+        for (const cell of expandRange(node.start, node.end)) {
+          deps.add(cell);
+        }
+        break;
+      case 'binop':
+        walk(node.left);
+        walk(node.right);
+        break;
+      case 'unary':
+        walk(node.operand);
+        break;
+      case 'func':
+        for (const arg of node.args) {
+          walk(arg);
+        }
+        break;
+      // number, string, boolean: no deps
+    }
+  }
+
+  walk(formula);
+  return deps;
+}
+
+// ============================================================
+// Spreadsheet Engine
+// ============================================================
+
+export class Spreadsheet {
+  private cells: Map<string, CellData> = new Map();
+
+  set(cell: string, value: string | number | boolean): void {
+    const ref = normalizeRef(cell);
+
+    // Parse formula if string starting with '='
+    let formula: Formula | null = null;
+    let newDeps = new Set<string>();
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      formula = parseFormula(value.substring(1));
+      newDeps = extractDeps(formula);
+    }
+
+    // Check for circular dependency before committing
+    if (newDeps.size > 0) {
+      this.checkCircular(ref, newDeps);
+    }
+
+    // Get or create cell data
+    const existing = this.cells.get(ref);
+
+    // Remove old dependency edges
+    if (existing) {
+      for (const dep of existing.dependsOn) {
+        const depCell = this.cells.get(dep);
+        if (depCell) {
+          depCell.dependents.delete(ref);
+        }
+      }
+    }
+
+    // Create cell data
+    const cellData: CellData = {
+      raw: value,
+      formula,
+      value: null,
+      dependsOn: newDeps,
+      dependents: existing ? existing.dependents : new Set<string>(),
+    };
+
+    this.cells.set(ref, cellData);
+
+    // Add new dependency edges
+    for (const dep of newDeps) {
+      let depCell = this.cells.get(dep);
+      if (!depCell) {
+        depCell = {
+          raw: '',
+          formula: null,
+          value: null,
+          dependsOn: new Set(),
+          dependents: new Set(),
+        };
+        this.cells.set(dep, depCell);
+      }
+      depCell.dependents.add(ref);
+    }
+
+    // Evaluate this cell
+    cellData.value = this.evaluate(cellData);
+
+    // Propagate to dependents in topological order
+    this.propagate(ref);
+  }
+
+  get(cell: string): CellValue {
+    const ref = normalizeRef(cell);
+    const data = this.cells.get(ref);
+    if (!data) return null;
+    return data.value;
+  }
+
+  getDisplay(cell: string): string {
+    const value = this.get(cell);
+    if (value === null) return '';
+    return String(value);
+  }
+
+  getCells(): Map<string, CellValue> {
+    const result = new Map<string, CellValue>();
+    for (const [ref, data] of this.cells) {
+      // Only include cells that were explicitly set (not placeholder empty cells)
+      if (data.raw !== '' || data.formula !== null) {
+        result.set(ref, data.value);
+      }
+    }
+    return result;
+  }
+
+  // ----------------------------------------------------------
+  // Circular dependency detection
+  // ----------------------------------------------------------
+
+  private checkCircular(target: string, newDeps: Set<string>): void {
+    // DFS from each dependency to see if we can reach `target`
+    const visited = new Set<string>();
+
+    const dfs = (current: string): boolean => {
+      if (current === target) return true;
+      if (visited.has(current)) return false;
+      visited.add(current);
+
+      const cell = this.cells.get(current);
+      if (!cell) return false;
+
+      for (const dep of cell.dependsOn) {
+        if (dfs(dep)) return true;
+      }
+      return false;
+    };
+
+    for (const dep of newDeps) {
+      if (dep === target || dfs(dep)) {
+        throw new Error(`Circular reference detected involving ${target}`);
+      }
+    }
+  }
+
+  // ----------------------------------------------------------
+  // Propagation: topological sort of dependents, then evaluate
+  // ----------------------------------------------------------
+
+  private propagate(changedRef: string): void {
+    // Collect all transitive dependents in topological order
+    const order: string[] = [];
+    const visited = new Set<string>();
+
+    const visit = (ref: string): void => {
+      if (visited.has(ref)) return;
+      visited.add(ref);
+
+      const cell = this.cells.get(ref);
+      if (!cell) return;
+
+      for (const dep of cell.dependents) {
+        visit(dep);
+      }
+
+      order.push(ref);
+    };
+
+    // Start from direct dependents of the changed cell
+    const changedCell = this.cells.get(changedRef);
+    if (!changedCell) return;
+
+    for (const dep of changedCell.dependents) {
+      visit(dep);
+    }
+
+    // Reverse for correct topological order (dependencies before dependents)
+    order.reverse();
+
+    // Re-evaluate each in order
+    for (const ref of order) {
+      const cell = this.cells.get(ref);
+      if (cell && cell.formula) {
+        cell.value = this.evaluate(cell);
+      }
+    }
+  }
+
+  // ----------------------------------------------------------
+  // Formula evaluation
+  // ----------------------------------------------------------
+
+  private evaluate(cell: CellData): CellValue {
+    if (!cell.formula) {
+      // Raw value
+      if (typeof cell.raw === 'string' && cell.raw === '') return null;
+      return cell.raw as CellValue;
+    }
+
+    return this.evalNode(cell.formula);
+  }
+
+  private evalNode(node: Formula): CellValue {
+    switch (node.type) {
+      case 'number':
+        return node.value;
+
+      case 'string':
+        return node.value;
+
+      case 'boolean':
+        return node.value;
+
+      case 'cellref': {
+        const cell = this.cells.get(node.ref);
+        if (!cell) return null;
+        return cell.value;
+      }
+
+      case 'range':
+        // Ranges are only valid inside aggregate functions; evaluate them there
+        throw new Error('Range used outside of function');
+
+      case 'unary': {
+        const operand = this.evalNode(node.operand);
+        if (node.op === '-') return -(operand as number);
+        return operand;
+      }
+
+      case 'binop': {
+        const left = this.evalNode(node.left);
+        const right = this.evalNode(node.right);
+
+        switch (node.op) {
+          case '+': return (left as number) + (right as number);
+          case '-': return (left as number) - (right as number);
+          case '*': return (left as number) * (right as number);
+          case '/': return (left as number) / (right as number);
+          case '>': return (left as number) > (right as number);
+          case '<': return (left as number) < (right as number);
+          case '>=': return (left as number) >= (right as number);
+          case '<=': return (left as number) <= (right as number);
+          case '=': return left === right;
+          case '<>': return left !== right;
+          default: throw new Error(`Unknown operator: ${node.op}`);
+        }
+      }
+
+      case 'func':
+        return this.evalFunc(node.name, node.args);
+    }
+  }
+
+  private resolveRangeValues(args: Formula[]): number[] {
+    const values: number[] = [];
+    for (const arg of args) {
+      if (arg.type === 'range') {
+        const cells = expandRange(arg.start, arg.end);
+        for (const ref of cells) {
+          const cell = this.cells.get(ref);
+          if (cell && typeof cell.value === 'number') {
+            values.push(cell.value);
+          }
+        }
+      } else {
+        const val = this.evalNode(arg);
+        if (typeof val === 'number') {
+          values.push(val);
+        }
+      }
+    }
+    return values;
+  }
+
+  private evalFunc(name: string, args: Formula[]): CellValue {
+    switch (name) {
+      case 'SUM': {
+        const values = this.resolveRangeValues(args);
+        return values.reduce((a, b) => a + b, 0);
+      }
+
+      case 'AVERAGE': {
+        const values = this.resolveRangeValues(args);
+        if (values.length === 0) return 0;
+        return values.reduce((a, b) => a + b, 0) / values.length;
+      }
+
+      case 'MIN': {
+        const values = this.resolveRangeValues(args);
+        if (values.length === 0) return 0;
+        return Math.min(...values);
+      }
+
+      case 'MAX': {
+        const values = this.resolveRangeValues(args);
+        if (values.length === 0) return 0;
+        return Math.max(...values);
+      }
+
+      case 'COUNT': {
+        const values = this.resolveRangeValues(args);
+        return values.length;
+      }
+
+      case 'IF': {
+        if (args.length < 3) throw new Error('IF requires 3 arguments');
+        const condition = this.evalNode(args[0]);
+        if (condition) {
+          return this.evalNode(args[1]);
+        } else {
+          return this.evalNode(args[2]);
+        }
+      }
+
+      default:
+        throw new Error(`Unknown function: ${name}`);
+    }
+  }
+}
