+          while (this.peek()?.type === 'comma') {
+            this.consume();
+            args.push(this.parseFuncArg());
+          }
+        }
+        const closing = this.consume();
+        if (!(closing?.type === 'paren' && closing.value === ')')) {
+          throw new Error('Expected closing parenthesis');
+        }
+        return { type: 'func', name: t.value, args };
+      }
+
+      // Range: REF:REF
+      if (next && next.type === 'colon') {
+        this.consume(); // consume ':'
+        const endToken = this.consume();
+        if (endToken?.type !== 'ref') throw new Error('Expected cell reference after colon');
+        return { type: 'range', start: t.value, end: endToken.value };
+      }
+
+      // Cell reference
+      return { type: 'ref', ref: t.value };
+    }
+
+    if (t.type === 'paren' && t.value === '(') {
+      this.consume();
+      const node = this.parseComparison();
+      const closing = this.consume();
+      if (!(closing?.type === 'paren' && closing.value === ')')) {
+        throw new Error('Expected closing parenthesis');
+      }
+      return node;
+    }
+
+    throw new Error(`Unexpected token: ${JSON.stringify(t)}`);
+  }
+
+  private parseFuncArg(): ASTNode {
+    // Inside function arguments, a ref:ref could be a range
+    const t = this.peek();
+    if (t && t.type === 'ref') {
+      // Look ahead for colon (range)
+      const saved = this.pos;
+      this.consume();
+      const next = this.peek();
+      if (next && next.type === 'colon') {
+        this.consume();
+        const endToken = this.peek();
+        if (endToken?.type === 'ref') {
+          this.consume();
+          return { type: 'range', start: t.value, end: endToken.value };
+        }
+        // Not a valid range, backtrack
+        this.pos = saved;
+      } else {
+        // Backtrack and parse normally
+        this.pos = saved;
+      }
+    }
+    return this.parseComparison();
+  }
+}
+
+function parseFormula(formula: string): ASTNode {
+  const tokens = tokenize(formula);
+  const parser = new Parser(tokens);
+  return parser.parse();
+}
+
+// ─── Dependency Extraction ──────────────────────────────────────────────────
+
+function extractDependencies(ast: ASTNode): Set<string> {
+  const deps = new Set<string>();
+
+  function walk(node: ASTNode): void {
+    switch (node.type) {
+      case 'ref':
+        deps.add(node.ref);
+        break;
+      case 'range':
+        for (const cell of expandRange(node.start, node.end)) {
+          deps.add(cell);
+        }
+        break;
+      case 'binop':
+        walk(node.left);
+        walk(node.right);
+        break;
+      case 'unary':
+        walk(node.operand);
+        break;
+      case 'func':
+        for (const arg of node.args) {
+          walk(arg);
+        }
+        break;
+      // number, string, boolean: no deps
+    }
+  }
+
+  walk(ast);
+  return deps;
+}
+
+// ─── Cell Storage ───────────────────────────────────────────────────────────
+
+interface CellData {
+  raw: string | number | boolean;
+  formula: ASTNode | null;     // parsed AST if formula
+  value: string | number | boolean | null; // computed value
+  deps: Set<string>;           // cells this cell depends on
+}
+
+// ─── Spreadsheet Class ──────────────────────────────────────────────────────
+
+export class Spreadsheet {
+  private cells: Map<string, CellData> = new Map();
+  // Reverse dependency map: if A1 depends on B1, then dependents.get('B1') contains 'A1'
+  private dependents: Map<string, Set<string>> = new Map();
+
+  set(cell: string, value: string | number | boolean): void {
+    const ref = cell.toUpperCase();
+
+    // Save old state for rollback
+    const oldCellData = this.cells.get(ref);
+
+    // Remove old dependency edges
+    if (oldCellData) {
+      for (const dep of oldCellData.deps) {
+        this.dependents.get(dep)?.delete(ref);
+      }
+    }
+
+    let formula: ASTNode | null = null;
+    let deps = new Set<string>();
+    let computedValue: string | number | boolean | null;
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      const formulaStr = value.slice(1);
+      formula = parseFormula(formulaStr);
+      deps = extractDependencies(formula);
+
+      // Register forward dependency edges
+      for (const dep of deps) {
+        if (!this.dependents.has(dep)) {
+          this.dependents.set(dep, new Set());
+        }
+        this.dependents.get(dep)!.add(ref);
+      }
+
+      // Store cell with deps so cycle detection can traverse it
+      this.cells.set(ref, {
+        raw: value,
+        formula,
+        value: null,
+        deps,
+      });
+
+      // Check for circular references before evaluating
+      try {
+        this.detectCycle(ref);
+      } catch (e) {
+        // Rollback: remove dependency edges and restore old state
+        for (const dep of deps) {
+          this.dependents.get(dep)?.delete(ref);
+        }
+        if (oldCellData) {
+          this.cells.set(ref, oldCellData);
+          for (const dep of oldCellData.deps) {
+            if (!this.dependents.has(dep)) {
+              this.dependents.set(dep, new Set());
+            }
+            this.dependents.get(dep)!.add(ref);
+          }
+        } else {
+          this.cells.delete(ref);
+        }
+        throw e;
+      }
+
+      computedValue = this.evaluate(formula);
+      this.cells.get(ref)!.value = computedValue;
+    } else {
+      computedValue = value;
+      this.cells.set(ref, {
+        raw: value,
+        formula,
+        value: computedValue,
+        deps,
+      });
+    }
+
+    // Propagate changes to all transitive dependents
+    this.propagate(ref);
+  }
+
+  get(cell: string): string | number | boolean | null {
+    const ref = cell.toUpperCase();
+    const data = this.cells.get(ref);
+    if (!data) return null;
+    return data.value;
+  }
+
+  getDisplay(cell: string): string {
+    const value = this.get(cell);
+    if (value === null) return '';
+    return String(value);
+  }
+
+  getCells(): Map<string, string | number | boolean | null> {
+    const result = new Map<string, string | number | boolean | null>();
+    for (const [ref, data] of this.cells) {
+      result.set(ref, data.value);
+    }
+    return result;
+  }
+
+  // ─── Cycle Detection ───────────────────────────────────────────────────
+
+  private detectCycle(startRef: string): void {
+    // Follow the dependency chain from startRef. If we encounter startRef
+    // again, there's a cycle. The cell data for startRef is already in this.cells.
+    const visited = new Set<string>();
+
+    const hasCycle = (ref: string): boolean => {
+      if (visited.has(ref)) return false;
+      visited.add(ref);
+      const cellData = this.cells.get(ref);
+      if (!cellData) return false;
+      for (const dep of cellData.deps) {
+        if (dep === startRef) return true;
+        if (hasCycle(dep)) return true;
+      }
+      return false;
+    };
+
+    if (hasCycle(startRef)) {
+      throw new Error('Circular reference detected');
+    }
+  }
+
+  // ─── Reactive Propagation ─────────────────────────────────────────────
+
+  private propagate(changedRef: string): void {
+    // Topologically sort all transitive dependents, then recompute
+    const order = this.topologicalSort(changedRef);
+    for (const ref of order) {
+      const data = this.cells.get(ref);
+      if (data && data.formula) {
+        data.value = this.evaluate(data.formula);
+      }
+    }
+  }
+
+  private topologicalSort(startRef: string): string[] {
+    // Collect all transitive dependents of startRef
+    const visited = new Set<string>();
+    const result: string[] = [];
+
+    const visit = (ref: string): void => {
+      if (visited.has(ref)) return;
+      visited.add(ref);
+      const deps = this.dependents.get(ref);
+      if (deps) {
+        for (const dep of deps) {
+          visit(dep);
+        }
+      }
+      result.push(ref);
+    };
+
+    // Start from the changed cell's dependents
+    const directDeps = this.dependents.get(startRef);
+    if (directDeps) {
+      for (const dep of directDeps) {
+        visit(dep);
+      }
+    }
+
+    // result is in reverse topological order (post-order), so reverse it
+    // Actually for propagation, we want cells whose dependencies come first.
+    // Post-order DFS on dependents gives us leaves last, so we need to reverse.
+    return result.reverse();
+  }
+
+  // ─── Formula Evaluation ───────────────────────────────────────────────
+
+  private evaluate(node: ASTNode): string | number | boolean | null {
+    switch (node.type) {
+      case 'number':
+        return node.value;
+      case 'string':
+        return node.value;
+      case 'boolean':
+        return node.value;
+      case 'ref':
+        return this.get(node.ref);
+      case 'range':
+        throw new Error('Range can only be used inside functions');
+      case 'unary': {
+        const val = this.evaluate(node.operand);
+        if (node.op === '-' && typeof val === 'number') return -val;
+        return val;
+      }
+      case 'binop': {
+        const left = this.evaluate(node.left);
+        const right = this.evaluate(node.right);
+        return this.evalBinop(node.op, left, right);
+      }
+      case 'func':
+        return this.evalFunc(node.name, node.args);
+    }
+  }
+
+  private evalBinop(
+    op: string,
+    left: string | number | boolean | null,
+    right: string | number | boolean | null
+  ): string | number | boolean | null {
+    const l = typeof left === 'number' ? left : 0;
+    const r = typeof right === 'number' ? right : 0;
+
+    switch (op) {
+      case '+': return l + r;
+      case '-': return l - r;
+      case '*': return l * r;
+      case '/': return r === 0 ? 0 : l / r;
+      case '>': return l > r;
+      case '<': return l < r;
+      case '>=': return l >= r;
+      case '<=': return l <= r;
+      case '=': return left === right;
+      case '<>': return left !== right;
+      default:
+        throw new Error(`Unknown operator: ${op}`);
+    }
+  }
+
+  private evalFunc(name: string, args: ASTNode[]): string | number | boolean | null {
+    switch (name) {
+      case 'SUM': {
+        const values = this.collectNumericValues(args);
+        return values.reduce((sum, v) => sum + v, 0);
+      }
+      case 'AVERAGE': {
+        const values = this.collectNumericValues(args);
+        if (values.length === 0) return 0;
+        return values.reduce((sum, v) => sum + v, 0) / values.length;
+      }
+      case 'MIN': {
+        const values = this.collectNumericValues(args);
+        if (values.length === 0) return 0;
+        return Math.min(...values);
+      }
+      case 'MAX': {
+        const values = this.collectNumericValues(args);
+        if (values.length === 0) return 0;
+        return Math.max(...values);
+      }
+      case 'COUNT': {
+        const values = this.collectNumericValues(args);
+        return values.length;
+      }
+      case 'IF': {
+        if (args.length < 3) throw new Error('IF requires 3 arguments');
+        const condition = this.evaluate(args[0]);
+        if (condition && condition !== 0) {
+          return this.evaluate(args[1]);
+        } else {
+          return this.evaluate(args[2]);
+        }
+      }
+      default:
+        throw new Error(`Unknown function: ${name}`);
+    }
+  }
+
+  private collectNumericValues(args: ASTNode[]): number[] {
+    const values: number[] = [];
+    for (const arg of args) {
+      if (arg.type === 'range') {
+        const cells = expandRange(arg.start, arg.end);
+        for (const cellRef of cells) {
+          const val = this.get(cellRef);
+          if (typeof val === 'number') {
+            values.push(val);
+          }
+        }
+      } else {
+        const val = this.evaluate(arg);
+        if (typeof val === 'number') {
+          values.push(val);
+        }
+      }
+    }
+    return values;
+  }
+}
