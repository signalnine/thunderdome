s = parseRef(start);\n  const e = parseRef(end);\n  const minCol = Math.min(s.col, e.col);\n  const maxCol = Math.max(s.col, e.col);\n  const minRow = Math.min(s.row, e.row);\n  const maxRow = Math.max(s.row, e.row);\n  const cells: string[] = [];\n  for (let r = minRow; r <= maxRow; r++) {\n    for (let c = minCol; c <= maxCol; c++) {\n      cells.push(toRef(c, r));\n    }\n  }\n  return cells;\n}\n\n// ─── Formula AST ────────────────────────────────────────────────────────────\n\ntype ASTNode =\n  | { type: 'number'; value: number }\n  | { type: 'string'; value: string }\n  | { type: 'boolean'; value: boolean }\n  | { type: 'ref'; ref: string }\n  | { type: 'range'; start: string; end: string }\n  | { type: 'binop'; op: string; left: ASTNode; right: ASTNode }\n  | { type: 'unary'; op: string; operand: ASTNode }\n  | { type: 'func'; name: string; args: ASTNode[] };\n\n// ─── Tokenizer ──────────────────────────────────────────────────────────────\n\ntype Token =\n  | { type: 'number'; value: number }\n  | { type: 'string'; value: string }\n  | { type: 'boolean'; value: boolean }\n  | { type: 'ref'; value: string }\n  | { type: 'op'; value: string }\n  | { type: 'paren'; value: '(' | ')' }\n  | { type: 'comma' }\n  | { type: 'colon' };\n\nfunction tokenize(input: string): Token[] {\n  const tokens: Token[] = [];\n  let i = 0;\n\n  while (i < input.length) {\n    const ch = input[i];\n\n    if (ch === ' ' || ch === '\\t') {\n      i++;\n      continue;\n    }\n\n    // String literals\n    if (ch === '\"') {\n      let str = '';\n      i++; // skip opening quote\n      while (i < input.length && input[i] !== '\"') {\n        str += input[i];\n        i++;\n      }\n      i++; // skip closing quote\n      tokens.push({ type: 'string', value: str });\n      continue;\n    }\n\n    // Numbers\n    if (ch >= '0' && ch <= '9') {\n      let num = '';\n      while (i < input.length && ((input[i] >= '0' && input[i] <= '9') || input[i] === '.')) {\n        num += input[i];\n        i++;\n      }\n      tokens.push({ type: 'number', value: parseFloat(num) });\n      continue;\n    }\n\n    // Identifiers (cell refs, function names, booleans)\n    if ((ch >= 'A' && ch <= 'Z') || (ch >= 'a' && ch <= 'z')) {\n      let ident = '';\n      while (i < input.length && ((input[i] >= 'A' && input[i] <= 'Z') || (input[i] >= 'a' && input[i] <= 'z') || (input[i] >= '0' && input[i] <= '9'))) {\n        ident += input[i];\n        i++;\n      }\n\n      const upper = ident.toUpperCase();\n      if (upper === 'TRUE') {\n        tokens.push({ type: 'boolean', value: true });\n      } else if (upper === 'FALSE') {\n        tokens.push({ type: 'boolean', value: false });\n      } else if (/^[A-Z]+\\d+$/i.test(ident)) {\n        tokens.push({ type: 'ref', value: ident.toUpperCase() });\n      } else {\n        // Function name — treat as ref, parser handles it when followed by '('\n        tokens.push({ type: 'ref', value: upper });\n      }\n      continue;\n    }\n\n    // Multi-char operators\n    if (ch === '<' || ch === '>') {\n      if (i + 1 < input.length && input[i + 1] === '=') {\n        tokens.push({ type: 'op', value: ch + '=' });\n        i += 2;\n        continue;\n      }\n      if (ch === '<' && i + 1 < input.length && input[i + 1] === '>') {\n        tokens.push({ type: 'op', value: '<>' });\n        i += 2;\n        continue;\n      }\n      tokens.push({ type: 'op', value: ch });\n      i++;\n      continue;\n    }\n\n    if (ch === '=' ) {\n      tokens.push({ type: 'op', value: '=' });\n      i++;\n      continue;\n    }\n\n    if (ch === '+' || ch === '-' || ch === '*' || ch === '/') {\n      tokens.push({ type: 'op', value: ch });\n      i++;\n      continue;\n    }\n\n    if (ch === '(') { tokens.push({ type: 'paren', value: '(' }); i++; continue; }\n    if (ch === ')') { tokens.push({ type: 'paren', value: ')' }); i++; continue; }\n    if (ch === ',') { tokens.push({ type: 'comma' }); i++; continue; }\n    if (ch === ':') { tokens.push({ type: 'colon' }); i++; continue; }\n\n    throw new Error(`Unexpected character in formula: ${ch}`);\n  }\n\n  return tokens;\n}\n\n// ─── Parser (Recursive Descent) ─────────────────────────────────────────────\n\nclass Parser {\n  private tokens: Token[];\n  private pos: number;\n\n  constructor(tokens: Token[]) {\n    this.tokens = tokens;\n    this.pos = 0;\n  }\n\n  private peek(): Token | undefined {\n    return this.tokens[this.pos];\n  }\n\n  private consume(): Token {\n    return this.tokens[this.pos++];\n  }\n\n  parse(): ASTNode {\n    const node = this.parseComparison();\n    if (this.pos < this.tokens.length) {\n      throw new Error('Unexpected tokens after expression');\n    }\n    return node;\n  }\n\n  private parseComparison(): ASTNode {\n    let left = this.parseAddSub();\n    const t = this.peek();\n    if (t && t.type === 'op' && ['>', '<', '>=', '<=', '=', '<>'].includes(t.value)) {\n      this.consume();\n      const right = this.parseAddSub();\n      return { type: 'binop', op: t.value, left, right };\n    }\n    return left;\n  }\n\n  private parseAddSub(): ASTNode {\n    let left = this.parseMulDiv();\n    while (true) {\n      const t = this.peek();\n      if (t && t.type === 'op' && (t.value === '+' || t.value === '-')) {\n        this.consume();\n        const right = this.parseMulDiv();\n        left = { type: 'binop', op: t.value, left, right };\n      } else {\n        break;\n      }\n    }\n    return left;\n  }\n\n  private parseMulDiv(): ASTNode {\n    let left = this.parseUnary();\n    while (true) {\n      const t = this.peek();\n      if (t && t.type === 'op' && (t.value === '*' || t.value === '/')) {\n        this.consume();\n        const right = this.parseUnary();\n        left = { type: 'binop', op: t.value, left, right };\n      } else {\n        break;\n      }\n    }\n    return left;\n  }\n\n  private parseUnary(): ASTNode {\n    const t = this.peek();\n    if (t && t.type === 'op' && (t.value === '+' || t.value === '-')) {\n      this.consume();\n      const operand = this.parseUnary();\n      if (t.value === '+') return operand;\n      return { type: 'unary', op: '-', operand };\n    }\n    return this.parsePrimary();\n  }\n\n  private parsePrimary(): ASTNode {\n    const t = this.peek();\n    if (!t) throw new Error('Unexpected end of formula');\n\n    if (t.type === 'number') {\n      this.consume();\n      return { type: 'number', value: t.value };\n    }\n\n    if (t.type === 'string') {\n      this.consume();\n      return { type: 'string', value: t.value };\n    }\n\n    if (t.type === 'boolean') {\n      this.consume();\n      return { type: 'boolean', value: t.value };\n    }\n\n    if (t.type === 'ref') {\n      this.consume();\n      const next = this.peek();\n\n      // Function call: NAME(args...)\n      if (next && next.type === 'paren' && next.value === '(') {\n        this.consume(); // consume '('\n        const args: ASTNode[] = [];\n        if (!(this.peek()?.type === 'paren' && (this.peek() as Token & { value: string }).value === ')')) {\n          args.push(this.parseFuncArg());\n          while (this.peek()?.type === 'comma') {\n            this.consume();\n            args.push(this.parseFuncArg());\n          }\n        }\n        const closing = this.consume();\n        if (!(closing?.type === 'paren' && closing.value === ')')) {\n          throw new Error('Expected closing parenthesis');\n        }\n        return { type: 'func', name: t.value, args };\n      }\n\n      // Range: REF:REF\n      if (next && next.type === 'colon') {\n        this.consume(); // consume ':'\n        const endToken = this.consume();\n        if (endToken?.type !== 'ref') throw new Error('Expected cell reference after colon');\n        return { type: 'range', start: t.value, end: endToken.value };\n      }\n\n      // Cell reference\n      return { type: 'ref', ref: t.value };\n    }\n\n    if (t.type === 'paren' && t.value === '(') {\n      this.consume();\n      const node = this.parseComparison();\n      const closing = this.consume();\n      if (!(closing?.type === 'paren' && closing.value === ')')) {\n        throw new Error('Expected closing parenthesis');\n      }\n      return node;\n    }\n\n    throw new Error(`Unexpected token: ${JSON.stringify(t)}`);\n  }\n\n  private parseFuncArg(): ASTNode {\n    // Inside function arguments, a ref:ref could be a range\n    const t = this.peek();\n    if (t && t.type === 'ref') {\n      // Look ahead for colon (range)\n      const saved = this.pos;\n      this.consume();\n      const next = this.peek();\n      if (next && next.type === 'colon') {\n        this.consume();\n        const endToken = this.peek();\n        if (endToken?.type === 'ref') {\n          this.consume();\n          return { type: 'range', start: t.value, end: endToken.value };\n        }\n        // Not a valid range, backtrack\n        this.pos = saved;\n      } else {\n        // Backtrack and parse normally\n        this.pos = saved;\n      }\n    }\n    return this.parseComparison();\n  }\n}\n\nfunction parseFormula(formula: string): ASTNode {\n  const tokens = tokenize(formula);\n  const parser = new Parser(tokens);\n  return parser.parse();\n}\n\n// ─── Dependency Extraction ──────────────────────────────────────────────────\n\nfunction extractDependencies(ast: ASTNode): Set<string> {\n  const deps = new Set<string>();\n\n  function walk(node: ASTNode): void {\n    switch (node.type) {\n      case 'ref':\n        deps.add(node.ref);\n        break;\n      case 'range':\n        for (const cell of expandRange(node.start, node.end)) {\n          deps.add(cell);\n        }\n        break;\n      case 'binop':\n        walk(node.left);\n        walk(node.right);\n        break;\n      case 'unary':\n        walk(node.operand);\n        break;\n      case 'func':\n        for (const arg of node.args) {\n          walk(arg);\n        }\n        break;\n      // number, string, boolean: no deps\n    }\n  }\n\n  walk(ast);\n  return deps;\n}\n\n// ─── Cell Storage ───────────────────────────────────────────────────────────\n\ninterface CellData {\n  raw: string | number | boolean;\n  formula: ASTNode | null;     // parsed AST if formula\n  value: string | number | boolean | null; // computed value\n  deps: Set<string>;           // cells this cell depends on\n}\n\n// ─── Spreadsheet Class ──────────────────────────────────────────────────────\n\nexport class Spreadsheet {\n  private cells: Map<string, CellData> = new Map();\n  // Reverse dependency map: if A1 depends on B1, then dependents.get('B1') contains 'A1'\n  private dependents: Map<string, Set<string>> = new Map();\n\n  set(cell: string, value: string | number | boolean): void {\n    const ref = cell.toUpperCase();\n\n    // Save old state for rollback\n    const oldCellData = this.cells.get(ref);\n\n    // Remove old dependency edges\n    if (oldCellData) {\n      for (const dep of oldCellData.deps) {\n        this.dependents.get(dep)?.delete(ref);\n      }\n    }\n\n    let formula: ASTNode | null = null;\n    let deps = new Set<string>();\n    let computedValue: string | number | boolean | null;\n\n    if (typeof value === 'string' && value.startsWith('=')) {\n      const formulaStr = value.slice(1);\n      formula = parseFormula(formulaStr);\n      deps = extractDependencies(formula);\n\n      // Register forward dependency edges\n      for (const dep of deps) {\n        if (!this.dependents.has(dep)) {\n          this.dependents.set(dep, new Set());\n        }\n        this.dependents.get(dep)!.add(ref);\n      }\n\n      // Store cell with deps so cycle detection can traverse it\n      this.cells.set(ref, {\n        raw: value,\n        formula,\n        value: null,\n        deps,\n      });\n\n      // Check for circular references before evaluating\n      try {\n        this.detectCycle(ref);\n      } catch (e) {\n        // Rollback: remove dependency edges and restore old state\n        for (const dep of