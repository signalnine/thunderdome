) => {\n    it('should handle greater than', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 5);\n      sheet.set('A3', '=A1>A2');\n      expect(sheet.get('A3')).toBe(true);\n    });\n\n    it('should handle less than', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 3);\n      sheet.set('A2', 5);\n      sheet.set('A3', '=A1<A2');\n      expect(sheet.get('A3')).toBe(true);\n    });\n\n    it('should handle equals', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 10);\n      sheet.set('A3', '=A1=A2');\n      expect(sheet.get('A3')).toBe(true);\n    });\n\n    it('should handle not equals', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', '=A1<>A2');\n      expect(sheet.get('A3')).toBe(true);\n    });\n\n    it('should handle greater than or equal', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 10);\n      sheet.set('A3', '=A1>=A2');\n      expect(sheet.get('A3')).toBe(true);\n    });\n\n    it('should handle less than or equal', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 10);\n      sheet.set('A3', '=A1<=A2');\n      expect(sheet.get('A3')).toBe(true);\n    });\n  });\n\n  describe('SUM function', () => {\n    it('should sum a column range', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', 30);\n      sheet.set('B1', '=SUM(A1:A3)');\n      expect(sheet.get('B1')).toBe(60);\n    });\n\n    it('should sum a row range', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', 20);\n      sheet.set('C1', 30);\n      sheet.set('D1', '=SUM(A1:C1)');\n      expect(sheet.get('D1')).toBe(60);\n    });\n\n    it('should sum a block range', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 1);\n      sheet.set('A2', 2);\n      sheet.set('B1', 3);\n      sheet.set('B2', 4);\n      sheet.set('C1', '=SUM(A1:B2)');\n      expect(sheet.get('C1')).toBe(10);\n    });\n\n    it('should ignore non-numeric values', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 'hello');\n      sheet.set('A3', 20);\n      sheet.set('B1', '=SUM(A1:A3)');\n      expect(sheet.get('B1')).toBe(30);\n    });\n\n    it('should return 0 for empty range', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('B1', '=SUM(A1:A5)');\n      expect(sheet.get('B1')).toBe(0);\n    });\n  });\n\n  describe('AVERAGE function', () => {\n    it('should compute average', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', 30);\n      sheet.set('B1', '=AVERAGE(A1:A3)');\n      expect(sheet.get('B1')).toBe(20);\n    });\n\n    it('should ignore non-numeric values in average', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 'text');\n      sheet.set('A3', 30);\n      sheet.set('B1', '=AVERAGE(A1:A3)');\n      expect(sheet.get('B1')).toBe(20); // (10+30)/2\n    });\n  });\n\n  describe('MIN function', () => {\n    it('should find minimum', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 30);\n      sheet.set('A2', 10);\n      sheet.set('A3', 20);\n      sheet.set('B1', '=MIN(A1:A3)');\n      expect(sheet.get('B1')).toBe(10);\n    });\n  });\n\n  describe('MAX function', () => {\n    it('should find maximum', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 30);\n      sheet.set('A2', 10);\n      sheet.set('A3', 20);\n      sheet.set('B1', '=MAX(A1:A3)');\n      expect(sheet.get('B1')).toBe(30);\n    });\n  });\n\n  describe('COUNT function', () => {\n    it('should count numeric values', () => {\n      const sheet =