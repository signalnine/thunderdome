n    it('should update SUM when referenced cells change', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('B1', '=SUM(A1:A2)');\n      expect(sheet.get('B1')).toBe(30);\n\n      sheet.set('A2', 30);\n      expect(sheet.get('B1')).toBe(40);\n    });\n\n    it('should handle multiple dependents', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', '=A1+1');\n      sheet.set('C1', '=A1+2');\n      sheet.set('D1', '=A1+3');\n      expect(sheet.get('B1')).toBe(11);\n      expect(sheet.get('C1')).toBe(12);\n      expect(sheet.get('D1')).toBe(13);\n\n      sheet.set('A1', 20);\n      expect(sheet.get('B1')).toBe(21);\n      expect(sheet.get('C1')).toBe(22);\n      expect(sheet.get('D1')).toBe(23);\n    });\n\n    it('should update when overwriting a formula cell with a value', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', '=A1+1');\n      expect(sheet.get('B1')).toBe(11);\n\n      sheet.set('B1', 42);\n      expect(sheet.get('B1')).toBe(42);\n    });\n\n    it('should handle diamond dependencies', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 1);\n      sheet.set('B1', '=A1+1');   // B1 = 2\n      sheet.set('C1', '=A1+2');   // C1 = 3\n      sheet.set('D1', '=B1+C1');  // D1 = 5\n      expect(sheet.get('D1')).toBe(5);\n\n      sheet.set('A1', 10);\n      expect(sheet.get('B1')).toBe(11);\n      expect(sheet.get('C1')).toBe(12);\n      expect(sheet.get('D1')).toBe(23);\n    });\n  });\n\n  describe('circular reference detection', () => {\n    it('should detect direct self-reference', () => {\n      const sheet = new Spreadsheet();\n      expect(() => sheet.set('A1', '=A1')).toThrow(/[Cc]ircular/);\n    });\n\n    it('should detect two-cell cycle', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', '=B1');\n      expect(() => sheet.set('B1', '=A1')).toThrow(/[C