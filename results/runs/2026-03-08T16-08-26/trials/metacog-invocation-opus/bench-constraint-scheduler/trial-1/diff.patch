e: string[] = [];\n  for (const [id, deg] of inDegree) {\n    if (deg === 0) queue.push(id);\n  }\n\n  const sorted: string[] = [];\n  while (queue.length > 0) {\n    const node = queue.shift()!;\n    sorted.push(node);\n    for (const neighbor of adjList.get(node) || []) {\n      const newDeg = inDegree.get(neighbor)! - 1;\n      inDegree.set(neighbor, newDeg);\n      if (newDeg === 0) queue.push(neighbor);\n    }\n  }\n\n  if (sorted.length !== events.length) {\n    throw new Error('Cycle detected in prerequisite graph');\n  }\n\n  return sorted;\n}\n\nexport function schedule(\n  events: Event[],\n  rooms: Room[],\n  options: ScheduleOptions\n): ScheduleResult {\n  const gap = options.gap ?? 15;\n\n  if (events.length === 0) {\n    return { assignments: [], unscheduled: [] };\n  }\n\n  // Detect cycles and get topological order\n  const topoOrder = detectCycleAndTopoSort(events);\n\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  // Build dependency info: for each event, which events depend on it\n  const dependents = new Map<string, Set<string>>();\n  const prerequisites = new Map<string, Set<string>>();\n  for (const e of events) {\n    dependents.set(e.id, new Set());\n    prerequisites.set(e.id, new Set());\n  }\n  for (const e of events) {\n    if (e.prerequisites) {\n      for (const prereq of e.prerequisites) {\n        if (eventMap.has(prereq)) {\n          dependents.get(prereq)!.add(e.id);\n          prerequisites.get(e.id)!.add(prereq);\n        }\n      }\n    }\n  }\n\n  // Count transitive dependents to prioritize events that unlock more others\n  const transitiveDependentCount = new Map<string, number>();\n  function countTransitiveDependents(id: string, visited: Set<string>): number {\n    if (transitiveDependentCount.has(id)) return transitiveDependentCount.get(id)!;\n    if (visited.has(id)) return 0;\n    visited.add(id);\n    let count = 0;\n    for (const dep of dependents.get(id) || []) {\n      count += 1 + countTransitiveDependents(dep, visited);\n    }\n    transitiveDependentCount.set(id, count);\n    return count;\n  }\n  for (const e of events) {\n    if (!transitiveDependentCount.has(e.id)) {\n      countTransitiveDependents(e.id, new Set());\n    }\n  }\n\n  // Sort rooms by capacity (ascending) for best-fit\n  const sortedRooms = [...rooms].sort((a, b) => a.capacity - b.capacity);\n\n  // Get eligible rooms for an event (capacity check)\n  function getEligibleRooms(event: Event): Room[] {\n    const attendees = event.attendees ?? 1;\n    return sortedRooms.filter(r => r.capacity >= attendees);\n  }\n\n  // State: for each room, list of scheduled intervals sorted by start time\n  type RoomSlot = { startTime: number; endTime: number };\n  const roomSchedules = new Map<string, RoomSlot[]>();\n  for (const r of rooms) {\n    roomSchedules.set(r.id, []);\n  }\n\n  // Find earliest available start time in a room for a given duration\n  function findEarliestSlot(\n    roomId: string,\n    duration: number,\n    earliestStart: number\n  ): number | null {\n    const slots = roomSchedules.get(roomId)!;\n    const effectiveStart = Math.max(options.startTime, earliestStart);\n\n    if (effectiveStart + duration > options.endTime) return null;\n\n    if (slots.length === 0) {\n      return effectiveStart;\n    }\n\n    // Try before the first slot\n    let candidate = effectiveStart;\n    for (const slot of slots) {\n      // candidate must end + gap <= slot.startTime\n      if (candidate + duration + gap <= slot.startTime) {\n        // Found a gap\n        if (candidate + duration <= options.endTime) {\n          return candidate;\n        }\n      }\n      // Move candidate past this slot\n      candidate = Math.max(candidate, slot.endTime + gap);\n    }\n\n    // Try after all slots\n    if (candidate + duration <= options.endTime) {\n      return candidate;\n    }\n\n    return null;\n  }\n\n  // Place an event in a room at a specific time\n  function placeEvent(roomId: string, startTime: number, endTime: number): void {\n    const slots = roomSchedules.get(roomId)!;\n    const newSlot: RoomSlot = { startTime, endTime };\n    // Insert in sorted order\n    let i = 0;\n    while (i < slots.length && slots[i].startTime < startTime) i++;\n    slots.splice(i, 0, newSlot);\n  }\n\n  // Remove an event from a room\n  function removeEvent(roomId: string, startTime: number, endTime: number): void {\n    const slots = roomSchedules.get(roomId)!;\n    const idx = slots.findIndex(s => s.startTime === startTime && s.endTime === endTime);\n    if (idx >= 0) slots.splice(idx, 1);\n  }\n\n  // Track assignments\n  const assignmentMap = new Map<string, Assignment>();\n\n  // Get the earliest start time for an event considering prerequisites\n  function getEarliestStartForEvent(eventId: string): number {\n    let earliest = options.startTime;\n    const prereqs = prerequisites.get(eventId);\n    if (prereqs) {\n      for (const prereqId of prereqs) {\n        const prereqAssignment = assignmentMap.get(prereqId);\n        if (prereqAssignment) {\n          earliest = Math.max(earliest, prereqAssignment.endTime + gap);\n        } else {\n          // Prerequisite not scheduled — this event can't be scheduled\n          return -1;\n        }\n      }\n    }\n    return earliest;\n  }\n\n  // Try to schedule an event, return true if successful\n  function tryScheduleEvent(eventId: string): boolean {\n    const event = eventMap.get(eventId)!;\n    const earliestStart = getEarliestStartForEvent(eventId);\n    if (earliestStart < 0) return false;\n\n    if (earliestStart + event.duration > options.endTime) return false;\n\n    const eligibleRooms = getEligibleRooms(event);\n    if (eligibleRooms.length === 0) return false;\n\n    // Order rooms: preferred room first, then by capacity (best fit)\n    const orderedRooms = [...eligibleRooms];\n    if (event.preferredRoom) {\n      const prefIdx = orderedRooms.findIndex(r => r.id === event.preferredRoom);\n      if (prefIdx > 0) {\n        const [pref] = orderedRooms.splice(prefIdx, 1);\n        orderedRooms.unshift(pref);\n      }\n    }\n\n    let bestRoom: string | null = null;\n    let bestStart: number | null = null;\n\n    for (const room of orderedRooms) {\n      const start = findEarliestSlot(room.id, event.duration, earliestStart);\n      if (start !== null) {\n        if (bestStart === null || start < bestStart) {\n          bestRoom = room.id;\n          bestStart = start;\n          // If it's the preferred room and can start earliest, take it immediately\n          if (room.id === event.preferredRoom) break;\n        }\n      }\n    }\n\n    if (bestRoom !== null && bestStart !== null) {\n      const endTime = bestStart + event.duration;\n      placeEvent(bestRoom, bestStart, endTime);\n      assignmentMap.set(eventId, {\n        eventId,\n        roomId: bestRoom,\n        startTime: bestStart,\n        endTime,\n      });\n      return true;\n    }\n\n    return false;\n  }\n\n  // Process events in topological order, but within each \"level\" prioritize by:\n  // 1. More transitive dependents first (they unlock more scheduling)\n  // 2. Larger duration first (harder to place)\n  // 3. More attendees first (fewer rooms available)\n\n  // Build levels from topological sort\n  const topoIndex = new Map<string, number>();\n  for (let i = 0; i < topoOrder.length; i++) {\n    topoIndex.set(topoOrder[i], i);\n  }\n\n  // Compute topological \"depth\" (longest path from a root)\n  const depth = new Map<string, number>();\n  function getDepth(id: string): number {\n    if (depth.has(id)) return depth.get(id)!;\n    const prereqs = prerequisites.get(id);\n    if (!prereqs || prereqs.size === 0) {\n      depth.set(id, 0);\n      return 0;\n    }\n    let maxDepth = 0;\n    for (const p of prereqs) {\n      if (eventMap.has(p)) {\n        maxDepth = Math.max(maxDepth, getDepth(p) + 1);\n      }\n    }\n    depth.set(id, maxDepth);\n    return maxDepth;\n  }\n  for (const e of events) {\n    getDepth(e.id);\n  }\n\n  // Sort events: by depth first (to respect dependencies), then by heuristic priority\n  const schedulingOrder = [...topoOrder].sort((a, b) => {\n    const depthA = depth.get(a) || 0;\n    const depthB = depth.get(b) || 0;\n    if (depthA !== depthB) return depthA - depthB;\n\n    // More dependents first\n    const depsA = transitiveDependentCount.get(a) || 0;\n    const depsB = transitiveDependentCount.get(b) || 0;\n    if (depsA !== depsB) return depsB - depsA;\n\n    // Larger duration first (harder to fit)\n    const durA = eventMap.get(a)!.duration;\n    const durB = eventMap.get(b)!.duration;\n    if (durA !== durB) return durB - durA;\n\n    // More attendees first\n    const attA = eventMap.get(a)!.attendees ?? 1;\n    const attB = eventMap.get(b)!.attendees ?? 1;\n    return attB - attA;\n  });\n\n  // First pass: greedy scheduling\n  const unscheduled: string[] = [];\n  for (const eventId of schedulingOrder) {\n    if (!tryScheduleEvent(eventId)) {\n      unscheduled.push(eventId);\n    }\n  }\n\n  // Second pass: retry unscheduled events (dependencies may have been scheduled\n  // in a different order, opening up new slots)\n  if (unscheduled.length > 0) {\n    const stillUnscheduled: string[] = [];\n    for (const eventId of unscheduled) {\n      if (!tryScheduleEvent(eventId)) {\n        stillUnscheduled.push(eventId);\n      }\n    }\n    unscheduled.length = 0;\n    unscheduled.push(...stillUnscheduled);\n  }\n\n  // Third pass: For events that are unscheduled because their prerequisites\n  // were unscheduled, try to see if removing a less important event helps.\n  // This is a simple improvement heuristic.\n  if (unscheduled.length > 0) {\n    let improved = true;\n    while (improved) {\n      improved = false;\n      for (let i = unscheduled.length - 1; i >= 0; i--) {\n        const eventId = unscheduled[i];\n        // Check if all prerequisites are scheduled\n 