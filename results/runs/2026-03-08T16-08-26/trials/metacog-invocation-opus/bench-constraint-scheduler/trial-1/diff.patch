+export interface Event {
+  id: string;
+  name: string;
+  duration: number;
+  attendees?: number;
+  prerequisites?: string[];
+  preferredRoom?: string;
+}
+
+export interface Room {
+  id: string;
+  name: string;
+  capacity: number;
+}
+
+export interface ScheduleOptions {
+  startTime: number;
+  endTime: number;
+  gap?: number;
+}
+
+export interface Assignment {
+  eventId: string;
+  roomId: string;
+  startTime: number;
+  endTime: number;
+}
+
+export interface ScheduleResult {
+  assignments: Assignment[];
+  unscheduled: string[];
+}
+
+function detectCycleAndTopoSort(events: Event[]): string[] {
+  const eventMap = new Map<string, Event>();
+  for (const e of events) {
+    eventMap.set(e.id, e);
+  }
+
+  const adjList = new Map<string, string[]>();
+  const inDegree = new Map<string, number>();
+
+  for (const e of events) {
+    if (!adjList.has(e.id)) adjList.set(e.id, []);
+    if (!inDegree.has(e.id)) inDegree.set(e.id, 0);
+
+    if (e.prerequisites) {
+      for (const prereq of e.prerequisites) {
+        if (prereq === e.id) {
+          throw new Error(`Cycle detected: event "${e.id}" has a self-referencing prerequisite`);
+        }
+        if (!adjList.has(prereq)) adjList.set(prereq, []);
+        adjList.get(prereq)!.push(e.id);
+        inDegree.set(e.id, (inDegree.get(e.id) || 0) + 1);
+      }
+    }
+  }
+
+  const queue: string[] = [];
+  for (const [id, deg] of inDegree) {
+    if (deg === 0) queue.push(id);
+  }
+
+  const sorted: string[] = [];
+  while (queue.length > 0) {
+    const node = queue.shift()!;
+    sorted.push(node);
+    for (const neighbor of adjList.get(node) || []) {
+      const newDeg = inDegree.get(neighbor)! - 1;
+      inDegree.set(neighbor, newDeg);
+      if (newDeg === 0) queue.push(neighbor);
+    }
+  }
+
+  if (sorted.length !== events.length) {
+    throw new Error('Cycle detected in prerequisite graph');
+  }
+
+  return sorted;
+}
+
+interface SchedulerState {
+  roomSchedules: Map<string, { startTime: number; endTime: number }[]>;
+  assignmentMap: Map<string, Assignment>;
+}
+
+function createState(rooms: Room[]): SchedulerState {
+  const roomSchedules = new Map<string, { startTime: number; endTime: number }[]>();
+  for (const r of rooms) {
+    roomSchedules.set(r.id, []);
+  }
+  return { roomSchedules, assignmentMap: new Map() };
+}
+
+function cloneState(state: SchedulerState): SchedulerState {
+  const roomSchedules = new Map<string, { startTime: number; endTime: number }[]>();
+  for (const [k, v] of state.roomSchedules) {
+    roomSchedules.set(k, v.map(s => ({ ...s })));
+  }
+  const assignmentMap = new Map<string, Assignment>();
+  for (const [k, v] of state.assignmentMap) {
+    assignmentMap.set(k, { ...v });
+  }
+  return { roomSchedules, assignmentMap };
+}
+
+function findEarliestSlot(
+  state: SchedulerState,
+  roomId: string,
+  duration: number,
+  earliestStart: number,
+  endTime: number,
+  gap: number
+): number | null {
+  const slots = state.roomSchedules.get(roomId)!;
+  const effectiveStart = earliestStart;
+
+  if (effectiveStart + duration > endTime) return null;
+
+  if (slots.length === 0) {
+    return effectiveStart;
+  }
+
+  let candidate = effectiveStart;
+  for (const slot of slots) {
+    if (candidate + duration + gap <= slot.startTime) {
+      if (candidate + duration <= endTime) {
+        return candidate;
+      }
+    }
+    candidate = Math.max(candidate, slot.endTime + gap);
+  }
+
+  if (candidate + duration <= endTime) {
+    return candidate;
+  }
+
+  return null;
+}
+
+function placeEvent(state: SchedulerState, roomId: string, startTime: number, endTime: number): void {
+  const slots = state.roomSchedules.get(roomId)!;
+  let i = 0;
+  while (i < slots.length && slots[i].startTime < startTime) i++;
+  slots.splice(i, 0, { startTime, endTime });
+}
+
+function removeEvent(state: SchedulerState, roomId: string, startTime: number, endTime: number): void {
+  const slots = state.roomSchedules.get(roomId)!;
+  const idx = slots.findIndex(s => s.startTime === startTime && s.endTime === endTime);
+  if (idx >= 0) slots.splice(idx, 1);
+}
+
+function getEarliestStartForEvent(
+  eventId: string,
+  state: SchedulerState,
+  prereqMap: Map<string, Set<string>>,
+  startTime: number,
+  gap: number
+): number {
+  let earliest = startTime;
+  const prereqs = prereqMap.get(eventId);
+  if (prereqs) {
+    for (const prereqId of prereqs) {
+      const prereqAssignment = state.assignmentMap.get(prereqId);
+      if (prereqAssignment) {
+        earliest = Math.max(earliest, prereqAssignment.endTime + gap);
+      } else {
+        return -1;
+      }
+    }
+  }
+  return earliest;
+}
+
+function tryScheduleEvent(
+  eventId: string,
+  state: SchedulerState,
+  eventMap: Map<string, Event>,
+  prereqMap: Map<string, Set<string>>,
+  sortedRooms: Room[],
+  options: ScheduleOptions,
+  gap: number
+): boolean {
+  const event = eventMap.get(eventId)!;
+  const earliestStart = getEarliestStartForEvent(eventId, state, prereqMap, options.startTime, gap);
+  if (earliestStart < 0) return false;
+  if (earliestStart + event.duration > options.endTime) return false;
+
+  const attendees = event.attendees ?? 1;
+  const eligibleRooms = sortedRooms.filter(r => r.capacity >= attendees);
+  if (eligibleRooms.length === 0) return false;
+
+  const orderedRooms = [...eligibleRooms];
+  if (event.preferredRoom) {
+    const prefIdx = orderedRooms.findIndex(r => r.id === event.preferredRoom);
+    if (prefIdx > 0) {
+      const [pref] = orderedRooms.splice(prefIdx, 1);
+      orderedRooms.unshift(pref);
+    }
+  }
+
+  let bestRoom: string | null = null;
+  let bestStart: number | null = null;
+
+  for (const room of orderedRooms) {
+    const start = findEarliestSlot(state, room.id, event.duration, earliestStart, options.endTime, gap);
+    if (start !== null) {
+      if (bestStart === null || start < bestStart) {
+        bestRoom = room.id;
+        bestStart = start;
+        if (room.id === event.preferredRoom) break;
+      }
+    }
+  }
+
+  if (bestRoom !== null && bestStart !== null) {
+    const endTime = bestStart + event.duration;
+    placeEvent(state, bestRoom, bestStart, endTime);
+    state.assignmentMap.set(eventId, {
+      eventId,
+      roomId: bestRoom,
+      startTime: bestStart,
+      endTime,
+    });
+    return true;
+  }
+
+  return false;
+}
+
+function runGreedy(
+  order: string[],
+  eventMap: Map<string, Event>,
+  prereqMap: Map<string, Set<string>>,
+  sortedRooms: Room[],
+  rooms: Room[],
+  options: ScheduleOptions,
+  gap: number
+): { state: SchedulerState; scheduled: string[]; unscheduled: string[] } {
+  const state = createState(rooms);
+  const scheduled: string[] = [];
+  const unscheduled: string[] = [];
+
+  for (const eventId of order) {
+    if (tryScheduleEvent(eventId, state, eventMap, prereqMap, sortedRooms, options, gap)) {
+      scheduled.push(eventId);
+    } else {
+      unscheduled.push(eventId);
+    }
+  }
+
+  // Retry unscheduled (some may now fit due to ordering)
+  if (unscheduled.length > 0) {
+    let improved = true;
+    while (improved) {
+      improved = false;
+      for (let i = unscheduled.length - 1; i >= 0; i--) {
+        const eventId = unscheduled[i];
+        if (tryScheduleEvent(eventId, state, eventMap, prereqMap, sortedRooms, options, gap)) {
+          unscheduled.splice(i, 1);
+          scheduled.push(eventId);
+          improved = true;
+        }
+      }
+    }
+  }
+
+  return { state, scheduled, unscheduled };
+}
+
+export function schedule(
+  events: Event[],
+  rooms: Room[],
+  options: ScheduleOptions
+): ScheduleResult {
+  const gap = options.gap ?? 15;
+
+  if (events.length === 0) {
+    return { assignments: [], unscheduled: [] };
+  }
+
+  // Detect cycles and get topological order
+  detectCycleAndTopoSort(events);
+
+  const eventMap = new Map<string, Event>();
+  for (const e of events) {
+    eventMap.set(e.id, e);
+  }
+
+  // Build prerequisite info
+  const dependents = new Map<string, Set<string>>();
+  const prereqMap = new Map<string, Set<string>>();
+  for (const e of events) {
+    dependents.set(e.id, new Set());
+    prereqMap.set(e.id, new Set());
+  }
+  for (const e of events) {
+    if (e.prerequisites) {
+      for (const prereq of e.prerequisites) {
+        if (eventMap.has(prereq)) {
+          dependents.get(prereq)!.add(e.id);
+          prereqMap.get(e.id)!.add(prereq);
+        }
+      }
+    }
+  }
+
+  // Compute transitive dependents count
+  const transDepCount = new Map<string, number>();
+  function countTransDeps(id: string, visited: Set<string>): number {
+    if (transDepCount.has(id)) return transDepCount.get(id)!;
+    if (visited.has(id)) return 0;
+    visited.add(id);
+    let count = 0;
+    for (const dep of dependents.get(id) || []) {
+      count += 1 + countTransDeps(dep, visited);
+    }
+    transDepCount.set(id, count);
+    return count;
+  }
+  for (const e of events) {
+    if (!transDepCount.has(e.id)) countTransDeps(e.id, new Set());
+  }
+
+  // Compute topological depth
+  const depthMap = new Map<string, number>();
+  function getDepth(id: string): number {
+    if (depthMap.has(id)) return depthMap.get(id)!;
+    const prereqs = prereqMap.get(id);
+    if (!prereqs || prereqs.size === 0) {
+      depthMap.set(id, 0);
+      return 0;
+    }
+    let maxDepth = 0;
+    for (const p of prereqs) {
+      if (eventMap.has(p)) {
+        maxDepth = Math.max(maxDepth, getDepth(p) + 1);
+      }
+    }
+    depthMap.set(id, maxDepth);
+    return maxDepth;
+  }
+  for (const e of events) getDepth(e.id);
+
+  // Sort rooms by capacity (ascending) for best-fit
+  const sortedRooms = [...rooms].sort((a, b) => a.capacity - b.capacity);
+
+  // Generate multiple ordering strategies and pick the best result
+  const eventIds = events.map(e => e.id);
+
+  // Helper: sort while respecting topological order (depth first, then by comparator)
+  function topoAwareSort(compareFn: (a: string, b: string) => number): string[] {
+    return [...eventIds].sort((a, b) => {
+      const da = depthMap.get(a) || 0;
+      const db = depthMap.get(b) || 0;
+      if (da !== db) return da - db;
+      return compareFn(a, b);
+    });
+  }
+
+  // Strategy 1: Shorter duration first (pack more events)
+  const shortFirst = topoAwareSort((a, b) => {
+    const durA = eventMap.get(a)!.duration;
+    const durB = eventMap.get(b)!.duration;
+    if (durA !== durB) return durA - durB;
+    const depsA = transDepCount.get(a) || 0;
+    const depsB = transDepCount.get(b) || 0;
+    return depsB - depsA;
+  });
+
+  // Strategy 2: More dependents first (unlock more events)
+  const depsFirst = topoAwareSort((a, b) => {
+    const depsA = transDepCount.get(a) || 0;
+    const depsB = transDepCount.get(b) || 0;
+    if (depsA !== depsB) return depsB - depsA;
+    const durA = eventMap.get(a)!.duration;
+    const durB = eventMap.get(b)!.duration;
+    return durA - durB;
+  });
+
+  // Strategy 3: Longer duration first (harder to place)
+  const longFirst = topoAwareSort((a, b) => {
+    const durA = eventMap.get(a)!.duration;
+    const durB = eventMap.get(b)!.duration;
+    if (durA !== durB) return durB - durA;
+    const depsA = transDepCount.get(a) || 0;
+    const depsB = transDepCount.get(b) || 0;
+    return depsB - depsA;
+  });
+
+  // Strategy 4: More constrained first (fewer eligible rooms)
+  const constrainedFirst = topoAwareSort((a, b) => {
+    const attA = eventMap.get(a)!.attendees ?? 1;
+    const attB = eventMap.get(b)!.attendees ?? 1;
+    const roomsA = sortedRooms.filter(r => r.capacity >= attA).length;
+    const roomsB = sortedRooms.filter(r => r.capacity >= attB).length;
+    if (roomsA !== roomsB) return roomsA - roomsB;
+    const durA = eventMap.get(a)!.duration;
+    const durB = eventMap.get(b)!.duration;
+    return durB - durA;
+  });
+
+  // Strategy 5: Short + constrained hybrid
+  const hybridOrder = topoAwareSort((a, b) => {
+    const attA = eventMap.get(a)!.attendees ?? 1;
+    const attB = eventMap.get(b)!.attendees ?? 1;
+    const roomsA = sortedRooms.filter(r => r.capacity >= attA).length;
+    const roomsB = sortedRooms.filter(r => r.capacity >= attB).length;
+    const durA = eventMap.get(a)!.duration;
+    const durB = eventMap.get(b)!.duration;
+    // Score: fewer rooms + shorter duration = higher priority
+    const scoreA = roomsA * 1000 + durA;
+    const scoreB = roomsB * 1000 + durB;
+    return scoreA - scoreB;
+  });
+
+  const strategies = [shortFirst, depsFirst, longFirst, constrainedFirst, hybridOrder];
+
+  let bestResult: { state: SchedulerState; scheduled: string[]; unscheduled: string[] } | null = null;
+
+  for (const order of strategies) {
+    const result = runGreedy(order, eventMap, prereqMap, sortedRooms, rooms, options, gap);
+    if (bestResult === null || result.scheduled.length > bestResult.scheduled.length) {
+      bestResult = result;
+    }
+    if (result.unscheduled.length === 0) break;
+  }
+
+  // Improvement: try removing each scheduled event and see if we can fit more of the unscheduled
+  if (bestResult!.unscheduled.length > 0) {
+    let improved = true;
+    while (improved) {
+      improved = false;
+      const currentUnscheduled = [...bestResult!.unscheduled];
+      const currentScheduled = [...bestResult!.scheduled];
+
+      for (const scheduledId of currentScheduled) {
+        // Don't remove events that are prerequisites of other scheduled events
+        const deps = dependents.get(scheduledId);
+        let hasDep = false;
+        if (deps) {
+          for (const d of deps) {
+            if (bestResult!.state.assignmentMap.has(d)) {
+              hasDep = true;
+              break;
+            }
+          }
+        }
+        if (hasDep) continue;
+
+        // Try removing this event and scheduling unscheduled events instead
+        const testState = cloneState(bestResult!.state);
+        const removedAssignment = testState.assignmentMap.get(scheduledId)!;
+        removeEvent(testState, removedAssignment.roomId, removedAssignment.startTime, removedAssignment.endTime);
+        testState.assignmentMap.delete(scheduledId);
+
+        let newlyScheduled = 0;
+        const tempScheduled: string[] = [];
+        for (const unsId of currentUnscheduled) {
+          if (tryScheduleEvent(unsId, testState, eventMap, prereqMap, sortedRooms, options, gap)) {
+            newlyScheduled++;
+            tempScheduled.push(unsId);
+          }
+        }
+
+        if (newlyScheduled >= 2) {
+          // Net gain: we removed 1 and added newlyScheduled (>= 2)
+          bestResult = {
+            state: testState,
+            scheduled: currentScheduled.filter(id => id !== scheduledId).concat(tempScheduled),
+            unscheduled: currentUnscheduled.filter(id => !tempScheduled.includes(id)).concat(scheduledId),
+          };
+          // Re-filter: the removed event might now fit
+          const finalUnsched: string[] = [];
+          for (const u of bestResult.unscheduled) {
+            if (tryScheduleEvent(u, bestResult.state, eventMap, prereqMap, sortedRooms, options, gap)) {
+              bestResult.scheduled.push(u);
+            } else {
+              finalUnsched.push(u);
+            }
+          }
+          bestResult.unscheduled = finalUnsched;
+          improved = true;
+          break;
+        } else {
+          // Undo: restore the scheduled event assignments in testState
+          // (we don't use testState, so no action needed)
+        }
+      }
+    }
+  }
+
+  const assignments = Array.from(bestResult!.state.assignmentMap.values());
+  assignments.sort((a, b) => a.startTime - b.startTime || a.roomId.localeCompare(b.roomId));
+
+  return { assignments, unscheduled: bestResult!.unscheduled };
+}
