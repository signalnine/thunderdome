xDepth;\n  }\n  for (const e of events) {\n    getDepth(e.id);\n  }\n\n  // Sort events: by depth first (to respect dependencies), then by heuristic priority\n  const schedulingOrder = [...topoOrder].sort((a, b) => {\n    const depthA = depth.get(a) || 0;\n    const depthB = depth.get(b) || 0;\n    if (depthA !== depthB) return depthA - depthB;\n\n    // More dependents first\n    const depsA = transitiveDependentCount.get(a) || 0;\n    const depsB = transitiveDependentCount.get(b) || 0;\n    if (depsA !== depsB) return depsB - depsA;\n\n    // Larger duration first (harder to fit)\n    const durA = eventMap.get(a)!.duration;\n    const durB = eventMap.get(b)!.duration;\n    if (durA !== durB) return durB - durA;\n\n    // More attendees first\n    const attA = eventMap.get(a)!.attendees ?? 1;\n    const attB = eventMap.get(b)!.attendees ?? 1;\n    return attB - attA;\n  });\n\n  // First pass: greedy scheduling\n  const unscheduled: string[] = [];\n  for (const eventId of schedulingOrder) {\n    if (!tryScheduleEvent(eventId)) {\n      unscheduled.push(eventId);\n    }\n  }\n\n  // Second pass: retry unscheduled events (dependencies may have been scheduled\n  // in a different order, opening up new slots)\n  if (unscheduled.length > 0) {\n    const stillUnscheduled: string[] = [];\n    for (const eventId of unscheduled) {\n      if (!tryScheduleEvent(eventId)) {\n        stillUnscheduled.push(eventId);\n      }\n    }\n    unscheduled.length = 0;\n    unscheduled.push(...stillUnscheduled);\n  }\n\n  // Third pass: For events that are unscheduled because their prerequisites\n  // were unscheduled, try to see if removing a less important event helps.\n  // This is a simple improvement heuristic.\n  if (unscheduled.length > 0) {\n    let improved = true;\n    while (improved) {\n      improved = false;\n      for (let i = unscheduled.length - 1; i >= 0; i--) {\n        const eventId = unscheduled[i];\n        // Check if all prerequisites are scheduled\n        const 