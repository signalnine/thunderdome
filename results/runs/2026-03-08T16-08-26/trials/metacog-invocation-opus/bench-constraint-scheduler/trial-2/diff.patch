n   558→        } else if (\n   559→          p.roomId === best.roomId\n   560→            ? p.startTime < best.startTime\n   561→            : !event.preferredRoom || best.roomId !== event.preferredRoom\n   562→              ? p.startTime < best.startTime\n   563→              : false\n   564→        ) {\n   565→          best = p;\n   566→        }\n   567→      }\n   568→\n   569→      assignments.push({\n   570→        eventId: event.id,\n   571→        roomId: best.roomId,\n   572→        startTime: best.startTime,\n   573→        endTime: best.startTime + event.duration,\n   574→      });\n   575→      scheduled.add(event.id);\n   576→    } else {\n   577→      unscheduled.push(event.id);\n   578→    }\n   579→  }\n   580→\n   581→  return { assignments, unscheduled };\n   582→}\n   583→\n   584→/**\n   585→ * Backtracking scheduler for small instances.\n   586→ * Tries to maximize the number of scheduled events.\n   587→ */\n   588→function backtrackSchedule(\n   589→  events: Event[],\n   590→  rooms: Room[],\n   591→  options: ScheduleOptions,\n   592→  gap: number,\n   593→  eventMap: Map<string, Event>,\n   594→  topoLevels: Map<string, number>,\n   595→  _adj: Map<string, string[]>,\n   596→): ScheduleResult {\n   597→  // Sort by topo level first\n   598→  const sorted = [...events].sort((a, b) => {\n   599→    const aLevel = topoLevels.get(a.id) ?? 0;\n   600→    const bLevel = topoLevels.get(b.id) ?? 0;\n   601→    return aLevel - bLevel;\n   602→  });\n   603→\n   604→  let bestAssignments: Assignment[] = [];\n   605→  let bestCount = 0;\n   606→  const totalEvents = sorted.length;\n   607→  let iterations = 0;\n   608→  const maxIterations = 50000;\n   609→\n   610→  function bt(\n   611→    idx: number,\n   612→    assignments: Assignment[],\n   613→    scheduled: Set<string>,\n   614→  ): void {\n   615→    iterations++;\n   616→    if (iterations > maxIterations) return;\n   617→\n   618→    if (assignments.length > bestCount) {\n   619→      bes