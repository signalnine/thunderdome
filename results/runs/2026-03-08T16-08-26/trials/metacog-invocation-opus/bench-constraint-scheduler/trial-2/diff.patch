number>();\n   389→  const inDeg = new Map<string, number>();\n   390→  for (const e of sortedEvents) {\n   391→    inDeg.set(e.id, 0);\n   392→  }\n   393→  for (const e of sortedEvents) {\n   394→    if (e.prerequisites) {\n   395→      for (const prereq of e.prerequisites) {\n   396→        if (inDeg.has(prereq)) {\n   397→          inDeg.set(e.id, (inDeg.get(e.id) ?? 0) + 1);\n   398→        }\n   399→      }\n   400→    }\n   401→  }\n   402→\n   403→  // BFS to compute levels\n   404→  const queue: string[] = [];\n   405→  for (const [id, deg] of inDeg) {\n   406→    if (deg === 0) {\n   407→      queue.push(id);\n   408→      topoLevels.set(id, 0);\n   409→    }\n   410→  }\n   411→  const inDegCopy = new Map(inDeg);\n   412→  while (queue.length > 0) {\n   413→    const node = queue.shift()!;\n   414→    const level = topoLevels.get(node) ?? 0;\n   415→    for (const dep of adj.get(node) ?? []) {\n   416→      const newDeg = inDegCopy.get(dep)! - 1;\n   417→      inDegCopy.set(dep, newDeg);\n   418→      topoLevels.set(dep, Math.max(topoLevels.get(dep) ?? 0, level + 1));\n   419→      if (newDeg === 0) queue.push(dep);\n   420→    }\n   421→  }\n   422→\n   423→  // Strategy: sort by topo level, then by transitive dependents (desc), then constraints\n   424→  const strategy2 = [...sortedEvents].sort((a, b) => {\n   425→    const aLevel = topoLevels.get(a.id) ?? 0;\n   426→    const bLevel = topoLevels.get(b.id) ?? 0;\n   427→    if (aLevel !== bLevel) return aLevel - bLevel;\n   428→\n   429→    const aDeps = transitiveDeps.get(a.id) ?? 0;\n   430→    const bDeps = transitiveDeps.get(b.id) ?? 0;\n   431→    if (aDeps !== bDeps) return bDeps - aDeps;\n   432→\n   433→    const aRooms = rooms.filter(\n   434→      (r) => r.capacity >= (a.attendees ?? 1),\n   435→    ).length;\n   436→    const bRooms = rooms.filter(\n   437→      (r) => r.capacity >= (b.attendees ?? 1),\n   438→    ).length;\n   439→    if (aRooms !== bRooms) return aRooms - bRooms;\n   440→\n   441→    return b.duration - a.duration;\n   442→  });\n   443→\n   444→  const result2 = greedySchedule(strategy2, rooms, options, gap, eventMap);\n   445→  if (result2.unscheduled.length < bestResult.unscheduled.length) {\n   446→    bestResult = result2;\n   447→  }\n   448→\n   449→  if (bestResult.unscheduled.length === 0) {\n   450→    return bestResult;\n   451→  }\n   452→\n   453→  // Strategy 3: largest attendees first (within topo levels)\n   454→  const strategy3 = [...sortedEvents].sort((a, b) => {\n   455→    const aLevel = topoLevels.get(a.id) ?? 0;\n   456→    const bLevel = topoLevels.get(b.id) ?? 0;\n   457→    if (aLevel !== bLevel) return aLevel - bLevel;\n   458→\n   459→    return (b.attendees ?? 1) - (a.attendees ?? 1);\n   460→  });\n   461→\n   462→  const result3 = greedySchedule(strategy3, rooms, options, gap, eventMap);\n   463→  if (result3.unscheduled.length < bestResult.unscheduled.length) {\n   464→    bestResult = result3;\n   465→  }\n   466→\n   467→  if (bestResult.unscheduled.length === 0) {\n   468→    return bestResult;\n   469→  }\n   470→\n   471→  // Strategy 4: shortest duration first (within topo levels) — pack more events\n   472→  const strategy4 = [...sortedEvents].sort((a, b) => {\n   473→    const aLevel = topoLevels.get(a.id) ?? 0;\n   474→    const bLevel = topoLevels.get(b.id) ?? 0;\n   475→    if (aLevel !== bLevel) return aLevel - bLevel;\n   476→\n   477→    return a.duration - b.duration;\n   478→  });\n   479→\n   480→  const result4 = greedySchedule(strategy4, rooms, options, gap, eventMap);\n   481→  if (result4.unscheduled.length < bestResult.unscheduled.length) {\n   482→    bestResult = result4;\n   483→  }\n   484→\n   485→  if (bestResult.unscheduled.length === 0) {\n   486→    return bestResult;\n   487→  }\n   488→\n   489→  // Strategy 5: try backtracking for small instances\n   490→  if (sortedEvents.length <= 20) {\n   491→    const btResult = backtrackSchedule(\n   492→      sortedEvents,\n   49