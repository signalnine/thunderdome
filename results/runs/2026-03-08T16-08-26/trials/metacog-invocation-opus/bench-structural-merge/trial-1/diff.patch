+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WQQNi4YnTCkpdHfkUE2RWo","type":"tool_result","content":"     1→// ─── Types ───────────────────────────────────────────────────────────\n     2→\n     3→export interface Version {\n     4→  id: string;\n     5→  timestamp: number;\n     6→  content: object;\n     7→}\n     8→\n     9→export interface Conflict {\n    10→  documentId: string;\n    11→  path: string;\n    12→  base: unknown;\n    13→  ours: unknown;\n    14→  theirs: unknown;\n    15→}\n    16→\n    17→export interface MergeResult {\n    18→  merged: Record<string, object>;\n    19→  conflicts: Conflict[];\n    20→  applied: boolean;\n    21→}\n    22→\n    23→// ─── Internal types ──────────────────────────────────────────────────\n    24→\n    25→interface DocumentRecord {\n    26→  content: object;\n    27→  versions: Version[];\n    28→  deleted: boolean;\n    29→}\n    30→\n    31→interface BranchData {\n    32→  documents: Map<string, DocumentRecord>;\n    33→  /** Snapshot of all documents at the time this branch was created (the merge base). */\n    34→  ancestor: Map<string, object | null>;\n    35→}\n    36→\n    37→// ─── Helpers ─────────────────────────────────────────────────────────\n    38→\n    39→function deepClone<T>(value: T): T {\n    40→  if (value === null || value === undefined) return value;\n    41→  return JSON.parse(JSON.stringify(value));\n    42→}\n    43→\n    44→let versionCounter = 0;\n    45→function makeVersionId(): string {\n    46→  return `v_${++versionCounter}_${Date.now()}`;\n    47→}\n    48→\n    49→/**\n    50→ * Recursively collect all leaf-level field paths from an object.\n    51→ * Returns dot-separated paths.\n    52→ */\n    53→function collectPaths(obj: unknown, prefix: string, paths: Set<string>): void {\n    54→  if (obj === null || obj === undefined || typeof obj !== 'object' || Array.isArray(obj)) {\n    55→    paths.add(prefix);\n    56→    return;\n    57→  }\n    58→  const keys = Object.keys(obj as Record<string, unknown>);\n    59→  if (keys.length === 0) {\n    60→    paths.add(prefix);\n    61→    return;\n    62→  }\n    63→  for (const key of keys) {\n    64→    const newPrefix = prefix ? `${prefix}.${key}` : key;\n    65→    collectPaths((obj as Record<string, unknown>)[key], newPrefix, paths);\n    66→  }\n    67→}\n    68→\n    69→/**\n    70→ * Get a value at a dot-separated path from an object.\n    71→ * Returns undefined if the path doesn't exist.\n    72→ */\n    73→function getAtPath(obj: unknown, path: string): unknown {\n    74→  const parts = path.split('.');\n    75→  let current: unknown = obj;\n    76→  for (const part of parts) {\n    77→    if (current === null || current === undefined || typeof current !== 'object' || Array.isArray(current)) {\n    78→      return undefined;\n    79→    }\n    80→    current = (current as Record<string, unknown>)[part];\n    81→  }\n    82→  return current;\n    83→}\n    84→\n    85→/**\n    86→ * Set a value at a dot-separated path on an object, creating intermediate objects as needed.\n    87→ */\n    88→function setAtPath(obj: Record<string, unknown>, path: string, value: unknown): void {\n    89→  const parts = path.split('.');\n    90→  let current: Record<string, unknown> = obj;\n    91→  for (let i = 0; i < parts.length - 1; i++) {\n    92→    const part = parts[i];\n    93→    if (!(part in current) || typeof current[part] !== 'object' || current[part] === null || Array.isArray(current[part])) {\n    94→      current[part] = {};\n    95→    }\n    96→    current = current[part] as Record<string, unknown>;\n    97→  }\n    98→  current[parts[parts.length - 1]] = value;\n    99→}\n   100→\n   101→/**\n   102→ * Delete a value at a dot-separated path on an object.\n   103→ */\n   104→function deleteAtPath(obj: Record<string, unknown>, path: string): void {\n   105→  const parts = path.split('.');\n   106→  let current: Record<string, unknown> = obj;\n   107→  for (let i = 0; i < parts.length - 1; i++) {\n   108→    const part = parts[i];\n   109→    if (!(part in current) || typeof current[part] !== 'object' || current[part] === null) {\n   110→      return;\n   111→    }\n   112→    current = current[part] as Record<string, unknown>;\n   113→  }\n   114→  delete current[parts[parts.length - 1]];\n   115→}\n   116→\n   117→function deepEqual(a: unknown, b: unknown): boolean {\n   118→  return JSON.stringify(a) === JSON.stringify(b);\n   119→}\n   120→\n   121→/**\n   122→ * Snapshot the current documents on a branch: returns a map from docId to deep-cloned content\n   123→ * (or null if the document is deleted / doesn't exist).\n   124→ */\n   125→function snapshotBranch(branch: BranchData): Map<string, object | null> {\n   126→  const snap = new Map<string, object | null>();\n   127→  for (const [id, rec] of branch.documents) {\n   128→    snap.set(id, rec.deleted ? null : deepClone(rec.content));\n   129→  }\n   130→  return snap;\n   131→}\n   132→\n   133→// ─── DocumentStore ───────────────────────────────────────────────────\n   134→\n   135→export class DocumentStore {\n   136→  private branches: Map<string, BranchData> = new Map();\n   137→  private currentBranch: string = 'main';\n   138→\n   139→  constructor() {\n   140→    this.branches.set('main', {\n   141→      documents: new Map(),\n   142→      ancestor: new Map(),\n   143→    });\n   144→  }\n   145→\n   146→  // ── helpers ──\n   147→\n   148→  private branch(): BranchData {\n   149→    return this.branches.get(this.currentBranch)!;\n   150→  }\n   151→\n   152→  private getRecord(id: string): DocumentRecord {\n   153→    const rec = this.branch().documents.get(id);\n   154→    if (!rec || rec.deleted) {\n   155→      throw new Error(`Document \"${id}\" not found`);\n   156→    }\n   157→    return rec;\n   158→  }\n   159→\n   160→  // ── CRUD ──\n   161→\n   162→  create(id: string, content: object): void {\n   163→    const branch = this.branch();\n   164→    const existing = branch.documents.get(id);\n   165→    if (existing && !existing.deleted) {\n   166→      throw new Error(`Document \"${id}\" already exists`);\n   167→    }\n   168→    const cloned = deepClone(content);\n   169→    const version: Version = {\n   170→      id: makeVersionId(),\n   171→      timestamp: Date.now(),\n   172→      content: deepClone(cloned),\n   173→    };\n   174→    branch.documents.set(id, {\n   175→      content: cloned,\n   176→      versions: existing && existing.deleted ? [...existing.versions, version] : [version],\n   177→      deleted: false,\n   178→    });\n   179→  }\n   180→\n   181→  get(id: string): object {\n   182→    return deepClone(this.getRecord(id).content);\n   183→  }\n   184→\n   185→  update(id: string, content: object): void {\n   186→    const rec = this.getRecord(id);\n   187→    const cloned = deepClone(content);\n   188→    const version: Version = {\n   189→      id: makeVersionId(),\n   190→      timestamp: Date.now(),\n   191→      content: deepClone(cloned),\n   192→    };\n   193→    rec.content = cloned;\n   194→    rec.versions.push(version);\n   195→  }\n   196→\n   197→  delete(id: string): void {\n   198→    const rec = this.getRecord(id); // throws if not found\n   199→    rec.deleted = true;\n   200→    rec.content = {};\n   201→  }\n   202→\n   203→  // ── Version History ──\n   204→\n   205→  getHistory(id: string): Version[] {\n   206→    const branch = this.branch();\n   207→    const rec = branch.documents.get(id);\n   208→    if (!rec) {\n   209→      throw new Error(`Document \"${id}\" not found`);\n   210→    }\n   211→    return rec.versions.map(v => ({\n   212→      id: v.id,\n   213→      timestamp: v.timestamp,\n   214→      content: deepClone(v.content),\n   215→    }));\n   216→  }\n   217→\n   218→  getVersion(id: string, versionId: string): object {\n   219→    const branch = this.branch();\n   220→    const rec = branch.documents.get(id);\n   221→    if (!rec) {\n   222→      throw new Error(`Document \"${id}\" not found`);\n   223→    }\n   224→    const version = rec.versions.find(v => v.id === versionId);\n   225→    if (!version) {\n   226→      throw new Error(`Version \"${versionId}\" not found for document \"${id}\"`);\n   227→    }\n   228→    return deepClone(version.content);\n   229→  }\n   230→\n   231→  // ── Branching ──\n   232→\n   233→  createBranch(name: string, fromBranch?: string): void {\n   234→    if (this.branches.has(name)) {\n   235→      throw new Error(`Branch \"${name}\" already exists`);\n   236→    }\n   237→    const sourceName = fromBranch ?? this.currentBranch;\n   238→    const source = this.branches.get(sourceName);\n   239→    if (!source) {\n   240→      throw new Error(`Branch \"${sourceName}\" not found`);\n   241→    }\n   242→\n   243→    // Deep-clone all documents from the source branch\n   244→    const newDocs = new Map<string, DocumentRecord>();\n   245→    for (const [id, rec] of source.documents) {\n   246→      newDocs.set(id, {\n   247→        content: deepClone(rec.content),\n   248→        versions: rec.versions.map(v => ({\n   249→          id: v.id,\n   250→          timestamp: v.timestamp,\n   251→          content: deepClone(v.content),\n   252→        })),\n   253→        deleted: rec.deleted,\n   254→      });\n   255→    }\n   256→\n   257→    // The ancestor snapshot is the current state of the source branch at this moment.\n   258→    // This will be used as the merge base for three-way merging.\n   259→    const ancestor = snapshotBranch(source);\n   260→\n   261→    this.branches.set(name, {\n   262→      documents: newDocs,\n   263→      ancestor,\n   264→    });\n   265→  }\n   266→\n   267→  switchBranch(name: string): void {\n   268→    if (!this.branches.has(name)) {\n   269→      throw new Error(`Branch \"${name}\" not found`);\n   270→    }\n   271→    this.currentBranch = name;\n   272→  }\n   273→\n   274→  getBranch(): string {\n   275→    return this.currentBranch;\n   276→  }\n   277→\n   278→  listBranches(): string[] {\n   279→    return Array.from(this.branches.keys());\n   280→  }\n   281→\n   282→  // ── Merging ──\n   283→\n   284→  merge(sourceBranch: string): MergeResult {\n   285→    const source = this.branches.get(sourceBranch);\n   286→    if (!source) {\n   287→      throw new Error(`Branch \"${sourceBranch}\" not found`);\n   288→    }\n   289→    const target = this.branch();\n   290→\n   291→    // The common ancestor is the snapshot taken when the source branch was created.\n   292→    // This represents the state of the parent branch at branch creation time.\n   293→    const base = source.ancestor;\n   294→\n   295→    // Collect all document IDs across base, source, and target\n   296→    const allDocIds = new Set<string>();\n   297→    for (const id of base.keys()) allDocIds.add(id);\n   298→    for (const [id, rec] of source.documents) {\n   299→      if (!rec.deleted) allDocIds.add(id);\n   300→    }\n   301→    for (const [id, rec] of target.documents) {\n   302→      if (!rec.deleted) allDocIds.add(id);\n   303→    }\n   304→\n   305→    const merged: Record<string, object> = {};\n   306→    const conflicts: Conflict[] = [];\n   307→\n   308→    for (const docId of allDocIds) {\n   309→      const baseContent = base.has(docId) ? base.get(docId) : undefined;\n   310→      const baseExists = base.has(docId) && baseContent !== null;\n   311→\n   312→      const sourceRec = source.documents.get(docId);\n   313→      const sourceExists = sourceRec != null && !sourceRec.deleted;\n   314→      const sourceContent = sourceExists ? sourceRec.content : undefined;\n   315→\n   316→      const targetRec = target.documents.get(docId);\n   317→      const targetExists = targetRec != null && !targetRec.deleted;\n   318→      const targetContent = targetExists ? targetRec.content : undefined;\n   319→\n   320→      const sourceDeleted = base.has(docId) && baseContent !== null && sourceRec != null && sourceRec.deleted;\n   321→      const targetDeleted = base.has(docId) && baseContent !== null && targetRec != null && targetRec.deleted;\n   322→\n   323→      // Determine what changed on each side\n   324→      const sourceChanged = !deepEqual(\n   325→        baseExists ? baseContent : undefined,\n   326→        sourceDeleted ? undefined : sourceContent\n   327→      );\n   328→      const targetChanged = !deepEqual(\n   329→        baseExists ? baseContent : undefined,\n   330→        targetDeleted ? undefined : targetContent\n   331→      );\n   332→\n   333→      if (!sourceChanged && !targetChanged) {\n   334→        // No changes on either side — keep target as-is\n   335→        if (targetExists) {\n   336→          merged[docId] = deepClone(targetContent!);\n   337→        }\n   338→        continue;\n   339→      }\n   340→\n   341→      if (sourceChanged && !targetChanged) {\n   342→        // Only source changed — take source's version\n   343→        if (sourceDeleted) {\n   344→          // Source deleted the document — don't include in merged\n   345→          continue;\n   346→        }\n   347→        if (sourceExists) {\n   348→          merged[docId] = deepClone(sourceContent!);\n   349→        }\n   350→        continue;\n   351→      }\n   352→\n   353→      if (!sourceChanged && targetChanged) {\n   354→        // Only target changed — keep target's version (already there)\n   355→        if (targetExists) {\n   356→          merged[docId] = deepClone(targetContent!);\n   357→        }\n   358→        continue;\n   359→      }\n   360→\n   361→      // Both sides changed — need field-level three-way merge\n   362→      // Handle document-level create/delete scenarios\n   363→      if (sourceDeleted && targetDeleted) {\n   364→        // Both deleted — agree, no conflict\n   365→        continue;\n   366→      }\n   367→\n   368→      if (sourceDeleted && !targetDeleted) {\n   369→        // Source deleted, target modified — conflict at document level\n   370→        // For \"ours\" (target), keep target version\n   371→        merged[docId] = deepClone(targetContent!);\n   372→        // We treat this as a conflict but \"ours\" wins for the merged output\n   373→        continue;\n   374→      }\n   375→\n   376→      if (!sourceDeleted && targetDeleted) {\n   377→        // Target deleted, source modified — we keep \"ours\" (deleted)\n   378→        // Don't include in merged\n   379→        continue;\n   380→      }\n   381→\n   382→      // Both sides modified the document — do field-level merge\n   383→      const baseObj = baseExists ? baseContent : {};\n   384→      const sourceObj = sourceContent!;\n   385→      const targetObj = targetContent!;\n   386→\n   387→      const result = this.threeWayMergeObject(\n   388→        docId,\n   389→        baseObj as Record<string, unknown>,\n   390→        targetObj as Record<string, unknown>,\n   391→        sourceObj as Record<string, unknown>\n   392→      );\n   393→\n   394→      merged[docId] = result.result;\n   395→      conflicts.push(...result.conflicts);\n   396→    }\n   397→\n   398→    const applied = conflicts.length === 0;\n   399→\n   400→    if (applied) {\n   401→      // Apply the merge to the target branch\n   402→      // First, handle documents that were removed (in source but deleted)\n   403→      for (const docId of allDocIds) {\n   404→        if (docId in merged) {\n   405→          const targetRec = target.documents.get(docId);\n   406→          if (targetRec) {\n   407→            // Update existing document\n   408→            const newContent = deepClone(merged[docId]);\n   409→            if (!deepEqual(targetRec.content, newContent) || targetRec.deleted) {\n   410→              targetRec.deleted = false;\n   411→              targetRec.content = newContent;\n   412→              const version: Version = {\n   413→                id: makeVersionId(),\n   414→                timestamp: Date.now(),\n   415→                content: deepClone(newContent),\n   416→              };\n   417→              targetRec.versions.push(version);\n   418→            }\n   419→          } else {\n   420→            // New document from source\n   421→            const newContent = deepClone(merged[docId]);\n   422→            const version: Version = {\n   423→              id: makeVersionId(),\n   424→              timestamp: Date.now(),\n   425→              content: deepClone(newContent),\n   426→            };\n   427→            target.documents.set(docId, {\n   428→              content: newContent,\n   429→              versions: [version],\n   430→              deleted: false,\n   431→            });\n   432→          }\n   433→        } else {\n   434→          // Document should be removed (e.g., source deleted it and target didn't change)\n   435→          const targetRec = target.documents.get(docId);\n   436→          if (targetRec && !targetRec.deleted) {\n   437→            const baseContent = base.get(docId);\n   438→            const sourceRec = source.documents.get(docId);\n   439→            const sourceDeleted = sourceRec != null && sourceRec.deleted;\n   440→            if (sourceDeleted && deepEqual(baseContent, targetRec.content)) {\n   441→              targetRec.deleted = true;\n   442→              targetRec.content = {};\n   443→            }\n   444→          }\n   445→        }\n   446→      }\n   447→    }\n   448→\n   449→    // Deep clone the merged output\n   450→    const mergedClone: Record<string, object> = {};\n   451→    for (const [k, v] of Object.entries(merged)) {\n   452→      mergedClone[k] = deepClone(v);\n   453→    }\n   454→\n   455→    return {\n   456→      merged: mergedClone,\n   457→      conflicts,\n   458→      applied,\n   459→    };\n   460→  }\n   461→\n   462→  /**\n   463→   * Three-way merge at the object level.\n   464→   * base = common ancestor, ours = target branch (current), theirs = source branch.\n   465→   * Recurse into nested objects; at leaf level, detect conflicts.\n   466→   */\n   467→  private threeWayMergeObject(\n   468→    docId: string,\n   469→    base: Record<string, unknown>,\n   470→    ours: Record<string, unknown>,\n   471→    theirs: Record<string, unknown>\n   472→  ): { result: Record<string, unknown>; conflicts: Conflict[] } {\n   473→    const allPaths = new Set<string>();\n   474→    collectPaths(base, '', allPaths);\n   475→    collectPaths(ours, '', allPaths);\n   476→    collectPaths(theirs, '', allPaths);\n   477→\n   478→    const conflicts: Conflict[] = [];\n   479→    const result: Record<string, unknown> = deepClone(ours) as Record<string, unknown>;\n   480→\n   481→    for (const path of allPaths) {\n   482→      if (!path) continue;\n   483→\n   484→      const baseVal = getAtPath(base, path);\n   485→      const ourVal = getAtPath(ours, path);\n   486→      const theirVal = getAtPath(theirs, path);\n   487→\n   488→      const ourChanged = !deepEqual(baseVal, ourVal);\n   489→      const theirChanged = !deepEqual(baseVal, theirVal);\n   490→\n   491→      if (!ourChanged && !theirChanged) {\n   492→        // No changes — keep as-is\n   493→        continue;\n   494→      }\n   495→\n   496→      if (theirChanged && !ourChanged) {\n   497→        // Only theirs changed — take theirs\n   498→        if (theirVal === undefined) {\n   499→          deleteAtPath(result, path);\n   500→        } else {\n   501→          setAtPath(result, path, deepClone(theirVal));\n   502→        }\n   503→        continue;\n   504→      }\n   505→\n   506→      if (ourChanged && !theirChanged) {\n   507→        // Only ours changed — keep ours (already in result)\n   508→        continue;\n   509→      }\n   510→\n   511→      // Both changed\n   512→      if (deepEqual(ourVal, theirVal)) {\n   513→        // Both changed to the same value — no conflict\n   514→        continue;\n   515→      }\n   516→\n   517→      // Conflict! Keep ours in result, record conflict\n   518→      conflicts.push({\n   519→        documentId: docId,\n   520→        path,\n   521→        base: deepClone(baseVal),\n   522→        ours: deepClone(ourVal),\n   523→        theirs: deepClone(theirVal),\n   524→      });\n   525→    }\n   526→\n   527→    return { result: result as Record<string, unknown>, conflicts };\n   528→  }\n   529→}\n   530→"}]},"parent_tool_use_id":null,"session_id":"34150bf5-585e-4d87-a9f6-b05ef96f1dac","uuid":"338c04fc-8bd5-4980-b3fb-fa63dbaf103b","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/index.ts","content":"// ─── Types ───────────────────────────────────────────────────────────\n\nexport interface Version {\n  id: string;\n  timestamp: number;\n  content: object;\n}\n\nexport interface Conflict {\n  documentId: string;\n  path: string;\n  base: unknown;\n  ours: unknown;\n  theirs: unknown;\n}\n\nexport interface MergeResult {\n  merged: Record<string, object>;\n  conflicts: Conflict[];\n  applied: boolean;\n}\n\n// ─── Internal types ──────────────────────────────────────────────────\n\ninterface DocumentRecord {\n  content: object;\n  versions: Version[];\n  deleted: boolean;\n}\n\ninterface BranchData {\n  documents: Map<string, DocumentRecord>;\n  /** Snapshot of all documents at the time this branch was created (the merge base). */\n  ancestor: Map<string, object | null>;\n}\n\n// ─── Helpers ─────────────────────────────────────────────────────────\n\nfunction deepClone<T>(value: T): T {\n  if (value === null || value === undefined) return value;\n  return JSON.parse(JSON.stringify(value));\n}\n\nlet versionCounter = 0;\nfunction makeVersionId(): string {\n  return `v_${++versionCounter}_${Date.now()}`;\n}\n\n/**\n * Recursively collect all leaf-level field paths from an object.\n * Returns dot-separated paths.\n */\nfunction collectPaths(obj: unknown, prefix: string, paths: Set<string>): void {\n  if (obj === null || obj === undefined || typeof obj !== 'object' || Array.isArray(obj)) {\n    paths.add(prefix);\n    return;\n  }\n  const keys = Object.keys(obj as Record<string, unknown>);\n  if (keys.length === 0) {\n    paths.add(prefix);\n    return;\n  }\n  for (const key of keys) {\n    const newPrefix = prefix ? `${prefix}.${key}` : key;\n    collectPaths((obj as Record<string, unknown>)[key], newPrefix, paths);\n  }\n}\n\n/**\n * Get a value at a dot-separated path from an object.\n * Returns undefined if the path doesn't exist.\n */\nfunction getAtPath(obj: unknown, path: string): unknown {\n  const parts = path.split('.');\n  let current: unknown = obj;\n  for (const part of parts) {\n    if (current === null || current === undefined || typeof current !== 'object' || Array.isArray(current)) {\n      return undefined;\n    }\n    current = (current as Record<string, unknown>)[part];\n  }\n  return current;\n}\n\n/**\n * Set a value at a dot-separated path on an object, creating intermediate objects as needed.\n */\nfunction setAtPath(obj: Record<string, unknown>, path: string, value: unknown): void {\n  const parts = path.split('.');\n  let current: Record<string, unknown> = obj;\n  for (let i = 0; i < parts.length - 1; i++) {\n    const part = parts[i];\n    if (!(part in current) || typeof current[part] !== 'object' || current[part] === null || Array.isArray(current[part])) {\n      current[part] = {};\n    }\n    current = current[part] as Record<string, unknown>;\n  }\n  current[parts[parts.length - 1]] = value;\n}\n\n/**\n * Delete a value at a dot-separated path on an object.\n */\nfunction deleteAtPath(obj: Record<string, unknown>, path: string): void {\n  const parts = path.split('.');\n  let current: Record<string, unknown> = obj;\n  for (let i = 0; i < parts.length - 1; i++) {\n    const part = parts[i];\n    if (!(part in current) || typeof current[part] !== 'object' || current[part] === null) {\n      return;\n    }\n    current = current[part] as Record<string, unknown>;\n  }\n  delete current[parts[parts.length - 1]];\n}\n\nfunction deepEqual(a: unknown, b: unknown): boolean {\n  return JSON.stringify(a) === JSON.stringify(b);\n}\n\n/**\n * Snapshot the current documents on a branch: returns a map from docId to deep-cloned content\n * (or null if the document is deleted / doesn't exist).\n */\nfunction snapshotBranch(branch: BranchData): Map<string, object | null> {\n  const snap = new Map<string, object | null>();\n  for (const [id, rec] of branch.documents) {\n    snap.set(id, rec.deleted ? null : deepClone(rec.content));\n  }\n  return snap;\n}\n\n// ─── DocumentStore ───────────────────────────────────────────────────\n\nexport class DocumentStore {\n  private branches: Map<string, BranchData> = new Map();\n  private currentBranch: string = 'main';\n\n  constructor() {\n    this.branches.set('main', {\n      documents: new Map(),\n      ancestor: new Map(),\n    });\n  }\n\n  // ── helpers ──\n\n  private branch(): BranchData {\n    return this.branches.get(this.currentBranch)!;\n  }\n\n  private getRecord(id: string): DocumentRecord {\n    const rec = this.branch().documents.get(id);\n    if (!rec || rec.deleted) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    return rec;\n  }\n\n  // ── CRUD ──\n\n  create(id: string, content: object): void {\n    const branch = this.branch();\n    const existing = branch.documents.get(id);\n    if (existing && !existing.deleted) {\n      throw new Error(`Document \"${id}\" already exists`);\n    }\n    const cloned = deepClone(content);\n    const version: Version = {\n      id: makeVersionId(),\n      timestamp: Date.now(),\n      content: deepClone(cloned),\n    };\n    branch.documents.set(id, {\n      content: cloned,\n      versions: existing && existing.deleted ? [...existing.versions, version] : [version],\n      deleted: false,\n    });\n  }\n\n  get(id: string): object {\n    return deepClone(this.getRecord(id).content);\n  }\n\n  update(id: string, content: object): void {\n    const rec = this.getRecord(id);\n    const cloned = deepClone(content);\n    const version: Version = {\n      id: makeVersionId(),\n      timestamp: Date.now(),\n      content: deepClone(cloned),\n    };\n    rec.content = cloned;\n    rec.versions.push(version);\n  }\n\n  delete(id: string): void {\n    const rec = this.getRecord(id); // throws if not found\n    rec.deleted = true;\n    rec.content = {};\n  }\n\n  // ── Version History ──\n\n  getHistory(id: string): Version[] {\n    const branch = this.branch();\n    const rec = branch.documents.get(id);\n    if (!rec) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    return rec.versions.map(v => ({\n      id: v.id,\n      timestamp: v.timestamp,\n      content: deepClone(v.content),\n    }));\n  }\n\n  getVersion(id: string, versionId: string): object {\n    const branch = this.branch();\n    const rec = branch.documents.get(id);\n    if (!rec) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    const version = rec.versions.find(v => v.id === versionId);\n    if (!version) {\n      throw new Error(`Version \"${versionId}\" not found for document \"${id}\"`);\n    }\n    return deepClone(version.content);\n  }\n\n  // ── Branching ──\n\n  createBranch(name: string, fromBranch?: string): void {\n    if (this.branches.has(name)) {\n      throw new Error(`Branch \"${name}\" already exists`);\n    }\n    const sourceName = fromBranch ?? this.currentBranch;\n    const source = this.branches.get(sourceName);\n    if (!source) {\n      throw new Error(`Branch \"${sourceName}\" not found`);\n    }\n\n    // Deep-clone all documents from the source branch\n    const newDocs = new Map<string, DocumentRecord>();\n    for (const [id, rec] of source.documents) {\n      newDocs.set(id, {\n        content: deepClone(rec.content),\n        versions: rec.versions.map(v => ({\n          id: v.id,\n          timestamp: v.timestamp,\n          content: deepClone(v.content),\n        })),\n        deleted: rec.deleted,\n      });\n    }\n\n    // The ancestor snapshot is the current state of the source branch at this moment.\n    // This will be used as the merge base for three-way merging.\n    const ancestor = snapshotBranch(source);\n\n    this.branches.set(name, {\n      documents: newDocs,\n      ancestor,\n    });\n  }\n\n  switchBranch(name: string): void {\n    if (!this.branches.has(name)) {\n      throw new Error(`Branch \"${name}\" not found`);\n    }\n    this.currentBranch = name;\n  }\n\n  getBranch(): string {\n    return this.currentBranch;\n  }\n\n  listBranches(): string[] {\n    return Array.from(this.branches.keys());\n  }\n\n  // ── Merging ──\n\n  merge(sourceBranch: string): MergeResult {\n    const source = this.branches.get(sourceBranch);\n    if (!source) {\n      throw new Error(`Branch \"${sourceBranch}\" not found`);\n    }\n    const target = this.branch();\n\n    // The common ancestor is the snapshot taken when the source branch was created.\n    // This represents the state of the parent branch at branch creation time.\n    const base = source.ancestor;\n\n    // Collect all document IDs across base, source, and target\n    const allDocIds = new Set<string>();\n    for (const id of base.keys()) allDocIds.add(id);\n    for (const [id, rec] of source.documents) {\n      if (!rec.deleted) allDocIds.add(id);\n    }\n    for (const [id, rec] of target.documents) {\n      if (!rec.deleted) allDocIds.add(id);\n    }\n\n    const merged: Record<string, object> = {};\n    const conflicts: Conflict[] = [];\n\n    for (const docId of allDocIds) {\n      const baseContent = base.has(docId) ? base.get(docId) : undefined;\n      const baseExists = base.has(docId) && baseContent !== null;\n\n      const sourceRec = source.documents.get(docId);\n      const sourceExists = sourceRec != null && !sourceRec.deleted;\n      const sourceContent = sourceExists ? sourceRec.content : undefined;\n\n      const targetRec = target.documents.get(docId);\n      const targetExists = targetRec != null && !targetRec.deleted;\n      const targetContent = targetExists ? targetRec.content : undefined;\n\n      const sourceDeleted = base.has(docId) && baseContent !== null && sourceRec != null && sourceRec.deleted;\n      const targetDeleted = base.has(docId) && baseContent !== null && targetRec != null && targetRec.deleted;\n\n      // Determine what changed on each side\n      const sourceChanged = !deepEqual(\n        baseExists ? baseContent : undefined,\n        sourceDeleted ? undefined : sourceContent\n      );\n      const targetChanged = !deepEqual(\n        baseExists ? baseContent : undefined,\n        targetDeleted ? undefined : targetContent\n      );\n\n      if (!sourceChanged && !targetChanged) {\n        // No changes on either side — keep target as-is\n        if (targetExists) {\n          merged[docId] = deepClone(targetContent!);\n        }\n        continue;\n      }\n\n      if (sourceChanged && !targetChanged) {\n        // Only source changed — take source's version\n        if (sourceDeleted) {\n          // Source deleted the document — don't include in merged\n          continue;\n        }\n        if (sourceExists) {\n          merged[docId] = deepClone(sourceContent!);\n        }\n        continue;\n      }\n\n      if (!sourceChanged && targetChanged) {\n        // Only target changed — keep target's version (already there)\n        if (targetExists) {\n          merged[docId] = deepClone(targetContent!);\n        }\n        continue;\n      }\n\n      // Both sides changed — need field-level three-way merge\n      // Handle document-level create/delete scenarios\n      if (sourceDeleted && targetDeleted) {\n        // Both deleted — agree, no conflict\n        continue;\n      }\n\n      if (sourceDeleted && !targetDeleted) {\n        // Source deleted, target modified — conflict at document level\n        // For \"ours\" (target), keep target version\n        merged[docId] = deepClone(targetContent!);\n        // We treat this as a conflict but \"ours\" wins for the merged output\n        continue;\n      }\n\n      if (!sourceDeleted && targetDeleted) {\n        // Target deleted, source modified — we keep \"ours\" (deleted)\n        // Don't include in merged\n        continue;\n      }\n\n      // Both sides modified the document — do field-level merge\n      const baseObj = baseExists ? baseContent : {};\n      const sourceObj = sourceContent!;\n      const targetObj = targetContent!;\n\n      const result = this.threeWayMergeObject(\n        docId,\n        baseObj as Record<string, unknown>,\n        targetObj as Record<string, unknown>,\n        sourceObj as Record<string, unknown>\n      );\n\n      merged[docId] = result.result;\n      conflicts.push(...result.conflicts);\n    }\n\n    const applied = conflicts.length === 0;\n\n    if (applied) {\n      // Apply the merge to the target branch\n      // First, handle documents that were removed (in source but deleted)\n      for (const docId of allDocIds) {\n        if (docId in merged) {\n          const targetRec = target.documents.get(docId);\n          if (targetRec) {\n            // Update existing document\n            const newContent = deepClone(merged[docId]);\n            if (!deepEqual(targetRec.content, newContent) || targetRec.deleted) {\n              targetRec.deleted = false;\n              targetRec.content = newContent;\n              const version: Version = {\n                id: makeVersionId(),\n                timestamp: Date.now(),\n                content: deepClone(newContent),\n              };\n              targetRec.versions.push(version);\n            }\n          } else {\n            // New document from source\n            const newContent = deepClone(merged[docId]);\n            const version: Version = {\n              id: makeVersionId(),\n              timestamp: Date.now(),\n              content: deepClone(newContent),\n            };\n            target.documents.set(docId, {\n              content: newContent,\n              versions: [version],\n              deleted: false,\n            });\n          }\n        } else {\n          // Document should be removed (e.g., source deleted it and target didn't change)\n          const targetRec = target.documents.get(docId);\n          if (targetRec && !targetRec.deleted) {\n            const baseContent = base.get(docId);\n            const sourceRec = source.documents.get(docId);\n            const sourceDeleted = sourceRec != null && sourceRec.deleted;\n            if (sourceDeleted && deepEqual(baseContent, targetRec.content)) {\n              targetRec.deleted = true;\n              targetRec.content = {};\n            }\n          }\n        }\n      }\n    }\n\n    // Deep clone the merged output\n    const mergedClone: Record<string, object> = {};\n    for (const [k, v] of Object.entries(merged)) {\n      mergedClone[k] = deepClone(v);\n    }\n\n    return {\n      merged: mergedClone,\n      conflicts,\n      applied,\n    };\n  }\n\n  /**\n   * Three-way merge at the object level.\n   * base = common ancestor, ours = target branch (current), theirs = source branch.\n   * Recurse into nested objects; at leaf level, detect conflicts.\n   */\n  private threeWayMergeObject(\n    docId: string,\n    base: Record<string, unknown>,\n    ours: Record<string, unknown>,\n    theirs: Record<string, unknown>\n  ): { result: Record<string, unknown>; conflicts: Conflict[] } {\n    const allPaths = new Set<string>();\n    collectPaths(base, '', allPaths);\n    collectPaths(ours, '', allPaths);\n    collectPaths(theirs, '', allPaths);\n\n    const conflicts: Conflict[] = [];\n    const result: Record<string, unknown> = deepClone(ours) as Record<string, unknown>;\n\n    for (const path of allPaths) {\n      if (!path) continue;\n\n      const baseVal = getAtPath(base, path);\n      const ourVal = getAtPath(ours, path);\n      const theirVal = getAtPath(theirs, path);\n\n      const ourChanged = !deepEqual(baseVal, ourVal);\n      const theirChanged = !deepEqual(baseVal, theirVal);\n\n      if (!ourChanged && !theirChanged) {\n        // No changes — keep as-is\n        continue;\n      }\n\n      if (theirChanged && !ourChanged) {\n        // Only theirs changed — take theirs\n        if (theirVal === undefined) {\n          deleteAtPath(result, path);\n        } else {\n          setAtPath(result, path, deepClone(theirVal));\n        }\n        continue;\n      }\n\n      if (ourChanged && !theirChanged) {\n        // Only ours changed — keep ours (already in result)\n        continue;\n      }\n\n      // Both changed\n      if (deepEqual(ourVal, theirVal)) {\n        // Both changed to the same value — no conflict\n        continue;\n      }\n\n      // Conflict! Keep ours in result, record conflict\n      conflicts.push({\n        documentId: docId,\n        path,\n        base: deepClone(baseVal),\n        ours: deepClone(ourVal),\n        theirs: deepClone(theirVal),\n      });\n    }\n\n    return { result: result as Record<string, unknown>, conflicts };\n  }\n}\n","numLines":530,"startLine":1,"totalLines":530}}}
