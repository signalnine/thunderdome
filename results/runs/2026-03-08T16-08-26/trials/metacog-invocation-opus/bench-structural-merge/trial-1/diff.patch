──────────────────────────────────────────────────\n\ninterface DocumentRecord {\n  content: object;\n  versions: Version[];\n  deleted: boolean;\n}\n\ninterface BranchData {\n  documents: Map<string, DocumentRecord>;\n  /** Snapshot of all documents at the time this branch was created (the merge base). */\n  ancestor: Map<string, object | null>;\n}\n\n// ─── Helpers ─────────────────────────────────────────────────────────\n\nfunction deepClone<T>(value: T): T {\n  if (value === null || value === undefined) return value;\n  return JSON.parse(JSON.stringify(value));\n}\n\nlet versionCounter = 0;\nfunction makeVersionId(): string {\n  return `v_${++versionCounter}_${Date.now()}`;\n}\n\n/**\n * Recursively collect all leaf-level field paths from an object.\n * Returns dot-separated paths.\n */\nfunction collectPaths(obj: unknown, prefix: string, paths: Set<string>): void {\n  if (obj === null || obj === undefined || typeof obj !== 'object' || Array.isArray(obj)) {\n    paths.add(prefix);\n    return;\n  }\n  const keys = Object.keys(obj as Record<string, unknown>);\n  if (keys.length === 0) {\n    paths.add(prefix);\n    return;\n  }\n  for (const key of keys) {\n    const newPrefix = prefix ? `${prefix}.${key}` : key;\n    collectPaths((obj as Record<string, unknown>)[key], newPrefix, paths);\n  }\n}\n\n/**\n * Get a value at a dot-separated path from an object.\n * Returns undefined if the path doesn't exist.\n */\nfunction getAtPath(obj: unknown, path: string): unknown {\n  const parts = path.split('.');\n  let current: unknown = obj;\n  for (const part of parts) {\n    if (current === null || current === undefined || typeof current !== 'object' || Array.isArray(current)) {\n      return undefined;\n    }\n    current = (current as Record<string, unknown>)[part];\n  }\n  return current;\n}\n\n/**\n * Set a value at a dot-separated path on an object, creating intermediate objects as needed.\n */\nfunction setAtPath(obj: Record<string, unknown>, path: string, value: unknown): void {\n  const parts = path.split('.');\n  let current: Record<string, unknown> = obj;\n  for (let i = 0; i < parts.length - 1; i++) {\n    const part = parts[i];\n    if (!(part in current) || typeof current[part] !== 'object' || current[part] === null || Array.isArray(current[part])) {\n      current[part] = {};\n    }\n    current = current[part] as Record<string, unknown>;\n  }\n  current[parts[parts.length - 1]] = value;\n}\n\n/**\n * Delete a value at a dot-separated path on an object.\n */\nfunction deleteAtPath(obj: Record<string, unknown>, path: string): void {\n  const parts = path.split('.');\n  let current: Record<string, unknown> = obj;\n  for (let i = 0; i < parts.length - 1; i++) {\n    const part = parts[i];\n    if (!(part in current) || typeof current[part] !== 'object' || current[part] === null) {\n      return;\n    }\n    current = current[part] as Record<string, unknown>;\n  }\n  delete current[parts[parts.length - 1]];\n}\n\nfunction deepEqual(a: unknown, b: unknown): boolean {\n  return JSON.stringify(a) === JSON.stringify(b);\n}\n\n/**\n * Snapshot the current documents on a branch: returns a map from docId to deep-cloned content\n * (or null if the document is deleted / doesn't exist).\n */\nfunction snapshotBranch(branch: BranchData): Map<string, object | null> {\n  const snap = new Map<string, object | null>();\n  for (const [id, rec] of branch.documents) {\n    snap.set(id, rec.deleted ? null : deepClone(rec.content));\n  }\n  return snap;\n}\n\n// ─── DocumentStore ───────────────────────────────────────────────────\n\nexport class DocumentStore {\n  private branches: Map<string, BranchData> = new Map();\n  private currentBranch: string = 'main';\n\n  constructor() {\n    this.branches.set('main', {\n      documents: new Map(),\n      ancestor: new Map(),\n    });\n  }\n\n  // ── helpers ──\n\n  private branch(): BranchData {\n    return this.branches.get(this.currentBranch)!;\n  }\n\n  private getRecord(id: string): DocumentRecord {\n    const rec = this.branch().documents.get(id);\n    if (!rec || rec.deleted) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    return rec;\n  }\n\n  // ── CRUD ──\n\n  create(id: string, content: object): void {\n    const branch = this.branch();\n    const existing = branch.documents.get(id);\n    if (existing && !existing.deleted) {\n      throw new Error(`Document \"${id}\" already exists`);\n    }\n    const cloned = deepClone(content);\n    const version: Version = {\n      id: makeVersionId(),\n      timestamp: Date.now(),\n      content: deepClone(cloned),\n    };\n    branch.documents.set(id, {\n      content: cloned,\n      versions: existing && existing.deleted ? [...existing.versions, version] : [version],\n      deleted: false,\n    });\n  }\n\n  get(id: string): object {\n    return deepClone(this.getRecord(id).content);\n  }\n\n  update(id: string, content: object): void {\n    const rec = this.getRecord(id);\n    const cloned = deepClone(content);\n    const version: Version = {\n      id: makeVersionId(),\n      timestamp: Date.now(),\n      content: deepClone(cloned),\n    };\n    rec.content = cloned;\n    rec.versions.push(version);\n  }\n\n  delete(id: string): void {\n    const rec = this.getRecord(id); // throws if not found\n    rec.deleted = true;\n    rec.content = {};\n  }\n\n  // ── Version History ──\n\n  getHistory(id: string): Version[] {\n    const branch = this.branch();\n    const rec = branch.documents.get(id);\n    if (!rec) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    return rec.versions.map(v => ({\n      id: v.id,\n      timestamp: v.timestamp,\n      content: deepClone(v.content),\n    }));\n  }\n\n  getVersion(id: string, versionId: string): object {\n    const branch = this.branch();\n    const rec = branch.documents.get(id);\n    if (!rec) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    const version = rec.versions.find(v => v.id === versionId);\n    if (!version) {\n      throw new Error(`Version \"${versionId}\" not found for document \"${id}\"`);\n    }\n    return deepClone(version.content);\n  }\n\n  // ── Branching ──\n\n  createBranch(name: string, fromBranch?: string): void {\n    if (this.branches.has(name)) {\n      throw new Error(`Branch \"${name}\" already exists`);\n    }\n    const sourceName = fromBranch ?? this.currentBranch;\n    const source = this.branches.get(sourceName);\n    if (!source) {\n      throw new Error(`Branch \"${sourceName}\" not found`);\n    }\n\n    // Deep-clone all documents from the source branch\n    const newDocs = new Map<string, DocumentRecord>();\n    for (const [id, rec] of source.documents) {\n      newDocs.set(id, {\n        content: deepClone(rec.content),\n        versions: rec.versions.map(v => ({\n          id: v.id,\n          timestamp: v.timestamp,\n          content: deepClone(v.content),\n        })),\n        deleted: rec.deleted,\n      });\n    }\n\n    // The ancestor snapshot is the current state of the source branch at this moment.\n    // This will be used as the merge base for three-way merging.\n    const ancestor = snapshotBranch(source);\n\n    this.branches.set(name, {\n      documents: newDocs,\n      ancestor,\n    });\n  }\n\n  switchBranch(name: string): void {\n    if (!this.branches.has(name)) {\n      throw new Error(`Branch \"${name}\" not found`);\n    }\n    this.currentBranch = name;\n  }\n\n  getBranch(): string {\n    return this.currentBranch;\n  }\n\n  listBranches(): string[] {\n    return Array.from(this.branches.keys());\n  }\n\n  // ── Merging ──\n\n  merge(sourceBranch: string): MergeResult {\n    const source = this.branches.get(sourceBranch);\n    if (!source) {\n      throw new Error(`Branch \"${sourceBranch}\" not found`);\n    }\n    const target = this.branch();\n\n    // The common ancestor is the snapshot taken when the source branch was created.\n    // This represents the state of the parent branch at branch creation time.\n    const base = source.ancestor;\n\n    // Collect all document IDs across base, source, and target\n    const allDocIds = new Set<string>();\n    for (const id of base.keys()) allDocIds.add(id);\n    for (const [id, rec] of source.documents) {\n      if (!rec.deleted) allDocIds.add(id);\n    }\n    for (const [id, rec] of target.documents) {\n      if (!rec.deleted) allDocIds.add(id);\n    }\n\n    const merged: Record<string, object> = {};\n    const conflicts: Conflict[] = [];\n\n    for (const docId of allDocIds) {\n      const baseContent = base.has(docId) ? base.get(docId) : undefined;\n      const baseExists = base.has(docId) && baseContent !== null;\n\n      const sourceRec = source.documents.get(docId);\n      const sourceExists = sourceRec != null && !sourceRec.deleted;\n      const sourceContent = sourceExists ? sourceRec.content : undefined;\n\n      const targetRec = target.documents.get(docId);\n      const targetExists = targetRec != null && !targetRec.deleted;\n      const targetContent = targetExists ? targetRec.content : undefined;\n\n      const sourceDeleted = base.has(docId) && baseContent !== null && sourceRec != null && sourceRec.deleted;\n      const targetDeleted = base.has(docId) && baseContent !== null && targetRec != null && targetRec.deleted;\n\n      // Determine what changed on each side\n      const sourceChanged = !deepEqual(\n        baseExists ? baseContent : undefined,\n        sourceDeleted ? undefined : sourceContent\n      );\n      const targetChanged = !deepEqual(\n        baseExists ? baseContent : undefined,\n        targetDeleted ? undefined : targetContent\n      );\n\n      if (!sourceChanged && !targetChanged) {\n        // No changes on either side — keep target as-is\n        if (targetExists) {\n          merged[docId] = deepClone(targetContent!);\n        }\n        continue;\n      }\n\n      if (sourceChanged && !targetChanged) {\n        // Only source changed — take source's version\n        if (sourceDeleted) {\n          // Source deleted the document — don't include in merged\n          continue;\n        }\n        if (sourceExists) {\n          merged[docId] = deepClone(sourceContent!);\n        }\n        continue;\n      }\n\n      if (!sourceChanged && targetChanged) {\n        // Only target changed — keep target's version (already there)\n        if (targetExists) {\n          merged[docId] = deepClone(targetContent!);\n        }\n        continue;\n      }\n\n      // Both sides changed — need field-level three-way merge\n      // Handle document-level create/delete scenarios\n      if (sourceDeleted && targetDeleted) {\n        // Both deleted — agree, no conflict\n        continue;\n      }\n\n      if (sourceDeleted && !targetDeleted) {\n        // Source deleted, target modified — conflict at document level\n        // For \"ours\" (target), keep target version\n        merged[docId] = deepClone(targetContent!);\n        // We treat this as a conflict but \"ours\" wins for the merged output\n        continue;\n      }\n\n      if (!sourceDeleted && targetDeleted) {\n        // Target deleted, source modified — we keep \"ours\" (deleted)\n        // Don't include in merged\n        continue;\n      }\n\n      // Both sides modified the document — do field-level merge\n      const baseObj = baseExists ? baseContent : {};\n      const sourceObj = sourceContent!;\n      const targetObj = targetContent!;\n\n      const result = this.threeWayMergeObject(\n        docId,\n        baseObj as Record<string, unknown>,\n        targetObj as Record<string, unknown>,\n        sourceObj as Record<string, unknown>\n      );\n\n      merged[docId] = result.result;\n      conflicts.push(...result.conflicts);\n    }\n\n    const applied = conflicts.length === 0;\n\n    if (applied) {\n      // Apply the merge to the target branch\n      // First, handle documents that were removed (in source but deleted)\n      for (const docId of allDocIds) {\n        if (docId in merged) {\n          const targetRec = target.documents.get(docId);\n          if (targetRec) {\n            // Update existing document\n            const newContent = deepClone(merged[docId]);\n            if (!deepEqual(targetRec.content, newContent) || targetRec.deleted) {\n              targetRec.deleted = false;\n              targetRec.content = newContent;\n              const version: Version = {\n                id: makeVersionId(),\n                timestamp: Date.now(),\n                content: deepClone(newContent),\n              };\n              targetRec.versions.push(version);\n            }\n          } else {\n            // New document from source\n            const newContent = deepClone(merged[docId]);\n            const version: Version = {\n              id: makeVersionId(),\n              timestamp: Date.now(),\n              content: deepClone(newContent),\n            };\n            target.documents.set(docId, {\n              content: newContent,\n              versions: [version],\n              deleted: false,\n            });\n          }\n        } else {\n          // Document should be removed (e.g., source deleted it and target didn't change)\n          const targetRec = target.documents.get(docId);\n          if (targetRec && !targetRec.deleted) {\n            const baseContent = base.get(docId);\n            const sourceRec = source.documents.get(docId);\n            const sourceDeleted = sourceRec != null && sourceRec.deleted;\n            if (sourceDeleted && deepEqual(baseContent, targetRec.content)) {\n              targetRec.deleted = true;\n              targetRec.content = {};\n            }\n          }\n        }\n      }\n    }\n\n    // Deep clone the merged output\n    const mergedClone: Record<string, object> = {};\n    for (const [k, v] of Object.entries(merged)) {\n      mergedClone[k] = deepClone(v);\n    }\n\n    return {\n      merged: mergedClone,\n      conflicts,\n      applied,\n    };\n  }\n\n  /**\n   * Three-way merge at the object level.\n   * base = common ancestor, ours = target branch (current), theirs = source branch.\n   * Recurse into nested objects key-by-key; at leaf level, detect conflicts.\n   */\n  private threeWayMergeObject(\n    docId: string,\n    base: Record<string, unknown>,\n    ours: Record<string, unknown>,\n    theirs: Record<string, unknown>\n  ): { result: Record<string, unknown>; conflicts: Conflict[] } {\n    const conflicts: Conflict[] = [];\n    const result: Record<string, unknown> = deepClone(ours) as Record<string, unknown>;\n\n    this.mergeRecursive(docId, '', base, ours, theirs, result, conflicts);\n\n    return { result, conflicts };\n  }\n\n  private isPlainObject(val: unknown): val is Record<string, unknown> {\n    return val !== null && typeof val === 'object' && !Array.isArray(val);\n  }\n\n  private mergeRecursive(\n    docId: string,\n    prefix: string,\n    base: unknown,\n    ours: unknown,\n    theirs: unknown,\n    result: Record<string, unknown>,\n    conflicts: Conflict[]\n  ): void {\n    // If all three are plain objects, merge key-by-key\n    if (this.isPlainObject(base) && this.isPlainObject(ours) && this.isPlainObject(theirs)) {\n      const allKeys = new Set<string>();\n      for (const k of Object.keys(base)) allKeys.add(k);\n      for (const k of Object.keys(ours)) allKeys.add(k);\n      for (const k of Object.keys(theirs)) allKeys.add(k);\n\n      for (const key of allKeys) {\n        const path = prefix ? `${prefix}.${key}` : key;\n        const baseVal = base[key];\n        const ourVal = ours[key];\n        const theirVal = theirs[key];\n\n        const ourChanged = !deepEqual(baseVal, ourVal);\n        const theirChanged = !deepEqual(baseVal, theirVal);\n\n        if (!ourChanged && !theirChanged) {\n          continue;\n        }\n\n        if (theirChanged && !ourChanged) {\n          if (theirVal === undefined) {\n            deleteAtPath(result, path);\n          } else {\n            setAtPath(result, path, deepClone(theirVal));\n          }\n          continue;\n        }\n\n        if (ourChanged && !theirChanged) {\n          // Already in result (cloned from ours)\n          continue;\n        }\n\n        // Both changed\n        if (deepEqual(ourVal, theirVal)) {\n          continue;\n        }\n\n        // Both changed to different values. If both are objects, recurse.\n        if (this.isPlainObject(baseVal) && this.isPlainObject(ourVal) && this.isPlainObject(theirVal)) {\n          this.mergeRecursive(docId, path, baseVal, ourVal, theirVal, result, conflicts);\n        } else {\n          // Leaf-level conflict — keep ours, record conflict\n          conflicts.push({\n            documentId: docId,\n            path,\n            base: deepClone(baseVal),\n            ours: deepClone(ourVal),\n            theirs: deepClone(theirVal),\n          });\n        }\n      }\n    } else {\n      // At least one is not a plain object — treat as leaf\n      const path = prefix;\n      const ourChanged = !deepEqual(base, ours);\n      const theirChanged = !deepEqual(base, theirs);\n\n      if (!ourChanged && !theirChanged) return;\n\n      if (theirChanged && !ourChanged) {\n        if (theirs === undefined) {\n          if (path) deleteAtPath(result, path);\n        } else {\n          if (path) setAtPath(result, path, deepClone(theirs));\n        }\n        return;\n      }\n\n      if (ourChanged && !theirChanged) return;\n\n      if (deepEqual(ours, theirs)) return;\n\n      if (path) {\n        conflicts.push({\n          documentId: docId,\n          path,\n          base: deepClone(base),\n          ours: deepClone(ours),\n          theirs: deepClone(theirs),\n        });\n      }\n    }\n  }\n}\n","structuredPatch":[{"oldStart":47,"oldLines":42,"newStart":47,"newLines":6,"lines":[" }"," "," /**","- * Recursively collect all leaf-level field paths from an object.","- * Returns dot-separated paths.","- */","-function collectPaths(obj: unknown, p