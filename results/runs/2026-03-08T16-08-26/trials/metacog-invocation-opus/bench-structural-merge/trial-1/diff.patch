name: 'Alice', nested: { x: 1 } });\n    });\n\n    it('should allow create after delete', () => {\n      store.create('doc1', { v: 1 });\n      store.delete('doc1');\n      store.create('doc1', { v: 2 });\n      expect(store.get('doc1')).toEqual({ v: 2 });\n    });\n  });\n\n  describe('Version History', () => {\n    it('should track versions on create and update', () => {\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n      store.update('doc1', { v: 3 });\n\n      const history = store.getHistory('doc1');\n      expect(history).toHaveLength(3);\n      expect(history[0].content).toEqual({ v: 1 });\n      expect(history[1].content).toEqual({ v: 2 });\n      expect(history[2].content).toEqual({ v: 3 });\n    });\n\n    it('should return versions in chronological order', () => {\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n      const history = store.getHistory('doc1');\n      expect(history[0].timestamp).toBeLessThanOrEqual(history[1].timestamp);\n    });\n\n    it('should get specific version by id', () => {\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n      const history = store.getHistory('doc1');\n      const v1 = store.getVersion('doc1', history[0].id);\n      expect(v1).toEqual({ v: 1 });\n    });\n\n    it('should throw for non-existent version', () => {\n      store.create('doc1', { v: 1 });\n      expect(() => store.getVersion('doc1', 'nonexistent')).toThrow();\n    });\n\n    it('each version should have a unique id', () => {\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n      const history = store.getHistory('doc1');\n      expect(history[0].id).not.toBe(history[1].id);\n    });\n  });\n\n  describe('Branching', () => {\n    it('should start on main branch', () => {\n      expect(store.getBranch()).toBe('main');\n    });\n\n    it('should create and switch branches', () => {\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      expect(store.getBranch()).toBe('feature');\n    });\n\n    it('should list branches', () => {\n      store.createBranch('feature');\n      store.createBranch('bugfix');\n      const branches = store.listBranches();\n      expect(branches).toContain('main');\n      expect(branches).toContain('feature');\n      expect(branches).toContain('bugfix');\n    });\n\n    it('should isolate changes between branches', () => {\n      store.create('doc1', { v: 1 });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { v: 2 });\n\n      expect(store.get('doc1')).toEqual({ v: 2 });\n      store.switchBranch('main');\n      expect(store.get('doc1')).toEqual({ v: 1 });\n    });\n\n    it('should create branch from specific branch', () => {\n      store.create('doc1', { v: 1 });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { v: 2 });\n\n      store.createBranch('feature2', 'feature');\n      store.switchBranch('feature2');\n      expect(store.get('doc1')).toEqual({ v: 2 });\n    });\n\n    it('should throw when creating duplicate branch', () => {\n      store.createBranch('feature');\n      expect(() => store.createBranch('feature')).toThrow();\n    });\n\n    it('should throw when switching to non-existent branch', () => {\n      expect(() => store.switchBranch('nonexistent')).toThrow();\n    });\n  });\n\n  describe('Merging', () => {\n    it('should merge non-conflicting changes from source', () => {\n      store.create('doc1', { a: 1, b: 2 });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: 10, b: 2 });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(result.merged['doc1']).toEqual({ a: 10, b: 2 });\n      expect(store.get('doc1')).toEqual({ a: 10, b: 2 });\n    });\n\n    it('should merge when both sides change different fields', () => {\n      store.create('doc1', { a: 1, b: 2, c: 3 });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: 10, b: 2, c: 3 });\n\n      store.switchBranch('main');\n      store.update('doc1', { a: 1, b: 20, c: 3 });\n\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(result.merged['doc1']).toEqual({ a: 10, b: 20, c: 3 });\n      expect(store.get('doc1')).toEqual({ a: 10, b: 20, c: 3 });\n    });\n\n    it('should detect conflicts when both sides change same field to different values', () => {\n      store.create('doc1', { a: 1, b: 2 });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: 100, b: 2 });\n\n      store.switchBranch('main');\n      store.update('doc1', { a: 200, b: 2 });\n\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(false);\n      expect(result.conflicts).toHaveLength(1);\n      expect(result.conflicts[0]).toEqual({\n        documentId: 'doc1',\n        path: 'a',\n        base: 1,\n        ours: 200,\n        theirs: 100,\n      });\n      expect(result.merged['doc1']).toEqual({ a: 200, b: 2 });\n      expect(store.get('doc1')).toEqual({ a: 200, b: 2 });\n    });\n\n    it('should not conflict when both sides change to same value', () => {\n      store.create('doc1', { a: 1 });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: 42 });\n\n      store.switchBranch('main');\n      store.update('doc1', { a: 42 });\n\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n    });\n\n    it('should merge new documents from source', () => {\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.create('doc1', { name: 'new' });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.merged['doc1']).toEqual({ name: 'new' });\n      expect(store.get('doc1')).toEqual({ name: 'new' });\n    });\n\n    it('should handle independent documents on different branches', () => {\n      store.create('doc1', { x: 1 });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.create('doc2', { y: 2 });\n\n      store.switchBranch('main');\n      store.create('doc3', { z: 3 });\n\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(store.get('doc1')).toEqual({ x: 1 });\n      expect(store.get('doc2')).toEqual({ y: 2 });\n      expect(store.get('doc3')).toEqual({ z: 3 });\n    });\n\n    it('should handle nested object merges', () => {\n      store.create('doc1', { user: { name: 'Alice', age: 30 }, settings: { theme: 'light' } });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.update('doc1', { user: { name: 'Alice', age: 31 }, settings: { theme: 'light' } });\n\n      store.switchBranch('main');\n      store.update('doc1', { user: { name: 'Alice', age: 30 }, settings: { theme: 'dark' } });\n\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.merged['doc1']).toEqual({\n        user: { name: 'Alice', age: 31 },\n        settings: { theme: 'dark' },\n      });\n    });\n\n    it('should not apply merge when conflicts exist', () => {\n      store.create('doc1', { a: 1 });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: 2 });\n\n      store.switchBranch('main');\n      store.update('doc1', { a: 3 });\n\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(false);\n      expect(store.get('doc1')).toEqual({ a: 3 });\n    });\n\n    it('should handle fast-forward (no changes)', () => {\n      store.create('doc1', { a: 1 });\n      store.createBranch('feature');\n\n      const result = store.merge('feature');\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n    });\n\n    it('should handle document deletion on source', () => {\n      store.create('doc1', { a: 1 });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.delete('doc1');\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(() => store.get('doc1')).toThrow();\n    });\n\n    it('should handle adding new fields on source', () => {\n      store.create('doc1', { a: 1 });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: 1, b: 2 });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.merged['doc1']).toEqual({ a: 1, b: 2 });\n      expect(store.get('doc1')).toEqual({ a: 1, b: 2 });\n    });\n\n    it('should handle deeply nested conflict paths', () => {\n      store.create('doc1', { a: { b: { c: 1 } } });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: { b: { c: 2 } } });\n\n      store.switchBranch('main');\n      store.update('doc1', { a: { b: { c: 3 } } });\n\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(false);\n      expect(result.conflicts).toHaveLength(1);\n      expect(result.conflicts[0].path).toBe('a.b.c');\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":232,"cache_read_input_tokens