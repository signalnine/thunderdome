es.push({ op: 'OR', in1: generate, in2: propagate, out: `z${String(bits).padStart(2, '0')}` });","+      prevCarry = `z${String(bits).padStart(2, '0')}`;","+    } else {","+      const carry = randomName();","+      gates.push({ op: 'OR', in1: generate, in2: propagate, out: carry });","+      prevCarry = carry;","+    }","+  }","+","+  return gates;","+}","+"," function makeInputs(bits: number, x: number, y: number): Record<string, number> {","   const inputs: Record<string, number> = {};","   for (let i = 0; i < bits; i++) {","-    const pad = String(i).padStart(2, '0');","-    inputs[`x${pad}`] = (x >> i) & 1;","-    inputs[`y${pad}`] = (y >> i) & 1;","+    const p = String(i).padStart(2, '0');","+    inputs[`x${p}`] = (x >> i) & 1;","+    inputs[`y${p}`] = (y >> i) & 1;","   }","   return inputs;"," }"]},{"oldStart":142,"oldLines":8,"newStart":263,"newLines":8,"lines":[" function expectSum(result: Record<string, number>, bits: number, expected: number) {","   let actual = 0;","   for (let i = 0; i <= bits; i++) {","-    const pad = String(i).padStart(2, '0');","-    const bit = result[`z${pad}`];","+    const p = String(i).padStart(2, '0');","+    const bit = result[`z${p}`];","     expect(bit).toBeDefined();","     actual |= (bit << i);","   }"]}],"originalFile":"import { simulate, findSwappedWires, Gate } from '../src/index.js';\n\ndescribe('simulate', () => {\n  it('should handle basic AND gate', () => {\n    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 0 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 0 });\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n  });\n\n  it('should handle basic OR gate', () => {\n    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n  });\n\n  it('should handle basic XOR gate', () => {\n    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 0 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n  });\n\n  it('should handle chained gates in dependency order', () => {\n    const gates: Gate[] = [\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },\n    ];\n    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({ a: 1, b: 1, c: 1, d: 0, e: 1 });\n    expect(simulate(gates, { a: 0, b: 1, d: 0 })).toEqual({ a: 0, b: 1, c: 0, d: 0, e: 0 });\n  });\n\n  it('should simulate the 4-bit adder example: 0+0', () => {\n    const gates = make4BitAdder();\n    const inputs = makeInputs(4, 0, 0);\n    const result = simulate(gates, inputs);\n    expectSum(result, 4, 0);\n  });\n\n  it('should simulate the 4-bit adder example: 5+3=8', () => {\n    const gates = make4BitAdder();\n    const inputs = makeInputs(4, 5, 3);\n    const result = simulate(gates, inputs);\n    expectSum(result, 4, 8);\n  });\n\n  it('should simulate the 4-bit adder example: 15+15=30', () => {\n    const gates = make4BitAdder();\n    const inputs = makeInputs(4, 15, 15);\n    const result = simulate(gates, inputs);\n    expectSum(result, 4, 30);\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  it('should find swapped wires in a simple 4-bit adder with 4 swaps', () => {\n    // Build a correct 4-bit adder, then swap 4 pairs of outputs\n    const gates = make4BitAdder();\n\n    // Swap pairs: (z01, a01), (z02, b02), (t03, a03), (c01, c02)\n    // Wait — we need to be more careful about which wires we swap.\n    // Let's swap: z01 <-> a01, z02 <-> a02, t03 <-> b03, c01 <-> c02\n    const swapped = swapOutputs(gates, [\n      ['z01', 'a01'],\n      ['z02', 'a02'],\n      ['t03', 'b03'],\n      ['c01', 'c02'],\n    ]);\n\n    const result = findSwappedWires(swapped);\n    expect(result).toEqual(['a01', 'a02', 'b03', 'c01', 'c02', 't03', 'z01', 'z02']);\n  });\n\n  it('should find swapped wires in larger adder', () => {\n    // Build a correct 8-bit adder, then swap 4 pairs\n    const gates = makeNBitAdder(8);\n\n    const swapped = swapOutputs(gates, [\n      ['z03', 'a03'],\n      ['z05', 'b05'],\n      ['t07', 'a07'],\n      ['c02', 'c06'],\n    ]);\n\n    const result = findSwappedWires(swapped);\n    expect(result).toEqual(['a03', 'a07', 'b05', 'c02', 'c06', 't07', 'z03', 'z05']);\n  });\n});\n\n// --- Helpers ---\n\nfunction make4BitAdder(): Gate[] {\n  return makeNBitAdder(4);\n}\n\nfunction makeNBitAdder(bits: number): Gate[] {\n  const gates: Gate[] = [];\n\n  // Bit 0: half adder\n  gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });\n  gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });\n\n  // Bits 1..N-1: full adders\n  for (let i = 1; i < bits; i++) {\n    const pad = String(i).padStart(2, '0');\n    const prevPad = String(i - 1).padStart(2, '0');\n    gates.push({ op: 'XOR', in1: `x${pad}`, in2: `y${pad}`, out: `t${pad}` });\n    gates.push({ op: 'XOR', in1: `t${pad}`, in2: `c${prevPad}`, out: `z${pad}` });\n    gates.push({ op: 'AND', in1: `x${pad}`, in2: `y${pad}`, out: `a${pad}` });\n    gates.push({ op: 'AND', in1: `t${pad}`, in2: `c${prevPad}`, out: `b${pad}` });\n    gates.push({ op: 'OR', in1: `a${pad}`, in2: `b${pad}`, out: `c${pad}` });\n  }\n\n  // Final carry\n  const lastPad = String(bits - 1).padStart(2, '0');\n  const outPad = String(bits).padStart(2, '0');\n  // The last carry c(N-1) should become z(N)\n  // In the example, c03 -> z04 is shown as a direct wire, but in gate form,\n  // we can model this as the last OR gate outputting z(N) directly.\n  // Actually, looking at the example more carefully, c03 IS z04.\n  // So let's modify the last full adder's OR to output z(N) instead.\n  // Find and update the last OR gate\n  for (const gate of gates) {\n    if (gate.op === 'OR' && gate.out === `c${lastPad}`) {\n      gate.out = `z${outPad}`;\n    }\n  }\n\n  return gates;\n}\n\nfunction makeInputs(bits: number, x: number, y: number): Record<string, number> {\n  const inputs: Record<string, number> = {};\n  for (let i = 0; i < bits; i++) {\n    const pad = String(i).padStart(2, '0');\n    inputs[`x${pad}`] = (x >> i) & 1;\n    inputs[`y${pad}`] = (y >> i) & 1;\n  }\n  return inputs;\n}\n\nfunction expectSum(result: Record<string, number>, bits: number, expected: number) {\n  let actual = 0;\n  for (let i = 0; i <= bits; i++) {\n    const pad = String(i).padStart(2, '0');\n    const bit = result[`z${pad}`];\n    expect(bit).toBeDefined();\n    actual |= (bit << i);\n  }\n  expect(actual).toBe(expected);\n}\n\nfunction swapOutputs(gates: Gate[], swaps: [string, string][]): Gate[] {\n  const swapMap: Record<string, string> = {};\n  for (const [a, b] of swaps) {\n    swapMap[a] = b;\n    swapMap[b] = a;\n  }\n\n  return gates.map((gate) => ({\n    ...gate,\n    out: swapMap[gate.out] ?? gate.out,\n  }));\n}\n"}}
