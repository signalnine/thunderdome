p of [producer.in1, producer.in2]) {\n        const xorGate = gateByOutput[andInp];\n        if (xorGate && xorGate.op === 'XOR') {\n          const xm1 = xorGate.in1.match(/^[xy](\\d+)$/);\n          const xm2 = xorGate.in2.match(/^[xy](\\d+)$/);\n          if (xm1 && xm2 && xm1[1] === xm2[1]) {\n            return parseInt(xm1[1], 10);\n          }\n        }\n      }\n    }\n    return -1;\n  }\n\n  // Check carry wires: OR gate outputs and AND(x00,y00) output\n  const carryWires: Array<{ wire: string; bit: number }> = [];\n\n  for (const gate of gates) {\n    if (gate.op === 'OR' && !swapped.has(gate.out) && gate.out !== lastZ) {\n      const bit = getOrGateBit(gate);\n      if (bit >= 0) carryWires.push({ wire: gate.out, bit });\n    }\n    if (gate.op === 'AND') {\n      const m1 = gate.in1.match(/^[xy](\\d+)$/);\n      const m2 = gate.in2.match(/^[xy](\\d+)$/);\n      if (m1 && m2 && parseInt(m1[1], 10) === 0 && !swapped.has(gate.out)) {\n        carryWires.push({ wire: gate.out, bit: 0 });\n      }\n    }\n  }\n\n  for (const { wire, bit } of carryWires) {\n    const nextBit = bit + 1;\n    if (nextBit >= numBits) continue;\n\n    const users = consumers[wire] || [];\n    const xorUser = users.find((u) => u.op === 'XOR');\n    if (!xorUser) {\n      swapped.add(wire);\n      continue;\n    }\n\n    // The other input of the consuming XOR should be the partial sum\n    // for nextBit: i.e., output of XOR(x(nextBit), y(nextBit))\n    const otherInput = xorUser.in1 === wire ? xorUser.in2 : xorUser.in1;\n    const otherProducer = gateByOutput[otherInput];\n\n    let otherIsCorrectPartialSum = false;\n    if (otherProducer && otherProducer.op === 'XOR') {\n      const m1 = otherProducer.in1.match(/^[xy](\\d+)$/);\n      const m2 = otherProducer.in2.match(/^[xy](\\d+)$/);\n      if (m1 && m2 && m1[1] === m2[1] && parseInt(m1[1], 10) === nextBit) {\n        otherIsCorrectPartialSum = true;\n      }\n    }\n\n    if (!otherIsCorrectPartialSum) {\n      // The XOR consumer doesn't pair carry with the correct partial sum.\n      // This means either:\n      // (a) the carry wire is going to the wrong bit → carry is swapped\n      // (b) the partial sum wire is wrong → partial sum is swapped\n      //\n      // If the other input is already marked as swapped, we check if the\n      // carry should actually go to a different bit by checking the AND consumer.\n      const andUser = users.find((u) => u.op === 'AND');\n      if (andUser) {\n        const andOtherInput = andUser.in1 === wire ? andUser.in2 : andUser.in1;\n        // The AND consumer should also pair carry with the same partial sum\n        const andOtherProducer = gateByOutput[andOtherInput];\n        if (andOtherProducer && andOtherProducer.op === 'XOR') {\n          const m1 = andOtherProducer.in1.match(/^[xy](\\d+)$/);\n          const m2 = andOtherProducer.in2.match(/^[xy](\\d+)$/);\n          if (m1 && m2 && m1[1] === m2[1] && parseInt(m1[1], 10) === nextBit) {\n            // AND consumer pairs correctly → partial sum is the issue, not carry\n            // But this contradicts XOR not pairing correctly...\n            // Actually this means AND and XOR have different partners, which\n            // shouldn't happen. Both should use the same partial sum and carry.\n            // If XOR is wrong but AND is right, something else is going on.\n          }\n        }\n      }\n\n      // Check if there exists a gate that uses BOTH this carry wire AND the\n      // correct partial sum for nextBit. The partial sum is the output of\n      // XOR(x(nextBit), y(nextBit)).\n      const xNext = `x${pad(nextBit)}`;\n      const yNext = `y${pad(nextBit)}`;\n      const partialSumGate = findGate('XOR', xNext, yNext);\n      const expectedPartialSum = partialSumGate?.out;\n\n      let carryFeedsCorrectBit = false;\n      if (expectedPartialSum) {\n        // Check if any consumer of this carry also takes expectedPartialSum as input\n        for (const u of users) {\n          