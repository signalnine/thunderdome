+  });
+
+  it('should find swapped wires in an 8-bit adder', () => {
+    const gates = makeNBitAdder(8);
+    const swapped = swapOutputs(gates, [
+      ['z03', 'a03'],
+      ['z05', 'b05'],
+      ['t07', 'a07'],
+      ['c02', 'c06'],
+    ]);
+
+    const result = findSwappedWires(swapped);
+    expect(result).toEqual(['a03', 'a07', 'b05', 'c02', 'c06', 't07', 'z03', 'z05']);
+  });
+
+  it('should find swapped wires with randomized wire names', () => {
+    // Build adder with random wire names (like the real puzzle)
+    const gates = makeNBitAdderRandomNames(8);
+    // Record original names for verification
+    const wireNames = gates.map((g) => g.out);
+
+    // Pick 4 pairs to swap (using the original indices)
+    // Find specific wires by their role
+    const partialSums: string[] = []; // XOR(xNN, yNN) outputs for bit > 0
+    const generates: string[] = [];   // AND(xNN, yNN) outputs
+    const propagates: string[] = [];  // AND(partial, carry) outputs
+    const carries: string[] = [];     // OR outputs
+
+    for (const gate of gates) {
+      const m1 = gate.in1.match(/^[xy](\d+)$/);
+      const m2 = gate.in2.match(/^[xy](\d+)$/);
+      if (m1 && m2) {
+        if (gate.op === 'XOR' && parseInt(m1[1], 10) > 0) partialSums.push(gate.out);
+        if (gate.op === 'AND') generates.push(gate.out);
+      } else {
+        if (gate.op === 'AND') propagates.push(gate.out);
+        if (gate.op === 'OR') carries.push(gate.out);
+      }
+    }
+
+    // Swap: a z-wire with a generate, and two carries
+    const swaps: [string, string][] = [
+      ['z03', generates[3]],        // z03 with generate for bit 3
+      ['z05', propagates[4]],       // z05 with a propagate
+      [partialSums[6], generates[6]], // partial sum with generate for bit 7
+      [carries[1], carries[5]],     // two carries swapped
+    ];
+
+    const swappedGates = swapOutputs(gates, swaps);
+    const result = findSwappedWires(swappedGates);
+    const expected = swaps.flat().sort();
+    expect(result).toEqual(expected);
