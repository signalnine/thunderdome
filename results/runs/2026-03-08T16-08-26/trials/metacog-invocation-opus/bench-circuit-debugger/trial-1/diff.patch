p: which gates consume a wire?\n  const consumers: Record<string, Gate[]> = {};\n  for (const gate of gates) {\n    for (const inp of [gate.in1, gate.in2]) {\n      if (!consumers[inp]) consumers[inp] = [];\n      consumers[inp].push(gate);\n    }\n  }\n\n  // Determine the number of input bits\n  let maxBit = 0;\n  for (const gate of gates) {\n    for (const wire of [gate.in1, gate.in2]) {\n      const m = wire.match(/^[xy](\\d+)$/);\n      if (m) {\n        maxBit = Math.max(maxBit, parseInt(m[1], 10));\n      }\n    }\n  }\n  const numBits = maxBit + 1;\n\n  function isZ(wire: string): boolean {\n    return /^z\\d+$/.test(wire);\n  }\n\n  function pad(n: number): string {\n    return String(n).padStart(2, '0');\n  }\n\n  const swapped = new Set<string>();\n\n  // ===== Walk the adder bit by bit, tracing the carry chain =====\n\n  // Bit 0: half adder\n  // XOR(x00, y00) -> z00\n  // AND(x00, y00) -> carry_out_0\n  const xorBit0 = findGate('XOR', 'x00', 'y00');\n  const andBit0 = findGate('AND', 'x00', 'y00');\n\n  let carry: string | undefined;\n\n  if (xorBit0) {\n    if (xorBit0.out !== 'z00') {\n      swapped.add(xorBit0.out);\n      swapped.add('z00');\n    }\n  }\n\n  if (andBit0) {\n    carry = andBit0.out;\n    // carry should not be a z-wire\n    if (isZ(carry)) {\n      swapped.add(carry);\n      // We don't know the correct carry wire name, but we can still trace.\n      // The correct carry should be consumed by bit 1's XOR and AND.\n      // We'll handle this below.\n    }\n  }\n\n  // For bits 1..numBits-1: full adder\n  for (let bit = 1; bit < numBits; bit++) {\n    const xN = `x${pad(bit)}`;\n    const yN = `y${pad(bit)}`;\n    const zN = `z${pad(bit)}`;\n\n    // Step 1: Find the first-stage XOR: XOR(xN, yN) -> partial_sum\n    const xorStage1 = findGate('XOR', xN, yN);\n    // Step 2: Find the first-stage AND: AND(xN, yN) -> generate\n    const andGenerate = findGate('AND', xN, yN);\n\n    if (!xorStage1 || !andGenerate || !carry) {\n      // Can