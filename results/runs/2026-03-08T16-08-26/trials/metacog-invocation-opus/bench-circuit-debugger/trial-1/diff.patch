2 = gate.in2.match(/^[xy](\\d+)$/);\n    if (m1 && m2 && parseInt(m1[1], 10) === 0) continue; // bit 0 AND is carry, skip\n    const users = consumers[gate.out] || [];\n    if (users.length > 0 && !users.some((u) => u.op === 'OR')) {\n      swapped.add(gate.out);\n    }\n  }\n\n  // R10: Carry wires must feed into the correct next-bit gates.\n  // For each carry wire (OR output or AND(x00,y00) output), determine which bit\n  // it belongs to, then verify the XOR consumer also takes the correct partial sum.\n  //\n  // Determine bit for each OR gate by looking at its AND inputs:\n  // One AND input should be AND(xNN, yNN) → bit = NN.\n  function getOrGateBit(gate: Gate): number {\n    for (const inp of [gate.in1, gate.in2]) {\n      const producer = gateByOutput[inp];\n      if (producer && producer.op === 'AND') {\n        const m1 = producer.in1.match(/^[xy](\\d+)$/);\n        const m2 = producer.in2.match(/^[xy](\\d+)$/);\n        if (m1 && m2 && m1[1] === m2[1]) {\n          return parseInt(m1[1], 10);\n        }\n      }\n    }\n    return -1;\n  }\n\n  // Check carry wires: OR gate outputs and AND(x00,y00) output\n  const carryWires: Array<{ wire: string; bit: number }> = [];\n\n  for (const gate of gates) {\n    if (gate.op === 'OR' && !swapped.has(gate.out) && gate.out !== lastZ) {\n      const bit = getOrGateBit(gate);\n      if (bit >= 0) carryWires.push({ wire: gate.out, bit });\n    }\n    if (gate.op === 'AND') {\n      const m1 = gate.in1.match(/^[xy](\\d+)$/);\n      const m2 = gate.in2.match(/^[xy](\\d+)$/);\n      if (m1 && m2 && parseInt(m1[1], 10) === 0 && !swapped.has(gate.out)) {\n        carryWires.push({ wire: gate.out, bit: 0 });\n      }\n    }\n  }\n\n  for (const { wire, bit } of carryWires) {\n    const nextBit = bit + 1;\n    if (nextBit >= numBits) continue;\n\n    const users = consumers[wire] || [];\n    const xorUser = users.find((u) => u.op === 'XOR');\n    if (!xorUser) {\n      swapped.add(wire);\n      continue;\n    }\n\n    // The other input of the XOR should be XOR(x(nextBit), y(nextBit))\n    const otherInput = xorUser.in1 === wire ? xorUser.in2 : xorUser.in1;\n    const otherProducer = gateByOutput[otherInput];\n    if (otherProducer) {\n      if (otherProducer.op === 'XOR') {\n        const m1 = otherProducer.in1.match(/^[xy](\\d+)$/);\n        const m2 = otherProducer.in2.match(/^[xy](\\d+)$/);\n        if (m1 && m2 && m1[1] === m2[1]) {\n          const partialBit = parseInt(m1[1], 10);\n          if (partialBit !== nextBit) {\n            // Carry feeds into wrong bit's gates → carry wire is swapped\n            swapped.add(wire);\n          }\n        }\n        // If otherProducer is XOR but not a first-stage XOR, it's wrong\n        // (the second-stage XOR shouldn't be consumed by another XOR)\n        if (!(m1 && m2)) {\n          swapped.add(wire);\n        }\n      } else {\n        // otherInput is not from an XOR gate → something is wrong\n        // The carry should be paired with a partial sum (first-stage XOR output)\n        swapped.add(wire);\n      }\n    }\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[{"oldStart":209,"oldLines":14,"newStart":209,"newLines":29,"lines":["   //","   // Determine bit for each OR gate by looking at its AND inputs:","   // One AND input should be AND(xNN, yNN) → bit = NN.","+  // Determine which bit an OR gate belongs to by examining its AND inputs.","+  // The generate AND takes (xNN, yNN) and the propagate AND takes (partialSum, carry).","+  // We check both paths.","   function getOrGateBit(gate: Gate): number {","     for (const inp of [gate.in1, gate.in2]) {","       const producer = gateByOutput[inp];","-      if (producer && producer.op === 'AND') {","-        const m1 = producer.in1.match(/^[xy](\\d+)$/);","-        const m2 = producer.in2.match(/^[xy](\\d+)$/);","-        if (m1 && m2 && m1[1] === m2[1]) {","-          return parseInt(m1[1], 10);","+      if (!producer || producer.op !== 'AND') continue;","+     