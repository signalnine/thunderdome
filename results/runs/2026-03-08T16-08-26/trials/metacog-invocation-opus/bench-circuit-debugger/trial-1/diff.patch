 case 'XOR':\n            wires[gate.out] = a ^ b;\n            break;\n        }\n        remaining.splice(i, 1);\n        changed = true;\n      }\n    }\n  }\n\n  return wires;\n}\n\n/**\n * Find the 8 wires involved in 4 output-wire swaps in a binary adder circuit.\n *\n * Approach: Structural reconstruction of the ripple-carry adder.\n * Walk through each bit position, identify the gates by their roles,\n * and validate that outputs connect correctly to downstream consumers.\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Build lookup structures\n  const gateByOutput: Record<string, Gate> = {};\n  for (const gate of gates) {\n    gateByOutput[gate.out] = gate;\n  }\n\n  // Build reverse lookup: for a given wire, which gates consume it as input?\n  const consumers: Record<string, Gate[]> = {};\n  for (const gate of gates) {\n    for (const inp of [gate.in1, gate.in2]) {\n      if (!consumers[inp]) consumers[inp] = [];\n      consumers[inp].push(gate);\n    }\n  }\n\n  // Determine the number of input bits\n  let maxBit = 0;\n  for (const gate of gates) {\n    for (const wire of [gate.in1, gate.in2]) {\n      const m = wire.match(/^[xy](\\d+)$/);\n      if (m) {\n        maxBit = Math.max(maxBit, parseInt(m[1], 10));\n      }\n    }\n  }\n  const numBits = maxBit + 1;\n  const lastZ = `z${String(numBits).padStart(2, '0')}`;\n\n  const swapped = new Set<string>();\n\n  function isXY(wire: string): boolean {\n    return /^[xy]\\d+$/.test(wire);\n  }\n\n  function isZ(wire: string): boolean {\n    return /^z\\d+$/.test(wire);\n  }\n\n  function pad(n: number): string {\n    return String(n).padStart(2, '0');\n  }\n\n  // Find a gate by op and input set\n  function findGate(op: string, inputs: Set<string>): Gate | undefined {\n    return gates.find(\n      (g) =>\n        g.op === op &&\n        inputs.has(g.in1) &&\n        inputs.has(g.in2)\n    );\n  }\n\n  // Structural rules that apply to ALL gates regardless of position:\n\n  // RULE 1: Every z-wire (except possibly the last one) must be produced by an XOR gate.\n  for (let bit = 0; bit < numBits; bit++) {\n    const zWire = `z${pad(bit)}`;\n    const producer = gateByOutput[zWire];\n    if (producer && producer.op !== 'XOR') {\n      swapped.add(zWire);\n    }\n  }\n\n  // RULE 2: The last z-wire must be produced by an OR gate (it's the final carry-out).\n  // For numBits > 1. For numBits === 1, it could be AND.\n  if (numBits > 1) {\n    const producer = gateByOutput[lastZ];\n    if (producer && producer.op !== 'OR') {\n      swapped.add(lastZ);\n    }\n  }\n\n  // RULE 3: XOR gates with xNN/yNN inputs for bit > 0 must NOT output z-wire\n  // (they produce a partial sum, which gets XORed with carry)\n  for (const gate of gates) {\n    if (gate.op === 'XOR' && isXY(gate.in1) && isXY(gate.in2)) {\n      const bit = parseInt(gate.in1.slice(1), 10);\n      if (bit > 0 && isZ(gate.out)) {\n        swapped.add(gate.out);\n      }\n    }\n  }\n\n  // RULE 4: XOR gates with xNN/yNN inputs for bit 0 must output z00\n  for (const gate of gates) {\n    if (gate.op === 'XOR' && isXY(gate.in1) && isXY(gate.in2)) {\n      const bit = parseInt(gate.in1.slice(1), 10);\n      if (bit === 0 && gate.out !== 'z00') {\n        swapped.add(gate.out);\n      }\n    }\n  }\n\n  // RULE 5: Second-stage XOR gates (non-xy inputs) must output z-wires\n  for (const gate of gates) {\n    if (gate.op === 'XOR' && !(isXY(gate.in1) && isXY(gate.in2))) {\n      if (!isZ(gate.out)) {\n        swapped.add(gate.out);\n      }\n    }\n  }\n\n  // RULE 6: AND gates must NOT output z-wires\n  for (const gate of gates) {\n    if (gate.op === 'AND') {\n      if (isZ(gate.out)) {\n        swapped.add(gate.out);\n      }\n    }\n  }\n\n  // RULE 7: OR gates must NOT output z-wires except for the last bit\n  for (const gate of gates) {\n    if (gate.op === 'OR') {\n      if (isZ(gate.out) && gate.out !== lastZ) {\n        swapped.add(gate.out);\n      }\n    }\n  }\n\n  // RULE 8: OR gate inputs must come from AND gates\n  for (const gate of gates) {\n    if (gate.op === 'OR') {\n      for (const inp of [gate.in1, gate.in2]) {\n        const producer = gateByOutput[inp];\n        if (producer && producer.op !== 'AND') {\n          swapped.add(inp);\n        }\n      }\n    }\n  }\n\n  // RULE 9: First-stage XOR outputs (except bit 0) must be consumed by\n  // exactly one second-stage XOR and one AND gate. If consumed by an OR,\n  // the wire is swapped.\n  for (const gate of gates) {\n    if (gate.op === 'XOR' && isXY(gate.in1) && isXY(gate.in2)) {\n      const bit = parseInt(gate.in1.slice(1), 10);\n      if (bit > 0 && !swapped.has(gate.out)) {\n        const users = consumers[gate.out] || [];\n        const ops = users.map((u) => u.op).sort();\n        // Should be consumed by exactly one XOR and one AND\n        // If consumed by an OR, something is wrong\n        if (ops.includes('OR')) {\n          swapped.add(gate.out);\n        }\n      }\n    }\n  }\n\n  // RULE 10: AND gate outputs (non-z, non-bit0-special) should be consumed by OR gates.\n  // If an AND gate output is consumed by an XOR or AND (not OR), it's suspicious.\n  for (const gate of gates) {\n    if (gate.op === 'AND' && !swapped.has(gate.out)) {\n      // Special case: AND(x00, y00) output is the carry for bit 0,\n      // which feeds into the XOR and AND of bit 1. This is correct —\n      // it's consumed by both XOR and AND.\n      if (isXY(gate.in1) && isXY(gate.in2)) {\n        const bit = parseInt(gate.in1.slice(1), 10);\n        if (bit === 0) continue; // bit 0 carry is consumed by XOR+AND of bit 1\n      }\n      // For other AND gates, output should feed into an OR gate\n      const users = consumers[gate.out] || [];\n      if (users.length > 0) {\n        const hasOR = users.some((u) => u.op === 'OR');\n        if (!hasOR) {\n          swapped.add(gate.out);\n        }\n      }\n    }\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[{"oldStart":47,"oldLines