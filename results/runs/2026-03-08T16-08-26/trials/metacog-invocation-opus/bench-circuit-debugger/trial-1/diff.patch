+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+/**
+ * Simulate a circuit of logic gates given initial wire values.
+ * Gates are processed in dependency order (topological sort).
+ */
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+
+  let changed = true;
+  while (remaining.length > 0 && changed) {
+    changed = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        switch (gate.op) {
+          case 'AND':
+            wires[gate.out] = a & b;
+            break;
+          case 'OR':
+            wires[gate.out] = a | b;
+            break;
+          case 'XOR':
+            wires[gate.out] = a ^ b;
+            break;
+        }
+        remaining.splice(i, 1);
+        changed = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+/**
+ * Find the 8 wires involved in 4 output-wire swaps in a binary adder circuit.
+ *
+ * Uses a combination of:
+ * 1. Global structural rules (gate type vs output naming constraints)
+ * 2. Local connectivity rules (each gate's output should be consumed correctly)
+ * 3. Carry chain walk (verify carry propagation through the adder)
+ */
+export function findSwappedWires(gates: Gate[]): string[] {
+  const gateByOutput: Record<string, Gate> = {};
+  for (const gate of gates) {
+    gateByOutput[gate.out] = gate;
+  }
+
+  // Reverse lookup: which gates consume a given wire as input?
+  const consumers: Record<string, Gate[]> = {};
+  for (const gate of gates) {
+    for (const inp of [gate.in1, gate.in2]) {
+      if (!consumers[inp]) consumers[inp] = [];
+      consumers[inp].push(gate);
+    }
+  }
+
+  let maxBit = 0;
+  for (const gate of gates) {
+    for (const wire of [gate.in1, gate.in2]) {
+      const m = wire.match(/^[xy](\d+)$/);
+      if (m) maxBit = Math.max(maxBit, parseInt(m[1], 10));
+    }
+  }
+  const numBits = maxBit + 1;
+  const lastZ = `z${String(numBits).padStart(2, '0')}`;
+
+  function isZ(w: string): boolean {
+    return /^z\d+$/.test(w);
+  }
+
+  function pad(n: number): string {
+    return String(n).padStart(2, '0');
+  }
+
+  const swapped = new Set<string>();
+
+  // ============ GLOBAL STRUCTURAL RULES ============
+  // These rules can identify swaps purely based on gate type and output wire name.
+
+  // R1: z00..z(N-1) must be produced by XOR gates
+  for (let bit = 0; bit < numBits; bit++) {
+    const zWire = `z${pad(bit)}`;
+    const producer = gateByOutput[zWire];
+    if (producer && producer.op !== 'XOR') {
+      swapped.add(zWire);
+    }
+  }
+
+  // R2: z(N) (last z, the final carry) must be produced by OR (for N>1)
+  if (numBits > 1) {
+    const producer = gateByOutput[lastZ];
+    if (producer && producer.op !== 'OR') {
+      swapped.add(lastZ);
+    }
+  }
+
+  // R3: First-stage XOR (xNN XOR yNN, bit>0) must NOT output z-wire
+  for (const gate of gates) {
+    if (gate.op !== 'XOR') continue;
+    const m1 = gate.in1.match(/^[xy](\d+)$/);
+    const m2 = gate.in2.match(/^[xy](\d+)$/);
+    if (m1 && m2 && m1[1] === m2[1]) {
+      const bit = parseInt(m1[1], 10);
+      if (bit > 0 && isZ(gate.out)) {
+        swapped.add(gate.out);
+      }
+      if (bit === 0 && gate.out !== 'z00') {
+        swapped.add(gate.out);
+        swapped.add('z00');
+      }
+    }
+  }
+
+  // R4: Second-stage XOR (non-xy inputs) must output z-wire
+  for (const gate of gates) {
+    if (gate.op !== 'XOR') continue;
+    const m1 = gate.in1.match(/^[xy]\d+$/);
+    const m2 = gate.in2.match(/^[xy]\d+$/);
+    if (!(m1 && m2)) {
+      if (!isZ(gate.out)) {
+        swapped.add(gate.out);
+      }
+    }
+  }
+
+  // R5: AND outputs must NOT be z-wires
+  for (const gate of gates) {
+    if (gate.op === 'AND' && isZ(gate.out)) {
+      swapped.add(gate.out);
+    }
+  }
+
+  // R6: OR outputs must NOT be z-wires (except lastZ)
+  for (const gate of gates) {
+    if (gate.op === 'OR' && isZ(gate.out) && gate.out !== lastZ) {
+      swapped.add(gate.out);
+    }
+  }
+
+  // ============ LOCAL CONNECTIVITY RULES ============
+
+  // R7: OR gate inputs must come from AND gates
+  for (const gate of gates) {
+    if (gate.op !== 'OR') continue;
+    for (const inp of [gate.in1, gate.in2]) {
+      const producer = gateByOutput[inp];
+      if (producer && producer.op !== 'AND') {
+        swapped.add(inp);
+      }
+    }
+  }
+
+  // R8: First-stage XOR outputs (bit > 0) should be consumed by XOR and AND only
+  for (const gate of gates) {
+    if (gate.op !== 'XOR') continue;
+    const m1 = gate.in1.match(/^[xy](\d+)$/);
+    const m2 = gate.in2.match(/^[xy](\d+)$/);
+    if (m1 && m2 && m1[1] === m2[1] && parseInt(m1[1], 10) > 0) {
+      if (!swapped.has(gate.out)) {
+        const users = consumers[gate.out] || [];
+        if (users.some((u) => u.op === 'OR')) {
+          swapped.add(gate.out);
+        }
+      }
+    }
+  }
+
+  // R9: Non-bit0 AND outputs should feed into an OR gate
+  for (const gate of gates) {
+    if (gate.op !== 'AND' || swapped.has(gate.out)) continue;
+    const m1 = gate.in1.match(/^[xy](\d+)$/);
+    const m2 = gate.in2.match(/^[xy](\d+)$/);
+    if (m1 && m2 && parseInt(m1[1], 10) === 0) continue; // bit 0 AND is carry, skip
+    const users = consumers[gate.out] || [];
+    if (users.length > 0 && !users.some((u) => u.op === 'OR')) {
+      swapped.add(gate.out);
+    }
+  }
+
+  if (swapped.size >= 8) return [...swapped].sort();
+
+  // R10: Carry wires must feed into the correct next-bit gates.
+  // For each carry wire (OR output or AND(x00,y00) output), determine which bit
+  // it belongs to, then verify the XOR consumer also takes the correct partial sum.
+  //
+  // Determine bit for each OR gate by looking at its AND inputs:
+  // One AND input should be AND(xNN, yNN) → bit = NN.
+  // Determine which bit an OR gate belongs to by examining its AND inputs.
+  // The generate AND takes (xNN, yNN) and the propagate AND takes (partialSum, carry).
+  // We check both paths.
+  function getOrGateBit(gate: Gate): number {
+    for (const inp of [gate.in1, gate.in2]) {
+      const producer = gateByOutput[inp];
+      if (!producer || producer.op !== 'AND') continue;
+      // Check if it's the generate AND: AND(xNN, yNN)
+      const m1 = producer.in1.match(/^[xy](\d+)$/);
+      const m2 = producer.in2.match(/^[xy](\d+)$/);
+      if (m1 && m2 && m1[1] === m2[1]) {
+        return parseInt(m1[1], 10);
+      }
+      // Check if it's the propagate AND: AND(partialSum, carry)
+      // The partialSum input should be from XOR(xNN, yNN)
+      for (const andInp of [producer.in1, producer.in2]) {
+        const xorGate = gateByOutput[andInp];
+        if (xorGate && xorGate.op === 'XOR') {
+          const xm1 = xorGate.in1.match(/^[xy](\d+)$/);
+          const xm2 = xorGate.in2.match(/^[xy](\d+)$/);
+          if (xm1 && xm2 && xm1[1] === xm2[1]) {
+            return parseInt(xm1[1], 10);
+          }
+        }
+      }
+    }
+    return -1;
+  }
+
+  // Check carry wires: OR gate outputs and AND(x00,y00) output
+  const carryWires: Array<{ wire: string; bit: number }> = [];
+
+  for (const gate of gates) {
+    if (gate.op === 'OR' && !swapped.has(gate.out) && gate.out !== lastZ) {
+      const bit = getOrGateBit(gate);
+      if (bit >= 0) carryWires.push({ wire: gate.out, bit });
+    }
+    if (gate.op === 'AND') {
+      const m1 = gate.in1.match(/^[xy](\d+)$/);
+      const m2 = gate.in2.match(/^[xy](\d+)$/);
+      if (m1 && m2 && parseInt(m1[1], 10) === 0 && !swapped.has(gate.out)) {
+        carryWires.push({ wire: gate.out, bit: 0 });
+      }
+    }
+  }
+
+  for (const { wire, bit } of carryWires) {
+    const nextBit = bit + 1;
+    if (nextBit >= numBits) continue;
+
+    const users = consumers[wire] || [];
+    const xorUser = users.find((u) => u.op === 'XOR');
+    if (!xorUser) {
+      swapped.add(wire);
+      continue;
+    }
+
+    // The other input of the consuming XOR should be the partial sum
+    // for nextBit: i.e., output of XOR(x(nextBit), y(nextBit))
+    const otherInput = xorUser.in1 === wire ? xorUser.in2 : xorUser.in1;
+    const otherProducer = gateByOutput[otherInput];
+
+    let otherIsCorrectPartialSum = false;
+    if (otherProducer && otherProducer.op === 'XOR') {
+      const m1 = otherProducer.in1.match(/^[xy](\d+)$/);
+      const m2 = otherProducer.in2.match(/^[xy](\d+)$/);
+      if (m1 && m2 && m1[1] === m2[1] && parseInt(m1[1], 10) === nextBit) {
+        otherIsCorrectPartialSum = true;
+      }
+    }
+
+    if (!otherIsCorrectPartialSum) {
+      // The consumers' other input doesn't match the expected partial sum.
+      // Determine if the carry feeds into the correct bit position.
+      //
+      // Key insight: if the carry's XOR consumer outputs z(nextBit),
+      // the carry is feeding into the correct bit position. The issue is
+      // with the partial sum, not the carry.
+      let carryAtCorrectBit = false;
+
+      // Check 1: Does the carry's XOR consumer output z(nextBit)?
+      const expectedZ = `z${pad(nextBit)}`;
+      if (xorUser.out === expectedZ) {
+        carryAtCorrectBit = true;
+      }
+
+      // Check 2: Does the carry's XOR consumer output a wire that is
+      // already known to be swapped AND the expected z-wire for nextBit
+      // is also swapped? (e.g., if z05 was swapped with something else,
+      // the XOR outputs the swap partner instead)
+      if (!carryAtCorrectBit && swapped.has(xorUser.out) && swapped.has(expectedZ)) {
+        // The XOR's output and z(nextBit) are both swapped — they might be partners
+        carryAtCorrectBit = true;
+      }
+
+      // Check 3: If the XOR consumer outputs neither z(nextBit) nor a known-swapped
+      // wire, check if the output is z(M) for some M. If M matches the producer's
+      // bit, the carry is correct for that bit.
+      if (!carryAtCorrectBit) {
+        const zMatch = xorUser.out.match(/^z(\d+)$/);
+        if (zMatch) {
+          const zBit = parseInt(zMatch[1], 10);
+          if (zBit === nextBit) {
+            carryAtCorrectBit = true;
+          }
+        }
+      }
+
+      // Check 4: For cases where the second-stage XOR output is swapped away
+      // from being a z-wire, check if the consumer belongs to the correct bit
+      // by examining the other input. If the other input is produced by (or was
+      // originally produced by) a gate with x(nextBit)/y(nextBit) inputs:
+      if (!carryAtCorrectBit) {
+        const otherProd = gateByOutput[otherInput];
+        if (otherProd) {
+          const m1 = otherProd.in1.match(/^[xy](\d+)$/);
+          const m2 = otherProd.in2.match(/^[xy](\d+)$/);
+          if (m1 && m2 && m1[1] === m2[1]) {
+            if (parseInt(m1[1], 10) === nextBit) {
+              carryAtCorrectBit = true;
+            }
+          }
+        }
+      }
+
+      // Check 5: Find all output wire names from gates with nextBit xy inputs.
+      // Check if otherInput matches any of these (handles case where partial
+      // sum output name matches because it wasn't swapped, just wrong gate type).
+      if (!carryAtCorrectBit) {
+        const xNext = `x${pad(nextBit)}`;
+        const yNext = `y${pad(nextBit)}`;
+        for (const g of gates) {
+          const gInputs = new Set([g.in1, g.in2]);
+          if (gInputs.has(xNext) && gInputs.has(yNext)) {
+            if (g.out === otherInput) {
+              carryAtCorrectBit = true;
+              break;
+            }
+          }
+        }
+      }
+
+      if (!carryAtCorrectBit) {
+        swapped.add(wire);
+      }
+    }
+  }
+
+  return [...swapped].sort();
+}
