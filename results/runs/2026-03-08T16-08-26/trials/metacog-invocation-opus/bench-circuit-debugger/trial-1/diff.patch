utput should be consumed correctly)\n * 3. Carry chain walk (verify carry propagation through the adder)\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  const gateByOutput: Record<string, Gate> = {};\n  for (const gate of gates) {\n    gateByOutput[gate.out] = gate;\n  }\n\n  // Index: for a sorted pair of input wires, find all gates with those inputs\n  const gatesByInputPair: Map<string, Gate[]> = new Map();\n  for (const gate of gates) {\n    const key = [gate.in1, gate.in2].sort().join(',');\n    if (!gatesByInputPair.has(key)) gatesByInputPair.set(key, []);\n    gatesByInputPair.get(key)!.push(gate);\n  }\n\n  function findGate(op: string, a: string, b: string): Gate | undefined {\n    const key = [a, b].sort().join(',');\n    return gatesByInputPair.get(key)?.find((g) => g.op === op);\n  }\n\n  // Reverse lookup: which gates consume a given wire as input?\n  const consumers: Record<string, Gate[]> = {};\n  for (const gate of gates) {\n    for (const inp of [gate.in1, gate.in2]) {\n      if (!consumers[inp]) consumers[inp] = [];\n      consumers[inp].push(gate);\n    }\n  }\n\n  let maxBit = 0;\n  for (const gate of gates) {\n    for (const wire of [gate.in1, gate.in2]) {\n      const m = wire.match(/^[xy](\\d+)$/);\n      if (m) maxBit = Math.max(maxBit, parseInt(m[1], 10));\n    }\n  }\n  const numBits = maxBit + 1;\n  const lastZ = `z${String(numBits).padStart(2, '0')}`;\n\n  function isZ(w: string): boolean {\n    return /^z\\d+$/.test(w);\n  }\n\n  function pad(n: number): string {\n    return String(n).padStart(2, '0');\n  }\n\n  const swapped = new Set<string>();\n\n  // ============ GLOBAL STRUCTURAL RULES ============\n  // These rules can identify swaps purely based on gate type and output wire name.\n\n  // R1: z00..z(N-1) must be produced by XOR gates\n  for (let bit = 0; bit < numBits; bit++) {\n    const zWire = `z${pad(bit)}`;\n    const producer = gateByOutput[zWire];\n    if (producer && producer.op !== 'XOR') {\n      swapped.add(zWire);\n    }\n  }\n\n  // R2: z(N) (last z, the final carry) must be produced by OR (for N>1)\n  if (numBits > 1) {\n    const producer = gateByOutput[lastZ];\n    if (producer && producer.op !== 'OR') {\n      swapped.add(lastZ);\n    }\n  }\n\n  // R3: First-stage XOR (xNN XOR yNN, bit>0) must NOT output z-wire\n  for (const gate of gates) {\n    if (gate.op !== 'XOR') continue;\n    const m1 = gate.in1.match(/^[xy](\\d+)$/);\n    const m2 = gate.in2.match(/^[xy](\\d+)$/);\n    if (m1 && m2 && m1[1] === m2[1]) {\n      const bit = parseInt(m1[1], 10);\n      if (bit > 0 && isZ(gate.out)) {\n        swapped.add(gate.out);\n      }\n      if (bit === 0 && gate.out !== 'z00') {\n        swapped.add(gate.out);\n        swapped.add('z00');\n      }\n    }\n  }\n\n  // R4: Second-stage XOR (non-xy inputs) must output z-wire\n  for (const gate of gates) {\n    if (gate.op !== 'XOR') continue;\n    const m1 = gate.in1.match(/^[xy]\\d+$/);\n    const m2 = gate.in2.match(/^[xy]\\d+$/);\n    if (!(m1 && m2)) {\n      if (!isZ(gate.out)) {\n        swapped.add(gate.out);\n      }\n    }\n  }\n\n  // R5: AND outputs must NOT be z-wires\n  for (const gate of gates) {\n    if (gate.op === 'AND' && isZ(gate.out)) {\n      swapped.add(gate.out);\n    }\n  }\n\n  // R6: OR outputs must NOT be z-wires (except lastZ)\n  for (const gate of gates) {\n    if (gate.op === 'OR' && isZ(gate.out) && gate.out !== lastZ) {\n      swapped.add(gate.out);\n    }\n  }\n\n  // ============ LOCAL CONNECTIVITY RULES ============\n\n  // R7: OR gate inputs must come from AND gates\n  for (const gate of gates) {\n    if (gate.op !== 'OR') continue;\n    for (const inp of [gate.in1, gate.in2]) {\n      const producer = gateByOutput[inp];\n      if (producer && producer.op !== 'AND') {\n        swapped.add(inp);\n      }\n    }\n  }\n\n  // R8: First-stage XOR outputs (bit > 0) should be consumed by XOR and AND only\n  for (const gate of gates) {\n    if (gate.op !== 'XOR') continue;\n    cons