export interface Gate {\n  op: 'AND' | 'OR' | 'XOR';\n  in1: string;\n  in2: string;\n  out: string;\n}\n\n/**\n * Simulate a circuit of logic gates given initial wire values.\n * Gates are processed in dependency order (topological sort).\n */\nexport function simulate(\n  gates: Gate[],\n  inputs: Record<string, number>\n): Record<string, number> {\n  const wires: Record<string, number> = { ...inputs };\n  const remaining = [...gates];\n\n  let changed = true;\n  while (remaining.length > 0 && changed) {\n    changed = false;\n    for (let i = remaining.length - 1; i >= 0; i--) {\n      const gate = remaining[i];\n      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {\n        const a = wires[gate.in1];\n        const b = wires[gate.in2];\n        switch (gate.op) {\n          case 'AND':\n            wires[gate.out] = a & b;\n            break;\n          case 'OR':\n            wires[gate.out] = a | b;\n            break;\n          case 'XOR':\n            wires[gate.out] = a ^ b;\n            break;\n        }\n        remaining.splice(i, 1);\n        changed = true;\n      }\n    }\n  }\n\n  return wires;\n}\n\n/**\n * Find the 8 wires involved in 4 output-wire swaps in a binary adder circuit.\n *\n * Approach: Combine structural rule checking with simulation-based verification.\n *\n * Phase 1: Apply structural rules that catch most swap types.\n * Phase 2: Use targeted simulation to find remaining swaps that structural\n *          rules miss (e.g., carry wires swapped between bit positions).\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  const gateByOutput: Record<string, Gate> = {};\n  for (const gate of gates) {\n    gateByOutput[gate.out] = gate;\n  }\n\n  const consumers: Record<string, Gate[]> = {};\n  for (const gate of gates) {\n    for (const inp of [gate.in1, gate.in2]) {\n      if (!consumers[inp]) consumers[inp] = [];\n      consumers[inp].push(gate);\n    }\n  }\n\n  let maxBit = 0;\n  for (const gate of gates) {\n    for (const wire of [gate.in1, gate.in2]) {\n      const m = wire.match(/^[xy](\\d+)$/);\n      if (m) {\n        maxBit = Math.max(maxBit, parseInt(m[1], 10));\n      }\n    }\n  }\n  const numBits = maxBit + 1;\n  const lastZ = `z${String(numBits).padStart(2, '0')}`;\n\n  const swapped = new Set<string>();\n\n  function isXY(wire: string): boolean {\n    return /^[xy]\\d+$/.test(wire);\n  }\n\n  function isZ(wire: string): boolean {\n    return /^z\\d+$/.test(wire);\n  }\n\n  function pad(n: number): string {\n    return String(n).padStart(2, '0');\n  }\n\n  function findGateByOpAndInputs(op: string, in1: string, in2: string): Gate | undefined {\n    return gates.find(\n      (g) =>\n        g.op === op &&\n        ((g.in1 === in1 && g.in2 === in2) || (g.in1 === in2 && g.in2 === in1))\n    );\n  }\n\n  // ========== PHASE 1: Structural rules ==========\n\n  // RULE 1: z-wires (except last) must be produced by XOR gates\n  for (let bit = 0; bit < numBits; bit++) {\n    const zWire = `z${pad(bit)}`;\n    const producer = gateByOutput[zWire];\n    if (producer && producer.op !== 'XOR') {\n      swapped.add(zWire);\n    }\n  }\n\n  // RULE 2: Last z-wire must be produced by OR gate (final carry)\n  if (numBits > 1) {\n    const producer = gateByOutput[lastZ];\n    if (producer && producer.op !== 'OR') {\n      swapped.add(lastZ);\n    }\n  }\n\n  // RULE 3: First-stage XOR (xNN XOR yNN) for bit > 0 must NOT output z-wire\n  for (const gate of gates) {\n    if (gate.op === 'XOR' && isXY(gate.in1) && isXY(gate.in2)) {\n      const bit = parseInt(gate.in1.slice(1), 10);\n      if (bit > 0 && isZ(gate.out)) {\n        swapped.add(gate.out);\n      }\n    }\n  }\n\n  // RULE 4: First-stage XOR for bit 0 must output z00\n  for (const gate of gates) {\n    if (gate.op === 'XOR' && isXY(gate.in1) && isXY(gate.in2)) {\n      const bit = parseInt(gate.in1.slice(1), 10);\n      if (bit === 0 && gate.out !== 'z00') {\n        swapped.add(gate.out);\n      }\n    }\n  }\n\n  // RULE 5: Second-stage XOR (non-xy inputs) must output z-wire\n  for (const gate of gates) {\n    if (gate.op === 'XOR' && !(isXY(gate.in1) && isXY(gate.in2))) {\n      if (!isZ(gate.out)) {\n        swapped.add(gate.out);\n      }\n    }\n  }\n\n  // RULE 6: AND gates must NOT output z-wires\n  for (const gate of gates) {\n    if (gate.op === 'AND' && isZ(gate.out)) {\n      swapped.add(gate.out);\n    }\n  }\n\n  // RULE 7: OR gates must NOT output z-wires except last\n  for (const gate of gates) {\n    if (gate.op === 'OR' && isZ(gate.out) && gate.out !== lastZ) {\n      swapped.add(gate.out);\n    }\n  }\n\n  // RULE 8: OR gate inputs must come from AND gates\n  for (const gate of gates) {\n    if (gate.op === 'OR') {\n      for (const inp of [gate.in1, gate.in2]) {\n        const producer = gateByOutput[inp];\n        if (producer && producer.op !== 'AND') {\n          swapped.add(inp);\n        }\n      }\n    }\n  }\n\n  // RULE 9: First-stage XOR outputs (bit > 0) should be consumed by XOR and AND, not OR\n  for (const gate of gates) {\n    if (gate.op === 'XOR' && isXY(gate.in1) && isXY(gate.in2)) {\n      const bit = parseInt(gate.in1.slice(1), 10);\n      if (bit > 0 && !swapped.has(gate.out)) {\n        const users = consumers[gate.out] || [];\n        if (users.some((u) => u.op === 'OR')) {\n          swapped.add(gate.out);\n        }\n      }\n    }\n  }\n\n  // RULE 10: Non-bit0 AND outputs should be consumed by an OR gate\n  for (const gate of gates) {\n    if (gate.op === 'AND' && !swapped.has(gate.out)) {\n      if (isXY(gate.in1) && isXY(gate.in2)) {\n        const bit = parseInt(gate.in1.slice(1), 10);\n        if (bit === 0) continue;\n      }\n      const users = consumers[gate.out] || [];\n      if (users.length > 0 && !users.some((u) => u.op === 'OR')) {\n        swapped.add(gate.out);\n      }\n    }\n  }\n\n  // If we already found 8, we're done\n  if (swapped.size === 8) {\n    return [...swapped].sort();\n  }\n\n  // ========== PHASE 2: Simulation-based verification ==========\n  // Test each bit position independently to find remaining swaps.\n  // For each bit, we set specific inputs and check if the output matches.\n  // If a bit produces wrong output, we look at which wires are involved.\n\n  // First, apply all known swaps in reverse to get a partially-fixed circuit\n  // Actually, let's use a different approach: test per-bit correctness.\n\n  // For each bit position, test the adder with carefully chosen inputs\n  // that isolate that bit's behavior.\n  function testBit(bit: number): boolean {\n    // Test: set only this bit's x and y to 1, all others to 0\n    // Expected: if bit 0, z00=0, z01=1 (carry). If bit N, similar propagation.\n    // Actually, a simpler test: set x=2^bit, y=0. Result should be z=2^bit.\n    const inputs: Record<string, number> = {};\n    for (let i = 0; i < numBits; i++) {\n      inputs[`x${pad(i)}`] = i === bit ? 1 : 0;\n      inputs[`y${pad(i)}`] = 0;\n    }\n    const result = simulate(gates, inputs);\n    // z should be 2^bit, so z[bit] = 1, all others = 0\n    for (let i = 0; i <= numBits; i++) {\n      const expected = i === bit ? 1 : 0;\n      if ((result[`z${pad(i)}`] ?? 0) !== expected) return false;\n    }\n    return true;\n  }\n\n  // Find which bits are broken\n  const brokenBits: number[] = [];\n  for (let bit = 0; bit < numBits; bit++) {\n    if (!testBit(bit)) {\n      brokenBits.push(bit);\n    }\n  }\n\n  // For each pair of broken bits, try swapping each pair of gate outputs\n  // involving those bits to find the fix.\n  if (swapped.size < 8 && brokenBits.length > 0) {\n    // Collect all gate outputs that are involved in the broken bits' computation\n    // (i.e., gates that are reachable from the broken z-wires)\n    function getAncestorWires(wire: string, visited: Set<string>): void {\n      if (visited.has(wire) || isXY(wire)) return;\n      visited.add(wire);\n      const producer = gateByOutput[wire];\n      if (producer) {\n        getAncestorWires(producer.in1, visited);\n        getAncestorWires(producer.in2, visited);\n      }\n    }\n\n    // Get all wires involved in broken bit computations\n    const involvedWires = new Set<string>();\n    for (const bit of brokenBits) {\n      getAncestorWires(`z${pad(bit)}`, involvedWires);\n    }\n    // Also include z-wires for broken bits\n    for (const bit of brokenBits) {\n      involvedWires.add(`z${pad(bit)}`);\n    }\n\n    // Try swapping pairs of outputs among involved wires\n    const wireList = [...involvedWires].filter((w) => !swapped.has(w));\n\n    // We need to find the remaining swaps (4 - swapped.size/2 pairs)\n    const remainingPairs = 4 - swapped.size / 2;\n\n    if (remainingPairs > 0) {\n      // Try each pair of wires in the involved set\n      for (let i = 0; i < wireList.length; i++) {\n        for (let j = i + 1; j < wireList.length; j++) {\n          const w1 = wireList[i];\n          const w2 = wireList[j];\n\n          // Try swapping w1 and w2\n          const testGates = gates.map((g) => ({\n            ...g,\n            out: g.out === w1 ? w2 : g.out === w2 ? w1 : g.out,\n          }));\n\n          // Re-apply existing swaps too\n          // Actually, since we're testing against the original circuit,\n          // and the existing swaps are already in the circuit,\n          // we just need to test if this additional swap fixes some broken bits.\n\n          // Quick check: does this swap fix at least one broken bit?\n          let fixesSomething = false;\n          for (const bit of brokenBits) {\n            const inputs: Record<string, number> = {};\n            for (let k = 0; k < numBits; k++) {\n              inputs[`x${pad(k)}`] = k === bit ? 1 : 0;\n              inputs[`y${pad(k)}`] = 0;\n            }\n            const result = simulate(testGates, inputs);\n            let correct = true;\n            for (let k = 0; k <= numBits; k++) {\n              const expected = k === bit ? 1 : 0;\n              if ((result[`z${pad(k)}`] ?? 0) !== expected) {\n                correct = false;\n                break;\n              }\n            }\n            // Check original\n            const origResult = simulate(gates, inputs);\n            let origCorrect = true;\n            for (let k = 0; k <= numBits; k++) {\n              const expected = k === bit ? 1 : 0;\n              if ((origResult[`z${pad(k)}`] ?? 0) !== expected) {\n                origCorrect = false;\n                break;\n              }\n            }\n            if (correct && !origCorrect) {\n              fixesSomething = true;\n            }\n          }\n\n          if (fixesSomething) {\n            // Validate more thoroughly: test multiple inputs\n            let allGood = true;\n            const testCases = [\n              [0, 0],\n              [1, 1],\n              [(1 << numBits) - 1, 1],\n              [(1 << numBits) - 1, (1 << numBits) - 1],\n            ];\n            for (const [x, y] of testCases) {\n              const inputs: Record<string, number> = {};\n              for (let k = 0; k < numBits; k++) {\n                inputs[`x${pad(k)}`] = (x >> k) & 1;\n                inputs[`y${pad(k)}`] = (y >> k) & 1;\n              }\n              const result = simulate(testGates, inputs);\n              let actual = 0;\n              for (let k = 0; k <= numBits; k++) {\n                actual |= (result[`z${pad(k)}`] ?? 0) << k;\n              }\n              if (actual !== x + y) {\n                allGood = false;\n                break;\n              }\n            }\n            // Even if not all good, this might be one of the swap pairs\n            // (other swaps might still be needed)\n            if (fixesSomething) {\n              swapped.add(w1);\n              swapped.add(w2);\n              if (swapped.size >= 8) break;\n            }\n          }\n        }\n        if (swapped.size >= 8) break;\n      }\n    }\n  }\n\n  return [...swapped].sort();\n}\n"}}
