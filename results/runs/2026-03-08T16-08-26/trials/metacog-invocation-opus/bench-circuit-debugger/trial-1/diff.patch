+// --- Helpers ---
+
+function makeNBitAdder(bits: number): Gate[] {
+  const gates: Gate[] = [];
+
+  gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });
+  gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });
+
+  for (let i = 1; i < bits; i++) {
+    const p = String(i).padStart(2, '0');
+    const pp = String(i - 1).padStart(2, '0');
+    gates.push({ op: 'XOR', in1: `x${p}`, in2: `y${p}`, out: `t${p}` });
+    gates.push({ op: 'XOR', in1: `t${p}`, in2: `c${pp}`, out: `z${p}` });
+    gates.push({ op: 'AND', in1: `x${p}`, in2: `y${p}`, out: `a${p}` });
+    gates.push({ op: 'AND', in1: `t${p}`, in2: `c${pp}`, out: `b${p}` });
+    gates.push({ op: 'OR', in1: `a${p}`, in2: `b${p}`, out: `c${p}` });
+  }
+
+  const lastPad = String(bits - 1).padStart(2, '0');
+  const outPad = String(bits).padStart(2, '0');
+  for (const gate of gates) {
+    if (gate.op === 'OR' && gate.out === `c${lastPad}`) {
+      gate.out = `z${outPad}`;
+    }
+  }
+
+  return gates;
+}
+
+function makeNBitAdderRandomNames(bits: number): Gate[] {
+  // Build adder with random 3-letter wire names for intermediate wires
+  let nameCounter = 0;
+  function randomName(): string {
+    const n = nameCounter++;
+    const a = String.fromCharCode(97 + (n % 26));
+    const b = String.fromCharCode(97 + (Math.floor(n / 26) % 26));
+    const c = String.fromCharCode(97 + (Math.floor(n / 676) % 26));
+    return `${c}${b}${a}`;
+  }
+
+  const gates: Gate[] = [];
+
+  gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });
+  const carry0 = randomName();
+  gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: carry0 });
+
+  let prevCarry = carry0;
+
+  for (let i = 1; i < bits; i++) {
+    const p = String(i).padStart(2, '0');
+    const partialSum = randomName();
+    const generate = randomName();
+    const propagate = randomName();
+
+    gates.push({ op: 'XOR', in1: `x${p}`, in2: `y${p}`, out: partialSum });
+    gates.push({ op: 'XOR', in1: partialSum, in2: prevCarry, out: `z${p}` });
+    gates.push({ op: 'AND', in1: `x${p}`, in2: `y${p}`, out: generate });
+    gates.push({ op: 'AND', in1: partialSum, in2: prevCarry, out: propagate });
+
+    if (i === bits - 1) {
+      // Last bit: carry-out is the final z-wire
+      gates.push({ op: 'OR', in1: generate, in2: propagate, out: `z${String(bits).padStart(2, '0')}` });
+      prevCarry = `z${String(bits).padStart(2, '0')}`;
+    } else {
+      const carry = randomName();
+      gates.push({ op: 'OR', in1: generate, in2: propagate, out: carry });
+      prevCarry = carry;
+    }
+  }
+
+  return gates;
+}
+
+function makeInputs(bits: number, x: number, y: number): Record<string, number> {
+  const inputs: Record<string, number> = {};
+  for (let i = 0; i < bits; i++) {
+    const p = String(i).padStart(2, '0');
+    inputs[`x${p}`] = (x >> i) & 1;
+    inputs[`y${p}`] = (y >> i) & 1;
+  }
+  return inputs;
+}
+
+function expectSum(result: Record<string, number>, bits: number, expected: number) {
+  let actual = 0;
+  for (let i = 0; i <= bits; i++) {
+    const p = String(i).padStart(2, '0');
+    const bit = result[`z${p}`];
+    expect(bit).toBeDefined();
+    actual |= (bit << i);
+  }
+  expect(actual).toBe(expected);
+}
+
+function swapOutputs(gates: Gate[], swaps: [string, string][]): Gate[] {
+  const swapMap: Record<string, string> = {};
+  for (const [a, b] of swaps) {
+    swapMap[a] = b;
+    swapMap[b] = a;
+  }
+
+  return gates.map((gate) => ({
+    ...gate,
+    out: swapMap[gate.out] ?? gate.out,
+  }));
+}
