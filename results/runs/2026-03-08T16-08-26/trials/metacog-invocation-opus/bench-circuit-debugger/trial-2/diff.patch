+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+/**
+ * Simulate a circuit: given gates and initial wire values, compute all wire values.
+ */
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>,
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+
+  let changed = true;
+  while (remaining.length > 0 && changed) {
+    changed = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        let result: number;
+        switch (gate.op) {
+          case 'AND':
+            result = a & b;
+            break;
+          case 'OR':
+            result = a | b;
+            break;
+          case 'XOR':
+            result = a ^ b;
+            break;
+        }
+        wires[gate.out] = result;
+        remaining.splice(i, 1);
+        changed = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+/**
+ * Find the 8 wires involved in 4 output-wire swaps in a ripple-carry adder circuit.
+ *
+ * Strategy: A correct ripple-carry adder has strict structural invariants for each gate
+ * based on its operation type and the provenance of its inputs. We check these rules
+ * and collect violations.
+ */
+export function findSwappedWires(gates: Gate[]): string[] {
+  // Find the number of input bits by looking at x-wires
+  const xWires = gates
+    .flatMap((g) => [g.in1, g.in2])
+    .filter((w) => w.startsWith('x'));
+  const numBits =
+    Math.max(...xWires.map((w) => parseInt(w.slice(1), 10))) + 1;
+
+  // The highest z bit
+  const highestZ = `z${String(numBits).padStart(2, '0')}`;
+
+  const swapped = new Set<string>();
+
+  // Helper: check if both inputs of a gate are x/y wires (for the same bit)
+  function hasXYInputs(g: Gate): boolean {
+    return (
+      (g.in1.startsWith('x') && g.in2.startsWith('y')) ||
+      (g.in1.startsWith('y') && g.in2.startsWith('x'))
+    );
+  }
+
+  // Structural rules for a ripple-carry adder:
+  //
+  // Rule 1: XOR gates with x/y inputs (partial sum generators) should NOT output to z
+  //         (except for bit 0 where XOR(x00,y00)->z00 is correct)
+  // Rule 2: XOR gates that output to z should have non-x/y inputs (they combine partial sum with carry)
+  // Rule 3: The only gates that should output to z are XOR gates (except the highest z bit)
+  // Rule 4: AND gates should never output to z
+  // Rule 5: OR gates should never output to z (except possibly the highest bit)
+  // Rule 6: XOR gates with non-x/y inputs that DON'T output to z are suspicious —
+  //         they should be producing a z output
+  // Rule 7: The output of XOR(x,y) for bit>0 should feed into exactly one XOR and one AND
+  // Rule 8: OR gates produce carries; their output should feed into XOR and AND gates, not other OR gates
+
+  for (const gate of gates) {
+    const { op, out } = gate;
+    const outputsToZ = out.startsWith('z');
+    const xyInputs = hasXYInputs(gate);
+
+    if (op === 'XOR') {
+      if (xyInputs) {
+        // XOR with x/y inputs: partial sum. Should NOT output to z (except bit 0)
+        if (outputsToZ && out !== 'z00') {
+          swapped.add(out);
+        }
+      } else {
+        // XOR with non-x/y inputs: final sum. SHOULD output to z
+        if (!outputsToZ) {
+          swapped.add(out);
+        }
+      }
+    } else if (op === 'AND') {
+      // AND gates should never output to z
+      if (outputsToZ) {
+        swapped.add(out);
+      }
+    } else if (op === 'OR') {
+      // OR gates (carry out) should never output to z, except possibly the highest z
+      if (outputsToZ && out !== highestZ) {
+        swapped.add(out);
+      }
+    }
+  }
+
+  // Now we need to find the swap partners. The above rules catch one wire of each swap.
+  // We also need a downstream check: each gate's output should be used correctly.
+  // For gates that produce wrong outputs (caught above), we need to verify their
+  // expected consumers to find the partner.
+
+  // Additional rule: Check what consumes each gate's output
+  // - XOR(x,y) for bit>0 output should be consumed by exactly one XOR and one AND
+  // - AND gate outputs (except for bit 0's AND) should be consumed by an OR
+  // - OR gate outputs should be consumed by a XOR and an AND
+
+  // Build consumer map: wire -> list of gates that use it as input
+  const consumers = new Map<string, Gate[]>();
+  for (const g of gates) {
+    if (!consumers.has(g.in1)) consumers.set(g.in1, []);
+    consumers.get(g.in1)!.push(g);
+    if (!consumers.has(g.in2)) consumers.set(g.in2, []);
+    consumers.get(g.in2)!.push(g);
+  }
+
+  for (const gate of gates) {
+    if (swapped.has(gate.out)) continue; // Already flagged
+    const { op, out } = gate;
+
+    const cons = consumers.get(out) || [];
+    const consOps = cons.map((c) => c.op).sort();
+
+    if (op === 'XOR' && hasXYInputs(gate)) {
+      // XOR(x,y) for bit>0: should feed into one XOR and one AND
+      if (out === 'z00') continue; // bit 0 is special
+      // Check consumers
+      if (
+        consOps.length !== 2 ||
+        consOps[0] !== 'AND' ||
+        consOps[1] !== 'XOR'
+      ) {
+        swapped.add(out);
+      }
+    } else if (op === 'AND') {
+      // AND outputs should feed into an OR (except maybe special cases)
+      // For bit 0's AND (x00 AND y00), it should feed into XOR and AND of bit 1
+      if (
+        hasXYInputs(gate) &&
+        (gate.in1 === 'x00' || gate.in1 === 'y00')
+      ) {
+        // bit 0 carry: should feed into XOR and AND
+        if (
+          consOps.length !== 2 ||
+          consOps[0] !== 'AND' ||
+          consOps[1] !== 'XOR'
+        ) {
+          swapped.add(out);
+        }
+      } else {
+        // Regular AND: should feed into exactly one OR
+        if (consOps.length !== 1 || consOps[0] !== 'OR') {
+          swapped.add(out);
+        }
+      }
+    } else if (op === 'OR') {
+      // OR outputs (carry) should feed into XOR and AND of next bit
+      // Exception: the last carry becomes the highest z bit directly
+      if (out === `z${String(numBits).padStart(2, '0')}`) continue;
+      if (
+        consOps.length !== 2 ||
+        consOps[0] !== 'AND' ||
+        consOps[1] !== 'XOR'
+      ) {
+        swapped.add(out);
+      }
+    }
+  }
+
+  return [...swapped].sort();
+}
