+      ['z03', wireNames['a03']],         // z swapped with AND(x,y) output
+      [wireNames['c04'], wireNames['b05']],  // carry swapped with propagate AND from different bit
+      [wireNames['t06'], wireNames['a06']],  // XOR(x,y) swapped with AND(x,y) from same bit
