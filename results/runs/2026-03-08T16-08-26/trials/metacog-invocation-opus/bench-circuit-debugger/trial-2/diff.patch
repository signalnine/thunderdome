OR gates (carry out) should never output to z, except possibly the highest z\n      if (outputsToZ && out !== highestZ) {\n        swapped.add(out);\n      }\n    }\n  }\n\n  // Now we need to find the swap partners. The above rules catch one wire of each swap.\n  // We also need a downstream check: each gate's output should be used correctly.\n  // For gates that produce wrong outputs (caught above), we need to verify their\n  // expected consumers to find the partner.\n\n  // Additional rule: Check what consumes each gate's output\n  // - XOR(x,y) for bit>0 output should be consumed by exactly one XOR and one AND\n  // - AND gate outputs (except for bit 0's AND) should be consumed by an OR\n  // - OR gate outputs should be consumed by a XOR and an AND\n\n  // Build consumer map: wire -> list of gates that use it as input\n  const consumers = new Map<string, Gate[]>();\n  for (const g of gates) {\n    if (!consumers.has(g.in1)) consumers.set(g.in1, []);\n    consumers.get(g.in1)!.push(g);\n    if (!consumers.has(g.in2)) consumers.set(g.in2, []);\n    consumers.get(g.in2)!.push(g);\n  }\n\n  for (const gate of gates) {\n    if (swapped.has(gate.out)) continue; // Already flagged\n    const { op, out } = gate;\n\n    const cons = consumers.get(out) || [];\n    const consOps = cons.map((c) => c.op).sort();\n\n    if (op === 'XOR' && hasXYInputs(gate)) {\n      // XOR(x,y) for bit>0: should feed into one XOR and one AND\n      if (out === 'z00') continue; // bit 0 is special\n      // Check consumers\n      if (\n        consOps.length !== 2 ||\n        consOps[0] !== 'AND' ||\n        consOps[1] !== 'XOR'\n      ) {\n        swapped.add(out);\n      }\n    } else if (op === 'AND') {\n      // AND outputs should feed into an OR (except maybe special cases)\n      // For bit 0's AND (x00 AND y00), it should feed into XOR and AND of bit 1\n      if (\n        hasXYInputs(gate) &&\n        (gate.in1 === 'x00' || gate.in1 === 'y00')\n      ) {\n        // bit 0 carry: shou