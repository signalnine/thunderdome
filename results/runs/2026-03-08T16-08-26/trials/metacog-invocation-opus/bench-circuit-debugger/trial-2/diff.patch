   expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 0 });\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n  });\n\n  it('should evaluate a simple OR gate', () => {\n    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });\n  });\n\n  it('should evaluate a simple XOR gate', () => {\n    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 0 });\n  });\n\n  it('should handle chained gates in dependency order', () => {\n    const gates: Gate[] = [\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },\n    ];\n    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({\n      a: 1, b: 1, c: 1, d: 0, e: 1,\n    });\n    expect(simulate(gates, { a: 0, b: 1, d: 0 })).toEqual({\n      a: 0, b: 1, c: 0, d: 0, e: 0,\n    });\n  });\n\n  it('should handle gates listed in reverse dependency order', () => {\n    const gates: Gate[] = [\n      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n    ];\n    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({\n      a: 1, b: 1, c: 1, d: 0, e: 1,\n    });\n  });\n\n  it('should simulate a correct 4-bit adder: 3 + 5 = 8', () => {\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n      { op: 'OR', in1: 'a03', in2: 'b03', out: 'z04' },\n    ];\n    const inputs: Record<string, number> = {\n      x00: 1, x01: 1, x02: 0, x03: 0,\n      y00: 1, y01: 0, y02: 1, y03: 0,\n    };\n    const result = simulate(gates, inputs);\n    // 3+5=8 = 01000\n    expect(result['z00']).toBe(0);\n    expect(result['z01']).toBe(0);\n    expect(result['z02']).toBe(0);\n    expect(result['z03']).toBe(1);\n    expect(result['z04']).toBe(0);\n  });\n\n  it('should simulate a correct 4-bit adder: 7 + 7 = 14', () => {\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n      { op: 'OR', in1: 'a03', in2: 'b03', out: 'z04' },\n    ];\n    const inputs: Record<string, number> = {\n      x00: 1, x01: 1, x02: 1, x03: 0,\n      y00: 1, y01: 1, y02: 1, y03: 0,\n    };\n    const result = simulate(gates, inputs);\n    // 7+7=14 = 01110\n    expect(result['z00']).toBe(0);\n    expect(result['z01']).toBe(1);\n    expect(result['z02']).toBe(1);\n    expect(result['z03']).toBe(1);\n    expect(result['z04']).toBe(0);\n  });\n\n  it('should simulate 15 + 15 = 30', () => {\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n      { op: 'OR', in1: 'a03', in2: 'b03', out: 'z04' },\n    ];\n    const inputs: Record<string, number> = {\n      x00: 1, x01: 1, x02: 1, x03: 1,\n      y00: 1, y01: 1, y02: 1, y03: 1,\n    };\n    const result = simulate(gates, inputs);\n    // 15+15=30 = 11110\n    expect(result['z00']).toBe(0);\n    expect(result['z01']).toBe(1);\n    expect(result['z02']).toBe(1);\n    expect(result['z03']).toBe(1);\n    expect(result['z04']).toBe(1);\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  // Helper to build a correct N-bit adder with random wire names\n  function buildCorrectAdder(numBits: number): { gates: Gate[], wireNames: Record<string, string> } {\n    const gates: Gate[] = [];\n    const wireNames: Record<string, string> = {};\n    let wireId = 0;\n    const rn = () => `w${String(wireId++).padStart(3, '0')}`;\n\n    // Bit 0: half adder\n    const z00 = 'z00';\n    const c00 = rn();\n    wireNames['c00'] = c00;\n    gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: z00 });\n    gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: c00 });\n\n    let prevCarry = c00;\n\n    for (let i = 1; i < numBits; i++) {\n      const xi = `x${String(i).padStart(2, '0')}`;\n      const yi = `y${String(i).padStart(2, '0')}`;\n      const zi = `z${String(i).padStart(2, '0')}`;\n\n      const ti = rn();\n      const ai = rn();\n      const bi = rn();\n      const ci = rn();\n\n      wireNames[`t${String(i).padStart(2, '0')}`] = ti;\n      wireNames[`a${String(i).padStart(2, '0')}`] = ai;\n      wireNames[`b${String(i).padStart(2, '0')}`] = bi;\n      wireNames[`c${String(i).padStart(2, '0')}`] = ci;\n\n      gates.push({ op: 'XOR', in1: xi, in2: yi, out: ti });\n      gates.push({ op: 'XOR', in1: ti, in2: prevCarry, out: zi });\n      gates.push({ op: 'AND', in1: xi, in2: yi, out: ai });\n      gates.push({ op: 'AND', in1: ti, in2: prevCarry, out: bi });\n\n      if (i === numBits - 1) {\n        // Last bit: carry out becomes the highest z bit\n        const zHigh = `z${String(numBits).padStart(2, '0')}`;\n        gates.push({ op: 'OR', in1: ai, in2: bi, out: zHigh });\n      } else {\n        gates.push({ op: 'OR', in1: ai, in2: bi, out: ci });\n        prevCarry = ci;\n      }\n    }\n\n    return { gates, wireNames };\n  }\n\n  function applySwaps(gates: Gate[], swaps: [string, string][]): Gate[] {\n    const swapMap: Record<string, string> = {};\n    for (const [a, b] of swaps) {\n      swapMap[a] = b;\n      swapMap[b] = a;\n    }\n    return gates.map(g => ({\n      ...g,\n      out: swapMap[g.out] || g.out,\n    }));\n  }\n\n  it('should find swapped wires in a 4-bit adder with 4 swaps', () => {\n    const { gates, wireNames } = buildCorrectAdder(4);\n\n    // Swap: z01 <-> a01, t02 <-> b02, z03 <-> c02, c00 <-> a03\n    const swaps: [string, string][] = [\n      ['z01', wireNames['a01']],\n      [wireNames['t02'], wireNames['b02']],\n      ['z03', wireNames['c02']],\n      [wireNames['c00'], wireNames['a03']],\n    ];\n    const swappedGates = applySwaps(gates, swaps);\n\n    const result = findSwappedWires(swappedGates);\n    const expected = swaps.flatMap(([a, b]) => [a, b]).sort();\n    expect(result).toEqual(expected);\n  });\n\n  it('should find swapped wires in an 8-bit adder', () => {\n    const { gates, wireNames } = buildCorrectAdder(8);\n\n    // Swap 4 pairs of wires\n    const swaps: [string, string][] = [\n      ['z02', wireNames['a02']],  // z output swapped with AND output\n      [wireNames['t04'], wireNames['b04']],  // XOR(x,y) swapped with AND(t,c)\n      ['z06', wireNames['c05']],  // z output swapped with carry\n      [wireNames['a07'], wireNames['b07']],  // two AND outputs swapped\n    ];\n    const swappedGates = applySwaps(gates, swaps);\n\n    const result = findSwappedWires(swappedGates);\n    const expected = swaps.flatMap(([a, b]) => [a, b]).sort();\n    expect(result).toEqual(expected);\n  });\n\n  it('should return a sorted array of exactly 8 wires', () => {\n    const { gates, wireNames } = buildCorrectAdder(8);\n\n    const swaps: [string, string][] = [\n      ['z01', wireNames['t01']],\n      ['z03', wireNames['a03']],\n      [wireNames['c04'], wireNames['b05']],\n      [wireNames['t07'], wireNames['c06']],\n    ];\n    const swappedGates = applySwaps(gates, swaps);\n\n    const result = findSwappedWires(swappedGates);\n    expect(result).toHaveLength(8);\n    expect(result).toEqual([...result].sort());\n  });\n\n  it('should handle a larger adder (16 bits)', () => {\n    const { gates, wireNames } = buildCorrectAdder(16);\n\n    const swaps: [string, string][] = [\n      ['z05', wireNames['a05']],\n      [wireNames['t10'], wireNames['b10']],\n      ['z12', wireNames['c11']],\n      [wireNames['a15'], wireNames['b15']],\n    ];\n    const swappedGates = applySwaps(gates, swaps);\n\n    const result = findSwappedWires(swappedGates);\n    const expected = swaps.flatMap(([a, b]) => [a, b]).sort();\n    expect(result).toEqual(expected);\n  });\n});\n","structuredPatch":[{"oldStart":39,"oldLines":48,"newStart":39,"newLines":47,"lines":["     });","   });"," ","+  it('should handle gates listed in reverse dependency order', () => {","+    const gates: Gate[] = [","+      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },","+      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },","+    ];","+    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({","+      a: 1, b: 1, c: 1, d: 0, e: 1,","+    });","+  });","+","   it('should simulate a correct 4-bit adder: 3 + 5 = 8', () => {","-    // 3 = 0011, 5 = 0101","-    // 3 + 5 = 8 = 01000","     const gates: Gate[] = [","-      // bit 0","       { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },","       { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },","-      // bit 1","       { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },","       { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },","       { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },","       { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },","       { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },","-      // bit 2","       { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },","       { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },","       { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },","       { op: