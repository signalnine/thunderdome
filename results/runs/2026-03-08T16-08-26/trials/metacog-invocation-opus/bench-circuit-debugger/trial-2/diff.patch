+    const inputs: Record<string, number> = {","+      x00: 1, x01: 1, x02: 1, x03: 1,","+      y00: 1, y01: 1, y02: 1, y03: 1,","+    };","+    const result = simulate(gates, inputs);","+    // 15+15=30 = 11110","+    expect(result['z00']).toBe(0);","+    expect(result['z01']).toBe(1);","+    expect(result['z02']).toBe(1);","+    expect(result['z03']).toBe(1);","+    expect(result['z04']).toBe(1);","+  });","+});"," ","-    // Swap 4 pairs: z01<->a01, t02<->b02, z03<->c02, c03<->a03","-    const swappedGates = correctGates.map((g) => {","-      const swapMap: Record<string, string> = {","-        z01: 'a01',","-        a01: 'z01',","-        t02: 'b02',","-        b02: 't02',","-        z03: 'c02',","-        c02: 'z03',","-        c03: 'a03',","-        a03: 'c03',","-      };","-      return { ...g, out: swapMap[g.out] || g.out };","-    });","+describe('findSwappedWires', () => {","+  // Helper to build a correct N-bit adder with random wire names","+  function buildCorrectAdder(numBits: number): { gates: Gate[], wireNames: Record<string, string> } {","+    const gates: Gate[] = [];","+    const wireNames: Record<string, string> = {};","+    let wireId = 0;","+    const rn = () => `w${String(wireId++).padStart(3, '0')}`;"," ","-    const result = findSwappedWires(swappedGates);","-    expect(result).toEqual([","-      'a01', 'a03', 'b02', 'c02', 'c03', 't02', 'z01', 'z03',","-    ]);","-  });","+    // Bit 0: half adder","+    const z00 = 'z00';","+    const c00 = rn();","+    wireNames['c00'] = c00;","+    gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: z00 });","+    gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: c00 });"," ","-  it('should return a sorted array of exactly 8 wires', () => {","-    // Build a 4-bit adder with known swaps","-    const gates: Gate[] = [","-      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },","-      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },","-      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },","-      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },","-      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },","-      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },","-      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },","-      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },","-      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },","-      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },","-      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },","-      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },","-      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },","-      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },","-      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },","-      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },","-      { op: 'OR', in1: 'a03', in2: 'b03', out: 'c03' },","-      { op: 'OR', in1: 'c03', in2: 'c03', out: 'z04' },","-    ];","+    let prevCarry = c00;"," ","-    // Swap: z01<->c01, z02<->a02, t03<->b03, z04<->a03","-    const swapMap: Record<string, string> = {","-      z01: 'c01', c01: 'z01',","-      z02: 'a02', a02: 'z02',","-      t03: 'b03', b03: 't03',","-      z04: 'a03', a03: 'z04',","-    };","-    const swapped = gates.map((g) => ({","+    for (let i = 1; i < numBits; i++) {","+      const xi = `x${String(i).padStart(2, '0')}`;","+      const yi = `y${String(i).padStart(2, '0')}`;","+      const zi = `z${String(i).padStart(2, '0')}`;","+","+      const ti = rn();","+      const ai = rn();","+      const bi = rn();","+      const ci = rn();","+","+      wireNames[`t${String(i).padStart(2, '0')}`] = ti;","+      wireNames[`a${String(i).padStart(2, '0')}`] = ai;","+      wireNames[`b${String(i).padStart(2, '0')}`] = bi;","+      wireNames[`c${String(i).padStart(2, '0')}`] = ci;","+","+      gates.push({ op: 'XOR', in1: xi, in2: yi, out: ti });","+      gates.push({ op: 'XOR', in1: ti, in2: prevCarry, out: zi });","+      gates.push({ op: 'AND', in1: xi, in2: yi, out: ai });","+      gates.push({ op: 'AND', in1: ti, in2: prevCarry, out: bi });","+","+      if (i === numBits - 1) {","+        // Last bit: carry out becomes the highest z bit","+        const zHigh = `z${String(numBits).padStart(2, '0')}`;","+        gates.push({ op: 'OR', in1: ai, in2: bi, out: zHigh });","+      } else {","+        gates.push({ op: 'OR', in1: ai, in2: bi, out: ci });","+        prevCarry = ci;","+      }","+    }","+","+    return { gates, wireNames };","+  }","+","+  function applySwaps(gates: Gate[], swaps: [string, string][]): Gate[] {","+    const swapMap: Record<string, string> = {};","+    for (const [a, b] of swaps) {","+      swapMap[a] = b;","+      swapMap[b] = a;","+    }","+    return gates.map(g => ({","       ...g,","       out: swapMap[g.out] || g.out,","     }));","+  }"," ","-    const result = findSwappedWires(swapped);","+  it('should find swapped wires in a 4-bit adder with 4 swaps', () => {","+    const { gates, wireNames } = buildCorrectAdder(4);","+","+    // Swap: z01 <-> a01, t02 <-> b02, z03 <-> c02, c00 <-> a03","+    const swaps: [string, string][] = [","+      ['z01', wireNames['a01']],","+      [wireNames['t02'], wireNames['b02']],","+      ['z03', wireNames['c02']],","+      [wireNames['c00'], wireNames['a03']],","+    ];","+    const swappedGates = applySwaps(gates, swaps);","+","+    const result = findSwappedWires(swappedGates);","+    const expected = swaps.flatMap(([a, b]) => [a, b]).sort();","+    expect(result).toEqual(expected);","+  });","+","+  it('should find swapped wires in an 8-bit adder', () => {","+    const { gates, wireNames } = buildCorrectAdder(8);","+","+    // Swap 4 pairs of wires","+    const swaps: [string, string][] = [","+      ['z02', wireNames['a02']],  // z output swapped with AND output","+      [wireNames['t04'], wireNames['b04']],  // XOR(x,y) swapped with AND(t,c)","+      ['z06', wireNames['c05']],  // z output swapped with carry","+      [wireNames['a07'], wireNames['b07']],  // two AND outputs swapped","+    ];","+    const swappedGates = applySwaps(gates, swaps);","+","+    const result = findSwappedWires(swappedGates);","+    const expected = swaps.flatMap(([a, b]) => [a, b]).sort();","+    expect(result).toEqual(expected);","+  });","+","+  it('should return a sorted array of exactly 8 wires', () => {","+    const { gates, wireNames } = buildCorrectAdder(8);","+","+    const swaps: [string, string][] = [","+      ['z01', wireNames['t01']],","+      ['z03', wireNames['a03']],","+      [wireNames['c04'], wireNames['b05']],","+      [wireNames['t07'], wireNames['c06']],","+    ];","+    const swappedGates = applySwaps(gates, swaps);","+","+    const result = findSwappedWires(swappedGates);","     expect(result).toHaveLength(8);","     expect(result).toEqual([...result].sort());","   });","+","+  it('should handle a larger adder (16 bits)', () => {","+    const { gates, wireNames } = buildCorrectAdder(16);","+","+    const swaps: [string, string][] = [","+      ['z05', wireNames['a05']],","+      [wireNames['t10'], wireNames['b10']],","+      ['z12', wireNames['c11']],","+      [wireNames['a15'], wireNames['b15']],","+    ];","+    const swappedGates = applySwaps(gates, swaps);","+","+    const result = findSwappedWires(swappedGates);","+    const expected = swaps.flatMap(([a, b]) => [a, b]).sort();","+    expect(result).toEqual(expected);","+  });"," });"]}],"originalFile":"import { describe, it, expect } from 'vitest';\nimport { simulate, findSwappedWires, Gate } from './index.js';\n\ndescribe('simulate', () => {\n  it('should evaluate a simple AND gate', () => {\n    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 0 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 0 });\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n  });\n\n  it('should evaluate a simple OR gate', () => {\n    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });\n  });\n\n  it('should evaluate a simple XOR gate', () => {\n    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 0 });\n  });\n\n  it('should handle chained gates in dependency order', () => {\n    const gates: Gate[] = [\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },\n    ];\n    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({\n      a: 1, b: 1, c: 1, d: 0, e: 1,\n    });\n    expect(simulate(gates, { a: 0, b: 1, d: 0 })).toEqual({\n      a: 0, b: 1, c: 0, d: 0, e: 0,\n    });\n  });\n\n  it('should simulate a correct 4-bit adder: 3 + 5 = 8', () => {\n    // 3 = 0011, 5 = 0101\n    // 3 + 5 = 8 = 01000\n    const gates: Gate[] = [\n      // bit 0\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      // bit 1\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n      // bit 2\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n      // bit 3\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n      { op: 'OR', in1: 'a03', in2: 'b03', out: 'c03' },\n      // final carry\n      { op: 'OR', in1: 'c03', in2: 'c03', out: 'z04' }, // hack: c03 -> z04 via self-OR\n    ];\n    // Actually, z04 = c03 directly, but our model needs a gate.\n    // Let's remove the z04 gate and just check the bits we have.\n    const gatesWithoutFinalCarry = gates.slice(0, -1);\n    const inputs: Record<string, number> = {\n      x00: 1, x01: 1, x02: 0, x03: 0, // 3\n      y00: 1, y01: 0, y02: 1, y03: 0, // 5\n    };\n    const result = simulate(gatesWithoutFinalCarry, inputs);\n    expect(result['z00']).toBe(0);\n    expect(result['z01']).toBe(0);\n    expect(result['z02']).toBe(0);\n    expect(result['z03']).toBe(1);\n    expect(result['c03']).toBe(0);\n    // 3+5=8 = 1000 in binary, z03=1, z02=0, z01=0, z00=0\n  });\n\n  it('should simulate a correct 4-bit adder: 7 + 7 = 14', () => {\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n      { op: 'OR', in1: 'a02', in2: