lper to build a correct N-bit adder with random wire names\n   154→  function buildCorrectAdder(numBits: number): { gates: Gate[], wireNames: Record<string, string> } {\n   155→    const gates: Gate[] = [];\n   156→    const wireNames: Record<string, string> = {};\n   157→    let wireId = 0;\n   158→    const rn = () => `w${String(wireId++).padStart(3, '0')}`;\n   159→\n   160→    // Bit 0: half adder\n   161→    const z00 = 'z00';\n   162→    const c00 = rn();\n   163→    wireNames['c00'] = c00;\n   164→    gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: z00 });\n   165→    gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: c00 });\n   166→\n   167→    let prevCarry = c00;\n   168→\n   169→    for (let i = 1; i < numBits; i++) {\n   170→      const xi = `x${String(i).padStart(2, '0')}`;\n   171→      const yi = `y${String(i).padStart(2, '0')}`;\n   172→      const zi = `z${String(i).padStart(2, '0')}`;\n   173→\n   174→      const ti = rn();\n   175→      const ai = rn();\n   176→      const bi = rn();\n   177→      const ci = rn();\n   178→\n   179→      wireNames[`t${String(i).padStart(2, '0')}`] = ti;\n   180→      wireNames[`a${String(i).padStart(2, '0')}`] = ai;\n   181→      wireNames[`b${String(i).padStart(2, '0')}`] = bi;\n   182→      wireNames[`c${String(i).padStart(2, '0')}`] = ci;\n   183→\n   184→      gates.push({ op: 'XOR', in1: xi, in2: yi, out: ti });\n   185→      gates.push({ op: 'XOR', in1: ti, in2: prevCarry, out: zi });\n   186→      gates.push({ op: 'AND', in1: xi, in2: yi, out: ai });\n   187→      gates.push({ op: 'AND', in1: ti, in2: prevCarry, out: bi });\n   188→\n   189→      if (i === numBits - 1) {\n   190→        // Last bit: carry out becomes the highest z bit\n   191→        const zHigh = `z${String(numBits).padStart(2, '0')}`;\n   192→        gates.push({ op: 'OR', in1: ai, in2: bi, out: zHigh });\n   193→      } else {\n   194→        gates.push({ op: 'OR', in1: ai, in2: bi, out: ci });\n   195→        prevCarry = ci;\n   