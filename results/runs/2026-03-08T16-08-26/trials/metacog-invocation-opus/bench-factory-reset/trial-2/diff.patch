ivot variable values from RREF\n      for (let r = 0; r < rank; r++) {\n        const pc = pivotCol[r];\n        let val = aug[r][n]; // RHS\n        for (let i = 0; i < numFree; i++) {\n          const fc = freeVars[i];\n          val = (((val - aug[r][fc] * freeValues[i]) % modulus) + modulus) % modulus;\n        }\n        solution[pc] = val;\n      }\n\n      // Compute total presses\n      let total = 0;\n      for (let i = 0; i < n; i++) total += solution[i];\n\n      if (total < bestTotal || (total === bestTotal && bestSolution !== null && lexLess(solution, bestSolution))) {\n        bestTotal = total;\n        bestSolution = solution.slice();\n      }\n    };\n\n    // Iterate through all combinations of free variable values\n    const iterateFreeVars = (idx: number): void => {\n      if (idx === numFree) {\n        enumerate();\n        return;\n      }\n      for (let v = 0; v < modulus; v++) {\n        freeValues[idx] = v;\n        iterateFreeVars(idx + 1);\n      }\n    };\n\n    iterateFreeVars(0);\n  } else {\n    // For large search spaces, use optimization approach.\n    // Each pivot variable is: x_pivot = b'_r - sum(a'_{r,f} * x_f) mod p\n    // Total = sum of pivot vars + sum of free vars\n    // We want to minimize total.\n    //\n    // For mod 2, this is equivalent to minimizing Hamming weight — NP-hard in general\n    // but with constraint of 40 buttons total, we can use meet-in-the-middle.\n    //\n    // Split free vars into two halves and enumerate each half.\n    bestSolution = solveWithMeetInMiddle(aug, n, rank, pivotCol, freeVars, modulus);\n  }\n\n  return bestSolution;\n}\n\nfunction lexLess(a: number[], b: number[]): boolean {\n  for (let i = 0; i < a.length; i++) {\n    if (a[i] < b[i]) return true;\n    if (a[i] > b[i]) return false;\n  }\n  return false;\n}\n\n/**\n * Meet-in-the-middle approach for when we have too many free variables to enumerate directly.\n * Split free vars into two halves, enumerate each half, and combine.\n */\nfunction solveWithMeetInMiddle(\n  aug: number[][],\n  numButtons: number,\n  rank: number,\n  pivotCol: number[],\n  freeVars: number[],\n  modulus: number\n): number[] | null {\n  const n = numButtons;\n  const numFree = freeVars.length;\n  const halfSize = Math.floor(numFree / 2);\n  const firstHalf = freeVars.slice(0, halfSize);\n  const secondHalf = freeVars.slice(halfSize);\n\n  // For each pivot variable, precompute the coefficients for free variables\n  // x_pivot_r = rhs_r - sum(coeff[r][f] * x_f) mod p\n  // where r is the rank index\n  const pivotInfo: { col: number; rhs: number; coeffs: Map<number, number> }[] = [];\n  for (let r = 0; r < rank; r++) {\n    const pc = pivotCol[r];\n    const coeffs = new Map<number, number>();\n    for (const f of freeVars) {\n      if (aug[r][f] !== 0) {\n        coeffs.set(f, aug[r][f]);\n      }\n    }\n    pivotInfo.push({ col: pc, rhs: aug[r][n], coeffs });\n  }\n\n  // For the meet-in-the-middle approach with mod 2:\n  // We want to find the combination that minimizes total presses.\n  //\n  // Compute for each first-half assignment: the \"partial sums\" vector\n  // that contributes to each pivot variable, plus the free var sum.\n  // Then for each second-half assignment, find the best first-half complement.\n  //\n  // This is complex to implement optimally for general modulus.\n  // For mod 2, we can use a hash map approach.\n\n  if (modulus === 2) {\n    return meetInMiddleMod2(aug, n, rank, pivotCol, pivotInfo, firstHalf, secondHalf, freeVars);\n  }\n\n  // For general prime modulus with many free vars — very unlikely with 40 buttons\n  // and 40 lights. Fall back to a heuristic: try each free var independently.\n  return greedyOptimize(aug, n, rank, pivotCol, freeVars, modulus);\n}\n\nfunction meetInMiddleMod2(\n  aug: number[][],\n  n: number,\n  rank: number,\n  pivotCol: number[],\n  pivotInfo: { col: number; rhs: number; coeffs: Map<number, number> }[],\n  firstHalf: number[],\n  secondHalf: number[],\n  allFreeVars: number[]\n): number[] | null {\n  // For mod 2 with many free variables (up to 40), we use meet-in-the-middle.\n  // Split free vars in half. For each assignment of the first half, compute\n  // a \"signature\" (the partial contribution to each pivot variable).\n  // Store in a map: signature -> (freeVarAssignment, partialTotal).\n  // Then for each second-half assignment, compute what first-half signature\n  // we need, look it up, and track the best total.\n\n  const h1 = firstHalf.length;\n  const h2 = secondHalf.length;\n\n  // For each first-half assignment, compute:\n  // - The partial contribution to each pivot row (mod 2)\n  // - The sum of the first-half free vars\n  // - The partial contribution to the total from pivot vars so far\n\n  // Signature: for each pivot row, the partial sum contribution from first-half free vars\n  // signature[r] = sum(aug[r][f] * x_f for f in firstHalf) mod 2\n  //\n  // When we combine with second half:\n  // pivot_r = (rhs_r - sig1[r] - sig2[r]) mod 2\n  // total = sum(pivot_r) + sum(first_half_free) + sum(second_half_free)\n\n  // Use bitmask to encode signature (rank bits) + first half values\n  // Map from signature bitmask -> { bestTotal, bestAssignment bitmask }\n\n  // Build the map for first half\n  type Entry = { total: number; assignment: number };\n  const map = new Map<number, Entry>();\n\n  for (let mask = 0; mask < (1 << h1); mask++) {\n    // Compute signature\n    let sig = 0;\n    for (let r = 0; r < rank; r++) {\n      let partialSum = 0;\n      for (let i = 0; i < h1; i++) {\n        if (mask & (1 << i)) {\n          const c = pivotInfo[r].coeffs.get(firstHalf[i]);\n          if (c) partialSum ^= 1;\n        }\n      }\n      if (partialSum) sig |= (1 << r);\n    }\n\n    // Count bits in mask (free var sum for first half)\n    let freeSum = 0;\n    for (let i = 0; i < h1; i++) {\n      if (mask & (1 << i)) freeSum++;\n    }\n\n    const existing = map.get(sig);\n    if (!existing || freeSum