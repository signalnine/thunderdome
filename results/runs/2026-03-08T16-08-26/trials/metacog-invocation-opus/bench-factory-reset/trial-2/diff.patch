t [T, F, T]\n    // Button 0: [0, 2]\n    // Button 1: [0, 1]\n    // Button 2: [1, 2]\n    // Press 0: [T, F, T] → perfect!\n    const result = solveToggle({\n      target: [true, false, true],\n      buttons: [[0, 2], [0, 1], [1, 2]],\n    });\n    expect(result).toEqual([0]);\n  });\n});\n\ndescribe('solveCounter', () => {\n  it('should solve a simple counter puzzle', () => {\n    // Target: [1, 0] mod 3\n    // Button 0: affects counter 0\n    // Press button 0 once → [1, 0]\n    const result = solveCounter([1, 0], [[0]], 3);\n    expect(result).toEqual([1]);\n  });\n\n  it('should return null when no solution exists', () => {\n    // Target: [1, 0] mod 2\n    // Button 0: affects both counters [0, 1]\n    // Can't get [1, 0] since pressing button always increments both\n    const result = solveCounter([1, 0], [[0, 1]], 2);\n    expect(result).toBeNull();\n  });\n\n  it('should minimize total presses', () => {\n    // Target: [2] mod 5\n    // Button 0: affects [0]\n    // Press 2 times: [2] ✓\n    const result = solveCounter([2], [[0]], 5);\n    expect(result).toEqual([2]);\n  });\n\n  it('should handle wrapping with modulus', () => {\n    // Target: [0] mod 3\n    // Button 0: affects [0]\n    // Press 0 times: [0] ✓ (minimum)\n    const result = solveCounter([0], [[0]], 3);\n    expect(result).toEqual([0]);\n  });\n\n  it('should return all zeros when target is all zero', () => {\n    const result = solveCounter([0, 0, 0], [[0, 1], [1, 2], [0, 2]], 5);\n    expect(result).toEqual([0, 0, 0]);\n  });\n\n  it('should solve with multiple buttons', () => {\n    // Target: [1, 1] mod 3\n    // Button 0: affects [0, 1]\n    // Button 1: affects [0]\n    // Press button 0 once → [1, 1] ✓\n    const result = solveCounter([1, 1], [[0, 1], [0]], 3);\n    expect(result).toEqual([1, 0]);\n  });\n\n  it('should pick lexicographically smallest when tied on total', () => {\n    // Target: [1] mod 3\n    // Button 0: affects [0]\n    // Button 1: affects [0]\n    // Both require 1 press; [0, 1] is lex smaller than [1, 0]\n    const result = solveCounter([1], [[0], [0]], 3);\n    expect(result).toEqual([0, 1]);\n  });\n\n  it('should handle larger modulus', () => {\n    // Target: [5] mod 7\n    // Button 0: affects [0]\n    // Press 5 times → [5] ✓\n    // OR press 5 times (not 12 since 12 mod 7 = 5, but we want minimum which is 5)\n    const result = solveCounter([5], [[0]], 7);\n    expect(result).toEqual([5]);\n  });\n});\n"}}
