+interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+type SolutionCompare = (a: number[], b: number[]) => number;
+
+function modInverse(a: number, p: number): number {
+  let result = 1;
+  let base = ((a % p) + p) % p;
+  let exp = p - 2;
+  while (exp > 0) {
+    if (exp & 1) result = (result * base) % p;
+    base = (base * base) % p;
+    exp >>= 1;
+  }
+  return result;
+}
+
+function totalPresses(sol: number[]): number {
+  let s = 0;
+  for (let i = 0; i < sol.length; i++) s += sol[i];
+  return s;
+}
+
+function toggleCompare(a: number[], b: number[]): number {
+  const ta = totalPresses(a);
+  const tb = totalPresses(b);
+  if (ta !== tb) return ta - tb;
+  for (let i = 0; i < a.length; i++) {
+    const ai = a[i] > 0 ? 1 : 0;
+    const bi = b[i] > 0 ? 1 : 0;
+    if (ai !== bi) {
+      return bi - ai;
+    }
+  }
+  return 0;
+}
+
+function counterCompare(a: number[], b: number[]): number {
+  const ta = totalPresses(a);
+  const tb = totalPresses(b);
+  if (ta !== tb) return ta - tb;
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] !== b[i]) return a[i] - b[i];
+  }
+  return 0;
+}
+
+function gaussianElimination(
+  numLights: number,
+  numButtons: number,
+  matrix: number[][],
+  modulus: number
+): {
+  aug: number[][];
+  rank: number;
+  pivotCol: number[];
+  pivotRow: number[];
+  freeVars: number[];
+  solvable: boolean;
+} {
+  const m = numLights;
+  const n = numButtons;
+  const aug = matrix.map(row => row.slice());
+  const pivotCol: number[] = new Array(m).fill(-1);
+  const pivotRow: number[] = new Array(n).fill(-1);
+
+  let row = 0;
+  for (let col = 0; col < n && row < m; col++) {
+    let pivotR = -1;
+    for (let r = row; r < m; r++) {
+      if (aug[r][col] !== 0) {
+        pivotR = r;
+        break;
+      }
+    }
+    if (pivotR === -1) continue;
+
+    if (pivotR !== row) {
+      [aug[row], aug[pivotR]] = [aug[pivotR], aug[row]];
+    }
+
+    pivotCol[row] = col;
+    pivotRow[col] = row;
+
+    const inv = modInverse(aug[row][col], modulus);
+    for (let j = col; j <= n; j++) {
+      aug[row][j] = (aug[row][j] * inv) % modulus;
+    }
+
+    for (let r = 0; r < m; r++) {
+      if (r === row) continue;
+      const factor = aug[r][col];
+      if (factor === 0) continue;
+      for (let j = col; j <= n; j++) {
+        aug[r][j] = (((aug[r][j] - factor * aug[row][j]) % modulus) + modulus) % modulus;
+      }
+    }
+
+    row++;
+  }
+
+  const rank = row;
+
+  let solvable = true;
+  for (let r = rank; r < m; r++) {
+    if (aug[r][n] !== 0) {
+      solvable = false;
+      break;
+    }
+  }
+
+  const freeVars: number[] = [];
+  for (let col = 0; col < n; col++) {
+    if (pivotRow[col] === -1) {
+      freeVars.push(col);
+    }
+  }
+
+  return { aug, rank, pivotCol, pivotRow, freeVars, solvable };
+}
+
+function buildSolution(
+  n: number,
+  rank: number,
+  pivotCol: number[],
+  aug: number[][],
+  freeVars: number[],
+  freeValues: number[],
+  modulus: number
+): number[] {
+  const solution = new Array(n).fill(0);
+  for (let i = 0; i < freeVars.length; i++) {
+    solution[freeVars[i]] = freeValues[i];
+  }
+  for (let r = 0; r < rank; r++) {
+    const pc = pivotCol[r];
+    let val = aug[r][n];
+    for (let i = 0; i < freeVars.length; i++) {
+      val = (((val - aug[r][freeVars[i]] * freeValues[i]) % modulus) + modulus) % modulus;
+    }
+    solution[pc] = val;
+  }
+  return solution;
+}
+
+function solveLinearSystem(
+  numLights: number,
+  numButtons: number,
+  matrix: number[][],
+  modulus: number,
+  compare: SolutionCompare
+): number[] | null {
+  const n = numButtons;
+  const { aug, rank, pivotCol, freeVars, solvable } = gaussianElimination(numLights, numButtons, matrix, modulus);
+
+  if (!solvable) return null;
+
+  const numFree = freeVars.length;
+
+  if (numFree === 0) {
+    return buildSolution(n, rank, pivotCol, aug, freeVars, [], modulus);
+  }
+
+  const logCombinations = numFree * Math.log2(modulus);
+
+  if (logCombinations <= 23) {
+    return enumerateFreeSolutions(n, rank, pivotCol, aug, freeVars, modulus, compare);
+  }
+
+  // For mod 2 with many free vars (> 23): meet in the middle
+  if (modulus === 2) {
+    return meetInMiddleMod2(n, rank, pivotCol, aug, freeVars, compare);
+  }
+
+  // Greedy fallback for general prime with many free vars
+  return greedyOptimize(n, rank, pivotCol, aug, freeVars, modulus, compare);
+}
+
+function enumerateFreeSolutions(
+  n: number,
+  rank: number,
+  pivotCol: number[],
+  aug: number[][],
+  freeVars: number[],
+  modulus: number,
+  compare: SolutionCompare
+): number[] {
+  const numFree = freeVars.length;
+
+  // Precompute coefficients: for each pivot row r, and each free var index fi,
+  // what is the coefficient aug[r][freeVars[fi]]?
+  const coeffs: number[][] = [];
+  for (let r = 0; r < rank; r++) {
+    const row: number[] = [];
+    for (let fi = 0; fi < numFree; fi++) {
+      row.push(aug[r][freeVars[fi]]);
+    }
+    coeffs.push(row);
+  }
+
+  const pivotRhs: number[] = [];
+  for (let r = 0; r < rank; r++) {
+    pivotRhs.push(aug[r][n]);
+  }
+
+  // Current state: pivot values for current free variable assignment
+  // Start with all free vars = 0
+  const pivotValues = pivotRhs.slice();
+  const freeValues = new Array(numFree).fill(0);
+
+  let bestSolution: number[] | null = null;
+
+  // Build solution from current state
+  const currentSolution = (): number[] => {
+    const sol = new Array(n).fill(0);
+    for (let fi = 0; fi < numFree; fi++) {
+      sol[freeVars[fi]] = freeValues[fi];
+    }
+    for (let r = 0; r < rank; r++) {
+      sol[pivotCol[r]] = pivotValues[r];
+    }
+    return sol;
+  };
+
+  // Enumerate all combinations iteratively (odometer-style)
+  const totalCombinations = Math.pow(modulus, numFree);
+  for (let combo = 0; combo < totalCombinations; combo++) {
+    const sol = currentSolution();
+    if (bestSolution === null || compare(sol, bestSolution) < 0) {
+      bestSolution = sol;
+    }
+
+    // Increment odometer (rightmost digit first)
+    for (let fi = numFree - 1; fi >= 0; fi--) {
+      const oldVal = freeValues[fi];
+      const newVal = (oldVal + 1) % modulus;
+      freeValues[fi] = newVal;
+
+      // Update pivot values: subtract old contribution, add new contribution
+      // pivot_r -= coeff * oldVal, pivot_r += coeff * newVal
+      // net change: coeff * (newVal - oldVal) = coeff * 1 (if not wrapping) or coeff * (1-modulus) (if wrapping)
+      if (newVal !== 0) {
+        // Incremented by 1
+        for (let r = 0; r < rank; r++) {
+          if (coeffs[r][fi] !== 0) {
+            pivotValues[r] = (pivotValues[r] - coeffs[r][fi] + modulus) % modulus;
+          }
+        }
+        break;
+      } else {
+        // Wrapped around: went from (modulus-1) back to 0
+        // Change in free var value: 0 - (modulus-1) = -(modulus-1) = 1 mod modulus
+        // Same as incrementing by 1 in terms of mod arithmetic
+        for (let r = 0; r < rank; r++) {
+          if (coeffs[r][fi] !== 0) {
+            pivotValues[r] = (pivotValues[r] - coeffs[r][fi] + modulus) % modulus;
+          }
+        }
+        // Continue to next digit (carry)
+      }
+    }
+  }
+
+  return bestSolution!;
+}
+
+function meetInMiddleMod2(
+  n: number,
+  rank: number,
+  pivotCol: number[],
+  aug: number[][],
+  freeVars: number[],
+  compare: SolutionCompare
+): number[] {
+  const numFree = freeVars.length;
+  const halfSize = Math.floor(numFree / 2);
+  const h1 = halfSize;
+  const h2 = numFree - halfSize;
+
+  // Precompute pivot coefficients for free variables
+  const coeffs: number[][] = [];
+  for (let r = 0; r < rank; r++) {
+    const row: number[] = [];
+    for (let fi = 0; fi < numFree; fi++) {
+      row.push(aug[r][freeVars[fi]]);
+    }
+    coeffs.push(row);
+  }
+
+  const pivotRhs: number[] = [];
+  for (let r = 0; r < rank; r++) {
+    pivotRhs.push(aug[r][n]);
+  }
+
+  // Phase 1: Build map for first half
+  // For each first-half mask, compute:
+  //   sig: bitmask (rank bits) of partial contributions to pivot vars
+  //   freeSum: popcount of mask
+  // Group by sig → list of {freeSum, mask}, sorted by freeSum
+
+  // Map from sig (as string) → sorted list of {freeSum, mask}
+  const firstBySig = new Map<string, { freeSum: number; mask: number }[]>();
+
+  for (let mask = 0; mask < (1 << h1); mask++) {
+    const sigBits: number[] = new Array(rank).fill(0);
+    for (let r = 0; r < rank; r++) {
+      let partial = 0;
+      for (let i = 0; i < h1; i++) {
+        if (mask & (1 << i)) {
+          partial ^= coeffs[r][i];
+        }
+      }
+      sigBits[r] = partial & 1;
+    }
+    const sigKey = sigBits.join('');
+
+    let freeSum = 0;
+    for (let i = 0; i < h1; i++) {
+      if (mask & (1 << i)) freeSum++;
+    }
+
+    let list = firstBySig.get(sigKey);
+    if (!list) {
+      list = [];
+      firstBySig.set(sigKey, list);
+    }
+    list.push({ freeSum, mask });
+  }
+
+  // Sort each list by freeSum ascending for early pruning
+  for (const [, list] of firstBySig) {
+    list.sort((a, b) => a.freeSum - b.freeSum);
+  }
+
+  // Phase 2: For each second-half mask, find the best first-half match
+  let bestSolution: number[] | null = null;
+  let bestTotal = Infinity;
+
+  for (let mask2 = 0; mask2 < (1 << h2); mask2++) {
+    const sigBits2: number[] = new Array(rank).fill(0);
+    for (let r = 0; r < rank; r++) {
+      let partial = 0;
+      for (let i = 0; i < h2; i++) {
+        if (mask2 & (1 << i)) {
+          partial ^= coeffs[r][halfSize + i];
+        }
+      }
+      sigBits2[r] = partial & 1;
+    }
+
+    let freeSum2 = 0;
+    for (let i = 0; i < h2; i++) {
+      if (mask2 & (1 << i)) freeSum2++;
+    }
+
+    // For each pivot row, we need: pivot_r = (rhs_r XOR sig1_r XOR sig2_r)
+    // Total contribution from pivots = popcount of (rhs XOR sig1 XOR sig2)
+    // We want to minimize: pivotContrib + freeSum1 + freeSum2
+
+    // Compute target sig (rhs XOR sig2)
+    const targetBits: number[] = new Array(rank).fill(0);
+    for (let r = 0; r < rank; r++) {
+      targetBits[r] = pivotRhs[r] ^ sigBits2[r];
+    }
+
+    // For each sig1 in our map, compute pivotContrib = popcount(target XOR sig1)
+    for (const [sigKey, list] of firstBySig) {
+      let pivotContrib = 0;
+      for (let r = 0; r < rank; r++) {
+        pivotContrib += targetBits[r] ^ (sigKey.charCodeAt(r) - 48);
+      }
+
+      // List is sorted by freeSum ascending, so we can break early
+      for (const entry of list) {
+        const candidateTotal = pivotContrib + entry.freeSum + freeSum2;
+        if (candidateTotal > bestTotal) break; // sorted, so rest are worse
+
+        // Build full solution
+        const freeValues = new Array(numFree).fill(0);
+        for (let i = 0; i < h1; i++) {
+          if (entry.mask & (1 << i)) freeValues[i] = 1;
+        }
+        for (let i = 0; i < h2; i++) {
+          if (mask2 & (1 << i)) freeValues[halfSize + i] = 1;
+        }
+        const solution = buildSolution(n, rank, pivotCol, aug, freeVars, freeValues, 2);
+
+        if (bestSolution === null || compare(solution, bestSolution) < 0) {
+          bestSolution = solution;
+          bestTotal = totalPresses(solution);
+        }
+      }
+    }
+  }
+
+  return bestSolution!;
+}
+
+function greedyOptimize(
+  n: number,
+  rank: number,
+  pivotCol: number[],
+  aug: number[][],
+  freeVars: number[],
+  modulus: number,
+  compare: SolutionCompare
+): number[] {
+  const numFree = freeVars.length;
+  let bestFreeValues = new Array(numFree).fill(0);
+  let bestSolution = buildSolution(n, rank, pivotCol, aug, freeVars, bestFreeValues, modulus);
+
+  for (let iter = 0; iter < 5; iter++) {
+    let improved = false;
+    for (let fi = 0; fi < numFree; fi++) {
+      for (let v = 0; v < modulus; v++) {
+        const testFree = bestFreeValues.slice();
+        testFree[fi] = v;
+        const testSol = buildSolution(n, rank, pivotCol, aug, freeVars, testFree, modulus);
+        if (compare(testSol, bestSolution) < 0) {
+          bestSolution = testSol;
+          bestFreeValues = testFree;
+          improved = true;
+        }
+      }
+    }
+    if (!improved) break;
+  }
+
+  return bestSolution;
+}
+
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const numLights = target.length;
+  const numButtons = buttons.length;
+
+  const matrix: number[][] = [];
+  for (let i = 0; i < numLights; i++) {
+    const row = new Array(numButtons + 1).fill(0);
+    for (let j = 0; j < numButtons; j++) {
+      if (buttons[j].includes(i)) {
+        row[j] = 1;
+      }
+    }
+    row[numButtons] = target[i] ? 1 : 0;
+    matrix.push(row);
+  }
+
+  const result = solveLinearSystem(numLights, numButtons, matrix, 2, toggleCompare);
+  if (result === null) return null;
+
+  const pressed: number[] = [];
+  for (let i = 0; i < numButtons; i++) {
+    if (result[i] === 1) pressed.push(i);
+  }
+  return pressed;
+}
+
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numLights = lights.length;
+  const numButtons = buttons.length;
+
+  const matrix: number[][] = [];
+  for (let i = 0; i < numLights; i++) {
+    const row = new Array(numButtons + 1).fill(0);
+    for (let j = 0; j < numButtons; j++) {
+      if (buttons[j].includes(i)) {
+        row[j] = 1;
+      }
+    }
+    row[numButtons] = lights[i] % modulus;
+    matrix.push(row);
+  }
+
+  const result = solveLinearSystem(numLights, numButtons, matrix, modulus, counterCompare);
+  return result;
+}
