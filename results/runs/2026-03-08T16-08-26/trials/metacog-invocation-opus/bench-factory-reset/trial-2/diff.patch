mber;\n\nfunction modInverse(a: number, p: number): number {\n  let result = 1;\n  let base = ((a % p) + p) % p;\n  let exp = p - 2;\n  while (exp > 0) {\n    if (exp & 1) result = (result * base) % p;\n    base = (base * base) % p;\n    exp >>= 1;\n  }\n  return result;\n}\n\nfunction computeSolutionFromFreeVars(\n  n: number,\n  rank: number,\n  pivotCol: number[],\n  aug: number[][],\n  freeVars: number[],\n  freeValues: number[],\n  modulus: number\n): number[] {\n  const solution = new Array(n).fill(0);\n  for (let i = 0; i < freeVars.length; i++) {\n    solution[freeVars[i]] = freeValues[i];\n  }\n  for (let r = 0; r < rank; r++) {\n    const pc = pivotCol[r];\n    let val = aug[r][n];\n    for (let i = 0; i < freeVars.length; i++) {\n      val = (((val - aug[r][freeVars[i]] * freeValues[i]) % modulus) + modulus) % modulus;\n    }\n    solution[pc] = val;\n  }\n  return solution;\n}\n\nfunction totalPresses(sol: number[]): number {\n  let s = 0;\n  for (let i = 0; i < sol.length; i++) s += sol[i];\n  return s;\n}\n\n/**\n * Compare for toggle: fewer presses first, then lex-smallest set of pressed indices.\n * Pressed indices are sorted ascending. Lex comparison of these sorted lists.\n */\nfunction toggleCompare(a: number[], b: number[]): number {\n  const ta = totalPresses(a);\n  const tb = totalPresses(b);\n  if (ta !== tb) return ta - tb;\n  // Compare pressed index sets lexicographically\n  // Walk through indices, comparing the positions where buttons are pressed\n  for (let i = 0; i < a.length; i++) {\n    const ai = a[i] > 0 ? 1 : 0;\n    const bi = b[i] > 0 ? 1 : 0;\n    // For toggle: we want the set with earlier 1s to win.\n    // {0} vs {1}: at i=0, a[0]=1, b[0]=0 → a has a 1 here, b doesn't.\n    // In lex comparison of sets, {0} < {1}. So a is better. a[i]=1 > b[i]=0 means a is better.\n    // But for sets of different elements at same positions...\n    // Actually: pressed indices for a: indices where a[i]=1.\n    // pressed indices for b: indices where b[i]=1.\n    // Both lists have same length (same total presses).\n    // We want lex-smallest list. So compare first differing pressed index.\n    // If a has a 1 at position i and b doesn't, then a's set includes i but b's doesn't.\n    // Since b must have a 1 somewhere later (same total), a's set has a smaller element.\n    // So a is better (lex smaller set).\n    if (ai !== bi) {\n      // a[i]=1, b[i]=0: a has this index, b doesn't → a's set is lex smaller → a wins → return -1\n      // a[i]=0, b[i]=1: b has this index, a doesn't → b's set is lex smaller → b wins → return 1\n      return bi - ai; // if a[i]=1,b[i]=0: 0-1=-1 (a wins). if a[i]=0,b[i]=1: 1-0=1 (b wins).\n    }\n  }\n  return 0;\n}\n\n/**\n * Compare for counter: fewer total presses first, then lex-smallest solution array.\n */\nfunction counterCompare(a: number[], b: number[]): number {\n  const ta = totalPresses(a);\n  const tb = totalPresses(b);\n  if (ta !== tb) return ta - tb;\n  for (let i = 0; i < a.length; i++) {\n    if (a[i] !== b[i]) return a[i] - b[i];\n  }\n  return 0;\n}\n\nfunction solveLinearSystem(\n  numLights: number,\n  numButtons: number,\n  matrix: number[][],\n  modulus: number,\n  compare: SolutionCompare\n): number[] | null {\n  const m = numLights;\n  const n = numButtons;\n  const aug = matrix.map(row => row.slice());\n  const pivotCol: number[] = new Array(m).fill(-1);\n  const pivotRow: number[] = new Array(n).fill(-1);\n\n  let row = 0;\n  for (let col = 0; col < n && row < m; col++) {\n    let pivotR = -1;\n    for (let r = row; r < m; r++) {\n      if (aug[r][col] !== 0) {\n        pivotR = r;\n        break;\n      }\n    }\n    if (pivotR === -1) continue;\n\n    if (pivotR !== row) {\n      [aug[row], aug[pivotR]] = [aug[pivotR], aug[row]];\n    }\n\n    pivotCol[row] = col;\n    pivotRow[col] = row;\n\n    const inv = modInverse(aug[row][col], modulus);\n    for (let j = col; j <= n; j++) {\n      aug[row][j] = (aug[row][j] * inv) % modulus;\n    }\n\n    for (let r = 0; r < m; r++) {\n      if (r === row) continue;\n      const factor = aug[r][col];\n      if (factor === 0) continue;\n      for (let j = col; j <= n; j++) {\n        aug[r][j] = (((aug[r][j] - factor * aug[row][j]) % modulus) + modulus) % modulus;\n      }\n    }\n\n    row++;\n  }\n\n  const rank = row;\n\n  for (let r = rank; r < m; r++) {\n    if (aug[r][n] !== 0) return null;\n  }\n\n  const freeVars: number[] = [];\n  for (let col = 0; col < n; col++) {\n    if (pivotRow[col] === -1) {\n      freeVars.push(col);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  if (numFree === 0) {\n    return computeSolutionFromFreeVars(n, rank, pivotCol, aug, freeVars, [], modulus);\n  }\n\n  // Check if enumeration is feasible\n  // For mod 2: 2^numFree. For general mod: modulus^numFree.\n  // We can handle up to about 2^22 = 4M combinations comfortably.\n  const logCombinations = numFree * Math.log2(modulus);\n\n  if (logCombinations <= 22) {\n    return enumerateFreeSolutions(n, rank, pivotCol, aug, freeVars, modulus, compare);\n  }\n\n  // For mod 2 with many free vars: meet in the middle\n  if (modulus === 2) {\n    return meetInMiddleMod2(n, rank, pivotCol, aug, freeVars, compare);\n  }\n\n  // For general prime with many free vars — shouldn't happen with 40 buttons/40 lights\n  // but handle gracefully with greedy optimization\n  return greedyOptimize(n, rank, pivotCol, aug, freeVars, modulus, compare);\n}\n\nfunction enumerateFreeSolutions(\n  n: number,\n  rank: number,\n  pivotCol: number[],\n  aug: number[][],\n  freeVars: number[],\n  modulus: number,\n  compare: SolutionCompare\n): number[] {\n  const numFree = freeVars.length;\n  const freeValues = new Array(numFree).fill(0);\n  let bestSolution: number[] | null = null;\n\n  const enumerate = (idx: number): void => {\n    if (idx === numFree) {\n      const solution = computeSolutionFromFreeVars(n, rank, pivotCol, aug, freeVars, freeValues, modulus);\n      if (bestSolution === null || com