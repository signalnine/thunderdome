+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+function lexSmaller(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return false;
+}
+
+// For binary solution vectors, compare by resulting index set.
+// A set like {0,2} < {0,3} < {1,2}. At the first position where vectors
+// differ, the one with 1 includes that index, making its set "smaller".
+function toggleSetSmaller(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] > b[i]) return true;
+    if (a[i] < b[i]) return false;
+  }
+  return false;
+}
+
+function modPow(base: number, exp: number, m: number): number {
+  let result = 1;
+  base = ((base % m) + m) % m;
+  while (exp > 0) {
+    if (exp & 1) result = (result * base) % m;
+    exp >>= 1;
+    base = (base * base) % m;
+  }
+  return result;
+}
+
+function modInverse(a: number, m: number): number {
+  return modPow(a, m - 2, m);
+}
+
+interface GaussResult {
+  matrix: number[][];
+  pivotCol: number[];
+  pivotRow: number[];
+  rank: number;
+  freeVars: number[];
+}
+
+function gaussianElimination(
+  matrix: number[][],
+  numRows: number,
+  numVarCols: number,
+  modulus: number
+): GaussResult | null {
+  const pivotCol: number[] = [];
+  const pivotRow: number[] = new Array(numVarCols).fill(-1);
+  let row = 0;
+
+  for (let col = 0; col < numVarCols && row < numRows; col++) {
+    let pivotR = -1;
+    for (let r = row; r < numRows; r++) {
+      if (matrix[r][col] !== 0) {
+        pivotR = r;
+        break;
+      }
+    }
+    if (pivotR === -1) continue;
+
+    [matrix[row], matrix[pivotR]] = [matrix[pivotR], matrix[row]];
+    pivotCol.push(col);
+    pivotRow[col] = row;
+
+    if (modulus > 2) {
+      const inv = modInverse(matrix[row][col], modulus);
+      for (let c = col; c <= numVarCols; c++) {
+        matrix[row][c] = (matrix[row][c] * inv) % modulus;
+      }
+    }
+
+    for (let r = 0; r < numRows; r++) {
+      if (r !== row && matrix[r][col] !== 0) {
+        if (modulus === 2) {
+          for (let c = col; c <= numVarCols; c++) {
+            matrix[r][c] ^= matrix[row][c];
+          }
+        } else {
+          const factor = matrix[r][col];
+          for (let c = col; c <= numVarCols; c++) {
+            matrix[r][c] = (((matrix[r][c] - factor * matrix[row][c]) % modulus) + modulus) % modulus;
+          }
+        }
+      }
+    }
+    row++;
+  }
+
+  const rank = pivotCol.length;
+
+  for (let r = rank; r < numRows; r++) {
+    if (matrix[r][numVarCols] !== 0) {
+      return null;
+    }
+  }
+
+  const freeVars: number[] = [];
+  for (let col = 0; col < numVarCols; col++) {
+    if (pivotRow[col] === -1) {
+      freeVars.push(col);
+    }
+  }
+
+  return { matrix, pivotCol, pivotRow, rank, freeVars };
+}
+
+// Back-substitute to get full solution given free variable assignments.
+// After RREF, each pivot row p has: x_{pivotCol[p]} + sum(matrix[p][c] * x_c, c > pivotCol[p]) = matrix[p][augCol]
+// So x_{pivotCol[p]} = matrix[p][augCol] - sum(matrix[p][c] * x_c, c > pivotCol[p])
+function backSubstituteGF2(
+  gauss: GaussResult,
+  solution: number[],
+  numVarCols: number,
+): void {
+  for (let p = gauss.rank - 1; p >= 0; p--) {
+    const pCol = gauss.pivotCol[p];
+    let val = gauss.matrix[p][numVarCols];
+    for (let c = pCol + 1; c < numVarCols; c++) {
+      if (gauss.matrix[p][c] === 1) {
+        val ^= solution[c];
+      }
+    }
+    solution[pCol] = val;
+  }
