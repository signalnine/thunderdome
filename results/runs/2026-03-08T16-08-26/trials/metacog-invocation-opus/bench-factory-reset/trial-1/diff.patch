+
+  const { freeVars } = gauss;
+  const numFree = freeVars.length;
+
+  if (numFree === 0) {
+    const solution = new Array(numButtons).fill(0);
+    for (let p = 0; p < gauss.rank; p++) {
+      solution[gauss.pivotCol[p]] = gauss.matrix[p][numButtons];
+    }
+    return solution;
+  }
+
+  // Precompute pivot dependencies
+  const pivotRhs: number[] = [];
+  const pivotCols: number[] = [];
+  const pivotCoeffs: number[][] = []; // pivotCoeffs[p][f] = coeff of free var f
+  for (let p = 0; p < gauss.rank; p++) {
+    pivotRhs.push(gauss.matrix[p][numButtons]);
+    pivotCols.push(gauss.pivotCol[p]);
+    const coeffs = new Array(numFree).fill(0);
+    for (let f = 0; f < numFree; f++) {
+      coeffs[f] = gauss.matrix[p][freeVars[f]];
+    }
+    pivotCoeffs.push(coeffs);
+  }
+
+  let bestSolution: number[] | null = null;
+  let bestCost = Infinity;
+
+  // Check feasibility of direct enumeration
+  let totalCombinations = 1;
+  let feasible = true;
+  for (let f = 0; f < numFree; f++) {
+    totalCombinations *= modulus;
+    if (totalCombinations > 50_000_000) {
+      feasible = false;
+      break;
+    }
+  }
+
+  if (feasible) {
+    const freeValues = new Array(numFree).fill(0);
+
+    for (;;) {
+      const solution = new Array(numButtons).fill(0);
+      let cost = 0;
+
+      for (let f = 0; f < numFree; f++) {
+        solution[freeVars[f]] = freeValues[f];
+        cost += freeValues[f];
+      }
+
+      for (let p = 0; p < gauss.rank; p++) {
+        let val = pivotRhs[p];
+        for (let f = 0; f < numFree; f++) {
+          if (pivotCoeffs[p][f] !== 0) {
+            val = (((val - pivotCoeffs[p][f] * freeValues[f]) % modulus) + modulus) % modulus;
+          }
+        }
+        solution[pivotCols[p]] = val;
+        cost += val;
+      }
+
+      if (cost < bestCost || (cost === bestCost && lexSmaller(solution, bestSolution!))) {
+        bestCost = cost;
+        bestSolution = solution.slice();
+      }
+
+      let carry = true;
+      for (let f = 0; f < numFree; f++) {
+        freeValues[f]++;
+        if (freeValues[f] >= modulus) {
+          freeValues[f] = 0;
+        } else {
+          carry = false;
+          break;
+        }
+      }
+      if (carry) break;
+    }
+  } else {
+    // DFS with pruning
+    const currentFreeVals = new Array(numFree).fill(0);
+
+    // For each pivot, compute the maximum free index that affects it.
+    // Once we've assigned all free vars up to that index, we can compute
+    // the exact pivot value and add it to the cost bound.
+    const pivotMaxFreeIdx: number[] = new Array(gauss.rank).fill(-1);
+    for (let p = 0; p < gauss.rank; p++) {
+      for (let f = numFree - 1; f >= 0; f--) {
+        if (pivotCoeffs[p][f] !== 0) {
+          pivotMaxFreeIdx[p] = f;
+          break;
+        }
+      }
+    }
+
+    // Compute initial solution (all free vars = 0) to seed bestCost
+    {
+      const solution = new Array(numButtons).fill(0);
+      let cost = 0;
+      for (let p = 0; p < gauss.rank; p++) {
+        solution[pivotCols[p]] = pivotRhs[p];
+        cost += pivotRhs[p];
+      }
+      if (cost < bestCost || (cost === bestCost && lexSmaller(solution, bestSolution!))) {
+        bestCost = cost;
+        bestSolution = solution.slice();
+      }
+    }
+
+    const dfs = (freeIdx: number, costSoFar: number): void => {
+      if (costSoFar >= bestCost) return;
+
+      if (freeIdx === numFree) {
+        // All free vars assigned, compute remaining pivot values
+        let totalCost = costSoFar;
+        const solution = new Array(numButtons).fill(0);
+        for (let f = 0; f < numFree; f++) {
+          solution[freeVars[f]] = currentFreeVals[f];
+        }
+        for (let p = 0; p < gauss.rank; p++) {
+          let val = pivotRhs[p];
+          for (let f = 0; f < numFree; f++) {
+            if (pivotCoeffs[p][f] !== 0) {
+              val = (((val - pivotCoeffs[p][f] * currentFreeVals[f]) % modulus) + modulus) % modulus;
+            }
+          }
+          solution[pivotCols[p]] = val;
+          totalCost += val;
+        }
+        if (totalCost < bestCost || (totalCost === bestCost && lexSmaller(solution, bestSolution!))) {
+          bestCost = totalCost;
+          bestSolution = solution.slice();
+        }
+        return;
+      }
+
+      for (let val = 0; val < modulus; val++) {
+        currentFreeVals[freeIdx] = val;
+
+        // Compute cost including this free var and any pivots now fully determined
+        let newCost = costSoFar + val;
+
+        // Check pivots that are fully determined after assigning freeIdx
+        for (let p = 0; p < gauss.rank; p++) {
+          if (pivotMaxFreeIdx[p] === freeIdx) {
+            // This pivot is now fully determined
+            let pval = pivotRhs[p];
+            for (let f = 0; f <= freeIdx; f++) {
+              if (pivotCoeffs[p][f] !== 0) {
+                pval = (((pval - pivotCoeffs[p][f] * currentFreeVals[f]) % modulus) + modulus) % modulus;
+              }
+            }
+            newCost += pval;
+          }
+        }
+
+        if (newCost <= bestCost) {
+          dfs(freeIdx + 1, newCost);
+        }
+      }
+      currentFreeVals[freeIdx] = 0;
+    };
+
+    dfs(0, 0);
+  }
+
+  return bestSolution;
+}
