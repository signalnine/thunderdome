+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter, Machine } from '../src/index.js';
+
+function verifyToggle(machine: Machine, result: number[] | null): boolean {
+  if (result === null) return true;
+  const state = new Array(machine.target.length).fill(false);
+  for (const btnIdx of result) {
+    for (const lightIdx of machine.buttons[btnIdx]) {
+      state[lightIdx] = !state[lightIdx];
+    }
+  }
+  for (let i = 0; i < machine.target.length; i++) {
+    if (state[i] !== machine.target[i]) return false;
+  }
+  return true;
+}
+
+function verifyCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number,
+  result: number[] | null
+): boolean {
+  if (result === null) return true;
+  const state = new Array(lights.length).fill(0);
+  for (let i = 0; i < buttons.length; i++) {
+    for (const counterIdx of buttons[i]) {
+      state[counterIdx] = (state[counterIdx] + result[i]) % modulus;
+    }
+  }
+  for (let i = 0; i < lights.length; i++) {
+    if (state[i] !== ((lights[i] % modulus + modulus) % modulus)) return false;
+  }
+  return true;
+}
+
+describe('solveToggle', () => {
+  it('should return empty array when target is all off', () => {
+    const machine: Machine = {
+      target: [false, false, false],
+      buttons: [[0, 1], [1, 2]],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('should return null when no solution exists (example from spec)', () => {
+    const machine: Machine = {
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('should solve a simple toggle puzzle', () => {
+    const machine: Machine = {
+      target: [true, false],
+      buttons: [[0], [1], [0, 1]],
+    };
+    const result = solveToggle(machine);
+    expect(result).not.toBeNull();
+    expect(verifyToggle(machine, result)).toBe(true);
+    expect(result).toEqual([0]);
+  });
+
+  it('should return minimum button presses', () => {
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [[0], [1], [0, 1]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([2]);
+  });
+
+  it('should handle single button single light', () => {
+    const machine: Machine = { target: [true], buttons: [[0]] };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('should return null with no buttons and target on', () => {
+    const machine: Machine = { target: [true], buttons: [] };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('should handle larger puzzle with 5 lights', () => {
+    const machine: Machine = {
+      target: [true, true, true, true, true],
+      buttons: [[0, 1], [1, 2], [2, 3], [3, 4], [0, 4]],
+    };
+    const result = solveToggle(machine);
+    if (result !== null) {
+      expect(verifyToggle(machine, result)).toBe(true);
+    }
+  });
+
+  it('should return lexicographically smallest when tied on count', () => {
+    const machine: Machine = {
+      target: [true],
+      buttons: [[0], [0]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0]);
+  });
+
+  it('should handle identity matrix (each button toggles one unique light)', () => {
+    const machine: Machine = {
+      target: [true, false, true],
+      buttons: [[0], [1], [2]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0, 2]);
+  });
+
+  it('should handle all lights on target with single button that toggles all', () => {
+    const machine: Machine = {
+      target: [true, true, true],
+      buttons: [[0, 1, 2]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0]);
+    expect(verifyToggle(machine, result)).toBe(true);
+  });
+
+  it('should handle overlapping buttons requiring multiple presses', () => {
+    // 3 lights, 3 buttons
+    // b0: {0,1}, b1: {1,2}, b2: {0,2}
+    // target: [true, true, true]
+    // Need: b0 XOR b2 = 1 (light 0), b0 XOR b1 = 1 (light 1), b1 XOR b2 = 1 (light 2)
+    // Adding all: 0 = 1 (mod 2) -> inconsistent? Let's check:
+    // b0+b2=1, b0+b1=1, b1+b2=1 => b0-b1=b2-b0 => and (b0+b2)+(b1+b2)-(b0+b1) = 2*b2 = 1 => b2=1/2... impossible in GF(2)
+    // Sum of all equations: 2(b0+b1+b2) = 3 => 0 = 1 (mod 2) => no solution
+    const machine: Machine = {
+      target: [true, true, true],
+      buttons: [[0, 1], [1, 2], [0, 2]],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('should handle 10x10 puzzle', () => {
+    const n = 10;
+    const machine: Machine = {
+      target: new Array(n).fill(true),
+      buttons: Array.from({ length: n }, (_, i) => [i, (i + 1) % n]),
+    };
+    const result = solveToggle(machine);
+    if (result !== null) {
+      expect(verifyToggle(machine, result)).toBe(true);
+    }
+  });
+
+  it('should handle empty target (0 lights)', () => {
+    const machine: Machine = { target: [], buttons: [[]] };
+    const result = solveToggle(machine);
+    expect(result).toEqual([]);
+  });
+
+  it('should handle buttons that toggle no lights', () => {
+    const machine: Machine = {
+      target: [false],
+      buttons: [[]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([]);
+    expect(verifyToggle(machine, result)).toBe(true);
+  });
+
+  it('should handle more buttons than lights with free variables', () => {
+    // 2 lights, 4 buttons
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [[0], [1], [0, 1], [0]],
+    };
+    const result = solveToggle(machine);
+    expect(result).not.toBeNull();
+    expect(verifyToggle(machine, result)).toBe(true);
+    // Minimum presses should be 1: button 2 toggles both
+    expect(result!.length).toBe(1);
+    expect(result).toEqual([2]);
+  });
+});
+
+describe('solveCounter', () => {
+  it('should return all zeros when target is all zero', () => {
+    const result = solveCounter([0, 0, 0], [[0, 1], [1, 2]], 5);
+    expect(result).toEqual([0, 0]);
+  });
+
+  it('should solve a simple counter puzzle', () => {
+    const result = solveCounter([3], [[0]], 5);
+    expect(result).toEqual([3]);
+  });
+
+  it('should return null when no solution exists', () => {
+    const result = solveCounter([1, 2], [[0, 1]], 3);
+    expect(result).toBeNull();
+  });
+
+  it('should handle multiple buttons', () => {
+    const result = solveCounter([2, 3], [[0], [1]], 5);
+    expect(result).toEqual([2, 3]);
+    expect(verifyCounter([2, 3], [[0], [1]], 5, result)).toBe(true);
+  });
+
+  it('should minimize total presses', () => {
+    const result = solveCounter([1], [[0], [0]], 5);
+    expect(result).not.toBeNull();
+    expect(verifyCounter([1], [[0], [0]], 5, result)).toBe(true);
+    const sum = result!.reduce((s, v) => s + v, 0);
+    expect(sum).toBe(1);
+    expect(result).toEqual([0, 1]);
+  });
+
+  it('should return empty array with no buttons and all zeros', () => {
+    const result = solveCounter([0, 0], [], 3);
+    expect(result).toEqual([]);
+  });
+
+  it('should return null with no buttons and nonzero target', () => {
+    const result = solveCounter([1], [], 3);
+    expect(result).toBeNull();
+  });
+
+  it('should handle mod 2', () => {
+    const result = solveCounter([1, 1], [[0], [0, 1]], 2);
+    expect(result).toEqual([0, 1]);
+    expect(verifyCounter([1, 1], [[0], [0, 1]], 2, result)).toBe(true);
+  });
+
+  it('should handle larger modulus', () => {
+    const result = solveCounter([50], [[0]], 97);
+    expect(result).toEqual([50]);
+    expect(verifyCounter([50], [[0]], 97, result)).toBe(true);
+  });
+
+  it('should handle 3x3 system mod 7', () => {
+    // 3 counters, 3 buttons
+    // b0: {0}, b1: {1}, b2: {2}
+    // target [3, 5, 2], mod 7
+    const result = solveCounter([3, 5, 2], [[0], [1], [2]], 7);
+    expect(result).toEqual([3, 5, 2]);
+    expect(verifyCounter([3, 5, 2], [[0], [1], [2]], 7, result)).toBe(true);
+  });
+
+  it('should minimize total with free variables mod 3', () => {
+    // 1 counter, 3 buttons each affecting counter 0
+    // target 2 mod 3
+    // x0 + x1 + x2 ≡ 2 (mod 3)
+    // Min sum: (0,0,2) or (0,2,0) or (2,0,0) with sum=2
+    // Also (1,1,0), (1,0,1), (0,1,1) with sum=2
+    // Lex smallest: [0,0,2]
+    const result = solveCounter([2], [[0], [0], [0]], 3);
+    expect(result).not.toBeNull();
+    expect(verifyCounter([2], [[0], [0], [0]], 3, result)).toBe(true);
+    const sum = result!.reduce((s, v) => s + v, 0);
+    expect(sum).toBe(2);
+    expect(result).toEqual([0, 0, 2]);
+  });
+
+  it('should handle coupled system mod 5', () => {
+    // 2 counters, 2 buttons
+    // b0: {0, 1}, b1: {1}
+    // target [3, 4] mod 5
+    // x0 ≡ 3 (mod 5) for counter 0
+    // x0 + x1 ≡ 4 (mod 5) for counter 1
+    // => x0=3, x1=1
+    const result = solveCounter([3, 4], [[0, 1], [1]], 5);
+    expect(result).toEqual([3, 1]);
+    expect(verifyCounter([3, 4], [[0, 1], [1]], 5, result)).toBe(true);
+  });
+
+  it('should handle result array length matching number of buttons', () => {
+    const result = solveCounter([1, 2, 3], [[0], [1], [2]], 5);
+    expect(result).not.toBeNull();
+    expect(result!.length).toBe(3);
+    expect(verifyCounter([1, 2, 3], [[0], [1], [2]], 5, result)).toBe(true);
+  });
+
+  it('should handle wrapping correctly', () => {
+    // 1 counter, 1 button, target 0, mod 5
+    // x=0 is the solution (0 presses)
+    const result = solveCounter([0], [[0]], 5);
+    expect(result).toEqual([0]);
+  });
+
+  it('should prefer lexicographically smaller with same cost', () => {
+    // 2 counters, 2 buttons, each affecting only its counter
+    // target [1, 0] mod 3
+    // unique solution: [1, 0]
+    const result = solveCounter([1, 0], [[0], [1]], 3);
+    expect(result).toEqual([1, 0]);
+  });
+});
