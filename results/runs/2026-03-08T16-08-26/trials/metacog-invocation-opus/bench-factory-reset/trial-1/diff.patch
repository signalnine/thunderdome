+    bestSolution = solution.slice();
+
+    const total = 1 << numFree;
+    let prevGray = 0;
+
+    for (let mask = 1; mask < total; mask++) {
+      const gray = mask ^ (mask >> 1);
+      const changedBit = gray ^ prevGray;
+      // Find which free variable changed
+      let f = 0;
+      let tmp = changedBit;
+      while (tmp > 1) { tmp >>= 1; f++; }
+
+      // Toggle this free variable
+      const freeCol = freeVars[f];
+      if (solution[freeCol] === 0) {
+        solution[freeCol] = 1;
