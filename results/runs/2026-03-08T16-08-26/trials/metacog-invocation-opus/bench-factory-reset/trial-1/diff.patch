+      }
+
+      prevGray = gray;
+    }
+  } else {
+    // Meet-in-the-middle: split free vars into two halves.
+    // Enumerate each half, then combine to find minimum-weight solution.
+    const halfA = Math.ceil(numFree / 2);
+    const halfB = numFree - halfA;
+
