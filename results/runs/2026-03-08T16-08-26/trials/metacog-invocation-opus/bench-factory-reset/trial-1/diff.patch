+          // Compare by scanning from bit 0 (earliest B free var):
+          const diff = entries[i].mask ^ best.mask;
+          if (diff !== 0) {
+            const lowestDiffBit = diff & (-diff);
+            // If entries[i] has this bit set, it has 1 at an earlier position
+            if (entries[i].mask & lowestDiffBit) {
