i]) return true;\n    if (a[i] > b[i]) return false;\n  }\n  return false;\n}\n\nfunction modPow(base: number, exp: number, m: number): number {\n  let result = 1;\n  base = ((base % m) + m) % m;\n  while (exp > 0) {\n    if (exp & 1) result = (result * base) % m;\n    exp >>= 1;\n    base = (base * base) % m;\n  }\n  return result;\n}\n\nfunction modInverse(a: number, m: number): number {\n  return modPow(a, m - 2, m);\n}\n\ninterface GaussResult {\n  matrix: number[][];\n  pivotCol: number[];\n  pivotRow: number[];\n  rank: number;\n  freeVars: number[];\n  numCols: number; // number of variable columns (excluding augmented)\n}\n\nfunction gaussianElimination(\n  matrix: number[][],\n  numRows: number,\n  numVarCols: number,\n  modulus: number\n): GaussResult | null {\n  const pivotCol: number[] = [];\n  const pivotRow: number[] = new Array(numVarCols).fill(-1);\n  let row = 0;\n\n  for (let col = 0; col < numVarCols && row < numRows; col++) {\n    let pivotR = -1;\n    for (let r = row; r < numRows; r++) {\n      if (matrix[r][col] !== 0) {\n        pivotR = r;\n        break;\n      }\n    }\n    if (pivotR === -1) continue;\n\n    [matrix[row], matrix[pivotR]] = [matrix[pivotR], matrix[row]];\n    pivotCol.push(col);\n    pivotRow[col] = row;\n\n    if (modulus > 2) {\n      const inv = modInverse(matrix[row][col], modulus);\n      for (let c = col; c <= numVarCols; c++) {\n        matrix[row][c] = (matrix[row][c] * inv) % modulus;\n      }\n    }\n\n    for (let r = 0; r < numRows; r++) {\n      if (r !== row && matrix[r][col] !== 0) {\n        if (modulus === 2) {\n          for (let c = col; c <= numVarCols; c++) {\n            matrix[r][c] ^= matrix[row][c];\n          }\n        } else {\n          const factor = matrix[r][col];\n          for (let c = col; c <= numVarCols; c++) {\n            matrix[r][c] = (((matrix[r][c] - factor * matrix[row][c]) % modulus) + modulus) % modulus;\n          }\n        }\n      }\n    }\n    row++;\n  }\n\n  const rank =