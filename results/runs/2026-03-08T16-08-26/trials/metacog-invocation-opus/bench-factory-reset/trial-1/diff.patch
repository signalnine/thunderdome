+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter, Machine } from '../src/index.js';
+
+function verifyToggle(machine: Machine, result: number[] | null): boolean {
+  if (result === null) return true;
+  const state = new Array(machine.target.length).fill(false);
+  for (const btnIdx of result) {
+    for (const lightIdx of machine.buttons[btnIdx]) {
+      state[lightIdx] = !state[lightIdx];
+    }
+  }
+  for (let i = 0; i < machine.target.length; i++) {
+    if (state[i] !== machine.target[i]) return false;
+  }
+  return true;
+}
+
+function verifyCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number,
+  result: number[] | null
+): boolean {
+  if (result === null) return true;
+  const state = new Array(lights.length).fill(0);
+  for (let i = 0; i < buttons.length; i++) {
+    for (const counterIdx of buttons[i]) {
+      state[counterIdx] = (state[counterIdx] + result[i]) % modulus;
+    }
+  }
+  for (let i = 0; i < lights.length; i++) {
+    if (state[i] !== ((lights[i] % modulus + modulus) % modulus)) return false;
+  }
+  return true;
+}
+
+describe('performance tests', () => {
+  it('solveToggle: 20 lights, 20 buttons, full rank', () => {
+    const n = 20;
+    const machine: Machine = {
+      target: Array.from({ length: n }, (_, i) => i % 2 === 0),
+      buttons: Array.from({ length: n }, (_, i) => {
+        const affected = [i];
+        if (i > 0) affected.push(i - 1);
+        return affected;
+      }),
+    };
+    const result = solveToggle(machine);
+    if (result !== null) {
+      expect(verifyToggle(machine, result)).toBe(true);
+    }
+  });
+
+  it('solveToggle: 40 lights, 40 buttons, full rank', () => {
+    const n = 40;
+    const machine: Machine = {
+      target: Array.from({ length: n }, (_, i) => i % 3 === 0),
+      buttons: Array.from({ length: n }, (_, i) => {
+        const affected = [i];
+        if (i > 0) affected.push(i - 1);
+        if (i < n - 1) affected.push(i + 1);
+        return affected;
+      }),
+    };
+    const result = solveToggle(machine);
+    if (result !== null) {
+      expect(verifyToggle(machine, result)).toBe(true);
+    }
+  });
+
+  it('solveToggle: 20 lights, 30 buttons (10 free vars)', () => {
+    const nLights = 20;
+    const nButtons = 30;
+    const machine: Machine = {
+      target: Array.from({ length: nLights }, () => true),
+      buttons: Array.from({ length: nButtons }, (_, i) => {
+        const affected = [i % nLights];
+        if (i % 3 === 0) affected.push((i + 1) % nLights);
+        return affected;
+      }),
+    };
+    const result = solveToggle(machine);
+    if (result !== null) {
+      expect(verifyToggle(machine, result)).toBe(true);
+    }
+  });
+
+  it('solveCounter: 20 counters, 20 buttons, mod 7', () => {
+    const n = 20;
+    const lights = Array.from({ length: n }, (_, i) => (i * 3 + 1) % 7);
+    const buttons = Array.from({ length: n }, (_, i) => {
+      const affected = [i];
+      if (i > 0) affected.push(i - 1);
+      return affected;
+    });
+    const result = solveCounter(lights, buttons, 7);
+    if (result !== null) {
+      expect(verifyCounter(lights, buttons, 7, result)).toBe(true);
+    }
+  });
+
+  it('solveCounter: 40 counters, 40 buttons, mod 97, full rank', () => {
+    const n = 40;
+    const lights = Array.from({ length: n }, (_, i) => (i * 13 + 5) % 97);
+    const buttons = Array.from({ length: n }, (_, i) => {
+      const affected = [i];
+      if (i > 0) affected.push(i - 1);
+      if (i < n - 1) affected.push(i + 1);
+      return affected;
+    });
+    const result = solveCounter(lights, buttons, 97);
+    if (result !== null) {
+      expect(verifyCounter(lights, buttons, 97, result)).toBe(true);
+      expect(result.length).toBe(n);
+    }
+  });
+
+  it('solveCounter: 10 counters, 12 buttons, mod 5 (2 free vars)', () => {
+    const nCounters = 10;
+    const nButtons = 12;
+    const lights = Array.from({ length: nCounters }, (_, i) => (i * 2 + 1) % 5);
+    const buttons = Array.from({ length: nButtons }, (_, i) => {
+      const affected = [i % nCounters];
+      if (i % 2 === 0) affected.push((i + 3) % nCounters);
+      return affected;
+    });
+    const result = solveCounter(lights, buttons, 5);
+    if (result !== null) {
+      expect(verifyCounter(lights, buttons, 5, result)).toBe(true);
+    }
+  });
+});
