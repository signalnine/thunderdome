+// Direction enum: 0 = down, 1 = down-left, 2 = down-right
+const DOWN = 0;
+const DOWN_LEFT = 1;
+const DOWN_RIGHT = 2;
+
+type Direction = 0 | 1 | 2;
+
+function dirDelta(dir: Direction): [number, number] {
+  switch (dir) {
+    case DOWN: return [1, 0];
+    case DOWN_LEFT: return [1, -1];
+    case DOWN_RIGHT: return [1, 1];
+  }
+}
+
+function stateKey(row: number, col: number, dir: Direction): string {
+  return `${row},${col},${dir}`;
+}
+
+function findSource(grid: string[][]): [number, number] {
+  const cols = grid[0].length;
+  for (let c = 0; c < cols; c++) {
+    if (grid[0][c] === 'S') {
+      return [0, c];
+    }
+  }
+  throw new Error('No source found');
+}
+
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const [sr, sc] = findSource(grid);
+
+  const visited = new Set<string>();
+  const seen = new Set<string>();
+
+  // Queue entries: [row, col, direction]
+  const queue: Array<[number, number, Direction]> = [];
+
+  // Source cell is visited
+  visited.add(`${sr},${sc}`);
+
+  // Initial beam goes down from source
+  const initKey = stateKey(sr, sc, DOWN);
+  seen.add(initKey);
+  queue.push([sr, sc, DOWN]);
+
+  let head = 0;
+  while (head < queue.length) {
+    const [r, c, dir] = queue[head++];
+
+    // Determine next position
+    const [dr, dc] = dirDelta(dir);
+    const nr = r + dr;
+    const nc = c + dc;
+
+    // Check bounds
+    if (nr < 0 || nr >= rows || nc < 0 || nc >= cols) {
+      continue; // beam exits grid
+    }
+
+    visited.add(`${nr},${nc}`);
+
+    if (grid[nr][nc] === '^') {
+      // Splitter: beam splits into down-left and down-right
+      for (const newDir of [DOWN_LEFT, DOWN_RIGHT] as Direction[]) {
+        const key = stateKey(nr, nc, newDir);
+        if (!seen.has(key)) {
+          seen.add(key);
+          queue.push([nr, nc, newDir]);
+        }
+      }
+    } else {
+      // Continue in same direction
+      const key = stateKey(nr, nc, dir);
+      if (!seen.has(key)) {
+        seen.add(key);
+        queue.push([nr, nc, dir]);
+      }
+    }
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const [sr, sc] = findSource(grid);
+
+  // We propagate path counts through states.
+  // A state is (row, col, direction).
+  // We process states in topological order (by row, since all beams move downward).
+  // For each state, we compute how many paths reach it, then propagate to successors.
+
+  const pathCounts = new Map<string, bigint>();
+
+  // Initial state: source cell, going down, 1 path
+  const initKey = stateKey(sr, sc, DOWN);
+  pathCounts.set(initKey, 1n);
+
+  let totalExitPaths = 0n;
+
+  // Process states row by row (topological order since all directions go down)
+  // Collect all states per row, process them
+  // We need to iterate: for each row, for each col, for each direction
+  // But we only need to process states that have nonzero path counts.
+
+  // Use a queue sorted by row. Since all moves go to row+1, we can process row by row.
+  // Actually, let's use a more efficient approach: iterate rows 0..rows-1,
+  // and for each state in that row with a path count, propagate to next row.
+
+  // First, group states by row. Since states are created dynamically, let's use
+  // an array of maps.
+  const rowStates: Map<string, bigint>[] = new Array(rows);
+  for (let i = 0; i < rows; i++) {
+    rowStates[i] = new Map();
+  }
+
+  rowStates[sr].set(`${sc},${DOWN}`, 1n);
+
+  for (let r = 0; r < rows; r++) {
+    for (const [key, count] of rowStates[r]) {
+      const commaIdx = key.indexOf(',');
+      const c = parseInt(key.substring(0, commaIdx));
+      const dir = parseInt(key.substring(commaIdx + 1)) as Direction;
+
+      const [dr, dc] = dirDelta(dir);
+      const nr = r + dr;
+      const nc = c + dc;
+
+      if (nr < 0 || nr >= rows || nc < 0 || nc >= cols) {
+        // Beam exits grid — count as exit path
+        totalExitPaths += count;
+        continue;
+      }
+
+      if (grid[nr][nc] === '^') {
+        // Splitter: splits into two directions
+        for (const newDir of [DOWN_LEFT, DOWN_RIGHT] as Direction[]) {
+          const nkey = `${nc},${newDir}`;
+          const existing = rowStates[nr].get(nkey) ?? 0n;
+          rowStates[nr].set(nkey, existing + count);
+        }
+      } else {
+        // Continue in same direction
+        const nkey = `${nc},${dir}`;
+        const existing = rowStates[nr].get(nkey) ?? 0n;
+        rowStates[nr].set(nkey, existing + count);
+      }
+    }
+  }
+
+  // Also count beams that are on the last row and would exit on next step
+  // Actually, those are already handled: when nr >= rows, we add to totalExitPaths.
+  // But we need to handle beams that are still on the last row (rows-1).
+  // When r = rows-1, nr = rows which is >= rows, so they get counted as exits. ✓
+
+  return totalExitPaths;
+}
