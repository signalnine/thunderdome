+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TGQ4JBPi2FpphpdFUJyv2z","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach } from 'vitest';\n     2→import {\n     3→  registerUser,\n     4→  validateUser,\n     5→  getUserById,\n     6→  getAllUsers,\n     7→  resetDefaultConnection,\n     8→} from '../src/user.js';\n     9→\n    10→describe('User Management', () => {\n    11→  beforeEach(() => {\n    12→    resetDefaultConnection();\n    13→  });\n    14→\n    15→  it('registers a new user with valid data', () => {\n    16→    const user = registerUser({\n    17→      name: 'Alice',\n    18→      email: 'alice@example.com',\n    19→      role: 'admin',\n    20→    });\n    21→    expect(user.id).toBe(1);\n    22→    expect(user.name).toBe('Alice');\n    23→    expect(user.email).toBe('alice@example.com');\n    24→    expect(user.role).toBe('admin');\n    25→  });\n    26→\n    27→  it('throws on invalid user data', () => {\n    28→    expect(() =>\n    29→      registerUser({ name: '', email: 'bad', role: 'admin' })\n    30→    ).toThrow('Invalid user data');\n    31→  });\n    32→\n    33→  it('retrieves a user by id', () => {\n    34→    const created = registerUser({\n    35→      name: 'Bob',\n    36→      email: 'bob@example.com',\n    37→      role: 'user',\n    38→    });\n    39→    const found = getUserById(created.id);\n    40→    expect(found).not.toBeNull();\n    41→    expect(found!.name).toBe('Bob');\n    42→  });\n    43→\n    44→  it('returns null for nonexistent user', () => {\n    45→    const found = getUserById(999);\n    46→    expect(found).toBeNull();\n    47→  });\n    48→\n    49→  it('lists all users', () => {\n    50→    registerUser({ name: 'A', email: 'a@a.com', role: 'user' });\n    51→    registerUser({ name: 'B', email: 'b@b.com', role: 'viewer' });\n    52→    const all = getAllUsers();\n    53→    expect(all).toHaveLength(2);\n    54→  });\n    55→\n    56→  it('validates us