d) {\n        summary[entry.task] = 0;\n      }\n      summary[entry.task] += duration;\n    }\n\n    return summary;\n  }\n\n  getRunning(): TimeEntry | undefined {\n    return this.entries.find((entry) => !entry.stop);\n  }\n\n  private load(): void {\n    try {\n      const data = fs.readFileSync(this.filePath, \"utf-8\");\n      const parsed: unknown = JSON.parse(data);\n      if (Array.isArray(parsed)) {\n        this.entries = parsed as TimeEntry[];\n      }\n    } catch {\n      this.entries = [];\n    }\n  }\n\n  private save(): void {\n    const dir = path.dirname(this.filePath);\n    fs.mkdirSync(dir, { recursive: true });\n    fs.writeFileSync(this.filePath, JSON.stringify(this.entries, null, 2), \"utf-8\");\n  }\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":266,"cache_read_input_tokens":22397,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":266},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"5cbb850a-0d02-4b5d-8f0a-8ace1cb90381","uuid":"c1fcabcd-5dd4-4d80-8ef7-b0a843cff15c"}
