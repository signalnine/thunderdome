@@ -0,0 +1,102 @@
+import fs from "node:fs";
+import path from "node:path";
+
+export interface TimeEntry {
+  task: string;
+  start: string;
+  stop?: string;
+}
+
+export interface TimeSummary {
+  [task: string]: number;
+}
+
+export class TimeTracker {
+  private entries: TimeEntry[] = [];
+  private readonly filePath: string;
+
+  constructor(filePath: string) {
+    this.filePath = path.resolve(filePath);
+    this.load();
+  }
+
+  start(task: string): void {
+    if (!task || task.trim().length === 0) {
+      throw new Error("Task name cannot be empty");
+    }
+
+    const running = this.getRunning();
+    if (running) {
+      running.stop = new Date().toISOString();
+    }
+
+    this.entries.push({
+      task,
+      start: new Date().toISOString(),
+    });
+
+    this.save();
+  }
+
+  stop(): TimeEntry {
+    const running = this.getRunning();
+    if (!running) {
+      throw new Error("No timer is currently running");
+    }
+
+    running.stop = new Date().toISOString();
+    this.save();
+    return { ...running };
+  }
+
+  getEntries(from?: Date, to?: Date): TimeEntry[] {
+    return this.entries.filter((entry) => {
+      const start = new Date(entry.start);
+      if (from && start < from) return false;
+      if (to && start > to) return false;
+      return true;
+    });
+  }
+
+  getSummary(from?: Date, to?: Date): TimeSummary {
+    const filtered = this.getEntries(from, to);
+    const summary: TimeSummary = {};
+
+    for (const entry of filtered) {
+      const start = new Date(entry.start).getTime();
+      const end = entry.stop
+        ? new Date(entry.stop).getTime()
+        : Date.now();
+      const duration = end - start;
+
+      if (summary[entry.task] === undefined) {
+        summary[entry.task] = 0;
+      }
+      summary[entry.task] += duration;
+    }
+
+    return summary;
+  }
+
+  getRunning(): TimeEntry | undefined {
+    return this.entries.find((entry) => !entry.stop);
+  }
+
+  private load(): void {
+    try {
+      const data = fs.readFileSync(this.filePath, "utf-8");
+      const parsed: unknown = JSON.parse(data);
+      if (Array.isArray(parsed)) {
+        this.entries = parsed as TimeEntry[];
+      }
+    } catch {
+      this.entries = [];
+    }
+  }
+
+  private save(): void {
+    const dir = path.dirname(this.filePath);
+    fs.mkdirSync(dir, { recursive: true });
+    fs.writeFileSync(this.filePath, JSON.stringify(this.entries, null, 2), "utf-8");
+  }
+}
