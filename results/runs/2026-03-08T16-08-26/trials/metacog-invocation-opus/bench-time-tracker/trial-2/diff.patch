+import { describe, it, expect, beforeEach, afterEach } from "vitest";
+import fs from "node:fs";
+import path from "node:path";
+import os from "node:os";
+import { TimeTracker } from "./tracker.js";
+
+function tmpFile(): string {
+  const dir = fs.mkdtempSync(path.join(os.tmpdir(), "tt-"));
+  return path.join(dir, "data.json");
+}
+
+function cleanup(filePath: string): void {
+  try {
+    fs.rmSync(path.dirname(filePath), { recursive: true, force: true });
+  } catch {
+    // ignore
+  }
+}
+
+describe("TimeTracker", () => {
+  let fp: string;
+
+  beforeEach(() => {
+    fp = tmpFile();
+  });
+
+  afterEach(() => {
+    cleanup(fp);
+  });
+
+  it("should start and stop a timer", () => {
+    const tracker = new TimeTracker(fp);
+    tracker.start("coding");
+    const entry = tracker.stop();
+    expect(entry.task).toBe("coding");
+    expect(entry.start).toBeDefined();
+    expect(entry.stop).toBeDefined();
+  });
+
+  it("should throw when starting with empty name", () => {
+    const tracker = new TimeTracker(fp);
+    expect(() => tracker.start("")).toThrow("Task name cannot be empty");
+    expect(() => tracker.start("   ")).toThrow("Task name cannot be empty");
+  });
+
+  it("should throw when stopping with no running timer", () => {
+    const tracker = new TimeTracker(fp);
+    expect(() => tracker.stop()).toThrow("No timer is currently running");
+  });
+
+  it("should auto-stop previous timer when starting a new one", () => {
+    const tracker = new TimeTracker(fp);
+    tracker.start("task1");
+    tracker.start("task2");
+    const entries = tracker.getEntries();
+    expect(entries).toHaveLength(2);
+    expect(entries[0].stop).toBeDefined();
+    expect(entries[1].stop).toBeUndefined();
+  });
+
+  it("should persist data to file", () => {
+    const tracker1 = new TimeTracker(fp);
+    tracker1.start("persist-test");
+    tracker1.stop();
+
+    const tracker2 = new TimeTracker(fp);
+    const entries = tracker2.getEntries();
+    expect(entries).toHaveLength(1);
+    expect(entries[0].task).toBe("persist-test");
+  });
+
+  it("should create parent directories if they don't exist", () => {
+    const nested = path.join(os.tmpdir(), "tt-nested", "a", "b", "data.json");
+    const tracker = new TimeTracker(nested);
+    tracker.start("deep");
+    tracker.stop();
+    expect(fs.existsSync(nested)).toBe(true);
+    fs.rmSync(path.join(os.tmpdir(), "tt-nested"), { recursive: true, force: true });
+  });
+
+  it("should filter entries by date range", () => {
+    const now = Date.now();
+
+    // Manually write entries with known timestamps
+    const entries = [
+      { task: "old", start: new Date(now - 86400000 * 2).toISOString(), stop: new Date(now - 86400000 * 2 + 1000).toISOString() },
+      { task: "recent", start: new Date(now - 3600000).toISOString(), stop: new Date(now - 3500000).toISOString() },
+    ];
+    fs.writeFileSync(fp, JSON.stringify(entries), "utf-8");
+
+    const tracker = new TimeTracker(fp);
+    const filtered = tracker.getEntries(new Date(now - 86400000));
+    expect(filtered).toHaveLength(1);
+    expect(filtered[0].task).toBe("recent");
+  });
+
+  it("should summarize time per task", () => {
+    const now = Date.now();
+
+    const entries = [
+      { task: "coding", start: new Date(now - 10000).toISOString(), stop: new Date(now - 5000).toISOString() },
+      { task: "coding", start: new Date(now - 4000).toISOString(), stop: new Date(now - 2000).toISOString() },
+      { task: "review", start: new Date(now - 3000).toISOString(), stop: new Date(now - 1000).toISOString() },
+    ];
+    fs.writeFileSync(fp, JSON.stringify(entries), "utf-8");
+
+    const tracker = new TimeTracker(fp);
+    const summary = tracker.getSummary();
+    expect(summary["coding"]).toBeCloseTo(7000, -2);
+    expect(summary["review"]).toBeCloseTo(2000, -2);
+  });
+
+  it("should include running timer duration in summary using current time", () => {
+    const tracker = new TimeTracker(fp);
+    tracker.start("running-task");
+    const summary = tracker.getSummary();
+    expect(summary["running-task"]).toBeGreaterThanOrEqual(0);
+    expect(summary["running-task"]).toBeDefined();
+    // Verify running task appears in summary (duration may be 0ms if same tick)
+    expect("running-task" in summary).toBe(true);
+  });
+
+  it("should support unicode and emoji task names", () => {
+    const tracker = new TimeTracker(fp);
+    tracker.start("📝 日本語タスク");
+    const entry = tracker.stop();
+    expect(entry.task).toBe("📝 日本語タスク");
+
+    const tracker2 = new TimeTracker(fp);
+    const entries = tracker2.getEntries();
+    expect(entries[0].task).toBe("📝 日本語タスク");
+  });
+
+  it("should return running entry from getRunning", () => {
+    const tracker = new TimeTracker(fp);
+    expect(tracker.getRunning()).toBeUndefined();
+    tracker.start("active");
+    const running = tracker.getRunning();
+    expect(running).toBeDefined();
+    expect(running!.task).toBe("active");
+    tracker.stop();
+    expect(tracker.getRunning()).toBeUndefined();
+  });
+});
