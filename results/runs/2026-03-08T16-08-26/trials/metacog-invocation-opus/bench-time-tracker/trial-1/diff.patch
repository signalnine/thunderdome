diff --git a/src/tracker.test.ts b/src/tracker.test.ts
new file mode 100644
index 0000000..f07c367
--- /dev/null
+++ b/src/tracker.test.ts
@@ -0,0 +1,225 @@
+import { describe, it, expect, beforeEach, afterEach } from "vitest";
+import fs from "node:fs";
+import path from "node:path";
+import os from "node:os";
+import { TimeTracker } from "./tracker.js";
+
+function tmpFile(): string {
+  const dir = fs.mkdtempSync(path.join(os.tmpdir(), "tracker-test-"));
+  return path.join(dir, "data.json");
+}
+
+function cleanup(filePath: string): void {
+  try {
+    fs.rmSync(path.dirname(filePath), { recursive: true, force: true });
+  } catch {
+    // ignore
+  }
+}
+
+describe("TimeTracker", () => {
+  let file: string;
+
+  beforeEach(() => {
+    file = tmpFile();
+  });
+
+  afterEach(() => {
+    cleanup(file);
+  });
+
+  describe("start/stop", () => {
+    it("should start and stop a timer", () => {
+      const tracker = new TimeTracker(file);
+      tracker.start("coding");
+      expect(tracker.isRunning()).toBe(true);
+
+      const entry = tracker.stop();
+      expect(entry.task).toBe("coding");
+      expect(entry.start).toBeInstanceOf(Date);
+      expect(entry.end).toBeInstanceOf(Date);
+      expect(tracker.isRunning()).toBe(false);
+    });
+
+    it("should throw when starting with empty name", () => {
+      const tracker = new TimeTracker(file);
+      expect(() => tracker.start("")).toThrow("Task name cannot be empty");
+      expect(() => tracker.start("   ")).toThrow("Task name cannot be empty");
+    });
+
+    it("should throw when stopping with no running timer", () => {
+      const tracker = new TimeTracker(file);
+      expect(() => tracker.stop()).toThrow("No timer is currently running");
+    });
+
+    it("should auto-stop previous timer when starting new one", () => {
+      const tracker = new TimeTracker(file);
+      tracker.start("task1");
+      tracker.start("task2");
+
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(2);
+      expect(entries[0].task).toBe("task1");
+      expect(entries[0].end).toBeInstanceOf(Date);
+      expect(entries[1].task).toBe("task2");
+      expect(entries[1].end).toBeNull();
+    });
+  });
+
+  describe("persistence", () => {
+    it("should persist entries to file", () => {
+      const tracker1 = new TimeTracker(file);
+      tracker1.start("coding");
+      tracker1.stop();
+
+      const tracker2 = new TimeTracker(file);
+      const entries = tracker2.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].task).toBe("coding");
+      expect(entries[0].start).toBeInstanceOf(Date);
+      expect(entries[0].end).toBeInstanceOf(Date);
+    });
+
+    it("should create parent directories automatically", () => {
+      const nested = path.join(
+        os.tmpdir(),
+        `tracker-test-${Date.now()}`,
+        "a",
+        "b",
+        "c",
+        "data.json"
+      );
+      const tracker = new TimeTracker(nested);
+      tracker.start("test");
+      tracker.stop();
+
+      expect(fs.existsSync(nested)).toBe(true);
+      fs.rmSync(path.join(os.tmpdir(), `tracker-test-${Date.now()}`), {
+        recursive: true,
+        force: true,
+      });
+    });
+
+    it("should handle missing file gracefully", () => {
+      const tracker = new TimeTracker(file);
+      expect(tracker.getEntries()).toEqual([]);
+    });
+  });
+
+  describe("getEntries", () => {
+    it("should return all entries without filter", () => {
+      const tracker = new TimeTracker(file);
+      tracker.start("a");
+      tracker.stop();
+      tracker.start("b");
+      tracker.stop();
+
+      expect(tracker.getEntries()).toHaveLength(2);
+    });
+
+    it("should filter entries by date range", () => {
+      const tracker = new TimeTracker(file);
+
+      tracker.start("old-task");
+      tracker.stop();
+
+      const from = new Date();
+
+      tracker.start("new-task");
+      tracker.stop();
+
+      const filtered = tracker.getEntries({ from });
+      expect(filtered).toHaveLength(1);
+      expect(filtered[0].task).toBe("new-task");
+    });
+
+    it("should filter with to date", () => {
+      const tracker = new TimeTracker(file);
+
+      tracker.start("first");
+      tracker.stop();
+
+      const to = new Date();
+
+      tracker.start("second");
+      tracker.stop();
+
+      // Filter: only entries started before or at 'to'
+      const filtered = tracker.getEntries({ to });
+      // first started before 'to', second started after—but they could be at the same ms
+      expect(filtered.length).toBeGreaterThanOrEqual(1);
+      expect(filtered.every((e) => e.start <= to)).toBe(true);
+    });
+
+    it("should return copies, not references", () => {
+      const tracker = new TimeTracker(file);
+      tracker.start("task");
+      tracker.stop();
+
+      const entries = tracker.getEntries();
+      entries[0].task = "modified";
+
+      const again = tracker.getEntries();
+      expect(again[0].task).toBe("task");
+    });
+  });
+
+  describe("getSummary", () => {
+    it("should sum time per task", () => {
+      const tracker = new TimeTracker(file);
+
+      tracker.start("coding");
+      tracker.stop();
+      tracker.start("coding");
+      tracker.stop();
+      tracker.start("review");
+      tracker.stop();
+
+      const summary = tracker.getSummary();
+      expect(summary["coding"]).toBeGreaterThanOrEqual(0);
+      expect(summary["review"]).toBeGreaterThanOrEqual(0);
