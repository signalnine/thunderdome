index 0000000..de72ff2
--- /dev/null
+++ b/src/tracker.ts
@@ -0,0 +1,137 @@
+import fs from "node:fs";
+import path from "node:path";
+
+export interface TimeEntry {
+  task: string;
+  start: Date;
+  end: Date | null;
+}
+
+interface SerializedEntry {
+  task: string;
+  start: string;
+  end: string | null;
+}
+
+export interface DateRange {
+  from?: Date;
+  to?: Date;
+}
+
+export interface TimeSummary {
+  [task: string]: number;
+}
+
+export class TimeTracker {
+  private entries: TimeEntry[] = [];
+  private filePath: string;
+
+  constructor(filePath: string) {
+    this.filePath = path.resolve(filePath);
+    this.load();
+  }
+
+  start(task: string): void {
+    if (!task || task.trim().length === 0) {
+      throw new Error("Task name cannot be empty");
+    }
+
+    // Auto-stop any running timer
+    const running = this.getRunningEntry();
+    if (running) {
+      running.end = new Date();
+    }
+
+    this.entries.push({
+      task,
+      start: new Date(),
+      end: null,
+    });
+
+    this.save();
+  }
+
+  stop(): TimeEntry {
+    const running = this.getRunningEntry();
+    if (!running) {
+      throw new Error("No timer is currently running");
+    }
+
+    running.end = new Date();
+    this.save();
+
+    return { ...running };
+  }
+
+  getEntries(range?: DateRange): TimeEntry[] {
+    if (!range) {
+      return this.entries.map((e) => ({ ...e }));
+    }
+
+    return this.entries
+      .filter((entry) => {
+        if (range.from && entry.start < range.from) {
+          return false;
+        }
+        if (range.to && entry.start > range.to) {
+          return false;
+        }
+        return true;
+      })
+      .map((e) => ({ ...e }));
+  }
+
+  getSummary(): TimeSummary {
+    const summary: TimeSummary = {};
+    const now = new Date();
+
+    for (const entry of this.entries) {
+      const end = entry.end ?? now;
+      const duration = end.getTime() - entry.start.getTime();
+      summary[entry.task] = (summary[entry.task] ?? 0) + duration;
+    }
+
+    return summary;
+  }
+
+  isRunning(): boolean {
+    return this.getRunningEntry() !== null;
+  }
+
+  private getRunningEntry(): TimeEntry | null {
+    for (let i = this.entries.length - 1; i >= 0; i--) {
+      if (this.entries[i].end === null) {
+        return this.entries[i];
+      }
+    }
+    return null;
+  }
+
+  private load(): void {
+    try {
+      const data = fs.readFileSync(this.filePath, "utf-8");
+      const parsed: SerializedEntry[] = JSON.parse(data);
+      this.entries = parsed.map((e) => ({
+        task: e.task,
+        start: new Date(e.start),
+        end: e.end ? new Date(e.end) : null,
+      }));
+    } catch {
+      // File doesn't exist or is invalid — start fresh
+      this.entries = [];
+    }
+  }
+
+  private save(): void {
+    const dir = path.dirname(this.filePath);
+    fs.mkdirSync(dir, { recursive: true });
+
+    const serialized: SerializedEntry[] = this.entries.map((e) => ({
+      task: e.task,
+      start: e.start.toISOString(),
+      end: e.end ? e.end.toISOString() : null,
+    }));
+
+    fs.writeFileSync(this.filePath, JSON.stringify(serialized, null, 2), "utf-8");
+  }
+}
