ers.createOrder('user1', cartId, total.total);\n    expect(orders.getOrder(orderId)!.status).toBe(OrderStatus.PENDING);\n\n    // Process payment\n    const paymentResult = await payment.processPayment(orderId, total.total);\n    expect(paymentResult.status).toBe(PaymentStatus.SUCCESS);\n\n    // Update order status\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    expect(orders.getOrder(orderId)!.status).toBe(OrderStatus.CONFIRMED);\n\n    // Check notifications\n    await new Promise(r => setTimeout(r, 10));\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThan(0);\n\n    // Check analytics\n    expect(analytics.getRevenue()).toBeCloseTo(1162.7);\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n  });\n});\n","structuredPatch":[{"oldStart":377,"oldLines":6,"newStart":377,"newLines":34,"lines":["     // 1 order / 2 unique carts = 0.5","     expect(analytics.getConversionRate()).toBe(0.5);","   });","+","+  it('should rank products by order quantity', async () => {","+    const analytics = createAnalyticsService(bus);","+    const cartService = createCartService(bus);","+    const orders = createOrderService(bus);","+","+    const cart1 = cartService.createCart('user1');","+    cartService.addItem(cart1, 'p1', 3);","+    cartService.addItem(cart1, 'p2', 1);","+","+    await new Promise(r => setTimeout(r, 10));","+","+    orders.createOrder('user1', cart1, 100);","+","+    await new Promise(r => setTimeout(r, 10));","+","+    const top = analytics.getTopProducts(5);","+    expect(top).toHaveLength(2);","+    expect(top[0].productId).toBe('p1');","+    expect(top[0].count).toBe(3);","+    expect(top[1].productId).toBe('p2');","+    expect(top[1].count).toBe(1);","+  });","+","+  it('should return 0 conversion rate with no carts', () => {","+    const analytics = createAnalyticsService(bus);","+    expect(analytics.getConversionRate()).toBe(0);","+  });"," });"," "," describe('Integrati