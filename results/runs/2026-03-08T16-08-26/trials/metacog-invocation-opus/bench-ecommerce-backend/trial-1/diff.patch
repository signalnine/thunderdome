(1);\n    expect(catalog.listProducts()).toHaveLength(3);\n  });\n\n  it('should search products by name', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('Blue Widget', 1, 'x');\n    catalog.createProduct('Red Gadget', 2, 'x');\n    catalog.createProduct('Blue Gadget', 3, 'x');\n    expect(catalog.searchProducts('blue')).toHaveLength(2);\n    expect(catalog.searchProducts('gadget')).toHaveLength(2);\n  });\n\n  it('should update a product', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Old', 5, 'c');\n    catalog.updateProduct(id, { name: 'New', price: 10 });\n    expect(catalog.getProduct(id)).toEqual({ id, name: 'New', price: 10, category: 'c' });\n  });\n\n  it('should remove a product', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('X', 1, 'c');\n    expect(catalog.removeProduct(id)).toBe(true);\n    expect(catalog.getProduct(id)).toBeNull();\n    expect(catalog.removeProduct('nonexistent')).toBe(false);\n  });\n\n  it('should emit product:created event', async () => {\n    const catalog = createCatalogService(bus);\n    const events: unknown[] = [];\n    bus.on(Events.PRODUCT_CREATED, (p) => { events.push(p); });\n    catalog.createProduct('Test', 5, 'c');\n    // Wait for async event handling\n    await new Promise(r => setTimeout(r, 10));\n    expect(events).toHaveLength(1);\n  });\n});\n\ndescribe('InventoryService', () => {\n  it('should set and get stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 100);\n    expect(inventory.getStock('p1')).toBe(100);\n  });\n\n  it('should return 0 for unknown product stock', () => {\n    const inventory = createInventoryService(bus);\n    expect(inventory.getStock('unknown')).toBe(0);\n  });\n\n  it('should reserve stock successfully', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 10);\n    expect(inventory.reserve('p1', 5)).toBe(true);\n    expect(inventory.reserve('p1', 5)).toBe(true);\n    expect(inventory.reserve('p1', 1)).toBe(false);\n  });\n\n  it('should release reserved stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 10);\n    inventory.reserve('p1', 5);\n    inventory.release('p1', 3);\n    expect(inventory.reserve('p1', 8)).toBe(true);\n  });\n\n  it('should emit low stock alert', async () => {\n    const inventory = createInventoryService(bus);\n    const alerts: unknown[] = [];\n    bus.on(Events.LOW_STOCK_ALERT, (p) => { alerts.push(p); });\n    inventory.setLowStockThreshold('p1', 5);\n    inventory.setStock('p1', 3);\n    await new Promise(r => setTimeout(r, 10));\n    expect(alerts.length).toBeGreaterThanOrEqual(1);\n  });\n});\n\ndescribe('CartService', () => {\n  it('should create and retrieve a cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    expect(cart.getCart(id)).toEqual({ id, userId: 'user1', items: [] });\n  });\n\n  it('should return null for unknown cart', () => {\n    const cart = createCartService(bus);\n    expect(cart.getCart('nonexistent')).toBeNull();\n  });\n\n  it('should add items and consolidate duplicates', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p1', 3);\n    const c = cart.getCart(id);\n    expect(c!.items).toHaveLength(1);\n    expect(c!.items[0].quantity).toBe(5);\n  });\n\n  it('should remove items', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p2', 1);\n    cart.removeItem(id, 'p1');\n    expect(cart.getCart(id)!.items).toHaveLength(1);\n  });\n\n  it('should clear a cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.clearCart(id);\n    expect(cart.getCart(id)!.items).toHaveLength(0);\n  });\n\n  it('should update quantity', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.updateQuantity(id, 'p1', 10);\n    expect(cart.getCart(id)!.items[0].quantity).toBe(10);\n  });\n});\n\ndescribe('PricingService', () => {\n  it('should calculate total with tax', () => {\n    const pricing = createPricingService(bus);\n    const result = pricing.calculateTotal([\n      { productId: 'p1', quantity: 2, price: 10 },\n      { productId: 'p2', quantity: 1, price: 20 },\n    ]);\n    expect(result.subtotal).toBe(40);\n    expect(result.discount).toBe(0);\n    expect(result.tax).toBe(4); // 10% of 40\n    expect(result.total).toBe(44);\n  });\n\n  it('should apply discount codes before tax', () => {\n    const pricing = createPricingService(bus);\n    pricing.addDiscountCode('SAVE20', 20);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'SAVE20',\n    );\n    expect(result.subtotal).toBe(100);\n    expect(result.discount).toBe(20);\n    expect(result.tax).toBe(8); // 10% of 80\n    expect(result.total).toBe(88);\n  });\n\n  it('should track prices from product:created events', () => {\n    const pricing = createPricingService(bus);\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 15, 'c');\n    expect(pricing.getPrice(id)).toBe(15);\n  });\n\n  it('should return 0 for unknown product price', () => {\n    const pricing = createPricingService(bus);\n    expect(pricing.getPrice('unknown')).toBe(0);\n  });\n});\n\ndescribe('OrderService', () => {\n  it('should create an order with pending status', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    const order = orders.getOrder(id);\n    expect(order).toEqual({ id, userId: 'user1', status: OrderStatus.PENDING, total: 50 });\n  });\n\n  it('should return null for unknown order', () => {\n    const orders = createOrderService(bus);\n    expect(orders.getOrder('nonexistent')).toBeNull();\n  });\n\n  it('should update order status and emit event with previousStatus', async () => {\n    const orders = createOrderService(bus);\n    const events: unknown[] = [];\n    bus.on(Events.ORDER_STATUS_CHANGED, (p) => { events.push(p); });\n    const id = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    await new Promise(r => setTimeout(r, 10));\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.CONFIRMED);\n    expect(events).toHaveLength(1);\n    const evt = events[0] as { orderId: string; status: string; previousStatus: string };\n    expect(evt.previousStatus).toBe(OrderStatus.PENDING);\n    expect(evt.status).toBe(OrderStatus.CONFIRMED);\n  });\n\n  it('should list orders for a user', () => {\n    const orders = createOrderService(bus);\n    orders.createOrder('user1', 'c1', 10);\n    orders.createOrder('user2', 'c2', 20);\n    orders.createOrder('user1', 'c3', 30);\n    expect(orders.listOrders('user1')).toHaveLength(2);\n    expect(orders.listOrders('user2')).toHaveLength(1);\n  });\n});\n\ndescribe('PaymentService', () => {\n  it('should process successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.SUCCESS);\n    expect(result.transactionId).toBeDefined();\n  });\n\n  it('should simulate payment failure', async () => {\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.FAILED);\n    expect(result.error).toBeDefined();\n  });\n\n  it('should simulate payment timeout', async () => {\n    const payment = createPaymentService(bus, { simulateTimeout: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.TIMEOUT);\n    expect(result.error).toBeDefined();\n  });\n\n  it('should refund a successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    const refunded = await payment.refund(result.transactionId!);\n    expect(refunded).toBe(true);\n  });\n\n  it('should not refund an invalid transaction', async () => {\n    const payment = createPaymentService(bus);\n    const refunded = await payment.refund('nonexistent');\n    expect(refunded).toBe(false);\n  });\n\n  it('should emit payment:processed event', async () => {\n    const events: unknown[] = [];\n    bus.on(Events.PAYMENT_PROCESSED, (p) => { events.push(p); });\n    const payment = createPaymentService(bus);\n    await payment.processPayment('order1', 100);\n    expect(events).toHaveLength(1);\n  });\n});\n\ndescribe('NotificationService', () => {\n  it('should only notify subscribed users', async () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n\n    notifications.subscribe('user1');\n    orders.createOrder('user1', 'cart1', 50);\n    orders.createOrder('user2', 'cart2', 30);\n\n    await new Promise(r => setTimeout(r, 10));\n    expect(notifications.getNotifications('user1').length).toBeGreaterThan(0);\n    expect(notifications.getNotifications('user2')).toHaveLength(0);\n  });\n\n  it('should notify on order status change', async () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n\n    notifications.subscribe('user1');\n    const orderId = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n\n    await new Promise(r => setTimeout(r, 10));\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.some(n => n.type === 'order_status')).toBe(true);\n  });\n\n  it('should notify on payment events', async () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n\n    notifications.subscribe('user1');\n    const orderId = orders.createOrder('user1', 'cart1', 50);\n\n    const payment = createPaymentService(bus);\n    await payment.processPayment(orderId, 50);\n\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.some(n => n.type === 'payment')).toBe(true);\n  });\n});\n\ndescribe('AnalyticsService', () => {\n  it('should count events', async () => {\n    const analytics = createAnalyticsService(bus);\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('A', 1, 'c');\n    catalog.createProduct('B', 2, 'c');\n\n    await new Promise(r => setTimeout(r, 10));\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n  });\n\n  it('should track revenue from successful payments', async () => {\n    const analytics = createAnalyticsService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    await payment.processPayment(orderId, 100);\n\n    expect(analytics.getRevenue()).toBe(100);\n  });\n\n  it('should not track revenue from failed payments', async () => {\n    const analytics = createAnalyticsService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus, { simulateFailure: true });\n\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    await payment.processPayment(orderId, 100);\n\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  it('should calculate conversion rate', async () => {\n    const analytics = createAnalyticsService(bus);\n    const cartService = createCartService(bus);\n    const orders = createOrderService(bus);\n\n    const cart1 = cartService.createCart('user1');\n    