ength(2);\n    expect(catalog.listProducts('cat2')).toHaveLength(1);\n    expect(catalog.listProducts()).toHaveLength(3);\n  });\n\n  it('should search products by name', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('Blue Widget', 5, 'widgets');\n    catalog.createProduct('Red Gadget', 10, 'gadgets');\n    const results = catalog.searchProducts('widget');\n    expect(results).toHaveLength(1);\n    expect(results[0].name).toBe('Blue Widget');\n  });\n\n  it('should search products by category', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('Thing', 5, 'widgets');\n    const results = catalog.searchProducts('widgets');\n    expect(results).toHaveLength(1);\n  });\n\n  it('should update a product', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Old', 5, 'cat');\n    catalog.updateProduct(id, { name: 'New', price: 10 });\n    expect(catalog.getProduct(id)?.name).toBe('New');\n    expect(catalog.getProduct(id)?.price).toBe(10);\n  });\n\n  it('should remove a product', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Gone', 1, 'cat');\n    expect(catalog.removeProduct(id)).toBe(true);\n    expect(catalog.getProduct(id)).toBeNull();\n    expect(catalog.removeProduct('nope')).toBe(false);\n  });\n\n  it('should emit product:created event', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('Widget', 5, 'cat');\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.PRODUCT_CREATED)).toBe(true);\n  });\n});\n\ndescribe('Inventory Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should set and get stock', () => {\n    const inv = createInventoryService(bus);\n    inv.setStock('p1', 100);\n    expect(inv.getStock('p1')).toBe(100);\n  });\n\n  it('should return 0 for unknown product', () => {\n    const inv = createInventoryService(bus);\n    expect(inv.getStock('nope')).toBe(0);\n  });\n\n  it('should reserve stock', () => {\n    const inv = createInventoryService(bus);\n    inv.setStock('p1', 10);\n    expect(inv.reserve('p1', 5)).toBe(true);\n    expect(inv.getStock('p1')).toBe(5);\n  });\n\n  it('should fail to reserve when insufficient stock', () => {\n    const inv = createInventoryService(bus);\n    inv.setStock('p1', 3);\n    expect(inv.reserve('p1', 5)).toBe(false);\n  });\n\n  it('should release reserved stock', () => {\n    const inv = createInventoryService(bus);\n    inv.setStock('p1', 10);\n    inv.reserve('p1', 5);\n    inv.release('p1', 3);\n    expect(inv.getStock('p1')).toBe(8);\n  });\n\n  it('should emit low stock alert', () => {\n    const inv = createInventoryService(bus);\n    inv.setStock('p1', 10);\n    inv.setLowStockThreshold('p1', 5);\n    inv.setStock('p1', 3);\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.LOW_STOCK_ALERT)).toBe(true);\n  });\n});\n\ndescribe('Cart Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should create a cart and retrieve it', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    const c = cart.getCart(id);\n    expect(c).toEqual({ id, userId: 'user1', items: [] });\n  });\n\n  it('should return null for unknown cart', () => {\n    const cart = createCartService(bus);\n    expect(cart.getCart('nope')).toBeNull();\n  });\n\n  it('should add items and consolidate duplicates', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p1', 3);\n    const c = cart.getCart(id);\n    expect(c?.items).toEqual([{ productId: 'p1', quantity: 5 }]);\n  });\n\n  it('should remove items', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p2', 1);\n    cart.removeItem(id, 'p1');\n    const c = cart.getCart(id);\n    expect(c?.items).toEqual([{ productId: 'p2', quantity: 1 }]);\n  });\n\n  it('should clear cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.clearCart(id);\n    expect(cart.getCart(id)?.items).toEqual([]);\n  });\n\n  it('should update quantity', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.updateQuantity(id, 'p1', 10);\n    expect(cart.getCart(id)?.items).toEqual([{ productId: 'p1', quantity: 10 }]);\n  });\n});\n\ndescribe('Pricing Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should calculate total with tax', () => {\n    const pricing = createPricingService(bus);\n    const result = pricing.calculateTotal([{ productId: 'p1', quantity: 2, price: 10 }]);\n    expect(result.subtotal).toBe(20);\n    expect(result.discount).toBe(0);\n    expect(result.tax).toBe(2);\n    expect(result.total).toBe(22);\n  });\n\n  it('should apply discount code', () => {\n    const pricing = createPricingService(bus);\n    pricing.addDiscountCode('SAVE10', 10);\n    const result = pricing.calculateTotal([{ productId: 'p1', quantity: 1, price: 100 }], 'SAVE10');\n    expect(result.subtotal).toBe(100);\n    expect(result.discount).toBe(10);\n    expect(result.tax).toBe(9);\n    expect(result.total).toBe(99);\n  });\n\n  it('should track prices from product created events', async () => {\n    const pricing = createPricingService(bus);\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('Widget', 25, 'gadgets');\n    // Need to wait for event propagation since emit is async\n    await new Promise(resolve => setTimeout(resolve, 10));\n    // The price should have been recorded via the event\n    expect(pricing.getPrice('prod_1')).toBe(25);\n  });\n\n  it('should ignore unknown discount codes', () => {\n    const pricing = createPricingService(bus);\n    const result = pricing.calculateTotal([{ productId: 'p1', quantity: 1, price: 100 }], 'INVALID');\n    expect(result.discount).toBe(0);\n    expect(result.total).toBe(110);\n  });\n});\n\ndescribe('Order Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should create an order in pending state', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    const order = orders.getOrder(id);\n    expect(order?.status).toBe(OrderStatus.PENDING);\n    expect(order?.total).toBe(50);\n    expect(order?.userId).toBe('user1');\n  });\n\n  it('should return null for unknown order', () => {\n    const orders = createOrderService(bus);\n    expect(orders.getOrder('nope')).toBeNull();\n  });\n\n  it('should update order status', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    expect(orders.getOrder(id)?.status).toBe(OrderStatus.CONFIRMED);\n  });\n\n  it('should emit order:created and order:status_changed events', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(id, OrderStatus.SHIPPED);\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.ORDER_CREATED)).toBe(true);\n    expect(log.some(e => e.event === Events.ORDER_STATUS_CHANGED)).toBe(true);\n  });\n\n  it('should include previous status in status change event', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    const log = bus.getLog();\n    const statusEvent = log.find(e => e.event === Events.ORDER_STATUS_CHANGED);\n    const payload = statusEvent?.payload as { previousStatus: string };\n    expect(payload.previousStatus).toBe(OrderStatus.PENDING);\n  });\n\n  it('should list orders by user', () => {\n    const orders = createOrderService(bus);\n    orders.createOrder('user1', 'c1', 10);\n    orders.createOrder('user2', 'c2', 20);\n    orders.createOrder('user1', 'c3', 30);\n    expect(orders.listOrders('user1')).toHaveLength(2);\n    expect(orders.listOrders('user2')).toHaveLength(1);\n  });\n});\n\ndescribe('Payment Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should process payment successfully by default', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 50);\n    expect(result.status).toBe(PaymentStatus.SUCCESS);\n    expect(result.transactionId).toBeDefined();\n  });\n\n  it('should simulate failure', async () => {\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const result = await payment.processPayment('order1', 50);\n    expect(result.status).toBe(PaymentStatus.FAILED);\n    expect(result.error).toBe('Payment failed');\n  });\n\n  it('should simulate timeout', async () => {\n    const payment = createPaymentService(bus, { simulateTimeout: true });\n    const result = await payment.processPayment('order1', 50);\n    expect(result.status).toBe(PaymentStatus.TIMEOUT);\n  });\n\n  it('should refund a successful transaction', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 50);\n    const refunded = await payment.refund(result.transactionId!);\n    expect(refunded).toBe(true);\n  });\n\n  it('should not refund a non-existent transaction', async () => {\n    const payment = createPaymentService(bus);\n    const refunded = await payment.refund('nope');\n    expect(refunded).toBe(false);\n  });\n\n  it('should emit payment:processed event', async () => {\n    const payment = createPaymentService(bus);\n    await payment.processPayment('order1', 50);\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.PAYMENT_PROCESSED)).toBe(true);\n  });\n});\n\ndescribe('Notification Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should deliver notifications to subscribed users on order creation', () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n    notifications.subscribe('user1');\n    orders.createOrder('user1', 'cart1', 50);\n    const notes = notifications.getNotifications('user1');\n    expect(notes.length).toBeGreaterThan(0);\n    expect(notes[0].type).toBe('order_created');\n  });\n\n  it('should not deliver notifications to unsubscribed users', () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n    orders.createOrder('user1', 'cart1', 50);\n    expect(notifications.getNotifications('user1')).toHaveLength(0);\n  });\n\n  it('should notify on order status change', () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n    notifications.subscribe('user1');\n    const id = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    const notes = notifications.getNotifications('user1');\n    expect(notes.some(n => n.type === 'order_status')).toBe(true);\n  });\n\n  it('should notify on payment processed', async () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    notifications.subscribe('user1');\n    const orderId = orders.createOrder('user1', 'cart1', 50);\n    await payment.processPayment(orderId, 50);\n    const notes = notifications.getNotifications('user1');\n    expect(notes.some(n => n.type === 'payment')).toBe(true);\n  });\n});\n\ndescribe('Analytics Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should track event counts', () => {\n    const analytics = createAnalyticsService(bus);\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('A', 10, 'cat');\n    catalog.createProduct('B', 20, 'cat');\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n  });\n\n  it('should track revenue from successful payments', async () => {\n    const analytics = createAnalyticsService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    await payment.processPayment(orderId, 100);\n    expect(analytics.getRevenue()).toBe(100);\n  });\n\n  it('should not count revenue from failed payments', async () => {\n    const analytics = createAnalyticsService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    await payment.processPayment(orderId, 100);\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  it('should calculate conversion rate', () => {\n    const analytics = createAnalyticsService(bus);\n    const cart = createCartService(bus);\n    const orders = createOrderService(bus);\n    const c1 = cart.createCart('user1');\n    cart.addItem(c1, 'p1', 1);\n    const c2 = cart.createCart('user2');\n    cart.addItem(c2, 'p2', 1);\n    orders.createOrder('user1', c1, 50);\n    // 1 order / 2 unique carts = 0.5\n    expect(analytics.getConversionRate()).toBe(0.5);\n  });\n\n  it('should return 0 conversion rate with no carts', () => {\n    const analytics = createAnalyticsService(bus);\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n\n  it('should rank top products', () => {\n    const analytics = createAnalyticsService(bus);\n    const cart = createCartService(bus);\n    const orders = createOrderService(bus);\n    const c1 = cart.createCart('user1');\n    cart.addItem(c1, 'p1', 5);\n    cart.addItem(c1, 'p2', 2);\n    orders.createOrder('user1', c1, 70);\n    const top = analytics.getTopProducts(10);\n    expect(top[0].productId).toBe('p1');\n    expect(top[0].count).toBe(5);\n    expect(top[1].productId).toBe('p2');\n    expect(top[1].count).toBe(2);\n  });\n});\n\ndescribe('Integration: Full E-Commerce Flow', () => {\n  it('should process a complete order flow', async () => {\n    const bus = new EventBus();\n    const catalog = createCatalogService(bus);\n    const inventory = createInventoryService(bus);\n    const cartSvc = createCartService(bus);\n    const pricing = createPricingService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    const notifications = createNotificationService(bus);\n    const analytics = createAnalyticsService(bus);\n\n    // Setup\n    notifications.subscribe('user1');\n    const p1 = catalog.createProduct('Laptop', 999, 'electronics');\n    const p2 = catalog.createProduct('Mouse', 29, 'electronics');\n    inventory.setStock(p1, 50);\n    inventory.setStock(p2, 200);\n    inventory.setLowStockThreshold(p1, 10);\n\n    // Add to cart\n    const cartId = cartSvc.createCart('user1');\n    cartSvc.addItem(cartId, p1, 1);\n    cartSvc.addItem(cartId, p2, 2);\n\n    // Calculate price\n    const cart = cartSvc.getCart(cartId)!;\n    const items = cart.items.map(i => ({\n      productId: i.productId,\n      quantity: i.quantity,\n      price: pricing.getPrice(i.productId),\n    }));\n    const total = pricing.calculateTotal(items);\n    expect(total.subtotal).toBe(999 + 29 * 2);\n    expect(total.tax).toBeCloseTo((999 + 58) * 0.1, 2);\n\n    // Reserve inventory\n    for (const item of cart.items) {\n      expect(inventory.reserve(item.productId, item.quantity)).toBe(true);\n    }\n\n    // Create order\n    const orderId = orders.createOrder('user1', cartId, total.total);\n    expect(orders.getOrder(orderId)?.status).toBe(OrderStatus.PENDING);\n\n    // Process payment\n    const payResult = await payment.processPayment(orderId, total.total);\n    expect(payResult.status).toBe(PaymentStatus.SUCCESS);\n\n    // Update order status\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    orders.updateStatus(orderId, OrderStatus.SHIPPED);\n    orders.updateStatus(orderId, OrderStatus.DELIVERED);\n    expect(orders.getOrder(orderId)?.status).toBe(OrderStatus.DELIVERED);\n\n    // Check notifications\n    const notes = notifications.getNotifications('user1');\n    expect(notes.length).toBeGreaterThanOrEqual(3); // created, payment, status changes\n\n    // Check analytics\n    expect(analytics.getRevenue()).toBe(total.total);\n    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBe(1);\n    expect(analytics.getConversionRate()).toBe(1); // 1 order / 1 cart\n  });\n});\n","structuredPatch":[],"originalFile":null}}
