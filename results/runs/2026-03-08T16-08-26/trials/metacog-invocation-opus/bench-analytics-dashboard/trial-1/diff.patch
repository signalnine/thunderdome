+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01MkQFVcj7Fj6mnhF6Gn9cq2","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Uu5uu8mEvW3P5i4TTVFy1c","name":"Write","input":{"file_path":"/workspace/src/routes/dashboards.ts","content":"import { Router, Response } from \"express\";\nimport Database from \"better-sqlite3\";\nimport { v4 as uuidv4 } from \"uuid\";\nimport { authMiddleware } from \"../auth.js\";\nimport { AuthenticatedRequest, DashboardRow, WidgetRow } from \"../types.js\";\n\nexport function createDashboardRoutes(db: Database.Database): Router {\n  const router = Router();\n\n  router.use(authMiddleware);\n\n  // Create dashboard\n  router.post(\"/\", (req: AuthenticatedRequest, res: Response) => {\n    const { name, config, widgets } = req.body;\n\n    if (!name) {\n      res.status(400).json({ error: \"Dashboard name is required\" });\n      return;\n    }\n\n    const id = uuidv4();\n    const now = new Date().toISOString();\n    const dashConfig = JSON.stringify(config || {});\n\n    db.prepare(\n      \"INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)\"\n    ).run(id, req.user!.tenantId, name, req.user!.userId, dashConfig, now, now);\n\n    // Insert widgets if provided\n    if (widgets && Array.isArray(widgets)) {\n      const insertWidget = db.prepare(\n        \"INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)\"\n      );\n\n      for (const widget of widgets) {\n        insertWidget.run(\n          uuidv4(),\n          id,\n          widget.type || \"counter\",\n          JSON.stringify(widget.config || {}),\n          widget.positionX || 0,\n          widget.positionY || 0,\n          widget.width || 1,\n          widget.height || 1\n        );\n      }\n    }\n\n    res.status(201).json({\n      id,\n      tenantId: req.user!.tenantId,\n      name,\n      ownerId: req.user!.userId,\n      config: config || {},\n      createdAt: now,\n      updatedAt: now,\n    });\n  });\n\n  // List dashboards for tenant\n  router.get(\"/\", (req: AuthenticatedRequest, res: Response) => {\n    const dashboards = db\n      .prepare(\"SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC\")\n      .all(req.user!.tenantId) as DashboardRow[];\n\n    res.json(\n      dashboards.map((d) => ({\n        id: d.id,\n        tenantId: d.tenant_id,\n        name: d.name,\n        ownerId: d.owner_id,\n        config: JSON.parse(d.config),\n        createdAt: d.created_at,\n        updatedAt: d.updated_at,\n      }))\n    );\n  });\n\n  // Get single dashboard with widgets\n  router.get(\"/:id\", (req: AuthenticatedRequest, res: Response) => {\n    const dashboard = db\n      .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n      .get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;\n\n    if (!dashboard) {\n      res.status(404).json({ error: \"Dashboard not found\" });\n      return;\n    }\n\n    const widgets = db\n      .prepare(\"SELECT * FROM widgets WHERE dashboard_id = ?\")\n      .all(dashboard.id) as WidgetRow[];\n\n    res.json({\n      id: dashboard.id,\n      tenantId: dashboard.tenant_id,\n      name: dashboard.name,\n      ownerId: dashboard.owner_id,\n      config: JSON.parse(dashboard.config),\n      createdAt: dashboard.created_at,\n      updatedAt: dashboard.updated_at,\n      widgets: widgets.map((w) => ({\n        id: w.id,\n        dashboardId: w.dashboard_id,\n        type: w.type,\n        config: JSON.parse(w.config),\n        positionX: w.position_x,\n        positionY: w.position_y,\n        width: w.width,\n        height: w.height,\n      })),\n    });\n  });\n\n  // Update dashboard\n  router.put(\"/:id\", (req: AuthenticatedRequest, res: Response) => {\n    const dashboard = db\n      .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n      .get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;\n\n    if (!dashboard) {\n      res.status(404).json({ error: \"Dashboard not found\" });\n      return;\n    }\n\n    const { name, config } = req.body;\n    const now = new Date().toISOString();\n\n    db.prepare(\"UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?\").run(\n      name || dashboard.name,\n      config ? JSON.stringify(config) : dashboard.config,\n      now,\n      dashboard.id\n    );\n\n    res.json({\n      id: dashboard.id,\n      tenantId: dashboard.tenant_id,\n      name: name || dashboard.name,\n      ownerId: dashboard.owner_id,\n      config: config || JSON.parse(dashboard.config),\n      createdAt: dashboard.created_at,\n      updatedAt: now,\n    });\n  });\n\n  // Delete dashboard\n  router.delete(\"/:id\", (req: AuthenticatedRequest, res: Response) => {\n    const dashboard = db\n      .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n      .get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;\n\n    if (!dashboard) {\n      res.status(404).json({ error: \"Dashboard not found\" });\n      return;\n    }\n\n    db.prepare(\"DELETE FROM widgets WHERE dashboard_id = ?\").run(dashboard.id);\n    db.prepare(\"DELETE FROM dashboards WHERE id = ?\").run(dashboard.id);\n\n    res.status(204).send();\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":369,"cache_read_input_tokens":30854,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":369},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"b273b31d-8caa-4a40-b300-6127fb7bd76e","uuid":"7c6877dd-81a7-4811-b062-613a7cffc7d3"}
