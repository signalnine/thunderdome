(\"/api/users/login\")\n        .send({ email: \"admin@test.com\", password: \"pass123\" });\n\n      expect(res.status).toBe(200);\n      expect(res.body.token).toBeDefined();\n      adminToken = res.body.token;\n    });\n\n    it(\"should reject invalid credentials\", async () => {\n      const res = await request(app)\n        .post(\"/api/users/login\")\n        .send({ email: \"admin@test.com\", password: \"wrong\" });\n\n      expect(res.status).toBe(401);\n    });\n\n    it(\"should get own profile\", async () => {\n      const res = await request(app)\n        .get(\"/api/users/me\")\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body.email).toBe(\"admin@test.com\");\n      expect(res.body.role).toBe(\"admin\");\n    });\n\n    it(\"should return 401 without token\", async () => {\n      const res = await request(app).get(\"/api/users/me\");\n      expect(res.status).toBe(401);\n    });\n\n    it(\"should allow admin to change roles\", async () => {\n      const res = await request(app)\n        .put(`/api/users/${viewerUserId}/role`)\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ role: \"editor\" });\n\n      expect(res.status).toBe(200);\n      expect(res.body.role).toBe(\"editor\");\n    });\n\n    it(\"should reject non-admin role changes\", async () => {\n      const res = await request(app)\n        .put(`/api/users/${adminUserId}/role`)\n        .set(\"Authorization\", `Bearer ${viewerToken}`)\n        .send({ role: \"admin\" });\n\n      expect(res.status).toBe(403);\n    });\n  });\n\n  describe(\"Event Ingestion\", () => {\n    it(\"should ingest a single event\", async () => {\n      const res = await request(app)\n        .post(\"/api/events\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({\n          name: \"page_view\",\n          properties: { url: \"/home\", browser: \"Chrome\" },\n          timestamp: \"2024-01-15T10:00:00Z\",\n        });\n\n      expect(res.status).toBe(201);\n      expect(res.body.name).toBe(\"page_view\");\n      expect(res.body.tenantId).toBe(tenantId);\n    });\n\n    it(\"should ingest batch events\", async () => {\n      const res = await request(app)\n        .post(\"/api/events/batch\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({\n          events: [\n            { name: \"page_view\", properties: { url: \"/about\" }, timestamp: \"2024-01-15T11:00:00Z\" },\n            { name: \"page_view\", properties: { url: \"/home\" }, timestamp: \"2024-01-16T10:00:00Z\" },\n            { name: \"click\", properties: { button: \"signup\" }, timestamp: \"2024-01-16T11:00:00Z\" },\n            { name: \"page_view\", properties: { url: \"/pricing\" }, timestamp: \"2024-01-17T10:00:00Z\" },\n          ],\n        });\n\n      expect(res.status).toBe(201);\n      expect(res.body.inserted).toBe(4);\n    });\n\n    it(\"should reject unauthenticated event ingestion\", async () => {\n      const res = await request(app)\n        .post(\"/api/events\")\n        .send({ name: \"page_view\" });\n\n      expect(res.status).toBe(401);\n    });\n  });\n\n  describe(\"Query Engine\", () => {\n    it(\"should count events\", async () => {\n      const res = await request(app)\n        .post(\"/api/queries/count\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ eventName: \"page_view\" });\n\n      expect(res.status).toBe(200);\n      expect(res.body.count).toBe(4);\n    });\n\n    it(\"should count all events\", async () => {\n      const res = await request(app)\n        .post(\"/api/queries/count\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({});\n\n      expect(res.status).toBe(200);\n      expect(res.body.count).toBe(5);\n    });\n\n    it(\"should count events with date filter\", async () => {\n      const res = await request(app)\n        .post(\"/api/queries/count\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ eventName: \"page_view\", startDate: \"2024-01-16T00:00:00Z\" });\n\n      expect(res.status).toBe(200);\n      expect(res.body.count).toBe(2);\n    });\n\n    it(\"should return timeseries data\", async () => {\n      const res = await request(app)\n        .post(\"/api/queries/timeseries\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ eventName: \"page_view\", interval: \"day\" });\n\n      expect(res.status).toBe(200);\n      expect(res.body.interval).toBe(\"day\");\n      expect(res.body.data.length).toBeGreaterThan(0);\n    });\n\n    it(\"should return breakdown data\", async () => {\n      const res = await request(app)\n        .post(\"/api/queries/breakdown\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ eventName: \"page_view\", property: \"url\" });\n\n      expect(res.status).toBe(200);\n      expect(res.body.property).toBe(\"url\");\n      expect(res.body.data.length).toBeGreaterThan(0);\n    });\n\n    it(\"should enforce tenant isolation for queries\", async () => {\n      // Register user in different tenant\n      const regRes = await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"other@test.com\", password: \"pass123\", tenantId: tenant2Id });\n\n      const otherToken = regRes.body.token;\n\n      const res = await request(app)\n        .post(\"/api/queries/count\")\n        .set(\"Authorization\", `Bearer ${otherToken}`)\n        .send({});\n\n      expect(res.status).toBe(200);\n      expect(res.body.count).toBe(0);\n    });\n  });\n\n  describe(\"Dashboard CRUD\", () => {\n    let dashboardId: string;\n\n    it(\"should create a dashboard\", async () => {\n      const res = await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({\n          name: \"My Dashboard\",\n          config: { theme: \"dark\" },\n          widgets: [\n            