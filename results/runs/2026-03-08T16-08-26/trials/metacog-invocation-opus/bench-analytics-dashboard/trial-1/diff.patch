+++ b/src/app.ts
@@ -0,0 +1,29 @@
+import express from "express";
+import Database from "better-sqlite3";
+import { createDatabase } from "./database.js";
+import { createUserRoutes } from "./routes/users.js";
+import { createEventRoutes } from "./routes/events.js";
+import { createQueryRoutes } from "./routes/queries.js";
+import { createDashboardRoutes } from "./routes/dashboards.js";
+import { createExportRoutes } from "./routes/export.js";
+
+export function createApp(dbPath?: string): express.Application {
+  const app = express();
+  const db: Database.Database = createDatabase(dbPath);
+
+  app.use(express.json());
+
+  // Health check
+  app.get("/health", (_req, res) => {
+    res.json({ status: "ok" });
+  });
+
+  // Mount routes
+  app.use("/api/users", createUserRoutes(db));
+  app.use("/api/events", createEventRoutes(db));
+  app.use("/api/queries", createQueryRoutes(db));
+  app.use("/api/dashboards", createDashboardRoutes(db));
+  app.use("/api/export", createExportRoutes(db));
+
+  return app;
+}
diff --git a/src/auth.ts b/src/auth.ts
new file mode 100644
index 0000000..1f29ffe
--- /dev/null
+++ b/src/auth.ts
@@ -0,0 +1,38 @@
+import { Response, NextFunction } from "express";
+import jwt from "jsonwebtoken";
+import { AuthenticatedRequest, UserPayload } from "./types.js";
+
+const JWT_SECRET = process.env.JWT_SECRET || "analytics-dashboard-secret-key";
+
+export function generateToken(payload: UserPayload): string {
+  return jwt.sign(payload, JWT_SECRET, { expiresIn: "24h" });
+}
+
+export function verifyToken(token: string): UserPayload {
+  return jwt.verify(token, JWT_SECRET) as UserPayload;
+}
+
+export function authMiddleware(
+  req: AuthenticatedRequest,
+  res: Response,
+  next: NextFunction
+): void {
+  const authHeader = req.headers.authorization;
+
+  if (!authHeader || !authHeader.startsWith("Bearer ")) {
+    res.status(401).json({ error: "Authentication required" });
+    return;
+  }
+
+  const token = authHeader.substring(7);
+
+  try {
+    const payload = verifyToken(token);
+    req.user = payload;
+    next();
+  } catch {
+    res.status(401).json({ error: "Invalid or expired token" });
+  }
+}
+
+export { JWT_SECRET };
diff --git a/src/database.ts b/src/database.ts
new file mode 100644
index 0000000..c7e1295
--- /dev/null
+++ b/src/database.ts
@@ -0,0 +1,22 @@
+import Database from "better-sqlite3";
+import { readFileSync } from "fs";
+import { join } from "path";
+
+export function createDatabase(dbPath: string = ":memory:"): Database.Database {
+  const db = new Database(dbPath);
+  db.pragma("journal_mode = WAL");
+  db.pragma("foreign_keys = ON");
+
+  const schemaPath = join(__dirname, "..", "schema.sql");
+  try {
+    const schema = readFileSync(schemaPath, "utf-8");
+    db.exec(schema);
+  } catch {
+    // If schema.sql is not found relative to dist, try workspace root
+    const altPath = join(process.cwd(), "schema.sql");
+    const schema = readFileSync(altPath, "utf-8");
+    db.exec(schema);
+  }
+
+  return db;
+}
