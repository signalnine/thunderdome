index 0000000..0472fe1
--- /dev/null
+++ b/src/routes/queries.ts
@@ -0,0 +1,158 @@
+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { authMiddleware } from "../auth.js";
+import { AuthenticatedRequest } from "../types.js";
+
+interface CountResult {
+  count: number;
+}
+
+interface TimeseriesBucket {
+  period: string;
+  count: number;
+}
+
+interface BreakdownEntry {
+  value: string;
+  count: number;
+}
+
+export function createQueryRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  router.use(authMiddleware);
+
+  // Count query
+  router.post("/count", (req: AuthenticatedRequest, res: Response) => {
+    const { eventName, startDate, endDate, filters } = req.body;
+
+    let sql = "SELECT COUNT(*) as count FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [req.user!.tenantId];
+
+    if (eventName) {
+      sql += " AND name = ?";
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value);
+      }
+    }
+
+    const result = db.prepare(sql).get(...params) as CountResult;
+
+    res.json({ count: result.count });
+  });
+
+  // Timeseries query
+  router.post("/timeseries", (req: AuthenticatedRequest, res: Response) => {
+    const { eventName, startDate, endDate, interval, filters } = req.body;
+
+    const granularity = interval || "day";
+
+    let dateFormat: string;
+    switch (granularity) {
+      case "hour":
+        dateFormat = "%Y-%m-%dT%H:00:00";
+        break;
+      case "month":
+        dateFormat = "%Y-%m-01";
+        break;
+      case "week":
+        dateFormat = "%Y-%W";
+        break;
+      default: // day
+        dateFormat = "%Y-%m-%d";
+        break;
+    }
+
+    let sql = `SELECT strftime('${dateFormat}', timestamp) as period, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: unknown[] = [req.user!.tenantId];
+
+    if (eventName) {
+      sql += " AND name = ?";
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value);
+      }
+    }
+
+    sql += " GROUP BY period ORDER BY period";
+
+    const results = db.prepare(sql).all(...params) as TimeseriesBucket[];
+
+    res.json({ interval: granularity, data: results });
+  });
+
+  // Breakdown query
+  router.post("/breakdown", (req: AuthenticatedRequest, res: Response) => {
+    const { eventName, property, startDate, endDate, filters } = req.body;
+
+    if (!property) {
+      res.status(400).json({ error: "property is required for breakdown queries" });
+      return;
+    }
+
+    let sql = `SELECT json_extract(properties, ?) as value, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: unknown[] = [`$.${property}`, req.user!.tenantId];
+
+    if (eventName) {
+      sql += " AND name = ?";
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value);
+      }
+    }
+
+    sql += " AND json_extract(properties, ?) IS NOT NULL";
+    params.push(`$.${property}`);
+
+    sql += " GROUP BY value ORDER BY count DESC";
+
+    const results = db.prepare(sql).all(...params) as BreakdownEntry[];
+
+    res.json({ property, data: results });
+  });
+
+  return router;
+}
diff --git a/src/routes/users.ts b/src/routes/users.ts
new file mode 100644
index 0000000..66ca9c0
--- /dev/null
+++ b/src/routes/users.ts
@@ -0,0 +1,147 @@
+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { createHash } from "crypto";
+import { v4 as uuidv4 } from "uuid";
+import { generateToken } from "../auth.js";
+import { authMiddleware } from "../auth.js";
+import { AuthenticatedRequest, UserRow } from "../types.js";
+
+function hashPassword(password: string): string {
+  return createHash("sha256").update(password).digest("hex");
+}
+
+export function createUserRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Register
+  router.post("/register", (req: AuthenticatedRequest, res: Response) => {
+    const { email, password, tenantId, role } = req.body;
+
+    if (!email || !password || !tenantId) {
+      res.status(400).json({ error: "email, password, and tenantId are required" });
+      return;
+    }
+
+    const existing = db
+      .prepare("SELECT id FROM users WHERE email = ?")
+      .get(email) as UserRow | undefined;
+
+    if (existing) {
+      res.status(409).json({ error: "Email already registered" });
+      return;
+    }
+
+    const id = uuidv4();
+    const passwordHash = hashPassword(password);
+    const userRole = role && ["admin", "editor", "viewer"].includes(role) ? role : "viewer";
+
+    db.prepare(
+      "INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)"
+    ).run(id, email, passwordHash, tenantId, userRole);
+
+    const token = generateToken({
+      userId: id,
+      email,
+      tenantId,
+      role: userRole,
+    });
+
+    res.status(201).json({
+      id,
+      email,
+      tenantId,
+      role: userRole,
+      token,
+    });
+  });
+
+  // Login
+  router.post("/login", (req: AuthenticatedRequest, res: Response) => {
+    const { email, password } = req.body;
+
+    if (!email || !password) {
+      res.status(400).json({ error: "email and password are required" });
+      return;
+    }
+
+    const user = db
+      .prepare("SELECT * FROM users WHERE email = ?")
+      .get(email) as UserRow | undefined;
+
+    if (!user || user.password_hash !== hashPassword(password)) {
+      res.status(401).json({ error: "Invalid credentials" });
+      return;
+    }
+
+    const token = generateToken({
+      userId: user.id,
+      email: user.email,
+      tenantId: user.tenant_id,
+      role: user.role,
+    });
+
+    res.json({
+      id: user.id,
+      email: user.email,
+      tenantId: user.tenant_id,
+      role: user.role,
+      token,
+    });
+  });
+
+  // Get own profile
+  router.get("/me", authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+    const user = db
+      .prepare("SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?")
+      .get(req.user!.userId) as Omit<UserRow, "password_hash"> | undefined;
+
+    if (!user) {
+      res.status(404).json({ error: "User not found" });
+      return;
+    }
+
+    res.json({
+      id: user.id,
+      email: user.email,
+      tenantId: user.tenant_id,
+      role: user.role,
+      createdAt: user.created_at,
+    });
+  });
+
+  // Change user role (admin only)
+  router.put("/:userId/role", authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+    if (req.user!.role !== "admin") {
+      res.status(403).json({ error: "Only admins can change roles" });
+      return;
+    }
+
+    const { role } = req.body;
+    const { userId } = req.params;
+
+    if (!role || !["admin", "editor", "viewer"].includes(role)) {
+      res.status(400).json({ error: "Valid role is required (admin, editor, viewer)" });
+      return;
+    }
+
+    const targetUser = db
+      .prepare("SELECT * FROM users WHERE id = ? AND tenant_id = ?")
+      .get(userId, req.user!.tenantId) as UserRow | undefined;
+
+    if (!targetUser) {
+      res.status(404).json({ error: "User not found in your tenant" });
+      return;
+    }
+
+    db.prepare("UPDATE users SET role = ? WHERE id = ?").run(role, userId);
+
+    res.json({
+      id: targetUser.id,
+      email: targetUser.email,
+      tenantId: targetUser.tenant_id,
+      role,
+    });
+  });
+
+  return router;
+}
