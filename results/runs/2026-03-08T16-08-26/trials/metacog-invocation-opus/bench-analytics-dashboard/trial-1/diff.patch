+import { Request } from "express";
+
+export interface UserPayload {
+  userId: string;
+  email: string;
+  tenantId: string;
+  role: string;
+}
+
+export interface AuthenticatedRequest extends Request {
+  user?: UserPayload;
+}
+
+export interface UserRow {
+  id: string;
+  email: string;
+  password_hash: string;
+  tenant_id: string;
+  role: string;
+  created_at: string;
+}
+
+export interface EventRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string | null;
+  session_id: string | null;
+}
+
+export interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface WidgetRow {
+  id: string;
+  dashboard_id: string;
+  type: string;
+  config: string;
+  position_x: number;
+  position_y: number;
+  width: number;
+  height: number;
+}
