@@ -0,0 +1,94 @@
+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { v4 as uuidv4 } from "uuid";
+import { authMiddleware } from "../auth.js";
+import { AuthenticatedRequest } from "../types.js";
+
+interface EventInput {
+  name: string;
+  properties?: Record<string, unknown>;
+  timestamp?: string;
+  sessionId?: string;
+}
+
+export function createEventRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // All event routes require auth
+  router.use(authMiddleware);
+
+  // Ingest single event
+  router.post("/", (req: AuthenticatedRequest, res: Response) => {
+    const { name, properties, timestamp, sessionId } = req.body as EventInput;
+
+    if (!name) {
+      res.status(400).json({ error: "Event name is required" });
+      return;
+    }
+
+    const id = uuidv4();
+    const eventTimestamp = timestamp || new Date().toISOString();
+    const eventProperties = JSON.stringify(properties || {});
+
+    db.prepare(
+      "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    ).run(id, req.user!.tenantId, name, eventProperties, eventTimestamp, req.user!.userId, sessionId || null);
+
+    res.status(201).json({
+      id,
+      tenantId: req.user!.tenantId,
+      name,
+      properties: properties || {},
+      timestamp: eventTimestamp,
+      userId: req.user!.userId,
+      sessionId: sessionId || null,
+    });
+  });
+
+  // Ingest batch of events
+  router.post("/batch", (req: AuthenticatedRequest, res: Response) => {
+    const { events } = req.body as { events: EventInput[] };
+
+    if (!events || !Array.isArray(events) || events.length === 0) {
+      res.status(400).json({ error: "events array is required and must not be empty" });
+      return;
+    }
+
+    const insertStmt = db.prepare(
+      "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    );
+
+    const results: Array<{ id: string; name: string }> = [];
+
+    const insertMany = db.transaction((eventList: EventInput[]) => {
+      for (const event of eventList) {
+        if (!event.name) continue;
+
+        const id = uuidv4();
+        const eventTimestamp = event.timestamp || new Date().toISOString();
+        const eventProperties = JSON.stringify(event.properties || {});
+
+        insertStmt.run(
+          id,
+          req.user!.tenantId,
+          event.name,
+          eventProperties,
+          eventTimestamp,
+          req.user!.userId,
+          event.sessionId || null
+        );
+
+        results.push({ id, name: event.name });
+      }
+    });
+
+    insertMany(events);
+
+    res.status(201).json({
+      inserted: results.length,
+      events: results,
+    });
+  });
+
+  return router;
+}
diff --git a/src/routes/export.ts b/src/routes/export.ts
