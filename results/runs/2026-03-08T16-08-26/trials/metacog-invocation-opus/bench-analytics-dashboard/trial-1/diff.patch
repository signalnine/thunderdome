@@ -0,0 +1,192 @@
+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { authMiddleware } from "../auth.js";
+import { AuthenticatedRequest, EventRow, DashboardRow, WidgetRow } from "../types.js";
+
+function eventsToCSV(events: EventRow[]): string {
+  const headers = ["id", "name", "properties", "timestamp", "user_id", "session_id"];
+  const rows = events.map((e) =>
+    [
+      e.id,
+      `"${e.name}"`,
+      `"${e.properties.replace(/"/g, '""')}"`,
+      e.timestamp,
+      e.user_id || "",
+      e.session_id || "",
+    ].join(",")
+  );
+  return [headers.join(","), ...rows].join("\n");
+}
+
+function dashboardToCSV(dashboard: DashboardRow, widgets: WidgetRow[]): string {
+  const lines: string[] = [];
+  lines.push("# Dashboard");
+  lines.push(["id", "name", "owner_id", "config", "created_at", "updated_at"].join(","));
+  lines.push(
+    [
+      dashboard.id,
+      `"${dashboard.name}"`,
+      dashboard.owner_id,
+      `"${dashboard.config.replace(/"/g, '""')}"`,
+      dashboard.created_at,
+      dashboard.updated_at,
+    ].join(",")
+  );
+  lines.push("");
+  lines.push("# Widgets");
+  lines.push(
+    ["id", "dashboard_id", "type", "config", "position_x", "position_y", "width", "height"].join(
+      ","
+    )
+  );
+  for (const w of widgets) {
+    lines.push(
+      [
+        w.id,
+        w.dashboard_id,
+        w.type,
+        `"${w.config.replace(/"/g, '""')}"`,
+        w.position_x,
+        w.position_y,
+        w.width,
+        w.height,
+      ].join(",")
+    );
+  }
+  return lines.join("\n");
+}
+
+export function createExportRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  router.use(authMiddleware);
+
+  // Export events as JSON
+  router.get("/events/json", (req: AuthenticatedRequest, res: Response) => {
+    const { eventName, startDate, endDate } = req.query;
+
+    let sql = "SELECT * FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [req.user!.tenantId];
+
+    if (eventName) {
+      sql += " AND name = ?";
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    sql += " ORDER BY timestamp DESC";
+
+    const events = db.prepare(sql).all(...params) as EventRow[];
+
+    const mapped = events.map((e) => ({
+      id: e.id,
+      name: e.name,
+      properties: JSON.parse(e.properties),
+      timestamp: e.timestamp,
+      userId: e.user_id,
+      sessionId: e.session_id,
+    }));
+
+    res.setHeader("Content-Type", "application/json");
+    res.setHeader("Content-Disposition", "attachment; filename=events.json");
+    res.json(mapped);
+  });
+
+  // Export events as CSV
+  router.get("/events/csv", (req: AuthenticatedRequest, res: Response) => {
+    const { eventName, startDate, endDate } = req.query;
+
+    let sql = "SELECT * FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [req.user!.tenantId];
+
+    if (eventName) {
+      sql += " AND name = ?";
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    sql += " ORDER BY timestamp DESC";
+
+    const events = db.prepare(sql).all(...params) as EventRow[];
+
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader("Content-Disposition", "attachment; filename=events.csv");
+    res.send(eventsToCSV(events));
+  });
+
+  // Export dashboard as JSON
+  router.get("/dashboards/:id/json", (req: AuthenticatedRequest, res: Response) => {
+    const dashboard = db
+      .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const widgets = db
+      .prepare("SELECT * FROM widgets WHERE dashboard_id = ?")
+      .all(dashboard.id) as WidgetRow[];
+
+    res.setHeader("Content-Type", "application/json");
+    res.setHeader("Content-Disposition", `attachment; filename=dashboard-${dashboard.id}.json`);
+    res.json({
+      id: dashboard.id,
+      name: dashboard.name,
+      ownerId: dashboard.owner_id,
+      config: JSON.parse(dashboard.config),
+      createdAt: dashboard.created_at,
+      updatedAt: dashboard.updated_at,
+      widgets: widgets.map((w) => ({
+        id: w.id,
+        type: w.type,
+        config: JSON.parse(w.config),
+        positionX: w.position_x,
+        positionY: w.position_y,
+        width: w.width,
+        height: w.height,
+      })),
+    });
+  });
+
+  // Export dashboard as CSV
+  router.get("/dashboards/:id/csv", (req: AuthenticatedRequest, res: Response) => {
+    const dashboard = db
+      .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const widgets = db
+      .prepare("SELECT * FROM widgets WHERE dashboard_id = ?")
+      .all(dashboard.id) as WidgetRow[];
+
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader("Content-Disposition", `attachment; filename=dashboard-${dashboard.id}.csv`);
+    res.send(dashboardToCSV(dashboard, widgets));
+  });
+
+  return router;
+}
