adminToken}`);\n\n      expect(res.status).toBe(200);\n      expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n    });\n\n    it(\"should not export other tenant's dashboard\", async () => {\n      const regRes = await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"export-other@test.com\", password: \"pass123\", tenantId: \"tenant-export-other\" });\n\n      const otherToken = regRes.body.token;\n\n      const res = await request(app)\n        .get(`/api/export/dashboards/${dashId}/json`)\n        .set(\"Authorization\", `Bearer ${otherToken}`);\n\n      expect(res.status).toBe(404);\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
