new file mode 100644
index 0000000..325d724
--- /dev/null
+++ b/src/routes/events.ts
@@ -0,0 +1,81 @@
+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { v4 as uuidv4 } from "uuid";
+import { AuthenticatedRequest, authenticate } from "../auth.js";
+
+interface EventInput {
+  name: string;
+  properties?: Record<string, unknown>;
+  timestamp?: string;
+  user_id?: string;
+  session_id?: string;
+}
+
+export function createEventRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Ingest single event
+  router.post("/", authenticate, (req: AuthenticatedRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: "Authentication required" });
+      return;
+    }
+
+    const { name, properties, timestamp, user_id, session_id } = req.body as EventInput;
+
+    if (!name) {
+      res.status(400).json({ error: "Event name is required" });
+      return;
+    }
+
+    const id = uuidv4();
+    const tenantId = req.user.tenantId;
+    const eventTimestamp = timestamp || new Date().toISOString();
+    const eventProperties = JSON.stringify(properties || {});
+
+    db.prepare(
+      "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    ).run(id, tenantId, name, eventProperties, eventTimestamp, user_id || null, session_id || null);
+
+    res.status(201).json({ id, tenant_id: tenantId, name, properties: properties || {}, timestamp: eventTimestamp });
+  });
+
+  // Batch ingest events
+  router.post("/batch", authenticate, (req: AuthenticatedRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: "Authentication required" });
+      return;
+    }
+
+    const { events } = req.body as { events: EventInput[] };
+
+    if (!events || !Array.isArray(events) || events.length === 0) {
+      res.status(400).json({ error: "events array is required and must not be empty" });
+      return;
+    }
+
+    const tenantId = req.user.tenantId;
+    const insert = db.prepare(
+      "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    );
+
+    const insertMany = db.transaction((evts: EventInput[]) => {
+      const results: Array<{ id: string; name: string }> = [];
+      for (const evt of evts) {
+        if (!evt.name) continue;
+        const id = uuidv4();
+        const eventTimestamp = evt.timestamp || new Date().toISOString();
+        const eventProperties = JSON.stringify(evt.properties || {});
+        insert.run(id, tenantId, evt.name, eventProperties, eventTimestamp, evt.user_id || null, evt.session_id || null);
+        results.push({ id, name: evt.name });
+      }
+      return results;
+    });
+
+    const results = insertMany(events);
+
+    res.status(201).json({ inserted: results.length, events: results });
+  });
+
+  return router;
+}
