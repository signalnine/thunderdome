+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { AuthenticatedRequest, authenticate } from "../auth.js";
+import { AnalyticsEvent, Dashboard } from "../db.js";
+
+function eventsToCsv(events: AnalyticsEvent[]): string {
+  const header = "id,tenant_id,name,properties,timestamp,user_id,session_id";
+  const rows = events.map((e) => {
+    const props = e.properties.replace(/"/g, '""');
+    const userId = e.user_id || "";
+    const sessionId = e.session_id || "";
+    return `${e.id},${e.tenant_id},${e.name},"${props}",${e.timestamp},${userId},${sessionId}`;
+  });
+  return [header, ...rows].join("\n");
+}
+
+function dashboardsToCsv(dashboards: Dashboard[]): string {
+  const header = "id,tenant_id,name,owner_id,config,created_at,updated_at";
+  const rows = dashboards.map((d) => {
+    const config = d.config.replace(/"/g, '""');
+    return `${d.id},${d.tenant_id},${d.name},${d.owner_id},"${config}",${d.created_at},${d.updated_at}`;
+  });
+  return [header, ...rows].join("\n");
+}
+
+export function createExportRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Export events as JSON
+  router.get("/events/json", authenticate, (req: AuthenticatedRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: "Authentication required" });
+      return;
+    }
+
+    let sql = "SELECT * FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [req.user.tenantId];
+
+    const eventName = req.query.event_name;
+    if (eventName && typeof eventName === "string") {
+      sql += " AND name = ?";
+      params.push(eventName);
+    }
+
+    const startDate = req.query.start_date;
+    if (startDate && typeof startDate === "string") {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+
+    const endDate = req.query.end_date;
+    if (endDate && typeof endDate === "string") {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    sql += " ORDER BY timestamp DESC";
+
+    const events = db.prepare(sql).all(...params) as AnalyticsEvent[];
+
+    const parsed = events.map((e) => ({
+      ...e,
+      properties: JSON.parse(e.properties),
+    }));
+
+    res.json({ events: parsed });
+  });
+
+  // Export events as CSV
+  router.get("/events/csv", authenticate, (req: AuthenticatedRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: "Authentication required" });
+      return;
+    }
+
+    let sql = "SELECT * FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [req.user.tenantId];
+
+    const eventName = req.query.event_name;
+    if (eventName && typeof eventName === "string") {
+      sql += " AND name = ?";
+      params.push(eventName);
+    }
+
+    const startDate = req.query.start_date;
+    if (startDate && typeof startDate === "string") {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+
+    const endDate = req.query.end_date;
+    if (endDate && typeof endDate === "string") {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    sql += " ORDER BY timestamp DESC";
+
+    const events = db.prepare(sql).all(...params) as AnalyticsEvent[];
+
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader("Content-Disposition", "attachment; filename=events.csv");
+    res.send(eventsToCsv(events));
+  });
+
+  // Export dashboards as JSON
+  router.get("/dashboards/json", authenticate, (req: AuthenticatedRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: "Authentication required" });
+      return;
+    }
+
+    const dashboards = db
+      .prepare("SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC")
+      .all(req.user.tenantId) as Dashboard[];
+
+    const parsed = dashboards.map((d) => ({
+      ...d,
+      config: JSON.parse(d.config),
+    }));
+
+    res.json({ dashboards: parsed });
+  });
+
+  // Export dashboards as CSV
+  router.get("/dashboards/csv", authenticate, (req: AuthenticatedRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: "Authentication required" });
+      return;
+    }
+
+    const dashboards = db
+      .prepare("SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC")
+      .all(req.user.tenantId) as Dashboard[];
+
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader("Content-Disposition", "attachment; filename=dashboards.csv");
+    res.send(dashboardsToCsv(dashboards));
+  });
+
+  return router;
+}
diff --git a/src/routes/queries.ts b/src/routes/queries.ts
new file mode 100644
index 0000000..22072eb
--- /dev/null
+++ b/src/routes/queries.ts
@@ -0,0 +1,161 @@
+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { AuthenticatedRequest, authenticate } from "../auth.js";
+
+interface CountQuery {
+  event_name?: string;
+  start_date?: string;
+  end_date?: string;
+  filters?: Record<string, string>;
+}
+
+interface TimeseriesQuery extends CountQuery {
+  interval?: "hour" | "day" | "week" | "month";
+}
+
+interface BreakdownQuery extends CountQuery {
+  property: string;
+}
+
+export function createQueryRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Count events
+  router.post("/count", authenticate, (req: AuthenticatedRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: "Authentication required" });
+      return;
+    }
+
+    const { event_name, start_date, end_date, filters } = req.body as CountQuery;
+    const tenantId = req.user.tenantId;
+
+    let sql = "SELECT COUNT(*) as count FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [tenantId];
+
+    if (event_name) {
+      sql += " AND name = ?";
+      params.push(event_name);
+    }
+    if (start_date) {
+      sql += " AND timestamp >= ?";
+      params.push(start_date);
+    }
+    if (end_date) {
+      sql += " AND timestamp <= ?";
+      params.push(end_date);
+    }
+    if (filters) {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value);
+      }
+    }
+
+    const result = db.prepare(sql).get(...params) as { count: number };
+
+    res.json({ count: result.count });
+  });
+
+  // Timeseries query
+  router.post("/timeseries", authenticate, (req: AuthenticatedRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: "Authentication required" });
+      return;
+    }
+
+    const { event_name, start_date, end_date, interval, filters } = req.body as TimeseriesQuery;
+    const tenantId = req.user.tenantId;
+
+    let dateFormat: string;
+    switch (interval) {
+      case "hour":
+        dateFormat = "%Y-%m-%dT%H:00:00";
+        break;
+      case "week":
+        dateFormat = "%Y-W%W";
+        break;
+      case "month":
+        dateFormat = "%Y-%m";
+        break;
+      case "day":
+      default:
+        dateFormat = "%Y-%m-%d";
+        break;
+    }
+
+    let sql = `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: unknown[] = [tenantId];
+
+    if (event_name) {
+      sql += " AND name = ?";
+      params.push(event_name);
+    }
+    if (start_date) {
+      sql += " AND timestamp >= ?";
+      params.push(start_date);
+    }
+    if (end_date) {
+      sql += " AND timestamp <= ?";
+      params.push(end_date);
+    }
+    if (filters) {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value);
+      }
+    }
+
+    sql += " GROUP BY bucket ORDER BY bucket ASC";
+
+    const results = db.prepare(sql).all(...params) as Array<{ bucket: string; count: number }>;
+
+    res.json({ interval: interval || "day", data: results });
+  });
+
+  // Breakdown query
+  router.post("/breakdown", authenticate, (req: AuthenticatedRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: "Authentication required" });
+      return;
+    }
+
+    const { event_name, start_date, end_date, property, filters } = req.body as BreakdownQuery;
+    const tenantId = req.user.tenantId;
+
+    if (!property) {
+      res.status(400).json({ error: "property is required for breakdown queries" });
+      return;
+    }
+
+    let sql = `SELECT json_extract(properties, ?) as value, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: unknown[] = [`$.${property}`, tenantId];
+
+    if (event_name) {
+      sql += " AND name = ?";
+      params.push(event_name);
+    }
+    if (start_date) {
+      sql += " AND timestamp >= ?";
+      params.push(start_date);
+    }
+    if (end_date) {
+      sql += " AND timestamp <= ?";
+      params.push(end_date);
+    }
+    if (filters) {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value);
+      }
+    }
+
+    sql += " GROUP BY value ORDER BY count DESC";
+
+    const results = db.prepare(sql).all(...params) as Array<{ value: string | null; count: number }>;
+
+    res.json({ property, data: results });
+  });
+
+  return router;
+}
