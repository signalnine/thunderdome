+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01JyWZKY9d2jZS4KE9shndQD","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Kq5nHGWubTZWyAp9MhmMk5","name":"Write","input":{"file_path":"/workspace/src/routes/dashboards.ts","content":"import { Router, Response } from \"express\";\nimport Database from \"better-sqlite3\";\nimport { v4 as uuidv4 } from \"uuid\";\nimport { AuthenticatedRequest, authenticate } from \"../auth.js\";\nimport { Dashboard } from \"../db.js\";\n\nexport function createDashboardRoutes(db: Database.Database): Router {\n  const router = Router();\n\n  // Create dashboard\n  router.post(\"/\", authenticate, (req: AuthenticatedRequest, res: Response): void => {\n    if (!req.user) {\n      res.status(401).json({ error: \"Authentication required\" });\n      return;\n    }\n\n    const { name, config } = req.body;\n\n    if (!name) {\n      res.status(400).json({ error: \"Dashboard name is required\" });\n      return;\n    }\n\n    const id = uuidv4();\n    const tenantId = req.user.tenantId;\n    const ownerId = req.user.userId;\n    const dashConfig = JSON.stringify(config || {});\n    const now = new Date().toISOString();\n\n    db.prepare(\n      \"INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)\"\n    ).run(id, tenantId, name, ownerId, dashConfig, now, now);\n\n    res.status(201).json({\n      id,\n      tenant_id: tenantId,\n      name,\n      owner_id: ownerId,\n      config: config || {},\n      created_at: now,\n      updated_at: now,\n    });\n  });\n\n  // List dashboards for tenant\n  router.get(\"/\", authenticate, (req: AuthenticatedRequest, res: Response): void => {\n    if (!req.user) {\n      res.status(401).json({ error: \"Authentication required\" });\n      return;\n    }\n\n    const dashboards = db\n      .prepare(\"SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC\")\n      .all(req.user.tenantId) as Dashboard[];\n\n    const result = dashboards.map((d) => ({\n      ...d,\n      config: JSON.parse(d.config),\n    }));\n\n    res.json(result);\n  });\n\n  // Get single dashboard\n  router.get(\"/:id\", authenticate, (req: AuthenticatedRequest, res: Response): void => {\n    if (!req.user) {\n      res.status(401).json({ error: \"Authentication required\" });\n      return;\n    }\n\n    const dashboard = db\n      .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n      .get(req.params.id, req.user.tenantId) as Dashboard | undefined;\n\n    if (!dashboard) {\n      res.status(404).json({ error: \"Dashboard not found\" });\n      return;\n    }\n\n    res.json({ ...dashboard, config: JSON.parse(dashboard.config) });\n  });\n\n  // Update dashboard\n  router.put(\"/:id\", authenticate, (req: AuthenticatedRequest, res: Response): void => {\n    if (!req.user) {\n      res.status(401).json({ error: \"Authentication required\" });\n      return;\n    }\n\n    const dashboard = db\n      .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n      .get(req.params.id, req.user.tenantId) as Dashboard | undefined;\n\n    if (!dashboard) {\n      res.status(404).json({ error: \"Dashboard not found\" });\n      return;\n    }\n\n    const { name, config } = req.body;\n    const updatedName = name || dashboard.name;\n    const updatedConfig = config !== undefined ? JSON.stringify(config) : dashboard.config;\n    const now = new Date().toISOString();\n\n    db.prepare(\"UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?\").run(\n      updatedName,\n      updatedConfig,\n      now,\n      req.params.id\n    );\n\n    res.json({\n      id: req.params.id,\n      tenant_id: req.user.tenantId,\n      name: updatedName,\n      owner_id: dashboard.owner_id,\n      config: config !== undefined ? config : JSON.parse(dashboard.config),\n      created_at: dashboard.created_at,\n      updated_at: now,\n    });\n  });\n\n  // Delete dashboard\n  router.delete(\"/:id\", authenticate, (req: AuthenticatedRequest, res: Response): void => {\n    if (!req.user) {\n      res.status(401).json({ error: \"Authentication required\" });\n      return;\n    }\n\n    const dashboard = db\n      .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n      .get(req.params.id, req.user.tenantId) as Dashboard | undefined;\n\n    if (!dashboard) {\n      res.status(404).json({ error: \"Dashboard not found\" });\n      return;\n    }\n\n    db.prepare(\"DELETE FROM dashboards WHERE id = ?\").run(req.params.id);\n\n    res.status(204).send();\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1498,"cache_read_input_tokens":27568,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1498},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"f6337947-929b-4d26-a55f-e5e4c099272c","uuid":"18b5e17a-2eb2-48c8-9c9f-1fa3d09ef73e"}
