+// Helper: wait for a condition (with timeout)
+function waitFor(fn: () => boolean, timeout = 5000): Promise<void> {
+  return new Promise((resolve, reject) => {
+    const start = Date.now();
+    const check = () => {
+      if (fn()) return resolve();
+      if (Date.now() - start > timeout) return reject(new Error('waitFor timed out'));
+      setTimeout(check, 10);
+    };
+    check();
+  });
+}
+
+// Helper: open WebSocket and wait for sync
+function openWs(port: number, docId: string): Promise<{ ws: WebSocket; sync: { content: string; version: number; clientId: string } }> {
+  return new Promise((resolve, reject) => {
+    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/${docId}`);
+    const timeout = setTimeout(() => reject(new Error('WebSocket connect timeout')), 5000);
+    ws.on('message', (data) => {
+      const msg = JSON.parse(data.toString());
+      if (msg.type === 'sync') {
+        clearTimeout(timeout);
+        resolve({ ws, sync: msg });
+      }
+    });
+    ws.on('error', (err) => {
+      clearTimeout(timeout);
+      reject(err);
+    });
+  });
+}
+
+// Helper: collect messages from a WebSocket
+function collectMessages(ws: WebSocket): Array<Record<string, unknown>> {
+  const messages: Array<Record<string, unknown>> = [];
+  ws.on('message', (data) => {
+    messages.push(JSON.parse(data.toString()));
+  });
+  return messages;
+}
+
+// Helper: send operation and wait for ack
+function sendOp(ws: WebSocket, version: number, ops: Operation): Promise<Record<string, unknown>> {
+  return new Promise((resolve, reject) => {
+    const timeout = setTimeout(() => reject(new Error('sendOp ack timeout')), 5000);
+    const handler = (data: WebSocket.Data) => {
+      const msg = JSON.parse(data.toString());
+      if (msg.type === 'ack' || msg.type === 'error') {
+        clearTimeout(timeout);
+        ws.off('message', handler);
+        resolve(msg);
+      }
+    };
+    ws.on('message', handler);
+    ws.send(JSON.stringify({ type: 'operation', version, ops }));
+  });
+}
+
+// Helper: wait for next operation message
+function waitForOp(ws: WebSocket): Promise<Record<string, unknown>> {
+  return new Promise((resolve, reject) => {
+    const timeout = setTimeout(() => reject(new Error('waitForOp timeout')), 5000);
+    const handler = (data: WebSocket.Data) => {
+      const msg = JSON.parse(data.toString());
+      if (msg.type === 'operation') {
+        clearTimeout(timeout);
+        ws.off('message', handler);
+        resolve(msg);
+      }
+    };
+    ws.on('message', handler);
+  });
+}
+
+function sleep(ms: number): Promise<void> {
+  return new Promise((resolve) => setTimeout(resolve, ms));
+}
