index 0000000..e8a8962
--- /dev/null
+++ b/src/ws.ts
@@ -0,0 +1,224 @@
+import { WebSocketServer, WebSocket } from 'ws';
+import { IncomingMessage } from 'http';
+import { Server } from 'http';
+import { randomUUID } from 'crypto';
+import { DocumentStore } from './db.js';
+import {
+  Operation,
+  applyOperation,
+  transformOperations,
+  validateOperation,
+} from './ot.js';
+
+interface ClientConnection {
+  id: string;
+  ws: WebSocket;
+  docId: string;
+}
+
+interface DocumentState {
+  version: number;
+  content: string;
+  clients: Map<string, ClientConnection>;
+}
+
+export class CollaborationServer {
+  private wss: WebSocketServer;
+  private store: DocumentStore;
+  private documents: Map<string, DocumentState> = new Map();
+
+  constructor(server: Server, store: DocumentStore) {
+    this.store = store;
+    this.wss = new WebSocketServer({ server });
+
+    this.wss.on('connection', (ws: WebSocket, req: IncomingMessage) => {
+      this.handleConnection(ws, req);
+    });
+  }
+
+  private getDocumentState(docId: string): DocumentState | null {
+    if (this.documents.has(docId)) {
+      return this.documents.get(docId)!;
+    }
+
+    const doc = this.store.getDocument(docId);
+    if (!doc) return null;
+
+    const latestVersion = this.store.getLatestVersion(docId);
+    const state: DocumentState = {
+      version: latestVersion ? latestVersion.version : 0,
+      content: doc.content,
+      clients: new Map(),
+    };
+    this.documents.set(docId, state);
+    return state;
+  }
+
+  private handleConnection(ws: WebSocket, req: IncomingMessage) {
+    const url = req.url || '';
+    // Extract document ID from URL path: /ws/documents/:id or /documents/:id
+    const match = url.match(/\/(?:ws\/)?documents\/([^/?]+)/);
+    if (!match) {
+      ws.send(JSON.stringify({ type: 'error', message: 'Invalid WebSocket path. Use /ws/documents/:id' }));
+      ws.close(1008, 'Invalid path');
+      return;
+    }
+
+    const docId = match[1];
+    const state = this.getDocumentState(docId);
+    if (!state) {
+      ws.send(JSON.stringify({ type: 'error', message: 'Document not found' }));
+      ws.close(1008, 'Document not found');
+      return;
+    }
+
+    const clientId = randomUUID();
+    const client: ClientConnection = { id: clientId, ws, docId };
+    state.clients.set(clientId, client);
+
+    // Send sync message with current document state
+    ws.send(JSON.stringify({
+      type: 'sync',
+      docId,
+      content: state.content,
+      version: state.version,
+      clientId,
+    }));
+
+    ws.on('message', (data: Buffer | string) => {
+      try {
+        const message = JSON.parse(data.toString());
+        this.handleMessage(client, state, message);
+      } catch (err) {
+        ws.send(JSON.stringify({
+          type: 'error',
+          message: 'Invalid message format',
+        }));
+      }
+    });
+
+    ws.on('close', () => {
+      state.clients.delete(clientId);
+      if (state.clients.size === 0) {
+        // Keep the state cached; it's synced to DB already
+      }
+    });
+
+    ws.on('error', () => {
+      state.clients.delete(clientId);
+    });
+  }
+
+  private handleMessage(client: ClientConnection, state: DocumentState, message: unknown) {
+    if (!message || typeof message !== 'object') {
+      client.ws.send(JSON.stringify({ type: 'error', message: 'Invalid message' }));
+      return;
+    }
+
+    const msg = message as Record<string, unknown>;
+
+    if (msg.type === 'operation') {
+      this.handleOperation(client, state, msg);
+    } else {
+      client.ws.send(JSON.stringify({ type: 'error', message: `Unknown message type: ${msg.type}` }));
+    }
+  }
+
+  private handleOperation(
+    client: ClientConnection,
+    state: DocumentState,
+    msg: Record<string, unknown>
+  ) {
+    const ops = msg.ops as Operation | undefined;
+    const clientVersion = msg.version as number | undefined;
+
+    if (!ops || !Array.isArray(ops)) {
+      client.ws.send(JSON.stringify({ type: 'error', message: 'Missing or invalid ops' }));
+      return;
+    }
+
+    if (typeof clientVersion !== 'number') {
+      client.ws.send(JSON.stringify({ type: 'error', message: 'Missing or invalid version' }));
+      return;
+    }
+
+    // Validate the operation
+    // We need to transform against all operations since the client's version
+    // The client's version tells us against which version of the document this operation was created
+    let transformedOps = ops;
+
+    if (clientVersion > state.version) {
+      client.ws.send(JSON.stringify({
+        type: 'error',
+        message: `Client version ${clientVersion} is ahead of server version ${state.version}`,
+      }));
+      return;
+    }
+
+    // Get all operations between clientVersion and current version to transform against
+    if (clientVersion < state.version) {
+      const versions = this.store.getVersions(client.docId);
+      // We need to transform against ops from clientVersion+1 to state.version
+      for (const v of versions) {
+        if (v.version > clientVersion && v.version <= state.version && v.operation) {
+          try {
+            const serverOp = JSON.parse(v.operation) as Operation;
+            if (Array.isArray(serverOp)) {
+              const [transformedClient] = transformOperations(transformedOps, serverOp);
+              transformedOps = transformedClient;
+            }
+          } catch {
+            // Skip invalid stored operations
+          }
+        }
+      }
+    }
+
+    // Validate the (possibly transformed) operation against current document
+    const validationError = validateOperation(transformedOps, state.content.length);
+    if (validationError) {
+      client.ws.send(JSON.stringify({ type: 'error', message: validationError }));
+      return;
+    }
+
+    // Apply the operation
+    try {
+      const newContent = applyOperation(state.content, transformedOps);
+      state.content = newContent;
+      state.version++;
+
+      // Save to database
+      this.store.saveVersion(client.docId, newContent, JSON.stringify(transformedOps));
+
+      // Acknowledge to the sender
+      client.ws.send(JSON.stringify({
+        type: 'ack',
+        version: state.version,
+      }));
+
+      // Broadcast to other clients
+      for (const [id, otherClient] of state.clients) {
+        if (id !== client.id && otherClient.ws.readyState === WebSocket.OPEN) {
+          otherClient.ws.send(JSON.stringify({
+            type: 'operation',
+            ops: transformedOps,
+            version: state.version,
+            clientId: client.id,
+          }));
+        }
+      }
+    } catch (err) {
+      const errorMessage = err instanceof Error ? err.message : 'Failed to apply operation';
+      client.ws.send(JSON.stringify({ type: 'error', message: errorMessage }));
+    }
+  }
+
+  closeAll() {
+    for (const [, state] of this.documents) {
+      for (const [, client] of state.clients) {
+        client.ws.close(1001, 'Server shutting down');
+      }
+    }
+    this.wss.close();
+  }
+}
