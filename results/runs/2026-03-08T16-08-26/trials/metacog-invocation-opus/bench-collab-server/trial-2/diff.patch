+
+  afterEach(() => {
+    instance.stop();
+  });
+
+  it('should handle 10 concurrent clients connecting', async () => {
+    const createRes = await request(instance.app)
+      .post('/api/documents')
+      .send({ title: 'Stress', content: '' });
+
+    const clients: Array<{ ws: WebSocket; sync: { content: string; version: number; clientId: string } }> = [];
+    for (let i = 0; i < 10; i++) {
+      const client = await openWs(port, createRes.body.id);
+      clients.push(client);
+    }
+
+    expect(clients.length).toBe(10);
+    for (const c of clients) {
+      expect(c.sync.content).toBe('');
+      c.ws.close();
+    }
+  });
+
+  it('should handle 10 sequential edits from different clients', async () => {
+    const createRes = await request(instance.app)
+      .post('/api/documents')
+      .send({ title: 'Seq Stress', content: '' });
+
+    const clients: Array<{ ws: WebSocket; sync: { content: string; version: number; clientId: string } }> = [];
+    for (let i = 0; i < 10; i++) {
+      const client = await openWs(port, createRes.body.id);
+      clients.push(client);
+    }
+
+    let currentVersion = clients[0].sync.version;
+    let currentLength = 0;
+
+    for (let i = 0; i < 10; i++) {
+      const ops = createInsertOp(currentLength, currentLength, String(i));
+      const ack = await sendOp(clients[i].ws, currentVersion, ops);
+      expect(ack.type).toBe('ack');
+      currentVersion = (ack as { version: number }).version;
+      currentLength += 1;
+      await sleep(20);
+    }
+
+    const getRes = await request(instance.app)
+      .get(`/api/documents/${createRes.body.id}`);
+    expect(getRes.body.content).toBe('0123456789');
+
+    for (const c of clients) c.ws.close();
+  });
+
+  it('should not corrupt document with concurrent edits from 10 clients', async () => {
+    const createRes = await request(instance.app)
+      .post('/api/documents')
+      .send({ title: 'Concurrent Stress', content: '' });
+
+    const clients: Array<{ ws: WebSocket; sync: { content: string; version: number; clientId: string } }> = [];
+    for (let i = 0; i < 10; i++) {
+      const client = await openWs(port, createRes.body.id);
+      clients.push(client);
+    }
+
+    // All clients send inserts based on initial (empty) version
+    const acks = await Promise.all(
+      clients.map((c, i) =>
+        sendOp(c.ws, c.sync.version, createInsertOp(0, 0, String.fromCharCode(65 + i)))
+      )
+    );
+
+    // All should get acks (some might be errors from OT transform issues, but no crashes)
+    for (const ack of acks) {
+      expect(ack.type === 'ack' || ack.type === 'error').toBe(true);
+    }
+    await sleep(200);
+
+    const getRes = await request(instance.app)
+      .get(`/api/documents/${createRes.body.id}`);
+    // The content should contain some characters (at least the first one)
+    expect(getRes.body.content.length).toBeGreaterThan(0);
+
+    for (const c of clients) c.ws.close();
+  });
+
+  it('should maintain document integrity after many operations', async () => {
+    const createRes = await request(instance.app)
+      .post('/api/documents')
+      .send({ title: 'Integrity', content: '' });
+
+    const { ws, sync } = await openWs(port, createRes.body.id);
+    let version = sync.version;
+    let docLength = 0;
+
+    for (let i = 0; i < 50; i++) {
+      const char = String.fromCharCode(65 + (i % 26));
+      const ops = createInsertOp(docLength, docLength, char);
+      const ack = await sendOp(ws, version, ops);
+      expect(ack.type).toBe('ack');
+      version = (ack as { version: number }).version;
+      docLength += 1;
+    }
+
+    const getRes = await request(instance.app)
+      .get(`/api/documents/${createRes.body.id}`);
+    expect(getRes.body.content.length).toBe(50);
