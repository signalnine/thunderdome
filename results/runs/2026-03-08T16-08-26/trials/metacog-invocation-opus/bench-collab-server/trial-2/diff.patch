+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01W66h4Ka6ZQT5T9BBoVizBj","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_016WGubJa2sStzEUsn5U4Nc4","name":"Write","input":{"file_path":"/workspace/tests/server.test.ts","content":"import { describe, it, expect, beforeEach, afterEach, beforeAll, afterAll } from 'vitest';\nimport { createApp, AppInstance } from '../src/server.js';\nimport request from 'supertest';\nimport WebSocket from 'ws';\nimport fs from 'fs';\nimport path from 'path';\nimport { createInsertOp, createDeleteOp, applyOperation, Operation } from '../src/ot.js';\n\n// Helper: wait for a condition (with timeout)\nfunction waitFor(fn: () => boolean, timeout = 5000): Promise<void> {\n  return new Promise((resolve, reject) => {\n    const start = Date.now();\n    const check = () => {\n      if (fn()) return resolve();\n      if (Date.now() - start > timeout) return reject(new Error('waitFor timed out'));\n      setTimeout(check, 10);\n    };\n    check();\n  });\n}\n\n// Helper: open WebSocket and wait for sync\nfunction openWs(port: number, docId: string): Promise<{ ws: WebSocket; sync: { content: string; version: number; clientId: string } }> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/${docId}`);\n    const timeout = setTimeout(() => reject(new Error('WebSocket connect timeout')), 5000);\n    ws.on('message', (data) => {\n      const msg = JSON.parse(data.toString());\n      if (msg.type === 'sync') {\n        clearTimeout(timeout);\n        resolve({ ws, sync: msg });\n      }\n    });\n    ws.on('error', (err) => {\n      clearTimeout(timeout);\n      reject(err);\n    });\n  });\n}\n\n// Helper: collect messages from a WebSocket\nfunction collectMessages(ws: WebSocket): Array<Record<string, unknown>> {\n  const messages: Array<Record<string, unknown>> = [];\n  ws.on('message', (data) => {\n    messages.push(JSON.parse(data.toString()));\n  });\n  return messages;\n}\n\n// Helper: send operation and wait for ack\nfunction sendOp(ws: WebSocket, version: number, ops: Operation): Promise<Record<string, unknown>> {\n  return new Promise((resolve, reject) => {\n    const timeout = setTimeout(() => reject(new Error('sendOp ack timeout')), 5000);\n    const handler = (data: WebSocket.Data) => {\n      const msg = JSON.parse(data.toString());\n      if (msg.type === 'ack' || msg.type === 'error') {\n        clearTimeout(timeout);\n        ws.off('message', handler);\n        resolve(msg);\n      }\n    };\n    ws.on('message', handler);\n    ws.send(JSON.stringify({ type: 'operation', version, ops }));\n  });\n}\n\n// Helper: wait for next operation message\nfunction waitForOp(ws: WebSocket): Promise<Record<string, unknown>> {\n  return new Promise((resolve, reject) => {\n    const timeout = setTimeout(() => reject(new Error('waitForOp timeout')), 5000);\n    const handler = (data: WebSocket.Data) => {\n      const msg = JSON.parse(data.toString());\n      if (msg.type === 'operation') {\n        clearTimeout(timeout);\n        ws.off('message', handler);\n        resolve(msg);\n      }\n    };\n    ws.on('message', handler);\n  });\n}\n\nfunction sleep(ms: number): Promise<void> {\n  return new Promise((resolve) => setTimeout(resolve, ms));\n}\n\n// ============================================================\n// REST CRUD Tests (10 tests)\n// ============================================================\ndescribe('REST CRUD', () => {\n  let instance: AppInstance;\n\n  beforeEach(() => {\n    instance = createApp();\n    instance.start(0);\n  });\n\n  afterEach(() => {\n    instance.stop();\n  });\n\n  it('should create a document', async () => {\n    const res = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Test Doc', content: 'Hello' });\n    expect(res.status).toBe(201);\n    expect(res.body).toHaveProperty('id');\n    expect(res.body.title).toBe('Test Doc');\n    expect(res.body.content).toBe('Hello');\n  });\n\n  it('should create a document with empty content', async () => {\n    const res = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Empty Doc' });\n    expect(res.status).toBe(201);\n    expect(res.body.content).toBe('');\n  });\n\n  it('should reject document creation without title', async () => {\n    const res = await request(instance.app)\n      .post('/api/documents')\n      .send({ content: 'No title' });\n    expect(res.status).toBe(400);\n  });\n\n  it('should get a document by id', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Test Doc', content: 'Hello' });\n\n    const res = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}`);\n    expect(res.status).toBe(200);\n    expect(res.body.title).toBe('Test Doc');\n  });\n\n  it('should return 404 for non-existent document', async () => {\n    const res = await request(instance.app)\n      .get('/api/documents/nonexistent');\n    expect(res.status).toBe(404);\n  });\n\n  it('should list all documents', async () => {\n    await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Doc 1' });\n    await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Doc 2' });\n\n    const res = await request(instance.app).get('/api/documents');\n    expect(res.status).toBe(200);\n    expect(res.body.length).toBe(2);\n  });\n\n  it('should update a document', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Test Doc', content: 'Hello' });\n\n    const res = await request(instance.app)\n      .put(`/api/documents/${createRes.body.id}`)\n      .send({ title: 'Updated', content: 'World' });\n    expect(res.status).toBe(200);\n    expect(res.body.title).toBe('Updated');\n    expect(res.body.content).toBe('World');\n  });\n\n  it('should delete a document', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Test Doc' });\n\n    const res = await request(instance.app)\n      .delete(`/api/documents/${createRes.body.id}`);\n    expect(res.status).toBe(204);\n\n    const getRes = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}`);\n    expect(getRes.status).toBe(404);\n  });\n\n  it('should return 404 when deleting non-existent document', async () => {\n    const res = await request(instance.app)\n      .delete('/api/documents/nonexistent');\n    expect(res.status).toBe(404);\n  });\n\n  it('should get document version history', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Test Doc', content: 'v1' });\n\n    await request(instance.app)\n      .put(`/api/documents/${createRes.body.id}`)\n      .send({ content: 'v2' });\n\n    const res = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}/versions`);\n    expect(res.status).toBe(200);\n    expect(res.body.length).toBeGreaterThanOrEqual(2);\n    expect(res.body[0].content).toBe('v1');\n  });\n});\n\n// ============================================================\n// WebSocket Lifecycle Tests (8 tests)\n// ============================================================\ndescribe('WebSocket Lifecycle', () => {\n  let instance: AppInstance;\n  let port: number;\n\n  beforeEach(() => {\n    instance = createApp();\n    port = instance.start(0);\n  });\n\n  afterEach(() => {\n    instance.stop();\n  });\n\n  it('should connect to a document via WebSocket', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'WS Doc', content: 'Hello' });\n\n    const { ws, sync } = await openWs(port, createRes.body.id);\n    expect(sync.content).toBe('Hello');\n    expect(sync.version).toBeGreaterThanOrEqual(1);\n    ws.close();\n  });\n\n  it('should receive sync message with document content', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'WS Doc', content: 'Initial content' });\n\n    const { ws, sync } = await openWs(port, createRes.body.id);\n    expect(sync.type).toBe('sync');\n    expect(sync.content).toBe('Initial content');\n    expect(typeof sync.clientId).toBe('string');\n    ws.close();\n  });\n\n  it('should receive clientId on connect', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'WS Doc', content: '' });\n\n    const { ws, sync } = await openWs(port, createRes.body.id);\n    expect(sync.clientId).toBeDefined();\n    expect(typeof sync.clientId).toBe('string');\n    ws.close();\n  });\n\n  it('should reject connection to non-existent document', async () => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/nonexistent`);\n\n    const msg = await new Promise<Record<string, unknown>>((resolve) => {\n      ws.on('message', (data) => {\n        resolve(JSON.parse(data.toString()));\n      });\n    });\n\n    expect(msg.type).toBe('error');\n    ws.close();\n  });\n\n  it('should handle multiple clients connecting to same document', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Multi Client', content: 'test' });\n\n    const client1 = await openWs(port, createRes.body.id);\n    const client2 = await openWs(port, createRes.body.id);\n\n    expect(client1.sync.content).toBe('test');\n    expect(client2.sync.content).toBe('test');\n    expect(client1.sync.clientId).not.toBe(client2.sync.clientId);\n\n    client1.ws.close();\n    client2.ws.close();\n  });\n\n  it('should handle client disconnection gracefully', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Disconnect Test', content: 'data' });\n\n    const { ws } = await openWs(port, createRes.body.id);\n    ws.close();\n\n    // Wait a bit for cleanup\n    await sleep(100);\n\n    // Should still be able to connect\n    const { ws: ws2, sync } = await openWs(port, createRes.body.id);\n    expect(sync.content).toBe('data');\n    ws2.close();\n  });\n\n  it('should reject invalid WebSocket path', async () => {\n    const ws = new WebSocket(`ws://localhost:${port}/invalid`);\n\n    const msg = await new Promise<Record<string, unknown>>((resolve, reject) => {\n      const timeout = setTimeout(() => reject(new Error('timeout')), 3000);\n      ws.on('message', (data) => {\n        clearTimeout(timeout);\n        resolve(JSON.parse(data.toString()));\n      });\n      ws.on('close', () => {\n        clearTimeout(timeout);\n        resolve({ type: 'closed' });\n      });\n    });\n\n    expect(msg.type === 'error' || msg.type === 'closed').toBe(true);\n    ws.close();\n  });\n\n  it('should support connecting via /documents/:id path too', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Alt Path', content: 'alt' });\n\n    const { ws, sync } = await openWs(port, createRes.body.id);\n    expect(sync.content).toBe('alt');\n    ws.close();\n  });\n});\n\n// ============================================================\n// Single Client Editing Tests (6 tests)\n// ============================================================\ndescribe('Single Client Editing', () => {\n  let instance: AppInstance;\n  let port: number;\n\n  beforeEach(() => {\n    instance = createApp();\n    port = instance.start(0);\n  });\n\n  afterEach(() => {\n    instance.stop();\n  });\n\n  it('should apply an insert operation', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Edit Test', content: '' });\n\n    const { ws, sync } = await openWs(port, createRes.body.id);\n    const ops = createInsertOp(0, 0, 'Hello');\n    const ack = await sendOp(ws, sync.version, ops);\n    expect(ack.type).toBe('ack');\n\n    // Verify via REST\n    const getRes = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}`);\n    expect(getRes.body.content).toBe('Hello');\n    ws.close();\n  });\n\n  it('should apply a delete operation', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Delete Test', content: 'Hello World' });\n\n    const { ws, sync } = await openWs(port, createRes.body.id);\n    // Delete \"World\" (5 chars starting at position 6)\n    const ops = createDeleteOp(sync.content.length, 6, 5);\n    const ack = await sendOp(ws, sync.version, ops);\n    expect(ack.type).toBe('ack');\n\n    const getRes = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}`);\n    expect(getRes.body.content).toBe('Hello ');\n    ws.close();\n  });\n\n  it('should apply sequential operations', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Seq Test', content: '' });\n\n    const { ws, sync } = await openWs(port, createRes.body.id);\n\n    // Insert \"Hello\"\n    let ack = await sendOp(ws, sync.version, createInsertOp(0, 0, 'Hello'));\n    expect(ack.type).toBe('ack');\n    const v1 = (ack as { version: number }).version;\n\n    // Insert \" World\"\n    ack = await sendOp(ws, v1, createInsertOp(5, 5, ' World'));\n    expect(ack.type).toBe('ack');\n\n    const getRes = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}`);\n    expect(getRes.body.content).toBe('Hello World');\n    ws.close();\n  });\n\n  it('should update version numbers correctly', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Version Test', content: '' });\n\n    const { ws, sync } = await openWs(port, createRes.body.id);\n    const initialVersion = sync.version;\n\n    const ack = await sendOp(ws, sync.version, createInsertOp(0, 0, 'A'));\n    expect((ack as { version: number }).version).toBe(initialVersion + 1);\n\n    ws.close();\n  });\n\n  it('should persist changes to version history', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'History Test', content: '' });\n\n    const { ws, sync } = await openWs(port, createRes.body.id);\n    await sendOp(ws, sync.version, createInsertOp(0, 0, 'Hello'));\n    ws.close();\n\n    const versionsRes = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}/versions`);\n    expect(versionsRes.body.length).toBeGreaterThanOrEqual(2);\n  });\n\n  it('should handle insert at various positions', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Position Test', content: 'AC' });\n\n    const { ws, sync } = await openWs(port, createRes.body.id);\n    // Insert 'B' at position 1 (between A and C)\n    const ack = await sendOp(ws, sync.version, createInsertOp(2, 1, 'B'));\n    expect(ack.type).toBe('ack');\n\n    const getRes = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}`);\n    expect(getRes.body.content).toBe('ABC');\n    ws.close();\n  });\n});\n\n// ============================================================\n// Two-Client Convergence Tests (8 tests)\n// ============================================================\ndescribe('Two-Client Convergence', () => {\n  let instance: AppInstance;\n  let port: number;\n\n  beforeEach(() => {\n    instance = createApp();\n    port = instance.start(0);\n  });\n\n  afterEach(() => {\n    instance.stop();\n  });\n\n  it('should broadcast operations to other clients', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Broadcast', content: '' });\n\n    const c1 = await openWs(port, createRes.body.id);\n    const c2 = await openWs(port, createRes.body.id);\n\n    const opPromise = waitForOp(c2.ws);\n    await sendOp(c1.ws, c1.sync.version, createInsertOp(0, 0, 'Hello'));\n    const receivedOp = await opPromise;\n\n    expect(receivedOp.type).toBe('operation');\n    expect(receivedOp.ops).toBeDefined();\n\n    c1.ws.close();\n    c2.ws.close();\n  });\n\n  it('should converge with two sequential edits from different clients', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Sequential', content: '' });\n\n    const c1 = await openWs(port, createRes.body.id);\n    const c2 = await openWs(port, createRes.body.id);\n\n    // Client 1 inserts \"Hello\"\n    const ack1 = await sendOp(c1.ws, c1.sync.version, createInsertOp(0, 0, 'Hello'));\n    await sleep(100);\n\n    // Client 2 inserts \" World\" after seeing client 1's update\n    const ack2 = await sendOp(c2.ws, (ack1 as { version: number }).version, createInsertOp(5, 5, ' World'));\n    await sleep(100);\n\n    const getRes = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}`);\n    expect(getRes.body.content).toBe('Hello World');\n\n    c1.ws.close();\n    c2.ws.close();\n  });\n\n  it('should converge with concurrent inserts at different positions', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Concurrent', content: 'ABCD' });\n\n    const c1 = await openWs(port, createRes.body.id);\n    const c2 = await openWs(port, createRes.body.id);\n\n    // Both clients see version 1, content \"ABCD\"\n    // Client 1: insert \"X\" at position 1 (between A and B)\n    // Client 2: insert \"Y\" at position 3 (between C and D)\n    const op1 = createInsertOp(4, 1, 'X');\n    const op2 = createInsertOp(4, 3, 'Y');\n\n    const opFromC1 = waitForOp(c2.ws);\n    const ack1Promise = sendOp(c1.ws, c1.sync.version, op1);\n    const ack1 = await ack1Promise;\n    expect(ack1.type).toBe('ack');\n\n    // Wait for c2 to receive c1's operation\n    await opFromC1;\n\n    // c2 sends its op based on original version\n    const ack2 = await sendOp(c2.ws, c2.sync.version, op2);\n    expect(ack2.type).toBe('ack');\n    await sleep(100);\n\n    const getRes = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}`);\n    // Both inserts should be present\n    const content = getRes.body.content;\n    expect(content).toContain('X');\n    expect(content).toContain('Y');\n    expect(content.length).toBe(6); // \"ABCD\" + \"X\" + \"Y\"\n  });\n\n  it('should converge with concurrent inserts at same position', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Same Pos', content: '' });\n\n    const c1 = await openWs(port, createRes.body.id);\n    const c2 = await openWs(port, createRes.body.id);\n\n    // Both insert at position 0\n    const op1 = createInsertOp(0, 0, 'A');\n    const op2 = createInsertOp(0, 0, 'B');\n\n    const ack1 = await sendOp(c1.ws, c1.sync.version, op1);\n    expect(ack1.type).toBe('ack');\n    await sleep(50);\n\n    const ack2 = await sendOp(c2.ws, c2.sync.version, op2);\n    expect(ack2.type).toBe('ack');\n    await sleep(100);\n\n    const getRes = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}`);\n    // Both A and B should be present\n    expect(getRes.body.content).toContain('A');\n    expect(getRes.body.content).toContain('B');\n    expect(getRes.body.content.length).toBe(2);\n  });\n\n  it('should converge with concurrent insert and delete', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Insert Delete', content: 'Hello' });\n\n    const c1 = await openWs(port, createRes.body.id);\n    const c2 = await openWs(port, createRes.body.id);\n\n    // Client 1: insert \" World\" at end\n    const op1 = createInsertOp(5, 5, ' World');\n    // Client 2: delete \"llo\" (3 chars from position 2)\n    const op2 = createDeleteOp(5, 2, 3);\n\n    const ack1 = await sendOp(c1.ws, c1.sync.version, op1);\n    expect(ack1.type).toBe('ack');\n    await sleep(50);\n\n    const ack2 = await sendOp(c2.ws, c2.sync.version, op2);\n    expect(ack2.type).toBe('ack');\n    await sleep(100);\n\n    const getRes = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}`);\n    // \"He\" + \" World\" = \"He World\"\n    expect(getRes.body.content).toBe('He World');\n  });\n\n  it('should include version number in broadcast', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Version Broadcast', content: '' });\n\n    const c1 = await openWs(port, createRes.body.id);\n    const c2 = await openWs(port, createRes.body.id);\n\n    const opPromise = waitForOp(c2.ws);\n    await sendOp(c1.ws, c1.sync.version, createInsertOp(0, 0, 'Hi'));\n    const broadcast = await opPromise;\n\n    expect(broadcast.version).toBeDefined();\n    expect(typeof broadcast.version).toBe('number');\n\n    c1.ws.close();\n    c2.ws.close();\n  });\n\n  it('should handle rapid alternating edits', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Rapid', content: '' });\n\n    const c1 = await openWs(port, createRes.body.id);\n    const c2 = await openWs(port, createRes.body.id);\n\n    // c1: insert \"A\"\n    let ack = await sendOp(c1.ws, c1.sync.version, createInsertOp(0, 0, 'A'));\n    const v1 = (ack as { version: number }).version;\n    await sleep(50);\n\n    // c2: insert \"B\" (after seeing c1's edit)\n    ack = await sendOp(c2.ws, v1, createInsertOp(1, 1, 'B'));\n    const v2 = (ack as { version: number }).version;\n    await sleep(50);\n\n    // c1: insert \"C\"\n    ack = await sendOp(c1.ws, v2, createInsertOp(2, 2, 'C'));\n    await sleep(50);\n\n    const getRes = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}`);\n    expect(getRes.body.content).toBe('ABC');\n\n    c1.ws.close();\n    c2.ws.close();\n  });\n\n  it('should preserve all insertions in concurrent edits', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Preserve', content: 'X' });\n\n    const c1 = await openWs(port, createRes.body.id);\n    const c2 = await openWs(port, createRes.body.id);\n\n    // Both based on version with \"X\"\n    const op1 = createInsertOp(1, 0, 'A'); // insert A at beginning\n    const op2 = createInsertOp(1, 1, 'B'); // insert B at end\n\n    const ack1 = await sendOp(c1.ws, c1.sync.version, op1);\n    expect(ack1.type).toBe('ack');\n    await sleep(50);\n\n    const ack2 = await sendOp(c2.ws, c2.sync.version, op2);\n    expect(ack2.type).toBe('ack');\n    await sleep(100);\n\n    const getRes = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}`);\n    const content = getRes.body.content;\n    expect(content).toContain('A');\n    expect(content).toContain('B');\n    expect(content).toContain('X');\n    expect(content.length).toBe(3);\n\n    c1.ws.close();\n    c2.ws.close();\n  });\n});\n\n// ============================================================\n// Stress Test (5 tests)\n// ============================================================\ndescribe('Stress Test', () => {\n  let instance: AppInstance;\n  let port: number;\n\n  beforeEach(() => {\n    instance = createApp();\n    port = instance.start(0);\n  });\n\n  afterEach(() => {\n    instance.stop();\n  });\n\n  it('should handle 10 concurrent clients connecting', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Stress', content: '' });\n\n    const clients: Array<{ ws: WebSocket; sync: { content: string; version: number; clientId: string } }> = [];\n    for (let i = 0; i < 10; i++) {\n      const client = await openWs(port, createRes.body.id);\n      clients.push(client);\n    }\n\n    expect(clients.length).toBe(10);\n    for (const c of clients) {\n      expect(c.sync.content).toBe('');\n      c.ws.close();\n    }\n  });\n\n  it('should handle 10 sequential edits from different clients', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Seq Stress', content: '' });\n\n    const clients: Array<{ ws: WebSocket; sync: { content: string; version: number; clientId: string } }> = [];\n    for (let i = 0; i < 10; i++) {\n      const client = await openWs(port, createRes.body.id);\n      clients.push(client);\n    }\n\n    let currentVersion = clients[0].sync.version;\n    let currentLength = 0;\n\n    for (let i = 0; i < 10; i++) {\n      const ops = createInsertOp(currentLength, currentLength, String(i));\n      const ack = await sendOp(clients[i].ws, currentVersion, ops);\n      expect(ack.type).toBe('ack');\n      currentVersion = (ack as { version: number }).version;\n      currentLength += 1;\n      await sleep(20);\n    }\n\n    const getRes = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}`);\n    expect(getRes.body.content).toBe('0123456789');\n\n    for (const c of clients) c.ws.close();\n  });\n\n  it('should not corrupt document with concurrent edits from 10 clients', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Concurrent Stress', content: '' });\n\n    const clients: Array<{ ws: WebSocket; sync: { content: string; version: number; clientId: string } }> = [];\n    for (let i = 0; i < 10; i++) {\n      const client = await openWs(port, createRes.body.id);\n      clients.push(client);\n    }\n\n    // All clients send inserts based on initial (empty) version\n    const acks = await Promise.all(\n      clients.map((c, i) =>\n        sendOp(c.ws, c.sync.version, createInsertOp(0, 0, String.fromCharCode(65 + i)))\n      )\n    );\n\n    // All should get acks (some might be errors from OT transform issues, but no crashes)\n    for (const ack of acks) {\n      expect(ack.type === 'ack' || ack.type === 'error').toBe(true);\n    }\n    await sleep(200);\n\n    const getRes = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}`);\n    // The content should contain some characters (at least the first one)\n    expect(getRes.body.content.length).toBeGreaterThan(0);\n\n    for (const c of clients) c.ws.close();\n  });\n\n  it('should maintain document integrity after many operations', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Integrity', content: '' });\n\n    const { ws, sync } = await openWs(port, createRes.body.id);\n    let version = sync.version;\n    let docLength = 0;\n\n    for (let i = 0; i < 50; i++) {\n      const char = String.fromCharCode(65 + (i % 26));\n      const ops = createInsertOp(docLength, docLength, char);\n      const ack = await sendOp(ws, version, ops);\n      expect(ack.type).toBe('ack');\n      version = (ack as { version: number }).version;\n      docLength += 1;\n    }\n\n    const getRes = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}`);\n    expect(getRes.body.content.length).toBe(50);\n\n    ws.close();\n  });\n\n  it('should handle rapid fire operations from multiple clients', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Rapid Fire', content: 'START' });\n\n    const c1 = await openWs(port, createRes.body.id);\n    const c2 = await openWs(port, createRes.body.id);\n\n    let v = c1.sync.version;\n    let len = 5;\n\n    // Alternate between clients\n    for (let i = 0; i < 10; i++) {\n      const client = i % 2 === 0 ? c1 : c2;\n      const ops = createInsertOp(len, len, String(i));\n      const ack = await sendOp(client.ws, v, ops);\n      expect(ack.type).toBe('ack');\n      v = (ack as { version: number }).version;\n      len += 1;\n      await sleep(10);\n    }\n\n    const getRes = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}`);\n    expect(getRes.body.content).toBe('START0123456789');\n\n    c1.ws.close();\n    c2.ws.close();\n  });\n});\n\n// ============================================================\n// Error Handling Tests (5 tests)\n// ============================================================\ndescribe('Error Handling', () => {\n  let instance: AppInstance;\n  let port: number;\n\n  beforeEach(() => {\n    instance = createApp();\n    port = instance.start(0);\n  });\n\n  afterEach(() => {\n    instance.stop();\n  });\n\n  it('should reject operation with wrong base length', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Error Test', content: 'Hello' });\n\n    const { ws, sync } = await openWs(port, createRes.body.id);\n    // Send operation with wrong base length (says doc is 10 chars but it's 5)\n    const ops: Operation = [10, 'X'];\n    const result = await sendOp(ws, sync.version, ops);\n    expect(result.type).toBe('error');\n    ws.close();\n  });\n\n  it('should reject operation with invalid version', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Error Version', content: '' });\n\n    const { ws } = await openWs(port, createRes.body.id);\n    const ops = createInsertOp(0, 0, 'X');\n    const result = await sendOp(ws, 999, ops);\n    expect(result.type).toBe('error');\n    ws.close();\n  });\n\n  it('should reject malformed message', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Malformed', content: '' });\n\n    const { ws } = await openWs(port, createRes.body.id);\n\n    const response = await new Promise<Record<string, unknown>>((resolve) => {\n      ws.on('message', (data) => {\n        const msg = JSON.parse(data.toString());\n        if (msg.type === 'error') resolve(msg);\n      });\n      ws.send('not json!!!');\n    });\n\n    expect(response.type).toBe('error');\n    ws.close();\n  });\n\n  it('should reject operation with missing ops field', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Missing Ops', content: '' });\n\n    const { ws, sync } = await openWs(port, createRes.body.id);\n\n    const response = await new Promise<Record<string, unknown>>((resolve) => {\n      ws.on('message', (data) => {\n        const msg = JSON.parse(data.toString());\n        if (msg.type === 'error') resolve(msg);\n      });\n      ws.send(JSON.stringify({ type: 'operation', version: sync.version }));\n    });\n\n    expect(response.type).toBe('error');\n    ws.close();\n  });\n\n  it('should not crash on unknown message types', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Unknown Type', content: '' });\n\n    const { ws } = await openWs(port, createRes.body.id);\n\n    const response = await new Promise<Record<string, unknown>>((resolve) => {\n      ws.on('message', (data) => {\n        const msg = JSON.parse(data.toString());\n        if (msg.type === 'error') resolve(msg);\n      });\n      ws.send(JSON.stringify({ type: 'unknown_type' }));\n    });\n\n    expect(response.type).toBe('error');\n\n    // Server should still be alive - try sending a valid operation\n    const ops = createInsertOp(0, 0, 'X');\n    ws.send(JSON.stringify({ type: 'operation', version: 1, ops }));\n    ws.close();\n  });\n});\n\n// ============================================================\n// Persistence Tests (3 tests)\n// ============================================================\ndescribe('Persistence', () => {\n  const dbPath = '/tmp/test-persistence-' + Date.now() + '.db';\n\n  afterAll(() => {\n    try { fs.unlinkSync(dbPath); } catch { /* ignore */ }\n  });\n\n  it('should persist documents across server restarts', async () => {\n    // Start first instance\n    let instance = createApp(dbPath);\n    instance.start(0);\n\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Persist Test', content: 'Saved data' });\n    const docId = createRes.body.id;\n\n    instance.stop();\n\n    // Start second instance with same DB\n    instance = createApp(dbPath);\n    instance.start(0);\n\n    const getRes = await request(instance.app)\n      .get(`/api/documents/${docId}`);\n    expect(getRes.status).toBe(200);\n    expect(getRes.body.content).toBe('Saved data');\n    expect(getRes.body.title).toBe('Persist Test');\n\n    instance.stop();\n  });\n\n  it('should persist version history across restarts', async () => {\n    let instance = createApp(dbPath);\n    instance.start(0);\n\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Version Persist', content: 'v1' });\n    const docId = createRes.body.id;\n\n    await request(instance.app)\n      .put(`/api/documents/${docId}`)\n      .send({ content: 'v2' });\n\n    instance.stop();\n\n    instance = createApp(dbPath);\n    instance.start(0);\n\n    const versionsRes = await request(instance.app)\n      .get(`/api/documents/${docId}/versions`);\n    expect(versionsRes.body.length).toBeGreaterThanOrEqual(2);\n\n    instance.stop();\n  });\n\n  it('should persist WebSocket edits across restarts', async () => {\n    let instance = createApp(dbPath);\n    let port = instance.start(0);\n\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'WS Persist', content: '' });\n    const docId = createRes.body.id;\n\n    const { ws, sync } = await openWs(port, docId);\n    await sendOp(ws, sync.version, createInsertOp(0, 0, 'Persisted'));\n    ws.close();\n    await sleep(100);\n\n    instance.stop();\n\n    instance = createApp(dbPath);\n    port = instance.start(0);\n\n    const getRes = await request(instance.app)\n      .get(`/api/documents/${docId}`);\n    expect(getRes.body.content).toBe('Persisted');\n\n    instance.stop();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":327,"cache_read_input_tokens":35781,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":327},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"16b1a5b7-79ce-4e2a-acb9-8421fb63a641","uuid":"687109fe-0e6a-4e57-8924-8054f417328c"}
+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016WGubJa2sStzEUsn5U4Nc4","type":"tool_result","content":"File created successfully at: /workspace/tests/server.test.ts"}]},"parent_tool_use_id":null,"session_id":"16b1a5b7-79ce-4e2a-acb9-8421fb63a641","uuid":"6b9e5440-949d-4841-a9b7-eb24a24091b6","tool_use_result":{"type":"create","filePath":"/workspace/tests/server.test.ts","content":"import { describe, it, expect, beforeEach, afterEach, beforeAll, afterAll } from 'vitest';\nimport { createApp, AppInstance } from '../src/server.js';\nimport request from 'supertest';\nimport WebSocket from 'ws';\nimport fs from 'fs';\nimport path from 'path';\nimport { createInsertOp, createDeleteOp, applyOperation, Operation } from '../src/ot.js';\n\n// Helper: wait for a condition (with timeout)\nfunction waitFor(fn: () => boolean, timeout = 5000): Promise<void> {\n  return new Promise((resolve, reject) => {\n    const start = Date.now();\n    const check = () => {\n      if (fn()) return resolve();\n      if (Date.now() - start > timeout) return reject(new Error('waitFor timed out'));\n      setTimeout(check, 10);\n    };\n    check();\n  });\n}\n\n// Helper: open WebSocket and wait for sync\nfunction openWs(port: number, docId: string): Promise<{ ws: WebSocket; sync: { content: string; version: number; clientId: string } }> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/${docId}`);\n    const timeout = setTimeout(() => reject(new Error('WebSocket connect timeout')), 5000);\n    ws.on('message', (data) => {\n      const msg = JSON.parse(data.toString());\n      if (msg.type === 'sync') {\n        clearTimeout(timeout);\n        resolve({ ws, sync: msg });\n      }\n    });\n    ws.on('error', (err) => {\n      clearTimeout(timeout);\n      reject(err);\n    });\n  });\n}\n\n// Helper: collect messages from a WebSocket\nfunction collectMessages(ws: WebSocket): Array<Record<string, unknown>> {\n  const messages: Array<Record<string, unknown>> = [];\n  ws.on('message', (data) => {\n    messages.push(JSON.parse(data.toString()));\n  });\n  return messages;\n}\n\n// Helper: send operation and wait for ack\nfunction sendOp(ws: WebSocket, version: number, ops: Operation): Promise<Record<string, unknown>> {\n  return new Promise((resolve, reject) => {\n    const timeout = setTimeout(() => reject(new Error('sendOp ack timeout')), 5000);\n    const handler = (data: WebSocket.Data) => {\n      const msg = JSON.parse(data.toString());\n      if (msg.type === 'ack' || msg.type === 'error') {\n        clearTimeout(timeout);\n        ws.off('message', handler);\n        resolve(msg);\n      }\n    };\n    ws.on('message', handler);\n    ws.send(JSON.stringify({ type: 'operation', version, ops }));\n  });\n}\n\n// Helper: wait for next operation message\nfunction waitForOp(ws: WebSocket): Promise<Record<string, unknown>> {\n  return new Promise((resolve, reject) => {\n    const timeout = setTimeout(() => reject(new Error('waitForOp timeout')), 5000);\n    const handler = (data: WebSocket.Data) => {\n      const msg = JSON.parse(data.toString());\n      if (msg.type === 'operation') {\n        clearTimeout(timeout);\n        ws.off('message', handler);\n        resolve(msg);\n      }\n    };\n    ws.on('message', handler);\n  });\n}\n\nfunction sleep(ms: number): Promise<void> {\n  return new Promise((resolve) => setTimeout(resolve, ms));\n}\n\n// ============================================================\n// REST CRUD Tests (10 tests)\n// ============================================================\ndescribe('REST CRUD', () => {\n  let instance: AppInstance;\n\n  beforeEach(() => {\n    instance = createApp();\n    instance.start(0);\n  });\n\n  afterEach(() => {\n    instance.stop();\n  });\n\n  it('should create a document', async () => {\n    const res = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Test Doc', content: 'Hello' });\n    expect(res.status).toBe(201);\n    expect(res.body).toHaveProperty('id');\n    expect(res.body.title).toBe('Test Doc');\n    expect(res.body.content).toBe('Hello');\n  });\n\n  it('should create a document with empty content', async () => {\n    const res = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Empty Doc' });\n    expect(res.status).toBe(201);\n    expect(res.body.content).toBe('');\n  });\n\n  it('should reject document creation without title', async () => {\n    const res = await request(instance.app)\n      .post('/api/documents')\n      .send({ content: 'No title' });\n    expect(res.status).toBe(400);\n  });\n\n  it('should get a document by id', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Test Doc', content: 'Hello' });\n\n    const res = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}`);\n    expect(res.status).toBe(200);\n    expect(res.body.title).toBe('Test Doc');\n  });\n\n  it('should return 404 for non-existent document', async () => {\n    const res = await request(instance.app)\n      .get('/api/documents/nonexistent');\n    expect(res.status).toBe(404);\n  });\n\n  it('should list all documents', async () => {\n    await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Doc 1' });\n    await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Doc 2' });\n\n    const res = await request(instance.app).get('/api/documents');\n    expect(res.status).toBe(200);\n    expect(res.body.length).toBe(2);\n  });\n\n  it('should update a document', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Test Doc', content: 'Hello' });\n\n    const res = await request(instance.app)\n      .put(`/api/documents/${createRes.body.id}`)\n      .send({ title: 'Updated', content: 'World' });\n    expect(res.status).toBe(200);\n    expect(res.body.title).toBe('Updated');\n    expect(res.body.content).toBe('World');\n  });\n\n  it('should delete a document', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Test Doc' });\n\n    const res = await request(instance.app)\n      .delete(`/api/documents/${createRes.body.id}`);\n    expect(res.status).toBe(204);\n\n    const getRes = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}`);\n    expect(getRes.status).toBe(404);\n  });\n\n  it('should return 404 when deleting non-existent document', async () => {\n    const res = await request(instance.app)\n      .delete('/api/documents/nonexistent');\n    expect(res.status).toBe(404);\n  });\n\n  it('should get document version history', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Test Doc', content: 'v1' });\n\n    await request(instance.app)\n      .put(`/api/documents/${createRes.body.id}`)\n      .send({ content: 'v2' });\n\n    const res = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}/versions`);\n    expect(res.status).toBe(200);\n    expect(res.body.length).toBeGreaterThanOrEqual(2);\n    expect(res.body[0].content).toBe('v1');\n  });\n});\n\n// ============================================================\n// WebSocket Lifecycle Tests (8 tests)\n// ============================================================\ndescribe('WebSocket Lifecycle', () => {\n  let instance: AppInstance;\n  let port: number;\n\n  beforeEach(() => {\n    instance = createApp();\n    port = instance.start(0);\n  });\n\n  afterEach(() => {\n    instance.stop();\n  });\n\n  it('should connect to a document via WebSocket', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'WS Doc', content: 'Hello' });\n\n    const { ws, sync } = await openWs(port, createRes.body.id);\n    expect(sync.content).toBe('Hello');\n    expect(sync.version).toBeGreaterThanOrEqual(1);\n    ws.close();\n  });\n\n  it('should receive sync message with document content', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'WS Doc', content: 'Initial content' });\n\n    const { ws, sync } = await openWs(port, createRes.body.id);\n    expect(sync.type).toBe('sync');\n    expect(sync.content).toBe('Initial content');\n    expect(typeof sync.clientId).toBe('string');\n    ws.close();\n  });\n\n  it('should receive clientId on connect', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'WS Doc', content: '' });\n\n    const { ws, sync } = await openWs(port, createRes.body.id);\n    expect(sync.clientId).toBeDefined();\n    expect(typeof sync.clientId).toBe('string');\n    ws.close();\n  });\n\n  it('should reject connection to non-existent document', async () => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/nonexistent`);\n\n    const msg = await new Promise<Record<string, unknown>>((resolve) => {\n      ws.on('message', (data) => {\n        resolve(JSON.parse(data.toString()));\n      });\n    });\n\n    expect(msg.type).toBe('error');\n    ws.close();\n  });\n\n  it('should handle multiple clients connecting to same document', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Multi Client', content: 'test' });\n\n    const client1 = await openWs(port, createRes.body.id);\n    const client2 = await openWs(port, createRes.body.id);\n\n    expect(client1.sync.content).toBe('test');\n    expect(client2.sync.content).toBe('test');\n    expect(client1.sync.clientId).not.toBe(client2.sync.clientId);\n\n    client1.ws.close();\n    client2.ws.close();\n  });\n\n  it('should handle client disconnection gracefully', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Disconnect Test', content: 'data' });\n\n    const { ws } = await openWs(port, createRes.body.id);\n    ws.close();\n\n    // Wait a bit for cleanup\n    await sleep(100);\n\n    // Should still be able to connect\n    const { ws: ws2, sync } = await openWs(port, createRes.body.id);\n    expect(sync.content).toBe('data');\n    ws2.close();\n  });\n\n  it('should reject invalid WebSocket path', async () => {\n    const ws = new WebSocket(`ws://localhost:${port}/invalid`);\n\n    const msg = await new Promise<Record<string, unknown>>((resolve, reject) => {\n      const timeout = setTimeout(() => reject(new Error('timeout')), 3000);\n      ws.on('message', (data) => {\n        clearTimeout(timeout);\n        resolve(JSON.parse(data.toString()));\n      });\n      ws.on('close', () => {\n        clearTimeout(timeout);\n        resolve({ type: 'closed' });\n      });\n    });\n\n    expect(msg.type === 'error' || msg.type === 'closed').toBe(true);\n    ws.close();\n  });\n\n  it('should support connecting via /documents/:id path too', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Alt Path', content: 'alt' });\n\n    const { ws, sync } = await openWs(port, createRes.body.id);\n    expect(sync.content).toBe('alt');\n    ws.close();\n  });\n});\n\n// ============================================================\n// Single Client Editing Tests (6 tests)\n// ============================================================\ndescribe('Single Client Editing', () => {\n  let instance: AppInstance;\n  let port: number;\n\n  beforeEach(() => {\n    instance = createApp();\n    port = instance.start(0);\n  });\n\n  afterEach(() => {\n    instance.stop();\n  });\n\n  it('should apply an insert operation', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Edit Test', content: '' });\n\n    const { ws, sync } = await openWs(port, createRes.body.id);\n    const ops = createInsertOp(0, 0, 'Hello');\n    const ack = await sendOp(ws, sync.version, ops);\n    expect(ack.type).toBe('ack');\n\n    // Verify via REST\n    const getRes = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}`);\n    expect(getRes.body.content).toBe('Hello');\n    ws.close();\n  });\n\n  it('should apply a delete operation', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Delete Test', content: 'Hello World' });\n\n    const { ws, sync } = await openWs(port, createRes.body.id);\n    // Delete \"World\" (5 chars starting at position 6)\n    const ops = createDeleteOp(sync.content.length, 6, 5);\n    const ack = await sendOp(ws, sync.version, ops);\n    expect(ack.type).toBe('ack');\n\n    const getRes = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}`);\n    expect(getRes.body.content).toBe('Hello ');\n    ws.close();\n  });\n\n  it('should apply sequential operations', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Seq Test', content: '' });\n\n    const { ws, sync } = await openWs(port, createRes.body.id);\n\n    // Insert \"Hello\"\n    let ack = await sendOp(ws, sync.version, createInsertOp(0, 0, 'Hello'));\n    expect(ack.type).toBe('ack');\n    const v1 = (ack as { version: number }).version;\n\n    // Insert \" World\"\n    ack = await sendOp(ws, v1, createInsertOp(5, 5, ' World'));\n    expect(ack.type).toBe('ack');\n\n    const getRes = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}`);\n    expect(getRes.body.content).toBe('Hello World');\n    ws.close();\n  });\n\n  it('should update version numbers correctly', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Version Test', content: '' });\n\n    const { ws, sync } = await openWs(port, createRes.body.id);\n    const initialVersion = sync.version;\n\n    const ack = await sendOp(ws, sync.version, createInsertOp(0, 0, 'A'));\n    expect((ack as { version: number }).version).toBe(initialVersion + 1);\n\n    ws.close();\n  });\n\n  it('should persist changes to version history', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'History Test', content: '' });\n\n    const { ws, sync } = await openWs(port, createRes.body.id);\n    await sendOp(ws, sync.version, createInsertOp(0, 0, 'Hello'));\n    ws.close();\n\n    const versionsRes = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}/versions`);\n    expect(versionsRes.body.length).toBeGreaterThanOrEqual(2);\n  });\n\n  it('should handle insert at various positions', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Position Test', content: 'AC' });\n\n    const { ws, sync } = await openWs(port, createRes.body.id);\n    // Insert 'B' at position 1 (between A and C)\n    const ack = await sendOp(ws, sync.version, createInsertOp(2, 1, 'B'));\n    expect(ack.type).toBe('ack');\n\n    const getRes = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}`);\n    expect(getRes.body.content).toBe('ABC');\n    ws.close();\n  });\n});\n\n// ============================================================\n// Two-Client Convergence Tests (8 tests)\n// ============================================================\ndescribe('Two-Client Convergence', () => {\n  let instance: AppInstance;\n  let port: number;\n\n  beforeEach(() => {\n    instance = createApp();\n    port = instance.start(0);\n  });\n\n  afterEach(() => {\n    instance.stop();\n  });\n\n  it('should broadcast operations to other clients', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Broadcast', content: '' });\n\n    const c1 = await openWs(port, createRes.body.id);\n    const c2 = await openWs(port, createRes.body.id);\n\n    const opPromise = waitForOp(c2.ws);\n    await sendOp(c1.ws, c1.sync.version, createInsertOp(0, 0, 'Hello'));\n    const receivedOp = await opPromise;\n\n    expect(receivedOp.type).toBe('operation');\n    expect(receivedOp.ops).toBeDefined();\n\n    c1.ws.close();\n    c2.ws.close();\n  });\n\n  it('should converge with two sequential edits from different clients', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Sequential', content: '' });\n\n    const c1 = await openWs(port, createRes.body.id);\n    const c2 = await openWs(port, createRes.body.id);\n\n    // Client 1 inserts \"Hello\"\n    const ack1 = await sendOp(c1.ws, c1.sync.version, createInsertOp(0, 0, 'Hello'));\n    await sleep(100);\n\n    // Client 2 inserts \" World\" after seeing client 1's update\n    const ack2 = await sendOp(c2.ws, (ack1 as { version: number }).version, createInsertOp(5, 5, ' World'));\n    await sleep(100);\n\n    const getRes = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}`);\n    expect(getRes.body.content).toBe('Hello World');\n\n    c1.ws.close();\n    c2.ws.close();\n  });\n\n  it('should converge with concurrent inserts at different positions', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Concurrent', content: 'ABCD' });\n\n    const c1 = await openWs(port, createRes.body.id);\n    const c2 = await openWs(port, createRes.body.id);\n\n    // Both clients see version 1, content \"ABCD\"\n    // Client 1: insert \"X\" at position 1 (between A and B)\n    // Client 2: insert \"Y\" at position 3 (between C and D)\n    const op1 = createInsertOp(4, 1, 'X');\n    const op2 = createInsertOp(4, 3, 'Y');\n\n    const opFromC1 = waitForOp(c2.ws);\n    const ack1Promise = sendOp(c1.ws, c1.sync.version, op1);\n    const ack1 = await ack1Promise;\n    expect(ack1.type).toBe('ack');\n\n    // Wait for c2 to receive c1's operation\n    await opFromC1;\n\n    // c2 sends its op based on original version\n    const ack2 = await sendOp(c2.ws, c2.sync.version, op2);\n    expect(ack2.type).toBe('ack');\n    await sleep(100);\n\n    const getRes = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}`);\n    // Both inserts should be present\n    const content = getRes.body.content;\n    expect(content).toContain('X');\n    expect(content).toContain('Y');\n    expect(content.length).toBe(6); // \"ABCD\" + \"X\" + \"Y\"\n  });\n\n  it('should converge with concurrent inserts at same position', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Same Pos', content: '' });\n\n    const c1 = await openWs(port, createRes.body.id);\n    const c2 = await openWs(port, createRes.body.id);\n\n    // Both insert at position 0\n    const op1 = createInsertOp(0, 0, 'A');\n    const op2 = createInsertOp(0, 0, 'B');\n\n    const ack1 = await sendOp(c1.ws, c1.sync.version, op1);\n    expect(ack1.type).toBe('ack');\n    await sleep(50);\n\n    const ack2 = await sendOp(c2.ws, c2.sync.version, op2);\n    expect(ack2.type).toBe('ack');\n    await sleep(100);\n\n    const getRes = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}`);\n    // Both A and B should be present\n    expect(getRes.body.content).toContain('A');\n    expect(getRes.body.content).toContain('B');\n    expect(getRes.body.content.length).toBe(2);\n  });\n\n  it('should converge with concurrent insert and delete', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Insert Delete', content: 'Hello' });\n\n    const c1 = await openWs(port, createRes.body.id);\n    const c2 = await openWs(port, createRes.body.id);\n\n    // Client 1: insert \" World\" at end\n    const op1 = createInsertOp(5, 5, ' World');\n    // Client 2: delete \"llo\" (3 chars from position 2)\n    const op2 = createDeleteOp(5, 2, 3);\n\n    const ack1 = await sendOp(c1.ws, c1.sync.version, op1);\n    expect(ack1.type).toBe('ack');\n    await sleep(50);\n\n    const ack2 = await sendOp(c2.ws, c2.sync.version, op2);\n    expect(ack2.type).toBe('ack');\n    await sleep(100);\n\n    const getRes = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}`);\n    // \"He\" + \" World\" = \"He World\"\n    expect(getRes.body.content).toBe('He World');\n  });\n\n  it('should include version number in broadcast', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Version Broadcast', content: '' });\n\n    const c1 = await openWs(port, createRes.body.id);\n    const c2 = await openWs(port, createRes.body.id);\n\n    const opPromise = waitForOp(c2.ws);\n    await sendOp(c1.ws, c1.sync.version, createInsertOp(0, 0, 'Hi'));\n    const broadcast = await opPromise;\n\n    expect(broadcast.version).toBeDefined();\n    expect(typeof broadcast.version).toBe('number');\n\n    c1.ws.close();\n    c2.ws.close();\n  });\n\n  it('should handle rapid alternating edits', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Rapid', content: '' });\n\n    const c1 = await openWs(port, createRes.body.id);\n    const c2 = await openWs(port, createRes.body.id);\n\n    // c1: insert \"A\"\n    let ack = await sendOp(c1.ws, c1.sync.version, createInsertOp(0, 0, 'A'));\n    const v1 = (ack as { version: number }).version;\n    await sleep(50);\n\n    // c2: insert \"B\" (after seeing c1's edit)\n    ack = await sendOp(c2.ws, v1, createInsertOp(1, 1, 'B'));\n    const v2 = (ack as { version: number }).version;\n    await sleep(50);\n\n    // c1: insert \"C\"\n    ack = await sendOp(c1.ws, v2, createInsertOp(2, 2, 'C'));\n    await sleep(50);\n\n    const getRes = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}`);\n    expect(getRes.body.content).toBe('ABC');\n\n    c1.ws.close();\n    c2.ws.close();\n  });\n\n  it('should preserve all insertions in concurrent edits', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Preserve', content: 'X' });\n\n    const c1 = await openWs(port, createRes.body.id);\n    const c2 = await openWs(port, createRes.body.id);\n\n    // Both based on version with \"X\"\n    const op1 = createInsertOp(1, 0, 'A'); // insert A at beginning\n    const op2 = createInsertOp(1, 1, 'B'); // insert B at end\n\n    const ack1 = await sendOp(c1.ws, c1.sync.version, op1);\n    expect(ack1.type).toBe('ack');\n    await sleep(50);\n\n    const ack2 = await sendOp(c2.ws, c2.sync.version, op2);\n    expect(ack2.type).toBe('ack');\n    await sleep(100);\n\n    const getRes = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}`);\n    const content = getRes.body.content;\n    expect(content).toContain('A');\n    expect(content).toContain('B');\n    expect(content).toContain('X');\n    expect(content.length).toBe(3);\n\n    c1.ws.close();\n    c2.ws.close();\n  });\n});\n\n// ============================================================\n// Stress Test (5 tests)\n// ============================================================\ndescribe('Stress Test', () => {\n  let instance: AppInstance;\n  let port: number;\n\n  beforeEach(() => {\n    instance = createApp();\n    port = instance.start(0);\n  });\n\n  afterEach(() => {\n    instance.stop();\n  });\n\n  it('should handle 10 concurrent clients connecting', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Stress', content: '' });\n\n    const clients: Array<{ ws: WebSocket; sync: { content: string; version: number; clientId: string } }> = [];\n    for (let i = 0; i < 10; i++) {\n      const client = await openWs(port, createRes.body.id);\n      clients.push(client);\n    }\n\n    expect(clients.length).toBe(10);\n    for (const c of clients) {\n      expect(c.sync.content).toBe('');\n      c.ws.close();\n    }\n  });\n\n  it('should handle 10 sequential edits from different clients', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Seq Stress', content: '' });\n\n    const clients: Array<{ ws: WebSocket; sync: { content: string; version: number; clientId: string } }> = [];\n    for (let i = 0; i < 10; i++) {\n      const client = await openWs(port, createRes.body.id);\n      clients.push(client);\n    }\n\n    let currentVersion = clients[0].sync.version;\n    let currentLength = 0;\n\n    for (let i = 0; i < 10; i++) {\n      const ops = createInsertOp(currentLength, currentLength, String(i));\n      const ack = await sendOp(clients[i].ws, currentVersion, ops);\n      expect(ack.type).toBe('ack');\n      currentVersion = (ack as { version: number }).version;\n      currentLength += 1;\n      await sleep(20);\n    }\n\n    const getRes = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}`);\n    expect(getRes.body.content).toBe('0123456789');\n\n    for (const c of clients) c.ws.close();\n  });\n\n  it('should not corrupt document with concurrent edits from 10 clients', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Concurrent Stress', content: '' });\n\n    const clients: Array<{ ws: WebSocket; sync: { content: string; version: number; clientId: string } }> = [];\n    for (let i = 0; i < 10; i++) {\n      const client = await openWs(port, createRes.body.id);\n      clients.push(client);\n    }\n\n    // All clients send inserts based on initial (empty) version\n    const acks = await Promise.all(\n      clients.map((c, i) =>\n        sendOp(c.ws, c.sync.version, createInsertOp(0, 0, String.fromCharCode(65 + i)))\n      )\n    );\n\n    // All should get acks (some might be errors from OT transform issues, but no crashes)\n    for (const ack of acks) {\n      expect(ack.type === 'ack' || ack.type === 'error').toBe(true);\n    }\n    await sleep(200);\n\n    const getRes = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}`);\n    // The content should contain some characters (at least the first one)\n    expect(getRes.body.content.length).toBeGreaterThan(0);\n\n    for (const c of clients) c.ws.close();\n  });\n\n  it('should maintain document integrity after many operations', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Integrity', content: '' });\n\n    const { ws, sync } = await openWs(port, createRes.body.id);\n    let version = sync.version;\n    let docLength = 0;\n\n    for (let i = 0; i < 50; i++) {\n      const char = String.fromCharCode(65 + (i % 26));\n      const ops = createInsertOp(docLength, docLength, char);\n      const ack = await sendOp(ws, version, ops);\n      expect(ack.type).toBe('ack');\n      version = (ack as { version: number }).version;\n      docLength += 1;\n    }\n\n    const getRes = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}`);\n    expect(getRes.body.content.length).toBe(50);\n\n    ws.close();\n  });\n\n  it('should handle rapid fire operations from multiple clients', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Rapid Fire', content: 'START' });\n\n    const c1 = await openWs(port, createRes.body.id);\n    const c2 = await openWs(port, createRes.body.id);\n\n    let v = c1.sync.version;\n    let len = 5;\n\n    // Alternate between clients\n    for (let i = 0; i < 10; i++) {\n      const client = i % 2 === 0 ? c1 : c2;\n      const ops = createInsertOp(len, len, String(i));\n      const ack = await sendOp(client.ws, v, ops);\n      expect(ack.type).toBe('ack');\n      v = (ack as { version: number }).version;\n      len += 1;\n      await sleep(10);\n    }\n\n    const getRes = await request(instance.app)\n      .get(`/api/documents/${createRes.body.id}`);\n    expect(getRes.body.content).toBe('START0123456789');\n\n    c1.ws.close();\n    c2.ws.close();\n  });\n});\n\n// ============================================================\n// Error Handling Tests (5 tests)\n// ============================================================\ndescribe('Error Handling', () => {\n  let instance: AppInstance;\n  let port: number;\n\n  beforeEach(() => {\n    instance = createApp();\n    port = instance.start(0);\n  });\n\n  afterEach(() => {\n    instance.stop();\n  });\n\n  it('should reject operation with wrong base length', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Error Test', content: 'Hello' });\n\n    const { ws, sync } = await openWs(port, createRes.body.id);\n    // Send operation with wrong base length (says doc is 10 chars but it's 5)\n    const ops: Operation = [10, 'X'];\n    const result = await sendOp(ws, sync.version, ops);\n    expect(result.type).toBe('error');\n    ws.close();\n  });\n\n  it('should reject operation with invalid version', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Error Version', content: '' });\n\n    const { ws } = await openWs(port, createRes.body.id);\n    const ops = createInsertOp(0, 0, 'X');\n    const result = await sendOp(ws, 999, ops);\n    expect(result.type).toBe('error');\n    ws.close();\n  });\n\n  it('should reject malformed message', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Malformed', content: '' });\n\n    const { ws } = await openWs(port, createRes.body.id);\n\n    const response = await new Promise<Record<string, unknown>>((resolve) => {\n      ws.on('message', (data) => {\n        const msg = JSON.parse(data.toString());\n        if (msg.type === 'error') resolve(msg);\n      });\n      ws.send('not json!!!');\n    });\n\n    expect(response.type).toBe('error');\n    ws.close();\n  });\n\n  it('should reject operation with missing ops field', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Missing Ops', content: '' });\n\n    const { ws, sync } = await openWs(port, createRes.body.id);\n\n    const response = await new Promise<Record<string, unknown>>((resolve) => {\n      ws.on('message', (data) => {\n        const msg = JSON.parse(data.toString());\n        if (msg.type === 'error') resolve(msg);\n      });\n      ws.send(JSON.stringify({ type: 'operation', version: sync.version }));\n    });\n\n    expect(response.type).toBe('error');\n    ws.close();\n  });\n\n  it('should not crash on unknown message types', async () => {\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Unknown Type', content: '' });\n\n    const { ws } = await openWs(port, createRes.body.id);\n\n    const response = await new Promise<Record<string, unknown>>((resolve) => {\n      ws.on('message', (data) => {\n        const msg = JSON.parse(data.toString());\n        if (msg.type === 'error') resolve(msg);\n      });\n      ws.send(JSON.stringify({ type: 'unknown_type' }));\n    });\n\n    expect(response.type).toBe('error');\n\n    // Server should still be alive - try sending a valid operation\n    const ops = createInsertOp(0, 0, 'X');\n    ws.send(JSON.stringify({ type: 'operation', version: 1, ops }));\n    ws.close();\n  });\n});\n\n// ============================================================\n// Persistence Tests (3 tests)\n// ============================================================\ndescribe('Persistence', () => {\n  const dbPath = '/tmp/test-persistence-' + Date.now() + '.db';\n\n  afterAll(() => {\n    try { fs.unlinkSync(dbPath); } catch { /* ignore */ }\n  });\n\n  it('should persist documents across server restarts', async () => {\n    // Start first instance\n    let instance = createApp(dbPath);\n    instance.start(0);\n\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Persist Test', content: 'Saved data' });\n    const docId = createRes.body.id;\n\n    instance.stop();\n\n    // Start second instance with same DB\n    instance = createApp(dbPath);\n    instance.start(0);\n\n    const getRes = await request(instance.app)\n      .get(`/api/documents/${docId}`);\n    expect(getRes.status).toBe(200);\n    expect(getRes.body.content).toBe('Saved data');\n    expect(getRes.body.title).toBe('Persist Test');\n\n    instance.stop();\n  });\n\n  it('should persist version history across restarts', async () => {\n    let instance = createApp(dbPath);\n    instance.start(0);\n\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Version Persist', content: 'v1' });\n    const docId = createRes.body.id;\n\n    await request(instance.app)\n      .put(`/api/documents/${docId}`)\n      .send({ content: 'v2' });\n\n    instance.stop();\n\n    instance = createApp(dbPath);\n    instance.start(0);\n\n    const versionsRes = await request(instance.app)\n      .get(`/api/documents/${docId}/versions`);\n    expect(versionsRes.body.length).toBeGreaterThanOrEqual(2);\n\n    instance.stop();\n  });\n\n  it('should persist WebSocket edits across restarts', async () => {\n    let instance = createApp(dbPath);\n    let port = instance.start(0);\n\n    const createRes = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'WS Persist', content: '' });\n    const docId = createRes.body.id;\n\n    const { ws, sync } = await openWs(port, docId);\n    await sendOp(ws, sync.version, createInsertOp(0, 0, 'Persisted'));\n    ws.close();\n    await sleep(100);\n\n    instance.stop();\n\n    instance = createApp(dbPath);\n    port = instance.start(0);\n\n    const getRes = await request(instance.app)\n      .get(`/api/documents/${docId}`);\n    expect(getRes.body.content).toBe('Persisted');\n\n    instance.stop();\n  });\n});\n","structuredPatch":[],"originalFile":null}}
