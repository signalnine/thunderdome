+++ b/src/server.ts
@@ -0,0 +1,67 @@
+import express from 'express';
+import { createServer, Server } from 'http';
+import { createDatabase, DocumentStore } from './db.js';
+import { createRouter } from './routes.js';
+import { CollaborationServer } from './ws.js';
+import Database from 'better-sqlite3';
+
+export interface AppInstance {
+  app: express.Express;
+  start: (port?: number) => number;
+  stop: () => void;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db: Database.Database = createDatabase(dbPath);
+  const store = new DocumentStore(db);
+
+  const app = express();
+  app.use(express.json());
+
+  const router = createRouter(store);
+  app.use('/api', router);
+  // Also mount at root for convenience
+  app.use('/', router);
+
+  const server: Server = createServer(app);
+  const collab = new CollaborationServer(server, store);
+
+  let listening = false;
+
+  function start(port?: number): number {
+    const listenPort = port ?? 0;
+    server.listen(listenPort);
+    listening = true;
+    const addr = server.address();
+    if (addr && typeof addr === 'object') {
+      return addr.port;
+    }
+    return listenPort;
+  }
+
+  function stop(): void {
+    collab.closeAll();
+    if (listening) {
+      server.close();
+      listening = false;
+    }
+    db.close();
+  }
+
+  return { app, start, stop };
+}
+
+// Allow running directly
+const isMainModule = process.argv[1] &&
+  (process.argv[1].endsWith('/server.js') || process.argv[1].endsWith('/server.ts'));
+
+if (isMainModule) {
+  const instance = createApp('./collab.db');
+  const port = instance.start(3000);
+  console.log(`Collaborative editor server running on port ${port}`);
+
+  process.on('SIGINT', () => {
+    instance.stop();
+    process.exit(0);
+  });
+}
