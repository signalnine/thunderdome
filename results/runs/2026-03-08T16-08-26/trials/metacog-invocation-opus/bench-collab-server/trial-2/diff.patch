@@ -0,0 +1,434 @@
+/**
+ * Operational Transform (OT) engine for collaborative text editing.
+ *
+ * Operations are arrays of components:
+ * - number > 0: retain N characters
+ * - string: insert the given text
+ * - number < 0: delete |N| characters
+ *
+ * The base length of an operation is the sum of retains + |deletes|.
+ * The target length is the sum of retains + insert lengths.
+ */
+
+export type OpComponent = number | string;
+export type Operation = OpComponent[];
+
+export interface OperationMessage {
+  type: 'operation';
+  docId: string;
+  version: number;
+  ops: Operation;
+  clientId?: string;
+}
+
+export function operationBaseLength(ops: Operation): number {
+  let len = 0;
+  for (const op of ops) {
+    if (typeof op === 'number') {
+      if (op > 0) len += op;
+      else len += Math.abs(op);
+    }
+  }
+  return len;
+}
+
+export function operationTargetLength(ops: Operation): number {
+  let len = 0;
+  for (const op of ops) {
+    if (typeof op === 'number') {
+      if (op > 0) len += op;
+      // deletes don't contribute to target length
+    } else {
+      len += op.length;
+    }
+  }
+  return len;
+}
+
+/**
+ * Apply an operation to a document string.
+ */
+export function applyOperation(doc: string, ops: Operation): string {
+  if (operationBaseLength(ops) !== doc.length) {
+    throw new Error(
+      `Operation base length (${operationBaseLength(ops)}) does not match document length (${doc.length})`
+    );
+  }
+
+  let result = '';
+  let index = 0;
+
+  for (const op of ops) {
+    if (typeof op === 'number') {
+      if (op > 0) {
+        // retain
+        result += doc.slice(index, index + op);
+        index += op;
+      } else {
+        // delete
+        index += Math.abs(op);
+      }
+    } else {
+      // insert
+      result += op;
+    }
+  }
+
+  return result;
+}
+
+/**
+ * Compose two operations into a single operation.
+ * apply(apply(doc, a), b) === apply(doc, compose(a, b))
+ */
+export function composeOperations(a: Operation, b: Operation): Operation {
+  if (operationTargetLength(a) !== operationBaseLength(b)) {
+    throw new Error('Compose: target length of a must match base length of b');
+  }
+
+  const result: Operation = [];
+  let ia = 0;
+  let ib = 0;
+  let oa: OpComponent | undefined = a[ia];
+  let ob: OpComponent | undefined = b[ib];
+
+  function push(op: OpComponent) {
+    if (typeof op === 'number' && op === 0) return;
+    if (result.length > 0) {
+      const last = result[result.length - 1];
+      if (typeof op === 'number' && typeof last === 'number') {
+        if ((op > 0 && last > 0) || (op < 0 && last < 0)) {
+          result[result.length - 1] = last + op;
+          return;
+        }
+      } else if (typeof op === 'string' && typeof last === 'string') {
+        result[result.length - 1] = last + op;
+        return;
+      }
+    }
+    result.push(op);
+  }
+
+  while (oa !== undefined || ob !== undefined) {
+    // Delete from a
+    if (typeof oa === 'number' && oa < 0) {
+      push(oa);
+      ia++;
+      oa = a[ia];
+      continue;
+    }
+    // Insert from b
+    if (typeof ob === 'string') {
+      push(ob);
+      ib++;
+      ob = b[ib];
+      continue;
+    }
+
+    if (oa === undefined || ob === undefined) {
+      throw new Error('Compose: unexpected end of operations');
+    }
+
+    // Both retain
+    if (typeof oa === 'number' && oa > 0 && typeof ob === 'number' && ob > 0) {
+      if (oa > ob) {
+        push(ob);
+        oa = oa - ob;
+        ib++;
+        ob = b[ib];
+      } else if (oa < ob) {
+        push(oa);
+        ob = ob - oa;
+        ia++;
+        oa = a[ia];
+      } else {
+        push(oa);
+        ia++;
+        oa = a[ia];
+        ib++;
+        ob = b[ib];
+      }
+    }
+    // a insert, b retain
+    else if (typeof oa === 'string' && typeof ob === 'number' && ob > 0) {
+      if (oa.length > ob) {
+        push(oa.slice(0, ob));
+        oa = oa.slice(ob);
+        ib++;
+        ob = b[ib];
+      } else if (oa.length < ob) {
+        push(oa);
+        ob = ob - oa.length;
+        ia++;
+        oa = a[ia];
+      } else {
+        push(oa);
+        ia++;
+        oa = a[ia];
+        ib++;
+        ob = b[ib];
+      }
+    }
+    // a retain, b delete
+    else if (typeof oa === 'number' && oa > 0 && typeof ob === 'number' && ob < 0) {
+      const absOb = Math.abs(ob);
+      if (oa > absOb) {
+        push(ob);
+        oa = oa - absOb;
+        ib++;
+        ob = b[ib];
+      } else if (oa < absOb) {
+        push(-oa);
+        ob = -(absOb - oa);
+        ia++;
+        oa = a[ia];
+      } else {
+        push(ob);
+        ia++;
+        oa = a[ia];
+        ib++;
+        ob = b[ib];
+      }
+    }
+    // a insert, b delete
+    else if (typeof oa === 'string' && typeof ob === 'number' && ob < 0) {
+      const absOb = Math.abs(ob);
+      if (oa.length > absOb) {
+        oa = oa.slice(absOb);
+        ib++;
+        ob = b[ib];
+      } else if (oa.length < absOb) {
+        ob = -(absOb - oa.length);
+        ia++;
+        oa = a[ia];
+      } else {
+        ia++;
+        oa = a[ia];
+        ib++;
+        ob = b[ib];
+      }
+    } else {
+      throw new Error(`Compose: unhandled case: oa=${JSON.stringify(oa)}, ob=${JSON.stringify(ob)}`);
+    }
+  }
+
+  return result;
+}
+
+/**
+ * Transform operation a against operation b.
+ * Returns [a', b'] such that apply(apply(doc, a), b') === apply(apply(doc, b), a')
+ *
+ * Both operations must have the same base length (they were created against the same document).
+ */
+export function transformOperations(a: Operation, b: Operation): [Operation, Operation] {
+  if (operationBaseLength(a) !== operationBaseLength(b)) {
+    throw new Error(
+      `Transform: base lengths must match (a=${operationBaseLength(a)}, b=${operationBaseLength(b)})`
+    );
+  }
+
+  const aPrime: Operation = [];
+  const bPrime: Operation = [];
+
+  let ia = 0;
+  let ib = 0;
+  let oa: OpComponent | undefined = a[ia];
+  let ob: OpComponent | undefined = b[ib];
+
+  function pushA(op: OpComponent) {
+    if (typeof op === 'number' && op === 0) return;
+    if (aPrime.length > 0) {
+      const last = aPrime[aPrime.length - 1];
+      if (typeof op === 'number' && typeof last === 'number') {
+        if ((op > 0 && last > 0) || (op < 0 && last < 0)) {
+          aPrime[aPrime.length - 1] = last + op;
+          return;
+        }
+      } else if (typeof op === 'string' && typeof last === 'string') {
+        aPrime[aPrime.length - 1] = last + op;
+        return;
+      }
+    }
+    aPrime.push(op);
+  }
+
+  function pushB(op: OpComponent) {
+    if (typeof op === 'number' && op === 0) return;
+    if (bPrime.length > 0) {
+      const last = bPrime[bPrime.length - 1];
+      if (typeof op === 'number' && typeof last === 'number') {
+        if ((op > 0 && last > 0) || (op < 0 && last < 0)) {
+          bPrime[bPrime.length - 1] = last + op;
+          return;
+        }
+      } else if (typeof op === 'string' && typeof last === 'string') {
+        bPrime[bPrime.length - 1] = last + op;
+        return;
+      }
+    }
+    bPrime.push(op);
+  }
+
+  while (oa !== undefined || ob !== undefined) {
+    // Insert from a takes priority (left wins)
+    if (typeof oa === 'string') {
+      pushA(oa);
+      pushB(oa.length); // b' must retain over a's insert
+      ia++;
+      oa = a[ia];
+      continue;
+    }
+
+    // Insert from b
+    if (typeof ob === 'string') {
+      pushA(ob.length); // a' must retain over b's insert
+      pushB(ob);
+      ib++;
+      ob = b[ib];
+      continue;
+    }
+
+    if (oa === undefined || ob === undefined) {
+      throw new Error('Transform: unexpected end of operations');
+    }
+
+    // Both retain
+    if (typeof oa === 'number' && oa > 0 && typeof ob === 'number' && ob > 0) {
+      const min = Math.min(oa, ob);
+      pushA(min);
+      pushB(min);
+      if (oa > ob) {
+        oa = oa - ob;
+        ib++;
+        ob = b[ib];
+      } else if (oa < ob) {
+        ob = ob - oa;
+        ia++;
+        oa = a[ia];
+      } else {
+        ia++;
+        oa = a[ia];
+        ib++;
+        ob = b[ib];
+      }
+    }
+    // a delete, b delete
+    else if (typeof oa === 'number' && oa < 0 && typeof ob === 'number' && ob < 0) {
+      const absA = Math.abs(oa);
+      const absB = Math.abs(ob);
+      if (absA > absB) {
+        oa = -(absA - absB);
+        ib++;
+        ob = b[ib];
+      } else if (absA < absB) {
+        ob = -(absB - absA);
+        ia++;
+        oa = a[ia];
+      } else {
+        ia++;
+        oa = a[ia];
+        ib++;
+        ob = b[ib];
+      }
+    }
+    // a delete, b retain
+    else if (typeof oa === 'number' && oa < 0 && typeof ob === 'number' && ob > 0) {
+      const absA = Math.abs(oa);
+      if (absA > ob) {
+        pushA(-ob);
+        oa = -(absA - ob);
+        ib++;
+        ob = b[ib];
+      } else if (absA < ob) {
+        pushA(oa);
+        ob = ob - absA;
+        ia++;
+        oa = a[ia];
+      } else {
+        pushA(oa);
+        ia++;
+        oa = a[ia];
+        ib++;
+        ob = b[ib];
+      }
+    }
+    // a retain, b delete
+    else if (typeof oa === 'number' && oa > 0 && typeof ob === 'number' && ob < 0) {
+      const absB = Math.abs(ob);
+      if (oa > absB) {
+        pushB(ob);
+        oa = oa - absB;
+        ib++;
+        ob = b[ib];
+      } else if (oa < absB) {
+        pushB(-oa);
+        ob = -(absB - oa);
+        ia++;
+        oa = a[ia];
+      } else {
+        pushB(ob);
+        ia++;
+        oa = a[ia];
+        ib++;
+        ob = b[ib];
+      }
+    } else {
+      throw new Error(`Transform: unhandled case: oa=${JSON.stringify(oa)}, ob=${JSON.stringify(ob)}`);
+    }
+  }
+
+  return [aPrime, bPrime];
+}
+
+/**
+ * Create an insert operation at a specific position in a document of given length.
+ */
+export function createInsertOp(docLength: number, position: number, text: string): Operation {
+  const ops: Operation = [];
+  if (position > 0) ops.push(position);
+  ops.push(text);
+  if (docLength - position > 0) ops.push(docLength - position);
+  return ops;
+}
+
+/**
+ * Create a delete operation at a specific position in a document of given length.
+ */
+export function createDeleteOp(docLength: number, position: number, count: number): Operation {
+  const ops: Operation = [];
+  if (position > 0) ops.push(position);
+  ops.push(-count);
+  if (docLength - position - count > 0) ops.push(docLength - position - count);
+  return ops;
+}
+
+/**
+ * Validate an operation against a document length.
+ */
+export function validateOperation(ops: Operation, docLength: number): string | null {
+  if (!Array.isArray(ops)) {
+    return 'Operation must be an array';
+  }
+
+  for (const op of ops) {
+    if (typeof op === 'number') {
+      if (!Number.isInteger(op) || op === 0) {
+        return `Invalid operation component: ${op} (must be non-zero integer)`;
+      }
+    } else if (typeof op === 'string') {
+      if (op.length === 0) {
+        return 'Empty string insert is not allowed';
+      }
+    } else {
+      return `Invalid operation component type: ${typeof op}`;
+    }
+  }
+
+  const baseLen = operationBaseLength(ops);
+  if (baseLen !== docLength) {
+    return `Operation base length (${baseLen}) does not match document length (${docLength})`;
+  }
+
+  return null;
+}
