+    const ws = new WebSocket(wsUrl('nonexistent'));
+
+    await new Promise<void>((resolve) => {
+      ws.on('error', () => resolve());
+      ws.on('close', () => resolve());
+      setTimeout(() => {
+        ws.close();
+        resolve();
+      }, 500);
+    });
+  });
+
+  it('handles malformed messages gracefully', async () => {
+    const { body: created } = await fetchJson('/api/documents', {
+      method: 'POST',
+      body: JSON.stringify({ title: 'Error Test', content: 'test' }),
+    });
+    const docId = (created as { id: string }).id;
+
+    const { ws } = await connectWs(docId);
+
+    const errorPromise = waitForMessage(ws);
+    ws.send('not json{{{');
+    const errorMsg = await errorPromise as { type: string };
+    expect(errorMsg.type).toBe('error');
+
+    ws.close();
+  });
+
+  it('handles invalid operation gracefully', async () => {
+    const { body: created } = await fetchJson('/api/documents', {
+      method: 'POST',
+      body: JSON.stringify({ title: 'Invalid Op Test', content: 'test' }),
+    });
+    const docId = (created as { id: string }).id;
+
+    const { ws, messages } = await connectWs(docId);
+    const sync = messages[0] as { document: { version: number } };
+
+    const errorPromise = waitForMessage(ws);
+    ws.send(JSON.stringify({
+      type: 'operation',
+      op: { type: 'insert', position: 100, text: 'x' },
+      version: sync.document.version,
+    }));
+    const errorMsg = await errorPromise as { type: string; message: string };
+    expect(errorMsg.type).toBe('error');
+
+    ws.close();
+  });
+});
+
