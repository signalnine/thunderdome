— server will transform against client1's op\n    }));\n\n    // Wait for ack and broadcasts to settle\n    await new Promise(r => setTimeout(r, 300));\n    client2.ws.off('message', msgHandler);\n\n    // Check that client2 received an ack\n    const ack = client2Messages.find((m) => (m as { type: string }).type === 'ack');\n    expect(ack).toBeDefined();\n\n    // Check final document state via REST\n    const { body: doc } = await fetchJson(`/api/documents/${docId}`);\n    const content = (doc as { content: string }).content;\n    // Both X and Y should be present\n    expect(content).toContain('X');\n    expect(content).toContain('Y');\n    expect(content.length).toBe(8); // original 6 + X + Y\n\n    client1.ws.close();\n    client2.ws.close();\n  });","originalFile":"import { describe, it, expect, beforeEach, afterEach } from 'vitest';\nimport { createApp, AppInstance } from './server.js';\nimport WebSocket from 'ws';\n\nlet app: AppInstance;\nlet port: number;\nlet baseUrl: string;\n\nbeforeEach(async () => {\n  app = createApp();\n  port = await app.start(0);\n  baseUrl = `http://localhost:${port}`;\n});\n\nafterEach(async () => {\n  await app.stop();\n});\n\nfunction wsUrl(docId: string): string {\n  return `ws://localhost:${port}/documents/${docId}/ws`;\n}\n\nfunction connectWs(docId: string): Promise<{ ws: WebSocket; messages: unknown[] }> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(wsUrl(docId));\n    const messages: unknown[] = [];\n\n    ws.on('message', (data) => {\n      const msg = JSON.parse(data.toString());\n      messages.push(msg);\n      // Resolve once we get the sync message\n      if (msg.type === 'sync') {\n        resolve({ ws, messages });\n      }\n    });\n\n    ws.on('error', reject);\n    setTimeout(() => reject(new Error('Timeout connecting WebSocket')), 5000);\n  });\n}\n\nfunction waitForMessage(ws: WebSocket, timeout = 2000): Promise<unknown> {\n  return new Promise((resolve, reject) => {\n    const timer = setTimeout(() => reject(new Error('Timeout waiting for message')), timeout);\n    ws.once('message', (data) => {\n      clearTimeout(timer);\n      resolve(JSON.parse(data.toString()));\n    });\n  });\n}\n\nasync function fetchJson(path: string, options: RequestInit = {}): Promise<{ status: number; body: unknown }> {\n  const res = await fetch(`${baseUrl}${path}`, {\n    headers: { 'Content-Type': 'application/json', ...options.headers as Record<string, string> },\n    ...options,\n  });\n  const body = res.headers.get('content-type')?.includes('json') ? await res.json() : null;\n  return { status: res.status, body };\n}\n\ndescribe('REST API', () => {\n  it('creates a document', async () => {\n    const { status, body } = await fetchJson('/api/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Test Doc', content: 'Hello' }),\n    });\n    expect(status).toBe(201);\n    const doc = body as { id: string; title: string; content: string };\n    expect(doc.title).toBe('Test Doc');\n    expect(doc.content).toBe('Hello');\n    expect(doc.id).toBeDefined();\n  });\n\n  it('lists documents', async () => {\n    await fetchJson('/api/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Doc 1' }),\n    });\n    await fetchJson('/api/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Doc 2' }),\n    });\n\n    const { status, body } = await fetchJson('/api/documents');\n    expect(status).toBe(200);\n    expect(Array.isArray(body)).toBe(true);\n    expect((body as unknown[]).length).toBe(2);\n  });\n\n  it('gets a single document', async () => {\n    const { body: created } = await fetchJson('/api/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Test', content: 'content' }),\n    });\n    const id = (created as { id: string }).id;\n\n    const { status, body } = await fetchJson(`/api/documents/${id}`);\n    expect(status).toBe(200);\n    expect((body as { title: string }).title).toBe('Test');\n  });\n\n  it('returns 404 for non-existent document', async () => {\n    const { status } = await fetchJson('/api/documents/nonexistent');\n    expect(status).toBe(404);\n  });\n\n  it('updates a document', async () => {\n    const { body: created } = await fetchJson('/api/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Original', content: 'old' }),\n    });\n    const id = (created as { id: string }).id;\n\n    const { status, body } = await fetchJson(`/api/documents/${id}`, {\n      method: 'PUT',\n      body: JSON.stringify({ title: 'Updated', content: 'new' }),\n    });\n    expect(status).toBe(200);\n    expect((body as { title: string }).title).toBe('Updated');\n    expect((body as { content: string }).content).toBe('new');\n  });\n\n  it('deletes a document', async () => {\n    const { body: created } = await fetchJson('/api/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'ToDelete' }),\n    });\n    const id = (created as { id: string }).id;\n\n    const { status: deleteStatus } = await fetchJson(`/api/documents/${id}`, { method: 'DELETE' });\n    expect(deleteStatus).toBe(204);\n\n    const { status: getStatus } = await fetchJson(`/api/documents/${id}`);\n    expect(getStatus).toBe(404);\n  });\n\n  it('gets version history', async () => {\n    const { body: created } = await fetchJson('/api/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Versioned', content: 'v1' }),\n    });\n    const id = (created as { id: string }).id;\n\n    const { status, body } = await fetchJson(`/api/documents/${id}/versions`);\n    expect(status).toBe(200);\n    expect(Array.isArray(body)).toBe(true);\n    expect((body as unknown[]).length).toBeGreaterThanOrEqual(1);\n  });\n\n  it('rejects document creation without title', async () => {\n    const { status } = await fetchJson('/api/documents', {\n      method: 'POST',\n      body: JSON.stringify({ content: 'no title' }),\n    });\n    expect(status).toBe(400);\n  });\n});\n\ndescribe('WebSocket collaboration', () => {\n  it('connects and receives sync message', async () => {\n    const { body: created } = await fetchJson('/api/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'WS Test', content: 'hello' }),\n    });\n    const docId = (created as { id: string }).id;\n\n    const { ws, messages } = await connectWs(docId);\n\n    expect(messages.length).toBeGreaterThanOrEqual(1);\n    const sync = messages[0] as { type: string; document: { content: string }; clientId: string };\n    expect(sync.type).toBe('sync');\n    expect(sync.document.content).toBe('hello');\n    expect(sync.clientId).toBeDefined();\n\n    ws.close();\n  });\n\n  it('applies an operation and receives ack', async () => {\n    const { body: created } = await fetchJson('/api/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Op Test', content: 'hello' }),\n    });\n    const docId = (created as { id: string }).id;\n\n    const { ws, messages } = await connectWs(docId);\n    const sync = messages[0] as { type: string; document: { version: number } };\n\n    const ackPromise = waitForMessage(ws);\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      op: { type: 'insert', position: 5, text: ' world' },\n      version: sync.document.version,\n    }));\n\n    const ack = await ackPromise as { type: string; version: number };\n    expect(ack.type).toBe('ack');\n\n    // Verify via REST\n    const { body: doc } = await fetchJson(`/api/documents/${docId}`);\n    expect((doc as { content: string }).content).toBe('hello world');\n\n    ws.close();\n  });\n\n  it('broadcasts operations to other clients', async () => {\n    const { body: created } = await fetchJson('/api/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Broadcast Test', content: 'abc' }),\n    });\n    const docId = (created as { id: string }).id;\n\n    const client1 = await connectW