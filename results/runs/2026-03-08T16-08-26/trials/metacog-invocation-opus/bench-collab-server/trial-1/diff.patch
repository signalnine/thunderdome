ocumentId: string) => {\n      this.handleConnection(ws, documentId);\n    });\n  }\n\n  private getOrCreateDocumentState(documentId: string): DocumentState {\n    let state = this.documents.get(documentId);\n    if (!state) {\n      // Build the operation log from the database versions\n      const versions = this.db.getVersions(documentId);\n      const operationLog: Operation[] = [];\n      for (const v of versions) {\n        if (v.operation) {\n          try {\n            const parsed = JSON.parse(v.operation);\n            if (parsed.type === 'insert' || parsed.type === 'delete') {\n              operationLog.push(parsed as Operation);\n            }\n          } catch {\n            // Skip invalid operations\n          }\n        }\n      }\n      state = { clients: new Map(), operationLog };\n      this.documents.set(documentId, state);\n    }\n    return state;\n  }\n\n  private handleConnection(ws: WebSocket, documentId: string): void {\n    const clientId = randomUUID();\n    const state = this.getOrCreateDocumentState(documentId);\n\n    const client: ConnectedClient = { ws, clientId, documentId };\n    state.clients.set(clientId, client);\n    this.db.addConnection(clientId, documentId);\n\n    // Send current document state\n    const doc = this.db.getDocument(documentId);\n    if (doc) {\n      const version = this.db.getDocumentVersion(documentId);\n      this.sendMessage(ws, {\n        type: 'sync',\n        document: {\n          id: doc.id,\n          title: doc.title,\n          content: doc.content,\n          version,\n        },\n        clientId,\n      });\n    }\n\n    ws.on('message', (data) => {\n      try {\n        const message = JSON.parse(data.toString());\n        this.handleMessage(client, message);\n      } catch (err) {\n        this.sendMessage(ws, {\n          type: 'error',\n          message: 'Invalid message format',\n        });\n      }\n    });\n\n    ws.on('close', () => {\n      state.clients.delete(clientId);\n      this.db.removeConnection(clientId);\n      if (state.clients.size === 0) {\n        this.documents.delete(documentId);\n      }\n    });\n\n    ws.on('error', () => {\n      state.clients.delete(clientId);\n      this.db.removeConnection(clientId);\n    });\n  }\n\n  private handleMessage(client: ConnectedClient, message: unknown): void {\n    if (!message || typeof message !== 'object') {\n      this.sendMessage(client.ws, { type: 'error', message: 'Invalid message' });\n      return;\n    }\n\n    const msg = message as Record<string, unknown>;\n\n    if (msg.type === 'operation') {\n      this.handleOperation(client, msg as unknown as { type: 'operation'; op: Operation; version: number });\n    } else {\n      this.sendMessage(client.ws, { type: 'error', message: `Unknown message type: ${msg.type}` });\n    }\n  }\n\n  private handleOperation(\n    client: ConnectedClient,\n    message: { type: 'operation'; op: Operation; version: number }\n  ): void {\n    const { op, version } = message;\n    const state = this.documents.get(client.documentId);\n    if (!state) return;\n\n    const doc = this.db.getDocument(client.documentId);\n    if (!doc) return;\n\n    // Validate the operation\n    if (!op || typeof op !== 'object' || !op.type) {\n      this.sendMessage(client.ws, { type: 'error', message: 'Invalid operation format' });\n      return;\n    }\n\n    const currentVersion = this.db.getDocumentVersion(client.documentId);\n\n    if (typeof version !== 'number' || version < 0 || version > currentVersion) {\n      this.sendMessage(client.ws, {\n        type: 'error',\n        message: `Invalid version: ${version}. Current version is ${currentVersion}`,\n      });\n      return;\n    }\n\n    // Transform the operation against all operations that happened since the client's version\n    let transformedOp: Operation = { ...op };\n\n    // We need to transform against operations from version+1 to currentVersion\n    // The operation log contains all ops; version N w