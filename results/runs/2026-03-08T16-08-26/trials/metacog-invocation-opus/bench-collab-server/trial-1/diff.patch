n: 5, text: 'X' };\n      const b: Operation = { type: 'delete', position: 0, count: 2 };\n      const aPrime = transformOp(a, b);\n      expect(aPrime).toEqual({ type: 'insert', position: 3, text: 'X' });\n    });\n\n    it('insert within deleted range', () => {\n      const a: Operation = { type: 'insert', position: 2, text: 'X' };\n      const b: Operation = { type: 'delete', position: 1, count: 3 };\n      const aPrime = transformOp(a, b);\n      // Insert falls within deleted range — placed at delete position\n      expect(aPrime.type).toBe('insert');\n      expect((aPrime as { position: number }).position).toBe(1);\n    });\n  });\n\n  describe('transformOp - delete/insert', () => {\n    it('delete before insert', () => {\n      const a: Operation = { type: 'delete', position: 0, count: 2 };\n      const b: Operation = { type: 'insert', position: 5, text: 'X' };\n      const aPrime = transformOp(a, b);\n      expect(aPrime).toEqual({ type: 'delete', position: 0, count: 2 });\n    });\n\n    it('delete after insert', () => {\n      const a: Operation = { type: 'delete', position: 5, count: 2 };\n      const b: Operation = { type: 'insert', position: 0, text: 'XX' };\n      const aPrime = transformOp(a, b);\n      expect(aPrime).toEqual({ type: 'delete', position: 7, count: 2 });\n    });\n  });\n\n  describe('transformOp - delete/delete', () => {\n    it('non-overlapping deletes', () => {\n      const a: Operation = { type: 'delete', position: 0, count: 2 };\n      const b: Operation = { type: 'delete', position: 5, count: 2 };\n      const aPrime = transformOp(a, b);\n      expect(aPrime).toEqual({ type: 'delete', position: 0, count: 2 });\n    });\n\n    it('fully overlapping deletes (a inside b)', () => {\n      const a: Operation = { type: 'delete', position: 2, count: 1 };\n      const b: Operation = { type: 'delete', position: 1, count: 3 };\n      const aPrime = transformOp(a, b);\n      expect(aPrime).toEqual({ type: 'delete', position: 1, count: 0 });\