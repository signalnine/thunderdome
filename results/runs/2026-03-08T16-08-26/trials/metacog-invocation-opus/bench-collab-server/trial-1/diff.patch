,"tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/server.ts","content":"import express from 'express';\nimport { createServer, Server } from 'http';\nimport { DocumentDatabase } from './database.js';\nimport { createRouter } from './routes.js';\nimport { WebSocketHandler } from './websocket.js';\n\nexport interface AppInstance {\n  app: express.Express;\n  start(port?: number): Promise<number>;\n  stop(): Promise<void>;\n}\n\nexport function createApp(dbPath?: string): AppInstance {\n  const db = new DocumentDatabase(dbPath || ':memory:');\n  const app = express();\n\n  app.use(express.json());\n  app.use('/api', createRouter(db));\n\n  const server: Server = createServer(app);\n  let wsHandler: WebSocketHandler | null = null;\n\n  return {\n    app,\n    async start(port?: number): Promise<number> {\n      wsHandler = new WebSocketHandler(server, db);\n\n      return new Promise<number>((resolve) => {\n        server.listen(port ?? 0, () => {\n          const addr = server.address();\n          const actualPort = typeof addr === 'object' && addr ? addr.port : 0;\n          resolve(actualPort);\n        });\n      });\n    },\n    async stop(): Promise<void> {\n      return new Promise<void>((resolve, reject) => {\n        if (wsHandler) {\n          wsHandler.closeAll();\n        }\n        server.close((err) => {\n          db.close();\n          if (err) reject(err);\n          else resolve();\n        });\n      });\n    },\n  };\n}\n","numLines":50,"startLine":1,"totalLines":50}}}
