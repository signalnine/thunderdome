ition > docLength) {\n      return `Insert position ${op.position} is beyond document length ${docLength}`;\n    }\n    if (typeof op.text !== 'string' || op.text.length === 0) {\n      return 'Insert text must be a non-empty string';\n    }\n  } else if (op.type === 'delete') {\n    if (typeof op.position !== 'number' || op.position < 0) {\n      return 'Delete position must be a non-negative number';\n    }\n    if (typeof op.count !== 'number' || op.count < 1) {\n      return 'Delete count must be a positive number';\n    }\n    if (op.position + op.count > docLength) {\n      return `Delete range [${op.position}, ${op.position + op.count}) exceeds document length ${docLength}`;\n    }\n  } else {\n    return `Unknown operation type: ${(op as { type: string }).type}`;\n  }\n  return null;\n}\n","structuredPatch":[{"oldStart":56,"oldLines":8,"newStart":56,"newLines":11,"lines":["   if (a.position >= b.position + b.count) {","     return { ...a, position: a.position - b.count };","   }","-  // Insert falls within the deleted range — place at delete position","-  return { ...a, position: b.position };","+  // Insert falls strictly within the deleted range.","+  // The delete removes the region the insert targeted, so the insert becomes","+  // a no-op (empty text). The delete-side transform expands to consume the","+  // inserted text, ensuring convergence.","+  return { type: 'insert', position: b.position, text: '' };"," }"," "," function transformDeleteInsert(a: DeleteOp, b: InsertOp): DeleteOp {"]}],"userModified":false,"replaceAll":false}}
