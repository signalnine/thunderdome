diff --git a/src/database.ts b/src/database.ts
new file mode 100644
index 0000000..674505a
--- /dev/null
+++ b/src/database.ts
@@ -0,0 +1,162 @@
+import Database from 'better-sqlite3';
+import { randomUUID } from 'crypto';
+
+export interface Document {
+  id: string;
+  title: string;
+  content: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface Version {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operation: string | null;
+  created_at: string;
+}
+
+export class DocumentDatabase {
+  private db: Database.Database;
+
+  constructor(dbPath: string = ':memory:') {
+    this.db = new Database(dbPath);
+    this.db.pragma('journal_mode = WAL');
+    this.db.pragma('foreign_keys = ON');
+    this.init();
+  }
+
+  private init(): void {
+    this.db.exec(`
+      CREATE TABLE IF NOT EXISTS documents (
+        id TEXT PRIMARY KEY,
+        title TEXT NOT NULL,
+        content TEXT NOT NULL DEFAULT '',
+        created_at TEXT NOT NULL DEFAULT (datetime('now')),
+        updated_at TEXT NOT NULL DEFAULT (datetime('now'))
+      );
+
+      CREATE TABLE IF NOT EXISTS versions (
+        id INTEGER PRIMARY KEY AUTOINCREMENT,
+        document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
+        version INTEGER NOT NULL,
+        content TEXT NOT NULL,
+        operation TEXT,
+        created_at TEXT NOT NULL DEFAULT (datetime('now')),
+        UNIQUE(document_id, version)
+      );
+
+      CREATE TABLE IF NOT EXISTS active_connections (
+        id TEXT PRIMARY KEY,
+        document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
+        connected_at TEXT NOT NULL DEFAULT (datetime('now'))
+      );
+    `);
+  }
+
+  createDocument(title: string, content: string = ''): Document {
+    const id = randomUUID();
+    const stmt = this.db.prepare(
+      `INSERT INTO documents (id, title, content) VALUES (?, ?, ?)`
+    );
+    stmt.run(id, title, content);
+
+    // Create initial version
+    this.db.prepare(
+      `INSERT INTO versions (document_id, version, content, operation)
+       VALUES (?, 1, ?, ?)`
+    ).run(id, content, JSON.stringify({ type: 'init', content }));
+
+    return this.getDocument(id)!;
+  }
+
+  getDocument(id: string): Document | undefined {
+    const stmt = this.db.prepare(`SELECT * FROM documents WHERE id = ?`);
+    return stmt.get(id) as Document | undefined;
+  }
+
+  listDocuments(): Document[] {
+    const stmt = this.db.prepare(`SELECT * FROM documents ORDER BY updated_at DESC`);
+    return stmt.all() as Document[];
+  }
+
+  updateDocument(id: string, updates: { title?: string; content?: string }): Document | undefined {
+    const doc = this.getDocument(id);
+    if (!doc) return undefined;
+
+    const title = updates.title ?? doc.title;
+    const content = updates.content ?? doc.content;
+
+    this.db.prepare(
+      `UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?`
+    ).run(title, content, id);
+
+    return this.getDocument(id);
+  }
+
+  deleteDocument(id: string): boolean {
+    const result = this.db.prepare(`DELETE FROM documents WHERE id = ?`).run(id);
+    return result.changes > 0;
+  }
+
+  applyOperation(documentId: string, content: string, operation: object): Version {
+    const currentVersion = this.getLatestVersion(documentId);
+    const nextVersion = currentVersion ? currentVersion.version + 1 : 1;
+
+    this.db.prepare(
+      `INSERT INTO versions (document_id, version, content, operation)
+       VALUES (?, ?, ?, ?)`
+    ).run(documentId, nextVersion, content, JSON.stringify(operation));
+
+    this.db.prepare(
+      `UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?`
+    ).run(content, documentId);
+
+    return {
+      id: 0,
+      document_id: documentId,
+      version: nextVersion,
+      content,
+      operation: JSON.stringify(operation),
+      created_at: new Date().toISOString(),
+    };
+  }
+
+  getVersions(documentId: string): Version[] {
+    return this.db.prepare(
+      `SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC`
+    ).all(documentId) as Version[];
+  }
+
+  getLatestVersion(documentId: string): Version | undefined {
+    return this.db.prepare(
+      `SELECT * FROM versions WHERE document_id = ? ORDER BY version DESC LIMIT 1`
+    ).get(documentId) as Version | undefined;
+  }
+
+  getDocumentVersion(documentId: string): number {
+    const latest = this.getLatestVersion(documentId);
+    return latest ? latest.version : 0;
+  }
+
+  private closed = false;
+
+  addConnection(connectionId: string, documentId: string): void {
+    if (this.closed) return;
+    this.db.prepare(
+      `INSERT OR REPLACE INTO active_connections (id, document_id) VALUES (?, ?)`
+    ).run(connectionId, documentId);
+  }
+
+  removeConnection(connectionId: string): void {
+    if (this.closed) return;
+    this.db.prepare(`DELETE FROM active_connections WHERE id = ?`).run(connectionId);
+  }
+
+  close(): void {
+    this.closed = true;
+    this.db.close();
+  }
+}
diff --git a/src/ot.test.ts b/src/ot.test.ts
new file mode 100644
index 0000000..f090c27
--- /dev/null
+++ b/src/ot.test.ts
@@ -0,0 +1,218 @@
+import { describe, it, expect } from 'vitest';
+import { applyOp, transformOp, validateOp, Operation } from './ot.js';
+
+describe('OT Engine', () => {
+  describe('applyOp', () => {
+    it('applies insert at beginning', () => {
+      expect(applyOp('hello', { type: 'insert', position: 0, text: 'say ' })).toBe('say hello');
+    });
+
+    it('applies insert at end', () => {
+      expect(applyOp('hello', { type: 'insert', position: 5, text: ' world' })).toBe('hello world');
+    });
+
+    it('applies insert in middle', () => {
+      expect(applyOp('hllo', { type: 'insert', position: 1, text: 'e' })).toBe('hello');
+    });
+
+    it('applies delete at beginning', () => {
+      expect(applyOp('hello', { type: 'delete', position: 0, count: 1 })).toBe('ello');
+    });
+
+    it('applies delete at end', () => {
+      expect(applyOp('hello', { type: 'delete', position: 4, count: 1 })).toBe('hell');
+    });
+
+    it('applies delete in middle', () => {
+      expect(applyOp('hello', { type: 'delete', position: 1, count: 3 })).toBe('ho');
+    });
+
+    it('handles empty string insert', () => {
+      expect(applyOp('', { type: 'insert', position: 0, text: 'x' })).toBe('x');
+    });
+
+    it('clamps position for insert beyond length', () => {
+      expect(applyOp('ab', { type: 'insert', position: 100, text: 'c' })).toBe('abc');
+    });
+
+    it('handles delete with count 0', () => {
+      expect(applyOp('hello', { type: 'delete', position: 0, count: 0 })).toBe('hello');
+    });
+  });
+
+  describe('transformOp - insert/insert', () => {
+    it('transforms two inserts at different positions', () => {
+      const a: Operation = { type: 'insert', position: 0, text: 'A' };
+      const b: Operation = { type: 'insert', position: 5, text: 'B' };
+      const aPrime = transformOp(a, b);
+      expect(aPrime).toEqual({ type: 'insert', position: 0, text: 'A' });
+    });
+
+    it('transforms insert after another insert', () => {
+      const a: Operation = { type: 'insert', position: 5, text: 'A' };
+      const b: Operation = { type: 'insert', position: 2, text: 'BB' };
+      const aPrime = transformOp(a, b);
+      expect(aPrime).toEqual({ type: 'insert', position: 7, text: 'A' });
+    });
+
+    it('transforms two inserts at same position', () => {
+      const a: Operation = { type: 'insert', position: 3, text: 'A' };
+      const b: Operation = { type: 'insert', position: 3, text: 'B' };
+      // a.position <= b.position so a stays at 3
+      const aPrime = transformOp(a, b);
+      expect(aPrime.type).toBe('insert');
+      expect((aPrime as { position: number }).position).toBe(3);
+    });
+
+    it('converges: both inserts preserved', () => {
+      const doc = 'hello';
+      const a: Operation = { type: 'insert', position: 0, text: 'A' };
+      const b: Operation = { type: 'insert', position: 5, text: 'B' };
+
+      const aPrime = transformOp(a, b);
+      const bPrime = transformOp(b, a);
+
+      // Apply b then a' should equal apply a then b'
+      const result1 = applyOp(applyOp(doc, b), aPrime);
+      const result2 = applyOp(applyOp(doc, a), bPrime);
+      expect(result1).toBe(result2);
+      expect(result1).toContain('A');
+      expect(result1).toContain('B');
+    });
+  });
+
+  describe('transformOp - insert/delete', () => {
+    it('insert before delete', () => {
+      const a: Operation = { type: 'insert', position: 0, text: 'X' };
+      const b: Operation = { type: 'delete', position: 3, count: 2 };
+      const aPrime = transformOp(a, b);
+      expect(aPrime).toEqual({ type: 'insert', position: 0, text: 'X' });
+    });
+
+    it('insert after delete range', () => {
+      const a: Operation = { type: 'insert', position: 5, text: 'X' };
+      const b: Operation = { type: 'delete', position: 0, count: 2 };
+      const aPrime = transformOp(a, b);
+      expect(aPrime).toEqual({ type: 'insert', position: 3, text: 'X' });
+    });
+
+    it('insert within deleted range', () => {
+      const a: Operation = { type: 'insert', position: 2, text: 'X' };
+      const b: Operation = { type: 'delete', position: 1, count: 3 };
+      const aPrime = transformOp(a, b);
+      // Insert falls within deleted range — placed at delete position
+      expect(aPrime.type).toBe('insert');
+      expect((aPrime as { position: number }).position).toBe(1);
+    });
+  });
+
+  describe('transformOp - delete/insert', () => {
+    it('delete before insert', () => {
+      const a: Operation = { type: 'delete', position: 0, count: 2 };
+      const b: Operation = { type: 'insert', position: 5, text: 'X' };
+      const aPrime = transformOp(a, b);
+      expect(aPrime).toEqual({ type: 'delete', position: 0, count: 2 });
+    });
+
+    it('delete after insert', () => {
+      const a: Operation = { type: 'delete', position: 5, count: 2 };
+      const b: Operation = { type: 'insert', position: 0, text: 'XX' };
+      const aPrime = transformOp(a, b);
+      expect(aPrime).toEqual({ type: 'delete', position: 7, count: 2 });
+    });
+  });
+
+  describe('transformOp - delete/delete', () => {
+    it('non-overlapping deletes', () => {
+      const a: Operation = { type: 'delete', position: 0, count: 2 };
+      const b: Operation = { type: 'delete', position: 5, count: 2 };
+      const aPrime = transformOp(a, b);
+      expect(aPrime).toEqual({ type: 'delete', position: 0, count: 2 });
+    });
+
+    it('fully overlapping deletes (a inside b)', () => {
+      const a: Operation = { type: 'delete', position: 2, count: 1 };
+      const b: Operation = { type: 'delete', position: 1, count: 3 };
+      const aPrime = transformOp(a, b);
+      expect(aPrime).toEqual({ type: 'delete', position: 1, count: 0 });
+    });
+
+    it('delete after another delete shifts position', () => {
+      const a: Operation = { type: 'delete', position: 5, count: 2 };
+      const b: Operation = { type: 'delete', position: 0, count: 3 };
+      const aPrime = transformOp(a, b);
+      expect(aPrime).toEqual({ type: 'delete', position: 2, count: 2 });
+    });
+  });
+
+  describe('convergence property', () => {
+    it('insert + insert converges', () => {
+      const doc = 'abcdef';
+      const a: Operation = { type: 'insert', position: 2, text: 'X' };
+      const b: Operation = { type: 'insert', position: 4, text: 'Y' };
+
+      const aPrime = transformOp(a, b);
+      const bPrime = transformOp(b, a);
+
+      const result1 = applyOp(applyOp(doc, b), aPrime);
+      const result2 = applyOp(applyOp(doc, a), bPrime);
+      expect(result1).toBe(result2);
+    });
+
+    it('insert + delete converges', () => {
+      const doc = 'abcdef';
+      const a: Operation = { type: 'insert', position: 2, text: 'X' };
+      const b: Operation = { type: 'delete', position: 0, count: 3 };
+
+      const aPrime = transformOp(a, b);
+      const bPrime = transformOp(b, a);
+
+      const result1 = applyOp(applyOp(doc, b), aPrime);
+      const result2 = applyOp(applyOp(doc, a), bPrime);
+      expect(result1).toBe(result2);
+    });
+
+    it('delete + delete converges', () => {
+      const doc = 'abcdefgh';
+      const a: Operation = { type: 'delete', position: 1, count: 3 };
+      const b: Operation = { type: 'delete', position: 3, count: 3 };
+
+      const aPrime = transformOp(a, b);
+      const bPrime = transformOp(b, a);
+
+      const result1 = applyOp(applyOp(doc, b), aPrime);
+      const result2 = applyOp(applyOp(doc, a), bPrime);
+      expect(result1).toBe(result2);
+    });
+  });
+
+  describe('validateOp', () => {
+    it('accepts valid insert', () => {
+      expect(validateOp({ type: 'insert', position: 0, text: 'x' }, 5)).toBeNull();
+    });
+
+    it('rejects insert beyond document', () => {
+      expect(validateOp({ type: 'insert', position: 10, text: 'x' }, 5)).not.toBeNull();
+    });
+
+    it('rejects empty insert text', () => {
+      expect(validateOp({ type: 'insert', position: 0, text: '' }, 5)).not.toBeNull();
+    });
+
+    it('accepts valid delete', () => {
+      expect(validateOp({ type: 'delete', position: 0, count: 3 }, 5)).toBeNull();
+    });
+
+    it('rejects delete beyond document', () => {
+      expect(validateOp({ type: 'delete', position: 3, count: 5 }, 5)).not.toBeNull();
+    });
+
+    it('rejects delete with count 0', () => {
+      expect(validateOp({ type: 'delete', position: 0, count: 0 }, 5)).not.toBeNull();
+    });
+
+    it('rejects unknown type', () => {
+      expect(validateOp({ type: 'replace' } as unknown as Operation, 5)).not.toBeNull();
+    });
+  });
+});
