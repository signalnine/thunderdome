  return transformInsertDelete(a, b);\n  } else if (a.type === 'delete' && b.type === 'insert') {\n    return transformDeleteInsert(a as DeleteOp, b as InsertOp);\n  } else {\n    return transformDeleteDelete(a as DeleteOp, b as DeleteOp);\n  }\n}\n\nfunction transformInsertInsert(a: InsertOp, b: InsertOp): InsertOp {\n  if (a.position <= b.position) {\n    return { ...a };\n  }\n  return { ...a, position: a.position + b.text.length };\n}\n\nfunction transformInsertDelete(a: InsertOp, b: DeleteOp): InsertOp {\n  if (a.position <= b.position) {\n    return { ...a };\n  }\n  if (a.position >= b.position + b.count) {\n    return { ...a, position: a.position - b.count };\n  }\n  // Insert falls within the deleted range — place at delete position\n  return { ...a, position: b.position };\n}\n\nfunction transformDeleteInsert(a: DeleteOp, b: InsertOp): DeleteOp {\n  if (b.position >= a.position + a.count) {\n    // Insert is after the delete range — no effect on delete\n    return { ...a };\n  }\n  if (b.position <= a.position) {\n    // Insert is at or before delete start — shift delete right\n    return { ...a, position: a.position + b.text.length };\n  }\n  // Insert falls strictly within the delete range.\n  // The delete still removes its original characters but the inserted text\n  // now sits in the middle of the range. Expand count so the delete covers\n  // the full original span (which now includes the inserted text).\n  return { ...a, count: a.count + b.text.length };\n}\n\nfunction transformDeleteDelete(a: DeleteOp, b: DeleteOp): DeleteOp {\n  // If A's range is entirely before B's range\n  if (a.position + a.count <= b.position) {\n    return { ...a };\n  }\n  // If A's range is entirely after B's range\n  if (a.position >= b.position + b.count) {\n    return { ...a, position: a.position - b.count };\n  }\n  // Overlapping ranges\n  const aEnd = a.position + a.count;\n  const bEnd = b.position + b.count;\n\n  if (a.position >= b.position && aEnd <= bEnd) {\n    // A is entirely within B — nothing left to delete\n    return { type: 'delete', position: b.position, count: 0 };\n  }\n  if (a.position <= b.position && aEnd >= bEnd) {\n    // B is entirely within A — reduce A's count by B's count\n    return { ...a, count: a.count - b.count };\n  }\n  if (a.position < b.position) {\n    // A starts before B, overlaps partially\n    const overlap = aEnd - b.position;\n    return { ...a, count: a.count - overlap };\n  }\n  // A starts within B, extends past B\n  const overlap = bEnd - a.position;\n  return { type: 'delete', position: b.position, count: a.count - overlap };\n}\n\n/**\n * Apply an operation to a document string.\n */\nexport function applyOp(content: string, op: Operation): string {\n  if (op.type === 'insert') {\n    const pos = Math.min(Math.max(0, op.position), content.length);\n    return content.slice(0, pos) + op.text + content.slice(pos);\n  } else {\n    if (op.count <= 0) return content;\n    const pos = Math.min(Math.max(0, op.position), content.length);\n    const end = Math.min(pos + op.count, content.length);\n    return content.slice(0, pos) + content.slice(end);\n  }\n}\n\n/**\n * Validate that an operation is well-formed and applicable to a document of the given length.\n */\nexport function validateOp(op: Operation, docLength: number): string | null {\n  if (!op || typeof op !== 'object') {\n    return 'Operation must be an object';\n  }\n  if (op.type === 'insert') {\n    if (typeof op.position !== 'number' || op.position < 0) {\n      return 'Insert position must be a non-negative number';\n    }\n    if (op.position > docLength) {\n      return `Insert position ${op.position} is beyond document length ${docLength}`;\n    }\n    if (typeof op.text !== 'string' || op.text.length === 0) {\n      return 'Insert text must be a non-empty string';\n    }\n  } else if (op.type === 'delete') {\n    if (typeof op.position !== 'number' || op.position < 0) {\n      return 'Delete position must be a non-negative number';\n    }\n    if (typeof op.count !== 'number' || op.count < 1) {\n      return 'Delete count must be a positive number';\n    }\n    if (op.position + op.count > docLength) {\n      return `Delete range [${op.position}, ${op.position + op.count}) exceeds document length ${docLength}`;\n    }\n  } else {\n    return `Unknown operation type: ${(op as { type: string }).type}`;\n  }\n  return null;\n}\n","numLines":157,"startLine":1,"totalLines":157}}}
