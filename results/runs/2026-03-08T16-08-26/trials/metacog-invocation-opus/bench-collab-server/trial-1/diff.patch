as { content: string }).content;\n\n    // All digits should be present\n    for (let i = 0; i < 10; i++) {\n      expect(content).toContain(String(i));\n    }\n    expect(content.length).toBe(10);\n\n    // Cleanup\n    for (const client of clients) {\n      client.ws.close();\n    }\n  });","newString":"  it('handles 10 concurrent clients', async () => {\n    const { body: created } = await fetchJson('/api/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Concurrent Test', content: '' }),\n    });\n    const docId = (created as { id: string }).id;\n\n    // Connect 10 clients\n    const clients: { ws: WebSocket; messages: unknown[] }[] = [];\n    for (let i = 0; i < 10; i++) {\n      const client = await connectWs(docId);\n      clients.push(client);\n    }\n\n    // Each client inserts its number sequentially, using the ack version\n    let currentVersion = (clients[0].messages[0] as { document: { version: number } }).document.version;\n\n    for (let i = 0; i < 10; i++) {\n      const ackPromise = waitForMessage(clients[i].ws);\n\n      clients[i].ws.send(JSON.stringify({\n        type: 'operation',\n        op: { type: 'insert', position: i, text: String(i) },\n        version: currentVersion,\n      }));\n\n      const ack = await ackPromise as { type: string; version: number };\n      expect(ack.type).toBe('ack');\n      currentVersion = ack.version;\n\n      // Small delay to let broadcasts settle\n      await new Promise(r => setTimeout(r, 20));\n    }\n\n    // Wait for all messages to settle\n    await new Promise(r => setTimeout(r, 200));\n\n    // Verify final document\n    const { body: finalDoc } = await fetchJson(`/api/documents/${docId}`);\n    const content = (finalDoc as { content: string }).content;\n\n    // All digits should be present\n    for (let i = 0; i < 10; i++) {\n      expect(content).toContain(String(i));\n    }\n    expect(content.length).toBe(10);\n\n    // Cleanup\n    for (const client of clients) {\n      client.ws.close();\n    }\n  });","originalFile":"import { describe, it, expect, beforeEach, afterEach } from 'vitest';\nimport { createApp, AppInstance } from './server.js';\nimport WebSocket from 'ws';\n\nlet app: AppInstance;\nlet port: number;\nlet baseUrl: string;\n\nbeforeEach(async () => {\n  app = createApp();\n  port = await app.start(0);\n  baseUrl = `http://localhost:${port}`;\n});\n\nafterEach(async () => {\n  await app.stop();\n});\n\nfunction wsUrl(docId: string): string {\n  return `ws://localhost:${port}/documents/${docId}/ws`;\n}\n\nfunction connectWs(docId: string): Promise<{ ws: WebSocket; messages: unknown[] }> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(wsUrl(docId));\n    const messages: unknown[] = [];\n\n    ws.on('message', (data) => {\n      const msg = JSON.parse(data.toString());\n      messages.push(msg);\n      // Resolve once we get the sync message\n      if (msg.type === 'sync') {\n        resolve({ ws, messages });\n      }\n    });\n\n    ws.on('error', reject);\n    setTimeout(() => reject(new Error('Timeout connecting WebSocket')), 5000);\n  });\n}\n\nfunction waitForMessage(ws: WebSocket, timeout = 2000): Promise<unknown> {\n  return new Promise((resolve, reject) => {\n    const timer = setTimeout(() => reject(new Error('Timeout waiting for message')), timeout);\n    ws.once('message', (data) => {\n      clearTimeout(timer);\n      resolve(JSON.parse(data.toString()));\n    });\n  });\n}\n\nasync function fetchJson(path: string, options: RequestInit = {}): Promise<{ status: number; body: unknown }> {\n  const res = await fetch(`${baseUrl}${path}`, {\n    headers: { 'Content-Type': 'application/json', ...options.headers as Record<string, string> },\n    ...options,\n  });\n  const body = res.headers.get('content-type')?.includes('json') ? await res.json() : null;\n  return { status: res.status, body };\n}\n\ndescribe('REST API', () => {\n  it('creates a document', async () => {\n    const { status, body } = await fetchJson('/api/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Test Doc', content: 'Hello' }),\n    });\n    expect(status).toBe(201);\n    const doc = body as { id: string; title: string; content: string };\n    expect(doc.title).toBe('Test Doc');\n    expect(doc.content).toBe('Hello');\n    expect(doc.id).toBeDefined();\n  });\n\n  it('lists documents', async () => {\n    await fetchJson('/api/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Doc 1' }),\n    });\n    await fetchJson('/api/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Doc 2' }),\n    });\n\n    const { status, body } = await fetchJson('/api/documents');\n    expect(status).toBe(200);\n    expect(Array.isArray(body)).toBe(true);\n    expect((body as unknown[]).length).toBe(2);\n  });\n\n  it('gets a single document', async () => {\n    const { body: created } = await fetchJson('/api/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Test', content: 'content' }),\n    });\n    const id = (created as { id: string }).id;\n\n    const { status, body } = await fetchJson(`/api/documents/${id}`);\n    expect(status).toBe(200);\n    expect((body as { title: string }).title).toBe('Test');\n  });\n\n  it('returns 404 for non-existent document', async () => {\n    const { status } = await fetchJson('/api/documents/nonexistent');\n    expect(status).toBe(404);\n  });\n\n  it('updates a document', async () => {\n    const { body: created } = await fetchJson('/api/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Original', content: 'old' }),\n    });\n    const id = (created as { id: string }).id;\n\n    const { status, body } = await fetchJson(`/api/documents/${id}`, {\n      method: 'PUT',\n      body: JSON.stringify({ title: 'Updated', content: 'new' }),\n    });\n    expect(status).toBe(200);\n    expect((body as { title: string }).title).toBe('Updated');\n    expect((body as { content: string }).content).toBe('new');\n  });\n\n  it('deletes a document', async () => {\n    const { body: created } = await fetchJson('/api/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'ToDelete' }),\n    });\n    const id = (created as { id: string }).id;\n\n    const { status: deleteStatus } = await fetchJson(`/api/documents/${id}`, { method: 'DELETE' });\n    expect(deleteStatus).toBe(204);\n\n    const { status: getStatus } = await fetchJson(`/api/documents/${id}`);\n    expect(getStatus).toBe(404);\n  });\n\n  it('gets version history', async () => {\n    const { body: created } = await fetchJson('/api/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Versioned', content: 'v1' }),\n    });\n    const id = (created as { id: string }).id;\n\n    const { status, body } = await fetchJson(`/api/documents/${id}/versions`);\n    expect(status).toBe(200);\n    expect(Array.isArray(body)).toBe(true);\n    expect((body as unknown[]).length).toBeGreaterThanOrEqual(1);\n  });\n\n  it('rejects document creation without title', async () => {\n    const { status } = await fetchJson('/api/documents', {\n      method: 'POST',\n      body: JSON.stringify({ content: 'no title' }),\n    });\n    expect(status).toBe(400);\n  });\n});\n\ndescribe('WebSocket collaboration', () => {\n  it('connects and receives sync message', async () => {\n    const { body: created } = await fetchJson('/api/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'WS Test', content: 'hello' }),\n    });\n    const docId = (created as { id: string }).id;\n\n    const { ws, messages } = await connectWs(docId);\n\n    expect(messages.length).toBeGreaterThanOrEqual(1);\n    const sync = messages[0] as { type: string; document: { content: string }; clientId: string };\n    expect(sync.type).toBe('sync');\n    expect(sync.document.content).toBe('hello');\n    expect(sync.clientId).toBeDefined();\n\n    ws.close();\n  });\n\n  it('applies an operation and receives ack', async () => {\n    const { body: created } = await fetchJson('/api/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Op Test', content: 'hello' }),\n    });\n    const docId = (created as { id: string }).id;\n\n    const { ws, messages } = await connectWs(docId);\n    const sync = messages[0] as { type: string; document: { version: number } };\n\n    const ackPromise = waitForMessage(ws);\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      op: { type: 'insert', position: 5, text: ' world' },\n      version: sync.document.version,\n    }));\n\n    const ack = await ackPromise as { type: string; version: number };\n    expect(ack.type).toBe('ack');\n\n    // Verify via REST\n    const { body: doc } = await fetchJson(`/api/documents/${docId}`);\n    expect((doc as { content: string }).content).toBe('hello world');\n\n    ws.close();\n  });\n\n  it('broadcasts operations to other clients', async () => {\n    const { body: created } = await fetchJson('/api/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Broadcast Test', content: 'abc' }),\n    });\n    const docId = (created as { id: string }).id;\n\n    const client1 = await connectWs(docId);\n    const client2 = await connectWs(docId);\n\n    const sync1 = client1.messages[0] as { type: string; document: { version: number } };\n\n    const broadcastPromise = waitForMessage(client2.ws);\n\n    client1.ws.send(JSON.stringify({\n      type: 'operation',\n      op: { type: 'insert', position: 3, text: 'X' },\n      version: sync1.document.version,\n    }));\n\n    const broadcast = await broadcastPromise as { type: string; op: { type: string } };\n    expect(broadcast.type).toBe('operation');\n    expect(broadcast.op.type).toBe('insert');\n\n    client1.ws.close();\n    client2.ws.close();\n  });\n\n  it('handles concurrent inserts with convergence', async () => {\n    const { body: created } = await fetchJson('/api/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Converge Test', content: 'abcdef' }),\n    });\n    const docId = (created as { id: string }).id;\n\n    const client1 = await connectWs(docId);\n    const client2 = await connectWs(docId);\n\n    const sync1 = client1.messages[0] as { type: string; document: { version: number } };\n    const sync2 = client2.messages[0] as { type: string; document: { version: number } };\n\n    // Both based on same version\n    const version = sync1.document.version;\n    expect(sync2.document.version).toBe(version);\n\n    // Client 1 inserts at position 2\n    const ack1Promise = waitForMessage(client1.ws);\n    client1.ws.send(JSON.stringify({\n      type: 'operation',\n      op: { type: 'insert', position: 2, text: 'X' },\n      version,\n    }));\n    await ack1Promise;\n\n    // Client 2 inserts at position 4 (based on original version)\n    const ack2Promise = waitForMessage(client2.ws);\n    // Wait a bit for broadcast to arrive at client2 first\n    await new Promise(r => setTimeout(r, 50));\n    // Drain broadcast message from client2\n    client2.ws.once('message', () => { /* drain */ });\n\n    client2.ws.send(JSON.stringify({\n      type: 'operation',\n      op: { type: 'insert', position: 4, text: 'Y' },\n      version, // same base version as client1\n    }));\n    await ack2Promise;\n\n    // Wait for all broadcasts to settle\n    await new Promise(r => setTimeout(r, 200));\n\n    // Check final document state via REST\n    const { body: doc } = await fetchJson(`/api/documents/${docId}`);\n    const content = (doc as { content: string }).content;\n    // Both X and Y should be present\n    expect(content).toContain('X');\n    expect(content).toContain('Y');\n    expect(content.length).toBe(8); // original 6 + X + Y\n\n    client1.ws.close();\n    client2.ws.close();\n  });\n\n  it('handles 10 concurrent clients', async () => {\n    const { body: created } = await fetchJson('/api/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Concurrent Test', content: '' }),\n    });\n    const docId = (created as { id: string }).id;\n\n    // Connect 10 clients\n    const clients: { ws: WebSocket; messages: unknown[] }[] = [];\n    for (let i = 0; i < 10; i++) {\n      const client = await connectWs(docId);\n      clients.push(client);\n    }\n\n    // Each client inserts its number sequentially\n    for (let i = 0; i < 10; i++) {\n      const ackPromise = waitForMessage(clients[i].ws);\n      const currentDoc = await fetchJson(`/api/documents/${docId}`);\n      const currentVersion = ((currentDoc.body as { content: string }).content.length === 0) ? 1 :\n        (await fetchJson(`/api/documents/${docId}/versions`)).body as unknown[];\n\n      // Get the current version from sync or latest\n      const sync = clients[i].messages[0] as { document: { version: number } };\n      const ver = sync.document.version + i; // each previous client added 1 version\n\n      clients[i].ws.send(JSON.stringify({\n        type: 'operation',\n        op: { type: 'insert', position: i, text: String(i) },\n        version: ver,\n      }));\n\n      await ackPromise;\n      await new Promise(r => setTimeout(r, 50));\n    }\n\n    // Wait for all messages to settle\n    await new Promise(r => setTimeout(r, 500));\n\n    // Verify final document\n    const { body: finalDoc } = await fetchJson(`/api/documents/${docId}`);\n    const content = (finalDoc as { content: string }).content;\n\n    // All digits should be present\n    for (let i = 0; i < 10; i++) {\n      expect(content).toContain(String(i));\n    }\n    expect(content.length).toBe(10);\n\n    // Cleanup\n    for (const client of clients) {\n      client.ws.close();\n    }\n  });\n\n  it('rejects operations on non-existent document websocket', async () => {\n    // Try connecting to a non-existent document\n    const ws = new WebSocket(wsUrl('nonexistent'));\n\n    await new Promise<void>((resolve) => {\n      ws.on('error', () => resolve());\n      ws.on('close', () => resolve());\n      setTimeout(() => {\n        ws.close();\n        resolve();\n      }, 500);\n    });\n  });\n\n  it('handles malformed messages gracefully', async () => {\n    const { body: created } = await fetchJson('/api/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Error Test', content: 'test' }),\n    });\n    const docId = (created as { id: string }).id;\n\n    const { ws } = await connectWs(docId);\n\n    const errorPromise = waitForMessage(ws);\n    ws.send('not json{{{');\n    const errorMsg = await errorPromise as { type: string };\n    expect(errorMsg.type).toBe('error');\n\n    ws.close();\n  });\n\n  it('handles invalid operation gracefully', async () => {\n    const { body: created } = await fetchJson('/api/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Invalid Op Test', content: 'test' }),\n    });\n    const docId = (created as { id: string }).id;\n\n    const { ws, messages } = await connectWs(docId);\n    const sync = messages[0] as { document: { version: number } };\n\n    const errorPromise = waitForMessage(ws);\n    ws.send(JSON.stringify({\n      type: 'operation',\n      op: { type: 'insert', position: 100, text: 'x' },\n      version: sync.document.version,\n    }));\n    const errorMsg = await errorPromise as { type: string; message: string };\n    expect(errorMsg.type).toBe('error');\n\n    ws.close();\n  });\n});\n\ndescribe('Persistence', () => {\n  it('data survives server restart', async () => {\n    const tmpDb = '/tmp/test-collab-persist.db';\n\n    // Clean up any previous test db\n    try {\n      const { unlinkSync } = await import('fs');\n      unlinkSync(tmpDb);\n    } catch {\n      // ignore\n    }\n\n    // Create app with file-based DB\n    const app1 = createApp(tmpDb);\n    const port1 = await app1.start(0);\n    const url1 = `http://localhost:${port1}`;\n\n    // Create a document\n    const res = await fetch(`${url1}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Persist Test', content: 'persisted data' }),\n    });\n    const doc = await res.json() as { id: string };\n\n    await app1.stop();\n\n    // Restart with same DB\n    const app2 = createApp(tmpDb);\n    const port2 = await app2.start(0);\n    const url2 = `http://localhost:${port2}`;\n\n    // Check document still exists\n    const res2 = await fetch(`${url2}/api/documents/${doc.id}`);\n    const doc2 = await res2.json() as { title: string; content: string };\n    expect(doc2.title).toBe('Persist Test');\n    expect(doc2.content).toBe('persisted data');\n\n    await app2.stop();\n\n    // Cleanup\n    try {\n      const { unlinkSync } = await import('fs');\n      unlinkSync(tmpDb);\n    } catch {\n      // ignore\n    }\n  });\n});\n","structuredPatch":[{"oldStart":300,"oldLines":29,"newStart":300,"newLines":28,"lines":["       clients.push(client);","     }"," ","-    // Each client inserts its number sequentially","+    // Each client inserts its number sequentially, using the ack version","+    let currentVersion = (clients[0].messages[0] as { document: { version: number } }).document.version;","+","     for (let i = 0; i < 10; i++) {","       const ackPromise = waitForMessage(clients[i].ws);","-      const currentDoc = await fetchJson(`/api/documents/${docId}`);","-      const currentVersion = ((currentDoc.body as { content: string }).content.length === 0) ? 1 :","-        (await fetchJson(`/api/documents/${docId}/versions`)).body as unknown[];"," ","-      // Get the current version from sync or latest","-      const sync = clients[i].messages[0] as { document: { version: number } };","-      const ver = sync.document.version + i; // each previous client added 1 version","-","       clients[i].ws.send(JSON.stringify({","         type: 'operation',","         op: { type: 'insert', position: i, t