boolean {\n  const nowMinute = now.getMinutes();\n  const nowHour = now.getHours();\n\n  // Check if current time matches the cron pattern\n  let minuteMatches: boolean;\n  if (typeof fields.minute === 'object') {\n    // */N pattern: matches when minute is divisible by N\n    minuteMatches = nowMinute % fields.minute.every === 0;\n  } else {\n    minuteMatches = nowMinute === fields.minute;\n  }\n\n  let hourMatches: boolean;\n  if (fields.hour === '*') {\n    hourMatches = true;\n  } else {\n    hourMatches = nowHour === fields.hour;\n  }\n\n  if (!minuteMatches || !hourMatches) {\n    return false;\n  }\n\n  // If we haven't run before, go ahead\n  if (!lastRun) {\n    return true;\n  }\n\n  // Only trigger once per matching minute\n  // Check that we haven't already run in this same minute\n  const lastRunMinute = lastRun.getMinutes();\n  const lastRunHour = lastRun.getHours();\n  const lastRunDate = lastRun.toDateString();\n  const nowDate = now.toDateString();\n\n  if (nowDate === lastRunDate && nowHour === lastRunHour && nowMinute === lastRunMinute) {\n    return false;\n  }\n\n  return true;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":465,"cache_read_input_tokens":26804,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":465},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"81daa120-13b5-40c9-a720-4f525349a025","uuid":"8c359908-ee97-4e26-9049-dee3c6b2c82d"}
