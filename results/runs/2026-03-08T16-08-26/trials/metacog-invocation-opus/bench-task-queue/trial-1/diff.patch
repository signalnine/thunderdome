--- /dev/null
+++ b/src/task.ts
@@ -0,0 +1,36 @@
+import { randomUUID } from 'node:crypto';
+import type { Task, TaskOptions } from './types.js';
+
+export function createTask<T = unknown>(payload: T, options: TaskOptions = {}): Task<T> {
+  const now = new Date();
+  const priority = options.priority ?? 5;
+
+  if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {
+    throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);
+  }
+
+  let availableAt = now;
+  if (options.processAt) {
+    availableAt = options.processAt;
+  } else if (options.delay != null && options.delay > 0) {
+    availableAt = new Date(now.getTime() + options.delay);
+  }
+
+  const hasDependencies = options.dependencies != null && options.dependencies.length > 0;
+
+  return {
+    id: randomUUID(),
+    payload,
+    status: hasDependencies ? 'blocked' : 'pending',
+    queue: options.queue ?? 'default',
+    priority,
+    createdAt: now,
+    availableAt,
+    attempts: 0,
+    maxRetries: options.maxRetries ?? 3,
+    backoffDelay: options.backoffDelay ?? 1000,
+    failCount: 0,
+    dependencies: options.dependencies ? [...options.dependencies] : [],
+    progress: 0,
+  };
+}
diff --git a/src/types.ts b/src/types.ts
new file mode 100644
index 0000000..73648de
--- /dev/null
+++ b/src/types.ts
@@ -0,0 +1,60 @@
+// Core types for the task queue system
+
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled' | 'blocked';
+
+export interface TaskOptions {
+  queue?: string;
+  priority?: number;
+  delay?: number;
+  processAt?: Date;
+  maxRetries?: number;
+  backoffDelay?: number;
+  dependencies?: string[];
+}
+
+export interface Task<T = unknown> {
+  id: string;
+  payload: T;
+  status: TaskStatus;
+  queue: string;
+  priority: number;
+  createdAt: Date;
+  availableAt: Date;
+  attempts: number;
+  maxRetries: number;
+  backoffDelay: number;
+  error?: Error | string;
+  failCount: number;
+  dependencies: string[];
+  progress: number;
+  progressMessage?: string;
+  cancelledAt?: Date;
+}
+
+export type ProgressListener = (progress: number, message?: string) => void;
+
+export type Middleware<T = unknown> = (
+  task: Task<T>,
+  next: () => Promise<void>
+) => Promise<void> | void;
+
+export type TaskHandler<T = unknown> = (task: Task<T>) => Promise<void> | void;
+
+export interface ScheduleEntry {
+  id: string;
+  cronExpression: string;
+  queue: string;
+  payload: unknown;
+  taskOptions?: Omit<TaskOptions, 'queue'>;
+  lastRun?: Date;
+}
+
+export interface ShutdownOptions {
+  timeout?: number;
+}
+
+export interface ShutdownSummary {
+  completed: number;
+  forceCancelled: number;
+  durationMs: number;
+}
