@@ -0,0 +1,97 @@
+/**
+ * Simple cron expression parser supporting a subset:
+ * - `STAR/N * * * *` -- every N minutes
+ * - `0 * * * *`   -- every hour on the hour
+ * - `0 0 * * *`   -- every day at midnight
+ */
+
+export interface CronFields {
+  minute: number | { every: number };
+  hour: number | '*';
+  // day, month, weekday are always '*' in our subset
+}
+
+export function parseCron(expression: string): CronFields {
+  const parts = expression.trim().split(/\s+/);
+  if (parts.length !== 5) {
+    throw new Error(`Invalid cron expression: "${expression}". Expected 5 fields.`);
+  }
+
+  const [minutePart, hourPart, dayPart, monthPart, weekdayPart] = parts;
+
+  // We only support * for day, month, weekday
+  if (dayPart !== '*' || monthPart !== '*' || weekdayPart !== '*') {
+    throw new Error(`Unsupported cron expression: "${expression}". Day, month, and weekday must be *.`);
+  }
+
+  let minute: number | { every: number };
+  if (minutePart.startsWith('*/')) {
+    const n = parseInt(minutePart.slice(2), 10);
+    if (isNaN(n) || n <= 0 || n > 59) {
+      throw new Error(`Invalid cron minute interval: "${minutePart}".`);
+    }
+    minute = { every: n };
+  } else {
+    const m = parseInt(minutePart, 10);
+    if (isNaN(m) || m < 0 || m > 59) {
+      throw new Error(`Invalid cron minute: "${minutePart}".`);
+    }
+    minute = m;
+  }
+
+  let hour: number | '*';
+  if (hourPart === '*') {
+    hour = '*';
+  } else {
+    const h = parseInt(hourPart, 10);
+    if (isNaN(h) || h < 0 || h > 23) {
+      throw new Error(`Invalid cron hour: "${hourPart}".`);
+    }
+    hour = h;
+  }
+
+  return { minute, hour };
+}
+
+export function shouldRun(fields: CronFields, now: Date, lastRun?: Date): boolean {
+  const nowMinute = now.getMinutes();
+  const nowHour = now.getHours();
+
+  // Check if current time matches the cron pattern
+  let minuteMatches: boolean;
+  if (typeof fields.minute === 'object') {
+    // */N pattern: matches when minute is divisible by N
+    minuteMatches = nowMinute % fields.minute.every === 0;
+  } else {
+    minuteMatches = nowMinute === fields.minute;
+  }
+
+  let hourMatches: boolean;
+  if (fields.hour === '*') {
+    hourMatches = true;
+  } else {
+    hourMatches = nowHour === fields.hour;
+  }
+
+  if (!minuteMatches || !hourMatches) {
+    return false;
+  }
+
+  // If we haven't run before, go ahead
+  if (!lastRun) {
+    return true;
+  }
+
+  // Only trigger once per matching minute
+  // Check that we haven't already run in this same minute
+  const lastRunMinute = lastRun.getMinutes();
+  const lastRunHour = lastRun.getHours();
+  const lastRunDate = lastRun.toDateString();
+  const nowDate = now.toDateString();
+
+  if (nowDate === lastRunDate && nowHour === lastRunHour && nowMinute === lastRunMinute) {
+    return false;
+  }
+
+  return true;
+}
