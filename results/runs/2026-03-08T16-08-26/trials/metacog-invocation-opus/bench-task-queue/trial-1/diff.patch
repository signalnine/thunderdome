});\n\n    it('should return null when no tasks are available', () => {\n      expect(queue.getNextTask()).toBeNull();\n    });\n\n    it('should count pending tasks', () => {\n      expect(queue.getPendingCount()).toBe(0);\n      queue.addTask('a');\n      queue.addTask('b');\n      expect(queue.getPendingCount()).toBe(2);\n      queue.getNextTask();\n      expect(queue.getPendingCount()).toBe(1);\n    });\n\n    it('should not return processing tasks when getting next', () => {\n      queue.addTask('a');\n      queue.getNextTask(); // now processing\n      expect(queue.getNextTask()).toBeNull();\n    });\n  });\n\n  // ============================================================\n  // Phase 2: Named Queues\n  // ============================================================\n  describe('Phase 2: Named Queues', () => {\n    it('should use default queue when no name given', () => {\n      const task = queue.addTask('data');\n      expect(task.queue).toBe('default');\n    });\n\n    it('should support named queues', () => {\n      queue.addTask('email', { queue: 'emails' });\n      queue.addTask('sms', { queue: 'sms' });\n\n      const emailTask = queue.getNextTask('emails');\n      expect(emailTask?.payload).toBe('email');\n\n      const smsTask = queue.getNextTask('sms');\n      expect(smsTask?.payload).toBe('sms');\n    });\n\n    it('should operate independently between queues', () => {\n      queue.addTask('a', { queue: 'q1' });\n      queue.addTask('b', { queue: 'q2' });\n\n      expect(queue.getPendingCount('q1')).toBe(1);\n      expect(queue.getPendingCount('q2')).toBe(1);\n\n      queue.getNextTask('q1');\n      expect(queue.getPendingCount('q1')).toBe(0);\n      expect(queue.getPendingCount('q2')).toBe(1);\n    });\n\n    it('should list all queue names', () => {\n      queue.addTask('a', { queue: 'q1' });\n      queue.addTask('b', { queue: 'q2' });\n      const names = queue.getQueueNames();\n      expect(names).toContain('q1');\n      expect(names).toContain('q2');\n    });\n\n    it('should return null for non-existent queue', () => {\n      expect(queue.getNextTask('nonexistent')).toBeNull();\n    });\n\n    it('should create queue implicitly', () => {\n      queue.addTask('data', { queue: 'new-queue' });\n      expect(queue.getQueueNames()).toContain('new-queue');\n    });\n\n    it('backward compat: omitting queue name uses default', () => {\n      queue.addTask('data');\n      const task = queue.getNextTask();\n      expect(task?.payload).toBe('data');\n      expect(task?.queue).toBe('default');\n    });\n  });\n\n  // ============================================================\n  // Phase 3: Priority\n  // ============================================================\n  describe('Phase 3: Priority', () => {\n    it('should default to priority 5', () => {\n      const task = queue.addTask('data');\n      expect(task.priority).toBe(5);\n    });\n\n    it('should accept priority 1-10', () => {\n      const task = queue.addTask('data', { priority: 1 });\n      expect(task.priority).toBe(1);\n    });\n\n    it('should reject invalid priority', () => {\n      expect(() => queue.addTask('data', { priority: 0 })).toThrow();\n      expect(() => queue.addTask('data', { priority: 11 })).toThrow();\n      expect(() => queue.addTask('data', { priority: 3.5 })).toThrow();\n    });\n\n    it('should return higher priority first', () => {\n      queue.addTask('low', { priority: 10 });\n      queue.addTask('high', { priority: 1 });\n      queue.addTask('medium', { priority: 5 });\n\n      expect(queue.getNextTask()?.payload).toBe('high');\n      expect(queue.getNextTask()?.payload).toBe('medium');\n      expect(queue.getNextTask()?.payload).toBe('low');\n    });\n\n    it('should use FIFO within same priority', () => {\n      queue.addTask('first', { priority: 3 });\n      queue.addTask('second', { priority: 3 });\n\n      expect(queue.getNextTask()?.payload).toBe('first');\n      expect(queue.getNextTask()?.payload).toBe('second');\n    });\n\n    it('priority is per-queue', () => {\n      queue.addTask('q1-low', { queue: 'q1', priority: 10 });\n      queue.addTask('q1-high', { queue: 'q1', priority: 1 });\n      queue.addTask('q2-low', { queue: 'q2', priority: 10 });\n\n      expect(queue.getNextTask('q1')?.payload).toBe('q1-high');\n      expect(queue.getNextTask('q2')?.payload).toBe('q2-low');\n    });\n  });\n\n  // ============================================================\n  // Phase 4: Delayed Tasks\n  // ============================================================\n  describe('Phase 4: Delayed and Scheduled Tasks', () => {\n    it('should delay a task by ms', () => {\n      const task = queue.addTask('delayed', { delay: 60000 });\n      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now());\n      // Should not be retrievable yet\n      expect(queue.getNextTask()).toBeNull();\n    });\n\n    it('should return non-delayed tasks before delayed ones', () => {\n      queue.addTask('delayed', { delay: 60000 });\n      queue.addTask('immediate');\n\n      const task = queue.getNextTask();\n      expect(task?.payload).toBe('immediate');\n    });\n\n    it('should accept a processAt date', () => {\n      const futureDate = new Date(Date.now() + 60000);\n      const task = queue.addTask('scheduled', { processAt: futureDate });\n      expect(task.availableAt.getTime()).toBe(futureDate.getTime());\n    });\n\n    it('should return delayed task after delay passes', () => {\n      // Use a delay in the past\n      const task = queue.addTask('ready', { processAt: new Date(Date.now() - 1000) });\n      expect(task.availableAt.getTime()).toBeLessThan(Date.now());\n\n      const next = queue.getNextTask();\n      expect(next?.payload).toBe('ready');\n    });\n\n    it('should order by availableAt then priority then FIFO', () => {\n      const t1 = new Date(Date.now() - 3000);\n      const t2 = new Date(Date.now() - 2000);\n      const t3 = new Date(Date.now() - 1000);\n\n      queue.addTask('third', { processAt: t3, priority: 5 });\n      queue.addTask('first', { processAt: t1, priority: 5 });\n      queue.addTask('second', { processAt: t2, priority: 5 });\n\n      // All are available. Same priority, ordered by availableAt\n      expect(queue.getNextTask()?.payload).toBe('first');\n      expect(queue.getNextTask()?.payload).toBe('second');\n      expect(queue.getNextTask()?.payload).toBe('third');\n    });\n\n    it('delay works with named queues', () => {\n      queue.addTask('delayed', { queue: 'myq', delay: 60000 });\n      queue.addTask('ready', { queue: 'myq' });\n\n      expect(queue.getNextTask('myq')?.payload).toBe('ready');\n      expect(queue.getNextTask('myq')).toBeNull();\n    });\n  });\n\n  // ============================================================\n  // Phase 5: Retry with Backoff\n  // ============================================================\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should complete a task', () => {\n      queue.addTask('work');\n      const task = queue.getNextTask()!;\n      queue.completeTask(task.id);\n      expect(queue.getTask(task.id)?.status).toBe('completed');\n    });\n\n    it('should fail a task and re-enqueue with backoff', () => {\n      const task = queue.addTask('work');\n      const t = queue.getNextTask()!;\n      expect(t.attempts).toBe(1);\n\n      queue.failTask(t.id, new Error('oops'));\n      // Should be re-enqueued as pending (but delayed)\n      const updated = queue.getTask(t.id)!;\n      expect(updated.status).toBe('pending');\n      expect(updated.failCount).toBe(1);\n      expect(updated.availableAt.getTime()).toBeGreaterThan(Date.now());\n    });\n\n    it('should track attempt count', () => {\n      // Use a task with processAt in the past so retries are immediately available\n      const task = queue.addTask('work', { maxRetries: 3, backoffDelay: 0 });\n\n      // Attempt 1\n      let t = queue.getNextTask()!;\n      expect(t.attempts).toBe(1);\n      queue.failTask(t.id);\n\n      // Attempt 2 (backoffDelay: 0 still adds delay via formula)\n      // With backoffDelay 0, delay = 0 * 2^0 = 0\n      t = queue.getNextTask()!;\n      expect(t.attempts).toBe(2);\n      queue.failTask(t.id);\n\n      // Attempt 3\n      t = queue.getNextTask()!;\n      expect(t.attempts).toBe(3);\n      queue.failTask(t.id);\n\n      // Attempt 4 - this should be the last retry (maxRetries: 3 means 3 retries after initial = 4 attempts total)\n      // Wait, maxRetries=3 and we check attempts <= maxRetries\n      // attempt 1: fail -> retry (attempts=1, 1<=3 true)\n      // attempt 2: fail -> retry (attempts=2, 2<=3 true)\n      // attempt 3: fail -> retry (attempts=3, 3<=3 true)\n      // attempt 4: fail -> no retry (attempts=4, 4<=3 false) -> DLQ\n      t = queue.getNextTask()!;\n      expect(t.attempts).toBe(4);\n      queue.failTask(t.id);\n\n      const final = queue.getTask(task.id)!;\n      expect(final.status).toBe('failed');\n    });\n\n    it('should use exponential backoff delay', () => {\n      const task = queue.addTask('work', { maxRetries: 3, backoffDelay: 1000 });\n\n      // Attempt 1\n      let t = queue.getNextTask()!;\n      queue.failTask(t.id);\n\n      // After first failure: delay = 1000 * 2^0 = 1000ms\n      const afterFirst = queue.getTask(task.id)!;\n      expect(afterFirst.availableAt.getTime()).toBeGreaterThanOrEqual(Date.now() + 900);\n    });\n\n    it('should keep original queue and priority on retry', () => {\n      queue.addTask('work', { queue: 'myq', priority: 2, backoffDelay: 0 });\n      const t = queue.getNextTask('myq')!;\n      queue.failTask(t.id);\n\n      const updated = queue.getTask(t.id)!;\n      expect(updated.queue).toBe('myq');\n      expect(updated.priority).toBe(2);\n    });\n\n    it('should default maxRetries to 3', () => {\n      const task = queue.addTask('work');\n      expect(task.maxRetries).toBe(3);\n    });\n\n    it('should allow configurable maxRetries and backoffDelay', () => {\n      const task = queue.addTask('work', { maxRetries: 5, backoffDelay: 500 });\n      expect(task.maxRetries).toBe(5);\n      expect(task.backoffDelay).toBe(500);\n    });\n  });\n\n  // ============================================================\n  // Phase 6: Dead Letter Queue\n  // ============================================================\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move permanently failed tasks to DLQ', () => {\n      queue.addTask('work', { maxRetries: 0, backoffDelay: 0 });\n      const t = queue.getNextTask()!;\n      queue.failTask(t.id, 'permanent failure');\n\n      const dlq = queue.getDeadLetterTasks();\n      expect(dlq).toHaveLength(1);\n      expect(dlq[0].id).toBe(t.id);\n      expect(dlq[0].error).toBe('permanent failure');\n    });\n\n    it('should retain error info and fail count', () => {\n      queue.addTask('work', { maxRetries: 0 });\n      const t = queue.getNextTask()!;\n      queue.failTask(t.id, new Error('boom'));\n\n      const dlq = queue.getDeadLetterTasks();\n      expect(dlq[0].failCount).toBe(1);\n      expect(dlq[0].error).toBeInstanceOf(Error);\n    });\n\n    it('should requeue a dead-lettered task', () => {\n      queue.addTask('work', { maxRetries: 0 });\n      const t = queue.getNextTask()!;\n      queue.failTask(t.id, 'err');\n\n      const requeued = queue.requeue(t.id);\n      expect(requeued.status).toBe('pending');\n      expect(requeued.attempts).toBe(0);\n      expect(requeued.failCount).toBe(0);\n\n      expect(queue.getDeadLetterTasks()).toHaveLength(0);\n    });\n\n    it('should clear all dead-lettered tasks', () => {\n      queue.addTask('a', { maxRetries: 0 });\n      queue.addTask('b', { maxRetries: 0 });\n      queue.failTask(queue.getNextTask()!.id, 'err');\n      queue.failTask(queue.getNextTask()!.id, 'err');\n\n      expect(queue.getDeadLetterTasks()).toHaveLength(2);\n      queue.clearDeadLetterQueue();\n      expect(queue.getDeadLetterTasks()).toHaveLength(0);\n    });\n\n    it('each named queue has independent DLQ', () => {\n      queue.addTask('a', { queue: 'q1', maxRetries: 0 });\n      queue.addTask('b', { queue: 'q2', maxRetries: 0 });\n      queue.failTask(queue.getNextTask('q1')!.id, 'err');\n      queue.failTask(queue.getNextTask('q2')!.id, 'err');\n\n      expect(queue.getDeadLetterTasks('q1')).toHaveLength(1);\n      expect(queue.getDeadLetterTasks('q2')).toHaveLength(1);\n    });\n  });\n\n  // ============================================================\n  // Phase 7: Task Dependencies\n  // ============================================================\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block tasks with unresolved dependencies', () => {\n      const t1 = queue.addTask('first');\n      const t2 = queue.addTask('second', { dependencies: [t1.id] });\n      expect(t2.status).toBe('blocked');\n\n      // Should not return blocked task\n      const next = queue.getNextTask();\n      expect(next?.id).toBe(t1.id);\n\n      // t2 is still blocked\n      expect(queue.getNextTask()).toBeNull();\n    });\n\n    it('should unblock task when dependency completes', () => {\n      const t1 = queue.addTask('first');\n      const t2 = queue.addTask('second', { dependencies: [t1.id] });\n\n      const processing = queue.getNextTask()!;\n      queue.completeTask(processing.id);\n\n      // Now t2 should be available\n      const next = queue.getNextTask();\n      expect(next?.id).toBe(t2.id);\n    });\n\n    it('should reject non-existent dependency', () => {\n      expect(() =>\n        queue.addTask('work', { dependencies: ['nonexistent'] })\n      ).toThrow('Dependency task not found');\n    });\n\n    it('should keep dependents blocked when dependency fails', () => {\n      const t1 = queue.addTask('first', { maxRetries: 0 });\n      const t2 = queue.addTask('second', { dependencies: [t1.id] });\n\n      const processing = queue.getNextTask()!;\n      queue.failTask(processing.id, 'err');\n\n      // t2 should remain blocked\n      expect(queue.getTask(t2.id)?.status).toBe('blocked');\n      expect(queue.getNextTask()).toBeNull();\n    });\n\n    it('should support multiple dependencies', () => {\n      const t1 = queue.addTask('first');\n      const t2 = queue.addTask('second');\n      const t3 = queue.addTask('third', { dependencies: [t1.id, t2.id] });\n\n      // Complete t1\n      queue.completeTask(queue.getNextTask()!.id);\n      // t3 still blocked (t2 not done)\n      expect(queue.getTask(t3.id)?.status).toBe('blocked');\n\n      // Complete t2\n      queue.completeTask(queue.getNextTask()!.id);\n      // t3 should now be available\n      expect(queue.getTask(t3.id)?.status).toBe('pending');\n    });\n\n    it('should inspect dependency status', () => {\n      const t1 = queue.addTask('first');\n      const t2 = queue.addTask('second', { dependencies: [t1.id] });\n\n      const status = queue.getTaskDependencyStatus(t2.id);\n      expect(status).toHaveLength(1);\n      expect(status[0].taskId).toBe(t1.id);\n      expect(status[0].resolved).toBe(false);\n    });\n  });\n\n  // ============================================================\n  // Phase 8: Concurrency Control\n  // ============================================================\n  describe('Phase 8: Concurrency Control', () => {\n    it('should limit concurrent processing', () => {\n      queue.setConcurrency('default', 2);\n      queue.addTask('a');\n      queue.addTask('b');\n      queue.addTask('c');\n\n      expect(queue.getNextTask()).not.toBeNull(); // 1 active\n      expect(queue.getNextTask()).not.toBeNull(); // 2 active\n      expect(queue.getNextTask()).toBeNull(); // at limit\n    });\n\n    it('should free slot when task completes', () => {\n      queue.setConcurrency('default', 1);\n      queue.addTask('a');\n      queue.addTask('b');\n\n      const t1 = queue.getNextTask()!;\n      expect(queue.getNextTask()).toBeNull();\n\n      queue.completeTask(t1.id);\n      expect(queue.getNextTask()).not.toBeNull();\n    });\n\n    it('should free slot when task fails', () => {\n      queue.setConcurrency('default', 1);\n      queue.addTask('a', { maxRetries: 0 });\n      queue.addTask('b');\n\n      const t1 = queue.getNextTask()!;\n      expect(queue.getNextTask()).toBeNull();\n\n      queue.failTask(t1.id, 'err');\n      expect(queue.getNextTask()).not.toBeNull();\n    });\n\n    it('should default to unlimited concurrency', () => {\n      const { limit } = queue.getConcurrency();\n      expect(limit).toBeNull();\n    });\n\n    it('should query concurrency info', () => {\n      queue.setConcurrency('default', 5);\n      queue.addTask('a');\n      queue.getNextTask();\n\n      const info = queue.getConcurrency('default');\n      expect(info.limit).toBe(5);\n      expect(info.active).toBe(1);\n    });\n\n    it('should respect priority even with concurrency limits', () => {\n      queue.setConcurrency('default', 1);\n      queue.addTask('low', { priority: 10 });\n      queue.addTask('high', { priority: 1 });\n\n      const task = queue.getNextTask();\n      expect(task?.payload).toBe('high');\n    });\n  });\n\n  // ============================================================\n  // Phase 9: Progress Tracking and Cancellation\n  // ============================================================\n  describe('Phase 9: Progress Tracking and Cancellation', () => {\n    it('should update and query progress', () => {\n      queue.addTask('work');\n      const task = queue.getNextTask()!;\n\n      queue.updateProgress(task.id, 50, 'halfway');\n      const progress = queue.getProgress(task.id);\n      expect(progress.progress).toBe(50);\n      expect(progress.message).toBe('halfway');\n    });\n\n    it('should reject invalid progress values', () => {\n      queue.addTask('work');\n      const task = queue.getNextTask()!;\n\n      expect(() => queue.updateProgress(task.id, -1)).toThrow();\n      expect(() => queue.updateProgress(task.id, 101)).toThrow();\n    });\n\n    it('should notify progress listeners', () => {\n      queue.addTask('work');\n      const task = queue.getNextTask()!;\n\n      const updates: Array<{ progress: number; message?: string }> = [];\n      queue.onProgress(task.id, (p, m) => updates.push({ progress: p, message: m }));\n\n      queue.updateProgress(task.id, 25, 'step 1');\n      queue.updateProgress(task.id, 75, 'step 2');\n\n      expect(updates).toHaveLength(2);\n      expect(updates[0].progress).toBe(25);\n      expect(updates[1].progress).toBe(75);\n    });\n\n    it('should support unsubscribing from progress', () => {\n      queue.addTask('work');\n      const task = queue.getNextTask()!;\n\n      const updates: number[] = [];\n      const unsub = queue.onProgress(task.id, (p) => updates.push(p));\n\n      queue.updateProgress(task.id, 25);\n      unsub();\n      queue.updateProgress(task.id, 75);\n\n      expect(updates).toHaveLength(1);\n    });\n\n    it('should cancel a pending task', () => {\n      const task = queue.addTask('work');\n      queue.cancelTask(task.id);\n\n      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n      expect(queue.getTask(task.id)?.cancelledAt).toBeInstanceOf(Date);\n      expect(queue.getNextTask()).toBeNull();\n    });\n\n    it('should cancel a processing task', () => {\n      queue.addTask('work');\n      const task = queue.getNextTask()!;\n\n      queue.cancelTask(task.id);\n      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n    });\n\n    it('should free concurrency slot on cancel', () => {\n      queue.setConcurrency('default', 1);\n      queue.addTask('a');\n      queue.addTask('b');\n\n      const t1 = queue.getNextTask()!;\n      expect(queue.getNextTask()).toBeNull();\n\n      queue.cancelTask(t1.id);\n      expect(queue.getNextTask()).not.toBeNull();\n    });\n\n    it('cancelled tasks are never retried', () => {\n      queue.addTask('work', { maxRetries: 5 });\n      const task = queue.getNextTask()!;\n      queue.cancelTask(task.id);\n\n      // The task should be cancelled, not re-enqueued\n      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n      expect(queue.getNextTask()).toBeNull();\n    });\n  });\n\n  // ============================================================\n  // Phase 10: Recurring Tasks\n  // ============================================================\n  describe('Phase 10: Recurring Tasks', () => {\n    it('should create a schedule', () => {\n      const id = queue.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });\n      expect(id).toBeDefined();\n      expect(queue.getSchedules()).toHaveLength(1);\n    });\n\n    it('should reject invalid cron expression', () => {\n      expect(() => queue.addSchedule('invalid', 'default', {})).toThrow();\n    });\n\n    it('should remove a schedule', () => {\n      const id = queue.addSchedule('*/5 * * * *', 'default', {});\n      expect(queue.removeSchedule(id)).toBe(true);\n      expect(queue.getSchedules()).toHaveLength(0);\n    });\n\n    it('should enqueue tasks on tick when due', () => {\n      queue.addSchedule('0 * * * *', 'default', { type: 'hourly' });\n\n      // Tick at the top of an hour\n      const onTheHour = new Date('2025-01-01T12:00:00Z');\n      const tasks = queue.tick(onTheHour);\n      expect(tasks).toHaveLength(1);\n      expect(tasks[0].payload).toEqual({ type: 'hourly' });\n    });\n\n    it('should not double-trigger in same minute', () => {\n      queue.addSchedule('0 * * * *', 'default', { type: 'hourly' });\n\n      const onTheHour = new Date('2025-01-01T12:00:00Z');\n      queue.tick(onTheHour);\n      const tasks2 = queue.tick(new Date('2025-01-01T12:00:30Z'));\n      expect(tasks2).toHaveLength(0);\n    });\n\n    it('should not trigger at wrong time', () => {\n      queue.addSchedule('0 * * * *', 'default', { type: 'hourly' });\n\n      const notOnTheHour = new Date('2025-01-01T12:15:00Z');\n      const tasks = queue.tick(notOnTheHour);\n      expect(tasks).toHaveLength(0);\n    });\n\n    it('recurring tasks are regular tasks subject to queue rules', () => {\n      queue.addSchedule('0 * * * *', 'myq', { data: 'recurring' }, { priority: 2 });\n\n      const onTheHour = new Date('2025-01-01T12:00:00Z');\n      const created = queue.tick(onTheHour);\n      expect(created[0].queue).toBe('myq');\n      expect(created[0].priority).toBe(2);\n    });\n\n    it('removed schedule stops future occurrences', () => {\n      const id = queue.addSchedule('0 * * * *', 'default', {});\n      queue.removeSchedule(id);\n\n      const onTheHour = new Date('2025-01-01T12:00:00Z');\n      const tasks = queue.tick(onTheHour);\n      expect(tasks).toHaveLength(0);\n    });\n  });\n\n  // ============================================================\n  // Phase 11: Middleware Pipeline\n  // ============================================================\n  describe('Phase 11: Middleware Pipeline', () => {\n    it('should run middleware in order', async () => {\n      const order: string[] = [];\n\n      queue.use('default', async (_task, next) => {\n        order.push('mw1-before');\n        await next();\n        order.push('mw1-after');\n      });\n\n      queue.use('default', async (_task, next) => {\n        order.push('mw2-before');\n        await next();\n        order.push('mw2-after');\n      });\n\n      queue.setHandler('default', async () => {\n        order.push('handler');\n      });\n\n      queue.addTask('work');\n      await queue.process();\n\n      expect(order).toEqual([\n        'mw1-before',\n        'mw2-before',\n        'handler',\n        'mw2-after',\n        'mw1-after',\n      ]);\n    });\n\n    it('should skip processing if middleware does not call next', async () => {\n      const handlerCalled = vi.fn();\n\n      queue.use('default', async () => {\n        // Intentionally NOT calling next\n      });\n\n      queue.setHandler('default', handlerCalled);\n\n      queue.addTask('work');\n      await queue.process();\n\n      expect(handlerCalled).not.toHaveBeenCalled();\n    });\n\n    it('should allow middleware to modify task', async () => {\n      queue.use('default', async (task, next) => {\n        (task.payload as Record<string, unknown>).enriched = true;\n        await next();\n      });\n\n      let seenPayload: unknown;\n      queue.setHandler('default', async (task) => {\n        seenPayload = task.payload;\n      });\n\n      queue.addTask({ data: 'test' });\n      await queue.process();\n\n      expect(seenPayload).toEqual({ data: 'test', enriched: true });\n    });\n\n    it('should fail task if middleware throws', async () => {\n      queue.use('default', async () => {\n        throw new Error('middleware error');\n      });\n\n      const task = queue.addTask('work', { maxRetries: 0 });\n      await queue.process();\n\n      const updated = queue.getTask(task.id)!;\n      expect(updated.status).toBe('failed');\n    });\n\n    it('should complete task after successful processing', async () => {\n      queue.setHandler('default', async () => {\n        // Success\n      });\n\n      const task = queue.addTask('work');\n      await queue.process();\n\n      expect(queue.getTask(task.id)?.status).toBe('completed');\n    });\n\n    it('should return null if no tasks available', async () => {\n      const result = await queue.process();\n      expect(result).toBeNull();\n    });\n\n    it('each queue has independent middleware', async () => {\n      const q1Called = vi.fn();\n      const q2Called = vi.fn();\n\n      queue.use('q1', async (_task, next) => { q1Called(); await next(); });\n      queue.use('q2', async (_task, next) => { q2Called(); await next(); });\n\n      queue.addTask('a', { queue: 'q1' });\n      await queue.process('q1');\n\n      expect(q1Called).toHaveBeenCalled();\n      expect(q2Called).not.toHaveBeenCalled();\n    });\n  });\n\n  // ============================================================\n  // Phase 12: Graceful Shutdown\n  // =====================