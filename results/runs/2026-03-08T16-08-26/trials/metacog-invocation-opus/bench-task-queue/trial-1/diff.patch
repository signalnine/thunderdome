+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_019wjPK5PLtm26wvdKaDjv75","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01RyJ6GvzSaXzgwdzWaCVSrc","name":"Write","input":{"file_path":"/workspace/src/queue.ts","content":"import { randomUUID } from 'node:crypto';\nimport type {\n  Task,\n  TaskOptions,\n  TaskStatus,\n  ProgressListener,\n  Middleware,\n  TaskHandler,\n  ScheduleEntry,\n  ShutdownOptions,\n  ShutdownSummary,\n} from './types.js';\nimport { createTask } from './task.js';\nimport { parseCron, shouldRun } from './cron.js';\n\ninterface QueueState {\n  concurrencyLimit: number | null;\n  activeCount: number;\n  middlewares: Middleware[];\n  handler: TaskHandler | null;\n}\n\nexport class TaskQueue {\n  // All tasks by id\n  private tasks = new Map<string, Task>();\n  // Queue state per named queue\n  private queues = new Map<string, QueueState>();\n  // Dead letter queues per named queue\n  private dlqs = new Map<string, Task[]>();\n  // Progress listeners per task id\n  private progressListeners = new Map<string, Set<ProgressListener>>();\n  // Recurring schedules\n  private schedules = new Map<string, ScheduleEntry>();\n  // Shutdown state\n  private isShutdown = false;\n  private shutdownPromise: Promise<ShutdownSummary> | null = null;\n  // Shutdown callbacks\n  private shutdownCallbacks: Array<() => void | Promise<void>> = [];\n\n  // ---- Queue management ----\n\n  private ensureQueue(name: string): QueueState {\n    let q = this.queues.get(name);\n    if (!q) {\n      q = {\n        concurrencyLimit: null,\n        activeCount: 0,\n        middlewares: [],\n        handler: null,\n      };\n      this.queues.set(name, q);\n    }\n    return q;\n  }\n\n  getQueueNames(): string[] {\n    return [...this.queues.keys()];\n  }\n\n  // ---- Phase 1, 2, 3, 4: Adding tasks ----\n\n  addTask<T = unknown>(payload: T, options: TaskOptions = {}): Task<T> {\n    if (this.isShutdown) {\n      throw new Error('Cannot add tasks: the system is shutting down.');\n    }\n\n    const task = createTask(payload, options);\n    this.ensureQueue(task.queue);\n\n    // Phase 7: Validate dependencies\n    if (task.dependencies.length > 0) {\n      for (const depId of task.dependencies) {\n        if (!this.tasks.has(depId)) {\n          throw new Error(`Dependency task not found: ${depId}`);\n        }\n      }\n      // Check for circular dependencies\n      this.checkCircularDependencies(task.id, task.dependencies);\n    }\n\n    this.tasks.set(task.id, task as Task);\n\n    // Check if dependencies are already resolved\n    if (task.status === 'blocked') {\n      this.checkAndUnblock(task as Task);\n    }\n\n    return task;\n  }\n\n  // ---- Phase 1, 3, 4, 7, 8: Retrieving next task ----\n\n  getNextTask(queueName: string = 'default'): Task | null {\n    const queueState = this.queues.get(queueName);\n    if (!queueState) return null;\n\n    // Phase 8: Check concurrency limit\n    if (\n      queueState.concurrencyLimit !== null &&\n      queueState.activeCount >= queueState.concurrencyLimit\n    ) {\n      return null;\n    }\n\n    const now = new Date();\n    let bestTask: Task | null = null;\n\n    for (const task of this.tasks.values()) {\n      if (task.queue !== queueName) continue;\n      if (task.status !== 'pending') continue;\n\n      // Phase 4: Check delay\n      if (task.availableAt > now) continue;\n\n      if (!bestTask) {\n        bestTask = task;\n        continue;\n      }\n\n      // Phase 3: Priority comparison (lower number = higher priority)\n      if (task.priority < bestTask.priority) {\n        bestTask = task;\n      } else if (task.priority === bestTask.priority) {\n        // Phase 4: If both have same priority, prefer earlier availableAt\n        if (task.availableAt < bestTask.availableAt) {\n          bestTask = task;\n        } else if (task.availableAt.getTime() === bestTask.availableAt.getTime()) {\n          // FIFO: prefer earlier creation\n          if (task.createdAt < bestTask.createdAt) {\n            bestTask = task;\n          }\n        }\n      }\n    }\n\n    if (bestTask) {\n      bestTask.status = 'processing';\n      bestTask.attempts += 1;\n      queueState.activeCount += 1;\n    }\n\n    return bestTask;\n  }\n\n  // ---- Phase 1: Pending count ----\n\n  getPendingCount(queueName: string = 'default'): number {\n    let count = 0;\n    for (const task of this.tasks.values()) {\n      if (task.queue === queueName && task.status === 'pending') {\n        count++;\n      }\n    }\n    return count;\n  }\n\n  // ---- Phase 5: Complete and fail ----\n\n  completeTask(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot complete task in \"${task.status}\" status. Must be \"processing\".`);\n    }\n\n    task.status = 'completed';\n    task.progress = 100;\n\n    const queueState = this.queues.get(task.queue);\n    if (queueState) {\n      queueState.activeCount = Math.max(0, queueState.activeCount - 1);\n    }\n\n    // Phase 7: Unblock dependents\n    this.unblockDependents(taskId);\n\n    // Clean up progress listeners\n    this.progressListeners.delete(taskId);\n  }\n\n  failTask(taskId: string, error?: Error | string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot fail task in \"${task.status}\" status. Must be \"processing\".`);\n    }\n\n    const queueState = this.queues.get(task.queue);\n    if (queueState) {\n      queueState.activeCount = Math.max(0, queueState.activeCount - 1);\n    }\n\n    task.error = error;\n    task.failCount += 1;\n\n    // Phase 5: Check retries\n    if (task.attempts <= task.maxRetries) {\n      // Re-enqueue with backoff delay\n      const backoff = task.backoffDelay * Math.pow(2, task.attempts - 1);\n      task.availableAt = new Date(Date.now() + backoff);\n      task.status = 'pending';\n      task.progress = 0;\n      task.progressMessage = undefined;\n    } else {\n      // Phase 6: Move to DLQ\n      task.status = 'failed';\n      this.moveToDLQ(task);\n    }\n\n    // Clean up progress listeners\n    this.progressListeners.delete(taskId);\n  }\n\n  // ---- Phase 6: Dead Letter Queue ----\n\n  private moveToDLQ(task: Task): void {\n    let dlq = this.dlqs.get(task.queue);\n    if (!dlq) {\n      dlq = [];\n      this.dlqs.set(task.queue, dlq);\n    }\n    dlq.push(task);\n  }\n\n  getDeadLetterTasks(queueName: string = 'default'): Task[] {\n    return [...(this.dlqs.get(queueName) ?? [])];\n  }\n\n  requeue(taskId: string): Task {\n    // Find the task in DLQs\n    for (const [queueName, dlq] of this.dlqs.entries()) {\n      const idx = dlq.findIndex(t => t.id === taskId);\n      if (idx !== -1) {\n        const task = dlq[idx];\n        dlq.splice(idx, 1);\n        // Reset task for fresh retries\n        task.status = 'pending';\n        task.attempts = 0;\n        task.failCount = 0;\n        task.error = undefined;\n        task.progress = 0;\n        task.progressMessage = undefined;\n        task.availableAt = new Date();\n        // Ensure it's still in tasks map\n        this.tasks.set(task.id, task);\n        this.ensureQueue(queueName);\n        return task;\n      }\n    }\n    throw new Error(`Task not found in any dead letter queue: ${taskId}`);\n  }\n\n  clearDeadLetterQueue(queueName: string = 'default'): void {\n    const dlq = this.dlqs.get(queueName);\n    if (dlq) {\n      // Remove tasks from the main tasks map as well\n      for (const task of dlq) {\n        this.tasks.delete(task.id);\n      }\n      dlq.length = 0;\n    }\n  }\n\n  // ---- Phase 7: Task Dependencies ----\n\n  private checkCircularDependencies(newTaskId: string, dependencies: string[]): void {\n    // BFS/DFS to check if any dependency transitively depends on newTaskId\n    // Since newTaskId isn't in the map yet, we check if any dep's chain\n    // would form a loop. Actually, newTaskId is new so no existing task\n    // can depend on it yet (unless we added it to the map first).\n    // But we still need to check if the dependency chain itself forms a cycle.\n\n    // The real check: ensure no dependency chain creates a cycle.\n    // Since the new task isn't yet a dependency of anything, we just\n    // need to verify that dependencies themselves don't indirectly\n    // depend on this task. But since the task is new, they can't.\n    // However, we should still validate the dependency graph is acyclic.\n\n    // Actually, the spec says \"Circular dependencies (direct or indirect) must be detected\n    // and rejected at task-creation time.\" So if task A depends on task B which depends on task C,\n    // and we try to add task D depending on A, that's fine. But if we try to add task D\n    // depending on A, and A depends on D... well A can't depend on D because D doesn't exist yet.\n    // The only real case: A depends on B, B depends on A. But B would have been rejected when\n    // it tried to depend on A (which didn't exist then).\n    //\n    // The main case is if we add tasks with deps like:\n    //   A (no deps), B depends on A, C depends on B, then D depends on C and A depends on D?\n    //   But A is already created so we can't modify it.\n    //\n    // Actually the real risk: the new task depends on tasks that depend on each other.\n    // But more importantly: the user might create tasks that form a cycle through the\n    // dependency graph. Example: A depends on B (both created without deps), then create\n    // C that depends on A with an ID that B depends on... no, B is already created.\n    //\n    // The realistic scenario:\n    //   Create A, create B (depends on A), create C (depends on B).\n    //   Now create D (depends on C). Then want A to depend on D - but A already exists.\n    //\n    // I think the main safeguard needed is checking that we don't have dep chains\n    // that form cycles. For the new task, verify none of its deps transitively\n    // point back to it. But since it's new, they can't. Unless... we're dealing with\n    // blocked tasks that form cycles among themselves.\n    //\n    // Revisiting: the real case is tasks created with mutual dependencies in one batch setup.\n    // Since we require deps to already exist, true cycles are impossible — you can't create\n    // A depending on B if B doesn't exist yet, so you have to create B first, meaning B\n    // can't depend on A. The only check needed is the \"Depending on a non-existent task\"\n    // check, which we already do above. But let's be thorough anyway.\n\n    // Verify: for each dependency, walk its dependency chain and ensure we never see newTaskId\n    // (This is technically impossible since newTaskId is new, but let's be safe)\n    const visited = new Set<string>();\n    const stack = [...dependencies];\n\n    while (stack.length > 0) {\n      const current = stack.pop()!;\n      if (current === newTaskId) {\n        throw new Error('Circular dependency detected');\n      }\n      if (visited.has(current)) continue;\n      visited.add(current);\n\n      const currentTask = this.tasks.get(current);\n      if (currentTask) {\n        for (const dep of currentTask.dependencies) {\n          stack.push(dep);\n        }\n      }\n    }\n  }\n\n  private checkAndUnblock(task: Task): void {\n    const allResolved = task.dependencies.every(depId => {\n      const dep = this.tasks.get(depId);\n      return dep && dep.status === 'completed';\n    });\n    if (allResolved) {\n      task.status = 'pending';\n    }\n  }\n\n  private unblockDependents(completedTaskId: string): void {\n    for (const task of this.tasks.values()) {\n      if (task.status === 'blocked' && task.dependencies.includes(completedTaskId)) {\n        this.checkAndUnblock(task);\n      }\n    }\n  }\n\n  getTaskDependencyStatus(taskId: string): { taskId: string; resolved: boolean; status: TaskStatus }[] {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    return task.dependencies.map(depId => {\n      const dep = this.tasks.get(depId);\n      return {\n        taskId: depId,\n        resolved: dep?.status === 'completed',\n        status: dep?.status ?? 'pending' as TaskStatus,\n      };\n    });\n  }\n\n  // ---- Phase 8: Concurrency Control ----\n\n  setConcurrency(queueName: string, limit: number | null): void {\n    const q = this.ensureQueue(queueName);\n    q.concurrencyLimit = limit;\n  }\n\n  getConcurrency(queueName: string = 'default'): { limit: number | null; active: number } {\n    const q = this.queues.get(queueName);\n    if (!q) return { limit: null, active: 0 };\n    return { limit: q.concurrencyLimit, active: q.activeCount };\n  }\n\n  // ---- Phase 9: Progress Tracking ----\n\n  updateProgress(taskId: string, progress: number, message?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot update progress for task in \"${task.status}\" status.`);\n    }\n    if (progress < 0 || progress > 100) {\n      throw new Error(`Progress must be between 0 and 100, got ${progress}.`);\n    }\n\n    task.progress = progress;\n    task.progressMessage = message;\n\n    // Notify listeners\n    const listeners = this.progressListeners.get(taskId);\n    if (listeners) {\n      for (const listener of listeners) {\n        listener(progress, message);\n      }\n    }\n  }\n\n  getProgress(taskId: string): { progress: number; message?: string } {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    return { progress: task.progress, message: task.progressMessage };\n  }\n\n  onProgress(taskId: string, listener: ProgressListener): () => void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    let listeners = this.progressListeners.get(taskId);\n    if (!listeners) {\n      listeners = new Set();\n      this.progressListeners.set(taskId, listeners);\n    }\n    listeners.add(listener);\n\n    // Return unsubscribe function\n    return () => {\n      listeners!.delete(listener);\n      if (listeners!.size === 0) {\n        this.progressListeners.delete(taskId);\n      }\n    };\n  }\n\n  // ---- Phase 9: Cancellation ----\n\n  cancelTask(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    if (task.status !== 'pending' && task.status !== 'processing' && task.status !== 'blocked') {\n      throw new Error(`Cannot cancel task in \"${task.status}\" status.`);\n    }\n\n    const wasProcessing = task.status === 'processing';\n    task.status = 'cancelled';\n    task.cancelledAt = new Date();\n\n    if (wasProcessing) {\n      const queueState = this.queues.get(task.queue);\n      if (queueState) {\n        queueState.activeCount = Math.max(0, queueState.activeCount - 1);\n      }\n    }\n\n    // Clean up progress listeners\n    this.progressListeners.delete(taskId);\n  }\n\n  // ---- Phase 10: Recurring Tasks / Schedules ----\n\n  addSchedule(\n    cronExpression: string,\n    queueName: string,\n    payload: unknown,\n    taskOptions?: Omit<TaskOptions, 'queue'>\n  ): string {\n    if (this.isShutdown) {\n      throw new Error('Cannot add schedules: the system is shutting down.');\n    }\n\n    // Validate cron expression\n    parseCron(cronExpression);\n\n    const id = randomUUID();\n    this.schedules.set(id, {\n      id,\n      cronExpression,\n      queue: queueName,\n      payload,\n      taskOptions,\n    });\n    this.ensureQueue(queueName);\n    return id;\n  }\n\n  removeSchedule(scheduleId: string): boolean {\n    return this.schedules.delete(scheduleId);\n  }\n\n  getSchedules(): ScheduleEntry[] {\n    return [...this.schedules.values()];\n  }\n\n  tick(now?: Date): Task[] {\n    const currentTime = now ?? new Date();\n    const created: Task[] = [];\n\n    for (const schedule of this.schedules.values()) {\n      const fields = parseCron(schedule.cronExpression);\n      if (shouldRun(fields, currentTime, schedule.lastRun)) {\n        const task = this.addTask(schedule.payload, {\n          ...schedule.taskOptions,\n          queue: schedule.queue,\n        });\n        schedule.lastRun = currentTime;\n        created.push(task as Task);\n      }\n    }\n\n    return created;\n  }\n\n  // ---- Phase 11: Middleware ----\n\n  use(queueName: string, middleware: Middleware): void {\n    const q = this.ensureQueue(queueName);\n    q.middlewares.push(middleware);\n  }\n\n  setHandler(queueName: string, handler: TaskHandler): void {\n    const q = this.ensureQueue(queueName);\n    q.handler = handler;\n  }\n\n  async process(queueName: string = 'default'): Promise<Task | null> {\n    const task = this.getNextTask(queueName);\n    if (!task) return null;\n\n    const queueState = this.queues.get(queueName)!;\n    const middlewares = [...queueState.middlewares];\n    const handler = queueState.handler;\n\n    try {\n      await this.runMiddlewareChain(middlewares, task, handler);\n      if (task.status === 'processing') {\n        this.completeTask(task.id);\n      }\n    } catch (err) {\n      if (task.status === 'processing') {\n        this.failTask(task.id, err instanceof Error ? err : new Error(String(err)));\n      }\n    }\n\n    return task;\n  }\n\n  private async runMiddlewareChain(\n    middlewares: Middleware[],\n    task: Task,\n    handler: TaskHandler | null,\n    index: number = 0\n  ): Promise<void> {\n    if (index < middlewares.length) {\n      let nextCalled = false;\n      const next = async () => {\n        nextCalled = true;\n        await this.runMiddlewareChain(middlewares, 