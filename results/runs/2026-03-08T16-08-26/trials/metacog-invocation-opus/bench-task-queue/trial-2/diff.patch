ssion: ${cron}`);\n   465→    }\n   466→  }\n   467→\n   468→  private shouldRunSchedule(schedule: Schedule, now: Date): boolean {\n   469→    const parts = schedule.cron.trim().split(/\\s+/);\n   470→    const [minuteField, hourField] = parts;\n   471→\n   472→    const currentMinute = now.getMinutes();\n   473→    const currentHour = now.getHours();\n   474→\n   475→    // Check minute field\n   476→    if (!this.matchCronField(minuteField, currentMinute)) return false;\n   477→    // Check hour field\n   478→    if (!this.matchCronField(hourField, currentHour)) return false;\n   479→\n   480→    // Avoid running the same schedule multiple times in the same minute\n   481→    if (schedule.lastRun) {\n   482→      const lastMinute = schedule.lastRun.getMinutes();\n   483→      const lastHour = schedule.lastRun.getHours();\n   484→      const lastDate = schedule.lastRun.toDateString();\n   485→      const nowDate = now.toDateString();\n   486→      if (lastMinute === currentMinute && lastHour === currentHour && lastDate === nowDate) {\n   487→        return false;\n   488→      }\n   489→    }\n   490→\n   491→    return true;\n   492→  }\n   493→\n   494→  private matchCronField(field: string, value: number): boolean {\n   495→    if (field === '*') return true;\n   496→    if (/^\\*\\/(\\d+)$/.test(field)) {\n   497→      const interval = parseInt(field.slice(2), 10);\n   498→      return value % interval === 0;\n   499→    }\n   500→    if (/^\\d+$/.test(field)) {\n   501→      return parseInt(field, 10) === value;\n   502→    }\n   503→    return false;\n   504→  }\n   505→\n   506→  // ---- Phase 11: Middleware ----\n   507→\n   508→  use(queueName: string, middleware: MiddlewareFn): void {\n   509→    const state = this.ensureQueue(queueName);\n   510→    state.middleware.push(middleware);\n   511→  }\n   512→\n   513→  setHandler(queueName: string, handler: HandlerFn): void {\n   514→    const state = this.ensureQueue(queueName);\n   515→    state.handler = handler;\n   516→  }\n   517→\n   518→  async process(queueName?: string): Promise<Task | null> {\n   519→    const name = queueName ?? DEFAULT_QUEUE;\n   520→    const task = this.next(name);\n   521→    if (!task) return null;\n   522→\n   523→    const queueState = this.queues.get(name);\n   524→    const middlewares = queueState?.middleware ?? [];\n   525→    const handler = queueState?.handler;\n   526→\n   527→    try {\n   528→      await this.runMiddlewarePipeline(task, middlewares, handler);\n   529→      if (task.status === 'processing') {\n   530→        this.complete(task.id);\n   531→      }\n   532→    } catch (err) {\n   533→      if (task.status === 'processing') {\n   534→        this.fail(task.id, err instanceof Error ? err : new Error(String(err)));\n   535→      }\n   536→    }\n   537→\n   538→    return task;\n   539→  }\n   540→\n   541→  private async runMiddlewarePipeline(\n   542→    task: Task,\n   543→    middlewares: MiddlewareFn[],\n   544→    handler?: HandlerFn,\n   545→  ): Promise<void> {\n   546→    let index = 0;\n   547→    let called = false;\n   548→\n   549→    const runNext = async (): Promise<void> => {\n   550→      if (index < middlewares.length) {\n   551→        const mw = middlewares[index++];\n   552→        called = false;\n   553→        await mw(task, async () => {\n   554→          called = true;\n   555→          await runNext();\n   556→        });\n   557→        // If middleware didn't call next, processing is skipped\n   558→      } else if (handler) {\n   559→        await handler(task);\n   560→      }\n   561→    };\n   562→\n   563→    await runNext();\n   564→  }\n   565→\n   566→  // ---- Phase 12: Graceful Shutdown ----\n   567→\n   568→  onShutdown(callback: () => void | Promise<void>): void {\n   569→    this.shutdownCallbacks.push(callback);\n   570→  }\n   571→\n   572→  async shutdown(timeout = 30000): Promise<ShutdownResult> {\n   573→    if (this.shutdownPromise) {\n   574→      return this.shutdownPromise;\n   575→    }\n   576→\n   577→    this.isShutdown = true;\n   578→    this.shutdownPromise = this.performShutdown(timeout);\n   579→    return this.shutdownPromise;\n   580→  }\n   581→\n   582→  private async performShutdown(timeout: number): Promise<ShutdownResult> {\n   583→    const startTime = Date.now();\n   584→\n   585→    // Run shutdown callbacks\n   586→    for (const cb of this.shutdownCallbacks) {\n   587→      await cb();\n   588→    }\n   589→\n   590→    // Find all processing tasks\n   591→    const processingTasks: Task[] = [];\n   592→    for (const task of this.tasks.values()) {\n   593→      if (task.status === 'processing') {\n   594→        processingTasks.push(task);\n   595→      }\n   596→    }\n   597→\n   598→    let completed = 0;\n   599→    let forceCancelled = 0;\n   600→\n   601→    if (processingTasks.length === 0) {\n   602→      return {\n   603→        completed,\n   604→        forceCancelled,\n   605→        duration: Date.now() - startTime,\n   606→      };\n   607→    }\n   608→\n   609→    // Wait for processing tasks with timeout\n   610→    const waitUntil = startTime + timeout;\n   611→\n   612→    await new Promise<void>(resolve => {\n   613→      const checkInterval = setInterval(() => {\n   614→        const stillProcessing = processingTasks.filter(t => t.status === 'processing');\n   615→        if (stillProcessing.length === 0 || Date.now() >= waitUntil) {\n   616→          clearInterval(checkInterval);\n   617→          resolve();\n   618→        }\n   619→      }, 10);\n   620→    });\n   621→\n   622→    // Count results\n   623→    for (const task of processingTasks) {\n   624→      if (task.status === 'processing') {\n   625→        // Force cancel\n   626→        task.status = 'cancelled';\n   627→        const queueState = this.queues.get(task.queue);\n   628→        if (queueState) {\n   629→          queueState.activeCount = Math.max(0, queueState.activeCount - 1);\n   630→        }\n   631→        forceCancelled++;\n   632→      } else if (task.status === 'completed') {\n   633→        completed++;\n   634→      }\n   635→    }\n   636→\n   637→    return {\n   638→      completed,\n   639→      forceCancelled,\n   640→      duration: Date.now() - startTime,\n   641→    };\n   642→  }\n   643→\n   644→  get isShuttingDown(): boolean {\n   645→    return this.isShutdown;\n   646→  }\n   647→}\n   648→"}]},"parent_tool_use_id":null,"session_id":"e91e72a8-9e84-46b4-bdde-22c9ae46df0f","uuid":"ccdc1963-3b14-4698-a0be-0b2b38af8e1c","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/task-queue.ts","content":"import { randomUUID } from 'node:crypto';\nimport type {\n  Task,\n  TaskOptions,\n  TaskStatus,\n  ShutdownResult,\n  Schedule,\n  ScheduleOptions,\n  MiddlewareFn,\n  HandlerFn,\n  ProgressListener,\n} from './types.js';\n\nconst DEFAULT_QUEUE = 'default';\n\ninterface QueueState {\n  concurrency: number; // 0 means unlimited\n  activeCount: number;\n  middleware: MiddlewareFn[];\n  handler?: HandlerFn;\n}\n\nexport class TaskQueue {\n  private tasks = new Map<string, Task>();\n  private queues = new Map<string, QueueState>();\n  private dlq = new Map<string, Task[]>(); // queueName -> dead-lettered tasks\n  private schedules = new Map<string, Schedule>();\n  private progressListeners = new Map<string, Set<ProgressListener>>();\n  private isShutdown = false;\n  private shutdownPromise: Promise<ShutdownResult> | null = null;\n  private shutdownCallbacks: (() => void | Promise<void>)[] = [];\n\n  // ---- Phase 1: Basic FIFO Queue ----\n\n  add<T = unknown>(payload: T, options: TaskOptions = {}): Task<T> {\n    if (this.isShutdown) {\n      throw new Error('Queue system is shut down');\n    }\n\n    const queueName = options.queue ?? DEFAULT_QUEUE;\n\n    // Phase 3: validate priority\n    const priority = options.priority ?? 5;\n    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    }\n\n    // Phase 4: compute availability time\n    let availableAt = new Date();\n    if (options.processAt) {\n      availableAt = options.processAt;\n    } else if (options.delay != null && options.delay > 0) {\n      availableAt = new Date(Date.now() + options.delay);\n    }\n\n    // Phase 7: validate dependencies\n    const dependencies = options.dependencies ?? [];\n    for (const depId of dependencies) {\n      const depTask = this.tasks.get(depId);\n      if (!depTask) {\n        throw new Error(`Dependency task not found: ${depId}`);\n      }\n    }\n\n    // Circular dependency detection\n    if (dependencies.length > 0) {\n      const taskId = randomUUID();\n      // Check for cycles: if any dependency transitively depends on this new task\n      // Since this task doesn't exist yet, we only need to check if creating it\n      // would form a cycle. A cycle can only form if a dependency (or transitive dep)\n      // depends on this task — but since it doesn't exist yet, that's impossible.\n      // However, we need to check for existing cycles among the deps themselves.\n      // Actually, since we validate deps exist and have no cycles on creation,\n      // the only cycle would involve this new task. Since it's new, no existing task\n      // can depend on it. So no cycle is possible when adding a brand new task.\n      // We still need to use the taskId we generated.\n\n      const task = this.createTask(taskId, payload, queueName, priority, availableAt, options, dependencies);\n      this.ensureQueue(queueName);\n      this.tasks.set(taskId, task as Task);\n      return task;\n    }\n\n    const taskId = randomUUID();\n    const task = this.createTask(taskId, payload, queueName, priority, availableAt, options, dependencies);\n    this.ensureQueue(queueName);\n    this.tasks.set(taskId, task as Task);\n    return task;\n  }\n\n  private createTask<T>(\n    id: string,\n    payload: T,\n    queue: string,\n    priority: number,\n    availableAt: Date,\n    options: TaskOptions,\n    dependencies: string[],\n  ): Task<T> {\n    const resolvedDependencies = new Set<string>();\n    // Check which dependencies are already completed\n    for (const depId of dependencies) {\n      const depTask = this.tasks.get(depId);\n      if (depTask && depTask.status === 'completed') {\n        resolvedDependencies.add(depId);\n      }\n    }\n\n    return {\n      id,\n      payload,\n      status: 'pending',\n      queue,\n      priority,\n      createdAt: new Date(),\n      availableAt,\n      attempt: 0,\n      maxRetries: options.maxRetries ?? 3,\n      backoffDelay: options.backoffDelay ?? 1000,\n      progress: 0,\n      dependencies,\n      resolvedDependencies,\n    };\n  }\n\n  // ---- Phase 1: Get next task ----\n\n  next(queueName?: string): Task | null {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const queueState = this.queues.get(name);\n\n    // Phase 8: concurrency check\n    if (queueState && queueState.concurrency > 0 && queueState.activeCount >= queueState.concurrency) {\n      return null;\n    }\n\n    const now = Date.now();\n    const candidates: Task[] = [];\n\n    for (const task of this.tasks.values()) {\n      if (task.queue !== name) continue;\n      if (task.status !== 'pending') continue;\n\n      // Phase 7: check dependencies resolved\n      if (task.dependencies.length > 0) {\n        const allResolved = task.dependencies.every(depId => task.resolvedDependencies.has(depId));\n        if (!allResolved) continue;\n      }\n\n      // Phase 4: check availability\n      if (task.availableAt.getTime() > now) continue;\n\n      candidates.push(task);\n    }\n\n    if (candidates.length === 0) return null;\n\n    // Phase 3: sort by priority (lower number = higher priority), then by availableAt, then by createdAt (FIFO)\n    candidates.sort((a, b) => {\n      if (a.priority !== b.priority) return a.priority - b.priority;\n      const availDiff = a.availableAt.getTime() - b.availableAt.getTime();\n      if (availDiff !== 0) return availDiff;\n      return a.createdAt.getTime() - b.createdAt.getTime();\n    });\n\n    const task = candidates[0];\n    task.status = 'processing';\n    task.attempt += 1;\n\n    // Phase 8: track active count\n    if (queueState) {\n      queueState.activeCount++;\n    }\n\n    return task;\n  }\n\n  // ---- Phase 1: Count pending ----\n\n  pending(queueName?: string): number {\n    const name = queueName ?? DEFAULT_QUEUE;\n    let count = 0;\n    for (const task of this.tasks.values()) {\n      if (task.queue === name && task.status === 'pending') {\n        count++;\n      }\n    }\n    return count;\n  }\n\n  // ---- Phase 1: Get task by ID ----\n\n  get(taskId: string): Task | undefined {\n    return this.tasks.get(taskId);\n  }\n\n  // ---- Phase 2: Named Queues ----\n\n  private ensureQueue(name: string): QueueState {\n    let state = this.queues.get(name);\n    if (!state) {\n      state = { concurrency: 0, activeCount: 0, middleware: [], handler: undefined };\n      this.queues.set(name, state);\n    }\n    return state;\n  }\n\n  listQueues(): string[] {\n    return Array.from(this.queues.keys());\n  }\n\n  // ---- Phase 5: Complete / Fail ----\n\n  complete(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot complete task in status: ${task.status}`);\n    }\n\n    task.status = 'completed';\n    task.progress = 100;\n\n    // Phase 8: free concurrency slot\n    const queueState = this.queues.get(task.queue);\n    if (queueState) {\n      queueState.activeCount = Math.max(0, queueState.activeCount - 1);\n    }\n\n    // Phase 7: resolve dependencies\n    this.resolveDependency(taskId);\n  }\n\n  fail(taskId: string, error?: Error): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot fail task in status: ${task.status}`);\n    }\n\n    task.error = error;\n\n    // Phase 8: free concurrency slot\n    const queueState = this.queues.get(task.queue);\n    if (queueState) {\n      queueState.activeCount = Math.max(0, queueState.activeCount - 1);\n    }\n\n    // Phase 5: retry with backoff\n    if (task.attempt < task.maxRetries) {\n      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);\n      task.status = 'pending';\n      task.availableAt = new Date(Date.now() + delay);\n      task.progress = 0;\n    } else {\n      task.status = 'failed';\n      // Phase 6: move to DLQ\n      this.moveToDLQ(task);\n    }\n  }\n\n  // ---- Phase 6: Dead Letter Queue ----\n\n  private moveToDLQ(task: Task): void {\n    let dlqTasks = this.dlq.get(task.queue);\n    if (!dlqTasks) {\n      dlqTasks = [];\n      this.dlq.set(task.queue, dlqTasks);\n    }\n    dlqTasks.push(task);\n  }\n\n  getDeadLetterTasks(queueName?: string): Task[] {\n    const name = queueName ?? DEFAULT_QUEUE;\n    return this.dlq.get(name) ?? [];\n  }\n\n  replayDeadLetter(taskId: string): Task {\n    // Find and remove from DLQ\n    for (const [queueName, dlqTasks] of this.dlq.entries()) {\n      const idx = dlqTasks.findIndex(t => t.id === taskId);\n      if (idx !== -1) {\n        const task = dlqTasks.splice(idx, 1)[0];\n        // Reset for fresh retries\n        task.status = 'pending';\n        task.attempt = 0;\n        task.progress = 0;\n        task.error = undefined;\n        task.availableAt = new Date();\n        // Ensure queue exists\n        this.ensureQueue(queueName);\n        this.tasks.set(task.id, task);\n        return task;\n      }\n    }\n    throw new Error(`Dead-lettered task not found: ${taskId}`);\n  }\n\n  clearDeadLetterQueue(queueName?: string): void {\n    const name = queueName ?? DEFAULT_QUEUE;\n    this.dlq.set(name, []);\n  }\n\n  // ---- Phase 7: Task Dependencies ----\n\n  private resolveDependency(completedTaskId: string): void {\n    for (const task of this.tasks.values()) {\n      if (task.dependencies.includes(completedTaskId)) {\n        task.resolvedDependencies.add(completedTaskId);\n      }\n    }\n  }\n\n  getDependencyStatus(taskId: string): { dependencies: string[]; resolved: string[]; pending: string[] } {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    const resolved = Array.from(task.resolvedDependencies);\n    const pending = task.dependencies.filter(d => !task.resolvedDependencies.has(d));\n    return { dependencies: task.dependencies, resolved, pending };\n  }\n\n  // ---- Phase 8: Concurrency Control ----\n\n  setConcurrency(queueName: string, limit: number): void {\n    const state = this.ensureQueue(queueName);\n    state.concurrency = limit;\n  }\n\n  getConcurrency(queueName?: string): { limit: number; active: number } {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const state = this.queues.get(name);\n    if (!state) return { limit: 0, active: 0 };\n    return { limit: state.concurrency, active: state.activeCount };\n  }\n\n  // ---- Phase 9: Progress and Cancellation ----\n\n  reportProgress(taskId: string, progress: number, message?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot report progress for task in status: ${task.status}`);\n    }\n    if (progress < 0 || progress > 100) {\n      throw new Error(`Invalid progress value: ${progress}. Must be between 0 and 100.`);\n    }\n\n    task.progress = progress;\n    task.progressMessage = message;\n\n    // Notify listeners\n    const listeners = this.progressListeners.get(taskId);\n    if (listeners) {\n      for (const listener of listeners) {\n        listener(progress, message);\n      }\n    }\n  }\n\n  onProgress(taskId: