+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01Sn9gcj3jS99bAkY38UNYcv","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01HKzDnyCz5iE8qdax6xfvJm","name":"Write","input":{"file_path":"/workspace/src/task-queue.test.ts","content":"import { describe, it, expect, beforeEach } from 'vitest';\nimport { TaskQueue } from './task-queue.js';\n\ndescribe('TaskQueue', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  // ---- Phase 1: Basic FIFO Queue ----\n  describe('Phase 1: Basic FIFO Queue', () => {\n    it('should add a task and return a task object with unique id', () => {\n      const task = tq.add({ message: 'hello' });\n      expect(task.id).toBeDefined();\n      expect(typeof task.id).toBe('string');\n      expect(task.payload).toEqual({ message: 'hello' });\n      expect(task.status).toBe('pending');\n      expect(task.createdAt).toBeInstanceOf(Date);\n    });\n\n    it('should generate unique IDs for each task', () => {\n      const t1 = tq.add('a');\n      const t2 = tq.add('b');\n      expect(t1.id).not.toBe(t2.id);\n    });\n\n    it('should retrieve tasks in FIFO order', () => {\n      tq.add('first');\n      tq.add('second');\n      tq.add('third');\n\n      const t1 = tq.next();\n      expect(t1?.payload).toBe('first');\n      expect(t1?.status).toBe('processing');\n\n      const t2 = tq.next();\n      expect(t2?.payload).toBe('second');\n\n      const t3 = tq.next();\n      expect(t3?.payload).toBe('third');\n    });\n\n    it('should return null when no tasks available', () => {\n      expect(tq.next()).toBeNull();\n    });\n\n    it('should count pending tasks', () => {\n      expect(tq.pending()).toBe(0);\n      tq.add('a');\n      tq.add('b');\n      expect(tq.pending()).toBe(2);\n      tq.next();\n      expect(tq.pending()).toBe(1);\n    });\n\n    it('should get a task by ID', () => {\n      const task = tq.add('test');\n      const found = tq.get(task.id);\n      expect(found).toBeDefined();\n      expect(found?.id).toBe(task.id);\n    });\n\n    it('should return undefined for unknown task ID', () => {\n      expect(tq.get('nonexistent')).toBeUndefined();\n    });\n\n    it('should transition task to processing on next()', () => {\n      const added = tq.add('task');\n      expect(added.status).toBe('pending');\n      const retrieved = tq.next();\n      expect(retrieved?.status).toBe('processing');\n      expect(retrieved?.id).toBe(added.id);\n    });\n  });\n\n  // ---- Phase 2: Named Queues ----\n  describe('Phase 2: Named Queues', () => {\n    it('should use default queue when no name given', () => {\n      const task = tq.add('test');\n      expect(task.queue).toBe('default');\n    });\n\n    it('should support named queues independently', () => {\n      tq.add('email', { queue: 'emails' });\n      tq.add('sms', { queue: 'notifications' });\n\n      expect(tq.pending('emails')).toBe(1);\n      expect(tq.pending('notifications')).toBe(1);\n\n      const email = tq.next('emails');\n      expect(email?.payload).toBe('email');\n\n      expect(tq.next('emails')).toBeNull();\n      expect(tq.next('notifications')?.payload).toBe('sms');\n    });\n\n    it('should list all queues', () => {\n      tq.add('a', { queue: 'q1' });\n      tq.add('b', { queue: 'q2' });\n      const queues = tq.listQueues();\n      expect(queues).toContain('q1');\n      expect(queues).toContain('q2');\n    });\n\n    it('should return null from non-existent queue', () => {\n      expect(tq.next('nonexistent')).toBeNull();\n    });\n\n    it('should be backward-compatible with Phase 1 (default queue)', () => {\n      tq.add('test');\n      const task = tq.next();\n      expect(task?.payload).toBe('test');\n    });\n  });\n\n  // ---- Phase 3: Priority ----\n  describe('Phase 3: Priority', () => {\n    it('should default priority to 5', () => {\n      const task = tq.add('test');\n      expect(task.priority).toBe(5);\n    });\n\n    it('should return higher-priority tasks first', () => {\n      tq.add('low', { priority: 10 });\n      tq.add('high', { priority: 1 });\n      tq.add('medium', { priority: 5 });\n\n      expect(tq.next()?.payload).toBe('high');\n      expect(tq.next()?.payload).toBe('medium');\n      expect(tq.next()?.payload).toBe('low');\n    });\n\n    it('should maintain FIFO within same priority', () => {\n      tq.add('first', { priority: 3 });\n      tq.add('second', { priority: 3 });\n      tq.add('third', { priority: 3 });\n\n      expect(tq.next()?.payload).toBe('first');\n      expect(tq.next()?.payload).toBe('second');\n      expect(tq.next()?.payload).toBe('third');\n    });\n\n    it('should throw on invalid priority', () => {\n      expect(() => tq.add('test', { priority: 0 })).toThrow();\n      expect(() => tq.add('test', { priority: 11 })).toThrow();\n      expect(() => tq.add('test', { priority: 1.5 })).toThrow();\n    });\n\n    it('should maintain priority ordering per queue', () => {\n      tq.add('q1-low', { queue: 'q1', priority: 10 });\n      tq.add('q1-high', { queue: 'q1', priority: 1 });\n      tq.add('q2-low', { queue: 'q2', priority: 10 });\n      tq.add('q2-high', { queue: 'q2', priority: 1 });\n\n      expect(tq.next('q1')?.payload).toBe('q1-high');\n      expect(tq.next('q2')?.payload).toBe('q2-high');\n    });\n  });\n\n  // ---- Phase 4: Delayed Tasks ----\n  describe('Phase 4: Delayed Tasks', () => {\n    it('should not return delayed tasks before availability time', () => {\n      tq.add('delayed', { delay: 10000 });\n      expect(tq.next()).toBeNull();\n    });\n\n    it('should return tasks after delay has passed', () => {\n      const past = new Date(Date.now() - 1000);\n      tq.add('ready', { processAt: past });\n      const task = tq.next();\n      expect(task?.payload).toBe('ready');\n    });\n\n    it('should prefer non-delayed tasks over delayed tasks', () => {\n      tq.add('delayed', { delay: 10000 });\n      tq.add('immediate');\n      expect(tq.next()?.payload).toBe('immediate');\n    });\n\n    it('should expose availableAt on task', () => {\n      const task = tq.add('test', { delay: 5000 });\n      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now() - 100);\n    });\n\n    it('should support processAt option', () => {\n      const futureTime = new Date(Date.now() + 60000);\n      const task = tq.add('future', { processAt: futureTime });\n      expect(task.availableAt.getTime()).toBe(futureTime.getTime());\n      expect(tq.next()).toBeNull();\n    });\n  });\n\n  // ---- Phase 5: Retry with Backoff ----\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should complete a processing task', () => {\n      const task = tq.add('test');\n      tq.next();\n      tq.complete(task.id);\n      expect(task.status).toBe('completed');\n    });\n\n    it('should retry on failure with backoff', () => {\n      const task = tq.add('test', { maxRetries: 3, backoffDelay: 100 });\n      tq.next();\n      tq.fail(task.id, new Error('oops'));\n\n      expect(task.status).toBe('pending');\n      expect(task.attempt).toBe(1);\n      // Task should be delayed (not immediately available)\n      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now() - 10);\n    });\n\n    it('should use exponential backoff', () => {\n      const task = tq.add('test', { maxRetries: 3, backoffDelay: 1000 });\n\n      // Attempt 1\n      tq.next();\n      const beforeFail1 = Date.now();\n      tq.fail(task.id, new Error('fail'));\n      // backoff = 1000 * 2^0 = 1000ms\n      expect(task.availableAt.getTime()).toBeGreaterThanOrEqual(beforeFail1 + 900);\n\n      // Simulate time passing - make available now\n      task.availableAt = new Date(Date.now() - 1);\n\n      // Attempt 2\n      tq.next();\n      const beforeFail2 = Date.now();\n      tq.fail(task.id, new Error('fail'));\n      // backoff = 1000 * 2^1 = 2000ms\n      expect(task.availableAt.getTime()).toBeGreaterThanOrEqual(beforeFail2 + 1900);\n    });\n\n    it('should mark as failed when retries exhausted', () => {\n      const task = tq.add('test', { maxRetries: 1, backoffDelay: 1 });\n      tq.next();\n      tq.fail(task.id, new Error('fail'));\n      expect(task.status).toBe('failed');\n    });\n\n    it('should track attempt count', () => {\n      const task = tq.add('test', { maxRetries: 3, backoffDelay: 1 });\n      expect(task.attempt).toBe(0);\n\n      tq.next();\n      expect(task.attempt).toBe(1);\n    });\n\n    it('should default to 3 retries and 1000ms backoff', () => {\n      const task = tq.add('test');\n      expect(task.maxRetries).toBe(3);\n      expect(task.backoffDelay).toBe(1000);\n    });\n\n    it('should retain original queue and priority on retry', () => {\n      const task = tq.add('test', { queue: 'myq', priority: 2, maxRetries: 3, backoffDelay: 1 });\n      tq.next('myq');\n      tq.fail(task.id, new Error('fail'));\n      expect(task.queue).toBe('myq');\n      expect(task.priority).toBe(2);\n    });\n\n    it('should throw when completing a non-processing task', () => {\n      const task = tq.add('test');\n      expect(() => tq.complete(task.id)).toThrow();\n    });\n\n    it('should throw when failing a non-processing task', () => {\n      const task = tq.add('test');\n      expect(() => tq.fail(task.id)).toThrow();\n    });\n  });\n\n  // ---- Phase 6: Dead Letter Queue ----\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move permanently failed tasks to DLQ', () => {\n      const task = tq.add('test', { maxRetries: 1, backoffDelay: 1 });\n      tq.next();\n      tq.fail(task.id, new Error('permanent'));\n\n      const dlqTasks = tq.getDeadLetterTasks();\n      expect(dlqTasks).toHaveLength(1);\n      expect(dlqTasks[0].id).toBe(task.id);\n      expect(dlqTasks[0].error?.message).toBe('permanent');\n    });\n\n    it('should support per-queue DLQs', () => {\n      const t1 = tq.add('a', { queue: 'q1', maxRetries: 1, backoffDelay: 1 });\n      const t2 = tq.add('b', { queue: 'q2', maxRetries: 1, backoffDelay: 1 });\n\n      tq.next('q1');\n      tq.fail(t1.id, new Error('fail'));\n      tq.next('q2');\n      tq.fail(t2.id, new Error('fail'));\n\n      expect(tq.getDeadLetterTasks('q1')).toHaveLength(1);\n      expect(tq.getDeadLetterTasks('q2')).toHaveLength(1);\n    });\n\n    it('should replay a dead-lettered task', () => {\n      const task = tq.add('test', { maxRetries: 1, backoffDelay: 1 });\n      tq.next();\n      tq.fail(task.id, new Error('fail'));\n\n      const replayed = tq.replayDeadLetter(task.id);\n      expect(replayed.status).toBe('pending');\n      expect(replayed.attempt).toBe(0);\n      expect(replayed.error).toBeUndefined();\n      expect(tq.getDeadLetterTasks()).toHaveLength(0);\n    });\n\n    it('should clear dead letter queue', () => {\n      const task = tq.add('test', { maxRetries: 1, backoffDelay: 1 });\n      tq.next();\n      tq.fail(task.id, new Error('fail'));\n\n      tq.clearDeadLetterQueue();\n      expect(tq.getDeadLetterTasks()).toHaveLength(0);\n    });\n\n    it('should throw when replaying non-existent DLQ task', () => {\n      expect(() => tq.replayDeadLetter('nonexistent')).toThrow();\n    });\n  });\n\n  // ---- Phase 7: Task Dependencies ----\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block tasks with unresolved dependencies', () => {\n      const dep = tq.add('dependency');\n      tq.add('dependent', { dependencies: [dep.id] });\n\n      // The dependent should not be returned, only the dependency\n      const next = tq.next();\n      expect(next?.id).toBe(dep.id);\n\n      // No more available tasks since dependent is blocked\n      expect(tq.next()).toBeNull();\n    });\n\n    it('should unblock tasks when dependencies complete', () => {\n      const dep = tq.add('dependency');\n      const dependent = tq.add('dependent', { dependencies: [dep.id] });\n\n      tq.next(); // get dep\n      tq.complete(dep.id);\n\n      const next = tq.next();\n      expect(next?.id).toBe(dependent.id);\n    });\n\n    it('should throw when dependency does not exist', () => {\n      expect(() => tq.add('test', { dependencies: ['nonexistent'] })).toThrow();\n    });\n\n    it('should not unblock when dependency fails', () => {\n      const dep = tq.add('dependency', { maxRetries: 1, backoffDelay: 1 });\n      tq.add('dependent', { dependencies: [dep.id] });\n\n      tq.next();\n      tq.fail(dep.id, new Error('fail'));\n\n      // Dependent should still be blocked\n      expect(tq.next()).toBeNull();\n    });\n\n    it('should support multiple dependencies', () => {\n      const dep1 = tq.add('dep1');\n      const dep2 = tq.add('dep2');\n      const dependent = tq.add('test', { dependencies: [dep1.id, dep2.id] });\n\n      tq.next(); // dep1\n      tq.complete(dep1.id);\n      expect(tq.next()?.id).toBe(dep2.id); // dep2 comes next, dependent still blocked\n      expect(tq.next()).toBeNull(); // dependent blocked\n\n      tq.complete(dep2.id);\n      expect(tq.next()?.id).toBe(dependent.id); // now unblocked\n    });\n\n    it('should inspect dependency status', () => {\n      const dep1 = tq.add('dep1');\n      const dep2 = tq.add('dep2');\n      const dependent = tq.add('test', { dependencies: [dep1.id, dep2.id] });\n\n      const status = tq.getDependencyStatus(dependent.id);\n      expect(status.dependencies).toHaveLength(2);\n      expect(status.pending).toHaveLength(2);\n      expect(status.resolved).toHaveLength(0);\n\n      tq.next(); // dep1\n      tq.complete(dep1.id);\n\n      const status2 = tq.getDependencyStatus(dependent.id);\n      expect(status2.resolved).toHaveLength(1);\n      expect(status2.pending).toHaveLength(1);\n    });\n  });\n\n  // ---- Phase 8: Concurrency Control ----\n  describe('Phase 8: Concurrency Control', () => {\n    it('should limit concurrent processing tasks', () => {\n      tq.setConcurrency('default', 2);\n      tq.add('a');\n      tq.add('b');\n      tq.add('c');\n\n      expect(tq.next()).not.toBeNull();\n      expect(tq.next()).not.toBeNull();\n      expect(tq.next()).toBeNull(); // concurrency limit reached\n    });\n\n    it('should free slot when task completes', () => {\n      tq.setConcurrency('default', 1);\n      tq.add('a');\n      tq.add('b');\n\n      const t1 = tq.next()!;\n      expect(tq.next()).toBeNull();\n\n      tq.complete(t1.id);\n      expect(tq.next()).not.toBeNull();\n    });\n\n    it('should free slot when task fails', () => {\n      tq.setConcurrency('default', 1);\n      const task = tq.add('a', { maxRetries: 1, backoffDelay: 1 });\n      tq.add('b');\n\n      tq.next();\n      tq.fail(task.id, new Error('fail'));\n\n      // slot freed, b can be picked up\n      const next = tq.next();\n      expect(next?.payload).toBe('b');\n    });\n\n    it('should have unlimited concurrency by default', () => {\n      for (let i = 0; i < 100; i++) tq.add(`task-${i}`);\n      for (let i = 0; i < 100; i++) expect(tq.next()).not.toBeNull();\n    });\n\n    it('should query concurrency settings', () => {\n      tq.setConcurrency('default', 5);\n      tq.add('a');\n      tq.next();\n\n      const info = tq.getConcurrency('default');\n      expect(info.limit).toBe(5);\n      expect(info.active).toBe(1);\n    });\n  });\n\n  // ---- Phase 9: Progress and Cancellation ----\n  describe('Phase 9: Progress and Cancellation', () => {\n    it('should report progress on a processing task', () => {\n      const task = tq.add('test');\n      tq.next();\n      tq.reportProgress(task.id, 50, 'halfway');\n      expect(task.progress).toBe(50);\n      expect(task.progressMessage).toBe('halfway');\n    });\n\n    it('should notify progress listeners', () => {\n      const task = tq.add('test');\n      tq.next();\n\n      const updates: Array<[number, string | undefined]> = [];\n      tq.onProgress(task.id, (p, m) => updates.push([p, m]));\n\n      tq.reportProgress(task.id, 25, 'quarter');\n      tq.reportProgress(task.id, 75);\n\n      expect(updates).toEqual([\n        [25, 'quarter'],\n        [75, undefined],\n      ]);\n    });\n\n    it('should unsubscribe from progress', () => {\n      const task = tq.add('test');\n      tq.next();\n\n      const updates: number[] = [];\n      const unsub = tq.onProgress(task.id, (p) => updates.push(p));\n\n      tq.reportProgress(task.id, 25);\n      unsub();\n      tq.reportProgress(task.id, 75);\n\n      expect(updates).toEqual([25]);\n    });\n\n    it('should cancel a pending task', () => {\n      const task = tq.add('test');\n      tq.cancel(task.id);\n      expect(task.status).toBe('cancelled');\n      expect(tq.next()).toBeNull();\n    });\n\n    it('should cancel a processing task', () => {\n      const task = tq.add('test');\n      tq.next();\n      tq.cancel(task.id);\n      expect(task.status).toBe('cancelled');\n    });\n\n    it('should not retry cancelled tasks', () => {\n      const task = tq.add('test', { maxRetries: 3, backoffDelay: 1 });\n      tq.next();\n      tq.cancel(task.id);\n      expect(task.status).toBe('cancelled');\n      // Cannot fail a cancelled task\n      expect(() => tq.fail(task.id)).toThrow();\n    });\n\n    it('should throw on invalid progress value', () => {\n      const task = tq.add('test');\n      tq.next();\n      expect(() => tq.reportProgress(task.id, -1)).toThrow();\n      expect(() => tq.reportProgress(task.id, 101)).toThrow();\n    });\n\n    it('should throw when cancelling completed task', () => {\n      const task = tq.add('test');\n      tq.next();\n      tq.complete(task.id);\n      expect(() => tq.cancel(task.id)).toThrow();\n    });\n\n    it('should free concurrency slot on cancel processing task', () => {\n      tq.setConcurrency('default', 1);\n      tq.add('a');\n      tq.add('b');\n\n      const t1 = tq.next()!;\n      expect(tq.next()).toBeNull();\n      tq.cancel(t1.id);\n      expect(tq.next()).not.toBeNull();\n    });\n  });\n\n  // ---- Phase 10: Recurring Tasks ----\n  describe('Phase 10: Recurring Tasks', () => {\n    it('should create a schedule', () => {\n      const schedule = tq.addSchedule('*/5 * * * *', { queue: 'cron' });\n      expect(schedule.id).toBeDefined();\n      expect(schedule.cron).toBe('*/5 * * * *');\n    });\n\n    it('should list active schedules', () => {\n      tq.addSchedule('*/5 * * * *');\n      tq.addSchedule('0 * * * *');\n      expect(tq.listSchedules()).toHaveLength(2);\n    });\n\n    it('should remove a schedule', () => {\n      const s = tq.addSchedule('*/5 * * * *');\n      tq.removeSchedule(s.id);\n      expect(tq.listSchedules()).toHaveLength(0);\n    });\n\n    it('should enqueue tasks on tick when due', () => {\n      tq.addSchedule('*/5 * * * *', { payload: 'cron-task' });\n      // Tick at a time where minute % 5 === 0\n      const time = new Date(2024, 0, 1, 12, 0, 0);\n      const tasks = tq.tick(time);\n      expect(tasks).toHaveLength(1);\n      expect(tasks[0].payload).toBe('cron-task');\n    });\n\n    it('should not enqueue when not due', () => {\n      tq.addSchedule('*/5 * * * *', { payload: 'cron-task' });\n      const time = new Date(2024, 0, 1, 12, 3, 0);\n      const tasks = tq.tick(time);\n      expect(tasks).toHaveLength(0);\n    });\n\n    it('should not duplicate tasks on same minute tick', () => {\n      tq.addSchedule('*/5 * * * *', { payload: 'cron-task' });\n      const time = new Date(2024, 0, 1, 12, 0, 0);\n      tq.tick(time);\n      const tasks = tq.tick(time);\n      expect(tasks).toHaveLength(0);\n    });\n\n    it('should stop creating tasks after schedule removal', () => {\n      const s = tq.addSchedule('*/5 * * * *', { payload: 'cron-task' });\n      tq.removeSchedule(s.id);\n      const time = new Date(2024, 0, 1, 12, 0, 0);\n      const tasks = tq.tick(time);\n      expect(tasks).toHaveLength(0);\n    });\n\n    it('should match hourly schedule (0 * * * *)', () => {\n      tq.addSchedule('0 * * * *', { payload: 'hourly' });\n      // At the top of an hour\n      expect(tq.tick(new Date(2024, 0, 1, 14, 0, 0))).toHaveLength(1);\n      // Not at the top\n      expect(tq.tick(new Date(2024, 0, 1, 14, 30, 0))).toHaveLength(0);\n    });\n\n    it('should match daily schedule (0 0 * * *)', () => {\n      tq.addSchedule('0 0 * * *', { payload: 'daily' });\n      // At midnight\n      expect(tq.tick(new Date(2024, 0, 1, 0, 0, 0))).toHaveLength(1);\n      // Not at midnight\n      expect(tq.tick(new Date(2024, 0, 1, 12, 0, 0))).toHaveLength(0);\n    });\n\n    it('should throw on invalid cron', () => {\n      expect(() => tq.addSchedule('invalid')).toThrow();\n    });\n  });\n\n  // ---- Phase 11: Middleware Pipeline ----\n  describe('Phase 11: Middleware Pipeline', () => {\n    it('should run middleware and handler in order', async () => {\n      const order: string[] = [];\n      tq.use('default', async (_task, next) => {\n        order.push('mw1-before');\n        await next();\n        order.push('mw1-after');\n      });\n      tq.use('default', async (_task, next) => {\n        order.push('mw2-before');\n        await next();\n        order.push('mw2-after');\n      });\n      tq.setHandler('default', async () => {\n        order.push('handler');\n      });\n\n      tq.add('test');\n      await tq.process();\n\n      expect(order).toEqual(['mw1-before', 'mw2-before', 'handler', 'mw2-after', 'mw1-after']);\n    });\n\n    it('should skip processing if middleware does not call next', async () => {\n      const handlerCalled = { value: false };\n      tq.use('default', async () => {\n        // Deliberately not calling next\n      });\n      tq.setHandler('default', async () => {\n        handlerCalled.value = true;\n      });\n\n      tq.add('test');\n      await tq.process();\n\n      expect(handlerCalled.value).toBe(false);\n    });\n\n    it('should allow middleware to modify the task', async () => {\n      tq.use('default', async (task, next) => {\n        (task as Record<string, unknown>).metadata = 'added-by-middleware';\n        await next();\n      });\n      tq.setHandler('default', async () => {});\n\n      tq.add('test');\n      const result = await tq.process();\n      expect((result as Record<string, unknown>).metadata).toBe('added-by-middleware');\n    });\n\n    it('should fail task if middleware throws', async () => {\n      tq.use('default', async () => {\n        throw new Error('middleware error');\n      });\n\n      const task = tq.add('test', { maxRetries: 1, backoffDelay: 1 });\n      await tq.process();\n      expect(task.status).toBe('failed');\n      expect(task.error?.message).toBe('middleware error');\n    });\n\n    it('should complete task after handler without errors', async () => {\n      tq.setHandler('default', async () => {});\n      tq.add('test');\n      const result = await tq.process();\n      expect(result?.status).toBe('completed');\n    });\n\n    it('should return null when no tasks available', async () => {\n      const result = await tq.process();\n      expect(result).toBeNull();\n    });\n\n    it('should have independent middleware per queue', async () => {\n      const order: string[] = [];\n      tq.use('q1', async (_, next) => {\n        order.push('q1-mw');\n        await next();\n      });\n      tq.use('q2', async (_, next) => {\n        order.push('q2-mw');\n        await next();\n      });\n\n      tq.add('test', { queue: 'q1' });\n      tq.add('test', { queue: 'q2' });\n\n      await tq.process('q1');\n      await tq.process('q2');\n\n      expect(order).toEqual(['q1-mw', 'q2-mw']);\n    });\n  });\n\n  // ---- Phase 12: Graceful Shutdown ----\n  describe('Phase 12: Graceful Shutdown', () => {\n    it('should prevent adding tasks after shutdown', async () => {\n      await tq.shutdown();\n      expect(() => tq.add('test')).toThrow('Queue system is shut down');\n    });\n\n    it('should complete immediately when no tasks processing', async () => {\n      const result = await tq.shutdown();\n      expect(result.completed).toBe(0);\n      expect(result.forceCancelled).toBe(0);\n      expect(result.duration).toBeGreaterThanOrEqual(0);\n    });\n\n    it('should force-cancel processing tasks after timeout', async () => {\n      tq.add('slow');\n      tq.next(); // move to processing\n\n      const result = await tq.shutdown(50); // 50ms timeout\n      expect(result.forceCancelled).toBe(1);\n    });\n\n    it('should return same result on multiple shutdown calls', async () => {\n      const r1 = await tq.shutdown();\n      const r2 = await tq.shutdown();\n      expect(r1).toBe(r2);\n    });\n\n    it('should run shutdown callbacks', async () => {\n      let called = false;\n      tq.onShutdown(() => {\n        called = true;\n      });\n      await tq.shutdown();\n      expect(called).toBe(true);\n    });\n\n    it('should report isShuttingDown', async () => {\n      expect(tq.isShuttingDown).toBe(false);\n      await tq.shutdown();\n      expect(tq.isShuttingDown).toBe(true);\n    });\n\n    it('should count completed tasks during shutdown', async () => {\n      tq.add('quick');\n      const task = tq.next()!;\n\n      // Complete the task during shutdown\n      const shutdownPromise = tq.shutdown(1000);\n      tq.complete(task.id);\n      const result = await shutdownPromise;\n      expect(result.completed).toBe(1);\n      expect(result.forceCancelled).toBe(0);\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":136,"cache_read_input_tokens":42234,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":136},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"e91e72a8-9e84-46b4-bdde-22c9ae46df0f","uuid":"082e8753-6b82-4454-8da8-5c0762aa162d"}
+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HKzDnyCz5iE8qdax6xfvJm","type":"tool_result","content":"File created successfully at: /workspace/src/task-queue.test.ts"}]},"parent_tool_use_id":null,"session_id":"e91e72a8-9e84-46b4-bdde-22c9ae46df0f","uuid":"e6efcb35-4d72-4543-b073-f8f0b5b0ae85","tool_use_result":{"type":"create","filePath":"/workspace/src/task-queue.test.ts","content":"import { describe, it, expect, beforeEach } from 'vitest';\nimport { TaskQueue } from './task-queue.js';\n\ndescribe('TaskQueue', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  // ---- Phase 1: Basic FIFO Queue ----\n  describe('Phase 1: Basic FIFO Queue', () => {\n    it('should add a task and return a task object with unique id', () => {\n      const task = tq.add({ message: 'hello' });\n      expect(task.id).toBeDefined();\n      expect(typeof task.id).toBe('string');\n      expect(task.payload).toEqual({ message: 'hello' });\n      expect(task.status).toBe('pending');\n      expect(task.createdAt).toBeInstanceOf(Date);\n    });\n\n    it('should generate unique IDs for each task', () => {\n      const t1 = tq.add('a');\n      const t2 = tq.add('b');\n      expect(t1.id).not.toBe(t2.id);\n    });\n\n    it('should retrieve tasks in FIFO order', () => {\n      tq.add('first');\n      tq.add('second');\n      tq.add('third');\n\n      const t1 = tq.next();\n      expect(t1?.payload).toBe('first');\n      expect(t1?.status).toBe('processing');\n\n      const t2 = tq.next();\n      expect(t2?.payload).toBe('second');\n\n      const t3 = tq.next();\n      expect(t3?.payload).toBe('third');\n    });\n\n    it('should return null when no tasks available', () => {\n      expect(tq.next()).toBeNull();\n    });\n\n    it('should count pending tasks', () => {\n      expect(tq.pending()).toBe(0);\n      tq.add('a');\n      tq.add('b');\n      expect(tq.pending()).toBe(2);\n      tq.next();\n      expect(tq.pending()).toBe(1);\n    });\n\n    it('should get a task by ID', () => {\n      const task = tq.add('test');\n      const found = tq.get(task.id);\n      expect(found).toBeDefined();\n      expect(found?.id).toBe(task.id);\n    });\n\n    it('should return undefined for unknown task ID', () => {\n      expect(tq.get('nonexistent')).toBeUndefined();\n    });\n\n    it('should transition task to processing on next()', () => {\n      const added = tq.add('task');\n      expect(added.status).toBe('pending');\n      const retrieved = tq.next();\n      expect(retrieved?.status).toBe('processing');\n      expect(retrieved?.id).toBe(added.id);\n    });\n  });\n\n  // ---- Phase 2: Named Queues ----\n  describe('Phase 2: Named Queues', () => {\n    it('should use default queue when no name given', () => {\n      const task = tq.add('test');\n      expect(task.queue).toBe('default');\n    });\n\n    it('should support named queues independently', () => {\n      tq.add('email', { queue: 'emails' });\n      tq.add('sms', { queue: 'notifications' });\n\n      expect(tq.pending('emails')).toBe(1);\n      expect(tq.pending('notifications')).toBe(1);\n\n      const email = tq.next('emails');\n      expect(email?.payload).toBe('email');\n\n      expect(tq.next('emails')).toBeNull();\n      expect(tq.next('notifications')?.payload).toBe('sms');\n    });\n\n    it('should list all queues', () => {\n      tq.add('a', { queue: 'q1' });\n      tq.add('b', { queue: 'q2' });\n      const queues = tq.listQueues();\n      expect(queues).toContain('q1');\n      expect(queues).toContain('q2');\n    });\n\n    it('should return null from non-existent queue', () => {\n      expect(tq.next('nonexistent')).toBeNull();\n    });\n\n    it('should be backward-compatible with Phase 1 (default queue)', () => {\n      tq.add('test');\n      const task = tq.next();\n      expect(task?.payload).toBe('test');\n    });\n  });\n\n  // ---- Phase 3: Priority ----\n  describe('Phase 3: Priority', () => {\n    it('should default priority to 5', () => {\n      const task = tq.add('test');\n      expect(task.priority).toBe(5);\n    });\n\n    it('should return higher-priority tasks first', () => {\n      tq.add('low', { priority: 10 });\n      tq.add('high', { priority: 1 });\n      tq.add('medium', { priority: 5 });\n\n      expect(tq.next()?.payload).toBe('high');\n      expect(tq.next()?.payload).toBe('medium');\n      expect(tq.next()?.payload).toBe('low');\n    });\n\n    it('should maintain FIFO within same priority', () => {\n      tq.add('first', { priority: 3 });\n      tq.add('second', { priority: 3 });\n      tq.add('third', { priority: 3 });\n\n      expect(tq.next()?.payload).toBe('first');\n      expect(tq.next()?.payload).toBe('second');\n      expect(tq.next()?.payload).toBe('third');\n    });\n\n    it('should throw on invalid priority', () => {\n      expect(() => tq.add('test', { priority: 0 })).toThrow();\n      expect(() => tq.add('test', { priority: 11 })).toThrow();\n      expect(() => tq.add('test', { priority: 1.5 })).toThrow();\n    });\n\n    it('should maintain priority ordering per queue', () => {\n      tq.add('q1-low', { queue: 'q1', priority: 10 });\n      tq.add('q1-high', { queue: 'q1', priority: 1 });\n      tq.add('q2-low', { queue: 'q2', priority: 10 });\n      tq.add('q2-high', { queue: 'q2', priority: 1 });\n\n      expect(tq.next('q1')?.payload).toBe('q1-high');\n      expect(tq.next('q2')?.payload).toBe('q2-high');\n    });\n  });\n\n  // ---- Phase 4: Delayed Tasks ----\n  describe('Phase 4: Delayed Tasks', () => {\n    it('should not return delayed tasks before availability time', () => {\n      tq.add('delayed', { delay: 10000 });\n      expect(tq.next()).toBeNull();\n    });\n\n    it('should return tasks after delay has passed', () => {\n      const past = new Date(Date.now() - 1000);\n      tq.add('ready', { processAt: past });\n      const task = tq.next();\n      expect(task?.payload).toBe('ready');\n    });\n\n    it('should prefer non-delayed tasks over delayed tasks', () => {\n      tq.add('delayed', { delay: 10000 });\n      tq.add('immediate');\n      expect(tq.next()?.payload).toBe('immediate');\n    });\n\n    it('should expose availableAt on task', () => {\n      const task = tq.add('test', { delay: 5000 });\n      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now() - 100);\n    });\n\n    it('should support processAt option', () => {\n      const futureTime = new Date(Date.now() + 60000);\n      const task = tq.add('future', { processAt: futureTime });\n      expect(task.availableAt.getTime()).toBe(futureTime.getTime());\n      expect(tq.next()).toBeNull();\n    });\n  });\n\n  // ---- Phase 5: Retry with Backoff ----\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should complete a processing task', () => {\n      const task = tq.add('test');\n      tq.next();\n      tq.complete(task.id);\n      expect(task.status).toBe('completed');\n    });\n\n    it('should retry on failure with backoff', () => {\n      const task = tq.add('test', { maxRetries: 3, backoffDelay: 100 });\n      tq.next();\n      tq.fail(task.id, new Error('oops'));\n\n      expect(task.status).toBe('pending');\n      expect(task.attempt).toBe(1);\n      // Task should be delayed (not immediately available)\n      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now() - 10);\n    });\n\n    it('should use exponential backoff', () => {\n      const task = tq.add('test', { maxRetries: 3, backoffDelay: 1000 });\n\n      // Attempt 1\n      tq.next();\n      const beforeFail1 = Date.now();\n      tq.fail(task.id, new Error('fail'));\n      // backoff = 1000 * 2^0 = 1000ms\n      expect(task.availableAt.getTime()).toBeGreaterThanOrEqual(beforeFail1 + 900);\n\n      // Simulate time passing - make available now\n      task.availableAt = new Date(Date.now() - 1);\n\n      // Attempt 2\n      tq.next();\n      const beforeFail2 = Date.now();\n      tq.fail(task.id, new Error('fail'));\n      // backoff = 1000 * 2^1 = 2000ms\n      expect(task.availableAt.getTime()).toBeGreaterThanOrEqual(beforeFail2 + 1900);\n    });\n\n    it('should mark as failed when retries exhausted', () => {\n      const task = tq.add('test', { maxRetries: 1, backoffDelay: 1 });\n      tq.next();\n      tq.fail(task.id, new Error('fail'));\n      expect(task.status).toBe('failed');\n    });\n\n    it('should track attempt count', () => {\n      const task = tq.add('test', { maxRetries: 3, backoffDelay: 1 });\n      expect(task.attempt).toBe(0);\n\n      tq.next();\n      expect(task.attempt).toBe(1);\n    });\n\n    it('should default to 3 retries and 1000ms backoff', () => {\n      const task = tq.add('test');\n      expect(task.maxRetries).toBe(3);\n      expect(task.backoffDelay).toBe(1000);\n    });\n\n    it('should retain original queue and priority on retry', () => {\n      const task = tq.add('test', { queue: 'myq', priority: 2, maxRetries: 3, backoffDelay: 1 });\n      tq.next('myq');\n      tq.fail(task.id, new Error('fail'));\n      expect(task.queue).toBe('myq');\n      expect(task.priority).toBe(2);\n    });\n\n    it('should throw when completing a non-processing task', () => {\n      const task = tq.add('test');\n      expect(() => tq.complete(task.id)).toThrow();\n    });\n\n    it('should throw when failing a non-processing task', () => {\n      const task = tq.add('test');\n      expect(() => tq.fail(task.id)).toThrow();\n    });\n  });\n\n  // ---- Phase 6: Dead Letter Queue ----\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move permanently failed tasks to DLQ', () => {\n      const task = tq.add('test', { maxRetries: 1, backoffDelay: 1 });\n      tq.next();\n      tq.fail(task.id, new Error('permanent'));\n\n      const dlqTasks = tq.getDeadLetterTasks();\n      expect(dlqTasks).toHaveLength(1);\n      expect(dlqTasks[0].id).toBe(task.id);\n      expect(dlqTasks[0].error?.message).toBe('permanent');\n    });\n\n    it('should support per-queue DLQs', () => {\n      const t1 = tq.add('a', { queue: 'q1', maxRetries: 1, backoffDelay: 1 });\n      const t2 = tq.add('b', { queue: 'q2', maxRetries: 1, backoffDelay: 1 });\n\n      tq.next('q1');\n      tq.fail(t1.id, new Error('fail'));\n      tq.next('q2');\n      tq.fail(t2.id, new Error('fail'));\n\n      expect(tq.getDeadLetterTasks('q1')).toHaveLength(1);\n      expect(tq.getDeadLetterTasks('q2')).toHaveLength(1);\n    });\n\n    it('should replay a dead-lettered task', () => {\n      const task = tq.add('test', { maxRetries: 1, backoffDelay: 1 });\n      tq.next();\n      tq.fail(task.id, new Error('fail'));\n\n      const replayed = tq.replayDeadLetter(task.id);\n      expect(replayed.status).toBe('pending');\n      expect(replayed.attempt).toBe(0);\n      expect(replayed.error).toBeUndefined();\n      expect(tq.getDeadLetterTasks()).toHaveLength(0);\n    });\n\n    it('should clear dead letter queue', () => {\n      const task = tq.add('test', { maxRetries: 1, backoffDelay: 1 });\n      tq.next();\n      tq.fail(task.id, new Error('fail'));\n\n      tq.clearDeadLetterQueue();\n      expect(tq.getDeadLetterTasks()).toHaveLength(0);\n    });\n\n    it('should throw when replaying non-existent DLQ task', () => {\n      expect(() => tq.replayDeadLetter('nonexistent')).toThrow();\n    });\n  });\n\n  // ---- Phase 7: Task Dependencies ----\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block tasks with unresolved dependencies', () => {\n      const dep = tq.add('dependency');\n      tq.add('dependent', { dependencies: [dep.id] });\n\n      // The dependent should not be returned, only the dependency\n      const next = tq.next();\n      expect(next?.id).toBe(dep.id);\n\n      // No more available tasks since dependent is blocked\n      expect(tq.next()).toBeNull();\n    });\n\n    it('should unblock tasks when dependencies complete', () => {\n      const dep = tq.add('dependency');\n      const dependent = tq.add('dependent', { dependencies: [dep.id] });\n\n      tq.next(); // get dep\n      tq.complete(dep.id);\n\n      const next = tq.next();\n      expect(next?.id).toBe(dependent.id);\n    });\n\n    it('should throw when dependency does not exist', () => {\n      expect(() => tq.add('test', { dependencies: ['nonexistent'] })).toThrow();\n    });\n\n    it('should not unblock when dependency fails', () => {\n      const dep = tq.add('dependency', { maxRetries: 1, backoffDelay: 1 });\n      tq.add('dependent', { dependencies: [dep.id] });\n\n      tq.next();\n      tq.fail(dep.id, new Error('fail'));\n\n      // Dependent should still be blocked\n      expect(tq.next()).toBeNull();\n    });\n\n    it('should support multiple dependencies', () => {\n      const dep1 = tq.add('dep1');\n      const dep2 = tq.add('dep2');\n      const dependent = tq.add('test', { dependencies: [dep1.id, dep2.id] });\n\n      tq.next(); // dep1\n      tq.complete(dep1.id);\n      expect(tq.next()?.id).toBe(dep2.id); // dep2 comes next, dependent still blocked\n      expect(tq.next()).toBeNull(); // dependent blocked\n\n      tq.complete(dep2.id);\n      expect(tq.next()?.id).toBe(dependent.id); // now unblocked\n    });\n\n    it('should inspect dependency status', () => {\n      const dep1 = tq.add('dep1');\n      const dep2 = tq.add('dep2');\n      const dependent = tq.add('test', { dependencies: [dep1.id, dep2.id] });\n\n      const status = tq.getDependencyStatus(dependent.id);\n      expect(status.dependencies).toHaveLength(2);\n      expect(status.pending).toHaveLength(2);\n      expect(status.resolved).toHaveLength(0);\n\n      tq.next(); // dep1\n      tq.complete(dep1.id);\n\n      const status2 = tq.getDependencyStatus(dependent.id);\n      expect(status2.resolved).toHaveLength(1);\n      expect(status2.pending).toHaveLength(1);\n    });\n  });\n\n  // ---- Phase 8: Concurrency Control ----\n  describe('Phase 8: Concurrency Control', () => {\n    it('should limit concurrent processing tasks', () => {\n      tq.setConcurrency('default', 2);\n      tq.add('a');\n      tq.add('b');\n      tq.add('c');\n\n      expect(tq.next()).not.toBeNull();\n      expect(tq.next()).not.toBeNull();\n      expect(tq.next()).toBeNull(); // concurrency limit reached\n    });\n\n    it('should free slot when task completes', () => {\n      tq.setConcurrency('default', 1);\n      tq.add('a');\n      tq.add('b');\n\n      const t1 = tq.next()!;\n      expect(tq.next()).toBeNull();\n\n      tq.complete(t1.id);\n      expect(tq.next()).not.toBeNull();\n    });\n\n    it('should free slot when task fails', () => {\n      tq.setConcurrency('default', 1);\n      const task = tq.add('a', { maxRetries: 1, backoffDelay: 1 });\n      tq.add('b');\n\n      tq.next();\n      tq.fail(task.id, new Error('fail'));\n\n      // slot freed, b can be picked up\n      const next = tq.next();\n      expect(next?.payload).toBe('b');\n    });\n\n    it('should have unlimited concurrency by default', () => {\n      for (let i = 0; i < 100; i++) tq.add(`task-${i}`);\n      for (let i = 0; i < 100; i++) expect(tq.next()).not.toBeNull();\n    });\n\n    it('should query concurrency settings', () => {\n      tq.setConcurrency('default', 5);\n      tq.add('a');\n      tq.next();\n\n      const info = tq.getConcurrency('default');\n      expect(info.limit).toBe(5);\n      expect(info.active).toBe(1);\n    });\n  });\n\n  // ---- Phase 9: Progress and Cancellation ----\n  describe('Phase 9: Progress and Cancellation', () => {\n    it('should report progress on a processing task', () => {\n      const task = tq.add('test');\n      tq.next();\n      tq.reportProgress(task.id, 50, 'halfway');\n      expect(task.progress).toBe(50);\n      expect(task.progressMessage).toBe('halfway');\n    });\n\n    it('should notify progress listeners', () => {\n      const task = tq.add('test');\n      tq.next();\n\n      const updates: Array<[number, string | undefined]> = [];\n      tq.onProgress(task.id, (p, m) => updates.push([p, m]));\n\n      tq.reportProgress(task.id, 25, 'quarter');\n      tq.reportProgress(task.id, 75);\n\n      expect(updates).toEqual([\n        [25, 'quarter'],\n        [75, undefined],\n      ]);\n    });\n\n    it('should unsubscribe from progress', () => {\n      const task = tq.add('test');\n      tq.next();\n\n      const updates: number[] = [];\n      const unsub = tq.onProgress(task.id, (p) => updates.push(p));\n\n      tq.reportProgress(task.id, 25);\n      unsub();\n      tq.reportProgress(task.id, 75);\n\n      expect(updates).toEqual([25]);\n    });\n\n    it('should cancel a pending task', () => {\n      const task = tq.add('test');\n      tq.cancel(task.id);\n      expect(task.status).toBe('cancelled');\n      expect(tq.next()).toBeNull();\n    });\n\n    it('should cancel a processing task', () => {\n      const task = tq.add('test');\n      tq.next();\n      tq.cancel(task.id);\n      expect(task.status).toBe('cancelled');\n    });\n\n    it('should not retry cancelled tasks', () => {\n      const task = tq.add('test', { maxRetries: 3, backoffDelay: 1 });\n      tq.next();\n      tq.cancel(task.id);\n      expect(task.status).toBe('cancelled');\n      // Cannot fail a cancelled task\n      expect(() => tq.fail(task.id)).toThrow();\n    });\n\n    it('should throw on invalid progress value', () => {\n      const task = tq.add('test');\n      tq.next();\n      expect(() => tq.reportProgress(task.id, -1)).toThrow();\n      expect(() => tq.reportProgress(task.id, 101)).toThrow();\n    });\n\n    it('should throw when cancelling completed task', () => {\n      const task = tq.add('test');\n      tq.next();\n      tq.complete(task.id);\n      expect(() => tq.cancel(task.id)).toThrow();\n    });\n\n    it('should free concurrency slot on cancel processing task', () => {\n      tq.setConcurrency('default', 1);\n      tq.add('a');\n      tq.add('b');\n\n      const t1 = tq.next()!;\n      expect(tq.next()).toBeNull();\n      tq.cancel(t1.id);\n      expect(tq.next()).not.toBeNull();\n    });\n  });\n\n  // ---- Phase 10: Recurring Tasks ----\n  describe('Phase 10: Recurring Tasks', () => {\n    it('should create a schedule', () => {\n      const schedule = tq.addSchedule('*/5 * * * *', { queue: 'cron' });\n      expect(schedule.id).toBeDefined();\n      expect(schedule.cron).toBe('*/5 * * * *');\n    });\n\n    it('should list active schedules', () => {\n      tq.addSchedule('*/5 * * * *');\n      tq.addSchedule('0 * * * *');\n      expect(tq.listSchedules()).toHaveLength(2);\n    });\n\n    it('should remove a schedule', () => {\n      const s = tq.addSchedule('*/5 * * * *');\n      tq.removeSchedule(s.id);\n      expect(tq.listSchedules()).toHaveLength(0);\n    });\n\n    it('should enqueue tasks on tick when due', () => {\n      tq.addSchedule('*/5 * * * *', { payload: 'cron-task' });\n      // Tick at a time where minute % 5 === 0\n      const time = new Date(2024, 0, 1, 12, 0, 0);\n      const tasks = tq.tick(time);\n      expect(tasks).toHaveLength(1);\n      expect(tasks[0].payload).toBe('cron-task');\n    });\n\n    it('should not enqueue when not due', () => {\n      tq.addSchedule('*/5 * * * *', { payload: 'cron-task' });\n      const time = new Date(2024, 0, 1, 12, 3, 0);\n      const tasks = tq.tick(time);\n      expect(tasks).toHaveLength(0);\n    });\n\n    it('should not duplicate tasks on same minute tick', () => {\n      tq.addSchedule('*/5 * * * *', { payload: 'cron-task' });\n      const time = new Date(2024, 0, 1, 12, 0, 0);\n      tq.tick(time);\n      const tasks = tq.tick(time);\n      expect(tasks).toHaveLength(0);\n    });\n\n    it('should stop creating tasks after schedule removal', () => {\n      const s = tq.addSchedule('*/5 * * * *', { payload: 'cron-task' });\n      tq.removeSchedule(s.id);\n      const time = new Date(2024, 0, 1, 12, 0, 0);\n      const tasks = tq.tick(time);\n      expect(tasks).toHaveLength(0);\n    });\n\n    it('should match hourly schedule (0 * * * *)', () => {\n      tq.addSchedule('0 * * * *', { payload: 'hourly' });\n      // At the top of an hour\n      expect(tq.tick(new Date(2024, 0, 1, 14, 0, 0))).toHaveLength(1);\n      // Not at the top\n      expect(tq.tick(new Date(2024, 0, 1, 14, 30, 0))).toHaveLength(0);\n    });\n\n    it('should match daily schedule (0 0 * * *)', () => {\n      tq.addSchedule('0 0 * * *', { payload: 'daily' });\n      // At midnight\n      expect(tq.tick(new Date(2024, 0, 1, 0, 0, 0))).toHaveLength(1);\n      // Not at midnight\n      expect(tq.tick(new Date(2024, 0, 1, 12, 0, 0))).toHaveLength(0);\n    });\n\n    it('should throw on invalid cron', () => {\n      expect(() => tq.addSchedule('invalid')).toThrow();\n    });\n  });\n\n  // ---- Phase 11: Middleware Pipeline ----\n  describe('Phase 11: Middleware Pipeline', () => {\n    it('should run middleware and handler in order', async () => {\n      const order: string[] = [];\n      tq.use('default', async (_task, next) => {\n        order.push('mw1-before');\n        await next();\n        order.push('mw1-after');\n      });\n      tq.use('default', async (_task, next) => {\n        order.push('mw2-before');\n        await next();\n        order.push('mw2-after');\n      });\n      tq.setHandler('default', async () => {\n        order.push('handler');\n      });\n\n      tq.add('test');\n      await tq.process();\n\n      expect(order).toEqual(['mw1-before', 'mw2-before', 'handler', 'mw2-after', 'mw1-after']);\n    });\n\n    it('should skip processing if middleware does not call next', async () => {\n      const handlerCalled = { value: false };\n      tq.use('default', async () => {\n        // Deliberately not calling next\n      });\n      tq.setHandler('default', async () => {\n        handlerCalled.value = true;\n      });\n\n      tq.add('test');\n      await tq.process();\n\n      expect(handlerCalled.value).toBe(false);\n    });\n\n    it('should allow middleware to modify the task', async () => {\n      tq.use('default', async (task, next) => {\n        (task as Record<string, unknown>).metadata = 'added-by-middleware';\n        await next();\n      });\n      tq.setHandler('default', async () => {});\n\n      tq.add('test');\n      const result = await tq.process();\n      expect((result as Record<string, unknown>).metadata).toBe('added-by-middleware');\n    });\n\n    it('should fail task if middleware throws', async () => {\n      tq.use('default', async () => {\n        throw new Error('middleware error');\n      });\n\n      const task = tq.add('test', { maxRetries: 1, backoffDelay: 1 });\n      await tq.process();\n      expect(task.status).toBe('failed');\n      expect(task.error?.message).toBe('middleware error');\n    });\n\n    it('should complete task after handler without errors', async () => {\n      tq.setHandler('default', async () => {});\n      tq.add('test');\n      const result = await tq.process();\n      expect(result?.status).toBe('completed');\n    });\n\n    it('should return null when no tasks available', async () => {\n      const result = await tq.process();\n      expect(result).toBeNull();\n    });\n\n    it('should have independent middleware per queue', async () => {\n      const order: string[] = [];\n      tq.use('q1', async (_, next) => {\n        order.push('q1-mw');\n        await next();\n      });\n      tq.use('q2', async (_, next) => {\n        order.push('q2-mw');\n        await next();\n      });\n\n      tq.add('test', { queue: 'q1' });\n      tq.add('test', { queue: 'q2' });\n\n      await tq.process('q1');\n      await tq.process('q2');\n\n      expect(order).toEqual(['q1-mw', 'q2-mw']);\n    });\n  });\n\n  // ---- Phase 12: Graceful Shutdown ----\n  describe('Phase 12: Graceful Shutdown', () => {\n    it('should prevent adding tasks after shutdown', async () => {\n      await tq.shutdown();\n      expect(() => tq.add('test')).toThrow('Queue system is shut down');\n    });\n\n    it('should complete immediately when no tasks processing', async () => {\n      const result = await tq.shutdown();\n      expect(result.completed).toBe(0);\n      expect(result.forceCancelled).toBe(0);\n      expect(result.duration).toBeGreaterThanOrEqual(0);\n    });\n\n    it('should force-cancel processing tasks after timeout', async () => {\n      tq.add('slow');\n      tq.next(); // move to processing\n\n      const result = await tq.shutdown(50); // 50ms timeout\n      expect(result.forceCancelled).toBe(1);\n    });\n\n    it('should return same result on multiple shutdown calls', async () => {\n      const r1 = await tq.shutdown();\n      const r2 = await tq.shutdown();\n      expect(r1).toBe(r2);\n    });\n\n    it('should run shutdown callbacks', async () => {\n      let called = false;\n      tq.onShutdown(() => {\n        called = true;\n      });\n      await tq.shutdown();\n      expect(called).toBe(true);\n    });\n\n    it('should report isShuttingDown', async () => {\n      expect(tq.isShuttingDown).toBe(false);\n      await tq.shutdown();\n      expect(tq.isShuttingDown).toBe(true);\n    });\n\n    it('should count completed tasks during shutdown', async () => {\n      tq.add('quick');\n      const task = tq.next()!;\n\n      // Complete the task during shutdown\n      const shutdownPromise = tq.shutdown(1000);\n      tq.complete(task.id);\n      const result = await shutdownPromise;\n      expect(result.completed).toBe(1);\n      expect(result.forceCancelled).toBe(0);\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
