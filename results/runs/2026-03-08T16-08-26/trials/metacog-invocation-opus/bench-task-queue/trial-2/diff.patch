+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from './task-queue.js';
+
+describe('TaskQueue', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  // ---- Phase 1: Basic FIFO Queue ----
+  describe('Phase 1: Basic FIFO Queue', () => {
+    it('should add a task and return a task object with unique id', () => {
+      const task = tq.add({ message: 'hello' });
+      expect(task.id).toBeDefined();
+      expect(typeof task.id).toBe('string');
+      expect(task.payload).toEqual({ message: 'hello' });
+      expect(task.status).toBe('pending');
+      expect(task.createdAt).toBeInstanceOf(Date);
+    });
+
+    it('should generate unique IDs for each task', () => {
+      const t1 = tq.add('a');
+      const t2 = tq.add('b');
+      expect(t1.id).not.toBe(t2.id);
+    });
+
+    it('should retrieve tasks in FIFO order', () => {
+      tq.add('first');
+      tq.add('second');
+      tq.add('third');
+
+      const t1 = tq.next();
+      expect(t1?.payload).toBe('first');
+      expect(t1?.status).toBe('processing');
+
+      const t2 = tq.next();
+      expect(t2?.payload).toBe('second');
+
+      const t3 = tq.next();
+      expect(t3?.payload).toBe('third');
+    });
+
+    it('should return null when no tasks available', () => {
+      expect(tq.next()).toBeNull();
+    });
+
+    it('should count pending tasks', () => {
+      expect(tq.pending()).toBe(0);
+      tq.add('a');
+      tq.add('b');
+      expect(tq.pending()).toBe(2);
+      tq.next();
+      expect(tq.pending()).toBe(1);
+    });
+
+    it('should get a task by ID', () => {
+      const task = tq.add('test');
+      const found = tq.get(task.id);
+      expect(found).toBeDefined();
+      expect(found?.id).toBe(task.id);
+    });
+
+    it('should return undefined for unknown task ID', () => {
+      expect(tq.get('nonexistent')).toBeUndefined();
+    });
+
+    it('should transition task to processing on next()', () => {
+      const added = tq.add('task');
+      expect(added.status).toBe('pending');
+      const retrieved = tq.next();
+      expect(retrieved?.status).toBe('processing');
+      expect(retrieved?.id).toBe(added.id);
+    });
+  });
+
+  // ---- Phase 2: Named Queues ----
+  describe('Phase 2: Named Queues', () => {
+    it('should use default queue when no name given', () => {
+      const task = tq.add('test');
+      expect(task.queue).toBe('default');
+    });
+
+    it('should support named queues independently', () => {
+      tq.add('email', { queue: 'emails' });
+      tq.add('sms', { queue: 'notifications' });
+
+      expect(tq.pending('emails')).toBe(1);
+      expect(tq.pending('notifications')).toBe(1);
+
+      const email = tq.next('emails');
+      expect(email?.payload).toBe('email');
+
+      expect(tq.next('emails')).toBeNull();
+      expect(tq.next('notifications')?.payload).toBe('sms');
+    });
+
+    it('should list all queues', () => {
+      tq.add('a', { queue: 'q1' });
+      tq.add('b', { queue: 'q2' });
+      const queues = tq.listQueues();
+      expect(queues).toContain('q1');
+      expect(queues).toContain('q2');
+    });
+
+    it('should return null from non-existent queue', () => {
+      expect(tq.next('nonexistent')).toBeNull();
+    });
+
+    it('should be backward-compatible with Phase 1 (default queue)', () => {
+      tq.add('test');
+      const task = tq.next();
+      expect(task?.payload).toBe('test');
+    });
+  });
+
+  // ---- Phase 3: Priority ----
