+import { randomUUID } from 'node:crypto';
+import type {
+  Task,
+  TaskOptions,
+  ShutdownResult,
+  Schedule,
+  ScheduleOptions,
+  MiddlewareFn,
+  HandlerFn,
+  ProgressListener,
+} from './types.js';
+
+const DEFAULT_QUEUE = 'default';
+
+interface QueueState {
+  concurrency: number; // 0 means unlimited
+  activeCount: number;
+  middleware: MiddlewareFn[];
+  handler?: HandlerFn;
+}
+
+export class TaskQueue {
+  private tasks = new Map<string, Task>();
+  private queues = new Map<string, QueueState>();
+  private dlq = new Map<string, Task[]>(); // queueName -> dead-lettered tasks
+  private schedules = new Map<string, Schedule>();
+  private progressListeners = new Map<string, Set<ProgressListener>>();
+  private isShutdown = false;
+  private shutdownPromise: Promise<ShutdownResult> | null = null;
+  private shutdownCallbacks: (() => void | Promise<void>)[] = [];
+
+  // ---- Phase 1: Basic FIFO Queue ----
+
+  add<T = unknown>(payload: T, options: TaskOptions = {}): Task<T> {
+    if (this.isShutdown) {
+      throw new Error('Queue system is shut down');
+    }
+
+    const queueName = options.queue ?? DEFAULT_QUEUE;
+
+    // Phase 3: validate priority
+    const priority = options.priority ?? 5;
+    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {
+      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);
+    }
+
+    // Phase 4: compute availability time
+    let availableAt = new Date();
+    if (options.processAt) {
+      availableAt = options.processAt;
+    } else if (options.delay != null && options.delay > 0) {
+      availableAt = new Date(Date.now() + options.delay);
+    }
+
+    // Phase 7: validate dependencies
+    const dependencies = options.dependencies ?? [];
+    for (const depId of dependencies) {
+      const depTask = this.tasks.get(depId);
+      if (!depTask) {
+        throw new Error(`Dependency task not found: ${depId}`);
+      }
+    }
+
+    // Circular dependency detection
+    if (dependencies.length > 0) {
+      const taskId = randomUUID();
+      // Check for cycles: if any dependency transitively depends on this new task
+      // Since this task doesn't exist yet, we only need to check if creating it
+      // would form a cycle. A cycle can only form if a dependency (or transitive dep)
+      // depends on this task — but since it doesn't exist yet, that's impossible.
+      // However, we need to check for existing cycles among the deps themselves.
+      // Actually, since we validate deps exist and have no cycles on creation,
+      // the only cycle would involve this new task. Since it's new, no existing task
+      // can depend on it. So no cycle is possible when adding a brand new task.
+      // We still need to use the taskId we generated.
+
+      const task = this.createTask(taskId, payload, queueName, priority, availableAt, options, dependencies);
+      this.ensureQueue(queueName);
+      this.tasks.set(taskId, task as Task);
+      return task;
+    }
+
+    const taskId = randomUUID();
+    const task = this.createTask(taskId, payload, queueName, priority, availableAt, options, dependencies);
+    this.ensureQueue(queueName);
+    this.tasks.set(taskId, task as Task);
+    return task;
+  }
+
+  private createTask<T>(
+    id: string,
+    payload: T,
+    queue: string,
+    priority: number,
+    availableAt: Date,
+    options: TaskOptions,
+    dependencies: string[],
+  ): Task<T> {
+    const resolvedDependencies = new Set<string>();
+    // Check which dependencies are already completed
+    for (const depId of dependencies) {
+      const depTask = this.tasks.get(depId);
+      if (depTask && depTask.status === 'completed') {
+        resolvedDependencies.add(depId);
+      }
+    }
+
+    return {
+      id,
+      payload,
+      status: 'pending',
+      queue,
+      priority,
+      createdAt: new Date(),
+      availableAt,
+      attempt: 0,
+      maxRetries: options.maxRetries ?? 3,
+      backoffDelay: options.backoffDelay ?? 1000,
+      progress: 0,
+      dependencies,
+      resolvedDependencies,
+    };
+  }
+
+  // ---- Phase 1: Get next task ----
+
+  next(queueName?: string): Task | null {
+    const name = queueName ?? DEFAULT_QUEUE;
+    const queueState = this.queues.get(name);
+
+    // Phase 8: concurrency check
+    if (queueState && queueState.concurrency > 0 && queueState.activeCount >= queueState.concurrency) {
+      return null;
+    }
+
+    const now = Date.now();
+    const candidates: Task[] = [];
+
+    for (const task of this.tasks.values()) {
+      if (task.queue !== name) continue;
+      if (task.status !== 'pending') continue;
+
+      // Phase 7: check dependencies resolved
+      if (task.dependencies.length > 0) {
+        const allResolved = task.dependencies.every(depId => task.resolvedDependencies.has(depId));
+        if (!allResolved) continue;
+      }
+
+      // Phase 4: check availability
+      if (task.availableAt.getTime() > now) continue;
+
+      candidates.push(task);
+    }
+
+    if (candidates.length === 0) return null;
+
+    // Phase 3: sort by priority (lower number = higher priority), then by availableAt, then by createdAt (FIFO)
+    candidates.sort((a, b) => {
+      if (a.priority !== b.priority) return a.priority - b.priority;
+      const availDiff = a.availableAt.getTime() - b.availableAt.getTime();
+      if (availDiff !== 0) return availDiff;
+      return a.createdAt.getTime() - b.createdAt.getTime();
+    });
+
+    const task = candidates[0];
+    task.status = 'processing';
+    task.attempt += 1;
+
+    // Phase 8: track active count
+    if (queueState) {
+      queueState.activeCount++;
+    }
+
+    return task;
+  }
+
+  // ---- Phase 1: Count pending ----
+
+  pending(queueName?: string): number {
+    const name = queueName ?? DEFAULT_QUEUE;
+    let count = 0;
+    for (const task of this.tasks.values()) {
+      if (task.queue === name && task.status === 'pending') {
+        count++;
+      }
+    }
+    return count;
+  }
+
+  // ---- Phase 1: Get task by ID ----
+
+  get(taskId: string): Task | undefined {
+    return this.tasks.get(taskId);
+  }
+
+  // ---- Phase 2: Named Queues ----
+
+  private ensureQueue(name: string): QueueState {
+    let state = this.queues.get(name);
+    if (!state) {
+      state = { concurrency: 0, activeCount: 0, middleware: [], handler: undefined };
+      this.queues.set(name, state);
+    }
+    return state;
+  }
+
+  listQueues(): string[] {
+    return Array.from(this.queues.keys());
+  }
+
+  // ---- Phase 5: Complete / Fail ----
+
+  complete(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot complete task in status: ${task.status}`);
+    }
+
+    task.status = 'completed';
+    task.progress = 100;
+
+    // Phase 8: free concurrency slot
+    const queueState = this.queues.get(task.queue);
+    if (queueState) {
+      queueState.activeCount = Math.max(0, queueState.activeCount - 1);
+    }
+
+    // Phase 7: resolve dependencies
+    this.resolveDependency(taskId);
+  }
+
+  fail(taskId: string, error?: Error): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot fail task in status: ${task.status}`);
+    }
+
+    task.error = error;
+
+    // Phase 8: free concurrency slot
+    const queueState = this.queues.get(task.queue);
+    if (queueState) {
+      queueState.activeCount = Math.max(0, queueState.activeCount - 1);
+    }
+
+    // Phase 5: retry with backoff
+    if (task.attempt < task.maxRetries) {
+      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);
+      task.status = 'pending';
+      task.availableAt = new Date(Date.now() + delay);
+      task.progress = 0;
+    } else {
+      task.status = 'failed';
+      // Phase 6: move to DLQ
+      this.moveToDLQ(task);
+    }
+  }
+
+  // ---- Phase 6: Dead Letter Queue ----
+
+  private moveToDLQ(task: Task): void {
+    let dlqTasks = this.dlq.get(task.queue);
+    if (!dlqTasks) {
+      dlqTasks = [];
+      this.dlq.set(task.queue, dlqTasks);
+    }
+    dlqTasks.push(task);
+  }
+
+  getDeadLetterTasks(queueName?: string): Task[] {
+    const name = queueName ?? DEFAULT_QUEUE;
+    return this.dlq.get(name) ?? [];
+  }
+
+  replayDeadLetter(taskId: string): Task {
+    // Find and remove from DLQ
+    for (const [queueName, dlqTasks] of this.dlq.entries()) {
+      const idx = dlqTasks.findIndex(t => t.id === taskId);
+      if (idx !== -1) {
+        const task = dlqTasks.splice(idx, 1)[0];
+        // Reset for fresh retries
+        task.status = 'pending';
+        task.attempt = 0;
+        task.progress = 0;
+        task.error = undefined;
+        task.availableAt = new Date();
+        // Ensure queue exists
+        this.ensureQueue(queueName);
+        this.tasks.set(task.id, task);
+        return task;
+      }
+    }
+    throw new Error(`Dead-lettered task not found: ${taskId}`);
+  }
+
+  clearDeadLetterQueue(queueName?: string): void {
+    const name = queueName ?? DEFAULT_QUEUE;
+    this.dlq.set(name, []);
+  }
+
+  // ---- Phase 7: Task Dependencies ----
+
+  private resolveDependency(completedTaskId: string): void {
+    for (const task of this.tasks.values()) {
+      if (task.dependencies.includes(completedTaskId)) {
+        task.resolvedDependencies.add(completedTaskId);
+      }
+    }
+  }
+
+  getDependencyStatus(taskId: string): { dependencies: string[]; resolved: string[]; pending: string[] } {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    const resolved = Array.from(task.resolvedDependencies);
+    const pending = task.dependencies.filter(d => !task.resolvedDependencies.has(d));
+    return { dependencies: task.dependencies, resolved, pending };
+  }
+
+  // ---- Phase 8: Concurrency Control ----
+
+  setConcurrency(queueName: string, limit: number): void {
+    const state = this.ensureQueue(queueName);
+    state.concurrency = limit;
+  }
+
+  getConcurrency(queueName?: string): { limit: number; active: number } {
+    const name = queueName ?? DEFAULT_QUEUE;
+    const state = this.queues.get(name);
+    if (!state) return { limit: 0, active: 0 };
+    return { limit: state.concurrency, active: state.activeCount };
+  }
+
+  // ---- Phase 9: Progress and Cancellation ----
+
+  reportProgress(taskId: string, progress: number, message?: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot report progress for task in status: ${task.status}`);
+    }
+    if (progress < 0 || progress > 100) {
+      throw new Error(`Invalid progress value: ${progress}. Must be between 0 and 100.`);
+    }
+
+    task.progress = progress;
+    task.progressMessage = message;
+
+    // Notify listeners
+    const listeners = this.progressListeners.get(taskId);
+    if (listeners) {
+      for (const listener of listeners) {
+        listener(progress, message);
+      }
+    }
+  }
+
+  onProgress(taskId: string, listener: ProgressListener): () => void {
+    let listeners = this.progressListeners.get(taskId);
+    if (!listeners) {
+      listeners = new Set();
+      this.progressListeners.set(taskId, listeners);
+    }
+    listeners.add(listener);
+
+    // Return unsubscribe function
+    return () => {
+      listeners!.delete(listener);
+      if (listeners!.size === 0) {
+        this.progressListeners.delete(taskId);
+      }
+    };
+  }
+
+  cancel(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'pending' && task.status !== 'processing') {
+      throw new Error(`Cannot cancel task in status: ${task.status}`);
+    }
+
+    const wasProcessing = task.status === 'processing';
+    task.status = 'cancelled';
+    // Prevent retries
+    task.maxRetries = 0;
+
+    // Phase 8: free concurrency slot if was processing
+    if (wasProcessing) {
+      const queueState = this.queues.get(task.queue);
+      if (queueState) {
+        queueState.activeCount = Math.max(0, queueState.activeCount - 1);
+      }
+    }
+  }
+
+  // ---- Phase 10: Recurring Tasks ----
+
+  addSchedule(cron: string, options: ScheduleOptions = {}): Schedule {
+    if (this.isShutdown) {
+      throw new Error('Queue system is shut down');
+    }
+
+    this.validateCron(cron);
+
+    const schedule: Schedule = {
+      id: options.id ?? randomUUID(),
+      cron,
+      queue: options.queue ?? DEFAULT_QUEUE,
+      payload: options.payload,
+      options: {
+        priority: options.priority,
+        maxRetries: options.maxRetries,
+        backoffDelay: options.backoffDelay,
+      },
+    };
+
+    this.schedules.set(schedule.id, schedule);
+    return schedule;
+  }
+
+  removeSchedule(scheduleId: string): void {
+    if (!this.schedules.has(scheduleId)) {
+      throw new Error(`Schedule not found: ${scheduleId}`);
+    }
+    this.schedules.delete(scheduleId);
+  }
+
+  listSchedules(): Schedule[] {
+    return Array.from(this.schedules.values());
+  }
+
+  tick(now?: Date): Task[] {
+    const currentTime = now ?? new Date();
+    const enqueued: Task[] = [];
+
+    for (const schedule of this.schedules.values()) {
+      if (this.shouldRunSchedule(schedule, currentTime)) {
+        const task = this.add(schedule.payload, {
+          queue: schedule.queue,
+          priority: schedule.options.priority,
+          maxRetries: schedule.options.maxRetries,
+          backoffDelay: schedule.options.backoffDelay,
+        });
+        enqueued.push(task as Task);
+        schedule.lastRun = currentTime;
+      }
+    }
+
+    return enqueued;
+  }
+
+  private validateCron(cron: string): void {
+    const parts = cron.trim().split(/\s+/);
+    if (parts.length !== 5) {
+      throw new Error(`Invalid cron expression: ${cron}. Must have exactly 5 fields.`);
+    }
+    // Basic validation for our supported subset
+    const [minute, hour] = parts;
+    const validMinute = minute === '*' || /^\d+$/.test(minute) || /^\*\/\d+$/.test(minute);
+    const validHour = hour === '*' || /^\d+$/.test(hour) || /^\*\/\d+$/.test(hour);
+    if (!validMinute || !validHour) {
+      throw new Error(`Invalid cron expression: ${cron}`);
+    }
+  }
+
+  private shouldRunSchedule(schedule: Schedule, now: Date): boolean {
+    const parts = schedule.cron.trim().split(/\s+/);
+    const [minuteField, hourField] = parts;
+
+    const currentMinute = now.getMinutes();
+    const currentHour = now.getHours();
+
+    // Check minute field
+    if (!this.matchCronField(minuteField, currentMinute)) return false;
+    // Check hour field
+    if (!this.matchCronField(hourField, currentHour)) return false;
+
+    // Avoid running the same schedule multiple times in the same minute
+    if (schedule.lastRun) {
+      const lastMinute = schedule.lastRun.getMinutes();
+      const lastHour = schedule.lastRun.getHours();
+      const lastDate = schedule.lastRun.toDateString();
+      const nowDate = now.toDateString();
+      if (lastMinute === currentMinute && lastHour === currentHour && lastDate === nowDate) {
+        return false;
+      }
+    }
+
+    return true;
+  }
+
+  private matchCronField(field: string, value: number): boolean {
+    if (field === '*') return true;
+    if (/^\*\/(\d+)$/.test(field)) {
+      const interval = parseInt(field.slice(2), 10);
+      return value % interval === 0;
+    }
+    if (/^\d+$/.test(field)) {
+      return parseInt(field, 10) === value;
+    }
+    return false;
+  }
+
+  // ---- Phase 11: Middleware ----
+
+  use(queueName: string, middleware: MiddlewareFn): void {
+    const state = this.ensureQueue(queueName);
+    state.middleware.push(middleware);
+  }
+
+  setHandler(queueName: string, handler: HandlerFn): void {
+    const state = this.ensureQueue(queueName);
+    state.handler = handler;
+  }
+
+  async process(queueName?: string): Promise<Task | null> {
+    const name = queueName ?? DEFAULT_QUEUE;
+    const task = this.next(name);
+    if (!task) return null;
+
+    const queueState = this.queues.get(name);
+    const middlewares = queueState?.middleware ?? [];
+    const handler = queueState?.handler;
+
+    try {
+      await this.runMiddlewarePipeline(task, middlewares, handler);
+      if (task.status === 'processing') {
+        this.complete(task.id);
+      }
+    } catch (err) {
+      if (task.status === 'processing') {
+        this.fail(task.id, err instanceof Error ? err : new Error(String(err)));
+      }
+    }
+
+    return task;
+  }
+
+  private async runMiddlewarePipeline(
+    task: Task,
+    middlewares: MiddlewareFn[],
+    handler?: HandlerFn,
+  ): Promise<void> {
+    let index = 0;
+
+    const runNext = async (): Promise<void> => {
+      if (index < middlewares.length) {
+        const mw = middlewares[index++];
+        await mw(task, async () => {
+          await runNext();
+        });
+        // If middleware didn't call next, processing is skipped
+      } else if (handler) {
+        await handler(task);
+      }
+    };
+
+    await runNext();
+  }
+
+  // ---- Phase 12: Graceful Shutdown ----
+
+  onShutdown(callback: () => void | Promise<void>): void {
+    this.shutdownCallbacks.push(callback);
+  }
+
+  async shutdown(timeout = 30000): Promise<ShutdownResult> {
+    if (this.shutdownPromise) {
+      return this.shutdownPromise;
+    }
+
+    this.isShutdown = true;
+    this.shutdownPromise = this.performShutdown(timeout);
+    return this.shutdownPromise;
+  }
+
+  private async performShutdown(timeout: number): Promise<ShutdownResult> {
+    const startTime = Date.now();
+
+    // Run shutdown callbacks
+    for (const cb of this.shutdownCallbacks) {
+      await cb();
+    }
+
+    // Find all processing tasks
+    const processingTasks: Task[] = [];
+    for (const task of this.tasks.values()) {
+      if (task.status === 'processing') {
+        processingTasks.push(task);
+      }
+    }
+
+    let completed = 0;
+    let forceCancelled = 0;
+
+    if (processingTasks.length === 0) {
+      return {
+        completed,
+        forceCancelled,
+        duration: Date.now() - startTime,
+      };
+    }
+
+    // Wait for processing tasks with timeout
+    const waitUntil = startTime + timeout;
+
+    await new Promise<void>(resolve => {
+      const checkInterval = setInterval(() => {
+        const stillProcessing = processingTasks.filter(t => t.status === 'processing');
+        if (stillProcessing.length === 0 || Date.now() >= waitUntil) {
+          clearInterval(checkInterval);
+          resolve();
+        }
+      }, 10);
+    });
+
+    // Count results
+    for (const task of processingTasks) {
+      if (task.status === 'processing') {
+        // Force cancel
+        task.status = 'cancelled';
+        const queueState = this.queues.get(task.queue);
+        if (queueState) {
+          queueState.activeCount = Math.max(0, queueState.activeCount - 1);
+        }
+        forceCancelled++;
+      } else if (task.status === 'completed') {
+        completed++;
+      }
+    }
+
+    return {
+      completed,
+      forceCancelled,
+      duration: Date.now() - startTime,
+    };
+  }
+
+  get isShuttingDown(): boolean {
+    return this.isShutdown;
+  }
+}
diff --git a/src/types.ts b/src/types.ts
new file mode 100644
index 0000000..62a32f3
--- /dev/null
+++ b/src/types.ts
@@ -0,0 +1,57 @@
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';
+
+export interface TaskOptions {
+  queue?: string;
+  priority?: number;
+  delay?: number;
+  processAt?: Date;
+  maxRetries?: number;
+  backoffDelay?: number;
+  dependencies?: string[];
+}
+
+export interface Task<T = unknown> {
+  id: string;
+  payload: T;
+  status: TaskStatus;
+  queue: string;
+  priority: number;
+  createdAt: Date;
+  availableAt: Date;
+  attempt: number;
+  maxRetries: number;
+  backoffDelay: number;
+  progress: number;
+  progressMessage?: string;
+  error?: Error;
+  dependencies: string[];
+  resolvedDependencies: Set<string>;
+}
+
+export interface ShutdownResult {
+  completed: number;
+  forceCancelled: number;
+  duration: number;
+}
+
+export interface ScheduleOptions {
+  id?: string;
+  queue?: string;
+  payload?: unknown;
+  priority?: number;
+  maxRetries?: number;
+  backoffDelay?: number;
+}
+
+export interface Schedule {
+  id: string;
+  cron: string;
+  queue: string;
+  payload: unknown;
+  options: Omit<ScheduleOptions, 'id' | 'queue' | 'payload'>;
+  lastRun?: Date;
+}
+
+export type MiddlewareFn = (task: Task, next: () => Promise<void>) => Promise<void>;
+export type HandlerFn = (task: Task) => Promise<void> | void;
+export type ProgressListener = (progress: number, message?: string) => void;
