    if (!this.matchCronField(hourField, currentHour)) return false;\n\n    // Avoid running the same schedule multiple times in the same minute\n    if (schedule.lastRun) {\n      const lastMinute = schedule.lastRun.getMinutes();\n      const lastHour = schedule.lastRun.getHours();\n      const lastDate = schedule.lastRun.toDateString();\n      const nowDate = now.toDateString();\n      if (lastMinute === currentMinute && lastHour === currentHour && lastDate === nowDate) {\n        return false;\n      }\n    }\n\n    return true;\n  }\n\n  private matchCronField(field: string, value: number): boolean {\n    if (field === '*') return true;\n    if (/^\\*\\/(\\d+)$/.test(field)) {\n      const interval = parseInt(field.slice(2), 10);\n      return value % interval === 0;\n    }\n    if (/^\\d+$/.test(field)) {\n      return parseInt(field, 10) === value;\n    }\n    return false;\n  }\n\n  // ---- Phase 11: Middleware ----\n\n  use(queueName: string, middleware: MiddlewareFn): void {\n    const state = this.ensureQueue(queueName);\n    state.middleware.push(middleware);\n  }\n\n  setHandler(queueName: string, handler: HandlerFn): void {\n    const state = this.ensureQueue(queueName);\n    state.handler = handler;\n  }\n\n  async process(queueName?: string): Promise<Task | null> {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const task = this.next(name);\n    if (!task) return null;\n\n    const queueState = this.queues.get(name);\n    const middlewares = queueState?.middleware ?? [];\n    const handler = queueState?.handler;\n\n    try {\n      await this.runMiddlewarePipeline(task, middlewares, handler);\n      if (task.status === 'processing') {\n        this.complete(task.id);\n      }\n    } catch (err) {\n      if (task.status === 'processing') {\n        this.fail(task.id, err instanceof Error ? err : new Error(String(err)));\n      }\n    }\n\n    return task;\n  }\n\n  private async runMiddlewarePipeline(\n    task: Task,\n    middlewares: MiddlewareFn[],\n    handler?: HandlerFn,\n  ): Promise<void> {\n    let index = 0;\n    let called = false;\n\n    const runNext = async (): Promise<void> => {\n      if (index < middlewares.length) {\n        const mw = middlewares[index++];\n        called = false;\n        await mw(task, async () => {\n          called = true;\n          await runNext();\n        });\n        // If middleware didn't call next, processing is skipped\n      } else if (handler) {\n        await handler(task);\n      }\n    };\n\n    await runNext();\n  }\n\n  // ---- Phase 12: Graceful Shutdown ----\n\n  onShutdown(callback: () => void | Promise<void>): void {\n    this.shutdownCallbacks.push(callback);\n  }\n\n  async shutdown(timeout = 30000): Promise<ShutdownResult> {\n    if (this.shutdownPromise) {\n      return this.shutdownPromise;\n    }\n\n    this.isShutdown = true;\n    this.shutdownPromise = this.performShutdown(timeout);\n    return this.shutdownPromise;\n  }\n\n  private async performShutdown(timeout: number): Promise<ShutdownResult> {\n    const startTime = Date.now();\n\n    // Run shutdown callbacks\n    for (const cb of this.shutdownCallbacks) {\n      await cb();\n    }\n\n    // Find all processing tasks\n    const processingTasks: Task[] = [];\n    for (const task of this.tasks.values()) {\n      if (task.status === 'processing') {\n        processingTasks.push(task);\n      }\n    }\n\n    let completed = 0;\n    let forceCancelled = 0;\n\n    if (processingTasks.length === 0) {\n      return {\n        completed,\n        forceCancelled,\n        duration: Date.now() - startTime,\n      };\n    }\n\n    // Wait for processing tasks with timeout\n    const waitUntil = startTime + timeout;\n\n    await new Promise<void>(resolve => {\n      const checkInterval = setInterval(() => {\n        const stillProcessing = processingTasks.filter(t => t.status === 'processing');\n        if (stillProcessing.length === 0 || Date.now() >= waitUntil) {\n          clearInterval(checkInterval);\n          resolve();\n        }\n      }, 10);\n    });\n\n    // Count results\n    for (const task of processingTasks) {\n      if (task.status === 'processing') {\n        // Force cancel\n        task.status = 'cancelled';\n        const queueState = this.queues.get(task.queue);\n        if (queueState) {\n          queueState.activeCount = Math.max(0, queueState.activeCount - 1);\n        }\n        forceCancelled++;\n      } else if (task.status === 'completed') {\n        completed++;\n      }\n    }\n\n    return {\n      completed,\n      forceCancelled,\n      duration: Date.now() - startTime,\n    };\n  }\n\n  get isShuttingDown(): boolean {\n    return this.isShutdown;\n  }\n}\n","structuredPatch":[{"oldStart":543,"oldLines":14,"newStart":543,"newLines":11,"lines":["     handler?: HandlerFn,","   ): Promise<void> {","     let index = 0;","-    let called = false;"," ","     const runNext = async (): Promise<void> => {","       if (index < middlewares.length) {","         const mw = middlewares[index++];","-        called = false;","         await mw(task, async () => {","-          called = true;","           await runNext();","         });","         // If middleware didn't call next, processing is skipped"]}],"userModified":false,"replaceAll":false}}
