+import { describe, it, expect } from 'vitest';
+import { createResolver } from './index.js';
+
+describe('Version Resolver', () => {
+  const resolver = createResolver();
+
+  describe('resolve', () => {
+    it('should resolve constraints against available versions', () => {
+      const constraints = [
+        { name: 'lodash', range: '^4.0.0' },
+        { name: 'express', range: '~3.0.0' },
+      ];
+      const available = {
+        lodash: ['3.10.0', '4.0.0', '4.17.21'],
+        express: ['3.0.0', '3.0.5', '4.0.0'],
+      };
+
+      const resolved = resolver.resolve(constraints, available);
+      expect(resolved).toHaveLength(2);
+
+      const lodashResolved = resolved.find((r) => r.name === 'lodash');
+      expect(lodashResolved).toBeDefined();
+      expect(lodashResolved!.version).toBe('4.17.21');
+      expect(lodashResolved!.satisfies).toBe('^4.0.0');
+
+      const expressResolved = resolved.find((r) => r.name === 'express');
+      expect(expressResolved).toBeDefined();
+      expect(expressResolved!.version).toBe('3.0.5');
+    });
+
+    it('should skip unresolvable constraints', () => {
+      const constraints = [{ name: 'missing', range: '^1.0.0' }];
+      const available = {};
+
+      const resolved = resolver.resolve(constraints, available);
+      expect(resolved).toHaveLength(0);
+    });
+
+    it('should skip constraints with no matching version', () => {
+      const constraints = [{ name: 'pkg', range: '^5.0.0' }];
+      const available = { pkg: ['1.0.0', '2.0.0'] };
+
+      const resolved = resolver.resolve(constraints, available);
+      expect(resolved).toHaveLength(0);
+    });
+  });
+
+  describe('satisfies', () => {
+    it('should check if version satisfies range', () => {
+      expect(resolver.satisfies('1.5.0', '^1.0.0')).toBe(true);
+      expect(resolver.satisfies('2.0.0', '^1.0.0')).toBe(false);
+      expect(resolver.satisfies('1.0.5', '~1.0.0')).toBe(true);
+      expect(resolver.satisfies('1.1.0', '~1.0.0')).toBe(false);
+    });
+  });
+
+  describe('maxSatisfying', () => {
+    it('should return the maximum satisfying version', () => {
+      const versions = ['1.0.0', '1.5.0', '2.0.0', '2.5.0'];
+      expect(resolver.maxSatisfying(versions, '^1.0.0')).toBe('1.5.0');
+      expect(resolver.maxSatisfying(versions, '^2.0.0')).toBe('2.5.0');
+    });
+
+    it('should return null if nothing matches', () => {
+      expect(resolver.maxSatisfying(['1.0.0'], '^3.0.0')).toBeNull();
+    });
+  });
+
+  describe('validRange', () => {
+    it('should validate semver ranges', () => {
+      expect(resolver.validRange('^1.0.0')).toBe(true);
+      expect(resolver.validRange('~2.3.0')).toBe(true);
+      expect(resolver.validRange('>=1.0.0 <2.0.0')).toBe(true);
+      expect(resolver.validRange('not a range')).toBe(false);
+    });
+  });
+});
