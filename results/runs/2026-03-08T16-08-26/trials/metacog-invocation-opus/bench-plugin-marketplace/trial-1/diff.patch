ror(\"init failed\")' })\n    );\n\n    expect(result.executionResult.success).toBe(false);\n    expect(result.executionResult.error).toBe('init failed');\n  });\n\n  it('should install multiple plugins', async () => {\n    const mp = createMarketplace();\n\n    await mp.installPlugin(makeManifest({ name: 'plugin-1' }));\n    await mp.installPlugin(makeManifest({ name: 'plugin-2' }));\n\n    const all = mp.registry.list();\n    expect(all).toHaveLength(2);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1896,"cache_read_input_tokens":35985,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1896},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"aeb0b3d6-dcf1-4ae8-9097-c4f2d935ff69","uuid":"9874deca-bce5-4b80-8ecb-ed5c56857b4e"}
