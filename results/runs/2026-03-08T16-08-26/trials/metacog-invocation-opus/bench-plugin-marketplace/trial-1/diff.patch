+    description: 'A test plugin',
+    author: 'tester',
+    dependencies: {},
+    entryPoint: '2 + 2',
+    permissions: [],
+    ...overrides,
+  };
+}
+
+describe('Marketplace Integration', () => {
+  it('should create a marketplace with all services', () => {
+    const mp = createMarketplace();
+    expect(mp.registry).toBeDefined();
+    expect(mp.resolver).toBeDefined();
+    expect(mp.runner).toBeDefined();
+    expect(mp.reviews).toBeDefined();
+    expect(mp.deps).toBeDefined();
+    expect(mp.installPlugin).toBeDefined();
+  });
+
+  it('should install a simple plugin', async () => {
+    const mp = createMarketplace();
+    const result = await mp.installPlugin(makeManifest());
+
+    expect(result.executionResult.success).toBe(true);
+    expect(result.executionResult.output).toBe(4);
+    expect(result.resolvedDependencies).toEqual([]);
+
+    // Plugin should be in the registry
+    const registered = mp.registry.get('test-plugin');
+    expect(registered).not.toBeNull();
+  });
+
+  it('should reject plugin without name', async () => {
+    const mp = createMarketplace();
+    await expect(mp.installPlugin(makeManifest({ name: '' }))).rejects.toThrow(
+      'name, version, and entryPoint'
+    );
+  });
+
+  it('should reject plugin without version', async () => {
+    const mp = createMarketplace();
+    await expect(mp.installPlugin(makeManifest({ version: '' }))).rejects.toThrow(
+      'name, version, and entryPoint'
+    );
+  });
+
+  it('should reject plugin without entryPoint', async () => {
+    const mp = createMarketplace();
+    await expect(mp.installPlugin(makeManifest({ entryPoint: '' }))).rejects.toThrow(
+      'name, version, and entryPoint'
+    );
+  });
+
+  it('should resolve dependencies during install', async () => {
+    const mp = createMarketplace();
+
+    // Register dependency first
+    mp.registry.register(makeManifest({ name: 'dep-lib', version: '1.0.0' }));
+    mp.registry.register(makeManifest({ name: 'dep-lib', version: '1.5.0' }));
+
+    const result = await mp.installPlugin(
+      makeManifest({
+        name: 'my-plugin',
+        dependencies: { 'dep-lib': '^1.0.0' },
+      })
+    );
+
+    expect(result.resolvedDependencies).toHaveLength(1);
+    expect(result.resolvedDependencies[0].name).toBe('dep-lib');
+    expect(result.resolvedDependencies[0].version).toBe('1.5.0');
+  });
+
+  it('should detect and reject circular dependencies', async () => {
+    const mp = createMarketplace();
+
+    // Register A which depends on B
+    mp.registry.register(
+      makeManifest({ name: 'plugin-a', dependencies: { 'plugin-b': '^1.0.0' } })
+    );
+    // Register B which depends on a new plugin C
+    mp.registry.register(
+      makeManifest({ name: 'plugin-b', dependencies: { 'plugin-c': '^1.0.0' } })
+    );
+
+    // Install C which depends on A (creates cycle: C -> A -> B -> C)
+    await expect(
+      mp.installPlugin(
+        makeManifest({
+          name: 'plugin-c',
+          dependencies: { 'plugin-a': '^1.0.0' },
+        })
+      )
+    ).rejects.toThrow('Circular dependency');
+
+    // plugin-c should have been removed from registry
+    expect(mp.registry.get('plugin-c')).toBeNull();
+  });
+
+  it('should handle plugin execution failure gracefully', async () => {
+    const mp = createMarketplace();
+
+    const result = await mp.installPlugin(
+      makeManifest({ entryPoint: 'throw new Error("init failed")' })
+    );
+
+    expect(result.executionResult.success).toBe(false);
+    expect(result.executionResult.error).toBe('init failed');
+  });
+
+  it('should install multiple plugins', async () => {
+    const mp = createMarketplace();
+
+    await mp.installPlugin(makeManifest({ name: 'plugin-1' }));
+    await mp.installPlugin(makeManifest({ name: 'plugin-2' }));
+
+    const all = mp.registry.list();
+    expect(all).toHaveLength(2);
+  });
+});
