iews for a plugin', () => {\n    reviews.addReview({\n      pluginName: 'test-plugin',\n      pluginVersion: '1.0.0',\n      userId: 'user1',\n      rating: 5,\n      comment: 'A',\n    });\n    reviews.addReview({\n      pluginName: 'test-plugin',\n      pluginVersion: '1.0.0',\n      userId: 'user2',\n      rating: 4,\n      comment: 'B',\n    });\n    expect(reviews.getReviewCount('test-plugin')).toBe(2);\n  });\n\n  it('should reject invalid ratings', () => {\n    expect(() =>\n      reviews.addReview({\n        pluginName: 'test-plugin',\n        pluginVersion: '1.0.0',\n        userId: 'user1',\n        rating: 0,\n        comment: 'Bad',\n      })\n    ).toThrow();\n\n    expect(() =>\n      reviews.addReview({\n        pluginName: 'test-plugin',\n        pluginVersion: '1.0.0',\n        userId: 'user1',\n        rating: 6,\n        comment: 'Bad',\n      })\n    ).toThrow();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":103,"cache_read_input_tokens":30648,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":103},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"188fbbde-eedc-4171-98ec-f9de651f1c32","uuid":"a6a4f581-ec4f-4746-a34c-8ae37147c0d4"}
