--- /dev/null
+++ b/src/plugins/rss-feed.ts
@@ -0,0 +1,59 @@
+import { Plugin, BuildContext } from '../core/types.js';
+
+function escapeXml(str: string): string {
+  return str
+    .replace(/&/g, '&amp;')
+    .replace(/</g, '&lt;')
+    .replace(/>/g, '&gt;')
+    .replace(/"/g, '&quot;')
+    .replace(/'/g, '&apos;');
+}
+
+export function createRssFeedPlugin(): Plugin {
+  return {
+    name: 'rss-feed',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'taxonomy'],
+    hooks: {
+      afterBuild(ctx: BuildContext): void {
+        const { config, files } = ctx;
+
+        // Sort files by date, newest first
+        const sorted = [...files].sort((a, b) => {
+          if (!a.date && !b.date) return 0;
+          if (!a.date) return 1;
+          if (!b.date) return -1;
+          return new Date(b.date).getTime() - new Date(a.date).getTime();
+        });
+
+        const items = sorted.map(file => {
+          const categoryTags = file.tags
+            ? file.tags.map(tag => `      <category>${escapeXml(tag)}</category>`).join('\n')
+            : '';
+
+          const pubDate = file.date
+            ? `      <pubDate>${new Date(file.date).toUTCString()}</pubDate>`
+            : '';
+
+          return `    <item>
+      <title>${escapeXml(file.title)}</title>
+      <link>${config.baseUrl}/${file.slug}.html</link>
+      <description><![CDATA[${file.content}]]></description>
+${pubDate ? pubDate + '\n' : ''}${categoryTags ? categoryTags + '\n' : ''}    </item>`;
+        }).join('\n');
+
+        const feed = `<?xml version="1.0" encoding="UTF-8"?>
+<rss version="2.0">
+  <channel>
+    <title>${escapeXml(config.title)}</title>
+    <link>${config.baseUrl}</link>
+    <description>${escapeXml(config.title)}</description>
+${items}
+  </channel>
+</rss>`;
+
+        ctx.output.set('feed.xml', feed);
+      },
+    },
+  };
+}
