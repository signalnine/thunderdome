lace(/^#\\s+(.+)$/gm, '<h1>$1</h1>');\n\n  // Process bold and italic\n  html = html.replace(/\\*\\*(.+?)\\*\\*/g, '<strong>$1</strong>');\n  html = html.replace(/\\*(.+?)\\*/g, '<em>$1</em>');\n\n  // Process paragraphs: wrap non-tag, non-empty lines\n  const lines = html.split('\\n');\n  const result: string[] = [];\n  for (const line of lines) {\n    const trimmed = line.trim();\n    if (\n      trimmed === '' ||\n      trimmed.startsWith('<h') ||\n      trimmed.startsWith('<div') ||\n      trimmed.startsWith('</div') ||\n      trimmed.startsWith('<section') ||\n      trimmed.startsWith('</section') ||\n      trimmed.startsWith('<ol') ||\n      trimmed.startsWith('</ol') ||\n      trimmed.startsWith('<li') ||\n      trimmed.startsWith('<ul') ||\n      trimmed.startsWith('</ul') ||\n      trimmed.startsWith('<sup') ||\n      trimmed.startsWith('<pre') ||\n      trimmed.startsWith('<p') ||\n      trimmed.startsWith('</p')\n    ) {\n      result.push(line);\n    } else if (trimmed.length > 0) {\n      result.push(`<p>${trimmed}</p>`);\n    }\n  }\n\n  html = result.join('\\n');\n\n  // Clean up empty lines\n  html = html.replace(/\\n{3,}/g, '\\n\\n');\n  return html.trim();\n}\n\nexport function createMarkdownExtPlugin(): Plugin {\n  return {\n    name: 'markdown-ext',\n    version: '1.0.0',\n    dependencies: [],\n    hooks: {\n      transformContent(file: ContentFile, _ctx: BuildContext): ContentFile {\n        let content = file.content;\n\n        if (!content || content.trim() === '') {\n          return { ...file, content: '' };\n        }\n\n        // Check if content appears to be already HTML (starts with a tag)\n        const trimmed = content.trim();\n        if (trimmed.startsWith('<') && !trimmed.includes('[^') && !trimmed.includes(':::')) {\n          return { ...file, content };\n        }\n\n        // Process admonitions first (before markdown processing)\n        content = processAdmonitions(content);\n\n        // Process footnotes\n        const