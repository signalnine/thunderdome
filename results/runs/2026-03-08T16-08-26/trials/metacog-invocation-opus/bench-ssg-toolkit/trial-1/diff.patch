+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+function processAdmonitions(content: string): string {
+  return content.replace(
+    /^:::(note|warning|tip)\n([\s\S]*?)^:::/gm,
+    (_match, type: string, body: string) => {
+      return `<div class="admonition admonition-${type}">\n${body.trim()}\n</div>`;
+    }
+  );
+}
+
+function processFootnotes(content: string): { content: string; footnotes: Map<string, string> } {
+  const footnotes = new Map<string, string>();
+
+  // Extract footnote definitions
+  const withoutDefs = content.replace(
+    /^\[\^(\d+)\]:\s*(.+)$/gm,
+    (_match, id: string, text: string) => {
+      footnotes.set(id, text);
+      return '';
+    }
+  );
+
+  // Replace footnote references
+  const withRefs = withoutDefs.replace(
+    /\[\^(\d+)\]/g,
+    (_match, id: string) => `<sup><a href="#fn-${id}">${id}</a></sup>`
+  );
+
+  return { content: withRefs, footnotes };
+}
+
+function renderFootnoteSection(footnotes: Map<string, string>): string {
+  if (footnotes.size === 0) return '';
+  const items = Array.from(footnotes.entries())
+    .map(([id, text]) => `<li id="fn-${id}">${text}</li>`)
+    .join('\n');
+  return `\n<section class="footnotes">\n<ol>\n${items}\n</ol>\n</section>`;
+}
+
+function simpleMarkdownToHtml(md: string): string {
+  let html = md;
+
+  // Process headings (h1-h6)
+  html = html.replace(/^######\s+(.+)$/gm, '<h6>$1</h6>');
+  html = html.replace(/^#####\s+(.+)$/gm, '<h5>$1</h5>');
+  html = html.replace(/^####\s+(.+)$/gm, '<h4>$1</h4>');
+  html = html.replace(/^###\s+(.+)$/gm, '<h3>$1</h3>');
+  html = html.replace(/^##\s+(.+)$/gm, '<h2>$1</h2>');
+  html = html.replace(/^#\s+(.+)$/gm, '<h1>$1</h1>');
+
+  // Process bold and italic
+  html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
+  html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');
+
+  // Process paragraphs: wrap non-tag, non-empty lines
+  const lines = html.split('\n');
+  const result: string[] = [];
+  for (const line of lines) {
+    const trimmed = line.trim();
+    if (
+      trimmed === '' ||
+      trimmed.startsWith('<h') ||
+      trimmed.startsWith('<div') ||
+      trimmed.startsWith('</div') ||
+      trimmed.startsWith('<section') ||
+      trimmed.startsWith('</section') ||
+      trimmed.startsWith('<ol') ||
+      trimmed.startsWith('</ol') ||
+      trimmed.startsWith('<li') ||
+      trimmed.startsWith('<ul') ||
+      trimmed.startsWith('</ul') ||
+      trimmed.startsWith('<sup') ||
+      trimmed.startsWith('<pre') ||
+      trimmed.startsWith('<p') ||
+      trimmed.startsWith('</p')
+    ) {
+      result.push(line);
+    } else if (trimmed.length > 0) {
+      result.push(`<p>${trimmed}</p>`);
+    }
+  }
+
+  html = result.join('\n');
+
+  // Clean up empty lines
+  html = html.replace(/\n{3,}/g, '\n\n');
+  return html.trim();
+}
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file: ContentFile, _ctx: BuildContext): ContentFile {
+        let content = file.content;
+
+        if (!content || content.trim() === '') {
+          return { ...file, content: '' };
+        }
+
+        // Check if content appears to be already HTML (starts with a tag)
+        const trimmed = content.trim();
+        if (trimmed.startsWith('<') && !trimmed.includes('[^') && !trimmed.includes(':::')) {
+          return { ...file, content };
+        }
+
+        // Process admonitions first (before markdown processing)
+        content = processAdmonitions(content);
+
+        // Process footnotes
+        const { content: processedContent, footnotes } = processFootnotes(content);
+        content = processedContent;
+
+        // Convert basic markdown to HTML
+        content = simpleMarkdownToHtml(content);
+
+        // Append footnote section
+        content += renderFootnoteSection(footnotes);
+
+        return { ...file, content };
+      },
+    },
+  };
+}
