l')!;\n    94→    const newIdx = feed.indexOf('New Post');\n    95→    const midIdx = feed.indexOf('Mid Post');\n    96→    const oldIdx = feed.indexOf('Old Post');\n    97→    expect(newIdx).toBeLessThan(midIdx);\n    98→    expect(midIdx).toBeLessThan(oldIdx);\n    99→  });\n   100→\n   101→  it('handles files without dates', async () => {\n   102→    const files = [\n   103→      makeFile({ slug: 'no-date', title: 'No Date Post', content: '<p>No date</p>' }),\n   104→    ];\n   105→    const ctx = makeCtx(files);\n   106→    await plugin.hooks.afterBuild!(ctx);\n   107→    const feed = ctx.output.get('feed.xml')!;\n   108→    expect(feed).toContain('No Date Post');\n   109→    expect(feed).not.toContain('<pubDate>undefined</pubDate>');\n   110→  });\n   111→\n   112→  it('feed link uses baseUrl from config', async () => {\n   113→    const files = [makeFile({ slug: 'post-1', title: 'Post 1' })];\n   114→    const ctx = makeCtx(files);\n   115→    await plugin.hooks.afterBuild!(ctx);\n   116→    const feed = ctx.output.get('feed.xml')!;\n   117→    expect(feed).toContain('<link>https://example.com</link>');\n   118→    expect(feed).toContain('<link>https://example.com/post-1.html</link>');\n   119→  });\n   120→});\n   121→"}]},"parent_tool_use_id":"toolu_015fKwyGo6LhuF68zeg65WNT","session_id":"87306611-0e03-4ab2-aed5-8366ba6ca063","uuid":"515f73ec-3658-4dec-9425-cb9c928bce43"}
