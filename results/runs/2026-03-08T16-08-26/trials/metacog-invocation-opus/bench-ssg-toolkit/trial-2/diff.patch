+import { Plugin, BuildContext, ContentFile } from '../core/types.js';
+
+export function createRssFeedPlugin(): Plugin {
+  return {
+    name: 'rss-feed',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'taxonomy'],
+    hooks: {
+      afterBuild(ctx: BuildContext): void {
+        const { config, files } = ctx;
+        const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]> | undefined;
+
+        // Sort files by date, newest first
+        const sorted = [...files].sort((a, b) => {
+          const dateA = a.date ? new Date(a.date).getTime() : 0;
+          const dateB = b.date ? new Date(b.date).getTime() : 0;
+          return dateB - dateA;
+        });
+
+        const items = sorted.map(file => {
+          // Find tags for this file
+          const fileTags: string[] = [];
+          if (tagMap) {
+            for (const [tag, tagFiles] of tagMap) {
+              if (tagFiles.some(f => f.slug === file.slug)) {
+                fileTags.push(tag);
+              }
+            }
+          }
+          // Also use file.tags directly if taxonomy not available
+          if (fileTags.length === 0 && file.tags) {
+            fileTags.push(...file.tags);
+          }
+
+          const categoryTags = fileTags
+            .map(tag => `      <category>${tag}</category>`)
+            .join('\n');
+
+          const pubDate = file.date ? `      <pubDate>${file.date}</pubDate>\n` : '';
+
+          return `    <item>
+      <title>${file.title}</title>
+      <link>${config.baseUrl}/${file.slug}.html</link>
+      <description><![CDATA[${file.content}]]></description>
+${pubDate}${categoryTags ? categoryTags + '\n' : ''}    </item>`;
+        }).join('\n');
+
+        const feed = `<?xml version="1.0" encoding="UTF-8"?>
+<rss version="2.0">
+  <channel>
+    <title>${config.title}</title>
+    <link>${config.baseUrl}</link>
+    <description>${config.title} RSS Feed</description>
+${items}
+  </channel>
+</rss>`;
+
+        ctx.output.set('feed.xml', feed);
+      },
+    },
+  };
+}
