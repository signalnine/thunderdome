 slug: 'post-1', title: 'Post 1', tags: ['javascript'] }),\n    52→    ];\n    53→    const ctx = makeCtx(files);\n    54→    await plugin.hooks.beforeBuild!(ctx);\n    55→    await plugin.hooks.afterBuild!(ctx);\n    56→    expect(ctx.output.has('tags/javascript.html')).toBe(true);\n    57→    expect(ctx.output.get('tags/javascript.html')).toContain('Post 1');\n    58→  });\n    59→\n    60→  it('handles files with no tags', async () => {\n    61→    const files = [\n    62→      makeFile({ slug: 'post-1', title: 'Post 1' }),\n    63→    ];\n    64→    const ctx = makeCtx(files);\n    65→    await plugin.hooks.beforeBuild!(ctx);\n    66→    const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]>;\n    67→    expect(tagMap.size).toBe(0);\n    68→  });\n    69→\n    70→  it('handles files with multiple tags', async () => {\n    71→    const files = [\n    72→      makeFile({ slug: 'post-1', title: 'Post 1', tags: ['js', 'node', 'web'] }),\n    73→    ];\n    74→    const ctx = makeCtx(files);\n    75→    await plugin.hooks.beforeBuild!(ctx);\n    76→    const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]>;\n    77→    expect(tagMap.size).toBe(3);\n    78→    expect(tagMap.has('js')).toBe(true);\n    79→    expect(tagMap.has('node')).toBe(true);\n    80→    expect(tagMap.has('web')).toBe(true);\n    81→  });\n    82→\n    83→  it('tag pages list all files with that tag', async () => {\n    84→    const files = [\n    85→      makeFile({ slug: 'post-1', title: 'First Post', tags: ['tech'] }),\n    86→      makeFile({ slug: 'post-2', title: 'Second Post', tags: ['tech'] }),\n    87→    ];\n    88→    const ctx = makeCtx(files);\n    89→    await plugin.hooks.beforeBuild!(ctx);\n    90→    await plugin.hooks.afterBuild!(ctx);\n    91→    const tagPage = ctx.output.get('tags/tech.html')!;\n    92→    expect(tagPage).toContain('First Post');\n    93→    expect(tagPage).toContain('Second Post');\n    94→  });\n    95→\n    96→  it('s