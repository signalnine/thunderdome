.this.plugins];\n  }\n\n  getTemplates(): Map<string, Template> {\n    return new Map(this.templates);\n  }\n}\n```\n\n#### /workspace/src/core/templates.ts\n```typescript\nimport { Template } from './types.js';\n\nexport function createDefaultTemplate(): Template {\n  return {\n    name: 'default',\n    render: (content: string, data: Record<string, unknown>) => {\n      return `<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>${data.title || ''} | ${data.siteTitle || ''}</title>\n</head>\n<body>\n  <article>\n    <h1>${data.title || ''}</h1>\n    ${data.date ? `<time>${data.date}</time>` : ''}\n    <div class=\"content\">${content}</div>\n  </article>\n</body>\n</html>`;\n    }\n  };\n}\n\nexport function createListTemplate(): Template {\n  return {\n    name: 'list',\n    render: (content: string, data: Record<string, unknown>) => {\n      return `<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>${data.title || ''} | ${data.siteTitle || ''}</title>\n</head>\n<body>\n  <h1>${data.title || ''}</h1>\n  <div class=\"list\">${content}</div>\n</body>\n</html>`;\n    }\n  };\n}\n```\n\n#### /workspace/src/core/index.ts\n```typescript\nexport { BuildEngine } from './engine.js';\nexport { createDefaultTemplate, createListTemplate } from './templates.js';\nexport type { BuildContext, ContentFile, Plugin, PluginHooks, SiteConfig, Template } from './types.js';\n```\n\n---\n\n### 3. All Test Files - Complete List with Paths\n\n| Test File | Path |\n|-----------|------|\n| core.test.ts | /workspace/tests/core.test.ts |\n| asset-pipeline.test.ts | /workspace/tests/plugins/asset-pipeline.test.ts |\n| dev-server.test.ts | /workspace/tests/plugins/dev-server.test.ts |\n| markdown-ext.test.ts | /workspace/tests/plugins/markdown-ext.test.ts |\n| rss-feed.test.ts | /workspace/tests/plugins/rss-feed.test.ts |\n| search-index.test.ts | /workspace/tests/plugins/search-index.test.ts |\n| sitemap.test.ts | /workspace/tests/plugins/sitemap.test.ts 