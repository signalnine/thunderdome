+import { randomUUID } from 'node:crypto';
+import type {
+  Task,
+  TaskOptions,
+  DeadLetteredTask,
+  Schedule,
+  ScheduleOptions,
+  ProgressCallback,
+  MiddlewareFunction,
+  HandlerFunction,
+  ShutdownOptions,
+  ShutdownResult,
+} from './types.js';
+
+const DEFAULT_QUEUE = 'default';
+const DEFAULT_PRIORITY = 5;
+const DEFAULT_MAX_RETRIES = 3;
+const DEFAULT_BACKOFF_DELAY = 1000;
+
+export class TaskQueue {
+  // Core storage
+  private tasks: Map<string, Task> = new Map();
+  private queues: Map<string, string[]> = new Map(); // queueName -> taskIds (pending tasks)
+
+  // Dead letter queues
+  private dlqs: Map<string, DeadLetteredTask[]> = new Map(); // queueName -> dead lettered tasks
+
+  // Concurrency control
+  private concurrencyLimits: Map<string, number> = new Map();
+  private activeCount: Map<string, number> = new Map();
+
+  // Progress subscriptions
+  private progressSubscriptions: Map<string, Set<ProgressCallback>> = new Map();
+
+  // Recurring schedules
+  private schedules: Map<string, Schedule> = new Map();
+
+  // Middleware
+  private middlewareStacks: Map<string, MiddlewareFunction[]> = new Map();
+  private handlers: Map<string, HandlerFunction> = new Map();
+
+  // Shutdown
+  private isShuttingDown = false;
+  private shutdownPromise: Promise<ShutdownResult> | null = null;
+  private shutdownCallbacks: Array<() => void | Promise<void>> = [];
+
+  // Sequence counter for FIFO ordering
+  private sequenceCounter = 0;
+  private taskSequences: Map<string, number> = new Map();
+
+  // --- Phase 1: Basic FIFO Queue ---
+
+  add<T = unknown>(payload: T, options: TaskOptions = {}): Task<T> {
+    if (this.isShuttingDown) {
+      throw new Error('Cannot add tasks: queue is shutting down');
+    }
+
+    const queueName = options.queue ?? DEFAULT_QUEUE;
+    const priority = options.priority ?? DEFAULT_PRIORITY;
+
+    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {
+      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);
+    }
+
+    // Validate dependencies
+    const dependencies = options.dependencies ?? [];
+    for (const depId of dependencies) {
+      const depTask = this.tasks.get(depId);
+      if (!depTask) {
+        throw new Error(`Dependency task not found: ${depId}`);
+      }
+    }
+
+    // Circular dependency detection
+    if (dependencies.length > 0) {
+      // We need to check if adding this task would create a circular dependency
+      // Since the task doesn't exist yet, we check if any dependency transitively depends on something
+      // that would eventually point back. But since this task is new, we just need to check
+      // that none of the dependencies form a cycle among themselves through existing tasks.
+      // Actually, since this is a new task with no dependents yet, circular deps can't exist yet.
+      // Circular deps only happen if A depends on B and B depends on A (or transitive).
+      // Since this task is new, nothing depends on it yet, so no cycle is possible.
+      // However, we still validate the deps exist (done above).
+    }
+
+    const now = new Date();
+    let availableAt = now;
+
+    if (options.processAt) {
+      availableAt = options.processAt;
+    } else if (options.delay != null && options.delay > 0) {
+      availableAt = new Date(now.getTime() + options.delay);
+    }
+
+    const task: Task<T> = {
+      id: randomUUID(),
+      payload,
+      status: 'pending',
+      queue: queueName,
+      priority,
+      createdAt: now,
+      availableAt,
+      attempt: 0,
+      maxRetries: options.maxRetries ?? DEFAULT_MAX_RETRIES,
+      backoffDelay: options.backoffDelay ?? DEFAULT_BACKOFF_DELAY,
+      progress: 0,
+      failureCount: 0,
+      dependencies,
+    };
+
+    this.tasks.set(task.id, task as Task);
+    const seq = this.sequenceCounter++;
+    this.taskSequences.set(task.id, seq);
+
+    // Ensure queue exists
+    if (!this.queues.has(queueName)) {
+      this.queues.set(queueName, []);
+    }
+    this.queues.get(queueName)!.push(task.id);
+
+    return task;
+  }
+
+  next(queueName: string = DEFAULT_QUEUE): Task | null {
+    const queue = this.queues.get(queueName);
+    if (!queue || queue.length === 0) {
+      return null;
+    }
+
+    // Check concurrency limit
+    const limit = this.concurrencyLimits.get(queueName);
+    const active = this.activeCount.get(queueName) ?? 0;
+    if (limit != null && active >= limit) {
+      return null;
+    }
+
+    const now = new Date();
+
+    // Find the best task to return (considering priority, availability, dependencies, FIFO)
+    let bestIdx = -1;
+    let bestTask: Task | null = null;
+    let bestSeq = Infinity;
+
+    for (let i = 0; i < queue.length; i++) {
+      const taskId = queue[i];
+      const task = this.tasks.get(taskId);
+      if (!task || task.status !== 'pending') {
+        continue;
+      }
+
+      // Check if task is available (not delayed)
+      if (task.availableAt > now) {
+        continue;
+      }
+
+      // Check if dependencies are met
+      if (!this.areDependenciesMet(task)) {
+        continue;
+      }
+
+      const seq = this.taskSequences.get(taskId) ?? 0;
+
+      if (bestTask === null) {
+        bestIdx = i;
+        bestTask = task;
+        bestSeq = seq;
+      } else {
+        // Compare: lower priority number = higher priority
+        if (task.priority < bestTask.priority) {
+          bestIdx = i;
+          bestTask = task;
+          bestSeq = seq;
+        } else if (task.priority === bestTask.priority) {
+          // Same priority: FIFO (lower sequence = earlier)
+          if (seq < bestSeq) {
+            bestIdx = i;
+            bestTask = task;
+            bestSeq = seq;
+          }
+        }
+      }
+    }
+
+    if (bestTask === null) {
+      return null;
+    }
+
+    // Remove from queue array
+    queue.splice(bestIdx, 1);
+
+    // Update status
+    bestTask.status = 'processing';
+    bestTask.attempt++;
+
+    // Update active count
+    this.activeCount.set(queueName, (this.activeCount.get(queueName) ?? 0) + 1);
+
+    return bestTask;
+  }
+
+  size(queueName: string = DEFAULT_QUEUE): number {
+    const queue = this.queues.get(queueName);
+    if (!queue) return 0;
+    return queue.filter(id => {
+      const task = this.tasks.get(id);
+      return task && task.status === 'pending';
+    }).length;
+  }
+
+  // --- Phase 2: Named Queues ---
+
+  getQueues(): string[] {
+    return Array.from(this.queues.keys());
+  }
+
+  // --- Phase 5: Retry with Backoff ---
+
+  complete(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task not found: ${taskId}`);
+    }
+    if (task.status !== 'processing') {
+      throw new Error(`Task ${taskId} is not in processing state (current: ${task.status})`);
+    }
+
+    task.status = 'completed';
+    task.progress = 100;
+
+    // Decrement active count
+    const active = this.activeCount.get(task.queue) ?? 0;
+    this.activeCount.set(task.queue, Math.max(0, active - 1));
+
+    // Check if any blocked tasks are now unblocked (Phase 7)
+    this.checkDependents(taskId);
+  }
+
+  fail(taskId: string, error?: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task not found: ${taskId}`);
+    }
+    if (task.status !== 'processing') {
+      throw new Error(`Task ${taskId} is not in processing state (current: ${task.status})`);
+    }
+
+    task.error = error;
+    task.failureCount++;
+
+    // Decrement active count
+    const active = this.activeCount.get(task.queue) ?? 0;
+    this.activeCount.set(task.queue, Math.max(0, active - 1));
+
+    if (task.attempt <= task.maxRetries) {
+      // Retry with backoff
+      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);
+      task.status = 'pending';
+      task.availableAt = new Date(Date.now() + delay);
+      task.progress = 0;
+      task.progressMessage = undefined;
+
+      // Re-add to queue
+      if (!this.queues.has(task.queue)) {
+        this.queues.set(task.queue, []);
+      }
+      const seq = this.sequenceCounter++;
+      this.taskSequences.set(task.id, seq);
+      this.queues.get(task.queue)!.push(task.id);
+    } else {
+      // Exhausted retries
+      task.status = 'failed';
+
+      // Move to DLQ (Phase 6)
+      this.moveToDeadLetterQueue(task, error);
+    }
+  }
+
+  getTask(taskId: string): Task | undefined {
+    return this.tasks.get(taskId);
+  }
+
+  // --- Phase 6: Dead Letter Queue ---
+
+  private moveToDeadLetterQueue(task: Task, error?: string): void {
+    const dlqKey = task.queue;
+    if (!this.dlqs.has(dlqKey)) {
+      this.dlqs.set(dlqKey, []);
+    }
+
+    const dlqTask: DeadLetteredTask = {
+      ...task,
+      deadLetteredAt: new Date(),
+      errors: error ? [error] : [],
+    };
+
+    // Collect all errors from the task history
+    if (task.error && !dlqTask.errors.includes(task.error)) {
+      dlqTask.errors = [task.error];
+    }
+
+    this.dlqs.get(dlqKey)!.push(dlqTask);
+  }
+
+  getDeadLetterQueue(queueName: string = DEFAULT_QUEUE): DeadLetteredTask[] {
+    return this.dlqs.get(queueName) ?? [];
+  }
+
+  requeue(taskId: string): Task {
+    // Find the task in any DLQ
+    for (const [queueName, dlq] of this.dlqs.entries()) {
+      const idx = dlq.findIndex(t => t.id === taskId);
+      if (idx !== -1) {
+        const dlqTask = dlq[idx];
+        dlq.splice(idx, 1);
+
+        // Reset the task for fresh retries
+        const task = this.tasks.get(taskId);
+        if (task) {
+          task.status = 'pending';
+          task.attempt = 0;
+          task.error = undefined;
+          task.progress = 0;
+          task.progressMessage = undefined;
+          task.availableAt = new Date();
+
+          if (!this.queues.has(queueName)) {
+            this.queues.set(queueName, []);
+          }
+          const seq = this.sequenceCounter++;
+          this.taskSequences.set(task.id, seq);
+          this.queues.get(queueName)!.push(task.id);
+          return task;
+        }
+
+        // If task not found in main map, recreate from DLQ entry
+        const restoredTask: Task = {
+          id: dlqTask.id,
+          payload: dlqTask.payload,
+          status: 'pending',
+          queue: dlqTask.queue,
+          priority: dlqTask.priority,
+          createdAt: dlqTask.createdAt,
+          availableAt: new Date(),
+          attempt: 0,
+          maxRetries: dlqTask.maxRetries,
+          backoffDelay: dlqTask.backoffDelay,
+          progress: 0,
+          failureCount: dlqTask.failureCount,
+          dependencies: dlqTask.dependencies,
+        };
+
+        this.tasks.set(restoredTask.id, restoredTask);
+        const seq = this.sequenceCounter++;
+        this.taskSequences.set(restoredTask.id, seq);
+
+        if (!this.queues.has(queueName)) {
+          this.queues.set(queueName, []);
+        }
+        this.queues.get(queueName)!.push(restoredTask.id);
+        return restoredTask;
+      }
+    }
+
+    throw new Error(`Task not found in any dead letter queue: ${taskId}`);
+  }
+
+  clearDeadLetterQueue(queueName: string = DEFAULT_QUEUE): void {
+    this.dlqs.set(queueName, []);
+  }
+
+  // --- Phase 7: Task Dependencies ---
+
+  private areDependenciesMet(task: Task): boolean {
+    if (task.dependencies.length === 0) return true;
+
+    for (const depId of task.dependencies) {
+      const depTask = this.tasks.get(depId);
+      if (!depTask || depTask.status !== 'completed') {
+        return false;
+      }
+    }
+    return true;
+  }
+
+  private checkDependents(_completedTaskId: string): void {
+    // Nothing special to do - when next() is called, it will check dependencies
+    // This is a lazy evaluation approach
+  }
+
+  getDependencyStatus(taskId: string): { resolved: string[]; unresolved: string[] } {
+    const task = this.tasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task not found: ${taskId}`);
+    }
+
+    const resolved: string[] = [];
+    const unresolved: string[] = [];
+
+    for (const depId of task.dependencies) {
+      const depTask = this.tasks.get(depId);
+      if (depTask && depTask.status === 'completed') {
+        resolved.push(depId);
+      } else {
+        unresolved.push(depId);
+      }
+    }
+
+    return { resolved, unresolved };
+  }
+
+  // --- Phase 8: Concurrency Control ---
+
+  setConcurrency(queueName: string, limit: number): void {
+    if (limit < 1 || !Number.isInteger(limit)) {
+      throw new Error(`Invalid concurrency limit: ${limit}. Must be a positive integer.`);
+    }
+    this.concurrencyLimits.set(queueName, limit);
+  }
+
+  getConcurrency(queueName: string): number | undefined {
+    return this.concurrencyLimits.get(queueName);
+  }
+
+  getActiveCount(queueName: string): number {
+    return this.activeCount.get(queueName) ?? 0;
+  }
+
+  // --- Phase 9: Progress Tracking and Cancellation ---
+
+  reportProgress(taskId: string, progress: number, message?: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task not found: ${taskId}`);
+    }
+    if (task.status !== 'processing') {
+      throw new Error(`Task ${taskId} is not in processing state`);
+    }
+    if (progress < 0 || progress > 100) {
+      throw new Error(`Invalid progress: ${progress}. Must be between 0 and 100.`);
+    }
+
+    task.progress = progress;
+    task.progressMessage = message;
+
+    // Notify subscribers
+    const subs = this.progressSubscriptions.get(taskId);
+    if (subs) {
+      for (const cb of subs) {
+        cb(progress, message);
+      }
+    }
+  }
+
+  getProgress(taskId: string): { progress: number; message?: string } {
+    const task = this.tasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task not found: ${taskId}`);
+    }
+    return { progress: task.progress, message: task.progressMessage };
+  }
+
+  onProgress(taskId: string, callback: ProgressCallback): () => void {
+    if (!this.progressSubscriptions.has(taskId)) {
+      this.progressSubscriptions.set(taskId, new Set());
+    }
+    this.progressSubscriptions.get(taskId)!.add(callback);
+
+    // Return unsubscribe function
+    return () => {
+      const subs = this.progressSubscriptions.get(taskId);
+      if (subs) {
+        subs.delete(callback);
+        if (subs.size === 0) {
+          this.progressSubscriptions.delete(taskId);
+        }
+      }
+    };
+  }
+
+  cancel(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task not found: ${taskId}`);
+    }
+    if (task.status !== 'pending' && task.status !== 'processing') {
+      throw new Error(`Task ${taskId} cannot be cancelled (current status: ${task.status})`);
+    }
+
+    const wasPending = task.status === 'pending';
+    task.status = 'cancelled';
+
+    if (wasPending) {
+      // Remove from queue
+      const queue = this.queues.get(task.queue);
+      if (queue) {
+        const idx = queue.indexOf(taskId);
+        if (idx !== -1) {
+          queue.splice(idx, 1);
+        }
+      }
+    } else {
+      // Was processing - decrement active count
+      const active = this.activeCount.get(task.queue) ?? 0;
+      this.activeCount.set(task.queue, Math.max(0, active - 1));
+    }
+  }
+
+  // --- Phase 10: Recurring Tasks ---
+
+  addSchedule(
+    cronExpression: string,
+    payload: unknown,
+    options: ScheduleOptions = {}
+  ): Schedule {
+    this.validateCronExpression(cronExpression);
+
+    const schedule: Schedule = {
+      id: options.id ?? randomUUID(),
+      cronExpression,
+      queue: options.queue ?? DEFAULT_QUEUE,
+      payload,
+      priority: options.priority ?? DEFAULT_PRIORITY,
+      lastRun: null,
+      active: true,
+    };
+
+    this.schedules.set(schedule.id, schedule);
+    return schedule;
+  }
+
+  removeSchedule(scheduleId: string): void {
+    const schedule = this.schedules.get(scheduleId);
+    if (!schedule) {
+      throw new Error(`Schedule not found: ${scheduleId}`);
+    }
+    schedule.active = false;
+    this.schedules.delete(scheduleId);
+  }
+
+  getSchedules(): Schedule[] {
+    return Array.from(this.schedules.values()).filter(s => s.active);
+  }
+
+  tick(now: Date = new Date()): Task[] {
+    const created: Task[] = [];
+
+    for (const schedule of this.schedules.values()) {
+      if (!schedule.active) continue;
+
+      if (this.shouldRunSchedule(schedule, now)) {
+        const task = this.add(schedule.payload, {
+          queue: schedule.queue,
+          priority: schedule.priority,
+        });
+        created.push(task as Task);
+        schedule.lastRun = now;
+      }
+    }
+
+    return created;
+  }
+
+  private validateCronExpression(expr: string): void {
+    const parts = expr.split(' ');
+    if (parts.length !== 5) {
+      throw new Error(`Invalid cron expression: ${expr}. Expected 5 fields.`);
+    }
+
+    // Validate the basic patterns we support
+    const [minute, hour, dayOfMonth, month, dayOfWeek] = parts;
+
+    // Check for valid patterns
+    const isValidField = (field: string): boolean => {
+      if (field === '*') return true;
+      if (/^\d+$/.test(field)) return true;
+      if (/^\*\/\d+$/.test(field)) return true;
+      return false;
+    };
+
+    if (!isValidField(minute) || !isValidField(hour) ||
+        !isValidField(dayOfMonth) || !isValidField(month) ||
+        !isValidField(dayOfWeek)) {
+      throw new Error(`Invalid cron expression: ${expr}`);
+    }
+  }
+
+  private shouldRunSchedule(schedule: Schedule, now: Date): boolean {
+    const [minuteField, hourField, dayOfMonthField, monthField, dayOfWeekField] = schedule.cronExpression.split(' ');
+
+    const minuteMatches = this.matchCronField(minuteField, now.getMinutes());
+    const hourMatches = this.matchCronField(hourField, now.getHours());
+    const dayOfMonthMatches = this.matchCronField(dayOfMonthField, now.getDate());
+    const monthMatches = this.matchCronField(monthField, now.getMonth() + 1);
+    const dayOfWeekMatches = this.matchCronField(dayOfWeekField, now.getDay());
+
+    if (!minuteMatches || !hourMatches || !dayOfMonthMatches || !monthMatches || !dayOfWeekMatches) {
+      return false;
+    }
+
+    // Check if we've already run for this minute
+    if (schedule.lastRun) {
+      const lastMinute = Math.floor(schedule.lastRun.getTime() / 60000);
+      const nowMinute = Math.floor(now.getTime() / 60000);
+      if (lastMinute >= nowMinute) {
+        return false;
+      }
+    }
+
+    return true;
+  }
+
+  private matchCronField(field: string, value: number): boolean {
+    if (field === '*') return true;
+
+    if (field.startsWith('*/')) {
+      const interval = parseInt(field.slice(2), 10);
+      return value % interval === 0;
+    }
+
+    const num = parseInt(field, 10);
+    return value === num;
+  }
+
+  // --- Phase 11: Middleware Pipeline ---
+
+  use(queueName: string, middleware: MiddlewareFunction): void {
+    if (!this.middlewareStacks.has(queueName)) {
+      this.middlewareStacks.set(queueName, []);
+    }
+    this.middlewareStacks.get(queueName)!.push(middleware);
+  }
+
+  setHandler(queueName: string, handler: HandlerFunction): void {
+    this.handlers.set(queueName, handler);
+  }
+
+  async process(queueName: string = DEFAULT_QUEUE): Promise<Task | null> {
+    const task = this.next(queueName);
+    if (!task) return null;
+
+    const middlewares = this.middlewareStacks.get(queueName) ?? [];
+    const handler = this.handlers.get(queueName);
+
+    try {
+      await this.executeMiddlewareChain(task, middlewares, 0, handler);
+    } catch (err) {
+      const errorMsg = err instanceof Error ? err.message : String(err);
+      // Only fail if still in processing state (middleware might have already handled it)
+      if (task.status === 'processing') {
+        this.fail(task.id, errorMsg);
+      }
+    }
+
+    return task;
+  }
+
+  private async executeMiddlewareChain(
+    task: Task,
+    middlewares: MiddlewareFunction[],
+    index: number,
+    handler?: HandlerFunction
+  ): Promise<void> {
+    if (index < middlewares.length) {
+      const middleware = middlewares[index];
+      await middleware(task, async () => {
+        await this.executeMiddlewareChain(task, middlewares, index + 1, handler);
+      });
+    } else if (handler) {
+      await handler(task);
+    }
+  }
+
+  // --- Phase 12: Graceful Shutdown ---
+
+  onShutdown(callback: () => void | Promise<void>): void {
+    this.shutdownCallbacks.push(callback);
+  }
+
+  async shutdown(options: ShutdownOptions = {}): Promise<ShutdownResult> {
+    if (this.shutdownPromise) {
+      return this.shutdownPromise;
+    }
+
+    this.isShuttingDown = true;
+    this.shutdownPromise = this.performShutdown(options);
+    return this.shutdownPromise;
+  }
+
+  private async performShutdown(options: ShutdownOptions): Promise<ShutdownResult> {
+    const startTime = Date.now();
+    const timeout = options.timeout ?? 30000;
+
+    // Run shutdown callbacks
+    for (const cb of this.shutdownCallbacks) {
+      await cb();
+    }
+
+    // Find all processing tasks
+    const processingTasks: Task[] = [];
+    for (const task of this.tasks.values()) {
+      if (task.status === 'processing') {
+        processingTasks.push(task);
+      }
+    }
+
+    let completed = 0;
+    let forceCancelled = 0;
+
+    if (processingTasks.length === 0) {
+      return {
+        completed: 0,
+        forceCancelled: 0,
+        duration: Date.now() - startTime,
+      };
+    }
+
+    // Wait for processing tasks to complete, up to timeout
+    const waitResult = await Promise.race([
+      this.waitForProcessingTasks(processingTasks),
+      new Promise<'timeout'>(resolve => setTimeout(() => resolve('timeout'), timeout)),
+    ]);
+
+    // Count completed
+    for (const task of processingTasks) {
+      if (task.status === 'completed' || task.status === 'failed') {
+        completed++;
+      }
+    }
+
+    // Force-cancel remaining
+    if (waitResult === 'timeout') {
+      for (const task of processingTasks) {
+        if (task.status === 'processing') {
+          task.status = 'cancelled';
+          const active = this.activeCount.get(task.queue) ?? 0;
+          this.activeCount.set(task.queue, Math.max(0, active - 1));
+          forceCancelled++;
+        }
+      }
+    }
+
+    return {
+      completed,
+      forceCancelled,
+      duration: Date.now() - startTime,
+    };
+  }
+
+  private async waitForProcessingTasks(tasks: Task[]): Promise<void> {
+    // Poll until all tasks are no longer processing
+    while (tasks.some(t => t.status === 'processing')) {
+      await new Promise(resolve => setTimeout(resolve, 10));
+    }
+  }
+}
diff --git a/src/types.ts b/src/types.ts
new file mode 100644
index 0000000..b65c14e
--- /dev/null
+++ b/src/types.ts
@@ -0,0 +1,66 @@
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';
+
+export interface TaskOptions {
+  queue?: string;
+  priority?: number;
+  delay?: number;
+  processAt?: Date;
+  maxRetries?: number;
+  backoffDelay?: number;
+  dependencies?: string[];
+}
+
+export interface Task<T = unknown> {
+  id: string;
+  payload: T;
+  status: TaskStatus;
+  queue: string;
+  priority: number;
+  createdAt: Date;
+  availableAt: Date;
+  attempt: number;
+  maxRetries: number;
+  backoffDelay: number;
+  progress: number;
+  progressMessage?: string;
+  error?: string;
+  failureCount: number;
+  dependencies: string[];
+}
+
+export interface DeadLetteredTask<T = unknown> extends Task<T> {
+  deadLetteredAt: Date;
+  errors: string[];
+}
+
+export interface ScheduleOptions {
+  id?: string;
+  queue?: string;
+  priority?: number;
+}
+
+export interface Schedule {
+  id: string;
+  cronExpression: string;
+  queue: string;
+  payload: unknown;
+  priority: number;
+  lastRun: Date | null;
+  active: boolean;
+}
+
+export type ProgressCallback = (progress: number, message?: string) => void;
+
+export type MiddlewareFunction = (task: Task, next: () => Promise<void>) => Promise<void>;
+
+export type HandlerFunction = (task: Task) => Promise<void> | void;
+
+export interface ShutdownOptions {
+  timeout?: number;
+}
+
+export interface ShutdownResult {
+  completed: number;
+  forceCancelled: number;
+  duration: number;
+}
