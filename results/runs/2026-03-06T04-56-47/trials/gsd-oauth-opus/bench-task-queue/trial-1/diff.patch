rocessing tasks to complete, up to timeout\n    const waitResult = await Promise.race([\n      this.waitForProcessingTasks(processingTasks),\n      new Promise<'timeout'>(resolve => setTimeout(() => resolve('timeout'), timeout)),\n    ]);\n\n    // Count completed\n    for (const task of processingTasks) {\n      if (task.status === 'completed' || task.status === 'failed') {\n        completed++;\n      }\n    }\n\n    // Force-cancel remaining\n    if (waitResult === 'timeout') {\n      for (const task of processingTasks) {\n        if (task.status === 'processing') {\n          task.status = 'cancelled';\n          const active = this.activeCount.get(task.queue) ?? 0;\n          this.activeCount.set(task.queue, Math.max(0, active - 1));\n          forceCancelled++;\n        }\n      }\n    }\n\n    return {\n      completed,\n      forceCancelled,\n      duration: Date.now() - startTime,\n    };\n  }\n\n  private async waitForProcessingTasks(tasks: Task[]): Promise<void> {\n    // Poll until all tasks are no longer processing\n    while (tasks.some(t => t.status === 'processing')) {\n      await new Promise(resolve => setTimeout(resolve, 10));\n    }\n  }\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":559,"cache_read_input_tokens":25846,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":559},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"65b1958b-9c61-4a63-af5a-147634a8b71f","uuid":"d6e3f445-3115-4380-b1f1-00788d0e5f7b"}
