ate = new Date('2024-01-01T00:00:00.000Z');\n      const tasks = queue.tick(date);\n\n      expect(tasks[0].queue).toBe('jobs');\n      expect(tasks[0].priority).toBe(2);\n    });\n\n    it('should stop creating tasks after schedule removal', () => {\n      const schedule = queue.addSchedule('*/1 * * * *', { type: 'job' });\n\n      const date1 = new Date('2024-01-01T00:01:00.000Z');\n      const tasks1 = queue.tick(date1);\n      expect(tasks1.length).toBe(1);\n\n      queue.removeSchedule(schedule.id);\n\n      const date2 = new Date('2024-01-01T00:02:00.000Z');\n      const tasks2 = queue.tick(date2);\n      expect(tasks2.length).toBe(0);\n    });\n\n    it('should support hourly cron', () => {\n      queue.addSchedule('0 * * * *', { type: 'hourly' });\n\n      const onHour = new Date('2024-01-01T01:00:00.000Z');\n      const offHour = new Date('2024-01-01T01:30:00.000Z');\n\n      expect(queue.tick(onHour).length).toBe(1);\n      expect(queue.tick(offHour).length).toBe(0);\n    });\n\n    it('should support daily midnight cron', () => {\n      queue.addSchedule('0 0 * * *', { type: 'daily' });\n\n      const midnight = new Date('2024-01-02T00:00:00.000Z');\n      const noon = new Date('2024-01-02T12:00:00.000Z');\n\n      expect(queue.tick(midnight).length).toBe(1);\n      expect(queue.tick(noon).length).toBe(0);\n    });\n\n    it('should throw for invalid cron expression', () => {\n      expect(() => queue.addSchedule('invalid', { type: 'job' })).toThrow();\n    });\n\n    it('should throw for removing non-existent schedule', () => {\n      expect(() => queue.removeSchedule('nonexistent')).toThrow();\n    });\n  });\n\n  // ============================================================\n  // Phase 11: Middleware Pipeline\n  // ============================================================\n  describe('Phase 11: Middleware Pipeline', () => {\n    it('should execute middleware before handler', async () => {\n      const order: string[] = [];\n\n      queue.use('default', async (_task, next) => {\n        order.push('middleware');\n        await next();\n      });\n      queue.setHandler('default', async () => {\n        order.push('handler');\n      });\n\n      queue.add('task');\n      await queue.process();\n\n      expect(order).toEqual(['middleware', 'handler']);\n    });\n\n    it('should execute multiple middleware in order', async () => {\n      const order: string[] = [];\n\n      queue.use('default', async (_task, next) => {\n        order.push('mw1');\n        await next();\n      });\n      queue.use('default', async (_task, next) => {\n        order.push('mw2');\n        await next();\n      });\n      queue.setHandler('default', async () => {\n        order.push('handler');\n      });\n\n      queue.add('task');\n      await queue.process();\n\n      expect(order).toEqual(['mw1', 'mw2', 'handler']);\n    });\n\n    it('should skip processing if middleware does not call next', async () => {\n      const order: string[] = [];\n\n      queue.use('default', async (_task, _next) => {\n        order.push('blocking-mw');\n        // Not calling next()\n      });\n      queue.setHandler('default', async () => {\n        order.push('handler');\n      });\n\n      queue.add('task');\n      await queue.process();\n\n      expect(order).toEqual(['blocking-mw']);\n    });\n\n    it('should allow middleware to modify task', async () => {\n      queue.use('default', async (task, next) => {\n        (task as Record<string, unknown>).metadata = { enriched: true };\n        await next();\n      });\n\n      let capturedTask: Record<string, unknown> | null = null;\n      queue.setHandler('default', async (task) => {\n        capturedTask = task as Record<string, unknown>;\n      });\n\n      queue.add('task');\n      await queue.process();\n\n      expect(capturedTask?.metadata).toEqual({ enriched: true });\n    });\n\n    it('should mark task as failed when middleware throws', async () => {\n      queue.use('default', async () => 