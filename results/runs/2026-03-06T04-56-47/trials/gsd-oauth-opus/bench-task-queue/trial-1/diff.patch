+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from './task-queue.js';
+
+describe('TaskQueue', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  // ============================================================
+  // Phase 1: Basic FIFO Queue
+  // ============================================================
+  describe('Phase 1: Basic FIFO Queue', () => {
+    it('should add a task and return a task object with required fields', () => {
+      const task = queue.add({ message: 'hello' });
+
+      expect(task.id).toBeDefined();
+      expect(typeof task.id).toBe('string');
+      expect(task.payload).toEqual({ message: 'hello' });
+      expect(task.status).toBe('pending');
+      expect(task.createdAt).toBeInstanceOf(Date);
+    });
+
+    it('should assign unique IDs to each task', () => {
+      const t1 = queue.add('task1');
+      const t2 = queue.add('task2');
+      expect(t1.id).not.toBe(t2.id);
+    });
+
+    it('should retrieve tasks in FIFO order', () => {
+      queue.add('first');
+      queue.add('second');
+      queue.add('third');
+
+      const t1 = queue.next();
+      expect(t1?.payload).toBe('first');
+
+      const t2 = queue.next();
+      expect(t2?.payload).toBe('second');
+
+      const t3 = queue.next();
+      expect(t3?.payload).toBe('third');
+    });
+
+    it('should transition retrieved tasks to processing state', () => {
+      queue.add('task');
+      const task = queue.next();
+      expect(task?.status).toBe('processing');
+    });
+
+    it('should return null when no tasks are available', () => {
+      expect(queue.next()).toBeNull();
+    });
+
+    it('should return null after all tasks are retrieved', () => {
+      queue.add('only-task');
+      queue.next();
+      expect(queue.next()).toBeNull();
+    });
+
+    it('should count pending tasks correctly', () => {
+      expect(queue.size()).toBe(0);
+      queue.add('t1');
+      queue.add('t2');
+      expect(queue.size()).toBe(2);
+      queue.next();
+      expect(queue.size()).toBe(1);
+      queue.next();
+      expect(queue.size()).toBe(0);
+    });
+  });
+
+  // ============================================================
+  // Phase 2: Named Queues
+  // ============================================================
+  describe('Phase 2: Named Queues', () => {
+    it('should use default queue when no name specified', () => {
+      queue.add('default-task');
+      const task = queue.next();
+      expect(task?.payload).toBe('default-task');
+      expect(task?.queue).toBe('default');
+    });
+
+    it('should support named queues independently', () => {
+      queue.add('email-task', { queue: 'emails' });
+      queue.add('sms-task', { queue: 'sms' });
+
+      expect(queue.next('emails')?.payload).toBe('email-task');
+      expect(queue.next('sms')?.payload).toBe('sms-task');
+      expect(queue.next('emails')).toBeNull();
+      expect(queue.next('sms')).toBeNull();
+    });
+
+    it('should not mix tasks between queues', () => {
+      queue.add('email-task', { queue: 'emails' });
+      expect(queue.next('sms')).toBeNull();
+      expect(queue.next()).toBeNull(); // default queue
+    });
+
+    it('should list all queue names', () => {
+      queue.add('t1', { queue: 'alpha' });
+      queue.add('t2', { queue: 'beta' });
+      queue.add('t3'); // default
