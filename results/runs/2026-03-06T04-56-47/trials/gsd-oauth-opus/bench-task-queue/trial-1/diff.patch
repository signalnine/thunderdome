s = queue.getQueues();\n      expect(names).toContain('alpha');\n      expect(names).toContain('beta');\n      expect(names).toContain('default');\n    });\n\n    it('should return null for non-existent queue', () => {\n      expect(queue.next('nonexistent')).toBeNull();\n    });\n\n    it('should create queues implicitly', () => {\n      queue.add('task', { queue: 'new-queue' });\n      expect(queue.getQueues()).toContain('new-queue');\n    });\n\n    it('should maintain FIFO per-queue', () => {\n      queue.add('a1', { queue: 'a' });\n      queue.add('b1', { queue: 'b' });\n      queue.add('a2', { queue: 'a' });\n\n      expect(queue.next('a')?.payload).toBe('a1');\n      expect(queue.next('a')?.payload).toBe('a2');\n    });\n  });\n\n  // ============================================================\n  // Phase 3: Priority\n  // ============================================================\n  describe('Phase 3: Priority', () => {\n    it('should default priority to 5', () => {\n      const task = queue.add('task');\n      expect(task.priority).toBe(5);\n    });\n\n    it('should return higher priority tasks first', () => {\n      queue.add('low', { priority: 10 });\n      queue.add('high', { priority: 1 });\n      queue.add('medium', { priority: 5 });\n\n      expect(queue.next()?.payload).toBe('high');\n      expect(queue.next()?.payload).toBe('medium');\n      expect(queue.next()?.payload).toBe('low');\n    });\n\n    it('should maintain FIFO for same priority', () => {\n      queue.add('first', { priority: 5 });\n      queue.add('second', { priority: 5 });\n      queue.add('third', { priority: 5 });\n\n      expect(queue.next()?.payload).toBe('first');\n      expect(queue.next()?.payload).toBe('second');\n      expect(queue.next()?.payload).toBe('third');\n    });\n\n    it('should reject invalid priority values', () => {\n      expect(() => queue.add('task', { priority: 0 })).toThrow();\n      expect(() => queue.add('task', { priority: 11 })).toThrow();\n      expect(() => queue.add('task', { priority: -1 })).toThrow();\n      expect(() => queue.add('task', { priority: 1.5 })).toThrow();\n    });\n\n    it('should support valid priority range 1-10', () => {\n      for (let p = 1; p <= 10; p++) {\n        const task = queue.add(`task-${p}`, { priority: p });\n        expect(task.priority).toBe(p);\n      }\n    });\n\n    it('should maintain priority per queue', () => {\n      queue.add('a-low', { queue: 'a', priority: 10 });\n      queue.add('a-high', { queue: 'a', priority: 1 });\n      queue.add('b-low', { queue: 'b', priority: 10 });\n      queue.add('b-high', { queue: 'b', priority: 1 });\n\n      expect(queue.next('a')?.payload).toBe('a-high');\n      expect(queue.next('b')?.payload).toBe('b-high');\n    });\n\n    it('should expose priority on task object', () => {\n      const task = queue.add('task', { priority: 3 });\n      expect(task.priority).toBe(3);\n    });\n  });\n\n  // ============================================================\n  // Phase 4: Delayed and Scheduled Tasks\n  // ============================================================\n  describe('Phase 4: Delayed and Scheduled Tasks', () => {\n    it('should support delay in milliseconds', () => {\n      queue.add('delayed', { delay: 5000 });\n      // Task shouldn't be available yet\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should support a specific future processAt time', () => {\n      const future = new Date(Date.now() + 60000);\n      const task = queue.add('scheduled', { processAt: future });\n      expect(task.availableAt.getTime()).toBe(future.getTime());\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should return delayed tasks after they become available', () => {\n      const past = new Date(Date.now() - 1000);\n      queue.add('available', { processAt: past });\n      const task = queue.next();\n      expect(task?.payload).toBe('available');\n    });\n\n    it('should prefer non-delayed tasks over delayed ones', () => {\n      queue.add('delayed', { delay: 0 }); // available immediately but \"delayed\"\n      queue.add('immediate');\n\n      // Both should be available, FIFO order since both are available\n      const t1 = queue.next();\n      const t2 = queue.next();\n      expect(t1).not.toBeNull();\n      expect(t2).not.toBeNull();\n    });\n\n    it('should order delayed tasks by availability then priority then FIFO', () => {\n      const past1 = new Date(Date.now() - 3000);\n      const past2 = new Date(Date.now() - 2000);\n      const past3 = new Date(Date.now() - 1000);\n\n      queue.add('third', { processAt: past3, priority: 1 });\n      queue.add('first', { processAt: past1, priority: 5 });\n      queue.add('second', { processAt: past2, priority: 5 });\n\n      // All are available. Priority takes precedence, so priority 1 first\n      const t1 = queue.next();\n      expect(t1?.payload).toBe('third'); // priority 1 beats priority 5\n\n      // Then FIFO among same priority\n      const t2 = queue.next();\n      expect(t2?.payload).toBe('first');\n\n      const t3 = queue.next();\n      expect(t3?.payload).toBe('second');\n    });\n\n    it('should indicate availability time on task', () => {\n      const future = new Date(Date.now() + 5000);\n      const task = queue.add('task', { processAt: future });\n      expect(task.availableAt).toEqual(future);\n    });\n\n    it('should work with named queues', () => {\n      queue.add('delayed', { queue: 'emails', delay: 60000 });\n      queue.add('immediate', { queue: 'emails' });\n\n      expect(queue.next('emails')?.payload).toBe('immediate');\n      expect(queue.next('emails')).toBeNull(); // delayed one is not ready\n    });\n  });\n\n  // ============================================================\n  // Phase 5: Retry with Backoff\n  // ============================================================\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should mark a task as completed', () => {\n      queue.add('task');\n      const task = queue.next()!;\n      queue.complete(task.id);\n      expect(queue.getTask(task.id)?.status).toBe('completed');\n    });\n\n    it('should mark a task as failed', () => {\n      const task = queue.add('task', { maxRetries: 0 });\n      const retrieved = queue.next()!;\n      queue.fail(retrieved.id, 'something went wrong');\n      expect(queue.getTask(task.id)?.status).toBe('failed');\n    });\n\n    it('should auto-retry with backoff delay', () => {\n      const task = queue.add('task', { maxRetries: 3, backoffDelay: 1000 });\n      const t1 = queue.next()!;\n      expect(t1.attempt).toBe(1);\n\n      queue.fail(t1.id, 'error1');\n      // Task should be re-queued with delay\n      const retriedTask = queue.getTask(task.id)!;\n      expect(retriedTask.status).toBe('pending');\n      expect(retriedTask.availableAt.getTime()).toBeGreaterThan(Date.now());\n    });\n\n    it('should apply exponential backoff', () => {\n      const baseDelay = 1000;\n      const task = queue.add('task', { maxRetries: 3, backoffDelay: baseDelay });\n\n      // Attempt 1\n      const t1 = queue.next()!;\n      const beforeFail1 = Date.now();\n      queue.fail(t1.id, 'err');\n      const afterFail1 = queue.getTask(task.id)!.availableAt.getTime();\n      // backoff = 1000 * 2^0 = 1000\n      expect(afterFail1 - beforeFail1).toBeGreaterThanOrEqual(900);\n      expect(afterFail1 - beforeFail1).toBeLessThan(2000);\n    });\n\n    it('should default to 3 max retries', () => {\n      const task = queue.add('task');\n      expect(task.maxRetries).toBe(3);\n    });\n\n    it('should be configurable per task', () => {\n      const task = queue.add('task', { maxRetries: 5, backoffDelay: 500 });\n      expect(task.maxRetries).toBe(5);\n      expect(task.backoffDelay).toBe(500);\n    });\n\n    it('should track attempt count', () => {\n      queue.add('task', { maxRetries: 3, backoffDelay: 0 });\n\n      const t1 = queue.next()!;\n      expect(t1.attempt).toBe(1);\n\n      queue.fail(t1.id, 'err');\n      // Make the task available immediately for testing\n      const retriedTask = queue.getTask(t1.id)!;\n      retriedTask.availableAt = new Date(0);\n\n      const t2 = queue.next()!;\n      expect(t2.attempt).toBe(2);\n    });\n\n    it('should keep original queue and priority on retry', () => {\n      queue.add('task', { queue: 'special', priority: 2, maxRetries: 3, backoffDelay: 0 });\n\n      const t1 = queue.next('special')!;\n      queue.fail(t1.id, 'err');\n\n      const task = queue.getTask(t1.id)!;\n      expect(task.queue).toBe('special');\n      expect(task.priority).toBe(2);\n    });\n\n    it('should remain in failed state when retries exhausted', () => {\n      const task = queue.add('task', { maxRetries: 1, backoffDelay: 0 });\n\n      const t1 = queue.next()!;\n      queue.fail(t1.id, 'err');\n      // Set available immediately\n      queue.getTask(t1.id)!.availableAt = new Date(0);\n\n      const t2 = queue.next()!;\n      queue.fail(t2.id, 'err2');\n\n      expect(queue.getTask(task.id)?.status).toBe('failed');\n    });\n\n    it('should throw when completing non-processing task', () => {\n      const task = queue.add('task');\n      expect(() => queue.complete(task.id)).toThrow();\n    });\n\n    it('should throw for non-existent task', () => {\n      expect(() => queue.complete('nonexistent')).toThrow();\n      expect(() => queue.fail('nonexistent')).toThrow();\n    });\n  });\n\n  // ============================================================\n  // Phase 6: Dead Letter Queue\n  // ============================================================\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move exhausted tasks to DLQ', () => {\n      queue.add('task', { maxRetries: 1, backoffDelay: 0 });\n\n      const t1 = queue.next()!;\n      queue.fail(t1.id, 'err1');\n      queue.getTask(t1.id)!.availableAt = new Date(0);\n\n      const t2 = queue.next()!;\n      queue.fail(t2.id, 'err2');\n\n      const dlq = queue.getDeadLetterQueue();\n      expect(dlq.length).toBe(1);\n      expect(dlq[0].id).toBe(t1.id);\n    });\n\n    it('should retain error info on dead-lettered tasks', () => {\n      queue.add('task', { maxRetries: 0 });\n      const t1 = queue.next()!;\n      queue.fail(t1.id, 'fatal error');\n\n      const dlq = queue.getDeadLetterQueue();\n      expect(dlq[0].errors).toContain('fatal error');\n    });\n\n    it('should retain failure count', () => {\n      queue.add('task', { maxRetries: 1, backoffDelay: 0 });\n\n      const t1 = queue.next()!;\n      queue.fail(t1.id, 'err');\n      queue.getTask(t1.id)!.availableAt = new Date(0);\n\n      const t2 = queue.next()!;\n      queue.fail(t2.id, 'err');\n\n      const dlq = queue.getDeadLetterQueue();\n      expect(dlq[0].failureCount).toBe(2);\n    });\n\n    it('should support requeuing dead-lettered tasks', () => {\n      queue.add('task', { maxRetries: 0 });\n      const t1 = queue.next()!;\n      queue.fail(t1.id, 'err');\n\n      expect(queue.getDeadLetterQueue().length).toBe(1);\n\n      const requeued = queue.requeue(t1.id);\n      expect(requeued.status).toBe('pending');\n      expect(requeued.attempt).toBe(0);\n\n      expect(queue.getDeadLetterQueue().length).toBe(0);\n\n      const retrieved = queue.next()!;\n      expect(retrieved.id).toBe(t1.id);\n    });\n\n    it('should clear DLQ for a queue', () => {\n      queue.add('task1', { maxRetries: 0 });\n      queue.add('task2', { maxRetries: 0 });\n\n      queue.fail(queue.next()!.id, 'err');\n      queue.fail(queue.next()!.id, 'err');\n\n      expect(queue.getDeadLetterQueue().length).toBe(2);\n      queue.clearDeadLetterQueue();\n      expect(queue.getDeadLetterQueue().length).toBe(0);\n    });\n\n    it('should have independent DLQs per queue', () => {\n      queue.add('t1', { queue: 'q1', maxRetries: 0 });\n      queue.add('t2', { queue: 'q2', maxRetries: 0 });\n\n      queue.fail(queue.next('q1')!.id, 'err');\n      queue.fail(queue.next('q2')!.id, 'err');\n\n      expect(queue.getDeadLetterQueue('q1').length).toBe(1);\n      expect(queue.getDeadLetterQueue('q2').length).toBe(1);\n    });\n\n    it('should throw when requeuing non-existent DLQ task', () => {\n      expect(() => queue.requeue('nonexistent')).toThrow();\n    });\n  });\n\n  // ============================================================\n  // Phase 7: Task Dependencies\n  // ============================================================\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block tasks with unresolved dependencies', () => {\n      const t1 = queue.add('dep');\n      queue.add('dependent', { dependencies: [t1.id] });\n\n      // Only t1 should be available\n      const next = queue.next()!;\n      expect(next.payload).toBe('dep');\n      expect(queue.next()).toBeNull(); // dependent is blocked\n    });\n\n    it('should unblock tasks when dependencies complete', () => {\n      const t1 = queue.add('dep');\n      queue.add('dependent', { dependencies: [t1.id] });\n\n      const retrieved = queue.next()!;\n      queue.complete(retrieved.id);\n\n      // Now the dependent should be available\n      const dependent = queue.next()!;\n      expect(dependent.payload).toBe('dependent');\n    });\n\n    it('should error on non-existent dependency', () => {\n      expect(() => queue.add('task', { dependencies: ['nonexistent'] })).toThrow();\n    });\n\n    it('should not auto-fail dependents when dependency fails', () => {\n      const t1 = queue.add('dep', { maxRetries: 0 });\n      const t2 = queue.add('dependent', { dependencies: [t1.id] });\n\n      const retrieved = queue.next()!;\n      queue.fail(retrieved.id, 'err');\n\n      // Dependent should remain pending (blocked)\n      expect(queue.getTask(t2.id)?.status).toBe('pending');\n    });\n\n    it('should support multiple dependencies', () => {\n      const t1 = queue.add('dep1');\n      const t2 = queue.add('dep2');\n      queue.add('dependent', { dependencies: [t1.id, t2.id] });\n\n      // Process dep1\n      const r1 = queue.next()!;\n      expect(r1.payload).toBe('dep1');\n      queue.complete(r1.id);\n\n      // Process dep2\n      const r2 = queue.next()!;\n      expect(r2.payload).toBe('dep2');\n\n      // dependent still blocked (dep2 not completed yet)\n      expect(queue.next()).toBeNull();\n\n      queue.complete(r2.id);\n\n      // Now dependent is available\n      const dep = queue.next()!;\n      expect(dep.payload).toBe('dependent');\n    });\n\n    it('should inspect dependency status', () => {\n      const t1 = queue.add('dep1');\n      const t2 = queue.add('dep2');\n      const t3 = queue.add('dependent', { dependencies: [t1.id, t2.id] });\n\n      const status1 = queue.getDependencyStatus(t3.id);\n      expect(status1.unresolved).toContain(t1.id);\n      expect(status1.unresolved).toContain(t2.id);\n      expect(status1.resolved.length).toBe(0);\n\n      // Complete t1\n      queue.complete(queue.next()!.id);\n\n      const status2 = queue.getDependencyStatus(t3.id);\n      expect(status2.resolved).toContain(t1.id);\n      expect(status2.unresolved).toContain(t2.id);\n    });\n\n    it('should throw for dependency status of non-existent task', () => {\n      expect(() => queue.getDependencyStatus('nonexistent')).toThrow();\n    });\n  });\n\n  // ============================================================\n  // Phase 8: Concurrency Control\n  // ============================================================\n  describe('Phase 8: Concurrency Control', () => {\n    it('should limit concurrent processing tasks', () => {\n      queue.setConcurrency('default', 2);\n      queue.add('t1');\n      queue.add('t2');\n      queue.add('t3');\n\n      expect(queue.next()).not.toBeNull();\n      expect(queue.next()).not.toBeNull();\n      expect(queue.next()).toBeNull(); // limit reached\n    });\n\n    it('should free slot on complete', () => {\n      queue.setConcurrency('default', 1);\n      queue.add('t1');\n      queue.add('t2');\n\n      const t1 = queue.next()!;\n      expect(queue.next()).toBeNull();\n\n      queue.complete(t1.id);\n      expect(queue.next()).not.toBeNull();\n    });\n\n    it('should free slot on fail', () => {\n      queue.setConcurrency('default', 1);\n      queue.add('t1', { maxRetries: 0 });\n      queue.add('t2');\n\n      const t1 = queue.next()!;\n      expect(queue.next()).toBeNull();\n\n      queue.fail(t1.id, 'err');\n      expect(queue.next()).not.toBeNull();\n    });\n\n    it('should default to unlimited concurrency', () => {\n      for (let i = 0; i < 100; i++) {\n        queue.add(`task-${i}`);\n      }\n      for (let i = 0; i < 100; i++) {\n        expect(queue.next()).not.toBeNull();\n      }\n    });\n\n    it('should query concurrency limit and active count', () => {\n      queue.setConcurrency('default', 5);\n      expect(queue.getConcurrency('default')).toBe(5);\n      expect(queue.getActiveCount('default')).toBe(0);\n\n      queue.add('t1');\n      queue.next();\n      expect(queue.getActiveCount('default')).toBe(1);\n    });\n\n    it('should still respect priority with concurrency', () => {\n      queue.setConcurrency('default', 1);\n      queue.add('low', { priority: 10 });\n      queue.add('high', { priority: 1 });\n\n      const task = queue.next()!;\n      expect(task.payload).toBe('high');\n    });\n\n    it('should reject invalid concurrency limits', () => {\n      expect(() => queue.setConcurrency('default', 0)).toThrow();\n      expect(() => queue.setConcurrency('default', -1)).toThrow();\n    });\n  });\n\n  // ============================================================\n  // Phase 9: Progress Tracking and Cancellation\n  // ============================================================\n  describe('Phase 9: Progress Tracking and Cancellation', () => {\n    it('should report and query progress', () => {\n      queue.add('task');\n      const task = queue.next()!;\n\n      queue.reportProgress(task.id, 50, 'halfway');\n\n      const progress = queue.getProgress(task.id);\n      expect(progress.progress).toBe(50);\n      expect(progress.message).toBe('halfway');\n    });\n\n    it('should notify progress subscribers', () => {\n      queue.add('task');\n      const task = queue.next()!;\n\n      const updates: Array<{ progress: number; message?: string }> = [];\n      queue.onProgress(task.id, (progress, message) => {\n        updates.push({ progress, message });\n      });\n\n      queue.reportProgress(task.id, 25, 'quarter');\n      queue.reportProgress(task.id, 75, 'three-quarters');\n\n      expect(updates).toEqual([\n        { progress: 25, message: 'quarter' },\n        { progress: 75, message: 'three-quarters' },\n      ]);\n    });\n\n    it('should support unsubscribing from progress', () => {\n      queue.add('task');\n      const task = queue.next()!;\n\n      const updates: number[] = [];\n      const unsub = queue.onProgress(task.id, (progress) => {\n        updates.push(progress);\n      });\n\n      queue.reportProgress(task.id, 25);\n      unsub();\n      queue.reportProgress(task.id, 75);\n\n      expect(updates).toEqual([25]);\n    });\n\n    it('should cancel a pending task', () => {\n      const task = queue.add('task');\n      queue.cancel(task.id);\n\n      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n      expect(queue.next()).toBeNull(); // removed from queue\n    });\n\n    it('should cancel a processing task', () => {\n      queue.add('task');\n      const task = queue.next()!;\n      queue.cancel(task.id);\n      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n    });\n\n    it('should not retry cancelled tasks', () => {\n      queue.add('task', { maxRetries: 3 });\n      const task = queue.next()!;\n      queue.cancel(task.id);\n\n      // The task should not be re-queued\n      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should reject invalid progress values', () => {\n      queue.add('task');\n      const task = queue.next()!;\n\n      expect(() => queue.reportProgress(task.id, -1)).toThrow();\n      expect(() => queue.reportProgress(task.id, 101)).toThrow();\n    });\n\n    it('should throw when cancelling completed task', () => {\n      queue.add('task');\n      const task = queue.next()!;\n      queue.complete(task.id);\n      expect(() => queue.cancel(task.id)).toThrow();\n    });\n\n    it('should decrement active count when cancelling processing task', () => {\n      queue.setConcurrency('default', 1);\n      queue.add('t1');\n      queue.add('t2');\n\n      const t1 = queue.next()!;\n      expect(queue.next()).toBeNull(); // limited\n\n      queue.cancel(t1.id);\n      expect(queue.next()).not.toBeNull(); // slot freed\n    });\n  });\n\n  // ============================================================\n  // Phase 10: Recurring Tasks\n  // ============================================================\n  describe('Phase 10: Recurring Tasks', () => {\n    it('should create a schedule', () => {\n      const schedule = queue.addSchedule('*/5 * * * *', { type: 'cleanup' });\n      expect(schedule.id).toBeDefined();\n      expect(schedule.cronExpression).toBe('*/5 * * * *');\n      expect(schedule.active).toBe(true);\n    });\n\n    it('should list active schedules', () => {\n      queue.addSchedule('*/5 * * * *', { type: 'cleanup' });\n      queue.addSchedule('0 * * * *', { type: 'hourly' });\n\n      const schedules = queue.getSchedules();\n      expect(schedules.length).toBe(2);\n    });\n\n    it('should remove a schedule', () => {\n      const schedule = queue.addSchedule('*/5 * * * *', { type: 'cleanup' });\n      queue.removeSchedule(schedule.id);\n      expect(queue.getSchedules().length).toBe(0);\n    });\n\n    it('should enqueue tasks on tick when schedule matches', () => {\n      queue.addSchedule('*/5 * * * *', { type: 'cleanup' });\n\n      // Tick at a time divisible by 5\n      const date = new Date('2024-01-01T00:05:00.000Z');\n      const tasks = queue.tick(date);\n\n      expect(tasks.length).toBe(1);\n      expect(tasks[0].payload).toEqual({ type: 'cleanup' });\n    });\n\n    it('should not enqueue when cron does not match', () => {\n      queue.addSchedule('*/5 * * * *', { type: 'cleanup' });\n\n      // Tick at minute 3 (not divisible by 5)\n      const date = new Date('2024-01-01T00:03:00.000Z');\n      const tasks = queue.tick(date);\n\n      expect(tasks.length).toBe(0);\n    });\n\n    it('should not double-enqueue for the same minute', () => {\n      queue.addSchedule('*/5 * * * *', { type: 'cleanup' });\n\n      const date = new Date('2024-01-01T00:05:00.000Z');\n      queue.tick(date);\n      const tasks2 = queue.tick(date);\n\n      expect(tasks2.length).toBe(0);\n    });\n\n    it('should use configured queue and priority', () => {\n      queue.addSchedule('*/1 * * * *', { type: 'job' }, { queue: 'jobs', priority: 2 });\n\n      const date = new Date('2024-01-01T00:00:00.000Z');\n      const tasks = queue.tick(date);\n\n      expect(tasks[0].queue).toBe('jobs');\n      expect(tasks[0].priority).toBe(2);\n    });\n\n    it('should stop creating tasks after schedule removal', () => {\n      const schedule = queue.addSchedule('*/1 * * * *', { type: 'job' });\n\n      const date1 = new Date('2024-01-01T00:01:00.000Z');\n      const tasks1 = queue.tick(date1);\n      expect(tasks1.length).toBe(1);\n\n      queue.removeSchedule(schedule.id);\n\n      const date2 = new Date('2024-01-01T00:02:00.000Z');\n      const tasks2 = queue.tick(date2);\n      expect(tasks2.length).toBe(0);\n    });\n\n    it('should support hourly cron', () => {\n      queue.addSchedule('0 * * * *', { type: 'hourly' });\n\n      const onHour = new Date('2024-01-01T01:00:00.000Z');\n      const offHour = new Date('2024-01-01T01:30:00.000Z');\n\n      expect(queue.tick(onHour).length).toBe(1);\n      expect(queue.tick(offHour).length).toBe(0);\n    });\n\n    it('should support daily midnight cron', () => {\n      queue.addSchedule('0 0 * * *', { type: 'daily' });\n\n      const midnight = new Date('2024-01-02T00:00:00.000Z');\n      const noon = new Date('2024-01-02T12:00:00.000Z');\n\n      expect(queue.tick(midnight).length).toBe(1);\n      expect(queue.tick(noon).length).toBe(0);\n    });\n\n    it('should throw for invalid cron expression', () => {\n      expect(() => queue.addSchedule('invalid', { type: 'job' })).toThrow();\n    });\n\n    it('should throw for removing non-existent schedule', () => {\n      expect(() => queue.removeSchedule('nonexistent')).toThrow();\n    });\n  });\n\n  // ============================================================\n  // Phase 11: Middleware Pipeline\n  // ============================================================\n  describe('Phase 11: Middleware Pipeline', () => {\n    it('should execute middleware before handler', async () => {\n      const order: string[] = [];\n\n      queue.use('default', async (_task, next) => {\n        order.push('middleware');\n        await next();\n      });\n      queue.setHandler('default', async () => {\n        order.push('handler');\n      });\n\n      queue.add('task');\n      await queue.process();\n\n      expect(order).toEqual(['middleware', 'handler']);\n    });\n\n    it('should execute multiple middleware in order', async () => {\n      const order: string[] = [];\n\n      queue.use('default', async (_task, next) => {\n        order.push('mw1');\n        await next();\n      });\n      queue.use('default', async (_task, next) => {\n        order.push('mw2');\n        await next();\n      });\n      queue.setHandler('default', async () => {\n        order.push('handler');\n      });\n\n      queue.add('task');\n      await queue.process();\n\n      expect(order).toEqual(['mw1', 'mw2', 'handler']);\n    });\n\n    it('should skip processing if middleware does not call next', async () => {\n      const order: string[] = [];\n\n      queue.use('default', async (_task, _next) => {\n        order.push('blocking-mw');\n        // Not calling next()\n      });\n      queue.setHandler('default', async () => {\n        order.push('handler');\n      });\n\n      queue.add('task');\n      await queue.process();\n\n      expect(order).toEqual(['blocking-mw']);\n    });\n\n    it('should allow middleware to modify task', async () => {\n      queue.use('default', async (task, next) => {\n        // eslint-disable-next-line @typescript-eslint/no-explicit-any\n        (task as any).metadata = { enriched: true };\n        await next();\n      });\n\n      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n      let capturedTask: any = null;\n      queue.setHandler('default', async (task) => {\n        capturedTask = task;\n      });\n\n      queue.add('task');\n      await queue.process();\n\n      expect(capturedTask?.metadata).toEqual({ enriched: true });\n    });\n\n    it('should mark task as failed when middleware throws', async () => {\n      queue.use('default', async () => {\n        throw new Error('middleware error');\n      });\n\n      queue.add('task', { maxRetries: 0 });\n      const task = await queue.process();\n\n      expect(task?.status).toBe('failed');\n    });\n\n    it('should have independent middleware per queue', async () => {\n      const order: string[] = [];\n\n      queue.use('q1', async (_task, next) => {\n        order.push('q1-mw');\n        await next();\n      });\n      queue.use('q2', async (_task, next) => {\n        order.push('q2-mw');\n        await next();\n      });\n\n      queue.add('task1', { queue: 'q1' });\n      queue.add('task2', { queue: 'q2' });\n\n      await queue.process('q1');\n      expect(order).toEqual(['q1-mw']);\n\n      await queue.process('q2');\n      expect(order).toEqual(['q1-mw', 'q2-mw']);\n    });\n\n    it('should return null when no tasks to process', async () => {\n      const result = await queue.process();\n      expect(result).toBeNull();\n    });\n\n    it('should process without middleware or handler', async () => {\n      queue.add('task');\n      const task = await queue.process();\n      expect(task).not.toBeNull();\n      expect(task?.status).toBe('processing');\n    });\n  });\n\n  // ============================================================\n  // Phase 12: Graceful Shutdown\n  // ============================================================\n  describe('Phase 12: Graceful Shutdown', () => {\n    it('should reject new tasks after shutdown', async () => {\n      await queue.shutdown();\n      expect(() => queue.add('task')).toThrow(/shutting down/);\n    });\n\n    it('should complete immediately with no processing tasks', async () => {\n      const result = await queue.shutdown();\n      expect(result.completed).toBe(0);\n      expect(result.forceCancelled).toBe(0);\n      expect(result.duration).toBeGreaterThanOrEqual(0);\n    });\n\n    it('should wait for processing tasks to complete', async () => {\n      queue.add('task');\n      const task = queue.next()!;\n\n      // Complete the task asynchronously\n      setTimeout(() => queue.complete(task.id), 50);\n\n      const result = await queue.shutdown({ timeout: 5000 });\n      expect(result.completed).toBe(1);\n      expect(result.forceCancelled).toBe(0);\n    });\n\n    it('should force-cancel on timeout', async () => {\n      queue.add('task');\n      queue.next(); // start processing but never complete\n\n      const result = await queue.shutdown({ timeout: 50 });\n      expect(result.forceCancelled).toBe(1);\n    });\n\n    it('should run shutdown callbacks', async () => {\n      let callbackRan = false;\n      queue.onShutdown(() => {\n        callbackRan = true;\n      });\n\n      await queue.shutdown();\n      expect(callbackRan).toBe(true);\n    });\n\n    it('should return same result on multiple shutdown calls', async () => {\n      const result1 = queue.shutdown();\n      const result2 = queue.shutdown();\n\n      const r1 = await result1;\n      const r2 = await result2;\n      expect(r1).toEqual(r2);\n    });\n\n    it('should include duration in shutdown result', async () => {\n      const result = await queue.shutdown();\n      expect(typeof result.duration).toBe('number');\n      expect(result.duration).toBeGreaterThanOrEqual(0);\n    });\n  });\n\n  // ============================================================\n  // Integration Tests\n  // ============================================================\n  describe('Integration', () => {\n    it('should handle priority + delay + named queues together', () => {\n      const past = new Date(Date.now() - 1000);\n\n      queue.add('high-delayed', { queue: 'work', priority: 1, processAt: past });\n      queue.add('low-immediate', { queue: 'work', priority: 10 });\n\n      // High priority (even if was delayed, now available) should come first\n      expect(queue.next('work')?.payload).toBe('high-delayed');\n      expect(queue.next('work')?.payload).toBe('low-immediate');\n    });\n\n    it('should handle dependencies + concurrency together', () => {\n      queue.setConcurrency('default', 1);\n\n      const dep = queue.add('dep');\n      queue.add('dependent', { dependencies: [dep.id] });\n\n      const t1 = queue.next()!;\n      expect(t1.payload).toBe('dep');\n      // Concurrency limit reached AND dependent is blocked\n      expect(queue.next()).toBeNull();\n\n      queue.complete(t1.id);\n      // Now slot is free and dependency is met\n      const t2 = queue.next()!;\n      expect(t2.payload).toBe('dependent');\n    });\n\n    it('should handle retry + DLQ + progress flow', () => {\n      queue.add('fragile', { maxRetries: 1, backoffDelay: 0 });\n\n      const t1 = queue.next()!;\n      queue.reportProgress(t1.id, 50, 'halfway');\n      queue.fail(t1.id, 'err1');\n\n      // Make available for retry\n      queue.getTask(t1.id)!.availableAt = new Date(0);\n\n      const t2 = queue.next()!;\n      expect(t2.attempt).toBe(2);\n      queue.fail(t2.id, 'err2');\n\n      // Should be in DLQ\n      const dlq = queue.getDeadLetterQueue();\n      expect(dlq.length).toBe(1);\n\n      // Requeue it\n      queue.requeue(t1.id);\n      const t3 = queue.next()!;\n      expect(t3.id).toBe(t1.id);\n      expect(t3.attempt).toBe(1); // reset\n    });\n  });\n});\n","structuredPatch":[{"oldStart":1,"oldLines":4,"newStart":1,"newLines":4,"lines":["-import { describe, it, expect, beforeEach, vi } from 'vitest';","+import { describe, it, expect, beforeEach } from 'vitest';"," import { TaskQueue } from './task-queue.js';"," "," describe('TaskQueue', () => {"]}],"userModified":false,"replaceAll":false}}
