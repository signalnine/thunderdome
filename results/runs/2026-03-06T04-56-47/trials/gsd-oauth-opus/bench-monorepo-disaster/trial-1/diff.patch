+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01P4gcjmRHtTWEqtvcXgQ2N4","type":"tool_result","content":"     1→/**\n     2→ * Simple job scheduler for background tasks.\n     3→ */\n     4→\n     5→export interface JobDefinition {\n     6→  name: string;\n     7→  handler: () => Promise<void> | void;\n     8→  intervalMs: number;\n     9→  timer?: ReturnType<typeof setInterval>;\n    10→  lastRun?: Date;\n    11→  runCount: number;\n    12→  errors: string[];\n    13→}\n    14→\n    15→export class Scheduler {\n    16→  private jobs: Map<string, JobDefinition> = new Map();\n    17→  private running = false;\n    18→\n    19→  register(\n    20→    name: string,\n    21→    handler: () => Promise<void> | void,\n    22→    intervalMs: number\n    23→  ): void {\n    24→    this.jobs.set(name, {\n    25→      name,\n    26→      handler,\n    27→      intervalMs,\n    28→      runCount: 0,\n    29→      errors: [],\n    30→    });\n    31→  }\n    32→\n    33→  start(): void {\n    34→    if (this.running) return;\n    35→    this.running = true;\n    36→\n    37→    for (const [, job] of this.jobs) {\n    38→      job.timer = setInterval(async () => {\n    39→        try {\n    40→          await job.handler();\n    41→          job.lastRun = new Date();\n    42→          job.runCount++;\n    43→        } catch (err) {\n    44→          job.errors.push(\n    45→            err instanceof Error ? err.message : String(err)\n    46→          );\n    47→        }\n    48→      }, job.intervalMs);\n    49→    }\n    50→  }\n    51→\n    52→  stop(): void {\n    53→    if (!this.running) return;\n    54→    this.running = false;\n    55→\n    56→    for (const [, job] of this.jobs) {\n    57→      if (job.timer) {\n    58→        clearInterval(job.timer);\n    59→        job.timer = undefined;\n    60→      }\n    61→    }\n    62→  }\n    63→\n    64→  async runOnce(name: string): Promise<void> {\n    65→    const job = this.jobs.get(name);\n    66→    if (!job) {\n    67→      throw new Error(`Job '${name}' not found`);\n    68→    }\n    69→\n    70→    await job.handler();\n    71→    job.lastRun = new Date();\n    72→    job.runCount++;\n    73→  }\n    74→\n    75→  getStatus(): Array<{\n    76→    name: string;\n    77→    lastRun: Date | undefined;\n    78→    runCount: number;\n    79→    errorCount: number;\n    80→  }> {\n    81→    return Array.from(this.jobs.values()).map((job) => ({\n    82→      name: job.name,\n    83→      lastRun: job.lastRun,\n    84→      runCount: job.runCount,\n    85→      errorCount: job.errors.length,\n    86→    }));\n    87→  }\n    88→\n    89→  isRunning(): boolean {\n    90→    return this.running;\n    91→  }\n    92→}\n    93→"}]},"parent_tool_use_id":"toolu_01MEADvBPJrmgtTWP5XUFtPr","session_id":"6b55c90c-e967-46e9-b70c-910740745705","uuid":"5216bbd7-d641-4e91-894f-7a1ccbf01da4"}
