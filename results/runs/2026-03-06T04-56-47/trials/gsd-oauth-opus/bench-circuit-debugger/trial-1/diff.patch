+
+    for (const other of flagged) {
+      if (other === wire || paired.has(other) || other.startsWith('z')) continue;
+      const otherGate = gateByOutput.get(other);
+      if (!otherGate || otherGate.op !== 'XOR') continue;
+      const hasXY = /^[xy]\d+$/.test(otherGate.in1) && /^[xy]\d+$/.test(otherGate.in2);
+      if (!hasXY) {
+        pairs.push([wire, other]);
+        paired.add(wire);
+        paired.add(other);
+        break;
+      }
+    }
+  }
+
+  // Pair remaining
+  const unpaired = flagged.filter(w => !paired.has(w));
+  for (let i = 0; i < unpaired.length - 1; i += 2) {
+    pairs.push([unpaired[i], unpaired[i + 1]]);
+  }
+
+  return pairs;
+}
+
+// Walk the carry chain to find a same-role swap
+function walkAndFindSwap(gates: Gate[], numBits: number): [string, string] | null {
+  const lastZ = `z${pad(numBits)}`;
+
+  function findGate(op: string, a: string, b: string): Gate | undefined {
+    return gates.find(g => g.op === op &&
+      ((g.in1 === a && g.in2 === b) || (g.in1 === b && g.in2 === a)));
+  }
+
+  function findConsumer(wire: string, op: string): Gate | undefined {
+    return gates.find(g => g.op === op && (g.in1 === wire || g.in2 === wire));
+  }
+
+  function getOtherInput(gate: Gate, knownInput: string): string {
+    return gate.in1 === knownInput ? gate.in2 : gate.in1;
+  }
+
+  // Bit 0
+  const xorBit0 = findGate('XOR', 'x00', 'y00');
+  const andBit0 = findGate('AND', 'x00', 'y00');
+  if (!xorBit0 || !andBit0) return null;
+
+  // z00 should be correct (already fixed by structural rules)
+  let carry = andBit0.out;
+
+  for (let i = 1; i < numBits; i++) {
+    const xi = `x${pad(i)}`;
+    const yi = `y${pad(i)}`;
+    const zi = `z${pad(i)}`;
+
+    const xorXY = findGate('XOR', xi, yi);
+    if (!xorXY) continue;
+    const partialSum = xorXY.out;
+
+    // Find XOR(partialSum, carry) → zi
+    const xorFinal = findGate('XOR', partialSum, carry);
+
+    if (!xorFinal) {
+      // The carry or partialSum wire is wrong.
+      // Since structural rules already fixed cross-role issues,
+      // this must be a same-role swap affecting the carry.
+
+      // Look for the XOR that uses carry as one input
+      const xorUsingCarry = findConsumer(carry, 'XOR');
+      if (xorUsingCarry) {
+        // The other input should be partialSum but isn't
+        const actualOther = getOtherInput(xorUsingCarry, carry);
+        if (actualOther !== partialSum) {
+          // partialSum and actualOther are swapped
+          return [partialSum, actualOther].sort() as [string, string];
+        }
+      }
+
+      // Look for the XOR that uses partialSum as one input
+      const xorUsingPartial = findConsumer(partialSum, 'XOR');
+      if (xorUsingPartial) {
+        const actualOther = getOtherInput(xorUsingPartial, partialSum);
+        if (actualOther !== carry) {
+          // carry and actualOther are swapped
+          return [carry, actualOther].sort() as [string, string];
+        }
+      }
+
+      // Can't find the XOR at all - the carry wire must be wrong
+      // The correct carry should be findable via zi's producer
+      const ziGate = gates.find(g => g.out === zi);
+      if (ziGate && ziGate.op === 'XOR') {
+        // One of zi's inputs should be partialSum, the other should be carry
+        const ziOtherInput = getOtherInput(ziGate, partialSum);
+        if (ziOtherInput !== carry) {
+          return [carry, ziOtherInput].sort() as [string, string];
+        }
+      }
+
+      continue;
+    }
+
+    if (xorFinal.out !== zi) {
+      // This shouldn't happen if structural rules already fixed it
+      // but just in case
+      return [xorFinal.out, zi].sort() as [string, string];
+    }
+
+    // Find AND(xi, yi) → gen
+    const andXY = findGate('AND', xi, yi);
+    // Find AND(partialSum, carry) → prop
+    const andPC = findGate('AND', partialSum, carry);
+
+    if (!andXY || !andPC) continue;
+
+    const gen = andXY.out;
+    const prop = andPC.out;
+
+    // Find OR(gen, prop) → carryOut
+    const orGate = findGate('OR', gen, prop);
+
+    if (!orGate) {
+      // gen or prop has a wrong output name (same-role swap).
+      // To disambiguate, find the correct OR gate for THIS bit.
+      // The correct OR's output should feed into the next bit's XOR and AND.
+      // We can identify it by finding which OR gate's output is used by
+      // XOR(partial_{i+1}, ?) for the next bit, OR is lastZ for the last bit.
+
+      let expectedCarryOut: string | undefined;
+      if (i < numBits - 1) {
+        // Next bit's partial sum
+        const nextXi = `x${pad(i + 1)}`;
+        const nextYi = `y${pad(i + 1)}`;
+        const nextXorXY = findGate('XOR', nextXi, nextYi);
+        if (nextXorXY) {
+          const nextPartial = nextXorXY.out;
+          // Find XOR that uses nextPartial
+          const nextXorFinal = findConsumer(nextPartial, 'XOR');
+          if (nextXorFinal && nextXorFinal !== nextXorXY) {
+            expectedCarryOut = getOtherInput(nextXorFinal, nextPartial);
+          }
+        }
+      } else {
+        expectedCarryOut = lastZ;
+      }
+
+      if (expectedCarryOut) {
+        // Find the OR gate that outputs expectedCarryOut
+        const correctOR = gates.find(g => g.op === 'OR' && g.out === expectedCarryOut);
+        if (correctOR) {
+          // This OR gate's inputs should be gen and prop
+          const orIn1 = correctOR.in1;
+          const orIn2 = correctOR.in2;
+
+          if ((orIn1 === gen && orIn2 !== prop) || (orIn2 === gen && orIn1 !== prop)) {
+            // gen is correct, prop is wrong
+            const correctProp = orIn1 === gen ? orIn2 : orIn1;
+            return [prop, correctProp].sort() as [string, string];
+          }
+          if ((orIn1 === prop && orIn2 !== gen) || (orIn2 === prop && orIn1 !== gen)) {
+            // prop is correct, gen is wrong
+            const correctGen = orIn1 === prop ? orIn2 : orIn1;
+            return [gen, correctGen].sort() as [string, string];
+          }
+        }
+      }
+
+      // Fallback: try both OR consumers
+      const orUsingGen = findConsumer(gen, 'OR');
+      if (orUsingGen) {
+        const genPartner = getOtherInput(orUsingGen, gen);
+        if (genPartner !== prop) {
+          return [prop, genPartner].sort() as [string, string];
+        }
+      }
+
+      continue;
+    }
+
+    carry = orGate.out;
+
+    // For the last bit, carry should equal lastZ
+    if (i === numBits - 1) {
+      if (carry !== lastZ) {
+        return [carry, lastZ].sort() as [string, string];
+      }
+    }
+  }
+
+  return null;
+}
+
+function makeInputs(numBits: number, x: bigint, y: bigint): Record<string, number> {
+  const inputs: Record<string, number> = {};
+  for (let i = 0; i < numBits; i++) {
+    inputs[`x${pad(i)}`] = Number((x >> BigInt(i)) & 1n);
+    inputs[`y${pad(i)}`] = Number((y >> BigInt(i)) & 1n);
+  }
+  return inputs;
+}
+
+function findFirstBadBit(gates: Gate[], numBits: number): number {
+  for (let bit = 0; bit <= numBits; bit++) {
+    const testValues: [bigint, bigint][] = [];
+    if (bit < numBits) {
+      testValues.push(
+        [1n << BigInt(bit), 0n],
+        [0n, 1n << BigInt(bit)],
+        [1n << BigInt(bit), 1n << BigInt(bit)],
+      );
+      if (bit > 0) {
+        testValues.push([(1n << BigInt(bit)) - 1n, 1n]);
+      }
+    }
+    if (bit === numBits) {
+      testValues.push([(1n << BigInt(numBits)) - 1n, (1n << BigInt(numBits)) - 1n]);
+    }
+
+    for (const [x, y] of testValues) {
+      const inputs = makeInputs(numBits, x, y);
+      const result = simulate(gates, inputs);
+      const expected = x + y;
+
+      for (let i = bit; i <= numBits; i++) {
+        if (result[`z${pad(i)}`] !== Number((expected >> BigInt(i)) & 1n)) return bit;
+      }
+    }
+  }
+  return -1;
+}
+
+function findSwapsIteratively(gates: Gate[], numBits: number): string[] {
+  const allSwaps: [string, string][] = [];
+  let currentGates = gates.map(g => ({ ...g }));
+  const allOutputWires = gates.map(g => g.out);
+
+  for (let round = 0; round < 4; round++) {
+    const badBit = findFirstBadBit(currentGates, numBits);
+    if (badBit === -1) break;
+
+    let found = false;
+    for (let i = 0; i < allOutputWires.length && !found; i++) {
+      for (let j = i + 1; j < allOutputWires.length && !found; j++) {
+        const alreadyUsed = allSwaps.some(([a, b]) =>
+          a === allOutputWires[i] || b === allOutputWires[i] ||
+          a === allOutputWires[j] || b === allOutputWires[j]);
+        if (alreadyUsed) continue;
+
+        const testGates = applySwaps(currentGates, [[allOutputWires[i], allOutputWires[j]]]);
+        const newBadBit = findFirstBadBit(testGates, numBits);
+        if (newBadBit > badBit || newBadBit === -1) {
+          allSwaps.push([allOutputWires[i], allOutputWires[j]]);
+          currentGates = testGates;
+          found = true;
+        }
+      }
+    }
+
+    if (!found) break;
+  }
+
+  const result: string[] = [];
+  for (const [a, b] of allSwaps) {
+    result.push(a, b);
+  }
+  return result.sort();
+}
