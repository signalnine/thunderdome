 : g;\n  });\n}\n\nfunction testAdder(gates: Gate[], numBits: number): boolean {\n  const testCases: [bigint, bigint][] = [\n    [0n, 0n],\n    [1n, 0n],\n    [0n, 1n],\n    [1n, 1n],\n    [(1n << BigInt(numBits)) - 1n, 1n],\n    [1n, (1n << BigInt(numBits)) - 1n],\n    [(1n << BigInt(numBits)) - 1n, (1n << BigInt(numBits)) - 1n],\n  ];\n\n  for (let bit = 0; bit < numBits; bit++) {\n    testCases.push([1n << BigInt(bit), 1n << BigInt(bit)]);\n  }\n\n  for (const [x, y] of testCases) {\n    const inputs: Record<string, number> = {};\n    for (let i = 0; i < numBits; i++) {\n      inputs[`x${pad(i)}`] = Number((x >> BigInt(i)) & 1n);\n      inputs[`y${pad(i)}`] = Number((y >> BigInt(i)) & 1n);\n    }\n\n    const result = simulate(gates, inputs);\n    const expected = x + y;\n\n    for (let i = 0; i <= numBits; i++) {\n      const expectedBit = Number((expected >> BigInt(i)) & 1n);\n      const actualBit = result[`z${pad(i)}`];\n      if (actualBit !== expectedBit) return false;\n    }\n  }\n  return true;\n}\n\nfunction findFirstBadBit(gates: Gate[], numBits: number): number {\n  for (let bit = 0; bit <= numBits; bit++) {\n    const testValues: [bigint, bigint][] = [];\n    if (bit < numBits) {\n      testValues.push(\n        [1n << BigInt(bit), 0n],\n        [0n, 1n << BigInt(bit)],\n        [1n << BigInt(bit), 1n << BigInt(bit)],\n      );\n      if (bit > 0) {\n        testValues.push([(1n << BigInt(bit)) - 1n, 1n]);\n      }\n    }\n    if (bit === numBits) {\n      testValues.push([(1n << BigInt(numBits)) - 1n, (1n << BigInt(numBits)) - 1n]);\n    }\n\n    for (const [x, y] of testValues) {\n      const inputs: Record<string, number> = {};\n      for (let i = 0; i < numBits; i++) {\n        inputs[`x${pad(i)}`] = Number((x >> BigInt(i)) & 1n);\n        inputs[`y${pad(i)}`] = Number((y >> BigInt(i)) & 1n);\n      }\n\n      const result = simulate(gates, inputs);\n      const expected = x + y;\n\n      for (let i = bit; i <= numBits; i++) {\n        const expectedBit = Number((expected >> BigInt(i)) & 1n);\n        const actualBit = result[`z${pad(i)}`];\n        if (actualBit !== expectedBit) return bit;\n      }\n    }\n  }\n  return -1;\n}\n\n// Get all wires in the dependency cone of a given wire (upstream)\nfunction getDependencyCone(wire: string, gateByOutput: Map<string, Gate>): Set<string> {\n  const visited = new Set<string>();\n  const stack = [wire];\n  while (stack.length > 0) {\n    const w = stack.pop()!;\n    if (visited.has(w)) continue;\n    visited.add(w);\n    const gate = gateByOutput.get(w);\n    if (gate) {\n      stack.push(gate.in1);\n      stack.push(gate.in2);\n    }\n  }\n  return visited;\n}\n\nexport function findSwappedWires(gates: Gate[]): string[] {\n  const swapped: Set<string> = new Set();\n  const numBits = getNumBits(gates);\n  const lastZ = `z${pad(numBits)}`;\n\n  // Structural rules to detect most swaps:\n  // 1. Every z output (except last) must come from an XOR gate\n  // 2. XOR gates with x/y inputs: bit 0 → z00, others → feed into another XOR\n  // 3. XOR gates without x/y inputs must output to z\n  // 4. AND gates (except bit 0) must feed into an OR gate\n  // 5. OR gates must not output to z (except last z bit)\n\n  for (const gate of gates) {\n    const out = gate.out;\n\n    if (out.startsWith('z') && out !== lastZ && gate.op !== 'XOR') {\n      swapped.add(out);\n    }\n\n    if (gate.op === 'XOR') {\n      const hasXYInputs = /^[xy]\\d+$/.test(gate.in1) && /^[xy]\\d+$/.test(gate.in2);\n\n      if (hasXYInputs) {\n        if (gate.in1 === 'x00' || gate.in2 === 'x00') {\n          if (out !== 'z00') {\n            swapped.add(out);\n            swapped.add('z00');\n          }\n        } else {\n          const usedInXOR = gates.some(g => g.op === 'XOR' && (g.in1 === out || g.in2 === out));\n          if (!usedInXOR) {\n            swapped.add(out);\n          }\n        }\n      } else {\n        if (!out.startsWith('z')) {\n          swapped.add(out);\n        }\n      }\n    }\n\n    if (gate.op === 'AND') {\n      const isBit0 = (gate.in1 === 'x00' && gate.in2 === 'y00') || (gate.in1 === 'y00' && gate.in2 === 'x00');\n      if (!isBit0) {\n        const usedInOR = gates.some(g => g.op === 'OR' && (g.in1 === out || g.in2 === out));\n        if (!usedInOR) {\n          swapped.add(out);\n        }\n      }\n    }\n\n    if (gate.op === 'OR' && out.startsWith('z') && out !== lastZ) {\n      swapped.add(out);\n    }\n  }\n\n  if (swapped.size === 8) {\n    return [...swapped].sort();\n  }\n\n  // For 6 flagged wires: pair them up, fix, then find the remaining pair\n  if (swapped.size === 6) {\n    const flaggedWires = [...swapped];\n    const knownPairs = pairUpSwaps(gates, flaggedWires, numBits);\n\n    if (knownPairs) {\n      const fixedGates = applySwaps(gates, knownPairs);\n      const knownWires = new Set(flaggedWires);\n\n      const badBit = findFirstBadBit(fixedGates, numBits);\n      if (badBit >= 0) {\n        // Narrow candidates: find wires in the dependency cone of the bad z bit\n        const gateByOutput = new Map<string, Gate>();\n        for (const g of fixedGates) {\n          gateByOutput.set(g.out, g);\n        }\n\n        // Get dependency cone for the bad z bit and a few bits around it\n        const relevantWires = new Set<string>();\n        for (let b = badBit; b <= Math.min(badBit + 2, numBits); b++) {\n          const cone = getDependencyCone(`z${pad(b)}`, gateByOutput);\n          for (const w of cone) {\n            if (gateByOutput.has(w) && !knownWires.has(w)) {\n              relevantWires.add(w);\n            }\n          }\n        }\n\n        const candidateWires = [...relevantWires];\n\n        for (let i = 0; i < candidateWires.length; i++) {\n          for (let j = i + 1; j < candidateWires.length; j++) {\n            const testGates = applySwaps(fixedGates, [[candidateWires[i], candidateWires[j]]]);\n            if (testAdder(testGates, numBits)) {\n              swapped.add(candidateWires[i]);\n              swapped.add(candidateWires[j]);\n              return [...swapped].sort();\n            }\n          }\n        }\n\n        // If narrowed search didn't work, try all non-flagged output wires\n        const allCandidates = gates\n          .map(g => g.out)\n          .filter(w => !knownWires.has(w));\n\n        for (let i = 0; i < allCandidates.length; i++) {\n          for (let j = i + 1; j < allCandidates.length; j++) {\n            const testGates = applySwaps(fixedGates, [[allCandidates[i], allCandidates[j]]]);\n            if (testAdder(testGates, numBits)) {\n              swapped.add(allCandidates[i]);\n              swapped.add(allCandidates[j]);\n              return [...swapped].sort();\n            }\n          }\n        }\n      }\n    }\n  }\n\n  // Fallback: iterative simulation-based approach\n  if (swapped.size !== 8) {\n    return findSwapsIteratively(gates, numBits);\n  }\n\n  return [...swapped].sort();\n}\n\nfunction pairUpSwaps(gates: Gate[], flaggedWires: string[], numBits: number): [string, string][] | null {\n  const n = flaggedWires.length;\n  if (n % 2 !== 0) return null;\n\n  const pairings = generatePairings(flaggedWires);\n  let bestPairing: [string, string][] | null = null;\n  let bestScore = -1;\n\n  for (const pairing of pairings) {\n    const testGates = applySwaps(gates, pairing);\n    const badBit = findFirstBadBit(testGates, numBits);\n    const score = badBit === -1 ? numBits + 1 : badBit;\n    if (score > bestScore) {\n      bestScore = score;\n      bestPairing = pairing;\n    }\n  }\n\n  return bestPairing;\n}\n\nfunction generatePairings(wires: string[]): [string, string][][] {\n  if (wires.length === 0) return [[]];\n  if (wires.length === 2) return [[[wires[0], wires[1]]]];\n\n  const result: [string, string][][] = [];\n  const first = wires[0];\n  const rest = wires.slice(1);\n\n  for (let i = 0; i < rest.length; i++) {\n    const partner = rest[i];\n    const remaining = [...rest.slice(0, i), ...rest.slice(i + 1)];\n    const subPairings = generatePairings(remaining);\n    for (const sub of subPairings) {\n      result.push([[first, partner], ...sub]);\n    }\n  }\n\n  return result;\n}\n\nfunction findSwapsIteratively(gates: Gate[], numBits: number): string[] {\n  const allSwaps: [string, string][] = [];\n  let currentGates = gates.map(g => ({ ...g }));\n  const allOutputWires = gates.map(g => g.out);\n\n  for (let round = 0; round < 4; round++) {\n    const badBit = findFirstBadBit(currentGates, numBits);\n    if (badBit === -1) break;\n\n    let found = false;\n    for (let i = 0; i < allOutputWires.length && !found; i++) {\n      for (let j = i + 1; j < allOutputWires.length && !found; j++) {\n        const alreadyUsed = allSwaps.some(([a, b]) =>\n          a === allOutputWires[i] || b === allOutputWires[i] ||\n          a === allOutputWires[j] || b === allOutputWires[j]);\n        if (alreadyUsed) continue;\n\n        const testGates = applySwaps(currentGates, [[allOutputWires[i], allOutputWires[j]]]);\n        const newBadBit = findFirstBadBit(testGates, numBits);\n        if (newBadBit > badBit || newBadBit === -1) {\n          allSwaps.push([allOutputWires[i], allOutputWires[j]]);\n          currentGates = testGates;\n          found = true;\n        }\n      }\n    }\n\n    if (!found) break;\n  }\n\n  const result: string[] = [];\n  for (const [a, b] of allSwaps) {\n    result.push(a, b);\n  }\n  return result.sort();\n}\n","structuredPatch":[{"oldStart":70,"oldLines":7,"newStart":70,"newLines":6,"lines":[" }"," "," function testAdder(gates: Gate[], numBits: number): boolean {","-  // Test with a few specific inputs to check if the adder works","   const testCases: [bigint, bigint][] = [","     [0n, 0n],","     [1n, 0n],"]},{"oldStart":81,"oldLines":8,"newStart":80,"newLines":7,"lines":["     [(1n << BigInt(numBits)) - 1n, (1n << BigInt(numBits)) - 1n],","   ];"," ","-  // Also add some bit-pattern tests","-  for (let bit = 0; bit < numBits && bit < 10; bi