ate carry)\n  //   OR(a_i, b_i) -> c_i           (carry out)\n  //\n  // For bit 0:\n  //   XOR(x00, y00) -> z00\n  //   AND(x00, y00) -> c00\n  //\n  // We detect swaps by checking structural violations against this pattern.\n\n  const swapped: Set<string> = new Set();\n\n  // Build lookup structures\n  const gateByOutput: Map<string, Gate> = new Map();\n  for (const g of gates) {\n    gateByOutput.set(g.out, g);\n  }\n\n  // Find the number of input bits\n  let maxBit = 0;\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2]) {\n      const m = w.match(/^[xy](\\d+)$/);\n      if (m) {\n        const bit = parseInt(m[1], 10);\n        if (bit > maxBit) maxBit = bit;\n      }\n    }\n  }\n  const numBits = maxBit + 1;\n  const lastZBit = numBits; // z has one extra bit for carry\n\n  // Helper: check if a gate has a specific pair of inputs (order doesn't matter)\n  function hasInputs(gate: Gate, a: string, b: string): boolean {\n    return (gate.in1 === a && gate.in2 === b) || (gate.in1 === b && gate.in2 === a);\n  }\n\n  // Helper: find a gate by op and inputs\n  function findGate(op: string, a: string, b: string): Gate | undefined {\n    return gates.find(g => g.op === op && hasInputs(g, a, b));\n  }\n\n  // Strategy: Check structural rules that must hold for a correct adder.\n  // Any violation indicates a swap.\n  //\n  // Rules:\n  // 1. Every z output (except the last) must come from an XOR gate.\n  // 2. XOR gates with x/y inputs must output to z00 (for bit 0) or feed into another XOR (for bits > 0).\n  // 3. XOR gates that don't have x/y inputs must output to a z wire.\n  // 4. AND gates (except x00 AND y00) must feed into an OR gate.\n  // 5. OR gates must not output to z (except the last z bit).\n\n  const lastZ = `z${String(lastZBit).padStart(2, '0')}`;\n\n  for (const gate of gates) {\n    const out = gate.out;\n\n    // Rule 1: z-outputs (except last) must be from XOR gates\n    if (out.startsWith('z') && out !== lastZ) {\n      if (gate.op !== 'XOR') {\n        swapped.add(out);\n      }\n    }\n\n    // Rule 2 & 3: XOR gate checks\n    if (gate.op === 'XOR') {\n      const in1IsXY = /^[xy]\\d+$/.test(gate.in1);\n      const in2IsXY = /^[xy]\\d+$/.test(gate.in2);\n      const hasXYInputs = in1IsXY && in2IsXY;\n\n      if (hasXYInputs) {\n        // This is an x_i XOR y_i gate (partial sum or z00)\n        // For bit 0, it should output z00\n        // For other bits, it should feed into another XOR gate\n        if (gate.in1 === 'x00' || gate.in2 === 'x00') {\n          // Bit 0: should output z00\n          if (out !== 'z00') {\n            swapped.add(out);\n          }\n        } else {\n          // Other bits: this output should be used as input to another XOR\n          const usedInXOR = gates.some(g => g.op === 'XOR' && (g.in1 === out || g.in2 === out));\n          if (!usedInXOR) {\n            swapped.add(out);\n          }\n        }\n      } else {\n        // XOR without x/y inputs: should output to z\n        if (!out.startsWith('z')) {\n          swapped.add(out);\n        }\n      }\n    }\n\n    // Rule 4: AND gates (except bit 0's AND) must feed into OR\n    if (gate.op === 'AND') {\n      const isBit0 = hasInputs(gate, 'x00', 'y00');\n      if (!isBit0) {\n        const usedInOR = gates.some(g => g.op === 'OR' && (g.in1 === out || g.in2 === out));\n        if (!usedInOR) {\n          swapped.add(out);\n        }\n      }\n    }\n\n    // Rule 5: OR gates should not output to z (except last z bit)\n    if (gate.op === 'OR') {\n      if (out.startsWith('z') && out !== lastZ) {\n        swapped.add(out);\n      }\n    }\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[{"oldStart":80,"oldLines":11,"newStart":80,"newLines":6,"lines":["     return (gate.in1 === a && gate.in2 === b) || (gate.in1 === b && gate.in2 === a);","   }"," ","-  // Helper: find a gate by op and inputs","-  function findGate(op: string, a: string, b: string): Gate | undefined {","-    return gates.find(g