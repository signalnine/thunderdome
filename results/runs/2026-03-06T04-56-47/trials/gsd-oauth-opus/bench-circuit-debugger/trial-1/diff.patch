   remaining.splice(i, 1);\n        progress = true;\n      }\n    }\n  }\n\n  return wires;\n}\n\n// Fast simulation using topological order (precomputed)\nfunction topoSort(gates: Gate[], inputWires: Set<string>): Gate[] {\n  const resolved = new Set(inputWires);\n  const remaining = [...gates];\n  const sorted: Gate[] = [];\n\n  while (remaining.length > 0) {\n    let progress = false;\n    for (let i = remaining.length - 1; i >= 0; i--) {\n      const g = remaining[i];\n      if (resolved.has(g.in1) && resolved.has(g.in2)) {\n        sorted.push(g);\n        resolved.add(g.out);\n        remaining.splice(i, 1);\n        progress = true;\n      }\n    }\n    if (!progress) break;\n  }\n\n  return sorted;\n}\n\nfunction fastSimulate(sortedGates: Gate[], inputs: Record<string, number>): Record<string, number> {\n  const wires: Record<string, number> = { ...inputs };\n  for (const gate of sortedGates) {\n    const v1 = wires[gate.in1];\n    const v2 = wires[gate.in2];\n    if (v1 === undefined || v2 === undefined) continue;\n    switch (gate.op) {\n      case 'AND':\n        wires[gate.out] = v1 & v2;\n        break;\n      case 'OR':\n        wires[gate.out] = v1 | v2;\n        break;\n      case 'XOR':\n        wires[gate.out] = v1 ^ v2;\n        break;\n    }\n  }\n  return wires;\n}\n\nfunction pad(n: number): string {\n  return String(n).padStart(2, '0');\n}\n\nfunction getNumBits(gates: Gate[]): number {\n  let maxBit = 0;\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2]) {\n      const m = w.match(/^[xy](\\d+)$/);\n      if (m) {\n        const bit = parseInt(m[1], 10);\n        if (bit > maxBit) maxBit = bit;\n      }\n    }\n  }\n  return maxBit + 1;\n}\n\nfunction makeInputs(numBits: number, x: bigint, y: bigint): Record<string, number> {\n  const inputs: Record<string, number> = {};\n  for (let i = 0; i < numBits; i++) {\n    inputs[`x${pad(i)}`] = Number((x >> BigInt(i)) & 1n);\n    inputs[`y${pad(i)}`] = Number((y >> BigInt(i)) & 1n);\n  }\n  return inputs;\n}\n\nfunction checkResult(result: Record<string, number>, expected: bigint, numBits: number): boolean {\n  for (let i = 0; i <= numBits; i++) {\n    const expectedBit = Number((expected >> BigInt(i)) & 1n);\n    if (result[`z${pad(i)}`] !== expectedBit) return false;\n  }\n  return true;\n}\n\nfunction findFirstBadBit(gates: Gate[], numBits: number): number {\n  // Get all input wires\n  const inputWires = new Set<string>();\n  for (let i = 0; i < numBits; i++) {\n    inputWires.add(`x${pad(i)}`);\n    inputWires.add(`y${pad(i)}`);\n  }\n  const sorted = topoSort(gates, inputWires);\n\n  for (let bit = 0; bit <= numBits; bit++) {\n    const testValues: [bigint, bigint][] = [];\n    if (bit < numBits) {\n      testValues.push(\n        [1n << BigInt(bit), 0n],\n        [0n, 1n << BigInt(bit)],\n        [1n << BigInt(bit), 1n << BigInt(bit)],\n      );\n      if (bit > 0) {\n        testValues.push([(1n << BigInt(bit)) - 1n, 1n]);\n      }\n    }\n    if (bit === numBits) {\n      testValues.push([(1n << BigInt(numBits)) - 1n, (1n << BigInt(numBits)) - 1n]);\n    }\n\n    for (const [x, y] of testValues) {\n      const inputs = makeInputs(numBits, x, y);\n      const result = fastSimulate(sorted, inputs);\n      const expected = x + y;\n\n      for (let i = bit; i <= numBits; i++) {\n        if (result[`z${pad(i)}`] !== Number((expected >> BigInt(i)) & 1n)) return bit;\n      }\n    }\n  }\n  return -1;\n}\n\n// Quick test: just check if a specific bit works correctly\nfunction quickTestBit(sorted: Gate[], numBits: number, bit: number): boolean {\n  const testValues: [bigint, bigint][] = [];\n  if (bit < numBits) {\n    testValues.push(\n      [1n << BigInt(bit), 0n],\n      [0n, 1n << BigInt(bit)],\n      [1n << BigInt(bit), 1n << BigInt(bit)],\n    );\n    if (bit > 0) {\n      testValues.push([(1n << BigInt(bit)) - 1n, 1n]);\n    }\n  }\n  if (bit === numBits) {\n    testValues.push([(1n << BigInt(numBits)) - 1n, (1n << BigInt(numBits)) - 1n]);