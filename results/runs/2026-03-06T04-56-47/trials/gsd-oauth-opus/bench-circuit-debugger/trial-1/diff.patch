 // We can identify it by finding which OR gate's output is used by\n      // XOR(partial_{i+1}, ?) for the next bit, OR is lastZ for the last bit.\n\n      let expectedCarryOut: string | undefined;\n      if (i < numBits - 1) {\n        // Next bit's partial sum\n        const nextXi = `x${pad(i + 1)}`;\n        const nextYi = `y${pad(i + 1)}`;\n        const nextXorXY = findGate('XOR', nextXi, nextYi);\n        if (nextXorXY) {\n          const nextPartial = nextXorXY.out;\n          // Find XOR that uses nextPartial\n          const nextXorFinal = findConsumer(nextPartial, 'XOR');\n          if (nextXorFinal && nextXorFinal !== nextXorXY) {\n            expectedCarryOut = getOtherInput(nextXorFinal, nextPartial);\n          }\n        }\n      } else {\n        expectedCarryOut = lastZ;\n      }\n\n      if (expectedCarryOut) {\n        // Find the OR gate that outputs expectedCarryOut\n        const correctOR = gates.find(g => g.op === 'OR' && g.out === expectedCarryOut);\n        if (correctOR) {\n          // This OR gate's inputs should be gen and prop\n          const orIn1 = correctOR.in1;\n          const orIn2 = correctOR.in2;\n\n          if ((orIn1 === gen && orIn2 !== prop) || (orIn2 === gen && orIn1 !== prop)) {\n            // gen is correct, prop is wrong\n            const correctProp = orIn1 === gen ? orIn2 : orIn1;\n            return [prop, correctProp].sort() as [string, string];\n          }\n          if ((orIn1 === prop && orIn2 !== gen) || (orIn2 === prop && orIn1 !== gen)) {\n            // prop is correct, gen is wrong\n            const correctGen = orIn1 === prop ? orIn2 : orIn1;\n            return [gen, correctGen].sort() as [string, string];\n          }\n        }\n      }\n\n      // Fallback: try both OR consumers\n      const orUsingGen = findConsumer(gen, 'OR');\n      if (orUsingGen) {\n        const genPartner = getOtherInput(orUsingGen, gen);\n        if (genPartner !== prop) {\n          return [prop, genPartner].sort() as [string, string];\n        }\n      }\n\n      continue;\n    }","originalFile":"export interface Gate {\n  op: 'AND' | 'OR' | 'XOR';\n  in1: string;\n  in2: string;\n  out: string;\n}\n\nexport function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number> {\n  const wires: Record<string, number> = { ...inputs };\n  const remaining = [...gates];\n  let progress = true;\n\n  while (remaining.length > 0 && progress) {\n    progress = false;\n    for (let i = remaining.length - 1; i >= 0; i--) {\n      const gate = remaining[i];\n      const v1 = wires[gate.in1];\n      const v2 = wires[gate.in2];\n      if (v1 !== undefined && v2 !== undefined) {\n        let result: number;\n        switch (gate.op) {\n          case 'AND':\n            result = v1 & v2;\n            break;\n          case 'OR':\n            result = v1 | v2;\n            break;\n          case 'XOR':\n            result = v1 ^ v2;\n            break;\n        }\n        wires[gate.out] = result;\n        remaining.splice(i, 1);\n        progress = true;\n      }\n    }\n  }\n\n  return wires;\n}\n\nfunction pad(n: number): string {\n  return String(n).padStart(2, '0');\n}\n\nfunction getNumBits(gates: Gate[]): number {\n  let maxBit = 0;\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2]) {\n      const m = w.match(/^[xy](\\d+)$/);\n      if (m) {\n        const bit = parseInt(m[1], 10);\n        if (bit > maxBit) maxBit = bit;\n      }\n    }\n  }\n  return maxBit + 1;\n}\n\nexport function findSwappedWires(gates: Gate[]): string[] {\n  const numBits = getNumBits(gates);\n  const lastZ = `z${pad(numBits)}`;\n\n  const swapped = new Set<string>();\n\n  // Build index: gate by output wire\n  const gateByOutput = new Map<string, Gate>();\n  for (const g of gates) {\n    gateByOutput.set(g.out, g);\n  }\n\n  // Structural rules to detect cross-role swaps\n  for (const gate of gates) {\n    const out = gate.out;\n\n    // Rule 1: z-outputs (except last) must be from XOR gates\n    if (out.startsWith('z') && out !== lastZ && gate.op !== 'XOR') {\n      swapped.add(out);\n    }\n\n    // Rule 2/3: XOR gate output checks\n    if (gate.op === 'XOR') {\n      const hasXYInputs = /^[xy]\\d+$/.test(gate.in1) && /^[xy]\\d+$/.test(gate.in2);\n\n      if (hasXYInputs) {\n        if (gate.in1 === 'x00' || gate.in2 === 'x00') {\n          if (out !== 'z00') {\n            swapped.add(out);\n            swapped.add('z00');\n          }\n        } else {\n          const usedInXOR = gates.some(g => g.op === 'XOR' && (g.in1 === out || g.in2 === out));\n          if (!usedInXOR) {\n            swapped.add(out);\n          }\n        }\n      } else {\n        if (!out.startsWith('z')) {\n          swapped.add(out);\n        }\n      }\n    }\n\n    // Rule 4: AND gates (except bit 0) must feed into OR\n    if (gate.op === 'AND') {\n      const isBit0 = (gate.in1 === 'x00' && gate.in2 === 'y00') || (gate.in1 === 'y00' && gate.in2 === 'x00');\n      if (!isBit0) {\n        const usedInOR = gates.some(g => g.op === 'OR' && (g.in1 === out || g.in2 === out));\n        if (!usedInOR) {\n          swapped.add(out);\n        }\n      }\n    }\n\n    // Rule 5: OR gates should not output to z (except last z bit)\n    if (gate.op === 'OR' && out.startsWith('z') && out !== lastZ) {\n      swapped.add(out);\n    }\n  }\n\n  if (swapped.size === 8) {\n    return [...swapped].sort();\n  }\n\n  // If we found 6 wires, pair them and fix, then walk the carry chain to find the 4th pair\n  if (swapped.size === 6) {\n    const pairs = pairFlaggedWires([...swapped], gateByOutput);\n\n    if (pairs.length === 3) {\n      // Fix the known swaps\n      const fixedGates = applySwaps(gates, pairs);\n      const remaining = walkAndFindSwap(fixedGates, numBits);\n      if (remaining) {\n        swapped.add(remaining[0]);\n        swapped.add(remaining[1]);\n      }\n    }\n  }\n\n  if (swapped.size === 8) {\n    return [...swapped].sort();\n  }\n\n  // Fallback: iterative simulation approach\n  return findSwapsIteratively(gates, numBits);\n}\n\nfunction applySwaps(gates: Gate[], swapPairs: [string, string][]): Gate[] {\n  const swapMap = new Map<string, string>();\n  for (const [a, b] of swapPairs) {\n    swapMap.set(a, b);\n    swapMap.set(b, a);\n  }\n  return gates.map(g => {\n    const newOut = swapMap.get(g.out);\n    return newOut !== undefined ? { ...g, out: newOut } : g;\n  });\n}\n\nfunction pairFlaggedWires(flagged: string[], gateByOutput: Map<string, Gate>): [string, string][] {\n  const pairs: [string, string][] = [];\n  const paired = new Set<string>();\n\n  // First: pair z-wires (from non-XOR gates) with non-z wires (from non-xy XOR gates)\n  for (const wire of flagged) {\n    if (paired.has(wire)) continue;\n    if (!wire.startsWith('z')) continue;\n\n    const gate = gateByOutput.get(wire);\n    if (!gate || gate.op === 'XOR') continue;\n\n    for (const other of flagged) {\n      if (other === wire || paired.has(other) || other.startsWith('z')) continue;\n      const otherGate = gateByOutput.get(other);\n      if (!otherGate || otherGate.op !== 'XOR') continue;\n      const hasXY = /^[xy]\\d+$/.test(otherGate.in1) && /^[xy]\\d+$/.test(otherGate.in2);\n      if (!hasXY) {\n        pairs.push([wire, other]);\n        paired.add(wire);\n        paired.add(other);\n        break;\n      }\n    }\n  }\n\n  // Pair remaining\n  const unpaired = flagged.filter(w => !paired.has(w));\n  for (let i = 0; i < unpaired.length - 1; i += 2) {\n    pairs.push([unpaired[i], unpaired[i + 1]]);\n  }\n\n  return pairs;\n}\n\n// Walk the carry chain to find a same-role swap\nfunction walkAndFindSwap(gates: Gate[], numBits: number): [string, string] | null {\n  const lastZ = `z${pad(numBits)}`;\n\n  function findGate(op: string, a: string, b: string): Gate | undefined {\n    return gates.find(g => g.op === op &&\n      ((g.in1 === a && g.in2 === b) || (g.in1 === b && g.in2 === a)));\n  }\n\n  function findConsumer(wire: string, op: string): Gate | undefined {\n    return gates.find(g => g.op === op && (g.in1 === wire || g.in2 === wire));\n  }\n\n  function getOtherInput(gate: Gate, knownInput: string): string {\n    return gate.in1 === knownInput ? gate.in2 : gate.in1;\n  }\n\n  // Bit 0\n  const xorBit0 = findGate('XOR', 'x00', 'y00');\n  const andBit0 = findGate('AND', 'x00', 'y00');\n  if (!xorBit0 || !andBit0) return null;\n\n  // z00 should be correct (already fixed by structural rules)\n  let carry = andBit0.out;\n\n  for (let i = 1; i < numBits; i++) {\n    const xi = `x${pad(i)}`;\n    const yi = `y${pad(i)}`;\n    const zi = `z${pad(i)}`;\n\n    const xorXY = findGate('XOR', xi, yi);\n    if (!xorXY) continue;\n    const partialSum = xorXY.out;\n\n    // Find XOR(partialSum, carry) → zi\n    const xorFinal = findGate('XOR', partialSum, carry);\n\n    if (!xorFinal) {\n      // The carry or partialSum wire is wrong.\n      // Since structural rules already fixed cross-role issues,\n      // this must be a same-role swap affecting the carry.\n\n      // Look for the XOR that uses carry as one input\n      const xorUsingCarry = findConsumer(carry, 'XOR');\n      if (xorUsingCarry) {\n        // The other input should be partialSum but isn't\n        const actualOther = getOtherInput(xorUsingCarry, carry);\n        if (actualOther !== partialSum) {\n          // partialSum and actualOther are swapped\n          return [partialSum, actualOther].sort() as [string, string];\n        }\n      }\n\n      // Look for the XOR that uses partialSum as one input\n      const xorUsingPartial = findConsumer(partialSum, 'XOR');\n      if (xorUsingPartial) {\n        const actualOther = getOtherInput(xorUsingPartial, partialSum);\n        if (actualOther !== carry) {\n          // carry and actualOther are swapped\n          return [carry, actualOther].sort() as [string, string];\n        }\n      }\n\n      // Can't find the XOR at all - the carry wire must be wrong\n      // The correct carry should be findable via zi's producer\n      const ziGate = gates.find(g => g.out === zi);\n      if (ziGate && ziGate.op === 'XOR') {\n        // One of zi's inputs should be partialSum, the other should be carry\n        const ziOtherInput = getOtherInput(ziGate, partialSum);\n        if (ziOtherInput !== carry) {\n          return [carry, ziOtherInput].sort() as [string, string];\n        }\n      }\n\n      continue;\n    }\n\n    if (xorFinal.out !== zi) {\n      // This shouldn't happen if structural rules already fixed it\n      // but just in case\n      return [xorFinal.out, zi].sort() as [string, string];\n    }\n\n    // Find AND(xi, yi) → gen\n    const andXY = findGate('AND', xi, yi);\n    // Find AND(partialSum, carry) → prop\n    const andPC = findGate('AND', partialSum, carry);\n\n    if (!andXY || !andPC) continue;\n\n    const gen = andXY.out;\n    const prop = andPC.out;\n\n    // Find OR(gen, prop) → carryOut\n    const orGate = findGate('OR', gen, prop);\n\n    if (!orGate) {\n      // gen or prop has a wrong output name (same-role swap).\n      // Strategy: find the OR gate that uses gen. Its other input should\n      // be prop but has a different name. This tells us what prop SHOULD be\n      // named (and vice versa). We pick the one where gen is a confirmed\n      // \"correct\" input to the OR gate (meaning the OR also uses a wire\n      // from AND with inputs matching this bit's x/y or partialSum/carry).\n\n      const orUsingGen = findConsumer(gen, 'OR');\n      if (orUsingGen) {\n        const genPartner = getOtherInput(orUsingGen, gen);\n        if (genPartner !== prop) {\n          // This OR gate pairs gen with genPartner, but we computed prop\n          // as the prop for this bit. So prop should be genPartner.\n          // The swap is between prop and genPartner.\n          return [prop, genPartner].sort() as [string, string];\n        }\n      }\n\n      const orUsingProp = findConsumer(prop, 'OR');\n      if (orUsingProp) {\n        const propPartner = getOtherInput(orUsingProp, prop);\n        if (propPartner !== gen) {\n          // This OR gate pairs prop with propPartner, but we computed gen\n          // as the gen for this bit. So gen should be propPartner.\n          return [gen, propPartner].sort() as [string, string];\n        }\n      }\n\n      continue;\n    }\n\n    carry = orGate.out;\n\n    // For the last bit, carry should equal lastZ\n    if (i === numBits - 1) {\n      if (carry !== lastZ) {\n        return [carry, lastZ].sort() as [string, string];\n      }\n    }\n  }\n\n  return null;\n}\n\nfunction makeInputs(numBits: number, x: bigint, y: bigint): Record<string, number> {\n  const inputs: Record<string, number> = {};\n  for (let i = 0; i < numBits; i++) {\n    inputs[`x${pad(i)}`] = Number((x >> BigInt(i)) & 1n);\n    inputs[`y${pad(i)}`] = Number((y >> BigInt(i)) & 1n);\n  }\n  return inputs;\n}\n\nfunction findFirstBadBit(gates: Gate[], numBits: number): number {\n  for (let bit = 0; bit <= numBits; bit++) {\n    const testValues: [bigint, bigint][] = [];\n    if (bit < numBits) {\n      testValues.push(\n        [1n << BigInt(bit), 0n],\n        [0n, 1n << BigInt(bit)],\n        [1n << BigInt(bit), 1n << BigInt(bit)],\n      );\n      if (bit > 0) {\n        testValues.push([(1n << BigInt(bit)) - 1n, 1n]);\n      }\n    }\n    if (bit === numBits) {\n      testValues.push([(1n << BigInt(numBits)) - 1n, (1n << BigInt(numBits)) - 1n]);\n    }\n\n    for (const [x, y] of testValues) {\n      const inputs = makeInputs(numBits, x, y);\n      const result = simulate(gates, inputs);\n      const expected = x + y;\n\n      for (let i = bit; i <= numBits; i++) {\n        if (result[`z${pad(i)}`] !== Number((expected >> BigInt(i)) & 1n)) return bit;\n      }\n    }\n  }\n  return -1;\n}\n\nfunction findSwapsIteratively(gates: Gate[], numBits: number): string[] {\n  const allSwaps: [string, string][] = [];\n  let currentGates = gates.map(g => ({ ...g }));\n  const allOutputWires = gates.map(g => g.out);\n\n  for (let round = 0; round < 4; round++) {\n    const badBit = findFirstBadBit(currentGates, numBits);\n    if (badBit === -1) break;\n\n    let found = false;\n    for (let i = 0; i < allOutputWires.length && !found; i++) {\n      for (let j = i + 1; j < allOutputWires.length && !found; j++) {\n        const alreadyUsed = allSwaps.some(([a, b]) =>\n          a === allOutputWires[i] || b === allOutputWires[i] ||\n          a === allOutputWires[j] || b === allOutputWires[j]);\n        if (alreadyUsed) continue;\n\n        const testGates = applySwaps(currentGates, [[allOutputWires[i], allOutputWires[j]]]);\n        const newBadBit = findFirstBadBit(testGates, numBits);\n        if (newBadBit > badBit || newBadBit === -1) {\n          allSwaps.push([allOutputWires[i], allOutputWires[j]]);\n          currentGates = testGates;\n          found = true;\n        }\n      }\n    }\n\n    if (!found) break;\n  }\n\n  const result: string[] = [];\n  for (const [a, b] of allSwaps) {\n    result.push(a, b);\n  }\n  return result.sort();\n}\n","structuredPatch":[{"oldStart":290,"oldLines":33,"newStart":290,"newLines":59,"lines":[" ","     if (!orGate) {","       // gen or prop has a wrong output name (same-role swap).","-      // Strategy: find the OR gate that uses gen. Its other input should","-      // be prop but has a different name. This tells us what prop SHOULD be","-      // named (and vice versa). We pick the one where gen is a confirmed","-      // \"correct\" input to the OR gate (meaning the OR also uses a wire","-      // from AND with inputs matching this bit's x/y or partialSum/carry).","+      // To disambiguate, find the correct OR gate for THIS bit.","+      // The correct OR's output should feed into the next bit's XOR and AND.","+      // We can identify it by finding which OR gate's output is used by","+      // XOR(partial_{i+1}, ?) for the next bit, OR is lastZ for the last bit."," ","+      let expectedCarryOut: string | undefi