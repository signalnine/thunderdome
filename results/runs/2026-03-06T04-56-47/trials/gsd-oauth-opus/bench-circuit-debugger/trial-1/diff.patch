+import { describe, it, expect } from 'vitest';
+import { findSwappedWires, Gate } from '../src/index.js';
+
+function buildCorrectAdder(numBits: number): Gate[] {
+  const gates: Gate[] = [];
+
+  gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });
+  gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'carry_00' });
+
+  for (let i = 1; i < numBits; i++) {
+    const xi = `x${String(i).padStart(2, '0')}`;
+    const yi = `y${String(i).padStart(2, '0')}`;
+    const zi = `z${String(i).padStart(2, '0')}`;
+    const prevCarry = `carry_${String(i - 1).padStart(2, '0')}`;
+    const partial = `partial_${String(i).padStart(2, '0')}`;
+    const gen = `gen_${String(i).padStart(2, '0')}`;
+    const prop = `prop_${String(i).padStart(2, '0')}`;
+    const carry = i === numBits - 1
+      ? `z${String(numBits).padStart(2, '0')}`
+      : `carry_${String(i).padStart(2, '0')}`;
+
+    gates.push({ op: 'XOR', in1: xi, in2: yi, out: partial });
+    gates.push({ op: 'XOR', in1: partial, in2: prevCarry, out: zi });
+    gates.push({ op: 'AND', in1: xi, in2: yi, out: gen });
+    gates.push({ op: 'AND', in1: partial, in2: prevCarry, out: prop });
+    gates.push({ op: 'OR', in1: gen, in2: prop, out: carry });
+  }
+
+  return gates;
+}
+
+function swapOutputs(gates: Gate[], w1: string, w2: string): Gate[] {
+  return gates.map(g => {
+    if (g.out === w1) return { ...g, out: w2 };
+    if (g.out === w2) return { ...g, out: w1 };
+    return g;
+  });
+}
+
+describe('findSwappedWires performance', () => {
+  it('should handle 45-bit adder with all cross-role swaps', () => {
+    const numBits = 45;
+    let gates = buildCorrectAdder(numBits);
+
+    // 4 cross-role swaps (all detectable by structural rules)
+    gates = swapOutputs(gates, 'z05', 'gen_05');
+    gates = swapOutputs(gates, 'z20', 'prop_20');
+    gates = swapOutputs(gates, 'partial_30', 'gen_30');
+    gates = swapOutputs(gates, 'z10', 'gen_10');
+
+    const start = Date.now();
+    const result = findSwappedWires(gates);
+    const elapsed = Date.now() - start;
+
+    console.log(`45-bit cross-role: ${elapsed}ms, found: ${result}`);
+    expect(result).toHaveLength(8);
+    expect(result).toEqual([
+      'gen_05', 'gen_10', 'gen_30', 'partial_30',
+      'prop_20', 'z05', 'z10', 'z20'
+    ].sort());
+    expect(elapsed).toBeLessThan(5000);
+  });
+
+  it('should handle same-role swap (two generates swapped)', () => {
+    const numBits = 45;
+    let gates = buildCorrectAdder(numBits);
+
+    // 3 cross-role swaps + 1 same-role swap (two generates swapped)
+    gates = swapOutputs(gates, 'z05', 'gen_05');
+    gates = swapOutputs(gates, 'z20', 'prop_20');
+    gates = swapOutputs(gates, 'partial_30', 'gen_30');
+    // Same-role: swap gen_10 and gen_40 (both AND(xi,yi) outputs, no cycle)
+    gates = swapOutputs(gates, 'gen_10', 'gen_40');
+
+    const start = Date.now();
+    const result = findSwappedWires(gates);
+    const elapsed = Date.now() - start;
+
+    console.log(`45-bit same-role: ${elapsed}ms, found: ${result}`);
+    expect(result).toHaveLength(8);
+    expect(result).toEqual([
+      'gen_05', 'gen_10', 'gen_30', 'gen_40',
+      'partial_30', 'prop_20', 'z05', 'z20'
+    ].sort());
+    expect(elapsed).toBeLessThan(5000);
+  });
+
+  it('should handle same-role swap (two props swapped)', () => {
+    const numBits = 45;
+    let gates = buildCorrectAdder(numBits);
+
+    // 3 cross-role swaps + 1 same-role swap (two props)
+    gates = swapOutputs(gates, 'z05', 'gen_05');
+    gates = swapOutputs(gates, 'z20', 'prop_20');
+    gates = swapOutputs(gates, 'partial_30', 'gen_30');
+    gates = swapOutputs(gates, 'prop_15', 'prop_35');
+
+    const start = Date.now();
+    const result = findSwappedWires(gates);
+    const elapsed = Date.now() - start;
+
+    console.log(`45-bit prop swap: ${elapsed}ms, found: ${result}`);
+    expect(result).toHaveLength(8);
+    expect(result).toEqual([
+      'gen_05', 'gen_30', 'partial_30', 'prop_15',
+      'prop_20', 'prop_35', 'z05', 'z20'
+    ].sort());
+    expect(elapsed).toBeLessThan(5000);
+  });
+
+  it('should handle same-role swap (two partials swapped)', () => {
+    const numBits = 45;
+    let gates = buildCorrectAdder(numBits);
+
+    // 3 cross-role swaps + 1 same-role swap (two partials)
+    gates = swapOutputs(gates, 'z05', 'gen_05');
+    gates = swapOutputs(gates, 'z20', 'prop_20');
+    gates = swapOutputs(gates, 'partial_30', 'gen_30');
+    gates = swapOutputs(gates, 'partial_10', 'partial_40');
+
+    const start = Date.now();
+    const result = findSwappedWires(gates);
+    const elapsed = Date.now() - start;
+
+    console.log(`45-bit partial swap: ${elapsed}ms, found: ${result}`);
+    expect(result).toHaveLength(8);
+    expect(result).toEqual([
+      'gen_05', 'gen_30', 'partial_10', 'partial_30',
+      'partial_40', 'prop_20', 'z05', 'z20'
+    ].sort());
+    expect(elapsed).toBeLessThan(5000);
+  });
+});
