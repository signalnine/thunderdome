dd(out);\n        }\n      }\n    }\n\n    // Rule 4: AND gates (except bit 0) must feed into OR\n    if (gate.op === 'AND') {\n      const isBit0 = (gate.in1 === 'x00' && gate.in2 === 'y00') || (gate.in1 === 'y00' && gate.in2 === 'x00');\n      if (!isBit0) {\n        const usedInOR = gates.some(g => g.op === 'OR' && (g.in1 === out || g.in2 === out));\n        if (!usedInOR) {\n          swapped.add(out);\n        }\n      }\n    }\n\n    // Rule 5: OR gates should not output to z (except last z bit)\n    if (gate.op === 'OR' && out.startsWith('z') && out !== lastZ) {\n      swapped.add(out);\n    }\n  }\n\n  if (swapped.size === 8) {\n    return [...swapped].sort();\n  }\n\n  // If we found 6 wires, pair them and fix, then walk the carry chain to find the 4th pair\n  if (swapped.size === 6) {\n    const pairs = pairFlaggedWires([...swapped], gateByOutput);\n\n    if (pairs.length === 3) {\n      // Fix the known swaps\n      const fixedGates = applySwaps(gates, pairs);\n      const remaining = walkAndFindSwap(fixedGates, numBits);\n      if (remaining) {\n        swapped.add(remaining[0]);\n        swapped.add(remaining[1]);\n      }\n    }\n  }\n\n  if (swapped.size === 8) {\n    return [...swapped].sort();\n  }\n\n  // Fallback: iterative simulation approach\n  return findSwapsIteratively(gates, numBits);\n}\n\nfunction applySwaps(gates: Gate[], swapPairs: [string, string][]): Gate[] {\n  const swapMap = new Map<string, string>();\n  for (const [a, b] of swapPairs) {\n    swapMap.set(a, b);\n    swapMap.set(b, a);\n  }\n  return gates.map(g => {\n    const newOut = swapMap.get(g.out);\n    return newOut !== undefined ? { ...g, out: newOut } : g;\n  });\n}\n\nfunction pairFlaggedWires(flagged: string[], gateByOutput: Map<string, Gate>): [string, string][] {\n  const pairs: [string, string][] = [];\n  const paired = new Set<string>();\n\n  // First: pair z-wires (from non-XOR gates) with non-z wires (from non-xy XOR gates)\n  for (const wire of flagged) {\n    if 