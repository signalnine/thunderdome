@@ -0,0 +1,69 @@
+import { Router, Response } from 'express';
+import { v4 as uuidv4 } from 'uuid';
+import { getDb } from '../db.js';
+import { authenticate } from '../middleware.js';
+import { AuthenticatedRequest } from '../types.js';
+
+const router = Router();
+
+// Ingest single event
+router.post('/', authenticate, (req: AuthenticatedRequest, res: Response): void => {
+  const { name, properties, timestamp, session_id } = req.body;
+
+  if (!name) {
+    res.status(400).json({ error: 'Event name is required' });
+    return;
+  }
+
+  const db = getDb();
+  const id = uuidv4();
+  const tenantId = req.user!.tenantId;
+  const userId = req.user!.userId;
+  const eventTimestamp = timestamp || new Date().toISOString();
+  const eventProperties = properties ? JSON.stringify(properties) : '{}';
+
+  db.prepare(
+    'INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)'
+  ).run(id, tenantId, name, eventProperties, eventTimestamp, userId, session_id || null);
+
+  res.status(201).json({
+    event: { id, tenant_id: tenantId, name, properties: eventProperties, timestamp: eventTimestamp, user_id: userId, session_id: session_id || null }
+  });
+});
+
+// Ingest batch events
+router.post('/batch', authenticate, (req: AuthenticatedRequest, res: Response): void => {
+  const { events } = req.body;
+
+  if (!Array.isArray(events) || events.length === 0) {
+    res.status(400).json({ error: 'events array is required and must not be empty' });
+    return;
+  }
+
+  const db = getDb();
+  const tenantId = req.user!.tenantId;
+  const userId = req.user!.userId;
+
+  const insert = db.prepare(
+    'INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)'
+  );
+
+  const insertedEvents: Array<{id: string; name: string; tenant_id: string; timestamp: string}> = [];
+
+  const insertMany = db.transaction(() => {
+    for (const event of events) {
+      if (!event.name) continue;
+      const id = uuidv4();
+      const eventTimestamp = event.timestamp || new Date().toISOString();
+      const eventProperties = event.properties ? JSON.stringify(event.properties) : '{}';
+      insert.run(id, tenantId, event.name, eventProperties, eventTimestamp, userId, event.session_id || null);
+      insertedEvents.push({ id, name: event.name, tenant_id: tenantId, timestamp: eventTimestamp });
+    }
+  });
+
+  insertMany();
+
+  res.status(201).json({ inserted: insertedEvents.length, events: insertedEvents });
+});
+
+export default router;
