+  const app = express();
+
+  app.use(express.json());
+
+  app.use('/api/users', userRoutes);
+  app.use('/api/events', eventRoutes);
+  app.use('/api/queries', queryRoutes);
+  app.use('/api/dashboards', dashboardRoutes);
+  app.use('/api/export', exportRoutes);
+
+  return app;
+}
