+++ b/src/routes/export.ts
@@ -0,0 +1,165 @@
+import { Router, Response } from 'express';
+import { getDb } from '../db.js';
+import { authenticate } from '../middleware.js';
+import { AuthenticatedRequest, Dashboard } from '../types.js';
+
+const router = Router();
+
+interface EventRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string | null;
+  session_id: string | null;
+}
+
+function eventsToCsv(events: EventRow[]): string {
+  const headers = ['id', 'name', 'properties', 'timestamp', 'user_id', 'session_id'];
+  const lines = [headers.join(',')];
+  for (const event of events) {
+    const row = [
+      event.id,
+      `"${(event.name || '').replace(/"/g, '""')}"`,
+      `"${(event.properties || '').replace(/"/g, '""')}"`,
+      event.timestamp,
+      event.user_id || '',
+      event.session_id || ''
+    ];
+    lines.push(row.join(','));
+  }
+  return lines.join('\n');
+}
+
+// Export events as JSON
+router.get('/events/json', authenticate, (req: AuthenticatedRequest, res: Response): void => {
+  const db = getDb();
+  const tenantId = req.user!.tenantId;
+
+  let query = 'SELECT * FROM events WHERE tenant_id = ?';
+  const params: string[] = [tenantId];
+
+  if (req.query.event_name) {
+    query += ' AND name = ?';
+    params.push(req.query.event_name as string);
+  }
+
+  if (req.query.start_date) {
+    query += ' AND timestamp >= ?';
+    params.push(req.query.start_date as string);
+  }
+
+  if (req.query.end_date) {
+    query += ' AND timestamp <= ?';
+    params.push(req.query.end_date as string);
+  }
+
+  query += ' ORDER BY timestamp DESC';
+
+  const events = db.prepare(query).all(...params) as EventRow[];
+
+  res.json({ events });
+});
+
+// Export events as CSV
+router.get('/events/csv', authenticate, (req: AuthenticatedRequest, res: Response): void => {
+  const db = getDb();
+  const tenantId = req.user!.tenantId;
+
+  let query = 'SELECT * FROM events WHERE tenant_id = ?';
+  const params: string[] = [tenantId];
+
+  if (req.query.event_name) {
+    query += ' AND name = ?';
+    params.push(req.query.event_name as string);
+  }
+
+  if (req.query.start_date) {
+    query += ' AND timestamp >= ?';
+    params.push(req.query.start_date as string);
+  }
+
+  if (req.query.end_date) {
+    query += ' AND timestamp <= ?';
+    params.push(req.query.end_date as string);
+  }
+
+  query += ' ORDER BY timestamp DESC';
+
+  const events = db.prepare(query).all(...params) as EventRow[];
+
+  res.setHeader('Content-Type', 'text/csv');
+  res.setHeader('Content-Disposition', 'attachment; filename="events.csv"');
+  res.send(eventsToCsv(events));
+});
+
+// Export dashboard as JSON
+router.get('/dashboards/:id/json', authenticate, (req: AuthenticatedRequest, res: Response): void => {
+  const db = getDb();
+  const tenantId = req.user!.tenantId;
+
+  const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(req.params.id, tenantId) as Dashboard | undefined;
+
+  if (!dashboard) {
+    res.status(404).json({ error: 'Dashboard not found' });
+    return;
+  }
+
+  const widgets = db.prepare('SELECT * FROM widgets WHERE dashboard_id = ?').all(dashboard.id);
+
+  res.json({ dashboard: { ...dashboard, widgets } });
+});
+
+// Export dashboard as CSV
+router.get('/dashboards/:id/csv', authenticate, (req: AuthenticatedRequest, res: Response): void => {
+  const db = getDb();
+  const tenantId = req.user!.tenantId;
+
+  const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(req.params.id, tenantId) as Dashboard | undefined;
+
+  if (!dashboard) {
+    res.status(404).json({ error: 'Dashboard not found' });
+    return;
+  }
+
+  const widgets = db.prepare('SELECT * FROM widgets WHERE dashboard_id = ?').all(dashboard.id) as Array<{
+    id: string;
+    dashboard_id: string;
+    type: string;
+    config: string;
+    position_x: number;
+    position_y: number;
+    width: number;
+    height: number;
+  }>;
+
+  const headers = ['dashboard_id', 'dashboard_name', 'widget_id', 'widget_type', 'config', 'position_x', 'position_y', 'width', 'height'];
+  const lines = [headers.join(',')];
+
+  if (widgets.length === 0) {
+    const row = [dashboard.id, `"${dashboard.name.replace(/"/g, '""')}"`, '', '', '', '', '', '', ''];
+    lines.push(row.join(','));
+  } else {
+    for (const widget of widgets) {
+      const row = [
+        dashboard.id,
+        `"${dashboard.name.replace(/"/g, '""')}"`,
+        widget.id,
+        widget.type,
+        `"${(widget.config || '').replace(/"/g, '""')}"`,
+        String(widget.position_x),
+        String(widget.position_y),
+        String(widget.width),
+        String(widget.height)
+      ];
+      lines.push(row.join(','));
+    }
+  }
+
+  res.setHeader('Content-Type', 'text/csv');
+  res.setHeader('Content-Disposition', `attachment; filename="dashboard-${dashboard.id}.csv"`);
+  res.send(lines.join('\n'));
+});
+
+export default router;
