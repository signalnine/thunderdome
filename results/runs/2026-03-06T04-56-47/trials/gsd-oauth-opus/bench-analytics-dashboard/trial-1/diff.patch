+++ b/src/routes/queries.ts
@@ -0,0 +1,124 @@
+import { Router, Response } from 'express';
+import { getDb } from '../db.js';
+import { authenticate } from '../middleware.js';
+import { AuthenticatedRequest } from '../types.js';
+
+const router = Router();
+
+// Count events
+router.post('/count', authenticate, (req: AuthenticatedRequest, res: Response): void => {
+  const { event_name, start_date, end_date, filters } = req.body;
+
+  const db = getDb();
+  const tenantId = req.user!.tenantId;
+
+  let query = 'SELECT COUNT(*) as count FROM events WHERE tenant_id = ?';
+  const params: (string)[] = [tenantId];
+
+  if (event_name) {
+    query += ' AND name = ?';
+    params.push(event_name);
+  }
+
+  if (start_date) {
+    query += ' AND timestamp >= ?';
+    params.push(start_date);
+  }
+
+  if (end_date) {
+    query += ' AND timestamp <= ?';
+    params.push(end_date);
+  }
+
+  if (filters && typeof filters === 'object') {
+    for (const [key, value] of Object.entries(filters)) {
+      query += ` AND json_extract(properties, '$.${key}') = ?`;
+      params.push(String(value));
+    }
+  }
+
+  const result = db.prepare(query).get(...params) as { count: number };
+  res.json({ count: result.count });
+});
+
+// Timeseries query
+router.post('/timeseries', authenticate, (req: AuthenticatedRequest, res: Response): void => {
+  const { event_name, start_date, end_date, interval, filters } = req.body;
+
+  if (!event_name) {
+    res.status(400).json({ error: 'event_name is required' });
+    return;
+  }
+
+  const db = getDb();
+  const tenantId = req.user!.tenantId;
+
+  const bucket = interval === 'hour' ? '%Y-%m-%dT%H:00:00' :
+                 interval === 'month' ? '%Y-%m' :
+                 '%Y-%m-%d';
+
+  let query = `SELECT strftime('${bucket}', timestamp) as period, COUNT(*) as count FROM events WHERE tenant_id = ? AND name = ?`;
+  const params: string[] = [tenantId, event_name];
+
+  if (start_date) {
+    query += ' AND timestamp >= ?';
+    params.push(start_date);
+  }
+
+  if (end_date) {
+    query += ' AND timestamp <= ?';
+    params.push(end_date);
+  }
+
+  if (filters && typeof filters === 'object') {
+    for (const [key, value] of Object.entries(filters)) {
+      query += ` AND json_extract(properties, '$.${key}') = ?`;
+      params.push(String(value));
+    }
+  }
+
+  query += ` GROUP BY period ORDER BY period ASC`;
+
+  const results = db.prepare(query).all(...params) as Array<{ period: string; count: number }>;
+  res.json({ timeseries: results });
+});
+
+// Breakdown query
+router.post('/breakdown', authenticate, (req: AuthenticatedRequest, res: Response): void => {
+  const { event_name, property, start_date, end_date, filters } = req.body;
+
+  if (!event_name || !property) {
+    res.status(400).json({ error: 'event_name and property are required' });
+    return;
+  }
+
+  const db = getDb();
+  const tenantId = req.user!.tenantId;
+
+  let query = `SELECT json_extract(properties, '$.${property}') as value, COUNT(*) as count FROM events WHERE tenant_id = ? AND name = ?`;
+  const params: string[] = [tenantId, event_name];
+
+  if (start_date) {
+    query += ' AND timestamp >= ?';
+    params.push(start_date);
+  }
+
+  if (end_date) {
+    query += ' AND timestamp <= ?';
+    params.push(end_date);
+  }
+
+  if (filters && typeof filters === 'object') {
+    for (const [key, value] of Object.entries(filters)) {
+      query += ` AND json_extract(properties, '$.${key}') = ?`;
+      params.push(String(value));
+    }
+  }
+
+  query += ' GROUP BY value ORDER BY count DESC';
+
+  const results = db.prepare(query).all(...params) as Array<{ value: string; count: number }>;
+  res.json({ breakdown: results });
+});
+
+export default router;
