@@ -0,0 +1,99 @@
+import { Router, Response } from 'express';
+import { v4 as uuidv4 } from 'uuid';
+import { getDb } from '../db.js';
+import { authenticate } from '../middleware.js';
+import { AuthenticatedRequest, Dashboard } from '../types.js';
+
+const router = Router();
+
+// List dashboards for tenant
+router.get('/', authenticate, (req: AuthenticatedRequest, res: Response): void => {
+  const db = getDb();
+  const tenantId = req.user!.tenantId;
+
+  const dashboards = db.prepare('SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC').all(tenantId);
+  res.json({ dashboards });
+});
+
+// Get single dashboard
+router.get('/:id', authenticate, (req: AuthenticatedRequest, res: Response): void => {
+  const db = getDb();
+  const tenantId = req.user!.tenantId;
+
+  const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(req.params.id, tenantId) as Dashboard | undefined;
+
+  if (!dashboard) {
+    res.status(404).json({ error: 'Dashboard not found' });
+    return;
+  }
+
+  const widgets = db.prepare('SELECT * FROM widgets WHERE dashboard_id = ?').all(dashboard.id);
+
+  res.json({ dashboard: { ...dashboard, widgets } });
+});
+
+// Create dashboard
+router.post('/', authenticate, (req: AuthenticatedRequest, res: Response): void => {
+  const { name, config } = req.body;
+
+  if (!name) {
+    res.status(400).json({ error: 'Dashboard name is required' });
+    return;
+  }
+
+  const db = getDb();
+  const id = uuidv4();
+  const tenantId = req.user!.tenantId;
+  const ownerId = req.user!.userId;
+  const dashboardConfig = config ? JSON.stringify(config) : '{}';
+
+  db.prepare(
+    'INSERT INTO dashboards (id, tenant_id, name, owner_id, config) VALUES (?, ?, ?, ?, ?)'
+  ).run(id, tenantId, name, ownerId, dashboardConfig);
+
+  const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ?').get(id);
+  res.status(201).json({ dashboard });
+});
+
+// Update dashboard
+router.put('/:id', authenticate, (req: AuthenticatedRequest, res: Response): void => {
+  const db = getDb();
+  const tenantId = req.user!.tenantId;
+
+  const existing = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(req.params.id, tenantId) as Dashboard | undefined;
+
+  if (!existing) {
+    res.status(404).json({ error: 'Dashboard not found' });
+    return;
+  }
+
+  const { name, config } = req.body;
+  const updatedName = name || existing.name;
+  const updatedConfig = config ? JSON.stringify(config) : existing.config;
+  const updatedAt = new Date().toISOString();
+
+  db.prepare(
+    'UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?'
+  ).run(updatedName, updatedConfig, updatedAt, req.params.id);
+
+  const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ?').get(req.params.id);
+  res.json({ dashboard });
+});
+
+// Delete dashboard
+router.delete('/:id', authenticate, (req: AuthenticatedRequest, res: Response): void => {
+  const db = getDb();
+  const tenantId = req.user!.tenantId;
+
+  const existing = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(req.params.id, tenantId) as Dashboard | undefined;
+
+  if (!existing) {
+    res.status(404).json({ error: 'Dashboard not found' });
+    return;
+  }
+
+  db.prepare('DELETE FROM dashboards WHERE id = ?').run(req.params.id);
+  res.json({ message: 'Dashboard deleted' });
+});
+
+export default router;
