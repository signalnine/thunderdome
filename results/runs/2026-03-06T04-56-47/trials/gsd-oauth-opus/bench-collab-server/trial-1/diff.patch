+/**
+ * Operational Transform (OT) implementation for collaborative text editing.
+ *
+ * Operations are arrays of components:
+ * - number > 0: retain that many characters
+ * - string: insert that text
+ * - number < 0: delete that many characters
+ *
+ * An operation's "input length" is the sum of retains + abs(deletes).
+ * An operation's "output length" is the sum of retains + insert lengths.
+ */
+
+export type OpComponent = number | string;
+export type Operation = OpComponent[];
+
+export function inputLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (typeof c === "number") {
+      len += c > 0 ? c : -c;
+    }
+  }
+  return len;
+}
+
+export function outputLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (typeof c === "string") {
+      len += c.length;
+    } else if (c > 0) {
+      len += c;
+    }
+  }
+  return len;
+}
+
+/** Apply an operation to a document string. */
+export function apply(doc: string, op: Operation): string {
+  const inLen = inputLength(op);
+  if (inLen !== doc.length) {
+    throw new Error(
+      `Operation input length (${inLen}) does not match document length (${doc.length})`
+    );
+  }
+  let result = "";
+  let pos = 0;
+  for (const c of op) {
+    if (typeof c === "string") {
+      result += c;
+    } else if (c > 0) {
+      result += doc.slice(pos, pos + c);
+      pos += c;
+    } else {
+      // delete
+      pos += -c;
+    }
+  }
+  return result;
+}
+
+/**
+ * Compose two consecutive operations into one.
+ * apply(apply(doc, a), b) === apply(doc, compose(a, b))
+ */
+export function compose(a: Operation, b: Operation): Operation {
+  if (outputLength(a) !== inputLength(b)) {
+    throw new Error("Compose: output length of a must equal input length of b");
+  }
+
+  const result: Operation = [];
+  let ai = 0;
+  let bi = 0;
+  let aRem: OpComponent | null = null;
+  let bRem: OpComponent | null = null;
+
+  function nextA(): OpComponent | null {
+    if (aRem !== null) {
+      const v = aRem;
+      aRem = null;
+      return v;
+    }
+    if (ai < a.length) return a[ai++];
+    return null;
+  }
+
+  function nextB(): OpComponent | null {
+    if (bRem !== null) {
+      const v = bRem;
+      bRem = null;
+      return v;
+    }
+    if (bi < b.length) return b[bi++];
+    return null;
+  }
+
+  function push(c: OpComponent) {
+    if (c === 0 || c === "") return;
+    if (result.length > 0) {
+      const last = result[result.length - 1];
+      if (typeof c === "number" && typeof last === "number") {
+        if ((c > 0 && last > 0) || (c < 0 && last < 0)) {
+          result[result.length - 1] = last + c;
+          return;
+        }
+      }
+      if (typeof c === "string" && typeof last === "string") {
+        result[result.length - 1] = last + c;
+        return;
+      }
+    }
+    result.push(c);
+  }
+
+  let done = false;
+  while (!done) {
+    const ac = nextA();
+    const bc = nextB();
+    if (ac === null && bc === null) {
+      done = true;
+      continue;
+    }
+
+    // a is delete
+    if (typeof ac === "number" && ac !== null && ac < 0) {
+      push(ac);
+      if (bc !== null) bRem = bc;
+      continue;
+    }
+
+    // b is insert
+    if (typeof bc === "string") {
+      push(bc);
+      if (ac !== null) aRem = ac;
+      continue;
+    }
+
+    if (ac === null || bc === null) {
+      throw new Error("Compose: operations are incompatible");
+    }
+
+    // both retain
+    if (typeof ac === "number" && ac > 0 && typeof bc === "number" && bc > 0) {
+      const min = Math.min(ac, bc);
+      push(min);
+      if (ac > min) aRem = ac - min;
+      if (bc > min) bRem = bc - min;
+      continue;
+    }
+
+    // a is insert, b is retain
+    if (typeof ac === "string" && typeof bc === "number" && bc > 0) {
+      const min = Math.min(ac.length, bc);
+      push(ac.slice(0, min));
+      if (ac.length > min) aRem = ac.slice(min);
+      if (bc > min) bRem = bc - min;
+      continue;
+    }
+
+    // a is insert, b is delete
+    if (typeof ac === "string" && typeof bc === "number" && bc < 0) {
+      const min = Math.min(ac.length, -bc);
+      // insert then delete cancel out
+      if (ac.length > min) aRem = ac.slice(min);
+      if (-bc > min) bRem = -((-bc) - min);
+      continue;
+    }
+
+    // a is retain, b is delete
+    if (typeof ac === "number" && ac > 0 && typeof bc === "number" && bc < 0) {
+      const min = Math.min(ac, -bc);
+      push(-min);
+      if (ac > min) aRem = ac - min;
+      if (-bc > min) bRem = -((-bc) - min);
+      continue;
+    }
+
+    throw new Error(`Compose: unexpected components a=${ac} b=${bc}`);
+  }
+
+  return result;
+}
+
+/**
+ * Transform two concurrent operations.
+ * Given operations a and b that both apply to the same document,
+ * returns [a', b'] such that:
+ *   apply(apply(doc, a), b') === apply(apply(doc, b), a')
+ *
+ * a has priority when both insert at the same position (a's insert comes first).
+ */
+export function transform(
+  a: Operation,
+  b: Operation
+): [Operation, Operation] {
+  if (inputLength(a) !== inputLength(b)) {
+    throw new Error("Transform: both operations must have the same input length");
+  }
+
+  const aPrime: Operation = [];
+  const bPrime: Operation = [];
+  let ai = 0;
+  let bi = 0;
+  let aRem: OpComponent | null = null;
+  let bRem: OpComponent | null = null;
+
+  function nextA(): OpComponent | null {
+    if (aRem !== null) {
+      const v = aRem;
+      aRem = null;
+      return v;
+    }
+    if (ai < a.length) return a[ai++];
+    return null;
+  }
+
+  function nextB(): OpComponent | null {
+    if (bRem !== null) {
+      const v = bRem;
+      bRem = null;
+      return v;
+    }
+    if (bi < b.length) return b[bi++];
+    return null;
+  }
+
+  function pushA(c: OpComponent) {
+    if (c === 0 || c === "") return;
+    if (aPrime.length > 0) {
+      const last = aPrime[aPrime.length - 1];
+      if (typeof c === "number" && typeof last === "number" && ((c > 0 && last > 0) || (c < 0 && last < 0))) {
+        aPrime[aPrime.length - 1] = last + c;
+        return;
+      }
+      if (typeof c === "string" && typeof last === "string") {
+        aPrime[aPrime.length - 1] = last + c;
+        return;
+      }
+    }
+    aPrime.push(c);
+  }
+
+  function pushB(c: OpComponent) {
+    if (c === 0 || c === "") return;
+    if (bPrime.length > 0) {
+      const last = bPrime[bPrime.length - 1];
+      if (typeof c === "number" && typeof last === "number" && ((c > 0 && last > 0) || (c < 0 && last < 0))) {
+        bPrime[bPrime.length - 1] = last + c;
+        return;
+      }
+      if (typeof c === "string" && typeof last === "string") {
+        bPrime[bPrime.length - 1] = last + c;
+        return;
+      }
+    }
+    bPrime.push(c);
+  }
+
+  let finished = false;
+  while (!finished) {
+    const ac = nextA();
+    const bc = nextB();
+
+    if (ac === null && bc === null) {
+      finished = true;
+      continue;
+    }
+
+    // a inserts (priority: a's insert comes first)
+    if (typeof ac === "string") {
+      pushA(ac);
+      pushB(ac.length); // b' must retain over a's insertion
+      if (bc !== null) bRem = bc;
+      continue;
+    }
+
+    // b inserts
+    if (typeof bc === "string") {
+      pushB(bc);
+      pushA(bc.length); // a' must retain over b's insertion
+      if (ac !== null) aRem = ac;
+      continue;
+    }
+
+    if (ac === null || bc === null) {
+      throw new Error("Transform: operations are incompatible");
+    }
+
+    // both retain
+    if (typeof ac === "number" && ac > 0 && typeof bc === "number" && bc > 0) {
+      const min = Math.min(ac, bc);
+      pushA(min);
+      pushB(min);
+      if (ac > min) aRem = ac - min;
+      if (bc > min) bRem = bc - min;
+      continue;
+    }
+
+    // a deletes, b deletes
+    if (typeof ac === "number" && ac < 0 && typeof bc === "number" && bc < 0) {
+      const min = Math.min(-ac, -bc);
+      // both delete the same chars – no output in either prime
+      if (-ac > min) aRem = -((-ac) - min);
+      if (-bc > min) bRem = -((-bc) - min);
+      continue;
+    }
+
+    // a deletes, b retains
+    if (typeof ac === "number" && ac < 0 && typeof bc === "number" && bc > 0) {
+      const min = Math.min(-ac, bc);
+      pushA(-min);
+      // b' doesn't need to retain what a deleted
+      if (-ac > min) aRem = -((-ac) - min);
+      if (bc > min) bRem = bc - min;
+      continue;
+    }
+
+    // a retains, b deletes
+    if (typeof ac === "number" && ac > 0 && typeof bc === "number" && bc < 0) {
+      const min = Math.min(ac, -bc);
+      pushB(-min);
+      // a' doesn't need to retain what b deleted
+      if (ac > min) aRem = ac - min;
+      if (-bc > min) bRem = -((-bc) - min);
+      continue;
+    }
+
+    throw new Error(`Transform: unexpected components a=${ac} b=${bc}`);
+  }
+
+  return [aPrime, bPrime];
+}
+
+/** Validate that an operation is well-formed for a document of given length. */
+export function validate(op: Operation, docLength: number): string | null {
+  if (!Array.isArray(op)) return "Operation must be an array";
+  for (const c of op) {
+    if (typeof c === "number") {
+      if (!Number.isInteger(c) || c === 0) return "Numeric components must be non-zero integers";
+    } else if (typeof c === "string") {
+      if (c.length === 0) return "String components must be non-empty";
+    } else {
+      return "Components must be numbers or strings";
+    }
+  }
+  const inLen = inputLength(op);
+  if (inLen !== docLength) {
+    return `Operation input length (${inLen}) does not match document length (${docLength})`;
+  }
+  return null;
+}
+
+/** Create an insert operation at a position in a document of given length. */
+export function makeInsert(pos: number, text: string, docLength: number): Operation {
+  const op: Operation = [];
+  if (pos > 0) op.push(pos);
+  op.push(text);
+  if (docLength - pos > 0) op.push(docLength - pos);
+  return op;
+}
+
+/** Create a delete operation at a position in a document of given length. */
+export function makeDelete(pos: number, count: number, docLength: number): Operation {
+  const op: Operation = [];
+  if (pos > 0) op.push(pos);
+  op.push(-count);
+  if (docLength - pos - count > 0) op.push(docLength - pos - count);
+  return op;
+}
