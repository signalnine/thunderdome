+import { describe, it, expect } from "vitest";
+import {
+  apply,
+  compose,
+  transform,
+  validate,
+  makeInsert,
+  makeDelete,
+  inputLength,
+  outputLength,
+} from "./ot.js";
+
+describe("OT - basic operations", () => {
+  it("apply insert at beginning", () => {
+    expect(apply("hello", ["world ", 5])).toBe("world hello");
+  });
+
+  it("apply insert at end", () => {
+    expect(apply("hello", [5, " world"])).toBe("hello world");
+  });
+
+  it("apply insert in middle", () => {
+    expect(apply("hllo", [1, "e", 3])).toBe("hello");
+  });
+
+  it("apply delete", () => {
+    expect(apply("hello", [-1, 4])).toBe("ello");
+  });
+
+  it("apply delete in middle", () => {
+    expect(apply("hello", [1, -3, 1])).toBe("ho");
+  });
+
+  it("apply retain all", () => {
+    expect(apply("hello", [5])).toBe("hello");
+  });
+
+  it("apply on empty doc", () => {
+    expect(apply("", ["hello"])).toBe("hello");
+  });
+
+  it("throws on length mismatch", () => {
+    expect(() => apply("hello", [10])).toThrow();
+  });
+});
+
+describe("OT - inputLength / outputLength", () => {
+  it("inputLength of retain + delete", () => {
+    expect(inputLength([3, -2, 1])).toBe(6);
+  });
+
+  it("outputLength of retain + insert", () => {
+    expect(outputLength([3, "ab", 1])).toBe(6);
+  });
+
+  it("insert does not count as input", () => {
+    expect(inputLength(["hello"])).toBe(0);
+  });
+});
+
+describe("OT - validate", () => {
+  it("valid operation", () => {
+    expect(validate([3, "ab", -1, 2], 6)).toBeNull();
+  });
+
+  it("invalid - length mismatch", () => {
+    expect(validate([3], 5)).not.toBeNull();
+  });
+
+  it("invalid - zero component", () => {
+    expect(validate([0, 3], 3)).not.toBeNull();
+  });
+
+  it("invalid - empty string", () => {
+    expect(validate(["", 3], 3)).not.toBeNull();
+  });
+});
+
+describe("OT - compose", () => {
+  it("compose two inserts", () => {
+    const a = makeInsert(0, "hello", 0);
+    const b = makeInsert(5, " world", 5);
+    const c = compose(a, b);
+    expect(apply("", c)).toBe("hello world");
+  });
+
+  it("compose insert then delete", () => {
+    const a = makeInsert(0, "hello", 0);
+    const b = makeDelete(0, 2, 5);
+    const c = compose(a, b);
+    expect(apply("", c)).toBe("llo");
+  });
+
+  it("compose retains", () => {
+    const a = [5] as const;
+    const b = [5] as const;
+    const c = compose([...a], [...b]);
+    expect(apply("hello", c)).toBe("hello");
+  });
+});
+
+describe("OT - transform", () => {
+  it("transform two inserts at different positions", () => {
+    const doc = "hello";
+    const a = makeInsert(0, "A", 5); // "Ahello"
+    const b = makeInsert(5, "B", 5); // "helloB"
+
+    const [aPrime, bPrime] = transform(a, b);
+
+    const docA = apply(doc, a);
+    const docB = apply(doc, b);
+    const result1 = apply(docA, bPrime);
+    const result2 = apply(docB, aPrime);
+
+    expect(result1).toBe(result2);
+    expect(result1).toBe("AhelloB");
+  });
+
+  it("transform two inserts at same position", () => {
+    const doc = "hello";
+    const a = makeInsert(0, "A", 5);
+    const b = makeInsert(0, "B", 5);
+
+    const [aPrime, bPrime] = transform(a, b);
+
+    const result1 = apply(apply(doc, a), bPrime);
+    const result2 = apply(apply(doc, b), aPrime);
+
+    expect(result1).toBe(result2);
+    // a has priority, so A comes before B
+    expect(result1).toBe("ABhello");
+  });
+
+  it("transform insert and delete", () => {
+    const doc = "hello";
+    const a = makeInsert(2, "X", 5); // "heXllo"
+    const b = makeDelete(0, 2, 5); // "llo"
+
+    const [aPrime, bPrime] = transform(a, b);
+
+    const result1 = apply(apply(doc, a), bPrime);
+    const result2 = apply(apply(doc, b), aPrime);
+
+    expect(result1).toBe(result2);
+    expect(result1).toBe("Xllo");
+  });
+
+  it("transform two deletes at same position", () => {
+    const doc = "hello";
+    const a = makeDelete(0, 2, 5); // "llo"
+    const b = makeDelete(0, 2, 5); // "llo"
+
+    const [aPrime, bPrime] = transform(a, b);
+
+    const result1 = apply(apply(doc, a), bPrime);
+    const result2 = apply(apply(doc, b), aPrime);
+
+    expect(result1).toBe(result2);
+    expect(result1).toBe("llo");
+  });
+
+  it("transform overlapping deletes", () => {
+    const doc = "hello";
+    const a = makeDelete(0, 3, 5); // "lo"
+    const b = makeDelete(2, 3, 5); // "he"
+
+    const [aPrime, bPrime] = transform(a, b);
+
+    const result1 = apply(apply(doc, a), bPrime);
+    const result2 = apply(apply(doc, b), aPrime);
+
+    expect(result1).toBe(result2);
+  });
+
+  it("convergence with multiple concurrent edits", () => {
+    const doc = "abcdef";
+    // User A inserts "X" at position 2
+    const a = makeInsert(2, "X", 6);
+    // User B inserts "Y" at position 4
+    const b = makeInsert(4, "Y", 6);
+
+    const [aPrime, bPrime] = transform(a, b);
+
+    const result1 = apply(apply(doc, a), bPrime);
+    const result2 = apply(apply(doc, b), aPrime);
+
+    expect(result1).toBe(result2);
+    expect(result1).toBe("abXcdYef");
+  });
+});
+
+describe("OT - makeInsert / makeDelete", () => {
+  it("makeInsert creates valid operation", () => {
+    const op = makeInsert(3, "abc", 10);
+    expect(validate(op, 10)).toBeNull();
+    expect(apply("0123456789", op)).toBe("012abc3456789");
+  });
+
+  it("makeDelete creates valid operation", () => {
+    const op = makeDelete(3, 2, 10);
+    expect(validate(op, 10)).toBeNull();
+    expect(apply("0123456789", op)).toBe("01256789");
+  });
+});
