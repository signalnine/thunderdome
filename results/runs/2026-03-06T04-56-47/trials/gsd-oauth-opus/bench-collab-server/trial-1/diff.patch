new file mode 100644
index 0000000..7a9ac7e
--- /dev/null
+++ b/src/collaboration.ts
@@ -0,0 +1,313 @@
+import { WebSocketServer, WebSocket } from "ws";
+import { IncomingMessage } from "http";
+import { Server as HttpServer } from "http";
+import { DocumentStore } from "./db.js";
+import { Operation, apply, transform, validate } from "./ot.js";
+
+interface ClientConnection {
+  ws: WebSocket;
+  clientId: string;
+  documentId: string;
+  /** The server version that this client has acknowledged. */
+  acknowledgedVersion: number;
+}
+
+interface DocumentSession {
+  documentId: string;
+  clients: Map<string, ClientConnection>;
+  /** Current server version (incremented on each accepted operation). */
+  version: number;
+  /** The server version when the session was created (history[0] corresponds to startVersion). */
+  startVersion: number;
+  /** The current document content in memory. */
+  content: string;
+  /** History of operations. history[i] produced version (startVersion + i + 1). */
+  history: Operation[];
+}
+
+/** Messages from client to server */
+interface ClientOperationMessage {
+  type: "operation";
+  version: number;
+  operation: Operation;
+}
+
+/** Messages from server to client */
+interface ServerSyncMessage {
+  type: "sync";
+  content: string;
+  version: number;
+  clientId: string;
+}
+
+interface ServerAckMessage {
+  type: "ack";
+  version: number;
+}
+
+interface ServerOperationMessage {
+  type: "operation";
+  operation: Operation;
+  version: number;
+  clientId: string;
+}
+
+interface ServerErrorMessage {
+  type: "error";
+  message: string;
+}
+
+type ServerMessage =
+  | ServerSyncMessage
+  | ServerAckMessage
+  | ServerOperationMessage
+  | ServerErrorMessage;
+
+let clientCounter = 0;
+
+export class CollaborationManager {
+  private sessions: Map<string, DocumentSession> = new Map();
+  private wss: WebSocketServer | null = null;
+  private store: DocumentStore;
+
+  constructor(store: DocumentStore) {
+    this.store = store;
+  }
+
+  attach(server: HttpServer): void {
+    this.wss = new WebSocketServer({ server });
+
+    this.wss.on("connection", (ws: WebSocket, req: IncomingMessage) => {
+      const url = req.url || "";
+      // Expected path: /ws/documents/:id
+      const match = url.match(/^\/ws\/documents\/([^/?]+)/);
+      if (!match) {
+        this.send(ws, { type: "error", message: "Invalid WebSocket path. Use /ws/documents/:id" });
+        ws.close(1008, "Invalid path");
+        return;
+      }
+
+      const documentId = match[1];
+      this.handleConnection(ws, documentId);
+    });
+  }
+
+  private handleConnection(ws: WebSocket, documentId: string): void {
+    const doc = this.store.getById(documentId);
+    if (!doc) {
+      this.send(ws, { type: "error", message: "Document not found" });
+      ws.close(1008, "Document not found");
+      return;
+    }
+
+    const clientId = `client-${++clientCounter}`;
+    const session = this.getOrCreateSession(documentId, doc.content);
+
+    const client: ClientConnection = {
+      ws,
+      clientId,
+      documentId,
+      acknowledgedVersion: session.version,
+    };
+
+    session.clients.set(clientId, client);
+
+    // Send sync message
+    this.send(ws, {
+      type: "sync",
+      content: session.content,
+      version: session.version,
+      clientId,
+    });
+
+    ws.on("message", (data) => {
+      try {
+        const msg = JSON.parse(data.toString());
+        this.handleMessage(client, session, msg);
+      } catch (err) {
+        this.send(ws, {
+          type: "error",
+          message: `Invalid message: ${err instanceof Error ? err.message : String(err)}`,
+        });
+      }
+    });
+
+    ws.on("close", () => {
+      session.clients.delete(clientId);
+      if (session.clients.size === 0) {
+        // Persist final content and remove session
+        this.persistSession(session);
+        this.sessions.delete(documentId);
+      }
+    });
+
+    ws.on("error", () => {
+      session.clients.delete(clientId);
+    });
+  }
+
+  private handleMessage(
+    client: ClientConnection,
+    session: DocumentSession,
+    msg: unknown
+  ): void {
+    if (!msg || typeof msg !== "object" || !("type" in msg)) {
+      this.send(client.ws, { type: "error", message: "Invalid message format" });
+      return;
+    }
+
+    const message = msg as Record<string, unknown>;
+
+    if (message.type === "operation") {
+      this.handleOperation(client, session, message as unknown as ClientOperationMessage);
+    } else {
+      this.send(client.ws, { type: "error", message: `Unknown message type: ${String(message.type)}` });
+    }
+  }
+
+  private handleOperation(
+    client: ClientConnection,
+    session: DocumentSession,
+    msg: ClientOperationMessage
+  ): void {
+    const { version, operation } = msg;
+
+    if (typeof version !== "number" || !Number.isInteger(version)) {
+      this.send(client.ws, { type: "error", message: "version must be an integer" });
+      return;
+    }
+
+    if (!Array.isArray(operation)) {
+      this.send(client.ws, { type: "error", message: "operation must be an array" });
+      return;
+    }
+
+    if (version < session.startVersion || version > session.version) {
+      this.send(client.ws, {
+        type: "error",
+        message: `Invalid version ${version}. Current server version is ${session.version}`,
+      });
+      return;
+    }
+
+    // Transform operation against all operations that happened since the client's version.
+    let transformedOp = operation;
+    const startIndex = version - session.startVersion;
+    const endIndex = session.version - session.startVersion;
+    for (let i = startIndex; i < endIndex; i++) {
+      const serverOp = session.history[i];
+      try {
+        const [aPrime] = transform(transformedOp, serverOp);
+        transformedOp = aPrime;
+      } catch (err) {
+        this.send(client.ws, {
+          type: "error",
+          message: `Transform error: ${err instanceof Error ? err.message : String(err)}`,
+        });
+        return;
+      }
+    }
+
+    // Validate transformed operation against current document
+    const validationError = validate(transformedOp, session.content.length);
+    if (validationError) {
+      this.send(client.ws, { type: "error", message: `Invalid operation: ${validationError}` });
+      return;
+    }
+
+    // Apply
+    try {
+      session.content = apply(session.content, transformedOp);
+    } catch (err) {
+      this.send(client.ws, {
+        type: "error",
+        message: `Apply error: ${err instanceof Error ? err.message : String(err)}`,
+      });
+      return;
+    }
+
+    session.history.push(transformedOp);
+    session.version++;
+
+    // Acknowledge the sender
+    client.acknowledgedVersion = session.version;
+    this.send(client.ws, {
+      type: "ack",
+      version: session.version,
+    });
+
+    // Broadcast to all other clients
+    for (const [id, other] of session.clients) {
+      if (id === client.clientId) continue;
+      if (other.ws.readyState === WebSocket.OPEN) {
+        this.send(other.ws, {
+          type: "operation",
+          operation: transformedOp,
+          version: session.version,
+          clientId: client.clientId,
+        });
+      }
+    }
+
+    // Periodically persist (every 10 operations)
+    if (session.version % 10 === 0) {
+      this.persistSession(session);
+    }
+  }
+
+  private getOrCreateSession(documentId: string, content: string): DocumentSession {
+    let session = this.sessions.get(documentId);
+    if (!session) {
+      const maxVersion = this.store.getMaxVersion(documentId);
+      session = {
+        documentId,
+        clients: new Map(),
+        version: maxVersion,
+        startVersion: maxVersion,
+        content,
+        history: [],
+      };
+      this.sessions.set(documentId, session);
+    }
+    return session;
+  }
+
+  private persistSession(session: DocumentSession): void {
+    try {
+      this.store.updateContent(
+        session.documentId,
+        session.content,
+        JSON.stringify(session.history[session.history.length - 1] || null)
+      );
+    } catch {
+      // Silently handle persistence errors - don't crash
+    }
+  }
+
+  private send(ws: WebSocket, msg: ServerMessage): void {
+    if (ws.readyState === WebSocket.OPEN) {
+      ws.send(JSON.stringify(msg));
+    }
+  }
+
+  /** Get a session for testing/inspection purposes */
+  getSession(documentId: string): DocumentSession | undefined {
+    return this.sessions.get(documentId);
+  }
+
+  closeAll(): void {
+    // Persist all sessions before closing
+    for (const session of this.sessions.values()) {
+      this.persistSession(session);
+    }
+
+    if (this.wss) {
+      for (const client of this.wss.clients) {
+        client.close(1001, "Server shutting down");
+      }
+      this.wss.close();
+      this.wss = null;
+    }
+    this.sessions.clear();
+  }
+}
diff --git a/src/db.ts b/src/db.ts
new file mode 100644
index 0000000..ca0d485
--- /dev/null
+++ b/src/db.ts
@@ -0,0 +1,161 @@
+import Database from "better-sqlite3";
+import { readFileSync } from "fs";
+import { join, dirname } from "path";
+import { fileURLToPath } from "url";
+
+const __dirname = dirname(fileURLToPath(import.meta.url));
+
+export interface DocumentRow {
+  id: string;
+  title: string;
+  content: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface VersionRow {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operation: string | null;
+  created_at: string;
+}
+
+export function createDb(dbPath?: string): Database.Database {
+  const db = new Database(dbPath || ":memory:");
+  db.pragma("journal_mode = WAL");
+  db.pragma("foreign_keys = ON");
+
+  const schemaPath = join(__dirname, "..", "schema.sql");
+  try {
+    const schema = readFileSync(schemaPath, "utf-8");
+    db.exec(schema);
+  } catch {
+    // If schema file not found, define inline
+    db.exec(`
+      CREATE TABLE IF NOT EXISTS documents (
+        id TEXT PRIMARY KEY,
+        title TEXT NOT NULL,
+        content TEXT NOT NULL DEFAULT '',
+        created_at TEXT NOT NULL DEFAULT (datetime('now')),
+        updated_at TEXT NOT NULL DEFAULT (datetime('now'))
+      );
+      CREATE TABLE IF NOT EXISTS versions (
+        id INTEGER PRIMARY KEY AUTOINCREMENT,
+        document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
+        version INTEGER NOT NULL,
+        content TEXT NOT NULL,
+        operation TEXT,
+        created_at TEXT NOT NULL DEFAULT (datetime('now')),
+        UNIQUE(document_id, version)
+      );
+      CREATE TABLE IF NOT EXISTS active_connections (
+        id TEXT PRIMARY KEY,
+        document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
+        connected_at TEXT NOT NULL DEFAULT (datetime('now'))
+      );
+    `);
+  }
+
+  return db;
+}
+
+export class DocumentStore {
+  private db: Database.Database;
+
+  private stmts: {
+    insert: Database.Statement;
+    getById: Database.Statement;
+    getAll: Database.Statement;
+    update: Database.Statement;
+    updateContent: Database.Statement;
+    delete: Database.Statement;
+    insertVersion: Database.Statement;
+    getVersions: Database.Statement;
+    getMaxVersion: Database.Statement;
+  };
+
+  constructor(db: Database.Database) {
+    this.db = db;
+
+    this.stmts = {
+      insert: this.db.prepare(
+        "INSERT INTO documents (id, title, content) VALUES (?, ?, ?)"
+      ),
+      getById: this.db.prepare("SELECT * FROM documents WHERE id = ?"),
+      getAll: this.db.prepare("SELECT * FROM documents ORDER BY updated_at DESC"),
+      update: this.db.prepare(
+        "UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?"
+      ),
+      updateContent: this.db.prepare(
+        "UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?"
+      ),
+      delete: this.db.prepare("DELETE FROM documents WHERE id = ?"),
+      insertVersion: this.db.prepare(
+        "INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)"
+      ),
+      getVersions: this.db.prepare(
+        "SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC"
+      ),
+      getMaxVersion: this.db.prepare(
+        "SELECT COALESCE(MAX(version), 0) as max_version FROM versions WHERE document_id = ?"
+      ),
+    };
+  }
+
+  create(id: string, title: string, content: string = ""): DocumentRow {
+    this.stmts.insert.run(id, title, content);
+    // Save initial version
+    this.stmts.insertVersion.run(id, 1, content, null);
+    return this.getById(id)!;
+  }
+
+  getById(id: string): DocumentRow | undefined {
+    return this.stmts.getById.get(id) as DocumentRow | undefined;
+  }
+
+  getAll(): DocumentRow[] {
+    return this.stmts.getAll.all() as DocumentRow[];
+  }
+
+  update(id: string, title: string, content: string): DocumentRow | undefined {
+    const result = this.stmts.update.run(title, content, id);
+    if (result.changes === 0) return undefined;
+    // Save a new version
+    const maxVer = (
+      this.stmts.getMaxVersion.get(id) as { max_version: number }
+    ).max_version;
+    this.stmts.insertVersion.run(id, maxVer + 1, content, null);
+    return this.getById(id);
+  }
+
+  updateContent(id: string, content: string, operation?: string): number {
+    this.stmts.updateContent.run(content, id);
+    const maxVer = (
+      this.stmts.getMaxVersion.get(id) as { max_version: number }
+    ).max_version;
+    const newVersion = maxVer + 1;
+    this.stmts.insertVersion.run(id, newVersion, content, operation || null);
+    return newVersion;
+  }
+
+  delete(id: string): boolean {
+    const result = this.stmts.delete.run(id);
+    return result.changes > 0;
+  }
+
+  getVersions(documentId: string): VersionRow[] {
+    return this.stmts.getVersions.all(documentId) as VersionRow[];
+  }
+
+  getMaxVersion(documentId: string): number {
+    return (
+      this.stmts.getMaxVersion.get(documentId) as { max_version: number }
+    ).max_version;
+  }
+
+  close(): void {
+    this.db.close();
+  }
+}
