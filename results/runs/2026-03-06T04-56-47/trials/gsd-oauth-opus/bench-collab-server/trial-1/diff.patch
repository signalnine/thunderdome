.on(\"message\", handler);\n  });\n}\n\ndescribe(\"REST API\", () => {\n  it(\"creates a document\", async () => {\n    const res = await fetch(`${baseUrl}/api/documents`, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ title: \"Test Doc\", content: \"Hello\" }),\n    });\n    expect(res.status).toBe(201);\n    const doc = await res.json();\n    expect(doc.id).toBeDefined();\n    expect(doc.title).toBe(\"Test Doc\");\n    expect(doc.content).toBe(\"Hello\");\n  });\n\n  it(\"lists documents\", async () => {\n    await createDocument(\"Doc 1\");\n    await createDocument(\"Doc 2\");\n\n    const res = await fetch(`${baseUrl}/api/documents`);\n    const docs = await res.json();\n    expect(docs.length).toBeGreaterThanOrEqual(2);\n  });\n\n  it(\"gets a document by id\", async () => {\n    const created = await createDocument(\"Test\", \"content\");\n    const res = await fetch(`${baseUrl}/api/documents/${created.id}`);\n    expect(res.status).toBe(200);\n    const doc = await res.json();\n    expect(doc.title).toBe(\"Test\");\n    expect(doc.content).toBe(\"content\");\n  });\n\n  it(\"returns 404 for missing document\", async () => {\n    const res = await fetch(`${baseUrl}/api/documents/nonexistent`);\n    expect(res.status).toBe(404);\n  });\n\n  it(\"updates a document\", async () => {\n    const created = await createDocument(\"Original\", \"old content\");\n    const res = await fetch(`${baseUrl}/api/documents/${created.id}`, {\n      method: \"PUT\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ title: \"Updated\", content: \"new content\" }),\n    });\n    expect(res.status).toBe(200);\n    const doc = await res.json();\n    expect(doc.title).toBe(\"Updated\");\n    expect(doc.content).toBe(\"new content\");\n  });\n\n  it(\"deletes a document\", async () => {\n    const created = await createDocument(\"ToDelete\");\n    const res = await fetch(`${baseUrl}/api/documents/${created.id}`, {\n      method: \"DELETE\",\n    });\n    expect(res.status).toBe(204);\n\n    const getRes = await fetch(`${baseUrl}/api/documents/${created.id}`);\n    expect(getRes.status).toBe(404);\n  });\n\n  it(\"gets version history\", async () => {\n    const created = await createDocument(\"Versioned\", \"v1\");\n    // Update to create another version\n    await fetch(`${baseUrl}/api/documents/${created.id}`, {\n      method: \"PUT\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ title: \"Versioned\", content: \"v2\" }),\n    });\n\n    const res = await fetch(\n      `${baseUrl}/api/documents/${created.id}/versions`\n    );\n    const versions = await res.json();\n    expect(versions.length).toBeGreaterThanOrEqual(2);\n    expect(versions[0].content).toBe(\"v1\");\n    expect(versions[1].content).toBe(\"v2\");\n  });\n\n  it(\"rejects create without title\", async () => {\n    const res = await fetch(`${baseUrl}/api/documents`, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ content: \"no title\" }),\n    });\n    expect(res.status).toBe(400);\n  });\n});\n\ndescribe(\"WebSocket collaboration\", () => {\n  it(\"connects and receives sync message\", async () => {\n    const doc = await createDocument(\"WS Test\", \"hello\");\n    const { ws, sync } = await connectWs(doc.id);\n\n    expect(sync.type).toBe(\"sync\");\n    expect(sync.content).toBe(\"hello\");\n    expect(sync.version).toBe(1);\n    expect(sync.clientId).toBeDefined();\n\n    ws.close();\n  });\n\n  it(\"sends an operation and receives ack\", async () => {\n    const doc = await createDocument(\"Op Test\", \"hello\");\n    const { ws, sync } = await connectWs(doc.id);\n\n    const ackPromise = waitForMessage(ws, \"ack\");\n\n    ws.send(\n      JSON.stringify({\n        type: \"operation\",\n        version: sync.version,\n        operation: [5, \" world\"],\n      })\n    );\n\n    const ack = await ackPromise;\n    expect(ack.type).toBe(\"ack\");\n    expect(ack.version).toBe(2);\n\n    ws.close();\n\n    // Verify via REST\n    await new Promise((r) => setTimeout(r, 100));\n    const res = await fetch(`${baseUrl}/api/documents/${doc.id}`);\n    const updated = await res.json();\n    expect(updated.content).toBe(\"hello world\");\n  });\n\n  it(\"broadcasts operations to other clients\", async () => {\n    const doc = await createDocument(\"Broadcast Test\", \"hello\");\n    const { ws: ws1, sync: sync1 } = await connectWs(doc.id);\n    const { ws: ws2 } = await connectWs(doc.id);\n\n    const opPromise = waitForMessage(ws2, \"operation\");\n\n    ws1.send(\n      JSON.stringify({\n        type: \"operation\",\n        version: sync1.version,\n        operation: [5, \" world\"],\n      })\n    );\n\n    const opMsg = await opPromise;\n    expect(opMsg.type).toBe(\"operation\");\n    expect(opMsg.operation).toEqual([5, \" world\"]);\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"handles concurrent edits with OT\", async () => {\n    const doc = await createDocument(\"OT Test\", \"hello\");\n    const { ws: ws1, sync: sync1 } = await connectWs(doc.id);\n    const { ws: ws2, sync: sync2 } = await connectWs(doc.id);\n\n    // Both clients send operations based on the same version\n    const ack1Promise = waitForMessage(ws1, \"ack\");\n    const ack2Promise = waitForMessage(ws2, \"ack\");\n\n    // Client 1: insert \"A\" at beginning\n    ws1.send(\n      JSON.stringify({\n        type: \"operation\",\n        version: sync1.version,\n        operation: [\"A\", 5],\n      })\n    );\n\n    // Wait for ack1 before sending op2 to ensure ordering\n    await ack1Promise;\n\n    // Client 2: insert \"B\" at end (based on original version)\n    ws2.send(\n      JSON.stringify({\n        type: \"operation\",\n        version: sync2.version,\n        operation: [5, \"B\"],\n      })\n    );\n\n    await ack2Promise;\n\n    // Wait for persistence\n    await new Promise((r) => setTimeout(r, 200));\n\n    // Close connections to trigger persistence\n    ws1.close();\n    ws2.close();\n    await new Promise((r) => setTimeout(r, 200));\n\n    // Verify final state via REST\n    const res = await fetch(`${baseUrl}/api/documents/${doc.id}`);\n    const final = await res.json();\n    // Both insertions should be preserved\n    expect(final.content).toContain(\"A\");\n    expect(final.content).toContain(\"B\");\n    expect(final.content).toContain(\"hello\");\n    expect(final.content.length).toBe(7); // \"A\" + \"hello\" + \"B\"\n  });\n\n  it(\"rejects invalid operation format\", async () => {\n    const doc = await createDocument(\"Invalid Op\", \"hello\");\n    const { ws } = await connectWs(doc.id);\n\n    const errorPromise = waitForMessage(ws, \"error\");\n\n    ws.send(\n      JSON.stringify({\n        type: \"operation\",\n        version: 1,\n        operation: \"not an array\",\n      })\n    );\n\n    const error = await errorPromise;\n    expect(error.type).toBe(\"error\");\n\n    ws.close();\n  });\n\n  it(\"rejects operation with wrong doc length\", async () => {\n    const doc = await createDocument(\"Bad Length\", \"hello\");\n    const { ws } = await connectWs(doc.id);\n\n    const errorPromise = waitForMessage(ws, \"error\");\n\n    ws.send(\n      JSON.stringify({\n        type: \"operation\",\n        version: 1,\n        operation: [100, \"x\"], // retain 100 but doc is only 5 chars\n      })\n    );\n\n    const error = await errorPromise;\n    expect(error.type).toBe(\"error\");\n\n    ws.close();\n  });\n\n  it(\"handles 10 concurrent clients\", async () => {\n    const doc = await createDocument(\"Concurrency Test\", \"\");\n\n    const connections = await Promise.all(\n      Array.from({ length: 10 }, () => connectWs(doc.id))\n    );\n\n    // Each client inserts their index number\n    const ackPromises = connections.map(({ ws }, i) => {\n      const promise = waitForMessage(ws, \"ack\");\n      ws.send(\n        JSON.stringify({\n          type: \"operation\",\n          version: 1, // All based on initial version\n          operation: [String(i)],\n        })\n      );\n      return promise;\n    });\n\n    // Wait for all acks\n    await Promise.all(ackPromises);\n\n    // Close all connections to trigger persistence\n    connections.forEach(({ ws }) => ws.close());\n    await new Promise((r) => setTimeout(r, 300));\n\n    // Verify the document contains all 10 characters\n    const res = await fetch(`${baseUrl}/api/documents/${doc.id}`);\n    const final = await res.json();\n\n    // All digits 0-9 should be present\n    for (let i = 0; i < 10; i++) {\n      expect(final.content).toContain(String(i));\n    }\n    expect(final.content.length).toBe(10);\n  });\n});\n\ndescribe(\"Persistence\", () => {\n  it(\"data survives server restart\", async () => {\n    const tmpDb = `/tmp/test-persist-${Date.now()}.db`;\n\n    // Start first server\n    const app1 = createApp(tmpDb);\n    const port1 = await app1.start(0);\n\n    // Create a document\n    const res1 = await fetch(`http://localhost:${port1}/api/documents`, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ title: \"Persist\", content: \"survive\" }),\n    });\n    const doc = await res1.json();\n\n    // Stop first server\n    await app1.stop();\n\n    // Start second server with same db\n    const app2 = createApp(tmpDb);\n    const port2 = await app2.start(0);\n\n    // Verify document exists\n    const res2 = await fetch(\n      `http://localhost:${port2}/api/documents/${doc.id}`\n    );\n    const retrieved = await res2.json();\n    expect(retrieved.title).toBe(\"Persist\");\n    expect(retrieved.content).toBe(\"survive\");\n\n    await app2.stop();\n  });\n});\n","structuredPatch":[],"originalFile":null}}
