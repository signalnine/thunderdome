tore) {\n    this.store = store;\n  }\n\n  attach(server: HttpServer): void {\n    this.wss = new WebSocketServer({ server });\n\n    this.wss.on(\"connection\", (ws: WebSocket, req: IncomingMessage) => {\n      const url = req.url || \"\";\n      // Expected path: /ws/documents/:id\n      const match = url.match(/^\\/ws\\/documents\\/([^/?]+)/);\n      if (!match) {\n        this.send(ws, { type: \"error\", message: \"Invalid WebSocket path. Use /ws/documents/:id\" });\n        ws.close(1008, \"Invalid path\");\n        return;\n      }\n\n      const documentId = match[1];\n      this.handleConnection(ws, documentId);\n    });\n  }\n\n  private handleConnection(ws: WebSocket, documentId: string): void {\n    const doc = this.store.getById(documentId);\n    if (!doc) {\n      this.send(ws, { type: \"error\", message: \"Document not found\" });\n      ws.close(1008, \"Document not found\");\n      return;\n    }\n\n    const clientId = `client-${++clientCounter}`;\n    const session = this.getOrCreateSession(documentId, doc.content);\n\n    const client: ClientConnection = {\n      ws,\n      clientId,\n      documentId,\n      acknowledgedVersion: session.version,\n    };\n\n    session.clients.set(clientId, client);\n\n    // Send sync message\n    this.send(ws, {\n      type: \"sync\",\n      content: session.content,\n      version: session.version,\n      clientId,\n    });\n\n    ws.on(\"message\", (data) => {\n      try {\n        const msg = JSON.parse(data.toString());\n        this.handleMessage(client, session, msg);\n      } catch (err) {\n        this.send(ws, {\n          type: \"error\",\n          message: `Invalid message: ${err instanceof Error ? err.message : String(err)}`,\n        });\n      }\n    });\n\n    ws.on(\"close\", () => {\n      session.clients.delete(clientId);\n      if (session.clients.size === 0) {\n        // Persist final content and remove session\n        this.persistSession(session);\n        this.sessions.delete(documentId)