+import express from "express";
+import { createServer, Server as HttpServer } from "http";
+import { createDb } from "./db.js";
+import { DocumentStore } from "./db.js";
+import { createRouter } from "./routes.js";
+import { CollaborationManager } from "./collaboration.js";
+import type { AddressInfo } from "net";
+
+export interface AppInstance {
+  app: express.Express;
+  start: (port?: number) => Promise<number>;
+  stop: () => Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db = createDb(dbPath);
+  const store = new DocumentStore(db);
+
+  const app = express();
+  app.use(express.json());
+
+  const router = createRouter(store);
+  app.use("/api", router);
+
+  const httpServer: HttpServer = createServer(app);
+
+  const collaboration = new CollaborationManager(store);
+  collaboration.attach(httpServer);
+
+  let running = false;
+
+  return {
+    app,
+    async start(port = 0): Promise<number> {
+      return new Promise((resolve, reject) => {
+        httpServer.listen(port, () => {
+          running = true;
+          const addr = httpServer.address() as AddressInfo;
+          resolve(addr.port);
+        });
+        httpServer.on("error", reject);
+      });
+    },
+    async stop(): Promise<void> {
+      collaboration.closeAll();
+      if (running) {
+        return new Promise((resolve, reject) => {
+          httpServer.close((err) => {
+            running = false;
+            store.close();
+            if (err) reject(err);
+            else resolve();
+          });
+        });
+      }
+      store.close();
+    },
+  };
+}
