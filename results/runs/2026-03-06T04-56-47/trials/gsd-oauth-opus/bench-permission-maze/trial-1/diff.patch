+++ b/src/routes/documents.ts
@@ -0,0 +1,168 @@
+import { Router, Response } from 'express';
+import { Store, generateId } from '../store.js';
+import { AuthenticatedRequest, requireAuth } from '../middleware.js';
+import { hasPermission } from '../permissions.js';
+
+export function createDocumentsRouter(store: Store): Router {
+  const router = Router();
+
+  router.use(requireAuth);
+
+  // Create document
+  router.post('/', (req: AuthenticatedRequest, res: Response) => {
+    const user = req.user!;
+    const { title, content, folderId } = req.body;
+
+    if (!title || typeof title !== 'string') {
+      res.status(400).json({ error: 'Document title is required' });
+      return;
+    }
+
+    if (content === undefined || content === null) {
+      res.status(400).json({ error: 'Document content is required' });
+      return;
+    }
+
+    if (!folderId) {
+      res.status(400).json({ error: 'Folder ID is required' });
+      return;
+    }
+
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    // Must have at least editor permission on folder to create documents
+    if (!hasPermission(store, user.id, 'folder', folderId, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions on folder' });
+      return;
+    }
+
+    const id = generateId(store);
+    const now = new Date().toISOString();
+    const doc = {
+      id,
+      title,
+      content: String(content),
+      folderId,
+      ownerId: user.id,
+      createdAt: now,
+      updatedAt: now,
+    };
+
+    store.documents.set(id, doc);
+
+    // Log activity
+    store.activity.push({
+      id: generateId(store),
+      action: 'document_created',
+      userId: user.id,
+      resourceType: 'document',
+      resourceId: id,
+      timestamp: now,
+    });
+
+    res.status(201).json(doc);
+  });
+
+  // Get document
+  router.get('/:id', (req: AuthenticatedRequest, res: Response) => {
+    const user = req.user!;
+    const doc = store.documents.get(req.params.id);
+
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!hasPermission(store, user.id, 'document', doc.id, 'viewer')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    res.json(doc);
+  });
+
+  // Update document
+  router.put('/:id', (req: AuthenticatedRequest, res: Response) => {
+    const user = req.user!;
+    const doc = store.documents.get(req.params.id);
+
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!hasPermission(store, user.id, 'document', doc.id, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const { title, content } = req.body;
+
+    if (title !== undefined) {
+      if (typeof title !== 'string' || !title) {
+        res.status(400).json({ error: 'Invalid document title' });
+        return;
+      }
+      doc.title = title;
+    }
+
+    if (content !== undefined) {
+      doc.content = String(content);
+    }
+
+    doc.updatedAt = new Date().toISOString();
+
+    // Log activity
+    store.activity.push({
+      id: generateId(store),
+      action: 'document_updated',
+      userId: user.id,
+      resourceType: 'document',
+      resourceId: doc.id,
+      timestamp: doc.updatedAt,
+    });
+
+    res.json(doc);
+  });
+
+  // Delete document
+  router.delete('/:id', (req: AuthenticatedRequest, res: Response) => {
+    const user = req.user!;
+    const doc = store.documents.get(req.params.id);
+
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!hasPermission(store, user.id, 'document', doc.id, 'owner')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    // Remove shares for document
+    store.shares = store.shares.filter(s => !(s.resourceType === 'document' && s.resourceId === doc.id));
+
+    const now = new Date().toISOString();
+
+    // Log activity
+    store.activity.push({
+      id: generateId(store),
+      action: 'document_deleted',
+      userId: user.id,
+      resourceType: 'document',
+      resourceId: doc.id,
+      timestamp: now,
+    });
+
+    store.documents.delete(doc.id);
+
+    res.status(204).send();
+  });
+
+  return router;
+}
diff --git a/src/routes/folders.ts b/src/routes/folders.ts
