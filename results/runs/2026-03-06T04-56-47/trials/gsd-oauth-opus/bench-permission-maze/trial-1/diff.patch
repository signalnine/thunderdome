@@ -0,0 +1,157 @@
+import { Router, Response } from 'express';
+import { Store, generateId } from '../store.js';
+import { AuthenticatedRequest, requireAuth } from '../middleware.js';
+import { hasPermission, getEffectiveRole } from '../permissions.js';
+import { Role } from '../types.js';
+
+export function createShareRouter(store: Store): Router {
+  const router = Router();
+
+  router.use(requireAuth);
+
+  // Share a resource with a user
+  router.post('/', (req: AuthenticatedRequest, res: Response) => {
+    const user = req.user!;
+    const { resourceType, resourceId, userId, role } = req.body;
+
+    if (!resourceType || !resourceId || !userId || !role) {
+      res.status(400).json({ error: 'resourceType, resourceId, userId, and role are required' });
+      return;
+    }
+
+    if (resourceType !== 'folder' && resourceType !== 'document') {
+      res.status(400).json({ error: 'resourceType must be "folder" or "document"' });
+      return;
+    }
+
+    const validRoles: Role[] = ['viewer', 'editor', 'owner'];
+    if (!validRoles.includes(role)) {
+      res.status(400).json({ error: 'role must be "viewer", "editor", or "owner"' });
+      return;
+    }
+
+    // Check resource exists
+    if (resourceType === 'folder') {
+      if (!store.folders.has(resourceId)) {
+        res.status(404).json({ error: 'Folder not found' });
+        return;
+      }
+    } else {
+      if (!store.documents.has(resourceId)) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+    }
+
+    // Check target user exists
+    if (!store.users.has(userId)) {
+      res.status(404).json({ error: 'User not found' });
+      return;
+    }
+
+    // Cannot share with yourself
+    if (userId === user.id) {
+      res.status(400).json({ error: 'Cannot share with yourself' });
+      return;
+    }
+
+    // Determine required permission to share:
+    // - editors can share with viewer/editor roles
+    // - owners can share with any role (including owner)
+    const sharerRole = getEffectiveRole(store, user.id, resourceType, resourceId);
+    if (!sharerRole) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    if (role === 'owner') {
+      // Only owners can grant owner role
+      if (!hasPermission(store, user.id, resourceType, resourceId, 'owner')) {
+        res.status(403).json({ error: 'Only owners can grant owner role' });
+        return;
+      }
+    } else {
+      // Editors and owners can grant viewer/editor roles
+      if (!hasPermission(store, user.id, resourceType, resourceId, 'editor')) {
+        res.status(403).json({ error: 'Insufficient permissions to share' });
+        return;
+      }
+    }
+
+    // Check if share already exists, update role if so
+    const existingShare = store.shares.find(
+      s => s.resourceType === resourceType && s.resourceId === resourceId && s.userId === userId
+    );
+
+    const now = new Date().toISOString();
+
+    if (existingShare) {
+      existingShare.role = role;
+      existingShare.grantedBy = user.id;
+      existingShare.createdAt = now;
+
+      // Log activity
+      store.activity.push({
+        id: generateId(store),
+        action: 'share_updated',
+        userId: user.id,
+        resourceType,
+        resourceId,
+        details: `Shared with user ${userId} as ${role}`,
+        timestamp: now,
+      });
+
+      res.json(existingShare);
+    } else {
+      const id = generateId(store);
+      const share = {
+        id,
+        resourceType: resourceType as 'folder' | 'document',
+        resourceId,
+        userId,
+        role: role as Role,
+        grantedBy: user.id,
+        createdAt: now,
+      };
+
+      store.shares.push(share);
+
+      // Log activity
+      store.activity.push({
+        id: generateId(store),
+        action: 'share_created',
+        userId: user.id,
+        resourceType,
+        resourceId,
+        details: `Shared with user ${userId} as ${role}`,
+        timestamp: now,
+      });
+
+      res.status(201).json(share);
+    }
+  });
+
+  // Remove share
+  router.delete('/:shareId', (req: AuthenticatedRequest, res: Response) => {
+    const user = req.user!;
+    const shareIndex = store.shares.findIndex(s => s.id === req.params.shareId);
+
+    if (shareIndex === -1) {
+      res.status(404).json({ error: 'Share not found' });
+      return;
+    }
+
+    const share = store.shares[shareIndex];
+
+    // Only owners can remove shares
+    if (!hasPermission(store, user.id, share.resourceType, share.resourceId, 'owner')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    store.shares.splice(shareIndex, 1);
+    res.status(204).send();
+  });
+
+  return router;
+}
