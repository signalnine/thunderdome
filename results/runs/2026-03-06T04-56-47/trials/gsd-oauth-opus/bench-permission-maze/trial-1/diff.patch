ore.documents.set(id, doc);\n\n    // Log activity\n    store.activity.push({\n      id: generateId(store),\n      action: 'document_created',\n      userId: user.id,\n      resourceType: 'document',\n      resourceId: id,\n      timestamp: now,\n    });\n\n    res.status(201).json(doc);\n  });\n\n  // Get document\n  router.get('/:id', (req: AuthenticatedRequest, res: Response) => {\n    const user = req.user!;\n    const doc = store.documents.get(req.params.id);\n\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n\n    if (!hasPermission(store, user.id, 'document', doc.id, 'viewer')) {\n      res.status(403).json({ error: 'Insufficient permissions' });\n      return;\n    }\n\n    res.json(doc);\n  });\n\n  // Update document\n  router.put('/:id', (req: AuthenticatedRequest, res: Response) => {\n    const user = req.user!;\n    const doc = store.documents.get(req.params.id);\n\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n\n    if (!hasPermission(store, user.id, 'document', doc.id, 'editor')) {\n      res.status(403).json({ error: 'Insufficient permissions' });\n      return;\n    }\n\n    const { title, content } = req.body;\n\n    if (title !== undefined) {\n      if (typeof title !== 'string' || !title) {\n        res.status(400).json({ error: 'Invalid document title' });\n        return;\n      }\n      doc.title = title;\n    }\n\n    if (content !== undefined) {\n      doc.content = String(content);\n    }\n\n    doc.updatedAt = new Date().toISOString();\n\n    // Log activity\n    store.activity.push({\n      id: generateId(store),\n      action: 'document_updated',\n      userId: user.id,\n      resourceType: 'document',\n      resourceId: doc.id,\n      timestamp: doc.updatedAt,\n    });\n\n    res.json(doc);\n  });\n\n  // Delete document\n  router.delete('/:id', (req: AuthenticatedRequest, res: Response) => {\n    const user = req.user!;\n    const doc = store.documents.get(req.params.id);\n\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n\n    if (!hasPermission(store, user.id, 'document', doc.id, 'owner')) {\n      res.status(403).json({ error: 'Insufficient permissions' });\n      return;\n    }\n\n    // Remove shares for document\n    store.shares = store.shares.filter(s => !(s.resourceType === 'document' && s.resourceId === doc.id));\n\n    const now = new Date().toISOString();\n\n    // Log activity\n    store.activity.push({\n      id: generateId(store),\n      action: 'document_deleted',\n      userId: user.id,\n      resourceType: 'document',\n      resourceId: doc.id,\n      timestamp: now,\n    });\n\n    store.documents.delete(doc.id);\n\n    res.status(204).send();\n  });\n\n  return router;\n}\n","structuredPatch":[],"originalFile":null}}
