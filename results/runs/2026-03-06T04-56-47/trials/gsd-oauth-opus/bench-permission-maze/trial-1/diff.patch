ry).toHaveProperty('action');\n        expect(entry).toHaveProperty('userId');\n        expect(entry).toHaveProperty('resourceType');\n        expect(entry).toHaveProperty('resourceId');\n      }\n    });\n  });\n});\n","structuredPatch":[{"oldStart":502,"oldLines":8,"newStart":502,"newLines":8,"lines":["       const folder = await createFolder(aliceToken, 'Folder');","       await shareResource(aliceToken, 'folder', folder.body.id, bobId, 'editor');"," ","-      await registerUser('charlie', 'pass');","-      const charlieId = (await request(app).post('/auth/register').send({ username: 'charlie2', password: 'pass' })).body.id;","+      const charlieReg = await registerUser('charlie', 'pass');","+      const charlieId = charlieReg.body.id;"," ","       // Bob (editor) tries to grant owner role","       const res = await shareResource(bobToken, 'folder', folder.body.id, charlieId, 'owner');"]}],"userModified":false,"replaceAll":false}}
