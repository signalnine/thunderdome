+++ b/src/store.ts
@@ -0,0 +1,29 @@
+import { User, Folder, Document, Share, ActivityEntry } from './types.js';
+
+export interface Store {
+  users: Map<string, User>;
+  usersByUsername: Map<string, User>;
+  usersByToken: Map<string, User>;
+  folders: Map<string, Folder>;
+  documents: Map<string, Document>;
+  shares: Share[];
+  activity: ActivityEntry[];
+  nextId: number;
+}
+
+export function createStore(): Store {
+  return {
+    users: new Map(),
+    usersByUsername: new Map(),
+    usersByToken: new Map(),
+    folders: new Map(),
+    documents: new Map(),
+    shares: [],
+    activity: [],
+    nextId: 1,
+  };
+}
+
+export function generateId(store: Store): string {
+  return String(store.nextId++);
+}
