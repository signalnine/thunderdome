+import express from 'express';
+import { createStore } from './store.js';
+import { authMiddleware } from './middleware.js';
+import { createAuthRouter } from './routes/auth.js';
+import { createFoldersRouter } from './routes/folders.js';
+import { createDocumentsRouter } from './routes/documents.js';
+import { createShareRouter } from './routes/share.js';
+import { createActivityRouter } from './routes/activity.js';
+
+export function createApp(): express.Express {
+  const app = express();
+  const store = createStore();
+
+  app.use(express.json());
+  app.use(authMiddleware(store));
+
+  app.use('/auth', createAuthRouter(store));
+  app.use('/folders', createFoldersRouter(store));
+  app.use('/documents', createDocumentsRouter(store));
+  app.use('/share', createShareRouter(store));
+  app.use('/activity', createActivityRouter(store));
+
+  return app;
+}
diff --git a/src/middleware.ts b/src/middleware.ts
new file mode 100644
index 0000000..d3f1b4d
--- /dev/null
+++ b/src/middleware.ts
@@ -0,0 +1,29 @@
+import { Request, Response, NextFunction } from 'express';
+import { Store } from './store.js';
+import { User } from './types.js';
+
+export interface AuthenticatedRequest extends Request {
+  user?: User;
+}
+
+export function authMiddleware(store: Store) {
+  return (req: AuthenticatedRequest, _res: Response, next: NextFunction): void => {
+    const authHeader = req.headers.authorization;
+    if (authHeader && authHeader.startsWith('Bearer ')) {
+      const token = authHeader.slice(7);
+      const user = store.usersByToken.get(token);
+      if (user) {
+        req.user = user;
+      }
+    }
+    next();
+  };
+}
+
+export function requireAuth(req: AuthenticatedRequest, res: Response, next: NextFunction): void {
+  if (!req.user) {
+    res.status(401).json({ error: 'Authentication required' });
+    return;
+  }
+  next();
+}
diff --git a/src/permissions.ts b/src/permissions.ts
new file mode 100644
index 0000000..5a97184
--- /dev/null
+++ b/src/permissions.ts
@@ -0,0 +1,128 @@
+import { Store } from './store.js';
+import { Role } from './types.js';
+
+const ROLE_LEVEL: Record<Role, number> = {
+  viewer: 1,
+  editor: 2,
+  owner: 3,
+};
+
+export function getEffectiveRole(
+  store: Store,
+  userId: string,
+  resourceType: 'folder' | 'document',
+  resourceId: string
+): Role | null {
+  let bestRole: Role | null = null;
+  let bestLevel = 0;
+
+  // Check if user is the owner of the resource
+  if (resourceType === 'folder') {
+    const folder = store.folders.get(resourceId);
+    if (folder && folder.ownerId === userId) {
+      return 'owner';
+    }
+  } else {
+    const doc = store.documents.get(resourceId);
+    if (doc && doc.ownerId === userId) {
+      return 'owner';
+    }
+  }
+
+  // Check direct shares on this resource
+  for (const share of store.shares) {
+    if (share.userId === userId && share.resourceType === resourceType && share.resourceId === resourceId) {
+      const level = ROLE_LEVEL[share.role];
+      if (level > bestLevel) {
+        bestLevel = level;
+        bestRole = share.role;
+      }
+    }
+  }
+
+  // For documents, also check folder-level shares (inherited permissions)
+  if (resourceType === 'document') {
+    const doc = store.documents.get(resourceId);
+    if (doc) {
+      const folderRole = getEffectiveFolderRole(store, userId, doc.folderId);
+      if (folderRole) {
+        const level = ROLE_LEVEL[folderRole];
+        if (level > bestLevel) {
+          bestLevel = level;
+          bestRole = folderRole;
+        }
+      }
+    }
+  }
+
+  // For folders, also check parent folder shares (inherited permissions)
+  if (resourceType === 'folder') {
+    const folderRole = getInheritedFolderRole(store, userId, resourceId);
+    if (folderRole) {
+      const level = ROLE_LEVEL[folderRole];
+      if (level > bestLevel) {
+        bestLevel = level;
+        bestRole = folderRole;
+      }
+    }
+  }
+
+  return bestRole;
+}
+
+function getEffectiveFolderRole(store: Store, userId: string, folderId: string): Role | null {
+  let bestRole: Role | null = null;
+  let bestLevel = 0;
+
+  const folder = store.folders.get(folderId);
+  if (!folder) return null;
+
+  // Check if user is folder owner
+  if (folder.ownerId === userId) {
+    return 'owner';
+  }
+
+  // Check direct shares on this folder
+  for (const share of store.shares) {
+    if (share.userId === userId && share.resourceType === 'folder' && share.resourceId === folderId) {
+      const level = ROLE_LEVEL[share.role];
+      if (level > bestLevel) {
+        bestLevel = level;
+        bestRole = share.role;
+      }
+    }
+  }
+
+  // Check parent folder shares recursively
+  if (folder.parentId) {
+    const parentRole = getEffectiveFolderRole(store, userId, folder.parentId);
+    if (parentRole) {
+      const level = ROLE_LEVEL[parentRole];
+      if (level > bestLevel) {
+        bestLevel = level;
+        bestRole = parentRole;
+      }
+    }
+  }
+
+  return bestRole;
+}
+
+function getInheritedFolderRole(store: Store, userId: string, folderId: string): Role | null {
+  const folder = store.folders.get(folderId);
+  if (!folder || !folder.parentId) return null;
+
+  return getEffectiveFolderRole(store, userId, folder.parentId);
+}
+
+export function hasPermission(
+  store: Store,
+  userId: string,
+  resourceType: 'folder' | 'document',
+  resourceId: string,
+  requiredRole: Role
+): boolean {
+  const role = getEffectiveRole(store, userId, resourceType, resourceId);
+  if (!role) return false;
+  return ROLE_LEVEL[role] >= ROLE_LEVEL[requiredRole];
+}
