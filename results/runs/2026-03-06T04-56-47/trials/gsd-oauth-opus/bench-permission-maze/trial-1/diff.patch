--- /dev/null
+++ b/src/routes/activity.ts
@@ -0,0 +1,31 @@
+import { Router, Response } from 'express';
+import { Store } from '../store.js';
+import { AuthenticatedRequest, requireAuth } from '../middleware.js';
+
+export function createActivityRouter(store: Store): Router {
+  const router = Router();
+
+  router.use(requireAuth);
+
+  // Get activity log
+  router.get('/', (req: AuthenticatedRequest, res: Response) => {
+    const { resourceType, resourceId } = req.query;
+
+    let activities = [...store.activity];
+
+    if (resourceType && typeof resourceType === 'string') {
+      activities = activities.filter(a => a.resourceType === resourceType);
+    }
+
+    if (resourceId && typeof resourceId === 'string') {
+      activities = activities.filter(a => a.resourceId === resourceId);
+    }
+
+    // Return newest first
+    activities.sort((a, b) => new Date(b.timestamp).getTime() - new Date(a.timestamp).getTime());
+
+    res.json(activities);
+  });
+
+  return router;
+}
