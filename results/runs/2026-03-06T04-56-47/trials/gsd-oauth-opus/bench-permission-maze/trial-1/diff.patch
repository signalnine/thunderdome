@@ -0,0 +1,179 @@
+import { Router, Response } from 'express';
+import { Store, generateId } from '../store.js';
+import { AuthenticatedRequest, requireAuth } from '../middleware.js';
+import { hasPermission } from '../permissions.js';
+
+export function createFoldersRouter(store: Store): Router {
+  const router = Router();
+
+  router.use(requireAuth);
+
+  // Create folder
+  router.post('/', (req: AuthenticatedRequest, res: Response) => {
+    const user = req.user!;
+    const { name, parentId } = req.body;
+
+    if (!name || typeof name !== 'string') {
+      res.status(400).json({ error: 'Folder name is required' });
+      return;
+    }
+
+    if (parentId !== undefined && parentId !== null) {
+      const parentFolder = store.folders.get(parentId);
+      if (!parentFolder) {
+        res.status(404).json({ error: 'Parent folder not found' });
+        return;
+      }
+      // Must have at least editor on parent to create subfolder
+      if (!hasPermission(store, user.id, 'folder', parentId, 'editor')) {
+        res.status(403).json({ error: 'Insufficient permissions on parent folder' });
+        return;
+      }
+    }
+
+    const id = generateId(store);
+    const folder = {
+      id,
+      name,
+      parentId: parentId || null,
+      ownerId: user.id,
+      createdAt: new Date().toISOString(),
+    };
+
+    store.folders.set(id, folder);
+
+    res.status(201).json(folder);
+  });
+
+  // Get folder
+  router.get('/:id', (req: AuthenticatedRequest, res: Response) => {
+    const user = req.user!;
+    const folder = store.folders.get(req.params.id);
+
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!hasPermission(store, user.id, 'folder', folder.id, 'viewer')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    // Get child folders
+    const children: typeof folder[] = [];
+    for (const f of store.folders.values()) {
+      if (f.parentId === folder.id) {
+        children.push(f);
+      }
+    }
+
+    // Get documents in folder
+    const documents: { id: string; title: string; createdAt: string; updatedAt: string }[] = [];
+    for (const doc of store.documents.values()) {
+      if (doc.folderId === folder.id) {
+        documents.push({ id: doc.id, title: doc.title, createdAt: doc.createdAt, updatedAt: doc.updatedAt });
+      }
+    }
+
+    res.json({ ...folder, children, documents });
+  });
+
+  // Update folder
+  router.put('/:id', (req: AuthenticatedRequest, res: Response) => {
+    const user = req.user!;
+    const folder = store.folders.get(req.params.id);
+
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!hasPermission(store, user.id, 'folder', folder.id, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const { name, parentId } = req.body;
+
+    if (name !== undefined) {
+      if (typeof name !== 'string' || !name) {
+        res.status(400).json({ error: 'Invalid folder name' });
+        return;
+      }
+      folder.name = name;
+    }
+
+    if (parentId !== undefined) {
+      if (parentId !== null) {
+        const parentFolder = store.folders.get(parentId);
+        if (!parentFolder) {
+          res.status(404).json({ error: 'Parent folder not found' });
+          return;
+        }
+        // Prevent circular references
+        if (parentId === folder.id || isDescendant(store, parentId, folder.id)) {
+          res.status(400).json({ error: 'Cannot create circular folder reference' });
+          return;
+        }
+      }
+      folder.parentId = parentId;
+    }
+
+    res.json(folder);
+  });
+
+  // Delete folder
+  router.delete('/:id', (req: AuthenticatedRequest, res: Response) => {
+    const user = req.user!;
+    const folder = store.folders.get(req.params.id);
+
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!hasPermission(store, user.id, 'folder', folder.id, 'owner')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    // Delete folder and all contents recursively
+    deleteFolderRecursive(store, folder.id);
+
+    res.status(204).send();
+  });
+
+  return router;
+}
+
+function isDescendant(store: Store, folderId: string, potentialAncestorId: string): boolean {
+  const folder = store.folders.get(folderId);
+  if (!folder) return false;
+  if (folder.parentId === potentialAncestorId) return true;
+  if (folder.parentId) return isDescendant(store, folder.parentId, potentialAncestorId);
+  return false;
+}
+
+function deleteFolderRecursive(store: Store, folderId: string): void {
+  // Delete child folders
+  for (const folder of store.folders.values()) {
+    if (folder.parentId === folderId) {
+      deleteFolderRecursive(store, folder.id);
+    }
+  }
+
+  // Delete documents in folder
+  for (const doc of store.documents.values()) {
+    if (doc.folderId === folderId) {
+      store.documents.delete(doc.id);
+      // Remove shares for document
+      store.shares = store.shares.filter(s => !(s.resourceType === 'document' && s.resourceId === doc.id));
+    }
+  }
+
+  // Remove shares for folder
+  store.shares = store.shares.filter(s => !(s.resourceType === 'folder' && s.resourceId === folderId));
+
+  store.folders.delete(folderId);
+}
