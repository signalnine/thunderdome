-- `src/types.ts` — Read-only shared type definitions (~90 lines)
-- `package.json` — Dependencies already configured
-- `tsconfig.json`, `.eslintrc.cjs`, `vitest.config.ts` — Build/test config
-- All test files in `tests/`
