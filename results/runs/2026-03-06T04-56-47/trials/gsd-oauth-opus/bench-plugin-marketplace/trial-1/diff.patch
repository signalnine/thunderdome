+import type { Review, ReviewService } from '../types.js';
+
+export function createReviewService(): ReviewService {
+  const reviews: Review[] = [];
+  let nextId = 1;
+
+  function addReview(
+    review: Omit<Review, 'id' | 'createdAt' | 'flagged'>
+  ): Review {
+    if (review.rating < 1 || review.rating > 5) {
+      throw new Error('Rating must be between 1 and 5');
+    }
+
+    const newReview: Review = {
+      ...review,
+      id: nextId++,
+      flagged: false,
+      createdAt: new Date().toISOString(),
+    };
+    reviews.push(newReview);
+    return { ...newReview };
+  }
+
+  function getReviews(pluginName: string): Review[] {
+    return reviews
+      .filter((r) => r.pluginName === pluginName)
+      .map((r) => ({ ...r }));
+  }
+
+  function getAverageRating(pluginName: string): number {
+    const unflagged = reviews.filter(
+      (r) => r.pluginName === pluginName && !r.flagged
+    );
+    if (unflagged.length === 0) return 0;
+    const sum = unflagged.reduce((acc, r) => acc + r.rating, 0);
+    return sum / unflagged.length;
+  }
+
+  function flagReview(reviewId: number): void {
+    const review = reviews.find((r) => r.id === reviewId);
+    if (!review) throw new Error(`Review ${reviewId} not found`);
+    review.flagged = true;
+  }
+
+  function getFlaggedReviews(): Review[] {
+    return reviews.filter((r) => r.flagged).map((r) => ({ ...r }));
+  }
+
+  function removeReview(reviewId: number): boolean {
+    const index = reviews.findIndex((r) => r.id === reviewId);
+    if (index === -1) return false;
+    reviews.splice(index, 1);
+    return true;
+  }
+
+  function getReviewsByUser(userId: string): Review[] {
+    return reviews
+      .filter((r) => r.userId === userId)
+      .map((r) => ({ ...r }));
+  }
+
+  function getReviewCount(pluginName: string): number {
+    return reviews.filter((r) => r.pluginName === pluginName).length;
+  }
+
+  return {
+    addReview,
+    getReviews,
+    getAverageRating,
+    flagReview,
+    getFlaggedReviews,
+    removeReview,
+    getReviewsByUser,
+    getReviewCount,
+  };
+}
