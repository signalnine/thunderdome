@@ -0,0 +1,146 @@
+import type { DependencyNode, DepsService, RegistryService } from '../types.js';
+
+export function createDepsService(): DepsService {
+  function buildTree(name: string, registry: RegistryService): DependencyNode {
+    const manifest = registry.get(name);
+    if (!manifest) {
+      throw new Error(`Plugin "${name}" not found in registry`);
+    }
+
+    const visited = new Set<string>();
+
+    function build(pluginName: string): DependencyNode {
+      const m = registry.get(pluginName);
+      if (!m) {
+        return { name: pluginName, version: 'unknown', dependencies: [] };
+      }
+
+      if (visited.has(pluginName)) {
+        return { name: pluginName, version: m.version, dependencies: [] };
+      }
+      visited.add(pluginName);
+
+      const deps: DependencyNode[] = [];
+      for (const depName of Object.keys(m.dependencies)) {
+        deps.push(build(depName));
+      }
+
+      visited.delete(pluginName);
+      return { name: pluginName, version: m.version, dependencies: deps };
+    }
+
+    return build(name);
+  }
+
+  function detectCycles(
+    name: string,
+    registry: RegistryService
+  ): string[][] | null {
+    const manifest = registry.get(name);
+    if (!manifest) {
+      throw new Error(`Plugin "${name}" not found in registry`);
+    }
+
+    const cycles: string[][] = [];
+    const path: string[] = [];
+    const pathSet = new Set<string>();
+    const globalVisited = new Set<string>();
+
+    function dfs(pluginName: string): void {
+      if (pathSet.has(pluginName)) {
+        // Found a cycle - extract it
+        const cycleStart = path.indexOf(pluginName);
+        const cycle = [...path.slice(cycleStart), pluginName];
+        cycles.push(cycle);
+        return;
+      }
+
+      if (globalVisited.has(pluginName)) return;
+
+      const m = registry.get(pluginName);
+      if (!m) return;
+
+      path.push(pluginName);
+      pathSet.add(pluginName);
+
+      for (const depName of Object.keys(m.dependencies)) {
+        dfs(depName);
+      }
+
+      path.pop();
+      pathSet.delete(pluginName);
+      globalVisited.add(pluginName);
+    }
+
+    dfs(name);
+    return cycles.length > 0 ? cycles : null;
+  }
+
+  function topologicalSort(name: string, registry: RegistryService): string[] {
+    const result: string[] = [];
+    const visited = new Set<string>();
+    const visiting = new Set<string>();
+
+    function visit(pluginName: string): void {
+      if (visited.has(pluginName)) return;
+      if (visiting.has(pluginName)) {
+        throw new Error(`Circular dependency detected involving "${pluginName}"`);
+      }
+
+      visiting.add(pluginName);
+
+      const m = registry.get(pluginName);
+      if (m) {
+        for (const depName of Object.keys(m.dependencies)) {
+          visit(depName);
+        }
+      }
+
+      visiting.delete(pluginName);
+      visited.add(pluginName);
+      result.push(pluginName);
+    }
+
+    visit(name);
+    return result;
+  }
+
+  function flattenDependencies(
+    name: string,
+    registry: RegistryService
+  ): string[] {
+    const deps = new Set<string>();
+
+    function collect(pluginName: string, visited: Set<string>): void {
+      const m = registry.get(pluginName);
+      if (!m) return;
+
+      for (const depName of Object.keys(m.dependencies)) {
+        if (visited.has(depName)) continue;
+        visited.add(depName);
+        deps.add(depName);
+        collect(depName, visited);
+      }
+    }
+
+    const visited = new Set<string>([name]);
+    collect(name, visited);
+    return Array.from(deps);
+  }
+
+  function hasCircularDependency(
+    name: string,
+    registry: RegistryService
+  ): boolean {
+    const cycles = detectCycles(name, registry);
+    return cycles !== null;
+  }
+
+  return {
+    buildTree,
+    detectCycles,
+    topologicalSort,
+    flattenDependencies,
+    hasCircularDependency,
+  };
+}
