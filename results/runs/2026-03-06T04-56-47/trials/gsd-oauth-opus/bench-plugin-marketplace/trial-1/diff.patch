e: 'b', version: '1.0.0' }));\n    registry.register(makeManifest({ name: 'a', version: '2.0.0' }));\n\n    const all = registry.list();\n    expect(all).toHaveLength(3);\n  });\n\n  it('should search by name, description, and author', () => {\n    registry.register(makeManifest({ name: 'logger', description: 'Logs stuff', author: 'alice' }));\n    registry.register(makeManifest({ name: 'formatter', description: 'Formats logs', author: 'bob' }));\n    registry.register(makeManifest({ name: 'db-client', description: 'Database', author: 'alice' }));\n\n    expect(registry.search('log')).toHaveLength(2);\n    expect(registry.search('alice')).toHaveLength(2);\n    expect(registry.search('database')).toHaveLength(1);\n    expect(registry.search('nothing')).toHaveLength(0);\n  });\n\n  it('should remove a specific version', () => {\n    registry.register(makeManifest({ version: '1.0.0' }));\n    registry.register(makeManifest({ version: '2.0.0' }));\n\n    expect(registry.remove('test-plugin', '1.0.0')).toBe(true);\n    expect(registry.getVersion('test-plugin', '1.0.0')).toBeNull();\n    expect(registry.getVersion('test-plugin', '2.0.0')).not.toBeNull();\n  });\n\n  it('should return false when removing nonexistent version', () => {\n    expect(registry.remove('test-plugin', '1.0.0')).toBe(false);\n  });\n\n  it('should list versions for a plugin', () => {\n    registry.register(makeManifest({ version: '1.0.0' }));\n    registry.register(makeManifest({ version: '2.0.0' }));\n    registry.register(makeManifest({ version: '3.0.0-beta' }));\n\n    const versions = registry.listVersions('test-plugin');\n    expect(versions).toEqual(['1.0.0', '2.0.0', '3.0.0-beta']);\n  });\n\n  it('should return empty array for unknown plugin versions', () => {\n    expect(registry.listVersions('unknown')).toEqual([]);\n  });\n\n  it('should update a plugin manifest', () => {\n    registry.register(makeManifest());\n    registry.update('test-plugin', '1.0.0', { description: 'Updated description' });\n\n    const updated = registry.getVersion('test-plugin', '1.0.0');\n    expect(updated!.description).toBe('Updated description');\n  });\n\n  it('should throw when updating nonexistent plugin', () => {\n    expect(() => registry.update('unknown', '1.0.0', {})).toThrow();\n  });\n\n  it('should get latest version via get()', () => {\n    registry.register(makeManifest({ version: '1.0.0' }));\n    registry.register(makeManifest({ version: '2.0.0' }));\n\n    const latest = registry.get('test-plugin');\n    expect(latest!.version).toBe('2.0.0');\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":125,"cache_read_input_tokens":28882,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":125},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"4ccce91a-8e4d-4c7b-a2f6-c64bad4eeb11","uuid":"6e690ff2-e4da-4ad9-ae1e-ee138454969b"}
