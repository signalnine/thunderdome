+describe('solveCounter', () => {
+  it('returns all zeros when target is all zero', () => {
+    const result = solveCounter([0, 0, 0], [[0, 1], [1, 2]], 5);
+    expect(result).toEqual([0, 0]);
+  });
+
+  it('solves a simple single button press', () => {
+    const result = solveCounter([1, 1, 0], [[0, 1], [1, 2]], 5);
