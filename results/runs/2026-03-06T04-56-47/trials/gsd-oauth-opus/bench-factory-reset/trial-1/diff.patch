+    expect(result).toEqual([1, 0]);
+  });
+
+  it('solves with multiple presses', () => {
+    const result = solveCounter([3, 0, 0], [[0]], 5);
+    // Press button 0 three times: counter 0 = 3
+    expect(result).toEqual([3]);
+  });
+
+  it('returns null when no solution exists', () => {
+    // Want counter 0 = 1, but no button affects counter 0
+    const result = solveCounter([1, 0], [[1]], 5);
+    expect(result).toBeNull();
+  });
+
+  it('handles modular arithmetic', () => {
+    const result = solveCounter([0], [[0]], 5);
+    // Press 0 times (counter stays at 0) or 5 times (wraps to 0)
+    // Minimum: 0 presses
+    expect(result).toEqual([0]);
+  });
+
+  it('handles larger modulus', () => {
+    const result = solveCounter([96], [[0]], 97);
+    // Need counter 0 = 96. Press button 0 exactly 96 times.
+    // Or equivalently, in GF(97), need b0 * 1 ≡ 96 (mod 97), so b0 = 96.
+    // But we could also press 96 times. Check: 96 presses vs. (97-96=1 press of inverse)?
+    // No, each press adds 1, so pressing 96 times gives 96. That's the only option.
+    expect(result).toEqual([96]);
+  });
+
+  it('prefers minimum total presses', () => {
+    // Two buttons both affect counter 0. Modulus 5.
+    // Target: counter 0 = 1.
+    // Button 0: affects [0], Button 1: affects [0]
+    // Solutions: (b0, b1) where b0 + b1 ≡ 1 (mod 5)
+    // Options: (0,1), (1,0), (2,4), (3,3), (4,2)
+    // Total presses: 1, 1, 6, 6, 6
+    // Min total: 1. Lex smallest with total 1: [0, 1]
+    const result = solveCounter([1], [[0], [0]], 5);
+    expect(result).toEqual([0, 1]);
+  });
+
+  it('prefers lexicographically smallest when tied', () => {
+    // Same as above but target 2
+    // Solutions: (b0,b1) where b0+b1 ≡ 2 (mod 5)
+    // (0,2): total 2, (1,1): total 2, (2,0): total 2, (3,4): total 7, (4,3): total 7
+    // Min total: 2. Lex smallest: [0, 2]
+    const result = solveCounter([2], [[0], [0]], 5);
+    expect(result).toEqual([0, 2]);
+  });
+
+  it('handles multiple counters', () => {
+    // counter 0 = 1, counter 1 = 2
+    // button 0: [0], button 1: [1]
+    // Solution: press button 0 once, button 1 twice
+    const result = solveCounter([1, 2], [[0], [1]], 5);
+    expect(result).toEqual([1, 2]);
+  });
+
+  it('handles overlapping button effects', () => {
+    // counter 0 = 2, counter 1 = 1
+    // button 0: [0, 1], button 1: [0]
+    // b0 + b1 ≡ 2 (mod 5) [counter 0]
+    // b0 ≡ 1 (mod 5) [counter 1]
+    // So b0 = 1, b1 = 1
+    const result = solveCounter([2, 1], [[0, 1], [0]], 5);
+    expect(result).toEqual([1, 1]);
+  });
+
+  it('handles empty input', () => {
+    const result = solveCounter([], [], 5);
+    expect(result).toEqual([]);
+  });
+});
