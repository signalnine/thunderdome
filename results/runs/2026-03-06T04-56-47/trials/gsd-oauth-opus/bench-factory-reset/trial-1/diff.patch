+  const numFree = freeVars.length;
+
+  // Enumerate all 2^numFree assignments of free variables.
+  // With up to 40 lights and 40 buttons, rank <= min(40,40) = 40.
+  // Free vars = numButtons - rank. With 40 lights constraining rank,
