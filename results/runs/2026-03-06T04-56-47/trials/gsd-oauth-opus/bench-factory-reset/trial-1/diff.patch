+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter } from '../src/index.js';
+import type { Machine } from '../src/index.js';
+
+describe('solveToggle', () => {
+  it('returns empty array when target is all off', () => {
+    const machine: Machine = {
+      target: [false, false, false],
+      buttons: [[0, 1], [1, 2]],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('returns null when no solution exists (example from spec)', () => {
+    const machine: Machine = {
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('solves a simple single button press', () => {
+    const machine: Machine = {
+      target: [true, true, false],
+      buttons: [[0, 1], [1, 2]],
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('solves with multiple buttons needed', () => {
+    const machine: Machine = {
+      target: [true, false, true],
+      buttons: [[0, 1], [1, 2]],
+    };
+    // Button 0 toggles [0,1]: [on, on, off]
+    // Button 1 toggles [1,2]: [on, off, on]
+    expect(solveToggle(machine)).toEqual([0, 1]);
+  });
+
+  it('returns fewest presses among multiple solutions', () => {
+    // Two buttons that toggle the same light
+    const machine: Machine = {
+      target: [true],
+      buttons: [[0], [0]],
+    };
+    // Button 0 alone works (1 press), button 1 alone works (1 press)
+    // Both: 0 presses is wrong (they cancel). So minimum is 1 press.
+    // Lex smallest with 1 press: [0]
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('handles larger puzzle', () => {
+    const machine: Machine = {
+      target: [true, true, true, true],
+      buttons: [
+        [0],    // button 0: toggles light 0
+        [1],    // button 1: toggles light 1
+        [2],    // button 2: toggles light 2
+        [3],    // button 3: toggles light 3
+      ],
+    };
+    expect(solveToggle(machine)).toEqual([0, 1, 2, 3]);
+  });
+
+  it('handles puzzle where no buttons are needed', () => {
+    const machine: Machine = {
+      target: [false, false],
+      buttons: [[0], [1]],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('handles puzzle with redundant buttons', () => {
+    // 3 buttons but only 1 light
+    const machine: Machine = {
+      target: [true],
+      buttons: [[0], [0], [0]],
+    };
+    // Pressing any one button: 1 press. Pressing all three: 3 presses (but result is on XOR on XOR on = on).
+    // Minimum: 1 press. Lex smallest: [0].
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('handles empty buttons and target', () => {
+    const machine: Machine = {
+      target: [],
+      buttons: [],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('handles no buttons available', () => {
+    const machine: Machine = {
+      target: [true],
+      buttons: [],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('prefers lexicographically smallest solution when tied on count', () => {
+    // Two buttons each toggle a single light independently
+    // But there are also two other buttons that do the same thing
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [[0], [1], [0], [1]],
+    };
+    // Solutions with 2 presses: {0,1}, {0,3}, {2,1}, {2,3}
+    // Lex smallest: [0,1]
+    expect(solveToggle(machine)).toEqual([0, 1]);
+  });
+});
