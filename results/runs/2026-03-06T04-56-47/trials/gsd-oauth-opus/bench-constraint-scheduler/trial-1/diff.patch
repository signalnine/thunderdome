g, Assignment>,\n  gap: number,\n  windowStart: number,\n  windowEnd: number\n): PlacementOption[] {\n  const attendees = event.attendees ?? 1;\n  const earliest = earliestStartAfterPrereqs(event, currentAssignments, gap, windowStart);\n  if (earliest === -1) return [];\n\n  const options: PlacementOption[] = [];\n\n  for (const room of rooms) {\n    if (room.capacity < attendees) continue;\n\n    const roomAsgn = roomAssignmentsMap.get(room.id) || [];\n    const startTime = findEarliestSlotInRoom(roomAsgn, event.duration, earliest, windowEnd, gap);\n    if (startTime !== -1) {\n      options.push({\n        roomId: room.id,\n        startTime,\n        isPreferred: event.preferredRoom === room.id,\n      });\n    }\n  }\n\n  return options;\n}\n\n/**\n * Main scheduling function. Uses a greedy approach with smart ordering\n * and backtracking to maximize the number of scheduled events.\n */\nexport function schedule(\n  events: Event[],\n  rooms: Room[],\n  options: ScheduleOptions\n): ScheduleResult {\n  if (events.length === 0) {\n    return { assignments: [], unscheduled: [] };\n  }\n\n  const gap = options.gap ?? 15;\n\n  // Detect cycles — will throw on cycle\n  const topoOrder = topologicalSort(events);\n\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  // Try scheduling using greedy with topological order, prioritizing\n  // events that are harder to place (more constrained).\n  const result = greedySchedule(topoOrder, eventMap, rooms, options, gap);\n\n  return result;\n}\n\n/**\n * Greedy scheduling that tries multiple orderings and picks the best result.\n */\nfunction greedySchedule(\n  topoOrder: string[],\n  eventMap: Map<string, Event>,\n  rooms: Room[],\n  options: ScheduleOptions,\n  gap: number\n): ScheduleResult {\n  // Build dependency depth map (longest prerequisite chain)\n  const depthMap = new Map<string, number>();\n  function getDepth(id: string): number {\n    if (depthMap.has