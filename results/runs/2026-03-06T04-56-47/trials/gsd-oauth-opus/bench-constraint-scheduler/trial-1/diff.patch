+import type { Event, Room, ScheduleOptions, Assignment, ScheduleResult } from './types.js';
+
+/**
+ * Detect cycles in the prerequisite graph. Throws if any cycle is found.
+ * Returns a topological ordering of event IDs.
+ */
+function topologicalSort(events: Event[]): string[] {
+  const eventMap = new Map<string, Event>();
+  for (const e of events) {
+    eventMap.set(e.id, e);
+  }
+
+  // 0 = unvisited, 1 = in-progress, 2 = done
+  const state = new Map<string, number>();
+  const order: string[] = [];
+
+  function visit(id: string): void {
+    const s = state.get(id);
+    if (s === 2) return;
+    if (s === 1) {
+      throw new Error(`Prerequisite cycle detected involving event "${id}"`);
+    }
+
+    state.set(id, 1);
+    const ev = eventMap.get(id);
+    if (ev?.prerequisites) {
+      for (const prereqId of ev.prerequisites) {
+        // Self-reference is also a cycle
+        if (prereqId === id) {
+          throw new Error(`Prerequisite cycle detected involving event "${id}"`);
+        }
+        // Only visit prerequisites that exist in our event set
+        if (eventMap.has(prereqId)) {
+          visit(prereqId);
+        } else {
+          // Prerequisite references a non-existent event — still a dependency
+          // that can never be satisfied; we'll handle this during scheduling
+        }
+      }
+    }
+    state.set(id, 2);
+    order.push(id);
+  }
+
+  for (const e of events) {
+    visit(e.id);
+  }
+
+  return order;
+}
+
+/**
+ * Find the earliest start time for an event given its prerequisites
+ * and the current assignments.
+ */
+function earliestStartAfterPrereqs(
+  event: Event,
+  assignments: Map<string, Assignment>,
+  gap: number,
+  windowStart: number
+): number {
+  let earliest = windowStart;
+  if (event.prerequisites) {
+    for (const prereqId of event.prerequisites) {
+      const prereqAssignment = assignments.get(prereqId);
+      if (!prereqAssignment) {
+        // Prerequisite not scheduled — this event cannot be scheduled
+        return -1;
+      }
+      const prereqEnd = prereqAssignment.endTime + gap;
+      if (prereqEnd > earliest) {
+        earliest = prereqEnd;
+      }
+    }
+  }
+  return earliest;
+}
+
+/**
+ * Find the earliest available slot in a room starting at or after `earliest`,
+ * given existing assignments in that room.
+ */
+function findEarliestSlotInRoom(
+  roomAssignments: Assignment[],
+  duration: number,
+  earliest: number,
+  windowEnd: number,
+  gap: number
+): number {
+  // Sort room assignments by start time
+  const sorted = roomAssignments.slice().sort((a, b) => a.startTime - b.startTime);
+
+  let candidateStart = earliest;
+
+  for (const existing of sorted) {
+    const existingEnd = existing.endTime;
+    // If our candidate overlaps with this existing event (considering gaps)
+    if (candidateStart < existingEnd + gap && candidateStart + duration > existing.startTime - gap) {
+      // Move candidate to after this event + gap
+      candidateStart = existingEnd + gap;
+    }
+  }
+
+  if (candidateStart + duration <= windowEnd) {
+    return candidateStart;
+  }
+  return -1;
+}
+
+interface PlacementOption {
+  roomId: string;
+  startTime: number;
+  isPreferred: boolean;
+}
+
+/**
+ * Get all valid placement options for an event.
+ */
+function getPlacementOptions(
+  event: Event,
+  rooms: Room[],
+  roomAssignmentsMap: Map<string, Assignment[]>,
+  currentAssignments: Map<string, Assignment>,
+  gap: number,
+  windowStart: number,
+  windowEnd: number
+): PlacementOption[] {
+  const attendees = event.attendees ?? 1;
+  const earliest = earliestStartAfterPrereqs(event, currentAssignments, gap, windowStart);
+  if (earliest === -1) return [];
+
+  const options: PlacementOption[] = [];
+
+  for (const room of rooms) {
+    if (room.capacity < attendees) continue;
+
+    const roomAsgn = roomAssignmentsMap.get(room.id) || [];
+    const startTime = findEarliestSlotInRoom(roomAsgn, event.duration, earliest, windowEnd, gap);
+    if (startTime !== -1) {
+      options.push({
+        roomId: room.id,
+        startTime,
+        isPreferred: event.preferredRoom === room.id,
+      });
+    }
+  }
+
+  return options;
+}
+
+/**
+ * Main scheduling function. Uses a greedy approach with smart ordering
+ * and backtracking to maximize the number of scheduled events.
+ */
+export function schedule(
+  events: Event[],
+  rooms: Room[],
+  options: ScheduleOptions
+): ScheduleResult {
+  if (events.length === 0) {
+    return { assignments: [], unscheduled: [] };
+  }
+
+  const gap = options.gap ?? 15;
+
+  // Detect cycles — will throw on cycle
+  const topoOrder = topologicalSort(events);
+
+  const eventMap = new Map<string, Event>();
+  for (const e of events) {
+    eventMap.set(e.id, e);
+  }
+
+  // Try scheduling using greedy with topological order, prioritizing
+  // events that are harder to place (more constrained).
+  const result = greedySchedule(topoOrder, eventMap, rooms, options, gap);
+
+  return result;
+}
+
+/**
+ * Greedy scheduling that tries multiple orderings and picks the best result.
+ */
+function greedySchedule(
+  topoOrder: string[],
+  eventMap: Map<string, Event>,
+  rooms: Room[],
+  options: ScheduleOptions,
+  gap: number
+): ScheduleResult {
+  // Build dependency depth map (longest prerequisite chain)
+  const depthMap = new Map<string, number>();
+  function getDepth(id: string): number {
+    if (depthMap.has(id)) return depthMap.get(id)!;
+    const ev = eventMap.get(id);
+    if (!ev?.prerequisites || ev.prerequisites.length === 0) {
+      depthMap.set(id, 0);
+      return 0;
+    }
+    let maxDepth = 0;
+    for (const prereqId of ev.prerequisites) {
+      if (eventMap.has(prereqId)) {
+        maxDepth = Math.max(maxDepth, getDepth(prereqId) + 1);
+      }
+    }
+    depthMap.set(id, maxDepth);
+    return maxDepth;
+  }
+  for (const id of topoOrder) {
+    getDepth(id);
+  }
+
+  // Count how many rooms can fit each event
+  const fittingRoomCount = new Map<string, number>();
+  for (const id of topoOrder) {
+    const ev = eventMap.get(id)!;
+    const attendees = ev.attendees ?? 1;
+    let count = 0;
+    for (const room of rooms) {
+      if (room.capacity >= attendees) count++;
+    }
+    fittingRoomCount.set(id, count);
+  }
+
+  // Compute dependents count (how many events depend on this one)
+  const dependentsCount = new Map<string, number>();
+  for (const id of topoOrder) {
+    dependentsCount.set(id, 0);
+  }
+  for (const id of topoOrder) {
+    const ev = eventMap.get(id)!;
+    if (ev.prerequisites) {
+      for (const prereqId of ev.prerequisites) {
+        if (dependentsCount.has(prereqId)) {
+          dependentsCount.set(prereqId, dependentsCount.get(prereqId)! + 1);
+        }
+      }
+    }
+  }
+
+  // Try multiple orderings and pick the best
+  const orderings: string[][] = [];
+
+  // Ordering 1: topological order preserving, sort by depth then by constrainedness
+  const ordering1 = topoOrder.slice().sort((a, b) => {
+    const da = depthMap.get(a)!;
+    const db = depthMap.get(b)!;
+    if (da !== db) return da - db;
+    // More constrained events first (fewer rooms available)
+    const ra = fittingRoomCount.get(a)!;
+    const rb = fittingRoomCount.get(b)!;
+    if (ra !== rb) return ra - rb;
+    // Events with more dependents first
+    const depsA = dependentsCount.get(a)!;
+    const depsB = dependentsCount.get(b)!;
+    return depsB - depsA;
+  });
+  orderings.push(ordering1);
+
+  // Ordering 2: prioritize events with more dependents (prerequisite chains)
+  const ordering2 = topoOrder.slice().sort((a, b) => {
+    const da = depthMap.get(a)!;
+    const db = depthMap.get(b)!;
+    if (da !== db) return da - db;
+    const depsA = dependentsCount.get(a)!;
+    const depsB = dependentsCount.get(b)!;
+    if (depsA !== depsB) return depsB - depsA;
+    return fittingRoomCount.get(a)! - fittingRoomCount.get(b)!;
+  });
+  orderings.push(ordering2);
+
+  // Ordering 3: longest duration first (harder to fit)
+  const ordering3 = topoOrder.slice().sort((a, b) => {
+    const da = depthMap.get(a)!;
+    const db = depthMap.get(b)!;
+    if (da !== db) return da - db;
+    const durA = eventMap.get(a)!.duration;
+    const durB = eventMap.get(b)!.duration;
+    return durB - durA;
+  });
+  orderings.push(ordering3);
+
+  // Ordering 4: shortest duration first (more events can fit)
+  const ordering4 = topoOrder.slice().sort((a, b) => {
+    const da = depthMap.get(a)!;
+    const db = depthMap.get(b)!;
+    if (da !== db) return da - db;
+    const durA = eventMap.get(a)!.duration;
+    const durB = eventMap.get(b)!.duration;
+    return durA - durB;
+  });
+  orderings.push(ordering4);
+
+  let bestResult: ScheduleResult | null = null;
+
+  for (const ordering of orderings) {
+    const result = runGreedyWithOrder(ordering, eventMap, rooms, options, gap);
+    if (!bestResult || result.assignments.length > bestResult.assignments.length) {
+      bestResult = result;
+      if (bestResult.unscheduled.length === 0) break; // Perfect solution
+    }
+  }
+
+  // If we still have unscheduled events, try backtracking on the best ordering
+  if (bestResult!.unscheduled.length > 0 && eventMap.size <= 50) {
+    const btResult = backtrackSchedule(topoOrder, eventMap, rooms, options, gap);
+    if (btResult.assignments.length > bestResult!.assignments.length) {
+      bestResult = btResult;
+    }
+  }
+
+  return bestResult!;
+}
+
+/**
+ * Run greedy scheduling with a specific event ordering.
+ */
+function runGreedyWithOrder(
+  ordering: string[],
+  eventMap: Map<string, Event>,
+  rooms: Room[],
+  options: ScheduleOptions,
+  gap: number
+): ScheduleResult {
+  const assignments = new Map<string, Assignment>();
+  const roomAssignmentsMap = new Map<string, Assignment[]>();
+  for (const room of rooms) {
+    roomAssignmentsMap.set(room.id, []);
+  }
+  const unscheduled: string[] = [];
+
+  for (const eventId of ordering) {
+    const event = eventMap.get(eventId)!;
+    const placed = tryPlaceEvent(
+      event, rooms, roomAssignmentsMap, assignments, gap,
+      options.startTime, options.endTime
+    );
+    if (!placed) {
+      unscheduled.push(eventId);
+    }
+  }
+
+  return {
+    assignments: Array.from(assignments.values()),
+    unscheduled,
+  };
+}
+
+/**
+ * Try to place an event in the best available slot.
+ * Returns true if placed successfully.
+ */
+function tryPlaceEvent(
+  event: Event,
+  rooms: Room[],
+  roomAssignmentsMap: Map<string, Assignment[]>,
+  assignments: Map<string, Assignment>,
+  gap: number,
+  windowStart: number,
+  windowEnd: number
+): boolean {
+  const placementOptions = getPlacementOptions(
+    event, rooms, roomAssignmentsMap, assignments, gap, windowStart, windowEnd
+  );
+
+  if (placementOptions.length === 0) return false;
+
+  // Sort options: prefer preferred room, then earliest start time
+  placementOptions.sort((a, b) => {
+    if (a.isPreferred !== b.isPreferred) return a.isPreferred ? -1 : 1;
+    return a.startTime - b.startTime;
+  });
+
+  const best = placementOptions[0];
+  const assignment: Assignment = {
+    eventId: event.id,
+    roomId: best.roomId,
+    startTime: best.startTime,
+    endTime: best.startTime + event.duration,
+  };
+
+  assignments.set(event.id, assignment);
+  const roomList = roomAssignmentsMap.get(best.roomId)!;
+  roomList.push(assignment);
+
+  return true;
+}
+
+/**
+ * Backtracking scheduler for small event sets to find optimal placement.
+ */
+function backtrackSchedule(
+  topoOrder: string[],
+  eventMap: Map<string, Event>,
+  rooms: Room[],
+  options: ScheduleOptions,
+  gap: number
+): ScheduleResult {
+  const totalEvents = topoOrder.length;
+  let bestAssignments = new Map<string, Assignment>();
+  let bestCount = 0;
+
+  // Build prerequisite depth for ordering
+  const depthMap = new Map<string, number>();
+  function getDepth(id: string): number {
+    if (depthMap.has(id)) return depthMap.get(id)!;
+    const ev = eventMap.get(id);
+    if (!ev?.prerequisites || ev.prerequisites.length === 0) {
+      depthMap.set(id, 0);
+      return 0;
+    }
+    let maxD = 0;
+    for (const prereqId of ev.prerequisites) {
+      if (eventMap.has(prereqId)) {
+        maxD = Math.max(maxD, getDepth(prereqId) + 1);
+      }
+    }
+    depthMap.set(id, maxD);
+    return maxD;
+  }
+  for (const id of topoOrder) getDepth(id);
+
+  // Sort respecting topological order (depth first)
+  const sorted = topoOrder.slice().sort((a, b) => {
+    return depthMap.get(a)! - depthMap.get(b)!;
+  });
+
+  const assignments = new Map<string, Assignment>();
+  const roomAssignmentsMap = new Map<string, Assignment[]>();
+  for (const room of rooms) {
+    roomAssignmentsMap.set(room.id, []);
+  }
+
+  let iterations = 0;
+  const maxIterations = 100000;
+
+  function solve(index: number, placedCount: number): boolean {
+    if (iterations++ > maxIterations) return false;
+    if (placedCount > bestCount) {
+      bestCount = placedCount;
+      bestAssignments = new Map(assignments);
+      if (bestCount === totalEvents) return true; // optimal
+    }
+
+    if (index >= sorted.length) return false;
+
+    // Upper bound: even if we place all remaining, can we beat best?
+    const remaining = sorted.length - index;
+    if (placedCount + remaining <= bestCount) return false;
+
+    const eventId = sorted[index];
+    const event = eventMap.get(eventId)!;
+
+    const placementOpts = getPlacementOptions(
+      event, rooms, roomAssignmentsMap, assignments, gap,
+      options.startTime, options.endTime
+    );
+
+    // Sort: preferred room first, then earliest
+    placementOpts.sort((a, b) => {
+      if (a.isPreferred !== b.isPreferred) return a.isPreferred ? -1 : 1;
+      return a.startTime - b.startTime;
+    });
+
+    // Try placing in each valid option
+    for (const opt of placementOpts) {
+      const assignment: Assignment = {
+        eventId,
+        roomId: opt.roomId,
+        startTime: opt.startTime,
+        endTime: opt.startTime + event.duration,
+      };
+      assignments.set(eventId, assignment);
+      roomAssignmentsMap.get(opt.roomId)!.push(assignment);
+
+      if (solve(index + 1, placedCount + 1)) return true;
+
+      // Undo
+      assignments.delete(eventId);
+      const roomList = roomAssignmentsMap.get(opt.roomId)!;
+      roomList.pop();
+    }
+
+    // Try skipping this event
+    solve(index + 1, placedCount);
+
+    return bestCount === totalEvents;
+  }
+
+  solve(0, 0);
+
+  const resultAssignments = Array.from(bestAssignments.values());
+  const scheduled = new Set(resultAssignments.map(a => a.eventId));
+  const unscheduled = topoOrder.filter(id => !scheduled.has(id));
+
+  return { assignments: resultAssignments, unscheduled };
+}
