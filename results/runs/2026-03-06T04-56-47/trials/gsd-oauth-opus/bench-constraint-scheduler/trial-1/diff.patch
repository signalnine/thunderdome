).toHaveLength(0);\n    });\n  });\n\n  describe('room capacity', () => {\n    it('should respect room capacity constraints', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Big Event', duration: 60, attendees: 15 },\n      ];\n      const smallRooms: Room[] = [\n        { id: 'small', name: 'Small Room', capacity: 5 },\n      ];\n      const result = schedule(events, smallRooms, defaultOptions);\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toContain('e1');\n    });\n\n    it('should assign events to rooms with sufficient capacity', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Big Event', duration: 60, attendees: 15 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('room-b'); // only room-b has capacity >= 15\n    });\n\n    it('should default attendees to 1 when not specified', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Solo Event', duration: 60 },\n      ];\n      const tinyRoom: Room[] = [\n        { id: 'tiny', name: 'Tiny Room', capacity: 1 },\n      ];\n      const result = schedule(events, tinyRoom, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n    });\n  });\n\n  describe('time window', () => {\n    it('should keep events within the time window', () => {\n      const result = schedule(\n        [{ id: 'e1', name: 'Event 1', duration: 60 }],\n        rooms,\n        defaultOptions\n      );\n      for (const a of result.assignments) {\n        expect(a.startTime).toBeGreaterThanOrEqual(defaultOptions.startTime);\n        expect(a.endTime).toBeLessThanOrEqual(defaultOptions.endTime);\n      }\n    });\n\n    it('should not schedule events that exceed the time window', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Long Event', duration: 600 }, // 10 hours\n      ];\n      const short