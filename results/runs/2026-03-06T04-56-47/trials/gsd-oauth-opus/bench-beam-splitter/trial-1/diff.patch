@@ -0,0 +1,130 @@
+type Direction = 'down' | 'down-left' | 'down-right';
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+function findSource(grid: string[][]): [number, number] {
+  for (let c = 0; c < grid[0].length; c++) {
+    if (grid[0][c] === 'S') return [0, c];
+  }
+  throw new Error('No source found');
+}
+
+function advance(row: number, col: number, dir: Direction): [number, number] {
+  switch (dir) {
+    case 'down': return [row + 1, col];
+    case 'down-left': return [row + 1, col - 1];
+    case 'down-right': return [row + 1, col + 1];
+  }
+}
+
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const [sr, sc] = findSource(grid);
+
+  const visited = new Set<string>();
+  visited.add(`${sr},${sc}`);
+
+  const beams: Beam[] = [{ row: sr, col: sc, dir: 'down' }];
+
+  while (beams.length > 0) {
+    const beam = beams.pop()!;
+    const [nr, nc] = advance(beam.row, beam.col, beam.dir);
+
+    if (!inBounds(nr, nc, rows, cols)) continue;
+
+    visited.add(`${nr},${nc}`);
+    const cell = grid[nr][nc];
+
+    if (cell === '^') {
+      beams.push({ row: nr, col: nc, dir: 'down-left' });
+      beams.push({ row: nr, col: nc, dir: 'down-right' });
+    } else {
+      beams.push({ row: nr, col: nc, dir: beam.dir });
+    }
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  // We need to count distinct source-to-exit paths efficiently.
+  // With up to 50 splitters on a 200x200 grid, we can't enumerate 2^50 paths.
+  //
+  // Strategy: simulate beams but track path counts rather than individual paths.
+  // Each beam carries a count of how many paths are following that trajectory.
+  // When a beam hits a splitter, both children inherit the parent's count.
+  // When a beam exits the grid, we add its count to the total.
+  //
+  // But we must be careful: multiple beams can converge on the same cell with
+  // the same direction. We can merge them by summing their counts.
+  //
+  // Process row by row. For each row, we have a map of (col, direction) -> pathCount.
+  // We advance each beam and handle splitters.
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const [_sr, sc] = findSource(grid);
+
+  let totalPaths = 0n;
+
+  // Map from "col,dir" to path count for current processing
+  // We process row by row, advancing beams from current row to next row
+  type BeamState = Map<string, bigint>;
+
+  // Start: one beam at source going down, 1 path
+  let currentBeams: BeamState = new Map();
+  currentBeams.set(`${sc},down`, 1n);
+
+  for (let row = 0; row < rows; row++) {
+    const nextBeams: BeamState = new Map();
+
+    for (const [key, count] of currentBeams) {
+      const [colStr, dir] = splitKey(key);
+      const col = parseInt(colStr);
+      const [nr, nc] = advance(row, col, dir as Direction);
+
+      if (!inBounds(nr, nc, rows, cols)) {
+        // Beam exits - these are completed paths
+        totalPaths += count;
+        continue;
+      }
+
+      const cell = grid[nr][nc];
+      if (cell === '^') {
+        // Split into two beams
+        addToMap(nextBeams, `${nc},down-left`, count);
+        addToMap(nextBeams, `${nc},down-right`, count);
+      } else {
+        addToMap(nextBeams, `${nc},${dir}`, count);
+      }
+    }
+
+    currentBeams = nextBeams;
+  }
+
+  // Any beams still remaining after processing the last row exit the grid
+  for (const count of currentBeams.values()) {
+    totalPaths += count;
+  }
+
+  return totalPaths;
+}
+
+function splitKey(key: string): [string, string] {
+  const firstComma = key.indexOf(',');
+  return [key.substring(0, firstComma), key.substring(firstComma + 1)];
+}
+
+function addToMap(map: Map<string, bigint>, key: string, count: bigint): void {
+  const existing = map.get(key);
+  map.set(key, existing ? existing + count : count);
+}
