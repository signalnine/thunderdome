rue);\n    expect(inventory.getStock('p1')).toBe(5);\n  });\n\n  it('should reject reservation when insufficient stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 3);\n    expect(inventory.reserve('p1', 5)).toBe(false);\n    expect(inventory.getStock('p1')).toBe(3);\n  });\n\n  it('should release reserved stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 10);\n    inventory.reserve('p1', 5);\n    inventory.release('p1', 3);\n    expect(inventory.getStock('p1')).toBe(8);\n  });\n\n  it('should emit low stock alert', async () => {\n    const inventory = createInventoryService(bus);\n    const alerts: unknown[] = [];\n    bus.on(Events.LOW_STOCK_ALERT, (p) => { alerts.push(p); });\n    inventory.setStock('p1', 10);\n    inventory.setLowStockThreshold('p1', 5);\n    inventory.reserve('p1', 6);\n    await new Promise(r => setTimeout(r, 10));\n    expect(alerts.length).toBeGreaterThan(0);\n  });\n});\n\ndescribe('Cart Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should create a cart and add items', () => {\n    const cart = createCartService(bus);\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 2);\n    const result = cart.getCart(cartId);\n    expect(result).not.toBeNull();\n    expect(result!.items).toHaveLength(1);\n    expect(result!.items[0]).toEqual({ productId: 'p1', quantity: 2 });\n  });\n\n  it('should consolidate duplicate items', () => {\n    const cart = createCartService(bus);\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 2);\n    cart.addItem(cartId, 'p1', 3);\n    const result = cart.getCart(cartId);\n    expect(result!.items).toHaveLength(1);\n    expect(result!.items[0].quantity).toBe(5);\n  });\n\n  it('should remove items', () => {\n    const cart = createCartService(bus);\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 2);\n    cart.addItem(cartId, 'p2', 1);\n    cart.removeItem(cartId, 'p1');\n    const result = cart.getCart(cartId);\n    expect(result!.items).toHaveLength(1);\n    expect(result!.items[0].productId).toBe('p2');\n  });\n\n  it('should clear cart', () => {\n    const cart = createCartService(bus);\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 2);\n    cart.clearCart(cartId);\n    expect(cart.getCart(cartId)!.items).toHaveLength(0);\n  });\n\n  it('should update quantity', () => {\n    const cart = createCartService(bus);\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 2);\n    cart.updateQuantity(cartId, 'p1', 10);\n    expect(cart.getCart(cartId)!.items[0].quantity).toBe(10);\n  });\n\n  it('should return null for nonexistent cart', () => {\n    const cart = createCartService(bus);\n    expect(cart.getCart('nonexistent')).toBeNull();\n  });\n});\n\ndescribe('Pricing Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should calculate total with tax', () => {\n    const pricing = createPricingService(bus);\n    const result = pricing.calculateTotal([\n      { productId: 'p1', quantity: 2, price: 10 },\n    ]);\n    expect(result.subtotal).toBe(20);\n    expect(result.discount).toBe(0);\n    expect(result.tax).toBe(2);\n    expect(result.total).toBe(22);\n  });\n\n  it('should apply discount code', () => {\n    const pricing = createPricingService(bus);\n    pricing.addDiscountCode('SAVE10', 10);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'SAVE10',\n    );\n    expect(result.subtotal).toBe(100);\n    expect(result.discount).toBe(10);\n    expect(result.tax).toBe(9); // (100-10) * 0.1\n    expect(result.total).toBe(99); // 90 + 9\n  });\n\n  it('should track product prices from events', async () => {\n    const pricing = createPricingService(bus);\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'X', price: 25, category: 'cat' });\n    expect(pricing.getPrice('p1')).toBe(25);\n  });\n\n  it('should return 0 for unknown product price', () => {\n    const pricing = createPricingService(bus);\n    expect(pricing.getPrice('nonexistent')).toBe(0);\n  });\n});\n\ndescribe('Order Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should create an order in pending status', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    const order = orders.getOrder(id);\n    expect(order).not.toBeNull();\n    expect(order!.status).toBe(OrderStatus.PENDING);\n    expect(order!.total).toBe(50);\n  });\n\n  it('should update order status with previous status', async () => {\n    const orders = createOrderService(bus);\n    const events: unknown[] = [];\n    bus.on(Events.ORDER_STATUS_CHANGED, (p) => { events.push(p); });\n    const id = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    await new Promise(r => setTimeout(r, 10));\n    expect(events).toHaveLength(1);\n    const event = events[0] as { orderId: string; status: OrderStatus; previousStatus: OrderStatus };\n    expect(event.previousStatus).toBe(OrderStatus.PENDING);\n    expect(event.status).toBe(OrderStatus.CONFIRMED);\n  });\n\n  it('should list orders by user', () => {\n    const orders = createOrderService(bus);\n    orders.createOrder('user1', 'c1', 10);\n    orders.createOrder('user2', 'c2', 20);\n    orders.createOrder('user1', 'c3', 30);\n    expect(orders.listOrders('user1')).toHaveLength(2);\n    expect(orders.listOrders('user2')).toHaveLength(1);\n  });\n\n  it('should return null for nonexistent order', () => {\n    const orders = createOrderService(bus);\n    expect(orders.getOrder('nonexistent')).toBeNull();\n  });\n\n  it('should emit order:created event', async () => {\n    const orders = createOrderService(bus);\n    const events: unknown[] = [];\n    bus.on(Events.ORDER_CREATED, (p) => { events.push(p); });\n    orders.createOrder('user1', 'cart1', 100);\n    await new Promise(r => setTimeout(r, 10));\n    expect(events).toHaveLength(1);\n  });\n});\n\ndescribe('Payment Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should process payment successfully', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.SUCCESS);\n    expect(result.transactionId).toBeDefined();\n  });\n\n  it('should simulate failure', async () => {\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.FAILED);\n    expect(result.error).toBeDefined();\n  });\n\n  it('should simulate timeout', async () => {\n    const payment = createPaymentService(bus, { simulateTimeout: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.TIMEOUT);\n  });\n\n  it('should refund a successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    expect(await payment.refund(result.transactionId!)).toBe(true);\n  });\n\n  it('should not refund nonexistent transaction', async () => {\n    const payment = createPaymentService(bus);\n    expect(await payment.refund('nonexistent')).toBe(false);\n  });\n\n  it('should emit payment:processed event', async () => {\n    const events: unknown[] = [];\n    bus.on(Events.PAYMENT_PROCESSED, (p) => { events.push(p); });\n    const payment = createPaymentService(bus);\n    await payment.processPayment('order1', 100);\n    expect(events).toHaveLength(1);\n  });\n});\n\ndescribe('Notification Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should deliver notifications to subscribed users on order events', async () => {\n    const notifications = createNotificationService(bus);\n    notifications.subscribe('user1');\n\n    await bus.emit(Events.ORDER_CREATED, {\n      orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100,\n    });\n\n    const userNotifications = notifications.getNotifications('user1');\n    expect(userNotifications.length).toBeGreaterThan(0);\n    expect(userNotifications[0].type).toBe('order_created');\n  });\n\n  it('should not deliver to unsubscribed users', async () => {\n    const notifications = createNotificationService(bus);\n    // Don't subscribe user2\n\n    await bus.emit(Events.ORDER_CREATED, {\n      orderId: 'o1', userId: 'user2', cartId: 'c1', total: 100,\n    });\n\n    expect(notifications.getNotifications('user2')).toHaveLength(0);\n  });\n\n  it('should track order status changes', async () => {\n    const notifications = createNotificationService(bus);\n    notifications.subscribe('user1');\n\n    await bus.emit(Events.ORDER_CREATED, {\n      orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100,\n    });\n    await bus.emit(Events.ORDER_STATUS_CHANGED, {\n      orderId: 'o1', status: OrderStatus.CONFIRMED, previousStatus: OrderStatus.PENDING,\n    });\n\n    const userNotifications = notifications.getNotifications('user1');\n    expect(userNotifications.length).toBe(2);\n    expect(userNotifications[1].type).toBe('order_status');\n  });\n\n  it('should track payment events', async () => {\n    const notifications = createNotificationService(bus);\n    notifications.subscribe('user1');\n\n    await bus.emit(Events.ORDER_CREATED, {\n      orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100,\n    });\n    await bus.emit(Events.PAYMENT_PROCESSED, {\n      orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 'tx1',\n    });\n\n    const userNotifications = notifications.getNotifications('user1');\n    const paymentNotif = userNotifications.find(n => n.type === 'payment');\n    expect(paymentNotif).toBeDefined();\n  });\n});\n\ndescribe('Analytics Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should count events by type', async () => {\n    const analytics = createAnalyticsService(bus);\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'X', price: 10, category: 'cat' });\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p2', name: 'Y', price: 20, category: 'cat' });\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n  });\n\n  it('should track revenue from successful payments', async () => {\n    const analytics = createAnalyticsService(bus);\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 'tx1' });\n    expect(analytics.getRevenue()).toBe(100);\n  });\n\n  it('should not track revenue from failed payments', async () => {\n    const analytics = createAnalyticsService(bus);\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.FAILED, error: 'fail' });\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  it('should calculate conversion rate', async () => {\n    const analytics = createAnalyticsService(bus);\n    // 2 unique carts, 1 order\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [] });\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c2', userId: 'u2', items: [] });\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 50 });\n    expect(analytics.getConversionRate()).toBe(0.5);\n  });\n\n  it('should return 0 conversion rate when no carts', () => {\n    const analytics = createAnalyticsService(bus);\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n\n  it('should rank products by order quantity', async () => {\n    const analytics = createAnalyticsService(bus);\n    await bus.emit(Events.CART_UPDATED, {\n      cartId: 'c1', userId: 'u1', items: [\n        { productId: 'p1', quantity: 3 },\n        { productId: 'p2', quantity: 1 },\n      ],\n    });\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 50 });\n\n    const top = analytics.getTopProducts(10);\n    expect(top[0].productId).toBe('p1');\n    expect(top[0].count).toBe(3);\n    expect(top[1].productId).toBe('p2');\n    expect(top[1].count).toBe(1);\n  });\n});\n\ndescribe('Integration: Full E2E Flow', () => {\n  it('should process a complete order flow', async () => {\n    const bus = new EventBus();\n\n    const catalog = createCatalogService(bus);\n    const inventory = createInventoryService(bus);\n    const cart = createCartService(bus);\n    const pricing = createPricingService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    const notifications = createNotificationService(bus);\n    const analytics = createAnalyticsService(bus);\n\n    // Subscribe user for notifications\n    notifications.subscribe('user1');\n\n    // Create products\n    const p1 = catalog.createProduct('Laptop', 999, 'electronics');\n    const p2 = catalog.createProduct('Mouse', 29, 'electronics');\n\n    // Wait for events to propagate\n    await new Promise(r => setTimeout(r, 10));\n\n    // Set inventory\n    inventory.setStock(p1, 10);\n    inventory.setStock(p2, 50);\n\n    // Create cart and add items\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, p1, 1);\n    cart.addItem(cartId, p2, 2);\n\n    // Wait for cart events\n    await new Promise(r => setTimeout(r, 10));\n\n    // Calculate pricing\n    const cartData = cart.getCart(cartId)!;\n    const priceItems = cartData.items.map(item => ({\n      productId: item.productId,\n      quantity: item.quantity,\n      price: pricing.getPrice(item.productId),\n    }));\n    const totals = pricing.calculateTotal(priceItems);\n\n    expect(totals.subtotal).toBe(999 + 29 * 2);\n    expect(totals.tax).toBeCloseTo((999 + 58) * 0.1, 2);\n\n    // Reserve inventory\n    expect(inventory.reserve(p1, 1)).toBe(true);\n    expect(inventory.reserve(p2, 2)).toBe(true);\n\n    // Create order\n    const orderId = orders.createOrder('user1', cartId, totals.total);\n\n    // Wait for order events\n    await new Promise(r => setTimeout(r, 10));\n\n    // Process payment\n    const paymentResult = await payment.processPayment(orderId, totals.total);\n    expect(paymentResult.status).toBe(PaymentStatus.SUCCESS);\n\n    // Update order status\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n\n    // Wait for all events to propagate\n    await new Promise(r => setTimeout(r, 50));\n\n    // Verify order\n    const order = orders.getOrder(orderId);\n    expect(order!.status).toBe(OrderStatus.CONFIRMED);\n\n    // Verify notifications\n    const userNotifs = notifications.getNotifications('user1');\n    expect(userNotifs.length).toBeGreaterThan(0);\n\n    // Verify analytics\n    expect(analytics.getRevenue()).toBe(totals.total);\n    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBeGreaterThan(0);\n    expect(analytics.getConversionRate()).toBeGreaterThan(0);\n\n    // Verify inventory\n    expect(inventory.getStock(p1)).toBe(9);\n    expect(inventory.getStock(p2)).toBe(48);\n  });\n});\n","structuredPatch":[],"originalFile":null}}
