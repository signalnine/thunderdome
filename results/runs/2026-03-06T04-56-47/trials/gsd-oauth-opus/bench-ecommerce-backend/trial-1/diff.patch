+describe('Integration: Full E2E Flow', () => {
+  it('should process a complete order flow', async () => {
+    const bus = new EventBus();
+
+    const catalog = createCatalogService(bus);
+    const inventory = createInventoryService(bus);
+    const cart = createCartService(bus);
+    const pricing = createPricingService(bus);
+    const orders = createOrderService(bus);
+    const payment = createPaymentService(bus);
+    const notifications = createNotificationService(bus);
+    const analytics = createAnalyticsService(bus);
+
+    // Subscribe user for notifications
+    notifications.subscribe('user1');
+
+    // Create products
+    const p1 = catalog.createProduct('Laptop', 999, 'electronics');
+    const p2 = catalog.createProduct('Mouse', 29, 'electronics');
+
+    // Wait for events to propagate
+    await new Promise(r => setTimeout(r, 10));
+
+    // Set inventory
+    inventory.setStock(p1, 10);
+    inventory.setStock(p2, 50);
+
+    // Create cart and add items
+    const cartId = cart.createCart('user1');
+    cart.addItem(cartId, p1, 1);
+    cart.addItem(cartId, p2, 2);
+
+    // Wait for cart events
+    await new Promise(r => setTimeout(r, 10));
+
+    // Calculate pricing
+    const cartData = cart.getCart(cartId)!;
+    const priceItems = cartData.items.map(item => ({
+      productId: item.productId,
+      quantity: item.quantity,
+      price: pricing.getPrice(item.productId),
+    }));
+    const totals = pricing.calculateTotal(priceItems);
+
+    expect(totals.subtotal).toBe(999 + 29 * 2);
+    expect(totals.tax).toBeCloseTo((999 + 58) * 0.1, 2);
+
+    // Reserve inventory
+    expect(inventory.reserve(p1, 1)).toBe(true);
+    expect(inventory.reserve(p2, 2)).toBe(true);
+
+    // Create order
+    const orderId = orders.createOrder('user1', cartId, totals.total);
+
+    // Wait for order events
+    await new Promise(r => setTimeout(r, 10));
+
+    // Process payment
+    const paymentResult = await payment.processPayment(orderId, totals.total);
+    expect(paymentResult.status).toBe(PaymentStatus.SUCCESS);
+
+    // Update order status
+    orders.updateStatus(orderId, OrderStatus.CONFIRMED);
+
+    // Wait for all events to propagate
+    await new Promise(r => setTimeout(r, 50));
+
+    // Verify order
+    const order = orders.getOrder(orderId);
+    expect(order!.status).toBe(OrderStatus.CONFIRMED);
+
+    // Verify notifications
+    const userNotifs = notifications.getNotifications('user1');
+    expect(userNotifs.length).toBeGreaterThan(0);
+
+    // Verify analytics
+    expect(analytics.getRevenue()).toBe(totals.total);
+    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBeGreaterThan(0);
+    expect(analytics.getConversionRate()).toBeGreaterThan(0);
+
+    // Verify inventory
+    expect(inventory.getStock(p1)).toBe(9);
+    expect(inventory.getStock(p2)).toBe(48);
+  });
+});
