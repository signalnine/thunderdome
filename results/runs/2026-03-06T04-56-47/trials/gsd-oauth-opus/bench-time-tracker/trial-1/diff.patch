+++ b/src/tracker.test.ts
@@ -0,0 +1,144 @@
+import { describe, it, expect, beforeEach, afterEach } from "vitest";
+import fs from "node:fs";
+import path from "node:path";
+import os from "node:os";
+import { TimeTracker } from "./tracker.js";
+
+function tmpFile(): string {
+  const dir = fs.mkdtempSync(path.join(os.tmpdir(), "tt-"));
+  return path.join(dir, "data.json");
+}
+
+describe("TimeTracker", () => {
+  let filePath: string;
+
+  beforeEach(() => {
+    filePath = tmpFile();
+  });
+
+  afterEach(() => {
+    try {
+      fs.unlinkSync(filePath);
+      fs.rmdirSync(path.dirname(filePath));
+    } catch {
+      // ignore
+    }
+  });
+
+  it("starts and stops a timer", () => {
+    const tracker = new TimeTracker(filePath);
+    const entry = tracker.start("coding");
+    expect(entry.task).toBe("coding");
+    expect(entry.stop).toBeNull();
+
+    const stopped = tracker.stop();
+    expect(stopped.task).toBe("coding");
+    expect(stopped.stop).not.toBeNull();
+  });
+
+  it("throws on empty task name", () => {
+    const tracker = new TimeTracker(filePath);
+    expect(() => tracker.start("")).toThrow("Task name must not be empty");
+    expect(() => tracker.start("   ")).toThrow("Task name must not be empty");
+  });
+
+  it("throws on stop when nothing running", () => {
+    const tracker = new TimeTracker(filePath);
+    expect(() => tracker.stop()).toThrow("No timer is currently running");
+  });
+
+  it("auto-stops previous timer when starting a new one", () => {
+    const tracker = new TimeTracker(filePath);
+    tracker.start("task1");
+    tracker.start("task2");
+    const entries = tracker.getEntries();
+    expect(entries).toHaveLength(2);
+    expect(entries[0].stop).not.toBeNull();
+    expect(entries[1].stop).toBeNull();
+  });
+
+  it("persists data to file", () => {
+    const tracker1 = new TimeTracker(filePath);
+    tracker1.start("persist-test");
+    tracker1.stop();
+
+    const tracker2 = new TimeTracker(filePath);
+    const entries = tracker2.getEntries();
+    expect(entries).toHaveLength(1);
+    expect(entries[0].task).toBe("persist-test");
+  });
+
+  it("creates parent directories if they don't exist", () => {
+    const nested = path.join(os.tmpdir(), "tt-nested-" + Date.now(), "a", "b", "data.json");
+    const tracker = new TimeTracker(nested);
+    tracker.start("deep");
+    tracker.stop();
+    expect(fs.existsSync(nested)).toBe(true);
+    // cleanup
+    fs.rmSync(path.dirname(path.dirname(path.dirname(nested))), { recursive: true });
+  });
+
+  it("filters entries by date range", () => {
