+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012q6Hq5MSXpvrfaUZhp3cCb","type":"tool_result","content":"     1→import { describe, it, expect } from 'vitest';\n     2→import { createSearchIndexPlugin } from '../../src/plugins/search-index.js';\n     3→import { BuildContext, ContentFile, SiteConfig } from '../../src/core/types.js';\n     4→\n     5→const testConfig: SiteConfig = {\n     6→  title: 'Test Site',\n     7→  baseUrl: 'https://example.com',\n     8→  outputDir: './dist',\n     9→  contentDir: './content',\n    10→  templateDir: './templates',\n    11→};\n    12→\n    13→function makeCtx(files: ContentFile[] = []): BuildContext {\n    14→  return {\n    15→    config: testConfig,\n    16→    files,\n    17→    output: new Map(),\n    18→    assets: new Map(),\n    19→    data: new Map(),\n    20→  };\n    21→}\n    22→\n    23→function makeFile(overrides: Partial<ContentFile> = {}): ContentFile {\n    24→  return {\n    25→    slug: 'test',\n    26→    title: 'Test',\n    27→    content: '',\n    28→    metadata: {},\n    29→    ...overrides,\n    30→  };\n    31→}\n    32→\n    33→describe('search-index plugin', () => {\n    34→  const plugin = createSearchIndexPlugin();\n    35→\n    36→  it('generates search-index.json in ctx.output', async () => {\n    37→    const files = [makeFile({ slug: 'post-1', title: 'Post 1', content: '<p>Hello</p>' })];\n    38→    const ctx = makeCtx(files);\n    39→    await plugin.hooks.afterBuild!(ctx);\n    40→    expect(ctx.output.has('search-index.json')).toBe(true);\n    41→  });\n    42→\n    43→  it('index entries have title, slug, and plain text content', async () => {\n    44→    const files = [makeFile({ slug: 'my-post', title: 'My Post', content: '<p>Some text here</p>' })];\n    45→    const ctx = makeCtx(files);\n    46→    await plugin.hooks.afterBuild!(ctx);\n    47→    const index = JSON.parse(ctx.output.get('search-index.json')!);\n    48→    expect(index[0].slug).toBe('my-post');\n    49→    expect(index[0].title).toBe('My Post');\n    50→    expect(index[0].content).toBe('Some text here');\n    51→  });\n    52→\n    53→  it('HTML tags stripped from indexed content', async () => {\n    54→    const files = [\n    55→      makeFile({\n    56→        slug: 'post',\n    57→        title: 'Post',\n    58→        content: '<h1>Title</h1><p>This is <strong>bold</strong> text.</p>',\n    59→      }),\n    60→    ];\n    61→    const ctx = makeCtx(files);\n    62→    await plugin.hooks.afterBuild!(ctx);\n    63→    const index = JSON.parse(ctx.output.get('search-index.json')!);\n    64→    expect(index[0].content).not.toContain('<');\n    65→    expect(index[0].content).not.toContain('>');\n    66→    expect(index[0].content).toContain('bold');\n    67→    expect(index[0].content).toContain('text');\n    68→  });\n    69→\n    70→  it('code blocks included in searchable text', async () => {\n    71→    const files = [\n    72→      makeFile({\n    73→        slug: 'post',\n    74→        title: 'Code Post',\n    75→        content: '<p>Example:</p><pre><code class=\"language-js\">const x = 1;</code></pre>',\n    76→      }),\n    77→    ];\n    78→    const ctx = makeCtx(files);\n    79→    await plugin.hooks.afterBuild!(ctx);\n    80→    const index = JSON.parse(ctx.output.get('search-index.json')!);\n    81→    expect(index[0].content).toContain('const x = 1;');\n    82→  });\n    83→\n    84→  it('handles empty file list', async () => {\n    85→    const ctx = makeCtx([]);\n    86→    await plugin.hooks.afterBuild!(ctx);\n    87→    const index = JSON.parse(ctx.output.get('search-index.json')!);\n    88→    expect(index).toEqual([]);\n    89→  });\n    90→\n    91→  it('search index is valid JSON', async () => {\n    92→    const files = [\n    93→      makeFile({ slug: 'post-1', title: 'Post 1', content: '<p>Content</p>' }),\n    94→      makeFile({ slug: 'post-2', title: 'Post 2', content: '<p>More</p>' }),\n    95→    ];\n    96→    const ctx