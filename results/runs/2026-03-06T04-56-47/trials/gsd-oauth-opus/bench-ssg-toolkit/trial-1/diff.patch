0→  });\n    91→\n    92→  it('handles site with no tag pages', async () => {\n    93→    const output = new Map<string, string>();\n    94→    output.set('post.html', '<html></html>');\n    95→    const ctx = makeCtx(output);\n    96→    await plugin.hooks.afterBuild!(ctx);\n    97→    const sitemap = ctx.output.get('sitemap.xml')!;\n    98→    expect(sitemap).toContain('https://example.com/post.html');\n    99→    expect(sitemap).not.toContain('/tags/');\n   100→  });\n   101→});\n   102→"}]},"parent_tool_use_id":"toolu_01A3Es4sQST1Mwc4GT4LVrhY","session_id":"c826ed79-3b15-420c-896b-e4bb30d5b41e","uuid":"ddd55fc1-bc06-4f4e-a4e5-fc38e29a4fb9"}
