+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+function processAdmonitions(text: string): string {
+  return text.replace(/^:::(note|warning|tip)\n([\s\S]*?)^:::/gm, (_match, type: string, body: string) => {
+    return `<div class="admonition admonition-${type}">\n${body.trim()}\n</div>`;
+  });
+}
+
+function processFootnotes(text: string): { text: string; footnotes: { id: string; content: string }[] } {
+  const footnotes: { id: string; content: string }[] = [];
+  const footnoteDefRegex = /^\[\^(\d+)\]:\s*(.+)$/gm;
+  let match: RegExpExecArray | null;
+
+  while ((match = footnoteDefRegex.exec(text)) !== null) {
+    footnotes.push({ id: match[1], content: match[2] });
+  }
+
+  // Remove footnote definitions from text
+  let processed = text.replace(/^\[\^(\d+)\]:\s*(.+)$/gm, '');
+
+  // Replace footnote references with sup links
+  processed = processed.replace(/\[\^(\d+)\]/g, '<sup><a href="#fn-$1">$1</a></sup>');
+
+  return { text: processed, footnotes };
+}
+
+function markdownToHtml(md: string): string {
+  let html = md;
+
+  // Process headings (h1-h6)
+  html = html.replace(/^######\s+(.+)$/gm, '<h6>$1</h6>');
+  html = html.replace(/^#####\s+(.+)$/gm, '<h5>$1</h5>');
+  html = html.replace(/^####\s+(.+)$/gm, '<h4>$1</h4>');
+  html = html.replace(/^###\s+(.+)$/gm, '<h3>$1</h3>');
+  html = html.replace(/^##\s+(.+)$/gm, '<h2>$1</h2>');
+  html = html.replace(/^#\s+(.+)$/gm, '<h1>$1</h1>');
+
+  // Process bold and italic
+  html = html.replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>');
+  html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
+  html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');
+
+  // Process code blocks
+  html = html.replace(/```(\w+)?\n([\s\S]*?)```/g, (_match, lang: string | undefined, code: string) => {
+    if (lang) {
+      return `<pre><code class="language-${lang}">${code.trim()}</code></pre>`;
+    }
+    return `<pre><code>${code.trim()}</code></pre>`;
+  });
+
+  // Process inline code
+  html = html.replace(/`([^`]+)`/g, '<code>$1</code>');
+
+  // Process links
+  html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>');
+
+  // Process images
+  html = html.replace(/!\[([^\]]*)\]\(([^)]+)\)/g, '<img src="$2" alt="$1">');
+
+  // Process unordered lists
+  html = html.replace(/^[-*]\s+(.+)$/gm, '<li>$1</li>');
+
+  // Wrap paragraphs: lines that aren't already HTML tags
+  const lines = html.split('\n');
+  const result: string[] = [];
+  for (const line of lines) {
+    const trimmed = line.trim();
+    if (trimmed === '') {
+      result.push('');
+    } else if (trimmed.startsWith('<')) {
+      result.push(trimmed);
+    } else {
+      result.push(`<p>${trimmed}</p>`);
+    }
+  }
+
+  return result.filter(line => line !== '').join('\n');
+}
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file: ContentFile, _ctx: BuildContext): ContentFile {
+        let content = file.content;
+
+        // If content is already HTML (starts with <), return as-is
+        if (content.trim().startsWith('<')) {
+          return { ...file, content };
+        }
+
+        if (content === '') {
+          return { ...file, content: '' };
+        }
+
+        // Process admonitions first (before markdown conversion)
+        content = processAdmonitions(content);
+
+        // Process footnotes
+        const { text: withoutFootnoteDefs, footnotes } = processFootnotes(content);
+        content = withoutFootnoteDefs;
+
+        // Convert markdown to HTML
+        content = markdownToHtml(content);
+
+        // Add footnote section at the end
+        if (footnotes.length > 0) {
+          const footnotesHtml = footnotes
+            .map(fn => `<li id="fn-${fn.id}">${fn.content}</li>`)
+            .join('\n');
+          content += `\n<section class="footnotes">\n<ol>\n${footnotesHtml}\n</ol>\n</section>`;
+        }
+
+        return { ...file, content };
+      },
+    },
+  };
+}
