ng><em>$1</em></strong>');\n  html = html.replace(/\\*\\*(.+?)\\*\\*/g, '<strong>$1</strong>');\n  html = html.replace(/\\*(.+?)\\*/g, '<em>$1</em>');\n\n  // Process code blocks\n  html = html.replace(/```(\\w+)?\\n([\\s\\S]*?)```/g, (_match, lang: string | undefined, code: string) => {\n    if (lang) {\n      return `<pre><code class=\"language-${lang}\">${code.trim()}</code></pre>`;\n    }\n    return `<pre><code>${code.trim()}</code></pre>`;\n  });\n\n  // Process inline code\n  html = html.replace(/`([^`]+)`/g, '<code>$1</code>');\n\n  // Process links\n  html = html.replace(/\\[([^\\]]+)\\]\\(([^)]+)\\)/g, '<a href=\"$2\">$1</a>');\n\n  // Process images\n  html = html.replace(/!\\[([^\\]]*)\\]\\(([^)]+)\\)/g, '<img src=\"$2\" alt=\"$1\">');\n\n  // Process unordered lists\n  html = html.replace(/^[-*]\\s+(.+)$/gm, '<li>$1</li>');\n\n  // Wrap paragraphs: lines that aren't already HTML tags\n  const lines = html.split('\\n');\n  const result: string[] = [];\n  for (const line of lines) {\n    const trimmed = line.trim();\n    if (trimmed === '') {\n      result.push('');\n    } else if (trimmed.startsWith('<')) {\n      result.push(trimmed);\n    } else {\n      result.push(`<p>${trimmed}</p>`);\n    }\n  }\n\n  return result.filter(line => line !== '').join('\\n');\n}\n\nexport function createMarkdownExtPlugin(): Plugin {\n  return {\n    name: 'markdown-ext',\n    version: '1.0.0',\n    dependencies: [],\n    hooks: {\n      transformContent(file: ContentFile, _ctx: BuildContext): ContentFile {\n        let content = file.content;\n\n        // If content is already HTML (starts with <), return as-is\n        if (content.trim().startsWith('<')) {\n          return { ...file, content };\n        }\n\n        if (content === '') {\n          return { ...file, content: '' };\n        }\n\n        // Process admonitions first (before markdown conversion)\n        content = processAdmonitions(content);\n\n        // Process footnotes\n        const { text: withoutFootnoteDefs, footnotes } = processFootnotes(content);\n        content = withoutFootnoteDefs;\n\n        // Convert markdown to HTML\n        content = markdownToHtml(content);\n\n        // Add footnote section at the end\n        if (footnotes.length > 0) {\n          const footnotesHtml = footnotes\n            .map(fn => `<li id=\"fn-${fn.id}\">${fn.content}</li>`)\n            .join('\\n');\n          content += `\\n<section class=\"footnotes\">\\n<ol>\\n${footnotesHtml}\\n</ol>\\n</section>`;\n        }\n\n        return { ...file, content };\n      },\n    },\n  };\n}\n","structuredPatch":[],"originalFile":null}}
