pect(result.assignments[0].roomId).toBe('r2');\n  });\n\n  it('respects time window', () => {\n    const events: Event[] = [\n      { id: 'e1', name: 'Event 1', duration: 500 }, // 8h20m - doesn't fit in 8h window\n    ];\n    const rooms: Room[] = [\n      { id: 'r1', name: 'Room 1', capacity: 10 },\n    ];\n    const result = schedule(events, rooms, defaultOptions);\n    expect(result.assignments).toHaveLength(0);\n    expect(result.unscheduled).toEqual(['e1']);\n  });\n\n  it('respects gap between events in same room', () => {\n    const events: Event[] = [\n      { id: 'e1', name: 'Event 1', duration: 60 },\n      { id: 'e2', name: 'Event 2', duration: 60 },\n    ];\n    const rooms: Room[] = [\n      { id: 'r1', name: 'Room 1', capacity: 10 },\n    ];\n    const result = schedule(events, rooms, defaultOptions);\n    expect(result.assignments).toHaveLength(2);\n\n    const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n    const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n\n    // Default gap is 15 minutes\n    const [first, second] = a1.startTime < a2.startTime ? [a1, a2] : [a2, a1];\n    expect(second.startTime - first.endTime).toBeGreaterThanOrEqual(15);\n  });\n\n  it('respects prerequisites', () => {\n    const events: Event[] = [\n      { id: 'e1', name: 'Event 1', duration: 60 },\n      { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },\n    ];\n    const rooms: Room[] = [\n      { id: 'r1', name: 'Room 1', capacity: 10 },\n    ];\n    const result = schedule(events, rooms, defaultOptions);\n    expect(result.assignments).toHaveLength(2);\n\n    const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n    const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n\n    expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + 15);\n  });\n\n  it('honors preferred room', () => {\n    const events: Event[] = [\n      { id: 'e1', name: 'Event 1', duration: 60, preferredRoom: 'r2' },\n    ];\n    const rooms: Room[] = [\n      { id: 'r1', name: 'Room 1', capacity: 10 },\n      { id: 'r2', name: 'Room 2', capacity: 10 },\n    ];\n    const result = schedule(events, rooms, defaultOptions);\n    expect(result.assignments).toHaveLength(1);\n    expect(result.assignments[0].roomId).toBe('r2');\n  });\n\n  it('throws on self-referencing prerequisite', () => {\n    const events: Event[] = [\n      { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['e1'] },\n    ];\n    const rooms: Room[] = [\n      { id: 'r1', name: 'Room 1', capacity: 10 },\n    ];\n    expect(() => schedule(events, rooms, defaultOptions)).toThrow();\n  });\n\n  it('throws on prerequisite cycle', () => {\n    const events: Event[] = [\n      { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['e2'] },\n      { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },\n    ];\n    const rooms: Room[] = [\n      { id: 'r1', name: 'Room 1', capacity: 10 },\n    ];\n    expect(() => schedule(events, rooms, defaultOptions)).toThrow();\n  });\n\n  it('schedules multiple events across rooms', () => {\n    const events: Event[] = [\n      { id: 'e1', name: 'Event 1', duration: 60 },\n      { id: 'e2', name: 'Event 2', duration: 60 },\n      { id: 'e3', name: 'Event 3', duration: 60 },\n    ];\n    const rooms: Room[] = [\n      { id: 'r1', name: 'Room 1', capacity: 10 },\n      { id: 'r2', name: 'Room 2', capacity: 10 },\n    ];\n    const result = schedule(events, rooms, defaultOptions);\n    expect(result.assignments).toHaveLength(3);\n    expect(result.unscheduled).toHaveLength(0);\n  });\n\n  it('custom gap', () => {\n    const events: Event[] = [\n      { id: 'e1', name: 'Event 1', duration: 60 },\n      { id: 'e2', name: 'Event 2', duration: 60 },\n    ];\n    const rooms: Room[] = [\n      { id: 'r1', name: 'Room 1', capacity: 10 },\n    ];\n    const result = schedule(events, rooms, { ...defaultOptions, gap: 30 });\n    expect(result.assignments).toHaveLength(2);\n\n    const a1 = result