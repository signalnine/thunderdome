    }\n    color.set(id, BLACK);\n  }\n\n  for (const e of events) {\n    if (color.get(e.id) === WHITE) {\n      dfs(e.id);\n    }\n  }\n}\n\nfunction topologicalSort(events: Event[]): string[] {\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  const inDegree = new Map<string, number>();\n  for (const e of events) {\n    inDegree.set(e.id, 0);\n  }\n  for (const e of events) {\n    if (e.prerequisites) {\n      for (const prereqId of e.prerequisites) {\n        if (eventMap.has(prereqId)) {\n          inDegree.set(e.id, (inDegree.get(e.id) ?? 0) + 1);\n        }\n      }\n    }\n  }\n\n  const queue: string[] = [];\n  for (const [id, deg] of inDegree) {\n    if (deg === 0) queue.push(id);\n  }\n\n  const result: string[] = [];\n  while (queue.length > 0) {\n    const id = queue.shift()!;\n    result.push(id);\n    for (const e of events) {\n      if (e.prerequisites?.includes(id)) {\n        const newDeg = (inDegree.get(e.id) ?? 1) - 1;\n        inDegree.set(e.id, newDeg);\n        if (newDeg === 0) {\n          queue.push(e.id);\n        }\n      }\n    }\n  }\n\n  return result;\n}\n\n/**\n * Find the earliest start time for an event in a given room,\n * considering room schedule and prerequisite completion times.\n */\nfunction findEarliestStart(\n  event: Event,\n  roomId: string,\n  roomSchedules: Map<string, Assignment[]>,\n  assignmentMap: Map<string, Assignment>,\n  options: ScheduleOptions,\n  gap: number\n): number | null {\n  // Earliest start based on prerequisites\n  let earliest = options.startTime;\n  if (event.prerequisites) {\n    for (const prereqId of event.prerequisites) {\n      const prereqAssignment = assignmentMap.get(prereqId);\n      if (prereqAssignment) {\n        earliest = Math.max(earliest, prereqAssignment.endTime + gap);\n      }\n    }\n  }\n\n  // Quick check: can the event even fit in the window?\n  if (earliest + event.duration > options.endTime) {\n    return null;\n  }\n\n  const roomAssignments = roomSchedules.get(roomId) ?? [];\n\n  // If no events in this room, just check if it fits\n  if (roomAssignments.length === 0) {\n    return earliest;\n  }\n\n  // Sort room assignments by start time\n  const sorted = [...roomAssignments].sort((a, b) => a.startTime - b.startTime);\n\n  // Build list of candidate start times: earliest possible, and after each existing event\n  const candidates: number[] = [earliest];\n  for (const a of sorted) {\n    candidates.push(a.endTime + gap);\n  }\n\n  for (const candidateStart of candidates) {\n    const start = Math.max(candidateStart, earliest);\n    const end = start + event.duration;\n\n    // Must fit within the time window\n    if (end > options.endTime) continue;\n\n    // Check that this placement doesn't overlap with any existing assignment (including gaps)\n    let valid = true;\n    for (const a of sorted) {\n      // Our event occupies [start, end)\n      // Existing event occupies [a.startTime, a.endTime)\n      // We need: end + gap <= a.startTime OR a.endTime + gap <= start\n      if (!(end + gap <= a.startTime || a.endTime + gap <= start)) {\n        valid = false;\n        break;\n      }\n    }\n\n    if (valid) {\n      return start;\n    }\n  }\n\n  return null;\n}\n\nexport function schedule(\n  events: Event[],\n  rooms: Room[],\n  options: ScheduleOptions\n): ScheduleResult {\n  // Detect cycles first\n  detectCycle(events);\n\n  const gap = options.gap ?? 15;\n\n  const roomMap = new Map<string, Room>();\n  for (const room of rooms) {\n    roomMap.set(room.id, room);\n  }\n\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  // Get topological order\n  const topoOrder = topologicalSort(events);\n\n  // Add any events not in topo order (shouldn't happen if no cycle, but safe)\n  const topoSet = new Set(topoOrder);\n  for (const e of events) {\n    if (!topoSet.has(e.id)) {\n      topoOrder.push(e.id);\n    }\n  }\n\n  // For batch optimization, we use a backtracking approach for smaller inputs\n  // and a greedy approach with smart ordering for larger inputs.\n  const eventCount = events.length;\n  const roomCount = rooms.length;\n\n  if (eventCount <= 20 && roomCount <= 10) {\n    // Use backtracking for small inputs to maximize scheduled events\n    const result = backtrackSchedule(events, rooms, options, gap, topoOrder, eventMap, roomMap);\n    return result;\n  }\n\n  // Greedy approach for larger inputs\n  return greedySchedule(events, rooms, options, gap, topoOrder, eventMap, roomMap);\n}\n\nfunction greedySchedule(\n  events: Event[],\n  rooms: Room[],\n  options: ScheduleOptions,\n  gap: number,\n  topoOrder: string[],\n  eventMap: Map<string, Event>,\n  roomMap: Map<string, Room>\n): ScheduleResult {\n  const assignments: Assignment[] = [];\n  const unscheduled: string[] = [];\n  const assignmentMap = new Map<string, Assignment>();\n  const roomSchedules = new Map<string, Assignment[]>();\n\n  for (const room of rooms) {\n    roomSchedules.set(room.id, []);\n  }\n\n  // Sort rooms by capacity ascending for efficient packing\n  const sortedRooms = [...rooms].sort((a, b) => a.capacity - b.capacity);\n\n  for (const eventId of topoOrder) {\n    const event = eventMap.get(eventId);\n    if (!event) continue;\n\n    const attendees = event.attendees ?? 1;\n\n    // Check if prerequisites are all scheduled\n    let prereqsMet = true;\n    if (event.prerequisites) {\n      for (const prereqId of event.prerequisites) {\n        if (eventMap.has(prereqId) && !assignmentMap.has(prereqId)) {\n          prereqsMet = false;\n          break;\n        }\n      }\n    }\n\n    if (!prereqsMet) {\n      unscheduled.push(eventId);\n      continue;\n    }\n\n    let bestRoom: string | null = null;\n    let bestStart: number | null = null;\n\n    // Try preferred room first\n    if (event.preferredRoom && roomMap.has(event.preferredRoom)) {\n      const room = roomMap.get(event.preferredRoom)!;\n      if (room.capacity >= attendees) {\n        const start = findEarliestStart(event, room.id, roomSchedules, assignmentMap, options, gap);\n        if (start !== null) {\n          bestRoom = room.id;\n          bestStart = start;\n        }\n      }\n    }\n\n    // If preferred room didn't work, try all rooms\n    if (bestRoom === null) {\n      for (const room of sortedRooms) {\n        if (room.capacity < attendees) continue;\n        const start = findEarliestStart(event, room.id, roomSchedules, assignmentMap, options, gap);\n        if (start !== null) {\n          if (bestStart === null || start < bestStart) {\n            bestRoom = room.id;\n            bestStart = start;\n          }\n        }\n      }\n    }\n\n    if (bestRoom !== null && bestStart !== null) {\n      const assignment: Assignment = {\n        eventId,\n        roomId: bestRoom,\n        startTime: bestStart,\n        endTime: bestStart + event.duration,\n      };\n      assignments.push(assignment);\n      assignmentMap.set(eventId, assignment);\n      roomSchedules.get(bestRoom)!.push(assignment);\n    } else {\n      unscheduled.push(eventId);\n    }\n  }\n\n  return { assignments, unscheduled };\n}\n\nfunction backtrackSchedule(\n  events: Event[],\n  rooms: Room[],\n  options: ScheduleOptions,\n  gap: number,\n  topoOrder: string[],\n  eventMap: Map<string, Event>,\n  roomMap: Map<string, Room>\n): ScheduleResult {\n  const sortedRooms = [...rooms].sort((a, b) => a.capacity - b.capacity);\n\n  // State for best solution found\n  let bestAssignments: Assignment[] = [];\n  let bestUnscheduledCount = topoOrder.length;\n\n  // Current state\n  const currentAssignments = new Map<string, Assignment>();\n  const roomSchedules = new Map<string, Assignment[]>();\n  for (const room of rooms) {\n    roomSchedules.set(room.id, []);\n  }\n\n  function canScheduleRemaining(index: number, scheduledCount: number): boolean {\n    // Pruning: even if we schedule all remaining events, can we beat best?\n    const remaining = topoOrder.length - index;\n    return scheduledCount + remaining > (topoOrder.length - bestUnscheduledCount);\n  }\n\n  function solve(index: number, scheduledCount: number): void {\n    if (index === topoOrder.length) {\n      const unscheduledCount = topoOrder.length - scheduledCount;\n      if (unscheduledCount < bestUnscheduledCount) {\n        bestUnscheduledCount = unscheduledCount;\n        bestAssignments = [];\n        for (const assignment of currentAssignments.values()) {\n          bestAssignments.push({ ...assignment });\n        }\n      }\n      return;\n    }\n\n    // Pruning\n    if (!canScheduleRemaining(index, scheduledCount)) return;\n\n    // If we already have a perfect solution, stop\n    if (bestUnscheduledCount === 0) return;\n\n    const eventId = topoOrder[index];\n    const event = eventMap.get(eventId);\n    if (!event) {\n      solve(index + 1, scheduledCount);\n      return;\n    }\n\n    const attendees = event.attendees ?? 1;\n\n    // Check if prerequisites are all scheduled\n    let prereqsMet = true;\n    if (event.prerequisites) {\n      for (const prereqId of event.prerequisites) {\n        if (eventMap.has(prereqId) && !currentAssignments.has(prereqId)) {\n          prereqsMet = false;\n          break;\n        }\n      }\n    }\n\n    if (!prereqsMet) {\n      // Can't schedule this event, skip it\n      solve(index + 1, scheduledCount);\n      return;\n    }\n\n    // Collect all valid (room, startTime) options\n    type Placement = { roomId: string; startTime: number };\n    const placements: Placement[] = [];\n\n    // Try preferred room first\n    let preferredPlacement: Placement | null = null;\n    if (event.preferredRoom && roomMap.has(event.preferredRoom)) {\n      const room = roomMap.get(event.preferredRoom)!;\n      if (room.capacity >= attendees) {\n        const start = findEarliestStart(event, room.id, roomSchedules, currentAssignments, options, gap);\n        if (start !== null) {\n          preferredPlacement = { roomId: room.id, startTime: start };\n          placements.push(preferredPlacement);\n        }\n      }\n    }\n\n    for (const room of sortedRooms) {\n      if (room.capacity < attendees) continue;\n      if (preferredPlacement && room.id === event.preferredRoom) continue;\n      const start = findEarliestStart(event, room.id, roomSchedules, currentAssignments, options, gap);\n      if (start !== null) {\n        placements.push({ roomId: room.id, startTime: start });\n      }\n    }\n\n    // Try placing the event in each valid placement\n    for (const placement of placements) {\n      const assignment: Assignment = {\n        eventId,\n        roomId: placement.roomId,\n        startTime: placement.startTime,\n        endTime: placement.startTime + event.duration,\n      };\n\n      currentAssignments.set(eventId, assignment);\n      roomSchedules.get(placement.roomId)!.push(assignment);\n\n      solve(index + 1, scheduledCount + 1);\n\n      // Undo\n      currentAssignments.delete(eventId);\n      const arr = roomSchedules.get(placement.roomId)!;\n      arr.pop();\n\n      // If we found a perfect solution, stop\n      if (bestUnscheduledCount === 0) return;\n    }\n\n    // Try skipping this event\n    solve(index + 1, scheduledCount);\n  }\n\n  solve(0, 0);\n\n  // Build unscheduled list\n  const scheduledSet = new Set(bestAssignments.map(a => a.eventId));\n  const unscheduled = topoOrder.filter(id => !scheduledSet.has(id));\n\n  return { assignments: bestAssignments, unscheduled };\n}\n","numLines":458,"startLine":1,"totalLines":458}}}
