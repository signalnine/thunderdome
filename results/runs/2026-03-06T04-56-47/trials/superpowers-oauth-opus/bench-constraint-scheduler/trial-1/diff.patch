+import { describe, it, expect } from 'vitest';
+import { schedule, Event, Room, ScheduleOptions } from './scheduler.js';
+
+describe('schedule', () => {
+  const defaultOptions: ScheduleOptions = {
+    startTime: 540, // 9:00 AM
+    endTime: 1020,  // 5:00 PM
+  };
+
+  it('schedules a single event in a single room', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60 },
+    ];
+    const rooms: Room[] = [
+      { id: 'r1', name: 'Room 1', capacity: 10 },
+    ];
+    const result = schedule(events, rooms, defaultOptions);
+    expect(result.assignments).toHaveLength(1);
+    expect(result.unscheduled).toHaveLength(0);
+    expect(result.assignments[0].eventId).toBe('e1');
+    expect(result.assignments[0].roomId).toBe('r1');
+    expect(result.assignments[0].startTime).toBe(540);
+    expect(result.assignments[0].endTime).toBe(600);
+  });
+
+  it('respects room capacity', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60, attendees: 20 },
+    ];
+    const rooms: Room[] = [
+      { id: 'r1', name: 'Room 1', capacity: 10 },
+    ];
+    const result = schedule(events, rooms, defaultOptions);
+    expect(result.assignments).toHaveLength(0);
+    expect(result.unscheduled).toEqual(['e1']);
+  });
+
+  it('respects room capacity - picks correct room', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60, attendees: 20 },
+    ];
+    const rooms: Room[] = [
+      { id: 'r1', name: 'Room 1', capacity: 10 },
+      { id: 'r2', name: 'Room 2', capacity: 30 },
+    ];
+    const result = schedule(events, rooms, defaultOptions);
+    expect(result.assignments).toHaveLength(1);
+    expect(result.assignments[0].roomId).toBe('r2');
+  });
+
+  it('respects time window', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 500 }, // 8h20m - doesn't fit in 8h window
+    ];
+    const rooms: Room[] = [
+      { id: 'r1', name: 'Room 1', capacity: 10 },
+    ];
+    const result = schedule(events, rooms, defaultOptions);
+    expect(result.assignments).toHaveLength(0);
+    expect(result.unscheduled).toEqual(['e1']);
+  });
+
+  it('respects gap between events in same room', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60 },
+      { id: 'e2', name: 'Event 2', duration: 60 },
+    ];
+    const rooms: Room[] = [
+      { id: 'r1', name: 'Room 1', capacity: 10 },
+    ];
+    const result = schedule(events, rooms, defaultOptions);
+    expect(result.assignments).toHaveLength(2);
+
+    const a1 = result.assignments.find(a => a.eventId === 'e1')!;
+    const a2 = result.assignments.find(a => a.eventId === 'e2')!;
+
+    // Default gap is 15 minutes
+    const [first, second] = a1.startTime < a2.startTime ? [a1, a2] : [a2, a1];
+    expect(second.startTime - first.endTime).toBeGreaterThanOrEqual(15);
+  });
+
+  it('respects prerequisites', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60 },
+      { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },
+    ];
+    const rooms: Room[] = [
+      { id: 'r1', name: 'Room 1', capacity: 10 },
+    ];
+    const result = schedule(events, rooms, defaultOptions);
+    expect(result.assignments).toHaveLength(2);
+
+    const a1 = result.assignments.find(a => a.eventId === 'e1')!;
+    const a2 = result.assignments.find(a => a.eventId === 'e2')!;
+
+    expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + 15);
+  });
+
+  it('honors preferred room', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60, preferredRoom: 'r2' },
+    ];
+    const rooms: Room[] = [
+      { id: 'r1', name: 'Room 1', capacity: 10 },
+      { id: 'r2', name: 'Room 2', capacity: 10 },
+    ];
+    const result = schedule(events, rooms, defaultOptions);
+    expect(result.assignments).toHaveLength(1);
+    expect(result.assignments[0].roomId).toBe('r2');
+  });
+
+  it('throws on self-referencing prerequisite', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['e1'] },
+    ];
+    const rooms: Room[] = [
+      { id: 'r1', name: 'Room 1', capacity: 10 },
+    ];
+    expect(() => schedule(events, rooms, defaultOptions)).toThrow();
+  });
+
+  it('throws on prerequisite cycle', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['e2'] },
+      { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },
+    ];
+    const rooms: Room[] = [
+      { id: 'r1', name: 'Room 1', capacity: 10 },
+    ];
+    expect(() => schedule(events, rooms, defaultOptions)).toThrow();
+  });
+
+  it('schedules multiple events across rooms', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60 },
+      { id: 'e2', name: 'Event 2', duration: 60 },
+      { id: 'e3', name: 'Event 3', duration: 60 },
+    ];
+    const rooms: Room[] = [
+      { id: 'r1', name: 'Room 1', capacity: 10 },
+      { id: 'r2', name: 'Room 2', capacity: 10 },
+    ];
+    const result = schedule(events, rooms, defaultOptions);
+    expect(result.assignments).toHaveLength(3);
+    expect(result.unscheduled).toHaveLength(0);
+  });
+
+  it('custom gap', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60 },
+      { id: 'e2', name: 'Event 2', duration: 60 },
+    ];
+    const rooms: Room[] = [
+      { id: 'r1', name: 'Room 1', capacity: 10 },
+    ];
+    const result = schedule(events, rooms, { ...defaultOptions, gap: 30 });
+    expect(result.assignments).toHaveLength(2);
+
+    const a1 = result.assignments.find(a => a.eventId === 'e1')!;
+    const a2 = result.assignments.find(a => a.eventId === 'e2')!;
+
+    const [first, second] = a1.startTime < a2.startTime ? [a1, a2] : [a2, a1];
+    expect(second.startTime - first.endTime).toBeGreaterThanOrEqual(30);
+  });
+
+  it('handles empty events', () => {
+    const rooms: Room[] = [
+      { id: 'r1', name: 'Room 1', capacity: 10 },
+    ];
+    const result = schedule([], rooms, defaultOptions);
+    expect(result.assignments).toHaveLength(0);
+    expect(result.unscheduled).toHaveLength(0);
+  });
+
+  it('maximizes scheduled events (batch optimization)', () => {
+    // 2 events that each take 4 hours - only 1 room, 8 hour day
+    // Both can fit: 9:00-1:00 (240min) + 15min gap + 1:15-5:15
+    // But 5:15 > 5:00, so only if gap + second fits
+    // 540 + 240 = 780 + 15 = 795 + 240 = 1035 > 1020
+    // So only 1 fits in one room
+    // With 2 rooms, both should fit
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 240 },
+      { id: 'e2', name: 'Event 2', duration: 240 },
+    ];
+    const rooms: Room[] = [
+      { id: 'r1', name: 'Room 1', capacity: 10 },
+    ];
+    const result1 = schedule(events, rooms, defaultOptions);
+    expect(result1.assignments).toHaveLength(1);
+    expect(result1.unscheduled).toHaveLength(1);
+
+    const rooms2: Room[] = [
+      { id: 'r1', name: 'Room 1', capacity: 10 },
+      { id: 'r2', name: 'Room 2', capacity: 10 },
+    ];
+    const result2 = schedule(events, rooms2, defaultOptions);
+    expect(result2.assignments).toHaveLength(2);
+    expect(result2.unscheduled).toHaveLength(0);
+  });
+
+  it('default attendees is 1', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60 },
+    ];
+    const rooms: Room[] = [
+      { id: 'r1', name: 'Room 1', capacity: 1 },
+    ];
+    const result = schedule(events, rooms, defaultOptions);
+    expect(result.assignments).toHaveLength(1);
+  });
+
+  it('handles prerequisite chains', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60 },
+      { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },
+      { id: 'e3', name: 'Event 3', duration: 60, prerequisites: ['e2'] },
+    ];
+    const rooms: Room[] = [
+      { id: 'r1', name: 'Room 1', capacity: 10 },
+    ];
+    const result = schedule(events, rooms, defaultOptions);
+    expect(result.assignments).toHaveLength(3);
+
+    const a1 = result.assignments.find(a => a.eventId === 'e1')!;
+    const a2 = result.assignments.find(a => a.eventId === 'e2')!;
+    const a3 = result.assignments.find(a => a.eventId === 'e3')!;
+
+    expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + 15);
+    expect(a3.startTime).toBeGreaterThanOrEqual(a2.endTime + 15);
+  });
+
+  it('three-event cycle throws', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['e3'] },
+      { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },
+      { id: 'e3', name: 'Event 3', duration: 60, prerequisites: ['e2'] },
+    ];
+    const rooms: Room[] = [
+      { id: 'r1', name: 'Room 1', capacity: 10 },
+    ];
+    expect(() => schedule(events, rooms, defaultOptions)).toThrow();
+  });
+
+  it('uses gap 0 correctly', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 240 },
+      { id: 'e2', name: 'Event 2', duration: 240 },
+    ];
+    const rooms: Room[] = [
+      { id: 'r1', name: 'Room 1', capacity: 10 },
+    ];
+    const result = schedule(events, rooms, { ...defaultOptions, gap: 0 });
+    expect(result.assignments).toHaveLength(2);
+    expect(result.unscheduled).toHaveLength(0);
+  });
+});
