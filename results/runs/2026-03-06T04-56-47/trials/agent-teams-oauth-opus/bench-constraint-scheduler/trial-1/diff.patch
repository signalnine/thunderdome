+import { Event, Room, ScheduleOptions, Assignment, ScheduleResult } from './types.js';
+
+function detectCycle(events: Map<string, Event>): void {
+  const WHITE = 0, GRAY = 1, BLACK = 2;
+  const color = new Map<string, number>();
+  for (const id of events.keys()) color.set(id, WHITE);
+
+  function dfs(id: string): void {
+    color.set(id, GRAY);
+    const event = events.get(id);
+    if (event?.prerequisites) {
+      for (const pre of event.prerequisites) {
+        if (!events.has(pre)) continue;
+        const c = color.get(pre);
+        if (c === GRAY) throw new Error(`Prerequisite cycle detected involving event "${id}"`);
+        if (c === WHITE) dfs(pre);
+      }
+    }
+    color.set(id, BLACK);
+  }
+
+  for (const id of events.keys()) {
+    if (color.get(id) === WHITE) dfs(id);
+  }
+}
+
+function topologicalSort(events: Map<string, Event>): string[] {
+  const inDegree = new Map<string, number>();
+  for (const id of events.keys()) inDegree.set(id, 0);
+
+  for (const event of events.values()) {
+    if (event.prerequisites) {
+      for (const pre of event.prerequisites) {
+        if (events.has(pre)) {
+          inDegree.set(event.id, (inDegree.get(event.id) ?? 0) + 1);
+        }
+      }
+    }
+  }
+
+  const queue: string[] = [];
+  for (const [id, deg] of inDegree) {
+    if (deg === 0) queue.push(id);
+  }
+
+  const sorted: string[] = [];
+  while (queue.length > 0) {
+    queue.sort();
+    const id = queue.shift()!;
+    sorted.push(id);
+    for (const event of events.values()) {
+      if (event.prerequisites?.includes(id)) {
+        const newDeg = (inDegree.get(event.id) ?? 1) - 1;
+        inDegree.set(event.id, newDeg);
+        if (newDeg === 0) queue.push(event.id);
+      }
+    }
+  }
+
+  return sorted;
+}
+
+export function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {
+  const gap = options.gap ?? 15;
+  const eventMap = new Map<string, Event>();
+  for (const e of events) eventMap.set(e.id, e);
+
+  // Check for self-references explicitly
+  for (const e of events) {
+    if (e.prerequisites?.includes(e.id)) {
+      throw new Error(`Prerequisite cycle detected involving event "${e.id}"`);
+    }
+  }
+
+  detectCycle(eventMap);
+
+  if (rooms.length === 0 || events.length === 0) {
+    return {
+      assignments: [],
+      unscheduled: events.map(e => e.id),
+    };
+  }
+
+  const topoOrder = topologicalSort(eventMap);
+
+  // Build dependency graph: for each event, which events must come before it
+  const dependsOn = new Map<string, Set<string>>();
+  for (const e of events) {
+    dependsOn.set(e.id, new Set(e.prerequisites?.filter(p => eventMap.has(p)) ?? []));
+  }
+
+  // Get all transitive prerequisites for an event
+  function getTransitivePrereqs(eventId: string): Set<string> {
+    const result = new Set<string>();
+    const stack = [...(dependsOn.get(eventId) ?? [])];
+    while (stack.length > 0) {
+      const id = stack.pop()!;
+      if (!result.has(id)) {
+        result.add(id);
+        for (const pre of dependsOn.get(id) ?? []) {
+          stack.push(pre);
+        }
+      }
+    }
+    return result;
+  }
+
+  // Find eligible rooms for each event (capacity check)
+  const eligibleRooms = new Map<string, Room[]>();
+  for (const e of events) {
+    const attendees = e.attendees ?? 1;
+    const eligible = rooms.filter(r => r.capacity >= attendees);
+    // Sort: preferred room first, then by capacity (smaller first for better packing)
+    eligible.sort((a, b) => {
+      if (e.preferredRoom) {
+        if (a.id === e.preferredRoom && b.id !== e.preferredRoom) return -1;
+        if (b.id === e.preferredRoom && a.id !== e.preferredRoom) return 1;
+      }
+      return a.capacity - b.capacity;
+    });
+    eligibleRooms.set(e.id, eligible);
+  }
+
+  // Use backtracking to maximize scheduled events
+  // State: for each room, list of (start, end) intervals sorted by start
+  type RoomSchedule = { eventId: string; start: number; end: number }[];
+  const roomSchedules = new Map<string, RoomSchedule>();
+  for (const r of rooms) roomSchedules.set(r.id, []);
+
+  const assignments = new Map<string, Assignment>();
+
+  function getEarliestStartInRoom(roomId: string, duration: number, minStart: number): number | null {
+    const schedule = roomSchedules.get(roomId)!;
+    let candidateStart = Math.max(options.startTime, minStart);
+    const candidateEnd = candidateStart + duration;
+
+    if (candidateEnd > options.endTime) return null;
+
+    if (schedule.length === 0) return candidateStart;
+
+    // Try to fit before first event, between events, or after last event
+    for (const slot of schedule) {
+      if (candidateStart + duration <= slot.start - gap) {
+        // Fits before this slot (with gap)
+        if (candidateStart + duration > options.endTime) return null;
+        return candidateStart;
+      }
+      // Must start after this slot ends + gap
+      candidateStart = Math.max(candidateStart, slot.end + gap);
+    }
+
+    if (candidateStart + duration <= options.endTime) return candidateStart;
+    return null;
+  }
+
+  function findAllSlotsInRoom(roomId: string, duration: number, minStart: number): number[] {
+    const schedule = roomSchedules.get(roomId)!;
+    const slots: number[] = [];
+    let candidateStart = Math.max(options.startTime, minStart);
+
+    if (candidateStart + duration > options.endTime) return slots;
+
+    if (schedule.length === 0) {
+      slots.push(candidateStart);
+      return slots;
+    }
+
+    for (const slot of schedule) {
+      if (candidateStart + duration <= slot.start - gap) {
+        slots.push(candidateStart);
+      }
+      candidateStart = Math.max(candidateStart, slot.end + gap);
+      if (candidateStart + duration > options.endTime) break;
+    }
+
+    if (candidateStart + duration <= options.endTime) {
+      slots.push(candidateStart);
+    }
+
+    return slots;
+  }
+
+  function insertIntoRoom(roomId: string, eventId: string, start: number, end: number): void {
+    const schedule = roomSchedules.get(roomId)!;
+    const entry = { eventId, start, end };
+    let i = 0;
+    while (i < schedule.length && schedule[i].start < start) i++;
+    schedule.splice(i, 0, entry);
+  }
+
+  function removeFromRoom(roomId: string, eventId: string): void {
+    const schedule = roomSchedules.get(roomId)!;
+    const idx = schedule.findIndex(s => s.eventId === eventId);
+    if (idx !== -1) schedule.splice(idx, 1);
+  }
+
+  // Greedy approach with smarter ordering:
+  // Process events in topological order but also consider constrained events first
+  // (events with fewer eligible rooms or more prerequisites should be scheduled first)
+
+  // Score events by how constrained they are
+  const constraintScore = new Map<string, number>();
+  for (const e of events) {
+    const eligible = eligibleRooms.get(e.id)!;
+    // More constrained = fewer rooms, more prerequisites, larger duration
+    const score = eligible.length * 1000 - (e.prerequisites?.length ?? 0) * 100 - e.duration;
+    constraintScore.set(e.id, score);
+  }
+
+  // Build scheduling order: respect topo order but within same level, schedule most constrained first
+  const schedulingOrder = [...topoOrder].sort((a, b) => {
+    // First respect topological dependencies
+    const aPrereqs = getTransitivePrereqs(a);
+    const bPrereqs = getTransitivePrereqs(b);
+    if (aPrereqs.has(b)) return 1; // a depends on b, b goes first
+    if (bPrereqs.has(a)) return -1; // b depends on a, a goes first
+    // Neither depends on the other, schedule most constrained first
+    return (constraintScore.get(a) ?? 0) - (constraintScore.get(b) ?? 0);
+  });
+
+  // Try to schedule with backtracking for better optimization
+  let bestAssignments = new Map<string, Assignment>();
+  let bestCount = 0;
+
+  function getMinStartForEvent(eventId: string): number {
+    const event = eventMap.get(eventId)!;
+    let minStart = options.startTime;
+    if (event.prerequisites) {
+      for (const preId of event.prerequisites) {
+        const preAssignment = assignments.get(preId);
+        if (preAssignment) {
+          minStart = Math.max(minStart, preAssignment.endTime + gap);
+        }
+      }
+    }
+    return minStart;
+  }
+
+  function canScheduleRemaining(index: number): boolean {
+    // Quick check: can we beat current best with remaining events?
+    return assignments.size + (schedulingOrder.length - index) > bestCount;
+  }
+
+  function solve(index: number): void {
+    if (assignments.size > bestCount) {
+      bestCount = assignments.size;
+      bestAssignments = new Map(assignments);
+      if (bestCount === events.length) return; // All scheduled, optimal
+    }
+
+    if (index >= schedulingOrder.length) return;
+    if (bestCount === events.length) return; // Already optimal
+
+    // Prune: can't beat best even if we schedule everything remaining
+    if (!canScheduleRemaining(index)) return;
+
+    const eventId = schedulingOrder[index];
+    const event = eventMap.get(eventId)!;
+    const eligible = eligibleRooms.get(eventId)!;
+
+    // Check if prerequisites are met
+    let prereqsMet = true;
+    if (event.prerequisites) {
+      for (const preId of event.prerequisites) {
+        if (eventMap.has(preId) && !assignments.has(preId)) {
+          prereqsMet = false;
+          break;
+        }
+      }
+    }
+
+    if (prereqsMet && eligible.length > 0) {
+      const minStart = getMinStartForEvent(eventId);
+
+      // Try each eligible room
+      for (const room of eligible) {
+        const startTime = getEarliestStartInRoom(room.id, event.duration, minStart);
+        if (startTime !== null) {
+          const endTime = startTime + event.duration;
+          const assignment: Assignment = { eventId, roomId: room.id, startTime, endTime };
+          assignments.set(eventId, assignment);
+          insertIntoRoom(room.id, eventId, startTime, endTime);
+
+          solve(index + 1);
+
+          if (bestCount === events.length) return; // Found optimal
+
+          assignments.delete(eventId);
+          removeFromRoom(room.id, eventId);
+        }
+      }
+    }
+
+    // Also try skipping this event (it goes to unscheduled)
+    solve(index + 1);
+  }
+
+  // For small inputs, use full backtracking
+  // For larger inputs, use greedy with local improvements
+  if (events.length <= 12) {
+    solve(0);
+  } else {
+    // Greedy approach for larger inputs
+    for (const eventId of schedulingOrder) {
+      const event = eventMap.get(eventId)!;
+      const eligible = eligibleRooms.get(eventId)!;
+
+      if (eligible.length === 0) continue;
+
+      let prereqsMet = true;
+      if (event.prerequisites) {
+        for (const preId of event.prerequisites) {
+          if (eventMap.has(preId) && !assignments.has(preId)) {
+            prereqsMet = false;
+            break;
+          }
+        }
+      }
+      if (!prereqsMet) continue;
+
+      const minStart = getMinStartForEvent(eventId);
+
+      // Try preferred room first, then others
+      for (const room of eligible) {
+        const startTime = getEarliestStartInRoom(room.id, event.duration, minStart);
+        if (startTime !== null) {
+          const endTime = startTime + event.duration;
+          assignments.set(eventId, { eventId, roomId: room.id, startTime, endTime });
+          insertIntoRoom(room.id, eventId, startTime, endTime);
+          break;
+        }
+      }
+    }
+
+    bestAssignments = new Map(assignments);
+    bestCount = assignments.size;
+
+    // Try to improve: for each unscheduled event, see if rearranging helps
+    const unscheduledIds = events
+      .map(e => e.id)
+      .filter(id => !bestAssignments.has(id));
+
+    if (unscheduledIds.length > 0 && unscheduledIds.length <= 5) {
+      // Try to fit unscheduled events by trying different room/time combinations
+      for (const eventId of unscheduledIds) {
+        const event = eventMap.get(eventId)!;
+        const eligible = eligibleRooms.get(eventId)!;
+
+        let prereqsMet = true;
+        if (event.prerequisites) {
+          for (const preId of event.prerequisites) {
+            if (eventMap.has(preId) && !assignments.has(preId)) {
+              prereqsMet = false;
+              break;
+            }
+          }
+        }
+        if (!prereqsMet) continue;
+
+        const minStart = getMinStartForEvent(eventId);
+
+        for (const room of eligible) {
+          const slots = findAllSlotsInRoom(room.id, event.duration, minStart);
+          for (const startTime of slots) {
+            const endTime = startTime + event.duration;
+            assignments.set(eventId, { eventId, roomId: room.id, startTime, endTime });
+            insertIntoRoom(room.id, eventId, startTime, endTime);
+            bestAssignments.set(eventId, { eventId, roomId: room.id, startTime, endTime });
+            bestCount++;
+            break;
+          }
+          if (assignments.has(eventId)) break;
+        }
+      }
+    }
+  }
+
+  const resultAssignments: Assignment[] = [];
+  const unscheduled: string[] = [];
+
+  for (const e of events) {
+    const a = bestAssignments.get(e.id);
+    if (a) {
+      resultAssignments.push(a);
+    } else {
+      unscheduled.push(e.id);
+    }
+  }
+
+  return { assignments: resultAssignments, unscheduled };
+}
