nments.find(a => a.eventId === 'e1')!;\n      const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n\n      // Ensure gap between events in same room\n      if (a1.roomId === a2.roomId) {\n        const [first, second] = a1.startTime < a2.startTime ? [a1, a2] : [a2, a1];\n        expect(second.startTime - first.endTime).toBeGreaterThanOrEqual(15);\n      }\n    });\n\n    it('should schedule events across multiple rooms', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n        { id: 'e2', name: 'Event 2', duration: 60 },\n      ];\n      const rooms: Room[] = [\n        { id: 'r1', name: 'Room 1', capacity: 10 },\n        { id: 'r2', name: 'Room 2', capacity: 10 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(2);\n      expect(result.unscheduled).toHaveLength(0);\n    });\n\n    it('should handle empty events', () => {\n      const rooms: Room[] = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n      const result = schedule([], rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toHaveLength(0);\n    });\n\n    it('should handle empty rooms', () => {\n      const events: Event[] = [{ id: 'e1', name: 'Event 1', duration: 60 }];\n      const result = schedule(events, [], defaultOptions);\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toEqual(['e1']);\n    });\n  });\n\n  describe('capacity constraints', () => {\n    it('should not schedule an event in a room that is too small', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, attendees: 20 },\n      ];\n      const rooms: Room[] = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toEqual(['e1']);\n    });\n\n    it('should place events in rooms with sufficient capacity', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, attendees: 15 },\n      ];\n      const rooms: Room[] = [\n        { id: 'r1', name: 'Small Room', capacity: 10 },\n        { id: 'r2', name: 'Large Room', capacity: 20 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('r2');\n    });\n\n    it('should default attendees to 1', () => {\n      const events: Event[] = [{ id: 'e1', name: 'Event 1', duration: 60 }];\n      const rooms: Room[] = [{ id: 'r1', name: 'Room 1', capacity: 1 }];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(1);\n    });\n  });\n\n  describe('time window constraints', () => {\n    it('should not schedule events outside the time window', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 500 }, // 8+ hours\n      ];\n      const rooms: Room[] = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n      const result = schedule(events, rooms, defaultOptions); // 8 hour window\n\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toEqual(['e1']);\n    });\n\n    it('should respect custom start and end times', () => {\n      const events: Event[] = [{ id: 'e1', name: 'Event 1', duration: 60 }];\n      const rooms: Room[] = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n      const result = schedule(events, rooms, { startTime: 600, endTime: 660 });\n\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].startTime).toBeGreaterThanOrEqual(600);\n      expect(result.assignments[0].endTime).toBeLessThanOrEqual(660);\n    });\n\n    it('should not schedule if event does not fit in remaining window', () => {\n      const events: Event[] = [{ id: 'e1', name: 'Event 1', duration: 61 }];\n      const rooms: Room[] = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n      const result = schedule(events, rooms, { startTime: 600, endTime: 660 });\n\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toEqual(['e1']);\n    });\n  });\n\n  describe('gap constraints', () => {\n    it('should respect default 15-minute gap', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n        { id: 'e2', name: 'Event 2', duration: 60 },\n      ];\n      const rooms: Room[] = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(2);\n      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);\n      expect(sorted[1].startTime - sorted[0].endTime).toBeGreaterThanOrEqual(15);\n    });\n\n    it('should respect custom gap', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n        { id: 'e2', name: 'Event 2', duration: 60 },\n      ];\n      const rooms: Room[] = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n      const result = schedule(events, rooms, { ...defaultOptions, gap: 30 });\n\n      expect(result.assignments).toHaveLength(2);\n      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);\n      expect(sorted[1].startTime - sorted[0].endTime).toBeGreaterThanOrEqual(30);\n    });\n\n    it('should handle gap of 0', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n        { id: 'e2', name: 'Event 2', duration: 60 },\n      ];\n      const rooms: Room[] = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n      const result = schedule(events, rooms, { ...defaultOptions, gap: 0 });\n\n      expect(result.assignments).toHaveLength(2);\n      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);\n      expect(sorted[1].startTime).toBeGreaterThanOrEqual(sorted[0].endTime);\n    });\n  });\n\n  describe('prerequisites', () => {\n    it('should schedule prerequisite events before dependent events', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n        { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },\n      ];\n      const rooms: Room[] = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(2);\n      const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n      const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n      expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + 15);\n    });\n\n    it('should handle chain of prerequisites', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 30 },\n        { id: 'e2', name: 'Event 2', duration: 30, prerequisites: ['e1'] },\n        { id: 'e3', name: 'Event 3', duration: 30, prerequisites: ['e2'] },\n      ];\n      const rooms: Room[] = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(3);\n      const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n      const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n      const a3 = result.assignments.find(a => a.eventId === 'e3')!;\n      expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + 15);\n      expect(a3.startTime).toBeGreaterThanOrEqual(a2.endTime + 15);\n    });\n\n    it('should handle multiple prerequisites', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 30 },\n        { id: 'e2', name: 'Event 2', duration: 30 },\n        { id: 'e3', name: 'Event 3', duration: 30, prerequisites: ['e1', 'e2'] },\n      ];\n      const rooms: Room[] = [\n        { id: 'r1', name: 'Room 1', capacity: 10 },\n        { id: 'r2', name: 'Room 2', capacity: 10 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(3);\n      const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n      const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n      const a3 = result.assignments.find(a => a.eventId === 'e3')!;\n      expect(a3.startTime).toBeGreaterThanOrEqual(a1.endTime + 15);\n      expect(a3.startTime).toBeGreaterThanOrEqual(a2.endTime + 15);\n    });\n\n    it('should throw on prerequisite cycle', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 30, prerequisites: ['e2'] },\n        { id: 'e2', name: 'Event 2', duration: 30, prerequisites: ['e1'] },\n      ];\n      const rooms: Room[] = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n      expect(() => schedule(events, rooms, defaultOptions)).toThrow();\n    });\n\n    it('should throw on self-referencing prerequisite', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 30, prerequisites: ['e1'] },\n      ];\n      const rooms: Room[] = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n      expect(() => schedule(events, rooms, defaultOptions)).toThrow();\n    });\n\n    it('should throw on longer prerequisite cycle', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 30, prerequisites: ['e3'] },\n        { id: 'e2', name: 'Event 2', duration: 30, prerequisites: ['e1'] },\n        { id: 'e3', name: 'Event 3', duration: 30, prerequisites: ['e2'] },\n      ];\n      const rooms: Room[] = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n      expect(() => schedule(events, rooms, defaultOptions)).toThrow();\n    });\n\n    it('should apply gap between prerequisite and dependent events', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n        { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },\n      ];\n      const rooms: Room[] = [\n        { id: 'r1', name: 'Room 1', capacity: 10 },\n        { id: 'r2', name: 'Room 2', capacity: 10 },\n      ];\n      const result = schedule(events, rooms, { ...defaultOptions, gap: 30 });\n\n      const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n      const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n      expect(a2.startTime - a1.endTime).toBeGreaterThanOrEqual(30);\n    });\n  });\n\n  describe('preferred room', () => {\n    it('should honor preferred room when possible', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, preferredRoom: 'r2' },\n      ];\n      const rooms: Room[] = [\n        { id: 'r1', name: 'Room 1', capacity: 10 },\n        { id: 'r2', name: 'Room 2', capacity: 10 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('r2');\n    });\n\n    it('should fall back to other room if preferred room cannot accommodate', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, attendees: 15, preferredRoom: 'r1' },\n      ];\n      const rooms: Room[] = [\n        { id: 'r1', name: 'Small Room', capacity: 10 },\n        { id: 'r2', name: 'Large Room', capacity: 20 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('r2');\n    });\n  });\n\n  describe('unscheduled events', () => {\n    it('should list events that cannot be scheduled', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 400 },\n        { id: 'e2', name: 'Event 2', duration: 400 },\n      ];\n      const rooms: Room[] = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n      // 480 min window, two 400 min events + 15 min gap = 815 min needed\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(1);\n      expect(result.unscheduled).toHaveLength(1);\n    });\n\n    it('should maximize number of scheduled events', () => {\n      // One big event or two small ones - should prefer two small ones\n      const events: Event[] = [\n        { id: 'big', name: 'Big Event', duration: 300 },\n        { id: 'small1', name: 'Small 1', duration: 120 },\n        { id: 'small2', name: 'Small 2', duration: 120 },\n      ];\n      const rooms: Room[] = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n      // Window: 480 min. Big=300, leaves 165 after gap. Small1+Small2=120+15+120=255\n      const result = schedule(events, rooms, defaultOptions);\n\n      // Should schedule 2 events (either big alone or both smalls)\n      // Maximizing count: both small events (2 > 1)\n      expect(result.assignments).toHaveLength(2);\n      expect(result.unscheduled).toHaveLength(1);\n      const scheduledIds = result.assignments.map(a => a.eventId).sort();\n      expect(scheduledIds).toEqual(['small1', 'small2']);\n    });\n  });\n\n  describe('complex scenarios', () => {\n    it('should handle a conference-style schedule', () => {\n      const events: Event[] = [\n        { id: 'keynote', name: 'Keynote', duration: 90, attendees: 100 },\n        { id: 'talk1', name: 'Talk 1', duration: 45, attendees: 30, prerequisites: ['keynote'] },\n        { id: 'talk2', name: 'Talk 2', duration: 45, attendees: 20, prerequisites: ['keynote'] },\n        { id: 'talk3', name: 'Talk 3', duration: 45, attendees: 25, prerequisites: ['keynote'] },\n        { id: 'workshop', name: 'Workshop', duration: 120, attendees: 15, prerequisites: ['keynote'] },\n        { id: 'closing', name: 'Closing', duration: 30, attendees: 100, prerequisites: ['talk1', 'talk2', 'talk3', 'workshop'] },\n      ];\n      const rooms: Room[] = [\n        { id: 'main', name: 'Main Hall', capacity: 150 },\n        { id: 'a', name: 'Room A', capacity: 40 },\n        { id: 'b', name: 'Room B', capacity: 30 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(6);\n      expect(result.unscheduled).toHaveLength(0);\n\n      // Verify keynote is in main hall (only room big enough)\n      const keynoteAssignment = result.assignments.find(a => a.eventId === 'keynote');\n      expect(keynoteAssignment?.roomId).toBe('main');\n\n      // Verify closing is in main hall\n      const closingAssignment = result.assignments.find(a => a.eventId === 'closing');\n      expect(closingAssignment?.roomId).toBe('main');\n\n      // Verify all prerequisites are respected\n      const assignmentMap = new Map(result.assignments.map(a => [a.eventId, a]));\n      for (const event of events) {\n        if (event.prerequisites) {\n          for (const preId of event.prerequisites) {\n            const preAssignment = assignmentMap.get(preId)!;\n            const thisAssignment = assignmentMap.get(event.id)!;\n            expect(thisAssignment.startTime).toBeGreaterThanOrEqual(preAssignment.endTime + 15);\n          }\n        }\n      }\n    });\n\n    it('should handle events with no valid rooms', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, attendees: 100 },\n        { id: 'e2', name: 'Event 2', duration: 60, attendees: 5 },\n      ];\n      const rooms: Room[] = [{ id: 'r1', name: 'Small Room', capacity: 10 }];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].eventId).toBe('e2');\n      expect(result.unscheduled).toEqual(['e1']);\n    });\n\n    it('should handle tight scheduling with custom gap', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 55 },\n        { id: 'e2', name: 'Event 2', duration: 55 },\n        { id: 'e3', name: 'Event 3', duration: 55 },\n        { id: 'e4', name: 'Event 4', duration: 55 },\n      ];\n      const rooms: Room[] = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n      // Window: 480 min. 4 events of 55 + 3 gaps of 5 = 235 min\n      const result = schedule(events, rooms, { ...defaultOptions, gap: 5 });\n\n      expect(result.assignments).toHaveLength(4);\n      expect(result.unscheduled).toHaveLength(0);\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null},"sourceToolAssistantUUID":"20b64da1-be05-4504-b6ef-9e56350e82a5"}
