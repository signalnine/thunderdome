g, Assignment>,\n  roomSchedules: Map<string, Assignment[]>,\n  snapshot: { assigned: Map<string, Assignment>; roomSchedules: Map<string, Assignment[]> },\n): void {\n  assigned.clear();\n  for (const [k, v] of snapshot.assigned) assigned.set(k, v);\n  roomSchedules.clear();\n  for (const [k, v] of snapshot.roomSchedules) roomSchedules.set(k, v);\n}\n\n/**\n * Improvement pass: try to schedule unscheduled events by evicting\n * less valuable scheduled events when doing so increases total scheduled count.\n */\nfunction improveSchedule(\n  unscheduled: string[],\n  eventMap: Map<string, Event>,\n  rooms: Room[],\n  gap: number,\n  windowStart: number,\n  windowEnd: number,\n  assigned: Map<string, Assignment>,\n  roomSchedules: Map<string, Assignment[]>,\n  _dependentsMap: Map<string, Set<string>>,\n  _eventScore: Map<string, number>,\n): void {\n  let improved = true;\n  let iterations = 0;\n  const maxIterations = Math.min(unscheduled.length * 5, 200);\n\n  while (improved && iterations < maxIterations) {\n    improved = false;\n    iterations++;\n\n    for (let i = unscheduled.length - 1; i >= 0; i--) {\n      const eventId = unscheduled[i];\n      const event = eventMap.get(eventId)!;\n\n      // Check if all prerequisites are assigned\n      let prereqsMet = true;\n      if (event.prerequisites) {\n        for (const prereq of event.prerequisites) {\n          if (eventMap.has(prereq) && !assigned.has(prereq)) {\n            prereqsMet = false;\n            break;\n          }\n        }\n      }\n      if (!prereqsMet) continue;\n\n      // Try placing without eviction first\n      const placement = tryPlaceEvent(\n        event, rooms, gap, windowStart, windowEnd, assigned, roomSchedules,\n      );\n\n      if (placement) {\n        commitAssignment(placement, assigned, roomSchedules);\n        unscheduled.splice(i, 1);\n        improved = true;\n        continue;\n      }\n\n      // Try evicting a single scheduled event to make room\n      const scheduledEnt