er,\n  windowStart: number,\n  windowEnd: number,\n  assigned: Map<string, Assignment>,\n  roomSchedules: Map<string, Assignment[]>,\n): Assignment | null {\n  const attendees = event.attendees ?? 1;\n  const earliest = earliestStartAfterPrereqs(event, assigned, gap, windowStart);\n\n  // Filter rooms that have sufficient capacity\n  const validRooms = rooms.filter(r => r.capacity >= attendees);\n  if (validRooms.length === 0) return null;\n\n  // Sort rooms: preferred room first, then by capacity (smallest sufficient first)\n  const sortedRooms = [...validRooms].sort((a, b) => {\n    if (event.preferredRoom) {\n      if (a.id === event.preferredRoom && b.id !== event.preferredRoom) return -1;\n      if (b.id === event.preferredRoom && a.id !== event.preferredRoom) return 1;\n    }\n    return a.capacity - b.capacity;\n  });\n\n  let bestAssignment: Assignment | null = null;\n\n  for (const room of sortedRooms) {\n    const startTime = findSlotInRoom(\n      room.id,\n      event.duration,\n      earliest,\n      windowEnd,\n      gap,\n      roomSchedules,\n    );\n\n    if (startTime !== null) {\n      const assignment: Assignment = {\n        eventId: event.id,\n        roomId: room.id,\n        startTime,\n        endTime: startTime + event.duration,\n      };\n\n      // If this is the preferred room, use it immediately\n      if (event.preferredRoom && room.id === event.preferredRoom) {\n        return assignment;\n      }\n\n      // Otherwise keep the best (earliest start, smallest room)\n      if (!bestAssignment || startTime < bestAssignment.startTime) {\n        bestAssignment = assignment;\n      }\n    }\n  }\n\n  return bestAssignment;\n}\n\n/**\n * Commit an assignment: update tracking data structures.\n */\nfunction commitAssignment(\n  assignment: Assignment,\n  assigned: Map<string, Assignment>,\n  roomSchedules: Map<string, Assignment[]>,\n): void {\n  assigned.set(assignment.eventId, assignment);\n  if (!roomSchedules.has(assignment.roomId)) {\n    roomSchedules.set(assignment.roomId, []);\n  }\n  roomSchedules.get(assignment.roomId)!.push(assignment);\n}\n\n/**\n * Remove an assignment from tracking data structures.\n */\nfunction removeAssignment(\n  eventId: string,\n  assigned: Map<string, Assignment>,\n  roomSchedules: Map<string, Assignment[]>,\n): void {\n  const assignment = assigned.get(eventId);\n  if (!assignment) return;\n  assigned.delete(eventId);\n  const roomSched = roomSchedules.get(assignment.roomId);\n  if (roomSched) {\n    const idx = roomSched.findIndex(a => a.eventId === eventId);\n    if (idx !== -1) roomSched.splice(idx, 1);\n  }\n}\n\n/**\n * Get all events that transitively depend on a given event (its descendants\n * in the prerequisite DAG).\n */\nfunction getDependents(\n  eventId: string,\n  dependentsMap: Map<string, Set<string>>,\n): Set<string> {\n  return dependentsMap.get(eventId) ?? new Set();\n}\n\n/**\n * Build a map from each event to the set of events that directly depend on it.\n */\nfunction buildDirectDependentsMap(events: Event[]): Map<string, Set<string>> {\n  const map = new Map<string, Set<string>>();\n  for (const e of events) {\n    if (!map.has(e.id)) map.set(e.id, new Set());\n  }\n  for (const e of events) {\n    if (e.prerequisites) {\n      for (const prereq of e.prerequisites) {\n        if (map.has(prereq)) {\n          map.get(prereq)!.add(e.id);\n        }\n      }\n    }\n  }\n  return map;\n}\n\n/**\n * Build a map from each event to ALL events that transitively depend on it.\n */\nfunction buildTransitiveDependentsMap(\n  events: Event[],\n  topoOrder: string[],\n): Map<string, Set<string>> {\n  const direct = buildDirectDependentsMap(events);\n  const transitive = new Map<string, Set<string>>();\n\n  // Process in reverse topological order so dependents are computed bottom-up\n  for (let i = topoOrder.length - 1; i >= 0; i--) {\n    const id = topoOrder[i];\n    const allDeps = new Set<string>();\n    for (const child of direct.get(id) ?? []) {\