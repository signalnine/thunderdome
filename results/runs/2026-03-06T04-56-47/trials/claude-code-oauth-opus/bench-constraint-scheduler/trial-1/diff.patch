+++ b/src/scheduler.ts
@@ -0,0 +1,564 @@
+import type { Event, Room, ScheduleOptions, Assignment, ScheduleResult } from './types.js';
+
+const DEFAULT_GAP = 15;
+
+/**
+ * Detect cycles in the prerequisite graph. Throws if a cycle is found.
+ * Uses Kahn's algorithm: if we can't produce a full topological order,
+ * a cycle exists.
+ */
+function detectCyclesAndTopologicalSort(events: Event[]): string[] {
+  const eventIds = new Set(events.map(e => e.id));
+  const inDegree = new Map<string, number>();
+  const adjacency = new Map<string, string[]>();
+
+  for (const e of events) {
+    inDegree.set(e.id, 0);
+    adjacency.set(e.id, []);
+  }
+
+  for (const e of events) {
+    if (!e.prerequisites) continue;
+    for (const prereq of e.prerequisites) {
+      if (prereq === e.id) {
+        throw new Error(`Cycle detected: event "${e.id}" lists itself as a prerequisite`);
+      }
+      if (eventIds.has(prereq)) {
+        adjacency.get(prereq)!.push(e.id);
+        inDegree.set(e.id, (inDegree.get(e.id) ?? 0) + 1);
+      }
+    }
+  }
+
+  const queue: string[] = [];
+  for (const [id, deg] of inDegree) {
+    if (deg === 0) queue.push(id);
+  }
+
+  const order: string[] = [];
+  while (queue.length > 0) {
+    const node = queue.shift()!;
+    order.push(node);
+    for (const neighbor of adjacency.get(node) ?? []) {
+      const newDeg = (inDegree.get(neighbor) ?? 1) - 1;
+      inDegree.set(neighbor, newDeg);
+      if (newDeg === 0) queue.push(neighbor);
+    }
+  }
+
+  if (order.length !== events.length) {
+    throw new Error('Cycle detected in prerequisite graph');
+  }
+
+  return order;
+}
+
+/**
+ * Find the earliest start time for an event given its prerequisites
+ * and their already-assigned times.
+ */
+function earliestStartAfterPrereqs(
+  event: Event,
+  assigned: Map<string, Assignment>,
+  gap: number,
+  windowStart: number,
+): number {
+  let earliest = windowStart;
+  if (event.prerequisites) {
+    for (const prereqId of event.prerequisites) {
+      const prereqAssignment = assigned.get(prereqId);
+      if (prereqAssignment) {
+        earliest = Math.max(earliest, prereqAssignment.endTime + gap);
+      }
+    }
+  }
+  return earliest;
+}
+
+/**
+ * Find the earliest time slot in a room where an event can fit,
+ * starting no earlier than `earliest`.
+ */
+function findSlotInRoom(
+  roomId: string,
+  duration: number,
+  earliest: number,
+  windowEnd: number,
+  gap: number,
+  roomSchedules: Map<string, Assignment[]>,
+): number | null {
+  const schedule = roomSchedules.get(roomId) ?? [];
+
+  // Sort by start time
+  const sorted = [...schedule].sort((a, b) => a.startTime - b.startTime);
+
+  // Try to fit before the first event, between events, or after the last event
+  let candidateStart = earliest;
+
+  for (const existing of sorted) {
+    const candidateEnd = candidateStart + duration;
+
+    // Can we fit before this existing event?
+    if (candidateEnd + gap <= existing.startTime) {
+      // Yes, this slot works
+      if (candidateEnd <= windowEnd) {
+        return candidateStart;
+      }
+    }
+
+    // Move past this event
+    const afterExisting = existing.endTime + gap;
+    if (afterExisting > candidateStart) {
+      candidateStart = afterExisting;
+    }
+  }
+
+  // Try after all existing events
+  const candidateEnd = candidateStart + duration;
+  if (candidateEnd <= windowEnd) {
+    return candidateStart;
+  }
+
+  return null;
+}
+
+/**
+ * Try to place a single event into any valid room. Returns the assignment
+ * or null if it can't be placed.
+ *
+ * Prefers the event's preferredRoom if feasible.
+ */
+function tryPlaceEvent(
+  event: Event,
+  rooms: Room[],
+  gap: number,
+  windowStart: number,
+  windowEnd: number,
+  assigned: Map<string, Assignment>,
+  roomSchedules: Map<string, Assignment[]>,
+): Assignment | null {
+  const attendees = event.attendees ?? 1;
+  const earliest = earliestStartAfterPrereqs(event, assigned, gap, windowStart);
+
+  // Filter rooms that have sufficient capacity
+  const validRooms = rooms.filter(r => r.capacity >= attendees);
+  if (validRooms.length === 0) return null;
+
+  // Sort rooms: preferred room first, then by capacity (smallest sufficient first)
+  const sortedRooms = [...validRooms].sort((a, b) => {
+    if (event.preferredRoom) {
+      if (a.id === event.preferredRoom && b.id !== event.preferredRoom) return -1;
+      if (b.id === event.preferredRoom && a.id !== event.preferredRoom) return 1;
+    }
+    return a.capacity - b.capacity;
+  });
+
+  let bestAssignment: Assignment | null = null;
+
+  for (const room of sortedRooms) {
+    const startTime = findSlotInRoom(
+      room.id,
+      event.duration,
+      earliest,
+      windowEnd,
+      gap,
+      roomSchedules,
+    );
+
+    if (startTime !== null) {
+      const assignment: Assignment = {
+        eventId: event.id,
+        roomId: room.id,
+        startTime,
+        endTime: startTime + event.duration,
+      };
+
+      // If this is the preferred room, use it immediately
+      if (event.preferredRoom && room.id === event.preferredRoom) {
+        return assignment;
+      }
+
+      // Otherwise keep the best (earliest start, smallest room)
+      if (!bestAssignment || startTime < bestAssignment.startTime) {
+        bestAssignment = assignment;
+      }
+    }
+  }
+
+  return bestAssignment;
+}
+
+/**
+ * Commit an assignment: update tracking data structures.
+ */
+function commitAssignment(
+  assignment: Assignment,
+  assigned: Map<string, Assignment>,
+  roomSchedules: Map<string, Assignment[]>,
+): void {
+  assigned.set(assignment.eventId, assignment);
+  if (!roomSchedules.has(assignment.roomId)) {
+    roomSchedules.set(assignment.roomId, []);
+  }
+  roomSchedules.get(assignment.roomId)!.push(assignment);
+}
+
+/**
+ * Remove an assignment from tracking data structures.
+ */
+function removeAssignment(
+  eventId: string,
+  assigned: Map<string, Assignment>,
+  roomSchedules: Map<string, Assignment[]>,
+): void {
+  const assignment = assigned.get(eventId);
+  if (!assignment) return;
+  assigned.delete(eventId);
+  const roomSched = roomSchedules.get(assignment.roomId);
+  if (roomSched) {
+    const idx = roomSched.findIndex(a => a.eventId === eventId);
+    if (idx !== -1) roomSched.splice(idx, 1);
+  }
+}
+
+/**
+ * Get all events that transitively depend on a given event (its descendants
+ * in the prerequisite DAG).
+ */
+function getDependents(
+  eventId: string,
+  dependentsMap: Map<string, Set<string>>,
+): Set<string> {
+  return dependentsMap.get(eventId) ?? new Set();
+}
+
+/**
+ * Build a map from each event to the set of events that directly depend on it.
+ */
+function buildDirectDependentsMap(events: Event[]): Map<string, Set<string>> {
+  const map = new Map<string, Set<string>>();
+  for (const e of events) {
+    if (!map.has(e.id)) map.set(e.id, new Set());
+  }
+  for (const e of events) {
+    if (e.prerequisites) {
+      for (const prereq of e.prerequisites) {
+        if (map.has(prereq)) {
+          map.get(prereq)!.add(e.id);
+        }
+      }
+    }
+  }
+  return map;
+}
+
+/**
+ * Build a map from each event to ALL events that transitively depend on it.
+ */
+function buildTransitiveDependentsMap(
+  events: Event[],
+  topoOrder: string[],
+): Map<string, Set<string>> {
+  const direct = buildDirectDependentsMap(events);
+  const transitive = new Map<string, Set<string>>();
+
+  // Process in reverse topological order so dependents are computed bottom-up
+  for (let i = topoOrder.length - 1; i >= 0; i--) {
+    const id = topoOrder[i];
+    const allDeps = new Set<string>();
+    for (const child of direct.get(id) ?? []) {
+      allDeps.add(child);
+      for (const grandchild of transitive.get(child) ?? []) {
+        allDeps.add(grandchild);
+      }
+    }
+    transitive.set(id, allDeps);
+  }
+
+  return transitive;
+}
+
+/**
+ * Main scheduling function. Uses a greedy approach with backtracking
+ * to maximize the number of scheduled events.
+ */
+export function schedule(
+  events: Event[],
+  rooms: Room[],
+  options: ScheduleOptions,
+): ScheduleResult {
+  if (events.length === 0) {
+    return { assignments: [], unscheduled: [] };
+  }
+
+  const gap = options.gap ?? DEFAULT_GAP;
+  const { startTime: windowStart, endTime: windowEnd } = options;
+
+  // Detect cycles and get topological order
+  const topoOrder = detectCyclesAndTopologicalSort(events);
+
+  const eventMap = new Map<string, Event>();
+  for (const e of events) {
+    eventMap.set(e.id, e);
+  }
+
+  const dependentsMap = buildTransitiveDependentsMap(events, topoOrder);
+
+  // Score each event: events with more dependents are more important to schedule
+  // because scheduling them enables more other events.
+  const eventScore = new Map<string, number>();
+  for (const e of events) {
+    const deps = getDependents(e.id, dependentsMap);
+    const attendees = e.attendees ?? 1;
+    // Prioritize: more dependents, then more attendees (proxy for importance)
+    eventScore.set(e.id, deps.size * 1000 + attendees);
+  }
+
+  // Sort topological order by score within each "level" while respecting
+  // prerequisite constraints. We'll use a priority-based topological sort.
+  const orderedEventIds = priorityTopoSort(events, eventScore);
+
+  // Greedy scheduling pass
+  const assigned = new Map<string, Assignment>();
+  const roomSchedules = new Map<string, Assignment[]>();
+  const unscheduled: string[] = [];
+
+  for (const eventId of orderedEventIds) {
+    const event = eventMap.get(eventId)!;
+
+    // Check if all prerequisites are assigned
+    let prereqsMet = true;
+    if (event.prerequisites) {
+      for (const prereq of event.prerequisites) {
+        if (eventMap.has(prereq) && !assigned.has(prereq)) {
+          prereqsMet = false;
+          break;
+        }
+      }
+    }
+
+    if (!prereqsMet) {
+      unscheduled.push(eventId);
+      continue;
+    }
+
+    const assignment = tryPlaceEvent(
+      event,
+      rooms,
+      gap,
+      windowStart,
+      windowEnd,
+      assigned,
+      roomSchedules,
+    );
+
+    if (assignment) {
+      commitAssignment(assignment, assigned, roomSchedules);
+    } else {
+      unscheduled.push(eventId);
+    }
+  }
+
+  // Improvement pass: try to reschedule unscheduled events by swapping
+  // with less impactful scheduled events.
+  improveSchedule(
+    unscheduled,
+    eventMap,
+    rooms,
+    gap,
+    windowStart,
+    windowEnd,
+    assigned,
+    roomSchedules,
+    dependentsMap,
+    eventScore,
+  );
+
+  return {
+    assignments: Array.from(assigned.values()),
+    unscheduled,
+  };
+}
+
+/**
+ * Priority-based topological sort. Processes events in topological order
+ * but when multiple events are available (in-degree 0), picks the one
+ * with the highest score first.
+ */
+function priorityTopoSort(
+  events: Event[],
+  scores: Map<string, number>,
+): string[] {
+  const eventIds = new Set(events.map(e => e.id));
+  const inDegree = new Map<string, number>();
+  const adjacency = new Map<string, string[]>();
+
+  for (const e of events) {
+    inDegree.set(e.id, 0);
+    adjacency.set(e.id, []);
+  }
+
+  for (const e of events) {
+    if (!e.prerequisites) continue;
+    for (const prereq of e.prerequisites) {
+      if (eventIds.has(prereq)) {
+        adjacency.get(prereq)!.push(e.id);
+        inDegree.set(e.id, (inDegree.get(e.id) ?? 0) + 1);
+      }
+    }
+  }
+
+  // Use a sorted list as a priority queue
+  const available: string[] = [];
+  for (const [id, deg] of inDegree) {
+    if (deg === 0) available.push(id);
+  }
+  available.sort((a, b) => (scores.get(b) ?? 0) - (scores.get(a) ?? 0));
+
+  const order: string[] = [];
+  while (available.length > 0) {
+    const node = available.shift()!;
+    order.push(node);
+    for (const neighbor of adjacency.get(node) ?? []) {
+      const newDeg = (inDegree.get(neighbor) ?? 1) - 1;
+      inDegree.set(neighbor, newDeg);
+      if (newDeg === 0) {
+        available.push(neighbor);
+        available.sort((a, b) => (scores.get(b) ?? 0) - (scores.get(a) ?? 0));
+      }
+    }
+  }
+
+  return order;
+}
+
+/**
+ * Snapshot the current state of assignments and room schedules so we can
+ * restore them if a speculative eviction doesn't work out.
+ */
+function snapshotState(
+  assigned: Map<string, Assignment>,
+  roomSchedules: Map<string, Assignment[]>,
+): { assigned: Map<string, Assignment>; roomSchedules: Map<string, Assignment[]> } {
+  const assignedCopy = new Map<string, Assignment>();
+  for (const [k, v] of assigned) assignedCopy.set(k, { ...v });
+  const roomCopy = new Map<string, Assignment[]>();
+  for (const [k, v] of roomSchedules) roomCopy.set(k, v.map(a => ({ ...a })));
+  return { assigned: assignedCopy, roomSchedules: roomCopy };
+}
+
+/**
+ * Restore state from a snapshot.
+ */
+function restoreState(
+  assigned: Map<string, Assignment>,
+  roomSchedules: Map<string, Assignment[]>,
+  snapshot: { assigned: Map<string, Assignment>; roomSchedules: Map<string, Assignment[]> },
+): void {
+  assigned.clear();
+  for (const [k, v] of snapshot.assigned) assigned.set(k, v);
+  roomSchedules.clear();
+  for (const [k, v] of snapshot.roomSchedules) roomSchedules.set(k, v);
+}
+
+/**
+ * Improvement pass: try to schedule unscheduled events by evicting
+ * less valuable scheduled events when doing so increases total scheduled count.
+ */
+function improveSchedule(
+  unscheduled: string[],
+  eventMap: Map<string, Event>,
+  rooms: Room[],
+  gap: number,
+  windowStart: number,
+  windowEnd: number,
+  assigned: Map<string, Assignment>,
+  roomSchedules: Map<string, Assignment[]>,
+  _dependentsMap: Map<string, Set<string>>,
+  _eventScore: Map<string, number>,
+): void {
+  let improved = true;
+  let iterations = 0;
+  const maxIterations = Math.min(unscheduled.length * 5, 200);
+
+  while (improved && iterations < maxIterations) {
+    improved = false;
+    iterations++;
+
+    for (let i = unscheduled.length - 1; i >= 0; i--) {
+      const eventId = unscheduled[i];
+      const event = eventMap.get(eventId)!;
+
+      // Check if all prerequisites are assigned
+      let prereqsMet = true;
+      if (event.prerequisites) {
+        for (const prereq of event.prerequisites) {
+          if (eventMap.has(prereq) && !assigned.has(prereq)) {
+            prereqsMet = false;
+            break;
+          }
+        }
+      }
+      if (!prereqsMet) continue;
+
+      // Try placing without eviction first
+      const placement = tryPlaceEvent(
+        event, rooms, gap, windowStart, windowEnd, assigned, roomSchedules,
+      );
+
+      if (placement) {
+        commitAssignment(placement, assigned, roomSchedules);
+        unscheduled.splice(i, 1);
+        improved = true;
+        continue;
+      }
+
+      // Try evicting a single scheduled event to make room
+      const scheduledEntries = Array.from(assigned.entries());
+      for (const [scheduledId] of scheduledEntries) {
+        // Don't evict a prerequisite of the event we're trying to place
+        if (event.prerequisites?.includes(scheduledId)) continue;
+
+        // Save state
+        const snapshot = snapshotState(assigned, roomSchedules);
+        // Evict the candidate
+        removeAssignment(scheduledId, assigned, roomSchedules);
+
+        // Try to place our event
+        const newPlacement = tryPlaceEvent(
+          event, rooms, gap, windowStart, windowEnd, assigned, roomSchedules,
+        );
+
+        if (newPlacement) {
+          commitAssignment(newPlacement, assigned, roomSchedules);
+
+          // Try to re-place the evicted event elsewhere
+          const evictedEvent = eventMap.get(scheduledId)!;
+          const rePlacement = tryPlaceEvent(
+            evictedEvent, rooms, gap, windowStart, windowEnd, assigned, roomSchedules,
+          );
+
+          if (rePlacement) {
+            // Both events fit - net gain of 1
+            commitAssignment(rePlacement, assigned, roomSchedules);
+            unscheduled.splice(i, 1);
+            improved = true;
+            break;
+          } else {
+            // Swap: we placed our event but evicted another - net gain 0
+            // Only do this if the unscheduled event has higher score
+            // For now, accept swaps that don't reduce count
+            unscheduled.splice(i, 1);
+            unscheduled.push(scheduledId);
+            // No net gain, but might enable further improvements
+            // Don't set improved=true to avoid infinite loops on pure swaps
+            break;
+          }
+        } else {
+          // Couldn't place even after eviction - restore
+          restoreState(assigned, roomSchedules, snapshot);
+        }
+      }
+    }
+  }
+}
