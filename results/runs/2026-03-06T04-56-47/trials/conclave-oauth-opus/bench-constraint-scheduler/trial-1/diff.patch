 assignment: Assignment = {\n        eventId,\n        roomId: bestPlacement.roomId,\n        startTime: bestPlacement.start,\n        endTime: bestPlacement.start + event.duration,\n      };\n      assignments.push(assignment);\n      assignmentMap.set(eventId, assignment);\n\n      const roomList = roomSchedules.get(bestPlacement.roomId)!;\n      roomList.push(assignment);\n      roomList.sort((a, b) => a.startTime - b.startTime);\n    } else {\n      unscheduled.push(eventId);\n    }\n  }\n\n  return { assignments, unscheduled };\n}\n\nfunction findEarliestSlot(\n  roomAssignments: Assignment[],\n  earliestStart: number,\n  duration: number,\n  gap: number,\n  endTime: number,\n): number | null {\n  let candidate = earliestStart;\n\n  for (const existing of roomAssignments) {\n    // Can we fit before this existing event (with gap after our event)?\n    if (candidate + duration + gap <= existing.startTime) {\n      break;\n    }\n    // Move past this existing event (with gap after it)\n    candidate = Math.max(candidate, existing.endTime + gap);\n  }\n\n  if (candidate + duration <= endTime) {\n    return candidate;\n  }\n  return null;\n}\n\nfunction detectCyclesAndTopologicalSort(events: Event[]): string[] {\n  const eventMap = new Map<string, Event>();\n  for (const event of events) {\n    eventMap.set(event.id, event);\n  }\n\n  const WHITE = 0, GRAY = 1, BLACK = 2;\n  const color = new Map<string, number>();\n  const order: string[] = [];\n\n  for (const event of events) {\n    color.set(event.id, WHITE);\n  }\n\n  function dfs(id: string): void {\n    color.set(id, GRAY);\n    const event = eventMap.get(id);\n    if (event?.prerequisites) {\n      for (const prereqId of event.prerequisites) {\n        const prereqColor = color.get(prereqId);\n        if (prereqColor === GRAY) {\n          throw new Error(`Prerequisite cycle detected involving event '${prereqId}'`);\n        }\n        if (prereqColor === WHITE) {\n          dfs(prereqId);\n        }\n      }\n    }\n    color.set(id, BLACK);\n    order.push(id);\n  }\n\n  for (const event of events) {\n    if (color.get(event.id) === WHITE) {\n      dfs(event.id);\n    }\n  }\n\n  return order;\n}\n\nfunction sortByDurationAsc(topoOrder: string[], eventMap: Map<string, Event>): string[] {\n  // Compute topological level for each event\n  const levels = computeTopoLevels(topoOrder, eventMap);\n\n  return [...topoOrder].sort((a, b) => {\n    const levelDiff = levels.get(a)! - levels.get(b)!;\n    if (levelDiff !== 0) return levelDiff;\n    return (eventMap.get(a)!.duration) - (eventMap.get(b)!.duration);\n  });\n}\n\nfunction sortByConstraintDifficulty(\n  topoOrder: string[],\n  eventMap: Map<string, Event>,\n  rooms: Room[],\n): string[] {\n  const levels = computeTopoLevels(topoOrder, eventMap);\n\n  return [...topoOrder].sort((a, b) => {\n    const levelDiff = levels.get(a)! - levels.get(b)!;\n    if (levelDiff !== 0) return levelDiff;\n\n    const eventA = eventMap.get(a)!;\n    const eventB = eventMap.get(b)!;\n\n    // More constrained events first (fewer eligible rooms, more attendees, longer duration)\n    const eligibleA = rooms.filter(r => r.capacity >= (eventA.attendees ?? 1)).length;\n    const eligibleB = rooms.filter(r => r.capacity >= (eventB.attendees ?? 1)).length;\n    if (eligibleA !== eligibleB) return eligibleA - eligibleB;\n\n    return eventB.duration - eventA.duration; // longer first within same constraint level\n  });\n}\n\nfunction computeTopoLevels(topoOrder: string[], eventMap: Map<string, Event>): Map<string, number> {\n  const levels = new Map<string, number>();\n\n  for (const id of topoOrder) {\n    const event = eventMap.get(id)!;\n    let level = 0;\n    if (event.prerequisites) {\n      for (const prereqId of event.prerequisites) {\n        const prereqLevel = levels.get(prereqId);\n        if (prereqLevel !== undefined) {\n          level = Math.max(level, prereqLevel + 1);\n        }\n      }\n    }\n    levels.set(id, level);\n  }\n\n  return levels;\n}\n","structuredPatch":[],"originalFile":null}}
