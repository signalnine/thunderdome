te end + gap <= existing start? No, we need:\n   427→      // candidate + duration <= existing.startTime (with gap already accounted)\n   428→      // Actually: candidate + duration + gap <= existing.startTime + gap\n   429→      // The gap is between END of one event and START of next\n   430→      if (candidate + duration + gap <= existing.startTime + gap &&\n   431→          candidate + duration <= endTime) {\n   432→        // Wait, simplify: we need candidate+duration <= existing.startTime - gap? No.\n   433→        // Gap means: end of event A ... gap ... start of event B\n   434→        // So if our event ends at candidate+duration, next event starts at existing.startTime\n   435→        // Need: candidate + duration + gap <= existing.startTime + gap => candidate + duration <= existing.startTime\n   436→        // Actually just: candidate + duration <= existing.startTime - 0?\n   437→        // NO. Gap between events in same room: end of one + gap <= start of next\n   438→        // So: candidate + duration + gap <= existing.startTime\n   439→        // OR: existing.endTime + gap <= candidate\n   440→      }\n   441→    }\n   442→    // Simplified: try to fit before this event\n   443→    if (candidate + duration + gap <= existing.startTime + gap) {\n   444→      break; // candidate fits before this event\n   445→    }\n   446→    // Move candidate past this event + gap\n   447→    candidate = Math.max(candidate, existing.endTime + gap);\n   448→  }\n   449→\n   450→  if (candidate + duration <= endTime) {\n   451→    return candidate;\n   452→  }\n   453→  return null;\n   454→}\n   455→```\n   456→\n   457→**IMPORTANT:** The above `findEarliestSlot` has confused logic. Here is the correct version:\n   458→\n   459→```typescript\n   460→function findEarliestSlot(\n   461→  roomAssignments: Assignment[],\n   462→  earliestStart: number,\n   463→  duration: number,\n   464→  gap: number,\n   465→  endTime: number\n   466→): number | null {\n   467→  let candidate = earliestStart;\n   468→\n   469→  for (const existing of roomAssignments) {\n   470→    if (candidate + duration + gap <= existing.startTime + gap) {\n   471→      // candidate + duration <= existing.startTime means we fit before this event\n   472→      // (no gap needed before the first event in a slot, gap is between events)\n   473→      // Actually: we DO need gap between our event end and existing start:\n   474→      // candidate + duration + gap <= existing.startTime + gap is wrong\n   475→      // Correct: candidate + duration + gap <= existing.startTime + gap simplifies to\n   476→      // candidate + duration <= existing.startTime — NO, gap is BETWEEN events\n   477→      // If our event ends at (candidate + duration), next starts at existing.startTime:\n   478→      // (candidate + duration) + gap <= existing.startTime\n   479→      break;\n   480→    }\n   481→    candidate = Math.max(candidate, existing.endTime + gap);\n   482→  }\n   483→\n   484→  if (candidate + duration <= endTime) {\n   485→    return candidate;\n   486→  }\n   487→  return null;\n   488→}\n   489→```\n   490→\n   491→**FINAL correct `findEarliestSlot`:**\n   492→\n   493→```typescript\n   494→function findEarliestSlot(\n   495→  roomAssignments: Assignment[],\n   496→  earliestStart: number,\n   497→  duration: number,\n   498→  gap: number,\n   499→  endTime: number\n   500→): number | null {\n   501→  let candidate = earliestStart;\n   502→\n   503→  for (const existing of roomAssignments) {\n   504→    // Can we fit before this existing event (with gap)?\n   505→    if (candidate + duration + gap <= existing.startTime) {\n   506→      break;\n   507→    }\n   508→    // Move past this existing event (with gap after it)\n   509→    candidate = Math.max(candidate, existing.endTime + gap);\n   510→  }\n   511→\n   512→  if (candidate + duration <= endTime) {\n   513→    return candidate;\n   514→  }\n   515→  return null;\n   516→}\n   517→```\n   518→\n   519→Note: The gap between events in the same room means: `eventA.endTime + gap <= eventB.startTime`. So when checking if we fit before an existing event: `candidate + duration + gap <= existing.startTime`. When skipping past: `candidate = existing.endTime + gap`.\n   520→\n   521→**Step 4: Run tests to verify they pass**\n   522→\n   523→Run: `npx vitest run`\n   524→Expected: ALL tests PASS\n   525→\n   526→**Step 5: Commit**\n   527→\n   528→```bash\n   529→git add src/scheduler.ts src/__tests__/scheduler.test.ts\n   530→git commit -m \"feat: implement core greedy scheduling with capacity and time window checks\"\n   531→```\n   532→\n   533→---\n   534→\n   535→### Task 4: Gap Enforcement and Prerequisite Ordering Tests\n   536→\n   537→**Files:**\n   538→- Modify: `src/__tests__/scheduler.test.ts`\n   539→- Possibly modify: `src/scheduler.ts`\n   540→\n   541→**Dependencies:** Task 3\n   542→\n   543→**Step 1: Write failing tests for gaps and prerequisites**\n   544→\n   545→Add to test file:\n   546→\n   547→```typescript\n   548→describe('gap enforcement', () => {\n   549→  it('enforces default 15-minute gap between events in same room', () => {\n   550→    const events: Event[] = [\n   551→      { id: 'a', name: 'A', duration: 60 },\n   552→      { id: 'b', name: 'B', duration: 60 },\n   553→    ];\n   554→    const rooms: Room[] = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n   555→    const result = schedule(events, rooms, defaultOptions);\n   556→    expect(result.assignments).toHaveLength(2);\n   557→    const a = result.assignments.find(x => x.eventId === 'a')!;\n   558→    const b = result.assignments.find(x => x.eventId === 'b')!;\n   559→    // Second event should start at least 15 min after first ends\n   560→    const first = a.startTime < b.startTime ? a : b;\n   561→    const second = a.startTime < b.startTime ? b : a;\n   562→    expect(second.startTime).toBeGreaterThanOrEqual(first.endTime + 15);\n   563→  });\n   564→\n   565→  it('uses custom gap when specified', () => {\n   566→    const events: Event[] = [\n   567→      { id: 'a', name: 'A', duration: 60 },\n   568→      { id: 'b', name: 'B', duration: 60 },\n   569→    ];\n   570→    const rooms: Room[] = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n   571→    const opts: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 30 };\n   572→    const result = schedule(events, rooms, opts);\n   573→    expect(result.assignments).toHaveLength(2);\n   574→    const a = result.assignments.find(x => x.eventId === 'a')!;\n   575→    const b = result.assignments.find(x => x.eventId === 'b')!;\n   576→    const first = a.startTime < b.startTime ? a : b;\n   577→    const second = a.startTime < b.startTime ? b : a;\n   578→    expect(second.startTime).toBeGreaterThanOrEqual(first.endTime + 30);\n   579→  });\n   580→\n   581→  it('allows zero gap', () => {\n   582→    const events: Event[] = [\n   583→      { id: 'a', name: 'A', duration: 60 },\n   584→      { id: 'b', name: 'B', duration: 60 },\n   585→    ];\n   586→    const rooms: Room[] = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n   587→    const opts: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 0 };\n   588→    const result = schedule(events, rooms, opts);\n   589→    expect(result.assignments).toHaveLength(2);\n   590→    const a = result.assignments.find(x => x.eventId === 'a')!;\n   591→    const b = result.assignments.find(x => x.eventId === 'b')!;\n   592→    const first = a.startTime < b.startTime ? a : b;\n   593→    const second = a.startTime < b.startTime ? b : a;\n   594→    expect(second.startTime).toBeGreaterThanOrEqual(first.endTime);\n   595→  });\n   596→});\n   597→\n   598→describe('prerequisite ordering', () => {\n   599→  it('schedules prerequisite before dependent event', () => {\n   600→    const events: Event[] = [\n   601→      { id: 'b', name: 'B', duration: 60, prerequisites: ['a'] },\n   602→      { id: 'a', name: 'A', duration: 60 },\n   603→    ];\n   604→    const result = schedule(events, defaultRooms, defaultOptions);\n   605→    expect(result.assignments).toHaveLength(2);\n   606→    const a = result.assignments.find(x => x.eventId === 'a')!;\n   607→    const b = result.assignments.find(x => x.eventId === 'b')!;\n   608→    expect(b.startTime).toBeGreaterThanOrEqual(a.endTime + 15);\n   609→  });\n   610→\n   611→  it('respects chain of prerequisites', () => {\n   612→    const events: Event[] = [\n   613→      { id: 'c', name: 'C', duration: 30, prerequisites: ['b'] },\n   614→      { id: 'b', name: 'B', duration: 30, prerequisites: ['a'] },\n   615→      { id: 'a', name: 'A', duration: 30 },\n   616→    ];\n   617→    const result = schedule(events, defaultRooms, defaultOptions);\n   618→    expect(result.assignments).toHaveLength(3);\n   619→    const a = result.assignments.find(x => x.eventId === 'a')!;\n   620→    const b = result.assignments.find(x => x.eventId === 'b')!;\n   621→    const c = result.assignments.find(x => x.eventId === 'c')!;\n   622→    expect(b.startTime).toBeGreaterThanOrEqual(a.endTime + 15);\n   623→    expect(c.startTime).toBeGreaterThanOrEqual(b.endTime + 15);\n   624→  });\n   625→});\n   626→```\n   627→\n   628→**Step 2: Run tests**\n   629→\n   630→Run: `npx vitest run`\n   631→Expected: Should PASS if core logic is correct. If any fail, fix the scheduler.\n   632→\n   633→**Step 3: Commit**\n   634→\n   635→```bash\n   636→git add src/__tests__/scheduler.test.ts\n   637→git commit -m \"test: add gap enforcement and prerequisite ordering tests\"\n   638→```\n   639→\n   640→---\n   641→\n   642→### Task 5: Preferred Room Tests\n   643→\n   644→**Files:**\n   645→- Modify: `src/__tests__/scheduler.test.ts`\n   646→\n   647→**Dependencies:** Task 3\n   648→\n   649→**Step 1: Write tests for preferred room behavior**\n   650→\n   651→```typescript\n   652→describe('preferred room', () => {\n   653→  it('honors preferred room when possible', () => {\n   654→    const events: Event[] = [\n   655→    