ap<string, Event>();\n   324→  for (const event of events) {\n   325→    eventMap.set(event.id, event);\n   326→  }\n   327→\n   328→  // Room schedules: roomId -> sorted list of assignments\n   329→  const roomSchedules = new Map<string, Assignment[]>();\n   330→  for (const room of rooms) {\n   331→    roomSchedules.set(room.id, []);\n   332→  }\n   333→\n   334→  // Track assignments by event ID for prerequisite lookups\n   335→  const assignmentMap = new Map<string, Assignment>();\n   336→  const assignments: Assignment[] = [];\n   337→  const unscheduled: string[] = [];\n   338→\n   339→  // Schedule in topological order\n   340→  for (const eventId of topoOrder) {\n   341→    const event = eventMap.get(eventId)!;\n   342→    const attendees = event.attendees ?? 1;\n   343→\n   344→    // Find earliest start based on prerequisites\n   345→    let earliestStart = options.startTime;\n   346→    let prereqsMet = true;\n   347→    if (event.prerequisites) {\n   348→      for (const prereqId of event.prerequisites) {\n   349→        const prereqAssignment = assignmentMap.get(prereqId);\n   350→        if (!prereqAssignment) {\n   351→          // Prerequisite not scheduled (or doesn't exist) — can't schedule this event\n   352→          prereqsMet = false;\n   353→          break;\n   354→        }\n   355→        earliestStart = Math.max(earliestStart, prereqAssignment.endTime + gap);\n   356→      }\n   357→    }\n   358→\n   359→    if (!prereqsMet) {\n   360→      unscheduled.push(eventId);\n   361→      continue;\n   362→    }\n   363→\n   364→    // Find eligible rooms sorted: preferred first, then by capacity ascending\n   365→    const eligibleRooms = rooms\n   366→      .filter(r => r.capacity >= attendees)\n   367→      .sort((a, b) => {\n   368→        if (event.preferredRoom) {\n   369→          if (a.id === event.preferredRoom && b.id !== event.preferredRoom) return -1;\n   370→          if (b.id === event.preferredRoom && a.id !== event.preferredRoom) 