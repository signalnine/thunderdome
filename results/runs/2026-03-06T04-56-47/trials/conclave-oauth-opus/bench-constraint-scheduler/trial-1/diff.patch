;\n}\n\nexport { schedule } from './scheduler.js';\n```\n\n**Step 2: Create `src/scheduler.ts` with stub `schedule` function**\n\n```typescript\nimport type { Event, Room, ScheduleOptions, ScheduleResult } from './index.js';\n\nexport function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {\n  return { assignments: [], unscheduled: events.map(e => e.id) };\n}\n```\n\n**Step 3: Verify build compiles**\n\nRun: `npm run build`\nExpected: SUCCESS, no errors\n\n**Step 4: Verify lint passes**\n\nRun: `npm run lint`\nExpected: SUCCESS, no errors\n\n**Step 5: Commit**\n\n```bash\ngit add src/index.ts src/scheduler.ts\ngit commit -m \"feat: add type definitions and schedule function stub\"\n```\n\n---\n\n### Task 2: Cycle Detection and Topological Sort\n\n**Files:**\n- Modify: `src/scheduler.ts`\n- Create: `src/__tests__/scheduler.test.ts`\n\n**Dependencies:** Task 1\n\n**Step 1: Write failing tests for cycle detection**\n\nCreate `src/__tests__/scheduler.test.ts`:\n\n```typescript\nimport { describe, it, expect } from 'vitest';\nimport { schedule } from '../index.js';\nimport type { Event, Room, ScheduleOptions } from '../index.js';\n\nconst defaultRooms: Room[] = [\n  { id: 'r1', name: 'Room 1', capacity: 10 },\n];\n\nconst defaultOptions: ScheduleOptions = {\n  startTime: 540,  // 9:00 AM\n  endTime: 1020,   // 5:00 PM\n};\n\ndescribe('cycle detection', () => {\n  it('throws on self-referencing prerequisite', () => {\n    const events: Event[] = [\n      { id: 'a', name: 'A', duration: 60, prerequisites: ['a'] },\n    ];\n    expect(() => schedule(events, defaultRooms, defaultOptions)).toThrow();\n  });\n\n  it('throws on direct cycle between two events', () => {\n    const events: Event[] = [\n      { id: 'a', name: 'A', duration: 60, prerequisites: ['b'] },\n      { id: 'b', name: 'B', duration: 60, prerequisites: ['a'] },\n    ];\n    expect(() => schedule(events, defaultRooms, defaultOptions)).toThrow();\n  });\n\n  it('throws on indirect cycle among three events', () => {\n    const events: Event[] = [\n      { id: 'a', name: 'A', duration: 30, prerequisites: ['c'] },\n      { id: 'b', name: 'B', duration: 30, prerequisites: ['a'] },\n      { id: 'c', name: 'C', duration: 30, prerequisites: ['b'] },\n    ];\n    expect(() => schedule(events, defaultRooms, defaultOptions)).toThrow();\n  });\n\n  it('does not throw when prerequisites are acyclic', () => {\n    const events: Event[] = [\n      { id: 'a', name: 'A', duration: 30 },\n      { id: 'b', name: 'B', duration: 30, prerequisites: ['a'] },\n      { id: 'c', name: 'C', duration: 30, prerequisites: ['a', 'b'] },\n    ];\n    expect(() => schedule(events, defaultRooms, defaultOptions)).not.toThrow();\n  });\n});\n```\n\n**Step 2: Run tests to verify they fail**\n\nRun: `npx vitest run`\nExpected: 3 tests FAIL (self-ref, direct cycle, indirect cycle don't throw), 1 PASS (acyclic doesn't throw because stub doesn't throw)\n\n**Step 3: Implement cycle detection and topological sort in `scheduler.ts`**\n\nAdd to `scheduler.ts` before the `schedule` function:\n\n```typescript\nfunction detectCyclesAndTopologicalSort(events: Event[]): string[] {\n  const eventMap = new Map<string, Event>();\n  for (const event of events) {\n    eventMap.set(event.id, event);\n  }\n\n  const WHITE = 0, GRAY = 1, BLACK = 2;\n  const color = new Map<string, number>();\n  const order: string[] = [];\n\n  for (const event of events) {\n    color.set(event.id, WHITE);\n  }\n\n  function dfs(id: string): void {\n    color.set(id, GRAY);\n    const event = eventMap.get(id);\n    if (event?.prerequisites) {\n      for (const prereqId of event.prerequisites) {\n        const prereqColor = color.get(prereqId);\n        if (prereqColor === GRAY) {\n          throw new Error(`Prerequisite cycle detected involving event '${prereqId}'`);\n        }\n        if (prereqColor === WHITE) {\n          dfs(prereqId);\n        }\n        // If prereqColor is undefined (prereq not in events list), skip —\n        // it will be handled as unresolvable prerequisite during scheduling\n      }\n    }\n    color.set(id, BLACK);\n    order.push(id);\n  }\n\n  for (const event of events) {\n    if (color.get(event.id) === WHITE) {\n      dfs(event.id);\n    }\n  }\n\n  return order;\n}\n```\n\nUpdate the `schedule` function to call it:\n\n```typescript\nexport function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {\n  if (events.length === 0) {\n    return { assignments: [], unscheduled: [] };\n  }\n\n  const topoOrder = detectCyclesAndTopologicalSort(events);\n\n  return { assignments: [], unscheduled: events.map(e => e.id) };\n}\n```\n\n**Step 4: Run tests to verify they pass**\n\nRun: `npx vitest run`\nExpected: ALL 4 tests PASS\n\n**Step 5: Commit**\n\n```bash\ngit add src/scheduler.ts src/__tests__/scheduler.test.ts\ngit commit -m \"feat: add cycle detection and topological sort\"\n```\n\n---\n\n### Task 3: Basic Scheduling — Single Event, Capacity, Time Window\n\n**Files:**\n- Modify: `src/scheduler.ts`\n- Modify: `src/__tests__/scheduler.test.ts`\n\n**Dependencies:** Task 2\n\n**Step 1: Write failing tests for basic scheduling**\n\nAdd to test file:\n\n```typescript\ndescribe('basic scheduling', () => {\n  it('schedules a single event in a single room', () => {\n    const events: Event[] = [\n      { id: 'a', name: 'A', duration: 60 },\n    ];\n    const result = schedule(events, defaultRooms, defaultOptions);\n    expect(result.assignments).toHaveLength(1);\n    expect(result.unscheduled).toHaveLength(0);\n    expect(result.assignments[0].eventId).toBe('a');\n    expect(result.assignments[0].roomId).toBe('r1');\n    expect(result.assignments[0].startTime).toBe(540);\n    expect(result.assignments[0].endTime).toBe(600);\n  });\n\n  it('returns empty results for empty events', () => {\n    const result = schedule([], defaultRooms, defaultOptions);\n    expect(result.assignments).toHaveLength(0);\n    expect(result.unscheduled).toHaveLength(0);\n  });\n\n  it('puts all events in unscheduled when no rooms provided', () => {\n    const events: Event[] = [\n      { id: 'a', name: 'A', duration: 60 },\n    ];\n    const result = schedule(events, [], defaultOptions);\n    expect(result.assignments).toHaveLength(0);\n    expect(result.unscheduled).toEqual(['a']);\n  });\n\n  it('defaults attendees to 1', () => {\n    const events: Event[] = [\n      { id: 'a', name: 'A', duration: 60 },\n    ];\n    const rooms: Room[] = [{ id: 'r1', name: 'Room 1', capacity: 1 }];\n    const result = schedule(events, rooms, defaultOptions);\n    expect(result.assignments).toHaveLength(1);\n  });\n\n  it('rejects event when attendees exceed room capacity', () => {\n    const events: Event[] = [\n      { id: 'a', name: 'A', duration: 60, attendees: 20 },\n    ];\n    const rooms: Room[] = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n    const result = schedule(events, rooms, defaultOptions);\n    expect(result.assignments).toHaveLength(0);\n    expect(result.unscheduled).toEqual(['a']);\n  });\n\n  it('rejects event that does not fit within time window', () => {\n    const events: Event[] = [\n      { id: 'a', name: 'A', duration: 600 },\n    ];\n    // 9:00-5:00 = 480 minutes, event needs 600\n    const result = schedule(events, defaultRooms, defaultOptions);\n    expect(result.assignments).toHaveLength(0);\n    expect(result.unscheduled).toEqual(['a']);\n  });\n});\n```\n\n**Step 2: Run tests to verify they fail**\n\nRun: `npx vitest run`\nExpected: New basic scheduling tests FAIL (stub returns all as unscheduled)\n\n**Step 3: Implement core greedy scheduling in `scheduler.ts`**\n\nReplace the schedule function body with full greedy scheduling logic:\n\n```typescript\nexport function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {\n  if (events.length === 0) {\n    return { assignments: [], unscheduled: [] };\n  }\n\n  const gap = options.gap ?? 15;\n  const topoOrder = detectCyclesAndTopologicalSort(events);\n  const eventMap = new Map<string, Event>();\n  for (const event of events) {\n    eventMap.set(event.id, event);\n  }\n\n  // Room schedules: roomId -> sorted list of assignments\n  const roomSchedules = new Map<string, Assignment[]>();\n  for (const room of rooms) {\n    roomSchedules.set(room.id, []);\n  }\n\n  // Track assignments by event ID for prerequisite lookups\n  const assignmentMap = new Map<string, Assignment>();\n  const assignments: Assignment[] = [];\n  const unscheduled: string[] = [];\n\n  // Schedule in topological order\n  for (const eventId of topoOrder) {\n    const event = eventMap.get(eventId)!;\n    const attendees = event.attendees ?? 1;\n\n    // Find earliest start based on prerequisites\n    let earliestStart = options.startTime;\n    let prereqsMet = true;\n    if (event.prerequisites) {\n      for (const prereqId of event.prerequisites) {\n        const prereqAssignment = assignmentMap.get(prereqId);\n        if (!prereqAssignment) {\n          // Prerequisite not scheduled (or doesn't exist) — can't schedule this event\n          prereqsMet = false;\n          break;\n        }\n        earliestStart = Math.max(earliestStart, prereqAssignment.endTime + gap);\n      }\n    }\n\n    if (!prereqsMet) {\n      unscheduled.push(eventId);\n      continue;\n    }\n\n    // Find eligible rooms sorted: preferred first, then by capacity ascending\n    const eligibleRooms = rooms\n      .filter(r => r.capacity >= attendees)\n      .sort((a, b) => {\n        if (event.preferredRoom) {\n          if (a.id === event.preferredRoom && b.id !== event.preferredRoom) return -1;\n          if (b.id === event.preferredRoom && a.id !== event.preferredRoom) return 1;\n        }\n        return a.capacity - b.capacity;\n      });\n\n    let bestPlacement: { roomId: string; start: number } | null = null;\n\n    for (const room of eligibleRooms) {\n      const start = findEarliestSlot(\n        roomSchedules.get(room.id)!,\n        earliestStart,\n        event.duration,\n        gap,\n        options.endTime\n      );\n      if (start !== null) {\n        if (bestPlacement === null || start < bestPlacement.start ||\n            (start === bestPlacement.start && room.id === event.preferredRoom)) {\n          bestPlacement = { roomId: room.id, start };\n        }\n      }\n    }\n\n    if (bestPlacement) {\n      const assignment: Assignment = {\n        eventId,\n        roomId: bestPlacement.roomId,\n        startTime: bestPlacement.start,\n        endTime: bestPlacement.start + event.duration,\n      };\n      assignments.push(assignment);\n      assignmentMap.set(eventId, assignment);\n\n      const roomList = roomSchedules.get(bestPlacement.roomId)!;\n      roomList.push(assignment);\n      roomList.sort((a, b) => a.startTime - b.startTime);\n    } else {\n      unscheduled.push(eventId);\n    }\n  }\n\n  return { assignments, unscheduled };\n}\n\nfunction findEarliestSlot(\n  roomAssignments: Assignment[],\n  earliestStart: number,\n  duration: number,\n  gap: number,\n  endTime: number\n): number | null {\n  let candidate = earliestStart;\n\n  for (const existing of roomAssignments) {\n    // If candidate slot fits before this existing event\n    if (candidate + duration <= existing.startTime - gap + gap) {\n      // Check: candidate end + gap <= existing start? No, we need:\n      // candidate + duration <= existing.startTime (with gap already accounted)\n      // Actually: candidate + duration + gap <= existing.startTime + gap\n      // The gap is between END of one event and START of next\n      if (candidate + duration + gap <= existing.startTime + gap &&\n          candidate + duration <= endTime) {\n        // Wait, simplify: we need candidate+duration <= existing.startTime - gap? No.\n        // Gap means: end of event A ... gap ... start of event B\n        // So if our event ends at candidate+duration, next event starts at existing.startTime\n        // Need: candidate + duration + gap <= existing.startTime + gap => candidate + duration <= existing.startTime\n        // Actually just: candidate + duration <= existing.startTime - 0?\n        // NO. Gap between events in same room: end of one + gap <= start of next\n        // So: candidate + duration + gap <= existing.startTime\n        // OR: existing.endTime + gap <= candidate\n      }\n    }\n    // Simplified: try to fit before this event\n    if (candidate + duration + gap <= existing.startTime + gap) {\n      break; // candidate fits before this event\n    }\n    // Move candidate past this event + gap\n    candidate = Math.max(candidate, existing.endTime + gap);\n  }\n\n  if (candidate + duration <= endTime) {\n    return candidate;\n  }\n  return null;\n}\n```\n\n**IMPORTANT:** The above `findEarliestSlot` has confused logic. Here is the correct version:\n\n```typescript\nfunction findEarliestSlot(\n  roomAssignments: Assignment[],\n  earliestStart: number,\n  duration: number,\n  gap: number,\n  endTime: number\n): number | null {\n  let candidate = earliestStart;\n\n  for (const existing of roomAssignments) {\n    if (candidate + duration + gap <= existing.startTime + gap) {\n      // candidate + duration <= existing.startTime means we fit before this event\n      // (no gap needed before the first event in a slot, gap is between events)\n      // Actually: we DO need gap between our event end and existing start:\n      // candidate + duration + gap <= existing.startTime + gap is wrong\n      // Correct: candidate + duration + gap <= existing.startTime + gap simplifies to\n      // candidate + duration <= existing.startTime — NO, gap is BETWEEN events\n      // If our event ends at (candidate + duration), next starts at existing.startTime:\n      // (candidate + duration) + gap <= existing.startTime\n      break;\n    }\n    candidate = Math.max(candidate, existing.endTime + gap);\n  }\n\n  if (candidate + duration <= endTime) {\n    return candidate;\n  }\n  return null;\n}\n```\n\n**FINAL correct `findEarliestSlot`:**\n\n```typescript\nfunction findEarliestSlot(\n  roomAssignments: Assignment[],\n  earliestStart: number,\n  duration: number,\n  gap: number,\n  endTime: number\n): number | null {\n  let candidate = earliestStart;\n\n  for (const existing of roomAssignments) {\n    // Can we fit before this existing event (with gap)?\n    if (candidate + duration + gap <= existing.startTime) {\n      break;\n    }\n    // Move past this existing event (with gap after it)\n    candidate = Math.max(candidate, existing.endTime + gap);\n  }\n\n  if (candidate + duration <= endTime) {\n    return candidate;\n  }\n  return null;\n}\n```\n\nNote: The gap between events in the same room means: `eventA.endTime + gap <= eventB.startTime`. So when checking if we fit before an existing event: `candidate + duration + gap <= existing.startTime`. When skipping past: `candidate = existing.endTime + gap`.\n\n**Step 4: Run tests to verify they pass**\n\nRun: `npx vitest run`\nExpected: ALL tests PASS\n\n**Step 5: Commit**\n\n```bash\ngit add src/scheduler.ts src/__tests__/scheduler.test.ts\ngit commit -m \"feat: implement core greedy scheduling with capacity and time window checks\"\n```\n\n---\n\n### Task 4: Gap Enforcement and Prerequisite Ordering Tests\n\n**Files:**\n- Modify: `src/__tests__/scheduler.test.ts`\n- Possibly modify: `src/scheduler.ts`\n\n**Dependencies:** Task 3\n\n**Step 1: Write failing tests for gaps and prerequisites**\n\nAdd to test file:\n\n```typescript\ndescribe('gap enforcement', () => {\n  it('enforces default 15-minute gap between events in same room', () => {\n    const events: Event[] = [\n      { id: 'a', name: 'A', duration: 60 },\n      { id: 'b', name: 'B', duration: 60 },\n    ];\n    const rooms: Room[] = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n    const result = schedule(events, rooms, defaultOptions);\n    expect(result.assignments).toHaveLength(2);\n    const a = result.assignments.find(x => x.eventId === 'a')!;\n    const b = result.assignments.find(x => x.eventId === 'b')!;\n    // Second event should start at least 15 min after first ends\n    const first = a.startTime < b.startTime ? a : b;\n    const second = a.startTime < b.startTime ? b : a;\n    expect(second.startTime).toBeGreaterThanOrEqual(first.endTime + 15);\n  });\n\n  it('uses custom gap when specified', () => {\n    const events: Event[] = [\n      { id: 'a', name: 'A', duration: 60 },\n      { id: 'b', name: 'B', duration: 60 },\n    ];\n    const rooms: Room[] = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n    const opts: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 30 };\n    const result = schedule(events, rooms, opts);\n    expect(result.assignments).toHaveLength(2);\n    const a = result.assignments.find(x => x.eventId === 'a')!;\n    const b = result.assignments.find(x => x.eventId === 'b')!;\n    const first = a.startTime < b.startTime ? a : b;\n    const second = a.startTime < b.startTime ? b : a;\n    expect(second.startTime).toBeGreaterThanOrEqual(first.endTime + 30);\n  });\n\n  it('allows zero gap', () => {\n    const events: Event[] = [\n      { id: 'a', name: 'A', duration: 60 },\n      { id: 'b', name: 'B', duration: 60 },\n    ];\n    const rooms: Room[] = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n    const opts: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 0 };\n    const result = schedule(events, rooms, opts);\n    expect(result.assignments).toHaveLength(2);\n    const a = result.assignments.find(x => x.eventId === 'a')!;\n    const b = result.assignments.find(x => x.eventId === 'b')!;\n    const first = a.startTime < b.startTime ? a : b;\n    const second = a.startTime < b.startTime ? b : a;\n    expect(second.startTime).toBeGreaterThanOrEqual(first.endTime);\n  });\n});\n\ndescribe('prerequisite ordering', () => {\n  it('schedules prerequisite before dependent event', () => {\n    const events: Event[] = [\n      { id: 'b', name: 'B', duration: 60, prerequisites: ['a'] },\n      { id: 'a', name: 'A', duration: 60 },\n    ];\n    const result = schedule(events, defaultRooms, defaultOptions);\n    expect(result.assignments).toHaveLength(2);\n    const a = result.assignments.find(x => x.eventId === 'a')!;\n    const b = result.assignments.find(x => x.eventId === 'b')!;\n    expect(b.startTime).toBeGreaterThanOrEqual(a.endTime + 15);\n  });\n\n  it('respects chain of prerequisites', () => {\n    const events: Event[] = [\n      { id: 'c', name: 'C', duration: 30, prerequisites: ['b'] },\n      { id: 'b', name: 'B', duration: 30, prerequisites: ['a'] },\n      { id: 'a', name: 'A', duration: 30 },\n    ];\n    const result = schedule(events, defaultRooms, defaultOptions);\n    expect(result.assignments).toHaveLength(3);\n    const a = result.assignments.find(x => x.eventId === 'a')!;\n    const b = result.assignments.find(x => x.eventId === 'b')!;\n    const c = result.assignments.find(x => x.eventId === 'c')!;\n    expect(b.startTime).toBeGreaterThanOrEqual(a.endTime + 15);\n    expect(c.startTime).toBeGreaterThanOrEqual(b.endTime + 15);\n  });\n});\n```\n\n**Step 2: Run tests**\n\nRun: `npx vitest run`\nExpected: Should PASS if core logic is correct. If any fail, fix the scheduler.\n\n**Step 3: Commit**\n\n```bash\ngit add src/__tests__/scheduler.test.ts\ngit commit -m \"test: add gap enforcement and prerequisite ordering tests\"\n```\n\n---\n\n### Task 5: Preferred Room Tests\n\n**Files:**\n- Modify: `src/__tests__/scheduler.test.ts`\n\n**Dependencies:** Task 3\n\n**Step 1: Write tests for preferred room behavior**\n\n```typescript\ndescribe('preferred room', () => {\n  it('honors preferred room when possible', () => {\n    const events: Event[] = [\n      { id: 'a', name: 'A', duration: 60, preferredRoom: 'r2' },\n    ];\n    const rooms: Room[] = [\n      { id: 'r1', name: 'Room 1', capacity: 10 },\n      { id: 'r2', name: 'Room 2', capacity: 10 },\n    ];\n    const result = schedule(events,