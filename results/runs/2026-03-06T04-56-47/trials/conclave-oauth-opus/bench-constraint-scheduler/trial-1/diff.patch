+```typescript
+function detectCyclesAndTopologicalSort(events: Event[]): string[] {
+  const eventMap = new Map<string, Event>();
+  for (const event of events) {
+    eventMap.set(event.id, event);
+  }
+
+  const WHITE = 0, GRAY = 1, BLACK = 2;
+  const color = new Map<string, number>();
+  const order: string[] = [];
+
+  for (const event of events) {
+    color.set(event.id, WHITE);
+  }
+
+  function dfs(id: string): void {
+    color.set(id, GRAY);
+    const event = eventMap.get(id);
+    if (event?.prerequisites) {
+      for (const prereqId of event.prerequisites) {
+        const prereqColor = color.get(prereqId);
+        if (prereqColor === GRAY) {
+          throw new Error(`Prerequisite cycle detected involving event '${prereqId}'`);
+        }
+        if (prereqColor === WHITE) {
+          dfs(prereqId);
+        }
+        // If prereqColor is undefined (prereq not in events list), skip —
+        // it will be handled as unresolvable prerequisite during scheduling
+      }
+    }
+    color.set(id, BLACK);
+    order.push(id);
+  }
+
+  for (const event of events) {
+    if (color.get(event.id) === WHITE) {
+      dfs(event.id);
+    }
+  }
+
+  return order;
+}
+```
