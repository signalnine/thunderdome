Map<string, Event>();\n   163→  for (const event of events) {\n   164→    eventMap.set(event.id, event);\n   165→  }\n   166→\n   167→  const WHITE = 0, GRAY = 1, BLACK = 2;\n   168→  const color = new Map<string, number>();\n   169→  const order: string[] = [];\n   170→\n   171→  for (const event of events) {\n   172→    color.set(event.id, WHITE);\n   173→  }\n   174→\n   175→  function dfs(id: string): void {\n   176→    color.set(id, GRAY);\n   177→    const event = eventMap.get(id);\n   178→    if (event?.prerequisites) {\n   179→      for (const prereqId of event.prerequisites) {\n   180→        const prereqColor = color.get(prereqId);\n   181→        if (prereqColor === GRAY) {\n   182→          throw new Error(`Prerequisite cycle detected involving event '${prereqId}'`);\n   183→        }\n   184→        if (prereqColor === WHITE) {\n   185→          dfs(prereqId);\n   186→        }\n   187→        // If prereqColor is undefined (prereq not in events list), skip —\n   188→        // it will be handled as unresolvable prerequisite during scheduling\n   189→      }\n   190→    }\n   191→    color.set(id, BLACK);\n   192→    order.push(id);\n   193→  }\n   194→\n   195→  for (const event of events) {\n   196→    if (color.get(event.id) === WHITE) {\n   197→      dfs(event.id);\n   198→    }\n   199→  }\n   200→\n   201→  return order;\n   202→}\n   203→```\n   204→\n   205→Update the `schedule` function to call it:\n   206→\n   207→```typescript\n   208→export function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {\n   209→  if (events.length === 0) {\n   210→    return { assignments: [], unscheduled: [] };\n   211→  }\n   212→\n   213→  const topoOrder = detectCyclesAndTopologicalSort(events);\n   214→\n   215→  return { assignments: [], unscheduled: events.map(e => e.id) };\n   216→}\n   217→```\n   218→\n   219→**Step 4: Run tests to verify they pass**\n   220→\n   221→Run: `npx vitest run`\n   222→Expected: ALL 4 tests 