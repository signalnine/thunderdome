st\n    return (constraintScores.get(b) ?? 0) - (constraintScores.get(a) ?? 0);\n  });\n\n  // Step 4: Greedy scheduling\n  const assignments = new Map<string, Assignment>();\n  const roomSchedules = new Map<string, Assignment[]>();\n  for (const room of rooms) {\n    roomSchedules.set(room.id, []);\n  }\n\n  function addAssignment(assignment: Assignment): void {\n    assignments.set(assignment.eventId, assignment);\n    const roomList = roomSchedules.get(assignment.roomId)!;\n    roomList.push(assignment);\n    // Keep sorted by start time\n    roomList.sort((a, b) => a.startTime - b.startTime);\n  }\n\n  function removeAssignment(eventId: string): void {\n    const assignment = assignments.get(eventId);\n    if (!assignment) return;\n    assignments.delete(eventId);\n    const roomList = roomSchedules.get(assignment.roomId)!;\n    const idx = roomList.findIndex(a => a.eventId === eventId);\n    if (idx !== -1) roomList.splice(idx, 1);\n  }\n\n  // First pass: greedy placement\n  for (const eventId of processingOrder) {\n    const event = eventMap.get(eventId)!;\n    const assignment = placeEvent(event, rooms, roomSchedules, assignments, options, gap);\n    if (assignment) {\n      addAssignment(assignment);\n    }\n  }\n\n  // Step 5: Try to improve - attempt to schedule unscheduled events\n  // by trying alternative placements\n  const unscheduledIds = processingOrder.filter(id => !assignments.has(id));\n\n  if (unscheduledIds.length > 0) {\n    // Try a few different orderings to see if we can fit more events\n    // Approach: For each unscheduled event, try removing the least important\n    // conflicting event and re-scheduling\n\n    let improved = true;\n    let iterations = 0;\n    const maxIterations = unscheduledIds.length * 3;\n\n    while (improved && iterations < maxIterations) {\n      improved = false;\n      iterations++;\n\n      for (const eventId of [...unscheduledIds]) {\n        if (assignments.has(eventId)) continue;\n\n        const event = eventMap.get(eventId)!;\n        const assignment = placeEvent(event, rooms, roomSchedules, assignments, options, gap);\n        if (assignment) {\n          addAssignment(assignment);\n          const idx = unscheduledIds.indexOf(eventId);\n          if (idx !== -1) unscheduledIds.splice(idx, 1);\n          improved = true;\n        }\n      }\n    }\n  }\n\n  // Step 6: Try compacting - move events earlier to create more space\n  let compacted = true;\n  while (compacted) {\n    compacted = false;\n    for (const eventId of processingOrder) {\n      if (!assignments.has(eventId)) continue;\n      const event = eventMap.get(eventId)!;\n      const currentAssignment = assignments.get(eventId)!;\n\n      // Remove and try to place earlier\n      removeAssignment(eventId);\n      const newAssignment = placeEvent(event, rooms, roomSchedules, assignments, options, gap);\n\n      if (newAssignment && newAssignment.startTime < currentAssignment.startTime) {\n        addAssignment(newAssignment);\n        compacted = true;\n      } else {\n        // Put it back where it was\n        addAssignment(currentAssignment);\n      }\n    }\n  }\n\n  // After compaction, try again to schedule unscheduled events\n  const stillUnscheduled = processingOrder.filter(id => !assignments.has(id));\n  if (stillUnscheduled.length > 0) {\n    for (const eventId of stillUnscheduled) {\n      const event = eventMap.get(eventId)!;\n      const assignment = placeEvent(event, rooms, roomSchedules, assignments, options, gap);\n      if (assignment) {\n        addAssignment(assignment);\n      }\n    }\n  }\n\n  // Build final result\n  const finalAssignments: Assignment[] = [];\n  const finalUnscheduled: string[] = [];\n\n  for (const eventId of processingOrder) {\n    const assignment = assignments.get(eventId);\n    if (assignment) {\n      finalAssignments.push(assignment);\n    } else {\n      finalUnscheduled.push(eventId);\n    }\n  }\n\n  return {\n    assignments: finalAssignments,\n    uns