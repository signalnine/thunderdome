+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_0163vFHsj2LrtJgWiKQKKdm4","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01FieN3mBzbnHoRXm6JAU7vR","name":"Write","input":{"file_path":"/workspace/src/scheduler.ts","content":"import { Event, Room, ScheduleOptions, Assignment, ScheduleResult } from './types.js';\n\n/**\n * Detect cycles in the prerequisite graph using DFS.\n * Throws an error if a cycle is found (including self-references).\n * Returns a topological ordering of event IDs.\n */\nfunction topologicalSort(events: Event[]): string[] {\n  const eventMap = new Map<string, Event>();\n  for (const event of events) {\n    eventMap.set(event.id, event);\n  }\n\n  const WHITE = 0;\n  const GRAY = 1;\n  const BLACK = 2;\n\n  const color = new Map<string, number>();\n  for (const event of events) {\n    color.set(event.id, WHITE);\n  }\n\n  const order: string[] = [];\n\n  function dfs(id: string): void {\n    color.set(id, GRAY);\n\n    const event = eventMap.get(id);\n    if (event?.prerequisites) {\n      for (const prereqId of event.prerequisites) {\n        if (prereqId === id) {\n          throw new Error(`Cycle detected: event \"${id}\" has a self-reference`);\n        }\n\n        const prereqColor = color.get(prereqId);\n\n        if (prereqColor === GRAY) {\n          throw new Error(`Cycle detected in prerequisites involving event \"${prereqId}\"`);\n        }\n\n        if (prereqColor === WHITE) {\n          if (eventMap.has(prereqId)) {\n            dfs(prereqId);\n          }\n        }\n      }\n    }\n\n    color.set(id, BLACK);\n    order.push(id);\n  }\n\n  for (const event of events) {\n    if (color.get(event.id) === WHITE) {\n      dfs(event.id);\n    }\n  }\n\n  return order;\n}\n\n/**\n * Find the earliest start time for an event in a given room,\n * respecting room gaps and prerequisite completion times.\n */\nfunction findEarliestStart(\n  event: Event,\n  room: Room,\n  roomSchedules: Map<string, Assignment[]>,\n  assignments: Map<string, Assignment>,\n  options: ScheduleOptions,\n  gap: number\n): number | null {\n  const attendees = event.attendees ?? 1;\n  if (attendees > room.capacity) {\n    return null;\n  }\n\n  let earliest = options.startTime;\n  if (event.prerequisites) {\n    for (const prereqId of event.prerequisites) {\n      const prereqAssignment = assignments.get(prereqId);\n      if (prereqAssignment) {\n        earliest = Math.max(earliest, prereqAssignment.endTime + gap);\n      }\n    }\n  }\n\n  if (earliest + event.duration > options.endTime) {\n    return null;\n  }\n\n  const roomAssignments = roomSchedules.get(room.id) || [];\n\n  if (roomAssignments.length === 0) {\n    return earliest;\n  }\n\n  // Try before the first event\n  if (earliest + event.duration <= roomAssignments[0].startTime - gap ||\n      (earliest + event.duration <= roomAssignments[0].startTime && gap === 0)) {\n    return earliest;\n  }\n\n  // Try gaps between events and after the last event\n  for (let i = 0; i < roomAssignments.length; i++) {\n    const slotStart = Math.max(earliest, roomAssignments[i].endTime + gap);\n\n    if (slotStart + event.duration > options.endTime) {\n      return null;\n    }\n\n    if (i + 1 < roomAssignments.length) {\n      const nextStart = roomAssignments[i + 1].startTime;\n      if (slotStart + event.duration + gap <= nextStart ||\n          (slotStart + event.duration <= nextStart && gap === 0)) {\n        return slotStart;\n      }\n    } else {\n      if (slotStart + event.duration <= options.endTime) {\n        return slotStart;\n      }\n    }\n  }\n\n  return null;\n}\n\n/**\n * Place an event in the best available room and time slot.\n */\nfunction placeEvent(\n  event: Event,\n  rooms: Room[],\n  roomSchedules: Map<string, Assignment[]>,\n  assignments: Map<string, Assignment>,\n  options: ScheduleOptions,\n  gap: number\n): Assignment | null {\n  if (event.prerequisites) {\n    for (const prereqId of event.prerequisites) {\n      if (!assignments.has(prereqId)) {\n        return null;\n      }\n    }\n  }\n\n  interface Candidate {\n    roomId: string;\n    startTime: number;\n    isPreferred: boolean;\n    capacityFit: number;\n  }\n\n  const candidates: Candidate[] = [];\n\n  for (const room of rooms) {\n    const startTime = findEarliestStart(event, room, roomSchedules, assignments, options, gap);\n    if (startTime !== null) {\n      candidates.push({\n        roomId: room.id,\n        startTime,\n        isPreferred: room.id === event.preferredRoom,\n        capacityFit: room.capacity - (event.attendees ?? 1),\n      });\n    }\n  }\n\n  if (candidates.length === 0) {\n    return null;\n  }\n\n  candidates.sort((a, b) => {\n    if (a.isPreferred !== b.isPreferred) {\n      return a.isPreferred ? -1 : 1;\n    }\n    if (a.startTime !== b.startTime) {\n      return a.startTime - b.startTime;\n    }\n    return a.capacityFit - b.capacityFit;\n  });\n\n  const best = candidates[0];\n  return {\n    eventId: event.id,\n    roomId: best.roomId,\n    startTime: best.startTime,\n    endTime: best.startTime + event.duration,\n  };\n}\n\n/**\n * Compute dependency levels for topological ordering.\n */\nfunction computeLevels(events: Event[], eventMap: Map<string, Event>): Map<string, number> {\n  const levels = new Map<string, number>();\n\n  function getLevel(id: string): number {\n    if (levels.has(id)) return levels.get(id)!;\n    const event = eventMap.get(id)!;\n    let maxPrereqLevel = -1;\n    if (event.prerequisites) {\n      for (const prereqId of event.prerequisites) {\n        if (eventMap.has(prereqId)) {\n          maxPrereqLevel = Math.max(maxPrereqLevel, getLevel(prereqId));\n        }\n      }\n    }\n    const level = maxPrereqLevel + 1;\n    levels.set(id, level);\n    return level;\n  }\n\n  for (const event of events) {\n    getLevel(event.id);\n  }\n\n  return levels;\n}\n\n/**\n * Count transitive dependents for each event.\n */\nfunction computeDependentCounts(events: Event[]): Map<string, number> {\n  const dependents = new Map<string, Set<string>>();\n\n  for (const e of events) {\n    dependents.set(e.id, new Set());\n  }\n\n  for (const e of events) {\n    if (e.prerequisites) {\n      for (const prereqId of e.prerequisites) {\n        if (dependents.has(prereqId)) {\n          dependents.get(prereqId)!.add(e.id);\n        }\n      }\n    }\n  }\n\n  const transitiveCounts = new Map<string, number>();\n  for (const e of events) {\n    const visited = new Set<string>();\n    const queue = [...(dependents.get(e.id) || [])];\n    while (queue.length > 0) {\n      const current = queue.shift()!;\n      if (visited.has(current)) continue;\n      visited.add(current);\n      for (const dep of dependents.get(current) || []) {\n        queue.push(dep);\n      }\n    }\n    transitiveCounts.set(e.id, visited.size);\n  }\n\n  return transitiveCounts;\n}\n\n/**\n * Run a single greedy pass with the given ordering, returning the result.\n */\nfunction greedySchedule(\n  orderedEventIds: string[],\n  eventMap: Map<string, Event>,\n  rooms: Room[],\n  options: ScheduleOptions,\n  gap: number\n): { assignments: Map<string, Assignment>; roomSchedules: Map<string, Assignment[]> } {\n  const assignments = new Map<string, Assignment>();\n  const roomSchedules = new Map<string, Assignment[]>();\n  for (const room of rooms) {\n    roomSchedules.set(room.id, []);\n  }\n\n  for (const eventId of orderedEventIds) {\n    const event = eventMap.get(eventId)!;\n    const assignment = placeEvent(event, rooms, roomSchedules, assignments, options, gap);\n    if (assignment) {\n      assignments.set(assignment.eventId, assignment);\n      const roomList = roomSchedules.get(assignment.roomId)!;\n      roomList.push(assignment);\n      roomList.sort((a, b) => a.startTime - b.startTime);\n    }\n  }\n\n  return { assignments, roomSchedules };\n}\n\n/**\n * Generate multiple valid orderings respecting topological constraints.\n */\nfunction generateOrderings(\n  events: Event[],\n  eventMap: Map<string, Event>,\n  levels: Map<string, number>,\n  dependentCounts: Map<string, number>\n): string[][] {\n  const orderings: string[][] = [];\n\n  // Group events by level\n  const byLevel = new Map<number, string[]>();\n  for (const event of events) {\n    const level = levels.get(event.id)!;\n    if (!byLevel.has(level)) byLevel.set(level, []);\n    byLevel.get(level)!.push(event.id);\n  }\n\n  const maxLevel = Math.max(...byLevel.keys());\n\n  // Ordering 1: Short duration first within levels\n  {\n    const order: string[] = [];\n    for (let l = 0; l <= maxLevel; l++) {\n      const group = byLevel.get(l) || [];\n      const sorted = [...group].sort((a, b) => {\n        return eventMap.get(a)!.duration - eventMap.get(b)!.duration;\n      });\n      order.push(...sorted);\n    }\n    orderings.push(order);\n  }\n\n  // Ordering 2: Long duration first within levels\n  {\n    const order: string[] = [];\n    for (let l = 0; l <= maxLevel; l++) {\n      const group = byLevel.get(l) || [];\n      const sorted = [...group].sort((a, b) => {\n        return eventMap.get(b)!.duration - eventMap.get(a)!.duration;\n      });\n      order.push(...sorted);\n    }\n    orderings.push(order);\n  }\n\n  // Ordering 3: Most dependents first within levels\n  {\n    const order: string[] = [];\n    for (let l = 0; l <= maxLevel; l++) {\n      const group = byLevel.get(l) || [];\n      const sorted = [...group].sort((a, b) => {\n        return (dependentCounts.get(b) ?? 0) - (dependentCounts.get(a) ?? 0);\n      });\n      order.push(...sorted);\n    }\n    orderings.push(order);\n  }\n\n  // Ordering 4: Fewest fitting rooms first (most constrained by capacity)\n  {\n    const order: string[] = [];\n    for (let l = 0; l <= maxLevel; l++) {\n      const group = byLevel.get(l) || [];\n      const sorted = [...group].sort((a, b) => {\n        const attendeesA = eventMap.get(a)!.attendees ?? 1;\n        const attendeesB = eventMap.get(b)!.attendees ?? 1;\n        return attendeesB - attendeesA;\n      });\n      order.push(...sorted);\n    }\n    orderings.push(order);\n  }\n\n  // Ordering 5: Smallest attendees first\n  {\n    const order: string[] = [];\n    for (let l = 0; l <= maxLevel; l++) {\n      const group = byLevel.get(l) || [];\n      const sorted = [...group].sort((a, b) => {\n        const attendeesA = eventMap.get(a)!.attendees ?? 1;\n        const attendeesB = eventMap.get(b)!.attendees ?? 1;\n        return attendeesA - attendeesB;\n      });\n      order.push(...sorted);\n    }\n    orderings.push(order);\n  }\n\n  return orderings;\n}\n\n/**\n * Main scheduling function.\n * Tries multiple ordering strategies and picks the one that maximizes scheduled events.\n * Then applies compaction and retry to fill any remaining gaps.\n */\nexport function schedule(\n  events: Event[],\n  rooms: Room[],\n  options: ScheduleOptions\n): ScheduleResult {\n  if (events.length === 0) {\n    return { assignments: [], unscheduled: [] };\n  }\n\n  const gap = options.gap ?? 15;\n\n  // Step 1: Detect cycles and validate topological order\n  topologicalSort(events);\n\n  const eventMap = new Map<string, Event>();\n  for (const event of events) {\n    eventMap.set(event.id, event);\n  }\n\n  const levels = computeLevels(events, eventMap);\n  const dependentCounts = computeDependentCounts(events);\n\n  // Step 2: Generate multiple orderings\n  const orderings = generateOrderings(events, eventMap, levels, dependentCounts);\n\n  // Step 3: Try each ordering and pick the best\n  let bestAssignments = new Map<string, Assignment>();\n  let bestRoomSchedules = new Map<string, Assignment[]>();\n\n  for (const ordering of orderings) {\n    const result = greedySchedule(ordering, eventMap, rooms, options, gap);\n    if (result.assignments.size > bestAssignments.size) {\n      bestAssignments = result.assignments;\n      bestRoomSchedules = result.roomSchedules;\n    }\n  }\n\n  // Step 4: Compaction — move events earlier to free up space\n  const assignments = bestAssignments;\n  const roomSchedules = bestRoomSchedules;\n\n  function addAssignment(assignment: Assignment): void {\n    assignments.set(assignment.eventId, assignment);\n    const roomList = roomSchedules.get(assignment.roomId)!;\n    roomList.push(assignment);\n    roomList.sort((a, b) => a.startTime - b.startTime);\n  }\n\n  function removeAssignment(eventId: string): void {\n    const assignment = assignments.get(eventId);\n    if (!assignment) return;\n    assignments.delete(eventId);\n    const roomList = roomSchedules.get(assignment.roomId)!;\n    const idx = roomList.findIndex(a => a.eventId === eventId);\n    if (idx !== -1) roomList.splice(idx, 1);\n  }\n\n  // Build a dependency-aware processing order for compaction\n  const compactionOrder: string[] = [];\n  {\n    const byLevel = new Map<number, string[]>();\n    for (const [id] of assignments) {\n      const level = levels.get(id)!;\n      if (!byLevel.has(level)) byLevel.set(level, []);\n      byLevel.get(level)!.push(id);\n    }\n    const sortedLevels = [...byLevel.keys()].sort((a, b) => a - b);\n    for (const level of sortedLevels) {\n      const group = byLevel.get(level)!;\n      group.sort((a, b) => {\n        const aStart = assignments.get(a)!.startTime;\n        const bStart = assignments.get(b)!.startTime;\n        return aStart - bStart;\n      });\n      compactionOrder.push(...group);\n    }\n  }\n\n  let compacted = true;\n  let compactIterations = 0;\n  while (compacted && compactIterations < 10) {\n    compacted = false;\n    compactIterations++;\n    for (const eventId of compactionOrder) {\n      if (!assignments.has(eventId)) continue;\n      const event = eventMap.get(eventId)!;\n      const currentAssignment = assignments.get(eventId)!;\n\n      removeAssignment(eventId);\n      const newAssignment = placeEvent(event, rooms, roomSchedules, assignments, options, gap);\n\n      if (newAssignment && newAssignment.startTime < currentAssignment.startTime) {\n        addAssignment(newAssignment);\n        compacted = true;\n      } else {\n        addAssignment(currentAssignment);\n      }\n    }\n  }\n\n  // Step 5: Try to schedule remaining unscheduled events after compaction\n  const allEventIds = events.map(e => e.id);\n  const unscheduledAfterCompaction = allEventIds.filter(id => !assignments.has(id));\n\n  // Sort unscheduled by duration (shortest first) to maximize count\n  const sortedUnscheduled = [...unscheduledAfterCompaction].sort((a, b) => {\n    return eventMap.get(a)!.duration - eventMap.get(b)!.duration;\n  });\n\n  // Respect topological order: only try events whose prerequisites are all scheduled\n  let madeProgress = true;\n  while (madeProgress) {\n    madeProgress = false;\n    for (const eventId of sortedUnscheduled) {\n      if (assignments.has(eventId)) continue;\n      const event = eventMap.get(eventId)!;\n      const assignment = placeEvent(event, rooms, roomSchedules, assignments, options, gap);\n      if (assignment) {\n        addAssignment(assignment);\n        madeProgress = true;\n      }\n    }\n  }\n\n  // Step 6: Displacement optimization — try swapping scheduled long events\n  // with multiple unscheduled short events to increase total count\n  const finalUnscheduled = allEventIds.filter(id => !assignments.has(id));\n\n  if (finalUnscheduled.length > 0) {\n    let improved = true;\n    let swapIterations = 0;\n    while (improved && swapIterations < 5) {\n      improved = false;\n      swapIterations++;\n\n      // For each scheduled event, try removing it and see if we can fit more\n      // unscheduled events in its place\n      const scheduledEvents = [...assignments.keys()];\n\n      for (const scheduledId of scheduledEvents) {\n        const currentUnscheduled = allEventIds.filter(id => !assignments.has(id));\n        if (currentUnscheduled.length === 0) break;\n\n        const savedAssignment = assignments.get(scheduledId)!;\n        removeAssignment(scheduledId);\n\n        // Try to place unscheduled events\n        const newlyPlaced: string[] = [];\n        for (const unschedId of currentUnscheduled) {\n          const event = eventMap.get(unschedId)!;\n          const assignment = placeEvent(event, rooms, roomSchedules, assignments, options, gap);\n          if (assignment) {\n            addAssignment(assignment);\n            newlyPlaced.push(unschedId);\n          }\n        }\n\n        // Try to re-place the removed event\n        const reAssignment = placeEvent(eventMap.get(scheduledId)!, rooms, roomSchedules, assignments, options, gap);\n        if (reAssignment) {\n          addAssignment(reAssignment);\n          if (newlyPlaced.length > 0) {\n            improved = true;\n          }\n        } else {\n          // We lost one event but gained newlyPlaced.length events\n          if (newlyPlaced.length > 1) {\n            // Net gain, keep the swap\n            improved = true;\n          } else {\n            // Net loss or neutral, undo\n            for (const id of newlyPlaced) {\n              removeAssignment(id);\n            }\n            addAssignment(savedAssignment);\n          }\n        }\n      }\n    }\n  }\n\n  // Build final result\n  const finalAssignments: Assignment[] = [];\n  const resultUnscheduled: string[] = [];\n\n  for (const eventId of allEventIds) {\n    const assignment = assignments.get(eventId);\n    if (assignment) {\n      finalAssignments.push(assignment);\n    } else {\n      resultUnscheduled.push(eventId);\n    }\n  }\n\n  return {\n    assignments: finalAssignments,\n    unscheduled: resultUnscheduled,\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":392,"cache_read_input_tokens":40538,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":392},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":nul