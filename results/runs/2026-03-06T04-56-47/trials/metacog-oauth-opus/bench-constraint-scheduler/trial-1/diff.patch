rThanOrEqual(540);\n      expect(result.assignments[0].endTime).toBeLessThanOrEqual(600);\n    });\n\n    it('should not schedule event that exceeds time window', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Long Event', duration: 120 },\n      ];\n\n      const result = schedule(events, defaultRooms, {\n        startTime: 540,\n        endTime: 600, // only 60 min window\n      });\n\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toEqual(['e1']);\n    });\n  });\n\n  describe('room gaps', () => {\n    it('should maintain default 15-minute gap between events in same room', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n        { id: 'e2', name: 'Event 2', duration: 60 },\n      ];\n      const rooms: Room[] = [\n        { id: 'r1', name: 'Room 1', capacity: 10 },\n      ];\n\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(2);\n      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);\n      expect(sorted[1].startTime - sorted[0].endTime).toBeGreaterThanOrEqual(15);\n    });\n\n    it('should use custom gap when specified', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n        { id: 'e2', name: 'Event 2', duration: 60 },\n      ];\n      const rooms: Room[] = [\n        { id: 'r1', name: 'Room 1', capacity: 10 },\n      ];\n\n      const result = schedule(events, rooms, {\n        ...defaultOptions,\n        gap: 30,\n      });\n\n      expect(result.assignments).toHaveLength(2);\n      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);\n      expect(sorted[1].startTime - sorted[0].endTime).toBeGreaterThanOrEqual(30);\n    });\n\n    it('should allow events in different rooms without gap constraint', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n        { id: 'e2', name: 'Event 2', duration: 60 },\n      ];\n\n      const result = schedule(events, defaultRooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(2);\n      // If in different rooms, they can start at the same time\n      const rooms = new Set(result.assignments.map(a => a.roomId));\n      if (rooms.size === 2) {\n        // Both events could start at the same time\n        expect(result.assignments[0].startTime).toBe(result.assignments[1].startTime);\n      }\n    });\n  });\n\n  describe('prerequisites', () => {\n    it('should schedule prerequisite events before dependent events', () => {\n      const events: Event[] = [\n        { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },\n        { id: 'e1', name: 'Event 1', duration: 60 },\n      ];\n\n      const result = schedule(events, defaultRooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(2);\n      const e1 = result.assignments.find(a => a.eventId === 'e1')!;\n      const e2 = result.assignments.find(a => a.eventId === 'e2')!;\n      expect(e1.endTime).toBeLessThanOrEqual(e2.startTime);\n    });\n\n    it('should enforce gap between prerequisite and dependent events', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n        { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },\n      ];\n\n      const result = schedule(events, defaultRooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(2);\n      const e1 = result.assignments.find(a => a.eventId === 'e1')!;\n      const e2 = result.assignments.find(a => a.eventId === 'e2')!;\n      expect(e2.startTime - e1.endTime).toBeGreaterThanOrEqual(15);\n    });\n\n    it('should handle chains of prerequisites', () => {\n      const events: Event[] = [\n        { id: 'e3', name: 'Event 3', duration: 30, prerequisites: ['e2'] },\n        { id: 'e2', name: 'Event 2', duration: 30, prerequisites: ['e1'] },\n        { id: 'e1', name: 'Event 1', duration: 30 },\n      ];\n\n      const result = schedule(events, defaultRooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(3);\n      const e1 = result.assignments.find(a => a.eventId === 'e1')!;\n      const e2 = result.assignments.find(a => a.eventId === 'e2')!;\n      const e3 = result.assignments.find(a => a.eventId === 'e3')!;\n      expect(e1.endTime + 15).toBeLessThanOrEqual(e2.startTime + 0.001);\n      expect(e2.endTime + 15).toBeLessThanOrEqual(e3.startTime + 0.001);\n    });\n\n    it('should not schedule event if prerequisite cannot be scheduled', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Big Event', duration: 60, attendees: 100 },\n        { id: 'e2', name: 'Depends on Big', duration: 30, prerequisites: ['e1'] },\n      ];\n      const rooms: Room[] = [\n        { id: 'r1', name: 'Small Room', capacity: 10 },\n      ];\n\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.unscheduled).toContain('e1');\n      expect(result.unscheduled).toContain('e2');\n    });\n  });\n\n  describe('prerequisite cycles', () => {\n    it('should throw error on self-reference', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Self Ref', duration: 60, prerequisites: ['e1'] },\n      ];\n\n      expect(() => schedule(events, defaultRooms, defaultOptions)).toThrow();\n    });\n\n    it('should throw error on direct cycle', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['e2'] },\n        { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },\n      ];\n\n      expect(() => schedule(events, defaultRooms, defaultOptions)).toThrow();\n    });\n\n    it('should throw error on indirect cycle', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['e3'] },\n        { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },\n        { id: 'e3', name: 'Event 3', duration: 60, prerequisites: ['e2'] },\n      ];\n\n      expect(() => schedule(events, defaultRooms, defaultOptions)).toThrow();\n    });\n  });\n\n  describe('preferred room', () => {\n    it('should honor preferred room when possible', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, preferredRoom: 'room-b' },\n      ];\n\n      const result = schedule(events, defaultRooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('room-b');\n    });\n\n    it('should fall back to other room if preferred room cannot accommodate', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, attendees: 15, preferredRoom: 'room-a' },\n      ];\n\n      // room-a capacity is 10, event needs 15\n      const result = schedule(events, defaultRooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('room-b');\n    });\n  });\n\n  describe('unscheduled events', () => {\n    it('should report events that cannot be scheduled', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, attendees: 50 },\n      ];\n      const rooms: Room[] = [\n        { id: 'r1', name: 'Room 1', capacity: 10 },\n      ];\n\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toEqual(['e1']);\n    });\n\n    it('should schedule as many events as possible when not all fit', () => {\n      // 3-hour window, 60-min events, 15-min gaps = max 2 events per room\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n        { id: 'e2', name: 'Event 2', duration: 60 },\n        { id: 'e3', name: 'Event 3', duration: 60 },\n        { id: 'e4', name: 'Event 4', duration: 60 },\n        { id: 'e5', name: 'Event 5', duration: 60 },\n      ];\n      const rooms: Room[] = [\n        { id: 'r1', name: 'Room 1', capacity: 10 },\n        { id: 'r2', name: 'Room 2', capacity: 10 },\n      ];\n\n      const result = schedule(events, rooms, {\n        startTime: 540,\n        endTime: 720, // 3-hour window\n      });\n\n      // With 3h window, 60m events, 15m gaps: each room fits 2 events\n      // (60 + 15 + 60 = 135min, fits in 180min)\n      // So 4 events can be scheduled, 1 unscheduled\n      expect(result.assignments.length).toBe(4);\n      expect(result.unscheduled.length).toBe(1);\n    });\n  });\n\n  describe('batch optimization', () => {\n    it('should maximize the number of scheduled events', () => {\n      // Tight scheduling scenario\n      const events: Event[] = [\n        { id: 'e1', name: 'Short 1', duration: 30 },\n        { id: 'e2', name: 'Short 2', duration: 30 },\n        { id: 'e3', name: 'Short 3', duration: 30 },\n        { id: 'e4', name: 'Long Event', duration: 120 },\n      ];\n      const rooms: Room[] = [\n        { id: 'r1', name: 'Room 1', capacity: 10 },\n      ];\n\n      // 3-hour window\n      const result = schedule(events, rooms, {\n        startTime: 540,\n        endTime: 720,\n      });\n\n      // 3 short events (30+15+30+15+30=120) fit better than 1 long + 1 short (120+15+30=165)\n      // Optimal: 3 short events scheduled (120 min total with gaps)\n      // or long + 1 short (165 min)\n      // Maximizing count: 3 short events is better\n      expect(result.assignments.length).toBeGreaterThanOrEqual(3);\n    });\n  });\n\n  describe('gap of 0', () => {\n    it('should allow back-to-back events with gap of 0', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n        { id: 'e2', name: 'Event 2', duration: 60 },\n      ];\n      const rooms: Room[] = [\n        { id: 'r1', name: 'Room 1', capacity: 10 },\n      ];\n\n      const result = schedule(events, rooms, {\n        startTime: 540,\n        endTime: 660, // exactly 2 hours\n        gap: 0,\n      });\n\n      expect(result.assignments).toHaveLength(2);\n      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);\n      expect(sorted[0].endTime).toBe(sorted[1].startTime);\n    });\n  });\n\n  describe('complex scenarios', () => {\n    it('should handle a realistic conference schedule', () => {\n      const events: Event[] = [\n        { id: 'keynote', name: 'Keynote', duration: 90, attendees: 50, preferredRoom: 'main-hall' },\n        { id: 'workshop-a', name: 'Workshop A', duration: 120, attendees: 15, prerequisites: ['keynote'] },\n        { id: 'workshop-b', name: 'Workshop B', duration: 120, attendees: 20, prerequisites: ['keynote'] },\n        { id: 'talk-1', name: 'Talk 1', duration: 45, attendees: 30, prerequisites: ['keynote'] },\n        { id: 'talk-2', name: 'Talk 2', duration: 45, attendees: 25, prerequisites: ['keynote'] },\n        { id: 'panel', name: 'Panel', duration: 60, attendees: 40, prerequisites: ['talk-1', 'talk-2'] },\n        { id: 'closing', name: 'Closing', duration: 30, attendees: 50, prerequisites: ['panel', 'workshop-a', 'workshop-b'] },\n      ];\n      const rooms: Room[] = [\n        { id: 'main-hall', name: 'Main Hall', capacity: 100 },\n        { id: 'room-1', name: 'Room 1', capacity: 30 },\n        { id: 'room-2', name: 'Room 2', capacity: 25 },\n      ];\n\n      const result = schedule(events, rooms, defaultOptions);\n\n      // All events should be schedulable\n      expect(result.assignments).toHaveLength(7);\n      expect(result.unscheduled).toHaveLength(0);\n\n      // Keynote should be in main-hall (preferred)\n      const keynote = result.assignments.find(a => a.eventId === 'keynote')!;\n      expect(keynote.roomId).toBe('main-hall');\n\n      // All prerequisites should be respected\n      const getAssignment = (id: string) => result.assignments.find(a => a.eventId === id)!;\n\n      const workshopA = getAssignment('workshop-a');\n      const workshopB = getAssignment('workshop-b');\n      const talk1 = getAssignment('talk-1');\n      const talk2 = getAssignment('talk-2');\n      const panel = getAssignment('panel');\n      const closing = getAssignment('closing');\n\n      expect(keynote.endTime).toBeLessThanOrEqual(workshopA.startTime);\n      expect(keynote.endTime).toBeLessThanOrEqual(workshopB.startTime);\n      expect(keynote.endTime).toBeLessThanOrEqual(talk1.startTime);\n      expect(keynote.endTime).toBeLessThanOrEqual(talk2.startTime);\n      expect(talk1.endTime).toBeLessThanOrEqual(panel.startTime);\n      expect(talk2.endTime).toBeLessThanOrEqual(panel.startTime);\n      expect(panel.endTime).toBeLessThanOrEqual(closing.startTime);\n      expect(workshopA.endTime).toBeLessThanOrEqual(closing.startTime);\n      expect(workshopB.endTime).toBeLessThanOrEqual(closing.startTime);\n    });\n\n    it('should handle events with no valid rooms', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Huge Event', duration: 60, attendees: 1000 },\n      ];\n      const rooms: Room[] = [\n        { id: 'r1', name: 'Room 1', capacity: 50 },\n      ];\n\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toEqual(['e1']);\n    });\n  });\n\n  describe('assignment structure', () => {\n    it('should return correct assignment fields', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n      ];\n\n      const result = schedule(events, defaultRooms, defaultOptions);\n\n      expect(result.assignments[0]).toHaveProperty('eventId');\n      expect(result.assignments[0]).toHaveProperty('roomId');\n      expect(result.assignments[0]).toHaveProperty('startTime');\n      expect(result.assignments[0]).toHaveProperty('endTime');\n      expect(typeof result.assignments[0].eventId).toBe('string');\n      expect(typeof result.assignments[0].roomId).toBe('string');\n      expect(typeof result.assignments[0].startTime).toBe('number');\n      expect(typeof result.assignments[0].endTime).toBe('number');\n    });\n\n    it('endTime should equal startTime + duration', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 45 },\n      ];\n\n      const result = schedule(events, defaultRooms, defaultOptions);\n\n      expect(result.assignments[0].endTime - result.assignments[0].startTime).toBe(45);\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
