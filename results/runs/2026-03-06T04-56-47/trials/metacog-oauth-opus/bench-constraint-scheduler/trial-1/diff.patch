\n        capacityFit: room.capacity - (event.attendees ?? 1),\n      });\n    }\n  }\n\n  if (candidates.length === 0) {\n    return null;\n  }\n\n  // Sort candidates: preferred room first, then earliest start, then tightest capacity fit\n  candidates.sort((a, b) => {\n    // Preferred room takes priority\n    if (a.isPreferred !== b.isPreferred) {\n      return a.isPreferred ? -1 : 1;\n    }\n    // Then earliest start time\n    if (a.startTime !== b.startTime) {\n      return a.startTime - b.startTime;\n    }\n    // Then tightest capacity fit\n    return a.capacityFit - b.capacityFit;\n  });\n\n  const best = candidates[0];\n  return {\n    eventId: event.id,\n    roomId: best.roomId,\n    startTime: best.startTime,\n    endTime: best.startTime + event.duration,\n  };\n}\n\n/**\n * Compute how constrained each event is (higher = more constrained = should be scheduled first).\n */\nfunction computeConstraintScore(\n  event: Event,\n  rooms: Room[],\n  options: ScheduleOptions\n): number {\n  let score = 0;\n  const attendees = event.attendees ?? 1;\n\n  // Fewer rooms that can fit this event = more constrained\n  const fittingRooms = rooms.filter(r => r.capacity >= attendees).length;\n  if (fittingRooms === 0) return Infinity;\n  score += (rooms.length - fittingRooms) * 100;\n\n  // Longer events are more constrained (harder to fit in remaining gaps)\n  const windowSize = options.endTime - options.startTime;\n  score += (event.duration / windowSize) * 50;\n\n  // More prerequisites = more constrained (depends on other events' placement)\n  score += (event.prerequisites?.length ?? 0) * 20;\n\n  // More attendees = more constrained (fewer rooms can hold them)\n  score += attendees;\n\n  return score;\n}\n\n/**\n * Count how many dependents (direct and transitive) each event has.\n */\nfunction computeDependentCounts(events: Event[]): Map<string, number> {\n  const dependents = new Map<string, Set<string>>();\n  const eventMap = new Map<string, Event>();\n\n  for (const e of events) {\n    eventMap.set(e.id, e);\n    dependents.set(e.id, new Set());\n  }\n\n  // Build reverse dependency graph\n  for (const e of events) {\n    if (e.prerequisites) {\n      for (const prereqId of e.prerequisites) {\n        if (dependents.has(prereqId)) {\n          dependents.get(prereqId)!.add(e.id);\n        }\n      }\n    }\n  }\n\n  // Compute transitive dependents via BFS\n  const transitiveCounts = new Map<string, number>();\n  for (const e of events) {\n    const visited = new Set<string>();\n    const queue = [...(dependents.get(e.id) || [])];\n    while (queue.length > 0) {\n      const current = queue.shift()!;\n      if (visited.has(current)) continue;\n      visited.add(current);\n      for (const dep of dependents.get(current) || []) {\n        queue.push(dep);\n      }\n    }\n    transitiveCounts.set(e.id, visited.size);\n  }\n\n  return transitiveCounts;\n}\n\n/**\n * Main scheduling function using a greedy approach with backtracking\n * to maximize the number of scheduled events.\n */\nexport function schedule(\n  events: Event[],\n  rooms: Room[],\n  options: ScheduleOptions\n): ScheduleResult {\n  if (events.length === 0) {\n    return { assignments: [], unscheduled: [] };\n  }\n\n  const gap = options.gap ?? 15;\n\n  // Step 1: Detect cycles and get topological order\n  const topoOrder = topologicalSort(events);\n\n  const eventMap = new Map<string, Event>();\n  for (const event of events) {\n    eventMap.set(event.id, event);\n  }\n\n  // Step 2: Compute constraint scores and dependent counts for prioritization\n  const constraintScores = new Map<string, number>();\n  for (const event of events) {\n    constraintScores.set(event.id, computeConstraintScore(event, rooms, options));\n  }\n\n  const dependentCounts = computeDependentCounts(events);\n\n  // Step 3: Determine processing order respecting topological constraints\n  // but within those constraints, prioritize more-constrained events and\n  // events with more dependents.\n  const topoPosition = new Map<string, number>();\n  for (let i = 0; i < topoOrder.length; i++) {\n    topoPosition.set(topoOrder[i], i);\n  }\n\n  // Build dependency levels (events at same level can be reordered)\n  const levels = new Map<string, number>();\n  function getLevel(id: string): number {\n    if (levels.has(id)) return levels.get(id)!;\n    const event = eventMap.get(id)!;\n    let maxPrereqLevel = -1;\n    if (event.prerequisites) {\n      for (const prereqId of event.prerequisites) {\n        if (eventMap.has(prereqId)) {\n          maxPrereqLevel = Math.max(maxPrereqLevel, getLevel(prereqId));\n        }\n      }\n    }\n    const level = maxPrereqLevel + 1;\n    levels.set(id, level);\n    return level;\n  }\n\n  for (const event of events) {\n    getLevel(event.id);\n  }\n\n  // Sort: by dependency level first, then by dependent count (more dependents first),\n  // then by constraint score (more constrained first)\n  const processingOrder = [...topoOrder].sort((a, b) => {\n    const levelDiff = levels.get(a)! - levels.get(b)!;\n    if (levelDiff !== 0) return levelDiff;\n\n    // More dependents first (these are \"gateway\" events)\n    const depDiff = (dependentCounts.get(b) ?? 0) - (dependentCounts.get(a) ?? 0);\n    if (depDiff !== 0) return depDiff;\n\n    // More constrained first\n    return (constraintScores.get(b) ?? 0) - (constraintScores.get(a) ?? 0);\n  });\n\n  // Step 4: Greedy scheduling\n  const assignments = new Map<string, Assignment>();\n  const roomSchedules = new Map<string, Assignment[]>();\n  for (const room of rooms) {\n    roomSchedules.set(room.id, []);\n  }\n\n  function addAssignment(assignment: Assignment): void {\n    assignments.set(assignment.eventId, assignment);\n    const roomList = roomSchedules.get(assignment.roomId)!;\n    roomList.push(assignment);\n    // Keep sorted by start time\n    roomList.sort((a, b) => a.startTime - b.startTime);\n  }\n\n  function removeAssignment(eventId: string): void {\n    const assignment = assignments.get(eventId);\n    if (!assignment) return;\n    assignments.delete(eventId);\n    const roomList = roomSchedules.get(assignment.roomId)!;\n    const idx = roomList.findIndex(a => a.eventId === eventId);\n    if (idx !== -1) roomList.splice(idx, 1);\n  }\n\n  // First pass: greedy placement\n  for (const eventId of processingOrder) {\n    const event = eventMap.get(eventId)!;\n    const assignment = placeEvent(event, rooms, roomSchedules, assignments, options, gap);\n    if (assignment) {\n      addAssignment(assignment);\n    }\n  }\n\n  // Step 5: Try to improve - attempt to schedule unscheduled events\n  // by trying alternative placements\n  const unscheduledIds = processingOrder.filter(id => !assignments.has(id));\n\n  if (unscheduledIds.length > 0) {\n    // Try a few different orderings to see if we can fit more events\n    // Approach: For each unscheduled event, try removing the least important\n    // conflicting event and re-scheduling\n\n    let improved = true;\n    let iterations = 0;\n    const maxIterations = unscheduledIds.length * 3;\n\n    while (improved && iterations < maxIterations) {\n      improved = false;\n      iterations++;\n\n      for (const eventId of [...unscheduledIds]) {\n        if (assignments.has(eventId)) continue;\n\n        const event = eventMap.get(eventId)!;\n        const assignment = placeEvent(event, rooms, roomSchedules, assignments, options, gap);\n        if (assignment) {\n          addAssignment(assignment);\n          const idx = unscheduledIds.indexOf(eventId);\n          if (idx !== -1) unscheduledIds.splice(idx, 1);\n          improved = true;\n        }\n      }\n    }\n  }\n\n  // Step 6: Try compacting - move events earlier to create more space\n  let compacted = true;\n  while (compacted) {\n    compacted = false;\n    for (const eventId of processingOrder) {\n      if (!assignments.has(eventId)) continue;\n      const event = eventMap.get(eventId)!;\n      const currentAssig