nment, ScheduleResult } from './types.js';\n\n/**\n * Detect cycles in the prerequisite graph using DFS.\n * Throws an error if a cycle is found (including self-references).\n * Returns a topological ordering of event IDs.\n */\nfunction topologicalSort(events: Event[]): string[] {\n  const eventMap = new Map<string, Event>();\n  for (const event of events) {\n    eventMap.set(event.id, event);\n  }\n\n  const WHITE = 0;\n  const GRAY = 1;\n  const BLACK = 2;\n\n  const color = new Map<string, number>();\n  for (const event of events) {\n    color.set(event.id, WHITE);\n  }\n\n  const order: string[] = [];\n\n  function dfs(id: string): void {\n    color.set(id, GRAY);\n\n    const event = eventMap.get(id);\n    if (event?.prerequisites) {\n      for (const prereqId of event.prerequisites) {\n        if (prereqId === id) {\n          throw new Error(`Cycle detected: event \"${id}\" has a self-reference`);\n        }\n\n        const prereqColor = color.get(prereqId);\n\n        if (prereqColor === GRAY) {\n          throw new Error(`Cycle detected in prerequisites involving event \"${prereqId}\"`);\n        }\n\n        if (prereqColor === WHITE) {\n          if (eventMap.has(prereqId)) {\n            dfs(prereqId);\n          }\n        }\n      }\n    }\n\n    color.set(id, BLACK);\n    order.push(id);\n  }\n\n  for (const event of events) {\n    if (color.get(event.id) === WHITE) {\n      dfs(event.id);\n    }\n  }\n\n  return order;\n}\n\n/**\n * Find the earliest start time for an event in a given room,\n * respecting room gaps and prerequisite completion times.\n */\nfunction findEarliestStart(\n  event: Event,\n  room: Room,\n  roomSchedules: Map<string, Assignment[]>,\n  assignments: Map<string, Assignment>,\n  options: ScheduleOptions,\n  gap: number\n): number | null {\n  const attendees = event.attendees ?? 1;\n  if (attendees > room.capacity) {\n    return null;\n  }\n\n  let earliest = options.startTime;\n  if (event.prerequisites) {\n    for (const prereqId of event.prerequisites) {\n      const prereqAssignment = assignments.get(prereqId);\n      if (prereqAssignment) {\n        earliest = Math.max(earliest, prereqAssignment.endTime + gap);\n      }\n    }\n  }\n\n  if (earliest + event.duration > options.endTime) {\n    return null;\n  }\n\n  const roomAssignments = roomSchedules.get(room.id) || [];\n\n  if (roomAssignments.length === 0) {\n    return earliest;\n  }\n\n  // Try before the first event\n  if (earliest + event.duration <= roomAssignments[0].startTime - gap ||\n      (earliest + event.duration <= roomAssignments[0].startTime && gap === 0)) {\n    return earliest;\n  }\n\n  // Try gaps between events and after the last event\n  for (let i = 0; i < roomAssignments.length; i++) {\n    const slotStart = Math.max(earliest, roomAssignments[i].endTime + gap);\n\n    if (slotStart + event.duration > options.endTime) {\n      return null;\n    }\n\n    if (i + 1 < roomAssignments.length) {\n      const nextStart = roomAssignments[i + 1].startTime;\n      if (slotStart + event.duration + gap <= nextStart ||\n          (slotStart + event.duration <= nextStart && gap === 0)) {\n        return slotStart;\n      }\n    } else {\n      if (slotStart + event.duration <= options.endTime) {\n        return slotStart;\n      }\n    }\n  }\n\n  return null;\n}\n\n/**\n * Place an event in the best available room and time slot.\n */\nfunction placeEvent(\n  event: Event,\n  rooms: Room[],\n  roomSchedules: Map<string, Assignment[]>,\n  assignments: Map<string, Assignment>,\n  options: ScheduleOptions,\n  gap: number\n): Assignment | null {\n  if (event.prerequisites) {\n    for (const prereqId of event.prerequisites) {\n      if (!assignments.has(prereqId)) {\n        return null;\n      }\n    }\n  }\n\n  interface Candidate {\n    roomId: string;\n    startTime: number;\n    isPreferred: boolean;\n    capacityFit: number;\n  }\n\n  const candidates: Candidate[] = [];\n\n  for (const room of rooms) {\n    const startTime = findEarliestStart(event, room, roomSchedules, assignments, options, gap);\n    if (startTime !== null) {\n      candidates.push({\n        roomId: room.id,\n        startTime,\n        isPreferred: room.id === event.preferredRoom,\n        capacityFit: room.capacity - (event.attendees ?? 1),\n      });\n    }\n  }\n\n  if (candidates.length === 0) {\n    return null;\n  }\n\n  candidates.sort((a, b) => {\n    if (a.isPreferred !== b.isPreferred) {\n      return a.isPreferred ? -1 : 1;\n    }\n    if (a.startTime !== b.startTime) {\n      return a.startTime - b.startTime;\n    }\n    return a.capacityFit - b.capacityFit;\n  });\n\n  const best = candidates[0];\n  return {\n    eventId: event.id,\n    roomId: best.roomId,\n    startTime: best.startTime,\n    endTime: best.startTime + event.duration,\n  };\n}\n\n/**\n * Compute dependency levels for topological ordering.\n */\nfunction computeLevels(events: Event[], eventMap: Map<string, Event>): Map<string, number> {\n  const levels = new Map<string, number>();\n\n  function getLevel(id: string): number {\n    if (levels.has(id)) return levels.get(id)!;\n    const event = eventMap.get(id)!;\n    let maxPrereqLevel = -1;\n    if (event.prerequisites) {\n      for (const prereqId of event.prerequisites) {\n        if (eventMap.has(prereqId)) {\n          maxPrereqLevel = Math.max(maxPrereqLevel, getLevel(prereqId));\n        }\n      }\n    }\n    const level = maxPrereqLevel + 1;\n    levels.set(id, level);\n    return level;\n  }\n\n  for (const event of events) {\n    getLevel(event.id);\n  }\n\n  return levels;\n}\n\n/**\n * Count transitive dependents for each event.\n */\nfunction computeDependentCounts(events: Event[]): Map<string, number> {\n  const dependents = new Map<string, Set<string>>();\n\n  for (const e of events) {\n    dependents.set(e.id, new Set());\n  }\n\n  for (const e of events) {\n    if (e.prerequisites) {\n      for (const prereqId of e.prerequisites) {\n        if (dependents.has(prereq