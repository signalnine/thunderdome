onstrained (harder to fit in remaining gaps)\n  const windowSize = options.endTime - options.startTime;\n  score += (event.duration / windowSize) * 50;\n\n  // More prerequisites = more constrained (depends on other events' placement)\n  score += (event.prerequisites?.length ?? 0) * 20;\n\n  // More attendees = more constrained (fewer rooms can hold them)\n  score += attendees;\n\n  return score;\n}\n\n/**\n * Count how many dependents (direct and transitive) each event has.\n */\nfunction computeDependentCounts(events: Event[]): Map<string, number> {\n  const dependents = new Map<string, Set<string>>();\n  const eventMap = new Map<string, Event>();\n\n  for (const e of events) {\n    eventMap.set(e.id, e);\n    dependents.set(e.id, new Set());\n  }\n\n  // Build reverse dependency graph\n  for (const e of events) {\n    if (e.prerequisites) {\n      for (const prereqId of e.prerequisites) {\n        if (dependents.has(prereqId)) {\n          dependents.get(prereqId)!.add(e.id);\n        }\n      }\n    }\n  }\n\n  // Compute transitive dependents via BFS\n  const transitiveCounts = new Map<string, number>();\n  for (const e of events) {\n    const visited = new Set<string>();\n    const queue = [...(dependents.get(e.id) || [])];\n    while (queue.length > 0) {\n      const current = queue.shift()!;\n      if (visited.has(current)) continue;\n      visited.add(current);\n      for (const dep of dependents.get(current) || []) {\n        queue.push(dep);\n      }\n    }\n    transitiveCounts.set(e.id, visited.size);\n  }\n\n  return transitiveCounts;\n}\n\n/**\n * Main scheduling function using a greedy approach with backtracking\n * to maximize the number of scheduled events.\n */\nexport function schedule(\n  events: Event[],\n  rooms: Room[],\n  options: ScheduleOptions\n): ScheduleResult {\n  if (events.length === 0) {\n    return { assignments: [], unscheduled: [] };\n  }\n\n  const gap = options.gap ?? 15;\n\n  // Step 1: Detect cycles and get topological order\