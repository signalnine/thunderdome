ing[]>();\n   448→    for (const [id] of assignments) {\n   449→      const level = levels.get(id)!;\n   450→      if (!byLevel.has(level)) byLevel.set(level, []);\n   451→      byLevel.get(level)!.push(id);\n   452→    }\n   453→    const sortedLevels = [...byLevel.keys()].sort((a, b) => a - b);\n   454→    for (const level of sortedLevels) {\n   455→      const group = byLevel.get(level)!;\n   456→      group.sort((a, b) => {\n   457→        const aStart = assignments.get(a)!.startTime;\n   458→        const bStart = assignments.get(b)!.startTime;\n   459→        return aStart - bStart;\n   460→      });\n   461→      compactionOrder.push(...group);\n   462→    }\n   463→  }\n   464→\n   465→  let compacted = true;\n   466→  let compactIterations = 0;\n   467→  while (compacted && compactIterations < 10) {\n   468→    compacted = false;\n   469→    compactIterations++;\n   470→    for (const eventId of compactionOrder) {\n   471→      if (!assignments.has(eventId)) continue;\n   472→      const event = eventMap.get(eventId)!;\n   473→      const currentAssignment = assignments.get(eventId)!;\n   474→\n   475→      removeAssignment(eventId);\n   476→      const newAssignment = placeEvent(event, rooms, roomSchedules, assignments, options, gap);\n   477→\n   478→      if (newAssignment && newAssignment.startTime < currentAssignment.startTime) {\n   479→        addAssignment(newAssignment);\n   480→        compacted = true;\n   481→      } else {\n   482→        addAssignment(currentAssignment);\n   483→      }\n   484→    }\n   485→  }\n   486→\n   487→  // Step 5: Try to schedule remaining unscheduled events after compaction\n   488→  const allEventIds = events.map(e => e.id);\n   489→  const unscheduledAfterCompaction = allEventIds.filter(id => !assignments.has(id));\n   490→\n   491→  // Sort unscheduled by duration (shortest first) to maximize count\n   492→  const sortedUnscheduled = [...unscheduledAfterCompaction].sort((a, b) => {\n   493→    return eventMap.ge