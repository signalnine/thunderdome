@@ -0,0 +1,255 @@
+import { describe, it, expect } from 'vitest';
+import { simulate, findSwappedWires, Gate } from '../src/index.js';
+
+describe('simulate', () => {
+  it('evaluates AND gate', () => {
+    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });
+    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 0 });
+    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });
+  });
+
+  it('evaluates OR gate', () => {
+    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });
+    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });
+    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });
+    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });
+  });
+
+  it('evaluates XOR gate', () => {
+    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });
+    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });
+    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });
+    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 0 });
+  });
+
+  it('handles chained gates in dependency order', () => {
+    const gates: Gate[] = [
+      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },
+      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },
+    ];
+    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({
+      a: 1, b: 1, c: 1, d: 0, e: 1,
+    });
+  });
+
+  it('handles gates listed out of dependency order', () => {
+    const gates: Gate[] = [
+      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },
+      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },
+    ];
+    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({
+      a: 1, b: 1, c: 1, d: 0, e: 1,
+    });
+  });
+
+  it('simulates a 2-bit adder', () => {
+    const gates: Gate[] = [
+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },
+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },
+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },
+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },
+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },
+    ];
+
+    // 1 + 1 = 2 (01 + 01 = 010)
+    let result = simulate(gates, { x00: 1, x01: 0, y00: 1, y01: 0 });
+    expect(result.z00).toBe(0);
+    expect(result.z01).toBe(1);
+    expect(result.z02).toBe(0);
+
+    // 3 + 3 = 6 (11 + 11 = 110)
+    result = simulate(gates, { x00: 1, x01: 1, y00: 1, y01: 1 });
+    expect(result.z00).toBe(0);
+    expect(result.z01).toBe(1);
+    expect(result.z02).toBe(1);
+
+    // 2 + 1 = 3 (10 + 01 = 011)
+    result = simulate(gates, { x00: 0, x01: 1, y00: 1, y01: 0 });
+    expect(result.z00).toBe(1);
+    expect(result.z01).toBe(1);
+    expect(result.z02).toBe(0);
+  });
+});
+
+describe('findSwappedWires', () => {
+  function makeNBitAdder(n: number): Gate[] {
+    const gates: Gate[] = [
+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+    ];
+    for (let i = 1; i < n; i++) {
+      const nn = i.toString().padStart(2, '0');
+      const prev = (i - 1).toString().padStart(2, '0');
+      gates.push(
+        { op: 'XOR', in1: `x${nn}`, in2: `y${nn}`, out: `t${nn}` },
+        { op: 'XOR', in1: `t${nn}`, in2: `c${prev}`, out: `z${nn}` },
+        { op: 'AND', in1: `x${nn}`, in2: `y${nn}`, out: `a${nn}` },
+        { op: 'AND', in1: `t${nn}`, in2: `c${prev}`, out: `b${nn}` },
+        { op: 'OR', in1: `a${nn}`, in2: `b${nn}`, out: `c${nn}` },
+      );
+    }
+    return gates;
+  }
+
+  function swapOutputs(gates: Gate[], wireA: string, wireB: string) {
+    const gateA = gates.find((g) => g.out === wireA)!;
+    const gateB = gates.find((g) => g.out === wireB)!;
+    gateA.out = wireB;
+    gateB.out = wireA;
+  }
+
+  it('finds swapped z-wire with AND output', () => {
+    // Swap z01 (sum XOR output) with a01 (AND generate output)
+    // z01 should be XOR output, a01 should feed into OR
+    const gates = makeNBitAdder(8);
+    swapOutputs(gates, 'z01', 'a01');
+    swapOutputs(gates, 'z03', 'b03');
+    swapOutputs(gates, 'z05', 't05');
+    swapOutputs(gates, 'c06', 'z07');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(
+      ['z01', 'a01', 'z03', 'b03', 'z05', 't05', 'c06', 'z07'].sort()
+    );
+  });
+
+  it('finds swapped z-wire with OR carry output', () => {
+    // Swap z02 with c02 (carry OR output)
+    const gates = makeNBitAdder(8);
+    swapOutputs(gates, 'z02', 'c02');
+    swapOutputs(gates, 'z04', 'a04');
+    swapOutputs(gates, 'z06', 'b06');
+    swapOutputs(gates, 'z00', 'c00');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(
+      ['z02', 'c02', 'z04', 'a04', 'z06', 'b06', 'z00', 'c00'].sort()
+    );
+  });
+
+  it('finds swapped partial sum with carry', () => {
+    // Swap partial sum t01 with z01 (partial sum should not be z output)
+    const gates = makeNBitAdder(8);
+    swapOutputs(gates, 't01', 'z01');
+    swapOutputs(gates, 'a03', 'z03');
+    swapOutputs(gates, 'b05', 'z05');
+    swapOutputs(gates, 'c07', 'z07');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(
+      ['t01', 'z01', 'a03', 'z03', 'b05', 'z05', 'c07', 'z07'].sort()
+    );
+  });
+
+  it('handles larger 45-bit adder circuits', () => {
+    const gates = makeNBitAdder(45);
+
+    swapOutputs(gates, 'z10', 'a10');
+    swapOutputs(gates, 'z20', 'b20');
+    swapOutputs(gates, 'z30', 't30');
+    swapOutputs(gates, 'z40', 'c40');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(
+      ['z10', 'a10', 'z20', 'b20', 'z30', 't30', 'z40', 'c40'].sort()
+    );
+  });
+
+  it('handles cross-bit swaps', () => {
+    // Swap wires between different bit positions
+    const gates = makeNBitAdder(8);
+    swapOutputs(gates, 'a01', 'z02');  // AND output -> z wire of different bit
+    swapOutputs(gates, 'b03', 'z04');  // AND output -> z wire of different bit
+    swapOutputs(gates, 't05', 'z06');  // partial sum -> z wire of different bit
+    swapOutputs(gates, 'c06', 'z07');  // carry -> z wire
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(
+      ['a01', 'z02', 'b03', 'z04', 't05', 'z06', 'c06', 'z07'].sort()
+    );
+  });
+
+  it('handles swaps with random wire names', () => {
+    // Build a 6-bit adder with random internal wire names
+    const gates: Gate[] = [
+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'abc' },
+
+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 'def' },
+      { op: 'XOR', in1: 'def', in2: 'abc', out: 'z01' },
+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'ghi' },
+      { op: 'AND', in1: 'def', in2: 'abc', out: 'jkl' },
+      { op: 'OR', in1: 'ghi', in2: 'jkl', out: 'mno' },
+
+      { op: 'XOR', in1: 'x02', in2: 'y02', out: 'pqr' },
+      { op: 'XOR', in1: 'pqr', in2: 'mno', out: 'z02' },
+      { op: 'AND', in1: 'x02', in2: 'y02', out: 'stu' },
+      { op: 'AND', in1: 'pqr', in2: 'mno', out: 'vwx' },
+      { op: 'OR', in1: 'stu', in2: 'vwx', out: 'yza' },
+
+      { op: 'XOR', in1: 'x03', in2: 'y03', out: 'bcd' },
+      { op: 'XOR', in1: 'bcd', in2: 'yza', out: 'z03' },
+      { op: 'AND', in1: 'x03', in2: 'y03', out: 'efg' },
+      { op: 'AND', in1: 'bcd', in2: 'yza', out: 'hij' },
+      { op: 'OR', in1: 'efg', in2: 'hij', out: 'klm' },
+
+      { op: 'XOR', in1: 'x04', in2: 'y04', out: 'nop' },
+      { op: 'XOR', in1: 'nop', in2: 'klm', out: 'z04' },
+      { op: 'AND', in1: 'x04', in2: 'y04', out: 'qrs' },
+      { op: 'AND', in1: 'nop', in2: 'klm', out: 'tuv' },
+      { op: 'OR', in1: 'qrs', in2: 'tuv', out: 'wxy' },
+
+      { op: 'XOR', in1: 'x05', in2: 'y05', out: 'zab' },
+      { op: 'XOR', in1: 'zab', in2: 'wxy', out: 'z05' },
+      { op: 'AND', in1: 'x05', in2: 'y05', out: 'cde' },
+      { op: 'AND', in1: 'zab', in2: 'wxy', out: 'fgh' },
+      { op: 'OR', in1: 'cde', in2: 'fgh', out: 'z06' },
+    ];
+
+    // Swap 4 pairs:
+    // 1. z01 <-> ghi (sum output <-> AND generate)
+    swapOutputs(gates, 'z01', 'ghi');
+    // 2. z03 <-> hij (sum output <-> AND propagate)
+    swapOutputs(gates, 'z03', 'hij');
+    // 3. pqr <-> z02 (partial sum <-> sum output at same bit)
+    swapOutputs(gates, 'pqr', 'z02');
+    // 4. klm <-> z04 (carry <-> sum output at next bit)
+    swapOutputs(gates, 'klm', 'z04');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(
+      ['z01', 'ghi', 'z03', 'hij', 'pqr', 'z02', 'klm', 'z04'].sort()
+    );
+  });
+
+  it('detects when final carry z-wire is swapped', () => {
+    const gates = makeNBitAdder(4);
