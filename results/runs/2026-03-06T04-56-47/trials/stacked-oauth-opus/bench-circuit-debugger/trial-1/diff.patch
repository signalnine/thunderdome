+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+/**
+ * Simulate a logic gate circuit. Process gates in dependency order,
+ * returning final values of all wires.
+ */
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+
+  let progress = true;
+  while (remaining.length > 0 && progress) {
+    progress = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        switch (gate.op) {
+          case 'AND':
+            wires[gate.out] = a & b;
+            break;
+          case 'OR':
+            wires[gate.out] = a | b;
+            break;
+          case 'XOR':
+            wires[gate.out] = a ^ b;
+            break;
+        }
+        remaining.splice(i, 1);
+        progress = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+/**
+ * Find the 8 wires involved in 4 output-wire swaps in a broken ripple-carry adder.
+ *
+ * Uses rule-based structural analysis. Each gate in a correct ripple-carry adder
+ * must satisfy specific constraints about its output's role and usage pattern.
+ * Violations of these constraints identify the swapped wires.
+ */
+export function findSwappedWires(gates: Gate[]): string[] {
+  // Work on a deep copy
+  const g: Gate[] = gates.map((gate) => ({ ...gate }));
+
+  // Determine number of input bits and the last z-wire
+  let maxBit = 0;
+  for (const gate of g) {
+    for (const wire of [gate.in1, gate.in2]) {
+      const m = wire.match(/^[xy](\d+)$/);
+      if (m) maxBit = Math.max(maxBit, parseInt(m[1], 10));
+    }
+  }
+  const numBits = maxBit + 1;
+  const lastZ = `z${numBits.toString().padStart(2, '0')}`;
+
+  // Build output->gate index
+  const byOut = new Map<string, Gate>();
+  for (const gate of g) byOut.set(gate.out, gate);
+
+  const swapped = new Set<string>();
+
+  function doSwap(wireA: string, wireB: string) {
+    if (wireA === wireB) return;
+    swapped.add(wireA);
+    swapped.add(wireB);
+    const gA = byOut.get(wireA)!;
+    const gB = byOut.get(wireB)!;
+    gA.out = wireB;
+    gB.out = wireA;
+    byOut.set(wireA, gB);
+    byOut.set(wireB, gA);
+  }
+
+  // Find gate by op and inputs (order-independent)
+  function find(op: string, a: string, b: string): Gate | undefined {
+    for (const gate of g) {
+      if (gate.op === op &&
+        ((gate.in1 === a && gate.in2 === b) || (gate.in1 === b && gate.in2 === a)))
+        return gate;
+    }
+    return undefined;
+  }
+
+  // Find XOR gates using a wire as input, excluding x/y-input XOR gates
+  function findNonInputXor(wire: string, exclude?: Gate): Gate | undefined {
+    for (const gate of g) {
+      if (gate.op === 'XOR' && gate !== exclude &&
+          (gate.in1 === wire || gate.in2 === wire) &&
+          !(/^[xy]\d+$/.test(gate.in1) && /^[xy]\d+$/.test(gate.in2))) {
+        return gate;
+      }
+    }
+    return undefined;
+  }
+
+  // Trace the adder structure bit by bit.
+  // At each bit, identify the 5 gates and validate/fix their output wires.
+  let carry = '';
+
+  for (let i = 0; i < numBits; i++) {
+    const xi = `x${i.toString().padStart(2, '0')}`;
+    const yi = `y${i.toString().padStart(2, '0')}`;
+    const zi = `z${i.toString().padStart(2, '0')}`;
+
+    if (i === 0) {
+      // Half adder: x00 XOR y00 -> z00, x00 AND y00 -> carry
+      const xorGate = find('XOR', xi, yi)!;
+      if (xorGate.out !== zi) {
+        doSwap(xorGate.out, zi);
+      }
+      const andGate = find('AND', xi, yi)!;
+      carry = andGate.out;
+    } else {
+      // Full adder:
+      //   xNN XOR yNN -> partialSum
+      //   partialSum XOR carry -> zNN
+      //   xNN AND yNN -> generate
+      //   partialSum AND carry -> propagate
+      //   generate OR propagate -> carryOut
+
+      const xorGate = find('XOR', xi, yi)!;
+      let partialSum = xorGate.out;
+
+      // Try to find sum gate: XOR(partialSum, carry)
+      let sumGate = find('XOR', partialSum, carry);
+
+      if (!sumGate) {
+        // Either partialSum or carry is swapped.
+        // Strategy 1: Find the non-input XOR gate that uses carry
+        const carryXor = findNonInputXor(carry);
+        if (carryXor) {
+          // Found a sum gate using carry. Its other input should be partialSum.
+          const actualPS = carryXor.in1 === carry ? carryXor.in2 : carryXor.in1;
+          doSwap(partialSum, actualPS);
+          partialSum = actualPS;
+          sumGate = carryXor;
+        } else {
+          // No XOR gate uses carry. Carry must be swapped.
+          // Find the non-input XOR gate that uses partialSum
+          const psXor = findNonInputXor(partialSum, xorGate);
+          if (psXor) {
+            const actualCarry = psXor.in1 === partialSum ? psXor.in2 : psXor.in1;
+            doSwap(carry, actualCarry);
+            carry = actualCarry;
+            sumGate = psXor;
+          }
+        }
+      }
+
+      if (sumGate && sumGate.out !== zi) {
+        doSwap(sumGate.out, zi);
+      }
+
+      // Generate: xNN AND yNN
+      const genGate = find('AND', xi, yi)!;
+      const generate = genGate.out;
+
+      // Propagate: partialSum AND carry
+      const propGate = find('AND', partialSum, carry);
+      const propagate = propGate ? propGate.out : '';
+
+      // Carry out: generate OR propagate
+      if (propagate) {
+        const carryGate = find('OR', generate, propagate);
+        if (carryGate) {
+          carry = carryGate.out;
+        } else {
+          // generate or propagate output is swapped
+          // Find the OR gate that uses one of them
+          for (const gate of g) {
+            if (gate.op === 'OR') {
+              if (gate.in1 === generate || gate.in2 === generate) {
+                const wrongProp = gate.in1 === generate ? gate.in2 : gate.in1;
+                doSwap(propagate, wrongProp);
+                carry = gate.out;
+                break;
+              }
+              if (gate.in1 === propagate || gate.in2 === propagate) {
+                const wrongGen = gate.in1 === propagate ? gate.in2 : gate.in1;
+                doSwap(generate, wrongGen);
+                carry = gate.out;
+                break;
+              }
+            }
+          }
+        }
+      }
+    }
+  }
+
+  // Final carry should be the last z-wire
+  if (carry && carry !== lastZ && byOut.has(carry) && byOut.has(lastZ)) {
+    doSwap(carry, lastZ);
+  }
+
+  return [...swapped].sort();
+}
diff --git a/tests/index.test.ts b/tests/index.test.ts
