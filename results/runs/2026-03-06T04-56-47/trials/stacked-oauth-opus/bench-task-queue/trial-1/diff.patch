new file mode 100644
index 0000000..7d55585
--- /dev/null
+++ b/src/types.ts
@@ -0,0 +1,66 @@
+export type TaskStatus =
+  | 'pending'
+  | 'processing'
+  | 'completed'
+  | 'failed'
+  | 'cancelled'
+  | 'blocked';
+
+export interface Task<T = unknown> {
+  id: string;
+  payload: T;
+  status: TaskStatus;
+  queue: string;
+  priority: number;
+  createdAt: Date;
+  availableAt: Date;
+  attempts: number;
+  maxRetries: number;
+  backoffDelay: number;
+  dependencies: string[];
+  progress: number;
+  progressMessage?: string;
+  error?: Error;
+  failCount: number;
+}
+
+export interface TaskOptions {
+  priority?: number;
+  delay?: number;
+  runAt?: Date;
+  maxRetries?: number;
+  backoffDelay?: number;
+  dependencies?: string[];
+}
+
+export interface QueueOptions {
+  concurrency?: number;
+}
+
+export interface ShutdownResult {
+  completed: number;
+  forceCancelled: number;
+  duration: number;
+}
+
+export interface ProgressInfo {
+  progress: number;
+  message?: string;
+}
+
+export type ProgressListener = (info: ProgressInfo) => void;
+
+export type Middleware = (
+  task: Task,
+  next: () => Promise<void>
+) => Promise<void> | void;
+
+export interface Schedule {
+  id: string;
+  cron: string;
+  queue: string;
+  payload: unknown;
+  lastRun?: Date;
+}
+
+export type CronExpression = string;
