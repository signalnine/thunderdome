@@ -0,0 +1,161 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { createMarketplace } from '../src/index.js';
+import type { Marketplace } from '../src/index.js';
+import type { PluginManifest } from '../src/types.js';
+
+function makeManifest(overrides: Partial<PluginManifest> = {}): PluginManifest {
+  return {
+    name: 'test-plugin',
+    version: '1.0.0',
+    description: 'A test plugin',
+    author: 'tester',
+    dependencies: {},
+    entryPoint: '"hello from plugin"',
+    permissions: [],
+    ...overrides,
+  };
+}
+
+describe('createMarketplace', () => {
+  let marketplace: Marketplace;
+
+  beforeEach(() => {
+    marketplace = createMarketplace();
+  });
+
+  it('should expose all services', () => {
+    expect(marketplace.registry).toBeDefined();
+    expect(marketplace.resolver).toBeDefined();
+    expect(marketplace.runner).toBeDefined();
+    expect(marketplace.reviews).toBeDefined();
+    expect(marketplace.deps).toBeDefined();
+    expect(marketplace.installPlugin).toBeDefined();
+  });
+
+  it('should install a simple plugin', async () => {
+    const result = await marketplace.installPlugin(makeManifest());
+    expect(result.resolvedDependencies).toHaveLength(0);
+    expect(result.executionResult.success).toBe(true);
+    expect(result.executionResult.output).toBe('hello from plugin');
+  });
+
+  it('should register plugin during install', async () => {
+    await marketplace.installPlugin(makeManifest());
+    const plugin = marketplace.registry.get('test-plugin');
+    expect(plugin).not.toBeNull();
+    expect(plugin!.name).toBe('test-plugin');
+  });
+
+  it('should reject plugin without name', async () => {
+    await expect(
+      marketplace.installPlugin(makeManifest({ name: '' }))
+    ).rejects.toThrow('name');
+  });
+
+  it('should reject plugin without version', async () => {
+    await expect(
+      marketplace.installPlugin(makeManifest({ version: '' }))
+    ).rejects.toThrow('version');
+  });
+
+  it('should reject plugin without entryPoint', async () => {
+    await expect(
+      marketplace.installPlugin(makeManifest({ entryPoint: '' }))
+    ).rejects.toThrow('entryPoint');
+  });
+
+  it('should resolve dependencies during install', async () => {
+    // Register a dependency first
+    marketplace.registry.register(
+      makeManifest({ name: 'dep-a', version: '1.0.0' })
+    );
+    marketplace.registry.register(
+      makeManifest({ name: 'dep-a', version: '1.1.0' })
+    );
+
+    const result = await marketplace.installPlugin(
+      makeManifest({
+        name: 'my-plugin',
+        dependencies: { 'dep-a': '^1.0.0' },
+      })
+    );
+
+    expect(result.resolvedDependencies).toHaveLength(1);
+    expect(result.resolvedDependencies[0].name).toBe('dep-a');
+    expect(result.resolvedDependencies[0].version).toBe('1.1.0');
+  });
+
+  it('should reject if dependency is not registered', async () => {
+    await expect(
+      marketplace.installPlugin(
+        makeManifest({
+          name: 'my-plugin',
+          dependencies: { 'missing-dep': '^1.0.0' },
+        })
+      )
+    ).rejects.toThrow('missing-dep');
+  });
+
+  it('should reject circular dependencies', async () => {
+    // Register plugin-a depends on plugin-b
+    marketplace.registry.register(
+      makeManifest({
+        name: 'plugin-a',
+        version: '1.0.0',
+        dependencies: { 'plugin-b': '^1.0.0' },
+      })
+    );
+
+    // Now try to install plugin-b which depends on plugin-a
+    await expect(
+      marketplace.installPlugin(
+        makeManifest({
+          name: 'plugin-b',
+          version: '1.0.0',
+          dependencies: { 'plugin-a': '^1.0.0' },
+        })
+      )
+    ).rejects.toThrow('Circular');
+  });
+
+  it('should handle plugin code that returns results', async () => {
+    const result = await marketplace.installPlugin(
+      makeManifest({ entryPoint: '2 + 2' })
+    );
+    expect(result.executionResult.success).toBe(true);
+    expect(result.executionResult.output).toBe(4);
+  });
+
+  it('should handle plugin code that throws', async () => {
+    const result = await marketplace.installPlugin(
+      makeManifest({ entryPoint: 'throw new Error("plugin failed")' })
+    );
+    expect(result.executionResult.success).toBe(false);
+    expect(result.executionResult.error).toBe('plugin failed');
+  });
+
+  it('should clean up registration on circular dependency rejection', async () => {
+    marketplace.registry.register(
+      makeManifest({
+        name: 'plugin-a',
+        version: '1.0.0',
+        dependencies: { 'plugin-b': '^1.0.0' },
+      })
+    );
+
+    try {
+      await marketplace.installPlugin(
+        makeManifest({
+          name: 'plugin-b',
+          version: '1.0.0',
+          dependencies: { 'plugin-a': '^1.0.0' },
+        })
+      );
+    } catch {
+      // expected
+    }
+
+    // plugin-b should have been removed from registry
+    expect(marketplace.registry.get('plugin-b')).toBeNull();
+  });
+});
