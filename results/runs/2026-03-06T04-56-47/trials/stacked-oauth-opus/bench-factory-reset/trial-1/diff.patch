@@ -0,0 +1,236 @@
+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter } from './index.js';
+import type { Machine } from './index.js';
+
+// Helper: verify a toggle solution is correct
+function verifyToggle(machine: Machine, pressed: number[]): boolean {
+  const state = new Array(machine.target.length).fill(false);
+  for (const btn of pressed) {
+    for (const light of machine.buttons[btn]) {
+      state[light] = !state[light];
+    }
+  }
+  return state.every((v, i) => v === machine.target[i]);
+}
+
+// Helper: verify a counter solution is correct
+function verifyCounter(
+  target: number[],
+  buttons: number[][],
+  modulus: number,
+  presses: number[]
+): boolean {
+  const state = new Array(target.length).fill(0);
+  for (let btn = 0; btn < buttons.length; btn++) {
+    for (const counter of buttons[btn]) {
+      state[counter] = (state[counter] + presses[btn]) % modulus;
+    }
+  }
+  return state.every((v, i) => v === target[i]);
+}
+
+describe('solveToggle', () => {
+  it('should return empty array when target is all off', () => {
+    const result = solveToggle({
+      target: [false, false, false],
+      buttons: [[0, 1], [1, 2]],
+    });
+    expect(result).toEqual([]);
+  });
+
+  it('should return null when no solution exists (example from spec)', () => {
+    const result = solveToggle({
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]],
+    });
+    expect(result).toBeNull();
+  });
+
+  it('should solve a simple single-button case', () => {
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [[0, 1]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0]);
+    expect(verifyToggle(machine, result!)).toBe(true);
+  });
+
+  it('should solve a two-button case', () => {
+    const machine: Machine = {
+      target: [true, false, true],
+      buttons: [[0], [2]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0, 1]);
+    expect(verifyToggle(machine, result!)).toBe(true);
+  });
+
+  it('should find minimum presses', () => {
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [[0, 1], [0], [1]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0]);
+    expect(verifyToggle(machine, result!)).toBe(true);
+  });
+
+  it('should return lexicographically smallest when tied on count', () => {
+    const machine: Machine = {
+      target: [true],
+      buttons: [[0], [0]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0]);
+    expect(verifyToggle(machine, result!)).toBe(true);
+  });
+
+  it('should handle no buttons with non-trivial target', () => {
+    expect(solveToggle({ target: [true], buttons: [] })).toBeNull();
+  });
+
+  it('should handle no buttons with all-off target', () => {
+    expect(solveToggle({ target: [false, false], buttons: [] })).toEqual([]);
+  });
+
+  it('should handle larger puzzle', () => {
+    // 6 lights, 4 buttons
+    const machine: Machine = {
+      target: [true, true, true, true, true, true],
+      buttons: [
+        [0, 1, 2],    // Button 0
+        [3, 4, 5],    // Button 1
+        [0, 3],       // Button 2
+        [1, 4],       // Button 3
+      ],
+    };
+    const result = solveToggle(machine);
+    if (result !== null) {
+      expect(verifyToggle(machine, result)).toBe(true);
+    }
+  });
+
+  it('should handle buttons that affect no lights', () => {
+    const machine: Machine = {
+      target: [true],
+      buttons: [[0], []],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0]);
+    expect(verifyToggle(machine, result!)).toBe(true);
+  });
+
+  it('should handle overlapping buttons correctly', () => {
+    // Buttons that cancel each other out
+    const machine: Machine = {
+      target: [false, true],
+      buttons: [[0, 1], [0]],
+    };
+    const result = solveToggle(machine);
+    expect(result).not.toBeNull();
+    expect(verifyToggle(machine, result!)).toBe(true);
+    // Pressing both: [0,1] toggle then [0] toggle → [false, true]. Correct!
+    expect(result).toEqual([0, 1]);
+  });
+
+  it('should prefer fewer buttons pressed', () => {
+    // 3 lights, 4 buttons. Multiple solutions possible.
+    const machine: Machine = {
+      target: [true, true, true],
+      buttons: [
+        [0, 1, 2],  // Button 0: all three
+        [0],         // Button 1
+        [1],         // Button 2
+        [2],         // Button 3
+      ],
+    };
+    const result = solveToggle(machine);
+    // Button 0 alone does it (1 press vs 3 presses for buttons 1+2+3)
+    expect(result).toEqual([0]);
+    expect(verifyToggle(machine, result!)).toBe(true);
+  });
+});
+
+describe('solveCounter', () => {
+  it('should return array of zeros when target is all 0', () => {
+    expect(solveCounter([0, 0, 0], [[0, 1], [1, 2]], 5)).toEqual([0, 0]);
+  });
+
+  it('should solve a simple single-button case', () => {
+    const result = solveCounter([3, 3], [[0, 1]], 5);
+    expect(result).toEqual([3]);
+    expect(verifyCounter([3, 3], [[0, 1]], 5, result!)).toBe(true);
+  });
+
+  it('should return null when no solution exists', () => {
+    expect(solveCounter([1, 1], [[0]], 3)).toBeNull();
+  });
+
+  it('should find minimum total presses with lex tiebreaking', () => {
+    const result = solveCounter([1], [[0], [0]], 5);
+    expect(result).toEqual([0, 1]);
+    expect(verifyCounter([1], [[0], [0]], 5, result!)).toBe(true);
+  });
+
+  it('should handle modular arithmetic', () => {
+    const result = solveCounter([2], [[0]], 3);
+    expect(result).toEqual([2]);
+    expect(verifyCounter([2], [[0]], 3, result!)).toBe(true);
+  });
+
+  it('should handle empty buttons with zero target', () => {
+    expect(solveCounter([0, 0], [], 5)).toEqual([]);
+  });
+
+  it('should handle empty buttons with non-zero target', () => {
+    expect(solveCounter([1], [], 5)).toBeNull();
+  });
+
+  it('should find lex smallest when tied on total', () => {
+    const result = solveCounter([2, 2], [[0, 1], [0, 1]], 5);
+    expect(result).toEqual([0, 2]);
+    expect(verifyCounter([2, 2], [[0, 1], [0, 1]], 5, result!)).toBe(true);
+  });
+
+  it('should handle mod 2 (matching toggle behavior)', () => {
+    // In mod 2, pressing 1 time is same as toggle
+    const result = solveCounter([1, 1, 0], [[0, 1], [1, 2]], 2);
+    if (result !== null) {
+      expect(verifyCounter([1, 1, 0], [[0, 1], [1, 2]], 2, result!)).toBe(true);
+    }
+  });
+
+  it('should handle larger modulus', () => {
+    // mod 97, button 0 affects counter 0
+    const result = solveCounter([50], [[0]], 97);
+    expect(result).toEqual([50]);
+    expect(verifyCounter([50], [[0]], 97, result!)).toBe(true);
+  });
+
+  it('should prefer using modular inverse for minimum presses', () => {
+    // mod 5, button 0 affects counter 0
+    // Target: [4]. Press 4 times (total=4) vs press 4 times (only option)
+    const result = solveCounter([4], [[0]], 5);
+    expect(result).toEqual([4]);
+    expect(verifyCounter([4], [[0]], 5, result!)).toBe(true);
+  });
+
+  it('should handle multiple counters with independent buttons', () => {
+    const lights = [1, 2, 3];
+    const buttons = [[0], [1], [2]];
+    const result = solveCounter(lights, buttons, 5);
+    expect(result).toEqual([1, 2, 3]);
+    expect(verifyCounter(lights, buttons, 5, result!)).toBe(true);
+  });
+
+  it('should handle overlapping buttons in counter mode', () => {
+    // 2 counters, 2 buttons, mod 7
+    // Button 0 affects [0, 1], button 1 affects [1]
+    // Target: [3, 5]
+    // Need: b0 = 3 (from counter 0), b0 + b1 = 5 (mod 7) → b1 = 2
+    const result = solveCounter([3, 5], [[0, 1], [1]], 7);
+    expect(result).toEqual([3, 2]);
+    expect(verifyCounter([3, 5], [[0, 1], [1]], 7, result!)).toBe(true);
+  });
+});
