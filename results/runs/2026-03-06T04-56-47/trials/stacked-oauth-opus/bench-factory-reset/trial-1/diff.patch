+++ b/src/index.ts
@@ -0,0 +1,414 @@
+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+function modInverse(a: number, p: number): number {
+  let [old_r, r] = [((a % p) + p) % p, p];
+  let [old_s, s] = [1, 0];
+  while (r !== 0) {
+    const q = Math.floor(old_r / r);
+    [old_r, r] = [r, old_r - q * r];
+    [old_s, s] = [s, old_s - q * s];
+  }
+  return ((old_s % p) + p) % p;
+}
+
+function mod(a: number, p: number): number {
+  return ((a % p) + p) % p;
+}
+
+interface GaussResult {
+  rref: number[][];
+  pivotCols: number[];
+  pivotRows: number[];
+  rank: number;
+}
+
+function gaussianElimination(
+  augmented: number[][],
+  numRows: number,
+  numCols: number,
+  p: number
+): GaussResult {
+  const mat = augmented.map(row => [...row]);
+  const pivotCols: number[] = [];
+  const pivotRows = new Array(numCols).fill(-1);
+
+  let row = 0;
+  for (let col = 0; col < numCols && row < numRows; col++) {
+    let pivotRow = -1;
+    for (let r = row; r < numRows; r++) {
+      if (mat[r][col] !== 0) {
+        pivotRow = r;
+        break;
+      }
+    }
+    if (pivotRow === -1) continue;
+
+    [mat[row], mat[pivotRow]] = [mat[pivotRow], mat[row]];
+
+    const inv = modInverse(mat[row][col], p);
+    for (let j = col; j <= numCols; j++) {
+      mat[row][j] = mod(mat[row][j] * inv, p);
+    }
+
+    for (let r = 0; r < numRows; r++) {
+      if (r === row || mat[r][col] === 0) continue;
+      const factor = mat[r][col];
+      for (let j = col; j <= numCols; j++) {
+        mat[r][j] = mod(mat[r][j] - factor * mat[row][j], p);
+      }
+    }
+
+    pivotCols.push(col);
+    pivotRows[col] = row;
+    row++;
+  }
+
+  return { rref: mat, pivotCols, pivotRows, rank: pivotCols.length };
+}
+
+type Comparator = (a: number[], b: number[]) => boolean;
+
+function lexSmaller(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return false;
+}
+
+function lexLarger(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] > b[i]) return true;
+    if (a[i] < b[i]) return false;
+  }
+  return false;
+}
+
+interface PivotDep {
+  col: number;
+  rhs: number;
+  freeCoeffs: number[];
+}
+
+function findOptimalSolution(
+  gauss: GaussResult,
+  numRows: number,
+  numCols: number,
+  p: number,
+  isBetter: Comparator
+): number[] | null {
+  const { rref, pivotCols, pivotRows, rank } = gauss;
+
+  for (let r = rank; r < numRows; r++) {
+    if (rref[r][numCols] !== 0) {
+      return null;
+    }
+  }
+
+  const isPivotSet = new Set(pivotCols);
+  const freeVars: number[] = [];
+  for (let col = 0; col < numCols; col++) {
+    if (!isPivotSet.has(col)) {
+      freeVars.push(col);
+    }
+  }
+
+  const numFree = freeVars.length;
+
+  if (numFree === 0) {
+    const solution = new Array(numCols).fill(0);
+    for (let i = 0; i < rank; i++) {
+      solution[pivotCols[i]] = rref[i][numCols];
+    }
+    return solution;
+  }
+
+  const pivotInfo: PivotDep[] = [];
+  for (const col of pivotCols) {
+    const r = pivotRows[col];
+    const freeCoeffs: number[] = freeVars.map(fc => rref[r][fc]);
+    pivotInfo.push({ col, rhs: rref[r][numCols], freeCoeffs });
+  }
+
+  // Direct enumeration threshold: 2^22 for p=2, general for other p
+  const totalCombinations = Math.pow(p, numFree);
+
+  if (totalCombinations <= 8_000_000) {
+    return enumerateFreeVars(numCols, pivotInfo, freeVars, p, isBetter);
+  }
+
+  if (p === 2) {
+    return meetInTheMiddleGF2(numCols, pivotInfo, freeVars, isBetter);
+  }
+
+  return enumerateFreeVars(numCols, pivotInfo, freeVars, p, isBetter);
+}
+
+function enumerateFreeVars(
+  numCols: number,
+  pivotInfo: PivotDep[],
+  freeVars: number[],
+  p: number,
+  isBetter: Comparator
+): number[] | null {
+  const numFree = freeVars.length;
+  const totalCombinations = Math.pow(p, numFree);
+
+  let bestSolution: number[] | null = null;
+  let bestTotal = Infinity;
+
+  const freeValues = new Array(numFree).fill(0);
+
+  for (let combo = 0; combo < totalCombinations; combo++) {
+    const solution = new Array(numCols).fill(0);
+    let total = 0;
+
+    for (let i = 0; i < numFree; i++) {
+      solution[freeVars[i]] = freeValues[i];
+      total += freeValues[i];
+    }
+
+    for (const pi of pivotInfo) {
+      let val = pi.rhs;
+      for (let i = 0; i < numFree; i++) {
+        val = mod(val - pi.freeCoeffs[i] * freeValues[i], p);
+      }
+      solution[pi.col] = val;
+      total += val;
+    }
+
+    if (total < bestTotal || (total === bestTotal && bestSolution && isBetter(solution, bestSolution))) {
+      bestTotal = total;
+      bestSolution = solution;
+    }
+
+    for (let i = numFree - 1; i >= 0; i--) {
+      freeValues[i]++;
+      if (freeValues[i] < p) break;
+      freeValues[i] = 0;
+    }
+  }
+
+  return bestSolution;
+}
+
+/**
+ * Meet-in-the-middle for GF(2) when free variables are too many to enumerate.
+ *
+ * Strategy:
+ * Split free vars into two halves A and B. For each A assignment, compute
+ * a "signature" = (partialPivotBitmask, freePressCount). Group by signature.
+ * For each B assignment, compute the complementary target and find the best A
+ * match. Use a precomputed lookup table indexed by target bitmask to avoid
+ * iterating over all A entries for each B.
+ */
+function meetInTheMiddleGF2(
+  numCols: number,
+  pivotInfo: PivotDep[],
+  freeVars: number[],
+  isBetter: Comparator
+): number[] | null {
+  const numFree = freeVars.length;
+  const halfA = Math.floor(numFree / 2);
+  const halfB = numFree - halfA;
+  const numPivots = pivotInfo.length;
+
+  const halfASize = 1 << halfA;
+  const halfBSize = 1 << halfB;
+  const pivotSpace = 1 << numPivots;
+
+  // Phase 1: Build A-side lookup table
+  // For each partialBitmaskA, store the minimum freePressCount and corresponding mask.
+  // Then build a precomputed table: for each target t ∈ {0..pivotSpace-1},
+  // the minimum (freePressCountA + popcount(partialBitmaskA XOR t)) and the A mask that achieves it.
+
+  // Step 1a: Compute all A entries
+  const aPartialBitmasks = new Int32Array(halfASize);
+  const aFreeCounts = new Int32Array(halfASize);
+
+  for (let mask = 0; mask < halfASize; mask++) {
+    let partial = 0;
+    for (let j = 0; j < numPivots; j++) {
+      let bit = 0;
+      for (let i = 0; i < halfA; i++) {
+        if ((mask >> i) & 1) {
+          bit ^= pivotInfo[j].freeCoeffs[i];
+        }
+      }
+      partial |= (bit << j);
+    }
+    aPartialBitmasks[mask] = partial;
+    aFreeCounts[mask] = popcount(mask);
+  }
+
+  // Step 1b: Group by partialBitmask, keep minimum freePressCount per partialBitmask
+  const bestCostPerPartial = new Int32Array(pivotSpace).fill(127);
+  const bestMaskPerPartial = new Int32Array(pivotSpace).fill(-1);
+
+  for (let mask = 0; mask < halfASize; mask++) {
+    const partial = aPartialBitmasks[mask];
+    const cost = aFreeCounts[mask];
+    if (cost < bestCostPerPartial[partial]) {
+      bestCostPerPartial[partial] = cost;
+      bestMaskPerPartial[partial] = mask;
+    }
+  }
+
+  // Step 1c: Precompute lookup: for each target t, find the best
+  // (minCostA + popcount(partialA XOR t)) and corresponding A mask.
+  const bestTotalForTarget = new Int32Array(pivotSpace).fill(127);
+  const bestAMaskForTarget = new Int32Array(pivotSpace).fill(-1);
+  const bestAPartialForTarget = new Int32Array(pivotSpace).fill(-1);
+
+  for (let partial = 0; partial < pivotSpace; partial++) {
+    if (bestCostPerPartial[partial] > 100) continue; // no entry
+    const costA = bestCostPerPartial[partial];
+    const aMask = bestMaskPerPartial[partial];
+
+    for (let t = 0; t < pivotSpace; t++) {
+      const pivotCost = popcount(partial ^ t);
+      const totalA = costA + pivotCost;
+      if (totalA < bestTotalForTarget[t]) {
+        bestTotalForTarget[t] = totalA;
+        bestAMaskForTarget[t] = aMask;
+        bestAPartialForTarget[t] = partial;
+      }
+    }
+  }
+
+  // Compute rhs bitmask
+  let rhsBitmask = 0;
+  for (let j = 0; j < numPivots; j++) {
+    rhsBitmask |= (pivotInfo[j].rhs << j);
+  }
+
+  // Phase 2: Enumerate B side and combine
+  let bestSolution: number[] | null = null;
+  let bestTotal = Infinity;
+
+  for (let maskB = 0; maskB < halfBSize; maskB++) {
+    let partialB = 0;
+    for (let j = 0; j < numPivots; j++) {
+      let bit = 0;
+      for (let i = 0; i < halfB; i++) {
+        if ((maskB >> i) & 1) {
+          bit ^= pivotInfo[j].freeCoeffs[halfA + i];
+        }
+      }
+      partialB |= (bit << j);
+    }
+
+    const costB = popcount(maskB);
+    const target = rhsBitmask ^ partialB;
+
+    const totalAContrib = bestTotalForTarget[target];
+    const total = totalAContrib + costB;
+
+    if (total > bestTotal) continue;
+
+    const maskA = bestAMaskForTarget[target];
+    const partialA = bestAPartialForTarget[target];
+
+    // Reconstruct solution
+    const solution = new Array(numCols).fill(0);
+    for (let i = 0; i < halfA; i++) {
+      if ((maskA >> i) & 1) {
+        solution[freeVars[i]] = 1;
+      }
+    }
+    for (let i = 0; i < halfB; i++) {
+      if ((maskB >> i) & 1) {
+        solution[freeVars[halfA + i]] = 1;
+      }
+    }
+    const pivotBits = target ^ partialA;
+    for (let j = 0; j < numPivots; j++) {
+      solution[pivotInfo[j].col] = (pivotBits >> j) & 1;
+    }
+
+    if (total < bestTotal || (total === bestTotal && bestSolution && isBetter(solution, bestSolution))) {
+      bestTotal = total;
+      bestSolution = solution;
+    }
+  }
+
+  return bestSolution;
+}
+
+function popcount(n: number): number {
+  let count = 0;
+  let v = n;
+  while (v) {
+    count += v & 1;
+    v >>>= 1;
+  }
+  return count;
+}
+
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const numLights = target.length;
+  const numButtons = buttons.length;
+
+  if (numButtons === 0) {
+    return target.every(t => !t) ? [] : null;
+  }
+
+  const buttonSets = buttons.map(b => new Set(b));
+  const augmented: number[][] = [];
+  for (let light = 0; light < numLights; light++) {
+    const row = new Array(numButtons + 1).fill(0);
+    for (let btn = 0; btn < numButtons; btn++) {
+      if (buttonSets[btn].has(light)) {
+        row[btn] = 1;
+      }
+    }
+    row[numButtons] = target[light] ? 1 : 0;
+    augmented.push(row);
+  }
+
+  const gauss = gaussianElimination(augmented, numLights, numButtons, 2);
+  const solution = findOptimalSolution(gauss, numLights, numButtons, 2, lexLarger);
+
+  if (!solution) return null;
+
+  const pressed: number[] = [];
+  for (let i = 0; i < numButtons; i++) {
+    if (solution[i] === 1) {
+      pressed.push(i);
+    }
+  }
+  return pressed;
+}
+
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numCounters = lights.length;
+  const numButtons = buttons.length;
+
+  if (numButtons === 0) {
+    return lights.every(l => l === 0) ? [] : null;
+  }
+
+  const buttonSets = buttons.map(b => new Set(b));
+  const augmented: number[][] = [];
+  for (let counter = 0; counter < numCounters; counter++) {
+    const row = new Array(numButtons + 1).fill(0);
+    for (let btn = 0; btn < numButtons; btn++) {
+      if (buttonSets[btn].has(counter)) {
+        row[btn] = 1;
+      }
+    }
+    row[numButtons] = mod(lights[counter], modulus);
+    augmented.push(row);
+  }
+
+  const gauss = gaussianElimination(augmented, numCounters, numButtons, modulus);
+  return findOptimalSolution(gauss, numCounters, numButtons, modulus, lexSmaller);
+}
