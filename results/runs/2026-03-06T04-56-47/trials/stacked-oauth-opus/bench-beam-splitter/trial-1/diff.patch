+++ b/src/index.ts
@@ -0,0 +1,170 @@
+type Direction = 'down' | 'down-left' | 'down-right';
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+function findSource(grid: string[][]): [number, number] | null {
+  for (let c = 0; c < grid[0].length; c++) {
+    if (grid[0][c] === 'S') return [0, c];
+  }
+  return null;
+}
+
+function advance(row: number, col: number, dir: Direction): [number, number] {
+  switch (dir) {
+    case 'down':       return [row + 1, col];
+    case 'down-left':  return [row + 1, col - 1];
+    case 'down-right': return [row + 1, col + 1];
+  }
+}
+
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+/**
+ * Trace a beam from a starting position in a given direction.
+ * Returns the list of cells visited (including start) and whether it
+ * hit a splitter (and if so, the splitter's position).
+ */
+function traceBeam(
+  grid: string[][],
+  startRow: number,
+  startCol: number,
+  dir: Direction,
+): { visited: [number, number][]; hitSplitter: [number, number] | null } {
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const visited: [number, number][] = [];
+
+  let r = startRow;
+  let c = startCol;
+
+  // The start cell is the cell we begin moving FROM (already visited elsewhere)
+  // We advance step by step in direction `dir`.
+  for (;;) {
+    const [nr, nc] = advance(r, c, dir);
+    if (!inBounds(nr, nc, rows, cols)) {
+      return { visited, hitSplitter: null };
+    }
+    visited.push([nr, nc]);
+    if (grid[nr][nc] === '^') {
+      return { visited, hitSplitter: [nr, nc] };
+    }
+    r = nr;
+    c = nc;
+  }
+}
+
+export function countBeamCells(grid: string[][]): number {
+  if (grid.length === 0 || grid[0].length === 0) return 0;
+
+  const source = findSource(grid);
+  if (!source) return 0;
+
+  const visitedSet = new Set<string>();
+  const key = (r: number, c: number) => `${r},${c}`;
+
+  // Mark source as visited
+  visitedSet.add(key(source[0], source[1]));
+
+  // BFS/queue of beams to process
+  // Each beam starts from a cell and moves in a direction
+  const queue: Beam[] = [{ row: source[0], col: source[1], dir: 'down' }];
+
+  // Track which (splitter, direction) combos we've already processed to avoid
+  // infinite work (though splitters only send beams downward, so no cycles possible)
+  const processed = new Set<string>();
+
+  while (queue.length > 0) {
+    const beam = queue.pop()!;
+    const result = traceBeam(grid, beam.row, beam.col, beam.dir);
+
+    for (const [r, c] of result.visited) {
+      visitedSet.add(key(r, c));
+    }
+
+    if (result.hitSplitter) {
+      const [sr, sc] = result.hitSplitter;
+      // Splitter sends beams down-left and down-right
+      for (const newDir of ['down-left', 'down-right'] as Direction[]) {
+        const pkey = `${sr},${sc},${newDir}`;
+        if (!processed.has(pkey)) {
+          processed.add(pkey);
+          queue.push({ row: sr, col: sc, dir: newDir });
+        }
+      }
+    }
+  }
+
+  return visitedSet.size;
+}
+
+/**
+ * For path counting, we build a DAG of splitters.
+ *
+ * From the source, the beam goes down. It either exits (1 path) or hits a splitter.
+ * When it hits a splitter, it splits into down-left and down-right.
+ * Each of those either exits (1 path) or hits another splitter.
+ *
+ * pathsFrom(splitter) = pathsFromDir(splitter, down-left) + pathsFromDir(splitter, down-right)
+ * pathsFromDir(pos, dir) = if exits grid: 1n, if hits splitter S: pathsFrom(S)
+ *
+ * Since beams always move downward (row increases), there are no cycles,
+ * so this is a proper DAG and memoization works.
+ */
+export function countBeamPaths(grid: string[][]): bigint {
+  if (grid.length === 0 || grid[0].length === 0) return 0n;
+
+  const source = findSource(grid);
+  if (!source) return 0n;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+
+  // Memoize: for a given (row, col, direction), how many paths emerge?
+  const memo = new Map<string, bigint>();
+
+  function pathsFromDir(row: number, col: number, dir: Direction): bigint {
+    const mkey = `${row},${col},${dir}`;
+    if (memo.has(mkey)) return memo.get(mkey)!;
+
+    // Trace beam from (row, col) in direction dir
+    let r = row;
+    let c = col;
+    for (;;) {
+      const [nr, nc] = advance(r, c, dir);
+      if (!inBounds(nr, nc, rows, cols)) {
+        memo.set(mkey, 1n);
+        return 1n;
+      }
+      if (grid[nr][nc] === '^') {
+        const result = pathsFromSplitter(nr, nc);
+        memo.set(mkey, result);
+        return result;
+      }
+      r = nr;
+      c = nc;
+    }
+  }
+
+  function pathsFromSplitter(row: number, col: number): bigint {
+    const skey = `splitter:${row},${col}`;
+    if (memo.has(skey)) return memo.get(skey)!;
+
+    // Prevent infinite recursion (shouldn't happen since rows always increase)
+    memo.set(skey, 0n); // placeholder
+
+    const left = pathsFromDir(row, col, 'down-left');
+    const right = pathsFromDir(row, col, 'down-right');
+    const total = left + right;
+    memo.set(skey, total);
+    return total;
+  }
+
+  // Start: beam goes down from source
+  return pathsFromDir(source[0], source[1], 'down');
+}
