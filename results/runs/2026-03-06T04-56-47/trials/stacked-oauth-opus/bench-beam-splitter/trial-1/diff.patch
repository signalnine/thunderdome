+import { describe, it, expect } from 'vitest';
+import { countBeamCells, countBeamPaths } from './index.js';
+
+describe('countBeamCells', () => {
+  it('example 1: single splitter', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(5);
+  });
+
+  it('example 2: two splitters on row 2', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(6);
+  });
+
+  it('no splitters - straight beam', () => {
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  it('empty grid', () => {
+    expect(countBeamCells([])).toBe(0);
+  });
+
+  it('source only - 1 row', () => {
+    const grid = [['S']];
+    expect(countBeamCells(grid)).toBe(1);
+  });
+
+  it('beam exits left boundary', () => {
+    const grid = [
+      ['S', '.', '.'],
+      ['^', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    // Source (0,0), down to (1,0) hits splitter
+    // down-left: (2,-1) absorbed, down-right: (2,1)
+    // Visited: (0,0), (1,0), (2,1) = 3
+    expect(countBeamCells(grid)).toBe(3);
+  });
+});
+
+describe('countBeamPaths', () => {
+  it('example 1: single splitter', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it('example 2: two splitters on row 2', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(4n);
+  });
+
+  it('no splitters - straight beam', () => {
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('empty grid', () => {
+    expect(countBeamPaths([])).toBe(0n);
+  });
+
+  it('source only - 1 row', () => {
+    const grid = [['S']];
+    // Beam goes down from row 0, exits immediately
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('chain of splitters - exponential paths', () => {
+    // 3 splitters in a chain, each splitting into two that each hit next splitter
+    // Actually let's make a simpler chain: each splitter's right beam hits next splitter
+    const grid = [
+      ['.', '.', 'S', '.', '.'],
+      ['.', '.', '^', '.', '.'],
+      ['.', '.', '.', '^', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    // Source at (0,2), down to (1,2) = splitter
+    // Left: (2,1) no splitter, exits at (3,1) -> 1 path
+    // Right: (2,3) = splitter
+    //   Left: (3,2) -> 1 path
+    //   Right: (3,4) -> 1 path
+    // Total: 1 + 2 = 3 paths
+    expect(countBeamPaths(grid)).toBe(3n);
+  });
+
+  it('large grid performance test', () => {
+    // 200x200 grid with ~50 splitters
+    const rows = 200;
+    const cols = 200;
+    const grid: string[][] = [];
+    for (let r = 0; r < rows; r++) {
+      grid.push(new Array(cols).fill('.'));
+    }
+    grid[0][100] = 'S';
+    // Place splitters at various positions
+    for (let i = 0; i < 50; i++) {
+      const row = 4 * (i + 1); // rows 4, 8, 12, ... 200 (but 200 is out of bounds)
+      if (row < rows) {
+        grid[row][100] = '^';
+      }
+    }
+    // This should complete in under 5 seconds
+    const start = Date.now();
+    const paths = countBeamPaths(grid);
+    const cells = countBeamCells(grid);
+    const elapsed = Date.now() - start;
+    expect(elapsed).toBeLessThan(5000);
+    expect(paths).toBeGreaterThan(0n);
+    expect(cells).toBeGreaterThan(0);
+  });
+});
