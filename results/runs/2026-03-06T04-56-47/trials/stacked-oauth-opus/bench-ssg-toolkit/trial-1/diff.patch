+++ b/src/plugins/dev-server.ts
@@ -0,0 +1,47 @@
+import type { Plugin, BuildContext } from '../core/types.js';
+
+interface Route {
+  path: string;
+  handler: string;
+}
+
+export function createDevServerPlugin(): Plugin {
+  return {
+    name: 'dev-server',
+    version: '1.0.0',
+    dependencies: ['asset-pipeline', 'search-index'],
+    hooks: {
+      afterBuild(ctx: BuildContext): void {
+        const routes: Route[] = [];
+
+        // Add static content routes for HTML files
+        for (const path of ctx.output.keys()) {
+          if (path.endsWith('.html')) {
+            routes.push({ path: `/${path}`, handler: 'static' });
+          }
+        }
+
+        // Add asset routes from asset-pipeline manifest
+        const manifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;
+        const assetPaths: string[] = manifest ? [...manifest.assets] : [];
+
+        for (const asset of assetPaths) {
+          routes.push({ path: `/assets/${asset}`, handler: 'asset' });
+        }
+
+        // Add search index route if present
+        const searchIndexPath = '/search-index.json';
+        if (ctx.output.has('search-index.json')) {
+          routes.push({ path: searchIndexPath, handler: 'json' });
+        }
+
+        ctx.data.set('dev-server-config', {
+          port: 3000,
+          routes,
+          assetPaths,
+          searchIndexPath,
+        });
+      },
+    },
+  };
+}
diff --git a/src/plugins/markdown-ext.ts b/src/plugins/markdown-ext.ts
new file mode 100644
index 0000000..7f26c2e
--- /dev/null
+++ b/src/plugins/markdown-ext.ts
@@ -0,0 +1,83 @@
+import type { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file: ContentFile, _ctx: BuildContext): ContentFile {
+        let content = file.content;
+
+        // Process admonition containers before markdown conversion
+        // :::type\ncontent\n:::
+        content = content.replace(
+          /^:::(note|warning|tip)\n([\s\S]*?)^:::/gm,
+          (_match, type: string, body: string) => {
+            return `<div class="admonition admonition-${type}">\n${body.trim()}\n</div>`;
+          }
+        );
+
+        // Extract footnote definitions [^N]: text
+        const footnoteDefRegex = /^\[\^(\d+)\]:\s*(.+)$/gm;
+        const footnotes: Map<string, string> = new Map();
+        let match: RegExpExecArray | null;
+        while ((match = footnoteDefRegex.exec(content)) !== null) {
+          footnotes.set(match[1], match[2]);
+        }
+        // Remove footnote definitions from content
+        content = content.replace(/^\[\^(\d+)\]:\s*(.+)$/gm, '');
+
+        // Replace footnote references [^N] with sup links
+        content = content.replace(/\[\^(\d+)\]/g, (_m, id: string) => {
+          return `<sup><a href="#fn-${id}">${id}</a></sup>`;
+        });
+
+        // Convert basic markdown to HTML
+        // Headers: # H1, ## H2, etc.
+        content = content.replace(/^######\s+(.+)$/gm, '<h6>$1</h6>');
+        content = content.replace(/^#####\s+(.+)$/gm, '<h5>$1</h5>');
+        content = content.replace(/^####\s+(.+)$/gm, '<h4>$1</h4>');
+        content = content.replace(/^###\s+(.+)$/gm, '<h3>$1</h3>');
+        content = content.replace(/^##\s+(.+)$/gm, '<h2>$1</h2>');
+        content = content.replace(/^#\s+(.+)$/gm, '<h1>$1</h1>');
+
+        // Bold: **text**
+        content = content.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
+
+        // Italic: *text*
+        content = content.replace(/\*(.+?)\*/g, '<em>$1</em>');
+
+        // Paragraphs: wrap non-empty, non-HTML lines in <p> tags
+        const lines = content.split('\n');
+        const processedLines: string[] = [];
+        for (const line of lines) {
+          const trimmed = line.trim();
+          if (
+            trimmed === '' ||
+            trimmed.startsWith('<') ||
+            trimmed.startsWith('#')
+          ) {
+            processedLines.push(line);
+          } else {
+            processedLines.push(`<p>${trimmed}</p>`);
+          }
+        }
+        content = processedLines.join('\n');
+
+        // Clean up empty lines
+        content = content.replace(/\n{3,}/g, '\n\n').trim();
+
+        // Append footnotes section if any
+        if (footnotes.size > 0) {
+          const items = Array.from(footnotes.entries())
+            .map(([id, text]) => `<li id="fn-${id}">${text}</li>`)
+            .join('\n');
+          content += `\n<section class="footnotes">\n<ol>\n${items}\n</ol>\n</section>`;
+        }
+
+        return { ...file, content };
+      },
+    },
+  };
+}
