new file mode 100644
index 0000000..9a8473c
--- /dev/null
+++ b/src/plugins/asset-pipeline.ts
@@ -0,0 +1,43 @@
+import type { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createAssetPipelinePlugin(): Plugin {
+  return {
+    name: 'asset-pipeline',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file: ContentFile, ctx: BuildContext): ContentFile {
+        const assets: string[] = [];
+
+        // Rewrite relative src="./..." in img tags
+        let content = file.content.replace(
+          /src="\.\/([^"]+)"/g,
+          (_match, filename: string) => {
+            assets.push(filename);
+            return `src="/assets/${filename}"`;
+          }
+        );
+
+        // Rewrite relative href="./..." in a tags
+        content = content.replace(
+          /href="\.\/([^"]+)"/g,
+          (_match, filename: string) => {
+            assets.push(filename);
+            return `href="/assets/${filename}"`;
+          }
+        );
+
+        // Update or create asset manifest in ctx.data
+        const existing = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;
+        if (existing) {
+          const allAssets = new Set([...existing.assets, ...assets]);
+          ctx.data.set('asset-manifest', { assets: Array.from(allAssets) });
+        } else if (assets.length > 0) {
+          ctx.data.set('asset-manifest', { assets: [...new Set(assets)] });
+        }
+
+        return { ...file, content };
+      },
+    },
+  };
+}
