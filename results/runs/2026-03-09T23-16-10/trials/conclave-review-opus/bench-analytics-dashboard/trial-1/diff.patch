+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NebobdzrQDTjMUuHMmYWZp","type":"tool_result","content":"     1→import { Response, Router } from \"express\";\n     2→import type Database from \"better-sqlite3\";\n     3→import { authMiddleware, AuthRequest } from \"./auth.js\";\n     4→\n     5→interface EventRow {\n     6→  id: string;\n     7→  tenant_id: string;\n     8→  name: string;\n     9→  properties: string;\n    10→  timestamp: string;\n    11→  user_id: string | null;\n    12→  session_id: string | null;\n    13→}\n    14→\n    15→function eventsToCsv(events: EventRow[]): string {\n    16→  const headers = [\"id\", \"name\", \"properties\", \"timestamp\", \"user_id\", \"session_id\"];\n    17→  const lines = [headers.join(\",\")];\n    18→\n    19→  for (const evt of events) {\n    20→    const row = [\n    21→      evt.id,\n    22→      `\"${evt.name.replace(/\"/g, '\"\"')}\"`,\n    23→      `\"${evt.properties.replace(/\"/g, '\"\"')}\"`,\n    24→      evt.timestamp,\n    25→      evt.user_id || \"\",\n    26→      evt.session_id || \"\",\n    27→    ];\n    28→    lines.push(row.join(\",\"));\n    29→  }\n    30→\n    31→  return lines.join(\"\\n\");\n    32→}\n    33→\n    34→export function createExportRouter(db: Database.Database): Router {\n    35→  const router = Router();\n    36→  router.use(authMiddleware);\n    37→\n    38→  // Export events as JSON\n    39→  router.get(\"/events/json\", (req: AuthRequest, res: Response) => {\n    40→    const user = req.user!;\n    41→    const { event_name, start_date, end_date } = req.query;\n    42→\n    43→    let sql = \"SELECT * FROM events WHERE tenant_id = ?\";\n    44→    const params: unknown[] = [user.tenant_id];\n    45→\n    46→    if (event_name) {\n    47→      sql += \" AND name = ?\";\n    48→      params.push(event_name);\n    49→    }\n    50→    if (start_date) {\n    51→      sql += \" AND timestamp >= ?\";\n    52→      params.push(start_date);\n    53→    }\n    54→    if (end_date) {\n    55→      sql += \" AND timestamp <= ?\";\n    56→      params.push(end_date);\n    57→    }\n    58→\n    59→    sql += \" ORDER BY timestamp DESC\";\n    60→\n    61→    const events = db.prepare(sql).all(...params) as EventRow[];\n    62→    const parsed = events.map((e) => ({\n    63→      ...e,\n    64→      properties: JSON.parse(e.properties),\n    65→    }));\n    66→\n    67→    res.setHeader(\"Content-Type\", \"application/json\");\n    68→    res.setHeader(\"Content-Disposition\", \"attachment; filename=events.json\");\n    69→    res.json({ events: parsed });\n    70→  });\n    71→\n    72→  // Export events as CSV\n    73→  router.get(\"/events/csv\", (req: AuthRequest, res: Response) => {\n    74→    const user = req.user!;\n    75→    const { event_name, start_date, end_date } = req.query;\n    76→\n    77→    let sql = \"SELECT * FROM events WHERE tenant_id = ?\";\n    78→    const params: unknown[] = [user.tenant_id];\n    79→\n    80→    if (event_name) {\n    81→      sql += \" AND name = ?\";\n    82→      params.push(event_name);\n    83→    }\n    84→    if (start_date) {\n    85→      sql += \" AND timestamp >= ?\";\n    86→      params.push(start_date);\n    87→    }\n    88→    if (end_date) {\n    89→      sql += \" AND timestamp <= ?\";\n    90→      params.push(end_date);\n    91→    }\n    92→\n    93→    sql += \" ORDER BY timestamp DESC\";\n    94→\n    95→    const events = db.prepare(sql).all(...params) as EventRow[];\n    96→\n    97→    res.setHeader(\"Content-Type\", \"text/csv\");\n    98→    res.setHeader(\"Content-Disposition\", \"attachment; filename=events.csv\");\n    99→    res.send(eventsToCsv(events));\n   100→  });\n   101→\n   102→  // Export dashboard as JSON\n   103→  router.get(\"/dashboards/:id/json\", (req: AuthRequest, res: Response) => {\n   104→    const user = req.user!;\n   105→    const dashboard = db.prepare(\n   106→      \"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\"\n   107→    ).get(req.params.id, user.tenant_id) as Record<string, unknown> | undefined;\n   108→\n   109→    if (!dashboard) {\n   110→      res.status(404).json({ error: \"Dashboard not found\" });\n   111→      return;\n   112→    }\n   113→\n   114→    const widgets = db.prepare(\n   115→      \"SELECT * FROM widgets WHERE dashboard_id = ?\"\n   116→    ).all(req.params.id) as Array<Record<string, unknown>>;\n   117→\n   118→    res.setHeader(\"Content-Type\", \"application/json\");\n   119→    res.setHeader(\"Content-Disposition\", `attachment; filename=dashboard-${req.params.id}.json`);\n   120→    res.json({\n   121→      dashboard: {\n   122→        ...dashboard,\n   123→        config: typeof dashboard.config === \"string\" ? JSON.parse(dashboard.config as string) : dashboard.config,\n   124→      },\n   125→      widgets: widgets.map((w) => ({\n   126→        ...w,\n   127→        config: typeof w.config === \"string\" ? JSON.parse(w.config as string) : w.config,\n   128→      })),\n   129→    });\n   130→  });\n   131→\n   132→  // Export dashboard as CSV\n   133→  router.get(\"/dashboards/:id/csv\", (req: AuthRequest, res: Response) => {\n   134→    const user = req.user!;\n   135→    const dashboard = db.prepare(\n   136→      \"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\"\n   137→    ).get(req.params.id, user.tenant_id) as Record<string, unknown> | undefined;\n   138→\n   139→    if (!dashboard) {\n   140→      res.status(404).json({ error: \"Dashboard not found\" });\n   141→      return;\n   142→    }\n   143→\n   144→    const widgets = db.prepare(\n   145→      \"SELECT * FROM widgets WHERE dashboard_id = ?\"\n   146→    ).all(req.params.id) as Array<Record<string, unknown>>;\n   147→\n   148→    const headers = [\"dashboard_id\", \"dashboard_name\", \"widget_id\", \"widget_type\", \"widget_config\", \"position_x\", \"position_y\", \"width\", \"height\"];\n   149→    const lines = [headers.join(\",\")];\n   150→\n   151→    if (widgets.length === 0) {\n   152→      lines.push([\n   153→        dashboard.id,\n   154→        `\"${(dashboard.name as string).replace(/\"/g, '\"\"')}\"`,\n   155→        \"\", \"\", \"\", \"\", \"\", \"\", \"\",\n   156→      ].join(\",\"));\n   157→    } else {\n   158→      for (const w of widgets) {\n   159→        const configStr = typeof w.config === \"string\" ? w.config : JSON.stringify(w.config);\n   160→        lines.push([\n   161→          dashboard.id,\n   162→          `\"${(dashboard.name as string).replace(/\"/g, '\"\"')}\"`,\n   163→          w.id,\n   164→          w.type,\n   165→          `\"${(configStr as string).replace(/\"/g, '\"\"')}\"`,\n   166→          w.position_x,\n   167→          w.position_y,\n   168→          w.width,\n   169→          w.height,\n   170→        ].join(\",\"));\n   171→      }\n   172→    }\n   173→\n   174→    res.setHeader(\"Content-Type\", \"text/csv\");\n   175→    res.setHeader(\"Content-Disposition\", `attachment; filename=dashboard-${req.params.id}.csv`);\n   176→    res.send(lines.join(\"\\n\"));\n   177→  });\n   178→\n   179→  return router;\n   180→}\n   181→"}]},"parent_tool_use_id":"toolu_01YNGJSwgKWQNuLNPxSaD7Lc","session_id":"88608cf6-7d8b-4ce0-84dd-65877bc79fbc","uuid":"49454f75-c4e3-48f8-8011-9f6db23dac3d"}
