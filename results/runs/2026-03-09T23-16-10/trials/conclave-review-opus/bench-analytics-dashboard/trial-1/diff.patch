+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DtwahUwcZ3Bvcnk7HbKmjr","type":"tool_result","content":"     1→import { Response, Router } from \"express\";\n     2→import { v4 as uuidv4 } from \"uuid\";\n     3→import type Database from \"better-sqlite3\";\n     4→import { authMiddleware, AuthRequest } from \"./auth.js\";\n     5→\n     6→export function createDashboardsRouter(db: Database.Database): Router {\n     7→  const router = Router();\n     8→  router.use(authMiddleware);\n     9→\n    10→  // Create dashboard\n    11→  router.post(\"/\", (req: AuthRequest, res: Response) => {\n    12→    const user = req.user!;\n    13→    const { name, config } = req.body;\n    14→\n    15→    if (!name) {\n    16→      res.status(400).json({ error: \"Dashboard name is required\" });\n    17→      return;\n    18→    }\n    19→\n    20→    const id = uuidv4();\n    21→    const dashConfig = config ? JSON.stringify(config) : \"{}\";\n    22→    const now = new Date().toISOString();\n    23→\n    24→    db.prepare(\n    25→      \"INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)\"\n    26→    ).run(id, user.tenant_id, name, user.id, dashConfig, now, now);\n    27→\n    28→    res.status(201).json({\n    29→      id,\n    30→      tenant_id: user.tenant_id,\n    31→      name,\n    32→      owner_id: user.id,\n    33→      config: config || {},\n    34→      created_at: now,\n    35→      updated_at: now,\n    36→    });\n    37→  });\n    38→\n    39→  // List dashboards for tenant\n    40→  router.get(\"/\", (req: AuthRequest, res: Response) => {\n    41→    const user = req.user!;\n    42→    const rows = db.prepare(\n    43→      \"SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC\"\n    44→    ).all(user.tenant_id) as Array<Record<string, unknown>>;\n    45→\n    46→    const dashboards = rows.map((r) => ({\n    47→      ...r,\n    48→      config: typeof r.config === \"string\" ? JSON.parse(r.config as string) : r.config,\n    49→    }));\n    50→\n    51→    res.json({ dashboards });\n    52→  });\n    53→\n    54→  // Get single dashboard\n    55→  router.get(\"/:id\", (req: AuthRequest, res: Response) => {\n    56→    const user = req.user!;\n    57→    const row = db.prepare(\n    58→      \"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\"\n    59→    ).get(req.params.id, user.tenant_id) as Record<string, unknown> | undefined;\n    60→\n    61→    if (!row) {\n    62→      res.status(404).json({ error: \"Dashboard not found\" });\n    63→      return;\n    64→    }\n    65→\n    66→    res.json({\n    67→      ...row,\n    68→      config: typeof row.config === \"string\" ? JSON.parse(row.config as string) : row.config,\n    69→    });\n    70→  });\n    71→\n    72→  // Update dashboard\n    73→  router.put(\"/:id\", (req: AuthRequest, res: Response) => {\n    74→    const user = req.user!;\n    75→    const { name, config } = req.body;\n    76→\n    77→    const existing = db.prepare(\n    78→      \"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\"\n    79→    ).get(req.params.id, user.tenant_id) as Record<string, unknown> | undefined;\n    80→\n    81→    if (!existing) {\n    82→      res.status(404).json({ error: \"Dashboard not found\" });\n    83→      return;\n    84→    }\n    85→\n    86→    const updatedName = name || existing.name;\n    87→    const updatedConfig = config !== undefined ? JSON.stringify(config) : (existing.config as string);\n    88→    const now = new Date().toISOString();\n    89→\n    90→    db.prepare(\n    91→      \"UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?\"\n    92→    ).run(updatedName, updatedConfig, now, req.params.id);\n    93→\n    94→    res.json({\n    95→      id: req.params.id,\n    96→      tenant_id: user.tenant_id,\n    97→      name: updatedName,\n    98→      owner_id: existing.owner_id,\n    99→      config: config !== undefined ? config : (typeof existing.config === \"string\" ? JSON.parse(existing.config as string) : existing.config),\n   100→      created_at: existing.created_at,\n   101→      updated_at: now,\n   102→    });\n   103→  });\n   104→\n   105→  // Delete dashboard\n   106→  router.delete(\"/:id\", (req: AuthRequest, res: Response) => {\n   107→    const user = req.user!;\n   108→\n   109→    const existing = db.prepare(\n   110→      \"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\"\n   111→    ).get(req.params.id, user.tenant_id) as Record<string, unknown> | undefined;\n   112→\n   113→    if (!existing) {\n   114→      res.status(404).json({ error: \"Dashboard not found\" });\n   115→      return;\n   116→    }\n   117→\n   118→    db.prepare(\"DELETE FROM widgets WHERE dashboard_id = ?\").run(req.params.id);\n   119→    db.prepare(\"DELETE FROM dashboards WHERE id = ?\").run(req.params.id);\n   120→\n   121→    res.json({ message: \"Dashboard deleted\", id: req.params.id });\n   122→  });\n   123→\n   124→  // --- Widget routes ---\n   125→\n   126→  // Add widget to dashboard\n   127→  router.post(\"/:id/widgets\", (req: AuthRequest, res: Response) => {\n   128→    const user = req.user!;\n   129→\n   130→    const dashboard = db.prepare(\n   131→      \"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\"\n   132→    ).get(req.params.id, user.tenant_id) as Record<string, unknown> | undefined;\n   133→\n   134→    if (!dashboard) {\n   135→      res.status(404).json({ error: \"Dashboard not found\" });\n   136→      return;\n   137→    }\n   138→\n   139→    const { type, config, position_x, position_y, width, height } = req.body;\n   140→\n   141→    if (!type || ![\"counter\", \"timeseries\", \"breakdown\", \"funnel\"].includes(type)) {\n   142→      res.status(400).json({ error: \"Valid widget type is required (counter, timeseries, breakdown, funnel)\" });\n   143→      return;\n   144→    }\n   145→\n   146→    const id = uuidv4();\n   147→    const widgetConfig = config ? JSON.stringify(config) : \"{}\";\n   148→\n   149→    db.prepare(\n   150→      \"INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)\"\n   151→    ).run(id, req.params.id, type, widgetConfig, position_x || 0, position_y || 0, width || 1, height || 1);\n   152→\n   153→    res.status(201).json({\n   154→      id,\n   155→      dashboard_id: req.params.id,\n   156→      type,\n   157→      config: config || {},\n   158→      position_x: position_x || 0,\n   159→      position_y: position_y || 0,\n   160→      width: width || 1,\n   161→      height: height || 1,\n   162→    });\n   163→  });\n   164→\n   165→  // List widgets for a dashboard\n   166→  router.get(\"/:id/widgets\", (req: AuthRequest, res: Response) => {\n   167→    const user = req.user!;\n   168→\n   169→    const dashboard = db.prepare(\n   170→      \"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\"\n   171→    ).get(req.params.id, user.tenant_id) as Record<string, unknown> | undefined;\n   172→\n   173→    if (!dashboard) {\n   174→      res.status(404).json({ error: \"Dashboard not found\" });\n   175→      return;\n   176→    }\n   177→\n   178→    const widgets = db.prepare(\n   179→      \"SELECT * FROM widgets WHERE dashboard_id = ?\"\n   180→    ).all(req.params.id) as Array<Record<string, unknown>>;\n   181→\n   182→    res.json({\n   183→      widgets: widgets.map((w) => ({\n   184→        ...w,\n   185→        config: typeof w.config === \"string\" ? JSON.parse(w.config as string) : w.config,\n   186→      })),\n   187→    });\n   188→  });\n   189→\n   190→  return router;\n   191→}\n   192→"}]},"parent_tool_use_id":"toolu_01YNGJSwgKWQNuLNPxSaD7Lc","session_id":"88608cf6-7d8b-4ce0-84dd-65877bc79fbc","uuid":"7f276eb2-04c5-4e16-ba5d-6adadef46de5"}
