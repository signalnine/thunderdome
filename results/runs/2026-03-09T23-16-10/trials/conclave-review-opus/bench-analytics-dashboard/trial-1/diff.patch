rties: { url: \"/home\" } });\n\n    const res = await request(app)\n      .get(\"/export/events/json\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.events.length).toBe(1);\n    expect(res.body.events[0].name).toBe(\"page_view\");\n  });\n\n  it(\"exports events as CSV\", async () => {\n    const token = await registerAndGetToken(\"u@t.com\", \"t1\");\n    await request(app)\n      .post(\"/events\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"page_view\", properties: { url: \"/home\" } });\n\n    const res = await request(app)\n      .get(\"/export/events/csv\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n    expect(res.text).toContain(\"page_view\");\n  });\n\n  it(\"exports dashboard as JSON\", async () => {\n    const token = await registerAndGetToken(\"u@t.com\", \"t1\");\n    const dash = await request(app)\n      .post(\"/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"My Dashboard\" });\n\n    const res = await request(app)\n      .get(`/export/dashboards/${dash.body.id}/json`)\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.dashboard.name).toBe(\"My Dashboard\");\n  });\n\n  it(\"exports dashboard as CSV\", async () => {\n    const token = await registerAndGetToken(\"u@t.com\", \"t1\");\n    const dash = await request(app)\n      .post(\"/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"My Dashboard\" });\n\n    const res = await request(app)\n      .get(`/export/dashboards/${dash.body.id}/csv`)\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n    expect(res.text).toContain(\"My Dashboard\");\n  });\n\n  it(\"export resp