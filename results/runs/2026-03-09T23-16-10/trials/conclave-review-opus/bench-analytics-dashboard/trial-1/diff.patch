@@ -0,0 +1,191 @@
+import { Response, Router } from "express";
+import { v4 as uuidv4 } from "uuid";
+import type Database from "better-sqlite3";
+import { authMiddleware, AuthRequest } from "./auth.js";
+
+export function createDashboardsRouter(db: Database.Database): Router {
+  const router = Router();
+  router.use(authMiddleware);
+
+  // Create dashboard
+  router.post("/", (req: AuthRequest, res: Response) => {
+    const user = req.user!;
+    const { name, config } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: "Dashboard name is required" });
+      return;
+    }
+
+    const id = uuidv4();
+    const dashConfig = config ? JSON.stringify(config) : "{}";
+    const now = new Date().toISOString();
+
+    db.prepare(
+      "INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    ).run(id, user.tenant_id, name, user.id, dashConfig, now, now);
+
+    res.status(201).json({
+      id,
+      tenant_id: user.tenant_id,
+      name,
+      owner_id: user.id,
+      config: config || {},
+      created_at: now,
+      updated_at: now,
+    });
+  });
+
+  // List dashboards for tenant
+  router.get("/", (req: AuthRequest, res: Response) => {
+    const user = req.user!;
+    const rows = db.prepare(
+      "SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC"
+    ).all(user.tenant_id) as Array<Record<string, unknown>>;
+
+    const dashboards = rows.map((r) => ({
+      ...r,
+      config: typeof r.config === "string" ? JSON.parse(r.config as string) : r.config,
+    }));
+
+    res.json({ dashboards });
+  });
+
+  // Get single dashboard
+  router.get("/:id", (req: AuthRequest, res: Response) => {
+    const user = req.user!;
+    const row = db.prepare(
+      "SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?"
+    ).get(req.params.id, user.tenant_id) as Record<string, unknown> | undefined;
+
+    if (!row) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    res.json({
+      ...row,
+      config: typeof row.config === "string" ? JSON.parse(row.config as string) : row.config,
+    });
+  });
+
+  // Update dashboard
+  router.put("/:id", (req: AuthRequest, res: Response) => {
+    const user = req.user!;
+    const { name, config } = req.body;
+
+    const existing = db.prepare(
+      "SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?"
+    ).get(req.params.id, user.tenant_id) as Record<string, unknown> | undefined;
+
+    if (!existing) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const updatedName = name || existing.name;
+    const updatedConfig = config !== undefined ? JSON.stringify(config) : (existing.config as string);
+    const now = new Date().toISOString();
+
+    db.prepare(
+      "UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?"
+    ).run(updatedName, updatedConfig, now, req.params.id);
+
+    res.json({
+      id: req.params.id,
+      tenant_id: user.tenant_id,
+      name: updatedName,
+      owner_id: existing.owner_id,
+      config: config !== undefined ? config : (typeof existing.config === "string" ? JSON.parse(existing.config as string) : existing.config),
+      created_at: existing.created_at,
+      updated_at: now,
+    });
+  });
+
+  // Delete dashboard
+  router.delete("/:id", (req: AuthRequest, res: Response) => {
+    const user = req.user!;
+
+    const existing = db.prepare(
+      "SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?"
+    ).get(req.params.id, user.tenant_id) as Record<string, unknown> | undefined;
+
+    if (!existing) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    db.prepare("DELETE FROM widgets WHERE dashboard_id = ?").run(req.params.id);
+    db.prepare("DELETE FROM dashboards WHERE id = ?").run(req.params.id);
+
+    res.json({ message: "Dashboard deleted", id: req.params.id });
+  });
+
+  // --- Widget routes ---
+
+  // Add widget to dashboard
+  router.post("/:id/widgets", (req: AuthRequest, res: Response) => {
+    const user = req.user!;
+
+    const dashboard = db.prepare(
+      "SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?"
+    ).get(req.params.id, user.tenant_id) as Record<string, unknown> | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const { type, config, position_x, position_y, width, height } = req.body;
+
+    if (!type || !["counter", "timeseries", "breakdown", "funnel"].includes(type)) {
+      res.status(400).json({ error: "Valid widget type is required (counter, timeseries, breakdown, funnel)" });
+      return;
+    }
+
+    const id = uuidv4();
+    const widgetConfig = config ? JSON.stringify(config) : "{}";
+
+    db.prepare(
+      "INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)"
+    ).run(id, req.params.id, type, widgetConfig, position_x || 0, position_y || 0, width || 1, height || 1);
+
+    res.status(201).json({
+      id,
+      dashboard_id: req.params.id,
+      type,
+      config: config || {},
+      position_x: position_x || 0,
+      position_y: position_y || 0,
+      width: width || 1,
+      height: height || 1,
+    });
+  });
+
+  // List widgets for a dashboard
+  router.get("/:id/widgets", (req: AuthRequest, res: Response) => {
+    const user = req.user!;
+
+    const dashboard = db.prepare(
+      "SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?"
+    ).get(req.params.id, user.tenant_id) as Record<string, unknown> | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const widgets = db.prepare(
+      "SELECT * FROM widgets WHERE dashboard_id = ?"
+    ).all(req.params.id) as Array<Record<string, unknown>>;
+
+    res.json({
+      widgets: widgets.map((w) => ({
+        ...w,
+        config: typeof w.config === "string" ? JSON.parse(w.config as string) : w.config,
+      })),
+    });
+  });
+
+  return router;
+}
diff --git a/src/db.ts b/src/db.ts
