--- /dev/null
+++ b/src/db.ts
@@ -0,0 +1,15 @@
+import Database from "better-sqlite3";
+import { readFileSync } from "fs";
+import { join } from "path";
+
+export function createDatabase(dbPath: string = ":memory:"): Database.Database {
+  const db = new Database(dbPath);
+  db.pragma("journal_mode = WAL");
+  db.pragma("foreign_keys = ON");
+
+  const schemaPath = join(__dirname, "..", "schema.sql");
+  const schema = readFileSync(schemaPath, "utf-8");
+  db.exec(schema);
+
+  return db;
+}
diff --git a/src/events.ts b/src/events.ts
new file mode 100644
index 0000000..e532189
--- /dev/null
+++ b/src/events.ts
@@ -0,0 +1,185 @@
+import { Response, Router } from "express";
+import { v4 as uuidv4 } from "uuid";
+import type Database from "better-sqlite3";
+import { authMiddleware, AuthRequest } from "./auth.js";
+
+export function createEventsRouter(db: Database.Database): Router {
+  const router = Router();
+  router.use(authMiddleware);
+
+  // Ingest a single event
+  router.post("/", (req: AuthRequest, res: Response) => {
+    const user = req.user!;
+    const { name, properties, timestamp, session_id } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: "Event name is required" });
+      return;
+    }
+
+    const id = uuidv4();
+    const eventTimestamp = timestamp || new Date().toISOString();
+    const eventProps = properties ? JSON.stringify(properties) : "{}";
+
+    db.prepare(
+      "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    ).run(id, user.tenant_id, name, eventProps, eventTimestamp, user.id, session_id || null);
+
+    res.status(201).json({ id, name, tenant_id: user.tenant_id, timestamp: eventTimestamp });
+  });
+
+  // Ingest batch events
+  router.post("/batch", (req: AuthRequest, res: Response) => {
+    const user = req.user!;
+    const { events } = req.body;
+
+    if (!Array.isArray(events) || events.length === 0) {
+      res.status(400).json({ error: "events array is required and must not be empty" });
+      return;
+    }
+
+    const insert = db.prepare(
+      "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    );
+
+    const insertMany = db.transaction((evts: Array<Record<string, unknown>>) => {
+      const results: Array<{ id: string; name: string }> = [];
+      for (const evt of evts) {
+        if (!evt.name) continue;
+        const id = uuidv4();
+        const ts = (evt.timestamp as string) || new Date().toISOString();
+        const props = evt.properties ? JSON.stringify(evt.properties) : "{}";
+        insert.run(id, user.tenant_id, evt.name, props, ts, user.id, (evt.session_id as string) || null);
+        results.push({ id, name: evt.name as string });
+      }
+      return results;
+    });
+
+    const results = insertMany(events);
+    res.status(201).json({ inserted: results.length, events: results });
+  });
+
+  // Query: count
+  router.post("/query/count", (req: AuthRequest, res: Response) => {
+    const user = req.user!;
+    const { event_name, start_date, end_date, filters } = req.body;
+
+    let sql = "SELECT COUNT(*) as count FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [user.tenant_id];
+
+    if (event_name) {
+      sql += " AND name = ?";
+      params.push(event_name);
+    }
+
+    if (start_date) {
+      sql += " AND timestamp >= ?";
+      params.push(start_date);
+    }
+
+    if (end_date) {
+      sql += " AND timestamp <= ?";
+      params.push(end_date);
+    }
+
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value);
+      }
+    }
+
+    const result = db.prepare(sql).get(...params) as { count: number };
+    res.json({ count: result.count });
+  });
+
+  // Query: timeseries
+  router.post("/query/timeseries", (req: AuthRequest, res: Response) => {
+    const user = req.user!;
+    const { event_name, start_date, end_date, interval, filters } = req.body;
+
+    const formatMap: Record<string, string> = {
+      hour: "%Y-%m-%dT%H:00:00",
+      day: "%Y-%m-%d",
+      month: "%Y-%m-01",
+    };
+    const dateFormat = formatMap[interval || "day"];
+    if (!dateFormat) {
+      res.status(400).json({ error: "Invalid interval. Must be hour, day, or month." });
+      return;
+    }
+
+    let sql = `SELECT strftime('${dateFormat}', timestamp) as period, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: unknown[] = [user.tenant_id];
+
+    if (event_name) {
+      sql += " AND name = ?";
+      params.push(event_name);
+    }
+
+    if (start_date) {
+      sql += " AND timestamp >= ?";
+      params.push(start_date);
+    }
+
+    if (end_date) {
+      sql += " AND timestamp <= ?";
+      params.push(end_date);
+    }
+
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value);
+      }
+    }
+
+    sql += " GROUP BY period ORDER BY period ASC";
+
+    const results = db.prepare(sql).all(...params) as Array<{ period: string; count: number }>;
+    res.json({ timeseries: results });
+  });
+
+  // Query: breakdown
+  router.post("/query/breakdown", (req: AuthRequest, res: Response) => {
+    const user = req.user!;
+    const { event_name, property, start_date, end_date, filters } = req.body;
+
+    if (!property) {
+      res.status(400).json({ error: "property is required for breakdown query" });
+      return;
+    }
+
+    let sql = `SELECT json_extract(properties, ?) as value, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: unknown[] = [`$.${property}`, user.tenant_id];
+
+    if (event_name) {
+      sql += " AND name = ?";
+      params.push(event_name);
+    }
+
+    if (start_date) {
+      sql += " AND timestamp >= ?";
+      params.push(start_date);
+    }
+
+    if (end_date) {
+      sql += " AND timestamp <= ?";
+      params.push(end_date);
+    }
+
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value);
+      }
+    }
+
+    sql += " GROUP BY value ORDER BY count DESC";
+
+    const results = db.prepare(sql).all(...params) as Array<{ value: string; count: number }>;
+    res.json({ breakdown: results });
+  });
+
+  return router;
+}
diff --git a/src/export.ts b/src/export.ts
new file mode 100644
index 0000000..d7e05f2
--- /dev/null
+++ b/src/export.ts
@@ -0,0 +1,188 @@
+import { Response, Router } from "express";
+import type Database from "better-sqlite3";
+import { authMiddleware, AuthRequest } from "./auth.js";
+
+interface EventRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string | null;
+  session_id: string | null;
+}
+
+function sanitizeCsvField(value: string): string {
+  const escaped = value.replace(/"/g, '""');
+  if (/^[=+\-@\t\r]/.test(escaped)) {
+    return `"'${escaped}"`;
+  }
+  return `"${escaped}"`;
+}
+
+function eventsToCsv(events: EventRow[]): string {
+  const headers = ["id", "name", "properties", "timestamp", "user_id", "session_id"];
+  const lines = [headers.join(",")];
+
+  for (const evt of events) {
+    const row = [
+      sanitizeCsvField(evt.id),
+      sanitizeCsvField(evt.name),
+      sanitizeCsvField(evt.properties),
+      sanitizeCsvField(evt.timestamp),
+      sanitizeCsvField(evt.user_id || ""),
+      sanitizeCsvField(evt.session_id || ""),
+    ];
+    lines.push(row.join(","));
+  }
+
+  return lines.join("\n");
+}
+
+export function createExportRouter(db: Database.Database): Router {
+  const router = Router();
+  router.use(authMiddleware);
+
+  // Export events as JSON
+  router.get("/events/json", (req: AuthRequest, res: Response) => {
+    const user = req.user!;
+    const { event_name, start_date, end_date } = req.query;
+
+    let sql = "SELECT * FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [user.tenant_id];
+
+    if (event_name) {
+      sql += " AND name = ?";
+      params.push(event_name);
+    }
+    if (start_date) {
+      sql += " AND timestamp >= ?";
+      params.push(start_date);
+    }
+    if (end_date) {
+      sql += " AND timestamp <= ?";
+      params.push(end_date);
+    }
+
+    sql += " ORDER BY timestamp DESC";
+
+    const events = db.prepare(sql).all(...params) as EventRow[];
+    const parsed = events.map((e) => ({
+      ...e,
+      properties: JSON.parse(e.properties),
+    }));
+
+    res.setHeader("Content-Type", "application/json");
+    res.setHeader("Content-Disposition", "attachment; filename=events.json");
+    res.json({ events: parsed });
+  });
+
+  // Export events as CSV
+  router.get("/events/csv", (req: AuthRequest, res: Response) => {
+    const user = req.user!;
+    const { event_name, start_date, end_date } = req.query;
+
+    let sql = "SELECT * FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [user.tenant_id];
+
+    if (event_name) {
+      sql += " AND name = ?";
+      params.push(event_name);
+    }
+    if (start_date) {
+      sql += " AND timestamp >= ?";
+      params.push(start_date);
+    }
+    if (end_date) {
+      sql += " AND timestamp <= ?";
+      params.push(end_date);
+    }
+
+    sql += " ORDER BY timestamp DESC";
+
+    const events = db.prepare(sql).all(...params) as EventRow[];
+
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader("Content-Disposition", "attachment; filename=events.csv");
+    res.send(eventsToCsv(events));
+  });
+
+  // Export dashboard as JSON
+  router.get("/dashboards/:id/json", (req: AuthRequest, res: Response) => {
+    const user = req.user!;
+    const dashboard = db.prepare(
+      "SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?"
+    ).get(req.params.id, user.tenant_id) as Record<string, unknown> | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const widgets = db.prepare(
+      "SELECT * FROM widgets WHERE dashboard_id = ?"
+    ).all(req.params.id) as Array<Record<string, unknown>>;
+
+    res.setHeader("Content-Type", "application/json");
+    res.setHeader("Content-Disposition", `attachment; filename=dashboard-${req.params.id}.json`);
+    res.json({
+      dashboard: {
+        ...dashboard,
+        config: typeof dashboard.config === "string" ? JSON.parse(dashboard.config as string) : dashboard.config,
+      },
+      widgets: widgets.map((w) => ({
+        ...w,
+        config: typeof w.config === "string" ? JSON.parse(w.config as string) : w.config,
+      })),
+    });
+  });
+
+  // Export dashboard as CSV
+  router.get("/dashboards/:id/csv", (req: AuthRequest, res: Response) => {
+    const user = req.user!;
+    const dashboard = db.prepare(
+      "SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?"
+    ).get(req.params.id, user.tenant_id) as Record<string, unknown> | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const widgets = db.prepare(
+      "SELECT * FROM widgets WHERE dashboard_id = ?"
+    ).all(req.params.id) as Array<Record<string, unknown>>;
+
+    const headers = ["dashboard_id", "dashboard_name", "widget_id", "widget_type", "widget_config", "position_x", "position_y", "width", "height"];
+    const lines = [headers.join(",")];
+
+    if (widgets.length === 0) {
+      lines.push([
+        dashboard.id,
+        `"${(dashboard.name as string).replace(/"/g, '""')}"`,
+        "", "", "", "", "", "", "",
+      ].join(","));
+    } else {
+      for (const w of widgets) {
+        const configStr = typeof w.config === "string" ? w.config : JSON.stringify(w.config);
+        lines.push([
+          dashboard.id,
+          `"${(dashboard.name as string).replace(/"/g, '""')}"`,
+          w.id,
+          w.type,
+          `"${(configStr as string).replace(/"/g, '""')}"`,
+          w.position_x,
+          w.position_y,
+          w.width,
+          w.height,
+        ].join(","));
+      }
+    }
+
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader("Content-Disposition", `attachment; filename=dashboard-${req.params.id}.csv`);
+    res.send(lines.join("\n"));
+  });
+
+  return router;
+}
