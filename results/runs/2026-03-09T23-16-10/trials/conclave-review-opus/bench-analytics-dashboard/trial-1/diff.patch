.json({ error: \"User not found\" });\n      return;\n    }\n\n    if (targetUser.tenant_id !== currentUser.tenant_id) {\n      res.status(403).json({ error: \"Cannot modify users from another tenant\" });\n      return;\n    }\n\n    db.prepare(\"UPDATE users SET role = ? WHERE id = ?\").run(role, userId);\n    res.json({ message: \"Role updated\", userId, role });\n  });\n\n  return router;\n}\n","structuredPatch":[{"oldStart":95,"oldLines":12,"newStart":95,"newLines":11,"lines":["       return;","     }"," ","-    const password_hash = hashPassword(password);","     const row = db.prepare(","-      \"SELECT id, email, tenant_id, role FROM users WHERE email = ? AND password_hash = ?\"","-    ).get(email, password_hash) as AuthUser | undefined;","+      \"SELECT id, email, tenant_id, role, password_hash FROM users WHERE email = ?\"","+    ).get(email) as (AuthUser & { password_hash: string }) | undefined;"," ","-    if (!row) {","+    if (!row || !verifyPassword(password, row.password_hash)) {","       res.status(401).json({ error: \"Invalid email or password\" });","       return;","     }"]}],"userModified":false,"replaceAll":false}}
