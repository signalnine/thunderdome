+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019wr9Q1fnQsiEGvGX5xAbJf","type":"tool_result","content":"     1→import { Request, Response, NextFunction, Router } from \"express\";\n     2→import jwt from \"jsonwebtoken\";\n     3→import crypto from \"crypto\";\n     4→import { v4 as uuidv4 } from \"uuid\";\n     5→import type Database from \"better-sqlite3\";\n     6→\n     7→const JWT_SECRET = process.env.JWT_SECRET || \"analytics-dashboard-secret-key\";\n     8→\n     9→export interface AuthUser {\n    10→  id: string;\n    11→  email: string;\n    12→  tenant_id: string;\n    13→  role: string;\n    14→}\n    15→\n    16→export interface AuthRequest extends Request {\n    17→  user?: AuthUser;\n    18→}\n    19→\n    20→export function hashPassword(password: string): string {\n    21→  return crypto.createHash(\"sha256\").update(password).digest(\"hex\");\n    22→}\n    23→\n    24→export function generateToken(user: AuthUser): string {\n    25→  return jwt.sign(\n    26→    { id: user.id, email: user.email, tenant_id: user.tenant_id, role: user.role },\n    27→    JWT_SECRET,\n    28→    { expiresIn: \"24h\" }\n    29→  );\n    30→}\n    31→\n    32→export function authMiddleware(req: AuthRequest, res: Response, next: NextFunction): void {\n    33→  const header = req.headers.authorization;\n    34→  if (!header || !header.startsWith(\"Bearer \")) {\n    35→    res.status(401).json({ error: \"Authentication required\" });\n    36→    return;\n    37→  }\n    38→\n    39→  const token = header.slice(7);\n    40→  try {\n    41→    const decoded = jwt.verify(token, JWT_SECRET) as AuthUser;\n    42→    req.user = decoded;\n    43→    next();\n    44→  } catch {\n    45→    res.status(401).json({ error: \"Invalid or expired token\" });\n    46→  }\n    47→}\n    48→\n    49→export function createAuthRouter(db: Database.Database): Router {\n    50→  const router = Router();\n    51→\n    52→  router.post(\"/register\", (req: Request, res: Response) => {\n    53→    const { email, password, tenant_id, role } = req.body;\n    54→\n    55→    if (!email || !password || !tenant_id) {\n    56→      res.status(400).json({ error: \"email, password, and tenant_id are required\" });\n    57→      return;\n    58→    }\n    59→\n    60→    const userRole = role && [\"admin\", \"viewer\", \"editor\"].includes(role) ? role : \"viewer\";\n    61→    const id = uuidv4();\n    62→    const password_hash = hashPassword(password);\n    63→\n    64→    try {\n    65→      db.prepare(\n    66→        \"INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)\"\n    67→      ).run(id, email, password_hash, tenant_id, userRole);\n    68→\n    69→      const user: AuthUser = { id, email, tenant_id, role: userRole };\n    70→      const token = generateToken(user);\n    71→\n    72→      res.status(201).json({ user: { id, email, tenant_id, role: userRole }, token });\n    73→    } catch (err: unknown) {\n    74→      if (err instanceof Error && err.message.includes(\"UNIQUE\")) {\n    75→        res.status(409).json({ error: \"Email already registered\" });\n    76→        return;\n    77→      }\n    78→      res.status(500).json({ error: \"Failed to register user\" });\n    79→    }\n    80→  });\n    81→\n    82→  router.post(\"/login\", (req: Request, res: Response) => {\n    83→    const { email, password } = req.body;\n    84→\n    85→    if (!email || !password) {\n    86→      res.status(400).json({ error: \"email and password are required\" });\n    87→      return;\n    88→    }\n    89→\n    90→    const password_hash = hashPassword(password);\n    91→    const row = db.prepare(\n    92→      \"SELECT id, email, tenant_id, role FROM users WHERE email = ? AND password_hash = ?\"\n    93→    ).get(email, password_hash) as AuthUser | undefined;\n    94→\n    95→    if (!row) {\n    96→      res.status(401).json({ error: \"Invalid email or password\" });\n    97→      return;\n    98→    }\n    99→\n   100→    const token = generateToken(row);\n   101→    res.json({ user: { id: row.id, email: row.email, tenant_id: row.tenant_id, role: row.role }, token });\n   102→  });\n   103→\n   104→  router.get(\"/me\", authMiddleware, (req: AuthRequest, res: Response) => {\n   105→    const user = req.user!;\n   106→    const row = db.prepare(\n   107→      \"SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?\"\n   108→    ).get(user.id) as Record<string, unknown> | undefined;\n   109→\n   110→    if (!row) {\n   111→      res.status(404).json({ error: \"User not found\" });\n   112→      return;\n   113→    }\n   114→\n   115→    res.json({ user: row });\n   116→  });\n   117→\n   118→  router.put(\"/users/:userId/role\", authMiddleware, (req: AuthRequest, res: Response) => {\n   119→    const currentUser = req.user!;\n   120→    if (currentUser.role !== \"admin\") {\n   121→      res.status(403).json({ error: \"Only admins can change user roles\" });\n   122→      return;\n   123→    }\n   124→\n   125→    const { userId } = req.params;\n   126→    const { role } = req.body;\n   127→\n   128→    if (!role || ![\"admin\", \"viewer\", \"editor\"].includes(role)) {\n   129→      res.status(400).json({ error: \"Valid role (admin, viewer, editor) is required\" });\n   130→      return;\n   131→    }\n   132→\n   133→    const targetUser = db.prepare(\n   134→      \"SELECT id, tenant_id FROM users WHERE id = ?\"\n   135→    ).get(userId) as { id: string; tenant_id: string } | undefined;\n   136→\n   137→    if (!targetUser) {\n   138→      res.status(404).json({ error: \"User not found\" });\n   139→      return;\n   140→    }\n   141→\n   142→    if (targetUser.tenant_id !== currentUser.tenant_id) {\n   143→      res.status(403).json({ error: \"Cannot modify users from another tenant\" });\n   144→      return;\n   145→    }\n   146→\n   147→    db.prepare(\"UPDATE users SET role = ? WHERE id = ?\").run(role, userId);\n   148→    res.json({ message: \"Role updated\", userId, role });\n   149→  });\n   150→\n   151→  return router;\n   152→}\n   153→"}]},"parent_tool_use_id":"toolu_01YNGJSwgKWQNuLNPxSaD7Lc","session_id":"88608cf6-7d8b-4ce0-84dd-65877bc79fbc","uuid":"d65a51f5-801f-4029-93a2-21daf8faea4e"}
