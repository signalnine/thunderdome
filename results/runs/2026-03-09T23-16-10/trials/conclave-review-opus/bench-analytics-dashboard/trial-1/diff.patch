l: \"test@example.com\", password: \"pass123\", tenant_id: \"t1\" });\n    const res = await request(app)\n      .post(\"/auth/register\")\n      .send({ email: \"test@example.com\", password: \"pass456\", tenant_id: \"t2\" });\n    expect(res.status).toBe(409);\n  });\n\n  it(\"POST /auth/register rejects missing fields\", async () => {\n    const res = await request(app).post(\"/auth/register\").send({ email: \"a@b.com\" });\n    expect(res.status).toBe(400);\n  });\n\n  it(\"POST /auth/login works with valid creds\", async () => {\n    await request(app)\n      .post(\"/auth/register\")\n      .send({ email: \"test@example.com\", password: \"pass123\", tenant_id: \"t1\" });\n    const res = await request(app)\n      .post(\"/auth/login\")\n      .send({ email: \"test@example.com\", password: \"pass123\" });\n    expect(res.status).toBe(200);\n    expect(res.body.token).toBeDefined();\n  });\n\n  it(\"POST /auth/login rejects wrong password\", async () => {\n    await request(app)\n      .post(\"/auth/register\")\n      .send({ email: \"test@example.com\", password: \"pass123\", tenant_id: \"t1\" });\n    const res = await request(app)\n      .post(\"/auth/login\")\n      .send({ email: \"test@example.com\", password: \"wrong\" });\n    expect(res.status).toBe(401);\n  });\n\n  it(\"GET /auth/me returns profile\", async () => {\n    const reg = await request(app)\n      .post(\"/auth/register\")\n      .send({ email: \"test@example.com\", password: \"pass123\", tenant_id: \"t1\" });\n    const res = await request(app)\n      .get(\"/auth/me\")\n      .set(\"Authorization\", `Bearer ${reg.body.token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.user.email).toBe(\"test@example.com\");\n  });\n\n  it(\"GET /auth/me requires auth\", async () => {\n    const res = await request(app).get(\"/auth/me\");\n    expect(res.status).toBe(401);\n  });\n\n  it(\"PUT /auth/users/:id/role changes role\", async () => {\n    const admin = await request(app)\n      .post(\"/auth/register\")\n      .send({ email: \"admin@example.com\", password: \"pass123\", tenant_id: \"t1\", role: \"admin\" });\n    const viewer = await request(app)\n      .post(\"/auth/register\")\n      .send({ email: \"viewer@example.com\", password: \"pass123\", tenant_id: \"t1\" });\n\n    const res = await request(app)\n      .put(`/auth/users/${viewer.body.user.id}/role`)\n      .set(\"Authorization\", `Bearer ${admin.body.token}`)\n      .send({ role: \"editor\" });\n    expect(res.status).toBe(200);\n    expect(res.body.role).toBe(\"editor\");\n  });\n\n  it(\"PUT /auth/users/:id/role blocked for non-admin\", async () => {\n    const viewer = await request(app)\n      .post(\"/auth/register\")\n      .send({ email: \"viewer@example.com\", password: \"pass123\", tenant_id: \"t1\" });\n\n    const res = await request(app)\n      .put(`/auth/users/${viewer.body.user.id}/role`)\n      .set(\"Authorization\", `Bearer ${viewer.body.token}`)\n      .send({ role: \"editor\" });\n    expect(res.status).toBe(403);\n  });\n\n  it(\"PUT /auth/users/:id/role blocked cross-tenant\", async () => {\n    const admin = await request(app)\n      .post(\"/auth/register\")\n      .send({ email: \"admin@example.com\", password: \"pass123\", tenant_id: \"t1\", role: \"admin\" });\n    const other = await request(app)\n      .post(\"/auth/register\")\n      .send({ email: \"other@example.com\", password: \"pass123\", tenant_id: \"t2\" });\n\n    const res = await request(app)\n      .put(`/auth/users/${other.body.user.id}/role`)\n      .set(\"Authorization\", `Bearer ${admin.body.token}`)\n      .send({ role: \"editor\" });\n    expect(res.status).toBe(403);\n  });\n});\n\nasync function registerAndGetToken(email: string, tenantId: string, role = \"viewer\") {\n  const res = await request(app)\n    .post(\"/auth/register\")\n    .send({ email, password: \"pass123\", tenant_id: tenantId, role });\n  return res.body.token as string;\n}\n\ndescribe(\"Events\", () => {\n  it(\"POST /events creates an event\", async () => {\n    const token = await registerAndGetToken(\"u@t.com\", \"t1\");\n    const res = await request(app)\n      .post(\"/events\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"page_view\", properties: { url: \"/home\" } });\n    expect(res.status).toBe(201);\n    expect(res.body.name).toBe(\"page_view\");\n  });\n\n  it(\"POST /events requires auth\", async () => {\n    const res = await request(app).post(\"/events\").send({ name: \"page_view\" });\n    expect(res.status).toBe(401);\n  });\n\n  it(\"POST /events/batch creates multiple events\", async () => {\n    const token = await registerAndGetToken(\"u@t.com\", \"t1\");\n    const res = await request(app)\n      .post(\"/events/batch\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({\n        events: [\n          { name: \"page_view\", properties: { url: \"/home\" } },\n          { name: \"click\", properties: { button: \"signup\" } },\n        ],\n      });\n    expect(res.status).toBe(201);\n    expect(res.body.inserted).toBe(2);\n  });\n\n  it(\"POST /events/query/count counts events\", async () => {\n    const token = await registerAndGetToken(\"u@t.com\", \"t1\");\n    await request(app)\n      .post(\"/events/batch\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({\n        events: [\n          { name: \"page_view\", properties: { url: \"/home\" }, timestamp: \"2024-01-01T10:00:00Z\" },\n          { name: \"page_view\", properties: { url: \"/about\" }, timestamp: \"2024-01-02T10:00:00Z\" },\n          { name: \"click\", properties: { button: \"signup\" }, timestamp: \"2024-01-03T10:00:00Z\" },\n        ],\n      });\n\n    const res = await request(app)\n      .post(\"/events/query/count\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ event_name: \"page_view\" });\n    expect(res.status).toBe(200);\n    expect(res.body.count).toBe(2);\n  });\n\n  it(\"POST /events/query/count respects 