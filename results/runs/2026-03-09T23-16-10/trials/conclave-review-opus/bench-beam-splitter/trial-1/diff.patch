+import { describe, it, expect } from 'vitest';
+import { countBeamCells, countBeamPaths } from './index.js';
+
+describe('countBeamCells', () => {
+  it('basic example: beam goes straight down', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(4);
+  });
+
+  it('example with one splitter', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(5);
+  });
+
+  it('example with two splitters on row 2', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(6);
+  });
+
+  it('empty grid', () => {
+    expect(countBeamCells([])).toBe(0);
+  });
+
+  it('no source', () => {
+    const grid = [['.', '.'], ['.', '.']];
+    expect(countBeamCells(grid)).toBe(0);
+  });
+
+  it('source only, 1 row', () => {
+    const grid = [['S']];
+    expect(countBeamCells(grid)).toBe(1);
+  });
+
+  it('beam absorbed at left edge', () => {
+    const grid = [
+      ['S', '.', '.'],
+      ['^', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    // Beam: (0,0) -> (1,0) hits splitter -> down-left (2,-1) absorbed, down-right (2,1)
+    expect(countBeamCells(grid)).toBe(3); // (0,0), (1,0), (2,1)
+  });
+
+  it('beam absorbed at right edge', () => {
+    const grid = [
+      ['.', '.', 'S'],
+      ['.', '.', '^'],
+      ['.', '.', '.'],
+    ];
+    // Beam: (0,2) -> (1,2) hits splitter -> down-left (2,1), down-right (2,3) absorbed
+    expect(countBeamCells(grid)).toBe(3); // (0,2), (1,2), (2,1)
+  });
+});
+
+describe('countBeamPaths', () => {
+  it('no splitters: 1 path', () => {
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('one splitter: 2 paths', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it('two splitters in cascade: 4 paths', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(4n);
+  });
+
+  it('empty grid', () => {
+    expect(countBeamPaths([])).toBe(0n);
+  });
+
+  it('no source', () => {
+    const grid = [['.', '.'], ['.', '.']];
+    expect(countBeamPaths(grid)).toBe(0n);
+  });
+
+  it('source only, 1 row', () => {
+    const grid = [['S']];
+    // beam starts at (0,0), moves to (1,0) which is out of bounds -> 1 path
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('absorbed beam still counts as a path', () => {
+    const grid = [
+      ['S', '.', '.'],
+      ['^', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    // down-left absorbed, down-right exits -> both count as paths
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it('performance: large grid with many splitters in line', () => {
+    const rows = 200;
+    const cols = 200;
+    const grid: string[][] = Array.from({ length: rows }, () =>
+      Array.from({ length: cols }, () => '.')
+    );
+    grid[0][100] = 'S';
+    for (let i = 0; i < 50; i++) {
+      const row = 2 + i * 3;
+      if (row < rows) {
+        const col = 100;
+        if (col < cols) grid[row][col] = '^';
+      }
+    }
+    const start = Date.now();
+    const result = countBeamPaths(grid);
+    const elapsed = Date.now() - start;
+    expect(result).toBeGreaterThan(0n);
+    expect(elapsed).toBeLessThan(5000);
+  });
+
+  it('performance: cascading splitters forming binary tree', () => {
+    // Place splitters so both outputs of each splitter hit another splitter
+    // Splitter at (r, c) outputs to (r+1, c-1) and (r+1, c+1)
+    // If we place splitters at those positions, we get exponential branching
+    const rows = 200;
+    const cols = 200;
+    const grid: string[][] = Array.from({ length: rows }, () =>
+      Array.from({ length: cols }, () => '.')
+    );
+    grid[0][100] = 'S';
+    // Row 1: splitter at col 100 (hit by source beam going down)
+    grid[1][100] = '^';
+    // Row 2: splitters at 99, 101
+    grid[2][99] = '^';
+    grid[2][101] = '^';
+    // Row 3: splitters at 98, 100, 102
+    grid[3][98] = '^';
+    grid[3][100] = '^';
+    grid[3][102] = '^';
+    // This creates a binary tree where many beams converge on the same splitters
+    // With memoization, this should be fast
+    const start = Date.now();
+    const resultPaths = countBeamPaths(grid);
+    const resultCells = countBeamCells(grid);
+    const elapsed = Date.now() - start;
+    expect(resultPaths).toBeGreaterThan(0n);
+    expect(resultCells).toBeGreaterThan(0);
+    expect(elapsed).toBeLessThan(5000);
+  });
+
+  it('performance: deep cascade of 50 splitters along diagonal', () => {
+    const rows = 200;
+    const cols = 200;
+    const grid: string[][] = Array.from({ length: rows }, () =>
+      Array.from({ length: cols }, () => '.')
+    );
+    grid[0][100] = 'S';
+    // Place 50 splitters along the down-right diagonal
+    // Each splitter's down-right output hits the next; down-left exits freely
+    // This gives 51 total paths (1 down-left exit per splitter + 1 final exit)
+    for (let i = 0; i < 50; i++) {
+      const row = 1 + i;
+      const col = 100 + i;
+      if (row < rows && col < cols) grid[row][col] = '^';
+    }
+    const start = Date.now();
+    const result = countBeamPaths(grid);
+    const elapsed = Date.now() - start;
+    expect(result).toBe(51n);
+    expect(elapsed).toBeLessThan(5000);
+  });
+
+  it('performance: triangle of splitters with exponential paths', () => {
+    // Arrange splitters in a triangle so both outputs of each hit another splitter
+    // Level k (0-indexed) has splitters at row k+1, cols 100-k, 100-k+2, ..., 100+k
+    // With 9 levels: 1+2+3+...+9+10 = 55 splitters (but we only use first 9 levels = 45)
+    // 2^9 = 512 paths from the triangle
+    const rows = 200;
+    const cols = 200;
+    const grid: string[][] = Array.from({ length: rows }, () =>
+      Array.from({ length: cols }, () => '.')
+    );
+    grid[0][100] = 'S';
+    const levels = 9;
+    for (let level = 0; level < levels; level++) {
+      const row = level + 1;
+      for (let j = 0; j <= level; j++) {
+        const col = 100 - level + 2 * j;
+        if (row < rows && col >= 0 && col < cols) {
+          grid[row][col] = '^';
+        }
+      }
+    }
+    const start = Date.now();
+    const result = countBeamPaths(grid);
+    const elapsed = Date.now() - start;
+    expect(result).toBe(2n ** BigInt(levels));
+    expect(elapsed).toBeLessThan(5000);
+  });
+});
