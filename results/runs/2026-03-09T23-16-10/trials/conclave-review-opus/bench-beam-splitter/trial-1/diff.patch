+  // Memoize: for a given (row, col, dir), how many paths exit from there?
+  const memo = new Map&lt;string, bigint&gt;();
+&nbsp;
+  function countFrom(row: number, col: number, dir: Direction): bigint {
+    const key = `${row},${col},${dir}`;
+    if (memo.has(key)) return memo.get(key)!;
+&nbsp;
+    // Temporarily set to 0n to handle any unexpected cycles
+    memo.set(key, 0n);
