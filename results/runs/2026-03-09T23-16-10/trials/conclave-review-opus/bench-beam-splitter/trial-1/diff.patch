+    let result: bigint;
+    if (!hitSplitter) {
+      // Beam exits the grid — 1 path
+      result = 1n;
+    } else {
+      const [spr, spc] = hitSplitter;
+      result = countFrom(spr, spc, 'down-left') + countFrom(spr, spc, 'down-right');
+    }
+&nbsp;
+    memo.set(key, result);
+    return result;
+  }
