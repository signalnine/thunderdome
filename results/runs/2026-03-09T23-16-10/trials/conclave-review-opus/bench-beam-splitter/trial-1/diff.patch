+<span class="cline-any cline-neutral">&nbsp;</span></td><td class="text"><pre class="prettyprint lang-js">type Direction = 'down' | 'down-left' | 'down-right';
+&nbsp;
+function findSource(grid: string[][]): [number, number] | null {
+  for (let c = 0; c &lt; (grid[0]?.<span class="branch-0 cbranch-no" title="branch not covered" >length ?? 0); c</span>++) {
+    if (grid[0][c] === 'S') return [0, c];
