+&nbsp;
+function advance(row: number, col: number, dir: Direction): [number, number] {
+  switch (dir) {
+    case 'down': return [row + 1, col];
+    case 'down-left': return [row + 1, col - 1];
+    case 'down-right': return [row + 1, col + 1];
+  }
+}
+&nbsp;
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row &gt;= 0 &amp;&amp; row &lt; rows &amp;&amp; col &gt;= 0 &amp;&amp; col &lt; cols;
+}
+&nbsp;
+/**
+ * Trace a beam from a starting position+direction until it hits a splitter or exits.
+ * Returns all cells visited along the way and the terminal event.
+ */
+function traceBeam(
+  grid: string[][],
+  startRow: number,
+  startCol: number,
+  dir: Direction,
+  rows: number,
+  cols: number,
+): { cells: [number, number][]; hitSplitter: [number, number] | null } {
+  const cells: [number, number][] = [];
+  let row = startRow;
+  let col = startCol;
+&nbsp;
+  for (;;) {
+    const [nr, nc] = advance(row, col, dir);
+    if (!inBounds(nr, nc, rows, cols)) {
+      return { cells, hitSplitter: null };
+    }
+    cells.push([nr, nc]);
+    if (grid[nr][nc] === '^') {
+      return { cells, hitSplitter: [nr, nc] };
+    }
+    row = nr;
+    col = nc;
+  }
+}
+&nbsp;
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  if (rows === 0) return 0;
+  const cols = grid[0].length;
+&nbsp;
+  const source = findSource(grid);
+  if (!source) return 0;
+&nbsp;
+  const visited = new Set&lt;string&gt;();
+  const [sr, sc] = source;
+  visited.add(`${sr},${sc}`);
+&nbsp;
+  // Track which (splitter, direction) pairs we've already processed
+  const processed = new Set&lt;string&gt;();
+&nbsp;
+  // Queue of (row, col, direction) to trace from
+  const queue: [number, number, Direction][] = [[sr, sc, 'down']];
+&nbsp;
+  while (queue.length &gt; 0) {
+    const [row, col, dir] = queue.pop()!;
+    const key = `${row},${col},${dir}`;
+    if (processed.has(key)) continue;
+    processed.add(key);
+&nbsp;
+    const { cells, hitSplitter } = traceBeam(grid, row, col, dir, rows, cols);
+    for (const [cr, cc] of cells) {
+      visited.add(`${cr},${cc}`);
+    }
+&nbsp;
+    if (hitSplitter) {
+      const [spr, spc] = hitSplitter;
+      queue.push([spr, spc, 'down-left']);
+      queue.push([spr, spc, 'down-right']);
+    }
+  }
+&nbsp;
+  return visited.size;
+}
+&nbsp;
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  if (rows === 0) return 0n;
+  const cols = grid[0].length;
+&nbsp;
