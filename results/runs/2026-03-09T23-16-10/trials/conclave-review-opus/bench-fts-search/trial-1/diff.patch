+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FdUYr9ySnZp9cBVqjAo3yP","type":"tool_result","content":"The file /workspace/src/routes.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"746ad443-2167-47a7-9c49-2ac15c9fcfc1","uuid":"3d2697c3-b692-4363-bc49-1cd7a406bd86","tool_use_result":{"filePath":"/workspace/src/routes.ts","oldString":"function sanitizeFtsQuery(q: string): string {\n  // Remove FTS5 special characters that could cause syntax errors,\n  // but preserve double quotes for phrase queries\n  return q.replace(/[*^:+\\-(){}[\\]|\\\\/<>!@#$%&=~`;,]/g, ' ').trim();\n}","newString":"function sanitizeFtsQuery(q: string): string {\n  // Check for phrase queries (double-quoted strings)\n  // Extract quoted phrases and individual terms separately\n  const phrases: string[] = [];\n  const remaining = q.replace(/\"([^\"]+)\"/g, (_match, phrase) => {\n    // Clean phrase content of special chars\n    const clean = phrase.replace(/[^\\w\\s]/g, ' ').trim();\n    if (clean) phrases.push(`\"${clean}\"`);\n    return ' ';\n  });\n\n  // Clean remaining terms of any FTS5 special characters\n  const cleanTerms = remaining.replace(/[^\\w\\s]/g, ' ').trim();\n  const terms = cleanTerms.split(/\\s+/).filter(Boolean);\n\n  const allParts = [...phrases, ...terms];\n  return allParts.join(' ');\n}","originalFile":"import { Router, Request, Response, NextFunction } from 'express';\nimport Database from 'better-sqlite3';\nimport { Note, NoteInput, SearchResult, SuggestResult } from './models.js';\nimport { NotFoundError, ValidationError } from './errors.js';\n\nfunction sanitizeFtsQuery(q: string): string {\n  // Remove FTS5 special characters that could cause syntax errors,\n  // but preserve double quotes for phrase queries\n  return q.replace(/[*^:+\\-(){}[\\]|\\\\/<>!@#$%&=~`;,]/g, ' ').trim();\n}\n\nexport function createRoutes(db: Database.Database): Router {\n  const router = Router();\n\n  // GET /notes/search/suggest - Autocomplete suggestions\n  router.get('/notes/search/suggest', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const q = req.query.q as string | undefined;\n\n      if (!q || q.trim() === '') {\n        throw new ValidationError('Search query is required');\n      }\n\n      const sanitized = sanitizeFtsQuery(q.trim());\n      if (!sanitized) {\n        res.json({ results: [] });\n        return;\n      }\n\n      // Use prefix matching with FTS5\n      const prefixQuery = sanitized.split(/\\s+/).map(term => `\"${term}\"*`).join(' ');\n\n      const stmt = db.prepare(`\n        SELECT notes.id, notes.title\n        FROM notes_fts\n        JOIN notes ON notes.id = notes_fts.rowid\n        WHERE notes_fts MATCH ?\n        ORDER BY rank\n        LIMIT 5\n      `);\n\n      const results = stmt.all(prefixQuery) as SuggestResult[];\n      res.json({ results });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // GET /notes/search - Full-text search\n  router.get('/notes/search', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const q = req.query.q as string | undefined;\n\n      if (!q || q.trim() === '') {\n        throw new ValidationError('Search query is required');\n      }\n\n      const page = Math.max(1, parseInt(req.query.page as string) || 1);\n      const perPage = 20;\n      const offset = (page - 1) * perPage;\n\n      const sanitized = sanitizeFtsQuery(q.trim());\n      if (!sanitized) {\n        res.json({ results: [], total: 0, page, perPage });\n        return;\n      }\n\n      // Build FTS query - handle each word as a term\n      // Double quotes are preserved by sanitizeFtsQuery for phrase matching\n      const ftsQuery = sanitized;\n\n      // Get total count\n      const countStmt = db.prepare(`\n        SELECT COUNT(*) as total\n        FROM notes_fts\n        WHERE notes_fts MATCH ?\n      `);\n      const { total } = countStmt.get(ftsQuery) as { total: number };\n\n      // Get paginated results with BM25 ranking and snippet highlighting\n      const searchStmt = db.prepare(`\n        SELECT\n          notes.id,\n          notes.title,\n          snippet(notes_fts, 1, '<mark>', '</mark>', '...', 32) as snippet,\n          bm25(notes_fts) as rank\n        FROM notes_fts\n        JOIN notes ON notes.id = notes_fts.rowid\n        WHERE notes_fts MATCH ?\n        ORDER BY rank\n        LIMIT ? OFFSET ?\n      `);\n\n      const results = searchStmt.all(ftsQuery, perPage, offset) as SearchResult[];\n\n      res.json({ results, total, page, perPage });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // GET /notes - List all notes (with optional tag filter)\n  router.get('/notes', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const tag = req.query.tag as string | undefined;\n\n      let notes: Note[];\n      if (tag) {\n        // Use a join with json_each for tag filtering\n        const tagStmt = db.prepare(`\n          SELECT DISTINCT notes.* FROM notes, json_each(notes.tags)\n          WHERE json_each.value = ?\n          ORDER BY created_at DESC\n        `);\n        notes = tagStmt.all(tag) as Note[];\n      } else {\n        const stmt = db.prepare('SELECT * FROM notes ORDER BY created_at DESC');\n        notes = stmt.all() as Note[];\n      }\n\n      res.json({ notes });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // GET /notes/:id - Get single note\n  router.get('/notes/:id', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const id = parseInt(req.params.id);\n      const stmt = db.prepare('SELECT * FROM notes WHERE id = ?');\n      const note = stmt.get(id) as Note | undefined;\n\n      if (!note) {\n        throw new NotFoundError('Note not found');\n      }\n\n      res.json({ note });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // POST /notes - Create note\n  router.post('/notes', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const input = req.body as NoteInput;\n\n      if (!input.title || input.title.trim() === '') {\n        throw new ValidationError('Title is required');\n      }\n      if (!input.body || input.body.trim() === '') {\n        throw new ValidationError('Body is required');\n      }\n\n      const tags = input.tags ? JSON.stringify(input.tags) : '[]';\n      const stmt = db.prepare(`\n        INSERT INTO notes (title, body, tags) VALUES (?, ?, ?)\n      `);\n      const result = stmt.run(input.title, input.body, tags);\n\n      const note = db.prepare('SELECT * FROM notes WHERE id = ?').get(result.lastInsertRowid) as Note;\n      res.status(201).json({ note });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // PUT /notes/:id - Update note\n  router.put('/notes/:id', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const id = parseInt(req.params.id);\n      const existing = db.prepare('SELECT * FROM notes WHERE id = ?').get(id) as Note | undefined;\n\n      if (!existing) {\n        throw new NotFoundError('Note not found');\n      }\n\n      const input = req.body as Partial<NoteInput>;\n      const title = input.title ?? existing.title;\n      const body = input.body ?? existing.body;\n      const tags = input.tags ? JSON.stringify(input.tags) : existing.tags;\n\n      const stmt = db.prepare(`\n        UPDATE notes SET title = ?, body = ?, tags = ?, updated_at = datetime('now')\n        WHERE id = ?\n      `);\n      stmt.run(title, body, tags, id);\n\n      const note = db.prepare('SELECT * FROM notes WHERE id = ?').get(id) as Note;\n      res.json({ note });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // DELETE /notes/:id - Delete note\n  router.delete('/notes/:id', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const id = parseInt(req.params.id);\n      const existing = db.prepare('SELECT * FROM notes WHERE id = ?').get(id) as Note | undefined;\n\n      if (!existing) {\n        throw new NotFoundError('Note not found');\n      }\n\n      db.prepare('DELETE FROM notes WHERE id = ?').run(id);\n      res.status(204).send();\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  return router;\n}\n","structuredPatch":[{"oldStart":4,"oldLines":9,"newStart":4,"newLines":22,"lines":[" import { NotFoundError, ValidationError } from './errors.js';"," "," function sanitizeFtsQuery(q: string): string {","-  // Remove FTS5 special characters that could cause syntax errors,","-  // but preserve double quotes for phrase queries","-  return q.replace(/[*^:+\\-(){}[\\]|\\\\/<>!@#$%&=~`;,]/g, ' ').trim();","+  // Check for phrase queries (double-quoted strings)","+  // Extract quoted phrases and individual terms separately","+  const phrases: string[] = [];","+  const remaining = q.replace(/\"([^\"]+)\"/g, (_match, phrase) => {","+    // Clean phrase content of special chars","+    const clean = phrase.replace(/[^\\w\\s]/g, ' ').trim();","+    if (clean) phrases.push(`\"${clean}\"`);","+    return ' ';","+  });","+","+  // Clean remaining terms of any FTS5 special characters","+  const cleanTerms = remaining.replace(/[^\\w\\s]/g, ' ').trim();","+  const terms = cleanTerms.split(/\\s+/).filter(Boolean);","+","+  const allParts = [...phrases, ...terms];","+  return allParts.join(' ');"," }"," "," export function createRoutes(db: Database.Database): Router {"]}],"userModified":false,"replaceAll":false}}
