@@ -0,0 +1,325 @@
+/**
+ * Operational Transform (OT) module for collaborative text editing.
+ *
+ * Operations are arrays of components:
+ * - positive number: retain N characters
+ * - string: insert text
+ * - negative number: delete N characters
+ *
+ * The "base length" of an operation is the total number of characters it expects
+ * the input document to have (sum of retains + sum of abs(deletes)).
+ * The "target length" is the length of the document after applying the operation
+ * (sum of retains + sum of insert lengths).
+ */
+
+export type OpComponent = number | string;
+export type Operation = OpComponent[];
+
+export interface OperationMessage {
+  type: 'operation';
+  docId: string;
+  version: number;
+  operation: Operation;
+  clientId: string;
+}
+
+export interface SyncMessage {
+  type: 'sync';
+  docId: string;
+  content: string;
+  version: number;
+}
+
+export interface AckMessage {
+  type: 'ack';
+  version: number;
+}
+
+export interface ErrorMessage {
+  type: 'error';
+  message: string;
+}
+
+export type ServerMessage = SyncMessage | AckMessage | ErrorMessage | (OperationMessage & { type: 'operation' });
+export type ClientMessage = OperationMessage;
+
+/** Calculate the base length (expected input length) of an operation. */
+export function baseLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) len += c;       // retain
+      else if (c < 0) len += -c; // delete
+    }
+    // inserts don't consume input characters
+  }
+  return len;
+}
+
+/** Calculate the target length (output length) of an operation. */
+export function targetLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) len += c;       // retain
+      // deletes don't produce output characters
+    } else {
+      len += c.length;           // insert
+    }
+  }
+  return len;
+}
+
+/** Normalize an operation by merging adjacent same-type components and removing no-ops. */
+function normalize(op: Operation): Operation {
+  const result: Operation = [];
+  for (const c of op) {
+    if (typeof c === 'number' && c === 0) continue;
+    if (typeof c === 'string' && c === '') continue;
+    if (result.length === 0) {
+      result.push(c);
+      continue;
+    }
+    const last = result[result.length - 1];
+    if (typeof c === 'string' && typeof last === 'string') {
+      result[result.length - 1] = last + c;
+    } else if (typeof c === 'number' && typeof last === 'number') {
+      if ((c > 0 && last > 0) || (c < 0 && last < 0)) {
+        result[result.length - 1] = last + c;
+      } else {
+        result.push(c);
+      }
+    } else {
+      result.push(c);
+    }
+  }
+  return result;
+}
+
+/** Apply an operation to a document string. */
+export function apply(doc: string, op: Operation): string {
+  if (baseLength(op) !== doc.length) {
+    throw new Error(`Operation base length (${baseLength(op)}) does not match document length (${doc.length})`);
+  }
+  let result = '';
+  let pos = 0;
+  for (const c of op) {
+    if (typeof c === 'string') {
+      result += c;
+    } else if (c > 0) {
+      result += doc.slice(pos, pos + c);
+      pos += c;
+    } else if (c < 0) {
+      pos += -c;
+    }
+  }
+  return result;
+}
+
+/**
+ * Transform two concurrent operations a and b (both applied to the same document)
+ * into a' and b' such that:
+ *   apply(apply(doc, a), b') === apply(apply(doc, b), a')
+ *
+ * Returns [a', b'] where:
+ *   a' is a transformed against b (apply after b)
+ *   b' is b transformed against a (apply after a)
+ */
+export function transform(origA: Operation, origB: Operation): [Operation, Operation] {
+  if (baseLength(origA) !== baseLength(origB)) {
+    throw new Error(`Operations have different base lengths: ${baseLength(origA)} vs ${baseLength(origB)}`);
+  }
+
+  const a: OpComponent[] = [...origA];
+  const b: OpComponent[] = [...origB];
+  const aPrime: Operation = [];
+  const bPrime: Operation = [];
+
+  let ia = 0;
+  let ib = 0;
+
+  while (ia < a.length || ib < b.length) {
+    const ca = ia < a.length ? a[ia] : undefined;
+    const cb = ib < b.length ? b[ib] : undefined;
+
+    // If a inserts, it goes into a' and b' retains over it
+    if (typeof ca === 'string') {
+      aPrime.push(ca);
+      bPrime.push(ca.length);
+      ia++;
+      continue;
+    }
+
+    // If b inserts, it goes into b' and a' retains over it
+    if (typeof cb === 'string') {
+      bPrime.push(cb);
+      aPrime.push(cb.length);
+      ib++;
+      continue;
+    }
+
+    if (ca === undefined && cb === undefined) break;
+
+    if (ca === undefined || cb === undefined) {
+      throw new Error('Operation transform mismatch: one operation ran out before the other');
+    }
+
+    // Both are numbers (retain or delete)
+    const aIsRetain = ca > 0;
+    const bIsRetain = cb > 0;
+    const aLen = Math.abs(ca);
+    const bLen = Math.abs(cb);
+
+    if (aIsRetain && bIsRetain) {
+      const minLen = Math.min(aLen, bLen);
+      aPrime.push(minLen);
+      bPrime.push(minLen);
+      if (aLen > bLen) {
+        a[ia] = aLen - bLen; ib++;
+      } else if (bLen > aLen) {
+        b[ib] = bLen - aLen; ia++;
+      } else {
+        ia++; ib++;
+      }
+    } else if (!aIsRetain && !bIsRetain) {
+      // Both delete - deletions cancel out
+      if (aLen > bLen) {
+        a[ia] = -(aLen - bLen); ib++;
+      } else if (bLen > aLen) {
+        b[ib] = -(bLen - aLen); ia++;
+      } else {
+        ia++; ib++;
+      }
+    } else if (!aIsRetain && bIsRetain) {
+      // a deletes, b retains
+      const minLen = Math.min(aLen, bLen);
+      aPrime.push(-minLen);
+      if (aLen > bLen) {
+        a[ia] = -(aLen - bLen); ib++;
+      } else if (bLen > aLen) {
+        b[ib] = bLen - aLen; ia++;
+      } else {
+        ia++; ib++;
+      }
+    } else {
+      // a retains, b deletes
+      const minLen = Math.min(aLen, bLen);
+      bPrime.push(-minLen);
+      if (aLen > bLen) {
+        a[ia] = aLen - bLen; ib++;
+      } else if (bLen > aLen) {
+        b[ib] = -(bLen - aLen); ia++;
+      } else {
+        ia++; ib++;
+      }
+    }
+  }
+
+  return [normalize(aPrime), normalize(bPrime)];
+}
+
+/** Compose two sequential operations into one: compose(a, b) = apply(doc, a) then apply(result, b). */
+export function compose(origA: Operation, origB: Operation): Operation {
+  if (targetLength(origA) !== baseLength(origB)) {
+    throw new Error(`Cannot compose: a's target length (${targetLength(origA)}) !== b's base length (${baseLength(origB)})`);
+  }
+
+  const a: OpComponent[] = [...origA];
+  const b: OpComponent[] = [...origB];
+  const result: Operation = [];
+  let ia = 0;
+  let ib = 0;
+
+  while (ia < a.length || ib < b.length) {
+    const ca = ia < a.length ? a[ia] : undefined;
+    const cb = ib < b.length ? b[ib] : undefined;
+
+    // a deletes go straight through
+    if (typeof ca === 'number' && ca < 0) {
+      result.push(ca);
+      ia++;
+      continue;
+    }
+
+    // b inserts go straight through
+    if (typeof cb === 'string') {
+      result.push(cb);
+      ib++;
+      continue;
+    }
+
+    if (ca === undefined && cb === undefined) break;
+    if (ca === undefined || cb === undefined) {
+      throw new Error('Compose mismatch');
+    }
+
+    if (typeof ca === 'string' && typeof cb === 'number' && cb > 0) {
+      // a inserts, b retains
+      const aLen = ca.length;
+      const bLen = cb;
+      const minLen = Math.min(aLen, bLen);
+      result.push(ca.slice(0, minLen));
+      if (aLen > bLen) {
+        a[ia] = ca.slice(bLen); ib++;
+      } else if (bLen > aLen) {
+        b[ib] = bLen - aLen; ia++;
+      } else {
+        ia++; ib++;
+      }
+    } else if (typeof ca === 'string' && typeof cb === 'number' && cb < 0) {
+      // a inserts, b deletes - inserted text is deleted, nothing in result
+      const aLen = ca.length;
+      const bLen = -cb;
+      if (aLen > bLen) {
+        a[ia] = ca.slice(bLen); ib++;
+      } else if (bLen > aLen) {
+        b[ib] = -(bLen - aLen); ia++;
+      } else {
+        ia++; ib++;
+      }
+    } else if (typeof ca === 'number' && ca > 0 && typeof cb === 'number' && cb > 0) {
+      // Both retain
+      const minLen = Math.min(ca, cb);
+      result.push(minLen);
+      if (ca > cb) {
+        a[ia] = ca - cb; ib++;
+      } else if (cb > ca) {
+        b[ib] = cb - ca; ia++;
+      } else {
+        ia++; ib++;
+      }
+    } else if (typeof ca === 'number' && ca > 0 && typeof cb === 'number' && cb < 0) {
+      // a retains, b deletes
+      const aLen = ca;
+      const bLen = -cb;
+      const minLen = Math.min(aLen, bLen);
+      result.push(-minLen);
+      if (aLen > bLen) {
+        a[ia] = aLen - bLen; ib++;
+      } else if (bLen > aLen) {
+        b[ib] = -(bLen - aLen); ia++;
+      } else {
+        ia++; ib++;
+      }
+    } else {
+      throw new Error(`Unexpected compose state: ca=${JSON.stringify(ca)}, cb=${JSON.stringify(cb)}`);
+    }
+  }
+
+  return normalize(result);
+}
+
+/** Validate that an operation is well-formed. */
+export function validate(op: unknown): op is Operation {
+  if (!Array.isArray(op)) return false;
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (!Number.isInteger(c) || c === 0) return false;
+    } else if (typeof c === 'string') {
+      if (c.length === 0) return false;
+    } else {
+      return false;
+    }
+  }
+  return true;
+}
