atestVersion(docId);\n    const version = latestVersion ? latestVersion.version : 1;\n\n    session = {\n      docId,\n      content: currentContent,\n      version,\n      minVersion: version,\n      operations: [],\n      clients: new Map(),\n    };\n    this.sessions.set(docId, session);\n    return session;\n  }\n\n  private handleClientMessage(clientId: string, msg: unknown): void {\n    if (!msg || typeof msg !== 'object') {\n      this.sendErrorToClient(clientId, 'Message must be an object');\n      return;\n    }\n\n    const m = msg as Record<string, unknown>;\n    if (m.type !== 'operation') {\n      this.sendErrorToClient(clientId, `Unknown message type: ${String(m.type)}`);\n      return;\n    }\n\n    const docId = m.docId as string;\n    const version = m.version as number;\n    const operation = m.operation as Operation;\n\n    if (!docId || typeof docId !== 'string') {\n      this.sendErrorToClient(clientId, 'docId is required');\n      return;\n    }\n    if (typeof version !== 'number' || !Number.isInteger(version) || version < 1) {\n      this.sendErrorToClient(clientId, 'version must be a positive integer');\n      return;\n    }\n    if (!validate(operation)) {\n      this.sendErrorToClient(clientId, 'Invalid operation format');\n      return;\n    }\n\n    const session = this.sessions.get(docId);\n    if (!session) {\n      this.sendErrorToClient(clientId, 'No active session for this document');\n      return;\n    }\n\n    const client = session.clients.get(clientId);\n    if (!client) {\n      this.sendErrorToClient(clientId, 'Client not found in session');\n      return;\n    }\n\n    // Check if version is too old (before our history window)\n    if (version < session.minVersion) {\n      this.sendMessage(client.ws, {\n        type: 'error',\n        message: `Version ${version} is too old. Please re-sync.`,\n      });\n      // Send a fresh sync so the client can recover\n      this.sendMessage(client.ws, {\n        type: 'sync',\n       