+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SFmmC8s5GUBDbNGQP43o7P","type":"tool_result","content":"     1→/**\n     2→ * Operational Transform (OT) module for collaborative text editing.\n     3→ *\n     4→ * Operations are arrays of components:\n     5→ * - positive number: retain N characters\n     6→ * - string: insert text\n     7→ * - negative number: delete N characters\n     8→ *\n     9→ * The \"base length\" of an operation is the total number of characters it expects\n    10→ * the input document to have (sum of retains + sum of abs(deletes)).\n    11→ * The \"target length\" is the length of the document after applying the operation\n    12→ * (sum of retains + sum of insert lengths).\n    13→ */\n    14→\n    15→export type OpComponent = number | string;\n    16→export type Operation = OpComponent[];\n    17→\n    18→export interface OperationMessage {\n    19→  type: 'operation';\n    20→  docId: string;\n    21→  version: number;\n    22→  operation: Operation;\n    23→  clientId: string;\n    24→}\n    25→\n    26→export interface SyncMessage {\n    27→  type: 'sync';\n    28→  docId: string;\n    29→  content: string;\n    30→  version: number;\n    31→}\n    32→\n    33→export interface AckMessage {\n    34→  type: 'ack';\n    35→  version: number;\n    36→}\n    37→\n    38→export interface ErrorMessage {\n    39→  type: 'error';\n    40→  message: string;\n    41→}\n    42→\n    43→export type ServerMessage = SyncMessage | AckMessage | ErrorMessage | (OperationMessage & { type: 'operation' });\n    44→export type ClientMessage = OperationMessage;\n    45→\n    46→/** Calculate the base length (expected input length) of an operation. */\n    47→export function baseLength(op: Operation): number {\n    48→  let len = 0;\n    49→  for (const c of op) {\n    50→    if (typeof c === 'number') {\n    51→      if (c > 0) len += c;       // retain\n    52→      else if (c < 0) len += -c; // delete\n    53→    }\n    54→    // inserts don't consume input characters\n    55→  }\n    56→  return len;\n    57→}\n    58→\n    59→/** Calculate the target length (output length) of an operation. */\n    60→export function targetLength(op: Operation): number {\n    61→  let len = 0;\n    62→  for (const c of op) {\n    63→    if (typeof c === 'number') {\n    64→      if (c > 0) len += c;       // retain\n    65→      // deletes don't produce output characters\n    66→    } else {\n    67→      len += c.length;           // insert\n    68→    }\n    69→  }\n    70→  return len;\n    71→}\n    72→\n    73→/** Normalize an operation by merging adjacent same-type components and removing no-ops. */\n    74→function normalize(op: Operation): Operation {\n    75→  const result: Operation = [];\n    76→  for (const c of op) {\n    77→    if (typeof c === 'number' && c === 0) continue;\n    78→    if (typeof c === 'string' && c === '') continue;\n    79→    if (result.length === 0) {\n    80→      result.push(c);\n    81→      continue;\n    82→    }\n    83→    const last = result[result.length - 1];\n    84→    if (typeof c === 'string' && typeof last === 'string') {\n    85→      result[result.length - 1] = last + c;\n    86→    } else if (typeof c === 'number' && typeof last === 'number') {\n    87→      if ((c > 0 && last > 0) || (c < 0 && last < 0)) {\n    88→        result[result.length - 1] = last + c;\n    89→      } else {\n    90→        result.push(c);\n    91→      }\n    92→    } else {\n    93→      result.push(c);\n    94→    }\n    95→  }\n    96→  return result;\n    97→}\n    98→\n    99→/** Apply an operation to a document string. */\n   100→export function apply(doc: string, op: Operation): string {\n   101→  if (baseLength(op) !== doc.length) {\n   102→    throw new Error(`Operation base length (${baseLength(op)}) does not match document length (${doc.length})`);\n   103→  }\n   104→  let result = '';\n   105→  let pos = 0;\n   106→  for (const c of op) {\n   107→    if (typeof c === 'string') {\n   108→      result += c;\n   109→    } else if (c > 0) {\n   110→      result += doc.slice(pos, pos + c);\n   111→      pos += c;\n   112→    } else if (c < 0) {\n   113→      pos += -c;\n   114→    }\n   115→  }\n   116→  return result;\n   117→}\n   118→\n   119→/**\n   120→ * Transform two concurrent operations a and b (both applied to the same document)\n   121→ * into a' and b' such that:\n   122→ *   apply(apply(doc, a), b') === apply(apply(doc, b), a')\n   123→ *\n   124→ * Returns [a', b'] where:\n   125→ *   a' is a transformed against b (apply after b)\n   126→ *   b' is b transformed against a (apply after a)\n   127→ */\n   128→export function transform(a: Operation, b: Operation): [Operation, Operation] {\n   129→  if (baseLength(a) !== baseLength(b)) {\n   130→    throw new Error(`Operations have different base lengths: ${baseLength(a)} vs ${baseLength(b)}`);\n   131→  }\n   132→\n   133→  const aPrime: Operation = [];\n   134→  const bPrime: Operation = [];\n   135→\n   136→  let ia = 0;\n   137→  let ib = 0;\n   138→\n   139→  while (ia < a.length || ib < b.length) {\n   140→    const ca = ia < a.length ? a[ia] : undefined;\n   141→    const cb = ib < b.length ? b[ib] : undefined;\n   142→\n   143→    // If a inserts, it goes into a' and b' retains over it\n   144→    if (typeof ca === 'string') {\n   145→      aPrime.push(ca);\n   146→      bPrime.push(ca.length);\n   147→      ia++;\n   148→      continue;\n   149→    }\n   150→\n   151→    // If b inserts, it goes into b' and a' retains over it\n   152→    if (typeof cb === 'string') {\n   153→      bPrime.push(cb);\n   154→      aPrime.push(cb.length);\n   155→      ib++;\n   156→      continue;\n   157→    }\n   158→\n   159→    if (ca === undefined && cb === undefined) break;\n   160→\n   161→    if (ca === undefined || cb === undefined) {\n   162→      throw new Error('Operation transform mismatch: one operation ran out before the other');\n   163→    }\n   164→\n   165→    // Both are numbers (retain or delete)\n   166→    const aIsRetain = ca > 0;\n   167→    const bIsRetain = cb > 0;\n   168→    const aLen = Math.abs(ca);\n   169→    const bLen = Math.abs(cb);\n   170→\n   171→    if (aIsRetain && bIsRetain) {\n   172→      // Both retain\n   173→      const minLen = Math.min(aLen, bLen);\n   174→      aPrime.push(minLen);\n   175→      bPrime.push(minLen);\n   176→      if (aLen > bLen) {\n   177→        a = [...a]; a[ia] = aLen - bLen; ib++;\n   178→      } else if (bLen > aLen) {\n   179→        b = [...b]; b[ib] = bLen - aLen; ia++;\n   180→      } else {\n   181→        ia++; ib++;\n   182→      }\n   183→    } else if (!aIsRetain && !bIsRetain) {\n   184→      // Both delete - deletions cancel out, neither produces output\n   185→      if (aLen > bLen) {\n   186→        a = [...a]; a[ia] = -(aLen - bLen); ib++;\n   187→      } else if (bLen > aLen) {\n   188→        b = [...b]; b[ib] = -(bLen - aLen); ia++;\n   189→      } else {\n   190→        ia++; ib++;\n   191→      }\n   192→    } else if (!aIsRetain && bIsRetain) {\n   193→      // a deletes, b retains\n   194→      const minLen = Math.min(aLen, bLen);\n   195→      aPrime.push(-minLen);\n   196→      // b's retain is consumed by a's delete, so nothing in bPrime\n   197→      if (aLen > bLen) {\n   198→        a = [...a]; a[ia] = -(aLen - bLen); ib++;\n   199→      } else if (bLen > aLen) {\n   200→        b = [...b]; b[ib] = bLen - aLen; ia++;\n   201→      } else {\n   202→        ia++; ib++;\n   203→      }\n   204→    } else {\n   205→      // a retains, b deletes\n   206→      const minLen = Math.min(aLen, bLen);\n   207→      bPrime.push(-minLen);\n   208→      // a's retain is consumed by b's delete, so nothing in aPrime\n   209→      if (aLen > bLen) {\n   210→        a = [...a]; a[ia] = aLen - bLen; ib++;\n   211→      } else if (bLen > aLen) {\n   212→        b = [...b]; b[ib] = -(bLen - aLen); ia++;\n   213→      } else {\n   214→        ia++; ib++;\n   215→      }\n   216→    }\n   217→  }\n   218→\n   219→  return [normalize(aPrime), normalize(bPrime)];\n   220→}\n   221→\n   222→/** Compose two sequential operations into one: compose(a, b) = apply(doc, a) then apply(result, b). */\n   223→export function compose(a: Operation, b: Operation): Operation {\n   224→  if (targetLength(a) !== baseLength(b)) {\n   225→    throw new Error(`Cannot compose: a's target length (${targetLength(a)}) !== b's base length (${baseLength(b)})`);\n   226→  }\n   227→\n   228→  const result: Operation = [];\n   229→  let ia = 0;\n   230→  let ib = 0;\n   231→\n   232→  while (ia < a.length || ib < b.length) {\n   233→    const ca = ia < a.length ? a[ia] : undefined;\n   234→    const cb = ib < b.length ? b[ib] : undefined;\n   235→\n   236→    // a deletes go straight through\n   237→    if (typeof ca === 'number' && ca < 0) {\n   238→      result.push(ca);\n   239→      ia++;\n   240→      continue;\n   241→    }\n   242→\n   243→    // b inserts go straight through\n   244→    if (typeof cb === 'string') {\n   245→      result.push(cb);\n   246→      ib++;\n   247→      continue;\n   248→    }\n   249→\n   250→    if (ca === undefined && cb === undefined) break;\n   251→    if (ca === undefined || cb === undefined) {\n   252→      throw new Error('Compose mismatch');\n   253→    }\n   254→\n   255→    if (typeof ca === 'string' && typeof cb === 'number' && cb > 0) {\n   256→      // a inserts, b retains\n   257→      const aLen = ca.length;\n   258→      const bLen = cb;\n   259→      const minLen = Math.min(aLen, bLen);\n   260→      result.push(ca.slice(0, minLen));\n   261→      if (aLen > bLen) {\n   262→        a = [...a]; a[ia] = ca.slice(bLen); ib++;\n   263→      } else if (bLen > aLen) {\n   264→        b = [...b]; b[ib] = bLen - aLen; ia++;\n   265→      } else {\n   266→        ia++; ib++;\n   267→      }\n   268→    } else if (typeof ca === 'string' && typeof cb === 'number' && cb < 0) {\n   269→      // a inserts, b deletes - inserted text is deleted, nothing in result\n   270→      const aLen = ca.length;\n   271→      const bLen = -cb;\n   272→      if (aLen > bLen) {\n   273→        a = [...a]; a[ia] = ca.slice(bLen); ib++;\n   274→      } else if (bLen > aLen) {\n   275→        b = [...b]; b[ib] = -(bLen - aLen); ia++;\n   276→      } else {\n   277→        ia++; ib++;\n   278→      }\n   279→    } else if (typeof ca === 'number' && ca > 0 && typeof cb === 'number' && cb > 0) {\n   280→      // Both retain\n   281→      const minLen = Math.min(ca, cb);\n   282→      result.push(minLen);\n   283→      if (ca > cb) {\n   284→        a = [...a]; a[ia] = ca - cb; ib++;\n   285→      } else if (cb > ca) {\n   286→        b = [...b]; b[ib] = cb - ca; ia++;\n   287→      } else {\n   288→        ia++; ib++;\n   289→      }\n   290→    } else if (typeof ca === 'number' && ca > 0 && typeof cb === 'number' && cb < 0) {\n   291→      // a retains, b deletes\n   292→      const aLen = ca;\n   293→      const bLen = -cb;\n   294→      const minLen = Math.min(aLen, bLen);\n   295→      result.push(-minLen);\n   296→      if (aLen > bLen) {\n   297→        a = [...a]; a[ia] = aLen - bLen; ib++;\n   298→      } else if (bLen > aLen) {\n   299→        b = [...b]; b[ib] = -(bLen - aLen); ia++;\n   300→      } else {\n   301→        ia++; ib++;\n   302→      }\n   303→    } else {\n   304→      throw new Error(`Unexpected compose state: ca=${JSON.stringify(ca)}, cb=${JSON.stringify(cb)}`);\n   305→    }\n   306→  }\n   307→\n   308→  return normalize(result);\n   309→}\n   310→\n   311→/** Validate that an operation is well-formed. */\n   312→export function validate(op: unknown): op is Operation {\n   313→  if (!Array.isArray(op)) return false;\n   314→  for (const c of op) {\n   315→    if (typeof c === 'number') {\n   316→      if (!Number.isInteger(c) || c === 0) return false;\n   317→    } else if (typeof c === 'string') {\n   318→      if (c.length === 0) return false;\n   319→    } else {\n   320→      return false;\n   321→    }\n   322→  }\n   323→  return true;\n   324→}\n   325→"}]},"parent_tool_use_id":"toolu_01CKt47vPmsp1npV36twR3jt","session_id":"1fc55f52-535e-46e1-825e-ef3cdbe6cf96","uuid":"d5d705b8-0d4b-426f-881e-8444897683f2"}
