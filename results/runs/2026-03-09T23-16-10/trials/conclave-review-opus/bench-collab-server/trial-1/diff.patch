+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XE8CSJ1Npn4jqiC61S4ppA","type":"tool_result","content":"     1→import { WebSocketServer, WebSocket } from 'ws';\n     2→import type { Server } from 'node:http';\n     3→import { randomUUID } from 'node:crypto';\n     4→import type { DocumentStore } from './db.js';\n     5→import { apply, transform, validate, baseLength } from './ot.js';\n     6→import type { Operation, ServerMessage } from './ot.js';\n     7→\n     8→interface ClientConnection {\n     9→  id: string;\n    10→  ws: WebSocket;\n    11→  docId: string;\n    12→}\n    13→\n    14→interface DocumentSession {\n    15→  docId: string;\n    16→  content: string;\n    17→  version: number;\n    18→  /** History of operations, indexed by version (op at index i transforms version i to i+1) */\n    19→  operations: Operation[];\n    20→  clients: Map<string, ClientConnection>;\n    21→}\n    22→\n    23→export class CollaborationManager {\n    24→  private sessions = new Map<string, DocumentSession>();\n    25→  private wss: WebSocketServer | null = null;\n    26→  private store: DocumentStore;\n    27→  private closed = false;\n    28→\n    29→  constructor(store: DocumentStore) {\n    30→    this.store = store;\n    31→  }\n    32→\n    33→  attach(server: Server): void {\n    34→    this.wss = new WebSocketServer({ server });\n    35→\n    36→    this.wss.on('connection', (ws, req) => {\n    37→      if (this.closed) {\n    38→        ws.close(1001, 'Server shutting down');\n    39→        return;\n    40→      }\n    41→\n    42→      const url = req.url ?? '';\n    43→      // Expected path: /ws/documents/:docId\n    44→      const match = url.match(/^\\/ws\\/documents\\/([^/?]+)/);\n    45→      if (!match) {\n    46→        this.sendMessage(ws, { type: 'error', message: 'Invalid WebSocket path. Use /ws/documents/:docId' });\n    47→        ws.close(1008, 'Invalid path');\n    48→        return;\n    49→      }\n    50→\n    51→      const docId = match[1];\n    52→      const doc = this.store.getById(docId);\n    53→      if (!doc) {\n    54→        this.sendMessage(ws, { type: 'error', message: 'Document not found' });\n    55→        ws.close(1008, 'Document not found');\n    56→        return;\n    57→      }\n    58→\n    59→      const clientId = randomUUID();\n    60→      const session = this.getOrCreateSession(docId, doc.content);\n    61→      const client: ClientConnection = { id: clientId, ws, docId };\n    62→      session.clients.set(clientId, client);\n    63→\n    64→      // Send current document state\n    65→      this.sendMessage(ws, {\n    66→        type: 'sync',\n    67→        docId,\n    68→        content: session.content,\n    69→        version: session.version,\n    70→      });\n    71→\n    72→      ws.on('message', (data) => {\n    73→        if (this.closed) return;\n    74→        try {\n    75→          const raw = typeof data === 'string' ? data : data.toString('utf-8');\n    76→          const msg = JSON.parse(raw);\n    77→          this.handleClientMessage(clientId, msg);\n    78→        } catch (err) {\n    79→          this.sendMessage(ws, {\n    80→            type: 'error',\n    81→            message: `Invalid message: ${err instanceof Error ? err.message : String(err)}`,\n    82→          });\n    83→        }\n    84→      });\n    85→\n    86→      ws.on('close', () => {\n    87→        session.clients.delete(clientId);\n    88→        if (!this.closed && session.clients.size === 0) {\n    89→          this.persistSession(session);\n    90→        }\n    91→      });\n    92→\n    93→      ws.on('error', () => {\n    94→        session.clients.delete(clientId);\n    95→      });\n    96→    });\n    97→  }\n    98→\n    99→  private getOrCreateSession(docId: string, currentContent: string): DocumentSession {\n   100→    let session = this.sessions.get(docId);\n   101→    if (session) return session;\n   102→\n   103→    // Load version from DB\n   104→    const latestVersion = this.store.getLatestVersion(docId);\n   105→    const version = latestVersion ? latestVersion.version : 1;\n   106→\n   107→    session = {\n   108→      docId,\n   109→      content: currentContent,\n   110→      version,\n   111→      operations: [],\n   112→      clients: new Map(),\n   113→    };\n   114→    this.sessions.set(docId, session);\n   115→    return session;\n   116→  }\n   117→\n   118→  private handleClientMessage(clientId: string, msg: unknown): void {\n   119→    if (!msg || typeof msg !== 'object') {\n   120→      this.sendErrorToClient(clientId, 'Message must be an object');\n   121→      return;\n   122→    }\n   123→\n   124→    const m = msg as Record<string, unknown>;\n   125→    if (m.type !== 'operation') {\n   126→      this.sendErrorToClient(clientId, `Unknown message type: ${String(m.type)}`);\n   127→      return;\n   128→    }\n   129→\n   130→    const docId = m.docId as string;\n   131→    const version = m.version as number;\n   132→    const operation = m.operation as Operation;\n   133→\n   134→    if (!docId || typeof docId !== 'string') {\n   135→      this.sendErrorToClient(clientId, 'docId is required');\n   136→      return;\n   137→    }\n   138→    if (typeof version !== 'number' || !Number.isInteger(version) || version < 1) {\n   139→      this.sendErrorToClient(clientId, 'version must be a positive integer');\n   140→      return;\n   141→    }\n   142→    if (!validate(operation)) {\n   143→      this.sendErrorToClient(clientId, 'Invalid operation format');\n   144→      return;\n   145→    }\n   146→\n   147→    const session = this.sessions.get(docId);\n   148→    if (!session) {\n   149→      this.sendErrorToClient(clientId, 'No active session for this document');\n   150→      return;\n   151→    }\n   152→\n   153→    const client = session.clients.get(clientId);\n   154→    if (!client) {\n   155→      this.sendErrorToClient(clientId, 'Client not found in session');\n   156→      return;\n   157→    }\n   158→\n   159→    // The client's operation was based on `version`. We need to transform it\n   160→    // against all operations that have happened since that version.\n   161→    const startIndex = version - session.version + session.operations.length;\n   162→    if (startIndex < 0 || startIndex > session.operations.length) {\n   163→      this.sendMessage(client.ws, {\n   164→        type: 'error',\n   165→        message: `Version ${version} is too old or invalid. Current server version is ${session.version}. Please re-sync.`,\n   166→      });\n   167→      return;\n   168→    }\n   169→\n   170→    let transformedOp = operation;\n   171→    try {\n   172→      for (let i = startIndex; i < session.operations.length; i++) {\n   173→        const [newOp] = transform(transformedOp, session.operations[i]);\n   174→        transformedOp = newOp;\n   175→      }\n   176→\n   177→      // Validate that the transformed operation matches current document length\n   178→      if (baseLength(transformedOp) !== session.content.length) {\n   179→        this.sendMessage(client.ws, {\n   180→          type: 'error',\n   181→          message: `Operation base length (${baseLength(transformedOp)}) doesn't match document length (${session.content.length})`,\n   182→        });\n   183→        return;\n   184→      }\n   185→\n   186→      // Apply the transformed operation\n   187→      session.content = apply(session.content, transformedOp);\n   188→      session.version++;\n   189→      session.operations.push(transformedOp);\n   190→\n   191→      // Persist to database\n   192→      this.store.updateContent(docId, session.content, transformedOp);\n   193→\n   194→      // Acknowledge the sender\n   195→      this.sendMessage(client.ws, {\n   196→        type: 'ack',\n   197→        version: session.version,\n   198→      });\n   199→\n   200→      // Broadcast to other clients\n   201→      for (const [id, otherClient] of session.clients) {\n   202→        if (id === clientId) continue;\n   203→        this.sendMessage(otherClient.ws, {\n   204→          type: 'operation',\n   205→          docId,\n   206→          version: session.version,\n   207→          operation: transformedOp,\n   208→          clientId,\n   209→        });\n   210→      }\n   211→    } catch (err) {\n   212→      this.sendMessage(client.ws, {\n   213→        type: 'error',\n   214→        message: `Failed to apply operation: ${err instanceof Error ? err.message : String(err)}`,\n   215→      });\n   216→    }\n   217→  }\n   218→\n   219→  private sendErrorToClient(clientId: string, message: string): void {\n   220→    for (const session of this.sessions.values()) {\n   221→      const client = session.clients.get(clientId);\n   222→      if (client) {\n   223→        this.sendMessage(client.ws, { type: 'error', message });\n   224→        return;\n   225→      }\n   226→    }\n   227→  }\n   228→\n   229→  private sendMessage(ws: WebSocket, msg: ServerMessage): void {\n   230→    if (ws.readyState === WebSocket.OPEN) {\n   231→      ws.send(JSON.stringify(msg));\n   232→    }\n   233→  }\n   234→\n   235→  private persistSession(session: DocumentSession): void {\n   236→    if (this.closed) return;\n   237→    try {\n   238→      this.store.updateContent(session.docId, session.content);\n   239→    } catch {\n   240→      // DB might be closed\n   241→    }\n   242→  }\n   243→\n   244→  closeAll(): void {\n   245→    // Persist all sessions before marking as closed\n   246→    for (const session of this.sessions.values()) {\n   247→      this.persistSession(session);\n   248→    }\n   249→    this.closed = true;\n   250→\n   251→    // Close all client connections\n   252→    for (const session of this.sessions.values()) {\n   253→      for (const client of session.clients.values()) {\n   254→        client.ws.close(1001, 'Server shutting down');\n   255→      }\n   256→    }\n   257→    this.sessions.clear();\n   258→    if (this.wss) {\n   259→      this.wss.close();\n   260→      this.wss = null;\n   261→    }\n   262→  }\n   263→}\n   264→"}]},"parent_tool_use_id":"toolu_01CKt47vPmsp1npV36twR3jt","session_id":"1fc55f52-535e-46e1-825e-ef3cdbe6cf96","uuid":"78f88de6-c4f5-42eb-a1c8-c5de059e64d4"}
