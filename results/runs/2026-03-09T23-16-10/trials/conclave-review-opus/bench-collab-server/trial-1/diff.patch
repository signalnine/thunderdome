+import express from 'express';
+import { createServer, type Server } from 'node:http';
+import { createDb, DocumentStore } from './db.js';
+import { createRouter } from './routes.js';
+import { CollaborationManager } from './collaboration.js';
+
+export interface AppInstance {
+  app: express.Express;
+  start(port?: number): Promise<number>;
+  stop(): Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db = createDb(dbPath);
+  const store = new DocumentStore(db);
+  const app = express();
+  const collab = new CollaborationManager(store);
+  const router = createRouter(store, collab);
+  app.use('/api', router);
+
+  const httpServer: Server = createServer(app);
+  collab.attach(httpServer);
+
+  let listening = false;
+
+  return {
+    app,
+    async start(port = 0): Promise<number> {
+      return new Promise((resolve, reject) => {
+        httpServer.listen(port, () => {
+          listening = true;
+          const addr = httpServer.address();
+          const actualPort = typeof addr === 'object' && addr ? addr.port : port;
+          resolve(actualPort);
+        });
+        httpServer.on('error', reject);
+      });
+    },
+    async stop(): Promise<void> {
+      collab.closeAll();
+      if (listening) {
+        return new Promise((resolve, reject) => {
+          httpServer.close((err) => {
+            store.close();
+            if (err) reject(err);
+            else resolve();
+          });
+        });
+      } else {
+        store.close();
+      }
+    },
+  };
+}
