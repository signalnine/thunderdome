diff --git a/src/ot.test.ts b/src/ot.test.ts
new file mode 100644
index 0000000..6411892
--- /dev/null
+++ b/src/ot.test.ts
@@ -0,0 +1,165 @@
+import { describe, it, expect } from 'vitest';
+import { apply, transform, compose, validate, baseLength, targetLength } from './ot.js';
+import type { Operation } from './ot.js';
+
+describe('OT primitives', () => {
+  describe('apply', () => {
+    it('should apply a simple insert', () => {
+      expect(apply('', ['hello'])).toBe('hello');
+    });
+
+    it('should apply insert at beginning', () => {
+      expect(apply('world', ['hello ', 5])).toBe('hello world');
+    });
+
+    it('should apply insert at end', () => {
+      expect(apply('hello', [5, ' world'])).toBe('hello world');
+    });
+
+    it('should apply insert in middle', () => {
+      expect(apply('hllo', [1, 'e', 3])).toBe('hello');
+    });
+
+    it('should apply a simple delete', () => {
+      expect(apply('hello', [-5])).toBe('');
+    });
+
+    it('should apply delete from beginning', () => {
+      expect(apply('hello world', [-6, 5])).toBe('world');
+    });
+
+    it('should apply delete from end', () => {
+      expect(apply('hello world', [5, -6])).toBe('hello');
+    });
+
+    it('should apply retain only (identity)', () => {
+      expect(apply('hello', [5])).toBe('hello');
+    });
+
+    it('should apply mixed operations', () => {
+      // "hello world" -> "Hi world!"
+      expect(apply('hello world', [-5, 'Hi', 6, '!'])).toBe('Hi world!');
+    });
+
+    it('should throw on length mismatch', () => {
+      expect(() => apply('hello', [10])).toThrow();
+    });
+  });
+
+  describe('baseLength and targetLength', () => {
+    it('should compute base length correctly', () => {
+      expect(baseLength([5, 'abc', -3])).toBe(8);
+    });
+
+    it('should compute target length correctly', () => {
+      expect(targetLength([5, 'abc', -3])).toBe(8);
+    });
+  });
+
+  describe('validate', () => {
+    it('should accept valid operations', () => {
+      expect(validate([5, 'hello', -3])).toBe(true);
+      expect(validate([])).toBe(true);
+    });
+
+    it('should reject invalid operations', () => {
+      expect(validate('not an array')).toBe(false);
+      expect(validate([0])).toBe(false);
+      expect(validate([1.5])).toBe(false);
+      expect(validate([''])).toBe(false);
+      expect(validate([null])).toBe(false);
+      expect(validate([{}])).toBe(false);
+    });
+  });
+
+  describe('transform', () => {
+    it('should handle two inserts at the same position', () => {
+      // Both insert at position 0 on an empty doc
+      const a: Operation = ['a'];
+      const b: Operation = ['b'];
+      const [aPrime, bPrime] = transform(a, b);
+      const doc = '';
+      // Apply a then b', or b then a'
+      const result1 = apply(apply(doc, a), bPrime);
+      const result2 = apply(apply(doc, b), aPrime);
+      expect(result1).toBe(result2);
+    });
+
+    it('should handle inserts at different positions', () => {
+      const doc = 'hello';
+      const a: Operation = [2, 'X', 3]; // "heXllo"
+      const b: Operation = [4, 'Y', 1]; // "hellYo"
+      const [aPrime, bPrime] = transform(a, b);
+      const result1 = apply(apply(doc, a), bPrime);
+      const result2 = apply(apply(doc, b), aPrime);
+      expect(result1).toBe(result2);
+      expect(result1).toBe('heXllYo');
+    });
+
+    it('should handle concurrent deletes of different regions', () => {
+      const doc = 'abcdef';
+      const a: Operation = [-2, 4]; // delete "ab" -> "cdef"
+      const b: Operation = [4, -2]; // delete "ef" -> "abcd"
+      const [aPrime, bPrime] = transform(a, b);
+      const result1 = apply(apply(doc, a), bPrime);
+      const result2 = apply(apply(doc, b), aPrime);
+      expect(result1).toBe(result2);
+      expect(result1).toBe('cd');
+    });
+
+    it('should handle concurrent deletes of same region', () => {
+      const doc = 'abcdef';
+      const a: Operation = [-3, 3]; // delete "abc" -> "def"
+      const b: Operation = [-3, 3]; // delete "abc" -> "def"
+      const [aPrime, bPrime] = transform(a, b);
+      const result1 = apply(apply(doc, a), bPrime);
+      const result2 = apply(apply(doc, b), aPrime);
+      expect(result1).toBe(result2);
+      expect(result1).toBe('def');
+    });
+
+    it('should handle insert vs delete', () => {
+      const doc = 'hello';
+      const a: Operation = [2, 'X', 3]; // insert X after 'he' -> "heXllo"
+      const b: Operation = [1, -3, 1];  // delete 'ell' -> "ho"
+      const [aPrime, bPrime] = transform(a, b);
+      const result1 = apply(apply(doc, a), bPrime);
+      const result2 = apply(apply(doc, b), aPrime);
+      expect(result1).toBe(result2);
+    });
+
+    it('should produce convergent results for complex concurrent edits', () => {
+      const doc = 'The quick brown fox';
+      // User A: "The quick brown fox" -> "The slow brown fox"
+      const a: Operation = [4, -5, 'slow', 10];
+      // User B: "The quick brown fox" -> "The quick red fox"
+      const b: Operation = [10, -5, 'red', 4];
+      const [aPrime, bPrime] = transform(a, b);
+      const result1 = apply(apply(doc, a), bPrime);
+      const result2 = apply(apply(doc, b), aPrime);
+      expect(result1).toBe(result2);
+    });
+  });
+
+  describe('compose', () => {
+    it('should compose two sequential operations', () => {
+      const doc = 'hello';
+      const a: Operation = [5, ' world']; // "hello world"
+      const b: Operation = [11, '!']; // "hello world!"
+      const composed = compose(a, b);
+      expect(apply(doc, composed)).toBe('hello world!');
+    });
+
+    it('should compose insert then delete', () => {
+      const doc = 'hello';
+      const a: Operation = [5, ' world']; // "hello world"
+      const b: Operation = [-6, 5]; // "world"
+      const composed = compose(a, b);
+      expect(apply(doc, composed)).toBe('world');
+    });
+
+    it('should throw if lengths do not match', () => {
+      expect(() => compose([5], [3])).toThrow();
+    });
+  });
+});
