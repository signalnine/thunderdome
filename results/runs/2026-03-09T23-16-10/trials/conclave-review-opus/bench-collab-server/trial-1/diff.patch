+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012wMkvM3MeNCiVfJEmwwS1y","type":"tool_result","content":"     1→import Database from 'better-sqlite3';\n     2→import { readFileSync } from 'node:fs';\n     3→import { join, dirname } from 'node:path';\n     4→import { fileURLToPath } from 'node:url';\n     5→import { randomUUID } from 'node:crypto';\n     6→import type { Operation } from './ot.js';\n     7→\n     8→const __dirname = dirname(fileURLToPath(import.meta.url));\n     9→\n    10→export interface DocumentRow {\n    11→  id: string;\n    12→  title: string;\n    13→  content: string;\n    14→  created_at: string;\n    15→  updated_at: string;\n    16→}\n    17→\n    18→export interface VersionRow {\n    19→  id: number;\n    20→  document_id: string;\n    21→  version: number;\n    22→  content: string;\n    23→  operation: string | null;\n    24→  created_at: string;\n    25→}\n    26→\n    27→export function createDb(dbPath?: string): Database.Database {\n    28→  const db = new Database(dbPath ?? ':memory:');\n    29→  db.pragma('journal_mode = WAL');\n    30→  db.pragma('foreign_keys = ON');\n    31→\n    32→  const schemaPath = join(__dirname, '..', 'schema.sql');\n    33→  const schema = readFileSync(schemaPath, 'utf-8');\n    34→  db.exec(schema);\n    35→\n    36→  return db;\n    37→}\n    38→\n    39→export class DocumentStore {\n    40→  private db: Database.Database;\n    41→\n    42→  private stmts: {\n    43→    insert: Database.Statement;\n    44→    getById: Database.Statement;\n    45→    list: Database.Statement;\n    46→    updateContent: Database.Statement;\n    47→    updateTitle: Database.Statement;\n    48→    deleteDoc: Database.Statement;\n    49→    insertVersion: Database.Statement;\n    50→    getVersions: Database.Statement;\n    51→    getLatestVersion: Database.Statement;\n    52→    getVersion: Database.Statement;\n    53→  };\n    54→\n    55→  constructor(db: Database.Database) {\n    56→    this.db = db;\n    57→    this.stmts = {\n    58→      insert: db.prepare('INSERT INTO documents (id, title, content) VALUES (?, ?, ?)'),\n    59→      getById: db.prepare('SELECT * FROM documents WHERE id = ?'),\n    60→      list: db.prepare('SELECT * FROM documents ORDER BY updated_at DESC'),\n    61→      updateContent: db.prepare(\"UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?\"),\n    62→      updateTitle: db.prepare(\"UPDATE documents SET title = ?, updated_at = datetime('now') WHERE id = ?\"),\n    63→      deleteDoc: db.prepare('DELETE FROM documents WHERE id = ?'),\n    64→      insertVersion: db.prepare('INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)'),\n    65→      getVersions: db.prepare('SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC'),\n    66→      getLatestVersion: db.prepare('SELECT * FROM versions WHERE document_id = ? ORDER BY version DESC LIMIT 1'),\n    67→      getVersion: db.prepare('SELECT * FROM versions WHERE document_id = ? AND version = ?'),\n    68→    };\n    69→  }\n    70→\n    71→  create(title: string, content: string = ''): DocumentRow {\n    72→    const id = randomUUID();\n    73→    this.stmts.insert.run(id, title, content);\n    74→    // Create initial version\n    75→    this.stmts.insertVersion.run(id, 1, content, null);\n    76→    return this.stmts.getById.get(id) as DocumentRow;\n    77→  }\n    78→\n    79→  getById(id: string): DocumentRow | undefined {\n    80→    return this.stmts.getById.get(id) as DocumentRow | undefined;\n    81→  }\n    82→\n    83→  list(): DocumentRow[] {\n    84→    return this.stmts.list.all() as DocumentRow[];\n    85→  }\n    86→\n    87→  updateContent(id: string, content: string, operation?: Operation): DocumentRow | undefined {\n    88→    const doc = this.getById(id);\n    89→    if (!doc) return undefined;\n    90→\n    91→    this.stmts.updateContent.run(content, id);\n    92→\n    93→    // Create a new version\n    94→    const latestVersion = this.stmts.getLatestVersion.get(id) as VersionRow | undefined;\n    95→    const nextVersion = latestVersion ? latestVersion.version + 1 : 1;\n    96→    this.stmts.insertVersion.run(id, nextVersion, content, operation ? JSON.stringify(operation) : null);\n    97→\n    98→    return this.stmts.getById.get(id) as DocumentRow;\n    99→  }\n   100→\n   101→  updateTitle(id: string, title: string): DocumentRow | undefined {\n   102→    const doc = this.getById(id);\n   103→    if (!doc) return undefined;\n   104→    this.stmts.updateTitle.run(title, id);\n   105→    return this.stmts.getById.get(id) as DocumentRow;\n   106→  }\n   107→\n   108→  delete(id: string): boolean {\n   109→    const result = this.stmts.deleteDoc.run(id);\n   110→    return result.changes > 0;\n   111→  }\n   112→\n   113→  getVersions(documentId: string): VersionRow[] {\n   114→    return this.stmts.getVersions.all(documentId) as VersionRow[];\n   115→  }\n   116→\n   117→  getVersion(documentId: string, version: number): VersionRow | undefined {\n   118→    return this.stmts.getVersion.get(documentId, version) as VersionRow | undefined;\n   119→  }\n   120→\n   121→  getLatestVersion(documentId: string): VersionRow | undefined {\n   122→    return this.stmts.getLatestVersion.get(documentId) as VersionRow | undefined;\n   123→  }\n   124→\n   125→  close(): void {\n   126→    this.db.close();\n   127→  }\n   128→}\n   129→"}]},"parent_tool_use_id":"toolu_01CKt47vPmsp1npV36twR3jt","session_id":"1fc55f52-535e-46e1-825e-ef3cdbe6cf96","uuid":"2fd7347b-f47a-49a7-9dd1-da1f16b81db8"}
