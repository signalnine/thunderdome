n message type: ${String(m.type)}`);\n      return;\n    }\n\n    const docId = m.docId as string;\n    const version = m.version as number;\n    const operation = m.operation as Operation;\n\n    if (!docId || typeof docId !== 'string') {\n      this.sendErrorToClient(clientId, 'docId is required');\n      return;\n    }\n    if (typeof version !== 'number' || !Number.isInteger(version) || version < 1) {\n      this.sendErrorToClient(clientId, 'version must be a positive integer');\n      return;\n    }\n    if (!validate(operation)) {\n      this.sendErrorToClient(clientId, 'Invalid operation format');\n      return;\n    }\n\n    const session = this.sessions.get(docId);\n    if (!session) {\n      this.sendErrorToClient(clientId, 'No active session for this document');\n      return;\n    }\n\n    const client = session.clients.get(clientId);\n    if (!client) {\n      this.sendErrorToClient(clientId, 'Client not found in session');\n      return;\n    }\n\n    // The client's operation was based on `version`. We need to transform it\n    // against all operations that have happened since that version.\n    const startIndex = version - session.version + session.operations.length;\n    if (startIndex < 0 || startIndex > session.operations.length) {\n      this.sendMessage(client.ws, {\n        type: 'error',\n        message: `Version ${version} is too old or invalid. Current server version is ${session.version}. Please re-sync.`,\n      });\n      return;\n    }\n\n    let transformedOp = operation;\n    try {\n      for (let i = startIndex; i < session.operations.length; i++) {\n        const [newOp] = transform(transformedOp, session.operations[i]);\n        transformedOp = newOp;\n      }\n\n      // Validate that the transformed operation matches current document length\n      if (baseLength(transformedOp) !== session.content.length) {\n        this.sendMessage(client.ws, {\n          type: 'error',\n          message: `Operation base length (${baseLength(transformedOp)}) doesn't match document length (${session.content.length})`,\n        });\n        return;\n      }\n\n      // Apply the transformed operation\n      session.content = apply(session.content, transformedOp);\n      session.version++;\n      session.operations.push(transformedOp);\n\n      // Persist to database\n      this.store.updateContent(docId, session.content, transformedOp);\n\n      // Acknowledge the sender\n      this.sendMessage(client.ws, {\n        type: 'ack',\n        version: session.version,\n      });\n\n      // Broadcast to other clients\n      for (const [id, otherClient] of session.clients) {\n        if (id === clientId) continue;\n        this.sendMessage(otherClient.ws, {\n          type: 'operation',\n          docId,\n          version: session.version,\n          operation: transformedOp,\n          clientId,\n        });\n      }\n    } catch (err) {\n      this.sendMessage(client.ws, {\n        type: 'error',\n        message: `Failed to apply operation: ${err instanceof Error ? err.message : String(err)}`,\n      });\n    }\n  }\n\n  private sendErrorToClient(clientId: string, message: string): void {\n    for (const session of this.sessions.values()) {\n      const client = session.clients.get(clientId);\n      if (client) {\n        this.sendMessage(client.ws, { type: 'error', message });\n        return;\n      }\n    }\n  }\n\n  private sendMessage(ws: WebSocket, msg: ServerMessage): void {\n    if (ws.readyState === WebSocket.OPEN) {\n      ws.send(JSON.stringify(msg));\n    }\n  }\n\n  private persistSession(session: DocumentSession): void {\n    this.store.updateContent(session.docId, session.content);\n  }\n\n  closeAll(): void {\n    // Persist all sessions before closing\n    for (const session of this.sessions.values()) {\n      this.persistSession(session);\n      for (const client of session.clients.values()) {\n        client.ws.close(1001, 'Server shutting down');\n      }\n    }\n    this.sessions.clear();