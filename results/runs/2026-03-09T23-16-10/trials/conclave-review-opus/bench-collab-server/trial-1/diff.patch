SC'),\n      updateContent: db.prepare(\"UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?\"),\n      updateTitle: db.prepare(\"UPDATE documents SET title = ?, updated_at = datetime('now') WHERE id = ?\"),\n      deleteDoc: db.prepare('DELETE FROM documents WHERE id = ?'),\n      insertVersion: db.prepare('INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)'),\n      getVersions: db.prepare('SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC'),\n      getLatestVersion: db.prepare('SELECT * FROM versions WHERE document_id = ? ORDER BY version DESC LIMIT 1'),\n      getVersion: db.prepare('SELECT * FROM versions WHERE document_id = ? AND version = ?'),\n    };\n  }\n\n  create(title: string, content: string = ''): DocumentRow {\n    const id = randomUUID();\n    this.stmts.insert.run(id, title, content);\n    // Create initial version\n    this.stmts.insertVersion.run(id, 1, content, null);\n    return this.stmts.getById.get(id) as DocumentRow;\n  }\n\n  getById(id: string): DocumentRow | undefined {\n    return this.stmts.getById.get(id) as DocumentRow | undefined;\n  }\n\n  list(): DocumentRow[] {\n    return this.stmts.list.all() as DocumentRow[];\n  }\n\n  updateContent(id: string, content: string, operation?: Operation): DocumentRow | undefined {\n    const doc = this.getById(id);\n    if (!doc) return undefined;\n\n    this.stmts.updateContent.run(content, id);\n\n    // Create a new version\n    const latestVersion = this.stmts.getLatestVersion.get(id) as VersionRow | undefined;\n    const nextVersion = latestVersion ? latestVersion.version + 1 : 1;\n    this.stmts.insertVersion.run(id, nextVersion, content, operation ? JSON.stringify(operation) : null);\n\n    return this.stmts.getById.get(id) as DocumentRow;\n  }\n\n  updateTitle(id: string, title: string): DocumentRow | undefined {\n    const doc = this.getById(id);\n    if (!doc) return undefined;\n    this.stmts.updateTitle.run(title,