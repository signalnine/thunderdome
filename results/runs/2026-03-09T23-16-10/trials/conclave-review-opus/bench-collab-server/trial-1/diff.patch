ation: string | null;\n  created_at: string;\n}\n\nexport function createDb(dbPath?: string): Database.Database {\n  const db = new Database(dbPath ?? ':memory:');\n  db.pragma('journal_mode = WAL');\n  db.pragma('foreign_keys = ON');\n\n  const schemaPath = join(__dirname, '..', 'schema.sql');\n  const schema = readFileSync(schemaPath, 'utf-8');\n  db.exec(schema);\n\n  return db;\n}\n\nexport class DocumentStore {\n  private db: Database.Database;\n\n  private stmts: {\n    insert: Database.Statement;\n    getById: Database.Statement;\n    list: Database.Statement;\n    updateContent: Database.Statement;\n    updateTitle: Database.Statement;\n    deleteDoc: Database.Statement;\n    insertVersion: Database.Statement;\n    getVersions: Database.Statement;\n    getLatestVersion: Database.Statement;\n    getVersion: Database.Statement;\n  };\n\n  constructor(db: Database.Database) {\n    this.db = db;\n    this.stmts = {\n      insert: db.prepare('INSERT INTO documents (id, title, content) VALUES (?, ?, ?)'),\n      getById: db.prepare('SELECT * FROM documents WHERE id = ?'),\n      list: db.prepare('SELECT * FROM documents ORDER BY updated_at DESC'),\n      updateContent: db.prepare(\"UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?\"),\n      updateTitle: db.prepare(\"UPDATE documents SET title = ?, updated_at = datetime('now') WHERE id = ?\"),\n      deleteDoc: db.prepare('DELETE FROM documents WHERE id = ?'),\n      insertVersion: db.prepare('INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)'),\n      getVersions: db.prepare('SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC'),\n      getLatestVersion: db.prepare('SELECT * FROM versions WHERE document_id = ? ORDER BY version DESC LIMIT 1'),\n      getVersion: db.prepare('SELECT * FROM versions WHERE document_id = ? AND version = ?'),\n    };\n  }\n\n  create(title: string, content: string = ''): DocumentRow {\n    const id = randomUUID();