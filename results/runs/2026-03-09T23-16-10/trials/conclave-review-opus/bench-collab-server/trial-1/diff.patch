s';\nimport type { Server } from 'node:http';\nimport { randomUUID } from 'node:crypto';\nimport type { DocumentStore } from './db.js';\nimport { apply, transform, validate, baseLength } from './ot.js';\nimport type { Operation, ServerMessage } from './ot.js';\n\ninterface ClientConnection {\n  id: string;\n  ws: WebSocket;\n  docId: string;\n}\n\ninterface DocumentSession {\n  docId: string;\n  content: string;\n  version: number;\n  /** Minimum version covered by the operations array */\n  minVersion: number;\n  /** History of operations for OT transform */\n  operations: Operation[];\n  clients: Map<string, ClientConnection>;\n}\n\nconst MAX_HISTORY = 1000;\n\nexport class CollaborationManager {\n  private sessions = new Map<string, DocumentSession>();\n  private allClients = new Map<string, ClientConnection>();\n  private wss: WebSocketServer | null = null;\n  private store: DocumentStore;\n  private closed = false;\n\n  constructor(store: DocumentStore) {\n    this.store = store;\n  }\n\n  /** Check if a document has an active collaboration session */\n  hasActiveSession(docId: string): boolean {\n    const session = this.sessions.get(docId);\n    return session !== undefined && session.clients.size > 0;\n  }\n\n  attach(server: Server): void {\n    this.wss = new WebSocketServer({ server });\n\n    this.wss.on('connection', (ws, req) => {\n      if (this.closed) {\n        ws.close(1001, 'Server shutting down');\n        return;\n      }\n\n      const url = req.url ?? '';\n      // Expected path: /ws/documents/:docId\n      const match = url.match(/^\\/ws\\/documents\\/([^/?]+)/);\n      if (!match) {\n        this.sendMessage(ws, { type: 'error', message: 'Invalid WebSocket path. Use /ws/documents/:docId' });\n        ws.close(1008, 'Invalid path');\n        return;\n      }\n\n      const docId = match[1];\n      const doc = this.store.getById(docId);\n      if (!doc) {\n        this.sendMessage(ws, { type: 'error', message: 'Document not found' });\n        ws.close(1008, 'Document not found');\n        return;\n      }\n\n      const clientId = randomUUID();\n      const session = this.getOrCreateSession(docId, doc.content);\n      const client: ClientConnection = { id: clientId, ws, docId };\n      session.clients.set(clientId, client);\n      this.allClients.set(clientId, client);\n\n      // Send current document state\n      this.sendMessage(ws, {\n        type: 'sync',\n        docId,\n        content: session.content,\n        version: session.version,\n      });\n\n      ws.on('message', (data) => {\n        if (this.closed) return;\n        try {\n          const raw = typeof data === 'string' ? data : data.toString('utf-8');\n          const msg = JSON.parse(raw);\n          this.handleClientMessage(clientId, msg);\n        } catch (err) {\n          this.sendMessage(ws, {\n            type: 'error',\n            message: `Invalid message: ${err instanceof Error ? err.message : String(err)}`,\n          });\n        }\n      });\n\n      ws.on('close', () => {\n        session.clients.delete(clientId);\n        this.allClients.delete(clientId);\n        if (!this.closed && session.clients.size === 0) {\n          this.persistSession(session);\n          this.sessions.delete(session.docId);\n        }\n      });\n\n      ws.on('error', () => {\n        session.clients.delete(clientId);\n        this.allClients.delete(clientId);\n      });\n    });\n  }\n\n  private getOrCreateSession(docId: string, currentContent: string): DocumentSession {\n    let session = this.sessions.get(docId);\n    if (session) return session;\n\n    // Load version from DB\n    const latestVersion = this.store.getLatestVersion(docId);\n    const version = latestVersion ? latestVersion.version : 1;\n\n    session = {\n      docId,\n      content: currentContent,\n      version,\n      minVersion: version,\n      operations: [],\n      clients: new Map(),\n    };\n    this.sessions.set(docId, session);\n    return session;\n  }\n\n  private handleClientMessage(clientId: string, msg: unknown): void {\n    if (!msg || typeof msg !== 'object') {\n      this.sendErrorToClient(clientId, 'Message must be an object');\n      return;\n    }\n\n    const m = msg as Record<string, unknown>;\n    if (m.type !== 'operation') {\n      this.sendErrorToClient(clientId, `Unknown message type: ${String(m.type)}`);\n      return;\n    }\n\n    const docId = m.docId as string;\n    const version = m.version as number;\n    const operation = m.operation as Operation;\n\n    if (!docId || typeof docId !== 'string') {\n      this.sendErrorToClient(clientId, 'docId is required');\n      return;\n    }\n    if (typeof version !== 'number' || !Number.isInteger(version) || version < 1) {\n      this.sendErrorToClient(clientId, 'version must be a positive integer');\n      return;\n    }\n    if (!validate(operation)) {\n      this.sendErrorToClient(clientId, 'Invalid operation format');\n      return;\n    }\n\n    const session = this.sessions.get(docId);\n    if (!session) {\n      this.sendErrorToClient(clientId, 'No active session for this document');\n      return;\n    }\n\n    const client = session.clients.get(clientId);\n    if (!client) {\n      this.sendErrorToClient(clientId, 'Client not found in session');\n      return;\n    }\n\n    // Check if version is too old (before our history window)\n    if (version < session.minVersion) {\n      this.sendMessage(client.ws, {\n        type: 'error',\n        message: `Version ${version} is too old. Please re-sync.`,\n      });\n      // Send a fresh sync so the client can recover\n      this.sendMessage(client.ws, {\n        type: 'sync',\n        docId,\n        content: session.content,\n        version: session.version,\n      });\n      return;\n    }\n\n    // The client's operation was based on `version`. We need to transform it\n    // against all operations that have happened since that version.\n    const startIndex = version - session.minVersion;\n    if (startIndex < 0 || startIndex > session.operations.length) {\n      this.sendMessage(client.ws, {\n        type: 'error',\n        message: `Version ${version} is invalid. Current server version is ${session.version}. Please re-sync.`,\n      });\n      return;\n    }\n\n    let transformedOp = operation;\n    try {\n      for (let i = startIndex; i < session.operations.length; i++) {\n        const [newOp] = transform(transformedOp, session.operations[i]);\n        transformedOp = newOp;\n      }\n\n      // Validate that the transformed operation matches current document length\n      if (baseLength(transformedOp) !== session.content.length) {\n        this.sendMessage(client.ws, {\n          type: 'error',\n          message: `Operation base length (${baseLength(transformedOp)}) doesn't match document length (${session.content.length})`,\n        });\n        return;\n      }\n\n      // Apply the transformed operation\n      session.content = apply(session.content, transformedOp);\n      session.version++;\n      session.operations.push(transformedOp);\n\n      // Trim operation history if it exceeds the limit\n      if (session.operations.length > MAX_HISTORY) {\n        const trimCount = session.operations.length - MAX_HISTORY;\n        session.operations.splice(0, trimCount);\n        session.minVersion += trimCount;\n      }\n\n      // Persist to database\n      this.store.updateContent(docId, session.content, transformedOp);\n\n      // Acknowledge the sender\n      this.sendMessage(client.ws, {\n        type: 'ack',\n        version: session.version,\n      });\n\n      // Broadcast to other clients\n      for (const [id, otherClient] of session.clients) {\n        if (id === clientId) continue;\n        this.sendMessage(otherClient.ws, {\n          type: 'operation',\n          docId,\n          version: session.version,\n          operation: transformedOp,\n          clientId,\n        });\n      }\n    } catch (err) {\n      this.sendMessage(client.ws, {\n        type: 'error',\n        message: `Failed to apply operation: ${err instanceof Error ? err.message : String(err)}`,\n      });\n    }\n  }\n\n  private sendErrorToClient(clientId: string, message: string): void {\n    const client = this.allClients.get(clientId);\n    if (client) {\n      this.sendMessage(client.ws, { type: 'error', message });\n    }\n  }\n\n  private sendMessage(ws: WebSocket, msg: ServerMessage): void {\n    if (ws.readyState === WebSocket.OPEN) {\n      ws.send(JSON.stringify(msg));\n    }\n  }\n\n  private persistSession(session: DocumentSession): void {\n    if (this.closed) return;\n    try {\n      this.store.updateContent(session.docId, session.content);\n    } catch {\n      // DB might be closed\n    }\n  }\n\n  closeAll(): void {\n    // Persist all sessions before marking as closed\n    for (const session of this.sessions.values()) {\n      this.persistSession(session);\n    }\n    this.closed = true;\n\n    // Close all client connections\n    for (const session of this.sessions.values()) {\n      for (const client of session.clients.values()) {\n        client.ws.close(1001, 'Server shutting down');\n      }\n    }\n    this.sessions.clear();\n    this.allClients.clear();\n    if (this.wss) {\n      this.wss.close();\n      this.wss = null;\n    }\n  }\n}\n","structuredPatch":[{"oldStart":15,"oldLines":13,"newStart":15,"newLines":18,"lines":["   docId: string;","   content: string;","   version: number;","-  /** History of operations, indexed by version (op at index i transforms version i to i+1) */","+  /** Minimum version covered by the operations array */","+  minVersion: number;","+  /** History of operations for OT transform */","   operations: Operation[];","   clients: Map<string, ClientConnection>;"," }"," ","+const MAX_HISTORY = 1000;","+"," export class CollaborationManager {","   private sessions = new Map<string, DocumentSession>();","+  private allClients = new Map<string, ClientConnection>();","   private wss: