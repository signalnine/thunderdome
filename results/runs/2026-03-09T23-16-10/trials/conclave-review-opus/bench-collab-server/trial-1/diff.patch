(docId));\n    ws.on('open', () => resolve(ws));\n    ws.on('error', reject);\n  });\n}\n\nfunction waitForMessage<T = unknown>(ws: WebSocket): Promise<T> {\n  return new Promise((resolve) => {\n    ws.once('message', (data) => {\n      resolve(JSON.parse(data.toString()));\n    });\n  });\n}\n\nfunction sendOp(ws: WebSocket, docId: string, version: number, operation: unknown[], clientId = 'test-client') {\n  ws.send(JSON.stringify({\n    type: 'operation',\n    docId,\n    version,\n    operation,\n    clientId,\n  }));\n}\n\ndescribe('REST API', () => {\n  it('should create a document', async () => {\n    const res = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Test Doc', content: 'Hello' }),\n    });\n    expect(res.status).toBe(201);\n    const doc = await res.json();\n    expect(doc.title).toBe('Test Doc');\n    expect(doc.content).toBe('Hello');\n    expect(doc.id).toBeDefined();\n  });\n\n  it('should reject document creation without title', async () => {\n    const res = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ content: 'Hello' }),\n    });\n    expect(res.status).toBe(400);\n  });\n\n  it('should list documents', async () => {\n    await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Doc 1' }),\n    });\n    await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Doc 2' }),\n    });\n\n    const res = await fetch(`${baseUrl}/api/documents`);\n    const docs = await res.json();\n    expect(docs.length).toBe(2);\n  });\n\n  it('should get a document by id', async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Test', content: 'Body' }),\n    });\n    const created = await createRes.json();\n\n    const res = await fetch(`${baseUrl}/api/documents/${created.id}`);\n    expect(res.status).toBe(200);\n    const doc = await res.json();\n    expect(doc.title).toBe('Test');\n    expect(doc.content).toBe('Body');\n  });\n\n  it('should return 404 for non-existent document', async () => {\n    const res = await fetch(`${baseUrl}/api/documents/non-existent-id`);\n    expect(res.status).toBe(404);\n  });\n\n  it('should update a document', async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Original', content: 'Body' }),\n    });\n    const created = await createRes.json();\n\n    const res = await fetch(`${baseUrl}/api/documents/${created.id}`, {\n      method: 'PUT',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Updated', content: 'New body' }),\n    });\n    expect(res.status).toBe(200);\n    const doc = await res.json();\n    expect(doc.title).toBe('Updated');\n    expect(doc.content).toBe('New body');\n  });\n\n  it('should delete a document', async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'To Delete' }),\n    });\n    const created = await createRes.json();\n\n    const deleteRes = await fetch(`${baseUrl}/api/documents/${created.id}`, {\n      method: 'DELETE',\n    });\n    expect(deleteRes.status).toBe(204);\n\n    const getRes = await fetch(`${baseUrl}/api/documents/${created.id}`);\n    expect(getRes.status).toBe(404);\n  });\n\n  it('should return 404 when deleting non-existent document', async () => {\n    const res = await fetch(`${baseUrl}/api/documents/non-existent`, {\n      method: 'DELETE',\n    });\n    expect(res.status).toBe(404);\n  });\n\n  it('should get version history', async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Versioned', content: 'v1' }),\n    });\n    const created = await createRes.json();\n\n    // Update the document to create a new version\n    await fetch(`${baseUrl}/api/documents/${created.id}`, {\n      method: 'PUT',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ content: 'v2' }),\n    });\n\n    const res = await fetch(`${baseUrl}/api/documents/${created.id}/versions`);\n    expect(res.status).toBe(200);\n    const versions = await res.json();\n    expect(versions.length).toBeGreaterThanOrEqual(2);\n    expect(versions[0].version).toBe(1);\n    expect(versions[0].content).toBe('v1');\n  });\n\n  it('should get a specific version', async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Versioned', content: 'initial' }),\n    });\n    const created = await createRes.json();\n\n    const res = await fetch(`${baseUrl}/api/documents/${created.id}/versions/1`);\n    expect(res.status).toBe(200);\n    const version = await res.json();\n    expect(version.version).toBe(1);\n    expect(version.content).toBe('initial');\n  });\n});\n\ndescribe('WebSocket collaboration', () => {\n  it('should send sync message on connect', async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'WS Test', content: 'hello' }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(doc.id);\n    const syncMsg = await waitForMessage<{ type: string; content: string; version: number }>(ws);\n\n    expect(syncMsg.type).toBe('sync');\n    expect(syncMsg.content).toBe('hello');\n    expect(syncMsg.version).toBe(1);\n\n    ws.close();\n  });\n\n  it('should reject connection to non-existent document', async () => {\n    const ws = new WebSocket(wsUrl('non-existent'));\n    const msg = await waitForMessage<{ type: string; message: string }>(ws);\n    expect(msg.type).toBe('error');\n\n    await new Promise<void>((resolve) => {\n      ws.on('close', () => resolve());\n    });\n  });\n\n  it('should apply and broadcast operations', async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Collab Test', content: 'hello' }),\n    });\n    const doc = await createRes.json();\n\n    // Connect two clients\n    const ws1 = await connectWs(doc.id);\n    const sync1 = await waitForMessage<{ type: string; version: number }>(ws1);\n\n    const ws2 = await connectWs(doc.id);\n    const sync2 = await waitForMessage<{ type: string; version: number }>(ws2);\n\n    // Client 1 sends an insert operation: \"hello\" -> \"hello world\"\n    sendOp(ws1, doc.id, sync1.version, [5, ' world']);\n\n    // Client 1 should get an ack\n    const ack = await waitForMessage<{ type: string; version: number }>(ws1);\n    expect(ack.type).toBe('ack');\n    expect(ack.version).toBe(2);\n\n    // Client 2 should receive the broadcast\n    const broadcast = await waitForMessage<{ type: string; operation: unknown[] }>(ws2);\n    expect(broadcast.type).toBe('operation');\n    expect(broadcast.operation).toEqual([5, ' world']);\n\n    // Verify via REST\n    const getRes = await fetch(`${baseUrl}/api/documents/${doc.id}`);\n    const updated = await getRes.json();\n    expect(updated.content).toBe('hello world');\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should handle concurrent edits with OT', async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'OT Test', content: 'hello' }),\n    });\n    const doc = await createRes.json();\n\n    const ws1 = await connectWs(doc.id);\n    const sync1 = await waitForMessage<{ type: string; version: number }>(ws1);\n\n    const ws2 = await connectWs(doc.id);\n    const sync2 = await waitForMessage<{ type: string; version: number }>(ws2);\n\n    // Both clients send operations based on the same version\n    // Client 1: insert \"X\" at position 0 -> \"Xhello\"\n    sendOp(ws1, doc.id, sync1.version, ['X', 5]);\n    // Client 2: insert \"Y\" at end -> \"helloY\"\n    sendOp(ws2, doc.id, sync2.version, [5, 'Y']);\n\n    // Wait for acks and broadcasts\n    const msg1a = await waitForMessage<{ type: string }>(ws1);\n    expect(msg1a.type).toBe('ack');\n\n    const msg2a = await waitForMessage<{ type: string }>(ws2);\n    // ws2 gets either the broadcast of ws1's op or an ack\n    // The first message ws2 gets should be the broadcast of ws1's operation\n    if (msg2a.type === 'operation') {\n      // Then ws2's ack should follow\n      const msg2b = await waitForMessage<{ type: string }>(ws2);\n      expect(msg2b.type).toBe('ack');\n    } else {\n      expect(msg2a.type).toBe('ack');\n    }\n\n    // Give a small delay for processing\n    await new Promise((r) => setTimeout(r, 100));\n\n    // Verify the document content via REST - both inserts should be present\n    const getRes = await fetch(`${baseUrl}/api/documents/${doc.id}`);\n    const updated = await getRes.json();\n    expect(updated.content).toContain('X');\n    expect(updated.content).toContain('Y');\n    expect(updated.content).toContain('hello');\n    expect(updated.content.length).toBe(7); // \"Xhello\" + \"Y\" = \"XhelloY\"\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should handle invalid operations gracefully', async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Error Test', content: 'hello' }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(doc.id);\n    await waitForMessage(ws); // sync\n\n    // Send invalid message\n    ws.send(JSON.stringify({ type: 'unknown' }));\n    const errorMsg = await waitForMessage<{ type: string; message: string }>(ws);\n    expect(errorMsg.type).toBe('error');\n\n    // Send malformed JSON\n    ws.send('not json');\n    const errorMsg2 = await waitForMessage<{ type: string }>(ws);\n    expect(errorMsg2.type).toBe('error');\n\n    ws.close();\n  });\n\n  it('should handle 10 concurrent clients', async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Stress Test', content: '' }),\n    });\n    const doc = await createRes.json();\n\n    const clients: WebSocket[] = [];\n    const versions: number[] = [];\n\n    // Connect 10 clients\n    for (let i = 0; i < 10; i++) {\n      const ws = await connectWs(doc.id);\n      const sync = await waitForMessage<{ type: string; version: number }>(ws);\n      versions.push(sync.version);\n      clients.push(ws);\n    }\n\n    // Each client inserts their index number sequentially\n    // We do this sequentially to ensure ordering and avoid race conditions in the test\n    for (let i = 0; i < 10; i++) {\n      const ws = clients[i];\n      // Each client inserts at the end of the current document\n      // Current doc length after i insertions = i (each char is 1 length)\n      sendOp(ws, doc.id, versions[i], [i, String(i)]);\n\n      // Wait for ack\n      let gotAck = false;\n      while (!gotAck) {\n        const msg = await waitForMessage<{ type: string; version?: number }>(ws);\n        if (msg.type === 'ack') {\n          gotAck = true;\n          // Update all subsequent clients' versions\n          for (let j = i + 1; j < 10; j++) {\n            // Drain broadcast messages that arrived for other clients\n            const broadcast = await waitForMessage<{ type: string }>(clients[j]);\n            expect(broadcast.type).toBe('operation');\n            versions[j] = (broadcast as unknown as { version: number }).version;\n          }\n        }\n      }\n    }\n\n    // Give a small delay for all to settle\n    await new Promise((r) => setTimeout(r, 200));\n\n    // Verify via REST that all 10 characters are present\n    const getRes = await fetch(`${baseUrl}/api/documents/${doc.id}`);\n    const updated = await getRes.json();\n    expect(updated.content.length).toBe(10);\n    for (let i = 0; i < 10; i++) {\n      expect(updated.content).toContain(String(i));\n    }\n\n    // Clean up\n    for (const ws of clients) {\n      ws.close();\n    }\n  });\n});\n\ndescribe('Persistence', () => {\n  it('should persist data across server restarts', async () => {\n    const tmpDb = '/tmp/test-collab-persist.db';\n\n    // First server instance\n    const app1 = createApp(tmpDb);\n    const port1 = await app1.start(0);\n\n    const createRes = await fetch(`http://localhost:${port1}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Persistent Doc', content: 'saved data' }),\n    });\n    const doc = await createRes.json();\n    await app1.stop();\n\n    // Second server instance with same DB\n    const app2 = createApp(tmpDb);\n    const port2 = await app2.start(0);\n\n    const getRes = await fetch(`http://localhost:${port2}/api/documents/${doc.id}`);\n    expect(getRes.status).toBe(200);\n    const loaded = await getRes.json();\n    expect(loaded.title).toBe('Persistent Doc');\n    expect(loaded.content).toBe('saved data');\n\n    await app2.stop();\n\n    // Clean up\n    const { unlinkSync } = await import('node:fs');\n    try { unlinkSync(tmpDb); } catch { /* ignore */ }\n    try { unlinkSync(tmpDb + '-wal'); } catch { /* ignore */ }\n    try { unlinkSync(tmpDb + '-shm'); } catch { /* ignore */ }\n  });\n});\n"}}
