ead', 'write', 'delete', 'manage_users', 'view_reports'],\n  user: ['read', 'write', 'view_reports'],\n  viewer: ['read'],\n};\n\nexport function hasPermission(role: Role, permission: Permission): boolean {\n  const permissions = ROLE_PERMISSIONS[role];\n  return permissions.includes(permission);\n}\n\nexport function getAllPermissions(role: Role): Permission[] {\n  return [...ROLE_PERMISSIONS[role]];\n}\n\nexport function canManageUsers(role: Role): boolean {\n  return hasPermission(role, 'manage_users');\n}\n\nexport function canWrite(role: Role): boolean {\n  return hasPermission(role, 'write');\n}\n\nexport function canDelete(role: Role): boolean {\n  return hasPermission(role, 'delete');\n}\n\nexport function requirePermission(\n  role: Role,\n  permission: Permission\n): void {\n  if (!hasPermission(role, permission)) {\n    throw new Error(\n      `Role '${role}' does not have permission '${permission}'`\n    );\n  }\n}\n","numLines":44,"startLine":1,"totalLines":44}}}
