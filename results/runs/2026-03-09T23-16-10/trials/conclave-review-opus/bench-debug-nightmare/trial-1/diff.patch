globalHandlers: Map<string, EventHandler[]> = new Map();\\n\\nexport class EventBus {\\n  on(event: string, handler: EventHandler): void {\\n    const existing = globalHandlers.get(event) ?? [];\\n    existing.push(handler);\\n    globalHandlers.set(event, existing);\\n  }\\n\\n  off(event: string, handler: EventHandler): void {\\n    const existing = globalHandlers.get(event);\\n    if (!existing) return;\\n    globalHandlers.set(\\n      event,\\n      existing.filter((h) => h !== handler)\\n    );\\n  }\\n\\n  async emit(event: string, data: unknown): Promise<void> {\\n    const handlers = globalHandlers.get(event) ?? [];\\n    for (const handler of handlers) {\\n      await handler(data);\\n    }\\n  }\\n\\n  clear(): void {\\n    globalHandlers.clear();\\n  }\\n}\\n\",\"numLines\":33,\"startLine\":1,\"totalLines\":33}}}\n+{\"type\":\"assistant\",\"message\":{\"model\":\"claude-opus-4-6\",\"id\":\"msg_01JV579AHBkj6FieKQjv25wR\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01C8dUxoG3RTaXi7suunhF3T\",\"name\":\"Read\",\"input\":{\"file_path\":\"/workspace/src/orders/repository.ts\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":1,\"cache_creation_input_tokens\":380,\"cache_read_input_tokens\":34482,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":380},\"output_tokens\":3,\"service_tier\":\"standard\",\"inference_geo\":\"not_available\"},\"context_management\":null},\"parent_tool_use_id\":null,\"session_id\":\"4f5276a9-8af1-49ed-888e-d6b9f91c15d6\",\"uuid\":\"9d3af895-2814-4c4d-acf7-c26650939252\"}\n+{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01C8dUxoG3RTaXi7suunhF3T\",\"type\":\"tool_result\",\"content\":\"     1→export type OrderStatus = 'pending' | 'confirmed' | 'cancelled' | 'refunded';\\n     2→\\n     3→export interface OrderItem {\\n     4→  productId: string;\\n     5→  quantity: number;\\n     6→  unitPrice: number;\\n     7→}\\n     8→\\n     9→export interface Order {\\n    10→  id: string;\\n    11→  customerId: string;\\n    12→  items: OrderItem[];\\n    13→  status: OrderStatus;\\n    14→  total: number;\\n    15→  discount: number;\\n    16→  taxRate: number;\\n    17→  createdAt: number;\\n    18→  updatedAt: number;\\n    19→  notes?: string;\\n    20→}\\n    21→\\n    22→export class OrderRepository {\\n    23→  private store: Map<string, Order> = new Map();\\n    24→\\n    25→  create(order: Order): Order {\\n    26→    this.store.set(order.id, { ...order });\\n    27→    return { ...order };\\n    28→  }\\n    29→\\n    30→  findById(id: string): Order | undefined {\\n    31→    const order = this.store.get(id);\\n    32→    return order ? { ...order } : undefined;\\n    33→  }\\n    34→\\n    35→  update(id: string, updates: Partial<Order>): Order | undefined {\\n    36→    const existing = this.store.get(id);\\n    37→    if (!existing) return undefined;\\n    38→    const updated = { ...updates, id, updatedAt: Date.now() } as Order;\\n    39→    this.store.set(id, updated);\\n    40→    return { ...updated };\\n    41→  }\\n    42→\\n    43→  findByCustomer(customerId: string): Order[] {\\n    44→    return Array.from(this.store.values())\\n    45→      .filter((o) => o.customerId === customerId)\\n    46→      .map((o) => ({ ...o }));\\n    47→  }\\n    48→\\n    49→  findByStatus(status: OrderStatus): Order[] {\\n    50→    return Array.from(this.store.values())\\n    51→      .filter((o) => o.status === status)\\n    52→      .map((o) => ({ ...o }));\\n    53→  }\\n    54→\\n    55→  clear(): void {\\n    56→    this.store.clear();\\n    57→  }\\n    58→}\\n    59→\"}]},\"parent_tool_use_id\":null,\"session_id\":\"4f5276a9-8af1-49ed-888e-d6b9f91c15d6\",\"uuid\":\"3ce8319c-c57a-4772-bdcb-71ad509dc9d1\",\"tool_use_result\":{\"type\":\"text\",\"file\":{\"filePath\":\"/workspace/src/orders/repository.ts\",\"content\":\"export type OrderStatus = 'pending' | 'confirmed' | 'cancelled' | 'refunded';\\n\\nexport interface OrderItem {\\n  productId: string;\\n  quantity: number;\\n  unitPrice: number;\\n}\\n\\nexport interface Order {\\n  id: string;\\n  customerId: string;\\n  items: OrderItem[];\\n  status: OrderStatus;\\n  total: number;\\n  discount: number;\\n  taxRate: number;\\n  createdAt: number;\\n  updatedAt: number;\\n  notes?: string;\\n}\\n\\nexport class OrderRepository {\\n  private store: Map<string, Order> = new Map();\\n\\n  create(order: Order): Order {\\n    this.store.set(order.id, { ...order });\\n    return { ...order };\\n  }\\n\\n  findById(id: string): Order | undefined {\\n    const order = this.store.get(id);\\n    return order ? { ...order } : undefined;\\n  }\\n\\n  update(id: string, updates: Partial<Order>): Order | undefined {\\n    const existing = this.store.get(id);\\n    if (!existing) return undefined;\\n    const updated = { ...updates, id, updatedAt: Date.now() } as Order;\\n    this.store.set(id, updated);\\n    return { ...updated };\\n  }\\n\\n  findByCustomer(customerId: string): Order[] {\\n    return Array.from(this.store.values())\\n      .filter((o) => o.customerId === customerId)\\n      .map((o) => ({ ...o }));\\n  }\\n\\n  findByStatus(status: OrderStatus): Order[] {\\n    return Array.from(this.store.values())\\n      .filter((o) => o.status === status)\\n      .map((o) => ({ ...o }));\\n  }\\n\\n  clear(): void {\\n    this.store.clear();\\n  }\\n}\\n\",\"numLines\":59,\"startLine\":1,\"totalLines\":59}}}\n+{\"type\":\"assistant\",\"message\":{\"model\":\"claude-opus-4-6\",\"id\":\"msg_01JV579AHBkj6FieKQjv25wR\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01VeVKogJ16pxoYkm2EMnfBN\",\"name\":\"Read\",\"input\":{\"file_path\":\"/workspace/src/billing/service.ts\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":1,\"cache_crea