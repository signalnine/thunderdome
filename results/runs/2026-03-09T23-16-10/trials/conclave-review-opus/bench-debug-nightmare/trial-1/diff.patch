, 10);\n    85→    await orderService.createOrder('O1', 'C1', [\n    86→      { productId: 'SKU-1', quantity: 1, unitPrice: 100 },\n    87→    ]);\n    88→    await orderService.cancelOrder('O1', 'not needed');\n    89→    const refunded = await orderService.refundOrder('O1');\n    90→    expect(refunded?.status).toBe('refunded');\n    91→  });\n    92→\n    93→  it('allows refund on exactly day 30', async () => {\n    94→    inventoryService.setStock('SKU-1', 10);\n    95→    await orderService.createOrder('O1', 'C1', [\n    96→      { productId: 'SKU-1', quantity: 1, unitPrice: 100 },\n    97→    ]);\n    98→    // Manually backdate the order to exactly 30 days ago\n    99→    const thirtyDaysMs = 30 * 24 * 60 * 60 * 1000;\n   100→    orderRepo.update('O1', { createdAt: Date.now() - thirtyDaysMs });\n   101→    await orderService.cancelOrder('O1', 'late cancel');\n   102→    const refunded = await orderService.refundOrder('O1');\n   103→    expect(refunded?.status).toBe('refunded');\n   104→  });\n   105→\n   106→  it('rejects refund after 30-day window', async () => {\n   107→    inventoryService.setStock('SKU-1', 10);\n   108→    await orderService.createOrder('O1', 'C1', [\n   109→      { productId: 'SKU-1', quantity: 1, unitPrice: 100 },\n   110→    ]);\n   111→    // Backdate to 31 days ago\n   112→    const thirtyOneDaysMs = 31 * 24 * 60 * 60 * 1000;\n   113→    orderRepo.update('O1', { createdAt: Date.now() - thirtyOneDaysMs });\n   114→    await orderService.cancelOrder('O1', 'very late');\n   115→    await expect(orderService.refundOrder('O1')).rejects.toThrow('Refund window expired');\n   116→  });\n   117→});\n   118→\n   119→describe('OrderRepository', () => {\n   120→  let repo: OrderRepository;\n   121→\n   122→  beforeEach(() => {\n   123→    repo = new OrderRepository();\n   124→  });\n   125→\n   126→  it('creates and retrieves an order', () => {\n   127→    const order = repo.create({\n   128→      id: 'O1',\n   129→      customerId: 'C1',\n   13