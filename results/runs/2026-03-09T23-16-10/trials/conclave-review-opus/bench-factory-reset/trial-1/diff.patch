+
+function solveCounterDirect(
+  numFree: number,
+  rank: number,
+  numButtons: number,
+  modulus: number,
+  freeVars: number[],
+  pivotColForRow: number[],
+  pivotBase: number[],
+  pivotFreeCoeff: number[][]
