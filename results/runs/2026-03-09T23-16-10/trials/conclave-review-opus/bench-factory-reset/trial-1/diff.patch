n  buttons: number[][];\n}\n\n/**\n * Solve a toggle puzzle using Gaussian elimination over GF(2).\n *\n * We model the problem as a system of linear equations over GF(2):\n * For each light j, sum of b_i where button i affects light j ≡ target[j] (mod 2)\n *\n * Returns the minimum set of button indices (sorted, lexicographically smallest),\n * or null if no solution exists.\n */\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const numLights = target.length;\n  const numButtons = buttons.length;\n\n  // Build augmented matrix: rows = lights, cols = buttons + 1 (augmented column)\n  // matrix[light][button] = 1 if button affects that light, last col = target\n  // We'll work with bitmask representation for efficiency with up to 40 buttons+1 = 41 bits\n  // Since JS bitwise ops are 32-bit, we'll use BigInt for correctness.\n\n  const numCols = numButtons + 1;\n  const matrix: bigint[] = new Array(numLights);\n\n  for (let light = 0; light < numLights; light++) {\n    matrix[light] = 0n;\n  }\n\n  for (let btn = 0; btn < numButtons; btn++) {\n    for (const light of buttons[btn]) {\n      if (light >= 0 && light < numLights) {\n        matrix[light] |= 1n << BigInt(btn);\n      }\n    }\n  }\n\n  // Set augmented column (target)\n  for (let light = 0; light < numLights; light++) {\n    if (target[light]) {\n      matrix[light] |= 1n << BigInt(numButtons);\n    }\n  }\n\n  // Gaussian elimination over GF(2)\n  // Track which column is the pivot for each row\n  const pivotCol: number[] = new Array(numLights).fill(-1);\n  const pivotRow: number[] = new Array(numButtons).fill(-1); // which row has pivot in this column\n  let currentRow = 0;\n\n  for (let col = 0; col < numButtons && currentRow < numLights; col++) {\n    // Find pivot row\n    let found = -1;\n    for (let row = currentRow; row < numLights; row++) {\n      if ((matrix[row] >> BigInt(col)) & 1n) {\n        found = row;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    // Swap rows\n    [matrix[currentRow], matrix[found]] = [matrix[found], matrix[currentRow]];\n\n    pivotCol[currentRow] = col;\n    pivotRow[col] = currentRow;\n\n    // Eliminate this column from all other rows\n    for (let row = 0; row < numLights; row++) {\n      if (row !== currentRow && (matrix[row] >> BigInt(col)) & 1n) {\n        matrix[row] ^= matrix[currentRow];\n      }\n    }\n\n    currentRow++;\n  }\n\n  const rank = currentRow;\n\n  // Check consistency: any row with all-zero coefficients but non-zero target\n  for (let row = rank; row < numLights; row++) {\n    if ((matrix[row] >> BigInt(numButtons)) & 1n) {\n      return null; // inconsistent system\n    }\n  }\n\n  // Identify free variables (columns without pivots)\n  const freeVars: number[] = [];\n  for (let col = 0; col < numButtons; col++) {\n    if (pivotRow[col] === -1) {\n      freeVars.push(col);\n    }\n  }\n\n  // If no free variables, there's exactly one solution\n  if (freeVars.length === 0) {\n    const result: number[] = [];\n    for (let row = 0; row < rank; row++) {\n      if ((matrix[row] >> BigInt(numButtons)) & 1n) {\n        result.push(pivotCol[row]);\n      }\n    }\n    result.sort((a, b) => a - b);\n    return result;\n  }\n\n  // Enumerate all 2^freeVars.length combinations to find minimum presses,\n  // then lexicographically smallest\n  const numFree = freeVars.length;\n  let bestResult: number[] | null = null;\n  let bestCount = numButtons + 1;\n\n  // For up to 40 buttons, free vars could be large. But with Gaussian elimination,\n  // free vars = numButtons - rank. In worst case this could be 40.\n  // However, the problem says we need to handle 40 buttons in 5 seconds.\n  // If rank is small, we could have many free vars. We need a smarter approach.\n  //\n  // For the minimum weight codeword problem over GF(2), when free vars are many,\n  // we need to be clever. But in practice, with 40 lights and 40 buttons,\n  // rank is at most 40, so free vars = 40 - rank. If rank is near 40, few free vars.\n  // If rank is small (say 0), then we just need target = 0.\n  //\n  // For the benchmark constraint, let's handle up to ~25 free vars by enumeration\n  // and use a meet-in-the-middle approach for more.\n\n  if (numFree <= 25) {\n    // Direct enumeration\n    for (let mask = 0; mask < (1 << numFree); mask++) {\n      const solution: number[] = [];\n      let count = 0;\n\n      // Set free variables\n      for (let i = 0; i < numFree; i++) {\n        if (mask & (1 << i)) {\n          solution.push(freeVars[i]);\n          count++;\n        }\n      }\n\n      // Determine pivot variables from back-substitution\n      for (let row = rank - 1; row >= 0; row--) {\n        const col = pivotCol[row];\n        let val = (matrix[row] >> BigInt(numButtons)) & 1n;\n        // XOR with free variable contributions\n        for (let i = 0; i < numFree; i++) {\n          if (mask & (1 << i)) {\n            val ^= (matrix[row] >> BigInt(freeVars[i])) & 1n;\n          }\n        }\n        if (val) {\n          solution.push(col);\n          count++;\n        }\n      }\n\n      if (count < bestCount || (count === bestCount && compareLex(solution, bestResult!) < 0)) {\n        bestCount = count;\n        bestResult = solution.slice();\n      }\n    }\n  } else {\n    // Meet in the middle for large number of free variables\n    const half1 = Math.floor(numFree / 2);\n    const half2 = numFree - half1;\n\n    // For each half, compute the effect on pivot variables and total cost\n    // First half: freeVars[0..half1-1], Second half: freeVars[half1..numFree-1]\n\n    // Precompute the contribution of each free variable to each pivot row\n    const freeContrib: bigint[] = new Array(numFree);\n    for (let i = 0; i < numFree; i++) {\n      let contrib = 0n;\n      for (let row = 0; row < rank; row++) {\n        if ((matrix[row] >> BigInt(freeVars[i])) & 1n) {\n          contrib |= 1n << BigInt(row);\n        }\n      }\n      freeContrib[i] = contrib;\n    }\n\n    // Base pivot values (from augmented column)\n    let basePivot = 0n;\n    for (let row = 0; row < rank; row++) {\n      if ((matrix[row] >> BigInt(numButtons)) & 1n) {\n        basePivot |= 1n << BigInt(row);\n      }\n    }\n\n    // For first half, build a map: pivotEffect -> {count, freeMask}\n    // pivotEffect is the XOR pattern on pivot rows\n    const firstHalfMap = new Map<bigint, { count: number; freeMask: number; totalButtons: number[] }>();\n\n    for (let mask = 0; mask < (1 << half1); mask++) {\n      let effect = 0n;\n      let freeCount = 0;\n      for (let i = 0; i < half1; i++) {\n        if (mask & (1 << i)) {\n          effect ^= freeContrib[i];\n          freeCount++;\n        }\n      }\n\n      // The pivot variables that would be 1 given this free var assignment\n      const pivotVals = basePivot ^ effect;\n      const pivotCount = popcount64(pivotVals);\n      const totalCount = freeCount + pivotCount;\n\n      const existing = firstHalfMap.get(effect);\n      if (!existing || totalCount < existing.count ||\n          (totalCount === existing.count && mask < existing.freeMask)) {\n        // Build buttons list for lex comparison\n        const btns: number[] = [];\n        for (let i = 0; i < half1; i++) {\n          if (mask & (1 << i)) btns.push(freeVars[i]);\n        }\n        // Add pivot buttons\n        for (let row = 0; row < rank; row++) {\n          if ((pivotVals >> BigInt(row)) & 1n) {\n            btns.push(pivotCol[row]);\n          }\n        }\n        firstHalfMap.set(effect, { count: totalCount, freeMask: mask, totalButtons: btns });\n      }\n    }\n\n    // For second half, enumerate and look up complementary first half\n    for (let mask2 = 0; mask2 < (1 << half2); mask2++) {\n      let effect2 = 0n;\n      let freeCount2 = 0;\n      for (let i = 0; i < half2; i++) {\n        if (mask2 & (1 << i)) {\n          effect2 ^= freeContrib[half1 + i];\n          freeCount2++;\n        }\n      }\n\n      // We need first half effect such that basePivot ^ effect1 ^ effect2 gives minimum 1s\n      // i.e., the combined pivot effect should cancel as much of basePivot as possible\n      // Actually, we want: pivotVals = basePivot ^ effect1 ^ effect2\n      // Total cost = popcount(pivotVals) + popcount(mask1) + popcount(mask2)\n      // For each mask2, we want to find effect1 that minimizes total cost.\n      // But we can't iterate over all effect1 values easily.\n      // Instead, for meet-in-middle, we enumerate all first-half effects and look up.\n      // The total effect is effect1 ^ effect2, and pivotVals = basePivot ^ effect1 ^ effect2.\n      // So for a given effect2, the pivotVals = (basePivot ^ effect2) ^ effect1.\n      // The total cost = popcount((basePivot ^ effect2) ^ effect1) + freeCount1 + freeCount2.\n      // This is still dependent on effect1 in a complex way.\n\n      // For the meet-in-middle approach, we iterate over all first half entries\n      // This is O(2^half1 * 2^half2) = O(2^numFree) which is what we're trying to avoid.\n      // Let's use a different strategy: just iterate all first half entries.\n\n      // Actually for the toggle problem with 40 buttons and 40 lights,\n      // rank should be close to min(40, 40) = 40, so free vars should be small.\n      // Let's just do the direct enumeration with the map lookup.\n\n      // For each entry in firstHalfMap:\n      for (const [effect1, entry1] of firstHalfMap) {\n        const pivotVals = basePivot ^ effect1 ^ effect2;\n        const pivotCount = popcount64(pivotVals);\n        const totalCount = entry1.count - popcount64(basePivot ^ effect1) + pivotCount + freeCount2;\n\n        // Rebuild actual count properly\n        let freeCount1 = 0;\n        for (let i = 0; i < half1; i++) {\n          if (entry1.freeMask & (1 << i)) freeCount1++;\n        }\n        const actualTotal = freeCount1 + freeCount2 + pivotCount;\n\n        if (bestResult === null || actualTotal < bestCount) {\n          bestCount = actualTotal;\n          const solution: number[] = [];\n          for (let i = 0; i < half1; i++) {\n            if (entry1.freeMask & (1 << i)) solution.push(freeVars[i]);\n          }\n          for (let i = 0; i < half2; i++) {\n            if (mask2 & (1 << i)) solution.push(freeVars[half1 + i]);\n          }\n          for (let row = 0; row < rank; row++) {\n            if ((pivotVals >> BigInt(row)) & 1n) {\n              solution.push(pivotCol[row]);\n            }\n          }\n          bestResult = solution;\n        } else if (actualTotal === bestCount) {\n          const solution: number[] = [];\n          for (let i = 0; i < half1; i++) {\n            if (entry1.freeMask & (1 << i)) solution.push(freeVars[i]);\n          }\n          for (let i = 0; i < half2; i++) {\n            if (mask2 & (1 << i)) solution.push(freeVars[half1 + i]);\n          }\n          for (let row = 0; row < rank; row++) {\n            if ((pivotVals >> BigInt(row)) & 1n) {\n              solution.push(pivotCol[row]);\n            }\n          }\n          if (compareLex(solution, bestResult!) < 0) {\n            bestResult = solution;\n          }\n        }\n      }\n    }\n  }\n\n  if (bestResult) {\n    bestResult.sort((a, b) => a - b);\n  }\n  return bestResult;\n}\n\nfunction popcount64(n: bigint): number {\n  let count = 0;\n  while (n > 0n) {\n    n &= n - 1n;\n    count++;\n  }\n  return count;\n}\n\nfunction compareLex(a: number[], b: number[]): number {\n  const sa = a.slice().sort((x, y) => x - y);\n  const sb = b.slice().sort((x, y) => x - y);\n  const len = Math.max(sa.length, sb.length);\n  for (let i = 0; i < len; i++) {\n    const va = i < sa.length ? sa[i] : Infinity;\n    const vb = i < sb.length ? sb[i] : Infinity;\n    if (va < vb) return -1;\n    if (va > vb) return 1;\n  }\n  return 0;\n}\n\n/**\n * Solve a counter puzzle using Gaussian elimination over GF(p).\n *\n * We model the problem as a system of linear equations over GF(p) where p = modulus:\n * For each counter j, sum of b_i (for buttons affecting counter j) ≡ target[j] (mod p)\n *\n * Returns array where result[i] is press count for button i, or null if no solution.\n * Minimizes total presses, then lexicographically smallest.\n */\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const numCounters = lights.length;\n  const numButtons = buttons.length;\n\n  if (numButtons === 0) {\n    // Check if all targets are 0\n    for (const t of lights) {\n      if (t % modulus !== 0) return null;\n    }\n    return [];\n  }\n\n  // Build augmented matrix over GF(modulus)\n  // matrix[counter][col] where col 0..numButtons-1 are button coefficients, col numButtons is target\n  const numCols = numButtons + 1;\n  const matrix: number[][] = [];\n\n  for (let counter = 0; counter < numCounters; counter++) {\n    const row = new Array(numCols).fill(0);\n    row[numButtons] = ((lights[counter] % modulus) + modulus) % modulus;\n    matrix.push(row);\n  }\n\n  for (let btn = 0; btn < numButtons; btn++) {\n    for (const counter of buttons[btn]) {\n      if (counter >= 0 && counter < numCounters) {\n        matrix[counter][btn] = (matrix[counter][btn] + 1) % modulus;\n      }\n    }\n  }\n\n  // Precompute modular inverse table\n  const inv = new Array(modulus).fill(0);\n  for (let i = 1; i < modulus; i++) {\n    inv[i] = modPow(i, modulus - 2, modulus);\n  }\n\n  // Gaussian elimination over GF(modulus)\n  const pivotCol: number[] = [];\n  const pivotRow: number[] = new Array(numButtons).fill(-1);\n  let currentRow = 0;\n\n  for (let col = 0; col < numButtons && currentRow < numCounters; col++) {\n    // Find pivot row\n    let found = -1;\n    for (let row = currentRow; row < numCounters; row++) {\n      if (matrix[row][col] !== 0) {\n        found = row;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    // Swap rows\n    [matrix[currentRow], matrix[found]] = [matrix[found], matrix[currentRow]];\n\n    // Scale pivot row so pivot element = 1\n    const scale = inv[matrix[currentRow][col]];\n    for (let c = 0; c < numCols; c++) {\n      matrix[currentRow][c] = (matrix[currentRow][c] * scale) % modulus;\n    }\n\n    pivotCol.push(col);\n    pivotRow[col] = currentRow;\n\n    // Eliminate this column from all other rows\n    for (let row = 0; row < numCounters; row++) {\n      if (row !== currentRow && matrix[row][col] !== 0) {\n        const factor = matrix[row][col];\n        for (let c = 0; c < numCols; c++) {\n          matrix[row][c] = (matrix[row][c] - factor * matrix[currentRow][c] % modulus + modulus * modulus) % modulus;\n        }\n      }\n    }\n\n    currentRow++;\n  }\n\n  const rank = currentRow;\n\n  // Check consistency\n  for (let row = rank; row < numCounters; row++) {\n    if (matrix[row][numButtons] !== 0) {\n      return null;\n    }\n  }\n\n  // Identify free variables\n  const freeVars: number[] = [];\n  for (let col = 0; col < numButtons; col++) {\n    if (pivotRow[col] === -1) {\n      freeVars.push(col);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  if (numFree === 0) {\n    // Unique solution\n    const result = new Array(numButtons).fill(0);\n    for (let row = 0; row < rank; row++) {\n      result[pivotCol[row]] = matrix[row][numButtons];\n    }\n    return result;\n  }\n\n  // For free variables, we need to try all modulus^numFree combinations.\n  // With modulus up to 97 and numFree potentially large, this could be infeasible.\n  // But with 40 lights and 40 buttons, rank ≤ 40, so free vars = numButtons - rank.\n  // If both are 40, free vars = 0. In practice, free vars should be small.\n  //\n  // For safety, let's handle up to ~6 free vars with brute force for large modulus,\n  // and more for small modulus.\n\n  const totalCombinations = Math.pow(modulus, numFree);\n\n  if (totalCombinations <= 5_000_000) {\n    // Direct enumeration\n    let bestResult: number[] | null = null;\n    let bestTotal = Infinity;\n\n    // Precompute: for each pivot row, what's the base value and contribution from each free var\n    const pivotBase: number[] = new Array(rank);\n    const pivotFreeContrib: number[][] = new Array(rank);\n\n    for (let r = 0; r < rank; r++) {\n      pivotBase[r] = matrix[r][numButtons];\n      pivotFreeContrib[r] = new Array(numFree);\n      for (let f = 0; f < numFree; f++) {\n        pivotFreeContrib[r][f] = matrix[r][freeVars[f]];\n      }\n    }\n\n    // Enumerate all combinations of free variable values\n    const freeValues = new Array(numFree).fill(0);\n\n    for (let combo = 0; combo < totalCombinations; combo++) {\n      // Compute solution\n      const result = new Array(numButtons).fill(0);\n\n      // Set free variables\n      for (let f = 0; f < numFree; f++) {\n        result[freeVars[f]] = freeValues[f];\n      }\n\n      // Compute pivot variables via back-substitution\n      let valid = true;\n      let total = 0;\n      for (let f = 0; f < numFree; f++) {\n        total += freeValues[f];\n      }\n\n      for (let r = 0; r < rank; r++) {\n        let val = pivotBase[r];\n        for (let f = 0; f < numFree; f++) {\n          val = (val - pivotFreeContrib[r][f] * freeValues[f] % modulus + modulus * modulus) % modulus;\n        }\n        result[pivotCol[r]] = val;\n        total += val;\n      }\n\n      if (valid && (total < bestTotal || (total === bestTotal && compareLexArr(result, bestResult!) < 0))) {\n        bestTotal = total;\n        bestResult = result.slice();\n      }\n\n      // Increment freeValues (mixed-radix counter)\n      let carry = true;\n      for (let f = numFree - 1; f >= 0 && carry; f--) {\n        freeValues[f]++;\n        if (freeValues[f] >= modulus) {\n          freeValues[f] = 0;\n        } else {\n          carry = false;\n        }\n      }\n    }\n\n    return bestResult;\n  }\n\n  // For very large search spaces, we need a smarter approach.\n  // 