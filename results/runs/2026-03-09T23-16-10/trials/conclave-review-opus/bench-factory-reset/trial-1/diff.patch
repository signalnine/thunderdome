ult = solveToggle({\n      target: [true, false],\n      buttons: [[0], [1]]\n    });\n    expect(result).toEqual([0]);\n  });\n\n  it('chooses minimum presses', () => {\n    // button 3 toggles both 0 and 2 (1 press)\n    // buttons 0 and 2 also work (2 presses)\n    const result = solveToggle({\n      target: [true, false, true],\n      buttons: [[0], [1], [2], [0, 2]]\n    });\n    expect(result).toEqual([3]);\n  });\n\n  it('chooses lexicographically smallest on tie in press count', () => {\n    // Both [0] and [1] work (1 press each), [0] is lex smallest\n    const result = solveToggle({\n      target: [true, true],\n      buttons: [[0, 1], [0, 1]]\n    });\n    expect(result).toEqual([0]);\n  });\n\n  it('handles redundant buttons (free variables)', () => {\n    // 5 lights, 10 buttons (identity + duplicates)\n    const buttons: number[][] = [];\n    for (let i = 0; i < 5; i++) buttons.push([i]);\n    for (let i = 0; i < 5; i++) buttons.push([i]);\n    const result = solveToggle({\n      target: [true, true, true, true, true],\n      buttons\n    });\n    expect(result).toEqual([0, 1, 2, 3, 4]);\n    expect(verifyToggle([true, true, true, true, true], buttons, result!)).toBe(true);\n  });\n\n  it('handles large full-rank system (40x40)', () => {\n    const N = 40;\n    const buttons: number[][] = [];\n    for (let i = 0; i < N; i++) {\n      const affected = [i];\n      if (i + 1 < N) affected.push(i + 1);\n      buttons.push(affected);\n    }\n    const target = new Array(N).fill(true);\n    const result = solveToggle({ target, buttons });\n    expect(result).not.toBeNull();\n    expect(verifyToggle(target, buttons, result!)).toBe(true);\n  });\n\n  it('handles empty buttons array', () => {\n    // No buttons, target all false => success\n    expect(solveToggle({ target: [false, false], buttons: [] })).toEqual([]);\n    // No buttons, target has true => impossible\n    expect(solveToggle({ target: [true], buttons: [] })).toBeNull();\n  });\n\n  it('handles no lights', () => {\n    expect(solveToggle({ target: [], buttons: [] })).toEqual([]);\n    expect(solveToggle({ target: [], buttons: [[]] })).toEqual([]);\n  });\n\n  it('handles MITM path (>20 free variables)', () => {\n    const buttons: number[][] = [];\n    for (let i = 0; i < 40; i++) {\n      buttons.push([i % 5]);\n    }\n    const target = [true, true, true, true, true];\n    const result = solveToggle({ target, buttons });\n    expect(result).not.toBeNull();\n    expect(result!.length).toBeLessThanOrEqual(5);\n    expect(verifyToggle(target, buttons, result!)).toBe(true);\n  });\n});\n\ndescribe('solveCounter', () => {\n  it('handles simple single counter', () => {\n    expect(solveCounter([2], [[0]], 3)).toEqual([2]);\n  });\n\n  it('handles two independent counters', () => {\n    expect(solveCounter([2, 0], [[0], [1]], 3)).toEqual([2, 0]);\n  });\n\n  it('handles shared button', () => {\n    expect(solveCounter([1, 1], [[0, 1]], 2)).toEqual([1]);\n  });\n\n  it('returns null for impossible case', () => {\n    // Button increments both counters, need [1, 0] which is impossible\n    expect(solveCounter([1, 0], [[0, 1]], 2)).toBeNull();\n  });\n\n  it('minimizes total presses', () => {\n    // Two buttons both increment counter 0 (mod 3)\n    // b0 + b1 ≡ 1 (mod 3)\n    // Solutions: (0,1), (1,0), (2,2) - totals 1, 1, 4\n    // Lex smallest with total 1 is (0,1)\n    expect(solveCounter([1], [[0], [0]], 3)).toEqual([0, 1]);\n  });\n\n  it('handles all-zero target', () => {\n    expect(solveCounter([0, 0, 0], [[0, 1], [1, 2]], 5)).toEqual([0, 0]);\n  });\n\n  it('handles larger modulus', () => {\n    const result = solveCounter([50], [[0]], 97);\n    expect(result).toEqual([50]);\n  });\n\n  it('handles empty buttons array', () => {\n    expect(solveCounter([0, 0], [], 3)).toEqual([]);\n    expect(solveCounter([1], [], 3)).toBeNull();\n  });\n\n  it('handles no counters', () => {\n    expect(solveCounter([], [], 2)).toEqual([]);\n    expect(solveCounter([], [[]], 2)).toEqual([0]);\n  });\n\n  it('handles full-rank system (40x40 mod 97)', () => {\n    const N = 40;\n    const buttons: number[][] = [];\n    for (let i = 0; i < N; i++) {\n      const affected = [i];\n      if (i + 1 < N) affected.push(i + 1);\n      buttons.push(affected);\n    }\n    const target = new Array(N).fill(0).map((_, i) => i % 97);\n    const result = solveCounter(target, buttons, 97);\n    expect(result).not.toBeNull();\n    expect(verifyCounter(target, buttons, 97, result!)).toBe(true);\n  });\n\n  it('handles counter with free variables minimizing total', () => {\n    // 3 counters, 6 buttons. Buttons 0-2 affect counter 0,1,2.\n    // Buttons 3-5 also affect counter 0,1,2.\n    const buttons = [[0], [1], [2], [0], [1], [2]];\n    const target = [1, 1, 1];\n    const result = solveCounter(target, buttons, 3);\n    expect(result).not.toBeNull();\n    expect(verifyCounter(target, buttons, 3, result!)).toBe(true);\n    // Total should be 3 (minimum)\n    expect(result!.reduce((a, b) => a + b, 0)).toBe(3);\n  });\n\n  it('handles mod 2 (binary, like toggle)', () => {\n    const result = solveCounter([1, 0, 1], [[0, 2], [1]], 2);\n    expect(result).toEqual([1, 0]);\n    expect(verifyCounter([1, 0, 1], [[0, 2], [1]], 2, result!)).toBe(true);\n  });\n});\n","structuredPatch":[],"originalFile":null}}
