ibution of each free variable to each pivot row\n    const freeContrib: bigint[] = new Array(numFree);\n    for (let i = 0; i < numFree; i++) {\n      let contrib = 0n;\n      for (let row = 0; row < rank; row++) {\n        if ((matrix[row] >> BigInt(freeVars[i])) & 1n) {\n          contrib |= 1n << BigInt(row);\n        }\n      }\n      freeContrib[i] = contrib;\n    }\n\n    // Base pivot values (from augmented column)\n    let basePivot = 0n;\n    for (let row = 0; row < rank; row++) {\n      if ((matrix[row] >> BigInt(numButtons)) & 1n) {\n        basePivot |= 1n << BigInt(row);\n      }\n    }\n\n    // For first half, build a map: pivotEffect -> {count, freeMask}\n    // pivotEffect is the XOR pattern on pivot rows\n    const firstHalfMap = new Map<bigint, { count: number; freeMask: number; totalButtons: number[] }>();\n\n    for (let mask = 0; mask < (1 << half1); mask++) {\n      let effect = 0n;\n      let freeCount = 0;\n      for (let i = 0; i < half1; i++) {\n        if (mask & (1 << i)) {\n          effect ^= freeContrib[i];\n          freeCount++;\n        }\n      }\n\n      // The pivot variables that would be 1 given this free var assignment\n      const pivotVals = basePivot ^ effect;\n      const pivotCount = popcount64(pivotVals);\n      const totalCount = freeCount + pivotCount;\n\n      const existing = firstHalfMap.get(effect);\n      if (!existing || totalCount < existing.count ||\n          (totalCount === existing.count && mask < existing.freeMask)) {\n        // Build buttons list for lex comparison\n        const btns: number[] = [];\n        for (let i = 0; i < half1; i++) {\n          if (mask & (1 << i)) btns.push(freeVars[i]);\n        }\n        // Add pivot buttons\n        for (let row = 0; row < rank; row++) {\n          if ((pivotVals >> BigInt(row)) & 1n) {\n            btns.push(pivotCol[row]);\n          }\n        }\n        firstHalfMap.set(effect, { count: totalCount, freeMask: mask, totalButtons: btns });\n      }\n    }\