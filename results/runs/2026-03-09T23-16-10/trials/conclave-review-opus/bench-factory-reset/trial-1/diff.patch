lf1, half2, rank);\n      } else if (totalCost === bestTotal) {\n        const candidate = buildCounterSolution(numButtons, freeVars, pivotColForRow, entry1.freeValues, freeVals2, pivotVals, half1, half2, rank);\n        if (compareLexArr(candidate, bestResult!) < 0) {\n          bestResult = candidate;\n        }\n      }\n    }\n\n    // Increment\n    for (let fi = half2 - 1; fi >= 0; fi--) {\n      freeVals2[fi]++;\n      if (freeVals2[fi] < modulus) break;\n      freeVals2[fi] = 0;\n    }\n  }\n\n  return bestResult;\n}\n\nfunction buildCounterSolution(\n  numButtons: number,\n  freeVars: number[],\n  pivotColForRow: number[],\n  freeVals1: number[],\n  freeVals2: number[],\n  pivotVals: number[],\n  half1: number,\n  half2: number,\n  rank: number\n): number[] {\n  const result = new Array(numButtons).fill(0);\n  for (let fi = 0; fi < half1; fi++) {\n    result[freeVars[fi]] = freeVals1[fi];\n  }\n  for (let fi = 0; fi < half2; fi++) {\n    result[freeVars[half1 + fi]] = freeVals2[fi];\n  }\n  for (let r = 0; r < rank; r++) {\n    result[pivotColForRow[r]] = pivotVals[r];\n  }\n  return result;\n}\n\nfunction compareLexArr(a: number[], b: number[]): number {\n  for (let i = 0; i < a.length; i++) {\n    if (a[i] < b[i]) return -1;\n    if (a[i] > b[i]) return 1;\n  }\n  return 0;\n}\n\nfunction compareLexArrRaw(a: number[], b: number[]): number {\n  for (let i = 0; i < Math.min(a.length, b.length); i++) {\n    if (a[i] < b[i]) return -1;\n    if (a[i] > b[i]) return 1;\n  }\n  return a.length - b.length;\n}\n\nfunction modPow(base: number, exp: number, mod: number): number {\n  let result = 1;\n  base = base % mod;\n  while (exp > 0) {\n    if (exp & 1) {\n      result = (result * base) % mod;\n    }\n    exp >>= 1;\n    base = (base * base) % mod;\n  }\n  return result;\n}\n","structuredPatch":[{"oldStart":5,"oldLines":11,"newStart":5,"newLines":7,"lines":[" "," /**","  * Solve a toggle puzzle using Gaussian elimination over GF(2).","- *","- * We model the pro