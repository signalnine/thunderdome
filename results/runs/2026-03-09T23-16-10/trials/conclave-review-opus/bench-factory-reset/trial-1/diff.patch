r; freeMask: number; totalButtons: number[] }>();\n   194→\n   195→    for (let mask = 0; mask < (1 << half1); mask++) {\n   196→      let effect = 0n;\n   197→      let freeCount = 0;\n   198→      for (let i = 0; i < half1; i++) {\n   199→        if (mask & (1 << i)) {\n   200→          effect ^= freeContrib[i];\n   201→          freeCount++;\n   202→        }\n   203→      }\n   204→\n   205→      // The pivot variables that would be 1 given this free var assignment\n   206→      const pivotVals = basePivot ^ effect;\n   207→      const pivotCount = popcount64(pivotVals);\n   208→      const totalCount = freeCount + pivotCount;\n   209→\n   210→      const existing = firstHalfMap.get(effect);\n   211→      if (!existing || totalCount < existing.count ||\n   212→          (totalCount === existing.count && mask < existing.freeMask)) {\n   213→        // Build buttons list for lex comparison\n   214→        const btns: number[] = [];\n   215→        for (let i = 0; i < half1; i++) {\n   216→          if (mask & (1 << i)) btns.push(freeVars[i]);\n   217→        }\n   218→        // Add pivot buttons\n   219→        for (let row = 0; row < rank; row++) {\n   220→          if ((pivotVals >> BigInt(row)) & 1n) {\n   221→            btns.push(pivotCol[row]);\n   222→          }\n   223→        }\n   224→        firstHalfMap.set(effect, { count: totalCount, freeMask: mask, totalButtons: btns });\n   225→      }\n   226→    }\n   227→\n   228→    // For second half, enumerate and look up complementary first half\n   229→    for (let mask2 = 0; mask2 < (1 << half2); mask2++) {\n   230→      let effect2 = 0n;\n   231→      let freeCount2 = 0;\n   232→      for (let i = 0; i < half2; i++) {\n   233→        if (mask2 & (1 << i)) {\n   234→          effect2 ^= freeContrib[half1 + i];\n   235→          freeCount2++;\n   236→        }\n   237→      }\n   238→\n   239→      // We need first half effect such that basePivot ^ effect1 ^ effect2 gives minimum 1s\n   240→      // i.e.,