n    freeCost: number;\n    freeValues: number[];\n    contrib: number[]; // contribution vector to each pivot row (mod p)\n  }\n\n  const half1Map = new Map<string, Half1Entry>();\n  const freeVals1 = new Array(half1).fill(0);\n\n  // Enumerate all modulus^half1 combinations using odometer-style counting\n  let done1 = false;\n  while (!done1) {\n    const contrib = new Array(rank);\n    let freeCost = 0;\n    for (let r = 0; r < rank; r++) {\n      let c = 0;\n      for (let fi = 0; fi < half1; fi++) {\n        c += pivotFreeCoeff[r][fi] * freeVals1[fi];\n      }\n      contrib[r] = ((c % modulus) + modulus) % modulus;\n    }\n    for (let fi = 0; fi < half1; fi++) {\n      freeCost += freeVals1[fi];\n    }\n\n    const key = contrib.join(',');\n    const existing = half1Map.get(key);\n    if (!existing || freeCost < existing.freeCost ||\n        (freeCost === existing.freeCost && compareLexArrRaw(freeVals1, existing.freeValues) < 0)) {\n      half1Map.set(key, { freeCost, freeValues: freeVals1.slice(), contrib: contrib.slice() });\n    }\n\n    // Increment odometer\n    done1 = true;\n    for (let fi = half1 - 1; fi >= 0; fi--) {\n      freeVals1[fi]++;\n      if (freeVals1[fi] < modulus) { done1 = false; break; }\n      freeVals1[fi] = 0;\n    }\n  }\n\n  // For the second half, enumerate and check all first half entries.\n  // The map deduplicates by contribution vector, so map size is at most modulus^rank.\n  let bestResult: number[] | null = null;\n  let bestTotal = Infinity;\n\n  const freeVals2 = new Array(half2).fill(0);\n\n  let done2 = false;\n  while (!done2) {\n    const contrib2 = new Array(rank);\n    let freeCost2 = 0;\n    for (let r = 0; r < rank; r++) {\n      let c = 0;\n      for (let fi = 0; fi < half2; fi++) {\n        c += pivotFreeCoeff[r][half1 + fi] * freeVals2[fi];\n      }\n      contrib2[r] = ((c % modulus) + modulus) % modulus;\n    }\n    for (let fi = 0; fi < half2; fi++) {\n      freeCost2 += freeVals2[fi];\n    }\n\n    // For each first half entry, compute pivot values using stored contribution\n    for (const [, entry1] of half1Map) {\n      let pivotCost = 0;\n      const pivotVals = new Array(rank);\n      for (let r = 0; r < rank; r++) {\n        const val = ((pivotBase[r] - entry1.contrib[r] - contrib2[r]) % modulus + modulus) % modulus;\n        pivotVals[r] = val;\n        pivotCost += val;\n      }\n      const totalCost = entry1.freeCost + freeCost2 + pivotCost;\n\n      if (totalCost < bestTotal) {\n        bestTotal = totalCost;\n        bestResult = buildCounterSolution(numButtons, freeVars, pivotColForRow, entry1.freeValues, freeVals2, pivotVals, half1, half2, rank);\n      } else if (totalCost === bestTotal) {\n        const candidate = buildCounterSolution(numButtons, freeVars, pivotColForRow, entry1.freeValues, freeVals2, pivotVals, half1, half2, rank);\n        if (compareLexArr(candidate, bestResult!) < 0) {\n          bestResult = candidate;\n        }\n      }\n    }\n\n    // Increment odometer\n    done2 = true;\n    for (let fi = half2 - 1; fi >= 0; fi--) {\n      freeVals2[fi]++;\n      if (freeVals2[fi] < modulus) { done2 = false; break; }\n      freeVals2[fi] = 0;\n    }\n  }\n\n  return bestResult;\n}","originalFile":"export interface Machine {\n  target: boolean[];\n  buttons: number[][];\n}\n\n/**\n * Solve a toggle puzzle using Gaussian elimination over GF(2).\n * Returns minimum set of button indices (sorted ascending, lexicographically smallest on ties),\n * or null if no solution exists.\n */\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const numLights = target.length;\n  const numButtons = buttons.length;\n\n  // Build augmented matrix over GF(2) using BigInt bitmasks.\n  // Rows = lights, Columns = buttons + 1 augmented column.\n  // matrix[light] has bit j set if button j toggles that light, and bit numButtons for target.\n  const matrix: bigint[] = new Array(numLights).fill(0n);\n\n  for (let btn = 0; btn < numButtons; btn++) {\n    const bit = 1n << BigInt(btn);\n    for (const light of buttons[btn]) {\n      if (light >= 0 && light < numLights) {\n        matrix[light] |= bit;\n      }\n    }\n  }\n\n  const augBit = 1n << BigInt(numButtons);\n  for (let light = 0; light < numLights; light++) {\n    if (target[light]) {\n      matrix[light] |= augBit;\n    }\n  }\n\n  // Gaussian elimination over GF(2) with full row reduction (RREF)\n  const pivotColForRow: number[] = []; // pivotColForRow[i] = column index of pivot in row i\n  const isPivotCol = new Array(numButtons).fill(false);\n  let row = 0;\n\n  for (let col = 0; col < numButtons && row < numLights; col++) {\n    // Find pivot\n    let pivotRow = -1;\n    const colBit = 1n << BigInt(col);\n    for (let r = row; r < numLights; r++) {\n      if (matrix[r] & colBit) {\n        pivotRow = r;\n        break;\n      }\n    }\n    if (pivotRow === -1) continue;\n\n    // Swap\n    [matrix[row], matrix[pivotRow]] = [matrix[pivotRow], matrix[row]];\n    isPivotCol[col] = true;\n    pivotColForRow.push(col);\n\n    // Eliminate from all other rows\n    for (let r = 0; r < numLights; r++) {\n      if (r !== row && (matrix[r] & colBit)) {\n        matrix[r] ^= matrix[row];\n      }\n    }\n    row++;\n  }\n\n  const rank = row;\n\n  // Check consistency\n  for (let r = rank; r < numLights; r++) {\n    if (matrix[r] & augBit) {\n      return null;\n    }\n  }\n\n  // Identify free variables\n  const freeVars: number[] = [];\n  for (let col = 0; col < numButtons; col++) {\n    if (!isPivotCol[col]) {\n      freeVars.push(col);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  // Unique solution: no free variables\n  if (numFree === 0) {\n    const result: number[] = [];\n    for (let r = 0; r < rank; r++) {\n      if (matrix[r] & augBit) {\n        result.push(pivotColForRow[r]);\n      }\n    }\n    result.sort((a, b) => a - b);\n    return result;\n  }\n\n  // With free variables, enumerate all 2^numFree assignments.\n  // For GF(2) with 40 buttons, worst case rank could be 0 (all target 0, buttons are linearly dependent).\n  // But with 40 lights constraints, rank is at most min(40, 40) = 40 and free vars = numButtons - rank.\n  // If numFree is large (>25), we need meet-in-the-middle.\n\n  // Precompute: for each pivot row, which free variables contribute\n  // After RREF, matrix[r] has pivot column pivotColForRow[r] = 1, and possibly some free variable columns = 1\n  // Value of pivot variable r = augmented_value XOR (sum of free vars that have 1 in row r)\n  const pivotAugVal: boolean[] = new Array(rank);\n  const freeContribMask: bigint[] = new Array(rank); // bitmask over free var indices\n  for (let r = 0; r < rank; r++) {\n    pivotAugVal[r] = !!(matrix[r] & augBit);\n    let mask = 0n;\n    for (let fi = 0; fi < numFree; fi++) {\n      if (matrix[r] & (1n << BigInt(freeVars[fi]))) {\n        mask |= 1n << BigInt(fi);\n      }\n    }\n    freeContribMask[r] = mask;\n  }\n\n  if (numFree <= 20) {\n    return solveToggleDirect(numFree, rank, freeVars, pivotColForRow, pivotAugVal, freeContribMask);\n  } else {\n    return solveToggleMITM(numFree, rank, freeVars, pivotColForRow, pivotAugVal, freeContribMask);\n  }\n}\n\nfunction solveToggleDirect(\n  numFree: number,\n  rank: number,\n  freeVars: number[],\n  pivotColForRow: number[],\n  pivotAugVal: boolean[],\n  freeContribMask: bigint[]\n): number[] {\n  let bestResult: number[] | null = null;\n  let bestCount = Infinity;\n\n  const limit = 1n << BigInt(numFree);\n  for (let freeMask = 0n; freeMask < limit; freeMask++) {\n    let count = popcount64(freeMask);\n\n    // Compute pivot variable values\n    let pivotPressCount = 0;\n    for (let r = 0; r < rank; r++) {\n      const contrib = popcount64(freeContribMask[r] & freeMask) & 1;\n      const val = (pivotAugVal[r] ? 1 : 0) ^ contrib;\n      pivotPressCount += val;\n    }\n    count += pivotPressCount;\n\n    if (count < bestCount) {\n      bestCount = count;\n      bestResult = buildToggleSolution(freeMask, numFree, rank, freeVars, pivotColForRow, pivotAugVal, freeContribMask);\n    } else if (count === bestCount) {\n      const candidate = buildToggleSolution(freeMask, numFree, rank, freeVars, pivotColForRow, pivotAugVal, freeContribMask);\n      if (compareSortedArrays(candidate, bestResult!) < 0) {\n        bestResult = candidate;\n      }\n    }\n  }\n\n  return bestResult!;\n}\n\nfunction solveToggleMITM(\n  numFree: number,\n  rank: number,\n  freeVars: number[],\n  pivotColForRow: number[],\n  pivotAugVal: boolean[],\n  freeContribMask: bigint[]\n): number[] {\n  const half1 = Math.ceil(numFree / 2);\n  const half2 = numFree - half1;\n  const half1Mask = (1n << BigInt(half1)) - 1n;\n\n  // Precompute augPattern\n  let augPattern = 0n;\n  for (let r = 0; r < rank; r++) {\n    if (pivotAugVal[r]) {\n      augPattern |= 1n << BigInt(r);\n    }\n  }\n\n  // First half: enumerate 2^half1 assignments\n  const half1Limit = 1n << BigInt(half1);\n  // Map from pivot-row-parity-pattern to best first-half assignment\n  const half1Map = new Map<bigint, { freeCount: number; freeMask: bigint }>();\n\n  for (let mask1 = 0n; mask1 < half1Limit; mask1++) {\n    let pattern = 0n;\n    for (let r = 0; r < rank; r++) {\n      const half1Contrib = freeContribMask[r] & half1Mask;\n      const parity = popcount64(half1Contrib & mask1) & 1;\n      if (parity) {\n        pattern |= 1n << BigInt(r);\n      }\n    }\n\n    const freeCount = popcount64(mask1);\n    const existing = half1Map.get(pattern);\n    if (!existing || freeCount < existing.freeCount ||\n        (freeCount === existing.freeCount && mask1 < existing.freeMask)) {\n      half1Map.set(pattern, { freeCount, freeMask: mask1 });\n    }\n  }\n\n  // Second half: enumerate 2^half2 assignments\n  const half2Limit = 1n << BigInt(half2);\n  let bestResult: number[] = buildToggleSolution(0n, numFree, rank, freeVars, pivotColForRow, pivotAugVal, freeContribMask);\n  let bestCount = bestResult.length;\n\n  for (let mask2 = 0n; mask2 < half2Limit; mask2++) {\n    const freeCount2 = popcount64(mask2);\n\n    // Compute half2 parity pattern on pivot rows\n    let half2Pattern = 0n;\n    for (let r = 0; r < rank; r++) {\n      const half2Contrib = freeContribMask[r] >> BigInt(half1);\n      const parity = popcount64(half2Contrib & mask2) & 1;\n      if (parity) {\n        half2Pattern |= 1n << BigInt(r);\n      }\n    }\n\n    for (const [pattern1, entry1] of half1Map) {\n      const pivotPattern = augPattern ^ pattern1 ^ half2Pattern;\n      const pivotCount = popcount64(pivotPattern);\n      const totalCount = entry1.freeCount + freeCount2 + pivotCount;\n\n      if (totalCount < bestCount) {\n        bestCount = totalCount;\n        const fullFreeMask = entry1.freeMask | (mask2 << BigInt(half1));\n        bestResult = buildToggleSolution(fullFreeMask, numFree, rank, freeVars, pivotColForRow, pivotAugVal, freeContribMask);\n      } else if (totalCount === bestCount) {\n        const fullFreeMask = entry1.freeMask | (mask2 << BigInt(half1));\n        const candidate = buildToggleSolution(fullFreeMask, numFree, rank, freeVars, pivotColForRow, pivotAugVal, freeContribMask);\n        if (compareSortedArrays(candidate, bestResult) < 0) {\n          bestResult = candidate;\n        }\n      }\n    }\n  }\n\n  return bestResult;\n}\n\nfunction buildToggleSolution(\n  freeMask: bigint,\n  numFree: number,\n  rank: number,\n  freeVars: number[],\n  pivotColForRow: number[],\n  pivotAugVal: boolean[],\n  freeContribMask: bigint[]\n): number[] {\n  const result: number[] = [];\n\n  for (let fi = 0; fi < numFree; fi++) {\n    if (freeMask & (1n << BigInt(fi))) {\n      result.push(freeVars[fi]);\n    }\n  }\n\n  for (let r = 0; r < rank; r++) {\n    const contrib = popcount64(freeContribMask[r] & freeMask) & 1;\n    const val = (pivotAugVal[r] ? 1 : 0) ^ contrib;\n    if (val) {\n      result.push(pivotColForRow[r]);\n    }\n  }\n\n  result.sort((a, b) => a - b);\n  return result;\n}\n\nfunction compareSortedArrays(a: number[], b: number[]): number {\n  // Compare two sorted arrays lexicographically\n  // Fewer elements wins (smaller set), then lex\n  if (a.length !== b.length) return a.length - b.length;\n  for (let i = 0; i < a.length; i++) {\n    if (a[i] !== b[i]) return a[i] - b[i];\n  }\n  return 0;\n}\n\nfunction popcount64(n: bigint): number {\n  let count = 0;\n  while (n > 0n) {\n    n &= n - 1n;\n    count++;\n  }\n  return count;\n}\n\n// ============================================================\n// Part 2: Counter Puzzle over GF(p)\n// ============================================================\n\n/**\n * Solve a counter puzzle using Gaussian elimination over GF(p).\n * Returns array where result[i] is press count for button i, or null if no solution.\n * Minimizes total presses, then lexicographically smallest.\n */\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const numCounters = lights.length;\n  const numButtons = buttons.length;\n\n  if (numButtons === 0) {\n    for (const t of lights) {\n      if (((t % modulus) + modulus) % modulus !== 0) return null;\n    }\n    return [];\n  }\n\n  // Build augmented matrix over GF(modulus)\n  const numCols = numButtons + 1;\n  const matrix: number[][] = [];\n\n  for (let c = 0; c < numCounters; c++) {\n    const row = new Array(numCols).fill(0);\n    row[numButtons] = ((lights[c] % modulus) + modulus) % modulus;\n    matrix.push(row);\n  }\n\n  for (let btn = 0; btn < numButtons; btn++) {\n    for (const counter of buttons[btn]) {\n      if (counter >= 0 && counter < numCounters) {\n        matrix[counter][btn] = (matrix[counter][btn] + 1) % modulus;\n      }\n    }\n  }\n\n  // Precompute modular inverse table using Fermat's little theorem\n  const inv = new Array(modulus).fill(0);\n  for (let i = 1; i < modulus; i++) {\n    inv[i] = modPow(i, modulus - 2, modulus);\n  }\n\n  // Gaussian elimination over GF(modulus) -> RREF\n  const pivotColForRow: number[] = [];\n  const isPivotCol = new Array(numButtons).fill(false);\n  let currentRow = 0;\n\n  for (let col = 0; col < numButtons && currentRow < numCounters; col++) {\n    // Find pivot\n    let pivotR = -1;\n    for (let r = currentRow; r < numCounters; r++) {\n      if (matrix[r][col] !== 0) {\n        pivotR = r;\n        break;\n      }\n    }\n    if (pivotR === -1) continue;\n\n    // Swap\n    [matrix[currentRow], matrix[pivotR]] = [matrix[pivotR], matrix[currentRow]];\n\n    // Scale pivot row\n    const scale = inv[matrix[currentRow][col]];\n    for (let c = 0; c < numCols; c++) {\n      matrix[currentRow][c] = (matrix[currentRow][c] * scale) % modulus;\n    }\n\n    isPivotCol[col] = true;\n    pivotColForRow.push(col);\n\n    // Eliminate from all other rows\n    for (let r = 0; r < numCounters; r++) {\n      if (r !== currentRow && matrix[r][col] !== 0) {\n        const factor = matrix[r][col];\n        for (let c = 0; c < numCols; c++) {\n          matrix[r][c] = ((matrix[r][c] - factor * matrix[currentRow][c]) % modulus + modulus) % modulus;\n        }\n      }\n    }\n\n    currentRow++;\n  }\n\n  const rank = currentRow;\n\n  // Check consistency\n  for (let r = rank; r < numCounters; r++) {\n    if (matrix[r][numButtons] !== 0) {\n      return null;\n    }\n  }\n\n  // Identify free variables\n  const freeVars: number[] = [];\n  for (let col = 0; col < numButtons; col++) {\n    if (!isPivotCol[col]) {\n      freeVars.push(col);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  // Precompute pivot info\n  const pivotBase: number[] = new Array(rank);\n  const pivotFreeCoeff: number[][] = new Array(rank);\n  for (let r = 0; r < rank; r++) {\n    pivotBase[r] = matrix[r][numButtons];\n    pivotFreeCoeff[r] = new Array(numFree);\n    for (let fi = 0; fi < numFree; fi++) {\n      pivotFreeCoeff[r][fi] = matrix[r][freeVars[fi]];\n    }\n  }\n\n  if (numFree === 0) {\n    c