^ effect1) + pivotCount + freeCount2;\n\n        // Rebuild actual count properly\n        let freeCount1 = 0;\n        for (let i = 0; i < half1; i++) {\n          if (entry1.freeMask & (1 << i)) freeCount1++;\n        }\n        const actualTotal = freeCount1 + freeCount2 + pivotCount;\n\n        if (bestResult === null || actualTotal < bestCount) {\n          bestCount = actualTotal;\n          const solution: number[] = [];\n          for (let i = 0; i < half1; i++) {\n            if (entry1.freeMask & (1 << i)) solution.push(freeVars[i]);\n          }\n          for (let i = 0; i < half2; i++) {\n            if (mask2 & (1 << i)) solution.push(freeVars[half1 + i]);\n          }\n          for (let row = 0; row < rank; row++) {\n            if ((pivotVals >> BigInt(row)) & 1n) {\n              solution.push(pivotCol[row]);\n            }\n          }\n          bestResult = solution;\n        } else if (actualTotal === bestCount) {\n          const solution: number[] = [];\n          for (let i = 0; i < half1; i++) {\n            if (entry1.freeMask & (1 << i)) solution.push(freeVars[i]);\n          }\n          for (let i = 0; i < half2; i++) {\n            if (mask2 & (1 << i)) solution.push(freeVars[half1 + i]);\n          }\n          for (let row = 0; row < rank; row++) {\n            if ((pivotVals >> BigInt(row)) & 1n) {\n              solution.push(pivotCol[row]);\n            }\n          }\n          if (compareLex(solution, bestResult!) < 0) {\n            bestResult = solution;\n          }\n        }\n      }\n    }\n  }\n\n  if (bestResult) {\n    bestResult.sort((a, b) => a - b);\n  }\n  return bestResult;\n}\n\nfunction popcount64(n: bigint): number {\n  let count = 0;\n  while (n > 0n) {\n    n &= n - 1n;\n    count++;\n  }\n  return count;\n}\n\nfunction compareLex(a: number[], b: number[]): number {\n  const sa = a.slice().sort((x, y) => x - y);\n  const sb = b.slice().sort((x, y) => x - y);\n  const len = Math.max(sa.length, sb.length);\n  fo