ate but isn't. So propagate was","+          // swapped with that other input.","+          const expectedProp =","+            orWithGen.in1 === generate ? orWithGen.in2 : orWithGen.in1;","+          doSwap(propagate, expectedProp);","+          propagate = andTC.out;","+          orGate = orWithGen;","+        } else {","+          throw new Error(","+            `Cannot resolve OR gate for bit ${i}, generate=${generate}, propagate=${propagate}`,","+          );","+        }","+      }","+","+      carry = orGate!.out;","     }","   }"," "]}],"originalFile":"export interface Gate {\n  op: 'AND' | 'OR' | 'XOR';\n  in1: string;\n  in2: string;\n  out: string;\n}\n\nexport function simulate(\n  gates: Gate[],\n  inputs: Record<string, number>,\n): Record<string, number> {\n  const wires: Record<string, number> = { ...inputs };\n  const remaining = [...gates];\n\n  let changed = true;\n  while (changed && remaining.length > 0) {\n    changed = false;\n    for (let i = remaining.length - 1; i >= 0; i--) {\n      const gate = remaining[i];\n      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {\n        const a = wires[gate.in1];\n        const b = wires[gate.in2];\n        let result: number;\n        switch (gate.op) {\n          case 'AND':\n            result = a & b;\n            break;\n          case 'OR':\n            result = a | b;\n            break;\n          case 'XOR':\n            result = a ^ b;\n            break;\n        }\n        wires[gate.out] = result;\n        remaining.splice(i, 1);\n        changed = true;\n      }\n    }\n  }\n\n  return wires;\n}\n\n/**\n * Find 4 pairs of swapped output wires in a ripple-carry adder circuit.\n *\n * A correct N-bit ripple-carry adder has this structure for each bit i:\n *\n * Bit 0 (half adder):\n *   x00 XOR y00 -> z00\n *   x00 AND y00 -> c00\n *\n * Bit i (i > 0, full adder):\n *   xNN XOR yNN -> tNN       (partial sum)\n *   tNN XOR c(N-1) -> zNN    (final sum)\n *   xNN AND yNN -> aNN       (generate)\n *   tNN AND c(N-1) -> bNN    (propagate)\n *   aNN OR bNN -> cNN        (carry out)\n *\n * Last bit: carry out -> z(N+1)\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Build lookup maps\n  const gateByOutput: Map<string, Gate> = new Map();\n  for (const gate of gates) {\n    gateByOutput.set(gate.out, gate);\n  }\n\n  // Find how many input bits we have\n  let maxBit = 0;\n  for (const gate of gates) {\n    for (const w of [gate.in1, gate.in2]) {\n      const m = w.match(/^[xy](\\d+)$/);\n      if (m) {\n        maxBit = Math.max(maxBit, parseInt(m[1], 10));\n      }\n    }\n  }\n\n  // Helper: find a gate by op and inputs (unordered)\n  function findGate(\n    op: string,\n    inA: string,\n    inB: string,\n  ): Gate | undefined {\n    return gates.find(\n      (g) =>\n        g.op === op &&\n        ((g.in1 === inA && g.in2 === inB) ||\n          (g.in1 === inB && g.in2 === inA)),\n    );\n  }\n\n  const swapped: Set<string> = new Set();\n\n  function swap(a: string, b: string): void {\n    // Swap the output wires of two gates\n    const gA = gateByOutput.get(a)!;\n    const gB = gateByOutput.get(b)!;\n    gA.out = b;\n    gB.out = a;\n    gateByOutput.set(a, gB);\n    gateByOutput.set(b, gA);\n    swapped.add(a);\n    swapped.add(b);\n  }\n\n  // We'll trace through the expected adder structure bit by bit,\n  // identifying where the wiring doesn't match expectations.\n  let carry = '';\n\n  for (let i = 0; i <= maxBit; i++) {\n    const xi = `x${i.toString().padStart(2, '0')}`;\n    const yi = `y${i.toString().padStart(2, '0')}`;\n    const zi = `z${i.toString().padStart(2, '0')}`;\n\n    if (i === 0) {\n      // Half adder: x00 XOR y00 -> z00, x00 AND y00 -> c00\n      const xorGate = findGate('XOR', xi, yi);\n      if (!xorGate) throw new Error(`Missing XOR gate for bit 0`);\n\n      if (xorGate.out !== zi) {\n        swap(xorGate.out, zi);\n      }\n\n      const andGate = findGate('AND', xi, yi);\n      if 