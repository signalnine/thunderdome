+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01MvCDUpYw4cCUUvZuDc7UMV","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01FTATMKN4gs3dgHBpqttsvF","name":"Write","input":{"file_path":"/workspace/src/index.test.ts","content":"import { describe, it, expect } from 'vitest';\nimport { simulate, findSwappedWires, Gate } from './index.js';\n\ndescribe('simulate', () => {\n  it('should compute AND gate', () => {\n    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 0 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 0 });\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n  });\n\n  it('should compute OR gate', () => {\n    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n  });\n\n  it('should compute XOR gate', () => {\n    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 0 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n  });\n\n  it('should handle chained gates in dependency order', () => {\n    const gates: Gate[] = [\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },\n    ];\n    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({\n      a: 1, b: 1, c: 1, d: 0, e: 1,\n    });\n    expect(simulate(gates, { a: 0, b: 1, d: 0 })).toEqual({\n      a: 0, b: 1, c: 0, d: 0, e: 0,\n    });\n  });\n\n  it('should handle gates defined out of order', () => {\n    // e depends on c, but gates are listed in reverse\n    const gates: Gate[] = [\n      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n    ];\n    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({\n      a: 1, b: 1, c: 1, d: 0, e: 1,\n    });\n  });\n\n  it('should simulate a half adder (bit 0)', () => {\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n    ];\n    // 1 + 1 = 10 in binary\n    const result = simulate(gates, { x00: 1, y00: 1 });\n    expect(result.z00).toBe(0);\n    expect(result.c00).toBe(1);\n\n    // 1 + 0 = 01\n    const result2 = simulate(gates, { x00: 1, y00: 0 });\n    expect(result2.z00).toBe(1);\n    expect(result2.c00).toBe(0);\n  });\n\n  it('should simulate a 2-bit adder', () => {\n    // 2-bit adder: x(1..0) + y(1..0) = z(2..0)\n    const gates: Gate[] = [\n      // Bit 0: half adder\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      // Bit 1: full adder\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },\n    ];\n\n    // 3 + 3 = 6 (11 + 11 = 110)\n    const r1 = simulate(gates, { x00: 1, x01: 1, y00: 1, y01: 1 });\n    expect(r1.z00).toBe(0);\n    expect(r1.z01).toBe(1);\n    expect(r1.z02).toBe(1);\n\n    // 2 + 1 = 3 (10 + 01 = 011)\n    const r2 = simulate(gates, { x00: 0, x01: 1, y00: 1, y01: 0 });\n    expect(r2.z00).toBe(1);\n    expect(r2.z01).toBe(1);\n    expect(r2.z02).toBe(0);\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  /**\n   * Helper to build a correct N-bit ripple-carry adder.\n   */\n  function buildAdder(bits: number): Gate[] {\n    const gates: Gate[] = [];\n    for (let i = 0; i < bits; i++) {\n      const xi = `x${i.toString().padStart(2, '0')}`;\n      const yi = `y${i.toString().padStart(2, '0')}`;\n      const zi = `z${i.toString().padStart(2, '0')}`;\n      if (i === 0) {\n        gates.push({ op: 'XOR', in1: xi, in2: yi, out: zi });\n        gates.push({ op: 'AND', in1: xi, in2: yi, out: `c${i.toString().padStart(2, '0')}` });\n      } else {\n        const carry = `c${(i - 1).toString().padStart(2, '0')}`;\n        const t = `t${i.toString().padStart(2, '0')}`;\n        const a = `a${i.toString().padStart(2, '0')}`;\n        const b = `b${i.toString().padStart(2, '0')}`;\n        const c = `c${i.toString().padStart(2, '0')}`;\n        gates.push({ op: 'XOR', in1: xi, in2: yi, out: t });\n        gates.push({ op: 'XOR', in1: t, in2: carry, out: zi });\n        gates.push({ op: 'AND', in1: xi, in2: yi, out: a });\n        gates.push({ op: 'AND', in1: t, in2: carry, out: b });\n        gates.push({ op: 'OR', in1: a, in2: b, out: c });\n      }\n    }\n    // Final carry -> MSB output\n    const lastCarry = `c${(bits - 1).toString().padStart(2, '0')}`;\n    const zMSB = `z${bits.toString().padStart(2, '0')}`;\n    // The final carry needs to be connected. In the spec example, \"c03 -> z04\".\n    // We model this as an OR gate with carry OR carry (identity through OR with self).\n    // Actually, let's use XOR with 0 or just check: the spec says carry is directly z.\n    // For the purpose of findSwappedWires, the last carry's output IS the z-bit.\n    // We need to rename the last carry gate's output to zMSB.\n    // Find the gate that outputs lastCarry and rename it.\n    const lastGate = gates.find(g => g.out === lastCarry);\n    if (lastGate) {\n      lastGate.out = zMSB;\n    }\n    return gates;\n  }\n\n  function swapOutputs(gates: Gate[], wire1: string, wire2: string): void {\n    const g1 = gates.find(g => g.out === wire1)!;\n    const g2 = gates.find(g => g.out === wire2)!;\n    g1.out = wire2;\n    g2.out = wire1;\n  }\n\n  function shuffleGates(gates: Gate[]): Gate[] {\n    // Fisher-Yates shuffle\n    const arr = [...gates];\n    for (let i = arr.length - 1; i > 0; i--) {\n      const j = Math.floor(Math.random() * (i + 1));\n      [arr[i], arr[j]] = [arr[j], arr[i]];\n    }\n    return arr;\n  }\n\n  it('should find 4 pairs of swapped wires in a small adder', () => {\n    const gates = buildAdder(8);\n    // Swap 4 pairs\n    swapOutputs(gates, 'z01', 'a01');\n    swapOutputs(gates, 'z03', 't03');\n    swapOutputs(gates, 'c04', 'b05');\n    swapOutputs(gates, 'z07', 'a07');\n\n    const result = findSwappedWires(shuffleGates(gates));\n    expect(result).toEqual(['a01', 'a07', 'b05', 'c04', 't03', 'z01', 'z03', 'z07']);\n  });\n\n  it('should find swapped wires in a larger adder', () => {\n    const gates = buildAdder(20);\n    swapOutputs(gates, 'z05', 't05');\n    swapOutputs(gates, 'a10', 'z10');\n    swapOutputs(gates, 'b15', 'c15');\n    swapOutputs(gates, 'z19', 'a19');\n\n    const result = findSwappedWires(shuffleGates(gates));\n    expect(result).toEqual(['a10', 'a19', 'b15', 'c15', 't05', 'z05', 'z10', 'z19']);\n  });\n\n  it('should handle a 45-bit adder within time limit', () => {\n    const gates = buildAdder(45);\n    swapOutputs(gates, 'z02', 't02');\n    swapOutputs(gates, 'z15', 'a15');\n    swapOutputs(gates, 'b30', 'c30');\n    swapOutputs(gates, 'z44', 'a44');\n\n    const start = Date.now();\n    const result = findSwappedWires(shuffleGates(gates));\n    const elapsed = Date.now() - start;\n\n    expect(result).toEqual(['a15', 'a44', 'b30', 'c30', 't02', 'z02', 'z15', 'z44']);\n    expect(elapsed).toBeLessThan(5000);\n  });\n\n  it('should find swaps involving the carry chain', () => {\n    const gates = buildAdder(10);\n    // Swap carry outputs\n    swapOutputs(gates, 'c01', 'a02');\n    swapOutputs(gates, 'c05', 'b06');\n    swapOutputs(gates, 'z08', 'a08');\n    swapOutputs(gates, 'z03', 't03');\n\n    const result = findSwappedWires(shuffleGates(gates));\n    expect(result).toEqual(['a02', 'a08', 'b06', 'c01', 'c05', 't03', 'z03', 'z08']);\n  });\n\n  it('should work with randomized wire names', () => {\n    // Build adder with random internal wire names\n    const bits = 10;\n    const gates: Gate[] = [];\n    let counter = 0;\n    const randName = () => `w${(counter++).toString().padStart(3, '0')}`;\n\n    const carries: string[] = [];\n    const internalWires: string[] = [];\n\n    for (let i = 0; i < bits; i++) {\n      const xi = `x${i.toString().padStart(2, '0')}`;\n      const yi = `y${i.toString().padStart(2, '0')}`;\n      const zi = `z${i.toString().padStart(2, '0')}`;\n      if (i === 0) {\n        gates.push({ op: 'XOR', in1: xi, in2: yi, out: zi });\n        const cName = randName();\n        gates.push({ op: 'AND', in1: xi, in2: yi, out: cName });\n        carries.push(cName);\n      } else {\n        const t = randName();\n        const a = randName();\n        const b = randName();\n        const c = i < bits - 1 ? randName() : `z${bits.toString().padStart(2, '0')}`;\n\n        gates.push({ op: 'XOR', in1: xi, in2: yi, out: t });\n        gates.push({ op: 'XOR', in1: t, in2: carries[i - 1], out: zi });\n        gates.push({ op: 'AND', in1: xi, in2: yi, out: a });\n        gates.push({ op: 'AND', in1: t, in2: carries[i - 1], out: b });\n        gates.push({ op: 'OR', in1: a, in2: b, out: c });\n\n        carries.push(c);\n        internalWires.push(t, a, b);\n      }\n    }\n\n    // Now swap 4 pairs of outputs\n    // Swap z01 <-> one of the internal wires\n    const z01Gate = gates.find(g => g.out === 'z01')!;\n    const w001Gate = gates.find(g => g.out === 'w001')!;\n    // swap them\n    z01Gate.out = 'w001';\n    w001Gate.out = 'z01';\n\n    const z03Gate = gates.find(g => g.out === 'z03')!;\n    const w005Gate = gates.find(g => g.out === 'w005')!;\n    z03Gate.out = 'w005';\n    w005Gate.out = 'z03';\n\n    const z05Gate = gates.find(g => g.out === 'z05')!;\n    const w010Gate = gates.find(g => g.out === 'w010')!;\n    z05Gate.out = 'w010';\n    w010Gate.out = 'z05';\n\n    const z07Gate = gates.find(g => g.out === 'z07')!;\n    const w015Gate = gates.find(g => g.out === 'w015')!;\n    z07Gate.out = 'w015';\n    w015Gate.out = 'z07';\n\n    const result = findSwappedWires(shuffleGates(gates));\n    expect(result).toHaveLength(8);\n    expect(result).toEqual(\n      ['w001', 'w005', 'w010', 'w015', 'z01', 'z03', 'z05', 'z07'].sort(),\n    );\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":176,"cache_read_input_tokens":23710,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":176},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"e64aebb8-f34b-40f4-b3e1-b114ea6a1c5c","uuid":"af51a0f7-6d34-47af-804a-67052d933cd8"}
+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FTATMKN4gs3dgHBpqttsvF","type":"tool_result","content":"File created successfully at: /workspace/src/index.test.ts"}]},"parent_tool_use_id":null,"session_id":"e64aebb8-f34b-40f4-b3e1-b114ea6a1c5c","uuid":"3c385af6-77e8-4450-bf94-7e260ac4d6be","tool_use_result":{"type":"create","filePath":"/workspace/src/index.test.ts","content":"import { describe, it, expect } from 'vitest';\nimport { simulate, findSwappedWires, Gate } from './index.js';\n\ndescribe('simulate', () => {\n  it('should compute AND gate', () => {\n    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 0 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 0 });\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n  });\n\n  it('should compute OR gate', () => {\n    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n  });\n\n  it('should compute XOR gate', () => {\n    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 0 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n  });\n\n  it('should handle chained gates in dependency order', () => {\n    const gates: Gate[] = [\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },\n    ];\n    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({\n      a: 1, b: 1, c: 1, d: 0, e: 1,\n    });\n    expect(simulate(gates, { a: 0, b: 1, d: 0 })).toEqual({\n      a: 0, b: 1, c: 0, d: 0, e: 0,\n    });\n  });\n\n  it('should handle gates defined out of order', () => {\n    // e depends on c, but gates are listed in reverse\n    const gates: Gate[] = [\n      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n    ];\n    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({\n      a: 1, b: 1, c: 1, d: 0, e: 1,\n    });\n  });\n\n  it('should simulate a half adder (bit 0)', () => {\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n    ];\n    // 1 + 1 = 10 in binary\n    const result = simulate(gates, { x00: 1, y00: 1 });\n    expect(result.z00).toBe(0);\n    expect(result.c00).toBe(1);\n\n    // 1 + 0 = 01\n    const result2 = simulate(gates, { x00: 1, y00: 0 });\n    expect(result2.z00).toBe(1);\n    expect(result2.c00).toBe(0);\n  });\n\n  it('should simulate a 2-bit adder', () => {\n    // 2-bit adder: x(1..0) + y(1..0) = z(2..0)\n    const gates: Gate[] = [\n      // Bit 0: half adder\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      // Bit 1: full adder\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },\n    ];\n\n    // 3 + 3 = 6 (11 + 11 = 110)\n    const r1 = simulate(gates, { x00: 1, x01: 1, y00: 1, y01: 1 });\n    expect(r1.z00).toBe(0);\n    expect(r1.z01).toBe(1);\n    expect(r1.z02).toBe(1);\n\n    // 2 + 1 = 3 (10 + 01 = 011)\n    const r2 = simulate(gates, { x00: 0, x01: 1, y00: 1, y01: 0 });\n    expect(r2.z00).toBe(1);\n    expect(r2.z01).toBe(1);\n    expect(r2.z02).toBe(0);\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  /**\n   * Helper to build a correct N-bit ripple-carry adder.\n   */\n  function buildAdder(bits: number): Gate[] {\n    const gates: Gate[] = [];\n    for (let i = 0; i < bits; i++) {\n      const xi = `x${i.toString().padStart(2, '0')}`;\n      const yi = `y${i.toString().padStart(2, '0')}`;\n      const zi = `z${i.toString().padStart(2, '0')}`;\n      if (i === 0) {\n        gates.push({ op: 'XOR', in1: xi, in2: yi, out: zi });\n        gates.push({ op: 'AND', in1: xi, in2: yi, out: `c${i.toString().padStart(2, '0')}` });\n      } else {\n        const carry = `c${(i - 1).toString().padStart(2, '0')}`;\n        const t = `t${i.toString().padStart(2, '0')}`;\n        const a = `a${i.toString().padStart(2, '0')}`;\n        const b = `b${i.toString().padStart(2, '0')}`;\n        const c = `c${i.toString().padStart(2, '0')}`;\n        gates.push({ op: 'XOR', in1: xi, in2: yi, out: t });\n        gates.push({ op: 'XOR', in1: t, in2: carry, out: zi });\n        gates.push({ op: 'AND', in1: xi, in2: yi, out: a });\n        gates.push({ op: 'AND', in1: t, in2: carry, out: b });\n        gates.push({ op: 'OR', in1: a, in2: b, out: c });\n      }\n    }\n    // Final carry -> MSB output\n    const lastCarry = `c${(bits - 1).toString().padStart(2, '0')}`;\n    const zMSB = `z${bits.toString().padStart(2, '0')}`;\n    // The final carry needs to be connected. In the spec example, \"c03 -> z04\".\n    // We model this as an OR gate with carry OR carry (identity through OR with self).\n    // Actually, let's use XOR with 0 or just check: the spec says carry is directly z.\n    // For the purpose of findSwappedWires, the last carry's output IS the z-bit.\n    // We need to rename the last carry gate's output to zMSB.\n    // Find the gate that outputs lastCarry and rename it.\n    const lastGate = gates.find(g => g.out === lastCarry);\n    if (lastGate) {\n      lastGate.out = zMSB;\n    }\n    return gates;\n  }\n\n  function swapOutputs(gates: Gate[], wire1: string, wire2: string): void {\n    const g1 = gates.find(g => g.out === wire1)!;\n    const g2 = gates.find(g => g.out === wire2)!;\n    g1.out = wire2;\n    g2.out = wire1;\n  }\n\n  function shuffleGates(gates: Gate[]): Gate[] {\n    // Fisher-Yates shuffle\n    const arr = [...gates];\n    for (let i = arr.length - 1; i > 0; i--) {\n      const j = Math.floor(Math.random() * (i + 1));\n      [arr[i], arr[j]] = [arr[j], arr[i]];\n    }\n    return arr;\n  }\n\n  it('should find 4 pairs of swapped wires in a small adder', () => {\n    const gates = buildAdder(8);\n    // Swap 4 pairs\n    swapOutputs(gates, 'z01', 'a01');\n    swapOutputs(gates, 'z03', 't03');\n    swapOutputs(gates, 'c04', 'b05');\n    swapOutputs(gates, 'z07', 'a07');\n\n    const result = findSwappedWires(shuffleGates(gates));\n    expect(result).toEqual(['a01', 'a07', 'b05', 'c04', 't03', 'z01', 'z03', 'z07']);\n  });\n\n  it('should find swapped wires in a larger adder', () => {\n    const gates = buildAdder(20);\n    swapOutputs(gates, 'z05', 't05');\n    swapOutputs(gates, 'a10', 'z10');\n    swapOutputs(gates, 'b15', 'c15');\n    swapOutputs(gates, 'z19', 'a19');\n\n    const result = findSwappedWires(shuffleGates(gates));\n    expect(result).toEqual(['a10', 'a19', 'b15', 'c15', 't05', 'z05', 'z10', 'z19']);\n  });\n\n  it('should handle a 45-bit adder within time limit', () => {\n    const gates = buildAdder(45);\n    swapOutputs(gates, 'z02', 't02');\n    swapOutputs(gates, 'z15', 'a15');\n    swapOutputs(gates, 'b30', 'c30');\n    swapOutputs(gates, 'z44', 'a44');\n\n    const start = Date.now();\n    const result = findSwappedWires(shuffleGates(gates));\n    const elapsed = Date.now() - start;\n\n    expect(result).toEqual(['a15', 'a44', 'b30', 'c30', 't02', 'z02', 'z15', 'z44']);\n    expect(elapsed).toBeLessThan(5000);\n  });\n\n  it('should find swaps involving the carry chain', () => {\n    const gates = buildAdder(10);\n    // Swap carry outputs\n    swapOutputs(gates, 'c01', 'a02');\n    swapOutputs(gates, 'c05', 'b06');\n    swapOutputs(gates, 'z08', 'a08');\n    swapOutputs(gates, 'z03', 't03');\n\n    const result = findSwappedWires(shuffleGates(gates));\n    expect(result).toEqual(['a02', 'a08', 'b06', 'c01', 'c05', 't03', 'z03', 'z08']);\n  });\n\n  it('should work with randomized wire names', () => {\n    // Build adder with random internal wire names\n    const bits = 10;\n    const gates: Gate[] = [];\n    let counter = 0;\n    const randName = () => `w${(counter++).toString().padStart(3, '0')}`;\n\n    const carries: string[] = [];\n    const internalWires: string[] = [];\n\n    for (let i = 0; i < bits; i++) {\n      const xi = `x${i.toString().padStart(2, '0')}`;\n      const yi = `y${i.toString().padStart(2, '0')}`;\n      const zi = `z${i.toString().padStart(2, '0')}`;\n      if (i === 0) {\n        gates.push({ op: 'XOR', in1: xi, in2: yi, out: zi });\n        const cName = randName();\n        gates.push({ op: 'AND', in1: xi, in2: yi, out: cName });\n        carries.push(cName);\n      } else {\n        const t = randName();\n        const a = randName();\n        const b = randName();\n        const c = i < bits - 1 ? randName() : `z${bits.toString().padStart(2, '0')}`;\n\n        gates.push({ op: 'XOR', in1: xi, in2: yi, out: t });\n        gates.push({ op: 'XOR', in1: t, in2: carries[i - 1], out: zi });\n        gates.push({ op: 'AND', in1: xi, in2: yi, out: a });\n        gates.push({ op: 'AND', in1: t, in2: carries[i - 1], out: b });\n        gates.push({ op: 'OR', in1: a, in2: b, out: c });\n\n        carries.push(c);\n        internalWires.push(t, a, b);\n      }\n    }\n\n    // Now swap 4 pairs of outputs\n    // Swap z01 <-> one of the internal wires\n    const z01Gate = gates.find(g => g.out === 'z01')!;\n    const w001Gate = gates.find(g => g.out === 'w001')!;\n    // swap them\n    z01Gate.out = 'w001';\n    w001Gate.out = 'z01';\n\n    const z03Gate = gates.find(g => g.out === 'z03')!;\n    const w005Gate = gates.find(g => g.out === 'w005')!;\n    z03Gate.out = 'w005';\n    w005Gate.out = 'z03';\n\n    const z05Gate = gates.find(g => g.out === 'z05')!;\n    const w010Gate = gates.find(g => g.out === 'w010')!;\n    z05Gate.out = 'w010';\n    w010Gate.out = 'z05';\n\n    const z07Gate = gates.find(g => g.out === 'z07')!;\n    const w015Gate = gates.find(g => g.out === 'w015')!;\n    z07Gate.out = 'w015';\n    w015Gate.out = 'z07';\n\n    const result = findSwappedWires(shuffleGates(gates));\n    expect(result).toHaveLength(8);\n    expect(result).toEqual(\n      ['w001', 'w005', 'w010', 'w015', 'z01', 'z03', 'z05', 'z07'].sort(),\n    );\n  });\n});\n","structuredPatch":[],"originalFile":null}}
