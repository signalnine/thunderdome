 gA = gateByOutput.get(a)!;\n    const gB = gateByOutput.get(b)!;\n    gA.out = b;\n    gB.out = a;\n    gateByOutput.set(a, gB);\n    gateByOutput.set(b, gA);\n    swapped.add(a);\n    swapped.add(b);\n  }\n\n  let carry = '';\n\n  for (let i = 0; i <= maxBit; i++) {\n    const xi = `x${i.toString().padStart(2, '0')}`;\n    const yi = `y${i.toString().padStart(2, '0')}`;\n    const zi = `z${i.toString().padStart(2, '0')}`;\n\n    if (i === 0) {\n      // Half adder: x00 XOR y00 -> z00, x00 AND y00 -> c00\n      const xorGate = findGate('XOR', xi, yi)!;\n      if (xorGate.out !== zi) {\n        doSwap(xorGate.out, zi);\n      }\n      const andGate = findGate('AND', xi, yi)!;\n      carry = andGate.out;\n    } else {\n      // Full adder for bit i\n      // Step 1: xNN XOR yNN -> partialSum\n      const xorXY = findGate('XOR', xi, yi)!;\n      let partialSum = xorXY.out;\n\n      // Step 2: partialSum XOR carry -> zNN\n      let xorTC = findGate('XOR', partialSum, carry);\n\n      if (!xorTC) {\n        // Either partialSum or carry is wrong due to a swap.\n        // Look for an XOR gate that uses carry as input\n        const xorWithCarry = gates.find(\n          (g) =>\n            g.op === 'XOR' &&\n            (g.in1 === carry || g.in2 === carry) &&\n            g.in1 !== partialSum &&\n            g.in2 !== partialSum,\n        );\n        if (xorWithCarry) {\n          // partialSum was swapped with something\n          const otherInput =\n            xorWithCarry.in1 === carry\n              ? xorWithCarry.in2\n              : xorWithCarry.in1;\n          doSwap(partialSum, otherInput);\n          partialSum = xorXY.out;\n          xorTC = xorWithCarry;\n        } else {\n          // carry was swapped - look for XOR gate that uses partialSum\n          const xorWithPS = gates.find(\n            (g) =>\n              g.op === 'XOR' &&\n              (g.in1 === partialSum || g.in2 === partialSum) &&\n              g.in1 !== carry &&\n              g.in2 !== carry,\n          );\n          if (xorWithPS) {\n            const otherInput =\n              xorWithPS.in1 === partialSum\n                ? xorWithPS.in2\n                : xorWithPS.in1;\n            doSwap(carry, otherInput);\n            carry = otherInput;\n            xorTC = xorWithPS;\n          }\n        }\n      }\n\n      if (!xorTC) {\n        throw new Error(`Cannot find XOR for final sum at bit ${i}`);\n      }\n\n      // The output of the final XOR should be zNN\n      if (xorTC.out !== zi) {\n        doSwap(xorTC.out, zi);\n      }\n\n      // Step 3: xNN AND yNN -> generate\n      const andXY = findGate('AND', xi, yi)!;\n      let generate = andXY.out;\n\n      // Step 4: partialSum AND carry -> propagate\n      const andTC = findGate('AND', partialSum, carry);\n      let propagate: string;\n\n      if (!andTC) {\n        throw new Error(\n          `Missing AND(t,c) gate for bit ${i}, partialSum=${partialSum}, carry=${carry}`,\n        );\n      }\n      propagate = andTC.out;\n\n      // Step 5: generate OR propagate -> carryOut\n      let orGate = findGate('OR', generate, propagate);\n\n      if (!orGate) {\n        // One of generate or propagate is swapped.\n        // There should be exactly one OR gate that uses either generate or propagate as input.\n        const orWithGen = findGateWithInput('OR', generate);\n        const orWithProp = findGateWithInput('OR', propagate);\n\n        if (orWithGen && !orWithProp) {\n          // propagate is wrong - find what the OR gate actually expects\n          const expectedProp =\n            orWithGen.in1 === generate ? orWithGen.in2 : orWithGen.in1;\n          doSwap(propagate, expectedProp);\n          propagate = andTC.out;\n          orGate = orWithGen;\n        } else if (!orWithGen && orWithProp) {\n          // generate is wrong\n          const expectedGen =\n            orWithProp.in1 === propagate ? orWithProp.in2 : orWithProp.in1;\n          doSwap(generate, expectedGen);\n          generate = andXY.out;\n          orGate = orWithProp;\n        } else if (orWithGen && orWithProp && orWithGen !== orWithProp) {\n          // Both are used as inputs to different OR gates - one of them is swapped\n          // The correct OR gate should have both generate and propagate as inputs.\n          // Try to figure out which one is the right gate by checking if the\n          // \"other\" input of the OR gate makes sense.\n          // Actually, if both are in OR gates but different ones, let's see which\n          // one has the other input that could be the swapped version.\n          // This is tricky. Let's try: the correct OR gate uses the actual\n          // generate and propagate. If generate is in orWithGen, then the other\n          // input of orWithGen should be propagate but isn't. So propagate was\n          // swapped with that other input.\n          const expectedProp =\n            orWithGen.in1 === generate ? orWithGen.in2 : orWithGen.in1;\n          doSwap(propagate, expectedProp);\n          propagate = andTC.out;\n          orGate = orWithGen;\n        } else {\n          throw new Error(\n            `Cannot resolve OR gate for bit ${i}, generate=${generate}, propagate=${propagate}`,\n          );\n        }\n      }\n\n      carry = orGate!.out;\n    }\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[{"oldStart":42,"oldLines":26,"newStart":42,"newLines":10,"lines":["   return wires;"," }"," ","-/**","- * Find 4 pairs of swapped output wires in a ripple-carry adder circuit.","- *","- * A correct N-bit ripple-carry adder has this structure for each bit i:","- *","- * Bit 0 (half adder):","- *   x00 XOR y00 -> z00","- *   x00 AND y00 -> c00","- *","- * Bit i (i > 0, full adder):","- *   xNN XOR yNN -> tNN       (partial sum)","- *   tNN XOR c(N-1) -> zNN    (final sum)","- *   xNN AND yNN -> aNN       (generate)","- *   tNN AND c(N-1) -> bNN    (propagate)","- *   aNN OR bNN -> cNN        (carry out)","- *","- * Last bit: ca