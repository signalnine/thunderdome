+describe('findSwappedWires', () => {
+  /**
+   * Helper to build a correct N-bit ripple-carry adder.
+   */
+  function buildAdder(bits: number): Gate[] {
+    const gates: Gate[] = [];
+    for (let i = 0; i < bits; i++) {
+      const xi = `x${i.toString().padStart(2, '0')}`;
+      const yi = `y${i.toString().padStart(2, '0')}`;
+      const zi = `z${i.toString().padStart(2, '0')}`;
+      if (i === 0) {
+        gates.push({ op: 'XOR', in1: xi, in2: yi, out: zi });
+        gates.push({ op: 'AND', in1: xi, in2: yi, out: `c${i.toString().padStart(2, '0')}` });
+      } else {
+        const carry = `c${(i - 1).toString().padStart(2, '0')}`;
+        const t = `t${i.toString().padStart(2, '0')}`;
+        const a = `a${i.toString().padStart(2, '0')}`;
+        const b = `b${i.toString().padStart(2, '0')}`;
+        const c = `c${i.toString().padStart(2, '0')}`;
+        gates.push({ op: 'XOR', in1: xi, in2: yi, out: t });
+        gates.push({ op: 'XOR', in1: t, in2: carry, out: zi });
+        gates.push({ op: 'AND', in1: xi, in2: yi, out: a });
+        gates.push({ op: 'AND', in1: t, in2: carry, out: b });
+        gates.push({ op: 'OR', in1: a, in2: b, out: c });
+      }
+    }
+    // Final carry -> MSB output
+    const lastCarry = `c${(bits - 1).toString().padStart(2, '0')}`;
+    const zMSB = `z${bits.toString().padStart(2, '0')}`;
+    // The final carry needs to be connected. In the spec example, "c03 -> z04".
+    // We model this as an OR gate with carry OR carry (identity through OR with self).
+    // Actually, let's use XOR with 0 or just check: the spec says carry is directly z.
+    // For the purpose of findSwappedWires, the last carry's output IS the z-bit.
+    // We need to rename the last carry gate's output to zMSB.
+    // Find the gate that outputs lastCarry and rename it.
+    const lastGate = gates.find(g => g.out === lastCarry);
+    if (lastGate) {
+      lastGate.out = zMSB;
+    }
+    return gates;
+  }
+
+  function swapOutputs(gates: Gate[], wire1: string, wire2: string): void {
+    const g1 = gates.find(g => g.out === wire1)!;
+    const g2 = gates.find(g => g.out === wire2)!;
+    g1.out = wire2;
+    g2.out = wire1;
+  }
+
+  function shuffleGates(gates: Gate[]): Gate[] {
+    // Fisher-Yates shuffle
+    const arr = [...gates];
+    for (let i = arr.length - 1; i > 0; i--) {
+      const j = Math.floor(Math.random() * (i + 1));
+      [arr[i], arr[j]] = [arr[j], arr[i]];
+    }
+    return arr;
+  }
+
+  it('should find 4 pairs of swapped wires in a small adder', () => {
+    const gates = buildAdder(8);
+    // Swap 4 pairs
+    swapOutputs(gates, 'z01', 'a01');
+    swapOutputs(gates, 'z03', 't03');
+    swapOutputs(gates, 'c04', 'b05');
+    swapOutputs(gates, 'z07', 'a07');
+
+    const result = findSwappedWires(shuffleGates(gates));
+    expect(result).toEqual(['a01', 'a07', 'b05', 'c04', 't03', 'z01', 'z03', 'z07']);
+  });
+
+  it('should find swapped wires in a larger adder', () => {
+    const gates = buildAdder(20);
+    swapOutputs(gates, 'z05', 't05');
+    swapOutputs(gates, 'a10', 'z10');
+    swapOutputs(gates, 'b15', 'c15');
+    swapOutputs(gates, 'z19', 'a19');
+
+    const result = findSwappedWires(shuffleGates(gates));
+    expect(result).toEqual(['a10', 'a19', 'b15', 'c15', 't05', 'z05', 'z10', 'z19']);
+  });
+
+  it('should handle a 45-bit adder within time limit', () => {
+    const gates = buildAdder(45);
+    swapOutputs(gates, 'z02', 't02');
+    swapOutputs(gates, 'z15', 'a15');
+    swapOutputs(gates, 'b30', 'c30');
+    swapOutputs(gates, 'z44', 'a44');
+
+    const start = Date.now();
+    const result = findSwappedWires(shuffleGates(gates));
+    const elapsed = Date.now() - start;
+
+    expect(result).toEqual(['a15', 'a44', 'b30', 'c30', 't02', 'z02', 'z15', 'z44']);
+    expect(elapsed).toBeLessThan(5000);
+  });
+
+  it('should find swaps involving the carry chain', () => {
+    const gates = buildAdder(10);
+    // Swap carry outputs
+    swapOutputs(gates, 'c01', 'a02');
+    swapOutputs(gates, 'c05', 'b06');
+    swapOutputs(gates, 'z08', 'a08');
+    swapOutputs(gates, 'z03', 't03');
+
+    const result = findSwappedWires(shuffleGates(gates));
+    expect(result).toEqual(['a02', 'a08', 'b06', 'c01', 'c05', 't03', 'z03', 'z08']);
+  });
+
+  it('should work with randomized wire names', () => {
+    // Build adder with random internal wire names
+    const bits = 10;
+    const gates: Gate[] = [];
+    let counter = 0;
+    const randName = () => `w${(counter++).toString().padStart(3, '0')}`;
+
+    const carries: string[] = [];
+    const internalWires: string[] = [];
+
+    for (let i = 0; i < bits; i++) {
+      const xi = `x${i.toString().padStart(2, '0')}`;
+      const yi = `y${i.toString().padStart(2, '0')}`;
+      const zi = `z${i.toString().padStart(2, '0')}`;
+      if (i === 0) {
+        gates.push({ op: 'XOR', in1: xi, in2: yi, out: zi });
+        const cName = randName();
+        gates.push({ op: 'AND', in1: xi, in2: yi, out: cName });
+        carries.push(cName);
+      } else {
+        const t = randName();
+        const a = randName();
+        const b = randName();
+        const c = i < bits - 1 ? randName() : `z${bits.toString().padStart(2, '0')}`;
+
+        gates.push({ op: 'XOR', in1: xi, in2: yi, out: t });
+        gates.push({ op: 'XOR', in1: t, in2: carries[i - 1], out: zi });
+        gates.push({ op: 'AND', in1: xi, in2: yi, out: a });
+        gates.push({ op: 'AND', in1: t, in2: carries[i - 1], out: b });
+        gates.push({ op: 'OR', in1: a, in2: b, out: c });
+
+        carries.push(c);
+        internalWires.push(t, a, b);
+      }
+    }
+
+    // Now swap 4 pairs of outputs
+    // Swap z01 <-> one of the internal wires
+    const z01Gate = gates.find(g => g.out === 'z01')!;
+    const w001Gate = gates.find(g => g.out === 'w001')!;
+    // swap them
+    z01Gate.out = 'w001';
+    w001Gate.out = 'z01';
+
+    const z03Gate = gates.find(g => g.out === 'z03')!;
+    const w005Gate = gates.find(g => g.out === 'w005')!;
+    z03Gate.out = 'w005';
+    w005Gate.out = 'z03';
+
+    const z05Gate = gates.find(g => g.out === 'z05')!;
+    const w010Gate = gates.find(g => g.out === 'w010')!;
+    z05Gate.out = 'w010';
+    w010Gate.out = 'z05';
+
+    const z07Gate = gates.find(g => g.out === 'z07')!;
+    const w015Gate = gates.find(g => g.out === 'w015')!;
+    z07Gate.out = 'w015';
+    w015Gate.out = 'z07';
+
+    const result = findSwappedWires(shuffleGates(gates));
+    expect(result).toHaveLength(8);
+    expect(result).toEqual(
+      ['w001', 'w005', 'w010', 'w015', 'z01', 'z03', 'z05', 'z07'].sort(),
+    );
+  });
+});
