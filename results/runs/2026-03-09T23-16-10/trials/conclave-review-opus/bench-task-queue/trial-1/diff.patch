n  } else {\n    const value = parseInt(hourStr, 10);\n    if (isNaN(value) || value < 0 || value > 23) {\n      throw new Error(`Invalid cron hour value: \"${hourStr}\"`);\n    }\n    hour = { type: 'exact', value };\n  }\n\n  return { minute, hour };\n}\n\nexport function shouldRunAt(cron: CronParts, date: Date): boolean {\n  const m = date.getMinutes();\n  const h = date.getHours();\n\n  // Check minute\n  if (cron.minute.type === 'exact' && cron.minute.value !== m) return false;\n  if (cron.minute.type === 'every' && m % cron.minute.interval !== 0) return false;\n\n  // Check hour\n  if (cron.hour.type === 'exact' && cron.hour.value !== h) return false;\n\n  return true;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":571,"cache_read_input_tokens":23753,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":571},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"5e1a8bde-1de8-4fa9-b2ee-2ad7ee761c40","uuid":"3af3fb8e-deeb-42db-8f3c-cb2728f73550"}
