264→      }\n   265→    }\n   266→    throw new Error(`Task not found in dead letter queue: ${taskId}`);\n   267→  }\n   268→\n   269→  clearDeadLetterQueue(queueName: string = DEFAULT_QUEUE): void {\n   270→    // Remove the tasks from the main tasks map as well\n   271→    const dlq = this.deadLetterQueues.get(queueName);\n   272→    if (dlq) {\n   273→      for (const task of dlq) {\n   274→        this.tasks.delete(task.id);\n   275→      }\n   276→    }\n   277→    this.deadLetterQueues.set(queueName, []);\n   278→  }\n   279→\n   280→  // ---- Phase 7: Task Dependencies ----\n   281→\n   282→  private detectCircularDependency(taskId: string, dependencies: string[]): void {\n   283→    // BFS/DFS from each dependency to see if any path leads back to taskId\n   284→    const visited = new Set<string>();\n   285→    const stack = [...dependencies];\n   286→\n   287→    while (stack.length > 0) {\n   288→      const current = stack.pop()!;\n   289→      if (current === taskId) {\n   290→        throw new Error(`Circular dependency detected involving task ${taskId}`);\n   291→      }\n   292→      if (visited.has(current)) continue;\n   293→      visited.add(current);\n   294→\n   295→      const currentTask = this.tasks.get(current);\n   296→      if (currentTask) {\n   297→        // Check dependents: tasks whose dependencies include `current`\n   298→        // Actually, we need to check the dependency chain the other way:\n   299→        // We need to ensure that none of the tasks that `taskId` depends on\n   300→        // (transitively) depend on `taskId`.\n   301→        // But `taskId` doesn't exist yet as a dependency.\n   302→        // The real check: does any of the dependency tasks depend (transitively) on taskId?\n   303→        // Since taskId is new and not yet stored, no existing task can depend on it.\n   304→        // However, the new task's dependencies form a chain. We need to check\n   305→        // that the dependency graph formed by existing tasks' `.dependencies` arrays\n   306→        // doesn't create a cycle when we add this new edge.\n   307→        // Actually, since the new task doesn't exist yet in anyone's deps, no cycle is possible.\n   308→        // But consider: A depends on B, now adding C that depends on A.\n   309→        // Then later adding D that depends on C. No cycle.\n   310→        // The only cycle possibility: A depends on B, B depends on A.\n   311→        // This is caught because when we add A with dep B, we check B's deps recursively.\n   312→        // B's deps include A but A doesn't exist yet... unless A was already added.\n   313→        // So we need to traverse the deps of the dependency tasks.\n   314→        for (const depId of currentTask.dependencies) {\n   315→          if (!visited.has(depId)) {\n   316→            stack.push(depId);\n   317→          }\n   318→        }\n   319→      }\n   320→    }\n   321→  }\n   322→\n   323→  getDependencyStatus(taskId: string): { taskId: string; resolved: boolean; dependencyStatuses: Array<{ id: string; status: TaskStatus }> } {\n   324→    const task = this.tasks.get(taskId);\n   325→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   326→\n   327→    const dependencyStatuses = task.dependencies.map(depId => {\n   328→      const dep = this.tasks.get(depId);\n   329→      return {\n   330→        id: depId,\n   331→        status: dep ? dep.status : ('unknown' as TaskStatus),\n   332→      };\n   333→    });\n   334→\n   335→    const resolved = task.dependencies.every(depId => {\n   336→      const dep = this.tasks.get(depId);\n   337→      return dep && dep.status === 'completed';\n   338→    });\n   339→\n   340→    return { taskId, resolved, dependencyStatuses };\n   341→  }\n   342→\n   343→  // ---- Phase 8: Concurrency Control ----\n   344→\n   345→  setConcurrency(queueName: string, limit: number): void {\n   346→    this.ensureQueue(queueName);\n   347→    const state = this.queues.get(queueName)!;\n   348→    state.concurrencyLimit = limit;\n   349→  }\n   350→\n   351→  getConcurrency(queueName: string = DEFAULT_QUEUE): { limit: number; active: number } {\n   352→    const state = this.queues.get(queueName);\n   353→    if (!state) return { limit: 0, active: 0 };\n   354→    return { limit: state.concurrencyLimit, active: state.activeCount };\n   355→  }\n   356→\n   357→  // ---- Phase 9: Progress Tracking and Cancellation ----\n   358→\n   359→  updateProgress(taskId: string, progress: number, message?: string): void {\n   360→    const task = this.tasks.get(taskId);\n   361→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   362→    if (task.status !== 'processing') {\n   363→      throw new Error(`Cannot update progress for task in status \"${task.status}\".`);\n   364→    }\n   365→    if (progress < 0 || progress > 100) {\n   366→      throw new Error(`Progress must be between 0 and 100. Got: ${progress}`);\n   367→    }\n   368→\n   369→    task.progress = progress;\n   370→    task.progressMessage = message;\n   371→\n   372→    // Notify listeners\n   373→    const listeners = this.progressListeners.get(taskId);\n   374→    if (listeners) {\n   375→      const update: ProgressUpdate = { taskId, progress, message };\n   376→      for (const listener of listeners) {\n   377→        listener(update);\n   378→      }\n   379→    }\n   380→  }\n   381→\n   382→  getProgress(taskId: string): { progress: number; message?: string } {\n   383→    const task = this.tasks.get(taskId);\n   384→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   385→    return { progress: task.progress, message: task.progressMessage };\n   386→  }\n   387→\n   388→  onProgress(taskId: string, listener: ProgressListener): () => void {\n   389→    if (!this.progressListeners.has(taskId)) {\n   390→      this.progressListeners.set(taskId, new Set());\n   391→    }\n   392→    this.progressListeners.get(taskId)!.add(listener);\n   393→\n   394→    // Retur