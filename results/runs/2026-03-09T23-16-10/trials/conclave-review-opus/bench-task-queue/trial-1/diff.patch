+      const result = await queue.shutdown(50); // very short timeout
+      expect(result.forceCancelled).toBe(1);
+      expect(queue.getTask(task.id)?.status).toBe('cancelled');
+    });
+
+    it('should run shutdown callbacks', async () => {
+      let callbackRan = false;
+      queue.onShutdown(() => { callbackRan = true; });
+
+      await queue.shutdown();
+      expect(callbackRan).toBe(true);
+    });
+
+    it('should be safe to call shutdown multiple times', async () => {
+      const result1 = await queue.shutdown();
+      const result2 = await queue.shutdown();
+      expect(result1).toBe(result2);
+    });
+
+    it('should report shutdown duration', async () => {
+      const result = await queue.shutdown();
+      expect(typeof result.durationMs).toBe('number');
+      expect(result.durationMs).toBeGreaterThanOrEqual(0);
+    });
+  });
+});
