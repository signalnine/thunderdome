ddTask({ payload: 'b' });\n   447→      queue.addTask({ payload: 'c' });\n   448→\n   449→      const t1 = queue.getNextTask();\n   450→      const t2 = queue.getNextTask();\n   451→      expect(t1).not.toBeNull();\n   452→      expect(t2).not.toBeNull();\n   453→\n   454→      // Third should be blocked\n   455→      expect(queue.getNextTask()).toBeNull();\n   456→\n   457→      // Complete one, third should be available\n   458→      queue.completeTask(t1!.id);\n   459→      const t3 = queue.getNextTask();\n   460→      expect(t3).not.toBeNull();\n   461→    });\n   462→\n   463→    it('should free slot on task failure', () => {\n   464→      queue.setConcurrency('default', 1);\n   465→      queue.addTask({ payload: 'a', maxRetries: 1, backoffDelay: 0 });\n   466→      queue.addTask({ payload: 'b' });\n   467→\n   468→      const t1 = queue.getNextTask()!;\n   469→      expect(queue.getNextTask()).toBeNull(); // limited to 1\n   470→\n   471→      queue.failTask(t1.id, 'fail'); // frees a slot (task goes to DLQ since maxRetries=1)\n   472→      const t2 = queue.getNextTask();\n   473→      expect(t2?.payload).toBe('b');\n   474→    });\n   475→\n   476→    it('should query concurrency state', () => {\n   477→      queue.setConcurrency('default', 3);\n   478→      queue.addTask({ payload: 'a' });\n   479→      queue.addTask({ payload: 'b' });\n   480→\n   481→      queue.getNextTask();\n   482→\n   483→      const state = queue.getConcurrency('default');\n   484→      expect(state.limit).toBe(3);\n   485→      expect(state.active).toBe(1);\n   486→    });\n   487→\n   488→    it('should still respect priority with concurrency', () => {\n   489→      queue.setConcurrency('default', 1);\n   490→      queue.addTask({ payload: 'low', priority: 10 });\n   491→      queue.addTask({ payload: 'high', priority: 1 });\n   492→\n   493→      const task = queue.getNextTask();\n   494→      expect(task?.payload).toBe('high');\n   495→    });\n   496→  });\n   497→\n   498→  // ---- Phase 9: Progress Tracking and Cancellation ----\n   499→  describe('Phase 9: Progress Tracking and Cancellation', () => {\n   500→    it('should update and query progress', () => {\n   501→      const task = queue.addTask({ payload: 'test' });\n   502→      queue.getNextTask();\n   503→\n   504→      queue.updateProgress(task.id, 50, 'halfway');\n   505→      const progress = queue.getProgress(task.id);\n   506→      expect(progress.progress).toBe(50);\n   507→      expect(progress.message).toBe('halfway');\n   508→    });\n   509→\n   510→    it('should reject invalid progress values', () => {\n   511→      const task = queue.addTask({ payload: 'test' });\n   512→      queue.getNextTask();\n   513→      expect(() => queue.updateProgress(task.id, -1)).toThrow();\n   514→      expect(() => queue.updateProgress(task.id, 101)).toThrow();\n   515→    });\n   516→\n   517→    it('should notify progress listeners', () => {\n   518→      const task = queue.addTask({ payload: 'test' });\n   519→      queue.getNextTask();\n   520→\n   521→      const updates: Array<{ progress: number; message?: string }> = [];\n   522→      queue.onProgress(task.id, (update) => {\n   523→        updates.push({ progress: update.progress, message: update.message });\n   524→      });\n   525→\n   526→      queue.updateProgress(task.id, 25, 'quarter');\n   527→      queue.updateProgress(task.id, 75, 'three quarters');\n   528→\n   529→      expect(updates).toHaveLength(2);\n   530→      expect(updates[0].progress).toBe(25);\n   531→      expect(updates[1].progress).toBe(75);\n   532→    });\n   533→\n   534→    it('should support unsubscribing from progress', () => {\n   535→      const task = queue.addTask({ payload: 'test' });\n   536→      queue.getNextTask();\n   537→\n   538→      const updates: number[] = [];\n   539→      const unsub = queue.onProgress(task.id, (u) => updates.push(u.progress));\n   540→\n   541→      queue.updateProgress(task.id, 25);\n   542→      unsub();\n   543→      queue.updateProgress(task.id, 50);\n   544→\n   545→      expect(updates).toHaveLength(1);\n   546→      expect(updates[0]).toBe(25);\n   547→    });\n   548→\n   549→    it('should cancel a pending task', () => {\n   550→      const task = queue.addTask({ payload: 'test' });\n   551→      queue.cancelTask(task.id);\n   552→\n   553→      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n   554→      expect(queue.getNextTask()).toBeNull(); // not available\n   555→    });\n   556→\n   557→    it('should cancel a processing task', () => {\n   558→      const task = queue.addTask({ payload: 'test' });\n   559→      queue.getNextTask();\n   560→      queue.cancelTask(task.id);\n   561→      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n   562→    });\n   563→\n   564→    it('should not cancel completed or failed tasks', () => {\n   565→      const task = queue.addTask({ payload: 'test' });\n   566→      queue.getNextTask();\n   567→      queue.completeTask(task.id);\n   568→      expect(() => queue.cancelTask(task.id)).toThrow();\n   569→    });\n   570→\n   571→    it('should not retry cancelled tasks', () => {\n   572→      const task = queue.addTask({ payload: 'test', maxRetries: 3 });\n   573→      queue.getNextTask();\n   574→      queue.cancelTask(task.id);\n   575→\n   576→      // Task should be cancelled, not pending for retry\n   577→      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n   578→    });\n   579→\n   580→    it('should free concurrency slot when cancelling processing task', () => {\n   581→      queue.setConcurrency('default', 1);\n   582→      queue.addTask({ payload: 'a' });\n   583→      queue.addTask({ payload: 'b' });\n   584→\n   585→      const t1 = queue.getNextTask()!;\n   586→      expect(queue.getNextTask()).toBeNull();\n   587→\n   588→      queue.cancelTask(t1.id);\n   589→      const t2 = queue.getNextTask();\n   590→      expect(t2?.payload).toBe('b');\n   591→    });\n   592→  });\n   593→\n   594→  // ---- Phase 10: Recurring Tasks ----\n   595→  describe('Phase 10: Recurring Tasks', () => {\n   596→    it('should create a schedule', () => {\n   597→      const schedule = queue.addSchedule({\n   598→        cronExpression: '*/5 * * * *',\n   599→        taskTemplate: { type: 'cleanup' },\n   600→      });\n   601→      expect(schedule.id).toBeDefined();\n   602→      expect(schedule.cronExpression).toBe('*/5 * * * *');\n   603→    });\n   604→\n   605→    it('should list active schedules', () => {\n   606→      queue.addSchedule({ cronExpression: '*/5 * * * *', taskTemplate: {} });\n   607→      queue.addSchedule({ cronExpression: '0 * * * *', taskTemplate: {} });\n   608→      expect(queue.getSchedules()).toHaveLength(2);\n   609→    });\n   610→\n   611→    it('should remove a schedule', () => {\n   612→      const schedule = queue.addSchedule({ cronExpression: '*/5 * * * *', taskTemplate: {} });\n   613→      queue.removeSchedule(schedule.id);\n   614→      expect(queue.getSchedules()).toHaveLength(0);\n   615→    });\n   616→\n   617→    it('should enqueue tasks on tick when due', () => {\n   618→      queue.addSchedule({\n   619→        cronExpression: '*/5 * * * *',\n   620→        taskTemplate: { type: 'recurring' },\n   621→      });\n   622→\n   623→      // Tick at minute 10 (divisible by 5)\n   624→      const date = new Date(2024, 0, 1, 12, 10, 0, 0);\n   625→      const tasks = queue.tick(date);\n   626→      expect(tasks).toHaveLength(1);\n   627→      expect(tasks[0].payload).toEqual({ type: 'recurring' });\n   628→    });\n   629→\n   630→    it('should not enqueue tasks when not due', () => {\n   631→      queue.addSchedule({\n   632→        cronExpression: '*/5 * * * *',\n   633→        taskTemplate: {},\n   634→      });\n   635→\n   636→      // Tick at minute 3 (not divisible by 5)\n   637→      const date = new Date(2024, 0, 1, 12, 3, 0, 0);\n   638→      const tasks = queue.tick(date);\n   639→      expect(tasks).toHaveLength(0);\n   640→    });\n   641→\n   642→    it('should not double-fire for the same minute', () => {\n   643→      queue.addSchedule({\n   644→        cronExpression: '*/5 * * * *',\n   645→        taskTemplate: {},\n   646→      });\n   647→\n   648→      const date = new Date(2024, 0, 1, 12, 10, 0, 0);\n   649→      queue.tick(date);\n   650→      const tasks2 = queue.tick(new Date(2024, 0, 1, 12, 10, 30, 0)); // 30 seconds later, same minute\n   651→      expect(tasks2).toHaveLength(0);\n   652→    });\n   653→\n   654→    it('should support hourly schedules', () => {\n   655→      queue.addSchedule({\n   656→        cronExpression: '0 * * * *',\n   657→        taskTemplate: { type: 'hourly' },\n   658→      });\n   659→\n   660→      // Minute 0 of any hour\n   661→      const tasks = queue.tick(new Date(2024, 0, 1, 14, 0, 0, 0));\n   662→      expect(tasks).toHaveLength(1);\n   663→\n   664→      // Minute 15 of the hour\n   665→      const tasks2 = queue.tick(new Date(2024, 0, 1, 14, 15, 0, 0));\n   666→      expect(tasks2).toHaveLength(0);\n   667→    });\n   668→\n   669→    it('should support daily midnight schedules', () => {\n   670→      queue.addSchedule({\n   671→        cronExpression: '0 0 * * *',\n   672→        taskTemplate: { type: 'daily' },\n   673→      });\n   674→\n   675→      const tasks = queue.tick(new Date(2024, 0, 1, 0, 0, 0, 0));\n   676→      expect(tasks).toHaveLength(1);\n   677→\n   678→      const tasks2 = queue.tick(new Date(2024, 0, 1, 12, 0, 0, 0));\n   679→      expect(tasks2).toHaveLength(0);\n   680→    });\n   681→\n   682→    it('should reject invalid cron expressions', () => {\n   683→      expect(() => queue.addSchedule({ cronExpression: 'invalid', taskTemplate: {} })).toThrow();\n   684→    });\n   685→\n   686→    it('recurring tasks are subject to queue rules', () => {\n   687→      queue.addSchedule({\n   688→        cronExpression: '*/5 * * * *',\n   689→        taskTemplate: { type: 'recurring' },\n   690→        queue