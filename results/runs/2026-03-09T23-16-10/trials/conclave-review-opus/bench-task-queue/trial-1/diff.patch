rocessing when retrieved', () => {\n      queue.addTask({ payload: 'test' });\n      const task = queue.getNextTask();\n      expect(task?.status).toBe('processing');\n    });\n\n    it('should return null when no tasks available', () => {\n      const task = queue.getNextTask();\n      expect(task).toBeNull();\n    });\n\n    it('should track pending count', () => {\n      expect(queue.pendingCount()).toBe(0);\n      queue.addTask({ payload: 'a' });\n      queue.addTask({ payload: 'b' });\n      expect(queue.pendingCount()).toBe(2);\n      queue.getNextTask();\n      expect(queue.pendingCount()).toBe(1);\n    });\n\n    it('should not return processing tasks again', () => {\n      queue.addTask({ payload: 'only' });\n      queue.getNextTask(); // moves to processing\n      expect(queue.getNextTask()).toBeNull();\n    });\n  });\n\n  // ---- Phase 2: Named Queues ----\n  describe('Phase 2: Named Queues', () => {\n    it('should support named queues', () => {\n      queue.addTask({ payload: 'email', queue: 'emails' });\n      queue.addTask({ payload: 'sms', queue: 'sms' });\n\n      const email = queue.getNextTask('emails');\n      expect(email?.payload).toBe('email');\n\n      const sms = queue.getNextTask('sms');\n      expect(sms?.payload).toBe('sms');\n    });\n\n    it('should use default queue when no name given', () => {\n      queue.addTask({ payload: 'default' });\n      const task = queue.getNextTask();\n      expect(task?.payload).toBe('default');\n      expect(task?.queue).toBe('default');\n    });\n\n    it('should operate queues independently', () => {\n      queue.addTask({ payload: 'a', queue: 'q1' });\n      queue.addTask({ payload: 'b', queue: 'q2' });\n\n      expect(queue.pendingCount('q1')).toBe(1);\n      expect(queue.pendingCount('q2')).toBe(1);\n\n      queue.getNextTask('q1');\n      expect(queue.pendingCount('q1')).toBe(0);\n      expect(queue.pendingCount('q2')).toBe(1);\n    });\n\n    it('should list all queue names', () => {\n      queue.addTask({ payload: 'a', queue: 'q1' });\n      queue.addTask({ payload: 'b', queue: 'q2' });\n      const names = queue.getQueueNames();\n      expect(names).toContain('q1');\n      expect(names).toContain('q2');\n    });\n\n    it('should return null from nonexistent queue', () => {\n      expect(queue.getNextTask('nonexistent')).toBeNull();\n    });\n\n    it('should return null from empty queue', () => {\n      queue.addTask({ payload: 'a', queue: 'q1' });\n      queue.getNextTask('q1');\n      expect(queue.getNextTask('q1')).toBeNull();\n    });\n  });\n\n  // ---- Phase 3: Priority ----\n  describe('Phase 3: Priority', () => {\n    it('should default to priority 5', () => {\n      const task = queue.addTask({ payload: 'default' });\n      expect(task.priority).toBe(5);\n    });\n\n    it('should return higher priority tasks first', () => {\n      queue.addTask({ payload: 'low', priority: 10 });\n      queue.addTask({ payload: 'high', priority: 1 });\n      queue.addTask({ payload: 'medium', priority: 5 });\n\n      expect(queue.getNextTask()?.payload).toBe('high');\n      expect(queue.getNextTask()?.payload).toBe('medium');\n      expect(queue.getNextTask()?.payload).toBe('low');\n    });\n\n    it('should maintain FIFO order within same priority', () => {\n      queue.addTask({ payload: 'first', priority: 3 });\n      queue.addTask({ payload: 'second', priority: 3 });\n      queue.addTask({ payload: 'third', priority: 3 });\n\n      expect(queue.getNextTask()?.payload).toBe('first');\n      expect(queue.getNextTask()?.payload).toBe('second');\n      expect(queue.getNextTask()?.payload).toBe('third');\n    });\n\n    it('should reject invalid priority values', () => {\n      expect(() => queue.addTask({ payload: 'a', priority: 0 })).toThrow();\n      expect(() => queue.addTask({ payload: 'a', priority: 11 })).toThrow();\n      expect(() => queue.addTask({ payload: 'a', priority: -1 })).toThrow();\n      expect(() => queue.addTask({ payload: 'a', priority: 1.5 