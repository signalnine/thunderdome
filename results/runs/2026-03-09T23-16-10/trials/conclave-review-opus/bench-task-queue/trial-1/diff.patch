e.id, schedule);\n   450→    return schedule;\n   451→  }\n   452→\n   453→  removeSchedule(scheduleId: string): boolean {\n   454→    return this.schedules.delete(scheduleId);\n   455→  }\n   456→\n   457→  getSchedules(): CronSchedule[] {\n   458→    return Array.from(this.schedules.values());\n   459→  }\n   460→\n   461→  tick(now: Date = new Date()): Task[] {\n   462→    const created: Task[] = [];\n   463→\n   464→    for (const schedule of this.schedules.values()) {\n   465→      const cron = parseCron(schedule.cronExpression);\n   466→\n   467→      // Round the check time to the current minute\n   468→      const checkTime = new Date(now);\n   469→      checkTime.setSeconds(0, 0);\n   470→\n   471→      if (shouldRunAt(cron, checkTime)) {\n   472→        // Check if we already ran for this minute\n   473→        if (schedule.lastRun) {\n   474→          const lastRunMinute = new Date(schedule.lastRun);\n   475→          lastRunMinute.setSeconds(0, 0);\n   476→          if (lastRunMinute.getTime() === checkTime.getTime()) {\n   477→            continue; // Already ran for this minute\n   478→          }\n   479→        }\n   480→\n   481→        schedule.lastRun = now;\n   482→        const task = this.addTask({\n   483→          payload: schedule.taskTemplate,\n   484→          queue: schedule.queue,\n   485→          priority: schedule.priority,\n   486→        });\n   487→        created.push(task);\n   488→      }\n   489→    }\n   490→\n   491→    return created;\n   492→  }\n   493→\n   494→  // ---- Phase 11: Middleware Pipeline ----\n   495→\n   496→  use(queueName: string, middleware: MiddlewareFn): void {\n   497→    this.ensureQueue(queueName);\n   498→    this.queues.get(queueName)!.middleware.push(middleware);\n   499→  }\n   500→\n   501→  setHandler(queueName: string, handler: HandlerFn): void {\n   502→    this.ensureQueue(queueName);\n   503→    this.queues.get(queueName)!.handler = handler;\n   504→  }\n   505→\n   506→  async processTask(taskId: string): Promise<void> {\n   507→    const task = this.tasks.get(taskId);\n   508→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   509→    if (task.status !== 'processing') {\n   510→      throw new Error(`Cannot process task in status \"${task.status}\". Must be \"processing\".`);\n   511→    }\n   512→\n   513→    const queueState = this.queues.get(task.queue);\n   514→    if (!queueState) {\n   515→      throw new Error(`Queue not found: ${task.queue}`);\n   516→    }\n   517→\n   518→    const middleware = [...queueState.middleware];\n   519→    const handler = queueState.handler;\n   520→\n   521→    let index = 0;\n   522→\n   523→    const executeNext = async (): Promise<void> => {\n   524→      if (index < middleware.length) {\n   525→        const mw = middleware[index++];\n   526→        await mw(task, async () => {\n   527→          await executeNext();\n   528→        });\n   529→        // If middleware didn't call next, pipeline stops\n   530→      } else if (handler) {\n   531→        await handler(task);\n   532→      }\n   533→    };\n   534→\n   535→    try {\n   536→      await executeNext();\n   537→    } catch (error) {\n   538→      const errorMsg = error instanceof Error ? error.message : String(error);\n   539→      this.failTask(taskId, errorMsg);\n   540→      throw error;\n   541→    }\n   542→  }\n   543→\n   544→  // ---- Phase 12: Graceful Shutdown ----\n   545→\n   546→  onShutdown(callback: () => void | Promise<void>): void {\n   547→    this.shutdownCallbacks.push(callback);\n   548→  }\n   549→\n   550→  async shutdown(timeoutMs: number = 30000): Promise<ShutdownResult> {\n   551→    if (this.shutdownPromise) {\n   552→      return this.shutdownPromise;\n   553→    }\n   554→\n   555→    this.isShuttingDown = true;\n   556→    this.shutdownPromise = this.performShutdown(timeoutMs);\n   557→    return this.shutdownPromise;\n   558→  }\n   559→\n   560→  private async performShutdown(timeoutMs: number): Promise<