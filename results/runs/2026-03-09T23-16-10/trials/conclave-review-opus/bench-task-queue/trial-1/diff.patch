+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012sdDhtCie2MZgNLeTPyjsW","type":"tool_result","content":"     1→import { randomUUID } from 'node:crypto';\n     2→import {\n     3→  Task,\n     4→  TaskStatus,\n     5→  AddTaskOptions,\n     6→  ProgressUpdate,\n     7→  ProgressListener,\n     8→  MiddlewareFn,\n     9→  HandlerFn,\n    10→  CronSchedule,\n    11→  ShutdownResult,\n    12→  DEFAULT_QUEUE,\n    13→  DEFAULT_PRIORITY,\n    14→  DEFAULT_MAX_RETRIES,\n    15→  DEFAULT_BACKOFF_DELAY,\n    16→} from './types.js';\n    17→import { parseCron, shouldRunAt } from './cron.js';\n    18→\n    19→interface QueueState {\n    20→  concurrencyLimit: number; // 0 = unlimited\n    21→  activeCount: number;\n    22→  middleware: MiddlewareFn[];\n    23→  handler?: HandlerFn;\n    24→}\n    25→\n    26→export class TaskQueue {\n    27→  private tasks: Map<string, Task> = new Map();\n    28→  private queues: Map<string, QueueState> = new Map();\n    29→  private deadLetterQueues: Map<string, Task[]> = new Map();\n    30→  private progressListeners: Map<string, Set<ProgressListener>> = new Map();\n    31→  private schedules: Map<string, CronSchedule> = new Map();\n    32→  private shutdownCallbacks: Array<() => void | Promise<void>> = [];\n    33→  private isShuttingDown = false;\n    34→  private shutdownPromise: Promise<ShutdownResult> | null = null;\n    35→\n    36→  // ---- Phase 1: Basic FIFO Queue ----\n    37→\n    38→  addTask<T = unknown>(options: AddTaskOptions<T>): Task<T> {\n    39→    if (this.isShuttingDown) {\n    40→      throw new Error('Cannot add tasks: the queue system is shutting down.');\n    41→    }\n    42→\n    43→    const queueName = options.queue ?? DEFAULT_QUEUE;\n    44→    const priority = options.priority ?? DEFAULT_PRIORITY;\n    45→\n    46→    // Phase 3: validate priority\n    47→    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n    48→      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    49→    }\n    50→\n    51→    // Phase 7: validate dependencies\n    52→    const dependencies = options.dependencies ?? [];\n    53→    for (const depId of dependencies) {\n    54→      const depTask = this.tasks.get(depId);\n    55→      if (!depTask) {\n    56→        throw new Error(`Dependency task not found: ${depId}`);\n    57→      }\n    58→    }\n    59→\n    60→    // Circular dependency detection\n    61→    if (dependencies.length > 0) {\n    62→      // This task doesn't have an ID yet; we'll check after creating it\n    63→    }\n    64→\n    65→    const now = new Date();\n    66→    let availableAt: Date;\n    67→    if (options.availableAt) {\n    68→      availableAt = options.availableAt;\n    69→    } else if (options.delay != null && options.delay > 0) {\n    70→      availableAt = new Date(now.getTime() + options.delay);\n    71→    } else {\n    72→      availableAt = now;\n    73→    }\n    74→\n    75→    const task: Task<T> = {\n    76→      id: randomUUID(),\n    77→      payload: options.payload,\n    78→      status: 'pending',\n    79→      queue: queueName,\n    80→      priority,\n    81→      createdAt: now,\n    82→      availableAt,\n    83→      attempts: 0,\n    84→      maxRetries: options.maxRetries ?? DEFAULT_MAX_RETRIES,\n    85→      backoffDelay: options.backoffDelay ?? DEFAULT_BACKOFF_DELAY,\n    86→      dependencies,\n    87→      progress: 0,\n    88→    };\n    89→\n    90→    // Circular dependency detection with the newly assigned ID\n    91→    if (dependencies.length > 0) {\n    92→      this.detectCircularDependency(task.id, dependencies);\n    93→    }\n    94→\n    95→    // Ensure queue exists\n    96→    this.ensureQueue(queueName);\n    97→\n    98→    this.tasks.set(task.id, task as Task);\n    99→    return task;\n   100→  }\n   101→\n   102→  getTask(taskId: string): Task | undefined {\n   103→    return this.tasks.get(taskId);\n   104→  }\n   105→\n   106→  getNextTask(queueName: string = DEFAULT_QUEUE): Task | null {\n   107→    const queueState = this.queues.get(queueName);\n   108→    if (!queueState) return null;\n   109→\n   110→    // Phase 8: check concurrency limit\n   111→    if (queueState.concurrencyLimit > 0 && queueState.activeCount >= queueState.concurrencyLimit) {\n   112→      return null;\n   113→    }\n   114→\n   115→    const now = new Date();\n   116→    const candidates: Task[] = [];\n   117→\n   118→    for (const task of this.tasks.values()) {\n   119→      if (task.queue !== queueName) continue;\n   120→      if (task.status !== 'pending') continue;\n   121→\n   122→      // Phase 4: skip tasks that aren't available yet\n   123→      if (task.availableAt > now) continue;\n   124→\n   125→      // Phase 7: skip tasks with unresolved dependencies\n   126→      if (task.dependencies.length > 0) {\n   127→        const allCompleted = task.dependencies.every(depId => {\n   128→          const dep = this.tasks.get(depId);\n   129→          return dep && dep.status === 'completed';\n   130→        });\n   131→        if (!allCompleted) continue;\n   132→      }\n   133→\n   134→      candidates.push(task);\n   135→    }\n   136→\n   137→    if (candidates.length === 0) return null;\n   138→\n   139→    // Sort: priority (ascending, lower = higher priority), then availableAt, then createdAt (FIFO)\n   140→    candidates.sort((a, b) => {\n   141→      if (a.priority !== b.priority) return a.priority - b.priority;\n   142→      const availDiff = a.availableAt.getTime() - b.availableAt.getTime();\n   143→      if (availDiff !== 0) return availDiff;\n   144→      return a.createdAt.getTime() - b.createdAt.getTime();\n   145→    });\n   146→\n   147→    const task = candidates[0];\n   148→    task.status = 'processing';\n   149→    task.attempts += 1;\n   150→    queueState.activeCount += 1;\n   151→\n   152→    return task;\n   153→  }\n   154→\n   155→  pendingCount(queueName: string = DEFAULT_QUEUE): number {\n   156→    let count = 0;\n   157→    for (const task of this.tasks.values()) {\n   158→      if (task.queue === queueName && task.status === 'pending') {\n   159→        count++;\n   160→      }\n   161→    }\n   162→    return count;\n   163→  }\n   164→\n   165→  // ---- Phase 2: Named Queues ----\n   166→\n   167→  private ensureQueue(name: string): void {\n   168→    if (!this.queues.has(name)) {\n   169→      this.queues.set(name, {\n   170→        concurrencyLimit: 0,\n   171→        activeCount: 0,\n   172→        middleware: [],\n   173→      });\n   174→    }\n   175→  }\n   176→\n   177→  getQueueNames(): string[] {\n   178→    return Array.from(this.queues.keys());\n   179→  }\n   180→\n   181→  // ---- Phase 5: Complete / Fail ----\n   182→\n   183→  completeTask(taskId: string): void {\n   184→    const task = this.tasks.get(taskId);\n   185→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   186→    if (task.status !== 'processing') {\n   187→      throw new Error(`Cannot complete task in status \"${task.status}\". Must be \"processing\".`);\n   188→    }\n   189→\n   190→    task.status = 'completed';\n   191→    task.completedAt = new Date();\n   192→    task.progress = 100;\n   193→\n   194→    const queueState = this.queues.get(task.queue);\n   195→    if (queueState) {\n   196→      queueState.activeCount = Math.max(0, queueState.activeCount - 1);\n   197→    }\n   198→\n   199→    // Phase 7: check if any blocked tasks are now unblocked (handled automatically in getNextTask)\n   200→  }\n   201→\n   202→  failTask(taskId: string, error?: string): void {\n   203→    const task = this.tasks.get(taskId);\n   204→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   205→    if (task.status !== 'processing') {\n   206→      throw new Error(`Cannot fail task in status \"${task.status}\". Must be \"processing\".`);\n   207→    }\n   208→\n   209→    const queueState = this.queues.get(task.queue);\n   210→    if (queueSt