   expect(handlerCalled).toBe(false);\n   743→    });\n   744→\n   745→    it('should allow middleware to modify task', async () => {\n   746→      queue.use('default', async (task, next) => {\n   747→        const existing = task.payload as Record<string, unknown>;\n   748→        task.payload = { ...existing, modified: true };\n   749→        await next();\n   750→      });\n   751→\n   752→      let receivedPayload: Record<string, unknown> | undefined;\n   753→      queue.setHandler('default', (task) => {\n   754→        receivedPayload = task.payload as Record<string, unknown>;\n   755→      });\n   756→\n   757→      const task = queue.addTask({ payload: { data: 'test' } });\n   758→      queue.getNextTask();\n   759→      await queue.processTask(task.id);\n   760→      expect(receivedPayload).toEqual({ data: 'test', modified: true });\n   761→    });\n   762→\n   763→    it('should fail task if middleware throws', async () => {\n   764→      queue.use('default', async () => {\n   765→        throw new Error('middleware error');\n   766→      });\n   767→\n   768→      const task = queue.addTask({ payload: 'test' });\n   769→      queue.getNextTask();\n   770→\n   771→      await expect(queue.processTask(task.id)).rejects.toThrow('middleware error');\n   772→      // Task should be failed (or in retry)\n   773→      const updated = queue.getTask(task.id)!;\n   774→      expect(updated.status === 'pending' || updated.status === 'failed').toBe(true);\n   775→    });\n   776→\n   777→    it('should have independent middleware per queue', async () => {\n   778→      const calls: string[] = [];\n   779→\n   780→      queue.use('q1', async (_task, next) => { calls.push('q1-mw'); await next(); });\n   781→      queue.use('q2', async (_task, next) => { calls.push('q2-mw'); await next(); });\n   782→      queue.setHandler('q1', () => { calls.push('q1-handler'); });\n   783→      queue.setHandler('q2', () => { calls.push('q2-handler'); });\n   784→\n   785→      const t1 = queue.addTask({ payload: 'a', queue: 'q1' });\n   786→      const t2 = queue.addTask({ payload: 'b', queue: 'q2' });\n   787→\n   788→      queue.getNextTask('q1');\n   789→      await queue.processTask(t1.id);\n   790→\n   791→      queue.getNextTask('q2');\n   792→      await queue.processTask(t2.id);\n   793→\n   794→      expect(calls).toEqual(['q1-mw', 'q1-handler', 'q2-mw', 'q2-handler']);\n   795→    });\n   796→  });\n   797→\n   798→  // ---- Phase 12: Graceful Shutdown ----\n   799→  describe('Phase 12: Graceful Shutdown', () => {\n   800→    it('should reject new tasks after shutdown', async () => {\n   801→      await queue.shutdown();\n   802→      expect(() => queue.addTask({ payload: 'test' })).toThrow();\n   803→    });\n   804→\n   805→    it('should complete immediately if no processing tasks', async () => {\n   806→      queue.addTask({ payload: 'pending' }); // pending, not processing\n   807→      const result = await queue.shutdown();\n   808→      expect(result.completed).toBe(0);\n   809→      expect(result.forceCancelled).toBe(0);\n   810→    });\n   811→\n   812→    it('should wait for processing tasks to complete', async () => {\n   813→      const task = queue.addTask({ payload: 'test' });\n   814→      queue.getNextTask();\n   815→\n   816→      // Complete the task after a short delay\n   817→      setTimeout(() => {\n   818→        queue.completeTask(task.id);\n   819→      }, 50);\n   820→\n   821→      const result = await queue.shutdown(5000);\n   822→      expect(result.completed).toBe(1);\n   823→      expect(result.forceCancelled).toBe(0);\n   824→    });\n   825→\n   826→    it('should force-cancel tasks on timeout', async () => {\n   827→      const task = queue.addTask({ payload: 'test' });\n   828→      queue.getNextTask();\n   829→      // Don't complete the task\n   830→\n   831→      const result = await queue.shutdown(50); // very short timeout\n   832→      expect(result.forceCancelled).toBe(1);\n   833→      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n   834→    });\n   835→\n   836→    it('should run shutdown callbacks', async () => {\n   837→      let callbackRan = false;\n   838→      queue.onShutdown(() => { callbackRan = true; });\n   839→\n   840→      await queue.shutdown();\n   841→      expect(callbackRan).toBe(true);\n   842→    });\n   843→\n   844→    it('should be safe to call shutdown multiple times', async () => {\n   845→      const result1 = await queue.shutdown();\n   846→      const result2 = await queue.shutdown();\n   847→      expect(result1).toBe(result2);\n   848→    });\n   849→\n   850→    it('should report shutdown duration', async () => {\n   851→      const result = await queue.shutdown();\n   852→      expect(typeof result.durationMs).toBe('number');\n   853→      expect(result.durationMs).toBeGreaterThanOrEqual(0);\n   854→    });\n   855→  });\n   856→});\n   857→"}]},"parent_tool_use_id":"toolu_01E59jS23ECpsfT6BMr9iUKA","session_id":"5e1a8bde-1de8-4fa9-b2ee-2ad7ee761c40","uuid":"1a974f83-b64b-4c2c-87d0-db81dd7bca58"}
