index 0000000..944fe38
--- /dev/null
+++ b/src/TaskQueue.ts
@@ -0,0 +1,616 @@
+import { randomUUID } from 'node:crypto';
+import {
+  Task,
+  TaskStatus,
+  AddTaskOptions,
+  ProgressUpdate,
+  ProgressListener,
+  MiddlewareFn,
+  HandlerFn,
+  CronSchedule,
+  ShutdownResult,
+  DEFAULT_QUEUE,
+  DEFAULT_PRIORITY,
+  DEFAULT_MAX_RETRIES,
+  DEFAULT_BACKOFF_DELAY,
+} from './types.js';
+import { parseCron, shouldRunAt } from './cron.js';
+
+interface QueueState {
+  concurrencyLimit: number; // 0 = unlimited
+  activeCount: number;
+  middleware: MiddlewareFn[];
+  handler?: HandlerFn;
+}
+
+export class TaskQueue {
+  private tasks: Map<string, Task> = new Map();
+  private queues: Map<string, QueueState> = new Map();
+  private deadLetterQueues: Map<string, Task[]> = new Map();
+  private progressListeners: Map<string, Set<ProgressListener>> = new Map();
+  private schedules: Map<string, CronSchedule> = new Map();
+  private shutdownCallbacks: Array<() => void | Promise<void>> = [];
+  private isShuttingDown = false;
+  private shutdownPromise: Promise<ShutdownResult> | null = null;
+
+  // ---- Phase 1: Basic FIFO Queue ----
+
+  addTask<T = unknown>(options: AddTaskOptions<T>): Task<T> {
+    if (this.isShuttingDown) {
+      throw new Error('Cannot add tasks: the queue system is shutting down.');
+    }
+
+    const queueName = options.queue ?? DEFAULT_QUEUE;
+    const priority = options.priority ?? DEFAULT_PRIORITY;
+
+    // Phase 3: validate priority
+    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {
+      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);
+    }
+
+    // Phase 7: validate dependencies
+    const dependencies = options.dependencies ?? [];
+    for (const depId of dependencies) {
+      const depTask = this.tasks.get(depId);
+      if (!depTask) {
+        throw new Error(`Dependency task not found: ${depId}`);
+      }
+    }
+
+    const now = new Date();
+    let availableAt: Date;
+    if (options.availableAt) {
+      availableAt = options.availableAt;
+    } else if (options.delay != null && options.delay > 0) {
+      availableAt = new Date(now.getTime() + options.delay);
+    } else {
+      availableAt = now;
+    }
+
+    const task: Task<T> = {
+      id: randomUUID(),
+      payload: options.payload,
+      status: 'pending',
+      queue: queueName,
+      priority,
+      createdAt: now,
+      availableAt,
+      attempts: 0,
+      maxRetries: options.maxRetries ?? DEFAULT_MAX_RETRIES,
+      backoffDelay: options.backoffDelay ?? DEFAULT_BACKOFF_DELAY,
+      dependencies,
+      progress: 0,
+    };
+
+    // Circular dependency detection with the newly assigned ID
+    if (dependencies.length > 0) {
+      this.detectCircularDependency(task.id, dependencies);
+    }
+
+    // Ensure queue exists
+    this.ensureQueue(queueName);
+
+    this.tasks.set(task.id, task as Task);
+    return task;
+  }
+
+  getTask(taskId: string): Task | undefined {
+    return this.tasks.get(taskId);
+  }
+
+  getNextTask(queueName: string = DEFAULT_QUEUE): Task | null {
+    const queueState = this.queues.get(queueName);
+    if (!queueState) return null;
+
+    // Phase 8: check concurrency limit
+    if (queueState.concurrencyLimit > 0 && queueState.activeCount >= queueState.concurrencyLimit) {
+      return null;
+    }
+
+    const now = new Date();
+    const candidates: Task[] = [];
+
+    for (const task of this.tasks.values()) {
+      if (task.queue !== queueName) continue;
+      if (task.status !== 'pending') continue;
+
+      // Phase 4: skip tasks that aren't available yet
+      if (task.availableAt > now) continue;
+
+      // Phase 7: skip tasks with unresolved dependencies
+      if (task.dependencies.length > 0) {
+        const allCompleted = task.dependencies.every(depId => {
+          const dep = this.tasks.get(depId);
+          return dep && dep.status === 'completed';
+        });
+        if (!allCompleted) continue;
+      }
+
+      candidates.push(task);
+    }
+
+    if (candidates.length === 0) return null;
+
+    // Sort: priority (ascending, lower = higher priority), then availableAt, then createdAt (FIFO)
+    candidates.sort((a, b) => {
+      if (a.priority !== b.priority) return a.priority - b.priority;
+      const availDiff = a.availableAt.getTime() - b.availableAt.getTime();
+      if (availDiff !== 0) return availDiff;
+      return a.createdAt.getTime() - b.createdAt.getTime();
+    });
+
+    const task = candidates[0];
+    task.status = 'processing';
+    task.attempts += 1;
+    queueState.activeCount += 1;
+
+    return task;
+  }
+
+  pendingCount(queueName: string = DEFAULT_QUEUE): number {
+    let count = 0;
+    for (const task of this.tasks.values()) {
+      if (task.queue === queueName && task.status === 'pending') {
+        count++;
+      }
+    }
+    return count;
+  }
+
+  // ---- Phase 2: Named Queues ----
+
+  private ensureQueue(name: string): void {
+    if (!this.queues.has(name)) {
+      this.queues.set(name, {
+        concurrencyLimit: 0,
+        activeCount: 0,
+        middleware: [],
+      });
+    }
+  }
+
+  getQueueNames(): string[] {
+    return Array.from(this.queues.keys());
+  }
+
+  // ---- Phase 5: Complete / Fail ----
+
+  completeTask(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot complete task in status "${task.status}". Must be "processing".`);
+    }
+
+    task.status = 'completed';
+    task.completedAt = new Date();
+    task.progress = 100;
+
+    const queueState = this.queues.get(task.queue);
+    if (queueState) {
+      queueState.activeCount = Math.max(0, queueState.activeCount - 1);
+    }
+
+    // Phase 7: check if any blocked tasks are now unblocked (handled automatically in getNextTask)
+  }
+
+  failTask(taskId: string, error?: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot fail task in status "${task.status}". Must be "processing".`);
+    }
+
+    const queueState = this.queues.get(task.queue);
+    if (queueState) {
+      queueState.activeCount = Math.max(0, queueState.activeCount - 1);
+    }
+
+    task.error = error;
+    task.lastFailedAt = new Date();
+
+    // Check if retries remain
+    if (task.attempts < task.maxRetries) {
+      // Re-queue with backoff delay
+      const backoffMs = task.backoffDelay * Math.pow(2, task.attempts - 1);
+      task.status = 'pending';
+      task.availableAt = new Date(Date.now() + backoffMs);
+      task.progress = 0;
+    } else {
+      // No retries remaining — mark as failed
+      task.status = 'failed';
+
+      // Phase 6: move to DLQ
+      this.moveToDeadLetterQueue(task);
+    }
+  }
+
+  // ---- Phase 6: Dead Letter Queue ----
+
+  private moveToDeadLetterQueue(task: Task): void {
+    const dlqKey = task.queue;
+    if (!this.deadLetterQueues.has(dlqKey)) {
+      this.deadLetterQueues.set(dlqKey, []);
+    }
+    this.deadLetterQueues.get(dlqKey)!.push(task);
+  }
+
+  getDeadLetterTasks(queueName: string = DEFAULT_QUEUE): Task[] {
+    return this.deadLetterQueues.get(queueName) ?? [];
+  }
+
+  replayDeadLetterTask(taskId: string): Task {
+    for (const [_queueName, dlq] of this.deadLetterQueues.entries()) {
+      const index = dlq.findIndex(t => t.id === taskId);
+      if (index !== -1) {
+        const task = dlq[index];
+        dlq.splice(index, 1);
+
+        // Reset for fresh retry
+        task.status = 'pending';
+        task.attempts = 0;
+        task.progress = 0;
+        task.error = undefined;
+        task.lastFailedAt = undefined;
+        task.availableAt = new Date();
+
+        // Ensure the task is in the main tasks store
+        this.tasks.set(task.id, task);
+
+        return task;
+      }
+    }
+    throw new Error(`Task not found in dead letter queue: ${taskId}`);
+  }
+
+  clearDeadLetterQueue(queueName: string = DEFAULT_QUEUE): void {
+    const dlq = this.deadLetterQueues.get(queueName);
+    if (!dlq) return;
+    for (const task of dlq) {
+      this.tasks.delete(task.id);
+    }
+    this.deadLetterQueues.delete(queueName);
+  }
+
+  // ---- Phase 7: Task Dependencies ----
+
+  private detectCircularDependency(taskId: string, dependencies: string[]): void {
+    // Traverse the transitive dependencies of the given dependency list.
+    // If any transitive dependency equals taskId, we have a cycle.
+    // This also checks that no dependency already in the store transitively
+    // depends on the new task (which is only possible if taskId is already stored).
+    const visited = new Set<string>();
+    const stack = [...dependencies];
+
+    while (stack.length > 0) {
+      const current = stack.pop()!;
+      if (current === taskId) {
+        throw new Error(`Circular dependency detected involving task ${taskId}`);
+      }
+      if (visited.has(current)) continue;
+      visited.add(current);
+
+      const currentTask = this.tasks.get(current);
+      if (currentTask) {
+        for (const depId of currentTask.dependencies) {
+          if (!visited.has(depId)) {
+            stack.push(depId);
+          }
+        }
+      }
+    }
+  }
+
+  getDependencyStatus(taskId: string): { taskId: string; resolved: boolean; dependencyStatuses: Array<{ id: string; status: TaskStatus | 'unknown' }> } {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+
+    const dependencyStatuses = task.dependencies.map(depId => {
+      const dep = this.tasks.get(depId);
+      return {
+        id: depId,
+        status: (dep ? dep.status : 'unknown') as TaskStatus | 'unknown',
+      };
+    });
+
+    const resolved = task.dependencies.every(depId => {
+      const dep = this.tasks.get(depId);
+      return dep && dep.status === 'completed';
+    });
+
+    return { taskId, resolved, dependencyStatuses };
+  }
+
+  // ---- Phase 8: Concurrency Control ----
+
+  setConcurrency(queueName: string, limit: number): void {
+    this.ensureQueue(queueName);
+    const state = this.queues.get(queueName)!;
+    state.concurrencyLimit = limit;
+  }
+
+  getConcurrency(queueName: string = DEFAULT_QUEUE): { limit: number; active: number } {
+    const state = this.queues.get(queueName);
+    if (!state) return { limit: 0, active: 0 };
+    return { limit: state.concurrencyLimit, active: state.activeCount };
+  }
+
+  // ---- Phase 9: Progress Tracking and Cancellation ----
+
+  updateProgress(taskId: string, progress: number, message?: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot update progress for task in status "${task.status}".`);
+    }
+    if (progress < 0 || progress > 100) {
+      throw new Error(`Progress must be between 0 and 100. Got: ${progress}`);
+    }
+
+    task.progress = progress;
+    task.progressMessage = message;
+
+    // Notify listeners
+    const listeners = this.progressListeners.get(taskId);
+    if (listeners) {
+      const update: ProgressUpdate = { taskId, progress, message };
+      for (const listener of listeners) {
+        listener(update);
+      }
+    }
+  }
+
+  getProgress(taskId: string): { progress: number; message?: string } {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    return { progress: task.progress, message: task.progressMessage };
+  }
+
+  onProgress(taskId: string, listener: ProgressListener): () => void {
+    if (!this.progressListeners.has(taskId)) {
+      this.progressListeners.set(taskId, new Set());
+    }
+    this.progressListeners.get(taskId)!.add(listener);
+
+    // Return unsubscribe function
+    return () => {
+      const listeners = this.progressListeners.get(taskId);
+      if (listeners) {
+        listeners.delete(listener);
+        if (listeners.size === 0) {
+          this.progressListeners.delete(taskId);
+        }
+      }
+    };
+  }
+
+  cancelTask(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+
+    if (task.status !== 'pending' && task.status !== 'processing') {
+      throw new Error(`Cannot cancel task in status "${task.status}". Must be "pending" or "processing".`);
+    }
+
+    if (task.status === 'processing') {
+      const queueState = this.queues.get(task.queue);
+      if (queueState) {
+        queueState.activeCount = Math.max(0, queueState.activeCount - 1);
+      }
+    }
+
+    task.status = 'cancelled';
+    task.cancelledAt = new Date();
+  }
+
+  // ---- Phase 10: Recurring Tasks ----
+
+  addSchedule(options: {
+    id?: string;
+    cronExpression: string;
+    queue?: string;
+    taskTemplate: unknown;
+    priority?: number;
+  }): CronSchedule {
+    if (this.isShuttingDown) {
+      throw new Error('Cannot add schedules: the queue system is shutting down.');
+    }
+
+    // Validate cron expression
+    parseCron(options.cronExpression);
+
+    const schedule: CronSchedule = {
+      id: options.id ?? randomUUID(),
+      cronExpression: options.cronExpression,
+      queue: options.queue ?? DEFAULT_QUEUE,
+      taskTemplate: options.taskTemplate,
+      priority: options.priority,
+    };
+
+    this.schedules.set(schedule.id, schedule);
+    return schedule;
+  }
+
+  removeSchedule(scheduleId: string): boolean {
+    return this.schedules.delete(scheduleId);
+  }
+
+  getSchedules(): CronSchedule[] {
+    return Array.from(this.schedules.values());
+  }
+
+  tick(now: Date = new Date()): Task[] {
+    if (this.isShuttingDown) {
+      return [];
+    }
+    const created: Task[] = [];
+
+    for (const schedule of this.schedules.values()) {
+      const cron = parseCron(schedule.cronExpression);
+
+      // Round the check time to the current minute
+      const checkTime = new Date(now);
+      checkTime.setSeconds(0, 0);
+
+      if (shouldRunAt(cron, checkTime)) {
+        // Check if we already ran for this minute
+        if (schedule.lastRun) {
+          const lastRunMinute = new Date(schedule.lastRun);
+          lastRunMinute.setSeconds(0, 0);
+          if (lastRunMinute.getTime() === checkTime.getTime()) {
+            continue; // Already ran for this minute
+          }
+        }
+
+        schedule.lastRun = now;
+        const task = this.addTask({
+          payload: schedule.taskTemplate,
+          queue: schedule.queue,
+          priority: schedule.priority,
+        });
+        created.push(task);
+      }
+    }
+
+    return created;
+  }
+
+  // ---- Phase 11: Middleware Pipeline ----
+
+  use(queueName: string, middleware: MiddlewareFn): void {
+    this.ensureQueue(queueName);
+    this.queues.get(queueName)!.middleware.push(middleware);
+  }
+
+  setHandler(queueName: string, handler: HandlerFn): void {
+    this.ensureQueue(queueName);
+    this.queues.get(queueName)!.handler = handler;
+  }
+
+  async processTask(taskId: string): Promise<void> {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot process task in status "${task.status}". Must be "processing".`);
+    }
+
+    const queueState = this.queues.get(task.queue);
+    if (!queueState) {
+      throw new Error(`Queue not found: ${task.queue}`);
+    }
+
+    const middleware = [...queueState.middleware];
+    const handler = queueState.handler;
+
+    let index = 0;
+
+    const executeNext = async (): Promise<void> => {
+      if (index < middleware.length) {
+        const mw = middleware[index++];
+        await mw(task, async () => {
+          await executeNext();
+        });
+        // If middleware didn't call next, pipeline stops
+      } else if (handler) {
+        await handler(task);
+      }
+    };
+
+    try {
+      await executeNext();
+    } catch (error) {
+      const errorMsg = error instanceof Error ? error.message : String(error);
+      this.failTask(taskId, errorMsg);
+      throw error;
+    }
+  }
+
+  // ---- Phase 12: Graceful Shutdown ----
+
+  onShutdown(callback: () => void | Promise<void>): void {
+    this.shutdownCallbacks.push(callback);
+  }
+
+  async shutdown(timeoutMs: number = 30000): Promise<ShutdownResult> {
+    if (this.shutdownPromise) {
+      return this.shutdownPromise;
+    }
+
+    this.isShuttingDown = true;
+    this.shutdownPromise = this.performShutdown(timeoutMs);
+    return this.shutdownPromise;
+  }
+
+  private async performShutdown(timeoutMs: number): Promise<ShutdownResult> {
+    const startTime = Date.now();
+
+    // Run shutdown callbacks
+    for (const cb of this.shutdownCallbacks) {
+      try {
+        await cb();
+      } catch {
+        // Ignore callback errors during shutdown
+      }
+    }
+
+    // Get all currently processing tasks
+    const processingTasks: Task[] = [];
+    for (const task of this.tasks.values()) {
+      if (task.status === 'processing') {
+        processingTasks.push(task);
+      }
+    }
+
+    if (processingTasks.length === 0) {
+      return {
+        completed: 0,
+        forceCancelled: 0,
+        durationMs: Date.now() - startTime,
+      };
+    }
+
+    // Wait for processing tasks to complete (up to timeout)
+    let completed = 0;
+    let forceCancelled = 0;
+
+    await new Promise<void>(resolve => {
+      const checkInterval = setInterval(() => {
+        const stillProcessing = processingTasks.filter(t => t.status === 'processing');
+        if (stillProcessing.length === 0) {
+          clearInterval(checkInterval);
+          resolve();
+        }
+      }, 10);
+
+      setTimeout(() => {
+        clearInterval(checkInterval);
+        resolve();
+      }, timeoutMs);
+    });
+
+    // Count completed and force-cancel remaining
+    for (const task of processingTasks) {
+      if (task.status === 'processing') {
+        task.status = 'cancelled';
+        task.cancelledAt = new Date();
+        const queueState = this.queues.get(task.queue);
+        if (queueState) {
+          queueState.activeCount = Math.max(0, queueState.activeCount - 1);
+        }
+        forceCancelled++;
+      } else {
+        completed++;
+      }
+    }
+
+    return {
+      completed,
+      forceCancelled,
+      durationMs: Date.now() - startTime,
+    };
+  }
+
+  get isShutdown(): boolean {
+    return this.isShuttingDown;
+  }
+}
diff --git a/src/cron.ts b/src/cron.ts
