index 0000000..48d7581
--- /dev/null
+++ b/src/cron.ts
@@ -0,0 +1,70 @@
+/**
+ * Simple cron expression parser supporting:
+ * - * /N * * * * -- every N minutes (written without space between * and /)
+ * - 0 * * * *   -- every hour on the hour
+ * - 0 0 * * *   -- every day at midnight
+ */
+
+export interface CronParts {
+  minute: { type: 'any' } | { type: 'exact'; value: number } | { type: 'every'; interval: number };
+  hour: { type: 'any' } | { type: 'exact'; value: number };
+  // day, month, weekday are always '*' for our subset
+}
+
+export function parseCron(expression: string): CronParts {
+  const parts = expression.trim().split(/\s+/);
+  if (parts.length !== 5) {
+    throw new Error(`Invalid cron expression: "${expression}". Expected 5 fields.`);
+  }
+
+  const [minuteStr, hourStr, dayStr, monthStr, weekdayStr] = parts;
+
+  // We only support * for day/month/weekday
+  if (dayStr !== '*' || monthStr !== '*' || weekdayStr !== '*') {
+    throw new Error(`Unsupported cron expression: "${expression}". Only * is supported for day, month, and weekday fields.`);
+  }
+
+  let minute: CronParts['minute'];
+  if (minuteStr === '*') {
+    minute = { type: 'any' };
+  } else if (minuteStr.startsWith('*/')) {
+    const interval = parseInt(minuteStr.slice(2), 10);
+    if (isNaN(interval) || interval <= 0 || interval > 59) {
+      throw new Error(`Invalid cron minute interval: "${minuteStr}"`);
+    }
+    minute = { type: 'every', interval };
+  } else {
+    const value = parseInt(minuteStr, 10);
+    if (isNaN(value) || value < 0 || value > 59) {
+      throw new Error(`Invalid cron minute value: "${minuteStr}"`);
+    }
+    minute = { type: 'exact', value };
+  }
+
+  let hour: CronParts['hour'];
+  if (hourStr === '*') {
+    hour = { type: 'any' };
+  } else {
+    const value = parseInt(hourStr, 10);
+    if (isNaN(value) || value < 0 || value > 23) {
+      throw new Error(`Invalid cron hour value: "${hourStr}"`);
+    }
+    hour = { type: 'exact', value };
+  }
+
+  return { minute, hour };
+}
+
+export function shouldRunAt(cron: CronParts, date: Date): boolean {
+  const m = date.getMinutes();
+  const h = date.getHours();
+
+  // Check minute
+  if (cron.minute.type === 'exact' && cron.minute.value !== m) return false;
+  if (cron.minute.type === 'every' && m % cron.minute.interval !== 0) return false;
+
+  // Check hour
+  if (cron.hour.type === 'exact' && cron.hour.value !== h) return false;
+
+  return true;
+}
