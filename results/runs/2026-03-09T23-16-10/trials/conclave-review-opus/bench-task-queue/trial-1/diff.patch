 const depTask = this.tasks.get(depId);\n      if (!depTask) {\n        throw new Error(`Dependency task not found: ${depId}`);\n      }\n    }\n\n    // Circular dependency detection\n    if (dependencies.length > 0) {\n      // This task doesn't have an ID yet; we'll check after creating it\n    }\n\n    const now = new Date();\n    let availableAt: Date;\n    if (options.availableAt) {\n      availableAt = options.availableAt;\n    } else if (options.delay != null && options.delay > 0) {\n      availableAt = new Date(now.getTime() + options.delay);\n    } else {\n      availableAt = now;\n    }\n\n    const task: Task<T> = {\n      id: randomUUID(),\n      payload: options.payload,\n      status: 'pending',\n      queue: queueName,\n      priority,\n      createdAt: now,\n      availableAt,\n      attempts: 0,\n      maxRetries: options.maxRetries ?? DEFAULT_MAX_RETRIES,\n      backoffDelay: options.backoffDelay ?? DEFAULT_BACKOFF_DELAY,\n      dependencies,\n      progress: 0,\n    };\n\n    // Circular dependency detection with the newly assigned ID\n    if (dependencies.length > 0) {\n      this.detectCircularDependency(task.id, dependencies);\n    }\n\n    // Ensure queue exists\n    this.ensureQueue(queueName);\n\n    this.tasks.set(task.id, task as Task);\n    return task;\n  }\n\n  getTask(taskId: string): Task | undefined {\n    return this.tasks.get(taskId);\n  }\n\n  getNextTask(queueName: string = DEFAULT_QUEUE): Task | null {\n    const queueState = this.queues.get(queueName);\n    if (!queueState) return null;\n\n    // Phase 8: check concurrency limit\n    if (queueState.concurrencyLimit > 0 && queueState.activeCount >= queueState.concurrencyLimit) {\n      return null;\n    }\n\n    const now = new Date();\n    const candidates: Task[] = [];\n\n    for (const task of this.tasks.values()) {\n      if (task.queue !== queueName) continue;\n      if (task.status !== 'pending') continue;\n\n      // Phase 4: skip tasks that aren't available yet\n      if (task.availableAt > now) continue;\n\n      // Phase 7: skip tasks with unresolved dependencies\n      if (task.dependencies.length > 0) {\n        const allCompleted = task.dependencies.every(depId => {\n          const dep = this.tasks.get(depId);\n          return dep && dep.status === 'completed';\n        });\n        if (!allCompleted) continue;\n      }\n\n      candidates.push(task);\n    }\n\n    if (candidates.length === 0) return null;\n\n    // Sort: priority (ascending, lower = higher priority), then availableAt, then createdAt (FIFO)\n    candidates.sort((a, b) => {\n      if (a.priority !== b.priority) return a.priority - b.priority;\n      const availDiff = a.availableAt.getTime() - b.availableAt.getTime();\n      if (availDiff !== 0) return availDiff;\n      return a.createdAt.getTime() - b.createdAt.getTime();\n    });\n\n    const task = candidates[0];\n    task.status = 'processing';\n    task.attempts += 1;\n    queueState.activeCount += 1;\n\n    return task;\n  }\n\n  pendingCount(queueName: string = DEFAULT_QUEUE): number {\n    let count = 0;\n    for (const task of this.tasks.values()) {\n      if (task.queue === queueName && task.status === 'pending') {\n        count++;\n      }\n    }\n    return count;\n  }\n\n  // ---- Phase 2: Named Queues ----\n\n  private ensureQueue(name: string): void {\n    if (!this.queues.has(name)) {\n      this.queues.set(name, {\n        concurrencyLimit: 0,\n        activeCount: 0,\n        middleware: [],\n      });\n    }\n  }\n\n  getQueueNames(): string[] {\n    return Array.from(this.queues.keys());\n  }\n\n  // ---- Phase 5: Complete / Fail ----\n\n  completeTask(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot complete task in status \"${task.status}\". Must be \"processing\".`);\n    }\n\n    task.status = 'completed';\n    task.completedAt = new Date();\n    task.progress = 100;\n\n    const queueState = this.queues.get(task.queue);\n    if (queueState) {\n      queueState.activeCount = Math.max(0, queueState.activeCount - 1);\n    }\n\n    // Phase 7: check if any blocked tasks are now unblocked (handled automatically in getNextTask)\n  }\n\n  failTask(taskId: string, error?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot fail task in status \"${task.status}\". Must be \"processing\".`);\n    }\n\n    const queueState = this.queues.get(task.queue);\n    if (queueState) {\n      queueState.activeCount = Math.max(0, queueState.activeCount - 1);\n    }\n\n    task.error = error;\n    task.lastFailedAt = new Date();\n\n    // Check if retries remain\n    if (task.attempts < task.maxRetries) {\n      // Re-queue with backoff delay\n      const backoffMs = task.backoffDelay * Math.pow(2, task.attempts - 1);\n      task.status = 'pending';\n      task.availableAt = new Date(Date.now() + backoffMs);\n      task.progress = 0;\n    } else {\n      // No retries remaining — mark as failed\n      task.status = 'failed';\n\n      // Phase 6: move to DLQ\n      this.moveToDeadLetterQueue(task);\n    }\n  }\n\n  // ---- Phase 6: Dead Letter Queue ----\n\n  private moveToDeadLetterQueue(task: Task): void {\n    const dlqKey = task.queue;\n    if (!this.deadLetterQueues.has(dlqKey)) {\n      this.deadLetterQueues.set(dlqKey, []);\n    }\n    this.deadLetterQueues.get(dlqKey)!.push(task);\n  }\n\n  getDeadLetterTasks(queueName: string = DEFAULT_QUEUE): Task[] {\n    return this.deadLetterQueues.get(queueName) ?? [];\n  }\n\n  replayDeadLetterTask(taskId: string): Task {\n    // Find the task in DLQs\n    for (const [queueName, dlq] of this.deadLetterQueues.entries()) {\n      const index = dlq.findIndex(t => t.id === taskId);\n      if (index !== -1) {\n        const task = dlq[index];\n        dlq.splice(index, 1);\n\n        // Reset for fresh retry\n        task.status = 'pending';\n        task.attempts = 0;\n        task.progress = 0;\n        task.error = undefined;\n        task.lastFailedAt = undefined;\n        task.availableAt = new Date();\n\n        return task;\n      }\n    }\n    throw new Error(`Task not found in dead letter queue: ${taskId}`);\n  }\n\n  clearDeadLetterQueue(queueName: string = DEFAULT_QUEUE): void {\n    // Remove the tasks from the main tasks map as well\n    const dlq = this.deadLetterQueues.get(queueName);\n    if (dlq) {\n      for (const task of dlq) {\n        this.tasks.delete(task.id);\n      }\n    }\n    this.deadLetterQueues.set(queueName, []);\n  }\n\n  // ---- Phase 7: Task Dependencies ----\n\n  private detectCircularDependency(taskId: string, dependencies: string[]): void {\n    // BFS/DFS from each dependency to see if any path leads back to taskId\n    const visited = new Set<string>();\n    const stack = [...dependencies];\n\n    while (stack.length > 0) {\n      const current = stack.pop()!;\n      if (current === taskId) {\n        throw new Error(`Circular dependency detected involving task ${taskId}`);\n      }\n      if (visited.has(current)) continue;\n      visited.add(current);\n\n      const currentTask = this.tasks.get(current);\n      if (currentTask) {\n        // Check dependents: tasks whose dependencies include `current`\n        // Actually, we need to check the dependency chain the other way:\n        // We need to ensure that none of the tasks that `taskId` depends on\n        // (transitively) depend on `taskId`.\n        // But `taskId` doesn't exist yet as a dependency.\n        // The real check: does any of the dependency tasks depend (transitively) on taskId?\n        // Since taskId is new and not yet stored, no existing task can depend on it.\n        // However, the new task's dependencies form a chain. We need to check\n        // that the dependency graph formed by