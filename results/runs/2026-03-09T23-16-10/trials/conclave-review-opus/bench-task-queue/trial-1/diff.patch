+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TK22okThbAcmQGsjkc3NPv","type":"tool_result","content":"     1→// ---- Core Types ----\n     2→\n     3→export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';\n     4→\n     5→export interface Task<T = unknown> {\n     6→  id: string;\n     7→  payload: T;\n     8→  status: TaskStatus;\n     9→  queue: string;\n    10→  priority: number;\n    11→  createdAt: Date;\n    12→  availableAt: Date;\n    13→  attempts: number;\n    14→  maxRetries: number;\n    15→  backoffDelay: number;\n    16→  dependencies: string[];\n    17→  progress: number;\n    18→  progressMessage?: string;\n    19→  error?: string;\n    20→  lastFailedAt?: Date;\n    21→  completedAt?: Date;\n    22→  cancelledAt?: Date;\n    23→}\n    24→\n    25→export interface AddTaskOptions<T = unknown> {\n    26→  payload: T;\n    27→  queue?: string;\n    28→  priority?: number;\n    29→  delay?: number;\n    30→  availableAt?: Date;\n    31→  maxRetries?: number;\n    32→  backoffDelay?: number;\n    33→  dependencies?: string[];\n    34→}\n    35→\n    36→export interface ProgressUpdate {\n    37→  taskId: string;\n    38→  progress: number;\n    39→  message?: string;\n    40→}\n    41→\n    42→export type ProgressListener = (update: ProgressUpdate) => void;\n    43→\n    44→export type MiddlewareFn = (task: Task, next: () => Promise<void>) => Promise<void>;\n    45→export type HandlerFn = (task: Task) => Promise<void> | void;\n    46→\n    47→export interface CronSchedule {\n    48→  id: string;\n    49→  cronExpression: string;\n    50→  queue: string;\n    51→  taskTemplate: unknown;\n    52→  lastRun?: Date;\n    53→  priority?: number;\n    54→}\n    55→\n    56→export interface ShutdownResult {\n    57→  completed: number;\n    58→  forceCancelled: number;\n    59→  durationMs: number;\n    60→}\n    61→\n    62→export const DEFAULT_QUEUE = 'default';\n    63→export const DEFAULT_PRIORITY = 5;\n    64→export const DEFAULT_MAX_RETRIES = 3;\n    65→export const DEFAULT_BACKOFF_DELAY = 1000;\n    66→"}]},"parent_tool_use_id":"toolu_01E59jS23ECpsfT6BMr9iUKA","session_id":"5e1a8bde-1de8-4fa9-b2ee-2ad7ee761c40","uuid":"ee3e146e-8ffe-4d75-a49e-004dd7651c8e"}
