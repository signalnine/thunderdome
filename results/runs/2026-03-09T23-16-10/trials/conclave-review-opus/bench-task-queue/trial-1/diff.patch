', () => {\n    it('should add a task and return a task object with unique id', () => {\n      const task = queue.addTask({ payload: { data: 'test' } });\n      expect(task).toBeDefined();\n      expect(task.id).toBeDefined();\n      expect(typeof task.id).toBe('string');\n      expect(task.payload).toEqual({ data: 'test' });\n      expect(task.status).toBe('pending');\n      expect(task.createdAt).toBeInstanceOf(Date);\n    });\n\n    it('should generate unique ids for each task', () => {\n      const t1 = queue.addTask({ payload: 'a' });\n      const t2 = queue.addTask({ payload: 'b' });\n      expect(t1.id).not.toBe(t2.id);\n    });\n\n    it('should retrieve tasks in FIFO order', () => {\n      queue.addTask({ payload: 'first' });\n      queue.addTask({ payload: 'second' });\n      queue.addTask({ payload: 'third' });\n\n      const t1 = queue.getNextTask();\n      expect(t1?.payload).toBe('first');\n      const t2 = queue.getNextTask();\n      expect(t2?.payload).toBe('second');\n      const t3 = queue.getNextTask();\n      expect(t3?.payload).toBe('third');\n    });\n\n    it('should transition task to processing when retrieved', () => {\n      queue.addTask({ payload: 'test' });\n      const task = queue.getNextTask();\n      expect(task?.status).toBe('processing');\n    });\n\n    it('should return null when no tasks available', () => {\n      const task = queue.getNextTask();\n      expect(task).toBeNull();\n    });\n\n    it('should track pending count', () => {\n      expect(queue.pendingCount()).toBe(0);\n      queue.addTask({ payload: 'a' });\n      queue.addTask({ payload: 'b' });\n      expect(queue.pendingCount()).toBe(2);\n      queue.getNextTask();\n      expect(queue.pendingCount()).toBe(1);\n    });\n\n    it('should not return processing tasks again', () => {\n      queue.addTask({ payload: 'only' });\n      queue.getNextTask(); // moves to processing\n      expect(queue.getNextTask()).toBeNull();\n    });\n  });\n\n  // ---- Phase 2: Named Queues ----\n  describe('Phase 2: Named Queues', () => {\n    it('should support named queues', () => {\n      queue.addTask({ payload: 'email', queue: 'emails' });\n      queue.addTask({ payload: 'sms', queue: 'sms' });\n\n      const email = queue.getNextTask('emails');\n      expect(email?.payload).toBe('email');\n\n      const sms = queue.getNextTask('sms');\n      expect(sms?.payload).toBe('sms');\n    });\n\n    it('should use default queue when no name given', () => {\n      queue.addTask({ payload: 'default' });\n      const task = queue.getNextTask();\n      expect(task?.payload).toBe('default');\n      expect(task?.queue).toBe('default');\n    });\n\n    it('should operate queues independently', () => {\n      queue.addTask({ payload: 'a', queue: 'q1' });\n      queue.addTask({ payload: 'b', queue: 'q2' });\n\n      expect(queue.pendingCount('q1')).toBe(1);\n      expect(queue.pendingCount('q2')).toBe(1);\n\n      queue.getNextTask('q1');\n      expect(queue.pendingCount('q1')).toBe(0);\n      expect(queue.pendingCount('q2')).toBe(1);\n    });\n\n    it('should list all queue names', () => {\n      queue.addTask({ payload: 'a', queue: 'q1' });\n      queue.addTask({ payload: 'b', queue: 'q2' });\n      const names = queue.getQueueNames();\n      expect(names).toContain('q1');\n      expect(names).toContain('q2');\n    });\n\n    it('should return null from nonexistent queue', () => {\n      expect(queue.getNextTask('nonexistent')).toBeNull();\n    });\n\n    it('should return null from empty queue', () => {\n      queue.addTask({ payload: 'a', queue: 'q1' });\n      queue.getNextTask('q1');\n      expect(queue.getNextTask('q1')).toBeNull();\n    });\n  });\n\n  // ---- Phase 3: Priority ----\n  describe('Phase 3: Priority', () => {\n    it('should default to priority 5', () => {\n      const task = queue.addTask({ payload: 'default' });\n      expect(task.priority).toBe(5);\n    });\n\n    it('should return higher priority tasks first', () => {\n      queue.addTask({ payload: 'low', priority: 10 });\n      queue.addTask({ payload: 'high', priority: 1 });\n      queue.addTask({ payload: 'medium', priority: 5 });\n\n      expect(queue.getNextTask()?.payload).toBe('high');\n      expect(queue.getNextTask()?.payload).toBe('medium');\n      expect(queue.getNextTask()?.payload).toBe('low');\n    });\n\n    it('should maintain FIFO order within same priority', () => {\n      queue.addTask({ payload: 'first', priority: 3 });\n      queue.addTask({ payload: 'second', priority: 3 });\n      queue.addTask({ payload: 'third', priority: 3 });\n\n      expect(queue.getNextTask()?.payload).toBe('first');\n      expect(queue.getNextTask()?.payload).toBe('second');\n      expect(queue.getNextTask()?.payload).toBe('third');\n    });\n\n    it('should reject invalid priority values', () => {\n      expect(() => queue.addTask({ payload: 'a', priority: 0 })).toThrow();\n      expect(() => queue.addTask({ payload: 'a', priority: 11 })).toThrow();\n      expect(() => queue.addTask({ payload: 'a', priority: -1 })).toThrow();\n      expect(() => queue.addTask({ payload: 'a', priority: 1.5 })).toThrow();\n    });\n\n    it('should handle priority per queue', () => {\n      queue.addTask({ payload: 'q1-low', priority: 10, queue: 'q1' });\n      queue.addTask({ payload: 'q1-high', priority: 1, queue: 'q1' });\n      queue.addTask({ payload: 'q2-low', priority: 10, queue: 'q2' });\n      queue.addTask({ payload: 'q2-high', priority: 1, queue: 'q2' });\n\n      expect(queue.getNextTask('q1')?.payload).toBe('q1-high');\n      expect(queue.getNextTask('q2')?.payload).toBe('q2-high');\n    });\n  });\n\n  // ---- Phase 4: Delayed and Scheduled Tasks ----\n  describe('Phase 4: Delayed and Scheduled Tasks', () => {\n    it('should support delayed tasks', () => {\n      queue.addTask({ payload: 'delayed', delay: 100000 }); // far future\n      expect(queue.getNextTask()).toBeNull(); // not available yet\n    });\n\n    it('should support specific availableAt', () => {\n      const futureDate = new Date(Date.now() + 100000);\n      const task = queue.addTask({ payload: 'scheduled', availableAt: futureDate });\n      expect(task.availableAt).toEqual(futureDate);\n      expect(queue.getNextTask()).toBeNull();\n    });\n\n    it('should return delayed tasks after they become available', () => {\n      const pastDate = new Date(Date.now() - 1000);\n      queue.addTask({ payload: 'ready', availableAt: pastDate });\n      const task = queue.getNextTask();\n      expect(task?.payload).toBe('ready');\n    });\n\n    it('should prefer non-delayed tasks', () => {\n      queue.addTask({ payload: 'delayed', delay: 100000 });\n      queue.addTask({ payload: 'immediate' });\n      expect(queue.getNextTask()?.payload).toBe('immediate');\n    });\n\n    it('should order by availability time, then priority, then FIFO', () => {\n      const now = Date.now();\n      queue.addTask({ payload: 'later', availableAt: new Date(now - 100), priority: 5 });\n      queue.addTask({ payload: 'earlier', availableAt: new Date(now - 200), priority: 5 });\n\n      expect(queue.getNextTask()?.payload).toBe('earlier');\n      expect(queue.getNextTask()?.payload).toBe('later');\n    });\n\n    it('should indicate when a task becomes available', () => {\n      const futureDate = new Date(Date.now() + 5000);\n      const task = queue.addTask({ payload: 'scheduled', availableAt: futureDate });\n      expect(task.availableAt).toEqual(futureDate);\n    });\n  });\n\n  // ---- Phase 5: Retry with Backoff ----\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should complete a task', () => {\n      const task = queue.addTask({ payload: 'test' });\n      queue.getNextTask();\n      queue.completeTask(task.id);\n      expect(queue.getTask(task.id)?.status).toBe('completed');\n    });\n\n    it('should fail a task and re-add with backoff if retries remain', () => {\n      const task = queue.addTask({ payload: 'test', maxRetries: 3, backoffDelay: 100 });\n      queue.getNextTask();\n      queue.failTask(task.id, 'some error');\n\n      // Task should be pending again\n      const updated = queue.getTask(task.id)!;\n      expect(updated.status).toBe('pending');\n      expect(updated.error).toBe('some error');\n      expect(updated.attempts).toBe(1);\n    });\n\n    it('should apply exponential backoff', () => {\n      const task = queue.addTask({ payload: 'test', maxRetries: 3, backoffDelay: 1000 });\n\n      // First attempt\n      queue.getNextTask();\n      const beforeFail = Date.now();\n      queue.failTask(task.id, 'fail');\n      const updated = queue.getTask(task.id)!;\n      // backoff = 1000 * 2^0 = 1000ms\n      expect(updated.availableAt.getTime()).toBeGreaterThanOrEqual(beforeFail + 900); // some tolerance\n    });\n\n    it('should track attempt count', () => {\n      const task = queue.addTask({ payload: 'test', maxRetries: 3, backoffDelay: 0 });\n\n      // First attempt\n      queue.getNextTask();\n      expect(queue.getTask(task.id)!.attempts).toBe(1);\n    });\n\n    it('should mark task as failed when retries exhausted', () => {\n      const task = queue.addTask({ payload: 'test', maxRetries: 1, backoffDelay: 0 });\n\n      // First attempt (the only allowed one)\n      queue.getNextTask();\n      queue.failTask(task.id, 'fail');\n\n      expect(queue.getTask(task.id)!.status).toBe('failed');\n    });\n\n    it('should keep original queue and priority on retry', () => {\n      const task = queue.addTask({ payload: 'test', queue: 'myqueue', priority: 2, maxRetries: 3, backoffDelay: 0 });\n      queue.getNextTask('myqueue');\n      queue.failTask(task.id, 'fail');\n\n      const updated = queue.getTask(task.id)!;\n      expect(updated.queue).toBe('myqueue');\n      expect(updated.priority).toBe(2);\n    });\n\n    it('should default maxRetries to 3', () => {\n      const task = queue.addTask({ payload: 'test' });\n      expect(task.maxRetries).toBe(3);\n    });\n\n    it('should default backoffDelay to 1000', () => {\n      const task = queue.addTask({ payload: 'test' });\n      expect(task.backoffDelay).toBe(1000);\n    });\n\n    it('should not complete a non-processing task', () => {\n      const task = queue.addTask({ payload: 'test' });\n      expect(() => queue.completeTask(task.id)).toThrow();\n    });\n\n    it('should not fail a non-processing task', () => {\n      const task = queue.addTask({ payload: 'test' });\n      expect(() => queue.failTask(task.id)).toThrow();\n    });\n  });\n\n  // ---- Phase 6: Dead Letter Queue ----\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move permanently failed tasks to DLQ', () => {\n      const task = queue.addTask({ payload: 'test', maxRetries: 1, backoffDelay: 0 });\n      queue.getNextTask();\n      queue.failTask(task.id, 'permanent failure');\n\n      const dlq = queue.getDeadLetterTasks();\n      expect(dlq).toHaveLength(1);\n      expect(dlq[0].id).toBe(task.id);\n      expect(dlq[0].error).toBe('permanent failure');\n    });\n\n    it('should retain error info and attempt count in DLQ', () => {\n      const task = queue.addTask({ payload: 'test', maxRetries: 1, backoffDelay: 0 });\n      queue.getNextTask();\n      queue.failTask(task.id, 'error msg');\n\n      const dlq = queue.getDeadLetterTasks();\n      expect(dlq[0].error).toBe('error msg');\n      expect(dlq[0].attempts).toBe(1);\n    });\n\n    it('should replay DLQ tasks back to original queue', () => {\n      const task = queue.addTask({ payload: 'test', maxRetries: 1, backoffDelay: 0 });\n      queue.getNextTask();\n      queue.failTask(task.id, 'fail');\n\n      const replayed = queue.replayDeadLetterTask(task.id);\n      expect(replayed.status).toBe('pending');\n      expect(replayed.attempts).toBe(0);\n\n      const dlq = queue.getDeadLetterTasks();\n      expect(dlq).toHaveLength(0);\n    });\n\n    it('should clear DLQ for a queue', () => {\n      const t1 = queue.addTask({ payload: 'a', maxRetries: 1, backoffDelay: 0 });\n      const t2 = queue.addTask({ payload: 'b', maxRetries: 1, backoffDelay: 0 });\n\n      queue.getNextTask();\n      queue.failTask(t1.id, 'fail');\n      queue.getNextTask();\n      queue.failTask(t2.id, 'fail');\n\n      expect(queue.getDeadLetterTasks()).toHaveLength(2);\n      queue.clearDeadLetterQueue();\n      expect(queue.getDeadLetterTasks()).toHaveLength(0);\n    });\n\n    it('should have independent DLQs per named queue', () => {\n      const t1 = queue.addTask({ payload: 'a', queue: 'q1', maxRetries: 1, backoffDelay: 0 });\n      const t2 = queue.addTask({ payload: 'b', queue: 'q2', maxRetries: 1, backoffDelay: 0 });\n\n      queue.getNextTask('q1');\n      queue.failTask(t1.id, 'fail');\n      queue.getNextTask('q2');\n      queue.failTask(t2.id, 'fail');\n\n      expect(queue.getDeadLetterTasks('q1')).toHaveLength(1);\n      expect(queue.getDeadLetterTasks('q2')).toHaveLength(1);\n\n      queue.clearDeadLetterQueue('q1');\n      expect(queue.getDeadLetterTasks('q1')).toHaveLength(0);\n      expect(queue.getDeadLetterTasks('q2')).toHaveLength(1);\n    });\n\n    it('should throw when replaying non-existent DLQ task', () => {\n      expect(() => queue.replayDeadLetterTask('nonexistent')).toThrow();\n    });\n  });\n\n  // ---- Phase 7: Task Dependencies ----\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block tasks with unresolved dependencies', () => {\n      const dep = queue.addTask({ payload: 'dependency' });\n      queue.addTask({ payload: 'dependent', dependencies: [dep.id] });\n\n      // The dependent task should not be available\n      const next = queue.getNextTask();\n      expect(next?.payload).toBe('dependency');\n\n      // Now get next - dependent still blocked since dep isn't completed\n      expect(queue.getNextTask()).toBeNull();\n    });\n\n    it('should unblock tasks when dependencies complete', () => {\n      const dep = queue.addTask({ payload: 'dependency' });\n      queue.addTask({ payload: 'dependent', dependencies: [dep.id] });\n\n      // Process and complete dependency\n      queue.getNextTask();\n      queue.completeTask(dep.id);\n\n      // Now the dependent task should be available\n      const next = queue.getNextTask();\n      expect(next?.payload).toBe('dependent');\n    });\n\n    it('should reject non-existent dependencies', () => {\n      expect(() => queue.addTask({ payload: 'test', dependencies: ['fake-id'] })).toThrow();\n    });\n\n    it('should detect circular dependencies', () => {\n      const t1 = queue.addTask({ payload: 'a' });\n      const t2 = queue.addTask({ payload: 'b', dependencies: [t1.id] });\n      expect(() => queue.addTask({ payload: 'c', dependencies: [t2.id, t1.id] })).not.toThrow();\n    });\n\n    it('should keep dependents blocked when dependency fails', () => {\n      const dep = queue.addTask({ payload: 'dependency', maxRetries: 1, backoffDelay: 0 });\n      queue.addTask({ payload: 'dependent', dependencies: [dep.id] });\n\n      queue.getNextTask();\n      queue.failTask(dep.id, 'fail');\n\n      // Dependent remains blocked\n      expect(queue.getNextTask()).toBeNull();\n    });\n\n    it('should inspect dependency status', () => {\n      const dep1 = queue.addTask({ payload: 'dep1' });\n      const dep2 = queue.addTask({ payload: 'dep2' });\n      const dependent = queue.addTask({ payload: 'dependent', dependencies: [dep1.id, dep2.id] });\n\n      const status = queue.getDependencyStatus(dependent.id);\n      expect(status.resolved).toBe(false);\n      expect(status.dependencyStatuses).toHaveLength(2);\n\n      // Complete dep1\n      queue.getNextTask();\n      queue.completeTask(dep1.id);\n\n      const status2 = queue.getDependencyStatus(dependent.id);\n      expect(status2.resolved).toBe(false);\n\n      // Complete dep2\n      queue.getNextTask();\n      queue.completeTask(dep2.id);\n\n      const status3 = queue.getDependencyStatus(dependent.id);\n      expect(status3.resolved).toBe(true);\n    });\n  });\n\n  // ---- Phase 8: Concurrency Control ----\n  describe('Phase 8: Concurrency Control', () => {\n    it('should default to unlimited concurrency', () => {\n      queue.addTask({ payload: 'a' });\n      const concurrency = queue.getConcurrency();\n      expect(concurrency.limit).toBe(0);\n    });\n\n    it('should enforce concurrency limit', () => {\n      queue.setConcurrency('default', 2);\n      queue.addTask({ payload: 'a' });\n      queue.addTask({ payload: 'b' });\n      queue.addTask({ payload: 'c' });\n\n      const t1 = queue.getNextTask();\n      const t2 = queue.getNextTask();\n      expect(t1).not.toBeNull();\n      expect(t2).not.toBeNull();\n\n      // Third should be blocked\n      expect(queue.getNextTask()).toBeNull();\n\n      // Complete one, third should be available\n      queue.completeTask(t1!.id);\n      const t3 = queue.getNextTask();\n      expect(t3).not.toBeNull();\n    });\n\n    it('should free slot on task failure', () => {\n      queue.setConcurrency('default', 1);\n      queue.addTask({ payload: 'a', maxRetries: 1, backoffDelay: 0 });\n      queue.addTask({ payload: 'b' });\n\n      const t1 = queue.getNextTask()!;\n      expect(queue.getNextTask()).toBeNull(); // limited to 1\n\n      queue.failTask(t1.id, 'fail'); // frees a slot (task goes to DLQ since maxRetries=1)\n      const t2 = queue.getNextTask();\n      expect(t2?.payload).toBe('b');\n    });\n\n    it('should query concurrency state', () => {\n      queue.setConcurrency('default', 3);\n      queue.addTask({ payload: 'a' });\n      queue.addTask({ payload: 'b' });\n\n      queue.getNextTask();\n\n      const state = queue.getConcurrency('default');\n      expect(state.limit).toBe(3);\n      expect(state.active).toBe(1);\n    });\n\n    it('should still respect priority with concurrency', () => {\n      queue.setConcurrency('default', 1);\n      queue.addTask({ payload: 'low', priority: 10 });\n      queue.addTask({ payload: 'high', priority: 1 });\n\n      const task = queue.getNextTask();\n      expect(task?.payload).toBe('high');\n    });\n  });\n\n  // ---- Phase 9: Progress Tracking and Cancellation ----\n  describe('Phase 9: Progress Tracking and Cancellation', () => {\n    it('should update and query progress', () => {\n      const task = queue.addTask({ payload: 'test' });\n      queue.getNextTask();\n\n      queue.updateProgress(task.id, 50, 'halfway');\n      const progress = queue.getProgress(task.id);\n      expect(progress.progress).toBe(50);\n      expect(progress.message).toBe('halfway');\n    });\n\n    it('should reject invalid progress values', () => {\n      const task = queue.addTask({ payload: 'test' });\n      queue.getNextTask();\n      expect(() => queue.updateProgress(task.id, -1)).toThrow();\n      expect(() => queue.updateProgress(task.id, 101)).toThrow();\n    });\n\n    it('should notify progress listeners', () => {\n      const task = queue.addTask({ payload: 'test' });\n      queue.getNextTask();\n\n      const updates: Array<{ progress: number; message?: string }> = [];\n      queue.onProgress(task.id, (update) => {\n        updates.push({ progress: update.progress, message: update.message });\n      });\n\n      queue.updateProgress(task.id, 25, 'quarter');\n      queue.updateProgress(task.id, 75, 'three quarters');\n\n      expect(updates).toHaveLength(2);\n      expect(updates[0].progress).toBe(25);\n      expect(updates[1].progress).toBe(75);\n    });\n\n    it('should support unsubscribing from progress', () => {\n      const task = queue.addTask({ payload: 'test' });\n      queue.getNextTask();\n\n      const updates: number[] = [];\n      const unsub = queue.onProgress(task.id, (u) => updates.push(u.progress));\n\n      queue.updateProgress(task.id, 25);\n      unsub();\n      queue.updateProgress(task.id, 50);\n\n      expect(updates).toHaveLength(1);\n      expect(updates[0]).toBe(25);\n    });\n\n    it('should cancel a pending task', () => {\n      const task = queue.addTask({ payload: 'test' });\n      queue.cancelTask(task.id);\n\n      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n      expect(queue.getNextTask()).toBeNull(); // not available\n    });\n\n    it('should cancel a processing task', () => {\n      const task = queue.addTask({ payload: 'test' });\n      queue.getNextTask();\n      queue.cancelTask(task.id);\n      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n    });\n\n    it('should not cancel completed or failed tasks', () => {\n      const task = queue.addTask({ payload: 'test' });\n      queue.getNextTask();\n      queue.completeTask(task.id);\n      expect(() => queue.cancelTask(task.id)).toThrow();\n    });\n\n    it('should not retry cancelled tasks', () => {\n      const task = queue.addTask({ payload: 'test', maxRetries: 3 });\n      queue.getNextTask();\n      queue.cancelTask(task.id);\n\n      // Task should be cancelled, not pending for retry\n      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n    });\n\n    it('should free concurrency slot when cancelling processing task', () => {\n      queue.setConcurrency('default', 1);\n      queue.addTask({ payload: 'a' });\n      queue.addTask({ payload: 'b' });\n\n      const t1 = queue.getNextTask()!;\n      expect(queue.getNextTask()).toBeNull();\n\n      queue.cancelTask(t1.id);\n      const t2 = queue.getNextTask();\n      expect(t2?.payload).toBe('b');\n    });\n  });\n\n  // ---- Phase 10: Recurring Tasks ----\n  describe('Phase 10: Recurring Tasks', () => {\n    it('should create a schedule', () => {\n      const schedule = queue.addSchedule({\n        cronExpression: '*/5 * * * *',\n        taskTemplate: { type: 'cleanup' },\n      });\n      expect(schedule.id).toBeDefined();\n      expect(schedule.cronExpression).toBe('*/5 * * * *');\n    });\n\n    it('should list active schedules', () => {\n      queue.addSchedule({ cronExpression: '*/5 * * * *', taskTemplate: {} });\n      queue.addSchedule({ cronExpression: '0 * * * *', taskTemplate: {} });\n      expect(queue.getSchedules()).toHaveLength(2);\n    });\n\n    it('should remove a schedule', () => {\n      const schedule = queue.addSchedule({ cronExpression: '*/5 * * * *', taskTemplate: {} });\n      queue.removeSchedule(schedule.id);\n      expect(queue.getSchedules()).toHaveLength(0);\n    });\n\n    it('should enqueue tasks on tick when due', () => {\n      queue.addSchedule({\n        cronExpression: '*/5 * * * *',\n        taskTemplate: { type: 'recurring' },\n      });\n\n      // Tick at minute 10 (divisible by 5)\n      const date = new Date(2024, 0, 1, 12, 10, 0, 0);\n      const tasks = queue.tick(date);\n      expect(tasks).toHaveLength(1);\n      expect(tasks[0].payload).toEqual({ type: 'recurring' });\n    });\n\n    it('should not enqueue tasks when not due', () => {\n      queue.addSchedule({\n        cronExpression: '*/5 * * * *',\n        taskTemplate: {},\n      });\n\n      // Tick at minute 3 (not divisible by 5)\n      const date = new Date(2024, 0, 1, 12, 3, 0, 0);\n      const tasks = queue.tick(date);\n      expect(tasks).toHaveLength(0);\n    });\n\n    it('should not double-fire for the same minute', () => {\n      queue.addSchedule({\n        cronExpression: '*/5 * * * *',\n        taskTemplate: {},\n      });\n\n      const date = new Date(2024, 0, 1, 12, 10, 0, 0);\n      queue.tick(date);\n      const tasks2 = queue.tick(new Date(2024, 0, 1, 12, 10, 30, 0)); // 30 seconds later, same minute\n      expect(tasks2).toHaveLength(0);\n    });\n\n    it('should support hourly schedules', () => {\n      queue.addSchedule({\n        cronExpression: '0 * * * *',\n        taskTemplate: { type: 'hourly' },\n      });\n\n      // Minute 0 of any hour\n      const tasks = queue.tick(new Date(2024, 0, 1, 14, 0, 0, 0));\n      expect(tasks).toHaveLength(1);\n\n      // Minute 15 of the hour\n      const tasks2 = queue.tick(new Date(2024, 0, 1, 14, 15, 0, 0));\n      expect(tasks2).toHaveLength(0);\n    });\n\n    it('should support daily midnight schedules', () => {\n      queue.addSchedule({\n        cronExpression: '0 0 * * *',\n        taskTemplate: { type: 'daily' },\n      });\n\n      const tasks = queue.tick(new Date(2024, 0, 1, 0, 0, 0, 0));\n      expect(tasks).toHaveLength(1);\n\n      const tasks2 = queue.tick(new Date(2024, 0, 1, 12, 0, 0, 0));\n      expect(tasks2).toHaveLength(0);\n    });\n\n    it('should reject invalid cron expressions', () => {\n      expect(() => queue.addSchedule({ cronExpression: 'invalid', taskTemplate: {} })).toThrow();\n    });\n\n    it('recurring tasks are subject to queue rules', () => {\n      queue.addSchedule({\n        cronExpression: '*/5 * * * *',\n        taskTemplate: { type: 'recurring' },\n        queue: 'myqueue',\n        priority: 2,\n      });\n\n      const tasks = queue.tick(new Date(2024, 0, 1, 12, 10, 0));\n      expect(tasks[0].queue).toBe('myqueue');\n      expect(tasks[0].priority).toBe(2);\n    });\n  });\n\n  // ---- Phase 11: Middleware Pipeline ----\n  describe('Phase 11: Middleware Pipeline', () => {\n    it('should execute handler when no middleware', async () => {\n      let handled = false;\n      queue.setHandler('default', () => { handled = true; });\n\n      const task = queue.addTask({ payload: 'test' });\n      queue.getNextTask();\n      await queue.processTask(task.id);\n      expect(handled).toBe(true);\n    });\n\n    it('should execute middleware in order', async () => {\n      const order: number[] = [];\n\n      queue.use('default', async (_task, next) => {\n        order.push(1);\n        await next();\n      });\n      queue.use('default', async (_task, next) => {\n        order.push(2);\n        await next();\n      });\n      queue.setHandler('default', () => { order.push(3); });\n\n      const task = queue.addTask({ payload: 'test' });\n      queue.getNextTask();\n      await queue.processTask(task.id);\n      expect(order).toEqual([1, 2, 3]);\n    });\n\n    it('should skip processing if middleware does not call next', async () => {\n      let handlerCalled = false;\n\n      queue.use('default', async (_task, _next) => {\n        // Intentionally not calling next\n      });\n      queue.setHandler('default', () => { handlerCalled = true; });\n\n      const task = queue.addTask({ payload: 'test' });\n      queue.getNextTask();\n      await queue.processTask(task.id);\n      expect(handlerCalled).toBe(false);\n    });\n\n    it('should allow middleware to modify task', async () => {\n      queue.use('default', async (task, next) => {\n        const existing = task.payload as Record<string, unknown>;\n        task.payload = { ...existing, modified: true };\n        await next();\n      });\n\n      let receivedPayload: Record<string, unknown> | undefined;\n      queue.setHandler('default', (task) => {\n        receivedPayload = task.payload as Record<string, unknown>;\n      });\n\n      const task = queue.addTask({ payload: { data: 'test' } });\n      queue.getNextTask();\n      await queue.processTask(task.id);\n      expect(receivedPayload).toEqual({ data: 'test', modified: true });\n    });\n\n    it('should fail task if middleware throws', async () => {\n      queue.use('default', async () => {\n        throw new Error('middleware error');\n      });\n\n      const task = queue.addTask({ payload: 'test' });\n      queue.getNextTask();\n\n      await expect(queue.processTask(task.id)).rejects.toThrow('middleware error');\n      // Task should be failed (or in retry)\n      const updated = queue.getTask(task.id)!;\n      expect(updated.status === 'pending' || updated.status === 'failed').toBe(true);\n    });\n\n    it('should have independent middleware per queue', async () => {\n      const calls: string[] = [];\n\n      queue.use('q1', async (_task, next) => { calls.push('q1-mw'); await next(); });\n      queue.use('q2', async (_task, next) => { calls.push('q2-mw'); await next(); });\n      queue.setHandler('q1', () => { calls.push('q1-handler'); });\n      queue.setHandler('q2', () => { calls.push('q2-handler'); });\n\n      const t1 = queue.addTask({ payload: 'a', queue: 'q1' });\n      const t2 = queue.addTask({ payload: 'b', queue: 'q2' });\n\n      queue.getNextTask('q1');\n      await queue.processTask(t1.id);\n\n      queue.getNextTask('q2');\n      await queue.processTask(t2.id);\n\n      expect(calls).toEqual(['q1-mw', 'q1-handler', 'q2-mw', 'q2-handler']);\n    });\n  });\n\n  // ---- Phase 12: Graceful Shutdown ----\n  describe('Phase 12: Graceful Shutdown', () => {\n    it('should reject new tasks after shutdown', async () => {\n      await queue.shutdown();\n      expect(() => queue.addTask({ payload: 'test' })).toThrow();\n    });\n\n    it('should complete immediately if no processing tasks', async () => {\n      queue.addTask({ payload: 'pending' }); // pending, not processing\n      const result = await queue.shutdown();\n      expect(result.completed).toBe(0);\n      expect(result.forceCancelled).toBe(0);\n    });\n\n    it('should wait for processing tasks to complete', async () => {\n      const task = queue.addTask({ payload: 'test' });\n      queue.getNextTask();\n\n      // Complete the task after a short delay\n      setTimeout(() => {\n        queue.completeTask(task.id);\n      }, 50);\n\n      const result = await queue.shutdown(5000);\n      expect(result.completed).toBe(1);\n      expect(result.forceCancelled).toBe(0);\n    });\n\n    it('should force-cancel tasks on timeout', async () => {\n      const task = queue.addTask({ payload: 'test' });\n      queue.getNextTask();\n      // Don't complete the task\n\n      const result = await queue.shutdown(50); // very short timeout\n      expect(result.forceCancelled).toBe(1);\n      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n    });\n\n    it('should run shutdown callbacks', async () => {\n      let callbackRan = false;\n      queue.onShutdown(() => { callbackRan = true; });\n\n      await queue.shutdown();\n      expect(callbackRan).toBe(true);\n    });\n\n    it('should be safe to call shutdown multiple times', async () => {\n      const result1 = await queue.shutdown();\n      const result2 = await queue.shutdown();\n      expect(result1).toBe(result2);\n    });\n\n    it('should report shutdown duration', async () => {\n      const result = await queue.shutdown();\n      expect(typeof result.durationMs).toBe('number');\n      expect(result.durationMs).toBeGreaterThanOrEqual(0);\n    });\n  });\n});\n","structuredPatch":[{"oldStart":390,"oldLines":12,"newStart":390,"newLines":30,"lines":["       expect(() => queue.addTask({ payload: 'test', dependencies: ['fake-id'] })).toThrow();","     });"," ","-    it('should detect circular dependencies', () => {","+    it('should allow valid non-circular dependency chains', () => {","       const t1 = queue.addTask({ payload: 'a' });","       const t2 = queue.addTask({ payload: 'b', dependencies: [t1.id] });","       expect(() => queue.addTask({ payload: 'c', dependencies: [t2.id, t1.id] })).not.toThrow();","     });"," ","+    it('should support multiple dependencies', () => {","+      const t1 = queue.addTask({ payload: 'a' });","+      const t2 = queue.addTask({ payload: 'b' });","+      const t3 = queue.addTask({ payload: 'c', dependencies: [t1.id, t2.id] });","+","+      // t3 should not be available until both t1 and t2 are completed","+      expect(queue.getNextTask()?.id).toBe(t1.id);","+      queue.completeTask(t1.id);","+","+      // t3 still blocked because t2 not completed","+      const next = queue.getNextTask();","+      expect(next?.id).toBe(t2.id);","+      queue.completeTask(t2.id);","+","+      // Now t3 should be available","+      expect(queue.getNextTask()?.id).toBe(t3.id);","+    });","+","     it('should keep dependents blocked when dependency fails', () => {","       const dep = queue.addTask({ payload: 'dependency', maxRetries: 1, backoffDelay: 0 });","       queue.addTask({ payload: 'dependent', dependencies: [dep.id] });"]}],"use