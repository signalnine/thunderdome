+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Q7YWeH7sPYhc4oGYHx5H2u","type":"tool_result","content":"     1→import { Router } from 'express';\n     2→import { Role } from '../types.js';\n     3→import { Store, generateId } from '../store.js';\n     4→import { authMiddleware, AuthenticatedRequest } from '../middleware.js';\n     5→import { hasPermission } from '../permissions.js';\n     6→\n     7→const VALID_ROLES: Role[] = ['viewer', 'editor', 'owner'];\n     8→\n     9→export function sharingRoutes(store: Store): Router {\n    10→  const router = Router();\n    11→\n    12→  router.use(authMiddleware(store));\n    13→\n    14→  // Share a resource\n    15→  router.post('/:resourceType/:resourceId/share', (req: AuthenticatedRequest, res) => {\n    16→    const userId = req.userId!;\n    17→    const { resourceType, resourceId } = req.params;\n    18→    const { targetUserId, role } = req.body;\n    19→\n    20→    // Validate resource type\n    21→    if (resourceType !== 'folders' && resourceType !== 'documents') {\n    22→      res.status(400).json({ error: 'Invalid resource type. Use \"folders\" or \"documents\"' });\n    23→      return;\n    24→    }\n    25→\n    26→    const normalizedType = resourceType === 'folders' ? 'folder' : 'document';\n    27→\n    28→    // Validate role\n    29→    if (!role || !VALID_ROLES.includes(role)) {\n    30→      res.status(400).json({ error: 'Invalid role. Use \"viewer\", \"editor\", or \"owner\"' });\n    31→      return;\n    32→    }\n    33→\n    34→    // Validate target user\n    35→    if (!targetUserId) {\n    36→      res.status(400).json({ error: 'Target user ID is required' });\n    37→      return;\n    38→    }\n    39→\n    40→    const targetUser = store.users.get(String(targetUserId));\n    41→    if (!targetUser) {\n    42→      res.status(404).json({ error: 'Target user not found' });\n    43→      return;\n    44→    }\n    45→\n    46→    // Check resource exists\n    47→    if (normalizedType === 'folder') {\n    48→      const folder = store.folders.get(resourceId);\n    49→      if (!folder) {\n    50→        res.status(404).json({ error: 'Folder not found' });\n    51→        return;\n    52→      }\n    53→    } else {\n    54→      const doc = store.documents.get(resourceId);\n    55→      if (!doc) {\n    56→        res.status(404).json({ error: 'Document not found' });\n    57→        return;\n    58→      }\n    59→    }\n    60→\n    61→    // Check if user can share (needs editor or owner)\n    62→    if (!hasPermission(store, userId, normalizedType, resourceId, 'editor')) {\n    63→      res.status(403).json({ error: 'Insufficient permissions to share' });\n    64→      return;\n    65→    }\n    66→\n    67→    // Only owners can grant owner role\n    68→    if (role === 'owner' && !hasPermission(store, userId, normalizedType, resourceId, 'owner')) {\n    69→      res.status(403).json({ error: 'Only owners can grant owner role' });\n    70→      return;\n    71→    }\n    72→\n    73→    // Check if permission already exists and update it\n    74→    const existing = store.permissions.find(\n    75→      p =>\n    76→        p.userId === String(targetUserId) &&\n    77→        p.resourceType === normalizedType &&\n    78→        p.resourceId === resourceId\n    79→    );\n    80→\n    81→    if (existing) {\n    82→      existing.role = role;\n    83→    } else {\n    84→      store.permissions.push({\n    85→        id: generateId(store),\n    86→        resourceType: normalizedType,\n    87→        resourceId,\n    88→        userId: String(targetUserId),\n    89→        role,\n    90→      });\n    91→    }\n    92→\n    93→    // Log activity\n    94→    store.activity.push({\n    95→      id: generateId(store),\n    96→      action: 'resource_shared',\n    97→      userId,\n    98→      resourceType: normalizedType,\n    99→      resourceId,\n   100→      timestamp: new Date().toISOString(),\n   101→      details: `Shared with user ${targetUserId} as ${role}`,\n   102→    });\n   103→\n   104→    res.status(200).json({ message: 'Resource shared successfully', resourceType: normalizedType, resourceId, targetUserId: String(targetUserId), role });\n   105→  });\n   106→\n   107→  return router;\n   108→}\n   109→"}]},"parent_tool_use_id":"toolu_01L7mWEwRJHtsQfeDzNvD3GS","session_id":"60187005-1346-4355-89d9-93507e669165","uuid":"f2dbf072-7ad7-4d12-8a94-301bdde16047"}
