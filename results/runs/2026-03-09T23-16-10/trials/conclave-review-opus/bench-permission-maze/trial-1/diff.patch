+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01FaebAwtQcEaeXAYwWhu6G7","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01EfK8B86zPwSUB4XQn6B8o9","name":"Write","input":{"file_path":"/workspace/src/permissions.ts","content":"import { Role } from './types.js';\nimport { Store } from './store.js';\n\nconst ROLE_LEVELS: Record<Role, number> = {\n  viewer: 1,\n  editor: 2,\n  owner: 3,\n};\n\nexport function getEffectiveRole(\n  store: Store,\n  userId: string,\n  resourceType: 'folder' | 'document',\n  resourceId: string\n): Role | null {\n  let bestRole: Role | null = null;\n  let bestLevel = 0;\n\n  // Check direct permissions on the resource\n  for (const perm of store.permissions) {\n    if (\n      perm.userId === userId &&\n      perm.resourceType === resourceType &&\n      perm.resourceId === resourceId\n    ) {\n      const level = ROLE_LEVELS[perm.role];\n      if (level > bestLevel) {\n        bestLevel = level;\n        bestRole = perm.role;\n      }\n    }\n  }\n\n  // If the resource is a document, check permissions on its folder hierarchy\n  if (resourceType === 'document') {\n    const doc = store.documents.get(resourceId);\n    if (doc) {\n      const folderRole = getEffectiveRole(store, userId, 'folder', doc.folderId);\n      if (folderRole) {\n        const level = ROLE_LEVELS[folderRole];\n        if (level > bestLevel) {\n          bestLevel = level;\n          bestRole = folderRole;\n        }\n      }\n    }\n  }\n\n  // If the resource is a folder, check permissions on parent folders\n  if (resourceType === 'folder') {\n    const folder = store.folders.get(resourceId);\n    if (folder && folder.parentId) {\n      const parentRole = getEffectiveRole(store, userId, 'folder', folder.parentId);\n      if (parentRole) {\n        const level = ROLE_LEVELS[parentRole];\n        if (level > bestLevel) {\n          bestLevel = level;\n          bestRole = parentRole;\n        }\n      }\n    }\n  }\n\n  return bestRole;\n}\n\nexport function hasPermission(\n  store: Store,\n  userId: string,\n  resourceType: 'folder' | 'document',\n  resourceId: string,\n  requiredRole: Role\n): boolean {\n  const effective = getEffectiveRole(store, userId, resourceType, resourceId);\n  if (!effective) return false;\n  return ROLE_LEVELS[effective] >= ROLE_LEVELS[requiredRole];\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":367,"cache_read_input_tokens":21685,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":367},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"60187005-1346-4355-89d9-93507e669165","uuid":"2f220b02-8e65-4953-b940-f27656a5ee0b"}
