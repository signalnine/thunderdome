+import { Router } from 'express';
+import { Store } from '../store.js';
+import { authMiddleware, AuthenticatedRequest } from '../middleware.js';
+
+export function activityRoutes(store: Store): Router {
+  const router = Router();
+
+  router.use(authMiddleware(store));
+
+  // Get activity log
+  router.get('/', (req: AuthenticatedRequest, res) => {
+    const userId = req.userId!;
+    const { resourceType, resourceId } = req.query;
+
+    let entries = [...store.activity];
+
+    // Filter by resource type and id if provided
+    if (resourceType) {
+      entries = entries.filter(e => e.resourceType === resourceType);
+    }
+    if (resourceId) {
+      entries = entries.filter(e => e.resourceId === String(resourceId));
+    }
+
+    // Only show activity for resources the user has access to or that they performed
+    // For simplicity, show all activity to authenticated users
+    // (the user can see all activity they are involved in)
+    void userId;
+
+    // Sort by timestamp descending
+    entries.sort((a, b) => new Date(b.timestamp).getTime() - new Date(a.timestamp).getTime());
+
+    res.status(200).json(entries);
+  });
+
+  return router;
+}
