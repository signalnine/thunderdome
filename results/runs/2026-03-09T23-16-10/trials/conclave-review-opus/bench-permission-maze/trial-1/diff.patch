+++ b/src/routes/documents.ts
@@ -0,0 +1,175 @@
+import { Router } from 'express';
+import { Store, generateId } from '../store.js';
+import { authMiddleware, AuthenticatedRequest } from '../middleware.js';
+import { hasPermission } from '../permissions.js';
+
+export function documentRoutes(store: Store): Router {
+  const router = Router();
+
+  router.use(authMiddleware(store));
+
+  // Create document
+  router.post('/', (req: AuthenticatedRequest, res) => {
+    const userId = req.userId!;
+    const { title, content, folderId } = req.body;
+
+    if (!title || typeof title !== 'string') {
+      res.status(400).json({ error: 'Document title is required' });
+      return;
+    }
+
+    if (content === undefined || content === null) {
+      res.status(400).json({ error: 'Document content is required' });
+      return;
+    }
+
+    if (!folderId) {
+      res.status(400).json({ error: 'Folder ID is required' });
+      return;
+    }
+
+    const folder = store.folders.get(String(folderId));
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    // Need at least editor on folder to create documents
+    if (!hasPermission(store, userId, 'folder', String(folderId), 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions on folder' });
+      return;
+    }
+
+    const id = generateId(store);
+    const now = new Date().toISOString();
+    const doc = {
+      id,
+      title,
+      content: String(content),
+      folderId: String(folderId),
+      ownerId: userId,
+      createdAt: now,
+      updatedAt: now,
+    };
+
+    store.documents.set(id, doc);
+
+    // Add owner permission
+    store.permissions.push({
+      id: generateId(store),
+      resourceType: 'document',
+      resourceId: id,
+      userId,
+      role: 'owner',
+    });
+
+    // Log activity
+    store.activity.push({
+      id: generateId(store),
+      action: 'document_created',
+      userId,
+      resourceType: 'document',
+      resourceId: id,
+      timestamp: now,
+    });
+
+    res.status(201).json(doc);
+  });
+
+  // Get document
+  router.get('/:id', (req: AuthenticatedRequest, res) => {
+    const userId = req.userId!;
+    const docId = req.params.id;
+
+    const doc = store.documents.get(docId);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'document', docId, 'viewer')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    res.status(200).json(doc);
+  });
+
+  // Update document
+  router.put('/:id', (req: AuthenticatedRequest, res) => {
+    const userId = req.userId!;
+    const docId = req.params.id;
+
+    const doc = store.documents.get(docId);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'document', docId, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const { title, content } = req.body;
+    if (title !== undefined) {
+      if (typeof title !== 'string' || title.length === 0) {
+        res.status(400).json({ error: 'Title must be a non-empty string' });
+        return;
+      }
+      doc.title = title;
+    }
+    if (content !== undefined) {
+      doc.content = String(content);
+    }
+    doc.updatedAt = new Date().toISOString();
+
+    // Log activity
+    store.activity.push({
+      id: generateId(store),
+      action: 'document_updated',
+      userId,
+      resourceType: 'document',
+      resourceId: docId,
+      timestamp: doc.updatedAt,
+    });
+
+    res.status(200).json(doc);
+  });
+
+  // Delete document
+  router.delete('/:id', (req: AuthenticatedRequest, res) => {
+    const userId = req.userId!;
+    const docId = req.params.id;
+
+    const doc = store.documents.get(docId);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'document', docId, 'owner')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    store.documents.delete(docId);
+    store.permissions = store.permissions.filter(
+      p => !(p.resourceType === 'document' && p.resourceId === docId)
+    );
+
+    // Log activity
+    store.activity.push({
+      id: generateId(store),
+      action: 'document_deleted',
+      userId,
+      resourceType: 'document',
+      resourceId: docId,
+      timestamp: new Date().toISOString(),
+    });
+
+    res.status(204).send();
+  });
+
+  return router;
+}
diff --git a/src/routes/folders.ts b/src/routes/folders.ts
new file mode 100644
index 0000000..c914145
--- /dev/null
+++ b/src/routes/folders.ts
@@ -0,0 +1,208 @@
+import { Router } from 'express';
+import { Store, generateId } from '../store.js';
+import { authMiddleware, AuthenticatedRequest } from '../middleware.js';
+import { hasPermission } from '../permissions.js';
+
+function wouldCreateCycle(store: Store, folderId: string, proposedParentId: string): boolean {
+  let currentId: string | null = proposedParentId;
+  while (currentId !== null) {
+    if (currentId === folderId) return true;
+    const folder = store.folders.get(currentId);
+    if (!folder) break;
+    currentId = folder.parentId;
+  }
+  return false;
+}
+
+export function folderRoutes(store: Store): Router {
+  const router = Router();
+
+  router.use(authMiddleware(store));
+
+  // Create folder
+  router.post('/', (req: AuthenticatedRequest, res) => {
+    const userId = req.userId!;
+    const { name, parentId } = req.body;
+
+    if (!name || typeof name !== 'string') {
+      res.status(400).json({ error: 'Folder name is required' });
+      return;
+    }
+
+    // Validate parent exists if provided
+    if (parentId !== undefined && parentId !== null) {
+      const parent = store.folders.get(String(parentId));
+      if (!parent) {
+        res.status(404).json({ error: 'Parent folder not found' });
+        return;
+      }
+      // Need at least editor on parent to create child folder
+      if (!hasPermission(store, userId, 'folder', String(parentId), 'editor')) {
+        res.status(403).json({ error: 'Insufficient permissions on parent folder' });
+        return;
+      }
+    }
+
+    const id = generateId(store);
+    const folder = {
+      id,
+      name,
+      parentId: parentId !== undefined && parentId !== null ? String(parentId) : null,
+      ownerId: userId,
+      createdAt: new Date().toISOString(),
+    };
+
+    store.folders.set(id, folder);
+
+    // Add owner permission
+    store.permissions.push({
+      id: generateId(store),
+      resourceType: 'folder',
+      resourceId: id,
+      userId,
+      role: 'owner',
+    });
+
+    res.status(201).json(folder);
+  });
+
+  // Get folder
+  router.get('/:id', (req: AuthenticatedRequest, res) => {
+    const userId = req.userId!;
+    const folderId = req.params.id;
+
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'folder', folderId, 'viewer')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    // Get child folders
+    const children: typeof folder[] = [];
+    for (const f of store.folders.values()) {
+      if (f.parentId === folderId) {
+        children.push(f);
+      }
+    }
+
+    // Get documents in folder
+    const documents: { id: string; title: string; createdAt: string; updatedAt: string }[] = [];
+    for (const doc of store.documents.values()) {
+      if (doc.folderId === folderId) {
+        documents.push({ id: doc.id, title: doc.title, createdAt: doc.createdAt, updatedAt: doc.updatedAt });
+      }
+    }
+
+    res.status(200).json({ ...folder, children, documents });
+  });
+
+  // Update folder
+  router.put('/:id', (req: AuthenticatedRequest, res) => {
+    const userId = req.userId!;
+    const folderId = req.params.id;
+
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'folder', folderId, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const { name, parentId } = req.body;
+    if (name !== undefined) {
+      if (typeof name !== 'string' || name.length === 0) {
+        res.status(400).json({ error: 'Folder name must be a non-empty string' });
+        return;
+      }
+      folder.name = name;
+    }
+
+    if (parentId !== undefined) {
+      if (parentId !== null) {
+        const newParentId = String(parentId);
+        const parent = store.folders.get(newParentId);
+        if (!parent) {
+          res.status(404).json({ error: 'Parent folder not found' });
+          return;
+        }
+        // Prevent circular references (including self-reference)
+        if (wouldCreateCycle(store, folderId, newParentId)) {
+          res.status(400).json({ error: 'Cannot move folder: would create circular reference' });
+          return;
+        }
+        // Check permission on destination folder
+        if (!hasPermission(store, userId, 'folder', newParentId, 'editor')) {
+          res.status(403).json({ error: 'Insufficient permissions on destination folder' });
+          return;
+        }
+        folder.parentId = newParentId;
+      } else {
+        folder.parentId = null;
+      }
+    }
+
+    res.status(200).json(folder);
+  });
+
+  // Delete folder
+  router.delete('/:id', (req: AuthenticatedRequest, res) => {
+    const userId = req.userId!;
+    const folderId = req.params.id;
+
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'folder', folderId, 'owner')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    // Delete folder and all its contents recursively
+    deleteFolderRecursive(store, folderId);
+
+    res.status(204).send();
+  });
+
+  return router;
+}
+
+function deleteFolderRecursive(store: Store, folderId: string): void {
+  // Collect child folder IDs first to avoid mutating during iteration
+  const childIds = [...store.folders.values()]
+    .filter(f => f.parentId === folderId)
+    .map(f => f.id);
+  for (const childId of childIds) {
+    deleteFolderRecursive(store, childId);
+  }
+
+  // Collect document IDs first to avoid mutating during iteration
+  const docIds = [...store.documents.values()]
+    .filter(d => d.folderId === folderId)
+    .map(d => d.id);
+  for (const docId of docIds) {
+    store.documents.delete(docId);
+    store.permissions = store.permissions.filter(
+      p => !(p.resourceType === 'document' && p.resourceId === docId)
+    );
+  }
+
+  // Delete the folder itself
+  store.folders.delete(folderId);
+
+  // Remove folder permissions
+  store.permissions = store.permissions.filter(
+    p => !(p.resourceType === 'folder' && p.resourceId === folderId)
+  );
+}
diff --git a/src/routes/sharing.ts b/src/routes/sharing.ts
new file mode 100644
index 0000000..364c1b3
--- /dev/null
+++ b/src/routes/sharing.ts
@@ -0,0 +1,108 @@
+import { Router } from 'express';
+import { Role } from '../types.js';
+import { Store, generateId } from '../store.js';
+import { authMiddleware, AuthenticatedRequest } from '../middleware.js';
+import { hasPermission } from '../permissions.js';
+
+const VALID_ROLES: Role[] = ['viewer', 'editor', 'owner'];
+
+export function sharingRoutes(store: Store): Router {
+  const router = Router();
+
+  router.use(authMiddleware(store));
+
+  // Share a resource
+  router.post('/:resourceType/:resourceId/share', (req: AuthenticatedRequest, res) => {
+    const userId = req.userId!;
+    const { resourceType, resourceId } = req.params;
+    const { targetUserId, role } = req.body;
+
+    // Validate resource type
+    if (resourceType !== 'folders' && resourceType !== 'documents') {
+      res.status(400).json({ error: 'Invalid resource type. Use "folders" or "documents"' });
+      return;
+    }
+
+    const normalizedType = resourceType === 'folders' ? 'folder' : 'document';
+
+    // Validate role
+    if (!role || !VALID_ROLES.includes(role)) {
+      res.status(400).json({ error: 'Invalid role. Use "viewer", "editor", or "owner"' });
+      return;
+    }
+
+    // Validate target user
+    if (!targetUserId) {
+      res.status(400).json({ error: 'Target user ID is required' });
+      return;
+    }
+
+    const targetUser = store.users.get(String(targetUserId));
+    if (!targetUser) {
+      res.status(404).json({ error: 'Target user not found' });
+      return;
+    }
+
+    // Check resource exists
+    if (normalizedType === 'folder') {
+      const folder = store.folders.get(resourceId);
+      if (!folder) {
+        res.status(404).json({ error: 'Folder not found' });
+        return;
+      }
+    } else {
+      const doc = store.documents.get(resourceId);
+      if (!doc) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+    }
+
+    // Check if user can share (needs editor or owner)
+    if (!hasPermission(store, userId, normalizedType, resourceId, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions to share' });
+      return;
+    }
+
+    // Only owners can grant owner role
+    if (role === 'owner' && !hasPermission(store, userId, normalizedType, resourceId, 'owner')) {
+      res.status(403).json({ error: 'Only owners can grant owner role' });
+      return;
+    }
+
+    // Check if permission already exists and update it
+    const existing = store.permissions.find(
+      p =>
+        p.userId === String(targetUserId) &&
+        p.resourceType === normalizedType &&
+        p.resourceId === resourceId
+    );
+
+    if (existing) {
+      existing.role = role;
+    } else {
+      store.permissions.push({
+        id: generateId(store),
+        resourceType: normalizedType,
+        resourceId,
+        userId: String(targetUserId),
+        role,
+      });
+    }
+
+    // Log activity
+    store.activity.push({
+      id: generateId(store),
+      action: 'resource_shared',
+      userId,
+      resourceType: normalizedType,
+      resourceId,
+      timestamp: new Date().toISOString(),
+      details: `Shared with user ${targetUserId} as ${role}`,
+    });
+
+    res.status(200).json({ message: 'Resource shared successfully', resourceType: normalizedType, resourceId, targetUserId: String(targetUserId), role });
+  });
+
+  return router;
+}
diff --git a/src/store.ts b/src/store.ts
new file mode 100644
index 0000000..5f194dd
--- /dev/null
+++ b/src/store.ts
@@ -0,0 +1,25 @@
+import { User, Folder, Document, Permission, ActivityEntry } from './types.js';
+
+export interface Store {
+  users: Map<string, User>;
+  folders: Map<string, Folder>;
+  documents: Map<string, Document>;
+  permissions: Permission[];
+  activity: ActivityEntry[];
+  nextId: number;
+}
+
+export function createStore(): Store {
+  return {
+    users: new Map(),
+    folders: new Map(),
+    documents: new Map(),
+    permissions: [],
+    activity: [],
+    nextId: 1,
+  };
+}
+
+export function generateId(store: Store): string {
+  return String(store.nextId++);
+}
