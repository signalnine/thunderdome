+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MWsohF3Vzk3TvHLsdN1D3X","type":"tool_result","content":"     1→import { Role } from './types.js';\n     2→import { Store } from './store.js';\n     3→\n     4→const ROLE_LEVELS: Record<Role, number> = {\n     5→  viewer: 1,\n     6→  editor: 2,\n     7→  owner: 3,\n     8→};\n     9→\n    10→export function getEffectiveRole(\n    11→  store: Store,\n    12→  userId: string,\n    13→  resourceType: 'folder' | 'document',\n    14→  resourceId: string\n    15→): Role | null {\n    16→  let bestRole: Role | null = null;\n    17→  let bestLevel = 0;\n    18→\n    19→  // Check direct permissions on the resource\n    20→  for (const perm of store.permissions) {\n    21→    if (\n    22→      perm.userId === userId &&\n    23→      perm.resourceType === resourceType &&\n    24→      perm.resourceId === resourceId\n    25→    ) {\n    26→      const level = ROLE_LEVELS[perm.role];\n    27→      if (level > bestLevel) {\n    28→        bestLevel = level;\n    29→        bestRole = perm.role;\n    30→      }\n    31→    }\n    32→  }\n    33→\n    34→  // If the resource is a document, check permissions on its folder hierarchy\n    35→  if (resourceType === 'document') {\n    36→    const doc = store.documents.get(resourceId);\n    37→    if (doc) {\n    38→      const folderRole = getEffectiveRole(store, userId, 'folder', doc.folderId);\n    39→      if (folderRole) {\n    40→        const level = ROLE_LEVELS[folderRole];\n    41→        if (level > bestLevel) {\n    42→          bestLevel = level;\n    43→          bestRole = folderRole;\n    44→        }\n    45→      }\n    46→    }\n    47→  }\n    48→\n    49→  // If the resource is a folder, check permissions on parent folders\n    50→  if (resourceType === 'folder') {\n    51→    const folder = store.folders.get(resourceId);\n    52→    if (folder && folder.parentId) {\n    53→      const parentRole = getEffectiveRole(store, userId, 'folder', folder.parentId);\n    54→      if (parentRole) {\n    55→        const level = ROLE_LEVELS[parentRole];\n    56→        if (level > bestLevel) {\n    57→          bestLevel = level;\n    58→          bestRole = parentRole;\n    59→        }\n    60→      }\n    61→    }\n    62→  }\n    63→\n    64→  return bestRole;\n    65→}\n    66→\n    67→export function hasPermission(\n    68→  store: Store,\n    69→  userId: string,\n    70→  resourceType: 'folder' | 'document',\n    71→  resourceId: string,\n    72→  requiredRole: Role\n    73→): boolean {\n    74→  const effective = getEffectiveRole(store, userId, resourceType, resourceId);\n    75→  if (!effective) return false;\n    76→  return ROLE_LEVELS[effective] >= ROLE_LEVELS[requiredRole];\n    77→}\n    78→"}]},"parent_tool_use_id":"toolu_01L7mWEwRJHtsQfeDzNvD3GS","session_id":"60187005-1346-4355-89d9-93507e669165","uuid":"efaf85bb-4913-492c-acbb-97fb4407ad53"}
