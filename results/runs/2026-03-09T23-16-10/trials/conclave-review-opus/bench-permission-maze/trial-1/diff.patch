+import { Role } from './types.js';
+import { Store } from './store.js';
+
+const ROLE_LEVELS: Record<Role, number> = {
+  viewer: 1,
+  editor: 2,
+  owner: 3,
+};
+
+export function getEffectiveRole(
+  store: Store,
+  userId: string,
+  resourceType: 'folder' | 'document',
+  resourceId: string
+): Role | null {
+  let bestRole: Role | null = null;
+  let bestLevel = 0;
+
+  // Check direct permissions on the resource
+  for (const perm of store.permissions) {
+    if (
+      perm.userId === userId &&
+      perm.resourceType === resourceType &&
+      perm.resourceId === resourceId
+    ) {
+      const level = ROLE_LEVELS[perm.role];
+      if (level > bestLevel) {
+        bestLevel = level;
+        bestRole = perm.role;
+      }
+    }
+  }
+
+  // If the resource is a document, check permissions on its folder hierarchy
+  if (resourceType === 'document') {
+    const doc = store.documents.get(resourceId);
+    if (doc) {
+      const folderRole = getEffectiveRole(store, userId, 'folder', doc.folderId);
+      if (folderRole) {
+        const level = ROLE_LEVELS[folderRole];
+        if (level > bestLevel) {
+          bestLevel = level;
+          bestRole = folderRole;
+        }
+      }
+    }
+  }
+
+  // If the resource is a folder, check permissions on parent folders
+  if (resourceType === 'folder') {
+    const folder = store.folders.get(resourceId);
+    if (folder && folder.parentId) {
+      const parentRole = getEffectiveRole(store, userId, 'folder', folder.parentId);
+      if (parentRole) {
+        const level = ROLE_LEVELS[parentRole];
+        if (level > bestLevel) {
+          bestLevel = level;
+          bestRole = parentRole;
+        }
+      }
+    }
+  }
+
+  return bestRole;
+}
+
+export function hasPermission(
+  store: Store,
+  userId: string,
+  resourceType: 'folder' | 'document',
+  resourceId: string,
+  requiredRole: Role
+): boolean {
+  const effective = getEffectiveRole(store, userId, resourceType, resourceId);
+  if (!effective) return false;
+  return ROLE_LEVELS[effective] >= ROLE_LEVELS[requiredRole];
+}
