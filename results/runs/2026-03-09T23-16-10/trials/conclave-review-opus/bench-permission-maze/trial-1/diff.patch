+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NfrHjcxynGKCFWUKBcB4He","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach } from 'vitest';\n     2→import request from 'supertest';\n     3→import { createApp } from './app.js';\n     4→import type { Express } from 'express';\n     5→\n     6→let app: Express;\n     7→\n     8→beforeEach(() => {\n     9→  app = createApp();\n    10→});\n    11→\n    12→// Helper to register + login and get token\n    13→async function createUser(username: string, password: string) {\n    14→  const regRes = await request(app)\n    15→    .post('/auth/register')\n    16→    .send({ username, password });\n    17→  const loginRes = await request(app)\n    18→    .post('/auth/login')\n    19→    .send({ username, password });\n    20→  return { userId: loginRes.body.userId, token: loginRes.body.token, regBody: regRes.body };\n    21→}\n    22→\n    23→// Helper to create a folder\n    24→async function createFolder(token: string, name: string, parentId?: string) {\n    25→  const body: Record<string, string> = { name };\n    26→  if (parentId !== undefined) body.parentId = parentId;\n    27→  const res = await request(app)\n    28→    .post('/folders')\n    29→    .set('Authorization', `Bearer ${token}`)\n    30→    .send(body);\n    31→  return res;\n    32→}\n    33→\n    34→// Helper to create a document\n    35→async function createDocument(token: string, title: string, content: string, folderId: string) {\n    36→  const res = await request(app)\n    37→    .post('/documents')\n    38→    .set('Authorization', `Bearer ${token}`)\n    39→    .send({ title, content, folderId });\n    40→  return res;\n    41→}\n    42→\n    43→// Helper to share\n    44→async function shareResource(\n    45→  token: string,\n    46→  resourceType: string,\n    47→  resourceId: string,\n    48→  targetUserId: string,\n    49→  role: string\n    50→) {\n    51→  return request(app)\n    52→    .post(`/${resourceType}/${resourceId}/share`)\n    53→    .set('Authorization', `Bearer ${token}`)\n    54→    .send({ targetUserId, role });\n    55→}\n    56→\n    57→describe('Auth', () => {\n    58→  it('should register a new user', async () => {\n    59→    const res = await request(app)\n    60→      .post('/auth/register')\n    61→      .send({ username: 'alice', password: 'pass123' });\n    62→    expect(res.status).toBe(201);\n    63→    expect(res.body.username).toBe('alice');\n    64→    expect(res.body.id).toBeDefined();\n    65→    expect(res.body.password).toBeUndefined();\n    66→  });\n    67→\n    68→  it('should reject duplicate username', async () => {\n    69→    await request(app).post('/auth/register').send({ username: 'alice', password: 'pass123' });\n    70→    const res = await request(app).post('/auth/register').send({ username: 'alice', password: 'pass456' });\n    71→    expect(res.status).toBe(409);\n    72→  });\n    73→\n    74→  it('should reject registration without username or password', async () => {\n    75→    const res1 = await request(app).post('/auth/register').send({ username: 'alice' });\n    76→    expect(res1.status).toBe(400);\n    77→    const res2 = await request(app).post('/auth/register').send({ password: 'pass' });\n    78→    expect(res2.status).toBe(400);\n    79→  });\n    80→\n    81→  it('should login and return token', async () => {\n    82→    await request(app).post('/auth/register').send({ username: 'alice', password: 'pass123' });\n    83→    const res = await request(app).post('/auth/login').send({ username: 'alice', password: 'pass123' });\n    84→    expect(res.status).toBe(200);\n    85→    expect(res.body.token).toBeDefined();\n    86→    expect(res.body.userId).toBeDefined();\n    87→  });\n    88→\n    89→  it('should reject login with wrong password', async () => {\n    90→    await request(app).post('/auth/register').send({ username: 'alice', password: 'pass123' });\n    91→    const res = await request(app).post('/auth/login').send({ username: 'alice', password: 'wrong' });\n    92→    expect(res.status).toBe(401);\n    93→  });\n    94→\n    95→  it('should reject login with non-existent user', async () => {\n    96→    const res = await request(app).post('/auth/login').send({ username: 'ghost', password: 'pass' });\n    97→    expect(res.status).toBe(401);\n    98→  });\n    99→});\n   100→\n   101→describe('Auth Middleware', () => {\n   102→  it('should reject requests without token', async () => {\n   103→    const res = await request(app).get('/folders/1');\n   104→    expect(res.status).toBe(401);\n   105→  });\n   106→\n   107→  it('should reject requests with invalid token', async () => {\n   108→    const res = await request(app)\n   109→      .get('/folders/1')\n   110→      .set('Authorization', 'Bearer invalid-token');\n   111→    expect(res.status).toBe(401);\n   112→  });\n   113→});\n   114→\n   115→describe('Folders', () => {\n   116→  it('should create a folder', async () => {\n   117→    const { token } = await createUser('alice', 'pass');\n   118→    const res = await createFolder(token, 'My Folder');\n   119→    expect(res.status).toBe(201);\n   120→    expect(res.body.name).toBe('My Folder');\n   121→    expect(res.body.parentId).toBeNull();\n   122→    expect(res.body.id).toBeDefined();\n   123→  });\n   124→\n   125→  it('should create a nested folder', async () => {\n   126→    const { token } = await createUser('alice', 'pass');\n   127→    const parent = await createFolder(token, 'Parent');\n   128→    const child = await createFolder(token, 'Child', parent.body.id);\n   129→    expect(child.status).toBe(201);\n   130→    expect(child.body.parentId).toBe(parent.body.id);\n   131→  });\n   132→\n   133→  it('should reject folder creation without name', async () => {\n   134→    const { token } = await createUser('alice', 'pass');\n   135→    const res = await request(app)\n   136→      .post('/folders')\n   137→      .set('Authorization', `Bearer ${token}`)\n   138→      .send({});\n   139→    expect(res.status).toBe(400);\n   140→  });\n   141→\n   142→  it('should get a folder with children and documents', async () => {\n   143→    const { token } = await createUser('alice', 'pass');\n   144→    const folder = await createFolder(token, 'Root');\n   145→    await createFolder(token, 'Sub', folder.body.id);\n   146→    await createDocument(token, 'Doc 1', 'content', folder.body.id);\n   147→\n   148→    const res = await request(app)\n   149→      .get(`/folders/${folder.body.id}`)\n   150→      .set('Authorization', `Bearer ${token}`);\n   151→    expect(res.status).toBe(200);\n   152→    expect(res.body.name).toBe('Root');\n   153→    expect(res.body.children).toHaveLength(1);\n   154→    expect(res.body.documents).toHaveLength(1);\n   155→  });\n   156→\n   157→  it('should update a folder name', async () => {\n   158→    const { token } = await createUser('alice', 'pass');\n   159→    const folder = await createFolder(token, 'Old Name');\n   160→    const res = await request(app)\n   161→      .put(`/folders/${folder.body.id}`)\n   162→      .set('Authorization', `Bearer ${token}`)\n   163→      .send({ name: 'New Name' });\n   164→    expect(res.status).toBe(200);\n   165→    expect(res.body.name).toBe('New Name');\n   166→  });\n   167→\n   168→  it('should delete a folder', async () => {\n   169→    const { token } = await createUser('alice', 'pass');\n   170→    const folder = await createFolder(token, 'Delete Me');\n   171→    const res = await request(app)\n   172→      .delete(`/folders/${folder.body.id}`)\n   173→      .set('Authorization', `Bearer ${token}`);\n   174→    expect(res.status).toBe(204);\n   175→\n   176→    const getRes = await request(app)\n   177→      .get(`/folders/${folder.body.id}`)\n   178→      .set('Authorization', `Bearer ${token}`);\n   179→    expect(getRes.status).toBe(404);\n   180→  });\n   181→\n   182→  it('should return 404 for non-existent folder', async () => {\n   183→    const { token } = await createUser('alice', 'pass');\n   184→    const res = await request(app)\n   185→      .get('/folders/999')\n   186→      .set('Authorization', `Bearer ${token}`);\n   187→    expect(res.status).toBe(404);\n   188→  });\n   189→\n   190→  it('should reject creating nested folder in non-existent parent', async () => {\n   191→    const { token } = await createUser('alice', 'pass');\n   192→    const res = await createFolder(token, 'Child', '999');\n   193→    expect(res.status).toBe(404);\n   194→  });\n   195→\n   196→  it('should delete folder recursively (children and docs)', async () => {\n   197→    const { token } = await createUser('alice', 'pass');\n   198→    const parent = await createFolder(token, 'Parent');\n   199→    const child = await createFolder(token, 'Child', parent.body.id);\n   200→    await createDocument(token, 'Doc', 'content', child.body.id);\n   201→\n   202→    const res = await request(app)\n   203→      .delete(`/folders/${parent.body.id}`)\n   204→      .set('Authorization', `Bearer ${token}`);\n   205→    expect(res.status).toBe(204);\n   206→\n   207→    const childRes = await request(app)\n   208→      .get(`/folders/${child.body.id}`)\n   209→      .set('Authorization', `Bearer ${token}`);\n   210→    expect(childRes.status).toBe(404);\n   211→  });\n   212→});\n   213→\n   214→describe('Documents', () => {\n   215→  it('should create a document in a folder', async () => {\n   216→    const { token } = await createUser('alice', 'pass');\n   217→    const folder = await createFolder(token, 'Folder');\n   218→    const res = await createDocument(token, 'My Doc', 'Hello world', folder.body.id);\n   219→    expect(res.status).toBe(201);\n   220→    expect(res.body.title).toBe('My Doc');\n   221→    expect(res.body.content).toBe('Hello world');\n   222→    expect(res.body.folderId).toBe(folder.body.id);\n   223→  });\n   224→\n   225→  it('should get a document', async () => {\n   226→    const { token } = await createUser('alice', 'pass');\n   227→    const folder = await createFolder(token, 'Folder');\n   228→    const doc = await createDocument(token, 'My Doc', 'Hello world', folder.body.id);\n   229→    const res = await request(app)\n   230→      .get(`/documents/${doc.body.id}`)\n   231→      .set('Authorization', `Bearer ${token}`);\n   232→    expect(res.status).toBe(200);\n   233→    expect(res.body.title).toBe('My Doc');\n   234→  });\n   235→\n   236→  it('should update a document', async () => {\n   237→    const { token } = await createUser('alice', 'pass');\n   238→    const folder = await createFolder(token, 'Folder');\n   239→    const doc = await createDocument(token, 'My Doc', 'Old content', folder.body.id);\n   240→    const res = await request(app)\n   241→      .put(`/documents/${doc.body.id}`)\n   242→      .set('Authorization', `Bearer ${token}`)\n   243→      .send({ title: 'Updated Doc', content: 'New content' });\n   244→    expect(res.status).toBe(200);\n   245→    expect(res.body.title).toBe('Updated Doc');\n   246→    expect(res.body.content).toBe('New content');\n   247→  });\n   248→\n   249→  it('should delete a document', async () => {\n   250→    const { token } = await createUser('alice', 'pass');\n   251→    const folder = await createFolder(token, 'Folder');\n   252→    const doc = await createDocument(token, 'My Doc', 'Content', folder.body.id);\n   253→    const res = await request(app)\n   254→      .delete(`/documents/${doc.body.id}`)\n   255→      .set('Authorization', `Bearer ${token}`);\n   256→    expect(res.status).toBe(204);\n   257→\n   258→    const getRes = await request(app)\n   259→      .get(`/documents/${doc.body.id}`)\n   260→      .set('Authorization', `Bearer ${token}`);\n   261→    expect(getRes.status).toBe(404);\n   262→  });\n   263→\n   264→  it('should reject creation without title', async () => {\n   265→    const { token } = await createUser('alice', 'pass');\n   266→    const folder = await createFolder(token, 'Folder');\n   267→    const res = await request(app)\n   268→      .post('/documents')\n   269→      .set('Authorization', `Bearer ${token}`)\n   270→      .send({ content: 'Hello', folderId: folder.body.id });\n   271→    expect(res.status).toBe(400);\n   272→  });\n   273→\n   274→  it('should reject creation without folderId', async () => {\n   275→    const { token } = await createUser('alice', 'pass');\n   276→    const res = await request(app)\n   277→      .post('/documents')\n   278→      .set('Authorization', `Bearer ${token}`)\n   279→      .send({ title: 'Doc', content: 'Hello' });\n   280→    expect(res.status).toBe(400);\n   281→  });\n   282→\n   283→  it('should reject creation in non-existent folder', async () => {\n   284→    const { token } = await createUser('alice', 'pass');\n   285→    const res = await createDocument(token, 'Doc', 'Content', '999');\n   286→    expect(res.status).toBe(404);\n   287→  });\n   288→\n   289→  it('should return 404 for non-existent document', async () => {\n   290→    const { token } = await createUser('alice', 'pass');\n   291→    const res = await request(app)\n   292→      .get('/documents/999')\n   293→      .set('Authorization', `Bearer ${token}`);\n   294→    expect(res.status).toBe(404);\n   295→  });\n   296→});\n   297→\n   298→describe('Sharing & Permissions', () => {\n   299→  it('should share a folder with another user as viewer', async () => {\n   300→    const { token: aliceToken } = await createUser('alice', 'pass');\n   301→    const { userId: bobId, token: bobToken } = await createUser('bob', 'pass');\n   302→    const folder = await createFolder(aliceToken, 'Shared Folder');\n   303→\n   304→    // Alice shares with Bob as viewer\n   305→    const shareRes = await shareResource(aliceToken, 'folders', folder.body.id, bobId, 'viewer');\n   306→    expect(shareRes.status).toBe(200);\n   307→\n   308→    // Bob can now read the folder\n   309→    const getRes = await request(app)\n   310→      .get(`/folders/${folder.body.id}`)\n   311→      .set('Authorization', `Bearer ${bobToken}`);\n   312→    expect(getRes.status).toBe(200);\n   313→\n   314→    // Bob cannot update the folder\n   315→    const updateRes = await request(app)\n   316→      .put(`/folders/${folder.body.id}`)\n   317→      .set('Authorization', `Bearer ${bobToken}`)\n   318→      .send({ name: 'Renamed' });\n   319→    expect(updateRes.status).toBe(403);\n   320→  });\n   321→\n   322→  it('should share a folder with another user as editor', async () => {\n   323→    const { token: aliceToken } = await createUser('alice', 'pass');\n   324→    const { userId: bobId, token: bobToken } = await createUser('bob', 'pass');\n   325→    const folder = await createFolder(aliceToken, 'Shared Folder');\n   326→\n   327→    await shareResource(aliceToken, 'folders', folder.body.id, bobId, 'editor');\n   328→\n   329→    // Bob can update the folder\n   330→    const updateRes = await request(app)\n   331→      .put(`/folders/${folder.body.id}`)\n   332→      .set('Authorization', `Bearer ${bobToken}`)\n   333→      .send({ name: 'Renamed' });\n   334→    expect(updateRes.status).toBe(200);\n   335→    expect(updateRes.body.name).toBe('Renamed');\n   336→\n   337→    // Bob cannot delete the folder\n   338→    const deleteRes = await request(app)\n   339→      .delete(`/folders/${folder.body.id}`)\n   340→      .set('Authorization', `Bearer ${bobToken}`);\n   341→    expect(deleteRes.status).toBe(403);\n   342→  });\n   343→\n   344→  it('should deny access to users without permission', async () => {\n   345→    const { token: aliceToken } = await createUser('alice', 'pass');\n   346→    const { token: bobToken } = await createUser('bob', 'pass');\n   347→    const folder = await createFolder(aliceToken, 'Private Folder');\n   348→\n   349→    const getRes = await request(app)\n   350→      .get(`/folders/${folder.body.id}`)\n   351→      .set('Authorization', `Bearer ${bobToken}`);\n   352→    expect(getRes.status).toBe(403);\n   353→  });\n   354→\n   355→  it('should share a document with another user', async () => {\n   356→    const { token: aliceToken } = await createUser('alice', 'pass');\n   357→    const { userId: bobId, token: bobToken } = await createUser('bob', 'pass');\n   358→    const folder = await createFolder(aliceToken, 'Folder');\n   359→    const doc = await createDocument(aliceToken, 'Doc', 'Content', folder.body.id);\n   360→\n   361→    await shareResource(aliceToken, 'documents', doc.body.id, bobId, 'viewer');\n   362→\n   363→    const getRes = await request(app)\n   364→      .get(`/documents/${doc.body.id}`)\n   365→      .set('Authorization', `Bearer ${bobToken}`);\n   366→    expect(getRes.status).toBe(200);\n   367→  });\n   368→\n   369→  it('should inherit folder permissions for documents', async () => {\n   370→    const { token: aliceToken } = await createUser('alice', 'pass');\n   371→    const { userId: bobId, token: bobToken } = await createUser('bob', 'pass');\n   372→    const folder = await createFolder(aliceToken, 'Shared Folder');\n   373→    const doc = await createDocument(aliceToken, 'Doc', 'Content', folder.body.id);\n   374→\n   375→    // Share the folder with Bob as editor\n   376→    await shareResource(aliceToken, 'folders', folder.body.id, bobId, 'editor');\n   377→\n   378→    // Bob should be able to read and edit the doc via folder permissions\n   379→    const getRes = await request(app)\n   380→      .get(`/documents/${doc.body.id}`)\n   381→      .set('Authorization', `Bearer ${bobToken}`);\n   382→    expect(getRes.status).toBe(200);\n   383→\n   384→    const updateRes = await request(app)\n   385→      .put(`/documents/${doc.body.id}`)\n   386→      .set('Authorization', `Bearer ${bobToken}`)\n   387→      .send({ content: 'Updated by Bob' });\n   388→    expect(updateRes.status).toBe(200);\n   389→  });\n   390→\n   391→  it('should inherit parent folder permissions for nested fol