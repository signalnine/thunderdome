+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01H49MsMYXgU3etWHS9NfkX6","type":"tool_result","content":"     1→import { Router } from 'express';\n     2→import { Store, generateId } from '../store.js';\n     3→import { authMiddleware, AuthenticatedRequest } from '../middleware.js';\n     4→import { hasPermission } from '../permissions.js';\n     5→\n     6→export function documentRoutes(store: Store): Router {\n     7→  const router = Router();\n     8→\n     9→  router.use(authMiddleware(store));\n    10→\n    11→  // Create document\n    12→  router.post('/', (req: AuthenticatedRequest, res) => {\n    13→    const userId = req.userId!;\n    14→    const { title, content, folderId } = req.body;\n    15→\n    16→    if (!title || typeof title !== 'string') {\n    17→      res.status(400).json({ error: 'Document title is required' });\n    18→      return;\n    19→    }\n    20→\n    21→    if (content === undefined || content === null) {\n    22→      res.status(400).json({ error: 'Document content is required' });\n    23→      return;\n    24→    }\n    25→\n    26→    if (!folderId) {\n    27→      res.status(400).json({ error: 'Folder ID is required' });\n    28→      return;\n    29→    }\n    30→\n    31→    const folder = store.folders.get(String(folderId));\n    32→    if (!folder) {\n    33→      res.status(404).json({ error: 'Folder not found' });\n    34→      return;\n    35→    }\n    36→\n    37→    // Need at least editor on folder to create documents\n    38→    if (!hasPermission(store, userId, 'folder', String(folderId), 'editor')) {\n    39→      res.status(403).json({ error: 'Insufficient permissions on folder' });\n    40→      return;\n    41→    }\n    42→\n    43→    const id = generateId(store);\n    44→    const now = new Date().toISOString();\n    45→    const doc = {\n    46→      id,\n    47→      title,\n    48→      content: String(content),\n    49→      folderId: String(folderId),\n    50→      ownerId: userId,\n    51→      createdAt: now,\n    52→      updatedAt: now,\n    53→    };\n    54→\n    55→    store.documents.set(id, doc);\n    56→\n    57→    // Add owner permission\n    58→    store.permissions.push({\n    59→      id: generateId(store),\n    60→      resourceType: 'document',\n    61→      resourceId: id,\n    62→      userId,\n    63→      role: 'owner',\n    64→    });\n    65→\n    66→    // Log activity\n    67→    store.activity.push({\n    68→      id: generateId(store),\n    69→      action: 'document_created',\n    70→      userId,\n    71→      resourceType: 'document',\n    72→      resourceId: id,\n    73→      timestamp: now,\n    74→    });\n    75→\n    76→    res.status(201).json(doc);\n    77→  });\n    78→\n    79→  // Get document\n    80→  router.get('/:id', (req: AuthenticatedRequest, res) => {\n    81→    const userId = req.userId!;\n    82→    const docId = req.params.id;\n    83→\n    84→    const doc = store.documents.get(docId);\n    85→    if (!doc) {\n    86→      res.status(404).json({ error: 'Document not found' });\n    87→      return;\n    88→    }\n    89→\n    90→    if (!hasPermission(store, userId, 'document', docId, 'viewer')) {\n    91→      res.status(403).json({ error: 'Insufficient permissions' });\n    92→      return;\n    93→    }\n    94→\n    95→    res.status(200).json(doc);\n    96→  });\n    97→\n    98→  // Update document\n    99→  router.put('/:id', (req: AuthenticatedRequest, res) => {\n   100→    const userId = req.userId!;\n   101→    const docId = req.params.id;\n   102→\n   103→    const doc = store.documents.get(docId);\n   104→    if (!doc) {\n   105→      res.status(404).json({ error: 'Document not found' });\n   106→      return;\n   107→    }\n   108→\n   109→    if (!hasPermission(store, userId, 'document', docId, 'editor')) {\n   110→      res.status(403).json({ error: 'Insufficient permissions' });\n   111→      return;\n   112→    }\n   113→\n   114→    const { title, content } = req.body;\n   115→    if (title !== undefined) {\n   116→      if (typeof title !== 'string' || title.length === 0) {\n   117→        res.status(400).json({ error: 'Title must be a non-empty string' });\n   118→        return;\n   119→      }\n   120→      doc.title = title;\n   121→    }\n   122→    if (content !== undefined) {\n   123→      doc.content = String(content);\n   124→    }\n   125→    doc.updatedAt = new Date().toISOString();\n   126→\n   127→    // Log activity\n   128→    store.activity.push({\n   129→      id: generateId(store),\n   130→      action: 'document_updated',\n   131→      userId,\n   132→      resourceType: 'document',\n   133→      resourceId: docId,\n   134→      timestamp: doc.updatedAt,\n   135→    });\n   136→\n   137→    res.status(200).json(doc);\n   138→  });\n   139→\n   140→  // Delete document\n   141→  router.delete('/:id', (req: AuthenticatedRequest, res) => {\n   142→    const userId = req.userId!;\n   143→    const docId = req.params.id;\n   144→\n   145→    const doc = store.documents.get(docId);\n   146→    if (!doc) {\n   147→      res.status(404).json({ error: 'Document not found' });\n   148→      return;\n   149→    }\n   150→\n   151→    if (!hasPermission(store, userId, 'document', docId, 'owner')) {\n   152→      res.status(403).json({ error: 'Insufficient permissions' });\n   153→      return;\n   154→    }\n   155→\n   156→    store.documents.delete(docId);\n   157→    store.permissions = store.permissions.filter(\n   158→      p => !(p.resourceType === 'document' && p.resourceId === docId)\n   159→    );\n   160→\n   161→    // Log activity\n   162→    store.activity.push({\n   163→      id: generateId(store),\n   164→      action: 'document_deleted',\n   165→      userId,\n   166→      resourceType: 'document',\n   167→      resourceId: docId,\n   168→      timestamp: new Date().toISOString(),\n   169→    });\n   170→\n   171→    res.status(204).send();\n   172→  });\n   173→\n   174→  return router;\n   175→}\n   17