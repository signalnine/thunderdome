@@ -0,0 +1,232 @@
+import { describe, it, expect, beforeEach, afterEach } from "vitest";
+import { TimeTracker } from "./tracker.js";
+import { mkdtempSync, rmSync, readFileSync } from "node:fs";
+import { join } from "node:path";
+import { tmpdir } from "node:os";
+
+let tmpDir: string;
+let filePath: string;
+
+beforeEach(() => {
+  tmpDir = mkdtempSync(join(tmpdir(), "tracker-test-"));
+  filePath = join(tmpDir, "data.json");
+});
+
+afterEach(() => {
+  rmSync(tmpDir, { recursive: true, force: true });
+});
+
+describe("TimeTracker", () => {
+  describe("start", () => {
+    it("should start a timer and return the entry", () => {
+      const tracker = new TimeTracker(filePath);
+      const entry = tracker.start("coding");
+      expect(entry.task).toBe("coding");
+      expect(entry.start).toBeTruthy();
+      expect(entry.stop).toBeNull();
+    });
+
+    it("should throw on empty task name", () => {
+      const tracker = new TimeTracker(filePath);
+      expect(() => tracker.start("")).toThrow("Task name cannot be empty");
+    });
+
+    it("should throw on whitespace-only task name", () => {
+      const tracker = new TimeTracker(filePath);
+      expect(() => tracker.start("   ")).toThrow("Task name cannot be empty");
+    });
+
+    it("should auto-stop previous timer when starting a new one", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("task1");
+      tracker.start("task2");
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(2);
+      expect(entries[0].stop).not.toBeNull();
+      expect(entries[1].stop).toBeNull();
+    });
+  });
+
+  describe("stop", () => {
+    it("should stop the running timer", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("coding");
+      const entry = tracker.stop();
+      expect(entry.task).toBe("coding");
+      expect(entry.stop).not.toBeNull();
+    });
+
+    it("should throw when no timer is running", () => {
+      const tracker = new TimeTracker(filePath);
+      expect(() => tracker.stop()).toThrow("No timer is currently running");
+    });
+
+    it("should throw when stopping after already stopped", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("coding");
+      tracker.stop();
+      expect(() => tracker.stop()).toThrow("No timer is currently running");
+    });
+  });
+
+  describe("persistence", () => {
+    it("should persist entries to file", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("coding");
+      tracker.stop();
+
+      const raw = readFileSync(filePath, "utf-8");
+      const data = JSON.parse(raw);
+      expect(data.entries).toHaveLength(1);
+      expect(data.entries[0].task).toBe("coding");
+    });
+
+    it("should load entries from file on construction", () => {
+      const tracker1 = new TimeTracker(filePath);
+      tracker1.start("coding");
+      tracker1.stop();
+
+      const tracker2 = new TimeTracker(filePath);
+      const entries = tracker2.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].task).toBe("coding");
+    });
+
+    it("should create parent directories if they don't exist", () => {
+      const deepPath = join(tmpDir, "a", "b", "c", "data.json");
+      const tracker = new TimeTracker(deepPath);
+      tracker.start("coding");
+      tracker.stop();
+
+      const raw = readFileSync(deepPath, "utf-8");
+      const data = JSON.parse(raw);
+      expect(data.entries).toHaveLength(1);
+    });
+  });
+
+  describe("getEntries", () => {
+    it("should return all entries when no filters provided", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("task1");
+      tracker.stop();
+      tracker.start("task2");
+      tracker.stop();
+      expect(tracker.getEntries()).toHaveLength(2);
+    });
+
+    it("should filter entries by date range", () => {
+      const tracker = new TimeTracker(filePath);
+
+      tracker.start("task1");
+      tracker.stop();
+      tracker.start("task2");
+      tracker.stop();
+
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(2);
+
+      // Use a 'to' date in the past to get zero entries
+      const ancient = new Date("2000-01-01");
+      expect(tracker.getEntries(undefined, ancient)).toHaveLength(0);
+
+      // Use a 'from' date in the future to get zero entries
+      const future = new Date("2099-01-01");
+      expect(tracker.getEntries(future)).toHaveLength(0);
+
+      // Use a 'from' date in the past to get all entries
+      expect(tracker.getEntries(ancient)).toHaveLength(2);
+
+      // Use a 'to' date in the future to get all entries
+      expect(tracker.getEntries(undefined, future)).toHaveLength(2);
+    });
+
+    it("should return a copy of entries array", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("task1");
+      tracker.stop();
+      const entries = tracker.getEntries();
+      entries.push({ task: "fake", start: "", stop: null });
+      expect(tracker.getEntries()).toHaveLength(1);
+    });
+  });
+
+  describe("getSummary", () => {
+    it("should sum durations per task name", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("coding");
+      tracker.stop();
+      tracker.start("coding");
+      tracker.stop();
+
+      const summary = tracker.getSummary();
+      expect(typeof summary["coding"]).toBe("number");
+      expect(summary["coding"]).toBeGreaterThanOrEqual(0);
+    });
+
+    it("should use current time for running tasks", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("coding");
+
+      const summary = tracker.getSummary();
+      expect(typeof summary["coding"]).toBe("number");
+      expect(summary["coding"]).toBeGreaterThanOrEqual(0);
+    });
+
+    it("should return separate entries for different task names", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("coding");
+      tracker.stop();
+      tracker.start("reviewing");
+      tracker.stop();
+
+      const summary = tracker.getSummary();
+      expect("coding" in summary).toBe(true);
+      expect("reviewing" in summary).toBe(true);
+    });
+  });
+
+  describe("unicode support", () => {
+    it("should handle emoji task names", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("🚀 deploying");
+      tracker.stop();
+
+      const tracker2 = new TimeTracker(filePath);
+      const entries = tracker2.getEntries();
+      expect(entries[0].task).toBe("🚀 deploying");
+    });
+
+    it("should handle CJK characters", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("编码工作");
+      tracker.stop();
+
+      const tracker2 = new TimeTracker(filePath);
+      expect(tracker2.getEntries()[0].task).toBe("编码工作");
+    });
+
+    it("should handle mixed unicode in task names", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("café ☕ работа 🎉");
+      tracker.stop();
+
+      const tracker2 = new TimeTracker(filePath);
+      expect(tracker2.getEntries()[0].task).toBe("café ☕ работа 🎉");
+    });
+  });
+
+  describe("getRunning", () => {
+    it("should return undefined when no timer is running", () => {
+      const tracker = new TimeTracker(filePath);
+      expect(tracker.getRunning()).toBeUndefined();
+    });
+
+    it("should return the running entry", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("coding");
+      const running = tracker.getRunning();
+      expect(running).toBeDefined();
+      expect(running!.task).toBe("coding");
+    });
+  });
+});
diff --git a/src/tracker.ts b/src/tracker.ts
new file mode 100644
index 0000000..8d5a56e
--- /dev/null
+++ b/src/tracker.ts
@@ -0,0 +1,114 @@
+import { readFileSync, writeFileSync, mkdirSync } from "node:fs";
+import { dirname } from "node:path";
+
+export interface TimeEntry {
+  task: string;
+  start: string;
+  stop: string | null;
+}
+
+interface StoreData {
+  entries: TimeEntry[];
+}
+
+export interface TimeSummary {
+  [task: string]: number;
+}
+
+export class TimeTracker {
+  private filePath: string;
+  private entries: TimeEntry[];
+
+  constructor(filePath: string) {
+    this.filePath = filePath;
+    this.entries = this.load();
+  }
+
+  private load(): TimeEntry[] {
+    try {
+      const raw = readFileSync(this.filePath, "utf-8");
+      const data: unknown = JSON.parse(raw);
+      if (
+        typeof data === "object" &&
+        data !== null &&
+        "entries" in data &&
+        Array.isArray((data as StoreData).entries)
+      ) {
+        return (data as StoreData).entries;
+      }
+      return [];
+    } catch {
+      return [];
+    }
+  }
+
+  private save(): void {
+    const dir = dirname(this.filePath);
+    mkdirSync(dir, { recursive: true });
+    const data: StoreData = { entries: this.entries };
+    writeFileSync(this.filePath, JSON.stringify(data, null, 2), "utf-8");
+  }
+
+  start(task: string): TimeEntry {
+    if (!task || task.trim().length === 0) {
+      throw new Error("Task name cannot be empty");
+    }
+
+    // Stop currently running timer if any
+    const running = this.getRunning();
+    if (running) {
+      running.stop = new Date().toISOString();
+    }
+
+    const entry: TimeEntry = {
+      task,
+      start: new Date().toISOString(),
+      stop: null,
+    };
+    this.entries.push(entry);
+    this.save();
+    return entry;
+  }
+
+  stop(): TimeEntry {
+    const running = this.getRunning();
+    if (!running) {
+      throw new Error("No timer is currently running");
+    }
+    running.stop = new Date().toISOString();
+    this.save();
+    return running;
+  }
+
+  getRunning(): TimeEntry | undefined {
+    return this.entries.find((e) => e.stop === null);
+  }
+
+  getEntries(from?: Date, to?: Date): TimeEntry[] {
+    let result = this.entries;
+    if (from || to) {
+      result = result.filter((entry) => {
+        const start = new Date(entry.start);
+        if (from && start < from) return false;
+        if (to && start > to) return false;
+        return true;
+      });
+    }
+    return result.map((e) => ({ ...e }));
+  }
+
+  getSummary(from?: Date, to?: Date): TimeSummary {
+    const entries = this.getEntries(from, to);
+    const summary: TimeSummary = {};
+    const now = new Date();
+
+    for (const entry of entries) {
+      const start = new Date(entry.start).getTime();
+      const end = entry.stop ? new Date(entry.stop).getTime() : now.getTime();
+      const duration = end - start;
+      summary[entry.task] = (summary[entry.task] ?? 0) + duration;
+    }
+
+    return summary;
+  }
+}
