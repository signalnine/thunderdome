er(filePath);\n   193→      const entries = tracker2.getEntries();\n   194→      expect(entries[0].task).toBe(\"🚀 deploying\");\n   195→    });\n   196→\n   197→    it(\"should handle CJK characters\", () => {\n   198→      const tracker = new TimeTracker(filePath);\n   199→      tracker.start(\"编码工作\");\n   200→      tracker.stop();\n   201→\n   202→      const tracker2 = new TimeTracker(filePath);\n   203→      expect(tracker2.getEntries()[0].task).toBe(\"编码工作\");\n   204→    });\n   205→\n   206→    it(\"should handle mixed unicode in task names\", () => {\n   207→      const tracker = new TimeTracker(filePath);\n   208→      tracker.start(\"café ☕ работа 🎉\");\n   209→      tracker.stop();\n   210→\n   211→      const tracker2 = new TimeTracker(filePath);\n   212→      expect(tracker2.getEntries()[0].task).toBe(\"café ☕ работа 🎉\");\n   213→    });\n   214→  });\n   215→\n   216→  describe(\"getRunning\", () => {\n   217→    it(\"should return undefined when no timer is running\", () => {\n   218→      const tracker = new TimeTracker(filePath);\n   219→      expect(tracker.getRunning()).toBeUndefined();\n   220→    });\n   221→\n   222→    it(\"should return the running entry\", () => {\n   223→      const tracker = new TimeTracker(filePath);\n   224→      tracker.start(\"coding\");\n   225→      const running = tracker.getRunning();\n   226→      expect(running).toBeDefined();\n   227→      expect(running!.task).toBe(\"coding\");\n   228→    });\n   229→  });\n   230→});\n   231→"}]},"parent_tool_use_id":"toolu_01AuNReFitox1f1MUJznrNhu","session_id":"53fc3bb9-e0c4-48ce-bdcf-20d554541c82","uuid":"6f416377-3849-4150-8b92-8ad5ed63ae0a"}
