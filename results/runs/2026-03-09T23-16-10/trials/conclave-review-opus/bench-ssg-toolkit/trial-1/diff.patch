+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Nh6okBKyqHp8T5ve5waPNR","type":"tool_result","content":"     1→import { Template } from './types.js';\n     2→\n     3→export function createDefaultTemplate(): Template {\n     4→  return {\n     5→    name: 'default',\n     6→    render: (content: string, data: Record<string, unknown>) => {\n     7→      return `<!DOCTYPE html>\n     8→<html>\n     9→<head>\n    10→  <meta charset=\"utf-8\">\n    11→  <title>${data.title || ''} | ${data.siteTitle || ''}</title>\n    12→</head>\n    13→<body>\n    14→  <article>\n    15→    <h1>${data.title || ''}</h1>\n    16→    ${data.date ? `<time>${data.date}</time>` : ''}\n    17→    <div class=\"content\">${content}</div>\n    18→  </article>\n    19→</body>\n    20→</html>`;\n    21→    }\n    22→  };\n    23→}\n    24→\n    25→export function createListTemplate(): Template {\n    26→  return {\n    27→    name: 'list',\n    28→    render: (content: string, data: Record<string, unknown>) => {\n    29→      return `<!DOCTYPE html>\n    30→<html>\n    31→<head>\n    32→  <meta charset=\"utf-8\">\n    33→  <title>${data.title || ''} | ${data.siteTitle || ''}</title>\n    34→</head>\n    35→<body>\n    36→  <h1>${data.title || ''}</h1>\n    37→  <div class=\"list\">${content}</div>\n    38→</body>\n    39→</html>`;\n    40→    }\n    41→  };\n    42→}\n    43→"}]},"parent_tool_use_id":"toolu_01Kc3Z8sNCtW9VZzU1TDjqXL","session_id":"e41ac24c-43f8-475c-b797-a61c96f046a7","uuid":"e35862e7-98c2-4755-b41a-7438247a7345"}
