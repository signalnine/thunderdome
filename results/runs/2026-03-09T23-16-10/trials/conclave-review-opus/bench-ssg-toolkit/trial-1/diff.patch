+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+function processAdmonitions(text: string): string {
+  return text.replace(/^:::\s*(\w+)\s*\n([\s\S]*?)^:::\s*$/gm, (_match, type: string, content: string) => {
+    return `<div class="admonition admonition-${type}">\n${content.trim()}\n</div>`;
+  });
+}
+
+function processFootnotes(text: string): { text: string; footnotes: Map<string, string> } {
+  const footnotes = new Map<string, string>();
+
+  // Extract footnote definitions
+  const withoutDefs = text.replace(/^\[\^(\d+)\]:\s*(.+)$/gm, (_match, id: string, note: string) => {
+    footnotes.set(id, note);
+    return '';
+  });
+
+  // Replace footnote references
+  const withRefs = withoutDefs.replace(/\[\^(\d+)\]/g, (_match, id: string) => {
+    return `<sup><a href="#fn-${id}">${id}</a></sup>`;
+  });
+
+  return { text: withRefs, footnotes };
+}
+
+function renderFootnoteSection(footnotes: Map<string, string>): string {
+  if (footnotes.size === 0) return '';
+  const items = Array.from(footnotes.entries())
+    .map(([id, note]) => `<li id="fn-${id}">${note}</li>`)
+    .join('\n');
+  return `\n<section class="footnotes">\n<ol>\n${items}\n</ol>\n</section>`;
+}
+
+function markdownToHtml(text: string): string {
+  let result = text;
+
+  // Process headings
+  result = result.replace(/^######\s+(.+)$/gm, '<h6>$1</h6>');
+  result = result.replace(/^#####\s+(.+)$/gm, '<h5>$1</h5>');
+  result = result.replace(/^####\s+(.+)$/gm, '<h4>$1</h4>');
+  result = result.replace(/^###\s+(.+)$/gm, '<h3>$1</h3>');
+  result = result.replace(/^##\s+(.+)$/gm, '<h2>$1</h2>');
+  result = result.replace(/^#\s+(.+)$/gm, '<h1>$1</h1>');
+
+  // Process bold and italic
+  result = result.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
+  result = result.replace(/\*(.+?)\*/g, '<em>$1</em>');
+
+  // Process paragraphs - wrap non-empty lines that aren't already HTML tags or headings
+  const lines = result.split('\n');
+  const processed: string[] = [];
+  let i = 0;
+  while (i < lines.length) {
+    const line = lines[i].trim();
+    if (line === '') {
+      processed.push('');
+      i++;
+    } else if (line.startsWith('<')) {
+      processed.push(lines[i]);
+      i++;
+    } else {
+      // Collect consecutive non-empty, non-HTML lines as a paragraph
+      const paraLines: string[] = [];
+      while (i < lines.length && lines[i].trim() !== '' && !lines[i].trim().startsWith('<')) {
+        paraLines.push(lines[i].trim());
+        i++;
+      }
+      processed.push(`<p>${paraLines.join(' ')}</p>`);
+    }
+  }
+  result = processed.join('\n');
+
+  // Clean up excessive blank lines
+  result = result.replace(/\n{3,}/g, '\n\n');
+
+  return result.trim();
+}
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file: ContentFile, _ctx: BuildContext): ContentFile {
+        let content = file.content;
+
+        if (!content) {
+          return { ...file, content: '' };
+        }
+
+        // Process admonitions before markdown conversion
+        content = processAdmonitions(content);
+
+        // Process footnotes
+        const { text, footnotes } = processFootnotes(content);
+        content = text;
+
+        // Convert markdown to HTML
+        content = markdownToHtml(content);
+
+        // Append footnote section
+        content += renderFootnoteSection(footnotes);
+
+        return { ...file, content };
+      },
+    },
+  };
+}
