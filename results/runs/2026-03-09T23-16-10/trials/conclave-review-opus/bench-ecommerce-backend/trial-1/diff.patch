: cart.userId,\n        items: cart.items.map(i => ({ ...i })),\n      };\n    },\n\n    clearCart(cartId: string): void {\n      const cart = carts.get(cartId);\n      if (!cart) return;\n      cart.items = [];\n      emitCartUpdated(cart);\n    },\n\n    updateQuantity(cartId: string, productId: string, quantity: number): void {\n      const cart = carts.get(cartId);\n      if (!cart) return;\n      const item = cart.items.find(i => i.productId === productId);\n      if (item) {\n        item.quantity = quantity;\n        emitCartUpdated(cart);\n      }\n    },\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":585,"cache_read_input_tokens":22303,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":585},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"b4eea072-9342-49af-9843-a74aec2ecf03","uuid":"99b7bf73-2c82-4727-a721-1040b688f9d6"}
