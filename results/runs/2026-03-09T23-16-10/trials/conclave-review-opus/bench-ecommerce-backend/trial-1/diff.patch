1', total: 100 });\n   494→    const top = analytics.getTopProducts(5);\n   495→    expect(top).toHaveLength(2);\n   496→    expect(top[0].productId).toBe('p1');\n   497→    expect(top[0].count).toBe(3);\n   498→    expect(top[1].productId).toBe('p2');\n   499→    expect(top[1].count).toBe(1);\n   500→  });\n   501→\n   502→  it('should limit top products', async () => {\n   503→    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [\n   504→      { productId: 'p1', quantity: 3 },\n   505→      { productId: 'p2', quantity: 2 },\n   506→      { productId: 'p3', quantity: 1 },\n   507→    ]});\n   508→    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n   509→    const top = analytics.getTopProducts(2);\n   510→    expect(top).toHaveLength(2);\n   511→  });\n   512→});\n   513→\n   514→describe('Integration: Full E-commerce Flow', () => {\n   515→  it('should handle a complete purchase flow', async () => {\n   516→    const bus = new EventBus();\n   517→    const catalog = createCatalogService(bus);\n   518→    const inventory = createInventoryService(bus);\n   519→    const cartService = createCartService(bus);\n   520→    const pricing = createPricingService(bus);\n   521→    const orderService = createOrderService(bus);\n   522→    const payment = createPaymentService(bus);\n   523→    const notificationService = createNotificationService(bus);\n   524→    const analytics = createAnalyticsService(bus);\n   525→\n   526→    // Subscribe user for notifications\n   527→    notificationService.subscribe('user1');\n   528→\n   529→    // Create products\n   530→    const productId = catalog.createProduct('Laptop', 999.99, 'electronics');\n   531→    // Wait for async event propagation\n   532→    await new Promise(resolve => setTimeout(resolve, 10));\n   533→\n   534→    // Set inventory\n   535→    inventory.setStock(productId, 50);\n   536→\n   537→    // Verify pricing tracked the product price\n   538→    expect(pricing.getPrice(productId)).toBe(999.99);\n   539→\n   540→    // Create cart and add items\n   541→    const cartId = cartService.createCart('user1');\n   542→    cartService.addItem(cartId, productId, 2);\n   543→    // Wait for cart event\n   544→    await new Promise(resolve => setTimeout(resolve, 10));\n   545→\n   546→    // Reserve inventory\n   547→    expect(inventory.reserve(productId, 2)).toBe(true);\n   548→\n   549→    // Calculate pricing\n   550→    const cart = cartService.getCart(cartId)!;\n   551→    const items = cart.items.map(item => ({\n   552→      productId: item.productId,\n   553→      quantity: item.quantity,\n   554→      price: pricing.getPrice(item.productId),\n   555→    }));\n   556→    const totals = pricing.calculateTotal(items);\n   557→    expect(totals.subtotal).toBe(1999.98);\n   558→    expect(totals.tax).toBeCloseTo(199.998, 1);\n   559→\n   560→    // Create order\n   561→    const orderId = orderService.createOrder('user1', cartId, totals.total);\n   562→    await new Promise(resolve => setTimeout(resolve, 10));\n   563→\n   564→    // Process payment\n   565→    const paymentResult = await payment.processPayment(orderId, totals.total);\n   566→    expect(paymentResult.status).toBe(PaymentStatus.SUCCESS);\n   567→\n   568→    // Update order status\n   569→    orderService.updateStatus(orderId, OrderStatus.CONFIRMED);\n   570→    await new Promise(resolve => setTimeout(resolve, 10));\n   571→\n   572→    // Verify order\n   573→    const order = orderService.getOrder(orderId);\n   574→    expect(order!.status).toBe(OrderStatus.CONFIRMED);\n   575→\n   576→    // Verify notifications were sent\n   577→    const notifs = notificationService.getNotifications('user1');\n   578→    expect(notifs.length).toBeGreaterThanOrEqual(3); // order_created, payment, order_status\n   579→\n   580→    // Verify analytics\n   581→    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(1);\n   582→    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBe(1);\n   583→    expect(analytics.getRevenue()).toBe(totals.total);\n   584→    expect(analytics.getConversionRate()).toBeGreaterThan(0);\n   585→\n   586→    const topProducts = analytics.getTopProducts(5);\n   587→    expect(topProducts).toHaveLength(1);\n   588→    expect(topProducts[0].productId).toBe(productId);\n   589→    expect(topProducts[0].count).toBe(2);\n   590→  });\n   591→\n   592→  it('should handle discount codes in flow', async () => {\n   593→    const bus = new EventBus();\n   594→    const catalog = createCatalogService(bus);\n   595→    const pricing = createPricingService(bus);\n   596→\n   597→    catalog.createProduct('Widget', 50, 'gadgets');\n   598→    await new Promise(resolve => setTimeout(resolve, 10));\n   599→\n   600→    pricing.addDiscountCode('HALF', 50);\n   601→    const result = pricing.calculateTotal(\n   602→      [{ productId: 'p1', quantity: 4, price: 50 }],\n   603→      'HALF'\n   604→    );\n   605→    // subtotal = 200, discount = 100, after = 100, tax = 10, total = 110\n   606→    expect(result.subtotal).toBe(200);\n   607→    expect(result.discount).toBe(100);\n   608→    expect(result.tax).toBe(10);\n   609→    expect(result.total).toBe(110);\n   610→  });\n   611→\n   612→  it('should handle payment failure gracefully', async () => {\n   613→    const bus = new EventBus();\n   614→    const payment = createPaymentService(bus, { simulateFailure: true });\n   615→    const result = await payment.processPayment('order1', 100);\n   616→    expect(result.status).toBe(PaymentStatus.FAILED);\n   617→    expect(result.transactionId).toBeUndefined();\n   618→    expect(result.error).toBeTruthy();\n   619→  });\n   620→\n   621→  it('should handle low stock alerts with threshold', async () => {\n   622→    const bus = new EventBus();\n   623→    const inventory = createInventoryService(bus);\n   624→    const alerts: unknown[] = [];\n   625→    bus.on(Events.LOW_STOCK_ALERT, (payload: unknown) => { alerts.push(payload); });\n   626→\n   627→    inventory.setStock('p1', 20);\n   628→    inventory.setLowStockThreshold('p1', 5);\n   629→    // Reserve most stock\n   630→    inventory.reserve('p1', 16);\n   631→    await new Promise(resolve => setTimeout(resolve, 10));\n   632→    expect(alerts.length).toBeGreaterThan(0);\n   633→  });\n   634→});\n   635→"}]},"parent_tool_use_id":"toolu_01SaDbMoxdFCiLKztzqqux1B","session_id":"b4eea072-9342-49af-9843-a74aec2ecf03","uuid":"1872ed07-dbe4-48c2-a644-80bf4b8cc37a"}
