rt { createPricingService } from '../src/pricing/index.js';\nimport { createOrderService } from '../src/orders/index.js';\nimport { createPaymentService } from '../src/payment/index.js';\nimport { createNotificationService } from '../src/notifications/index.js';\nimport { createAnalyticsService } from '../src/analytics/index.js';\nimport { OrderStatus, PaymentStatus, Events } from '../src/types.js';\n\ndescribe('Catalog Service', () => {\n  let bus: EventBus;\n  let catalog: ReturnType<typeof createCatalogService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    catalog = createCatalogService(bus);\n  });\n\n  it('should create a product and return its id', () => {\n    const id = catalog.createProduct('Laptop', 999.99, 'electronics');\n    expect(id).toBeTruthy();\n  });\n\n  it('should retrieve a created product', () => {\n    const id = catalog.createProduct('Laptop', 999.99, 'electronics');\n    const product = catalog.getProduct(id);\n    expect(product).toEqual({ id, name: 'Laptop', price: 999.99, category: 'electronics' });\n  });\n\n  it('should return null for nonexistent product', () => {\n    expect(catalog.getProduct('nonexistent')).toBeNull();\n  });\n\n  it('should list all products', () => {\n    catalog.createProduct('Laptop', 999.99, 'electronics');\n    catalog.createProduct('Shirt', 29.99, 'clothing');\n    expect(catalog.listProducts()).toHaveLength(2);\n  });\n\n  it('should list products by category', () => {\n    catalog.createProduct('Laptop', 999.99, 'electronics');\n    catalog.createProduct('Phone', 599.99, 'electronics');\n    catalog.createProduct('Shirt', 29.99, 'clothing');\n    expect(catalog.listProducts('electronics')).toHaveLength(2);\n    expect(catalog.listProducts('clothing')).toHaveLength(1);\n  });\n\n  it('should search products by name', () => {\n    catalog.createProduct('Laptop Pro', 999.99, 'electronics');\n    catalog.createProduct('Laptop Air', 799.99, 'electronics');\n    catalog.createProduct('Shirt', 29.99, 'clothing');\n    const results = catalog.searchProducts('laptop');\n    expect(results).toHaveLength(2);\n  });\n\n  it('should search products by category', () => {\n    catalog.createProduct('Laptop', 999.99, 'electronics');\n    catalog.createProduct('Shirt', 29.99, 'clothing');\n    const results = catalog.searchProducts('cloth');\n    expect(results).toHaveLength(1);\n  });\n\n  it('should update a product', () => {\n    const id = catalog.createProduct('Laptop', 999.99, 'electronics');\n    catalog.updateProduct(id, { name: 'Laptop Pro', price: 1299.99 });\n    const product = catalog.getProduct(id);\n    expect(product!.name).toBe('Laptop Pro');\n    expect(product!.price).toBe(1299.99);\n    expect(product!.category).toBe('electronics');\n  });\n\n  it('should remove a product', () => {\n    const id = catalog.createProduct('Laptop', 999.99, 'electronics');\n    expect(catalog.removeProduct(id)).toBe(true);\n    expect(catalog.getProduct(id)).toBeNull();\n    expect(catalog.removeProduct(id)).toBe(false);\n  });\n\n  it('should emit product:created event', async () => {\n    let emitted = false;\n    bus.on(Events.PRODUCT_CREATED, () => { emitted = true; });\n    catalog.createProduct('Laptop', 999.99, 'electronics');\n    // Allow the async emit to complete\n    await new Promise(resolve => setTimeout(resolve, 10));\n    expect(emitted).toBe(true);\n  });\n});\n\ndescribe('Inventory Service', () => {\n  let bus: EventBus;\n  let inventory: ReturnType<typeof createInventoryService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    inventory = createInventoryService(bus);\n  });\n\n  it('should set and get stock', () => {\n    inventory.setStock('p1', 100);\n    expect(inventory.getStock('p1')).toBe(100);\n  });\n\n  it('should return 0 for unknown product stock', () => {\n    expect(inventory.getStock('unknown')).toBe(0);\n  });\n\n  it('should reserve stock when available', () => {\n    inventory.setStock('p1', 10);\n    expect(inventory.reserve('p1', 5)).toBe(true);\n    expect(inventory.getStock('p1')).toBe(5);\n  });\n\n  it('should fail to reserve when insufficient stock', () => {\n    inventory.setStock('p1', 3);\n    expect(inventory.reserve('p1', 5)).toBe(false);\n    expect(inventory.getStock('p1')).toBe(3);\n  });\n\n  it('should release reserved stock', () => {\n    inventory.setStock('p1', 10);\n    inventory.reserve('p1', 5);\n    inventory.release('p1', 3);\n    expect(inventory.getStock('p1')).toBe(8);\n  });\n\n  it('should emit low stock alert when below threshold', async () => {\n    let alertEmitted = false;\n    bus.on(Events.LOW_STOCK_ALERT, () => { alertEmitted = true; });\n    inventory.setLowStockThreshold('p1', 5);\n    inventory.setStock('p1', 3);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    expect(alertEmitted).toBe(true);\n  });\n\n  it('should emit low stock alert on reserve', async () => {\n    let alertCount = 0;\n    bus.on(Events.LOW_STOCK_ALERT, () => { alertCount++; });\n    inventory.setStock('p1', 10);\n    inventory.setLowStockThreshold('p1', 5);\n    inventory.reserve('p1', 7);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    expect(alertCount).toBeGreaterThan(0);\n  });\n});\n\ndescribe('Cart Service', () => {\n  let bus: EventBus;\n  let cart: ReturnType<typeof createCartService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    cart = createCartService(bus);\n  });\n\n  it('should create a cart and return its id', () => {\n    const id = cart.createCart('user1');\n    expect(id).toBeTruthy();\n  });\n\n  it('should add items to cart', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    const c = cart.getCart(id);\n    expect(c!.items).toHaveLength(1);\n    expect(c!.items[0]).toEqual({ productId: 'p1', quantity: 2 });\n  });\n\n  it('should consolidate duplicate product adds', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p1', 3);\n    const c = cart.getCart(id);\n    expect(c!.items).toHaveLength(1);\n    expect(c!.items[0].quantity).toBe(5);\n  });\n\n  it('should remove items from cart', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p2', 1);\n    cart.removeItem(id, 'p1');\n    const c = cart.getCart(id);\n    expect(c!.items).toHaveLength(1);\n    expect(c!.items[0].productId).toBe('p2');\n  });\n\n  it('should clear cart', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.clearCart(id);\n    const c = cart.getCart(id);\n    expect(c!.items).toHaveLength(0);\n  });\n\n  it('should update item quantity', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.updateQuantity(id, 'p1', 10);\n    const c = cart.getCart(id);\n    expect(c!.items[0].quantity).toBe(10);\n  });\n\n  it('should return null for nonexistent cart', () => {\n    expect(cart.getCart('nonexistent')).toBeNull();\n  });\n\n  it('should emit cart:updated event on add', async () => {\n    let emitted = false;\n    bus.on(Events.CART_UPDATED, () => { emitted = true; });\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 1);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    expect(emitted).toBe(true);\n  });\n});\n\ndescribe('Pricing Service', () => {\n  let bus: EventBus;\n  let pricing: ReturnType<typeof createPricingService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    pricing = createPricingService(bus);\n  });\n\n  it('should calculate total with 10% tax', () => {\n    const result = pricing.calculateTotal([\n      { productId: 'p1', quantity: 2, price: 10 },\n    ]);\n    expect(result.subtotal).toBe(20);\n    expect(result.discount).toBe(0);\n    expect(result.tax).toBe(2);\n    expect(result.total).toBe(22);\n  });\n\n  it('should apply discount code before tax', () => {\n    pricing.addDiscountCode('SAVE20', 20);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'SAVE20'\n    );\n    expect(result.subtotal).toBe(100);\n    expect(result.discount).toBe(20);\n    expect(result.tax).toBe(8); // (100 - 20) * 0.10\n    expect(result.total).toBe(88); // 80 + 8\n  });\n\n  it('should ignore invalid discount codes', () => {\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'INVALID'\n    );\n    expect(result.discount).toBe(0);\n    expect(result.total).toBe(110);\n  });\n\n  it('should track prices from product:created events', async () => {\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'Test', price: 49.99, category: 'test' });\n    expect(pricing.getPrice('p1')).toBe(49.99);\n  });\n\n  it('should return 0 for unknown product price', () => {\n    expect(pricing.getPrice('unknown')).toBe(0);\n  });\n});\n\ndescribe('Order Service', () => {\n  let bus: EventBus;\n  let orders: ReturnType<typeof createOrderService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    orders = createOrderService(bus);\n  });\n\n  it('should create an order in pending status', () => {\n    const id = orders.createOrder('user1', 'cart1', 100);\n    const order = orders.getOrder(id);\n    expect(order!.status).toBe(OrderStatus.PENDING);\n    expect(order!.total).toBe(100);\n    expect(order!.userId).toBe('user1');\n  });\n\n  it('should update order status', () => {\n    const id = orders.createOrder('user1', 'cart1', 100);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.CONFIRMED);\n  });\n\n  it('should track status lifecycle', () => {\n    const id = orders.createOrder('user1', 'cart1', 100);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    orders.updateStatus(id, OrderStatus.SHIPPED);\n    orders.updateStatus(id, OrderStatus.DELIVERED);\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.DELIVERED);\n  });\n\n  it('should cancel an order', () => {\n    const id = orders.createOrder('user1', 'cart1', 100);\n    orders.updateStatus(id, OrderStatus.CANCELLED);\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.CANCELLED);\n  });\n\n  it('should list orders by user', () => {\n    orders.createOrder('user1', 'cart1', 100);\n    orders.createOrder('user1', 'cart2', 200);\n    orders.createOrder('user2', 'cart3', 150);\n    expect(orders.listOrders('user1')).toHaveLength(2);\n    expect(orders.listOrders('user2')).toHaveLength(1);\n  });\n\n  it('should return null for nonexistent order', () => {\n    expect(orders.getOrder('nonexistent')).toBeNull();\n  });\n\n  it('should emit order:created event', async () => {\n    let emitted = false;\n    bus.on(Events.ORDER_CREATED, () => { emitted = true; });\n    orders.createOrder('user1', 'cart1', 100);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    expect(emitted).toBe(true);\n  });\n\n  it('should emit order:status_changed event with previous status', async () => {\n    let eventPayload: { previousStatus: string; status: string } | null = null;\n    bus.on(Events.ORDER_STATUS_CHANGED, (payload: unknown) => {\n      eventPayload = payload as { previousStatus: string; status: string };\n    });\n    const id = orders.createOrder('user1', 'cart1', 100);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    expect(eventPayload).not.toBeNull();\n    expect(eventPayload!.previousStatus).toBe(OrderStatus.PENDING);\n    expect(eventPayload!.status).toBe(OrderStatus.CONFIRMED);\n  });\n});\n\ndescribe('Payment Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should process payment successfully by default', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.SUCCESS);\n    expect(result.transactionId).toBeTruthy();\n  });\n\n  it('should simulate payment failure', async () => {\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.FAILED);\n    expect(result.error).toBeTruthy();\n  });\n\n  it('should simulate payment timeout', async () => {\n    const payment = createPaymentService(bus, { simulateTimeout: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.TIMEOUT);\n    expect(result.error).toBeTruthy();\n  });\n\n  it('should refund a successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    const refunded = await payment.refund(result.transactionId!);\n    expect(refunded).toBe(true);\n  });\n\n  it('should fail to refund nonexistent transaction', async () => {\n    const payment = createPaymentService(bus);\n    const refunded = await payment.refund('nonexistent');\n    expect(refunded).toBe(false);\n  });\n\n  it('should fail to refund already refunded transaction', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    await payment.refund(result.transactionId!);\n    const refundedAgain = await payment.refund(result.transactionId!);\n    expect(refundedAgain).toBe(false);\n  });\n\n  it('should emit payment:processed event', async () => {\n    let emitted = false;\n    bus.on(Events.PAYMENT_PROCESSED, () => { emitted = true; });\n    const payment = createPaymentService(bus);\n    await payment.processPayment('order1', 100);\n    expect(emitted).toBe(true);\n  });\n});\n\ndescribe('Notification Service', () => {\n  let bus: EventBus;\n  let notifications: ReturnType<typeof createNotificationService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    notifications = createNotificationService(bus);\n  });\n\n  it('should subscribe a user', () => {\n    notifications.subscribe('user1');\n    expect(notifications.getNotifications('user1')).toEqual([]);\n  });\n\n  it('should record notification on order creation for subscribed user', async () => {\n    notifications.subscribe('user1');\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs).toHaveLength(1);\n    expect(notifs[0].type).toBe('order_created');\n  });\n\n  it('should not record notification for unsubscribed user', async () => {\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs).toHaveLength(0);\n  });\n\n  it('should record notification on order status change', async () => {\n    notifications.subscribe('user1');\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.ORDER_STATUS_CHANGED, { orderId: 'o1', status: OrderStatus.CONFIRMED, previousStatus: OrderStatus.PENDING });\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs).toHaveLength(2);\n    expect(notifs[1].type).toBe('order_status');\n  });\n\n  it('should record notification on payment processed', async () => {\n    notifications.subscribe('user1');\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 't1' });\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs).toHaveLength(2);\n    expect(notifs[1].type).toBe('payment');\n  });\n});\n\ndescribe('Analytics Service', () => {\n  let bus: EventBus;\n  let analytics: ReturnType<typeof createAnalyticsService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    analytics = createAnalyticsService(bus);\n  });\n\n  it('should count events by type', async () => {\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'Test', price: 10, category: 'test' });\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p2', name: 'Test2', price: 20, category: 'test' });\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n  });\n\n  it('should return 0 for untracked event types', () => {\n    expect(analytics.getEventCount('unknown:event')).toBe(0);\n  });\n\n  it('should track revenue from successful payments', async () => {\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 't1' });\n    expect(analytics.getRevenue()).toBe(100);\n  });\n\n  it('should not track revenue from failed payments', async () => {\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.FAILED, error: 'fail' });\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  it('should calculate conversion rate', async () => {\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [] });\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c2', userId: 'u2', items: [] });\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    expect(analytics.getConversionRate()).toBe(0.5); // 1 order / 2 carts\n  });\n\n  it('should return 0 conversion rate with no carts', () => {\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n\n  it('should rank products by order quantity', async () => {\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [\n      { productId: 'p1', quantity: 3 },\n      { productId: 'p2', quantity: 1 },\n    ]});\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    const top = analytics.getTopProducts(5);\n    expect(top).toHaveLength(2);\n    expect(top[0].productId).toBe('p1');\n    expect(top[0].count).toBe(3);\n    expect(top[1].productId).toBe('p2');\n    expect(top[1].count).toBe(1);\n  });\n\n  it('should limit top products', async () => {\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [\n      { productId: 'p1', quantity: 3 },\n      { productId: 'p2', quantity: 2 },\n      { productId: 'p3', quantity: 1 },\n    ]});\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    const top = analytics.getTopProducts(2);\n    expect(top).toHaveLength(2);\n  });\n});\n\ndescribe('Integration: Full E-commerce Flow', () => {\n  it('should handle a complete purchase flow', async () => {\n    const bus = new EventBus();\n    const catalog = createCatalogService(bus);\n    const inventory = createInventoryService(bus);\n    const cartService = createCartService(bus);\n    const pricing = createPricingService(bus);\n    const orderService = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    const notificationService = createNotificationService(bus);\n    const analytics = createAnalyticsService(bus);\n\n    // Subscribe user for notifications\n    notificationService.subscribe('user1');\n\n    // Create products\n    const productId = catalog.createProduct('Laptop', 999.99, 'electronics');\n    // Wait for async event propagation\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    // Set inventory\n    inventory.setStock(productId, 50);\n\n    // Verify pricing tracked the product price\n    expect(pricing.getPrice(productId)).toBe(999.99);\n\n    // Create cart and add items\n    const cartId = cartService.createCart('user1');\n    cartService.addItem(cartId, productId, 2);\n    // Wait for cart event\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    // Reserve inventory\n    expect(inventory.reserve(productId, 2)).toBe(true);\n\n    // Calculate pricing\n    const cart = cartService.getCart(cartId)!;\n    const items = cart.items.map(item => ({\n      productId: item.productId,\n      quantity: item.quantity,\n      price: pricing.getPrice(item.productId),\n    }));\n    const totals = pricing.calculateTotal(items);\n    expect(totals.subtotal).toBe(1999.98);\n    expect(totals.tax).toBeCloseTo(199.998, 1);\n\n    // Create order\n    const orderId = orderService.createOrder('user1', cartId, totals.total);\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    // Process payment\n    const paymentResult = await payment.processPayment(orderId, totals.total);\n    expect(paymentResult.status).toBe(PaymentStatus.SUCCESS);\n\n    // Update order status\n    orderService.updateStatus(orderId, OrderStatus.CONFIRMED);\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    // Verify order\n    const order = orderService.getOrder(orderId);\n    expect(order!.status).toBe(OrderStatus.CONFIRMED);\n\n    // Verify notifications were sent\n    const notifs = notificationService.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThanOrEqual(3); // order_created, payment, order_status\n\n    // Verify analytics\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(1);\n    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBe(1);\n    expect(analytics.getRevenue()).toBe(totals.total);\n    expect(analytics.getConversionRate()).toBeGreaterThan(0);\n\n    const topProducts = analytics.getTopProducts(5);\n    expect(topProducts).toHaveLength(1);\n    expect(topProducts[0].productId).toBe(productId);\n    expect(topProducts[0].count).toBe(2);\n  });\n\n  it('should handle discount codes in flow', async () => {\n    const bus = new EventBus();\n    const catalog = createCatalogService(bus);\n    const pricing = createPricingService(bus);\n\n    catalog.createProduct('Widget', 50, 'gadgets');\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    pricing.addDiscountCode('HALF', 50);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 4, price: 50 }],\n      'HALF'\n    );\n    // subtotal = 200, discount = 100, after = 100, tax = 10, total = 110\n    expect(result.subtotal).toBe(200);\n    expect(result.discount).toBe(100);\n    expect(result.tax).toBe(10);\n    expect(result.total).toBe(110);\n  });\n\n  it('should handle payment failure gracefully', async () => {\n    const bus = new EventBus();\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.FAILED);\n    expect(result.transactionId).toBeUndefined();\n    expect(result.error).toBeTruthy();\n  });\n\n  it('should handle low stock alerts with threshold', async () => {\n    const bus = new EventBus();\n    const inventory = createInventoryService(bus);\n    const alerts: unknown[] = [];\n    bus.on(Events.LOW_STOCK_ALERT, (payload: unknown) => { alerts.push(payload); });\n\n    inventory.setStock('p1', 20);\n    inventory.setLowStockThreshold('p1', 5);\n    // Reserve most stock\n    inventory.reserve('p1', 16);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    expect(alerts.length).toBeGreaterThan(0);\n  });\n});\n","structuredPatch":[{"oldStart":144,"oldLines":6,"newStart":144,"newLines":18,"lines":["     await new Promise(resolve => setTimeout(resolve, 10));","     expect(alertCount).toBeGreaterThan(0);","   });","+","+  it('should handle multiple reserves correctly', () => {","+    inventory.setStock('p1', 10);","+    expect(inventory.reserve('p1', 3)).toBe(true);","+    expect(inventory.getStock('p1')).toBe(7);","+    expect(inventory.reserve('p1', 3)).toBe(true);","+    expect(inventory.getStock('p1')).toBe(4);","+    expect(inventory.reserve('p1', 3)).toBe(true);","+    expect(inventory.getStock('p1')).toBe(1);","+    expect(inventory.reserve('p1', 3)).toBe(false);","+    expect(inventory.getStock('p1')).toBe(1);","+  });"," });"," "," describe('Cart Service', () => {"]}],"userModified":false,"replaceAll":false}}
