 () => {\n  let bus: EventBus;\n  let catalog: ReturnType<typeof createCatalogService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    catalog = createCatalogService(bus);\n  });\n\n  it('should create a product and return its id', () => {\n    const id = catalog.createProduct('Laptop', 999.99, 'electronics');\n    expect(id).toBeTruthy();\n  });\n\n  it('should retrieve a created product', () => {\n    const id = catalog.createProduct('Laptop', 999.99, 'electronics');\n    const product = catalog.getProduct(id);\n    expect(product).toEqual({ id, name: 'Laptop', price: 999.99, category: 'electronics' });\n  });\n\n  it('should return null for nonexistent product', () => {\n    expect(catalog.getProduct('nonexistent')).toBeNull();\n  });\n\n  it('should list all products', () => {\n    catalog.createProduct('Laptop', 999.99, 'electronics');\n    catalog.createProduct('Shirt', 29.99, 'clothing');\n    expect(catalog.listProducts()).toHaveLength(2);\n  });\n\n  it('should list products by category', () => {\n    catalog.createProduct('Laptop', 999.99, 'electronics');\n    catalog.createProduct('Phone', 599.99, 'electronics');\n    catalog.createProduct('Shirt', 29.99, 'clothing');\n    expect(catalog.listProducts('electronics')).toHaveLength(2);\n    expect(catalog.listProducts('clothing')).toHaveLength(1);\n  });\n\n  it('should search products by name', () => {\n    catalog.createProduct('Laptop Pro', 999.99, 'electronics');\n    catalog.createProduct('Laptop Air', 799.99, 'electronics');\n    catalog.createProduct('Shirt', 29.99, 'clothing');\n    const results = catalog.searchProducts('laptop');\n    expect(results).toHaveLength(2);\n  });\n\n  it('should search products by category', () => {\n    catalog.createProduct('Laptop', 999.99, 'electronics');\n    catalog.createProduct('Shirt', 29.99, 'clothing');\n    const results = catalog.searchProducts('cloth');\n    expect(results).toHaveLength(1);\n  });\n\n  it('should update a product', () => {\n    const id = catalog.createProduct('Laptop', 999.99, 'electronics');\n    catalog.updateProduct(id, { name: 'Laptop Pro', price: 1299.99 });\n    const product = catalog.getProduct(id);\n    expect(product!.name).toBe('Laptop Pro');\n    expect(product!.price).toBe(1299.99);\n    expect(product!.category).toBe('electronics');\n  });\n\n  it('should remove a product', () => {\n    const id = catalog.createProduct('Laptop', 999.99, 'electronics');\n    expect(catalog.removeProduct(id)).toBe(true);\n    expect(catalog.getProduct(id)).toBeNull();\n    expect(catalog.removeProduct(id)).toBe(false);\n  });\n\n  it('should emit product:created event', async () => {\n    let emitted = false;\n    bus.on(Events.PRODUCT_CREATED, () => { emitted = true; });\n    catalog.createProduct('Laptop', 999.99, 'electronics');\n    // Allow the async emit to complete\n    await new Promise(resolve => setTimeout(resolve, 10));\n    expect(emitted).toBe(true);\n  });\n});\n\ndescribe('Inventory Service', () => {\n  let bus: EventBus;\n  let inventory: ReturnType<typeof createInventoryService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    inventory = createInventoryService(bus);\n  });\n\n  it('should set and get stock', () => {\n    inventory.setStock('p1', 100);\n    expect(inventory.getStock('p1')).toBe(100);\n  });\n\n  it('should return 0 for unknown product stock', () => {\n    expect(inventory.getStock('unknown')).toBe(0);\n  });\n\n  it('should reserve stock when available', () => {\n    inventory.setStock('p1', 10);\n    expect(inventory.reserve('p1', 5)).toBe(true);\n    expect(inventory.getStock('p1')).toBe(5);\n  });\n\n  it('should fail to reserve when insufficient stock', () => {\n    inventory.setStock('p1', 3);\n    expect(inventory.reserve('p1', 5)).toBe(false);\n    expect(inventory.getStock('p1')).toBe(3);\n  });\n\n  it('should release reserved stock', () => {\n    inventory.setStock('p1', 10);\n    inventory.reserve('p1', 5);\n    inventory.release('p1', 3);\n    expect(inventory.getStock('p1')).toBe(8);\n  });\n\n  it('should emit low stock alert when below threshold', async () => {\n    let alertEmitted = false;\n    bus.on(Events.LOW_STOCK_ALERT, () => { alertEmitted = true; });\n    inventory.setLowStockThreshold('p1', 5);\n    inventory.setStock('p1', 3);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    expect(alertEmitted).toBe(true);\n  });\n\n  it('should emit low stock alert on reserve', async () => {\n    let alertCount = 0;\n    bus.on(Events.LOW_STOCK_ALERT, () => { alertCount++; });\n    inventory.setStock('p1', 10);\n    inventory.setLowStockThreshold('p1', 5);\n    inventory.reserve('p1', 7);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    expect(alertCount).toBeGreaterThan(0);\n  });\n\n  it('should handle multiple reserves correctly', () => {\n    inventory.setStock('p1', 10);\n    expect(inventory.reserve('p1', 3)).toBe(true);\n    expect(inventory.getStock('p1')).toBe(7);\n    expect(inventory.reserve('p1', 3)).toBe(true);\n    expect(inventory.getStock('p1')).toBe(4);\n    expect(inventory.reserve('p1', 3)).toBe(true);\n    expect(inventory.getStock('p1')).toBe(1);\n    expect(inventory.reserve('p1', 3)).toBe(false);\n    expect(inventory.getStock('p1')).toBe(1);\n  });\n});\n\ndescribe('Cart Service', () => {\n  let bus: EventBus;\n  let cart: ReturnType<typeof createCartService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    cart = createCartService(bus);\n  });\n\n  it('should create a cart and return its id', () => {\n    const id = cart.createCart('user1');\n    expect(id).toBeTruthy();\n  });\n\n  it('should add items to cart', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    const c = cart.getCart(id);\n    expect(c!.items).toHaveLength(1);\n    expect(c!.items[0]).toEqual({ productId: 'p1', quantity: 2 });\n  });\n\n  it('should consolidate duplicate product adds', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p1', 3);\n    const c = cart.getCart(id);\n    expect(c!.items).toHaveLength(1);\n    expect(c!.items[0].quantity).toBe(5);\n  });\n\n  it('should remove items from cart', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p2', 1);\n    cart.removeItem(id, 'p1');\n    const c = cart.getCart(id);\n    expect(c!.items).toHaveLength(1);\n    expect(c!.items[0].productId).toBe('p2');\n  });\n\n  it('should clear cart', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.clearCart(id);\n    const c = cart.getCart(id);\n    expect(c!.items).toHaveLength(0);\n  });\n\n  it('should update item quantity', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.updateQuantity(id, 'p1', 10);\n    const c = cart.getCart(id);\n    expect(c!.items[0].quantity).toBe(10);\n  });\n\n  it('should return null for nonexistent cart', () => {\n    expect(cart.getCart('nonexistent')).toBeNull();\n  });\n\n  it('should emit cart:updated event on add', async () => {\n    let emitted = false;\n    bus.on(Events.CART_UPDATED, () => { emitted = true; });\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 1);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    expect(emitted).toBe(true);\n  });\n});\n\ndescribe('Pricing Service', () => {\n  let bus: EventBus;\n  let pricing: ReturnType<typeof createPricingService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    pricing = createPricingService(bus);\n  });\n\n  it('should calculate total with 10% tax', () => {\n    const result = pricing.calculateTotal([\n      { productId: 'p1', quantity: 2, price: 10 },\n    ]);\n    expect(result.subtotal).toBe(20);\n    expect(result.discount).toBe(0);\n    expect(result.tax).toBe(2);\n    expect(result.total).toBe(22);\n  });\n\n  it('should apply discount code before tax', () => {\n    pricing.addDiscountCode('SAVE20', 20);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'SAVE20'\n    );\n    expect(result.subtotal).toBe(100);\n    expect(result.discount).toBe(20);\n    expect(result.tax).toBe(8); // (100 - 20) * 0.10\n    expect(result.total).toBe(88); // 80 + 8\n  });\n\n  it('should ignore invalid discount codes', () => {\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'INVALID'\n    );\n    expect(result.discount).toBe(0);\n    expect(result.total).toBe(110);\n  });\n\n  it('should track prices from product:created events', async () => {\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'Test', price: 49.99, category: 'test' });\n    expect(pricing.getPrice('p1')).toBe(49.99);\n  });\n\n  it('should return 0 for unknown product price', () => {\n    expect(pricing.getPrice('unknown')).toBe(0);\n  });\n});\n\ndescribe('Order Service', () => {\n  let bus: EventBus;\n  let orders: ReturnType<typeof createOrderService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    orders = createOrderService(bus);\n  });\n\n  it('should create an order in pending status', () => {\n    const id = orders.createOrder('user1', 'cart1', 100);\n    const order = orders.getOrder(id);\n    expect(order!.status).toBe(OrderStatus.PENDING);\n    expect(order!.total).toBe(100);\n    expect(order!.userId).toBe('user1');\n  });\n\n  it('should update order status', () => {\n    const id = orders.createOrder('user1', 'cart1', 100);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.CONFIRMED);\n  });\n\n  it('should track status lifecycle', () => {\n    const id = orders.createOrder('user1', 'cart1', 100);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    orders.updateStatus(id, OrderStatus.SHIPPED);\n    orders.updateStatus(id, OrderStatus.DELIVERED);\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.DELIVERED);\n  });\n\n  it('should cancel an order', () => {\n    const id = orders.createOrder('user1', 'cart1', 100);\n    orders.updateStatus(id, OrderStatus.CANCELLED);\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.CANCELLED);\n  });\n\n  it('should list orders by user', () => {\n    orders.createOrder('user1', 'cart1', 100);\n    orders.createOrder('user1', 'cart2', 200);\n    orders.createOrder('user2', 'cart3', 150);\n    expect(orders.listOrders('user1')).toHaveLength(2);\n    expect(orders.listOrders('user2')).toHaveLength(1);\n  });\n\n  it('should return null for nonexistent order', () => {\n    expect(orders.getOrder('nonexistent')).toBeNull();\n  });\n\n  it('should emit order:created event', async () => {\n    let emitted = false;\n    bus.on(Events.ORDER_CREATED, () => { emitted = true; });\n    orders.createOrder('user1', 'cart1', 100);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    expect(emitted).toBe(true);\n  });\n\n  it('should emit order:status_changed event with previous status', async () => {\n    let eventPayload: { previousStatus: string; status: string } | null = null;\n    bus.on(Events.ORDER_STATUS_CHANGED, (payload: unknown) => {\n      eventPayload = payload as { previousStatus: string; status: string };\n    });\n    const id = orders.createOrder('user1', 'cart1', 100);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    expect(eventPayload).not.toBeNull();\n    expect(eventPayload!.previousStatus).toBe(OrderStatus.PENDING);\n    expect(eventPayload!.status).toBe(OrderStatus.CONFIRMED);\n  });\n});\n\ndescribe('Payment Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should process payment successfully by default', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n   