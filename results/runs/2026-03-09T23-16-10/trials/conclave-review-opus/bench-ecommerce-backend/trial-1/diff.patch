s;\n  let analytics: ReturnType<typeof createAnalyticsService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    analytics = createAnalyticsService(bus);\n  });\n\n  it('should count events by type', async () => {\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'Test', price: 10, category: 'test' });\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p2', name: 'Test2', price: 20, category: 'test' });\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n  });\n\n  it('should return 0 for untracked event types', () => {\n    expect(analytics.getEventCount('unknown:event')).toBe(0);\n  });\n\n  it('should track revenue from successful payments', async () => {\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 't1' });\n    expect(analytics.getRevenue()).toBe(100);\n  });\n\n  it('should not track revenue from failed payments', async () => {\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.FAILED, error: 'fail' });\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  it('should calculate conversion rate', async () => {\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [] });\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c2', userId: 'u2', items: [] });\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    expect(analytics.getConversionRate()).toBe(0.5); // 1 order / 2 carts\n  });\n\n  it('should return 0 conversion rate with no carts', () => {\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n\n  it('should rank products by order quantity', async () => {\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [\n      { productId: 'p1', quantity: 3 },\n      { productId: 'p2', quantity: 1 },\n    ]});\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    const top = analytics.getTopProducts(5);\n    expect(top).toHaveLength(2);\n    expect(top[0].productId).toBe('p1');\n    expect(top[0].count).toBe(3);\n    expect(top[1].productId).toBe('p2');\n    expect(top[1].count).toBe(1);\n  });\n\n  it('should limit top products', async () => {\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [\n      { productId: 'p1', quantity: 3 },\n      { productId: 'p2', quantity: 2 },\n      { productId: 'p3', quantity: 1 },\n    ]});\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    const top = analytics.getTopProducts(2);\n    expect(top).toHaveLength(2);\n  });\n});\n\ndescribe('Integration: Full E-commerce Flow', () => {\n  it('should handle a complete purchase flow', async () => {\n    const bus = new EventBus();\n    const catalog = createCatalogService(bus);\n    const inventory = createInventoryService(bus);\n    const cartService = createCartService(bus);\n    const pricing = createPricingService(bus);\n    const orderService = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    const notificationService = createNotificationService(bus);\n    const analytics = createAnalyticsService(bus);\n\n    // Subscribe user for notifications\n    notificationService.subscribe('user1');\n\n    // Create products\n    const productId = catalog.createProduct('Laptop', 999.99, 'electronics');\n    // Wait for async event propagation\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    // Set inventory\n    inventory.setStock(productId, 50);\n\n    // Verify pricing tracked the product price\n    expect(pricing.getPrice(productId)).toBe(999.99);\n\n    // Create cart and add items\n    const cartId = cartService.createCart('user1');\n    cartService.addItem(cartId, productId, 2);\n    // Wait for cart event\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    // Reserve inventory\n    expect(inventory.reserve(productId, 2)).toBe(true);\n\n    // Calculate pricing\n    const cart = cartService.getCart(cartId)!;\n    const items = cart.items.map(item => ({\n      productId: item.productId,\n      quantity: item.quantity,\n      price: pricing.getPrice(item.productId),\n    }));\n    const totals = pricing.calculateTotal(items);\n    expect(totals.subtotal).toBe(1999.98);\n    expect(totals.tax).toBeCloseTo(199.998, 1);\n\n    // Create order\n    const orderId = orderService.createOrder('user1', cartId, totals.total);\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    // Process payment\n    const paymentResult = await payment.processPayment(orderId, totals.total);\n    expect(paymentResult.status).toBe(PaymentStatus.SUCCESS);\n\n    // Update order status\n    orderService.updateStatus(orderId, OrderStatus.CONFIRMED);\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    // Verify order\n    const order = orderService.getOrder(orderId);\n    expect(order!.status).toBe(OrderStatus.CONFIRMED);\n\n    // Verify notifications were sent\n    const notifs = notificationService.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThanOrEqual(3); // order_created, payment, order_status\n\n    // Verify analytics\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(1);\n    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBe(1);\n    expect(analytics.getRevenue()).toBe(totals.total);\n    expect(analytics.getConversionRate()).toBeGreaterThan(0);\n\n    const topProducts = analytics.getTopProducts(5);\n    expect(topProducts).toHaveLength(1);\n    expect(topProducts[0].productId).toBe(productId);\n    expect(topProducts[0].count).toBe(2);\n  });\n\n  it('should handle discount codes in flow', async () => {\n    