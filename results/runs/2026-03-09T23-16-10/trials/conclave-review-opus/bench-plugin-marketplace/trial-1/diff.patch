+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SSrXA3fDiuWEJV4BLBoZRP","type":"tool_result","content":"     1→import Database from 'better-sqlite3';\n     2→import type { PluginManifest, RegistryService } from '../types.js';\n     3→\n     4→export function createRegistry(dbPath: string = ':memory:'): RegistryService {\n     5→  const db = new Database(dbPath);\n     6→\n     7→  db.exec(`\n     8→    CREATE TABLE IF NOT EXISTS plugins (\n     9→      name TEXT NOT NULL,\n    10→      version TEXT NOT NULL,\n    11→      description TEXT NOT NULL DEFAULT '',\n    12→      author TEXT NOT NULL DEFAULT '',\n    13→      dependencies TEXT NOT NULL DEFAULT '{}',\n    14→      entryPoint TEXT NOT NULL DEFAULT '',\n    15→      permissions TEXT NOT NULL DEFAULT '[]',\n    16→      PRIMARY KEY (name, version)\n    17→    )\n    18→  `);\n    19→\n    20→  const insertStmt = db.prepare(\n    21→    `INSERT OR REPLACE INTO plugins (name, version, description, author, dependencies, entryPoint, permissions)\n    22→     VALUES (@name, @version, @description, @author, @dependencies, @entryPoint, @permissions)`\n    23→  );\n    24→\n    25→  const getLatestStmt = db.prepare(\n    26→    `SELECT * FROM plugins WHERE name = ? ORDER BY version DESC LIMIT 1`\n    27→  );\n    28→\n    29→  const getVersionStmt = db.prepare(\n    30→    `SELECT * FROM plugins WHERE name = ? AND version = ?`\n    31→  );\n    32→\n    33→  const listStmt = db.prepare(`SELECT * FROM plugins ORDER BY name, version`);\n    34→\n    35→  const searchStmt = db.prepare(\n    36→    `SELECT * FROM plugins WHERE name LIKE ? OR description LIKE ? ORDER BY name, version`\n    37→  );\n    38→\n    39→  const removeStmt = db.prepare(\n    40→    `DELETE FROM plugins WHERE name = ? AND version = ?`\n    41→  );\n    42→\n    43→  const listVersionsStmt = db.prepare(\n    44→    `SELECT version FROM plugins WHERE name = ? ORDER BY version`\n    45→  );\n    46→\n    47→  const updateStmt = db.prepare(\n    48→    `UPDATE plugins SET description = @description, author = @author, dependencies = @dependencies,\n    49→     entryPoint = @entryPoint, permissions = @permissions WHERE name = @name AND version = @version`\n    50→  );\n    51→\n    52→  function rowToManifest(row: Record<string, unknown>): PluginManifest {\n    53→    return {\n    54→      name: row.name as string,\n    55→      version: row.version as string,\n    56→      description: row.description as string,\n    57→      author: row.author as string,\n    58→      dependencies: JSON.parse(row.dependencies as string) as Record<string, string>,\n    59→      entryPoint: row.entryPoint as string,\n    60→      permissions: JSON.parse(row.permissions as string) as string[],\n    61→    };\n    62→  }\n    63→\n    64→  return {\n    65→    register(manifest: PluginManifest): void {\n    66→      insertStmt.run({\n    67→        name: manifest.name,\n    68→        version: manifest.version,\n    69→        description: manifest.description,\n    70→        author: manifest.author,\n    71→        dependencies: JSON.stringify(manifest.dependencies),\n    72→        entryPoint: manifest.entryPoint,\n    73→        permissions: JSON.stringify(manifest.permissions),\n    74→      });\n    75→    },\n    76→\n    77→    get(name: string): PluginManifest | null {\n    78→      const row = getLatestStmt.get(name) as Record<string, unknown> | undefined;\n    79→      return row ? rowToManifest(row) : null;\n    80→    },\n    81→\n    82→    getVersion(name: string, version: string): PluginManifest | null {\n    83→      const row = getVersionStmt.get(name, version) as Record<string, unknown> | undefined;\n    84→      return row ? rowToManifest(row) : null;\n    85→    },\n    86→\n    87→    list(): PluginManifest[] {\n    88→      const rows = listStmt.all() as Record<string, unknown>[];\n    89→      return rows.map(rowToManifest);\n    90→    },\n    91→\n    92→    search(query: string): PluginManifest[] {\n    93→      const pattern = `%${query}%`;\n    94→      const rows = searchStmt.all(pattern, pattern) as Record<string, unknown>[];\n    95→      return rows.map(rowToManifest);\n    96→    },\n    97→\n    98→    remove(name: string, version: string): boolean {\n    99→      const result = removeStmt.run(name, version);\n   100→      return result.changes > 0;\n   101→    },\n   102→\n   103→    listVersions(name: string): string[] {\n   104→      const rows = listVersionsStmt.all(name) as Array<{ version: string }>;\n   105→      return rows.map(r => r.version);\n   106→    },\n   107→\n   108→    update(name: string, version: string, updates: Partial<PluginManifest>): void {\n   109→      const existing = getVersionStmt.get(name, version) as Record<string, unknown> | undefined;\n   110→      if (!existing) {\n   111→        throw new Error(`Plugin ${name}@${version} not found`);\n   112→      }\n   113→      const current = rowToManifest(existing);\n   114→      const merged = { ...current, ...updates, name, version };\n   115→      updateStmt.run({\n   116→        name,\n   117→        version,\n   118→        description: merged.description,\n   119→        author: merged.author,\n   120→        dependencies: JSON.stringify(merged.dependencies),\n   121→        entryPoint: merged.entryPoint,\n   122→        permissions: JSON.stringify(merged.permissions),\n   123→      });\n   124→    },\n   125→  };\n   126→}\n   127→"}]},"parent_tool_use_id":"toolu_01RwJ8z877XUzWMzo9vy9CEf","session_id":"c9797534-91fa-4c5d-889f-7e2b43d26c4c","uuid":"2f6e450e-daa7-4a7c-8bd4-f23acc77b266"}
