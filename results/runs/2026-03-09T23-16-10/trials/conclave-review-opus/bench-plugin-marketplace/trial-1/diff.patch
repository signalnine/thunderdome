+import { describe, it, expect, beforeEach } from 'vitest';
+import { createMarketplace } from './index.js';
+import type { Marketplace } from './index.js';
+import type { PluginManifest } from './types.js';
+
+function makeManifest(overrides: Partial<PluginManifest> = {}): PluginManifest {
+  return {
+    name: 'test-plugin',
+    version: '1.0.0',
+    description: 'A test plugin',
+    author: 'tester',
+    dependencies: {},
+    entryPoint: '2 + 2',
+    permissions: [],
+    ...overrides,
+  };
+}
+
+describe('createMarketplace', () => {
+  let marketplace: Marketplace;
+
+  beforeEach(() => {
+    marketplace = createMarketplace();
+  });
+
+  it('should create marketplace with all services', () => {
+    expect(marketplace.registry).toBeDefined();
+    expect(marketplace.resolver).toBeDefined();
+    expect(marketplace.runner).toBeDefined();
+    expect(marketplace.reviews).toBeDefined();
+    expect(marketplace.deps).toBeDefined();
+    expect(marketplace.installPlugin).toBeDefined();
+  });
+
+  describe('installPlugin', () => {
+    it('should install a plugin with no dependencies', async () => {
+      const manifest = makeManifest({ entryPoint: '1 + 1' });
+      const result = await marketplace.installPlugin(manifest);
+
+      expect(result.resolvedDependencies).toHaveLength(0);
+      expect(result.executionResult.success).toBe(true);
+      expect(result.executionResult.output).toBe(2);
+
+      // Should be registered in the registry
+      const registered = marketplace.registry.get('test-plugin');
+      expect(registered).not.toBeNull();
+    });
+
+    it('should install a plugin with dependencies', async () => {
+      // First register dependencies
+      marketplace.registry.register(makeManifest({
+        name: 'dep-a',
+        version: '1.0.0',
+      }));
+      marketplace.registry.register(makeManifest({
+        name: 'dep-a',
+        version: '1.5.0',
+      }));
+
+      const manifest = makeManifest({
+        name: 'my-plugin',
+        dependencies: { 'dep-a': '^1.0.0' },
+        entryPoint: '"installed"',
+      });
+
+      const result = await marketplace.installPlugin(manifest);
+      expect(result.resolvedDependencies).toHaveLength(1);
+      expect(result.resolvedDependencies[0].name).toBe('dep-a');
+      expect(result.resolvedDependencies[0].version).toBe('1.5.0');
+      expect(result.executionResult.success).toBe(true);
+    });
+
+    it('should reject plugin with missing name', async () => {
+      const manifest = makeManifest({ name: '' });
+      await expect(marketplace.installPlugin(manifest))
+        .rejects.toThrow('valid name');
+    });
+
+    it('should reject plugin with missing version', async () => {
+      const manifest = makeManifest({ version: '' });
+      await expect(marketplace.installPlugin(manifest))
+        .rejects.toThrow('valid version');
+    });
+
+    it('should reject plugin with missing entryPoint', async () => {
+      const manifest = makeManifest({ entryPoint: '' });
+      await expect(marketplace.installPlugin(manifest))
+        .rejects.toThrow('valid entryPoint');
+    });
+
+    it('should reject plugin with circular dependencies', async () => {
+      // Create a cycle: a -> b -> a
+      marketplace.registry.register(makeManifest({
+        name: 'plugin-b',
+        version: '1.0.0',
+        dependencies: { 'plugin-a': '^1.0.0' },
+      }));
+
+      const manifest = makeManifest({
+        name: 'plugin-a',
+        version: '1.0.0',
+        dependencies: { 'plugin-b': '^1.0.0' },
+        entryPoint: '"hello"',
+      });
+
+      await expect(marketplace.installPlugin(manifest))
+        .rejects.toThrow('Circular dependency');
+    });
+
+    it('should reject plugin with missing dependencies', async () => {
+      const manifest = makeManifest({
+        dependencies: { 'nonexistent-pkg': '^1.0.0' },
+        entryPoint: '"hello"',
+      });
+
+      await expect(marketplace.installPlugin(manifest))
+        .rejects.toThrow('Missing dependencies');
+    });
+
+    it('should handle plugin execution failure', async () => {
+      const manifest = makeManifest({
+        entryPoint: 'throw new Error("boot failed")',
+      });
+
+      const result = await marketplace.installPlugin(manifest);
+      expect(result.executionResult.success).toBe(false);
+      expect(result.executionResult.error).toBe('boot failed');
+    });
+  });
+});
