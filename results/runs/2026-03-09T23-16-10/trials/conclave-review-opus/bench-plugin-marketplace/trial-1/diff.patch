+import { describe, it, expect, beforeEach } from 'vitest';
+import { createReviewService } from './index.js';
+import type { ReviewService } from '../types.js';
+
+describe('ReviewService', () => {
+  let reviews: ReviewService;
+
+  beforeEach(() => {
+    reviews = createReviewService(':memory:');
+  });
+
+  it('should add a review', () => {
+    const review = reviews.addReview({
+      pluginName: 'test-plugin',
+      pluginVersion: '1.0.0',
+      userId: 'user1',
+      rating: 5,
+      comment: 'Great plugin!',
+    });
+
+    expect(review.id).toBeDefined();
+    expect(review.pluginName).toBe('test-plugin');
+    expect(review.rating).toBe(5);
+    expect(review.flagged).toBe(false);
+    expect(review.createdAt).toBeDefined();
+  });
+
+  it('should get reviews by plugin', () => {
+    reviews.addReview({
+      pluginName: 'plugin-a',
+      pluginVersion: '1.0.0',
+      userId: 'user1',
+      rating: 4,
+      comment: 'Good',
+    });
+    reviews.addReview({
+      pluginName: 'plugin-a',
+      pluginVersion: '1.0.0',
+      userId: 'user2',
+      rating: 5,
+      comment: 'Excellent',
+    });
+    reviews.addReview({
+      pluginName: 'plugin-b',
+      pluginVersion: '1.0.0',
+      userId: 'user1',
+      rating: 3,
+      comment: 'OK',
+    });
+
+    const pluginAReviews = reviews.getReviews('plugin-a');
+    expect(pluginAReviews).toHaveLength(2);
+
+    const pluginBReviews = reviews.getReviews('plugin-b');
+    expect(pluginBReviews).toHaveLength(1);
+  });
+
+  it('should compute average rating excluding flagged reviews', () => {
+    reviews.addReview({
+      pluginName: 'plugin-a',
+      pluginVersion: '1.0.0',
+      userId: 'user1',
+      rating: 4,
+      comment: 'Good',
+    });
+    reviews.addReview({
+      pluginName: 'plugin-a',
+      pluginVersion: '1.0.0',
+      userId: 'user2',
+      rating: 2,
+      comment: 'Bad',
+    });
+    const flaggedReview = reviews.addReview({
+      pluginName: 'plugin-a',
+      pluginVersion: '1.0.0',
+      userId: 'user3',
+      rating: 1,
+      comment: 'Spam',
+    });
+
+    // Before flagging: average is (4+2+1)/3 = 2.333
+    expect(reviews.getAverageRating('plugin-a')).toBeCloseTo(2.333, 2);
+
+    // Flag the spam review
+    reviews.flagReview(flaggedReview.id);
+
+    // After flagging: average is (4+2)/2 = 3
+    expect(reviews.getAverageRating('plugin-a')).toBe(3);
+  });
+
+  it('should return 0 for average with no reviews', () => {
+    expect(reviews.getAverageRating('nonexistent')).toBe(0);
+  });
+
+  it('should flag a review', () => {
+    const review = reviews.addReview({
+      pluginName: 'plugin-a',
+      pluginVersion: '1.0.0',
+      userId: 'user1',
+      rating: 1,
+      comment: 'Spam content',
+    });
+
+    reviews.flagReview(review.id);
+
+    const flagged = reviews.getFlaggedReviews();
+    expect(flagged).toHaveLength(1);
+    expect(flagged[0].id).toBe(review.id);
+    expect(flagged[0].flagged).toBe(true);
+  });
+
+  it('should get flagged reviews', () => {
+    const r1 = reviews.addReview({
+      pluginName: 'plugin-a',
+      pluginVersion: '1.0.0',
+      userId: 'user1',
+      rating: 1,
+      comment: 'Spam 1',
+    });
+    reviews.addReview({
+      pluginName: 'plugin-a',
+      pluginVersion: '1.0.0',
+      userId: 'user2',
+      rating: 5,
+      comment: 'Good',
+    });
+    const r3 = reviews.addReview({
+      pluginName: 'plugin-b',
+      pluginVersion: '1.0.0',
+      userId: 'user3',
+      rating: 1,
+      comment: 'Spam 2',
+    });
+
+    reviews.flagReview(r1.id);
+    reviews.flagReview(r3.id);
+
+    const flagged = reviews.getFlaggedReviews();
+    expect(flagged).toHaveLength(2);
+  });
+
+  it('should remove a review', () => {
+    const review = reviews.addReview({
+      pluginName: 'plugin-a',
+      pluginVersion: '1.0.0',
+      userId: 'user1',
+      rating: 4,
+      comment: 'To be removed',
+    });
+
+    const removed = reviews.removeReview(review.id);
+    expect(removed).toBe(true);
+    expect(reviews.getReviews('plugin-a')).toHaveLength(0);
+  });
+
+  it('should return false when removing non-existent review', () => {
+    expect(reviews.removeReview(9999)).toBe(false);
+  });
+
+  it('should get reviews by user', () => {
+    reviews.addReview({
+      pluginName: 'plugin-a',
+      pluginVersion: '1.0.0',
+      userId: 'user1',
+      rating: 4,
+      comment: 'Review 1',
+    });
+    reviews.addReview({
+      pluginName: 'plugin-b',
+      pluginVersion: '1.0.0',
+      userId: 'user1',
+      rating: 3,
+      comment: 'Review 2',
+    });
+    reviews.addReview({
+      pluginName: 'plugin-a',
+      pluginVersion: '1.0.0',
+      userId: 'user2',
+      rating: 5,
+      comment: 'Review 3',
+    });
+
+    const user1Reviews = reviews.getReviewsByUser('user1');
+    expect(user1Reviews).toHaveLength(2);
+
+    const user2Reviews = reviews.getReviewsByUser('user2');
+    expect(user2Reviews).toHaveLength(1);
+  });
+
+  it('should get review count', () => {
+    reviews.addReview({
+      pluginName: 'plugin-a',
+      pluginVersion: '1.0.0',
+      userId: 'user1',
+      rating: 4,
+      comment: 'Review 1',
+    });
+    reviews.addReview({
+      pluginName: 'plugin-a',
+      pluginVersion: '1.0.0',
+      userId: 'user2',
+      rating: 3,
+      comment: 'Review 2',
+    });
+
+    expect(reviews.getReviewCount('plugin-a')).toBe(2);
+    expect(reviews.getReviewCount('nonexistent')).toBe(0);
+  });
+});
