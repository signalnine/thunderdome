s).toHaveLength(2);\n\n      const childA = tree.dependencies.find(d => d.name === 'child-a');\n      expect(childA).toBeDefined();\n      expect(childA!.dependencies).toHaveLength(1);\n      expect(childA!.dependencies[0].name).toBe('grandchild');\n    });\n\n    it('should handle missing plugins gracefully', () => {\n      const tree = deps.buildTree('nonexistent', registry);\n      expect(tree.name).toBe('nonexistent');\n      expect(tree.version).toBe('unknown');\n    });\n  });\n\n  describe('detectCycles', () => {\n    it('should return null for acyclic dependencies', () => {\n      registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0' } }));\n      registry.register(makeManifest({ name: 'b' }));\n\n      expect(deps.detectCycles('a', registry)).toBeNull();\n    });\n\n    it('should detect direct circular dependencies', () => {\n      registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0' } }));\n      registry.register(makeManifest({ name: 'b', dependencies: { a: '^1.0.0' } }));\n\n      const cycles = deps.detectCycles('a', registry);\n      expect(cycles).not.toBeNull();\n      expect(cycles!.length).toBeGreaterThan(0);\n    });\n\n    it('should detect indirect circular dependencies', () => {\n      registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0' } }));\n      registry.register(makeManifest({ name: 'b', dependencies: { c: '^1.0.0' } }));\n      registry.register(makeManifest({ name: 'c', dependencies: { a: '^1.0.0' } }));\n\n      const cycles = deps.detectCycles('a', registry);\n      expect(cycles).not.toBeNull();\n    });\n  });\n\n  describe('topologicalSort', () => {\n    it('should produce correct topological order', () => {\n      registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0', c: '^1.0.0' } }));\n      registry.register(makeManifest({ name: 'b', dependencies: { d: '^1.0.0' } }));\n      registry.register(makeManifest({ name: 'c' }));\n      registry.register(makeManifest({ name: 'd' }));\n\n      const sorted = deps.topologicalSort('a', registry);\n      expect(sorted).toContain('a');\n      expect(sorted).toContain('b');\n      expect(sorted).toContain('c');\n      expect(sorted).toContain('d');\n\n      // a should come after its dependencies\n      expect(sorted.indexOf('a')).toBeGreaterThan(sorted.indexOf('b'));\n      expect(sorted.indexOf('a')).toBeGreaterThan(sorted.indexOf('c'));\n      // b should come after d\n      expect(sorted.indexOf('b')).toBeGreaterThan(sorted.indexOf('d'));\n    });\n\n    it('should throw on circular dependencies', () => {\n      registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0' } }));\n      registry.register(makeManifest({ name: 'b', dependencies: { a: '^1.0.0' } }));\n\n      expect(() => deps.topologicalSort('a', registry)).toThrow('Circular dependency');\n    });\n  });\n\n  describe('flattenDependencies', () => {\n    it('should flatten all transitive dependencies', () => {\n      registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0', c: '^1.0.0' } }));\n      registry.register(makeManifest({ name: 'b', dependencies: { d: '^1.0.0' } }));\n      registry.register(makeManifest({ name: 'c' }));\n      registry.register(makeManifest({ name: 'd' }));\n\n      const flat = deps.flattenDependencies('a', registry);\n      expect(flat).toContain('b');\n      expect(flat).toContain('c');\n      expect(flat).toContain('d');\n      expect(flat).not.toContain('a'); // should not include the root\n    });\n\n    it('should return empty array for plugin with no dependencies', () => {\n      registry.register(makeManifest({ name: 'a' }));\n      const flat = deps.flattenDependencies('a', registry);\n      expect(flat).toHaveLength(0);\n    });\n\n    it('should handle diamond dependencies', () => {\n      registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0', c: '^1.0.0' } }));\n      registry.register(makeManifest({ name: 'b', dependencies: { 