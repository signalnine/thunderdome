eviews', () => {\n    reviews.addReview({\n      pluginName: 'plugin-a',\n      pluginVersion: '1.0.0',\n      userId: 'user1',\n      rating: 4,\n      comment: 'Good',\n    });\n    reviews.addReview({\n      pluginName: 'plugin-a',\n      pluginVersion: '1.0.0',\n      userId: 'user2',\n      rating: 2,\n      comment: 'Bad',\n    });\n    const flaggedReview = reviews.addReview({\n      pluginName: 'plugin-a',\n      pluginVersion: '1.0.0',\n      userId: 'user3',\n      rating: 1,\n      comment: 'Spam',\n    });\n\n    // Before flagging: average is (4+2+1)/3 = 2.333\n    expect(reviews.getAverageRating('plugin-a')).toBeCloseTo(2.333, 2);\n\n    // Flag the spam review\n    reviews.flagReview(flaggedReview.id);\n\n    // After flagging: average is (4+2)/2 = 3\n    expect(reviews.getAverageRating('plugin-a')).toBe(3);\n  });\n\n  it('should return 0 for average with no reviews', () => {\n    expect(reviews.getAverageRating('nonexistent')).toBe(0);\n  });\n\n  it('should flag a review', () => {\n    const review = reviews.addReview({\n      pluginName: 'plugin-a',\n      pluginVersion: '1.0.0',\n      userId: 'user1',\n      rating: 1,\n      comment: 'Spam content',\n    });\n\n    reviews.flagReview(review.id);\n\n    const flagged = reviews.getFlaggedReviews();\n    expect(flagged).toHaveLength(1);\n    expect(flagged[0].id).toBe(review.id);\n    expect(flagged[0].flagged).toBe(true);\n  });\n\n  it('should get flagged reviews', () => {\n    const r1 = reviews.addReview({\n      pluginName: 'plugin-a',\n      pluginVersion: '1.0.0',\n      userId: 'user1',\n      rating: 1,\n      comment: 'Spam 1',\n    });\n    reviews.addReview({\n      pluginName: 'plugin-a',\n      pluginVersion: '1.0.0',\n      userId: 'user2',\n      rating: 5,\n      comment: 'Good',\n    });\n    const r3 = reviews.addReview({\n      pluginName: 'plugin-b',\n      pluginVersion: '1.0.0',\n      userId: 'user3',\n      rating: 1,\n      comment: 'Spam 2',\n    });\n\n    reviews.flagReview(r1.id);\n    reviews.flagReview(r3.id);\n\n    const flagged = reviews.getFlaggedReviews();\n    expect(flagged).toHaveLength(2);\n  });\n\n  it('should remove a review', () => {\n    const review = reviews.addReview({\n      pluginName: 'plugin-a',\n      pluginVersion: '1.0.0',\n      userId: 'user1',\n      rating: 4,\n      comment: 'To be removed',\n    });\n\n    const removed = reviews.removeReview(review.id);\n    expect(removed).toBe(true);\n    expect(reviews.getReviews('plugin-a')).toHaveLength(0);\n  });\n\n  it('should return false when removing non-existent review', () => {\n    expect(reviews.removeReview(9999)).toBe(false);\n  });\n\n  it('should get reviews by user', () => {\n    reviews.addReview({\n      pluginName: 'plugin-a',\n      pluginVersion: '1.0.0',\n      userId: 'user1',\n      rating: 4,\n      comment: 'Review 1',\n    });\n    reviews.addReview({\n      pluginName: 'plugin-b',\n      pluginVersion: '1.0.0',\n      userId: 'user1',\n      rating: 3,\n      comment: 'Review 2',\n    });\n    reviews.addReview({\n      pluginName: 'plugin-a',\n      pluginVersion: '1.0.0',\n      userId: 'user2',\n      rating: 5,\n      comment: 'Review 3',\n    });\n\n    const user1Reviews = reviews.getReviewsByUser('user1');\n    expect(user1Reviews).toHaveLength(2);\n\n    const user2Reviews = reviews.getReviewsByUser('user2');\n    expect(user2Reviews).toHaveLength(1);\n  });\n\n  it('should get review count', () => {\n    reviews.addReview({\n      pluginName: 'plugin-a',\n      pluginVersion: '1.0.0',\n      userId: 'user1',\n      rating: 4,\n      comment: 'Review 1',\n    });\n    reviews.addReview({\n      pluginName: 'plugin-a',\n      pluginVersion: '1.0.0',\n      userId: 'user2',\n      rating: 3,\n      comment: 'Review 2',\n    });\n\n    expect(reviews.getReviewCount('plugin-a')).toBe(2);\n    expect(reviews.getReviewCount('nonexistent')).toBe(0);\n  });\n});\n","structuredPatch":[],"originalFile":null}}
