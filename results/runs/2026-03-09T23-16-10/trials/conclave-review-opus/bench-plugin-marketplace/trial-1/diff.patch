ons: perms }));\n+\n+    const result = registry.get('test-plugin');\n+    expect(result!.permissions).toEqual(perms);\n+  });\n+});\ndiff --git a/src/resolver/index.ts b/src/resolver/index.ts\nnew file mode 100644\nindex 0000000..51b08e3\n--- /dev/null\n+++ b/src/resolver/index.ts\n@@ -0,0 +1,44 @@\n+import semver from 'semver';\n+import type { VersionConstraint, ResolvedVersion, ResolverService } from '../types.js';\n+\n+export function createResolver(): ResolverService {\n+  return {\n+    resolve(constraints: VersionConstraint[], available: Record<string, string[]>): ResolvedVersion[] {\n+      const resolved: ResolvedVersion[] = [];\n+\n+      for (const constraint of constraints) {\n+        const versions = available[constraint.name];\n+        if (!versions || versions.length === 0) {\n+          throw new Error(`No versions available for ${constraint.name}`);\n+        }\n+\n+        const best = semver.maxSatisfying(versions, constraint.range);\n+        if (!best) {\n+          throw new Error(\n+            `No version of ${constraint.name} satisfies range ${constraint.range}`\n+          );\n+        }\n+\n+        resolved.push({\n+          name: constraint.name,\n+          version: best,\n+          satisfies: constraint.range,\n+        });\n+      }\n+\n+      return resolved;\n+    },\n+\n+    satisfies(version: string, range: string): boolean {\n+      return semver.satisfies(version, range);\n+    },\n+\n+    maxSatisfying(versions: string[], range: string): string | null {\n+      return semver.maxSatisfying(versions, range);\n+    },\n+\n+    validRange(range: string): boolean {\n+      return semver.validRange(range) !== null;\n+    },\n+  };\n+}\ndiff --git a/src/resolver/resolver.test.ts b/src/resolver/resolver.test.ts\nnew file mode 100644\nindex 0000000..8edcdc6\n--- /dev/null\n+++ b/src/resolver/resolver.test.ts\n@@ -0,0 +1,91 @@\n+import { describe, it, expect } from 'vitest';\n+import { createResolver } from './index.js';\n+import type { ResolverService } from '../types.js';\n+\n+describe('ResolverService', () => {\n+  let resolver: ResolverService;\n+\n+  beforeEach(() => {\n+    resolver = createResolver();\n+  });\n+\n+  describe('resolve', () => {\n+    it('should resolve version constraints', () => {\n+      const constraints = [\n+        { name: 'foo', range: '^1.0.0' },\n+        { name: 'bar', range: '~2.0.0' },\n+      ];\n+      const available = {\n+        foo: ['1.0.0', '1.2.0', '1.5.0', '2.0.0'],\n+        bar: ['2.0.0', '2.0.5', '2.1.0', '3.0.0'],\n+      };\n+\n+      const resolved = resolver.resolve(constraints, available);\n+      expect(resolved).toHaveLength(2);\n+\n+      const foo = resolved.find(r => r.name === 'foo');\n+      expect(foo).toBeDefined();\n+      expect(foo!.version).toBe('1.5.0');\n+      expect(foo!.satisfies).toBe('^1.0.0');\n+\n+      const bar = resolved.find(r => r.name === 'bar');\n+      expect(bar).toBeDefined();\n+      expect(bar!.version).toBe('2.0.5');\n+      expect(bar!.satisfies).toBe('~2.0.0');\n+    });\n+\n+    it('should throw when no versions are available for a package', () => {\n+      const constraints = [{ name: 'missing', range: '^1.0.0' }];\n+      expect(() => resolver.resolve(constraints, {}))\n+        .toThrow('No versions available for missing');\n+    });\n+\n+    it('should throw when no version satisfies the range', () => {\n+      const constraints = [{ name: 'foo', range: '^3.0.0' }];\n+      const available = { foo: ['1.0.0', '2.0.0'] };\n+      expect(() => resolver.resolve(constraints, available))\n+        .toThrow('No version of foo satisfies range ^3.0.0');\n+    });\n+\n+    it('should resolve exact versions', () => {\n+      const constraints = [{ name: 'foo', range: '1.0.0' }];\n+      const available = { foo: ['1.0.0', '2.0.0'] };\n+\n+      const resolved = resolver.resolve(constraints, available);\n+      expect(resolved[0].version).toBe('1.0.0');\n+    });\n+  });\n+\n+  describe('satisfies', () => {\n+    it('should return true for matching versions', () => {\n+      expect(resolver.satisfies('1.5.0', '^1.0.0')).toBe(true);\n+      expect(resolver.satisfies('2.0.5', '~2.0.0')).toBe(true);\n+    });\n+\n+    it('should return false for non-matching versions', () => {\n+      expect(resolver.satisfies('2.0.0', '^1.0.0')).toBe(false);\n+      expect(resolver.satisfies('2.1.0', '~2.0.0')).toBe(false);\n+    });\n+  });\n+\n+  describe('maxSatisfying', () => {\n+    it('should find the highest matching version', () => {\n+      const versions = ['1.0.0', '1.2.0', '1.5.0', '2.0.0'];\n+      expect(resolver.maxSatisfying(versions, '^1.0.0')).toBe('1.5.0');\n+    });\n+\n+    it('should return null when nothing matches', () => {\n+      const versions = ['1.0.0', '2.0.0'];\n+      expect(resolver.maxSatisfying(versions, '^3.0.0')).toBeNull();\n+    });\n+  });\n+\n+  describe('validRange', () => {\n+    it('should validate semver ranges', () => {\n+      expect(resolver.validRange('^1.0.0')).toBe(true);\n+      expect(resolver.validRange('~2.0.0')).toBe(true);\n+      expect(resolver.validRange('>=1.0.0 <2.0.0')).toBe(true);\n+      expect(resolver.validRange('not-a-version')).toBe(false);\n+    });\n+  });\n+});\ndiff --git a/src/reviews/index.ts b/src/reviews/index.ts\nnew file mode 100644\nindex 0000000..deec0d6\n--- /dev/null\n+++ b/src/reviews/index.ts\n@@ -0,0 +1,120 @@\n+import Database from 'better-sqlite3';\n+import type { Review, ReviewService } from '../types.js';\n+\n+export function createReviewService(dbPath: string = ':memory:'): ReviewService {\n+  const db = new Database(dbPath);\n+\n+  db.exec(`\n+    CREATE TABLE IF NOT EXISTS reviews (\n+      id INTEGER PRIMARY KEY AUTOINCREMENT,\n+      pluginName TEXT NOT NULL,\n+      pluginVersion TEXT NOT NULL,\n+      userId TEXT NOT NULL,\n+      rating INTEGER NOT NULL CHECK(rating >= 1 AND rating <= 5),\n+      comment TEXT NOT NULL DEFAULT '',\n+      flagged INTEGER NOT NULL DEFAULT 0,\n+      createdAt TEXT N