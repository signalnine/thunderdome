eviews).toHaveLength(1);\n    56→  });\n    57→\n    58→  it('should compute average rating excluding flagged reviews', () => {\n    59→    reviews.addReview({\n    60→      pluginName: 'plugin-a',\n    61→      pluginVersion: '1.0.0',\n    62→      userId: 'user1',\n    63→      rating: 4,\n    64→      comment: 'Good',\n    65→    });\n    66→    reviews.addReview({\n    67→      pluginName: 'plugin-a',\n    68→      pluginVersion: '1.0.0',\n    69→      userId: 'user2',\n    70→      rating: 2,\n    71→      comment: 'Bad',\n    72→    });\n    73→    const flaggedReview = reviews.addReview({\n    74→      pluginName: 'plugin-a',\n    75→      pluginVersion: '1.0.0',\n    76→      userId: 'user3',\n    77→      rating: 1,\n    78→      comment: 'Spam',\n    79→    });\n    80→\n    81→    // Before flagging: average is (4+2+1)/3 = 2.333\n    82→    expect(reviews.getAverageRating('plugin-a')).toBeCloseTo(2.333, 2);\n    83→\n    84→    // Flag the spam review\n    85→    reviews.flagReview(flaggedReview.id);\n    86→\n    87→    // After flagging: average is (4+2)/2 = 3\n    88→    expect(reviews.getAverageRating('plugin-a')).toBe(3);\n    89→  });\n    90→\n    91→  it('should return 0 for average with no reviews', () => {\n    92→    expect(reviews.getAverageRating('nonexistent')).toBe(0);\n    93→  });\n    94→\n    95→  it('should flag a review', () => {\n    96→    const review = reviews.addReview({\n    97→      pluginName: 'plugin-a',\n    98→      pluginVersion: '1.0.0',\n    99→      userId: 'user1',\n   100→      rating: 1,\n   101→      comment: 'Spam content',\n   102→    });\n   103→\n   104→    reviews.flagReview(review.id);\n   105→\n   106→    const flagged = reviews.getFlaggedReviews();\n   107→    expect(flagged).toHaveLength(1);\n   108→    expect(flagged[0].id).toBe(review.id);\n   109→    expect(flagged[0].flagged).toBe(true);\n   110→  });\n   111→\n   112→  it('should get flagged reviews', () => {\n   113→    const r1 = reviews.addReview({\