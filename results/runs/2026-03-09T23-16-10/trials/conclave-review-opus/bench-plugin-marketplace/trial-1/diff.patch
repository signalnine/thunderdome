@@ -0,0 +1,91 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { createResolver } from './index.js';
+import type { ResolverService } from '../types.js';
+
+describe('ResolverService', () => {
+  let resolver: ResolverService;
+
+  beforeEach(() => {
+    resolver = createResolver();
+  });
+
+  describe('resolve', () => {
+    it('should resolve version constraints', () => {
+      const constraints = [
+        { name: 'foo', range: '^1.0.0' },
+        { name: 'bar', range: '~2.0.0' },
+      ];
+      const available = {
+        foo: ['1.0.0', '1.2.0', '1.5.0', '2.0.0'],
+        bar: ['2.0.0', '2.0.5', '2.1.0', '3.0.0'],
+      };
+
+      const resolved = resolver.resolve(constraints, available);
+      expect(resolved).toHaveLength(2);
+
+      const foo = resolved.find(r => r.name === 'foo');
+      expect(foo).toBeDefined();
+      expect(foo!.version).toBe('1.5.0');
+      expect(foo!.satisfies).toBe('^1.0.0');
+
+      const bar = resolved.find(r => r.name === 'bar');
+      expect(bar).toBeDefined();
+      expect(bar!.version).toBe('2.0.5');
+      expect(bar!.satisfies).toBe('~2.0.0');
+    });
+
+    it('should throw when no versions are available for a package', () => {
+      const constraints = [{ name: 'missing', range: '^1.0.0' }];
+      expect(() => resolver.resolve(constraints, {}))
+        .toThrow('No versions available for missing');
+    });
+
+    it('should throw when no version satisfies the range', () => {
+      const constraints = [{ name: 'foo', range: '^3.0.0' }];
+      const available = { foo: ['1.0.0', '2.0.0'] };
+      expect(() => resolver.resolve(constraints, available))
+        .toThrow('No version of foo satisfies range ^3.0.0');
+    });
+
+    it('should resolve exact versions', () => {
+      const constraints = [{ name: 'foo', range: '1.0.0' }];
+      const available = { foo: ['1.0.0', '2.0.0'] };
+
+      const resolved = resolver.resolve(constraints, available);
+      expect(resolved[0].version).toBe('1.0.0');
+    });
+  });
+
+  describe('satisfies', () => {
+    it('should return true for matching versions', () => {
+      expect(resolver.satisfies('1.5.0', '^1.0.0')).toBe(true);
+      expect(resolver.satisfies('2.0.5', '~2.0.0')).toBe(true);
+    });
+
+    it('should return false for non-matching versions', () => {
+      expect(resolver.satisfies('2.0.0', '^1.0.0')).toBe(false);
+      expect(resolver.satisfies('2.1.0', '~2.0.0')).toBe(false);
+    });
+  });
+
+  describe('maxSatisfying', () => {
+    it('should find the highest matching version', () => {
+      const versions = ['1.0.0', '1.2.0', '1.5.0', '2.0.0'];
+      expect(resolver.maxSatisfying(versions, '^1.0.0')).toBe('1.5.0');
+    });
+
+    it('should return null when nothing matches', () => {
+      const versions = ['1.0.0', '2.0.0'];
+      expect(resolver.maxSatisfying(versions, '^3.0.0')).toBeNull();
+    });
+  });
+
+  describe('validRange', () => {
+    it('should validate semver ranges', () => {
+      expect(resolver.validRange('^1.0.0')).toBe(true);
+      expect(resolver.validRange('~2.0.0')).toBe(true);
+      expect(resolver.validRange('>=1.0.0 <2.0.0')).toBe(true);
+      expect(resolver.validRange('not-a-version')).toBe(false);
+    });
+  });
+});
