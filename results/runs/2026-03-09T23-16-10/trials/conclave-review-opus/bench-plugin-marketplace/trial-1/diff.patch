const cycles = deps.detectCycles('a', registry);\n    90→      expect(cycles).not.toBeNull();\n    91→    });\n    92→  });\n    93→\n    94→  describe('topologicalSort', () => {\n    95→    it('should produce correct topological order', () => {\n    96→      registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0', c: '^1.0.0' } }));\n    97→      registry.register(makeManifest({ name: 'b', dependencies: { d: '^1.0.0' } }));\n    98→      registry.register(makeManifest({ name: 'c' }));\n    99→      registry.register(makeManifest({ name: 'd' }));\n   100→\n   101→      const sorted = deps.topologicalSort('a', registry);\n   102→      expect(sorted).toContain('a');\n   103→      expect(sorted).toContain('b');\n   104→      expect(sorted).toContain('c');\n   105→      expect(sorted).toContain('d');\n   106→\n   107→      // a should come after its dependencies\n   108→      expect(sorted.indexOf('a')).toBeGreaterThan(sorted.indexOf('b'));\n   109→      expect(sorted.indexOf('a')).toBeGreaterThan(sorted.indexOf('c'));\n   110→      // b should come after d\n   111→      expect(sorted.indexOf('b')).toBeGreaterThan(sorted.indexOf('d'));\n   112→    });\n   113→\n   114→    it('should throw on circular dependencies', () => {\n   115→      registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0' } }));\n   116→      registry.register(makeManifest({ name: 'b', dependencies: { a: '^1.0.0' } }));\n   117→\n   118→      expect(() => deps.topologicalSort('a', registry)).toThrow('Circular dependency');\n   119→    });\n   120→  });\n   121→\n   122→  describe('flattenDependencies', () => {\n   123→    it('should flatten all transitive dependencies', () => {\n   124→      registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0', c: '^1.0.0' } }));\n   125→      registry.register(makeManifest({ name: 'b', dependencies: { d: '^1.0.0' } }));\n   126→      registry.register(makeManifest({ name: 'c' }));\n   127→      registry.register(mak