+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JfqDagxEQRBCTjtxk1dQVg","type":"tool_result","content":"     1→import { describe, it, expect } from 'vitest';\n     2→import { createResolver } from './index.js';\n     3→import type { ResolverService } from '../types.js';\n     4→\n     5→describe('ResolverService', () => {\n     6→  let resolver: ResolverService;\n     7→\n     8→  beforeEach(() => {\n     9→    resolver = createResolver();\n    10→  });\n    11→\n    12→  describe('resolve', () => {\n    13→    it('should resolve version constraints', () => {\n    14→      const constraints = [\n    15→        { name: 'foo', range: '^1.0.0' },\n    16→        { name: 'bar', range: '~2.0.0' },\n    17→      ];\n    18→      const available = {\n    19→        foo: ['1.0.0', '1.2.0', '1.5.0', '2.0.0'],\n    20→        bar: ['2.0.0', '2.0.5', '2.1.0', '3.0.0'],\n    21→      };\n    22→\n    23→      const resolved = resolver.resolve(constraints, available);\n    24→      expect(resolved).toHaveLength(2);\n    25→\n    26→      const foo = resolved.find(r => r.name === 'foo');\n    27→      expect(foo).toBeDefined();\n    28→      expect(foo!.version).toBe('1.5.0');\n    29→      expect(foo!.satisfies).toBe('^1.0.0');\n    30→\n    31→      const bar = resolved.find(r => r.name === 'bar');\n    32→      expect(bar).toBeDefined();\n    33→      expect(bar!.version).toBe('2.0.5');\n    34→      expect(bar!.satisfies).toBe('~2.0.0');\n    35→    });\n    36→\n    37→    it('should throw when no versions are available for a package', () => {\n    38→      const constraints = [{ name: 'missing', range: '^1.0.0' }];\n    39→      expect(() => resolver.resolve(constraints, {}))\n    40→        .toThrow('No versions available for missing');\n    41→    });\n    42→\n    43→    it('should throw when no version satisfies the range', () => {\n    44→      const constraints = [{ name: 'foo', range: '^3.0.0' }];\n    45→      const available = { foo: ['1.0.0', '2.0.0'] };\n    46→      expect(() => resolver.resolve(constraints, available))\n    47→        .toThrow('No version of foo satisfies range ^3.0.0');\n    48→    });\n    49→\n    50→    it('should resolve exact versions', () => {\n    51→      const constraints = [{ name: 'foo', range: '1.0.0' }];\n    52→      const available = { foo: ['1.0.0', '2.0.0'] };\n    53→\n    54→      const resolved = resolver.resolve(constraints, available);\n    55→      expect(resolved[0].version).toBe('1.0.0');\n    56→    });\n    57→  });\n    58→\n    59→  describe('satisfies', () => {\n    60→    it('should return true for matching versions', () => {\n    61→      expect(resolver.satisfies('1.5.0', '^1.0.0')).toBe(true);\n    62→      expect(resolver.satisfies('2.0.5', '~2.0.0')).toBe(true);\n    63→    });\n    64→\n    65→    it('should return false for non-matching versions', () => {\n    66→      expect(resolver.satisfies('2.0.0', '^1.0.0')).toBe(false);\n    67→      expect(resolver.satisfies('2.1.0', '~2.0.0')).toBe(false);\n    68→    });\n    69→  });\n    70→\n    71→  describe('maxSatisfying', () => {\n    72→    it('should find the highest matching version', () => {\n    73→      const versions = ['1.0.0', '1.2.0', '1.5.0', '2.0.0'];\n    74→      expect(resolver.maxSatisfying(versions, '^1.0.0')).toBe('1.5.0');\n    75→    });\n    76→\n    77→    it('should return null when nothing matches', () => {\n    78→      const versions = ['1.0.0', '2.0.0'];\n    79→      expect(resolver.maxSatisfying(versions, '^3.0.0')).toBeNull();\n    80→    });\n    81→  });\n    82→\n    83→  describe('validRange', () => {\n    84→    it('should validate semver ranges', () => {\n    85→      expect(resolver.validRange('^1.0.0')).toBe(true);\n    86→      expect(resolver.validRange('~2.0.0')).toBe(true);\n    87→      expect(resolver.validRange('>=1.0.0 <2.0.0')).toBe(true);\n    88→      expect(resolver.validRange('not-a-version')).toBe(false);\n    89→    });\n    90→  });\n    91→});\n    92→"}]},"parent_tool_use_id":"toolu_01RwJ8z877XUzWMzo9vy9CEf","session_id":"c9797534-91fa-4c5d-889f-7e2b43d26c4c","uuid":"c23577d1-3e8f-4dd4-a3e8-472c3496db86"}
