ay values changed differently', () => {\n      store.create('doc1', { tags: ['a'] });\n      store.createBranch('feature');\n\n      store.update('doc1', { tags: ['b'] });\n\n      store.switchBranch('feature');\n      store.update('doc1', { tags: ['c'] });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(false);\n      expect(result.conflicts).toHaveLength(1);\n      expect(result.conflicts[0].path).toBe('tags');\n    });\n\n    it('should throw when merging from non-existent branch', () => {\n      expect(() => store.merge('nonexistent')).toThrow();\n    });\n\n    it('should handle multiple conflicts across different documents', () => {\n      store.create('doc1', { x: 1 });\n      store.create('doc2', { y: 2 });\n      store.createBranch('feature');\n\n      store.update('doc1', { x: 10 });\n      store.update('doc2', { y: 20 });\n\n      store.switchBranch('feature');\n      store.update('doc1', { x: 100 });\n      store.update('doc2', { y: 200 });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(false);\n      expect(result.conflicts).toHaveLength(2);\n      const docIds = result.conflicts.map(c => c.documentId).sort();\n      expect(docIds).toEqual(['doc1', 'doc2']);\n    });\n\n    it('should handle merging when target creates a new document', () => {\n      store.createBranch('feature');\n\n      // Create doc on main after branching\n      store.create('doc1', { a: 1 });\n\n      // Merge feature (no changes) into main\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      // doc1 should still exist since it was only on main\n      expect(store.get('doc1')).toEqual({ a: 1 });\n    });\n\n    it('should produce a version entry after auto-applied merge', () => {\n      store.create('doc1', { a: 1, b: 2 });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: 1, b: 20 });\n\n      store.switchBranch('main');\n      const historyBefore = store.getHistory('doc1');\n\n      store.merge('feature');\n\n      const historyAfter = store.getHistory('doc1');\n      expect(historyAfter.length).toBe(historyBefore.length + 1);\n      expect(historyAfter[historyAfter.length - 1].content).toEqual({ a: 1, b: 20 });\n    });\n\n    it('should handle mixed conflicts and clean merges across fields', () => {\n      store.create('doc1', { a: 1, b: 2, c: 3 });\n      store.createBranch('feature');\n\n      // main changes a and c\n      store.update('doc1', { a: 10, b: 2, c: 30 });\n\n      // feature changes b and c (c conflicts)\n      store.switchBranch('feature');\n      store.update('doc1', { a: 1, b: 20, c: 300 });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(false);\n      expect(result.conflicts).toHaveLength(1);\n      expect(result.conflicts[0].path).toBe('c');\n      // merged should have: a=10 (ours), b=20 (theirs, no conflict), c=30 (ours, conflict)\n      expect(result.merged['doc1']).toEqual({ a: 10, b: 20, c: 30 });\n    });\n  });\n});\n","structuredPatch":[{"oldStart":578,"oldLines":5,"newStart":578,"newLines":88,"lines":["       // merged should have: a=10 (ours), b=20 (theirs, no conflict), c=30 (ours, conflict)","       expect(result.merged['doc1']).toEqual({ a: 10, b: 20, c: 30 });","     });","+","+    it('should handle deepEqual with different key order', () => {","+      store.create('doc1', { a: 1, b: 2 });","+      store.createBranch('feature');","+","+      // Both sides set identical content but potentially different key order","+      store.update('doc1', { b: 2, a: 1 });","+      store.switchBranch('feature');","+      store.update('doc1', { a: 1, b: 2 });","+","+      store.switchBranch('main');","+      const result = store.merge('feature');","+","+      // No change on either side relative to bas