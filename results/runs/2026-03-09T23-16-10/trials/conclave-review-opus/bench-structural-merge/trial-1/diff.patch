n      store.create('doc1', { a: { x: 1 }, b: 2 });\n      store.createBranch('feature');\n\n      // feature removes a.x, leaving a empty\n      store.switchBranch('feature');\n      store.update('doc1', { b: 2 });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.merged['doc1']).toEqual({ b: 2 });\n      expect(store.get('doc1')).toEqual({ b: 2 });\n    });\n\n    it('should handle null field values', () => {\n      store.create('doc1', { a: null, b: 2 });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: 'now set', b: 2 });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.merged['doc1']).toEqual({ a: 'now set', b: 2 });\n    });\n  });\n});","originalFile":"import { describe, it, expect, beforeEach } from 'vitest';\nimport { DocumentStore } from '../src/index.js';\nimport type { MergeResult, Version, Conflict } from '../src/index.js';\n\ndescribe('DocumentStore', () => {\n  let store: DocumentStore;\n\n  beforeEach(() => {\n    store = new DocumentStore();\n  });\n\n  describe('Document CRUD', () => {\n    it('should create and get a document', () => {\n      store.create('doc1', { name: 'Alice', age: 30 });\n      const doc = store.get('doc1');\n      expect(doc).toEqual({ name: 'Alice', age: 30 });\n    });\n\n    it('should throw when creating a document with duplicate ID', () => {\n      store.create('doc1', { name: 'Alice' });\n      expect(() => store.create('doc1', { name: 'Bob' })).toThrow();\n    });\n\n    it('should throw when getting a non-existent document', () => {\n      expect(() => store.get('nonexistent')).toThrow();\n    });\n\n    it('should update a document', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.update('doc1', { name: 'Bob' });\n      expect(store.get('doc1')).toEqual({ name: 'Bob' });\n    });\n\n    it('should throw when updating a non-existent document', () => {\n      expect(() => store.update('nonexistent', { name: 'Bob' })).toThrow();\n    });\n\n    it('should delete a document', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.delete('doc1');\n      expect(() => store.get('doc1')).toThrow();\n    });\n\n    it('should throw when deleting a non-existent document', () => {\n      expect(() => store.delete('nonexistent')).toThrow();\n    });\n\n    it('should throw when deleting an already deleted document', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.delete('doc1');\n      expect(() => store.delete('doc1')).toThrow();\n    });\n\n    it('should deep clone on create to prevent external mutation', () => {\n      const content = { name: 'Alice', nested: { x: 1 } };\n      store.create('doc1', content);\n      content.nested.x = 999;\n      expect(store.get('doc1')).toEqual({ name: 'Alice', nested: { x: 1 } });\n    });\n\n    it('should deep clone on get to prevent external mutation', () => {\n      store.create('doc1', { name: 'Alice', nested: { x: 1 } });\n      const doc = store.get('doc1') as any;\n      doc.nested.x = 999;\n      expect(store.get('doc1')).toEqual({ name: 'Alice', nested: { x: 1 } });\n    });\n\n    it('should deep clone on update to prevent external mutation', () => {\n      store.create('doc1', { name: 'Alice' });\n      const content = { name: 'Bob', nested: { x: 1 } };\n      store.update('doc1', content);\n      content.nested.x = 999;\n      expect(store.get('doc1')).toEqual({ name: 'Bob', nested: { x: 1 } });\n    });\n\n    it('should allow creating a document after it was deleted', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.delete('doc1');\n      store.create('doc1', { name: 'Bob' });\n      expect(store.get('doc1')).toEqual({ name: 'Bob' });\n    });\n  });\n\n  describe('Version History', () => {\n    it('should track versions on create', () => {\n      store.create('doc1', { name: 'Alice' });\n      const history = store.getHistory('doc1');\n      expect(history).toHaveLength(1);\n      expect(history[0].content).toEqual({ name: 'Alice' });\n      expect(typeof history[0].id).toBe('string');\n      expect(typeof history[0].timestamp).toBe('number');\n    });\n\n    it('should track versions on update', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.update('doc1', { name: 'Bob' });\n      store.update('doc1', { name: 'Charlie' });\n      const history = store.getHistory('doc1');\n      expect(history).toHaveLength(3);\n      expect(history[0].content).toEqual({ name: 'Alice' });\n      expect(history[1].content).toEqual({ name: 'Bob' });\n      expect(history[2].content).toEqual({ name: 'Charlie' });\n    });\n\n    it('should return versions in chronological order', () => {\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n      store.update('doc1', { v: 3 });\n      const history = store.getHistory('doc1');\n      for (let i = 1; i < history.length; i++) {\n        expect(history[i].timestamp).toBeGreaterThanOrEqual(history[i - 1].timestamp);\n      }\n    });\n\n    it('should get a specific version by versionId', () => {\n      store.create('doc1', { name: 'v1' });\n      store.update('doc1', { name: 'v2' });\n      const history = store.getHistory('doc1');\n      const v1Content = store.getVersion('doc1', history[0].id);\n      expect(v1Content).toEqual({ name: 'v1' });\n      const v2Content = store.getVersion('doc1', history[1].id);\n      expect(v2Content).toEqual({ name: 'v2' });\n    });\n\n    it('should throw when getting history for non-existent document', () => {\n      expect(() => store.getHistory('nonexistent')).toThrow();\n    });\n\n    it('should throw when getting a non-existent version', () => {\n      store.create('doc1', { name: 'Alice' });\n      expect(() => store.getVersion('doc1', 'bad-version-id')).toThrow();\n    });\n\n    it('should deep clone version contents', () => {\n      store.create('doc1', { nested: { x: 1 } });\n      const history = store.getHistory('doc1');\n      (history[0].content as any).nested.x = 999;\n      expect(store.getHistory('doc1')[0].content).toEqual({ nested: { x: 1 } });\n    });\n\n    it('should have unique version IDs', () => {\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n      store.update('doc1', { v: 3 });\n      const history = store.getHistory('doc1');\n      const ids = history.map(v => v.id);\n      expect(new Set(ids).size).toBe(ids.length);\n    });\n  });\n\n  describe('Branching', () => {\n    it('should default to main branch', () => {\n      expect(store.getBranch()).toBe('main');\n    });\n\n    it('should list branches', () => {\n      expect(store.listBranches()).toEqual(['main']);\n    });\n\n    it('should create a branch from current branch', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n      expect(store.listBranches()).toContain('feature');\n    });\n\n    it('should switch branches', () => {\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      expect(store.getBranch()).toBe('feature');\n    });\n\n    it('should throw when switching to non-existent branch', () => {\n      expect(() => store.switchBranch('nonexistent')).toThrow();\n    });\n\n    it('should throw when creating a branch that already exists', () => {\n      store.createBranch('feature');\n      expect(() => store.createBranch('feature')).toThrow();\n    });\n\n    it('should isolate changes between branches', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'Bob' });\n      expect(store.get('doc1')).toEqual({ name: 'Bob' });\n\n      store.switchBranch('main');\n      expect(store.get('doc1')).toEqual({ name: 'Alice' });\n    });\n\n    it('should inherit documents when branching', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      expect(store.get('doc1')).toEqual({ name: 'Alice' });\n    });\n\n    it('should create a branch from a specified branch', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'Bob' });\n\n      store.switchBranch('main');\n      store.createBranch('feature2', 'feature');\n      store.switchBranch('feature2');\n      expect(store.get('doc1')).toEqual({ name: 'Bob' });\n    });\n\n    it('should not share document references between branches', () => {\n      store.create('doc1', { nested: { x: 1 } });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { nested: { x: 2 } });\n\n      store.switchBranch('main');\n      expect(store.get('doc1')).toEqual({ nested: { x: 1 } });\n    });\n\n    it('should allow creating documents on one branch without affecting another', () => {\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.create('doc1', { name: 'Alice' });\n\n      store.switchBranch('main');\n      expect(() => store.get('doc1')).toThrow();\n    });\n\n    it('should allow deleting documents on one branch without affecting another', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.delete('doc1');\n\n      store.switchBranch('main');\n      expect(store.get('doc1')).toEqual({ name: 'Alice' });\n    });\n  });\n\n  describe('Merging', () => {\n    it('should merge non-conflicting changes from source into target', () => {\n      store.create('doc1', { a: 1, b: 2 });\n      store.createBranch('feature');\n\n      // Modify on feature\n      store.switchBranch('feature');\n      store.update('doc1', { a: 1, b: 3 });\n\n      // Merge feature into main\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(result.merged['doc1']).toEqual({ a: 1, b: 3 });\n      expect(store.get('doc1')).toEqual({ a: 1, b: 3 });\n    });\n\n    it('should merge when both sides change different fields', () => {\n      store.create('doc1', { a: 1, b: 2, c: 3 });\n      store.createBranch('feature');\n\n      // Modify field a on main\n      store.update('doc1', { a: 10, b: 2, c: 3 });\n\n      // Modify field b on feature\n      store.switchBranch('feature');\n      store.update('doc1', { a: 1, b: 20, c: 3 });\n\n      // Merge feature into main\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(result.merged['doc1']).toEqual({ a: 10, b: 20, c: 3 });\n      expect(store.get('doc1')).toEqual({ a: 10, b: 20, c: 3 });\n    });\n\n    it('should detect conflicts when both sides change the same field to different values', () => {\n      store.create('doc1', { a: 1, b: 2 });\n      store.createBranch('feature');\n\n      store.update('doc1', { a: 10, b: 2 });\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: 20, b: 2 });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(false);\n      expect(result.conflicts).toHaveLength(1);\n      expect(result.conflicts[0]).toEqual({\n        documentId: 'doc1',\n        path: 'a',\n        base: 1,\n        ours: 10,\n        theirs: 20,\n      });\n      // merged should show \"ours\" for conflicted fields\n      expect(result.merged['doc1']).toEqual({ a: 10, b: 2 });\n      // The branch should be unchanged\n      expect(store.get('doc1')).toEqual({ a: 10, b: 2 });\n    });\n\n    it('should not apply merge when there are conflicts', () => {\n      store.create('doc1', { a: 1 });\n      store.createBranch('feature');\n\n      store.update('doc1', { a: 2 });\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: 3 });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(false);\n      // doc1 should remain unchanged on main\n      expect(store.get('doc1')).toEqual({ a: 2 });\n    });\n\n    it('should not conflict when both sides change the same field to the same value', () => {\n      store.create('doc1', { a: 1, b: 2 });\n      store.createBranch('feature');\n\n      store.update('doc1', { a: 42, b: 2 });\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: 42, b: 2 });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(result.merged['doc1']).toEqual({ a: 42, b: 2 });\n    });\n\n    it('should merge new documents from source branch', () => {\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.create('doc1', { name: 'Alice' });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.merged['doc1']).toEqual({ name: 'Alice' });\n      expect(store.get('doc1')).toEqual({ name: 'Alice' });\n    });\n\n    it('should handle merging when source deletes a document not modified on target', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.delete('doc1');\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.merged['doc1']).toBeUndefined();\n      expect(() => store.get('doc1')).toThrow();\n    });\n\n    it('should handle merging multiple documents independently', () => {\n      store.create('doc1', { a: 1 });\n      store.create('doc2', { b: 2 });\n      store.createBranch('feature');\n\n      // Modify doc1 on main\n      store.update('doc1', { a: 10 });\n\n      // Modify doc2 on feature\n      store.switchBranch('feature');\n      store.update('doc2', { b: 20 });\n\n      // Merge\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(store.get('doc1')).toEqual({ a: 10 });\n      expect(store.get('doc2')).toEqual({ b: 20 });\n    });\n\n    it('should merge with deeply nested fields', () => {\n      store.create('doc1', { a: { b: { c: 1, d: 2 }, e: 3 } });\n      store.createBranch('feature');\n\n      // Modify c on main\n      store.update('doc1', { a: { b: { c: 10, d: 2 }, e: 3 } });\n\n      // Modify d on feature\n      store.switchBranch('feature');\n      store.update('doc1', { a: { b: { c: 1, d: 20 }, e: 3 } });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(result.merged['doc1']).toEqual({ a: { b: { c: 10, d: 20 }, e: 3 } });\n      expect(store.get('doc1')).toEqual({ a: { b: { c: 10, d: 20 }, e: 3 } });\n    });\n\n    it('should report conflict with dot-separated path for nested fields', () => {\n      store.create('doc1', { a: { b: { c: 1 } } });\n      store.createBranch('feature');\n\n      store.update('doc1', { a: { b: { c: 10 } } });\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: { b: { c: 20 } } });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(false);\n      expect(result.conflicts).toHaveLength(1);\n      expect(result.conflicts[0].path).to