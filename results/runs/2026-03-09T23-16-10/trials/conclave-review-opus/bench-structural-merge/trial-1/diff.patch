ure removes a.x, leaving a empty\n      store.switchBranch('feature');\n      store.update('doc1', { b: 2 });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.merged['doc1']).toEqual({ b: 2 });\n      expect(store.get('doc1')).toEqual({ b: 2 });\n    });\n\n    it('should handle null field values', () => {\n      store.create('doc1', { a: null, b: 2 });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: 'now set', b: 2 });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.merged['doc1']).toEqual({ a: 'now set', b: 2 });\n    });\n  });\n});"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3032,"cache_read_input_tokens":64263,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3032},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"e90bbadc-64ec-440b-831d-e01741cc18b3","uuid":"2b211e9a-a2ac-4a08-88b1-9fde7ddb3dc8"}
