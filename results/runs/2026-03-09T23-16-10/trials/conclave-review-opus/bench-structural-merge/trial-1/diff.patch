    expect(result.applied).toBe(false);\n   525→      expect(result.conflicts).toHaveLength(2);\n   526→      const docIds = result.conflicts.map(c => c.documentId).sort();\n   527→      expect(docIds).toEqual(['doc1', 'doc2']);\n   528→    });\n   529→\n   530→    it('should handle merging when target creates a new document', () => {\n   531→      store.createBranch('feature');\n   532→\n   533→      // Create doc on main after branching\n   534→      store.create('doc1', { a: 1 });\n   535→\n   536→      // Merge feature (no changes) into main\n   537→      const result = store.merge('feature');\n   538→\n   539→      expect(result.applied).toBe(true);\n   540→      // doc1 should still exist since it was only on main\n   541→      expect(store.get('doc1')).toEqual({ a: 1 });\n   542→    });\n   543→\n   544→    it('should produce a version entry after auto-applied merge', () => {\n   545→      store.create('doc1', { a: 1, b: 2 });\n   546→      store.createBranch('feature');\n   547→\n   548→      store.switchBranch('feature');\n   549→      store.update('doc1', { a: 1, b: 20 });\n   550→\n   551→      store.switchBranch('main');\n   552→      const historyBefore = store.getHistory('doc1');\n   553→\n   554→      store.merge('feature');\n   555→\n   556→      const historyAfter = store.getHistory('doc1');\n   557→      expect(historyAfter.length).toBe(historyBefore.length + 1);\n   558→      expect(historyAfter[historyAfter.length - 1].content).toEqual({ a: 1, b: 20 });\n   559→    });\n   560→\n   561→    it('should handle mixed conflicts and clean merges across fields', () => {\n   562→      store.create('doc1', { a: 1, b: 2, c: 3 });\n   563→      store.createBranch('feature');\n   564→\n   565→      // main changes a and c\n   566→      store.update('doc1', { a: 10, b: 2, c: 30 });\n   567→\n   568→      // feature changes b and c (c conflicts)\n   569→      store.switchBranch('feature');\n   570→      store.update('doc1', { a: 1, b: 20, c: 300 });\n   571→\n