+export interface Version {
+  id: string;
+  timestamp: number;
+  content: object;
+}
+
+export interface Conflict {
+  documentId: string;
+  path: string;
+  base: unknown;
+  ours: unknown;
+  theirs: unknown;
+}
+
+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+interface DocumentRecord {
+  content: object;
+  versions: Version[];
+  deleted: boolean;
+}
+
+interface BranchState {
+  documents: Map<string, DocumentRecord>;
+  forkPoint: Map<string, DocumentRecord> | null;
+  forkedFrom: string | null;
+}
+
+type JsonValue = string | number | boolean | null | JsonValue[] | { [key: string]: JsonValue };
+type JsonObject = Record<string, JsonValue>;
+
+function deepClone<T>(obj: T): T {
+  return JSON.parse(JSON.stringify(obj));
+}
+
+function generateId(): string {
+  return Math.random().toString(36).slice(2) + Date.now().toString(36);
+}
+
+function cloneDocumentRecord(rec: DocumentRecord): DocumentRecord {
+  return {
+    content: deepClone(rec.content),
+    versions: rec.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    })),
+    deleted: rec.deleted,
+  };
+}
+
+function cloneDocumentsMap(docs: Map<string, DocumentRecord>): Map<string, DocumentRecord> {
+  const cloned = new Map<string, DocumentRecord>();
+  for (const [id, rec] of docs) {
+    cloned.set(id, cloneDocumentRecord(rec));
+  }
+  return cloned;
+}
+
+/**
+ * Collect all leaf paths from an object. Returns dot-separated paths.
+ */
+function collectPaths(obj: unknown, prefix: string = ''): string[] {
+  const paths: string[] = [];
+  if (obj === null || obj === undefined || typeof obj !== 'object' || Array.isArray(obj)) {
+    return [prefix || ''];
+  }
+  const record = obj as JsonObject;
+  const keys = Object.keys(record);
+  if (keys.length === 0) {
+    return [prefix || ''];
+  }
+  for (const key of keys) {
+    const fullPath = prefix ? `${prefix}.${key}` : key;
+    const val = record[key];
+    if (val !== null && val !== undefined && typeof val === 'object' && !Array.isArray(val) && Object.keys(val).length > 0) {
+      paths.push(...collectPaths(val, fullPath));
+    } else {
+      paths.push(fullPath);
+    }
+  }
+  return paths;
+}
+
+function getByPath(obj: unknown, path: string): unknown {
+  if (!path) return obj;
+  const parts = path.split('.');
+  let current: unknown = obj;
+  for (const part of parts) {
+    if (current === null || current === undefined || typeof current !== 'object') {
+      return undefined;
+    }
+    current = (current as Record<string, unknown>)[part];
+  }
+  return current;
+}
+
+function setByPath(obj: Record<string, unknown>, path: string, value: unknown): void {
+  const parts = path.split('.');
+  let current: Record<string, unknown> = obj;
+  for (let i = 0; i < parts.length - 1; i++) {
+    const part = parts[i];
+    if (current[part] === undefined || current[part] === null || typeof current[part] !== 'object') {
+      current[part] = {};
+    }
+    current = current[part] as Record<string, unknown>;
+  }
+  current[parts[parts.length - 1]] = value;
+}
+
+function deleteByPath(obj: Record<string, unknown>, path: string): void {
+  const parts = path.split('.');
+  const stack: { parent: Record<string, unknown>; key: string }[] = [];
+  let current: Record<string, unknown> = obj;
+  for (let i = 0; i < parts.length - 1; i++) {
+    const part = parts[i];
+    if (current[part] === undefined || current[part] === null || typeof current[part] !== 'object') {
+      return;
+    }
+    stack.push({ parent: current, key: part });
+    current = current[part] as Record<string, unknown>;
+  }
+  delete current[parts[parts.length - 1]];
+
+  // Clean up empty parent objects
+  for (let i = stack.length - 1; i >= 0; i--) {
+    const { parent, key } = stack[i];
+    const child = parent[key];
+    if (child && typeof child === 'object' && Object.keys(child).length === 0) {
+      delete parent[key];
+    } else {
+      break;
+    }
+  }
+}
+
+function deepEqual(a: unknown, b: unknown): boolean {
+  if (a === b) return true;
+  if (a === null || b === null) return false;
+  if (a === undefined || b === undefined) return false;
+  if (typeof a !== typeof b) return false;
+  if (typeof a !== 'object') return a === b;
+
+  if (Array.isArray(a) !== Array.isArray(b)) return false;
+  if (Array.isArray(a) && Array.isArray(b)) {
+    if (a.length !== b.length) return false;
+    return a.every((val, i) => deepEqual(val, b[i]));
+  }
+
+  const aObj = a as Record<string, unknown>;
+  const bObj = b as Record<string, unknown>;
+  const aKeys = Object.keys(aObj);
+  const bKeys = Object.keys(bObj);
+  if (aKeys.length !== bKeys.length) return false;
+  return aKeys.every(key => key in bObj && deepEqual(aObj[key], bObj[key]));
+}
+
+/**
+ * Three-way merge of two objects against a common base.
+ * Returns the merged result and any conflicts.
+ */
+function threeWayMerge(
+  base: object | undefined,
+  ours: object | undefined,
+  theirs: object | undefined,
+  documentId: string,
+): { merged: object; conflicts: Conflict[] } {
+  const conflicts: Conflict[] = [];
+
+  // Collect all unique paths across base, ours, theirs
+  const allPaths = new Set<string>();
+  if (base && typeof base === 'object') collectPaths(base).forEach(p => allPaths.add(p));
+  if (ours && typeof ours === 'object') collectPaths(ours).forEach(p => allPaths.add(p));
+  if (theirs && typeof theirs === 'object') collectPaths(theirs).forEach(p => allPaths.add(p));
+
+  const merged = deepClone(ours ?? {}) as Record<string, unknown>;
+
+  // Sort paths so parent paths come before child paths.
+  // This allows us to skip child paths when a parent has already been resolved.
+  const sortedPaths = Array.from(allPaths).sort();
+  const resolvedPrefixes: string[] = [];
+
+  for (const path of sortedPaths) {
+    // Skip if a parent path was already resolved as a non-object value
+    if (resolvedPrefixes.some(prefix => path.startsWith(prefix + '.'))) {
+      continue;
+    }
+
+    const baseVal = base ? getByPath(base, path) : undefined;
+    const oursVal = ours ? getByPath(ours, path) : undefined;
+    const theirsVal = theirs ? getByPath(theirs, path) : undefined;
+
+    const oursChanged = !deepEqual(baseVal, oursVal);
+    const theirsChanged = !deepEqual(baseVal, theirsVal);
+
+    if (!oursChanged && !theirsChanged) {
+      continue;
+    }
+
+    if (oursChanged && !theirsChanged) {
+      continue;
+    }
+
+    if (!oursChanged && theirsChanged) {
+      if (theirsVal === undefined) {
+        deleteByPath(merged, path);
+      } else {
+        setByPath(merged, path, deepClone(theirsVal));
+        // If we set a non-object value at this path, mark it so child paths are skipped
+        if (typeof theirsVal !== 'object' || theirsVal === null || Array.isArray(theirsVal)) {
+          resolvedPrefixes.push(path);
+        }
+      }
+      continue;
+    }
+
+    // Both changed
+    if (deepEqual(oursVal, theirsVal)) {
+      continue;
+    }
+
+    // Conflict - keep ours in merged, record conflict
+    conflicts.push({
+      documentId,
+      path,
+      base: deepClone(baseVal),
+      ours: deepClone(oursVal),
+      theirs: deepClone(theirsVal),
+    });
+    // If ours is a non-object, child paths are irrelevant
+    if (typeof oursVal !== 'object' || oursVal === null || Array.isArray(oursVal)) {
+      resolvedPrefixes.push(path);
+    }
+  }
+
+  return { merged, conflicts };
+}
+
+export class DocumentStore {
+  private branches: Map<string, BranchState> = new Map();
+  private currentBranch: string = 'main';
+
+  constructor() {
+    this.branches.set('main', {
+      documents: new Map(),
+      forkPoint: null,
+      forkedFrom: null,
+    });
+  }
+
+  // --- Document CRUD ---
+
+  create(id: string, content: object): void {
+    const branch = this.getCurrentBranchState();
+    const existing = branch.documents.get(id);
+    if (existing && !existing.deleted) {
+      throw new Error(`Document "${id}" already exists`);
+    }
+    const version: Version = {
+      id: generateId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+    branch.documents.set(id, {
+      content: deepClone(content),
+      versions: [version],
+      deleted: false,
+    });
+  }
+
+  get(id: string): object {
+    const branch = this.getCurrentBranchState();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    return deepClone(doc.content);
+  }
+
+  update(id: string, content: object): void {
+    const branch = this.getCurrentBranchState();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    const version: Version = {
+      id: generateId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+    doc.content = deepClone(content);
+    doc.versions.push(version);
+  }
+
+  delete(id: string): void {
+    const branch = this.getCurrentBranchState();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    doc.deleted = true;
+    doc.content = {};
+  }
+
+  // --- Version History ---
+
+  getHistory(id: string): Version[] {
+    const branch = this.getCurrentBranchState();
+    const doc = branch.documents.get(id);
+    if (!doc) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    return doc.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    }));
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const branch = this.getCurrentBranchState();
+    const doc = branch.documents.get(id);
+    if (!doc) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    const version = doc.versions.find(v => v.id === versionId);
+    if (!version) {
+      throw new Error(`Version "${versionId}" not found for document "${id}"`);
+    }
+    return deepClone(version.content);
+  }
+
+  // --- Branching ---
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch "${name}" already exists`);
+    }
+    const sourceName = fromBranch ?? this.currentBranch;
+    const source = this.branches.get(sourceName);
+    if (!source) {
+      throw new Error(`Branch "${sourceName}" not found`);
+    }
+    const clonedDocs = cloneDocumentsMap(source.documents);
+    const forkSnapshot = cloneDocumentsMap(source.documents);
+    this.branches.set(name, {
+      documents: clonedDocs,
+      forkPoint: forkSnapshot,
+      forkedFrom: sourceName,
+    });
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch "${name}" not found`);
+    }
+    this.currentBranch = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranch;
+  }
+
+  listBranches(): string[] {
+    return Array.from(this.branches.keys());
+  }
+
+  // --- Merging ---
+
+  merge(sourceBranch: string): MergeResult {
+    const sourceBranchState = this.branches.get(sourceBranch);
+    if (!sourceBranchState) {
+      throw new Error(`Branch "${sourceBranch}" not found`);
+    }
+    const targetBranchState = this.getCurrentBranchState();
+
+    // Determine the common ancestor (base).
+    let base: Map<string, DocumentRecord>;
+    if (sourceBranchState.forkedFrom === this.currentBranch && sourceBranchState.forkPoint) {
+      base = sourceBranchState.forkPoint;
+    } else if (targetBranchState.forkedFrom === sourceBranch && targetBranchState.forkPoint) {
+      base = targetBranchState.forkPoint;
+    } else {
+      base = new Map();
+    }
+
+    // Collect all document IDs across base, source, and target
+    const allDocIds = new Set<string>();
+    for (const id of base.keys()) allDocIds.add(id);
+    for (const id of sourceBranchState.documents.keys()) allDocIds.add(id);
+    for (const id of targetBranchState.documents.keys()) allDocIds.add(id);
+
+    const merged: Record<string, object> = {};
+    const allConflicts: Conflict[] = [];
+
+    for (const docId of allDocIds) {
+      const baseDoc = base.get(docId);
+      const sourceDoc = sourceBranchState.documents.get(docId);
+      const targetDoc = targetBranchState.documents.get(docId);
+
+      const baseContent = baseDoc && !baseDoc.deleted ? baseDoc.content : undefined;
+      const sourceContent = sourceDoc && !sourceDoc.deleted ? sourceDoc.content : undefined;
+      const targetContent = targetDoc && !targetDoc.deleted ? targetDoc.content : undefined;
+
+      const baseDeleted = baseDoc ? baseDoc.deleted : true;
+      const sourceDeleted = sourceDoc ? sourceDoc.deleted : true;
+      const targetDeleted = targetDoc ? targetDoc.deleted : true;
+
+      const sourceChanged = !deepEqual(baseContent, sourceContent) || baseDeleted !== sourceDeleted;
+      const targetChanged = !deepEqual(baseContent, targetContent) || baseDeleted !== targetDeleted;
+
+      if (!sourceChanged && !targetChanged) {
+        if (targetContent !== undefined) {
+          merged[docId] = deepClone(targetContent);
+        }
+        continue;
+      }
+
+      if (sourceChanged && !targetChanged) {
+        if (!sourceDeleted) {
+          merged[docId] = deepClone(sourceContent!);
+        }
+        continue;
+      }
+
+      if (!sourceChanged && targetChanged) {
+        if (!targetDeleted) {
+          merged[docId] = deepClone(targetContent!);
+        }
+        continue;
+      }
+
+      // Both changed
+      if (sourceDeleted && targetDeleted) {
+        continue;
+      }
+
+      if (sourceDeleted && !targetDeleted) {
+        merged[docId] = deepClone(targetContent!);
+        allConflicts.push({
+          documentId: docId,
+          path: '',
+          base: baseContent !== undefined ? deepClone(baseContent) : undefined,
+          ours: deepClone(targetContent!),
+          theirs: undefined,
+        });
+        continue;
+      }
+
+      if (!sourceDeleted && targetDeleted) {
+        allConflicts.push({
+          documentId: docId,
+          path: '',
+          base: baseContent !== undefined ? deepClone(baseContent) : undefined,
+          ours: undefined,
+          theirs: deepClone(sourceContent!),
+        });
+        continue;
+      }
+
+      // Both modified the document content - do field-level three-way merge
+      const result = threeWayMerge(
+        baseContent ?? {},
+        targetContent!,
+        sourceContent!,
+        docId,
+      );
+      merged[docId] = result.merged;
+      allConflicts.push(...result.conflicts);
+    }
+
+    const applied = allConflicts.length === 0;
+
+    if (applied) {
+      for (const docId of allDocIds) {
+        if (docId in merged) {
+          const existingDoc = targetBranchState.documents.get(docId);
+          const mergedContent = deepClone(merged[docId]);
+          if (existingDoc && !existingDoc.deleted) {
+            if (!deepEqual(existingDoc.content, mergedContent)) {
+              const version: Version = {
+                id: generateId(),
+                timestamp: Date.now(),
+                content: deepClone(mergedContent),
+              };
+              existingDoc.content = mergedContent;
+              existingDoc.versions.push(version);
+            }
+          } else {
+            const version: Version = {
+              id: generateId(),
+              timestamp: Date.now(),
+              content: deepClone(mergedContent),
+            };
+            targetBranchState.documents.set(docId, {
+              content: mergedContent,
+              versions: [version],
+              deleted: false,
+            });
+          }
+        } else {
+          const existingDoc = targetBranchState.documents.get(docId);
+          if (existingDoc && !existingDoc.deleted) {
+            existingDoc.deleted = true;
+            existingDoc.content = {};
+          }
+        }
+      }
+    }
+
+    return { merged, conflicts: allConflicts, applied };
+  }
+
+  // --- Private helpers ---
+
+  private getCurrentBranchState(): BranchState {
+    const state = this.branches.get(this.currentBranch);
+    if (!state) {
+      throw new Error(`Branch "${this.currentBranch}" not found`);
+    }
+    return state;
+  }
+}
