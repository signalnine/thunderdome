   428→    const applied = allConflicts.length === 0;\n   429→\n   430→    if (applied) {\n   431→      for (const docId of allDocIds) {\n   432→        if (docId in merged) {\n   433→          const existingDoc = targetBranchState.documents.get(docId);\n   434→          const mergedContent = deepClone(merged[docId]);\n   435→          if (existingDoc && !existingDoc.deleted) {\n   436→            if (!deepEqual(existingDoc.content, mergedContent)) {\n   437→              const version: Version = {\n   438→                id: generateId(),\n   439→                timestamp: Date.now(),\n   440→                content: deepClone(mergedContent),\n   441→              };\n   442→              existingDoc.content = mergedContent;\n   443→              existingDoc.versions.push(version);\n   444→            }\n   445→          } else {\n   446→            const version: Version = {\n   447→              id: generateId(),\n   448→              timestamp: Date.now(),\n   449→              content: deepClone(mergedContent),\n   450→            };\n   451→            targetBranchState.documents.set(docId, {\n   452→              content: mergedContent,\n   453→              versions: [version],\n   454→              deleted: false,\n   455→            });\n   456→          }\n   457→        } else {\n   458→          const existingDoc = targetBranchState.documents.get(docId);\n   459→          if (existingDoc && !existingDoc.deleted) {\n   460→            existingDoc.deleted = true;\n   461→            existingDoc.content = {};\n   462→          }\n   463→        }\n   464→      }\n   465→    }\n   466→\n   467→    return { merged, conflicts: allConflicts, applied };\n   468→  }\n   469→\n   470→  // --- Private helpers ---\n   471→\n   472→  private getCurrentBranchState(): BranchState {\n   473→    const state = this.branches.get(this.currentBranch);\n   474→    if (!state) {\n   475→      throw new Error(`Branch \"${this.currentBranch}\" not found`);\n   476→    }\n   477