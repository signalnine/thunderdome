+// --- Cell Reference Utilities ---
+
+function columnToIndex(col: string): number {
+  let index = 0;
+  for (let i = 0; i < col.length; i++) {
+    index = index * 26 + (col.charCodeAt(i) - 64);
+  }
+  return index - 1; // 0-based
+}
+
+function indexToColumn(index: number): string {
+  let col = '';
+  let n = index + 1; // 1-based
+  while (n > 0) {
+    n--;
+    col = String.fromCharCode(65 + (n % 26)) + col;
+    n = Math.floor(n / 26);
+  }
+  return col;
+}
+
+function parseCell(ref: string): { col: number; row: number } {
+  const match = ref.match(/^([A-Z]+)(\d+)$/);
+  if (!match) throw new Error(`Invalid cell reference: ${ref}`);
+  return { col: columnToIndex(match[1]), row: parseInt(match[2], 10) - 1 };
+}
+
+function cellRef(col: number, row: number): string {
+  return `${indexToColumn(col)}${row + 1}`;
+}
+
+function expandRange(start: string, end: string): string[] {
+  const s = parseCell(start);
+  const e = parseCell(end);
+  const minCol = Math.min(s.col, e.col);
+  const maxCol = Math.max(s.col, e.col);
+  const minRow = Math.min(s.row, e.row);
+  const maxRow = Math.max(s.row, e.row);
+  const cells: string[] = [];
+  for (let r = minRow; r <= maxRow; r++) {
+    for (let c = minCol; c <= maxCol; c++) {
+      cells.push(cellRef(c, r));
+    }
+  }
+  return cells;
+}
+
+// --- Tokenizer ---
+
+type TokenType =
+  | 'NUMBER'
+  | 'STRING'
+  | 'BOOLEAN'
+  | 'CELL'
+  | 'RANGE'
+  | 'FUNC'
+  | 'OP'
+  | 'COMPARE'
+  | 'LPAREN'
+  | 'RPAREN'
+  | 'COMMA';
+
+interface Token {
+  type: TokenType;
+  value: string;
+}
+
+function tokenize(formula: string): Token[] {
+  const tokens: Token[] = [];
+  let i = 0;
+
+  while (i < formula.length) {
+    const ch = formula[i];
+
+    // Skip whitespace
+    if (ch === ' ' || ch === '\t') {
+      i++;
+      continue;
+    }
+
+    // String literal
+    if (ch === '"') {
+      let str = '';
+      i++;
+      while (i < formula.length && formula[i] !== '"') {
+        str += formula[i];
+        i++;
+      }
+      if (i >= formula.length) throw new Error('Unterminated string literal');
+      i++; // skip closing quote
+      tokens.push({ type: 'STRING', value: str });
+      continue;
+    }
+
+    // Number
+    if (/\d/.test(ch) || (ch === '.' && i + 1 < formula.length && /\d/.test(formula[i + 1]))) {
+      let num = '';
+      while (i < formula.length && (/\d/.test(formula[i]) || formula[i] === '.')) {
+        num += formula[i];
+        i++;
+      }
+      tokens.push({ type: 'NUMBER', value: num });
+      continue;
+    }
+
+    // Cell reference, range, function name, or boolean
+    if (/[A-Z]/i.test(ch)) {
+      let ident = '';
+      while (i < formula.length && /[A-Za-z0-9]/.test(formula[i])) {
+        ident += formula[i];
+        i++;
+      }
+
+      // Check for boolean
+      if (ident.toLowerCase() === 'true' || ident.toLowerCase() === 'false') {
+        tokens.push({ type: 'BOOLEAN', value: ident.toLowerCase() });
+        continue;
+      }
+
+      // Check for range (e.g., A1:B2)
+      if (i < formula.length && formula[i] === ':') {
+        i++; // skip ':'
+        let endRef = '';
+        while (i < formula.length && /[A-Za-z0-9]/.test(formula[i])) {
+          endRef += formula[i];
+          i++;
+        }
+        tokens.push({ type: 'RANGE', value: `${ident.toUpperCase()}:${endRef.toUpperCase()}` });
+        continue;
+      }
+
+      // Check if it's a function call (followed by '(')
+      if (i < formula.length && formula[i] === '(') {
+        tokens.push({ type: 'FUNC', value: ident.toUpperCase() });
+        continue;
+      }
+
+      // It's a cell reference
+      tokens.push({ type: 'CELL', value: ident.toUpperCase() });
+      continue;
+    }
+
+    // Comparison operators
+    if (ch === '<' && i + 1 < formula.length && formula[i + 1] === '>') {
+      tokens.push({ type: 'COMPARE', value: '<>' });
+      i += 2;
+      continue;
+    }
+    if (ch === '<' && i + 1 < formula.length && formula[i + 1] === '=') {
+      tokens.push({ type: 'COMPARE', value: '<=' });
+      i += 2;
+      continue;
+    }
+    if (ch === '>' && i + 1 < formula.length && formula[i + 1] === '=') {
+      tokens.push({ type: 'COMPARE', value: '>=' });
+      i += 2;
+      continue;
+    }
+    if (ch === '<') {
+      tokens.push({ type: 'COMPARE', value: '<' });
+      i++;
+      continue;
+    }
+    if (ch === '>') {
+      tokens.push({ type: 'COMPARE', value: '>' });
+      i++;
+      continue;
+    }
+    if (ch === '=' && tokens.length > 0) {
+      // '=' as comparison (not the leading '=')
+      tokens.push({ type: 'COMPARE', value: '=' });
+      i++;
+      continue;
+    }
+
+    // Arithmetic operators
+    if (ch === '+' || ch === '-' || ch === '*' || ch === '/') {
+      tokens.push({ type: 'OP', value: ch });
+      i++;
+      continue;
+    }
+
+    if (ch === '(') {
+      tokens.push({ type: 'LPAREN', value: '(' });
+      i++;
+      continue;
+    }
+    if (ch === ')') {
+      tokens.push({ type: 'RPAREN', value: ')' });
+      i++;
+      continue;
+    }
+    if (ch === ',') {
+      tokens.push({ type: 'COMMA', value: ',' });
+      i++;
+      continue;
+    }
+
+    throw new Error(`Unexpected character in formula: '${ch}'`);
+  }
+
+  return tokens;
+}
+
+// --- AST ---
+
+type ASTNode =
+  | { type: 'number'; value: number }
+  | { type: 'string'; value: string }
+  | { type: 'boolean'; value: boolean }
+  | { type: 'cell'; ref: string }
+  | { type: 'range'; start: string; end: string }
+  | { type: 'binop'; op: string; left: ASTNode; right: ASTNode }
+  | { type: 'unary'; op: string; operand: ASTNode }
+  | { type: 'func'; name: string; args: ASTNode[] };
+
+// --- Parser (recursive descent) ---
+
+class Parser {
+  private tokens: Token[];
+  private pos: number;
+
+  constructor(tokens: Token[]) {
+    this.tokens = tokens;
+    this.pos = 0;
+  }
+
+  parse(): ASTNode {
+    const node = this.parseComparison();
+    if (this.pos < this.tokens.length) {
+      throw new Error(`Unexpected token: ${this.tokens[this.pos].value}`);
+    }
+    return node;
+  }
+
+  private peek(): Token | null {
+    return this.pos < this.tokens.length ? this.tokens[this.pos] : null;
+  }
+
+  private consume(): Token {
+    return this.tokens[this.pos++];
+  }
+
+  private parseComparison(): ASTNode {
+    const left = this.parseAddSub();
+    const t = this.peek();
+    if (t && t.type === 'COMPARE') {
+      this.consume();
+      const right = this.parseAddSub();
+      return { type: 'binop', op: t.value, left, right };
+    }
+    return left;
+  }
+
+  private parseAddSub(): ASTNode {
+    let left = this.parseMulDiv();
+    for (;;) {
+      const t = this.peek();
+      if (t && t.type === 'OP' && (t.value === '+' || t.value === '-')) {
+        this.consume();
+        const right = this.parseMulDiv();
+        left = { type: 'binop', op: t.value, left, right };
+      } else {
+        break;
+      }
+    }
+    return left;
+  }
+
+  private parseMulDiv(): ASTNode {
+    let left = this.parseUnary();
+    for (;;) {
+      const t = this.peek();
+      if (t && t.type === 'OP' && (t.value === '*' || t.value === '/')) {
+        this.consume();
+        const right = this.parseUnary();
+        left = { type: 'binop', op: t.value, left, right };
+      } else {
+        break;
+      }
+    }
+    return left;
+  }
+
+  private parseUnary(): ASTNode {
+    const t = this.peek();
+    if (t && t.type === 'OP' && (t.value === '-' || t.value === '+')) {
+      this.consume();
+      const operand = this.parseUnary();
+      if (t.value === '-') {
+        return { type: 'unary', op: '-', operand };
+      }
+      return operand;
+    }
+    return this.parsePrimary();
+  }
+
+  private parsePrimary(): ASTNode {
+    const t = this.peek();
+    if (!t) throw new Error('Unexpected end of formula');
+
+    if (t.type === 'NUMBER') {
+      this.consume();
+      return { type: 'number', value: parseFloat(t.value) };
+    }
+
+    if (t.type === 'STRING') {
+      this.consume();
+      return { type: 'string', value: t.value };
+    }
+
+    if (t.type === 'BOOLEAN') {
+      this.consume();
+      return { type: 'boolean', value: t.value === 'true' };
+    }
+
+    if (t.type === 'CELL') {
+      this.consume();
+      return { type: 'cell', ref: t.value };
+    }
+
+    if (t.type === 'RANGE') {
+      this.consume();
+      const [start, end] = t.value.split(':');
+      return { type: 'range', start, end };
+    }
+
+    if (t.type === 'FUNC') {
+      this.consume();
+      const name = t.value;
+      // consume '('
+      const lp = this.peek();
+      if (!lp || lp.type !== 'LPAREN') throw new Error(`Expected ( after function ${name}`);
+      this.consume();
+
+      const args: ASTNode[] = [];
+      if (this.peek()?.type !== 'RPAREN') {
+        args.push(this.parseComparison());
+        while (this.peek()?.type === 'COMMA') {
+          this.consume();
+          args.push(this.parseComparison());
+        }
+      }
+
+      const rp = this.peek();
+      if (!rp || rp.type !== 'RPAREN') throw new Error(`Expected ) after function ${name} arguments`);
+      this.consume();
+      return { type: 'func', name, args };
+    }
+
+    if (t.type === 'LPAREN') {
+      this.consume();
+      const node = this.parseComparison();
+      const rp = this.peek();
+      if (!rp || rp.type !== 'RPAREN') throw new Error('Expected )');
+      this.consume();
+      return node;
+    }
+
+    throw new Error(`Unexpected token: ${t.value}`);
+  }
+}
+
+function parseFormula(formula: string): ASTNode {
+  const tokens = tokenize(formula);
+  return new Parser(tokens).parse();
+}
+
+// --- Collect dependencies from AST ---
+
+function collectDeps(node: ASTNode): Set<string> {
+  const deps = new Set<string>();
+
+  function walk(n: ASTNode): void {
+    switch (n.type) {
+      case 'cell':
+        deps.add(n.ref);
+        break;
+      case 'range': {
+        const cells = expandRange(n.start, n.end);
+        for (const c of cells) deps.add(c);
+        break;
+      }
+      case 'binop':
+        walk(n.left);
+        walk(n.right);
+        break;
+      case 'unary':
+        walk(n.operand);
+        break;
+      case 'func':
+        for (const arg of n.args) walk(arg);
+        break;
+      // number, string, boolean have no deps
+    }
+  }
+
+  walk(node);
+  return deps;
+}
+
+// --- Evaluate AST ---
+
+type CellValue = string | number | boolean | null;
+
+function evaluate(node: ASTNode, getCellValue: (ref: string) => CellValue): CellValue {
+  switch (node.type) {
+    case 'number':
+      return node.value;
+    case 'string':
+      return node.value;
+    case 'boolean':
+      return node.value;
+    case 'cell':
+      return getCellValue(node.ref);
+    case 'range':
+      throw new Error('Range cannot be used outside of a function');
+    case 'unary': {
+      const val = evaluate(node.operand, getCellValue);
+      if (typeof val === 'number') return -val;
+      throw new Error('Unary minus requires a number');
+    }
+    case 'binop': {
+      const left = evaluate(node.left, getCellValue);
+      const right = evaluate(node.right, getCellValue);
+
+      switch (node.op) {
+        case '+': return toNum(left) + toNum(right);
+        case '-': return toNum(left) - toNum(right);
+        case '*': return toNum(left) * toNum(right);
+        case '/': {
+          const divisor = toNum(right);
+          if (divisor === 0) throw new Error('Division by zero');
+          return toNum(left) / divisor;
+        }
+        case '>': return toNum(left) > toNum(right);
+        case '<': return toNum(left) < toNum(right);
+        case '>=': return toNum(left) >= toNum(right);
+        case '<=': return toNum(left) <= toNum(right);
+        case '=': return left === right;
+        case '<>': return left !== right;
+        default:
+          throw new Error(`Unknown operator: ${node.op}`);
+      }
+    }
+    case 'func':
+      return evaluateFunc(node.name, node.args, getCellValue);
+  }
+}
+
+function toNum(val: CellValue): number {
+  if (typeof val === 'number') return val;
+  if (typeof val === 'boolean') return val ? 1 : 0;
+  if (val === null) return 0;
+  const n = Number(val);
+  if (isNaN(n)) return 0;
+  return n;
+}
+
+function resolveRangeValues(args: ASTNode[], getCellValue: (ref: string) => CellValue): CellValue[] {
+  const values: CellValue[] = [];
+  for (const arg of args) {
+    if (arg.type === 'range') {
+      const cells = expandRange(arg.start, arg.end);
+      for (const c of cells) values.push(getCellValue(c));
+    } else {
+      values.push(evaluate(arg, getCellValue));
+    }
+  }
+  return values;
+}
+
+function evaluateFunc(name: string, args: ASTNode[], getCellValue: (ref: string) => CellValue): CellValue {
+  switch (name) {
+    case 'SUM': {
+      const values = resolveRangeValues(args, getCellValue);
+      let sum = 0;
+      for (const v of values) {
+        if (typeof v === 'number') sum += v;
+      }
+      return sum;
+    }
+    case 'AVERAGE': {
+      const values = resolveRangeValues(args, getCellValue);
+      let sum = 0;
+      let count = 0;
+      for (const v of values) {
+        if (typeof v === 'number') {
+          sum += v;
+          count++;
+        }
+      }
+      return count === 0 ? 0 : sum / count;
+    }
+    case 'MIN': {
+      const values = resolveRangeValues(args, getCellValue);
+      let min = Infinity;
+      for (const v of values) {
+        if (typeof v === 'number' && v < min) min = v;
+      }
+      return min === Infinity ? 0 : min;
+    }
+    case 'MAX': {
+      const values = resolveRangeValues(args, getCellValue);
+      let max = -Infinity;
+      for (const v of values) {
+        if (typeof v === 'number' && v > max) max = v;
+      }
+      return max === -Infinity ? 0 : max;
+    }
+    case 'COUNT': {
+      const values = resolveRangeValues(args, getCellValue);
+      let count = 0;
+      for (const v of values) {
+        if (typeof v === 'number') count++;
+      }
+      return count;
+    }
+    case 'IF': {
+      if (args.length !== 3) throw new Error('IF requires exactly 3 arguments');
+      const condition = evaluate(args[0], getCellValue);
+      const isTruthy = condition === true || (typeof condition === 'number' && condition !== 0);
+      return isTruthy
+        ? evaluate(args[1], getCellValue)
+        : evaluate(args[2], getCellValue);
+    }
+    default:
+      throw new Error(`Unknown function: ${name}`);
+  }
+}
+
+// --- Spreadsheet ---
+
+interface CellData {
+  raw: string | number | boolean;
+  formula: ASTNode | null;
+  value: CellValue;
+  deps: Set<string>; // cells this cell depends on
+}
+
+export class Spreadsheet {
+  private cells: Map<string, CellData> = new Map();
+  // Reverse dependency map: cell -> set of cells that depend on it
+  private dependents: Map<string, Set<string>> = new Map();
+
+  set(cell: string, value: string | number | boolean): void {
+    const ref = cell.toUpperCase();
+
+    // Remove old reverse dependencies
+    const existing = this.cells.get(ref);
+    if (existing) {
+      for (const dep of existing.deps) {
+        this.dependents.get(dep)?.delete(ref);
+      }
+    }
+
+    let formula: ASTNode | null = null;
+    let deps = new Set<string>();
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      formula = parseFormula(value.substring(1));
+      deps = collectDeps(formula);
+    }
+
+    // Check for circular references before committing
+    if (deps.size > 0) {
+      this.checkCircular(ref, deps);
+    }
+
+    // Register reverse dependencies
+    for (const dep of deps) {
+      if (!this.dependents.has(dep)) {
+        this.dependents.set(dep, new Set());
+      }
+      this.dependents.get(dep)!.add(ref);
+    }
+
+    const cellData: CellData = {
+      raw: value,
+      formula,
+      value: null,
+      deps,
+    };
+
+    this.cells.set(ref, cellData);
+
+    // Compute value
+    if (formula) {
+      cellData.value = evaluate(formula, (r) => this.getCellValue(r));
+    } else {
+      cellData.value = value;
+    }
+
+    // Propagate reactive updates
+    this.propagate(ref);
+  }
+
+  get(cell: string): CellValue {
+    const ref = cell.toUpperCase();
+    const data = this.cells.get(ref);
+    return data ? data.value : null;
+  }
+
+  getDisplay(cell: string): string {
+    const val = this.get(cell);
+    if (val === null) return '';
+    return String(val);
+  }
+
+  getCells(): Map<string, CellValue> {
+    const result = new Map<string, CellValue>();
+    for (const [ref, data] of this.cells) {
+      result.set(ref, data.value);
+    }
+    return result;
+  }
+
+  private getCellValue(ref: string): CellValue {
+    const data = this.cells.get(ref);
+    return data ? data.value : null;
+  }
+
+  private checkCircular(cell: string, deps: Set<string>): void {
+    // DFS from each dep to see if we can reach `cell`
+    const visited = new Set<string>();
+    const stack = [...deps];
+
+    while (stack.length > 0) {
+      const current = stack.pop()!;
+      if (current === cell) {
+        throw new Error(`Circular reference detected involving ${cell}`);
+      }
+      if (visited.has(current)) continue;
+      visited.add(current);
+
+      // Follow dependencies of current cell
+      const currentData = this.cells.get(current);
+      if (currentData) {
+        for (const dep of currentData.deps) {
+          if (!visited.has(dep)) {
+            stack.push(dep);
+          }
+        }
+      }
+    }
+  }
+
+  private propagate(changedCell: string): void {
+    // Topological sort of all transitive dependents, then recompute in order
+    const order = this.getEvalOrder(changedCell);
+
+    for (const ref of order) {
+      const data = this.cells.get(ref);
+      if (data && data.formula) {
+        data.value = evaluate(data.formula, (r) => this.getCellValue(r));
+      }
+    }
+  }
+
+  private getEvalOrder(startCell: string): string[] {
+    // Collect all transitive dependents of startCell via BFS
+    const allDependents = new Set<string>();
+    const queue = [startCell];
+    while (queue.length > 0) {
+      const cell = queue.shift()!;
+      const deps = this.dependents.get(cell);
+      if (deps) {
+        for (const dep of deps) {
+          if (!allDependents.has(dep)) {
+            allDependents.add(dep);
+            queue.push(dep);
+          }
+        }
+      }
+    }
+
+    // Topological sort using DFS post-order, then reverse
+    const visited = new Set<string>();
+    const order: string[] = [];
+
+    const visit = (cell: string): void => {
+      if (visited.has(cell)) return;
+      visited.add(cell);
+
+      // Visit all cells this cell depends on (that are also in the affected set)
+      const cellData = this.cells.get(cell);
+      if (cellData) {
+        for (const dep of cellData.deps) {
+          if (allDependents.has(dep)) {
+            visit(dep);
+          }
+        }
+      }
+      order.push(cell);
+    };
+
+    for (const cell of allDependents) {
+      visit(cell);
+    }
+
+    return order;
+  }
+}
