oom('R1')];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(2);\n      expect(result.unscheduled).toHaveLength(0);\n\n      const a = result.assignments.find(x => x.eventId === 'A')!;\n      const b = result.assignments.find(x => x.eventId === 'B')!;\n\n      // They should not overlap and must have at least 15 min gap\n      if (a.startTime < b.startTime) {\n        expect(b.startTime).toBeGreaterThanOrEqual(a.endTime + 15);\n      } else {\n        expect(a.startTime).toBeGreaterThanOrEqual(b.endTime + 15);\n      }\n    });\n\n    it('schedules events into multiple rooms', () => {\n      const events = [makeEvent('A', 60), makeEvent('B', 60)];\n      const rooms = [makeRoom('R1'), makeRoom('R2')];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(2);\n      expect(result.unscheduled).toHaveLength(0);\n    });\n\n    it('returns empty results for empty events', () => {\n      const result = schedule([], [makeRoom('R1')], defaultOptions);\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toHaveLength(0);\n    });\n  });\n\n  describe('capacity constraints', () => {\n    it('does not place event in room with insufficient capacity', () => {\n      const events = [makeEvent('A', 60, { attendees: 100 })];\n      const rooms = [makeRoom('R1', 50)];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toEqual(['A']);\n    });\n\n    it('places event in room with sufficient capacity', () => {\n      const events = [makeEvent('A', 60, { attendees: 30 })];\n      const rooms = [makeRoom('R1', 50), makeRoom('R2', 20)];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('R1');\n    });\n\n    it('assigns event to the only room with enough capacity', () => {\n      const events = [makeEvent('A', 60, { attendees: 40 })];\n      const rooms = [makeRoom('R1', 30), makeRoom('R2', 50)];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('R2');\n    });\n\n    it('defaults attendees to 1 when not specified', () => {\n      const events = [makeEvent('A', 60)];\n      const rooms = [makeRoom('R1', 1)];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(1);\n    });\n  });\n\n  describe('time window constraints', () => {\n    it('does not schedule events that exceed the time window', () => {\n      const events = [makeEvent('A', 600)]; // 10 hours\n      const opts: ScheduleOptions = { startTime: 540, endTime: 600 }; // only 1 hour\n      const result = schedule(events, [makeRoom('R1')], opts);\n\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toEqual(['A']);\n    });\n\n    it('schedules event that exactly fits the time window', () => {\n      const events = [makeEvent('A', 60)];\n      const opts: ScheduleOptions = { startTime: 540, endTime: 600 };\n      const result = schedule(events, [makeRoom('R1')], opts);\n\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].startTime).toBe(540);\n      expect(result.assignments[0].endTime).toBe(600);\n    });\n\n    it('events must end within the time window', () => {\n      const result = schedule(\n        [makeEvent('A', 60)],\n        [makeRoom('R1')],\n        defaultOptions\n      );\n\n      expect(result.assignments[0].endTime).toBeLessThanOrEqual(defaultOptions.endTime);\n    });\n  });\n\n  describe('gap constraints', () => {\n    it('uses default gap of 15 minutes', () => {\n      const events = [makeEvent('A', 60), makeEvent('B', 60)];\n      const rooms = [makeRoom('R1')];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(2);\n      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);\n      expect(sorted[1].startTime - sorted[0].endTime).toBeGreaterThanOrEqual(15);\n    });\n\n    it('respects custom gap', () => {\n      const events = [makeEvent('A', 60), makeEvent('B', 60)];\n      const rooms = [makeRoom('R1')];\n      const result = schedule(events, rooms, { ...defaultOptions, gap: 30 });\n\n      expect(result.assignments).toHaveLength(2);\n      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);\n      expect(sorted[1].startTime - sorted[0].endTime).toBeGreaterThanOrEqual(30);\n    });\n\n    it('gap of 0 allows back-to-back events', () => {\n      const events = [makeEvent('A', 60), makeEvent('B', 60)];\n      const rooms = [makeRoom('R1')];\n      const result = schedule(events, rooms, { ...defaultOptions, gap: 0 });\n\n      expect(result.assignments).toHaveLength(2);\n      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);\n      expect(sorted[1].startTime).toBeGreaterThanOrEqual(sorted[0].endTime);\n    });\n  });\n\n  describe('prerequisite constraints', () => {\n    it('schedules prerequisite before dependent event', () => {\n      const events = [\n        makeEvent('A', 60),\n        makeEvent('B', 60, { prerequisites: ['A'] }),\n      ];\n      const rooms = [makeRoom('R1')];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(2);\n      const a = result.assignments.find(x => x.eventId === 'A')!;\n      const b = result.assignments.find(x => x.eventId === 'B')!;\n      expect(b.startTime).toBeGreaterThanOrEqual(a.endTime + 15);\n    });\n\n    it('handles chain of prerequisites', () => {\n      const events = [\n        makeEvent('A', 60),\n        makeEvent('B', 60, { prerequisites: ['A'] }),\n        makeEvent('C', 60, { prerequisites: ['B'] }),\n      ];\n      const rooms = [makeRoom('R1')];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(3);\n      const a = result.assignments.find(x => x.eventId === 'A')!;\n      const b = result.assignments.find(x => x.eventId === 'B')!;\n      const c = result.assignments.find(x => x.eventId === 'C')!;\n      expect(b.startTime).toBeGreaterThanOrEqual(a.endTime + 15);\n      expect(c.startTime).toBeGreaterThanOrEqual(b.endTime + 15);\n    });\n\n    it('handles multiple prerequisites', () => {\n      const events = [\n        makeEvent('A', 30),\n        makeEvent('B', 30),\n        makeEvent('C', 30, { prerequisites: ['A', 'B'] }),\n      ];\n      const rooms = [makeRoom('R1'), makeRoom('R2')];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(3);\n      const a = result.assignments.find(x => x.eventId === 'A')!;\n      const b = result.assignments.find(x => x.eventId === 'B')!;\n      const c = result.assignments.find(x => x.eventId === 'C')!;\n      expect(c.startTime).toBeGreaterThanOrEqual(a.endTime + 15);\n      expect(c.startTime).toBeGreaterThanOrEqual(b.endTime + 15);\n    });\n\n    it('prerequisite gap is applied between dependent events', () => {\n      const events = [\n        makeEvent('A', 60),\n        makeEvent('B', 60, { prerequisites: ['A'] }),\n      ];\n      const rooms = [makeRoom('R1'), makeRoom('R2')];\n      const result = schedule(events, rooms, { ...defaultOptions, gap: 30 });\n\n      expect(result.assignments).toHaveLength(2);\n      const a = result.assignments.find(x => x.eventId === 'A')!;\n      const b = result.assignments.find(x => x.eventId === 'B')!;\n      expect(b.startTime).toBeGreaterThanOrEqual(a.endTime + 30);\n    });\n  });\n\n  describe('prerequisite cycles', () => {\n    it('throws on self-referencing prerequisite', () => {\n      const events = [makeEvent('A', 60, { prerequisites: ['A'] })];\n      expect(() => schedule(events, [makeRoom('R1')], defaultOptions)).toThrow();\n    });\n\n    it('throws on two-event cycle', () => {\n      const events = [\n        makeEvent('A', 60, { prerequisites: ['B'] }),\n        makeEvent('B', 60, { prerequisites: ['A'] }),\n      ];\n      expect(() => schedule(events, [makeRoom('R1')], defaultOptions)).toThrow();\n    });\n\n    it('throws on three-event cycle', () => {\n      const events = [\n        makeEvent('A', 60, { prerequisites: ['C'] }),\n        makeEvent('B', 60, { prerequisites: ['A'] }),\n        makeEvent('C', 60, { prerequisites: ['B'] }),\n      ];\n      expect(() => schedule(events, [makeRoom('R1')], defaultOptions)).toThrow();\n    });\n\n    it('does not throw when there is no cycle', () => {\n      const events = [\n        makeEvent('A', 60),\n        makeEvent('B', 60, { prerequisites: ['A'] }),\n        makeEvent('C', 60, { prerequisites: ['A'] }),\n      ];\n      expect(() => schedule(events, [makeRoom('R1')], defaultOptions)).not.toThrow();\n    });\n  });\n\n  describe('preferred room', () => {\n    it('places event in preferred room when possible', () => {\n      const events = [makeEvent('A', 60, { preferredRoom: 'R2' })];\n      const rooms = [makeRoom('R1'), makeRoom('R2')];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('R2');\n    });\n\n    it('falls back to another room when preferred room is not available', () => {\n      const events = [\n        makeEvent('A', 400, { preferredRoom: 'R1' }),\n        makeEvent('B', 400, { preferredRoom: 'R1' }),\n      ];\n      const rooms = [makeRoom('R1'), makeRoom('R2')];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(2);\n      // At least one should be in R1\n      const inR1 = result.assignments.filter(a => a.roomId === 'R1');\n      const inR2 