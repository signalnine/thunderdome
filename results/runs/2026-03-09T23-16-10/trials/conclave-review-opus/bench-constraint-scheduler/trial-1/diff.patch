rEach((id, i) => topoIndex.set(id, i));\n\n  const sortedByDifficulty = [...orderedIds].sort((a, b) => {\n    const roomsA = (compatibleRooms.get(a) ?? []).length;\n    const roomsB = (compatibleRooms.get(b) ?? []).length;\n    if (roomsA !== roomsB) return roomsA - roomsB; // fewer rooms = harder\n    const durA = eventMap.get(a)!.duration;\n    const durB = eventMap.get(b)!.duration;\n    if (durA !== durB) return durB - durA; // longer = harder\n    return (topoIndex.get(a) ?? 0) - (topoIndex.get(b) ?? 0);\n  });\n\n  // Need to ensure topological order: use a priority-based approach\n  // Build a scheduling order that respects prerequisites but prioritizes difficult events\n  function topoSortWithPriority(priority: Map<string, number>): string[] {\n    const inDeg = new Map<string, number>();\n    const adj = new Map<string, string[]>();\n    for (const e of events) {\n      inDeg.set(e.id, 0);\n      if (!adj.has(e.id)) adj.set(e.id, []);\n    }\n    for (const e of events) {\n      if (e.prerequisites) {\n        for (const preId of e.prerequisites) {\n          if (eventIds.has(preId)) {\n            if (!adj.has(preId)) adj.set(preId, []);\n            adj.get(preId)!.push(e.id);\n            inDeg.set(e.id, (inDeg.get(e.id) ?? 0) + 1);\n          }\n        }\n      }\n    }\n\n    const ready = events\n      .filter(e => (inDeg.get(e.id) ?? 0) === 0)\n      .map(e => e.id);\n    ready.sort((a, b) => (priority.get(a) ?? 0) - (priority.get(b) ?? 0));\n\n    const result: string[] = [];\n    while (ready.length > 0) {\n      // Pick highest priority (lowest number)\n      ready.sort((a, b) => (priority.get(a) ?? 0) - (priority.get(b) ?? 0));\n      const id = ready.shift()!;\n      result.push(id);\n      for (const dep of adj.get(id) ?? []) {\n        const d = (inDeg.get(dep) ?? 1) - 1;\n        inDeg.set(dep, d);\n        if (d === 0) {\n          ready.push(dep);\n        }\n      }\n    }\n    return result;\n  }\n\n  // Priority: fewer rooms first, then