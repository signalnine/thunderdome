ule(\n   127→        [makeEvent('A', 60)],\n   128→        [makeRoom('R1')],\n   129→        defaultOptions\n   130→      );\n   131→\n   132→      expect(result.assignments[0].endTime).toBeLessThanOrEqual(defaultOptions.endTime);\n   133→    });\n   134→  });\n   135→\n   136→  describe('gap constraints', () => {\n   137→    it('uses default gap of 15 minutes', () => {\n   138→      const events = [makeEvent('A', 60), makeEvent('B', 60)];\n   139→      const rooms = [makeRoom('R1')];\n   140→      const result = schedule(events, rooms, defaultOptions);\n   141→\n   142→      expect(result.assignments).toHaveLength(2);\n   143→      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);\n   144→      expect(sorted[1].startTime - sorted[0].endTime).toBeGreaterThanOrEqual(15);\n   145→    });\n   146→\n   147→    it('respects custom gap', () => {\n   148→      const events = [makeEvent('A', 60), makeEvent('B', 60)];\n   149→      const rooms = [makeRoom('R1')];\n   150→      const result = schedule(events, rooms, { ...defaultOptions, gap: 30 });\n   151→\n   152→      expect(result.assignments).toHaveLength(2);\n   153→      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);\n   154→      expect(sorted[1].startTime - sorted[0].endTime).toBeGreaterThanOrEqual(30);\n   155→    });\n   156→\n   157→    it('gap of 0 allows back-to-back events', () => {\n   158→      const events = [makeEvent('A', 60), makeEvent('B', 60)];\n   159→      const rooms = [makeRoom('R1')];\n   160→      const result = schedule(events, rooms, { ...defaultOptions, gap: 0 });\n   161→\n   162→      expect(result.assignments).toHaveLength(2);\n   163→      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);\n   164→      expect(sorted[1].startTime).toBeGreaterThanOrEqual(sorted[0].endTime);\n   165→    });\n   166→  });\n   167→\n   168→  describe('prerequisite constraints', () => {\n   169→    it('schedules prerequisite before dependent event', () => {\n   170→      const events = [\n   171→        makeEvent('A', 60),\n   172→        makeEvent('B', 60, { prerequisites: ['A'] }),\n   173→      ];\n   174→      const rooms = [makeRoom('R1')];\n   175→      const result = schedule(events, rooms, defaultOptions);\n   176→\n   177→      expect(result.assignments).toHaveLength(2);\n   178→      const a = result.assignments.find(x => x.eventId === 'A')!;\n   179→      const b = result.assignments.find(x => x.eventId === 'B')!;\n   180→      expect(b.startTime).toBeGreaterThanOrEqual(a.endTime + 15);\n   181→    });\n   182→\n   183→    it('handles chain of prerequisites', () => {\n   184→      const events = [\n   185→        makeEvent('A', 60),\n   186→        makeEvent('B', 60, { prerequisites: ['A'] }),\n   187→        makeEvent('C', 60, { prerequisites: ['B'] }),\n   188→      ];\n   189→      const rooms = [makeRoom('R1')];\n   190→      const result = schedule(events, rooms, defaultOptions);\n   191→\n   192→      expect(result.assignments).toHaveLength(3);\n   193→      const a = result.assignments.find(x => x.eventId === 'A')!;\n   194→      const b = result.assignments.find(x => x.eventId === 'B')!;\n   195→      const c = result.assignments.find(x => x.eventId === 'C')!;\n   196→      expect(b.startTime).toBeGreaterThanOrEqual(a.endTime + 15);\n   197→      expect(c.startTime).toBeGreaterThanOrEqual(b.endTime + 15);\n   198→    });\n   199→\n   200→    it('handles multiple prerequisites', () => {\n   201→      const events = [\n   202→        makeEvent('A', 30),\n   203→        makeEvent('B', 30),\n   204→        makeEvent('C', 30, { prerequisites: ['A', 'B'] }),\n   205→      ];\n   206→      const rooms = [makeRoom('R1'), makeRoom('R2')];\n   207→      const result = schedule(events, rooms, defaultOptions);\n   208→\n   209→      expect(result.assignments).toHaveLength(3);\n   210→      const a = result.assignments.find(x => x.eventId === 'A')!;\n   211→      const b = result.assignments.find(x => x.eventId === 'B')!;\n   212→      const c = result.assignments.find(x => x.eventId === 'C')!;\n   213→      expect(c.startTime).toBeGreaterThanOrEqual(a.endTime + 15);\n   214→      expect(c.startTime).toBeGreaterThanOrEqual(b.endTime + 15);\n   215→    });\n   216→\n   217→    it('prerequisite gap is applied between dependent events', () => {\n   218→      const events = [\n   219→        makeEvent('A', 60),\n   220→        makeEvent('B', 60, { prerequisites: ['A'] }),\n   221→      ];\n   222→      const rooms = [makeRoom('R1'), makeRoom('R2')];\n   223→      const result = schedule(events, rooms, { ...defaultOptions, gap: 30 });\n   224→\n   225→      expect(result.assignments).toHaveLength(2);\n   226→      const a = result.assignments.find(x => x.eventId === 'A')!;\n   227→      const b = result.assignments.find(x => x.eventId === 'B')!;\n   228→      expect(b.startTime).toBeGreaterThanOrEqual(a.endTime + 30);\n   229→    });\n   230→  });\n   231→\n   232→  describe('prerequisite cycles', () => {\n   233→    it('throws on self-referencing prerequisite', () => {\n   234→      const events = [makeEvent('A', 60, { prerequisites: ['A'] })];\n   235→      expect(() => schedule(events, [makeRoom('R1')], defaultOptions)).toThrow();\n   236→    });\n   237→\n   238→    it('throws on two-event cycle', () => {\n   239→      const events = [\n   240→        makeEvent('A', 60, { prerequisites: ['B'] }),\n   241→        makeEvent('B', 60, { prerequisites: ['A'] }),\n   242→      ];\n   243→      expect(() => schedule(events, [makeRoom('R1')], defaultOptions)).toThrow();\n   244→    });\n   245→\n   246→    it('throws on three-event cycle', () => {\n   247→      const events = [\n   248→        makeEvent('A', 60, { prerequisites: ['C'] }),\n   249→        makeEvent('B', 60, { prerequisites: ['A'] }),\n   250→        makeEvent('C', 60, { prerequisites: ['B'] }),\n   251→      ];\n   252→      expect(() => schedule(events, [makeRoom('R1')], defaultOptions)).