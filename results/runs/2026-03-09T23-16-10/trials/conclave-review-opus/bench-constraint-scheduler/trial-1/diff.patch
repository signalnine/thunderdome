te cycles', () => {\n    it('throws on self-referencing prerequisite', () => {\n      const events = [makeEvent('A', 60, { prerequisites: ['A'] })];\n      expect(() => schedule(events, [makeRoom('R1')], defaultOptions)).toThrow();\n    });\n\n    it('throws on two-event cycle', () => {\n      const events = [\n        makeEvent('A', 60, { prerequisites: ['B'] }),\n        makeEvent('B', 60, { prerequisites: ['A'] }),\n      ];\n      expect(() => schedule(events, [makeRoom('R1')], defaultOptions)).toThrow();\n    });\n\n    it('throws on three-event cycle', () => {\n      const events = [\n        makeEvent('A', 60, { prerequisites: ['C'] }),\n        makeEvent('B', 60, { prerequisites: ['A'] }),\n        makeEvent('C', 60, { prerequisites: ['B'] }),\n      ];\n      expect(() => schedule(events, [makeRoom('R1')], defaultOptions)).toThrow();\n    });\n\n    it('does not throw when there is no cycle', () => {\n      const events = [\n        makeEvent('A', 60),\n        makeEvent('B', 60, { prerequisites: ['A'] }),\n        makeEvent('C', 60, { prerequisites: ['A'] }),\n      ];\n      expect(() => schedule(events, [makeRoom('R1')], defaultOptions)).not.toThrow();\n    });\n  });\n\n  describe('preferred room', () => {\n    it('places event in preferred room when possible', () => {\n      const events = [makeEvent('A', 60, { preferredRoom: 'R2' })];\n      const rooms = [makeRoom('R1'), makeRoom('R2')];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('R2');\n    });\n\n    it('falls back to another room when preferred room is not available', () => {\n      const events = [\n        makeEvent('A', 400, { preferredRoom: 'R1' }),\n        makeEvent('B', 400, { preferredRoom: 'R1' }),\n      ];\n      const rooms = [makeRoom('R1'), makeRoom('R2')];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLen