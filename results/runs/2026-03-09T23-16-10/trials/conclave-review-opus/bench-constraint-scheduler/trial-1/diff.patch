  }\n\n  function findAllSlots(\n    roomSched: Slot[],\n    duration: number,\n    earliestStart: number,\n    deadline: number,\n    gapMinutes: number\n  ): number[] {\n    const results: number[] = [];\n    let candidate = earliestStart;\n\n    // Find all possible start times\n    while (candidate + duration <= deadline) {\n      let valid = true;\n      let nextCandidate = deadline; // default jump to end\n\n      for (const slot of roomSched) {\n        // Check conflict\n        const newEnd = candidate + duration;\n        if (newEnd + gapMinutes <= slot.start || slot.end + gapMinutes <= candidate) {\n          continue; // no conflict\n        }\n        // Conflict - must move past this slot\n        valid = false;\n        candidate = slot.end + gapMinutes;\n        break;\n      }\n\n      if (valid) {\n        results.push(candidate);\n        // Find next gap after this placement\n        const placedEnd = candidate + duration + gapMinutes;\n        // Move to next meaningful position\n        let jumped = false;\n        for (const slot of roomSched) {\n          if (slot.start >= placedEnd) {\n            // Could skip to just before this slot? No, just increment\n            break;\n          }\n        }\n        if (!jumped) {\n          // Just return the first valid slot for efficiency in backtracking\n          // Trying all slots would be too expensive\n          break;\n        }\n      }\n    }\n\n    return results;\n  }\n\n  const initState: State = {\n    roomSchedules: new Map(rooms.map(r => [r.id, []])),\n    assignments: new Map(),\n    scheduled: new Set(),\n  };\n\n  let bestResult: ScheduleResult = {\n    assignments: [],\n    unscheduled: [...orderedIds],\n  };\n\n  function canSchedulePrereqs(eventId: string, state: State): boolean {\n    const event = eventMap.get(eventId);\n    if (!event?.prerequisites) return true;\n    for (const preId of event.prerequisites) {\n      if (!state.scheduled.has(preId)) return false;\n    }\n  