+  }
+
+  return best;
+}
+
+function backtrackSchedule(
+  orderedIds: string[],
+  eventMap: Map<string, Event>,
+  rooms: Room[],
+  compatibleRooms: Map<string, Room[]>,
+  options: ScheduleOptions,
+  gap: number,
+  hasUnsatisfiablePrereqs: Set<string>
+): ScheduleResult {
+  type State = {
+    roomSchedules: Map<string, Slot[]>;
+    assignments: Map<string, Assignment>;
+    scheduled: Set<string>;
+  };
+
+  function cloneState(state: State): State {
+    const newRoomSchedules = new Map<string, Slot[]>();
+    for (const [k, v] of state.roomSchedules) {
+      newRoomSchedules.set(k, [...v]);
+    }
+    return {
+      roomSchedules: newRoomSchedules,
+      assignments: new Map(state.assignments),
+      scheduled: new Set(state.scheduled),
+    };
+  }
+
+  const initState: State = {
+    roomSchedules: new Map(rooms.map(r => [r.id, []])),
+    assignments: new Map(),
+    scheduled: new Set(),
+  };
+
+  let bestResult: ScheduleResult = {
+    assignments: [],
+    unscheduled: [...orderedIds],
+  };
+
+  function canSchedulePrereqs(eventId: string, state: State): boolean {
+    const event = eventMap.get(eventId);
+    if (!event?.prerequisites) return true;
+    for (const preId of event.prerequisites) {
+      if (!state.scheduled.has(preId)) return false;
+    }
+    return true;
+  }
+
+  function getEarliestStart(eventId: string, state: State): number {
+    const event = eventMap.get(eventId)!;
+    let earliest = options.startTime;
+    if (event.prerequisites) {
+      for (const preId of event.prerequisites) {
+        const a = state.assignments.get(preId);
+        if (a) {
+          earliest = Math.max(earliest, a.endTime + gap);
+        }
+      }
+    }
+    return earliest;
+  }
+
+  function solve(index: number, state: State): void {
+    // Prune: if we can't beat the best even scheduling all remaining
+    const remaining = orderedIds.length - index;
+    if (state.scheduled.size + remaining <= bestResult.assignments.length) {
+      return;
+    }
+
+    if (index >= orderedIds.length) {
+      if (state.scheduled.size > bestResult.assignments.length) {
+        bestResult = {
+          assignments: Array.from(state.assignments.values()),
+          unscheduled: orderedIds.filter(id => !state.scheduled.has(id)),
+        };
+      }
+      return;
+    }
+
+    const eventId = orderedIds[index];
+    const event = eventMap.get(eventId)!;
+
+    // Try to place this event first (maximization: placing is better than skipping)
+    if (!hasUnsatisfiablePrereqs.has(eventId) && canSchedulePrereqs(eventId, state)) {
+      const eligible = compatibleRooms.get(eventId) ?? [];
+      const earliestStart = getEarliestStart(eventId, state);
+
+      if (earliestStart + event.duration <= options.endTime) {
+        // Sort rooms: preferred first
+        const sortedRooms = [...eligible];
+        if (event.preferredRoom) {
+          sortedRooms.sort((a, b) => {
+            if (a.id === event.preferredRoom) return -1;
+            if (b.id === event.preferredRoom) return 1;
+            return 0;
+          });
+        }
+
+        for (const room of sortedRooms) {
+          const sched = state.roomSchedules.get(room.id)!;
+          const startTime = findEarliestSlot(sched, event.duration, earliestStart, options.endTime, gap);
+
+          if (startTime !== null) {
+            const newState = cloneState(state);
+            const assignment: Assignment = {
+              eventId,
+              roomId: room.id,
+              startTime,
+              endTime: startTime + event.duration,
+            };
+            newState.assignments.set(eventId, assignment);
+            newState.scheduled.add(eventId);
+            const roomSched = newState.roomSchedules.get(room.id)!;
+            insertSorted(roomSched, { eventId, start: startTime, end: startTime + event.duration });
+
+            solve(index + 1, newState);
+
+            // Early exit if we scheduled everything
+            if (bestResult.unscheduled.length === 0) return;
+          }
+        }
+      }
+    }
+
+    // Option 2: Skip this event
+    solve(index + 1, state);
+  }
+
+  solve(0, initState);
+  return bestResult;
+}
