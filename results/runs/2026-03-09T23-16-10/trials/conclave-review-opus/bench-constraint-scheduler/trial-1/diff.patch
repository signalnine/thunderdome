pect(result.assignments).toHaveLength(1);\n   296→      expect(result.assignments[0].roomId).toBe('R2');\n   297→    });\n   298→  });\n   299→\n   300→  describe('unscheduled events', () => {\n   301→    it('lists events that cannot fit as unscheduled', () => {\n   302→      // 8 hour day, 60-min events + 15-min gap = 75 min slots\n   303→      // 480 min / 75 = 6.4 => can fit 6 events + maybe partial 7th\n   304→      // Actually: 540 + 60 = 600, 600+15=615, 615+60=675, +15=690, +60=750, +15=765, +60=825, +15=840, +60=900, +15=915, +60=975, +15=990, +60=1050 > 1020\n   305→      // So: 540-600, 615-675, 690-750, 765-825, 840-900, 915-975 => 6 events in one room\n   306→      const events = Array.from({ length: 8 }, (_, i) => makeEvent(`E${i}`, 60));\n   307→      const rooms = [makeRoom('R1')];\n   308→      const result = schedule(events, rooms, defaultOptions);\n   309→\n   310→      // Can fit at most 6 events in one room over 8 hours with 15 min gaps\n   311→      expect(result.assignments.length).toBeLessThanOrEqual(7);\n   312→      expect(result.assignments.length + result.unscheduled.length).toBe(8);\n   313→    });\n   314→\n   315→    it('does not throw for conflicting constraints', () => {\n   316→      const events = [\n   317→        makeEvent('A', 400),\n   318→        makeEvent('B', 400),\n   319→      ];\n   320→      const rooms = [makeRoom('R1')];\n   321→      const result = schedule(events, rooms, defaultOptions);\n   322→\n   323→      // 480 min window, 400 + 15 + 400 = 815 > 480\n   324→      expect(result.assignments.length + result.unscheduled.length).toBe(2);\n   325→    });\n   326→  });\n   327→\n   328→  describe('batch optimization', () => {\n   329→    it('maximizes scheduled events when placement matters', () => {\n   330→      // 3 events, 2 fit in room, need to pick optimally\n   331→      // Room has 180 minutes. Events: 100, 100, 50\n   332→      // Greedy: 100 + 15 + 100 = 215 > 180 (only 1 fits)\n   333→      // Optimal: 100 +