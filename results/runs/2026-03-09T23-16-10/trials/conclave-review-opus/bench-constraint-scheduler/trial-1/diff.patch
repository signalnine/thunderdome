) {\n      dfs(e.id);\n    }\n  }\n}\n\nfunction topologicalSort(events: Event[]): string[] {\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  const inDegree = new Map<string, number>();\n  for (const e of events) {\n    if (!inDegree.has(e.id)) inDegree.set(e.id, 0);\n    if (e.prerequisites) {\n      for (const preId of e.prerequisites) {\n        if (!inDegree.has(preId)) inDegree.set(preId, 0);\n      }\n    }\n  }\n\n  // Build adjacency: prereq -> dependents\n  const adj = new Map<string, string[]>();\n  for (const e of events) {\n    if (e.prerequisites) {\n      for (const preId of e.prerequisites) {\n        if (!adj.has(preId)) adj.set(preId, []);\n        adj.get(preId)!.push(e.id);\n        inDegree.set(e.id, (inDegree.get(e.id) ?? 0) + 1);\n      }\n    }\n  }\n\n  const queue: string[] = [];\n  const eventIds = new Set(events.map(e => e.id));\n  for (const [id, deg] of inDegree) {\n    if (deg === 0) {\n      queue.push(id);\n    }\n  }\n\n  const result: string[] = [];\n  while (queue.length > 0) {\n    const id = queue.shift()!;\n    result.push(id);\n    for (const dep of adj.get(id) ?? []) {\n      const d = (inDegree.get(dep) ?? 1) - 1;\n      inDegree.set(dep, d);\n      if (d === 0) {\n        queue.push(dep);\n      }\n    }\n  }\n\n  return result;\n}\n\nexport function schedule(\n  events: Event[],\n  rooms: Room[],\n  options: ScheduleOptions\n): ScheduleResult {\n  if (events.length === 0) {\n    return { assignments: [], unscheduled: [] };\n  }\n\n  const gap = options.gap ?? 15;\n\n  // Detect cycles first - this throws\n  detectCycles(events);\n\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  // Get topological order\n  const topoOrder = topologicalSort(events);\n\n  // Filter to only events that exist in our event list\n  const eventIds = new Set(events.map(e => e.id));\n  const orderedIds = topoOrder.filter(id => eventIds.has(id));\n\n  // Find rooms that can fit each event (by capacity)\n  const compatibleRooms = new Map<string, Room[]>();\n  for (const e of events) {\n    const attendees = e.attendees ?? 1;\n    const fits = rooms.filter(r => r.capacity >= attendees);\n    compatibleRooms.set(e.id, fits);\n  }\n\n  // Use backtracking search to maximize scheduled events\n  // State: for each room, sorted list of (start, end) intervals\n  type RoomSchedule = { eventId: string; start: number; end: number }[];\n\n  function findEarliestSlot(\n    roomSched: RoomSchedule,\n    duration: number,\n    earliestStart: number,\n    deadline: number,\n    gapMinutes: number\n  ): number | null {\n    // Try to find the earliest time >= earliestStart where we can fit\n    // `duration` minutes without overlapping existing events (with gap)\n    let candidate = earliestStart;\n\n    for (const slot of roomSched) {\n      // Existing slot occupies [slot.start, slot.end)\n      // With gap, no new event can be in [slot.start - gapMinutes - duration, slot.end + gapMinutes)\n      // But more precisely: new event [candidate, candidate+duration) must not conflict\n      // Conflict if: candidate < slot.end + gapMinutes AND candidate + duration > slot.start - gapMinutes\n      // i.e., the new event's end must be <= slot.start - gapMinutes OR new event's start >= slot.end + gapMinutes\n\n      if (candidate + duration <= slot.start - gapMinutes + duration) {\n        // Actually let's think more carefully\n        // New event: [candidate, candidate + duration)\n        // Existing: [slot.start, slot.end)\n        // Gap requires: candidate + duration + gapMinutes <= slot.start  OR  slot.end + gapMinutes <= candidate\n        if (candidate + duration + gapMinutes <= slot.start) {\n          // Fits before this existing slot\n          break;\n        }\n      }\n\n      // Must go after this slot\n      if (candidate < slot.end + gapMinutes) {\n        candidate = slot.end + gapMinutes;\n      }\n    }\n\n    if (candidate + duration <= deadline) {\n      return candidate;\n    }\n    return null;\n  }\n\n  // Greedy approach first: schedule in topological order, trying preferred room first\n  // Then use a smarter approach if needed\n\n  // For optimization: try multiple strategies and pick the best one\n\n  function greedySchedule(orderedEventIds: string[]): ScheduleResult {\n    const roomSchedules = new Map<string, RoomSchedule>();\n    for (const r of rooms) {\n      roomSchedules.set(r.id, []);\n    }\n\n    const assignments: Assignment[] = [];\n    const unscheduled: string[] = [];\n    const assignedEvents = new Map<string, Assignment>();\n\n    for (const eventId of orderedEventIds) {\n      const event = eventMap.get(eventId);\n      if (!event) {\n        unscheduled.push(eventId);\n        continue;\n      }\n\n      const duration = event.duration;\n      const eligible = compatibleRooms.get(eventId) ?? [];\n      if (eligible.length === 0) {\n        unscheduled.push(eventId);\n        continue;\n      }\n\n      // Determine earliest start based on prerequisites\n      let earliestStart = options.startTime;\n      if (event.prerequisites) {\n        for (const preId of event.prerequisites) {\n          const preAssignment = assignedEvents.get(preId);\n          if (preAssignment) {\n            earliestStart = Math.max(earliestStart, preAssignment.endTime + gap);\n          } else {\n            // Prerequisite not scheduled - can't schedule this event\n            earliestStart = Infinity;\n            break;\n          }\n        }\n      }\n\n      if (earliestStart === Infinity || earliestStart + duration > options.endTime) {\n        unscheduled.push(eventId);\n        continue;\n      }\n\n      // Try preferred room first, then others\n      const sortedRooms = [...eligible];\n      if (event.preferredRoom) {\n        sortedRooms.sort((a, b) => {\n          if (a.id === event.preferredRoom) return -1;\n          if (b.id === event.preferredRoom) return 1;\n          return 0;\n        });\n      }\n\n      let bestAssignment: Assignment | null = null;\n\n      for (const room of sortedRooms) {\n        const sched = roomSchedules.get(room.id)!;\n        const startTime = findEarliestSlot(\n          sched,\n          duration,\n          earliestStart,\n          options.endTime,\n          gap\n        );\n        if (startTime !== null) {\n          if (!bestAssignment || startTime < bestAssignment.startTime) {\n            bestAssignment = {\n              eventId,\n              roomId: room.id,\n              startTime,\n              endTime: startTime + duration,\n            };\n            // If preferred room works, use it\n            if (room.id === event.preferredRoom) break;\n          }\n        }\n      }\n\n      if (bestAssignment) {\n        assignments.push(bestAssignment);\n        assignedEvents.set(eventId, bestAssignment);\n        const sched = roomSchedules.get(bestAssignment.roomId)!;\n        sched.push({\n          eventId,\n          start: bestAssignment.startTime,\n          end: bestAssignment.endTime,\n        });\n        sched.sort((a, b) => a.start - b.start);\n      } else {\n        unscheduled.push(eventId);\n      }\n    }\n\n    return { assignments, unscheduled };\n  }\n\n  // Strategy 1: Schedule in topological order\n  const result1 = greedySchedule(orderedIds);\n\n  // If everything is scheduled, return\n  if (result1.unscheduled.length === 0) {\n    return result1;\n  }\n\n  // Strategy 2: Schedule harder-to-place events first (fewer compatible rooms, longer duration)\n  // while respecting topological order\n  const topoIndex = new Map<string, number>();\n  orderedIds.forEach((id, i) => topoIndex.set(id, i));\n\n  const sortedByDifficulty = [...orderedIds].sort((a, b) => {\n    const roomsA = (compatibleRooms.get(a) ?? []).length;\n    const roomsB = (compatibleRooms.get(b) ?? []).length;\n    if (roomsA !== roomsB) return roomsA - roomsB; // fewer rooms = harder\n    const durA = eventMap.get(a)!.duration;\n    const durB = eventMap.get(b)!.duration;\n    if (durA !== durB) return durB - durA; // longer = harder\n    return (topoIndex.get(a) ?? 0) - (topoIndex.get(b) ?? 0);\n  });\n\n  // Need to ensure topological order: use a priority-based approach\n  // Build a scheduling order that respects prerequisites but prioritizes difficult events\n  function topoSortWithPriority(priority: Map<string, number>): string[] {\n    const inDeg = new Map<string, number>();\n    const adj = new Map<string, string[]>();\n    for (const e of events) {\n      inDeg.set(e.id, 0);\n      if (!adj.has(e.id)) adj.set(e.id, []);\n    }\n    for (const e of events) {\n      if (e.prerequisites) {\n        for (const preId of e.prerequisites) {\n          if (eventIds.has(preId)) {\n            if (!adj.has(preId)) adj.set(preId, []);\n            adj.get(preId)!.push(e.id);\n            inDeg.set(e.id, (inDeg.get(e.id) ?? 0) + 1);\n          }\n        }\n      }\n    }\n\n    const ready = events\n      .filter(e => (inDeg.get(e.id) ?? 0) === 0)\n      .map(e => e.id);\n    ready.sort((a, b) => (priority.get(a) ?? 0) - (priority.get(b) ?? 0));\n\n    const result: string[] = [];\n    while (ready.length > 0) {\n      // Pick highest priority (lowest number)\n      ready.sort((a, b) => (priority.get(a) ?? 0) - (priority.get(b) ?? 0));\n      const id = ready.shift()!;\n      result.push(id);\n      for (const dep of adj.get(id) ?? []) {\n        const d = (inDeg.get(dep) ?? 1) - 1;\n        inDeg.set(dep, d);\n        if (d === 0) {\n          ready.push(dep);\n        }\n      }\n    }\n    return result;\n  }\n\n  // Priority: fewer rooms first, then longer duration\n  const difficultyPriority = new Map<string, number>();\n  for (const e of events) {\n    const nRooms = (compatibleRooms.get(e.id) ?? []).length;\n    const dur = e.duration;\n    difficultyPriority.set(e.id, nRooms * 10000 - dur);\n  }\n  const order2 = topoSortWithPriority(difficultyPriority);\n  const result2 = greedySchedule(order2);\n\n  // Strategy 3: Longest duration first\n  const durationPriority = new Map<string, number>();\n  for (const e of events) {\n    durationPriority.set(e.id, -e.duration);\n  }\n  const order3 = topoSortWithPriority(durationPriority);\n  const result3 = greedySchedule(order3);\n\n  // Pick the result with most events scheduled\n  let best = result1;\n  if (result2.unscheduled.length < best.unscheduled.length) best = result2;\n  if (result3.unscheduled.length < best.unscheduled.length) best = result3;\n\n  // Strategy 4: If still unscheduled, try backtracking for small instances\n  if (best.unscheduled.length > 0 && events.length <= 50) {\n    const btResult = backtrackSchedule(orderedIds, eventMap, rooms, compatibleRooms, options, gap);\n    if (btResult.unscheduled.length < best.unscheduled.length) {\n      best = btResult;\n    }\n  }\n\n  // Ensure all events appear in either assignments or unscheduled\n  const scheduledIds = new Set(best.assignments.map(a => a.eventId));\n  const missingIds = events\n    .filter(e => !scheduledIds.has(e.id) && !best.unscheduled.includes(e.id))\n    .map(e => e.id);\n  if (missingIds.length > 0) {\n    best = {\n      assignments: best.assignments,\n      unscheduled: [...best.unscheduled, ...missingIds],\n    };\n  }\n\n  return best;\n}\n\nfunction backtrackSchedule(\n  orderedIds: string[],\n  eventMap: Map<string, Event>,\n  rooms: Room[],\n  compatibleRooms: Map<string, Room[]>,\n  options: ScheduleOptions,\n  gap: number\n): ScheduleResult {\n  type Slot = { eventId: string; start: number; end: number };\n  type State = {\n    roomSchedules: Map<string, Slot[]>;\n    assignments: Map<string, Assignment>;\n    scheduled: Set<string>;\n  };\n\n  function cloneState(state: State): State {\n    const newRoomSchedules = new Map<string, Slot[]>();\n    for (const [k, v] of state.roomSchedules) {\n      newRoomSchedules.set(k, [...v]);\n    }\n    return {\n      roomSchedules: newRoomSchedules,\n      assignments: new Map(state.assignments),\n      scheduled: new Set(state.scheduled),\n    };\n  }\n\n  function findAllSlots(\n    roomSched: Slot[],\n    duration: number,\n    earliestStart: number,\n    deadline: number,\n    gapMinutes: number\n  ): number[] {\n    const results: number[] = [];\n    let candidate = earliestStart;\n\n    // Find all possible start times\n    while (candidate + duration <= deadline) {\n      let valid = true;\n      let nextCandidate = deadline; // default jump to end\n\n      for (const slot of roomSched) {\n        // Check conflict\n        const newEnd = candidate + duration;\n        if (newEnd + gapMinutes <= slot.start || slot.end + gapMinutes <= candidate) {\n          continue; // no conflict\n        }\n        // Conflict - must move past this slot\n        valid = false;\n        candidate = slot.end + gapMinutes;\n        break;\n      }\n\n      if (valid) {\n        results.push(candidate);\n        // Find next gap after this placement\n        const placedEnd = candidate + duration + gapMinutes;\n        // Move to next meaningful position\n        let jumped = false;\n        for (const slot of roomSched) {\n          if (slot.start >= placedEnd) {\n            // Could skip to just before this slot? No, just increment\n            break;\n          }\n        }\n        if (!jumped) {\n          // Just return the first valid slot for efficiency in backtracking\n          // Trying all slots would be too expensive\n          break;\n        }\n      }\n    }\n\n    return results;\n  }\n\n  const initState: State = {\n    roomSchedules: new Map(rooms.map(r => [r.id, []])),\n    assignments: new Map(),\n    scheduled: new Set(),\n  };\n\n  let bestResult: ScheduleResult = {\n    assignments: [],\n    unscheduled: [...orderedIds],\n  };\n\n  function canSchedulePrereqs(eventId: string, state: State): boolean {\n    const event = eventMap.get(eventId);\n    if (!event?.prerequisites) return true;\n    for (const preId of event.prerequisites) {\n      if (!state.scheduled.has(preId)) return false;\n    }\n    return true;\n  }\n\n  function getEarliestStart(eventId: string, state: State): number {\n    const event = eventMap.get(eventId)!;\n    let earliest = options.startTime;\n    if (event.prerequisites) {\n      for (const preId of event.prerequisites) {\n        const a = state.assignments.get(preId);\n        if (a) {\n          earliest = Math.max(earliest, a.endTime + gap);\n        }\n      }\n    }\n    return earliest;\n  }\n\n  function solve(index: number, state: State): void {\n    // Prune: if we can't beat the best even scheduling all remaining\n    const remaining = orderedIds.length - index;\n    if (state.scheduled.size + remaining <= bestResult.assignments.length) {\n      return;\n    }\n\n    if (index >= orderedIds.length) {\n      if (state.scheduled.size > bestResult.assignments.length) {\n        bestResult = {\n          assignments: Array.from(state.assignments.values()),\n          unscheduled: orderedIds.filter(id => !state.scheduled.has(id)),\n        };\n      }\n      return;\n    }\n\n    const eventId = orderedIds[index];\n    const event = eventMap.get(eventId)!;\n\n    // Option 1: Skip this event\n    solve(index + 1, state);\n\n    // Option 2: Try to place this event\n    if (!canSchedulePrereqs(eventId, state)) {\n      return; // Prerequisites not met, can only skip\n    }\n\n    const eligible = compatibleRooms.get(eventId) ?? [];\n    const earliestStart = getEarliestStart(eventId, state);\n\n    if (earliestStart + event.duration > options.endTime) {\n      return;\n    }\n\n    // Sort rooms: preferred first\n    const sortedRooms = [...eligible];\n    if (event.preferredRoom) {\n      sortedRooms.sort((a, b) => {\n        if (a.id === event.preferredRoom) return -1;\n        if (b.id === event.preferredRoom) return 1;\n        return 0;\n      });\n    }\n\n    for (const