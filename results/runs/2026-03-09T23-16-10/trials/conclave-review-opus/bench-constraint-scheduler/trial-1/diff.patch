tTime + event.duration,\n        };\n        newState.assignments.set(eventId, assignment);\n        newState.scheduled.add(eventId);\n        const roomSched = newState.roomSchedules.get(room.id)!;\n        roomSched.push({ eventId, start: startTime, end: startTime + event.duration });\n        roomSched.sort((a, b) => a.start - b.start);\n\n        solve(index + 1, newState);\n\n        // Early exit if we scheduled everything\n        if (bestResult.unscheduled.length === 0) return;\n      }\n    }\n  }\n\n  solve(0, initState);\n  return bestResult;\n}\n","structuredPatch":[{"oldStart":534,"oldLines":9,"newStart":534,"newLines":9,"lines":[" ","     for (const room of sortedRooms) {","       const sched = state.roomSchedules.get(room.id)!;","-      const slots = findAllSlots(sched, event.duration, earliestStart, options.endTime, gap);","+      const startTime = findEarliestSlotBT(sched, event.duration, earliestStart, options.endTime, gap);"," ","-      for (const startTime of slots) {","+      if (startTime !== null) {","         const newState = cloneState(state);","         const assignment: Assignment = {","           eventId,"]}],"userModified":false,"replaceAll":false}}
