n      const a = result.assignments.find(x => x.eventId === 'A')!;\n      const b = result.assignments.find(x => x.eventId === 'B')!;\n\n      // They should not overlap and must have at least 15 min gap\n      if (a.startTime < b.startTime) {\n        expect(b.startTime).toBeGreaterThanOrEqual(a.endTime + 15);\n      } else {\n        expect(a.startTime).toBeGreaterThanOrEqual(b.endTime + 15);\n      }\n    });\n\n    it('schedules events into multiple rooms', () => {\n      const events = [makeEvent('A', 60), makeEvent('B', 60)];\n      const rooms = [makeRoom('R1'), makeRoom('R2')];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(2);\n      expect(result.unscheduled).toHaveLength(0);\n    });\n\n    it('returns empty results for empty events', () => {\n      const result = schedule([], [makeRoom('R1')], defaultOptions);\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toHaveLength(0);\n    });\n  });\n\n  describe('capacity constraints', () => {\n    it('does not place event in room with insufficient capacity', () => {\n      const events = [makeEvent('A', 60, { attendees: 100 })];\n      const rooms = [makeRoom('R1', 50)];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toEqual(['A']);\n    });\n\n    it('places event in room with sufficient capacity', () => {\n      const events = [makeEvent('A', 60, { attendees: 30 })];\n      const rooms = [makeRoom('R1', 50), makeRoom('R2', 20)];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('R1');\n    });\n\n    it('assigns event to the only room with enough capacity', () => {\n      const events = [makeEvent('A', 60, { attendees: 40 })];\n      const rooms = [makeRoom('R1', 30), makeRoom('R2', 50)];\n      