@@ -0,0 +1,62 @@
+import { marked } from 'marked';
+import { gfmHeadingId } from 'marked-gfm-heading-id';
+import markedFootnote from 'marked-footnote';
+import { BuildContext, ContentFile, Plugin } from '../core/types.js';
+
+// Admonition extension for marked
+const admonitionExtension = {
+  name: 'admonition',
+  level: 'block' as const,
+  start(src: string) {
+    return src.match(/^:::(note|warning|tip)/)?.index;
+  },
+  // eslint-disable-next-line @typescript-eslint/no-explicit-any
+  tokenizer(src: string, _tokens: any) {
+    const rule = new RegExp(/^:::(note|warning|tip)(?:[ \t]+([^\n]+))?\n([\s\S]*?)\n:::(?:\n|$)/.source);
+    const match = rule.exec(src);
+    if (match) {
+      const type = match[1];
+      const title = match[2] ? match[2].trim() : type.charAt(0).toUpperCase() + type.slice(1);
+      const text = match[3]; // Store raw text, do not tokenize here
+      return {
+        type: 'admonition',
+        raw: match[0],
+        type_name: type,
+        title,
+        text, // Pass raw text
+      };
+    }
+    return undefined;
+  },
+  // eslint-disable-next-line @typescript-eslint/no-explicit-any
+  renderer(_token: any) {
+    // Render the raw text using marked.parse
+    return `<div class="admonition admonition-${_token.type_name}"><p class="admonition-title">${_token.title}</p>${marked.parse(_token.text)}\n</div>\n`;
+  },
+};
+
+export function createMarkdownExtPlugin(): Plugin {
+  // Initialize marked with extensions
+  marked.use(gfmHeadingId());
+  marked.use(markedFootnote());
+  marked.use({ extensions: [admonitionExtension] });
+
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: async (file: ContentFile, _ctx: BuildContext): Promise<ContentFile> => {
+        // Only transform markdown files
+        // A simple check: if the content starts with '<', assume it's HTML and skip.
+        if (file.content.trim().startsWith('<')) {
+          return file;
+        }
+        return {
+          ...file,
+          content: await marked.parse(file.content), // Use marked.parse for the actual parsing
+        };
+      },
+    },
+  };
+}
