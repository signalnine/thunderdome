+++ b/src/plugins/asset-pipeline.ts
@@ -0,0 +1,44 @@
+import { BuildContext, ContentFile, Plugin } from '../core/types.js';
+
+export function createAssetPipelinePlugin(): Plugin {
+  return {
+    name: 'asset-pipeline',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: async (file: ContentFile, ctx: BuildContext): Promise<ContentFile> => {
+        const assetManifest = (ctx.data.get('asset-manifest') || { assets: [] }) as { assets: string[] };
+
+        // Regex to find src and href attributes in HTML tags
+        // It captures the attribute name (src or href) and the URL
+        const urlRegex = /(src|href)="([^"]*)"/g;
+
+        const newContent = file.content.replace(urlRegex, (match, attr, url) => {
+          if (url.startsWith('./') && !url.startsWith('/assets/')) {
+            // It's a relative URL, rewrite it
+            const assetName = url.substring(url.lastIndexOf('/') + 1);
+            if (!assetManifest.assets.includes(assetName)) {
+                assetManifest.assets.push(assetName);
+            }
+            return `${attr}="/assets/${assetName}"`;
+          } else if (url.startsWith('/') && url.includes('/assets/')) {
+            // Already rewritten, leave unchanged and do not add to manifest again.
+            // The manifest should only contain assets that were *originally* relative and rewritten.
+            return match;
+          } else if (url.startsWith('http://') || url.startsWith('https://') || url.startsWith('//')) {
+            // Absolute URL, leave unchanged
+            return match;
+          }
+          return match; // Other cases, leave unchanged
+        });
+
+        ctx.data.set('asset-manifest', assetManifest);
+
+        return {
+          ...file,
+          content: newContent,
+        };
+      },
+    },
+  };
+}
