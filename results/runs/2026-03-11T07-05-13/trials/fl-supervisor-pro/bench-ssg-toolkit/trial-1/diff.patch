@@ -0,0 +1,38 @@
+import { BuildContext, ContentFile as _ContentFile, Plugin } from '../core/types.js';
+
+export function createSearchIndexPlugin(): Plugin {
+  return {
+    name: 'search-index',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'syntax-highlight'], // Depends on these for HTML content
+    hooks: {
+      afterBuild: async (ctx: BuildContext): Promise<void> => {
+        const searchIndex: Array<{ slug: string; title: string; content: string; tags?: string[] }> = [];
+
+        for (const file of ctx.files) {
+          if (!file.title || !file.slug) {
+            continue; // Skip files that can't be meaningfully indexed
+          }
+
+          // Strip HTML tags to get plain text content
+          // This simple regex handles most cases, but might need refinement for complex HTML
+          const plainTextContent = file.content.replace(/<[^>]*>/g, '');
+
+          const indexEntry: { slug: string; title: string; content: string; tags?: string[] } = {
+            slug: file.slug,
+            title: file.title,
+            content: plainTextContent,
+          };
+
+          if (file.tags && file.tags.length > 0) {
+            indexEntry.tags = file.tags;
+          }
+
+          searchIndex.push(indexEntry);
+        }
+
+        ctx.output.set('search-index.json', JSON.stringify(searchIndex, null, 2));
+      },
+    },
+  };
+}
