@@ -0,0 +1,52 @@
+import { BuildContext, ContentFile, Plugin } from '../core/types.js';
+
+export function createSyntaxHighlightPlugin(): Plugin {
+  return {
+    name: 'syntax-highlight',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: async (file: ContentFile, _ctx: BuildContext): Promise<ContentFile> => {
+        // Regex to find <pre>...</pre> blocks containing <code>...</code>
+        // Captures:
+        // 1: attributes of the <pre> tag (preAttrs)
+        // 2: class attribute of the <code> tag (codeClassAttr), if it exists
+        // 3: existing classes in the <code> tag (existingClasses), if codeClassAttr exists
+        // 4: other attributes of the <code> tag (otherCodeAttrs)
+        // 5: content of the <code> tag (codeContent)
+        const codeBlockRegex = /(<pre[^>]*?>)\s*<code(?:\s+class="([^"]*)")?([^>]*)>([\s\S]*?)<\/code>\s*<\/pre>/g;
+
+        const newContent = file.content.replace(codeBlockRegex, (match, preTag, codeClassAttr, otherCodeAttrs, codeContent) => {
+          let language = '';
+          let newCodeClass = codeClassAttr || ''; // Start with existing classes or empty string
+
+          // Check if there's a language specified in the class
+          const langMatch = newCodeClass.match(/language-(\w+)/);
+          if (langMatch) {
+            language = langMatch[1];
+            // Add 'highlighted' class if not already present
+            if (!newCodeClass.includes('highlighted')) {
+              newCodeClass = `${newCodeClass.trim()} highlighted`.trim();
+            }
+          } else {
+            // No language specified, return original block unchanged
+            return match;
+          }
+
+          // Construct new <code> tag class attribute
+          const finalCodeClassAttr = newCodeClass ? ` class="${newCodeClass}"` : '';
+
+          // Construct new <pre> tag with data-language
+          const newPreTag = preTag.replace(/>$/, ` data-language="${language}">`);
+
+          return `${newPreTag}<code${finalCodeClassAttr}${otherCodeAttrs}>${codeContent}</code></pre>`;
+        });
+
+        return {
+          ...file,
+          content: newContent,
+        };
+      },
+    },
+  };
+}
diff --git a/src/plugins/taxonomy.ts b/src/plugins/taxonomy.ts
