@@ -0,0 +1,55 @@
+import { BuildContext, Plugin } from '../core/types.js';
+
+export function createSitemapPlugin(): Plugin {
+  return {
+    name: 'sitemap',
+    version: '1.0.0',
+    dependencies: ['taxonomy', 'rss-feed'], // Depends on these for their generated output
+    hooks: {
+      afterBuild: async (ctx: BuildContext): Promise<void> => {
+        const { config, output } = ctx;
+
+        let urlsetXml = '';
+        const handledPaths = new Set<string>();
+
+        // Add all HTML files and feed.xml from ctx.output
+        for (const outputPath of output.keys()) {
+          // Only include top-level HTML files and feed.xml, exclude tag pages that are handled explicitly below
+          // The assumption here is that tag pages are explicitly created by the taxonomy plugin
+          // and named consistently, so we avoid duplicate entries and handle them via taxonomy's data.
+          if (outputPath.endsWith('.html') || outputPath === 'feed.xml') {
+            const fullUrl = `${config.baseUrl}/${outputPath}`;
+            urlsetXml += `
+    <url>
+      <loc>${fullUrl}</loc>
+    </url>`;
+            handledPaths.add(outputPath);
+          }
+        }
+        
+        // Add taxonomy tag pages, if available
+        const tagMap = ctx.data.get('taxonomy-tags');
+        if (tagMap instanceof Map) {
+          for (const tag of tagMap.keys()) {
+            const tagPagePath = `tags/${tag}.html`;
+            if (!handledPaths.has(tagPagePath)) { // Avoid duplicates if tag page was already added (e.g. if it was an empty file in output)
+              const fullUrl = `${config.baseUrl}/${tagPagePath}`;
+              urlsetXml += `
+    <url>
+      <loc>${fullUrl}</loc>
+    </url>`;
+              handledPaths.add(tagPagePath);
+            }
+          }
+        }
+
+        const sitemapXml = `<?xml version="1.0" encoding="UTF-8"?>
+<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
+  ${urlsetXml}
+</urlset>`;
+
+        ctx.output.set('sitemap.xml', sitemapXml);
+      },
+    },
+  };
+}
