@@ -0,0 +1,53 @@
+import { BuildContext, Plugin, SiteConfig as _SiteConfig } from '../core/types.js';
+
+interface DevServerConfig {
+  port: number;
+  routes: Array<{ path: string; handler: string }>;
+  assetPaths: string[];
+  searchIndexPath: string;
+}
+
+export function createDevServerPlugin(): Plugin {
+  return {
+    name: 'dev-server',
+    version: '1.0.0',
+    dependencies: ['asset-pipeline', 'search-index'], // Depends on these for their generated data
+    hooks: {
+      afterBuild: async (ctx: BuildContext): Promise<void> => {
+        const { output, data } = ctx;
+        const config: DevServerConfig = {
+          port: 3000, // Default port
+          routes: [],
+          assetPaths: [],
+          searchIndexPath: '',
+        };
+
+        // Populate assetPaths from asset-manifest
+        const assetManifest = data.get('asset-manifest') as { assets: string[] } | undefined;
+        if (assetManifest && assetManifest.assets) {
+          config.assetPaths = assetManifest.assets;
+        }
+
+        // Populate routes for static HTML files
+        for (const outputPath of output.keys()) {
+          if (outputPath.endsWith('.html')) {
+            config.routes.push({ path: `/${outputPath}`, handler: 'static' });
+          }
+        }
+
+        // Populate routes for assets
+        for (const assetName of config.assetPaths) {
+          config.routes.push({ path: `/assets/${assetName}`, handler: 'asset' });
+        }
+
+        // Set search index path if it exists
+        if (output.has('search-index.json')) {
+          config.searchIndexPath = '/search-index.json';
+          config.routes.push({ path: '/search-index.json', handler: 'static' }); // Add route for search index
+        }
+        
+        ctx.data.set('dev-server-config', config);
+      },
+    },
+  };
+}
