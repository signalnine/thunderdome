@@ -0,0 +1,60 @@
+import { BuildContext, ContentFile, Plugin } from '../core/types.js';
+
+export function createRssFeedPlugin(): Plugin {
+  return {
+    name: 'rss-feed',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'taxonomy'], // Depends on these for HTML content and tags
+    hooks: {
+      afterBuild: async (ctx: BuildContext): Promise<void> => {
+        const { config, files, data } = ctx;
+        const tagMap = data.get('taxonomy-tags') as Map<string, ContentFile[]> | undefined;
+
+        // Filter and sort files suitable for RSS feed
+        const posts = files
+          .filter(file => file.title && file.content) // Allow files without dates
+          .sort((a, b) => new Date(b.date!).getTime() - new Date(a.date!).getTime()); // Newest first
+
+        let itemsXml = '';
+        for (const post of posts) {
+          const postLink = `${config.baseUrl}/${post.slug}.html`;
+          const pubDate = post.date ? new Date(post.date).toUTCString() : '';
+
+          let categoriesXml = '';
+          if (tagMap) {
+            for (const [tag, taggedFiles] of tagMap.entries()) {
+              if (taggedFiles.some(f => f.slug === post.slug)) {
+                categoriesXml += `<category>${tag}</category>
+`;
+              }
+            }
+          }
+
+          itemsXml += `
+    <item>
+      <title>${post.title}</title>
+      <link>${postLink}</link>
+      <guid>${postLink}</guid>
+      <description><![CDATA[${post.content}]]></description>
+      ${pubDate ? `<pubDate>${pubDate}</pubDate>` : ''}
+      ${categoriesXml}
+    </item>`;
+        }
+
+        const rssFeed = `<?xml version="1.0" encoding="UTF-8"?>
+<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
+  <channel>
+    <title>${config.title}</title>
+    <link>${config.baseUrl}</link>
+    <description>A feed of ${config.title}</description>
+    <language>en-us</language>
+    <atom:link href="${config.baseUrl}/feed.xml" rel="self" type="application/rss+xml" />
+    ${itemsXml}
+  </channel>
+</rss>`;
+
+        ctx.output.set('feed.xml', rssFeed);
+      },
+    },
+  };
+}
