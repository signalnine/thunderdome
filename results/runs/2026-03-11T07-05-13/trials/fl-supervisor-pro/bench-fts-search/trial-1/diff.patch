@@ -118,5 +118,66 @@ export function createRoutes(db: Database.Database): Router {
     }
   });
 
+  // GET /notes/search?q=<query>&page=N - Full-text search endpoint
+  router.get('/notes/search', (req: Request, res: Response, next: NextFunction) => {
+    try {
+      const query = req.query.q as string;
+      const page = parseInt(req.query.page as string) || 1;
+      const perPage = 20;
+      const offset = (page - 1) * perPage;
+
+      if (!query || query.trim() === '') {
+        throw new ValidationError('Query parameter "q" is required');
+      }
+
+      // SQL to fetch search results with snippet highlighting and rank
+      // The FTS5 MATCH operator allows for complex queries, including quoted phrases.
+      // The snippet function uses the same query to generate highlighted results.
+      const selectSql = `
+        SELECT
+            n.id,
+            n.title,
+            snippet(fts, ?, '<mark>', '</mark>', 10) AS snippet,
+            fts.rank
+        FROM notes AS n
+        JOIN notes_fts AS fts ON n.id = fts.id
+        WHERE fts.title MATCH ? OR fts.body MATCH ?
+        ORDER BY fts.rank DESC
+        LIMIT ? OFFSET ?
+      `;
+      const searchStmt = db.prepare(selectSql);
+      // Pass the query string for snippet generation, title search, and body search.
+      const searchResults = searchStmt.all(query, query, query, perPage, offset) as SearchResult[];
+
+      // SQL to count total matching results
+      const countSql = `
+        SELECT COUNT(n.id) AS total
+        FROM notes AS n
+        JOIN notes_fts AS fts ON n.id = fts.id
+        WHERE fts.title MATCH ? OR fts.body MATCH ?
+      `;
+      const countStmt = db.prepare(countSql);
+      // Pass the query string for both title and body search for counting.
+      const totalResult = countStmt.get(query, query) as { total: number };
+
+      res.json({
+        results: searchResults,
+        total: totalResult.total,
+        page: page,
+        perPage: perPage,
+      });
+    } catch (err) {
+      next(err);
+    }
+  });
+
+  // GET /notes/search/suggest?q=<prefix> - Autocomplete suggestions
+  // This endpoint will be implemented in the next subtask.
+  // For now, we can add a placeholder or leave it out.
+  // router.get('/notes/search/suggest', (req: Request, res: Response, next: NextFunction) => {
+  //   // Implementation for suggest endpoint
+  // });
+
+
   return router;
 }
