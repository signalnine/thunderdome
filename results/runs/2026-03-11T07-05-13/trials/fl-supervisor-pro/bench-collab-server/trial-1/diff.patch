+import express from 'express';
+import Database from 'better-sqlite3';
+import http from 'http';
+import { WebSocketServer, WebSocket } from 'ws'; // Correct import for WebSocketServer class
+
+const DEFAULT_DB_PATH = './documents.db';
+
+// Store active WebSocket connections per document
+interface DocumentConnections {
+  [documentId: string]: Set<WebSocket>;
+}
+
+// Database schema definition
+interface Document {
+  id: string;
+  title: string;
+  content: string;
+  created_at: number;
+  updated_at: number;
+}
+
+interface Version {
+  id: number;
+  document_id: string;
+  content_snapshot: string;
+  timestamp: number;
+  operation_details: string | null; // For OT/CRDT specific details if needed later
+}
+
+export function createApp(dbPath: string = DEFAULT_DB_PATH) {
+  const db = new Database(dbPath);
+  const app = express();
+  const server = http.createServer(app);
+  
+  // Initialize WebSocket server
+  const wss = new WebSocketServer({ server });
+  const documentConnections: DocumentConnections = {}; // Map to store connections per document
+
+  app.use(express.json()); // Middleware to parse JSON bodies
+
+  // Setup database schema
+  db.exec(`
+    CREATE TABLE IF NOT EXISTS documents (
+      id TEXT PRIMARY KEY,
+      title TEXT NOT NULL,
+      content TEXT NOT NULL,
+      created_at INTEGER NOT NULL,
+      updated_at INTEGER NOT NULL
+    );
+
+    CREATE TABLE IF NOT EXISTS versions (
+      id INTEGER PRIMARY KEY AUTOINCREMENT,
+      document_id TEXT NOT NULL,
+      content_snapshot TEXT NOT NULL,
+      timestamp INTEGER NOT NULL,
+      operation_details TEXT,
+      FOREIGN KEY (document_id) REFERENCES documents (id) ON DELETE CASCADE
+    );
+  `);
+
+  // REST API Endpoints for Document Management
+
+  // CREATE Document
+  app.post('/documents', (req, res) => {
+    const { title, content } = req.body;
+    if (!title || typeof content === 'undefined') {
+      return res.status(400).json({ error: 'Title and content are required' });
+    }
+    const id = crypto.randomUUID(); // Use crypto for UUID generation
+    const now = Date.now();
+    try {
+      const stmt = db.prepare('INSERT INTO documents (id, title, content, created_at, updated_at) VALUES (@id, @title, @content, @created_at, @updated_at)');
+      stmt.run({ id, title, content, created_at: now, updated_at: now });
+      // Create initial version
+      const versionStmt = db.prepare('INSERT INTO versions (document_id, content_snapshot, timestamp) VALUES (@document_id, @content_snapshot, @timestamp)');
+      versionStmt.run({ document_id: id, content_snapshot: content, timestamp: now });
+      res.status(201).json({ id, title, content, created_at: now, updated_at: now });
+    } catch (error) {
+      console.error('Error creating document:', error);
+      res.status(500).json({ error: 'Failed to create document' });
+    }
+  });
+
+  // LIST Documents
+  app.get('/documents', (_, res) => {
+    try {
+      const stmt = db.prepare('SELECT id, title, created_at, updated_at FROM documents ORDER BY updated_at DESC');
+      const documents = stmt.all() as Document[];
+      res.json(documents);
+    } catch (error) {
+      console.error('Error listing documents:', error);
+      res.status(500).json({ error: 'Failed to list documents' });
+    }
+  });
+
+  // READ Document
+  app.get('/documents/:id', (req, res) => {
+    const { id } = req.params;
+    try {
+      const stmt = db.prepare('SELECT * FROM documents WHERE id = @id');
+      const document = stmt.get({ id }) as Document | undefined;
+      if (!document) {
+        return res.status(404).json({ error: 'Document not found' });
+      }
+      res.json(document);
+    } catch (error) {
+      console.error(`Error reading document \${id}:`, error);
+      res.status(500).json({ error: 'Failed to read document' });
+    }
+  });
+
+  // UPDATE Document
+  app.put('/documents/:id', (req, res) => {
+    const { id } = req.params;
+    const { title, content } = req.body;
+    const now = Date.now();
+
+    try {
+      // Fetch current document to save its state as a version
+      const getStmt = db.prepare('SELECT * FROM documents WHERE id = @id');
+      const existingDoc = getStmt.get({ id }) as Document | undefined;
+
+      if (!existingDoc) {
+        return res.status(404).json({ error: 'Document not found' });
+      }
+
+      // Update document fields
+      const updateStmt = db.prepare('UPDATE documents SET title = @title, content = @content, updated_at = @updated_at WHERE id = @id');
+      updateStmt.run({ id, title: title ?? existingDoc.title, content: typeof content !== 'undefined' ? content : existingDoc.content, updated_at: now });
+
+      // Create a new version *before* committing the updated content,
+      // so the snapshot is of the state *before* this update.
+      // If content changed, save the old content as a version.
+      if (typeof content !== 'undefined' && content !== existingDoc.content) {
+        const versionStmt = db.prepare('INSERT INTO versions (document_id, content_snapshot, timestamp) VALUES (@document_id, @content_snapshot, @timestamp)');
+        versionStmt.run({ document_id: id, content_snapshot: existingDoc.content, timestamp: now });
+      } else if (title && title !== existingDoc.title) {
+        // If only title changed, we might still want to record a version if deemed necessary.
+        // For now, let's only version content changes.
+      }
+
+      // Fetch the updated document to return
+      const updatedDocStmt = db.prepare('SELECT * FROM documents WHERE id = @id');
+      const updatedDoc = updatedDocStmt.get({ id }) as Document;
+
+      res.json(updatedDoc);
+    } catch (error) {
+      console.error(`Error updating document ${id}:`, error);
+      res.status(500).json({ error: 'Failed to update document' });
+    }
+  });
+
+  // DELETE Document
+  app.delete('/documents/:id', (req, res) => {
+    const { id } = req.params;
+    try {
+      const stmt = db.prepare('DELETE FROM documents WHERE id = @id');
+      const result = stmt.run({ id });
+      if (result.changes === 0) {
+        return res.status(404).json({ error: 'Document not found' });
+      }
+      res.status(204).send(); // No content
+    } catch (error) {
+      console.error(`Error deleting document ${id}:`, error);
+      res.status(500).json({ error: 'Failed to delete document' });
+    }
+  });
+
+  // Endpoint to get version history (optional for now, but good to have)
+  app.get('/documents/:id/versions', (req, res) => {
+    const { id } = req.params;
+    try {
+      const stmt = db.prepare('SELECT id, timestamp, operation_details FROM versions WHERE document_id = @document_id ORDER BY timestamp ASC');
+      const versions = stmt.all({ document_id: id }) as Version[];
+      res.json(versions);
+    } catch (error) {
+      console.error(`Error getting versions for document ${id}:`, error);
+      res.status(500).json({ error: 'Failed to retrieve version history' });
+    }
+  });
+
+  // WebSocket event handling
+  wss.on('connection', (ws: WebSocket, req) => {
+    console.log('Client connected');
+
+    // Extract document ID from the WebSocket URL (e.g., ws://localhost:3000/ws/doc_id_123)
+    const url = new URL(req.url!, 'http://localhost'); // Provide a base URL for parsing
+    const documentId = url.pathname.split('/').pop(); // Get the last part of the path as document ID
+
+    if (!documentId) {
+      console.error('WebSocket connection attempted without a document ID.');
+      ws.send(JSON.stringify({ type: 'error', message: 'Document ID is required for WebSocket connection.' }));
+      ws.close(1008, 'Invalid document ID');
+      return;
+    }
+
+    // Add connection to the document's set of clients
+    if (!documentConnections[documentId]) {
+      documentConnections[documentId] = new Set<WebSocket>();
+    }
+    documentConnections[documentId].add(ws);
+
+    // Fetch the latest document state and send it to the newly connected client
+    try {
+      const getDocStmt = db.prepare('SELECT id, title, content FROM documents WHERE id = @id');
+      const document = getDocStmt.get({ id: documentId }) as Document | undefined;
+
+      if (!document) {
+        console.error(`Document not found for WebSocket connection: ${documentId}`);
+        ws.send(JSON.stringify({ type: 'error', message: 'Document not found.' }));
+        ws.close(1008, 'Document not found');
+        documentConnections[documentId].delete(ws); // Remove connection if document not found
+        return;
+      }
+
+      ws.send(JSON.stringify({ type: 'sync', documentId: document.id, title: document.title, content: document.content }));
+    } catch (error) {
+      console.error(`Error fetching document ${documentId} for WebSocket sync:`, error);
+      ws.send(JSON.stringify({ type: 'error', message: 'Failed to synchronize document.' }));
+      ws.close(1011, 'Internal Server Error');
+      documentConnections[documentId].delete(ws); // Remove connection on error
+    }
+
+    ws.on('message', (message: string) => {
+      console.log(`Received message from client for document ${documentId}: ${message}`);
+      // TODO: Implement message parsing and handling (e.g., for edits)
+      // For now, just log. Will be implemented in next steps.
+      try {
+        const parsedMessage = JSON.parse(message);
+        // Example: Broadcast edit to other clients
+        if (parsedMessage.type === 'edit') {
+          // TODO: Apply OT/CRDT transformation and update DB
+          const updatedContent = parsedMessage.content; // Placeholder for actual content
+          // Update document in DB
+          const now = Date.now();
+          const updateStmt = db.prepare('UPDATE documents SET content = @content, updated_at = @updated_at WHERE id = @id');
+          updateStmt.run({ id: documentId, content: updatedContent, updated_at: now });
+
+          // TODO: Save a version if content changed significantly
+          
+          // Broadcast to other clients
+          documentConnections[documentId].forEach((client) => {
+            if (client !== ws && client.readyState === WebSocket.OPEN) {
+              client.send(JSON.stringify({ type: 'edit', documentId, content: updatedContent }));
+            }
+          });
+        }
+      } catch (e) {
+        console.error(`Failed to process message: ${message}`, e);
+        ws.send(JSON.stringify({ type: 'error', message: 'Malformed message.' }));
+      }
+    });
+
+    ws.on('close', () => {
+      console.log('Client disconnected');
+      // Remove the connection from the set
+      if (documentConnections[documentId]) {
+        documentConnections[documentId].delete(ws);
+        // Clean up the document's connection set if it's empty
+        if (documentConnections[documentId].size === 0) {
+          delete documentConnections[documentId];
+        }
+      }
+    });
+
+    ws.on('error', (error) => {
+      console.error(`WebSocket error for document ${documentId}:`, error);
+      // Remove the connection on error
+      if (documentConnections[documentId]) {
+        documentConnections[documentId].delete(ws);
+        if (documentConnections[documentId].size === 0) {
+          delete documentConnections[documentId];
+        }
+      }
+    });
+  });
+
+
+  const start = (port?: number): Promise<number> => {
+    return new Promise((resolve) => {
+      server.listen(port, () => {
+        const actualPort = (server.address() as { port: number }).port;
+        console.log(`Server listening on port ${actualPort}`);
+        resolve(actualPort);
+      });
+    });
+  };
+
+  const stop = (): Promise<void> => {
+    return new Promise((resolve, reject) => {
+      // Close all WebSocket connections
+      for (const docId in documentConnections) {
+        documentConnections[docId].forEach((client) => {
+          client.close(1001, 'Server shutting down'); // 1001: Going Away
+        });
+      }
+
+      // Close the HTTP server. This should gracefully shut down its listeners,
+      // including the WebSocket server managed by it.
+      server.close((err) => {
+        if (err) {
+          console.error('Error closing HTTP server:', err);
+          // If HTTP server fails to close, reject.
+          return reject(err);
+        }
+
+        // The original `wss.close()` call was causing the "server is not running" error,
+        // likely because `server.close()` already handled the shutdown of underlying resources.
+        // We will rely on `server.close()` to manage the shutdown of the WebSocket server.
+
+        // Close the database, which is synchronous.
+        try {
+          db.close();
+          console.log('Server and database closed.');
+          resolve(); // All closures successful.
+        } catch (closeErr: any) {
+          console.error('Error closing database:', closeErr);
+          reject(closeErr); // Reject if database close fails.
+        }
+      });
+    });
+  };
+
+  return { app, start, stop };
+}
