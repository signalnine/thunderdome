@@ -0,0 +1,181 @@
+import request from 'supertest';
+import { createApp } from '../src/server'; // Adjust path if needed
+import fs from 'fs';
+import path from 'path';
+import http from 'http'; // Import http module
+import express from 'express'; // Import express type
+
+const DB_PATH = './test_documents.db';
+
+// Helper to clean up the database file
+const cleanupDb = () => {
+  if (fs.existsSync(DB_PATH)) {
+    fs.unlinkSync(DB_PATH);
+  }
+};
+
+describe('Document API', () => {
+  // Global variables to hold the current server instance and its lifecycle functions
+  let app: express.Express;
+  let serverInstance: http.Server; // Renamed to avoid confusion with module 'http'
+  let stopServerFn: () => Promise<void>;
+  let currentPort: number;
+
+  // Helper to initialize and start the server
+  const startTestServer = async (dbPath: string) => {
+    // Clean DB *before* starting a NEW server for a test, ensures a fresh state.
+    cleanupDb();
+    const { app: createdApp, start, stop: stopFn } = createApp(dbPath);
+    app = createdApp;
+    // Assuming createApp returns an object with `app`, `start`, and `stop`.
+    // If serverInstance is needed for other reasons, it might be accessible via app._server or returned by start.
+    // For now, we rely on stopFn.
+    stopServerFn = stopFn;
+    currentPort = await start(0); // Start server on a random port for testing
+    // We might need to capture the actual http.Server instance if it's not fully managed by stopFn.
+    // For now, we rely on stopFn.
+  };
+
+  // Helper to stop the server
+  const stopTestServer = async () => {
+    if (stopServerFn) {
+      await stopServerFn(); // Call the stop function provided by createApp
+      stopServerFn = undefined as any; // Reset for the next lifecycle
+    }
+    // CleanupDB is now handled in afterEach to ensure it's done once per test run.
+  };
+
+  beforeEach(async () => {
+    // Start a new server instance for each test case
+    await startTestServer(DB_PATH);
+  });
+
+  afterEach(async () => {
+    // Stop the server and clean up the DB file after each test
+    await stopTestServer();
+    cleanupDb(); // Ensure DB is cleaned up after each test run.
+  });
+
+  it('should create a new document', async () => {
+    const response = await request(app)
+      .post('/documents')
+      .send({ title: 'Test Doc', content: 'This is the content.' });
+
+    expect(response.status).toBe(201);
+    expect(response.body).toHaveProperty('id');
+    expect(response.body.title).toBe('Test Doc');
+    expect(response.body.content).toBe('This is the content.');
+    expect(response.body).toHaveProperty('created_at');
+    expect(response.body).toHaveProperty('updated_at');
+  });
+
+  it('should list all documents', async () => {
+    // Create a couple of documents first
+    await request(app).post('/documents').send({ title: 'Doc 1', content: 'Content 1' });
+    await request(app).post('/documents').send({ title: 'Doc 2', content: 'Content 2' });
+
+    const response = await request(app).get('/documents');
+
+    expect(response.status).toBe(200);
+    expect(response.body).toBeInstanceOf(Array);
+    expect(response.body.length).toBe(2);
+    expect(response.body[0]).toHaveProperty('id');
+    expect(response.body[0].title).toBe('Doc 2'); // Should be ordered by updated_at DESC
+  });
+
+  it('should get a specific document by ID', async () => {
+    const createResponse = await request(app)
+      .post('/documents')
+      .send({ title: 'Specific Doc', content: 'Unique content' });
+    const docId = createResponse.body.id;
+
+    const response = await request(app).get(`/documents/${docId}`);
+
+    expect(response.status).toBe(200);
+    expect(response.body).toHaveProperty('id', docId);
+    expect(response.body.title).toBe('Specific Doc');
+    expect(response.body.content).toBe('Unique content');
+  });
+
+  it('should return 404 for non-existent document GET', async () => {
+    const response = await request(app).get('/documents/non-existent-id');
+    expect(response.status).toBe(404);
+  });
+
+  it('should update an existing document', async () => {
+    const createResponse = await request(app)
+      .post('/documents')
+      .send({ title: 'Doc to Update', content: 'Initial content' });
+    const docId = createResponse.body.id;
+
+    const response = await request(app)
+      .put(`/documents/${docId}`)
+      .send({ title: 'Updated Title', content: 'New content for the doc' });
+
+    expect(response.status).toBe(200);
+    expect(response.body.id).toBe(docId);
+    expect(response.body.title).toBe('Updated Title');
+    expect(response.body.content).toBe('New content for the doc');
+    expect(response.body.updated_at).toBeGreaterThan(response.body.created_at);
+  });
+
+  it('should return 404 for non-existent document PUT', async () => {
+    const response = await request(app)
+      .put('/documents/non-existent-id')
+      .send({ title: 'Update Fail', content: 'Should not work' });
+    expect(response.status).toBe(404);
+  });
+
+  it('should delete a document', async () => {
+    const createResponse = await request(app)
+      .post('/documents')
+      .send({ title: 'Doc to Delete', content: 'Content to be deleted' });
+    const docId = createResponse.body.id;
+
+    const response = await request(app).delete(`/documents/${docId}`);
+    expect(response.status).toBe(204);
+
+    // Verify deletion by trying to get it again
+    const getResponse = await request(app).get(`/documents/${docId}`);
+    expect(getResponse.status).toBe(404);
+  });
+
+  it('should return 404 for non-existent document DELETE', async () => {
+    const response = await request(app).delete('/documents/non-existent-id');
+    expect(response.status).toBe(404);
+  });
+
+  // Persistence test: Create a doc, stop server, restart, check if doc exists
+  it('should persist documents across server restarts', async () => {
+    // 1. Create a document with the current app instance (started by beforeEach)
+    const createResponse = await request(app)
+      .post('/documents')
+      .send({ title: 'Persistent Doc', content: 'This should survive.' });
+    const docId = createResponse.body.id;
+
+    // 2. Manually stop the current server instance.
+    // This stops the server managed by beforeEach, but DOES NOT clean up the DB file.
+    await stopServerFn(); // Use the globally managed stopServerFn
+
+    // 3. Re-create and start a NEW server instance using the SAME DB path.
+    // This simulates a server restart and should load the persisted data.
+    // We re-initialize `app`, `serverInstance`, `stopServerFn`, `currentPort` from the new createApp call.
+    const { app: newApp, start: newStart, stop: newStop } = createApp(DB_PATH);
+    app = newApp; // Update the global 'app' variable
+    // serverInstance = (app as any)._server; // Capture if needed, but stopServerFn is primary
+    stopServerFn = newStop; // Update the global 'stopServerFn' to the new one
+
+    // Start the new server. Port 0 means it will pick a random available port.
+    currentPort = await newStart(0);
+
+    // 4. Check if the document still exists using the NEW app instance
+    const response = await request(app).get(`/documents/${docId}`);
+    
+    expect(response.status).toBe(200);
+    expect(response.body.id).toBe(docId);
+    expect(response.body.title).toBe('Persistent Doc');
+    expect(response.body.content).toBe('This should survive.');
+
+    // The `afterEach` hook will handle the final cleanup of the DB file.
+  });
+});
diff --git a/tests/websocket.test.ts b/tests/websocket.test.ts
new file mode 100644
index 0000000..606872c
