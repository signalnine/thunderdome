+++ b/tests/websocket.test.ts
@@ -0,0 +1,228 @@
+import WebSocket from 'ws';
+import request from 'supertest';
+import { createApp } from '../src/server'; // Adjust path if needed
+import fs from 'fs';
+import path from 'path';
+
+const DB_PATH = './test_websocket_documents.db';
+
+// Helper to clean up the database file
+const cleanupDb = () => {
+  if (fs.existsSync(DB_PATH)) {
+    fs.unlinkSync(DB_PATH);
+  }
+};
+
+describe('WebSocket Collaboration', () => {
+  let app: express.Express;
+  let server: http.Server;
+  let stopServer: () => Promise<void>;
+  let wsPort: number;
+
+  // Helper to create a WebSocket client connection to a specific document
+  const createWsClient = (docId: string): Promise<WebSocket> => {
+    return new Promise((resolve, reject) => {
+      const ws = new WebSocket(`ws://localhost:${wsPort}/ws/${docId}`); // Assuming path is /ws/:docId
+
+      ws.on('open', () => {
+        resolve(ws);
+      });
+
+      ws.on('error', (error) => {
+        reject(error);
+      });
+    });
+  };
+
+  beforeAll(async () => {
+    cleanupDb();
+    // Use a separate DB for WebSocket tests
+    const { app: createdApp, start, stop: stopFn } = createApp(DB_PATH);
+    app = createdApp;
+    stopServer = stopFn;
+    // Start server on a random port for testing
+    const port = await start(0);
+    wsPort = port;
+  });
+
+  afterAll(async () => {
+    await stopServer();
+    cleanupDb();
+  });
+
+  beforeEach(async () => {
+    // Clean DB and re-create server for each test to ensure isolation
+    cleanupDb();
+    const { app: createdApp, start, stop: stopFn } = createApp(DB_PATH);
+    app = createdApp;
+    stopServer = stopFn; // Update stopServer for this test's scope
+    const port = await start(0);
+    wsPort = port; // Update wsPort for this test's scope
+  });
+
+  afterEach(async () => {
+    await stopServer();
+  });
+
+  it('should sync document state to a new client', async () => {
+    // 1. Create a document via REST API
+    const createResponse = await request(app)
+      .post('/documents')
+      .send({ title: 'Sync Test Doc', content: 'Initial sync content' });
+    const docId = createResponse.body.id;
+    const initialVersion = createResponse.body.current_version;
+
+    // 2. Connect a WebSocket client
+    const wsClient = await createWsClient(docId);
+
+    // 3. Wait for the 'sync' message
+    const syncMessage = await new Promise((resolve) => {
+      wsClient.on('message', (message) => {
+        resolve(JSON.parse(message.toString()));
+      });
+    });
+
+    expect(syncMessage.type).toBe('sync');
+    expect(syncMessage.documentId).toBe(docId);
+    expect(syncMessage.content).toBe('Initial sync content');
+    expect(syncMessage.serverVersion).toBe(initialVersion);
+
+    wsClient.close();
+  });
+
+  it('should broadcast edits to other clients', async () => {
+    // 1. Create a document
+    const createResponse = await request(app)
+      .post('/documents')
+      .send({ title: 'Broadcast Test Doc', content: 'Start' });
+    const docId = createResponse.body.id;
+    const initialVersion = createResponse.body.current_version;
+
+    // 2. Connect two WebSocket clients
+    const wsClientA = await createWsClient(docId);
+    const wsClientB = await createWsClient(docId);
+
+    // Wait for both clients to sync
+    await new Promise(resolve => {
+      let syncedCount = 0;
+      const checkSync = () => {
+        if (++syncedCount === 2) resolve(null);
+      };
+      wsClientA.on('message', (msg) => JSON.parse(msg.toString()).type === 'sync' && checkSync());
+      wsClientB.on('message', (msg) => JSON.parse(msg.toString()).type === 'sync' && checkSync());
+    });
+
+    // 3. Client A sends an edit
+    const editOperation = { type: 'insert', position: 5, text: ' edited' }; // Insert ' edited' at position 5
+    const clientAVersion = initialVersion; // Client A is working from the initial version
+    
+    wsClientA.send(JSON.stringify({
+      type: 'edit',
+      documentId: docId,
+      operation: editOperation,
+      clientVersion: clientAVersion
+    }));
+
+    // 4. Wait for Client B to receive the broadcasted edit
+    const broadcastMessage = await new Promise((resolve) => {
+      wsClientB.on('message', (message) => {
+        resolve(JSON.parse(message.toString()));
+      });
+    });
+
+    expect(broadcastMessage.type).toBe('edit');
+    expect(broadcastMessage.documentId).toBe(docId);
+    // Check if the received operation is the one sent by A (or transformed if OT/CRDT were fully implemented)
+    expect(broadcastMessage.operation).toEqual(expect.objectContaining({
+      type: 'insert',
+      position: 5,
+      text: ' edited'
+    }));
+    // The server version should have been incremented
+    expect(broadcastMessage.serverVersion).toBe(initialVersion + 1);
+
+    wsClientA.close();
+    wsClientB.close();
+  });
+
+  it('should handle ping/pong messages', async () => {
+    const wsClient = await createWsClient('some-doc-id'); // Document ID doesn't matter for ping/pong test
+
+    wsClient.send(JSON.stringify({ type: 'ping' }));
+
+    const pongMessage = await new Promise((resolve) => {
+      wsClient.on('message', (message) => {
+        resolve(JSON.parse(message.toString()));
+      });
+    });
+
+    expect(pongMessage.type).toBe('pong');
+    wsClient.close();
+  });
+
+  it('should return error for malformed messages', async () => {
+    const wsClient = await createWsClient('some-doc-id');
+
+    wsClient.send('this is not JSON'); // Malformed JSON
+
+    const errorMessage = await new Promise((resolve) => {
+      wsClient.on('message', (message) => {
+        resolve(JSON.parse(message.toString()));
+      });
+    });
+
+    expect(errorMessage.type).toBe('error');
+    expect(errorMessage.message).toBe('Malformed message or internal error.');
+    wsClient.close();
+  });
+
+  it('should return error for unknown message types', async () => {
+    const wsClient = await createWsClient('some-doc-id');
+
+    wsClient.send(JSON.stringify({ type: 'unknown_command', data: 'test' })); // Unknown type
+
+    const errorMessage = await new Promise((resolve) => {
+      wsClient.on('message', (message) => {
+        resolve(JSON.parse(message.toString()));
+      });
+    });
+
+    expect(errorMessage.type).toBe('error');
+    expect(errorMessage.message).toBe('Unknown message type.');
+    wsClient.close();
+  });
+  
+  it('should reject connections without a document ID', async () => {
+    const ws = new WebSocket(`ws://localhost:${wsPort}/ws/`); // Missing doc ID
+
+    await new Promise((resolve, reject) => {
+      ws.on('error', (error) => reject(error));
+      ws.on('close', () => resolve(null)); // Expecting a close after error
+    }).catch(e => {
+      // Expected error or close
+    });
+
+    // We can't directly assert on the error message received before close easily here without more complex promise handling.
+    // The server logs the error, and the client should close.
+    // For now, checking that it doesn't crash and the connection doesn't stay open is sufficient.
+  });
+
+  it('should reject connections to non-existent documents', async () => {
+    const ws = await createWsClient('non-existent-doc-id');
+
+    // Expect an error message and close event
+    const closePromise = new Promise((resolve) => {
+      ws.on('message', (message) => {
+        const msg = JSON.parse(message.toString());
+        if (msg.type === 'error' && msg.message === 'Document not found.') {
+          resolve(null); // Received expected error
+        }
+      });
+      ws.on('close', () => resolve(null)); // Should close after error
+    });
+    
+    await closePromise;
+    expect(ws.readyState).toBe(WebSocket.CLOSED);
+  });
+
+});
