e });\n  }\n\n  function removeAssignment(eventId: string): void {\n    const assignment = assignments.get(eventId);\n    if (!assignment) return;\n    const timeline = timelines.get(assignment.roomId)!;\n    timeline.slots = timeline.slots.filter(\n      s => !(s.start === assignment.startTime && s.end === assignment.endTime)\n    );\n    assignments.delete(eventId);\n  }\n\n  // Initial greedy pass\n  for (const eventId of schedulingOrder) {\n    const event = eventMap.get(eventId)!;\n    const assignment = tryScheduleEvent(event);\n    if (assignment) {\n      placeAssignment(assignment);\n    } else {\n      unscheduled.push(eventId);\n    }\n  }\n\n  // Phase 4: Optimization — try swapping to schedule more events\n  // For each unscheduled event, try removing each scheduled event and see if\n  // we can place the unscheduled one (and possibly re-place the removed one elsewhere)\n  let improved = true;\n  while (improved) {\n    improved = false;\n    for (let i = unscheduled.length - 1; i >= 0; i--) {\n      const unschedId = unscheduled[i];\n      const unschedEvent = eventMap.get(unschedId)!;\n\n      // Check if prerequisites for this event are all scheduled\n      const prereqsMet = !unschedEvent.prerequisites ||\n        unschedEvent.prerequisites.every(p => assignments.has(p) || !eventMap.has(p));\n\n      if (!prereqsMet) continue;\n\n      // Skip events with unmet prerequisite (prereq not in event list)\n      if (unschedEvent.prerequisites) {\n        const hasNonexistentPrereq = unschedEvent.prerequisites.some(p => !eventMap.has(p) && !assignments.has(p));\n        if (hasNonexistentPrereq) continue;\n      }\n\n      // First just try scheduling again (timelines may have changed)\n      const directAttempt = tryScheduleEvent(unschedEvent);\n      if (directAttempt) {\n        placeAssignment(directAttempt);\n        unscheduled.splice(i, 1);\n        improved = true;\n        continue;\n      }\n\n      // Try swapping with each scheduled event\n      const scheduledIds = [...assignments.keys()];\n      for (const schedId of scheduledIds) {\n        const schedEvent = eventMap.get(schedId)!;\n\n        // Don't remove events that are prerequisites of other scheduled events\n        // (unless those dependents are also being reconsidered)\n        const hasDependents = [...assignments.keys()].some(id => {\n          const ev = eventMap.get(id)!;\n          return ev.prerequisites?.includes(schedId);\n        });\n\n        removeAssignment(schedId);\n\n        const newAssignment = tryScheduleEvent(unschedEvent);\n        if (newAssignment) {\n          // Can we also re-place the removed event?\n          placeAssignment(newAssignment);\n          const reAssignment = tryScheduleEvent(schedEvent);\n          if (reAssignment) {\n            // Both fit — net gain of 0 but could help cascading\n            placeAssignment(reAssignment);\n            unscheduled.splice(i, 1);\n            improved = true;\n            break;\n          } else if (!hasDependents) {\n            // Only the new event fits, old one doesn't — net 0, but swap if the\n            // unscheduled event was harder to place (more constrained)\n            // Keep it only if it doesn't affect dependents\n            unscheduled.splice(i, 1);\n            unscheduled.push(schedId);\n            improved = true;\n            break;\n          } else {\n            // Revert — removing the scheduled event would break dependents\n            removeAssignment(unschedId);\n            placeAssignment(assignments.get(schedId) ?? {\n              eventId: schedId,\n              roomId: '',\n              startTime: 0,\n              endTime: 0,\n            });\n          }\n        }\n\n        // Revert if we haven't broken out\n        if (!assignments.has(unschedId)) {\n          const origAssignment = tryScheduleEvent(schedEvent);\n          if (origAssignment) {\n            placeAssignment(origAssignment);\n          }\n        } else {\n 