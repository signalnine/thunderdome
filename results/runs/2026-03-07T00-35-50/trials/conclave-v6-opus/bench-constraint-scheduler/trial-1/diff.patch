cheduled.length === 0) break;\n+\n+    // Try removing each scheduled event and see if we gain more by fitting unscheduled ones\n+    const scheduledIds = [...assignments.keys()];\n+    let bestGain = 0;\n+    let bestRemoveId: string | null = null;\n+    let bestNewAssignments: Assignment[] = [];\n+\n+    for (const schedId of scheduledIds) {\n+      // Don't remove events that are prerequisites of other scheduled events\n+      const hasDependents = [...assignments.keys()].some(id => {\n+        if (id === schedId) return false;\n+        const ev = eventMap.get(id)!;\n+        return ev.prerequisites?.includes(schedId) ?? false;\n+      });\n+      if (hasDependents) continue;\n+\n+      const savedAssignment = { ...assignments.get(schedId)! };\n+      removeAssignment(schedId);\n+\n+      // Try to place as many unscheduled events as possible\n+      const placed: Assignment[] = [];\n+      const stillUnscheduled: string[] = [];\n+\n+      for (const unschedId of unscheduled) {\n+        const unschedEvent = eventMap.get(unschedId)!;\n+        const attempt = tryScheduleEvent(unschedEvent);\n+        if (attempt) {\n+          placeAssignment(attempt);\n+          placed.push(attempt);\n+        } else {\n+          stillUnscheduled.push(unschedId);\n+        }\n+      }\n+\n+      // gain = placed - 1 (the one we removed)\n+      const gain = placed.length - 1;\n+      if (gain > bestGain) {\n+        bestGain = gain;\n+        bestRemoveId = schedId;\n+        bestNewAssignments = [...placed];\n+      }\n+\n+      // Revert all placed events\n+      for (const a of placed) {\n+        removeAssignment(a.eventId);\n+      }\n+      // Restore the removed scheduled event\n+      placeAssignment(savedAssignment);\n+    }\n+\n+    if (bestRemoveId && bestGain > 0) {\n+      // Apply the best swap\n+      removeAssignment(bestRemoveId);\n+      for (const a of bestNewAssignments) {\n+        placeAssignment(a);\n+        const idx = unscheduled.indexOf(a.eventId);\