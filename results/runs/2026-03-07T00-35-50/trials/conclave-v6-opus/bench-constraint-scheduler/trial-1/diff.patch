+import { Event, Room, ScheduleOptions, Assignment, ScheduleResult } from './types.js';
+
+function detectCycles(events: Event[]): void {
+  const eventMap = new Map<string, Event>();
+  for (const event of events) {
+    eventMap.set(event.id, event);
+  }
+
+  const WHITE = 0, GRAY = 1, BLACK = 2;
+  const color = new Map<string, number>();
+  for (const event of events) {
+    color.set(event.id, WHITE);
+  }
+
+  function dfs(id: string): void {
+    color.set(id, GRAY);
+    const event = eventMap.get(id);
+    if (event?.prerequisites) {
+      for (const prereqId of event.prerequisites) {
+        if (prereqId === id) {
+          throw new Error(`Cycle detected: event "${id}" has a self-reference`);
+        }
+        const prereqColor = color.get(prereqId);
+        if (prereqColor === GRAY) {
+          throw new Error(`Cycle detected in prerequisites involving "${prereqId}"`);
+        }
+        if (prereqColor === WHITE) {
+          dfs(prereqId);
+        }
+      }
+    }
+    color.set(id, BLACK);
+  }
+
+  for (const event of events) {
+    if (color.get(event.id) === WHITE) {
+      dfs(event.id);
+    }
+  }
+}
+
+function topologicalSort(events: Event[]): string[] {
+  const eventMap = new Map<string, Event>();
+  for (const event of events) {
+    eventMap.set(event.id, event);
+  }
+
+  const visited = new Set<string>();
+  const result: string[] = [];
+
+  function visit(id: string): void {
+    if (visited.has(id)) return;
+    visited.add(id);
+    const event = eventMap.get(id);
+    if (event?.prerequisites) {
+      for (const prereqId of event.prerequisites) {
+        if (eventMap.has(prereqId)) {
+          visit(prereqId);
+        }
+      }
+    }
+    result.push(id);
+  }
+
+  for (const event of events) {
+    visit(event.id);
+  }
+
+  return result;
+}
+
+interface RoomTimeline {
+  roomId: string;
+  capacity: number;
+  slots: Array<{ start: number; end: number }>;
+}
+
+function findEarliestSlot(
+  timeline: RoomTimeline,
+  duration: number,
+  earliestStart: number,
+  endTime: number,
+  gap: number,
+): number | null {
+  if (earliestStart + duration > endTime) return null;
+
+  if (timeline.slots.length === 0) {
+    return earliestStart;
+  }
+
+  const sorted = [...timeline.slots].sort((a, b) => a.start - b.start);
+
+  // Try fitting before the first existing slot
+  if (earliestStart + duration + gap <= sorted[0].start ||
+      (gap === 0 && earliestStart + duration <= sorted[0].start)) {
+    return earliestStart;
+  }
+
+  // Try fitting after each existing slot
+  for (let i = 0; i < sorted.length; i++) {
+    const candidateStart = Math.max(sorted[i].end + gap, earliestStart);
+    const candidateEnd = candidateStart + duration;
+
+    if (candidateEnd > endTime) continue;
+
+    if (i + 1 < sorted.length) {
+      const nextStart = sorted[i + 1].start;
+      if (candidateEnd + gap <= nextStart || (gap === 0 && candidateEnd <= nextStart)) {
+        return candidateStart;
+      }
+    } else {
+      return candidateStart;
+    }
+  }
+
+  return null;
+}
+
+export function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {
+  const gap = options.gap ?? 15;
+
+  // Phase 1: Detect cycles
+  detectCycles(events);
+
+  if (events.length === 0) {
+    return { assignments: [], unscheduled: [] };
+  }
+
+  const eventMap = new Map<string, Event>();
+  for (const event of events) {
+    eventMap.set(event.id, event);
+  }
+
+  // Phase 2: Topological sort
+  const sortedIds = topologicalSort(events);
+
+  // Score events by "constrainedness" for scheduling order within same topo level
+  function getEligibleRoomCount(event: Event): number {
+    const attendees = event.attendees ?? 1;
+    return rooms.filter(r => r.capacity >= attendees).length;
+  }
+
+  // Build topo levels
+  const topoOrder = new Map<string, number>();
+  sortedIds.forEach((id, idx) => topoOrder.set(id, idx));
+
+  // Sort by: topo order first, then most constrained (fewest rooms), then shortest duration
+  // Shortest duration first helps maximize the number of events that can be scheduled.
+  const schedulingOrder = [...sortedIds].sort((a, b) => {
+    const topoA = topoOrder.get(a)!;
+    const topoB = topoOrder.get(b)!;
+    if (topoA !== topoB) return topoA - topoB;
+
+    const eventA = eventMap.get(a)!;
+    const eventB = eventMap.get(b)!;
+    const roomsA = getEligibleRoomCount(eventA);
+    const roomsB = getEligibleRoomCount(eventB);
+    if (roomsA !== roomsB) return roomsA - roomsB;
+    return eventA.duration - eventB.duration;
+  });
+
+  // Phase 3: Greedy assignment
+  const timelines = new Map<string, RoomTimeline>();
+  for (const room of rooms) {
+    timelines.set(room.id, { roomId: room.id, capacity: room.capacity, slots: [] });
+  }
+
+  const assignments = new Map<string, Assignment>();
+  const unscheduled: string[] = [];
+
+  function getEarliestPrereqEnd(event: Event): number | null {
+    if (!event.prerequisites || event.prerequisites.length === 0) {
+      return options.startTime;
+    }
+    let maxEnd = options.startTime;
+    for (const prereqId of event.prerequisites) {
+      const prereqAssignment = assignments.get(prereqId);
+      if (!prereqAssignment) {
+        // Prerequisite not scheduled (or doesn't exist) — this event can't be scheduled
+        return null;
+      }
+      maxEnd = Math.max(maxEnd, prereqAssignment.endTime + gap);
+    }
+    return maxEnd;
+  }
+
+  function tryScheduleEvent(event: Event): Assignment | null {
+    const attendees = event.attendees ?? 1;
+    const earliestStart = getEarliestPrereqEnd(event);
+    if (earliestStart === null) return null;
+
+    // Get eligible rooms sorted: preferred first, then by capacity (smallest first)
+    const eligibleRooms = rooms
+      .filter(r => r.capacity >= attendees)
+      .sort((a, b) => {
+        if (event.preferredRoom) {
+          if (a.id === event.preferredRoom && b.id !== event.preferredRoom) return -1;
+          if (b.id === event.preferredRoom && a.id !== event.preferredRoom) return 1;
+        }
+        return a.capacity - b.capacity;
+      });
+
+    let bestAssignment: Assignment | null = null;
+    let bestStart = Infinity;
+
+    for (const room of eligibleRooms) {
+      const timeline = timelines.get(room.id)!;
+      const startSlot = findEarliestSlot(timeline, event.duration, earliestStart, options.endTime, gap);
+      if (startSlot !== null && startSlot < bestStart) {
+        bestAssignment = {
+          eventId: event.id,
+          roomId: room.id,
+          startTime: startSlot,
+          endTime: startSlot + event.duration,
+        };
+        bestStart = startSlot;
+        // If we found a slot starting at the earliest possible time in the preferred room, stop
+        if (startSlot === earliestStart && room.id === event.preferredRoom) break;
+      }
+    }
+
+    return bestAssignment;
+  }
+
+  function placeAssignment(assignment: Assignment): void {
+    assignments.set(assignment.eventId, assignment);
+    const timeline = timelines.get(assignment.roomId)!;
+    timeline.slots.push({ start: assignment.startTime, end: assignment.endTime });
+  }
+
+  function removeAssignment(eventId: string): void {
+    const assignment = assignments.get(eventId);
+    if (!assignment) return;
+    const timeline = timelines.get(assignment.roomId)!;
+    timeline.slots = timeline.slots.filter(
+      s => !(s.start === assignment.startTime && s.end === assignment.endTime)
+    );
+    assignments.delete(eventId);
+  }
+
+  // Initial greedy pass
+  for (const eventId of schedulingOrder) {
+    const event = eventMap.get(eventId)!;
+    const assignment = tryScheduleEvent(event);
+    if (assignment) {
+      placeAssignment(assignment);
+    } else {
+      unscheduled.push(eventId);
+    }
+  }
+
+  // Phase 4: Optimization — try removing each scheduled event to see if
+  // removing it allows scheduling more unscheduled events (net gain > 0).
+  const maxPasses = events.length;
+  for (let pass = 0; pass < maxPasses && unscheduled.length > 0; pass++) {
+    let madeProgress = false;
+
+    // First, try direct placement for any unscheduled events
+    for (let i = unscheduled.length - 1; i >= 0; i--) {
+      const unschedEvent = eventMap.get(unscheduled[i])!;
+      const directAttempt = tryScheduleEvent(unschedEvent);
+      if (directAttempt) {
+        placeAssignment(directAttempt);
+        unscheduled.splice(i, 1);
+        madeProgress = true;
+      }
+    }
+
+    if (madeProgress) continue;
+    if (unscheduled.length === 0) break;
+
+    // Try removing each scheduled event and see if we gain more by fitting unscheduled ones
+    const scheduledIds = [...assignments.keys()];
+    let bestGain = 0;
+    let bestRemoveId: string | null = null;
+    let bestNewAssignments: Assignment[] = [];
+
+    for (const schedId of scheduledIds) {
+      // Don't remove events that are prerequisites of other scheduled events
+      const hasDependents = [...assignments.keys()].some(id => {
+        if (id === schedId) return false;
+        const ev = eventMap.get(id)!;
+        return ev.prerequisites?.includes(schedId) ?? false;
+      });
+      if (hasDependents) continue;
+
+      const savedAssignment = { ...assignments.get(schedId)! };
+      removeAssignment(schedId);
+
+      // Try to place as many unscheduled events as possible
+      const placed: Assignment[] = [];
+      const stillUnscheduled: string[] = [];
+
+      for (const unschedId of unscheduled) {
+        const unschedEvent = eventMap.get(unschedId)!;
+        const attempt = tryScheduleEvent(unschedEvent);
+        if (attempt) {
+          placeAssignment(attempt);
+          placed.push(attempt);
+        } else {
+          stillUnscheduled.push(unschedId);
+        }
+      }
+
+      // gain = placed - 1 (the one we removed)
+      const gain = placed.length - 1;
+      if (gain > bestGain) {
+        bestGain = gain;
+        bestRemoveId = schedId;
+        bestNewAssignments = [...placed];
+      }
+
+      // Revert all placed events
+      for (const a of placed) {
+        removeAssignment(a.eventId);
+      }
+      // Restore the removed scheduled event
+      placeAssignment(savedAssignment);
+    }
+
+    if (bestRemoveId && bestGain > 0) {
+      // Apply the best swap
+      removeAssignment(bestRemoveId);
+      for (const a of bestNewAssignments) {
+        placeAssignment(a);
+        const idx = unscheduled.indexOf(a.eventId);
+        if (idx >= 0) unscheduled.splice(idx, 1);
+      }
+      unscheduled.push(bestRemoveId);
+      madeProgress = true;
+    }
+
+    if (!madeProgress) break;
+  }
+
+  return {
+    assignments: [...assignments.values()],
+    unscheduled,
+  };
+}
