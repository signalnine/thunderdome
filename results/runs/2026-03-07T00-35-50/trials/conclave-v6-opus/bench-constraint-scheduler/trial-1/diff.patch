t.push(id);\n  }\n\n  for (const event of events) {\n    visit(event.id);\n  }\n\n  return result;\n}\n\ninterface RoomTimeline {\n  roomId: string;\n  capacity: number;\n  slots: Array<{ start: number; end: number }>;\n}\n\nfunction findEarliestSlot(\n  timeline: RoomTimeline,\n  duration: number,\n  earliestStart: number,\n  endTime: number,\n  gap: number,\n): number | null {\n  const desiredStart = earliestStart;\n  const desiredEnd = desiredStart + duration;\n\n  if (desiredEnd > endTime) return null;\n\n  if (timeline.slots.length === 0) {\n    return desiredStart;\n  }\n\n  // Sort slots by start time\n  const sorted = [...timeline.slots].sort((a, b) => a.start - b.start);\n\n  // Try fitting before all existing slots\n  if (desiredEnd + gap <= sorted[0].start || desiredEnd <= sorted[0].start && gap === 0) {\n    const gapOk = sorted[0].start - desiredEnd >= gap;\n    if (desiredStart >= earliestStart && gapOk) {\n      return desiredStart;\n    }\n  }\n\n  // Try fitting in gaps between existing slots\n  for (let i = 0; i < sorted.length; i++) {\n    const slotEnd = sorted[i].end;\n    const candidateStart = Math.max(slotEnd + gap, earliestStart);\n    const candidateEnd = candidateStart + duration;\n\n    if (candidateEnd > endTime) continue;\n\n    if (i + 1 < sorted.length) {\n      const nextStart = sorted[i + 1].start;\n      if (candidateEnd + gap <= nextStart || (candidateEnd <= nextStart && gap === 0)) {\n        return candidateStart;\n      }\n    } else {\n      // Last slot — fit after it\n      return candidateStart;\n    }\n  }\n\n  // Try before first slot if earliestStart allows\n  {\n    const candidateStart = earliestStart;\n    const candidateEnd = candidateStart + duration;\n    if (candidateEnd <= endTime) {\n      const firstSlot = sorted[0];\n      if (candidateEnd + gap <= firstSlot.start || (gap === 0 && candidateEnd <= firstSlot.start)) {\n        return candidateStart;\n      }\n    }\n  }\n\n  return null;\n}\n\nexport function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {\n  const gap = options.gap ?? 15;\n\n  // Phase 1: Detect cycles\n  detectCycles(events);\n\n  if (events.length === 0) {\n    return { assignments: [], unscheduled: [] };\n  }\n\n  const eventMap = new Map<string, Event>();\n  for (const event of events) {\n    eventMap.set(event.id, event);\n  }\n\n  // Phase 2: Topological sort\n  const sortedIds = topologicalSort(events);\n\n  // Score events by \"constrainedness\" for scheduling order within same topo level\n  function getEligibleRoomCount(event: Event): number {\n    const attendees = event.attendees ?? 1;\n    return rooms.filter(r => r.capacity >= attendees).length;\n  }\n\n  // Build topo levels\n  const topoOrder = new Map<string, number>();\n  sortedIds.forEach((id, idx) => topoOrder.set(id, idx));\n\n  // Sort by: topo order first, then most constrained (fewest rooms, longest duration)\n  const schedulingOrder = [...sortedIds].sort((a, b) => {\n    const topoA = topoOrder.get(a)!;\n    const topoB = topoOrder.get(b)!;\n    if (topoA !== topoB) return topoA - topoB;\n\n    const eventA = eventMap.get(a)!;\n    const eventB = eventMap.get(b)!;\n    const roomsA = getEligibleRoomCount(eventA);\n    const roomsB = getEligibleRoomCount(eventB);\n    if (roomsA !== roomsB) return roomsA - roomsB;\n    return eventB.duration - eventA.duration;\n  });\n\n  // Phase 3: Greedy assignment\n  const timelines = new Map<string, RoomTimeline>();\n  for (const room of rooms) {\n    timelines.set(room.id, { roomId: room.id, capacity: room.capacity, slots: [] });\n  }\n\n  const assignments = new Map<string, Assignment>();\n  const unscheduled: string[] = [];\n\n  function getEarliestPrereqEnd(event: Event): number | null {\n    if (!event.prerequisites || event.prerequisites.length === 0) {\n      return options.startTime;\n    }\n    let maxEnd = options.startTime;\n    for (const prereqId of event.prerequisites) {\n      const prereqAssi