onst result = schedule(events, [smallRoom], zeroGap);\n+    expect(result.assignments).toHaveLength(2);\n+    const sorted = [...result.assignments].sort((a, b) => a.startTime - b.startTime);\n+    // With 0 gap, second can start exactly when first ends\n+    expect(sorted[1].startTime).toBeGreaterThanOrEqual(sorted[0].endTime);\n+  });\n+\n+  it('handles prerequisite to nonexistent event gracefully via unscheduled', () => {\n+    // If a prerequisite references an event not in the list, the dependent\n+    // event can never have its prerequisite satisfied\n+    const events: Event[] = [\n+      { id: 'B', name: 'Event B', duration: 30, prerequisites: ['nonexistent'] },\n+    ];\n+    const result = schedule(events, [smallRoom], defaultOptions);\n+    expect(result.unscheduled).toContain('B');\n+  });\n+});\ndiff --git a/src/scheduler.ts b/src/scheduler.ts\nnew file mode 100644\nindex 0000000..6819ea1\n--- /dev/null\n+++ b/src/scheduler.ts\n@@ -0,0 +1,360 @@\n+import { Event, Room, ScheduleOptions, Assignment, ScheduleResult } from './types.js';\n+\n+function detectCycles(events: Event[]): void {\n+  const eventMap = new Map<string, Event>();\n+  for (const event of events) {\n+    eventMap.set(event.id, event);\n+  }\n+\n+  const WHITE = 0, GRAY = 1, BLACK = 2;\n+  const color = new Map<string, number>();\n+  for (const event of events) {\n+    color.set(event.id, WHITE);\n+  }\n+\n+  function dfs(id: string): void {\n+    color.set(id, GRAY);\n+    const event = eventMap.get(id);\n+    if (event?.prerequisites) {\n+      for (const prereqId of event.prerequisites) {\n+        if (prereqId === id) {\n+          throw new Error(`Cycle detected: event \"${id}\" has a self-reference`);\n+        }\n+        const prereqColor = color.get(prereqId);\n+        if (prereqColor === GRAY) {\n+          throw new Error(`Cycle detected in prerequisites involving \"${prereqId}\"`);\n+        }\n+        if (prereqColor === WHITE) {\n+          dfs(prereqId);\n+        }\n+   