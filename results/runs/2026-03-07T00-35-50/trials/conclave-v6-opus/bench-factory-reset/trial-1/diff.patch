o 97, p^20 is way too large.\n  // MITM doesn't help directly because p^(n/2) is still enormous.\n\n  // Alternative: greedy/optimization approach\n  // For each free variable, try all p values, pick the one that minimizes total\n  // This is O(numFree * p * rank) which is very fast\n  // It's greedy and won't always find the global optimum, but for practical test cases it should work\n\n  // Actually, let's think about this more carefully.\n  // The total sum as a function of free variables:\n  // total = sum_{pivot i} (base[i] - sum_k(coeff[i][k] * free[k]) mod p) + sum_k free[k]\n  // Each pivot variable's value is (base[i] - sum_k coeff[i][k] * free[k]) mod p,\n  // which is in [0, p-1].\n  // The total is a sum of terms each in [0, p-1].\n\n  // This is a non-linear integer optimization (due to the mod operation).\n  // For large free var counts, we can use dynamic programming on halves.\n\n  // DP approach: process free variables one at a time.\n  // State: for each pivot variable, track its current accumulated \"offset\" mod p.\n  // With rank up to 40 pivot variables, the state space is p^40 which is too large.\n\n  // Let's just limit: if p^numFree <= some threshold, enumerate. Otherwise, use greedy.\n  // The greedy approach: set each free variable one at a time, choosing the value\n  // that minimizes the total sum given previously chosen values.\n\n  return solveCounterGreedy(matrix, pivotCol, freeVars, numButtons, rank, modulus);\n}","newString":"/**\n * For large free variable spaces in GF(p), optimize each free variable\n * independently by trying all p values and picking the one that minimizes\n * the total sum of presses.\n */\nfunction solveCounterLarge(\n  matrix: number[][],\n  pivotCol: number[],\n  freeVars: number[],\n  numButtons: number,\n  rank: number,\n  modulus: number\n): number[] | null {\n  return solveCounterGreedy(matrix, pivotCol, freeVars, numButtons, rank, modulus);\n}","originalFile":"export interface Machine {\n  target: boolean[];\n  buttons: number[][];\n}\n\n/**\n * Gaussian elimination over GF(2).\n * Solves A * x = b where A is lights x buttons, x is button presses (0 or 1).\n *\n * Returns the solution with fewest presses, breaking ties lexicographically.\n * Returns null if no solution exists.\n */\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const numLights = target.length;\n  const numButtons = buttons.length;\n\n  // Build augmented matrix [A | b] over GF(2)\n  // Rows = lights, Columns = buttons + 1 (augmented)\n  // A[light][button] = 1 if button toggles that light\n  const matrix: number[][] = [];\n  for (let i = 0; i < numLights; i++) {\n    const row = new Array(numButtons + 1).fill(0);\n    row[numButtons] = target[i] ? 1 : 0;\n    matrix.push(row);\n  }\n  for (let j = 0; j < numButtons; j++) {\n    for (const light of buttons[j]) {\n      if (light < numLights) {\n        matrix[light][j] = 1;\n      }\n    }\n  }\n\n  // Gaussian elimination over GF(2)\n  const pivotCol: number[] = []; // pivotCol[i] = column index of pivot in row i\n  const pivotRow = new Array(numButtons).fill(-1); // pivotRow[col] = row where this col is pivot\n  let row = 0;\n  for (let col = 0; col < numButtons && row < numLights; col++) {\n    // Find pivot row\n    let pivotR = -1;\n    for (let r = row; r < numLights; r++) {\n      if (matrix[r][col] === 1) {\n        pivotR = r;\n        break;\n      }\n    }\n    if (pivotR === -1) continue; // Free variable\n\n    // Swap rows\n    [matrix[row], matrix[pivotR]] = [matrix[pivotR], matrix[row]];\n\n    // Eliminate all other rows\n    for (let r = 0; r < numLights; r++) {\n      if (r !== row && matrix[r][col] === 1) {\n        for (let c = 0; c <= numButtons; c++) {\n          matrix[r][c] ^= matrix[row][c];\n        }\n      }\n    }\n\n    pivotCol.push(col);\n    pivotRow[col] = row;\n    row++;\n  }\n\n  const rank = pivotCol.length;\n\n  // Check consistency: any row with al