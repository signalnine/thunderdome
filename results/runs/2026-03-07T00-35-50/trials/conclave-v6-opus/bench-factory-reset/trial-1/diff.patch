380→  return solution;\n   381→}\n   382→\n   383→function popcount(n: number): number {\n   384→  let count = 0;\n   385→  while (n) {\n   386→    count += n & 1;\n   387→    n >>>= 1;\n   388→  }\n   389→  return count;\n   390→}\n   391→\n   392→/**\n   393→ * Gaussian elimination over GF(p) where p is prime.\n   394→ * Solves A * x = b where A is counters x buttons, x[i] is how many times button i is pressed.\n   395→ *\n   396→ * Returns the solution with minimum total presses, breaking ties lexicographically.\n   397→ * Returns null if no solution exists.\n   398→ */\n   399→export function solveCounter(\n   400→  lights: number[],\n   401→  buttons: number[][],\n   402→  modulus: number\n   403→): number[] | null {\n   404→  const numCounters = lights.length;\n   405→  const numButtons = buttons.length;\n   406→\n   407→  // Build augmented matrix [A | b] over GF(p)\n   408→  const matrix: number[][] = [];\n   409→  for (let i = 0; i < numCounters; i++) {\n   410→    const row = new Array(numButtons + 1).fill(0);\n   411→    row[numButtons] = lights[i] % modulus;\n   412→    matrix.push(row);\n   413→  }\n   414→  for (let j = 0; j < numButtons; j++) {\n   415→    for (const counter of buttons[j]) {\n   416→      if (counter < numCounters) {\n   417→        matrix[counter][j] = (matrix[counter][j] + 1) % modulus;\n   418→      }\n   419→    }\n   420→  }\n   421→\n   422→  // Gaussian elimination over GF(p)\n   423→  const pivotCol: number[] = [];\n   424→  let row = 0;\n   425→\n   426→  for (let col = 0; col < numButtons && row < numCounters; col++) {\n   427→    // Find pivot row (non-zero entry)\n   428→    let pivotR = -1;\n   429→    for (let r = row; r < numCounters; r++) {\n   430→      if (matrix[r][col] !== 0) {\n   431→        pivotR = r;\n   432→        break;\n   433→      }\n   434→    }\n   435→    if (pivotR === -1) continue;\n   436→\n   437→    // Swap rows\n   438→    [matrix[row], matrix[pivotR]] = [matrix[pivotR], matrix[row]];\n   439→\n   440→    // Normalize pivot row: multiply by inverse of pivot element\n   441→    const pivotVal = matrix[row][col];\n   442→    const inv = modInverse(pivotVal, modulus);\n   443→    for (let c = 0; c <= numButtons; c++) {\n   444→      matrix[row][c] = (matrix[row][c] * inv) % modulus;\n   445→    }\n   446→\n   447→    // Eliminate all other rows\n   448→    for (let r = 0; r < numCounters; r++) {\n   449→      if (r !== row && matrix[r][col] !== 0) {\n   450→        const factor = matrix[r][col];\n   451→        for (let c = 0; c <= numButtons; c++) {\n   452→          matrix[r][c] = ((matrix[r][c] - factor * matrix[row][c]) % modulus + modulus) % modulus;\n   453→        }\n   454→      }\n   455→    }\n   456→\n   457→    pivotCol.push(col);\n   458→    row++;\n   459→  }\n   460→\n   461→  const rank = pivotCol.length;\n   462→\n   463→  // Check consistency\n   464→  for (let r = rank; r < numCounters; r++) {\n   465→    if (matrix[r][numButtons] !== 0) {\n   466→      return null;\n   467→    }\n   468→  }\n   469→\n   470→  // Identify free variables\n   471→  const pivotSet = new Set(pivotCol);\n   472→  const freeVars: number[] = [];\n   473→  for (let col = 0; col < numButtons; col++) {\n   474→    if (!pivotSet.has(col)) {\n   475→      freeVars.push(col);\n   476→    }\n   477→  }\n   478→\n   479→  const numFree = freeVars.length;\n   480→\n   481→  // For each pivot variable i (at pivotCol[i]), it equals:\n   482→  // matrix[i][numButtons] - sum(matrix[i][freeVars[k]] * freeVars[k]) mod p\n   483→  // We need to find free var assignments minimizing total presses.\n   484→\n   485→  // If numFree is small enough, enumerate directly\n   486→  // p^numFree combinations\n   487→  const totalCombinations = Math.pow(modulus, numFree);\n   488→\n   489→  if (numFree === 0) {\n   490→    // Unique solution\n   491→    const solution = new Array(numButtons).fill(0);\n   492→    for (let i = 0; i < rank; i++) {\n   493→      solution[pivotCol[i]] = matrix[i][numButtons];\n   494→    }\n   495→    return solution;\n   496→  }\n   497→\n   498→  // If too many combinations, use optimized approach\n   499→  if (totalCombinations > 5_000_000) {\n   500→    return solveCounterLarge(matrix, pivotCol, freeVars, numButtons, rank, modulus);\n   501→  }\n   502→\n   503→  let bestSolution: number[] | null = null;\n   504→  let bestSum = numButtons * modulus + 1;\n   505→\n   506→  // Enumerate free variable assignments\n   507→  const freeAssign = new Array(numFree).fill(0);\n   508→\n   509→  for (let iter = 0; iter < totalCombinations; iter++) {\n   510→    const solution = new Array(numButtons).fill(0);\n   511→\n   512→    // Set free variables\n   513→    for (let k = 0; k < numFree; k++) {\n   514→      solution[freeVars[k]] = freeAssign[k];\n   515→    }\n   516→\n   517→    // Compute pivot variables\n   518→    for (let i = 0; i < rank; i++) {\n   519→      const pc = pivotCol[i];\n   520→      let val = matrix[i][numButtons];\n   521→      for (let k = 0; k < numFree; k++) {\n   522→        val = ((val - matrix[i][freeVars[k]] * freeAssign[k]) % modulus + modulus) % modulus;\n   523→      }\n   524→      solution[pc] = val;\n   525→    }\n   526→\n   527→    // Compute total presses\n   528→    let sum = 0;\n   529→    for (let j = 0; j < numButtons; j++) {\n   530→      sum += solution[j];\n   531→    }\n   532→\n   533→    if (sum < bestSum || (sum === bestSum && bestSolution !== null && lexSmallerArr(solution, bestSolution, numButtons))) {\n   534→      bestSum = sum;\n   535→      bestSolution = solution.slice();\n   536→    }\n   537→\n   538→    // Increment freeAssign (mixed-radix counter)\n   539→    let carry = true;\n   540→    for (let k = numFree - 1; k >= 0 && carry; k--) {\n   541→      freeAssign[k]++;\n   542→      if (freeAssign[k] >= modulus) {\n   543→        freeAssign[k] = 0;\n   544→      } else {\n   545→        carry = false;\n   546→      }\n   547→    }\n   548→  }\n   549→\n   550→  return b