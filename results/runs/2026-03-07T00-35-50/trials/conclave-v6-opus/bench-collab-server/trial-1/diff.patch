 + op.content + doc.slice(op.position);\n  }\n\n  // delete\n  if (op.position + op.length > doc.length) {\n    throw new Error(`Delete range [${op.position}, ${op.position + op.length}) exceeds document length ${doc.length}`);\n  }\n  return doc.slice(0, op.position) + doc.slice(op.position + op.length);\n}\n\nexport function transformOperation(op: Operation, against: Operation): Operation {\n  if (op.type === 'insert' && against.type === 'insert') {\n    return transformInsertInsert(op, against);\n  }\n  if (op.type === 'insert' && against.type === 'delete') {\n    return transformInsertDelete(op, against);\n  }\n  if (op.type === 'delete' && against.type === 'insert') {\n    return transformDeleteInsert(op, against);\n  }\n  // delete vs delete\n  return transformDeleteDelete(\n    op as { type: 'delete'; position: number; length: number },\n    against as { type: 'delete'; position: number; length: number }\n  );\n}\n\nfunction transformInsertInsert(\n  op: { type: 'insert'; position: number; content: string },\n  against: { type: 'insert'; position: number; content: string }\n): Operation {\n  if (op.position > against.position || (op.position === against.position)) {\n    // Shift right by the length of the already-applied insert\n    return { type: 'insert', position: op.position + against.content.length, content: op.content };\n  }\n  return { ...op };\n}\n\nfunction transformInsertDelete(\n  op: { type: 'insert'; position: number; content: string },\n  against: { type: 'delete'; position: number; length: number }\n): Operation {\n  if (op.position <= against.position) {\n    // Insert is before or at the delete start — no change\n    return { ...op };\n  }\n  if (op.position >= against.position + against.length) {\n    // Insert is after the delete range — shift left\n    return { type: 'insert', position: op.position - against.length, content: op.content };\n  }\n  // Insert is within the deleted range — place at delete position\n  return { type: 'insert', position: against.position, content: op.content };\n}\n\nfunction transformDeleteInsert(\n  op: { type: 'delete'; position: number; length: number },\n  against: { type: 'insert'; position: number; content: string }\n): Operation {\n  const opEnd = op.position + op.length;\n\n  if (against.position >= opEnd) {\n    // Insert is after the delete range — no change\n    return { ...op };\n  }\n  if (against.position <= op.position) {\n    // Insert is before or at the delete start — shift right\n    return { type: 'delete', position: op.position + against.content.length, length: op.length };\n  }\n  // Insert is inside the delete range — expand the delete to cover inserted text too\n  return { type: 'delete', position: op.position, length: op.length + against.content.length };\n}\n\nfunction transformDeleteDelete(\n  op: { type: 'delete'; position: number; length: number },\n  against: { type: 'delete'; position: number; length: number }\n): Operation {\n  const opStart = op.position;\n  const opEnd = op.position + op.length;\n  const agStart = against.position;\n  const agEnd = against.position + against.length;\n\n  if (opEnd <= agStart) {\n    // op is entirely before against — no change\n    return { ...op };\n  }\n  if (opStart >= agEnd) {\n    // op is entirely after against — shift left\n    return { type: 'delete', position: op.position - against.length, length: op.length };\n  }\n\n  // Overlapping ranges\n  // Calculate the parts of op that are NOT covered by against\n  const beforeOverlap = Math.max(0, agStart - opStart);\n  const afterOverlap = Math.max(0, opEnd - agEnd);\n  const newLength = beforeOverlap + afterOverlap;\n  const newPosition = Math.min(opStart, agStart);\n\n  return { type: 'delete', position: newPosition, length: newLength };\n}\n"}}
