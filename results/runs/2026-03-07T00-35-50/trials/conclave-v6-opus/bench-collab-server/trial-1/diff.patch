thout title', async () => {\n    const res = await request('/documents', {\n      method: 'POST',\n      body: JSON.stringify({}),\n    });\n    expect(res.status).toBe(400);\n  });\n\n  it('lists all documents', async () => {\n    await request('/documents', { method: 'POST', body: JSON.stringify({ title: 'A' }) });\n    await request('/documents', { method: 'POST', body: JSON.stringify({ title: 'B' }) });\n    const res = await request('/documents');\n    expect(res.status).toBe(200);\n    const docs = await res.json();\n    expect(docs).toHaveLength(2);\n  });\n\n  it('gets a document by id', async () => {\n    const createRes = await request('/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Get Me', content: 'content' }),\n    });\n    const created = await createRes.json();\n    const res = await request(`/documents/${created.id}`);\n    expect(res.status).toBe(200);\n    const doc = await res.json();\n    expect(doc.title).toBe('Get Me');\n    expect(doc.content).toBe('content');\n  });\n\n  it('returns 404 for non-existent document', async () => {\n    const res = await request('/documents/nonexistent');\n    expect(res.status).toBe(404);\n  });\n\n  it('updates a document', async () => {\n    const createRes = await request('/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Old', content: 'old' }),\n    });\n    const created = await createRes.json();\n    const res = await request(`/documents/${created.id}`, {\n      method: 'PUT',\n      body: JSON.stringify({ title: 'New', content: 'new' }),\n    });\n    expect(res.status).toBe(200);\n    const doc = await res.json();\n    expect(doc.title).toBe('New');\n    expect(doc.content).toBe('new');\n  });\n\n  it('deletes a document', async () => {\n    const createRes = await request('/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Delete Me' }),\n    });\n    const created = await createRes.json();\n    const res = await request(`/documents/${created.id}`, { method: 'DELETE' });\n    expect(res.status).toBe(204);\n    const getRes = await request(`/documents/${created.id}`);\n    expect(getRes.status).toBe(404);\n  });\n\n  it('returns 404 when deleting non-existent document', async () => {\n    const res = await request('/documents/nonexistent', { method: 'DELETE' });\n    expect(res.status).toBe(404);\n  });\n});\n\ndescribe('REST API - Version History', () => {\n  it('returns version history for a document', async () => {\n    const createRes = await request('/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Versioned', content: 'v0' }),\n    });\n    const doc = await createRes.json();\n    const res = await request(`/documents/${doc.id}/versions`);\n    expect(res.status).toBe(200);\n    const versions = await res.json();\n    // Should have initial version (version 0)\n    expect(versions.length).toBeGreaterThanOrEqual(1);\n    expect(versions[0].version).toBe(0);\n    expect(versions[0].content).toBe('v0');\n  });\n\n  it('returns 404 for versions of non-existent document', async () => {\n    const res = await request('/documents/nonexistent/versions');\n    expect(res.status).toBe(404);\n  });\n});\n\n// ---- WebSocket Tests ----\n\nfunction connectWs(docId: string): Promise<WebSocket> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/documents/${docId}/ws`);\n    ws.on('open', () => resolve(ws));\n    ws.on('error', reject);\n  });\n}\n\nfunction waitForMessage(ws: WebSocket): Promise<Record<string, unknown>> {\n  return new Promise((resolve) => {\n    ws.once('message', (data) => {\n      resolve(JSON.parse(data.toString()));\n    });\n  });\n}\n\ndescribe('WebSocket - Connection', () => {\n  it('sends sync message on connect with current document state', async () => {\n    const createRes = await request('/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'WS Test', content: 'initial content' }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(doc.id);\n    const msg = await waitForMessage(ws);\n\n    expect(msg.type).toBe('sync');\n    expect(msg.content).toBe('initial content');\n    expect(msg.version).toBe(0);\n\n    ws.close();\n  });\n\n  it('rejects connection to non-existent document', async () => {\n    const ws = new WebSocket(`ws://localhost:${port}/documents/nonexistent/ws`);\n    const closePromise = new Promise<number>((resolve) => {\n      ws.on('close', (code) => resolve(code));\n    });\n    const code = await closePromise;\n    // Should close with an error code\n    expect(code).toBeGreaterThanOrEqual(4000);\n  });\n});\n\ndescribe('WebSocket - Operations', () => {\n  it('broadcasts insert operation to other clients', async () => {\n    const createRes = await request('/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Collab Test', content: 'hello' }),\n    });\n    const doc = await createRes.json();\n\n    const ws1 = await connectWs(doc.id);\n    const sync1 = await waitForMessage(ws1);\n    expect(sync1.type).toBe('sync');\n\n    const ws2 = await connectWs(doc.id);\n    const sync2 = await waitForMessage(ws2);\n    expect(sync2.type).toBe('sync');\n\n    // ws1 sends an operation\n    const opMsg = {\n      type: 'operation',\n      operation: { type: 'insert', position: 5, content: ' world' },\n      version: 0,\n    };\n    const ws2MsgPromise = waitForMessage(ws2);\n    ws1.send(JSON.stringify(opMsg));\n\n    // ws1 should get ack\n    const ack = await waitForMessage(ws1);\n    expect(ack.type).toBe('ack');\n    expect(ack.version).toBe(1);\n\n    // ws2 should receive broadcast\n    const broadcast = await ws2MsgPromise;\n    expect(broadcast.type).toBe('operation');\n    expect((broadcast.operation as Record<string, unknown>).type).toBe('insert');\n\n    // verify via REST\n    const getRes = await request(`/documents/${doc.id}`);\n    const updatedDoc = await getRes.json();\n    expect(updatedDoc.content).toBe('hello world');\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('broadcasts delete operation to other clients', async () => {\n    const createRes = await request('/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Delete Test', content: 'hello world' }),\n    });\n    const doc = await createRes.json();\n\n    const ws1 = await connectWs(doc.id);\n    await waitForMessage(ws1); // sync\n\n    const ws2 = await connectWs(doc.id);\n    await waitForMessage(ws2); // sync\n\n    const opMsg = {\n      type: 'operation',\n      operation: { type: 'delete', position: 5, length: 6 },\n      version: 0,\n    };\n    const ws2MsgPromise = waitForMessage(ws2);\n    ws1.send(JSON.stringify(opMsg));\n\n    await waitForMessage(ws1); // ack\n    const broadcast = await ws2MsgPromise;\n    expect(broadcast.type).toBe('operation');\n\n    const getRes = await request(`/documents/${doc.id}`);\n    const updatedDoc = await getRes.json();\n    expect(updatedDoc.content).toBe('hello');\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('rejects invalid operation', async () => {\n    const createRes = await request('/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Invalid Op', content: 'hello' }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(doc.id);\n    await waitForMessage(ws); // sync\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: { type: 'insert', position: 100, content: 'x' },\n      version: 0,\n    }));\n\n    const msg = await waitForMessage(ws);\n    expect(msg.type).toBe('error');\n\n    ws.close();\n  });\n\n  it('rejects malformed messages', async () => {\n    const createRes = await request('/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Bad Msg', content: '' }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(doc.id);\n    await waitForMessage(ws); // sync\n\n    ws.send('not json');\n    const msg = await waitForMessage(ws);\n    expect(msg.type).toBe('error');\n\n    ws.close();\n  });\n\n  it('handles multiple sequential operations', async () => {\n    const createRes = await request('/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Sequential', content: '' }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(doc.id);\n    await waitForMessage(ws); // sync\n\n    // Insert 'hello'\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: { type: 'insert', position: 0, content: 'hello' },\n      version: 0,\n    }));\n    const ack1 = await waitForMessage(ws);\n    expect(ack1.type).toBe('ack');\n    expect(ack1.version).toBe(1);\n\n    // Insert ' world'\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: { type: 'insert', position: 5, content: ' world' },\n      version: 1,\n    }));\n    const ack2 = await waitForMessage(ws);\n    expect(ack2.type).toBe('ack');\n    expect(ack2.version).toBe(2);\n\n    const getRes = await request(`/documents/${doc.id}`);\n    const updatedDoc = await getRes.json();\n    expect(updatedDoc.content).toBe('hello world');\n\n    ws.close();\n  });\n});\n\ndescribe('WebSocket - OT Conflict Resolution', () => {\n  it('transforms concurrent operations correctly', async () => {\n    const createRes = await request('/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Concurrent', content: 'hello' }),\n    });\n    const doc = await createRes.json();\n\n    const ws1 = await connectWs(doc.id);\n    await waitForMessage(ws1); // sync\n    const ws2 = await connectWs(doc.id);\n    await waitForMessage(ws2); // sync\n\n    // Both clients think they're at version 0\n    // ws1 inserts 'A' at position 0\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      operation: { type: 'insert', position: 0, content: 'A' },\n      version: 0,\n    }));\n\n    const ack1 = await waitForMessage(ws1);\n    expect(ack1.type).toBe('ack');\n    const ws2Broadcast1 = await waitForMessage(ws2);\n    expect(ws2Broadcast1.type).toBe('operation');\n\n    // ws2 also sends from version 0, inserts 'B' at position 5\n    // This should be transformed since server is now at version 1\n    ws2.send(JSON.stringify({\n      type: 'operation',\n      operation: { type: 'insert', position: 5, content: 'B' },\n      version: 0,\n    }));\n\n    const ack2 = await waitForMessage(ws2);\n    expect(ack2.type).toBe('ack');\n\n    // The 'B' should be transformed to position 6 (shifted by 'A' insertion)\n    const ws1Broadcast = await waitForMessage(ws1);\n    expect(ws1Broadcast.type).toBe('operation');\n\n    const getRes = await request(`/documents/${doc.id}`);\n    const updatedDoc = await getRes.json();\n    expect(updatedDoc.content).toBe('AhelloB');\n\n    ws1.close();\n    ws2.close();\n  });\n});\n","structuredPatch":[{"oldStart":13,"oldLines":8,"newStart":13,"newLines":8,"lines":["   port = await server.start(0);"," });"," ","-afterEach(() => {","-  server.stop();","+afterEach(async () => {","+  await server.stop();"," });"," "," async function request(path: string, options?: RequestInit) {"]}],"userModified":false,"replaceAll":false}}
