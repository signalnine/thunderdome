st createRes = await request('/documents', {\n   309→      method: 'POST',\n   310→      body: JSON.stringify({ title: 'Sequential', content: '' }),\n   311→    });\n   312→    const doc = await createRes.json();\n   313→\n   314→    const ws = await connectWs(doc.id);\n   315→    await waitForMessage(ws); // sync\n   316→\n   317→    // Insert 'hello'\n   318→    ws.send(JSON.stringify({\n   319→      type: 'operation',\n   320→      operation: { type: 'insert', position: 0, content: 'hello' },\n   321→      version: 0,\n   322→    }));\n   323→    const ack1 = await waitForMessage(ws);\n   324→    expect(ack1.type).toBe('ack');\n   325→    expect(ack1.version).toBe(1);\n   326→\n   327→    // Insert ' world'\n   328→    ws.send(JSON.stringify({\n   329→      type: 'operation',\n   330→      operation: { type: 'insert', position: 5, content: ' world' },\n   331→      version: 1,\n   332→    }));\n   333→    const ack2 = await waitForMessage(ws);\n   334→    expect(ack2.type).toBe('ack');\n   335→    expect(ack2.version).toBe(2);\n   336→\n   337→    const getRes = await request(`/documents/${doc.id}`);\n   338→    const updatedDoc = await getRes.json();\n   339→    expect(updatedDoc.content).toBe('hello world');\n   340→\n   341→    ws.close();\n   342→  });\n   343→});\n   344→\n   345→describe('WebSocket - OT Conflict Resolution', () => {\n   346→  it('transforms concurrent operations correctly', async () => {\n   347→    const createRes = await request('/documents', {\n   348→      method: 'POST',\n   349→      body: JSON.stringify({ title: 'Concurrent', content: 'hello' }),\n   350→    });\n   351→    const doc = await createRes.json();\n   352→\n   353→    const ws1 = await connectWs(doc.id);\n   354→    await waitForMessage(ws1); // sync\n   355→    const ws2 = await connectWs(doc.id);\n   356→    await waitForMessage(ws2); // sync\n   357→\n   358→    // Both clients think they're at version 0\n   359→    // ws1 inserts 'A' at position 0\n   360→    ws1.send