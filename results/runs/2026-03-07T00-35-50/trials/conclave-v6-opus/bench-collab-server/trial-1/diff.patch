+import express from 'express';
+import { createServer, type Server } from 'http';
+import { WebSocketServer, WebSocket } from 'ws';
+import { randomUUID } from 'crypto';
+import { createDb, type Document, type Version } from './db.js';
+import { applyOperation, transformOperation, type Operation } from './ot.js';
+import type Database from 'better-sqlite3';
+import type { IncomingMessage } from 'http';
+
+interface DocumentRoom {
+  clients: Set<WebSocket>;
+  version: number;
+}
+
+interface OperationMessage {
+  type: 'operation';
+  operation: Operation;
+  version: number;
+}
+
+export function createApp(dbPath?: string) {
+  const db: Database.Database = createDb(dbPath);
+  const app = express();
+  app.use(express.json());
+
+  const httpServer: Server = createServer(app);
+  const wss = new WebSocketServer({ noServer: true });
+  const rooms = new Map<string, DocumentRoom>();
+
+  // Prepared statements
+  const stmts = {
+    insertDoc: db.prepare('INSERT INTO documents (id, title, content) VALUES (?, ?, ?)'),
+    getDoc: db.prepare('SELECT * FROM documents WHERE id = ?'),
+    listDocs: db.prepare('SELECT * FROM documents ORDER BY updated_at DESC'),
+    updateDoc: db.prepare('UPDATE documents SET title = ?, content = ?, updated_at = datetime(\'now\') WHERE id = ?'),
+    deleteDoc: db.prepare('DELETE FROM documents WHERE id = ?'),
+    updateDocContent: db.prepare('UPDATE documents SET content = ?, updated_at = datetime(\'now\') WHERE id = ?'),
+    insertVersion: db.prepare('INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)'),
+    getVersions: db.prepare('SELECT * FROM versions WHERE document_id = ? ORDER BY version'),
+    getVersionsSince: db.prepare('SELECT * FROM versions WHERE document_id = ? AND version > ? ORDER BY version'),
+    getMaxVersion: db.prepare('SELECT COALESCE(MAX(version), -1) as max_version FROM versions WHERE document_id = ?'),
+  };
+
+  // ---- REST API ----
+
+  app.post('/documents', (req, res) => {
+    const { title, content } = req.body;
+    if (!title) {
+      res.status(400).json({ error: 'title is required' });
+      return;
+    }
+    const id = randomUUID();
+    const docContent = content ?? '';
+    stmts.insertDoc.run(id, title, docContent);
+    stmts.insertVersion.run(id, 0, docContent, null);
+    const doc = stmts.getDoc.get(id) as Document;
+    res.status(201).json(doc);
+  });
+
+  app.get('/documents', (_req, res) => {
+    const docs = stmts.listDocs.all();
+    res.json(docs);
+  });
+
+  app.get('/documents/:id', (req, res) => {
+    const doc = stmts.getDoc.get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.json(doc);
+  });
+
+  app.put('/documents/:id', (req, res) => {
+    const existing = stmts.getDoc.get(req.params.id);
+    if (!existing) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    const { title, content } = req.body;
+    stmts.updateDoc.run(
+      title ?? (existing as Document).title,
+      content ?? (existing as Document).content,
+      req.params.id
+    );
+    const doc = stmts.getDoc.get(req.params.id);
+    res.json(doc);
+  });
+
+  app.delete('/documents/:id', (req, res) => {
+    const existing = stmts.getDoc.get(req.params.id);
+    if (!existing) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    stmts.deleteDoc.run(req.params.id);
+    const room = rooms.get(req.params.id);
+    if (room) {
+      for (const client of room.clients) {
+        client.close(4004, 'Document deleted');
+      }
+      rooms.delete(req.params.id);
+    }
+    res.status(204).send();
+  });
+
+  app.get('/documents/:id/versions', (req, res) => {
+    const doc = stmts.getDoc.get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    const versions = stmts.getVersions.all(req.params.id);
+    res.json(versions);
+  });
+
+  // ---- WebSocket ----
+
+  httpServer.on('upgrade', (request: IncomingMessage, socket, head) => {
+    const url = new URL(request.url || '', `http://${request.headers.host}`);
+    const match = url.pathname.match(/^\/documents\/([^/]+)\/ws$/);
+
+    if (!match) {
+      socket.destroy();
+      return;
+    }
+
+    const docId = match[1];
+    const doc = stmts.getDoc.get(docId) as Document | undefined;
+
+    if (!doc) {
+      wss.handleUpgrade(request, socket, head, (ws) => {
+        ws.close(4004, 'Document not found');
+      });
+      return;
+    }
+
+    wss.handleUpgrade(request, socket, head, (ws) => {
+      handleConnection(ws, docId, doc);
+    });
+  });
+
+  function getOrCreateRoom(docId: string): DocumentRoom {
+    let room = rooms.get(docId);
+    if (!room) {
+      const maxVersion = (stmts.getMaxVersion.get(docId) as { max_version: number }).max_version;
+      room = {
+        clients: new Set(),
+        version: maxVersion,
+      };
+      rooms.set(docId, room);
+    }
+    return room;
+  }
+
+  function handleConnection(ws: WebSocket, docId: string, doc: Document) {
+    const room = getOrCreateRoom(docId);
+    room.clients.add(ws);
+
+    ws.send(JSON.stringify({
+      type: 'sync',
+      content: doc.content,
+      version: room.version,
+      documentId: docId,
+    }));
+
+    ws.on('message', (data) => {
+      let msg: OperationMessage;
+      try {
+        msg = JSON.parse(data.toString());
+      } catch {
+        ws.send(JSON.stringify({ type: 'error', message: 'Invalid JSON' }));
+        return;
+      }
+
+      if (msg.type !== 'operation' || !msg.operation || typeof msg.version !== 'number') {
+        ws.send(JSON.stringify({ type: 'error', message: 'Invalid message format' }));
+        return;
+      }
+
+      try {
+        processOperation(ws, docId, msg);
+      } catch (err) {
+        ws.send(JSON.stringify({
+          type: 'error',
+          message: err instanceof Error ? err.message : 'Operation failed',
+        }));
+      }
+    });
+
+    ws.on('close', () => {
+      room.clients.delete(ws);
+      if (room.clients.size === 0) {
+        rooms.delete(docId);
+      }
+    });
+  }
+
+  function processOperation(senderWs: WebSocket, docId: string, msg: OperationMessage) {
+    const room = getOrCreateRoom(docId);
+    let op = msg.operation;
+
+    if (msg.version < room.version) {
+      const missedVersions = stmts.getVersionsSince.all(docId, msg.version) as Version[];
+      for (const v of missedVersions) {
+        if (v.operation) {
+          const pastOp = JSON.parse(v.operation) as Operation;
+          op = transformOperation(op, pastOp);
+        }
+      }
+    }
+
+    const doc = stmts.getDoc.get(docId) as Document;
+    const newContent = applyOperation(doc.content, op);
+
+    room.version++;
+    stmts.updateDocContent.run(newContent, docId);
+    stmts.insertVersion.run(docId, room.version, newContent, JSON.stringify(op));
+
+    senderWs.send(JSON.stringify({
+      type: 'ack',
+      version: room.version,
+    }));
+
+    for (const client of room.clients) {
+      if (client !== senderWs && client.readyState === WebSocket.OPEN) {
+        client.send(JSON.stringify({
+          type: 'operation',
+          operation: op,
+          version: room.version,
+        }));
+      }
+    }
+  }
+
+  function start(port?: number): Promise<number> {
+    return new Promise((resolve) => {
+      const listenPort = port ?? 0;
+      httpServer.listen(listenPort, () => {
+        const addr = httpServer.address();
+        if (typeof addr === 'object' && addr !== null) {
+          resolve(addr.port);
+        } else {
+          resolve(listenPort);
+        }
+      });
+    });
+  }
+
+  function stop(): Promise<void> {
+    for (const room of rooms.values()) {
+      for (const client of room.clients) {
+        client.terminate();
+      }
+    }
+    rooms.clear();
+
+    return new Promise<void>((resolve, reject) => {
+      httpServer.close((err) => {
+        db.close();
+        if (err) reject(err);
+        else resolve();
+      });
+    });
+  }
+
+  return { app: httpServer, start, stop };
+}
