--- /dev/null
+++ b/src/db.test.ts
@@ -0,0 +1,102 @@
+import { describe, it, expect, beforeEach, afterEach } from 'vitest';
+import { createDb, type Document, type Version } from './db.js';
+import Database from 'better-sqlite3';
+
+let db: Database.Database;
+
+beforeEach(() => {
+  db = createDb(':memory:');
+});
+
+afterEach(() => {
+  db.close();
+});
+
+describe('createDb', () => {
+  it('creates tables on initialization', () => {
+    const tables = db.prepare(
+      "SELECT name FROM sqlite_master WHERE type='table' ORDER BY name"
+    ).all() as { name: string }[];
+    const names = tables.map(t => t.name);
+    expect(names).toContain('documents');
+    expect(names).toContain('versions');
+    expect(names).toContain('active_connections');
+  });
+});
+
+describe('documents CRUD', () => {
+  it('creates a document', () => {
+    const stmt = db.prepare('INSERT INTO documents (id, title, content) VALUES (?, ?, ?)');
+    stmt.run('doc1', 'Test Doc', 'Hello');
+    const doc = db.prepare('SELECT * FROM documents WHERE id = ?').get('doc1') as Document;
+    expect(doc.id).toBe('doc1');
+    expect(doc.title).toBe('Test Doc');
+    expect(doc.content).toBe('Hello');
+    expect(doc.created_at).toBeTruthy();
+    expect(doc.updated_at).toBeTruthy();
+  });
+
+  it('lists all documents', () => {
+    db.prepare('INSERT INTO documents (id, title, content) VALUES (?, ?, ?)').run('doc1', 'A', '');
+    db.prepare('INSERT INTO documents (id, title, content) VALUES (?, ?, ?)').run('doc2', 'B', '');
+    const docs = db.prepare('SELECT * FROM documents').all() as Document[];
+    expect(docs).toHaveLength(2);
+  });
+
+  it('updates a document', () => {
+    db.prepare('INSERT INTO documents (id, title, content) VALUES (?, ?, ?)').run('doc1', 'Old', 'old content');
+    db.prepare('UPDATE documents SET title = ?, content = ?, updated_at = datetime(\'now\') WHERE id = ?')
+      .run('New', 'new content', 'doc1');
+    const doc = db.prepare('SELECT * FROM documents WHERE id = ?').get('doc1') as Document;
+    expect(doc.title).toBe('New');
+    expect(doc.content).toBe('new content');
+  });
+
+  it('deletes a document', () => {
+    db.prepare('INSERT INTO documents (id, title, content) VALUES (?, ?, ?)').run('doc1', 'A', '');
+    db.prepare('DELETE FROM documents WHERE id = ?').run('doc1');
+    const doc = db.prepare('SELECT * FROM documents WHERE id = ?').get('doc1');
+    expect(doc).toBeUndefined();
+  });
+});
+
+describe('versions', () => {
+  it('creates a version entry', () => {
+    db.prepare('INSERT INTO documents (id, title, content) VALUES (?, ?, ?)').run('doc1', 'Test', '');
+    db.prepare('INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)')
+      .run('doc1', 1, 'Hello', JSON.stringify({ type: 'insert', position: 0, content: 'Hello' }));
+    const version = db.prepare('SELECT * FROM versions WHERE document_id = ? AND version = ?')
+      .get('doc1', 1) as Version;
+    expect(version.content).toBe('Hello');
+    expect(version.version).toBe(1);
+    expect(JSON.parse(version.operation!).type).toBe('insert');
+  });
+
+  it('enforces unique document_id + version', () => {
+    db.prepare('INSERT INTO documents (id, title, content) VALUES (?, ?, ?)').run('doc1', 'Test', '');
+    db.prepare('INSERT INTO versions (document_id, version, content) VALUES (?, ?, ?)').run('doc1', 1, 'v1');
+    expect(() => {
+      db.prepare('INSERT INTO versions (document_id, version, content) VALUES (?, ?, ?)').run('doc1', 1, 'v1dup');
+    }).toThrow();
+  });
+
+  it('lists versions in order', () => {
+    db.prepare('INSERT INTO documents (id, title, content) VALUES (?, ?, ?)').run('doc1', 'Test', '');
+    db.prepare('INSERT INTO versions (document_id, version, content) VALUES (?, ?, ?)').run('doc1', 1, 'v1');
+    db.prepare('INSERT INTO versions (document_id, version, content) VALUES (?, ?, ?)').run('doc1', 2, 'v2');
+    db.prepare('INSERT INTO versions (document_id, version, content) VALUES (?, ?, ?)').run('doc1', 3, 'v3');
+    const versions = db.prepare('SELECT * FROM versions WHERE document_id = ? ORDER BY version')
+      .all('doc1') as Version[];
+    expect(versions).toHaveLength(3);
+    expect(versions[0].version).toBe(1);
+    expect(versions[2].version).toBe(3);
+  });
+
+  it('cascades delete to versions when document is deleted', () => {
+    db.prepare('INSERT INTO documents (id, title, content) VALUES (?, ?, ?)').run('doc1', 'Test', '');
+    db.prepare('INSERT INTO versions (document_id, version, content) VALUES (?, ?, ?)').run('doc1', 1, 'v1');
+    db.prepare('DELETE FROM documents WHERE id = ?').run('doc1');
+    const versions = db.prepare('SELECT * FROM versions WHERE document_id = ?').all('doc1');
+    expect(versions).toHaveLength(0);
+  });
+});
