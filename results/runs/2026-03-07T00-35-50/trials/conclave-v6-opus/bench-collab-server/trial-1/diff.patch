escribe('delete vs insert', () => {\n   122→    it('shifts delete right when insert is before delete position', () => {\n   123→      const op: Operation = { type: 'delete', position: 5, length: 3 };\n   124→      const against: Operation = { type: 'insert', position: 2, content: 'ab' };\n   125→      const result = transformOperation(op, against);\n   126→      expect(result).toEqual({ type: 'delete', position: 7, length: 3 });\n   127→    });\n   128→\n   129→    it('shifts delete right when insert is at delete position', () => {\n   130→      const op: Operation = { type: 'delete', position: 3, length: 2 };\n   131→      const against: Operation = { type: 'insert', position: 3, content: 'xy' };\n   132→      const result = transformOperation(op, against);\n   133→      expect(result).toEqual({ type: 'delete', position: 5, length: 2 });\n   134→    });\n   135→\n   136→    it('splits delete when insert is inside deleted range', () => {\n   137→      // Deleting positions 2-6 (position=2, length=5), but insert at position 4\n   138→      // After insert of 2 chars at pos 4, the delete range shifted:\n   139→      // We still need to delete all original chars, but shifted around the insert\n   140→      // The simplest correct approach: shift the delete right by insert length\n   141→      // since the insert is within the delete range\n   142→      const op: Operation = { type: 'delete', position: 2, length: 5 };\n   143→      const against: Operation = { type: 'insert', position: 4, content: 'xy' };\n   144→      const result = transformOperation(op, against);\n   145→      // The delete should expand to cover the original range + skip the inserted text\n   146→      expect(result).toEqual({ type: 'delete', position: 2, length: 7 });\n   147→    });\n   148→\n   149→    it('does not shift delete when insert is after', () => {\n   150→      const op: Operation = { type: 'delete', position: 2, length: 3 };\n   151→      const against: Operation = { type: 'insert', position: 8, content: 'x' };\n   152→      const result = transformOperation(op, against);\n   153→      expect(result).toEqual({ type: 'delete', position: 2, length: 3 });\n   154→    });\n   155→  });\n   156→\n   157→  describe('delete vs delete', () => {\n   158→    it('shifts delete left when other delete is entirely before', () => {\n   159→      const op: Operation = { type: 'delete', position: 5, length: 3 };\n   160→      const against: Operation = { type: 'delete', position: 1, length: 2 };\n   161→      const result = transformOperation(op, against);\n   162→      expect(result).toEqual({ type: 'delete', position: 3, length: 3 });\n   163→    });\n   164→\n   165→    it('reduces length when deletes overlap at start', () => {\n   166→      const op: Operation = { type: 'delete', position: 2, length: 5 };\n   167→      const against: Operation = { type: 'delete', position: 4, length: 3 };\n   168→      // op deletes [2,7), against deletes [4,7) - overlap is [4,7) = 3 chars\n   169→      // after against applied, op should delete [2, 4) = position 2, length 2\n   170→      const result = transformOperation(op, against);\n   171→      expect(result).toEqual({ type: 'delete', position: 2, length: 2 });\n   172→    });\n   173→\n   174→    it('becomes no-op when other delete completely covers this one', () => {\n   175→      const op: Operation = { type: 'delete', position: 3, length: 2 };\n   176→      const against: Operation = { type: 'delete', position: 2, length: 6 };\n   177→      const result = transformOperation(op, against);\n   178→      // Nothing left to delete\n   179→      expect(result).toEqual({ type: 'delete', position: 2, length: 0 });\n   180→    });\n   181→\n   182→    it('adjusts when deletes overlap at end', () => {\n   183→      const op: Operation = { type: 'delete', position: 4, length: 4 };\n   184→      const against: Operation = { type: 'delete', position: 2, length: 4 };\n   185→      // op deletes [4,8), against deletes [2,6) - ove