nown>> {\n  const queued = ws.messageQueue.shift();\n  if (queued) return Promise.resolve(queued);\n\n  return new Promise((resolve, reject) => {\n    const timer = setTimeout(() => reject(new Error('waitForMessage timeout')), timeout);\n    ws.messageResolvers.push((msg) => {\n      clearTimeout(timer);\n      resolve(msg);\n    });\n  });\n}","originalFile":"import { describe, it, expect, beforeEach, afterEach } from 'vitest';\nimport { createApp } from './server.js';\nimport WebSocket from 'ws';\n\nlet server: ReturnType<typeof createApp>;\nlet port: number;\nconst openSockets: WebSocket[] = [];\n\nbeforeEach(async () => {\n  server = createApp(':memory:');\n  port = await server.start(0);\n});\n\nafterEach(async () => {\n  for (const ws of openSockets) {\n    if (ws.readyState === WebSocket.OPEN || ws.readyState === WebSocket.CONNECTING) {\n      ws.terminate();\n    }\n  }\n  openSockets.length = 0;\n  await server.stop();\n});\n\nasync function request(path: string, options?: RequestInit) {\n  return fetch(`http://localhost:${port}${path}`, {\n    headers: { 'Content-Type': 'application/json' },\n    ...options,\n  });\n}\n\nasync function createDoc(title: string, content = ''): Promise<{ id: string }> {\n  const res = await request('/documents', {\n    method: 'POST',\n    body: JSON.stringify({ title, content }),\n  });\n  return res.json();\n}\n\nfunction connectWs(docId: string): Promise<WebSocket> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/documents/${docId}/ws`);\n    openSockets.push(ws);\n    ws.on('open', () => resolve(ws));\n    ws.on('error', reject);\n  });\n}\n\nfunction waitForMessage(ws: WebSocket, timeout = 5000): Promise<Record<string, unknown>> {\n  return new Promise((resolve, reject) => {\n    const timer = setTimeout(() => reject(new Error('waitForMessage timeout')), timeout);\n    ws.once('message', (data) => {\n      clearTimeout(timer);\n      resolve(JSON.parse(data.toString()));\n    });\n  });\n}\n\ndescribe('WebSocket - Connection', () => {\n  it('sends sync message on connect with current document state', async () => {\n    const doc = await createDoc('WS Test', 'initial content');\n    const ws = await connectWs(doc.id);\n    const msg = await waitForMessage(ws);\n\n    expect(msg.type).toBe('sync');\n    expect(msg.content).toBe('initial content');\n    expect(msg.version).toBe(0);\n  });\n\n  it('rejects connection to non-existent document', async () => {\n    const ws = new WebSocket(`ws://localhost:${port}/documents/nonexistent/ws`);\n    openSockets.push(ws);\n    const code = await new Promise<number>((resolve) => {\n      ws.on('close', (code) => resolve(code));\n    });\n    expect(code).toBeGreaterThanOrEqual(4000);\n  });\n});\n\ndescribe('WebSocket - Operations', () => {\n  it('broadcasts insert operation to other clients', async () => {\n    const doc = await createDoc('Collab Test', 'hello');\n\n    const ws1 = await connectWs(doc.id);\n    await waitForMessage(ws1); // sync\n\n    const ws2 = await connectWs(doc.id);\n    await waitForMessage(ws2); // sync\n\n    const ws2MsgPromise = waitForMessage(ws2);\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      operation: { type: 'insert', position: 5, content: ' world' },\n      version: 0,\n    }));\n\n    const ack = await waitForMessage(ws1);\n    expect(ack.type).toBe('ack');\n    expect(ack.version).toBe(1);\n\n    const broadcast = await ws2MsgPromise;\n    expect(broadcast.type).toBe('operation');\n\n    const getRes = await request(`/documents/${doc.id}`);\n    const updatedDoc = await getRes.json();\n    expect(updatedDoc.content).toBe('hello world');\n  });\n\n  it('broadcasts delete operation to other clients', async () => {\n    const doc = await createDoc('Delete Test', 'hello world');\n\n    const ws1 = await connectWs(doc.id);\n    await waitForMessage(ws1);\n\n    const ws2 = await connectWs(doc.id);\n    await waitForMessage(ws2);\n\n    const ws2MsgPromise = waitForMessage(ws2);\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      operation: { type: 'delete', position: 5, length: 6 },\n      version: 0,\n    }));\n\n    await waitForMessage(ws1); // ack\n    const broadcast = await ws2MsgPromise;\n    expect(broadcast.type).toBe('operation');\n\n    const getRes = await request(`/documents/${doc.id}`);\n    const updatedDoc = await getRes.json();\n    expect(updatedDoc.content).toBe('hello');\n  });\n\n  it('rejects invalid operation', async () => {\n    const doc = await createDoc('Invalid Op', 'hello');\n    const ws = await connectWs(doc.id);\n    await waitForMessage(ws); // sync\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: { type: 'insert', position: 100, content: 'x' },\n      version: 0,\n    }));\n\n    const msg = await waitForMessage(ws);\n    expect(msg.type).toBe('error');\n  });\n\n  it('rejects malformed messages', async () => {\n    const doc = await createDoc('Bad Msg', '');\n    const ws = await connectWs(doc.id);\n    await waitForMessage(ws); // sync\n\n    ws.send('not json');\n    const msg = await waitForMessage(ws);\n    expect(msg.type).toBe('error');\n  });\n\n  it('handles multiple sequential operations', async () => {\n    const doc = await createDoc('Sequential', '');\n    const ws = await connectWs(doc.id);\n    await waitForMessage(ws); // sync\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: { type: 'insert', position: 0, content: 'hello' },\n      version: 0,\n    }));\n    const ack1 = await waitForMessage(ws);\n    expect(ack1.type).toBe('ack');\n    expect(ack1.version).toBe(1);\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: { type: 'insert', position: 5, content: ' world' },\n      version: 1,\n    }));\n    const ack2 = await waitForMessage(ws);\n    expect(ack2.type).toBe('ack');\n    expect(ack2.version).toBe(2);\n\n    const getRes = await request(`/documents/${doc.id}`);\n    const updatedDoc = await getRes.json();\n    expect(updatedDoc.content).toBe('hello world');\n  });\n});\n\ndescribe('WebSocket - OT Conflict Resolution', () => {\n  it('transforms concurrent operations correctly', async () => {\n    const doc = await createDoc('Concurrent', 'hello');\n\n    const ws1 = await connectWs(doc.id);\n    await waitForMessage(ws1); // sync\n    const ws2 = await connectWs(doc.id);\n    await waitForMessage(ws2); // sync\n\n    // ws1 inserts 'A' at position 0, both at version 0\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      operation: { type: 'insert', position: 0, content: 'A' },\n      version: 0,\n    }));\n\n    const ack1 = await waitForMessage(ws1);\n    expect(ack1.type).toBe('ack');\n    const ws2Broadcast1 = await waitForMessage(ws2);\n    expect(ws2Broadcast1.type).toBe('operation');\n\n    // ws2 sends from version 0, inserts 'B' at position 5\n    // Should be transformed since server is now at version 1\n    ws2.send(JSON.stringify({\n      type: 'operation',\n      operation: { type: 'insert', position: 5, content: 'B' },\n      version: 0,\n    }));\n\n    const ack2 = await waitForMessage(ws2);\n    expect(ack2.type).toBe('ack');\n\n    const ws1Broadcast = await waitForMessage(ws1);\n    expect(ws1Broadcast.type).toBe('operation');\n\n    const getRes = await request(`/documents/${doc.id}`);\n    const updatedDoc = await getRes.json();\n    expect(updatedDoc.content).toBe('AhelloB');\n  });\n\n  it('handles 10 concurrent clients without corruption', async () => {\n    const doc = await createDoc('Load Test', 'base');\n    const clients: WebSocket[] = [];\n\n    // Connect 10 clients\n    for (let i = 0; i < 10; i++) {\n      const ws = await connectWs(doc.id);\n      await waitForMessage(ws); // sync\n      clients.push(ws);\n    }\n\n    // Each client sends an insert at position 4 (end of \"base\")\n    // They all think they're at version 0\n    const ackPromises: Promise<Record<string, unknown>>[] = [];\n    for (let i = 0; i < 10; i++) {\n      ackPromises.push(waitForMessage(clients[i]));\n      clients[i].send(JSON.stringify({\n        type: 'operation',\n        operation: { type: 'insert', position: 4, content: String(i) },\n        version: 0,\n      }));\n      // Small delay to ensure ordering\n      await new Promise(r => setTimeout(r, 10));\n    }\n\n    // Wait for all acks\n    for (const p of ackPromises) {\n      const msg = await p;\n      expect(msg.type).toBe('ack');\n    }\n\n    // Drain any remaining broadcast messages\n    await new Promise(r => setTimeout(r, 200));\n\n    // Check final document via REST\n    const getRes = await request(`/documents/${doc.id}`);\n    const updatedDoc = await getRes.json();\n\n    // All 10 digits should be present plus \"base\"\n    expect(updatedDoc.content.length).toBe(14); // \"base\" + 10 single chars\n    expect(updatedDoc.content.startsWith('base')).toBe(true);\n    for (let i = 0; i < 10; i++) {\n      expect(updatedDoc.content).toContain(String(i));\n    }\n  });\n});\n","structuredPatch":[{"oldStart":36,"oldLines":21,"newStart":36,"newLines":43,"lines":["   return res.json();"," }"," ","-function connectWs(docId: string): Promise<WebSocket> {","+interface BufferedWebSocket extends WebSocket {","+  messageQueue: Record<string, unknown>[];","+  messageResolvers: ((msg: Record<string, unknown>) => void)[];","+}","+","+function connectWs(docId: string): Promise<BufferedWebSocket> {","   return new Promise((resolve, reject) => {","-    const ws = new WebSocket(`ws://localhost:${port}/documents/${docId}/ws`);","+    const ws = new WebSocket(`ws://localhost:${port}/documents/${docId}/ws`) as BufferedWebSocket;","+    ws.messageQueue = [];","+    ws.messageResolvers = [];","     openSockets.push(ws);","+","+    // Buffer all messages to avoid race conditions","+    ws.on('message', (data) => {","+      const parsed = JSON.parse(data.toString());","+      const resolver = ws.messageResolvers.shift();