@@ -0,0 +1,103 @@
+import * as fs from 'node:fs';
+import * as path from 'node:path';
+
+export interface TimeEntry {
+  taskName: string;
+  startTime: string;
+  endTime: string | null;
+}
+
+export interface DateRangeFilter {
+  from?: Date;
+  to?: Date;
+}
+
+export class TimeTracker {
+  private entries: TimeEntry[];
+  private filePath: string;
+
+  constructor(filePath: string) {
+    this.filePath = filePath;
+    this.entries = this.load();
+  }
+
+  start(taskName: string): void {
+    if (!taskName || !taskName.trim()) {
+      throw new Error('Task name must not be empty');
+    }
+
+    // Auto-stop any running timer
+    const running = this.entries.find(e => e.endTime === null);
+    if (running) {
+      running.endTime = new Date().toISOString();
+    }
+
+    this.entries.push({
+      taskName,
+      startTime: new Date().toISOString(),
+      endTime: null,
+    });
+
+    this.save();
+  }
+
+  stop(): void {
+    const running = this.entries.find(e => e.endTime === null);
+    if (!running) {
+      throw new Error('No timer is currently running');
+    }
+
+    running.endTime = new Date().toISOString();
+    this.save();
+  }
+
+  getEntries(filter?: DateRangeFilter): TimeEntry[] {
+    if (!filter) {
+      return [...this.entries];
+    }
+
+    return this.entries.filter(entry => {
+      const startTime = new Date(entry.startTime).getTime();
+      if (filter.from && startTime < filter.from.getTime()) {
+        return false;
+      }
+      if (filter.to && startTime > filter.to.getTime()) {
+        return false;
+      }
+      return true;
+    });
+  }
+
+  getSummary(): Record<string, number> {
+    const summary: Record<string, number> = {};
+    const now = Date.now();
+
+    for (const entry of this.entries) {
+      const start = new Date(entry.startTime).getTime();
+      const end = entry.endTime ? new Date(entry.endTime).getTime() : now;
+      const duration = end - start;
+
+      if (summary[entry.taskName] === undefined) {
+        summary[entry.taskName] = 0;
+      }
+      summary[entry.taskName] += duration;
+    }
+
+    return summary;
+  }
+
+  private load(): TimeEntry[] {
+    try {
+      const data = fs.readFileSync(this.filePath, 'utf-8');
+      return JSON.parse(data) as TimeEntry[];
+    } catch {
+      return [];
+    }
+  }
+
+  private save(): void {
+    const dir = path.dirname(this.filePath);
+    fs.mkdirSync(dir, { recursive: true });
+    fs.writeFileSync(this.filePath, JSON.stringify(this.entries, null, 2), 'utf-8');
+  }
+}
