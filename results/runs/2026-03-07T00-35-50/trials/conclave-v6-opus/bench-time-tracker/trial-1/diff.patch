@@ -0,0 +1,339 @@
+import { describe, test, expect, beforeEach, afterEach } from 'vitest';
+import * as fs from 'node:fs';
+import * as path from 'node:path';
+import * as os from 'node:os';
+import { TimeTracker } from './index.js';
+
+function makeTmpPath(): string {
+  const dir = fs.mkdtempSync(path.join(os.tmpdir(), 'tt-'));
+  return path.join(dir, 'data.json');
+}
+
+function makeTmpNestedPath(): string {
+  const dir = fs.mkdtempSync(path.join(os.tmpdir(), 'tt-'));
+  return path.join(dir, 'nested', 'deep', 'data.json');
+}
+
+describe('TimeTracker', () => {
+  let filePath: string;
+  let tracker: TimeTracker;
+
+  beforeEach(() => {
+    filePath = makeTmpPath();
+    tracker = new TimeTracker(filePath);
+  });
+
+  afterEach(() => {
+    // Clean up temp files
+    try {
+      const dir = path.dirname(filePath);
+      fs.rmSync(dir, { recursive: true, force: true });
+    } catch {
+      // ignore
+    }
+  });
+
+  // --- Starting and stopping timers ---
+
+  describe('starting and stopping timers', () => {
+    test('start creates a running entry', () => {
+      tracker.start('coding');
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].taskName).toBe('coding');
+      expect(entries[0].startTime).toBeDefined();
+      expect(entries[0].endTime).toBeNull();
+    });
+
+    test('stop ends the running entry', () => {
+      tracker.start('coding');
+      tracker.stop();
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].endTime).not.toBeNull();
+    });
+
+    test('starting a new timer auto-stops the previous one', () => {
+      tracker.start('coding');
+      tracker.start('meeting');
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(2);
+      expect(entries[0].taskName).toBe('coding');
+      expect(entries[0].endTime).not.toBeNull();
+      expect(entries[1].taskName).toBe('meeting');
+      expect(entries[1].endTime).toBeNull();
+    });
+
+    test('can start after stopping', () => {
+      tracker.start('coding');
+      tracker.stop();
+      tracker.start('meeting');
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(2);
+      expect(entries[0].endTime).not.toBeNull();
+      expect(entries[1].endTime).toBeNull();
+    });
+  });
+
+  // --- Recording time entries ---
+
+  describe('recording time entries', () => {
+    test('entry captures task name, start time, and end time', () => {
+      tracker.start('coding');
+      tracker.stop();
+      const entry = tracker.getEntries()[0];
+      expect(entry).toHaveProperty('taskName', 'coding');
+      expect(typeof entry.startTime).toBe('string');
+      expect(typeof entry.endTime).toBe('string');
+      // Valid ISO date strings
+      expect(new Date(entry.startTime).toISOString()).toBe(entry.startTime);
+      expect(new Date(entry.endTime!).toISOString()).toBe(entry.endTime);
+    });
+
+    test('running entry has null endTime', () => {
+      tracker.start('coding');
+      const entry = tracker.getEntries()[0];
+      expect(entry.endTime).toBeNull();
+    });
+  });
+
+  // --- Persistence ---
+
+  describe('persistence', () => {
+    test('data is saved to JSON file', () => {
+      tracker.start('coding');
+      tracker.stop();
+      expect(fs.existsSync(filePath)).toBe(true);
+      const raw = JSON.parse(fs.readFileSync(filePath, 'utf-8'));
+      expect(raw).toHaveLength(1);
+      expect(raw[0].taskName).toBe('coding');
+    });
+
+    test('data survives between sessions', () => {
+      tracker.start('coding');
+      tracker.stop();
+
+      // Create a new tracker with the same file
+      const tracker2 = new TimeTracker(filePath);
+      const entries = tracker2.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].taskName).toBe('coding');
+    });
+
+    test('creates parent directories if they do not exist', () => {
+      const nestedPath = makeTmpNestedPath();
+      const t = new TimeTracker(nestedPath);
+      t.start('coding');
+      t.stop();
+      expect(fs.existsSync(nestedPath)).toBe(true);
+      // Clean up
+      const root = path.dirname(path.dirname(path.dirname(nestedPath)));
+      fs.rmSync(root, { recursive: true, force: true });
+    });
+
+    test('file path is configurable', () => {
+      const customPath = makeTmpPath();
+      const t = new TimeTracker(customPath);
+      t.start('task');
+      t.stop();
+      expect(fs.existsSync(customPath)).toBe(true);
+      // Clean up
+      fs.rmSync(path.dirname(customPath), { recursive: true, force: true });
+    });
+
+    test('persists after start (running timer)', () => {
+      tracker.start('coding');
+      const raw = JSON.parse(fs.readFileSync(filePath, 'utf-8'));
+      expect(raw).toHaveLength(1);
+      expect(raw[0].endTime).toBeNull();
+    });
+
+    test('persists after auto-stop from starting new timer', () => {
+      tracker.start('coding');
+      tracker.start('meeting');
+      const raw = JSON.parse(fs.readFileSync(filePath, 'utf-8'));
+      expect(raw).toHaveLength(2);
+      expect(raw[0].endTime).not.toBeNull();
+    });
+  });
+
+  // --- Querying entries ---
+
+  describe('querying entries', () => {
+    test('getEntries returns all entries', () => {
+      tracker.start('a');
+      tracker.stop();
+      tracker.start('b');
+      tracker.stop();
+      tracker.start('c');
+      tracker.stop();
+      expect(tracker.getEntries()).toHaveLength(3);
+    });
+
+    test('getEntries with date range filters by start time', () => {
+      // Manually build entries with known dates
+      const now = new Date();
+      const yesterday = new Date(now.getTime() - 86400000);
+      const twoDaysAgo = new Date(now.getTime() - 2 * 86400000);
+      const threeDaysAgo = new Date(now.getTime() - 3 * 86400000);
+
+      // Write entries directly to the file for precise date control
+      const entries = [
+        { taskName: 'old', startTime: threeDaysAgo.toISOString(), endTime: threeDaysAgo.toISOString() },
+        { taskName: 'middle', startTime: yesterday.toISOString(), endTime: yesterday.toISOString() },
+        { taskName: 'recent', startTime: now.toISOString(), endTime: now.toISOString() },
+      ];
+      fs.writeFileSync(filePath, JSON.stringify(entries));
+
+      const filtered = new TimeTracker(filePath);
+      const result = filtered.getEntries({ from: twoDaysAgo, to: now });
+      const names = result.map(e => e.taskName);
+      expect(names).toContain('middle');
+      expect(names).toContain('recent');
+      expect(names).not.toContain('old');
+    });
+
+    test('getEntries with only from filter', () => {
+      const now = new Date();
+      const yesterday = new Date(now.getTime() - 86400000);
+      const twoDaysAgo = new Date(now.getTime() - 2 * 86400000);
+
+      const entries = [
+        { taskName: 'old', startTime: twoDaysAgo.toISOString(), endTime: twoDaysAgo.toISOString() },
+        { taskName: 'recent', startTime: now.toISOString(), endTime: now.toISOString() },
+      ];
+      fs.writeFileSync(filePath, JSON.stringify(entries));
+
+      const filtered = new TimeTracker(filePath);
+      const result = filtered.getEntries({ from: yesterday });
+      expect(result).toHaveLength(1);
+      expect(result[0].taskName).toBe('recent');
+    });
+
+    test('getEntries with only to filter', () => {
+      const now = new Date();
+      const yesterday = new Date(now.getTime() - 86400000);
+      const twoDaysAgo = new Date(now.getTime() - 2 * 86400000);
+
+      const entries = [
+        { taskName: 'old', startTime: twoDaysAgo.toISOString(), endTime: twoDaysAgo.toISOString() },
+        { taskName: 'recent', startTime: now.toISOString(), endTime: now.toISOString() },
+      ];
+      fs.writeFileSync(filePath, JSON.stringify(entries));
+
+      const filtered = new TimeTracker(filePath);
+      const result = filtered.getEntries({ to: yesterday });
+      expect(result).toHaveLength(1);
+      expect(result[0].taskName).toBe('old');
+    });
+  });
+
+  // --- Summarizing time ---
+
+  describe('summarizing time', () => {
+    test('getSummary returns total ms per task name', () => {
+      // Create entries with known durations
+      const start1 = new Date('2025-01-01T00:00:00Z');
+      const end1 = new Date('2025-01-01T01:00:00Z'); // 1 hour = 3600000ms
+      const start2 = new Date('2025-01-01T02:00:00Z');
+      const end2 = new Date('2025-01-01T02:30:00Z'); // 30 min = 1800000ms
+
+      const entries = [
+        { taskName: 'coding', startTime: start1.toISOString(), endTime: end1.toISOString() },
+        { taskName: 'meeting', startTime: start2.toISOString(), endTime: end2.toISOString() },
+      ];
+      fs.writeFileSync(filePath, JSON.stringify(entries));
+
+      const t = new TimeTracker(filePath);
+      const summary = t.getSummary();
+      expect(summary).toEqual({
+        coding: 3600000,
+        meeting: 1800000,
+      });
+    });
+
+    test('getSummary sums multiple entries with same task name', () => {
+      const entries = [
+        { taskName: 'coding', startTime: '2025-01-01T00:00:00.000Z', endTime: '2025-01-01T01:00:00.000Z' },
+        { taskName: 'coding', startTime: '2025-01-01T02:00:00.000Z', endTime: '2025-01-01T03:00:00.000Z' },
+      ];
+      fs.writeFileSync(filePath, JSON.stringify(entries));
+
+      const t = new TimeTracker(filePath);
+      const summary = t.getSummary();
+      expect(summary).toEqual({ coding: 7200000 }); // 2 hours
+    });
+
+    test('getSummary uses current time for running tasks', () => {
+      tracker.start('coding');
+      const before = Date.now();
+      const summary = tracker.getSummary();
+      const after = Date.now();
+
+      // The running task duration should be between 0 and (after - before + small tolerance)
+      expect(summary.coding).toBeGreaterThanOrEqual(0);
+      expect(summary.coding).toBeLessThanOrEqual(after - before + 100);
+    });
+  });
+
+  // --- Error handling ---
+
+  describe('error handling', () => {
+    test('start with empty string throws', () => {
+      expect(() => tracker.start('')).toThrow();
+    });
+
+    test('start with whitespace-only string throws', () => {
+      expect(() => tracker.start('   ')).toThrow();
+    });
+
+    test('stop when nothing is running throws', () => {
+      expect(() => tracker.stop()).toThrow();
+    });
+
+    test('stop after already stopped throws', () => {
+      tracker.start('coding');
+      tracker.stop();
+      expect(() => tracker.stop()).toThrow();
+    });
+  });
+
+  // --- Unicode support ---
+
+  describe('unicode support', () => {
