rderStatus, PaymentStatus } from '../src/types.js';\n\ndescribe('CatalogService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should create a product and return its id', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    expect(id).toBeTruthy();\n  });\n\n  it('should retrieve a product by id', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    const product = catalog.getProduct(id);\n    expect(product).toEqual({ id, name: 'Widget', price: 9.99, category: 'gadgets' });\n  });\n\n  it('should return null for nonexistent product', () => {\n    const catalog = createCatalogService(bus);\n    expect(catalog.getProduct('nope')).toBeNull();\n  });\n\n  it('should list all products', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('A', 1, 'cat1');\n    catalog.createProduct('B', 2, 'cat2');\n    expect(catalog.listProducts()).toHaveLength(2);\n  });\n\n  it('should list products filtered by category', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('A', 1, 'cat1');\n    catalog.createProduct('B', 2, 'cat2');\n    catalog.createProduct('C', 3, 'cat1');\n    const filtered = catalog.listProducts('cat1');\n    expect(filtered).toHaveLength(2);\n    expect(filtered.every(p => p.category === 'cat1')).toBe(true);\n  });\n\n  it('should search products by name', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('Blue Widget', 1, 'gadgets');\n    catalog.createProduct('Red Widget', 2, 'gadgets');\n    catalog.createProduct('Green Gizmo', 3, 'gadgets');\n    const results = catalog.searchProducts('widget');\n    expect(results).toHaveLength(2);\n  });\n\n  it('should search products by category', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('A', 1, 'electronics');\n    catalog.createProduct('B', 2, 'clothing');\n    const results = catalog.searchProducts('electron');\n    expect(results).toHaveLength(1);\n  });\n\n  it('should update product fields', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    catalog.updateProduct(id, { name: 'Super Widget', price: 19.99 });\n    const product = catalog.getProduct(id);\n    expect(product?.name).toBe('Super Widget');\n    expect(product?.price).toBe(19.99);\n    expect(product?.category).toBe('gadgets');\n  });\n\n  it('should remove a product', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    expect(catalog.removeProduct(id)).toBe(true);\n    expect(catalog.getProduct(id)).toBeNull();\n  });\n\n  it('should return false when removing nonexistent product', () => {\n    const catalog = createCatalogService(bus);\n    expect(catalog.removeProduct('nope')).toBe(false);\n  });\n\n  it('should emit PRODUCT_CREATED event', async () => {\n    const catalog = createCatalogService(bus);\n    const events: unknown[] = [];\n    bus.on(Events.PRODUCT_CREATED, (payload) => { events.push(payload); });\n    catalog.createProduct('Widget', 9.99, 'gadgets');\n    // Wait for async emit\n    await new Promise(r => setTimeout(r, 10));\n    expect(events).toHaveLength(1);\n  });\n});\n\ndescribe('InventoryService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should set and get stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 100);\n    expect(inventory.getStock('p1')).toBe(100);\n  });\n\n  it('should return 0 for unknown product stock', () => {\n    const inventory = createInventoryService(bus);\n    expect(inventory.getStock('unknown')).toBe(0);\n  });\n\n  it('should reserve stock successfully', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 10);\n    expect(inventory.reserve('p1', 5)).toBe(true);\n  });\n\n  it('should fail to reserve more than available', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 5);\n    expect(inventory.reserve('p1', 10)).toBe(false);\n  });\n\n  it('should track reserved quantities', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 10);\n    inventory.reserve('p1', 3);\n    inventory.reserve('p1', 4);\n    // Only 3 available now, should fail for 4 more\n    expect(inventory.reserve('p1', 4)).toBe(false);\n    expect(inventory.reserve('p1', 3)).toBe(true);\n  });\n\n  it('should release reserved stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 10);\n    inventory.reserve('p1', 5);\n    inventory.release('p1', 3);\n    // Now 8 available (10 - 5 + 3 released = 8 available)\n    expect(inventory.reserve('p1', 8)).toBe(true);\n  });\n\n  it('should emit low stock alert when stock falls below threshold', async () => {\n    const inventory = createInventoryService(bus);\n    const alerts: unknown[] = [];\n    bus.on(Events.LOW_STOCK_ALERT, (payload) => { alerts.push(payload); });\n\n    inventory.setLowStockThreshold('p1', 5);\n    inventory.setStock('p1', 3);\n\n    await new Promise(r => setTimeout(r, 10));\n    expect(alerts.length).toBeGreaterThanOrEqual(1);\n  });\n\n  it('should not alert when stock is above threshold', async () => {\n    const inventory = createInventoryService(bus);\n    const alerts: unknown[] = [];\n    bus.on(Events.LOW_STOCK_ALERT, (payload) => { alerts.push(payload); });\n\n    inventory.setLowStockThreshold('p1', 5);\n    inventory.setStock('p1', 10);\n\n    await new Promise(r => setTimeout(r, 10));\n    expect(alerts).toHaveLength(0);\n  });\n\n  it('should emit INVENTORY_UPDATED on setStock', async () => {\n    const inventory = createInventoryService(bus);\n    const events: unknown[] = [];\n    bus.on(Events.INVENTORY_UPDATED, (payload) => { events.push(payload); });\n    inventory.setStock('p1', 50);\n    await new Promise(r => setTimeout(r, 10));\n    expect(events).toHaveLength(1);\n  });\n});\n\ndescribe('CartService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should create a cart and return its id', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    expect(id).toBeTruthy();\n  });\n\n  it('should add items to cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    const c = cart.getCart(id);\n    expect(c?.items).toHaveLength(1);\n    expect(c?.items[0]).toEqual({ productId: 'p1', quantity: 2 });\n  });\n\n  it('should consolidate items for same product', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p1', 3);\n    const c = cart.getCart(id);\n    expect(c?.items).toHaveLength(1);\n    expect(c?.items[0].quantity).toBe(5);\n  });\n\n  it('should remove items from cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p2', 1);\n    cart.removeItem(id, 'p1');\n    const c = cart.getCart(id);\n    expect(c?.items).toHaveLength(1);\n    expect(c?.items[0].productId).toBe('p2');\n  });\n\n  it('should update quantity', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.updateQuantity(id, 'p1', 10);\n    const c = cart.getCart(id);\n    expect(c?.items[0].quantity).toBe(10);\n  });\n\n  it('should clear cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p2', 1);\n    cart.clearCart(id);\n    const c = cart.getCart(id);\n    expect(c?.items).toHaveLength(0);\n  });\n\n  it('should return null for nonexistent cart', () => {\n    const cart = createCartService(bus);\n    expect(cart.getCart('nope')).toBeNull();\n  });\n\n  it('should emit CART_UPDATED events', async () => {\n    const cart = createCartService(bus);\n    const events: unknown[] = [];\n    bus.on(Events.CART_UPDATED, (payload) => { events.push(payload); });\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    await new Promise(r => setTimeout(r, 10));\n    expect(events.length).toBeGreaterThanOrEqual(1);\n  });\n});\n\ndescribe('PricingService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should calculate total with 10% tax', () => {\n    const pricing = createPricingService(bus);\n    const result = pricing.calculateTotal([\n      { productId: 'p1', quantity: 2, price: 10 },\n    ]);\n    expect(result.subtotal).toBe(20);\n    expect(result.discount).toBe(0);\n    expect(result.tax).toBe(2);\n    expect(result.total).toBe(22);\n  });\n\n  it('should apply discount code before tax', () => {\n    const pricing = createPricingService(bus);\n    pricing.addDiscountCode('SAVE10', 10);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'SAVE10'\n    );\n    expect(result.subtotal).toBe(100);\n    expect(result.discount).toBe(10);\n    // Tax on 90 = 9\n    expect(result.tax).toBe(9);\n    expect(result.total).toBe(99);\n  });\n\n  it('should ignore invalid discount code', () => {\n    const pricing = createPricingService(bus);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'INVALID'\n    );\n    expect(result.discount).toBe(0);\n    expect(result.total).toBe(110);\n  });\n\n  it('should track prices from PRODUCT_CREATED events', async () => {\n    const pricing = createPricingService(bus);\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'Test', price: 25.99, category: 'test' });\n    expect(pricing.getPrice('p1')).toBe(25.99);\n  });\n\n  it('should return 0 for unknown product price', () => {\n    const pricing = createPricingService(bus);\n    expect(pricing.getPrice('unknown')).toBe(0);\n  });\n});\n\ndescribe('OrderService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should create an order in pending status', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 100);\n    const order = orders.getOrder(id);\n    expect(order?.status).toBe(OrderStatus.PENDING);\n    expect(order?.total).toBe(100);\n    expect(order?.userId).toBe('user1');\n  });\n\n  it('should return null for nonexistent order', () => {\n    const orders = createOrderService(bus);\n    expect(orders.getOrder('nope')).toBeNull();\n  });\n\n  it('should update order status', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 100);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    expect(orders.getOrder(id)?.status).toBe(OrderStatus.CONFIRMED);\n  });\n\n  it('should progress through status lifecycle', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 100);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    orders.updateStatus(id, OrderStatus.SHIPPED);\n    orders.updateStatus(id, OrderStatus.DELIVERED);\n    expect(orders.getOrder(id)?.status).toBe(OrderStatus.DELIVERED);\n  });\n\n  it('should cancel an order', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 100);\n    orders.updateStatus(id, OrderStatus.CANCELLED);\n    expect(orders.getOrder(id)?.status).toBe(OrderStatus.CANCELLED);\n  });\n\n  it('should list orders for a user', () => {\n    const orders = createOrderService(bus);\n    orders.createOrder('user1', 'cart1', 100);\n    orders.createOrder('user1', 'cart2', 200);\n    orders.createOrder('user2', 'cart3', 50);\n    const user1Orders = orders.listOrders('user1');\n    expect(user1Orders).toHaveLength(2);\n  });\n\n  it('should emit ORDER_CREATED event', async () => {\n    const orders = createOrderService(bus);\n    const events: unknown[] = [];\n    bus.on(Events.ORDER_CREATED, (payload) => { events.push(payload); });\n    orders.createOrder('user1', 'cart1', 100);\n    await new Promise(r => setTimeout(r, 10));\n    expect(events).toHaveLength(1);\n  });\n\n  it('should emit ORDER_STATUS_CHANGED with previous status', async () => {\n    const orders = createOrderService(bus);\n    const events: unknown[] = [];\n    bus.on(Events.ORDER_STATUS_CHANGED, (payload) => { events.push(payload); });\n    const id = orders.createOrder('user1', 'cart1', 100);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    await new Promise(r => setTimeout(r, 10));\n    expect(events).toHaveLength(1);\n    const event = events[0] as { orderId: string; status: OrderStatus; previousStatus: OrderStatus };\n    expect(event.previousStatus).toBe(OrderStatus.PENDING);\n    expect(event.status).toBe(OrderStatus.CONFIRMED);\n  });\n});\n\ndescribe('PaymentService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should process successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.SUCCESS);\n    expect(result.transactionId).toBeTruthy();\n  });\n\n  it('should simulate payment failure', async () => {\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.FAILED);\n    expect(result.error).toBeTruthy();\n  });\n\n  it('should simulate payment timeout', async () => {\n    const payment = createPaymentService(bus, { simulateTimeout: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.TIMEOUT);\n    expect(result.error).toBeTruthy();\n  });\n\n  it('should refund a successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    const refunded = await payment.refund(result.transactionId!);\n    expect(refunded).toBe(true);\n  });\n\n  it('should not refund an invalid transaction', async () => {\n    const payment = createPaymentService(bus);\n    const refunded = await payment.refund('invalid');\n    expect(refunded).toBe(false);\n  });\n\n  it('should emit PAYMENT_PROCESSED event', async () => {\n    const payment = createPaymentService(bus);\n    const events: unknown[] = [];\n    bus.on(Events.PAYMENT_PROCESSED, (payload) => { events.push(payload); });\n    await payment.processPayment('order1', 100);\n    expect(events.length).toBeGreaterThanOrEqual(1);\n  });\n});\n\ndescribe('NotificationService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should subscribe users and send notifications on order creation', async () => {\n    const notifications = createNotificationService(bus);\n    notifications.subscribe('user1');\n\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThanOrEqual(1);\n    expect(notifs[0].type).toBe('order_created');\n  });\n\n  it('should not send notifications to unsubscribed users', async () => {\n    const notifications = createNotificationService(bus);\n\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs).toHaveLength(0);\n  });\n\n  it('should track order-user mapping for status changes', async () => {\n    const notifications = createNotificationService(bus);\n    notifications.subscribe('user1');\n\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.ORDER_STATUS_CHANGED, { orderId: 'o1', status: OrderStatus.CONFIRMED, previousStatus: OrderStatus.PENDING });\n\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThanOrEqual(2);\n    expect(notifs.some(n => n.type === 'order_status')).toBe(true);\n  });\n\n  it('should notify on payment events', async () => {\n    const notifications = createNotificationService(bus);\n    notifications.subscribe('user1');\n\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 't1' });\n\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.some(n => n.type === 'payment')).toBe(true);\n  });\n\n  it('should return empty array for user with no notifications', () => {\n    const notifications = createNotificationService(bus);\n    expect(notifications.getNotifications('user1')).toEqual([]);\n  });\n});\n\ndescribe('AnalyticsService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should count events by type', async () => {\n    const analytics = createAnalyticsService(bus);\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'A', price: 10, category: 'c' });\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p2', name: 'B', price: 20, category: 'c' });\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n  });\n\n  it('should return 0 for untracked event types', () => {\n    const analytics = createAnalyticsService(bus);\n    expect(analytics.getEventCount('nonexistent')).toBe(0);\n  });\n\n  it('should track revenue from successful payments', async () => {\n    const analytics = createAnalyticsService(bus);\n\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 't1' });\n\n    expect(analytics.getRevenue()).toBe(100);\n  });\n\n  it('should not count failed payments as revenue', async () => {\n    const analytics = createAnalyticsService(bus);\n\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.FAILED });\n\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  it('should calculate conversion rate', async () => {\n    const analytics = createAnalyticsService(bus);\n\n    // 2 unique carts\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [] });\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c2', userId: 'u2', items: [] });\n\n    // 1 order\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 50 });\n\n    expect(analytics.getConversionRate()).toBe(0.5);\n  });\n\n  it('should return 0 conversion rate with no carts', () => {\n    const analytics = createAnalyticsService(bus);\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n\n  it('should rank products by order quantity', async () => {\n    const analytics = createAnalyticsService(bus);\n\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [{ productId: 'p1', quantity: 5 }, { productId: 'p2', quantity: 2 }] });\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 't1' });\n\n    const top = analytics.getTopProducts(5);\n    expect(top[0].productId).toBe('p1');\n    expect(top[0].count).toBe(5);\n    expect(top[1].productId).toBe('p2');\n    expect(top[1].count).toBe(2);\n  });\n\n  it('should return empty array for top products when no orders', () => {\n    const analytics = createAnalyticsService(bus);\n    expect(analytics.getTopProducts(5)).toEqual([]);\n  });\n});\n\ndescribe('Integration: Full e-commerce flow', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should handle a complete purchase flow', async () => {\n    // Set up all services\n    const catalog = createCatalogService(bus);\n    const inventory = createInventoryService(bus);\n    const cart = createCartService(bus);\n    const pricing = createPricingService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    const notifications = createNotificationService(bus);\n    const analytics = createAnalyticsService(bus);\n\n    // Subscribe user for notifications\n    notifications.subscribe('user1');\n\n    // Create products\n    const productId = catalog.createProduct('Laptop', 999.99, 'electronics');\n    // Wait for async event propagation\n    await new Promise(r => setTimeout(r, 10));\n\n    // Set inventory\n    inventory.setStock(productId, 10);\n    inventory.setLowStockThreshold(productId, 2);\n\n    // Check price was tracked\n    expect(pricing.getPrice(productId)).toBe(999.99);\n\n    // Create cart and add item\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, productId, 1);\n\n    // Calculate total\n    const price = pricing.getPrice(productId);\n    const total = pricing.calculateTotal([{ productId, quantity: 1, price }]);\n    expect(total.subtotal).toBe(999.99);\n    expect(total.tax).toBeCloseTo(100, 0);\n\n    // Reserve inventory\n    expect(inventory.reserve(productId, 1)).toBe(true);\n\n    // Create order\n    const orderId = orders.createOrder('user1', cartId, total.total);\n    await new Promise(r => setTimeout(r, 10));\n\n    // Process payment\n    const paymentResult = await payment.processPayment(orderId, total.total);\n    expect(paymentResult.status).toBe(PaymentStatus.SUCCESS);\n\n    // Update order status\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    orders.updateStatus(orderId, OrderStatus.SHIPPED);\n    orders.updateStatus(orderId, OrderStatus.DELIVERED);\n\n    await new Promise(r => setTimeout(r, 10));\n\n    // Check order\n    const order = orders.getOrder(orderId);\n    expect(order?.status).toBe(OrderStatus.DELIVERED);\n\n    // Check notifications\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThan(0);\n\n    // Check analytics\n    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBeGreaterThanOrEqual(1);\n    expect(analytics.getRevenue()).toBeGreaterThan(0);\n  });\n\n  it('should handle discount codes in pricing', () => {\n    const pricing = createPricingService(bus);\n    pricing.addDiscountCode('HALF', 50);\n\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 2, price: 50 }],\n      'HALF'\n    );\n\n    expect(result.subtotal).toBe(100);\n    expect(result.discount).toBe(50);\n    expect(result.tax).toBe(5); // 10% of 50\n    expect(result.total).toBe(55);\n  });\n\n  it('should handle inventory reservation failures', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 2);\n    expect(inventory.reserve('p1', 3)).toBe(false);\n    expect(inventory.reserve('p1', 2)).toBe(true);\n  });\n});\n","structuredPatch":[{"oldStart":168,"oldLines":9,"newStart":168,"newLines":12,"lines":["     const alerts: unknown[] = [];","     bus.on(Events.LOW_STOCK_ALERT, (payload) => { alerts.push(payload); });"," ","-    inventory.setLowStockThreshold('p1', 5);","     inventory.setStock('p1', 10);"," ","+    // Clear any events from setStock, then set threshold","+    alerts.length = 0;","+    inventory.setLowStockThreshold('p1', 5);","+","     await new Promise(r => setTimeout(r, 10));","     expect(alerts).toHaveLength(0);","   });"]}],"userModified":false,"replaceAll":false}}
