+import { marked } from 'marked';
+import type { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file: ContentFile, _ctx: BuildContext): ContentFile {
+        let content = file.content;
+
+        // Extract footnote definitions before markdown processing
+        const footnoteDefinitions = new Map<string, string>();
+        content = content.replace(/^\[\^(\d+)\]:\s*(.+)$/gm, (_match, id: string, text: string) => {
+          footnoteDefinitions.set(id, text);
+          return '';
+        });
+
+        // Replace footnote references with sup/a tags
+        content = content.replace(/\[\^(\d+)\]/g, (_match, id: string) => {
+          return `<sup><a href="#fn-${id}">${id}</a></sup>`;
+        });
+
+        // Process admonition containers before markdown
+        content = content.replace(/^:::(\w+)\n([\s\S]*?)^:::/gm, (_match, type: string, body: string) => {
+          return `<div class="admonition admonition-${type}">\n${body.trim()}\n</div>`;
+        });
+
+        // Convert markdown to HTML
+        content = marked.parse(content, { async: false }) as string;
+
+        // Append footnote section if there are footnotes
+        if (footnoteDefinitions.size > 0) {
+          let footnoteSection = '<section class="footnotes"><ol>';
+          for (const [id, text] of footnoteDefinitions) {
+            footnoteSection += `<li id="fn-${id}">${text}</li>`;
+          }
+          footnoteSection += '</ol></section>';
+          content += footnoteSection;
+        }
+
+        return { ...file, content };
+      },
+    },
+  };
+}
