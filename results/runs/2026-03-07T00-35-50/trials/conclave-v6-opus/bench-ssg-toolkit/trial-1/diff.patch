itle>\n    <link>${ctx.config.baseUrl}</link>\n    <description>${ctx.config.title} RSS Feed</description>\n${items}\n  </channel>\n</rss>`;\n\n        ctx.output.set('feed.xml', feed);\n      },\n    },\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":449,"cache_read_input_tokens":49919,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":449},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"149a2b1d-04e2-4369-8f92-eb13d6628038","uuid":"94b4c32a-e137-4f36-b3cf-565eac5ba6d0"}
