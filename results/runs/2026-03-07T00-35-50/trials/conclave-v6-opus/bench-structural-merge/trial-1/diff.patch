   if (!branch) {\n   717→+      throw new Error(`Branch \"${name ?? this.currentBranch}\" does not exist`);\n   718→+    }\n   719→+    return branch;\n   720→+  }\n   721→+\n   722→+  private getDoc(id: string): Document {\n   723→+    const branch = this.getBranchData();\n   724→+    const doc = branch.documents.get(id);\n   725→+    if (!doc || doc.deleted) {\n   726→+      throw new Error(`Document \"${id}\" does not exist`);\n   727→+    }\n   728→+    return doc;\n   729→+  }\n   730→+\n   731→+  create(id: string, content: object): void {\n   732→+    const branch = this.getBranchData();\n   733→+    const existing = branch.documents.get(id);\n   734→+    if (existing && !existing.deleted) {\n   735→+      throw new Error(`Document \"${id}\" already exists`);\n   736→+    }\n   737→+    const cloned = structuredClone(content);\n   738→+    const version: Version = {\n   739→+      id: crypto.randomUUID(),\n   740→+      timestamp: Date.now(),\n   741→+      content: structuredClone(cloned),\n   742→+    };\n   743→+    branch.documents.set(id, {\n   744→+      content: cloned,\n   745→+      versions: [version],\n   746→+      deleted: false,\n   747→+    });\n   748→+  }\n   749→+\n   750→+  get(id: string): object {\n   751→+    const doc = this.getDoc(id);\n   752→+    return structuredClone(doc.content);\n   753→+  }\n   754→+\n   755→+  update(id: string, content: object): void {\n   756→+    const doc = this.getDoc(id);\n   757→+    const cloned = structuredClone(content);\n   758→+    const version: Version = {\n   759→+      id: crypto.randomUUID(),\n   760→+      timestamp: Date.now(),\n   761→+      content: structuredClone(cloned),\n   762→+    };\n   763→+    doc.content = cloned;\n   764→+    doc.versions.push(version);\n   765→+  }\n   766→+\n   767→+  delete(id: string): void {\n   768→+    const doc = this.getDoc(id);\n   769→+    doc.deleted = true;\n   770→+  }\n   771→+\n   772→+  getHistory(id: string): Version[] {\n   773→+    const doc = this.getDoc(id);\n   774→+    return doc.versions.map((v) => structuredClone(v));\n   775→+  }\n   776→+\n   777→+  getVersion(id: string, versionId: string): object {\n   778→+    const doc = this.getDoc(id);\n   779→+    const version = doc.versions.find((v) => v.id === versionId);\n   780→+    if (!version) {\n   781→+      throw new Error(`Version \"${versionId}\" not found for document \"${id}\"`);\n   782→+    }\n   783→+    return structuredClone(version.content);\n   784→+  }\n   785→+\n   786→+  private cloneDocuments(docs: Map<string, Document>): Map<string, Document> {\n   787→+    const cloned = new Map<string, Document>();\n   788→+    for (const [id, doc] of docs) {\n   789→+      cloned.set(id, {\n   790→+        content: structuredClone(doc.content),\n   791→+        versions: doc.versions.map((v) => structuredClone(v)),\n   792→+        deleted: doc.deleted,\n   793→+      });\n   794→+    }\n   795→+    return cloned;\n   796→+  }\n   797→+\n   798→+  createBranch(name: string, fromBranch?: string): void {\n   799→+    if (this.branches.has(name)) {\n   800→+      throw new Error(`Branch \"${name}\" already exists`);\n   801→+    }\n   802→+    const source = this.getBranchData(fromBranch ?? this.currentBranch);\n   803→+    const clonedDocs = this.cloneDocuments(source.documents);\n   804→+    const forkSnapshot = this.cloneDocuments(source.documents);\n   805→+    this.branches.set(name, {\n   806→+      documents: clonedDocs,\n   807→+      forkPoint: forkSnapshot,\n   808→+      sourceBranch: fromBranch ?? this.currentBranch,\n   809→+    });\n   810→+  }\n   811→+\n   812→+  switchBranch(name: string): void {\n   813→+    if (!this.branches.has(name)) {\n   814→+      throw new Error(`Branch \"${name}\" does not exist`);\n   815→+    }\n   816→+    this.currentBranch = name;\n   817→+  }\n   818→+\n   819→+  getBranch(): string {\n   820→+    return this.currentBranch;\n   821→+  }\n   822→+\n   823→+  listBranches(): string[] {\n   824→+   