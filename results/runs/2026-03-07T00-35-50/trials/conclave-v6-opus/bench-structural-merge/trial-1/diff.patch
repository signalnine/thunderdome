loned),\n    };\n    doc.content = cloned;\n    doc.versions.push(version);\n  }\n\n  delete(id: string): void {\n    const doc = this.getDoc(id);\n    doc.deleted = true;\n  }\n\n  getHistory(id: string): Version[] {\n    const doc = this.getDoc(id);\n    return doc.versions.map((v) => structuredClone(v));\n  }\n\n  getVersion(id: string, versionId: string): object {\n    const doc = this.getDoc(id);\n    const version = doc.versions.find((v) => v.id === versionId);\n    if (!version) {\n      throw new Error(`Version \"${versionId}\" not found for document \"${id}\"`);\n    }\n    return structuredClone(version.content);\n  }\n\n  private cloneDocuments(docs: Map<string, Document>): Map<string, Document> {\n    const cloned = new Map<string, Document>();\n    for (const [id, doc] of docs) {\n      cloned.set(id, {\n        content: structuredClone(doc.content),\n        versions: doc.versions.map((v) => structuredClone(v)),\n        deleted: doc.deleted,\n      });\n    }\n    return cloned;\n  }\n\n  createBranch(name: string, fromBranch?: string): void {\n    if (this.branches.has(name)) {\n      throw new Error(`Branch \"${name}\" already exists`);\n    }\n    const source = this.getBranchData(fromBranch ?? this.currentBranch);\n    const clonedDocs = this.cloneDocuments(source.documents);\n    const forkSnapshot = this.cloneDocuments(source.documents);\n    this.branches.set(name, {\n      documents: clonedDocs,\n      forkPoint: forkSnapshot,\n      sourceBranch: fromBranch ?? this.currentBranch,\n    });\n  }\n\n  switchBranch(name: string): void {\n    if (!this.branches.has(name)) {\n      throw new Error(`Branch \"${name}\" does not exist`);\n    }\n    this.currentBranch = name;\n  }\n\n  getBranch(): string {\n    return this.currentBranch;\n  }\n\n  listBranches(): string[] {\n    return Array.from(this.branches.keys());\n  }\n\n  merge(_sourceBranch: string): MergeResult {\n    throw new Error('Not implemented');\n  }\n}\n","structuredPatch":[{"oldSta