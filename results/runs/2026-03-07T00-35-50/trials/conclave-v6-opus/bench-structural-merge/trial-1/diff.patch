+
+  test('merged field is present even with no conflicts', () => {
+    store.create('doc1', { name: 'Alice' });
+    store.createBranch('feature');
+    store.switchBranch('feature');
+    store.update('doc1', { name: 'Bob' });
+    store.switchBranch('main');
+    const result = store.merge('feature');
+    expect(result.merged).toHaveProperty('doc1');
+    expect(result.merged['doc1']).toEqual({ name: 'Bob' });
+  });
+});
+
+describe('DocumentStore - Edge Cases', () => {
+  let store: DocumentStore;
+
+  beforeEach(() => {
+    store = new DocumentStore();
+  });
+
+  test('update deep clones the input', () => {
+    store.create('doc1', { name: 'Alice' });
+    const input = { name: 'Bob', nested: { x: 1 } };
+    store.update('doc1', input);
+    input.nested.x = 999;
+    const retrieved = store.get('doc1') as typeof input;
+    expect(retrieved.nested.x).toBe(1);
+  });
+
+  test('multiple documents are independent', () => {
+    store.create('doc1', { name: 'Alice' });
+    store.create('doc2', { name: 'Bob' });
+    store.update('doc1', { name: 'Charlie' });
+    expect(store.get('doc2')).toEqual({ name: 'Bob' });
+  });
+
+  test('deleted document cannot be updated', () => {
+    store.create('doc1', { name: 'Alice' });
+    store.delete('doc1');
+    expect(() => store.update('doc1', { name: 'Bob' })).toThrow();
+  });
+
+  test('deleted document cannot be deleted again', () => {
+    store.create('doc1', { name: 'Alice' });
+    store.delete('doc1');
+    expect(() => store.delete('doc1')).toThrow();
+  });
+
+  test('getHistory throws for nonexistent document', () => {
+    expect(() => store.getHistory('nonexistent')).toThrow();
+  });
+
+  test('getVersion throws for nonexistent version', () => {
+    store.create('doc1', { name: 'Alice' });
+    expect(() => store.getVersion('doc1', 'nonexistent-version-id')).toThrow();
+  });
+
+  test('createBranch throws if branch already exists', () => {
+    store.createBranch('feature');
+    expect(() => store.createBranch('feature')).toThrow();
+  });
+
+  test('documents with nested objects are fully independent across branches', () => {
+    store.create('doc1', { nested: { deep: { value: 1 } } });
+    store.createBranch('feature');
+    store.switchBranch('feature');
+    const doc = store.get('doc1') as Record<string, Record<string, Record<string, number>>>;
+    doc.nested.deep.value = 999;
+    store.update('doc1', doc);
+    store.switchBranch('main');
+    const mainDoc = store.get('doc1') as Record<string, Record<string, Record<string, number>>>;
+    expect(mainDoc.nested.deep.value).toBe(1);
+  });
+});
