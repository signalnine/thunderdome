ain = store.get('doc1') as typeof original;\n    expect(again.nested.x).toBe(1);\n  });\n\n  test('create deep clones the input', () => {\n    const input = { name: 'Alice', nested: { x: 1 } };\n    store.create('doc1', input);\n    input.nested.x = 999;\n    const retrieved = store.get('doc1') as typeof input;\n    expect(retrieved.nested.x).toBe(1);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":399,"cache_read_input_tokens":29818,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":399},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"7a14b595-692b-4acf-9aa9-9e52d904e42a","uuid":"89f97686-9e09-4f28-ac29-deceae2aa47b"}
