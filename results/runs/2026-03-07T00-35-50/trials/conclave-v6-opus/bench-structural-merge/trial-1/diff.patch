ainDoc.nested.deep.value).toBe(1);\n  });\n});"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":333,"cache_read_input_tokens":59193,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":333},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"7a14b595-692b-4acf-9aa9-9e52d904e42a","uuid":"6a2d22a7-ac51-4110-84d5-f57ce38ecab1"}
