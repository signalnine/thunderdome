+import type { Conflict } from './types.js';
+
+type JsonValue = string | number | boolean | null | JsonValue[] | { [key: string]: JsonValue };
+type JsonObject = Record<string, JsonValue>;
+
+interface ThreeWayResult {
+  merged: JsonObject;
+  conflicts: Conflict[];
+}
+
+function isPlainObject(val: unknown): val is JsonObject {
+  return typeof val === 'object' && val !== null && !Array.isArray(val);
+}
+
+function deepEqual(a: unknown, b: unknown): boolean {
+  if (a === b) return true;
+  if (typeof a !== typeof b) return false;
+  if (a === null || b === null) return a === b;
+  if (Array.isArray(a) && Array.isArray(b)) {
+    if (a.length !== b.length) return false;
+    return a.every((v, i) => deepEqual(v, b[i]));
+  }
+  if (isPlainObject(a) && isPlainObject(b)) {
+    const keysA = Object.keys(a);
+    const keysB = Object.keys(b);
+    if (keysA.length !== keysB.length) return false;
+    return keysA.every((k) => k in b && deepEqual(a[k], b[k]));
+  }
+  return false;
+}
+
+export function threeWayMerge(
+  documentId: string,
+  base: Record<string, unknown>,
+  ours: Record<string, unknown>,
+  theirs: Record<string, unknown>,
+): ThreeWayResult {
+  const conflicts: Conflict[] = [];
+  const merged = mergeObjects(documentId, '', base as JsonObject, ours as JsonObject, theirs as JsonObject, conflicts);
+  return { merged, conflicts };
+}
+
+function mergeObjects(
+  documentId: string,
+  prefix: string,
+  base: JsonObject,
+  ours: JsonObject,
+  theirs: JsonObject,
+  conflicts: Conflict[],
+): JsonObject {
+  const result: JsonObject = {};
+  const allKeys = new Set([...Object.keys(base), ...Object.keys(ours), ...Object.keys(theirs)]);
+
+  for (const key of allKeys) {
+    const path = prefix ? `${prefix}.${key}` : key;
+    const baseVal = base[key];
+    const oursVal = ours[key];
+    const theirsVal = theirs[key];
+
+    const baseHas = key in base;
+    const oursHas = key in ours;
+    const theirsHas = key in theirs;
+
+    const oursChanged = !deepEqual(baseVal, oursVal) || (baseHas !== oursHas);
+    const theirsChanged = !deepEqual(baseVal, theirsVal) || (baseHas !== theirsHas);
+
+    if (!oursChanged && !theirsChanged) {
+      // Neither changed - use base value (if it exists)
+      if (baseHas) {
+        result[key] = structuredClone(baseVal) as JsonValue;
+      }
+    } else if (oursChanged && !theirsChanged) {
+      // Only ours changed - take ours
+      if (oursHas) {
+        result[key] = structuredClone(oursVal) as JsonValue;
+      }
+      // If ours deleted it (oursHas=false), don't add to result
+    } else if (!oursChanged && theirsChanged) {
+      // Only theirs changed - take theirs
+      if (theirsHas) {
+        result[key] = structuredClone(theirsVal) as JsonValue;
+      }
+      // If theirs deleted it, don't add to result
+    } else {
+      // Both changed
+      if (deepEqual(oursVal, theirsVal)) {
+        // Both changed to the same value - no conflict
+        if (oursHas) {
+          result[key] = structuredClone(oursVal) as JsonValue;
+        }
+      } else if (isPlainObject(baseVal) && isPlainObject(oursVal) && isPlainObject(theirsVal)) {
+        // Both are objects - recurse
+        result[key] = mergeObjects(documentId, path, baseVal, oursVal, theirsVal, conflicts);
+      } else {
+        // Conflict - take ours for the merged output
+        conflicts.push({
+          documentId,
+          path,
+          base: structuredClone(baseVal),
+          ours: structuredClone(oursVal),
+          theirs: structuredClone(theirsVal),
+        });
+        if (oursHas) {
+          result[key] = structuredClone(oursVal) as JsonValue;
+        }
+      }
+    }
+  }
+
+  return result;
+}
