1');\n    expect(result).toEqual({ name: 'Alice', age: 30 });\n  });\n\n  test('create throws if document ID already exists', () => {\n    store.create('doc1', { name: 'Alice' });\n    expect(() => store.create('doc1', { name: 'Bob' })).toThrow();\n  });\n\n  test('get throws if document does not exist', () => {\n    expect(() => store.get('nonexistent')).toThrow();\n  });\n\n  test('update replaces document content', () => {\n    store.create('doc1', { name: 'Alice' });\n    store.update('doc1', { name: 'Bob', role: 'admin' });\n    expect(store.get('doc1')).toEqual({ name: 'Bob', role: 'admin' });\n  });\n\n  test('update throws if document does not exist', () => {\n    expect(() => store.update('nonexistent', { name: 'Bob' })).toThrow();\n  });\n\n  test('delete removes a document', () => {\n    store.create('doc1', { name: 'Alice' });\n    store.delete('doc1');\n    expect(() => store.get('doc1')).toThrow();\n  });\n\n  test('delete throws if document does not exist', () => {\n    expect(() => store.delete('nonexistent')).toThrow();\n  });\n\n  test('get returns a deep clone, not a reference', () => {\n    const original = { name: 'Alice', nested: { x: 1 } };\n    store.create('doc1', original);\n    const retrieved = store.get('doc1') as typeof original;\n    retrieved.nested.x = 999;\n    const again = store.get('doc1') as typeof original;\n    expect(again.nested.x).toBe(1);\n  });\n\n  test('create deep clones the input', () => {\n    const input = { name: 'Alice', nested: { x: 1 } };\n    store.create('doc1', input);\n    input.nested.x = 999;\n    const retrieved = store.get('doc1') as typeof input;\n    expect(retrieved.nested.x).toBe(1);\n  });\n});\n\ndescribe('DocumentStore - Version History', () => {\n  let store: DocumentStore;\n\n  beforeEach(() => {\n    store = new DocumentStore();\n  });\n\n  test('create generates a version', () => {\n    store.create('doc1', { name: 'Alice' });\n    const history = store.getHistory('doc1');\n    expect(history).toHaveLength(1);\n    expect(history[0].content).toEqual({ name: 'Alice' });\n    expect(typeof history[0].id).toBe('string');\n    expect(typeof history[0].timestamp).toBe('number');\n  });\n\n  test('update generates additional versions', () => {\n    store.create('doc1', { name: 'Alice' });\n    store.update('doc1', { name: 'Bob' });\n    store.update('doc1', { name: 'Charlie' });\n    const history = store.getHistory('doc1');\n    expect(history).toHaveLength(3);\n    expect(history[0].content).toEqual({ name: 'Alice' });\n    expect(history[1].content).toEqual({ name: 'Bob' });\n    expect(history[2].content).toEqual({ name: 'Charlie' });\n  });\n\n  test('versions are in chronological order', () => {\n    store.create('doc1', { v: 1 });\n    store.update('doc1', { v: 2 });\n    const history = store.getHistory('doc1');\n    expect(history[0].timestamp).toBeLessThanOrEqual(history[1].timestamp);\n  });\n\n  test('each version has a unique id', () => {\n    store.create('doc1', { v: 1 });\n    store.update('doc1', { v: 2 });\n    const history = store.getHistory('doc1');\n    expect(history[0].id).not.toBe(history[1].id);\n  });\n\n  test('getVersion returns content at a specific version', () => {\n    store.create('doc1', { name: 'Alice' });\n    store.update('doc1', { name: 'Bob' });\n    const history = store.getHistory('doc1');\n    expect(store.getVersion('doc1', history[0].id)).toEqual({ name: 'Alice' });\n    expect(store.getVersion('doc1', history[1].id)).toEqual({ name: 'Bob' });\n  });\n\n  test('getHistory returns deep cloned versions', () => {\n    store.create('doc1', { nested: { x: 1 } });\n    const history = store.getHistory('doc1');\n    (history[0].content as Record<string, unknown>).nested = { x: 999 };\n    const again = store.getHistory('doc1');\n    expect((again[0].content as Record<string, Record<string, number>>).nested.x).toBe(1);\n  });\n\n  test('getVersion returns deep cloned content', () => {\n    store.create('doc1', { nested: { x: 1 } });\n    const history = store.getHistory('doc1');\n    const content = store.getVersion('doc1', history[0].id) as Record<string, Record<string, number>>;\n    content.nested.x = 999;\n    const again = store.getVersion('doc1', history[0].id) as Record<string, Record<string, number>>;\n    expect(again.nested.x).toBe(1);\n  });\n});\n\ndescribe('DocumentStore - Branching', () => {\n  let store: DocumentStore;\n\n  beforeEach(() => {\n    store = new DocumentStore();\n  });\n\n  test('default branch is main', () => {\n    expect(store.getBranch()).toBe('main');\n  });\n\n  test('listBranches returns all branch names', () => {\n    expect(store.listBranches()).toEqual(['main']);\n  });\n\n  test('createBranch creates a new branch from current branch', () => {\n    store.create('doc1', { name: 'Alice' });\n    store.createBranch('feature');\n    expect(store.listBranches()).toContain('feature');\n    expect(store.listBranches()).toContain('main');\n  });\n\n  test('switchBranch changes the active branch', () => {\n    store.createBranch('feature');\n    store.switchBranch('feature');\n    expect(store.getBranch()).toBe('feature');\n  });\n\n  test('switchBranch throws for nonexistent branch', () => {\n    expect(() => store.switchBranch('nonexistent')).toThrow();\n  });\n\n  test('new branch inherits documents from source branch', () => {\n    store.create('doc1', { name: 'Alice' });\n    store.createBranch('feature');\n    store.switchBranch('feature');\n    expect(store.get('doc1')).toEqual({ name: 'Alice' });\n  });\n\n  test('changes on one branch are not visible on another', () => {\n    store.create('doc1', { name: 'Alice' });\n    store.createBranch('feature');\n    store.switchBranch('feature');\n    store.update('doc1', { name: 'Bob' });\n    store.switchBranch('main');\n    expect(store.get('doc1')).toEqual({ name: 'Alice' });\n  });\n\n  test('documents created on a branch are not visible on other branches', () => {\n    store.createBranch('feature');\n    store.switchBranch('feature');\n    store.create('doc1', { name: 'Alice' });\n    store.switchBranch('main');\n    expect(() => store.get('doc1')).toThrow();\n  });\n\n  test('createBranch from a specific branch', () => {\n    store.create('doc1', { name: 'Alice' });\n    store.createBranch('feature');\n    store.switchBranch('feature');\n    store.update('doc1', { name: 'Bob' });\n    store.createBranch('feature2', 'main');\n    store.switchBranch('feature2');\n    expect(store.get('doc1')).toEqual({ name: 'Alice' });\n  });\n\n  test('deleting a document on one branch does not affect another', () => {\n    store.create('doc1', { name: 'Alice' });\n    store.createBranch('feature');\n    store.switchBranch('feature');\n    store.delete('doc1');\n    store.switchBranch('main');\n    expect(store.get('doc1')).toEqual({ name: 'Alice' });\n  });\n\n  test('version history is branch-independent', () => {\n    store.create('doc1', { name: 'Alice' });\n    store.createBranch('feature');\n    store.switchBranch('feature');\n    store.update('doc1', { name: 'Bob' });\n    const featureHistory = store.getHistory('doc1');\n    store.switchBranch('main');\n    const mainHistory = store.getHistory('doc1');\n    expect(featureHistory).toHaveLength(2);\n    expect(mainHistory).toHaveLength(1);\n  });\n});\n","numLines":218,"startLine":1,"totalLines":218}}}
