+import type { Version, MergeResult, Conflict } from './types.js';
+import { threeWayMerge } from './merge.js';
+
+interface Document {
+  content: object;
+  versions: Version[];
+  deleted: boolean;
+}
+
+interface BranchData {
+  documents: Map<string, Document>;
+  forkPoint: Map<string, Document> | null;
+  sourceBranch: string | null;
+}
+
+export class DocumentStore {
+  private branches: Map<string, BranchData> = new Map();
+  private currentBranch: string = 'main';
+
+  constructor() {
+    this.branches.set('main', { documents: new Map(), forkPoint: null, sourceBranch: null });
+  }
+
+  private getBranchData(name?: string): BranchData {
+    const branch = this.branches.get(name ?? this.currentBranch);
+    if (!branch) {
+      throw new Error(`Branch "${name ?? this.currentBranch}" does not exist`);
+    }
+    return branch;
+  }
+
+  private getDoc(id: string): Document {
+    const branch = this.getBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    return doc;
+  }
+
+  create(id: string, content: object): void {
+    const branch = this.getBranchData();
+    const existing = branch.documents.get(id);
+    if (existing && !existing.deleted) {
+      throw new Error(`Document "${id}" already exists`);
+    }
+    const cloned = structuredClone(content);
+    const version: Version = {
+      id: crypto.randomUUID(),
+      timestamp: Date.now(),
+      content: structuredClone(cloned),
+    };
+    branch.documents.set(id, {
+      content: cloned,
+      versions: [version],
+      deleted: false,
+    });
+  }
+
+  get(id: string): object {
+    const doc = this.getDoc(id);
+    return structuredClone(doc.content);
+  }
+
+  update(id: string, content: object): void {
+    const doc = this.getDoc(id);
+    const cloned = structuredClone(content);
+    const version: Version = {
+      id: crypto.randomUUID(),
+      timestamp: Date.now(),
+      content: structuredClone(cloned),
+    };
+    doc.content = cloned;
+    doc.versions.push(version);
+  }
+
+  delete(id: string): void {
+    const doc = this.getDoc(id);
+    doc.deleted = true;
+  }
+
+  getHistory(id: string): Version[] {
+    const doc = this.getDoc(id);
+    return doc.versions.map((v) => structuredClone(v));
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const doc = this.getDoc(id);
+    const version = doc.versions.find((v) => v.id === versionId);
+    if (!version) {
+      throw new Error(`Version "${versionId}" not found for document "${id}"`);
+    }
+    return structuredClone(version.content);
+  }
+
+  private cloneDocuments(docs: Map<string, Document>): Map<string, Document> {
+    const cloned = new Map<string, Document>();
+    for (const [id, doc] of docs) {
+      cloned.set(id, {
+        content: structuredClone(doc.content),
+        versions: doc.versions.map((v) => structuredClone(v)),
+        deleted: doc.deleted,
+      });
+    }
+    return cloned;
+  }
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch "${name}" already exists`);
+    }
+    const source = this.getBranchData(fromBranch ?? this.currentBranch);
+    const clonedDocs = this.cloneDocuments(source.documents);
+    const forkSnapshot = this.cloneDocuments(source.documents);
+    this.branches.set(name, {
+      documents: clonedDocs,
+      forkPoint: forkSnapshot,
+      sourceBranch: fromBranch ?? this.currentBranch,
+    });
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch "${name}" does not exist`);
+    }
+    this.currentBranch = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranch;
+  }
+
+  listBranches(): string[] {
+    return Array.from(this.branches.keys());
+  }
+
+  merge(sourceBranch: string): MergeResult {
+    const sourceBranchData = this.getBranchData(sourceBranch);
+    const currentBranchData = this.getBranchData();
+
+    // The common ancestor is the fork point of the source branch
+    // (the snapshot of documents at the time the source branch was created)
+    const base = sourceBranchData.forkPoint ?? new Map<string, Document>();
+
+    const allDocIds = new Set<string>();
+    for (const id of base.keys()) allDocIds.add(id);
+    for (const id of currentBranchData.documents.keys()) allDocIds.add(id);
+    for (const id of sourceBranchData.documents.keys()) allDocIds.add(id);
+
+    const merged: Record<string, object> = {};
+    const allConflicts: Conflict[] = [];
+    let hasChanges = false;
+
+    for (const docId of allDocIds) {
+      const baseDoc = base.get(docId);
+      const oursDoc = currentBranchData.documents.get(docId);
+      const theirsDoc = sourceBranchData.documents.get(docId);
+
+      const baseContent = baseDoc && !baseDoc.deleted ? baseDoc.content : null;
+      const oursContent = oursDoc && !oursDoc.deleted ? oursDoc.content : null;
+      const theirsContent = theirsDoc && !theirsDoc.deleted ? theirsDoc.content : null;
+
+      const baseObj = baseContent as Record<string, unknown> | null;
+      const oursObj = oursContent as Record<string, unknown> | null;
+      const theirsObj = theirsContent as Record<string, unknown> | null;
+
+      // Check if there are any changes
+      const oursChanged = !this.contentEqual(baseObj, oursObj);
+      const theirsChanged = !this.contentEqual(baseObj, theirsObj);
+
+      if (!oursChanged && !theirsChanged) {
+        // No changes on either side
+        if (oursObj) {
+          merged[docId] = structuredClone(oursObj);
+        }
+        continue;
+      }
+
+      hasChanges = true;
+
+      if (oursChanged && !theirsChanged) {
+        // Only current branch changed
+        if (oursObj) {
+          merged[docId] = structuredClone(oursObj);
+        }
+        // If ours deleted it, it stays deleted (don't add to merged)
+        continue;
+      }
+
+      if (!oursChanged && theirsChanged) {
+        // Only source branch changed
+        if (theirsObj) {
+          merged[docId] = structuredClone(theirsObj);
+        }
+        // If theirs deleted it, apply delete
+        continue;
+      }
+
+      // Both changed
+      if (this.contentEqual(oursObj, theirsObj)) {
+        // Both changed to the same thing
+        if (oursObj) {
+          merged[docId] = structuredClone(oursObj);
+        }
+        continue;
+      }
+
+      // Both changed differently - need three-way merge at field level
+      // Handle deletion cases as document-level conflicts
+      if (!oursObj || !theirsObj || !baseObj) {
+        // One side deleted, other modified (or both created differently)
+        // Treat as document-level situation
+        if (oursObj && theirsObj) {
+          // Both exist but no base - new doc on both sides
+          const result = threeWayMerge(docId, {} as Record<string, unknown>, oursObj, theirsObj);
+          merged[docId] = result.merged;
+          allConflicts.push(...result.conflicts);
+        } else {
+          // One deleted, one modified - take whatever exists for merged output
+          const existing = oursObj ?? theirsObj;
+          if (existing) {
+            merged[docId] = structuredClone(existing);
+          }
+        }
+        continue;
+      }
+
+      const result = threeWayMerge(docId, baseObj, oursObj, theirsObj);
+      merged[docId] = result.merged;
+      allConflicts.push(...result.conflicts);
+    }
+
+    const applied = allConflicts.length === 0;
+
+    if (applied && hasChanges) {
+      // Auto-apply: update current branch with merged content
+      for (const docId of allDocIds) {
+        if (docId in merged) {
+          const mergedContent = merged[docId];
+          const oursDoc = currentBranchData.documents.get(docId);
+          if (oursDoc && !oursDoc.deleted) {
+            // Update existing doc
+            const cloned = structuredClone(mergedContent);
+            const version: Version = {
+              id: crypto.randomUUID(),
+              timestamp: Date.now(),
+              content: structuredClone(cloned),
+            };
+            oursDoc.content = cloned;
+            oursDoc.versions.push(version);
+          } else {
+            // Create new doc (was added on source branch)
+            const cloned = structuredClone(mergedContent);
+            const version: Version = {
+              id: crypto.randomUUID(),
+              timestamp: Date.now(),
+              content: structuredClone(cloned),
+            };
+            currentBranchData.documents.set(docId, {
+              content: cloned,
+              versions: [version],
+              deleted: false,
+            });
+          }
+        } else {
+          // Document was deleted
+          const oursDoc = currentBranchData.documents.get(docId);
+          if (oursDoc) {
+            oursDoc.deleted = true;
+          }
+        }
+      }
+    }
+
+    return { merged, conflicts: allConflicts, applied };
+  }
+
+  private contentEqual(a: Record<string, unknown> | null, b: Record<string, unknown> | null): boolean {
+    if (a === null && b === null) return true;
+    if (a === null || b === null) return false;
+    return JSON.stringify(a) === JSON.stringify(b);
+  }
+}
