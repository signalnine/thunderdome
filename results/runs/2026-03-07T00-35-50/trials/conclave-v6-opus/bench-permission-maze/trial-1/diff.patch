Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'viewer',\n        });\n\n      expect(res.status).toBe(201);\n      expect(res.body.userId).toBe(bobId);\n      expect(res.body.role).toBe('viewer');\n    });\n\n    it('allows shared viewer to read folder', async () => {\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'viewer',\n        });\n\n      const res = await request(app)\n        .get(`/folders/${folderId}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe('Shared Folder');\n    });\n\n    it('returns 400 if required fields are missing', async () => {\n      const res = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ resourceType: 'folder' });\n\n      expect(res.status).toBe(400);\n    });\n\n    it('returns 400 for invalid role', async () => {\n      const res = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'superadmin',\n        });\n\n      expect(res.status).toBe(400);\n    });\n\n    it('returns 404 if target user does not exist', async () => {\n      const res = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: 'nonexistent',\n          role: 'viewer',\n        });\n\n      expect(res.status).toBe(404);\n    });\n\n    it('returns 404 if resource does not exist', async () =