  res.status(400).json({ error: 'resourceType, resourceId, targetUserId, and role are required' });","+      return;","+    }","+","+    if (!['viewer', 'editor', 'owner'].includes(role)) {","+      res.status(400).json({ error: 'Invalid role. Must be viewer, editor, or owner' });","+      return;","+    }","+","+    if (!['folder', 'document'].includes(resourceType)) {","+      res.status(400).json({ error: 'Invalid resourceType. Must be folder or document' });","+      return;","+    }","+","+    // Check target user exists","+    if (!store.users.has(targetUserId)) {","+      res.status(404).json({ error: 'Target user not found' });","+      return;","+    }","+","+    // Check resource exists","+    if (resourceType === 'folder' && !store.folders.has(resourceId)) {","+      res.status(404).json({ error: 'Folder not found' });","+      return;","+    }","+    if (resourceType === 'document' && !store.documents.has(resourceId)) {","+      res.status(404).json({ error: 'Document not found' });","+      return;","+    }","+","+    // Check sharer has permission (editor or owner)","+    const sharerRole = getEffectiveRole(store, userId, resourceType, resourceId);","+    if (!sharerRole || sharerRole === 'viewer') {","+      res.status(403).json({ error: 'Forbidden' });","+      return;","+    }","+","+    // Only owners can grant owner role","+    if (role === 'owner' && sharerRole !== 'owner') {","+      res.status(403).json({ error: 'Only owners can grant owner role' });","+      return;","+    }","+","+    // Update existing share or create new one","+    const existingShare = store.shares.find(","+      s => s.resourceType === resourceType && s.resourceId === resourceId && s.userId === targetUserId","+    );","+","+    if (existingShare) {","+      existingShare.role = role;","+      addActivity(store, 'share_updated', userId, resourceType, resourceId, `Shared with user ${targetUserId} as ${role}`);","+      res.json(existingShare);","+    } else {","+      const share: Share = {","+        id: generateId(),","+        resourceType,","+        resourceId,","+        userId: targetUserId,","+        role,","+      };","+      store.shares.push(share);","+      addActivity(store, 'share_created', userId, resourceType, resourceId, `Shared with user ${targetUserId} as ${role}`);","+      res.status(201).json(share);","+    }","+  });","+","+  // --- Activity log ---","+","+  app.get('/activity', auth, (req: AuthRequest, res: Response) => {","+    const userId = req.userId!;","+","+    // Return activity for resources the user has access to","+    const visibleActivity = store.activity.filter(entry => {","+      const role = getEffectiveRole(store, userId, entry.resourceType, entry.resourceId);","+      return role !== null;","+    });","+","+    res.json(visibleActivity);","+  });","+","   return app;"," }"]}],"originalFile":"import express from 'express';\n\nexport function createApp() {\n  const app = express();\n  app.use(express.json());\n  return app;\n}\n"}}
