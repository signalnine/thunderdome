+        .send({ title: 'Hacked' });
+
+      expect(res.status).toBe(403);
+    });
+
+    it('allows editor to update document', async () => {
+      const createRes = await request(app)
+        .post(`/folders/${folderId}/documents`)
+        .set('Authorization', `Bearer ${token}`)
+        .send({ title: 'Doc', content: 'Content' });
+
+      const bob = await registerAndLogin(app, 'bob', 'pass');
+
+      await request(app)
+        .post('/share')
+        .set('Authorization', `Bearer ${token}`)
+        .send({
+          resourceType: 'document',
+          resourceId: createRes.body.id,
+          targetUserId: bob.userId,
+          role: 'editor',
+        });
+
+      const res = await request(app)
+        .put(`/documents/${createRes.body.id}`)
+        .set('Authorization', `Bearer ${bob.token}`)
+        .send({ content: 'Updated by Bob' });
+
+      expect(res.status).toBe(200);
+      expect(res.body.content).toBe('Updated by Bob');
+    });
+  });
+
+  describe('DELETE /documents/:id', () => {
+    it('deletes a document owned by the user', async () => {
+      const createRes = await request(app)
+        .post(`/folders/${folderId}/documents`)
+        .set('Authorization', `Bearer ${token}`)
+        .send({ title: 'To Delete', content: 'Content' });
+
+      const deleteRes = await request(app)
+        .delete(`/documents/${createRes.body.id}`)
+        .set('Authorization', `Bearer ${token}`);
+
+      expect(deleteRes.status).toBe(204);
+
+      const getRes = await request(app)
+        .get(`/documents/${createRes.body.id}`)
+        .set('Authorization', `Bearer ${token}`);
+
+      expect(getRes.status).toBe(404);
+    });
+
+    it('returns 403 for non-owner (editor)', async () => {
+      const createRes = await request(app)
+        .post(`/folders/${folderId}/documents`)
+        .set('Authorization', `Bearer ${token}`)
+        .send({ title: 'Doc', content: 'Content' });
+
+      const bob = await registerAndLogin(app, 'bob', 'pass');
+
+      await request(app)
+        .post('/share')
+        .set('Authorization', `Bearer ${token}`)
+        .send({
+          resourceType: 'document',
+          resourceId: createRes.body.id,
+          targetUserId: bob.userId,
+          role: 'editor',
+        });
+
+      const res = await request(app)
+        .delete(`/documents/${createRes.body.id}`)
+        .set('Authorization', `Bearer ${bob.token}`);
+
+      expect(res.status).toBe(403);
+    });
+
+    it('returns 404 for nonexistent document', async () => {
+      const res = await request(app)
+        .delete('/documents/nonexistent')
+        .set('Authorization', `Bearer ${token}`);
+
+      expect(res.status).toBe(404);
+    });
+  });
+});
