  });\n\n    it('allows shared viewer to read folder', async () => {\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'viewer',\n        });\n\n      const res = await request(app)\n        .get(`/folders/${folderId}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe('Shared Folder');\n    });\n\n    it('returns 400 if required fields are missing', async () => {\n      const res = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ resourceType: 'folder' });\n\n      expect(res.status).toBe(400);\n    });\n\n    it('returns 400 for invalid role', async () => {\n      const res = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'superadmin',\n        });\n\n      expect(res.status).toBe(400);\n    });\n\n    it('returns 404 if target user does not exist', async () => {\n      const res = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: 'nonexistent',\n          role: 'viewer',\n        });\n\n      expect(res.status).toBe(404);\n    });\n\n    it('returns 404 if resource does not exist', async () => {\n      const res = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: 'nonexistent',\n          targetUserId: bobId,\n          role: 'viewer',\n        });\n\n      expect(res.status).toBe(404);\n    });\n\n    it('returns 403 if viewer tries to share', async () => {\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'viewer',\n        });\n\n      const charlie = await registerAndLogin(app, 'charlie', 'pass');\n\n      const res = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: charlie.userId,\n          role: 'viewer',\n        });\n\n      expect(res.status).toBe(403);\n    });\n\n    it('allows editor to share with others', async () => {\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'editor',\n        });\n\n      const charlie = await registerAndLogin(app, 'charlie', 'pass');\n\n      const res = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: charlie.userId,\n          role: 'viewer',\n        });\n\n      expect(res.status).toBe(201);\n    });\n\n    it('only owners can grant owner role', async () => {\n      // Make bob an editor\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'editor',\n        });\n\n      const charlie = await registerAndLogin(app, 'charlie', 'pass');\n\n      // Bob (editor) tries to grant owner\n      const res = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: charlie.userId,\n          role: 'owner',\n        });\n\n      expect(res.status).toBe(403);\n    });\n\n    it('owner can grant owner role', async () => {\n      const res = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'owner',\n        });\n\n      expect(res.status).toBe(201);\n      expect(res.body.role).toBe('owner');\n    });\n\n    it('updates existing share role', async () => {\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'viewer',\n        });\n\n      const res = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'editor',\n        });\n\n      expect(res.status).toBe(200);\n      expect(res.body.role).toBe('editor');\n    });\n\n    it('shares a document with another user', async () => {\n      const docRes = await request(app)\n        .post(`/folders/${folderId}/documents`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Shared Doc', content: 'Content' });\n\n      const res = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'document',\n          resourceId: docRes.body.id,\n          targetUserId: bobId,\n          role: 'viewer',\n        });\n\n      expect(res.status).toBe(201);\n\n      // Bob 