egisterAndLogin(app, 'charlie', 'pass');\n\n      // Bob (editor) tries to grant owner\n      const res = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: charlie.userId,\n          role: 'owner',\n        });\n\n      expect(res.status).toBe(403);\n    });\n\n    it('owner can grant owner role', async () => {\n      const res = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'owner',\n        });\n\n      expect(res.status).toBe(201);\n      expect(res.body.role).toBe('owner');\n    });\n\n    it('updates existing share role', async () => {\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'viewer',\n        });\n\n      const res = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'editor',\n        });\n\n      expect(res.status).toBe(200);\n      expect(res.body.role).toBe('editor');\n    });\n\n    it('shares a document with another user', async () => {\n      const docRes = await request(app)\n        .post(`/folders/${folderId}/documents`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Shared Doc', content: 'Content' });\n\n      const res = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'document',\n          resourceId: docRes.bod