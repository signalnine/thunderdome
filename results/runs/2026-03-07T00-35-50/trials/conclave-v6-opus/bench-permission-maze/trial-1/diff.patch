on', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: 'nonexistent',\n          targetUserId: bobId,\n          role: 'viewer',\n        });\n\n      expect(res.status).toBe(404);\n    });\n\n    it('returns 403 if viewer tries to share', async () => {\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'viewer',\n        });\n\n      const charlie = await registerAndLogin(app, 'charlie', 'pass');\n\n      const res = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: charlie.userId,\n          role: 'viewer',\n        });\n\n      expect(res.status).toBe(403);\n    });\n\n    it('allows editor to share with others', async () => {\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'editor',\n        });\n\n      const charlie = await registerAndLogin(app, 'charlie', 'pass');\n\n      const res = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: charlie.userId,\n          role: 'viewer',\n        });\n\n      expect(res.status).toBe(201);\n    });\n\n    it('only owners can grant owner role', async () => {\n      // Make bob an editor\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'editor',\n        });\n\n      const charlie = await registerAndLogin(app, 'charlie', 'pass');\n\n      // Bob (editor) tries to grant owner\n      const res = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: charlie.userId,\n          role: 'owner',\n        });\n\n      expect(res.status).toBe(403);\n    });\n\n    it('owner can grant owner role', async () => {\n      const res = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'owner',\n        });\n\n      expect(res.status).toBe(201);\n      expect(res.body.role).toBe('owner');\n    });\n\n    it('updates existing share role', async () => {\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'viewer',\n        });\n\n      const res = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'editor',\n        });\n\n      expect(res.status).toBe(200);\n      expect(res.body.role).toBe('editor');\n    });\n\n    it('shares a document with another user', async () => {\n      const docRes = await request(app)\n        .post(`/folders/${folderId}/documents`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Shared Doc', content: 'Content' });\n\n      const res = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'document',\n          resourceId: docRes.body.id,\n          targetUserId: bobId,\n          role: 'viewer',\n        });\n\n      expect(res.status).toBe(201);\n\n      // Bob can now read the document\n      const getRes = await request(app)\n        .get(`/documents/${docRes.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n\n      expect(getRes.status).toBe(200);\n      expect(getRes.body.title).toBe('Shared Doc');\n    });\n  });\n\n  describe('Permission inheritance', () => {\n    it('folder viewer can read documents in the folder', async () => {\n      const docRes = await request(app)\n        .post(`/folders/${folderId}/documents`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Doc in Folder', content: 'Content' });\n\n      // Share folder as viewer with bob\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'viewer',\n        });\n\n      const res = await request(app)\n        .get(`/documents/${docRes.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n\n      expect(res.status).toBe(200);\n    });\n\n    it('folder editor can edit documents in the folder', async () => {\n      const docRes = await request(app)\n        .post(`/folders/${folderId}/documents`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Doc', content: 'Original' });\n\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'editor',\n        });\n\n      const res = await request(app)\n        .put(`/documents/${docRes.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ content: 'Edited by Bob' });\n\n      expect(res.status).toBe(200);\n      expect(res.body.content).toBe('Edited by Bob');\n    });\n\n    it('most permissive role wins when accessed through multiple paths', async () => {\n      const docRes = await request(app)\n        .post(`/folders/${folderId}/documents`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Doc', content: 'Content' });\n\n      // Share folder as viewer\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'viewer',\n        });\n\n      // Share document directly as editor\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'document',\n          resourceId: docRes.body.id,\n          targetUserId: bobId,\n          role: 'editor',\n        });\n\n      // Bob should be able to edit (editor > viewer)\n      const res = await request(app)\n        .put(`/documents/${docRes.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ content: 'Edited' });\n\n      expect(res.status).toBe(200);\n    });\n\n    it('nested folder inherits parent folder permissions', async () => {\n      // Create nested folder structure\n      const childRes = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Child', parentId: folderId });\n\n      // Share parent folder with bob as viewer\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'viewer',\n        });\n\n      // Bob should be able to read the child folder\n      const res = await request(app)\n        .get(`/folders/${childRes.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n\n      expect(res.status).toBe(200);\n    });\n\n    it('document in nested folder inherits grandparent folder permissions', async () => {\n      // Create: Parent Folder > Child Folder > Document\n      const childRes = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Child', parentId: folderId });\n\n      const docRes = await request(app)\n        .post(`/folders/${childRes.body.id}/documents`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Deep Doc', content: 'Nested' });\n\n      // Share top-level folder with bob as editor\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'editor',\n        });\n\n      // Bob should be able to edit the deeply nested document\n      const res = await request(app)\n        .put(`/documents/${docRes.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ content: 'Edited by Bob' });\n\n      expect(res.status).toBe(200);\n      expect(res.body.content).toBe('Edited by Bob');\n    });\n  });\n});\n","structuredPatch":[{"oldStart":25,"oldLines":7,"newStart":25,"newLines":7,"lines":["     app = createApp();","     const alice = await registerAndLogin(app, 'alice', 'pass');","     aliceToken = alice.token;","-    aliceId = alice.userId;","+    _aliceId = alice.userId;"," ","     const bob = await registerAndLogin(app, 'bob', 'pass');","     bobToken = bob.token;"]}],"userModified":false,"replaceAll":false}}
