index 0000000..897ffa4
--- /dev/null
+++ b/src/activity.test.ts
@@ -0,0 +1,187 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import request from 'supertest';
+import { createApp } from './app.js';
+import type { Express } from 'express';
+
+async function registerAndLogin(app: Express, username: string, password: string) {
+  const regRes = await request(app)
+    .post('/auth/register')
+    .send({ username, password });
+  const loginRes = await request(app)
+    .post('/auth/login')
+    .send({ username, password });
+  return { userId: regRes.body.id, token: loginRes.body.token };
+}
+
+describe('Activity Log', () => {
+  let app: Express;
+  let aliceToken: string;
+  let aliceId: string;
+
+  beforeEach(async () => {
+    app = createApp();
+    const alice = await registerAndLogin(app, 'alice', 'pass');
+    aliceToken = alice.token;
+    aliceId = alice.userId;
+  });
+
+  it('logs document creation', async () => {
+    const folderRes = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ name: 'Folder' });
+
+    await request(app)
+      .post(`/folders/${folderRes.body.id}/documents`)
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ title: 'Doc', content: 'Content' });
+
+    const actRes = await request(app)
+      .get('/activity')
+      .set('Authorization', `Bearer ${aliceToken}`);
+
+    expect(actRes.status).toBe(200);
+    const docCreated = actRes.body.find((a: { action: string }) => a.action === 'document_created');
+    expect(docCreated).toBeDefined();
+    expect(docCreated.userId).toBe(aliceId);
+    expect(docCreated).toHaveProperty('timestamp');
+  });
+
+  it('logs document updates', async () => {
+    const folderRes = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ name: 'Folder' });
+
+    const docRes = await request(app)
+      .post(`/folders/${folderRes.body.id}/documents`)
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ title: 'Doc', content: 'Content' });
+
+    await request(app)
+      .put(`/documents/${docRes.body.id}`)
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ content: 'Updated' });
+
+    const actRes = await request(app)
+      .get('/activity')
+      .set('Authorization', `Bearer ${aliceToken}`);
+
+    const docUpdated = actRes.body.find((a: { action: string }) => a.action === 'document_updated');
+    expect(docUpdated).toBeDefined();
+    expect(docUpdated.resourceId).toBe(docRes.body.id);
+  });
+
+  it('logs document deletion', async () => {
+    const folderRes = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ name: 'Folder' });
+
+    const docRes = await request(app)
+      .post(`/folders/${folderRes.body.id}/documents`)
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ title: 'Doc', content: 'Content' });
+
+    const docId = docRes.body.id;
+
+    await request(app)
+      .delete(`/documents/${docId}`)
+      .set('Authorization', `Bearer ${aliceToken}`);
+
+    const actRes = await request(app)
+      .get('/activity')
+      .set('Authorization', `Bearer ${aliceToken}`);
+
+    // After deletion, the activity entries for the deleted doc may not be visible
+    // since the resource no longer exists. But folder_created should still be visible.
+    expect(actRes.status).toBe(200);
+    expect(actRes.body.length).toBeGreaterThan(0);
+  });
+
+  it('logs sharing events', async () => {
+    const bob = await registerAndLogin(app, 'bob', 'pass');
+
+    const folderRes = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ name: 'Folder' });
+
+    await request(app)
+      .post('/share')
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({
+        resourceType: 'folder',
+        resourceId: folderRes.body.id,
+        targetUserId: bob.userId,
+        role: 'viewer',
+      });
+
+    const actRes = await request(app)
+      .get('/activity')
+      .set('Authorization', `Bearer ${aliceToken}`);
+
+    const shareCreated = actRes.body.find((a: { action: string }) => a.action === 'share_created');
+    expect(shareCreated).toBeDefined();
+    expect(shareCreated.userId).toBe(aliceId);
+  });
+
+  it('only shows activity for resources user can access', async () => {
+    const bob = await registerAndLogin(app, 'bob', 'pass');
+
+    // Alice creates a folder and doc
+    const folderRes = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ name: 'Alice Folder' });
+
+    await request(app)
+      .post(`/folders/${folderRes.body.id}/documents`)
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ title: 'Alice Doc', content: 'Secret' });
+
+    // Bob creates his own folder
+    const bobFolder = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${bob.token}`)
+      .send({ name: 'Bob Folder' });
+
+    // Bob should only see his own activity
+    const actRes = await request(app)
+      .get('/activity')
+      .set('Authorization', `Bearer ${bob.token}`);
+
+    expect(actRes.status).toBe(200);
+    // Bob should only see folder_created for his own folder
+    const bobActivities = actRes.body.filter((a: { resourceId: string }) => a.resourceId === bobFolder.body.id);
+    expect(bobActivities.length).toBeGreaterThan(0);
+    // Bob should NOT see Alice's folder activities
+    const aliceActivities = actRes.body.filter((a: { resourceId: string }) => a.resourceId === folderRes.body.id);
+    expect(aliceActivities.length).toBe(0);
+  });
+
+  it('each log entry has required fields', async () => {
+    const folderRes = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ name: 'Folder' });
+
+    await request(app)
+      .post(`/folders/${folderRes.body.id}/documents`)
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ title: 'Doc', content: 'Content' });
+
+    const actRes = await request(app)
+      .get('/activity')
+      .set('Authorization', `Bearer ${aliceToken}`);
+
+    for (const entry of actRes.body) {
+      expect(entry).toHaveProperty('id');
+      expect(entry).toHaveProperty('action');
+      expect(entry).toHaveProperty('userId');
+      expect(entry).toHaveProperty('resourceType');
+      expect(entry).toHaveProperty('resourceId');
+      expect(entry).toHaveProperty('timestamp');
+    }
+  });
+});
diff --git a/src/app.ts b/src/app.ts
new file mode 100644
index 0000000..91609b6
--- /dev/null
+++ b/src/app.ts
@@ -0,0 +1,572 @@
+import express, { Request, Response, NextFunction } from 'express';
+import crypto from 'crypto';
+
+// --- Types ---
+
+interface User {
+  id: string;
+  username: string;
+  password: string;
+}
+
+interface Folder {
+  id: string;
+  name: string;
+  parentId: string | null;
+  ownerId: string;
+  createdAt: string;
+}
+
+interface Document {
+  id: string;
+  title: string;
+  content: string;
+  folderId: string;
+  ownerId: string;
+  createdAt: string;
+  updatedAt: string;
+}
+
+type Role = 'viewer' | 'editor' | 'owner';
+
+interface Share {
+  id: string;
+  resourceType: 'folder' | 'document';
+  resourceId: string;
+  userId: string;
+  role: Role;
+}
+
+interface ActivityEntry {
+  id: string;
+  action: string;
+  userId: string;
+  resourceType: 'folder' | 'document';
+  resourceId: string;
+  timestamp: string;
+  details?: string;
+}
+
+// --- Storage ---
+
+interface Store {
+  users: Map<string, User>;
+  tokens: Map<string, string>; // token -> userId
+  folders: Map<string, Folder>;
+  documents: Map<string, Document>;
+  shares: Share[];
+  activity: ActivityEntry[];
+}
+
+function createStore(): Store {
+  return {
+    users: new Map(),
+    tokens: new Map(),
+    folders: new Map(),
+    documents: new Map(),
+    shares: [],
+    activity: [],
+  };
+}
+
+// --- Helpers ---
+
+function generateId(): string {
+  return crypto.randomUUID();
+}
+
+function getEffectiveRole(store: Store, userId: string, resourceType: 'folder' | 'document', resourceId: string): Role | null {
+  const roles: Role[] = [];
+
+  // Direct shares on this resource
+  for (const share of store.shares) {
+    if (share.userId === userId && share.resourceType === resourceType && share.resourceId === resourceId) {
+      roles.push(share.role);
+    }
+  }
+
+  // Folder chain inheritance: documents inherit from their folder chain
+  if (resourceType === 'document') {
+    const doc = store.documents.get(resourceId);
+    if (doc) {
+      roles.push(...getFolderChainRoles(store, userId, doc.folderId));
+    }
+  }
+
+  // Folders inherit from parent folders
+  if (resourceType === 'folder') {
+    const folder = store.folders.get(resourceId);
+    if (folder?.parentId) {
+      roles.push(...getFolderChainRoles(store, userId, folder.parentId));
+    }
+  }
+
+  if (roles.length === 0) return null;
+
+  if (roles.includes('owner')) return 'owner';
+  if (roles.includes('editor')) return 'editor';
+  return 'viewer';
+}
+
+function getFolderChainRoles(store: Store, userId: string, folderId: string): Role[] {
+  const roles: Role[] = [];
+  let currentFolderId: string | null = folderId;
+
+  while (currentFolderId) {
+    for (const share of store.shares) {
+      if (share.userId === userId && share.resourceType === 'folder' && share.resourceId === currentFolderId) {
+        roles.push(share.role);
+      }
+    }
+    const folder = store.folders.get(currentFolderId);
+    currentFolderId = folder?.parentId ?? null;
+  }
+
+  return roles;
+}
+
+function addActivity(store: Store, action: string, userId: string, resourceType: 'folder' | 'document', resourceId: string, details?: string): void {
+  store.activity.push({
+    id: generateId(),
+    action,
+    userId,
+    resourceType,
+    resourceId,
+    timestamp: new Date().toISOString(),
+    details,
+  });
+}
+
+// --- Auth middleware ---
+
+interface AuthRequest extends Request {
+  userId?: string;
+}
+
+function authMiddleware(store: Store) {
+  return (req: AuthRequest, res: Response, next: NextFunction): void => {
+    const authHeader = req.headers.authorization;
+    if (!authHeader || !authHeader.startsWith('Bearer ')) {
+      res.status(401).json({ error: 'Authentication required' });
+      return;
+    }
+
+    const token = authHeader.slice(7);
+    const userId = store.tokens.get(token);
+    if (!userId) {
+      res.status(401).json({ error: 'Invalid token' });
+      return;
+    }
+
+    req.userId = userId;
+    next();
+  };
+}
+
+// --- App ---
+
+export function createApp() {
+  const app = express();
+  app.use(express.json());
+
+  const store = createStore();
+  const auth = authMiddleware(store);
+
+  // --- Auth routes ---
+
+  app.post('/auth/register', (req: Request, res: Response) => {
+    const { username, password } = req.body;
+
+    if (!username || !password) {
+      res.status(400).json({ error: 'Username and password are required' });
+      return;
+    }
+
+    // Check duplicate username
+    for (const user of store.users.values()) {
+      if (user.username === username) {
+        res.status(409).json({ error: 'Username already exists' });
+        return;
+      }
+    }
+
+    const id = generateId();
+    const user: User = { id, username, password };
+    store.users.set(id, user);
+
+    res.status(201).json({ id, username });
+  });
+
+  app.post('/auth/login', (req: Request, res: Response) => {
+    const { username, password } = req.body;
+
+    let foundUser: User | undefined;
+    for (const user of store.users.values()) {
+      if (user.username === username) {
+        foundUser = user;
+        break;
+      }
+    }
+
+    if (!foundUser || foundUser.password !== password) {
+      res.status(401).json({ error: 'Invalid credentials' });
+      return;
+    }
+
+    const token = generateId();
+    store.tokens.set(token, foundUser.id);
+
+    res.json({ token });
+  });
+
+  // --- Folder routes ---
+
+  app.post('/folders', auth, (req: AuthRequest, res: Response) => {
+    const { name, parentId } = req.body;
+    const userId = req.userId!;
+
+    if (!name) {
+      res.status(400).json({ error: 'Folder name is required' });
+      return;
+    }
+
+    if (parentId !== undefined && parentId !== null) {
+      const parentFolder = store.folders.get(parentId);
+      if (!parentFolder) {
+        res.status(404).json({ error: 'Parent folder not found' });
+        return;
+      }
+      // Check permission on parent
+      const role = getEffectiveRole(store, userId, 'folder', parentId);
+      if (!role || role === 'viewer') {
+        res.status(403).json({ error: 'Forbidden' });
+        return;
+      }
+    }
+
+    const id = generateId();
+    const folder: Folder = {
+      id,
+      name,
+      parentId: parentId || null,
+      ownerId: userId,
+      createdAt: new Date().toISOString(),
+    };
+    store.folders.set(id, folder);
+
+    // Auto-share as owner
+    store.shares.push({
+      id: generateId(),
+      resourceType: 'folder',
+      resourceId: id,
+      userId,
+      role: 'owner',
+    });
+
+    addActivity(store, 'folder_created', userId, 'folder', id);
+
+    res.status(201).json(folder);
+  });
+
+  app.get('/folders', auth, (req: AuthRequest, res: Response) => {
+    const userId = req.userId!;
+    const folders: Folder[] = [];
+
+    for (const folder of store.folders.values()) {
+      const role = getEffectiveRole(store, userId, 'folder', folder.id);
+      if (role) {
+        folders.push(folder);
+      }
+    }
+
+    res.json(folders);
+  });
+
+  app.get('/folders/:id', auth, (req: AuthRequest, res: Response) => {
+    const userId = req.userId!;
+    const folder = store.folders.get(req.params.id);
+
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, userId, 'folder', folder.id);
+    if (!role) {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+
+    res.json(folder);
+  });
+
+  app.put('/folders/:id', auth, (req: AuthRequest, res: Response) => {
+    const userId = req.userId!;
+    const folder = store.folders.get(req.params.id);
+
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, userId, 'folder', folder.id);
+    if (!role || role === 'viewer') {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+
+    if (req.body.name !== undefined) {
+      folder.name = req.body.name;
+    }
+    if (req.body.parentId !== undefined) {
+      folder.parentId = req.body.parentId;
+    }
+
+    res.json(folder);
+  });
+
+  app.delete('/folders/:id', auth, (req: AuthRequest, res: Response) => {
+    const userId = req.userId!;
+    const folder = store.folders.get(req.params.id);
+
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, userId, 'folder', folder.id);
+    if (role !== 'owner') {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+
+    store.folders.delete(folder.id);
+    // Remove shares for this folder
+    store.shares = store.shares.filter(s => !(s.resourceType === 'folder' && s.resourceId === folder.id));
+    // Remove documents in this folder
+    for (const doc of store.documents.values()) {
+      if (doc.folderId === folder.id) {
+        store.documents.delete(doc.id);
+        store.shares = store.shares.filter(s => !(s.resourceType === 'document' && s.resourceId === doc.id));
+      }
+    }
+
+    addActivity(store, 'folder_deleted', userId, 'folder', folder.id);
+
+    res.status(204).send();
+  });
+
+  // --- Document routes ---
+
+  app.post('/folders/:folderId/documents', auth, (req: AuthRequest, res: Response) => {
+    const userId = req.userId!;
+    const { folderId } = req.params;
+    const { title, content } = req.body;
+
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    const folderRole = getEffectiveRole(store, userId, 'folder', folderId);
+    if (!folderRole || folderRole === 'viewer') {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+
+    if (!title) {
+      res.status(400).json({ error: 'Document title is required' });
+      return;
+    }
+
+    const id = generateId();
+    const now = new Date().toISOString();
+    const doc: Document = {
+      id,
+      title,
+      content: content || '',
+      folderId,
+      ownerId: userId,
+      createdAt: now,
+      updatedAt: now,
+    };
+    store.documents.set(id, doc);
+
+    // Auto-share as owner
+    store.shares.push({
+      id: generateId(),
+      resourceType: 'document',
+      resourceId: id,
+      userId,
+      role: 'owner',
+    });
+
+    addActivity(store, 'document_created', userId, 'document', id);
+
+    res.status(201).json(doc);
+  });
+
+  app.get('/documents/:id', auth, (req: AuthRequest, res: Response) => {
+    const userId = req.userId!;
+    const doc = store.documents.get(req.params.id);
+
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, userId, 'document', doc.id);
+    if (!role) {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+
+    res.json(doc);
+  });
+
+  app.put('/documents/:id', auth, (req: AuthRequest, res: Response) => {
+    const userId = req.userId!;
+    const doc = store.documents.get(req.params.id);
+
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, userId, 'document', doc.id);
+    if (!role || role === 'viewer') {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+
+    if (req.body.title !== undefined) {
+      doc.title = req.body.title;
+    }
+    if (req.body.content !== undefined) {
+      doc.content = req.body.content;
+    }
+    doc.updatedAt = new Date().toISOString();
+
+    addActivity(store, 'document_updated', userId, 'document', doc.id);
+
+    res.json(doc);
+  });
+
+  app.delete('/documents/:id', auth, (req: AuthRequest, res: Response) => {
+    const userId = req.userId!;
+    const doc = store.documents.get(req.params.id);
+
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, userId, 'document', doc.id);
+    if (role !== 'owner') {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+
+    store.documents.delete(doc.id);
+    store.shares = store.shares.filter(s => !(s.resourceType === 'document' && s.resourceId === doc.id));
+
+    addActivity(store, 'document_deleted', userId, 'document', doc.id);
+
+    res.status(204).send();
+  });
+
+  // --- Sharing routes ---
+
+  app.post('/share', auth, (req: AuthRequest, res: Response) => {
+    const userId = req.userId!;
+    const { resourceType, resourceId, targetUserId, role } = req.body as {
+      resourceType: 'folder' | 'document';
+      resourceId: string;
+      targetUserId: string;
+      role: Role;
+    };
+
+    if (!resourceType || !resourceId || !targetUserId || !role) {
+      res.status(400).json({ error: 'resourceType, resourceId, targetUserId, and role are required' });
+      return;
+    }
+
+    if (!['viewer', 'editor', 'owner'].includes(role)) {
+      res.status(400).json({ error: 'Invalid role. Must be viewer, editor, or owner' });
+      return;
+    }
+
+    if (!['folder', 'document'].includes(resourceType)) {
+      res.status(400).json({ error: 'Invalid resourceType. Must be folder or document' });
+      return;
+    }
+
+    // Check target user exists
+    if (!store.users.has(targetUserId)) {
+      res.status(404).json({ error: 'Target user not found' });
+      return;
+    }
+
+    // Check resource exists
+    if (resourceType === 'folder' && !store.folders.has(resourceId)) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+    if (resourceType === 'document' && !store.documents.has(resourceId)) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    // Check sharer has permission (editor or owner)
+    const sharerRole = getEffectiveRole(store, userId, resourceType, resourceId);
+    if (!sharerRole || sharerRole === 'viewer') {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+
+    // Only owners can grant owner role
+    if (role === 'owner' && sharerRole !== 'owner') {
+      res.status(403).json({ error: 'Only owners can grant owner role' });
+      return;
+    }
+
+    // Update existing share or create new one
+    const existingShare = store.shares.find(
+      s => s.resourceType === resourceType && s.resourceId === resourceId && s.userId === targetUserId
+    );
+
+    if (existingShare) {
+      existingShare.role = role;
+      addActivity(store, 'share_updated', userId, resourceType, resourceId, `Shared with user ${targetUserId} as ${role}`);
+      res.json(existingShare);
+    } else {
+      const share: Share = {
+        id: generateId(),
+        resourceType,
+        resourceId,
+        userId: targetUserId,
+        role,
+      };
+      store.shares.push(share);
+      addActivity(store, 'share_created', userId, resourceType, resourceId, `Shared with user ${targetUserId} as ${role}`);
+      res.status(201).json(share);
+    }
+  });
+
+  // --- Activity log ---
+
+  app.get('/activity', auth, (req: AuthRequest, res: Response) => {
+    const userId = req.userId!;
+
+    // Return activity for resources the user has access to
+    const visibleActivity = store.activity.filter(entry => {
+      const role = getEffectiveRole(store, userId, entry.resourceType, entry.resourceId);
+      return role !== null;
+    });
+
+    res.json(visibleActivity);
+  });
+
+  return app;
+}
