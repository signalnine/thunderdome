cRes.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ content: 'Edited by Bob' });\n\n      expect(res.status).toBe(200);\n      expect(res.body.content).toBe('Edited by Bob');\n    });\n\n    it('most permissive role wins when accessed through multiple paths', async () => {\n      const docRes = await request(app)\n        .post(`/folders/${folderId}/documents`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Doc', content: 'Content' });\n\n      // Share folder as viewer\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'viewer',\n        });\n\n      // Share document directly as editor\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'document',\n          resourceId: docRes.body.id,\n          targetUserId: bobId,\n          role: 'editor',\n        });\n\n      // Bob should be able to edit (editor > viewer)\n      const res = await request(app)\n        .put(`/documents/${docRes.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ content: 'Edited' });\n\n      expect(res.status).toBe(200);\n    });\n\n    it('nested folder inherits parent folder permissions', async () => {\n      // Create nested folder structure\n      const childRes = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Child', parentId: folderId });\n\n      // Share parent folder with bob as viewer\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'viewer',