ct(res.body.ownerId).toBe(userId);\n    });\n\n    it('returns 400 if title is missing', async () => {\n      const res = await request(app)\n        .post(`/folders/${folderId}/documents`)\n        .set('Authorization', `Bearer ${token}`)\n        .send({ content: 'No title' });\n\n      expect(res.status).toBe(400);\n    });\n\n    it('returns 404 if folder does not exist', async () => {\n      const res = await request(app)\n        .post('/folders/nonexistent/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'Doc', content: 'Content' });\n\n      expect(res.status).toBe(404);\n    });\n\n    it('returns 403 if user is only a viewer of the folder', async () => {\n      const bob = await registerAndLogin(app, 'bob', 'pass');\n\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${token}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bob.userId,\n          role: 'viewer',\n        });\n\n      const res = await request(app)\n        .post(`/folders/${folderId}/documents`)\n        .set('Authorization', `Bearer ${bob.token}`)\n        .send({ title: 'Doc', content: 'Content' });\n\n      expect(res.status).toBe(403);\n    });\n\n    it('allows editor of folder to create documents', async () => {\n      const bob = await registerAndLogin(app, 'bob', 'pass');\n\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${token}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bob.userId,\n          role: 'editor',\n        });\n\n      const res = await request(app)\n        .post(`/folders/${folderId}/documents`)\n        .set('Authorization', `Bearer ${bob.token}`)\n        .send({ title: 'Bob Doc', content: 'Content' });\n\n      expect(res.status).toBe(201);\n      expect(res.body.ownerId).toBe(bob.userId);\n    });\n\n    it('creates 