+import { describe, it, expect, beforeEach } from 'vitest';
+import request from 'supertest';
+import { createApp } from './app.js';
+import type { Express } from 'express';
+
+describe('Auth', () => {
+  let app: Express;
+
+  beforeEach(() => {
+    app = createApp();
+  });
+
+  describe('POST /auth/register', () => {
+    it('registers a new user and returns 201 with user info', async () => {
+      const res = await request(app)
+        .post('/auth/register')
+        .send({ username: 'alice', password: 'secret123' });
+
+      expect(res.status).toBe(201);
+      expect(res.body).toHaveProperty('id');
+      expect(res.body.username).toBe('alice');
+      expect(res.body).not.toHaveProperty('password');
+    });
+
+    it('returns 400 if username is missing', async () => {
+      const res = await request(app)
+        .post('/auth/register')
+        .send({ password: 'secret123' });
+
+      expect(res.status).toBe(400);
+    });
+
+    it('returns 400 if password is missing', async () => {
+      const res = await request(app)
+        .post('/auth/register')
+        .send({ username: 'alice' });
+
+      expect(res.status).toBe(400);
+    });
+
+    it('returns 409 if username already exists', async () => {
+      await request(app)
+        .post('/auth/register')
+        .send({ username: 'alice', password: 'secret123' });
+
+      const res = await request(app)
+        .post('/auth/register')
+        .send({ username: 'alice', password: 'other' });
+
+      expect(res.status).toBe(409);
+    });
+  });
+
+  describe('POST /auth/login', () => {
+    it('returns 200 with a token on valid credentials', async () => {
+      await request(app)
+        .post('/auth/register')
+        .send({ username: 'alice', password: 'secret123' });
+
+      const res = await request(app)
+        .post('/auth/login')
+        .send({ username: 'alice', password: 'secret123' });
+
+      expect(res.status).toBe(200);
+      expect(res.body).toHaveProperty('token');
+      expect(typeof res.body.token).toBe('string');
+      expect(res.body.token.length).toBeGreaterThan(0);
+    });
+
+    it('returns 401 on invalid password', async () => {
+      await request(app)
+        .post('/auth/register')
+        .send({ username: 'alice', password: 'secret123' });
+
+      const res = await request(app)
+        .post('/auth/login')
+        .send({ username: 'alice', password: 'wrong' });
+
+      expect(res.status).toBe(401);
+    });
+
+    it('returns 401 on nonexistent user', async () => {
+      const res = await request(app)
+        .post('/auth/login')
+        .send({ username: 'nonexistent', password: 'secret123' });
+
+      expect(res.status).toBe(401);
+    });
+  });
+
+  describe('Authentication middleware', () => {
+    it('returns 401 when accessing protected route without token', async () => {
+      const res = await request(app).get('/folders');
+
+      expect(res.status).toBe(401);
+    });
+
+    it('returns 401 with invalid token', async () => {
+      const res = await request(app)
+        .get('/folders')
+        .set('Authorization', 'Bearer invalid-token');
+
+      expect(res.status).toBe(401);
+    });
+  });
+});
