s(timestamp);\nCREATE INDEX IF NOT EXISTS idx_dashboards_tenant ON dashboards(tenant_id);\nCREATE INDEX IF NOT EXISTS idx_users_tenant ON users(tenant_id);\n","numLines":49,"startLine":1,"totalLines":49}}}
