    const created = await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"My Dashboard\" });\n      const res = await request(app)\n        .post(`/api/dashboards/${created.body.id}/widgets`)\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ type: \"counter\", config: { event_name: \"page_view\" } });\n      expect(res.status).toBe(201);\n      expect(res.body.type).toBe(\"counter\");\n    });\n  });\n\n  describe(\"Export\", () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const reg = await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"test@example.com\", password: \"password123\", tenant_id: \"tenant1\" });\n      token = reg.body.token;\n\n      await request(app)\n        .post(\"/api/events/batch\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({\n          events: [\n            { name: \"page_view\", properties: { url: \"/home\" } },\n            { name: \"click\", properties: { button: \"signup\" } },\n          ],\n        });\n\n      await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"My Dashboard\" });\n    });\n\n    it(\"should export events as JSON\", async () => {\n      const res = await request(app)\n        .get(\"/api/export/events/json\")\n        .set(\"Authorization\", `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.events.length).toBe(2);\n    });\n\n    it(\"should export events as CSV\", async () => {\n      const res = await request(app)\n        .get(\"/api/export/events/csv\")\n        .set(\"Authorization\", `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n      expect(res.text).toContain(\"id,tenant_id,name\");\n    });\n\n    it(\"should export dashboards as JSON\", async () => {\n      const res = await request(app)\n        .get(\"/api/export/dashboards/json\")\n        .set(\"Authorization\", `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.dashboards.length).toBe(1);\n    });\n\n    it(\"should export dashboards as CSV\", async () => {\n      const res = await request(app)\n        .get(\"/api/export/dashboards/csv\")\n        .set(\"Authorization\", `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n    });\n\n    it(\"should enforce tenant isolation on export\", async () => {\n      const reg2 = await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"other@example.com\", password: \"password123\", tenant_id: \"tenant2\" });\n      const res = await request(app)\n        .get(\"/api/export/events/json\")\n        .set(\"Authorization\", `Bearer ${reg2.body.token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.events.length).toBe(0);\n    });\n\n    it(\"should reject unauthenticated export\", async () => {\n      const res = await request(app).get(\"/api/export/events/json\");\n      expect(res.status).toBe(401);\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
