new file mode 100644
index 0000000..0d93ad9
--- /dev/null
+++ b/src/routes/events.ts
@@ -0,0 +1,121 @@
+import { Router, Response } from "express";
+import { v4 as uuidv4 } from "uuid";
+import type Database from "better-sqlite3";
+import { AuthRequest, authMiddleware } from "../auth.js";
+
+export function createEventRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Ingest single event
+  router.post("/", authMiddleware, (req: AuthRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: "Authentication required" });
+      return;
+    }
+
+    const { name, properties, timestamp, session_id } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: "Event name is required" });
+      return;
+    }
+
+    const id = uuidv4();
+    const eventTimestamp = timestamp || new Date().toISOString();
+    const eventProperties = properties ? JSON.stringify(properties) : "{}";
+
+    db.prepare(
+      "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    ).run(id, req.user.tenant_id, name, eventProperties, eventTimestamp, req.user.id, session_id || null);
+
+    res.status(201).json({
+      id,
+      tenant_id: req.user.tenant_id,
+      name,
+      properties: properties || {},
+      timestamp: eventTimestamp,
+      user_id: req.user.id,
+      session_id: session_id || null,
+    });
+  });
+
+  // Batch ingest events
+  router.post("/batch", authMiddleware, (req: AuthRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: "Authentication required" });
+      return;
+    }
+
+    const { events } = req.body;
+
+    if (!Array.isArray(events) || events.length === 0) {
+      res.status(400).json({ error: "events array is required and must not be empty" });
+      return;
+    }
+
+    const insertStmt = db.prepare(
+      "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    );
+
+    const results: Array<{ id: string; name: string }> = [];
+
+    const insertMany = db.transaction(() => {
+      for (const event of events) {
+        if (!event.name) continue;
+        const id = uuidv4();
+        const eventTimestamp = event.timestamp || new Date().toISOString();
+        const eventProperties = event.properties ? JSON.stringify(event.properties) : "{}";
+
+        insertStmt.run(
+          id,
+          req.user!.tenant_id,
+          event.name,
+          eventProperties,
+          eventTimestamp,
+          req.user!.id,
+          event.session_id || null
+        );
+        results.push({ id, name: event.name });
+      }
+    });
+
+    insertMany();
+
+    res.status(201).json({
+      inserted: results.length,
+      events: results,
+    });
+  });
+
+  // List events for tenant
+  router.get("/", authMiddleware, (req: AuthRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: "Authentication required" });
+      return;
+    }
+
+    const limit = Math.min(parseInt(req.query.limit as string) || 100, 1000);
+    const offset = parseInt(req.query.offset as string) || 0;
+
+    const events = db.prepare(
+      "SELECT id, tenant_id, name, properties, timestamp, user_id, session_id FROM events WHERE tenant_id = ? ORDER BY timestamp DESC LIMIT ? OFFSET ?"
+    ).all(req.user.tenant_id, limit, offset) as Array<{
+      id: string;
+      tenant_id: string;
+      name: string;
+      properties: string;
+      timestamp: string;
+      user_id: string;
+      session_id: string | null;
+    }>;
+
+    const parsed = events.map((e) => ({
+      ...e,
+      properties: JSON.parse(e.properties),
+    }));
+
+    res.json({ events: parsed, limit, offset });
+  });
+
+  return router;
+}
diff --git a/src/routes/export.ts b/src/routes/export.ts
new file mode 100644
index 0000000..413b377
--- /dev/null
+++ b/src/routes/export.ts
@@ -0,0 +1,194 @@
+import { Router, Response } from "express";
+import type Database from "better-sqlite3";
+import { AuthRequest, authMiddleware } from "../auth.js";
+
+interface EventRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string;
+  session_id: string | null;
+}
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+interface WidgetRow {
+  id: string;
+  dashboard_id: string;
+  type: string;
+  config: string;
+  position_x: number;
+  position_y: number;
+  width: number;
+  height: number;
+}
+
+function eventsToCsv(events: EventRow[]): string {
+  const headers = ["id", "tenant_id", "name", "properties", "timestamp", "user_id", "session_id"];
+  const rows = events.map((e) =>
+    headers.map((h) => {
+      const val = e[h as keyof EventRow];
+      if (val === null || val === undefined) return "";
+      const str = String(val);
+      if (str.includes(",") || str.includes('"') || str.includes("\n")) {
+        return `"${str.replace(/"/g, '""')}"`;
+      }
+      return str;
+    }).join(",")
+  );
+  return [headers.join(","), ...rows].join("\n");
+}
+
+function dashboardsToCsv(dashboards: Array<DashboardRow & { widgets?: WidgetRow[] }>): string {
+  const headers = ["id", "tenant_id", "name", "owner_id", "config", "created_at", "updated_at"];
+  const rows = dashboards.map((d) =>
+    headers.map((h) => {
+      const val = d[h as keyof DashboardRow];
+      if (val === null || val === undefined) return "";
+      const str = String(val);
+      if (str.includes(",") || str.includes('"') || str.includes("\n")) {
+        return `"${str.replace(/"/g, '""')}"`;
+      }
+      return str;
+    }).join(",")
+  );
+  return [headers.join(","), ...rows].join("\n");
+}
+
+export function createExportRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Export events as JSON
+  router.get("/events/json", authMiddleware, (req: AuthRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: "Authentication required" });
+      return;
+    }
+
+    const { event_name, start_date, end_date } = req.query;
+
+    let sql = "SELECT * FROM events WHERE tenant_id = ?";
+    const params: string[] = [req.user.tenant_id];
+
+    if (event_name) {
+      sql += " AND name = ?";
+      params.push(event_name as string);
+    }
+    if (start_date) {
+      sql += " AND timestamp >= ?";
+      params.push(start_date as string);
+    }
+    if (end_date) {
+      sql += " AND timestamp <= ?";
+      params.push(end_date as string);
+    }
+
+    sql += " ORDER BY timestamp DESC";
+
+    const events = db.prepare(sql).all(...params) as EventRow[];
+    const parsed = events.map((e) => ({
+      ...e,
+      properties: JSON.parse(e.properties),
+    }));
+
+    res.setHeader("Content-Type", "application/json");
+    res.setHeader("Content-Disposition", "attachment; filename=events.json");
+    res.json({ events: parsed });
+  });
+
+  // Export events as CSV
+  router.get("/events/csv", authMiddleware, (req: AuthRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: "Authentication required" });
+      return;
+    }
+
+    const { event_name, start_date, end_date } = req.query;
+
+    let sql = "SELECT * FROM events WHERE tenant_id = ?";
+    const params: string[] = [req.user.tenant_id];
+
+    if (event_name) {
+      sql += " AND name = ?";
+      params.push(event_name as string);
+    }
+    if (start_date) {
+      sql += " AND timestamp >= ?";
+      params.push(start_date as string);
+    }
+    if (end_date) {
+      sql += " AND timestamp <= ?";
+      params.push(end_date as string);
+    }
+
+    sql += " ORDER BY timestamp DESC";
+
+    const events = db.prepare(sql).all(...params) as EventRow[];
+    const csv = eventsToCsv(events);
+
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader("Content-Disposition", "attachment; filename=events.csv");
+    res.send(csv);
+  });
+
+  // Export dashboards as JSON
+  router.get("/dashboards/json", authMiddleware, (req: AuthRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: "Authentication required" });
+      return;
+    }
+
+    const dashboards = db.prepare(
+      "SELECT * FROM dashboards WHERE tenant_id = ?"
+    ).all(req.user.tenant_id) as DashboardRow[];
+
+    const parsed = dashboards.map((d) => {
+      const widgets = db.prepare(
+        "SELECT * FROM widgets WHERE dashboard_id = ?"
+      ).all(d.id) as WidgetRow[];
+
+      return {
+        ...d,
+        config: JSON.parse(d.config),
+        widgets: widgets.map((w) => ({
+          ...w,
+          config: JSON.parse(w.config),
+        })),
+      };
+    });
+
+    res.setHeader("Content-Type", "application/json");
+    res.setHeader("Content-Disposition", "attachment; filename=dashboards.json");
+    res.json({ dashboards: parsed });
+  });
+
+  // Export dashboards as CSV
+  router.get("/dashboards/csv", authMiddleware, (req: AuthRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: "Authentication required" });
+      return;
+    }
+
+    const dashboards = db.prepare(
+      "SELECT * FROM dashboards WHERE tenant_id = ?"
+    ).all(req.user.tenant_id) as DashboardRow[];
+
+    const csv = dashboardsToCsv(dashboards);
+
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader("Content-Disposition", "attachment; filename=dashboards.csv");
+    res.send(csv);
+  });
+
+  return router;
+}
diff --git a/src/routes/queries.ts b/src/routes/queries.ts
new file mode 100644
index 0000000..854686a
--- /dev/null
+++ b/src/routes/queries.ts
@@ -0,0 +1,149 @@
+import { Router, Response } from "express";
+import type Database from "better-sqlite3";
+import { AuthRequest, authMiddleware } from "../auth.js";
+
+export function createQueryRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Count query
+  router.post("/count", authMiddleware, (req: AuthRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: "Authentication required" });
+      return;
+    }
+
+    const { event_name, start_date, end_date, filters } = req.body;
+
+    let sql = "SELECT COUNT(*) as count FROM events WHERE tenant_id = ?";
+    const params: (string | number)[] = [req.user.tenant_id];
+
+    if (event_name) {
+      sql += " AND name = ?";
+      params.push(event_name);
+    }
+
+    if (start_date) {
+      sql += " AND timestamp >= ?";
+      params.push(start_date);
+    }
+
+    if (end_date) {
+      sql += " AND timestamp <= ?";
+      params.push(end_date);
+    }
+
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, String(value));
+      }
+    }
+
+    const result = db.prepare(sql).get(...params) as { count: number };
+    res.json({ count: result.count });
+  });
+
+  // Timeseries query
+  router.post("/timeseries", authMiddleware, (req: AuthRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: "Authentication required" });
+      return;
+    }
+
+    const { event_name, start_date, end_date, interval, filters } = req.body;
+
+    if (!start_date || !end_date) {
+      res.status(400).json({ error: "start_date and end_date are required" });
+      return;
+    }
+
+    // Determine the date format based on interval
+    let dateFormat: string;
+    switch (interval) {
+      case "hour":
+        dateFormat = "%Y-%m-%dT%H:00:00";
+        break;
+      case "month":
+        dateFormat = "%Y-%m-01";
+        break;
+      case "week":
+        // SQLite doesn't have a native week start, approximate with day
+        dateFormat = "%Y-%m-%d";
+        break;
+      case "day":
+      default:
+        dateFormat = "%Y-%m-%d";
+        break;
+    }
+
+    let sql = `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: (string | number)[] = [req.user.tenant_id];
+
+    if (event_name) {
+      sql += " AND name = ?";
+      params.push(event_name);
+    }
+
+    sql += " AND timestamp >= ? AND timestamp <= ?";
+    params.push(start_date, end_date);
+
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, String(value));
+      }
+    }
+
+    sql += ` GROUP BY bucket ORDER BY bucket ASC`;
+
+    const results = db.prepare(sql).all(...params) as Array<{ bucket: string; count: number }>;
+    res.json({ timeseries: results, interval: interval || "day" });
+  });
+
+  // Breakdown query
+  router.post("/breakdown", authMiddleware, (req: AuthRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: "Authentication required" });
+      return;
+    }
+
+    const { event_name, property, start_date, end_date, filters } = req.body;
+
+    if (!property) {
+      res.status(400).json({ error: "property is required for breakdown queries" });
+      return;
+    }
+
+    let sql = `SELECT json_extract(properties, ?) as value, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: (string | number)[] = [`$.${property}`, req.user.tenant_id];
+
+    if (event_name) {
+      sql += " AND name = ?";
+      params.push(event_name);
+    }
+
+    if (start_date) {
+      sql += " AND timestamp >= ?";
+      params.push(start_date);
+    }
+
+    if (end_date) {
+      sql += " AND timestamp <= ?";
+      params.push(end_date);
+    }
+
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, String(value));
+      }
+    }
+
+    sql += " GROUP BY value ORDER BY count DESC";
+
+    const results = db.prepare(sql).all(...params) as Array<{ value: string | null; count: number }>;
+    res.json({ breakdown: results, property });
+  });
+
+  return router;
+}
