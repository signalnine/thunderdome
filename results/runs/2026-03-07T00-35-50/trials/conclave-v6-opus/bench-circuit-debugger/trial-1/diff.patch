uts: Record<string, number> = {};\n+    const x = 200, y = 55;\n+    for (let i = 0; i < 8; i++) {\n+      inputs[`x${String(i).padStart(2, '0')}`] = (x >> i) & 1;\n+      inputs[`y${String(i).padStart(2, '0')}`] = (y >> i) & 1;\n+    }\n+\n+    const wires = simulate(fixedGates, inputs);\n+    let z = 0;\n+    for (let i = 0; i <= 8; i++) {\n+      z |= (wires[`z${String(i).padStart(2, '0')}`] ?? 0) << i;\n+    }\n+    expect(z).toBe(x + y);\n+  });\n+});\ndiff --git a/src/index.ts b/src/index.ts\nnew file mode 100644\nindex 0000000..314bce6\n--- /dev/null\n+++ b/src/index.ts\n@@ -0,0 +1,227 @@\n+export interface Gate {\n+  op: 'AND' | 'OR' | 'XOR';\n+  in1: string;\n+  in2: string;\n+  out: string;\n+}\n+\n+export function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number> {\n+  const wires: Record<string, number> = { ...inputs };\n+  const pending = new Set(gates);\n+\n+  let progress = true;\n+  while (pending.size > 0 && progress) {\n+    progress = false;\n+    for (const gate of pending) {\n+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {\n+        const a = wires[gate.in1];\n+        const b = wires[gate.in2];\n+        switch (gate.op) {\n+          case 'AND': wires[gate.out] = a & b; break;\n+          case 'OR':  wires[gate.out] = a | b; break;\n+          case 'XOR': wires[gate.out] = a ^ b; break;\n+        }\n+        pending.delete(gate);\n+        progress = true;\n+      }\n+    }\n+  }\n+\n+  return wires;\n+}\n+\n+export function findSwappedWires(gates: Gate[]): string[] {\n+  // Work on a mutable copy of outputs\n+  const outputMap = new Map<string, { op: Gate['op']; in1: string; in2: string }>();\n+  for (const g of gates) {\n+    outputMap.set(g.out, { op: g.op, in1: g.in1, in2: g.in2 });\n+  }\n+\n+  const swapped = new Set<string>();\n+\n+  // Determine number of input bits\n+  let maxBit = 0;\n+  for (const g of gates) {\n+    for (const w of [g.in1, g.in2]) {\n+      const m = w.matc