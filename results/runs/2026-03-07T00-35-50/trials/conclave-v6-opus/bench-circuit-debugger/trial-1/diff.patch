al = findByInputOp(byInputOp, 'XOR', xW, yW);\n        if (!partial) continue;\n\n        // Check sum XOR: partial XOR carry -> zNN\n        let sumOut = findByInputOp(byInputOp, 'XOR', partial, carry);\n\n        if (!sumOut) {\n          // Can't find XOR(partial, carry).\n          // Either partial or carry output is swapped.\n          // Strategy: look at what gate produces zW and use its inputs to diagnose.\n          const zGate = byOutput.get(zW);\n\n          if (zGate && zGate.op === 'XOR') {\n            // zW is produced by an XOR — good type. Check which input is wrong.\n            const zIn1 = zGate.in1;\n            const zIn2 = zGate.in2;\n\n            if (zIn1 === carry || zIn2 === carry) {\n              // carry is correct, other input should be partial\n              const correctPartial = zIn1 === carry ? zIn2 : zIn1;\n              doSwap(partial, correctPartial);\n              foundSwap = true;\n              break;\n            } else if (zIn1 === partial || zIn2 === partial) {\n              // partial is correct, other input should be carry\n              const correctCarry = zIn1 === partial ? zIn2 : zIn1;\n              doSwap(carry, correctCarry);\n              foundSwap = true;\n              break;\n            } else {\n              // Neither partial nor carry appears in zGate inputs.\n              // The partial wire might have been swapped.\n              // Look for an XOR gate that uses carry as input (the sum XOR with wrong output)\n              let found = false;\n              for (const [, info] of outputMap) {\n                if (info.op === 'XOR' && (info.in1 === carry || info.in2 === carry)) {\n                  const otherIn = info.in1 === carry ? info.in2 : info.in1;\n                  // otherIn should equal partial but doesn't — swap them\n                  if (otherIn !== partial) {\n                    doSwap(partial, otherIn);\n                    foundSwap = true;\n                    found = true;\n     