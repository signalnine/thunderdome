[gates.length - 1];\n  lastGate.out = `z${outPad}`;\n\n  return gates;\n}\n\n// Helper: swap two gate outputs\nfunction swapOutputs(gates: Gate[], wire1: string, wire2: string): Gate[] {\n  return gates.map(g => {\n    if (g.out === wire1) return { ...g, out: wire2 };\n    if (g.out === wire2) return { ...g, out: wire1 };\n    return { ...g };\n  });\n}\n\ndescribe('findSwappedWires', () => {\n  it('finds 4 swapped pairs in an 8-bit adder', () => {\n    let gates = buildAdder(8);\n    // Swap 4 pairs\n    gates = swapOutputs(gates, 'z01', 'a01');\n    gates = swapOutputs(gates, 'z03', 't03');\n    gates = swapOutputs(gates, 'c04', 'b05');\n    gates = swapOutputs(gates, 'z07', 'a07');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a01', 'a07', 'b05', 'c04', 't03', 'z01', 'z03', 'z07']);\n  });\n\n  it('finds swapped pairs in a 4-bit adder', () => {\n    let gates = buildAdder(4);\n    // Swap 4 pairs\n    gates = swapOutputs(gates, 'z01', 'a01');\n    gates = swapOutputs(gates, 'z02', 't02');\n    gates = swapOutputs(gates, 'z03', 'b03');\n    gates = swapOutputs(gates, 'z04', 'a03');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a01', 'a03', 'b03', 't02', 'z01', 'z02', 'z03', 'z04']);\n  });\n\n  it('handles a larger 20-bit adder', () => {\n    let gates = buildAdder(20);\n    gates = swapOutputs(gates, 'z05', 'a05');\n    gates = swapOutputs(gates, 'z10', 't10');\n    gates = swapOutputs(gates, 'c14', 'b15');\n    gates = swapOutputs(gates, 'z19', 'a19');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a05', 'a19', 'b15', 'c14', 't10', 'z05', 'z10', 'z19']);\n  });\n\n  it('returns sorted array of 8 wire names', () => {\n    let gates = buildAdder(8);\n    gates = swapOutputs(gates, 'z01', 'a01');\n    gates = swapOutputs(gates, 'z03', 't03');\n    gates = swapOutputs(gates, 'c04', 'b05');\n    gates = swapOutputs(gates, 'z07', 'a07');\n\n    const result = findSwappedWires(g