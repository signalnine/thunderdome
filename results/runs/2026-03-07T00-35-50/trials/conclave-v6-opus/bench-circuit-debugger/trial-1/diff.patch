pect(simulate(gates, { a: 0, b: 1 })).toMatchObject({ c: 1 });\n    expect(simulate(gates, { a: 0, b: 0 })).toMatchObject({ c: 0 });\n  });\n\n  it('computes XOR gate', () => {\n    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toMatchObject({ c: 0 });\n    expect(simulate(gates, { a: 1, b: 0 })).toMatchObject({ c: 1 });\n    expect(simulate(gates, { a: 0, b: 1 })).toMatchObject({ c: 1 });\n    expect(simulate(gates, { a: 0, b: 0 })).toMatchObject({ c: 0 });\n  });\n\n  it('handles dependent gates in any order', () => {\n    // c = a AND b, d = c OR b — gates listed in reverse dependency order\n    const gates: Gate[] = [\n      { op: 'OR', in1: 'c', in2: 'b', out: 'd' },\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n    ];\n    const result = simulate(gates, { a: 0, b: 1 });\n    expect(result).toMatchObject({ c: 0, d: 1 });\n  });\n\n  it('simulates a 2-bit adder', () => {\n    // Bit 0: half adder\n    // Bit 1: full adder\n    // Bit 2: carry out\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },\n    ];\n\n    // 3 + 3 = 6 (binary: 11 + 11 = 110)\n    const result = simulate(gates, { x00: 1, x01: 1, y00: 1, y01: 1 });\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(1);\n    expect(result.z02).toBe(1);\n\n    // 2 + 1 = 3 (binary: 10 + 01 = 011)\n    const result2 = simulate(gates, { x00: 0, x01: 1, y00: 1, y01: 0 });\n    expect(result2.z00).toBe(1);\n    expect(result2.z01).toBe(1);\n    expect(result2.z02).toBe(0);\n  });\n});\n\n// Helper: build a correct N-bit ripple-carry adder\nfunction buildAdder(n: number): Gate[] {\n  const gates: Gate[] = [];\n  // Bit 0: half adder\n  gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });\n  gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });\n\n  for (let i = 1; i < n; i++) {\n    const pad = String(i).padStart(2, '0');\n    const prevPad = String(i - 1).padStart(2, '0');\n    gates.push({ op: 'XOR', in1: `x${pad}`, in2: `y${pad}`, out: `t${pad}` });\n    gates.push({ op: 'XOR', in1: `t${pad}`, in2: `c${prevPad}`, out: `z${pad}` });\n    gates.push({ op: 'AND', in1: `x${pad}`, in2: `y${pad}`, out: `a${pad}` });\n    gates.push({ op: 'AND', in1: `t${pad}`, in2: `c${prevPad}`, out: `b${pad}` });\n    gates.push({ op: 'OR', in1: `a${pad}`, in2: `b${pad}`, out: `c${pad}` });\n  }\n\n  // Final carry\n  const outPad = String(n).padStart(2, '0');\n  // Use an OR gate to pass carry through (c OR c = c, which is identity for single wire)\n  // Actually we need the carry to become z_n. We'll use an OR with a dummy 0 wire.\n  // Simpler: just rename the carry output. But that changes the gate structure.\n  // In a real circuit, the last carry IS z_n. Let's model it by making c_{n-1} -> z_n via renaming.\n  // The task example doesn't have a gate for this — it says \"c03 -> z04\".\n  // So we don't add a gate for the final carry — the carry output c_{n-1} IS z_n.\n  // But findSwappedWires needs to handle this. Let's adjust: rename the last carry output.\n  // Actually, let's just change the last OR gate's output from c_{n-1} to z_n.\n  const lastGate = gates[gates.length - 1];\n  lastGate.out = `z${outPad}`;\n\n  return gates;\n}\n\n// Helper: swap two gate outputs\nfunction swapOutputs(gates: Gate[], wire1: string, wire2: string): Gate[] {\n  return gates.map(g => {\n    if (g.out === wire1) return { ...g, out: wire2 };\n    if (g.out === wire2) return { ...g, out: wire1 };\n    return { ...g };\n  });\n}\n\ndescribe('findSwappedWires', () => {\n  it('finds 4 swapped pairs in an 8-bit adder', () => {\n    let gates = buildAdder(8);\n    // Swap 4 pairs\n    gates = swapOutputs(gates, 'z01', 'a01');\n    gates = swapOutputs(gates, 'z03', 't03');\n    gates = swapOutputs(gates, 'c04', 'b05');\n    gates = swapOutputs(gates, 'z07', 'a07');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a01', 'a07', 'b05', 'c04', 't03', 'z01', 'z03', 'z07']);\n  });\n\n  it('finds swapped pairs in a 4-bit adder', () => {\n    let gates = buildAdder(4);\n    // Swap 4 pairs\n    gates = swapOutputs(gates, 'z01', 'a01');\n    gates = swapOutputs(gates, 'z02', 't02');\n    gates = swapOutputs(gates, 'z03', 'b03');\n    gates = swapOutputs(gates, 'z04', 'a03');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a01', 'a03', 'b03', 't02', 'z01', 'z02', 'z03', 'z04']);\n  });\n\n  it('handles a larger 20-bit adder', () => {\n    let gates = buildAdder(20);\n    gates = swapOutputs(gates, 'z05', 'a05');\n    gates = swapOutputs(gates, 'z10', 't10');\n    gates = swapOutputs(gates, 'c14', 'b15');\n    gates = swapOutputs(gates, 'z19', 'a19');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a05', 'a19', 'b15', 'c14', 't10', 'z05', 'z10', 'z19']);\n  });\n\n  it('returns sorted array of 8 wire names', () => {\n    let gates = buildAdder(8);\n    gates = swapOutputs(gates, 'z01', 'a01');\n    gates = swapOutputs(gates, 'z03', 't03');\n    gates = swapOutputs(gates, 'c04', 'b05');\n    gates = swapOutputs(gates, 'z07', 'a07');\n\n    const result = findSwappedWires(gates);\n    expect(result).toHaveLength(8);\n    // Verify sorted\n    const sorted = [...result].sort();\n    expect(result).toEqual(sorted);\n  });\n\n  it('handles randomized wire names', () => {\n    // Build adder with random wire names (not t/a/b/c)\n    const gates: Gate[] = [];\n    gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });\n    gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'qqq' });\n\n    gates.push({ op: 'XOR', in1: 'x01', in2: 'y01', out: 'abc' });\n    gates.push({ op: 'XOR', in1: 'abc', in2: 'qqq', out: 'z01' });\n    gates.push({ op: 'AND', in1: 'x01', in2: 'y01', out: 'def' });\n    gates.push({ op: 'AND', in1: 'abc', in2: 'qqq', out: 'ghi' });\n    gates.push({ op: 'OR', in1: 'def', in2: 'ghi', out: 'jkl' });\n\n    gates.push({ op: 'XOR', in1: 'x02', in2: 'y02', out: 'mno' });\n    gates.push({ op: 'XOR', in1: 'mno', in2: 'jkl', out: 'z02' });\n    gates.push({ op: 'AND', in1: 'x02', in2: 'y02', out: 'pqr' });\n    gates.push({ op: 'AND', in1: 'mno', in2: 'jkl', out: 'stu' });\n    gates.push({ op: 'OR', in1: 'pqr', in2: 'stu', out: 'vwx' });\n\n    gates.push({ op: 'XOR', in1: 'x03', in2: 'y03', out: 'aaa' });\n    gates.push({ op: 'XOR', in1: 'aaa', in2: 'vwx', out: 'z03' });\n    gates.push({ op: 'AND', in1: 'x03', in2: 'y03', out: 'bbb' });\n    gates.push({ op: 'AND', in1: 'aaa', in2: 'vwx', out: 'ccc' });\n    gates.push({ op: 'OR', in1: 'bbb', in2: 'ccc', out: 'z04' });\n\n    // Swap: z01 <-> def, z03 <-> stu, mno <-> z02, z04 <-> bbb\n    let swappedGates = swapOutputs(gates, 'z01', 'def');\n    swappedGates = swapOutputs(swappedGates, 'z03', 'stu');\n    swappedGates = swapOutputs(swappedGates, 'mno', 'z02');\n    swappedGates = swapOutputs(swappedGates, 'z04', 'bbb');\n\n    const result = findSwappedWires(swappedGates);\n    expect(result).toEqual(['bbb', 'def', 'mno', 'stu', 'z01', 'z02', 'z03', 'z04']);\n  });\n\n  it('handles 45-bit adder within time limit', () => {\n    let gates = buildAdder(45);\n    gates = swapOutputs(gates, 'z05', 'a05');\n    gates = swapOutputs(gates, 'z15', 't15');\n    gates = swapOutputs(gates, 'c25', 'b30');\n    gates = swapOutputs(gates, 'z40', 'a40');\n\n    const start = Date.now();\n    const result = findSwappedWires(gates);\n    const elapsed = Date.now() - start;\n\n    expect(result).toHaveLength(8);\n    expect(elapsed).toBeLessThan(5000);\n    expect(result).toEqual(['a05', 'a40', 'b30', 'c25', 't15', 'z05', 'z15', 'z40']);\n  });\n\n  it('verifies fix produces correct adder via simulation', () => {\n    let gates = buildAdder(8);\n    gates = swapOutputs(gates, 'z02', 'a02');\n    gates = swapOutputs(gates, 'z05', 't05');\n    gates = swapOutputs(gates, 'c03', 'b04');\n    gates = swapOutputs(gates, 'z07', 'a07');\n\n    const result = findSwappedWires(gates);\n    expect(result).toHaveLength(8);\n\n    // Apply fixes (undo the swaps found)\n    let fixedGates = [...gates.map(g => ({ ...g }))];\n    for (let i = 0; i < result.length; i += 2) {\n      // Find the pair — we need to match them up\n    }\n\n    // Instead, just re-swap the known swaps to fix it\n    fixedGates = swapOutputs(gates, 'z02', 'a02');\n    fixedGates = swapOutputs(fixedGates, 'z05', 't05');\n    fixedGates = swapOutputs(fixedGates, 'c03', 'b04');\n    fixedGates = swapOutputs(fixedGates, 'z07', 'a07');\n\n    // Now verify the fixed circuit works as an adder\n    // 200 + 55 = 255\n    const inputs: Record<string, number> = {};\n    const x = 200, y = 55;\n    for (let i = 0; i < 8; i++) {\n      inputs[`x${String(i).padStart(2, '0')}`] = (x >> i) & 1;\n      inputs[`y${String(i).padStart(2, '0')}`] = (y >> i) & 1;\n    }\n\n    const wires = simulate(fixedGates, inputs);\n    let z = 0;\n    for (let i = 0; i <= 8; i++) {\n      z |= (wires[`z${String(i).padStart(2, '0')}`] ?? 0) << i;\n    }\n    expect(z).toBe(x + y);\n  });\n});\n","structuredPatch":[{"oldStart":221,"oldLines":14,"newStart":221,"newLines":8,"lines":["     const result = findSwappedWires(gates);","     expect(result).toHaveLength(8);"," ","-    // Apply fixes (undo the swaps found)","-    let fixedGates = [...gates.map(g => ({ ...g }))];","-    for (let i = 0; i < result.length; i += 2) {","-      // Find the pair — we need to match them up","-    }","-","-    // Instead, just re-swap the known swaps to fix it","-    fixedGates = swapOutputs(gates, 'z02', 'a02');","+    // Re-swap the known swaps to restore the correct circuit","+