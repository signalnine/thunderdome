 Find gate by operation and input pair (order-independent)\n  function findGate(op: string, in1: string, in2: string): Gate | undefined {\n    const key = [in1, in2].sort().join(',');\n    const candidates = byInputs.get(key);\n    if (!candidates) return undefined;\n    return candidates.find(g => g.op === op);\n  }\n\n  // Determine number of input bits\n  let maxBit = 0;\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2]) {\n      const m = w.match(/^[xy](\\d+)$/);\n      if (m) maxBit = Math.max(maxBit, parseInt(m[1]));\n    }\n  }\n  const numBits = maxBit + 1;\n\n  // Helper to mark a wire as swapped\n  function markSwapped(wire: string): void {\n    swapped.add(wire);\n  }\n\n  // Swap two outputs in our working maps to \"fix\" the circuit as we go\n  function doSwap(wire1: string, wire2: string): void {\n    markSwapped(wire1);\n    markSwapped(wire2);\n\n    const g1 = byOutput.get(wire1);\n    const g2 = byOutput.get(wire2);\n\n    if (g1 && g2) {\n      // Swap outputs\n      g1.out = wire2;\n      g2.out = wire1;\n\n      // Update maps\n      byOutput.set(wire1, g2);\n      byOutput.set(wire2, g1);\n\n      // Rebuild input map for affected gates\n      rebuildInputMap(g1);\n      rebuildInputMap(g2);\n    }\n  }\n\n  function rebuildInputMap(g: Gate): void {\n    // Remove from old entries and re-add\n    for (const [key, arr] of byInputs) {\n      const idx = arr.indexOf(g);\n      if (idx !== -1) {\n        arr.splice(idx, 1);\n        if (arr.length === 0) byInputs.delete(key);\n        break;\n      }\n    }\n    const newKey = [g.in1, g.in2].sort().join(',');\n    if (!byInputs.has(newKey)) byInputs.set(newKey, []);\n    byInputs.get(newKey)!.push(g);\n  }\n\n  // Trace the adder structure bit by bit\n  let carry = '';\n\n  for (let bit = 0; bit < numBits; bit++) {\n    const pad = String(bit).padStart(2, '0');\n    const xWire = `x${pad}`;\n    const yWire = `y${pad}`;\n    const zWire = `z${pad}`;\n\n    if (bit === 0) {\n      // Half adder: x XOR y -> z00, x AND y -> carry\n      const xorGate = findGate('XOR', xWire, yWire);\n      const andGate = findGate('AND', xWire, yWire);\n\n      if (xorGate && xorGate.out !== zWire) {\n        // The XOR gate's output should be z00 — it's been swapped\n        doSwap(xorGate.out, zWire);\n      }\n\n      // After potential fix, get carry\n      const andGateFixed = findGate('AND', xWire, yWire);\n      carry = andGateFixed ? andGateFixed.out : '';\n    } else {\n      // Full adder structure:\n      // xNN XOR yNN -> partial (tNN)\n      // partial XOR carry_in -> zNN\n      // xNN AND yNN -> generate (aNN)\n      // partial AND carry_in -> propagate (bNN)\n      // generate OR propagate -> carry_out (cNN)\n\n      const xyXor = findGate('XOR', xWire, yWire);\n      if (!xyXor) continue;\n\n      let partial = xyXor.out;\n\n      // Check if partial is involved in XOR with carry to produce zNN\n      let sumXor = findGate('XOR', partial, carry);\n\n      if (!sumXor) {\n        // The partial or carry might be swapped.\n        // Look at what gate produces zNN — it should be an XOR\n        const zGate = byOutput.get(zWire);\n\n        if (zGate && zGate.op === 'XOR') {\n          // z gate takes two inputs; one should be carry, one should be partial\n          // Figure out which is wrong\n          const zIn1 = zGate.in1;\n          const zIn2 = zGate.in2;\n\n          if (zIn1 === carry) {\n            // zIn2 should be partial but isn't — partial is swapped with zIn2\n            doSwap(partial, zIn2);\n            partial = zIn2;\n          } else if (zIn2 === carry) {\n            // zIn1 should be partial but isn't\n            doSwap(partial, zIn1);\n            partial = zIn1;\n          } else if (zIn1 === partial) {\n            // zIn2 should be carry but isn't — carry is swapped with zIn2\n            doSwap(carry, zIn2);\n            carry = zIn2;\n          } else if (zIn2 === partial) {\n            doSwap(carry, zIn1);\n          