  for (const g of gates) {\n    for (const w of [g.in1, g.in2]) {\n      const m = w.match(/^[xy](\\d+)$/);\n      if (m) maxBit = Math.max(maxBit, parseInt(m[1]));\n    }\n  }\n  const numBits = maxBit + 1;\n\n  function buildLookups(): {\n    byOutput: Map<string, { op: string; in1: string; in2: string; out: string }>;\n    byInputOp: Map<string, string>;\n  } {\n    const byOutput = new Map<string, { op: string; in1: string; in2: string; out: string }>();\n    const byInputOp = new Map<string, string>();\n    for (const [out, info] of outputMap) {\n      const entry = { ...info, out };\n      byOutput.set(out, entry);\n      const key = [info.in1, info.in2].sort().join(',') + ':' + info.op;\n      byInputOp.set(key, out);\n    }\n    return { byOutput, byInputOp };\n  }\n\n  function findByInputOp(byInputOp: Map<string, string>, op: string, a: string, b: string): string | undefined {\n    const key = [a, b].sort().join(',') + ':' + op;\n    return byInputOp.get(key);\n  }\n\n  function doSwap(w1: string, w2: string): void {\n    swapped.add(w1);\n    swapped.add(w2);\n    const info1 = outputMap.get(w1)!;\n    const info2 = outputMap.get(w2)!;\n    outputMap.delete(w1);\n    outputMap.delete(w2);\n    outputMap.set(w1, info2);\n    outputMap.set(w2, info1);\n  }\n\n  // Iteratively trace the adder structure, fixing swaps as we find them.\n  // After each fix, restart from bit 0 since the carry chain may have changed.\n  let maxIterations = 10;\n  while (maxIterations-- > 0) {\n    const { byOutput, byInputOp } = buildLookups();\n    let foundSwap = false;\n    let carry = '';\n\n    for (let bit = 0; bit < numBits; bit++) {\n      const pad = String(bit).padStart(2, '0');\n      const xW = `x${pad}`;\n      const yW = `y${pad}`;\n      const zW = `z${pad}`;\n\n      if (bit === 0) {\n        // Half adder\n        const xorOut = findByInputOp(byInputOp, 'XOR', xW, yW);\n        if (xorOut && xorOut !== zW) {\n          doSwap(xorOut, zW);\n          foundSwap = t