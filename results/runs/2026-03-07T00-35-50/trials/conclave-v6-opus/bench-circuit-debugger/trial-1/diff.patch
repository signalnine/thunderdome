@@ -0,0 +1,227 @@
+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const pending = new Set(gates);
+
+  let progress = true;
+  while (pending.size > 0 && progress) {
+    progress = false;
+    for (const gate of pending) {
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        switch (gate.op) {
+          case 'AND': wires[gate.out] = a & b; break;
+          case 'OR':  wires[gate.out] = a | b; break;
+          case 'XOR': wires[gate.out] = a ^ b; break;
+        }
+        pending.delete(gate);
+        progress = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+export function findSwappedWires(gates: Gate[]): string[] {
+  // Work on a mutable copy of outputs
+  const outputMap = new Map<string, { op: Gate['op']; in1: string; in2: string }>();
+  for (const g of gates) {
+    outputMap.set(g.out, { op: g.op, in1: g.in1, in2: g.in2 });
+  }
+
+  const swapped = new Set<string>();
+
+  // Determine number of input bits
+  let maxBit = 0;
+  for (const g of gates) {
+    for (const w of [g.in1, g.in2]) {
+      const m = w.match(/^[xy](\d+)$/);
+      if (m) maxBit = Math.max(maxBit, parseInt(m[1]));
+    }
+  }
+  const numBits = maxBit + 1;
+
+  function buildLookups(): {
+    byOutput: Map<string, { op: string; in1: string; in2: string; out: string }>;
+    byInputOp: Map<string, string>;
+  } {
+    const byOutput = new Map<string, { op: string; in1: string; in2: string; out: string }>();
+    const byInputOp = new Map<string, string>();
+    for (const [out, info] of outputMap) {
+      const entry = { ...info, out };
+      byOutput.set(out, entry);
+      const key = [info.in1, info.in2].sort().join(',') + ':' + info.op;
+      byInputOp.set(key, out);
+    }
+    return { byOutput, byInputOp };
+  }
+
+  function findByInputOp(byInputOp: Map<string, string>, op: string, a: string, b: string): string | undefined {
+    const key = [a, b].sort().join(',') + ':' + op;
+    return byInputOp.get(key);
+  }
+
+  function doSwap(w1: string, w2: string): void {
+    swapped.add(w1);
+    swapped.add(w2);
+    const info1 = outputMap.get(w1)!;
+    const info2 = outputMap.get(w2)!;
+    outputMap.delete(w1);
+    outputMap.delete(w2);
+    outputMap.set(w1, info2);
+    outputMap.set(w2, info1);
+  }
+
+  // Iteratively trace the adder structure, fixing swaps as we find them.
+  // After each fix, restart from bit 0 since the carry chain may have changed.
+  let maxIterations = 10;
+  while (maxIterations-- > 0) {
+    const { byOutput, byInputOp } = buildLookups();
+    let foundSwap = false;
+    let carry = '';
+
+    for (let bit = 0; bit < numBits; bit++) {
+      const pad = String(bit).padStart(2, '0');
+      const xW = `x${pad}`;
+      const yW = `y${pad}`;
+      const zW = `z${pad}`;
+
+      if (bit === 0) {
+        // Half adder
+        const xorOut = findByInputOp(byInputOp, 'XOR', xW, yW);
+        if (xorOut && xorOut !== zW) {
+          doSwap(xorOut, zW);
+          foundSwap = true;
+          break;
+        }
+        const andOut = findByInputOp(byInputOp, 'AND', xW, yW);
+        carry = andOut ?? '';
+      } else {
+        // Full adder
+        const partial = findByInputOp(byInputOp, 'XOR', xW, yW);
+        if (!partial) continue;
+
+        // Check sum XOR: partial XOR carry -> zNN
+        const sumOut = findByInputOp(byInputOp, 'XOR', partial, carry);
+
+        if (!sumOut) {
+          // Can't find XOR(partial, carry).
+          // Either partial or carry output is swapped.
+          // Strategy: look at what gate produces zW and use its inputs to diagnose.
+          const zGate = byOutput.get(zW);
+
+          if (zGate && zGate.op === 'XOR') {
+            // zW is produced by an XOR — good type. Check which input is wrong.
+            const zIn1 = zGate.in1;
+            const zIn2 = zGate.in2;
+
+            if (zIn1 === carry || zIn2 === carry) {
+              // carry is correct, other input should be partial
+              const correctPartial = zIn1 === carry ? zIn2 : zIn1;
+              doSwap(partial, correctPartial);
+              foundSwap = true;
+              break;
+            } else if (zIn1 === partial || zIn2 === partial) {
+              // partial is correct, other input should be carry
+              const correctCarry = zIn1 === partial ? zIn2 : zIn1;
+              doSwap(carry, correctCarry);
+              foundSwap = true;
+              break;
+            } else {
+              // Neither partial nor carry appears in zGate inputs.
+              // The partial wire might have been swapped.
+              // Look for an XOR gate that uses carry as input (the sum XOR with wrong output)
+              let found = false;
+              for (const [, info] of outputMap) {
+                if (info.op === 'XOR' && (info.in1 === carry || info.in2 === carry)) {
+                  const otherIn = info.in1 === carry ? info.in2 : info.in1;
+                  // otherIn should equal partial but doesn't — swap them
+                  if (otherIn !== partial) {
+                    doSwap(partial, otherIn);
+                    foundSwap = true;
+                    found = true;
+                    break;
+                  }
+                }
+              }
+              if (found) break;
+            }
+          } else if (zGate && zGate.op !== 'XOR') {
+            // zW is produced by non-XOR gate — zW output was swapped
+            // Find the XOR gate that should produce zW
+            // It's the one that uses partial as input (not the input XOR)
+            let found = false;
+            for (const [out, info] of outputMap) {
+              if (info.op === 'XOR' && out !== partial) {
+                if (info.in1 === partial || info.in2 === partial ||
+                    info.in1 === carry || info.in2 === carry) {
+                  doSwap(out, zW);
+                  foundSwap = true;
+                  found = true;
+                  break;
+                }
+              }
+            }
+            if (found) break;
+          } else if (!zGate) {
+            // zW doesn't exist as an output — very unusual, skip
+            continue;
+          }
+
+          if (foundSwap) break;
+          continue;
+        }
+
+        if (sumOut !== zW) {
+          // The sum XOR exists but outputs to wrong wire
+          doSwap(sumOut, zW);
+          foundSwap = true;
+          break;
+        }
+
+        // Carry chain: AND(x,y) -> gen, AND(partial, carry) -> prop, OR(gen, prop) -> carry_out
+        const genOut = findByInputOp(byInputOp, 'AND', xW, yW);
+        const propOut = findByInputOp(byInputOp, 'AND', partial, carry);
+
+        if (genOut && propOut) {
