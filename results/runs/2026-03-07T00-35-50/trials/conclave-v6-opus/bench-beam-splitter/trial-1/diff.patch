+import { describe, test, expect } from 'vitest';
+import { countBeamCells, countBeamPaths } from './index.js';
+
+describe('countBeamCells', () => {
+  test('single source, no splitters - beam goes straight down', () => {
+    // S
+    // .
+    // .
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    // Visited: (0,1), (1,1), (2,1) = 3
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  test('source at edge of 1-row grid - only source cell visited', () => {
+    const grid = [['S']];
+    // Beam starts at (0,0), tries to move to (1,0) which is out of bounds
+    // Only the source cell is visited
+    expect(countBeamCells(grid)).toBe(1);
+  });
+
+  test('example from spec: single splitter', () => {
+    // . S . . .
+    // . . . . .
+    // . ^ . . .
+    // . . . . .
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    // Visited: (0,1), (1,1), (2,1), (3,0), (3,2) = 5
+    expect(countBeamCells(grid)).toBe(5);
+  });
+
+  test('example from spec: two splitters on row 2', () => {
+    // . S . . .
+    // . ^ . . .
+    // ^ . ^ . .
+    // . . . . .
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    // Visited: (0,1), (1,1), (2,0), (2,2), (3,1), (3,3) = 6
+    // Note: (3,-1) is out of bounds so not counted, (3,1) visited by two beams but counted once
+    expect(countBeamCells(grid)).toBe(6);
+  });
+
+  test('beam absorbed when going out of bounds left', () => {
+    // S . .
+    // ^ . .
+    // . . .
+    const grid = [
+      ['S', '.', '.'],
+      ['^', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    // Beam at (0,0), moves to (1,0) hits splitter
+    // down-left: (2,-1) absorbed
+    // down-right: (2,1) visited
+    // Visited: (0,0), (1,0), (2,1) = 3
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  test('beam absorbed when going out of bounds right', () => {
+    // . . S
+    // . . ^
+    // . . .
+    const grid = [
+      ['.', '.', 'S'],
+      ['.', '.', '^'],
+      ['.', '.', '.'],
+    ];
+    // Beam at (0,2), moves to (1,2) hits splitter
+    // down-left: (2,1) visited
+    // down-right: (2,3) absorbed
+    // Visited: (0,2), (1,2), (2,1) = 3
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  test('no splitters - straight line down', () => {
+    const grid = [
+      ['.', 'S'],
+      ['.', '.'],
+      ['.', '.'],
+      ['.', '.'],
+    ];
+    // Visited: (0,1), (1,1), (2,1), (3,1) = 4
+    expect(countBeamCells(grid)).toBe(4);
+  });
+
+  test('splitter hit by diagonal beam still splits', () => {
+    // . S .
+    // . ^ .
+    // . . ^
+    // . . .
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '^', '.'],
+      ['.', '.', '^'],
+      ['.', '.', '.'],
+    ];
+    // (0,1) S, moves down to (1,1) hits ^
+    // splits: down-left (2,0), down-right (2,2) hits ^
+    // (2,0) continues down-left to (3,-1) absorbed
+    // (2,2) ^ splits: down-left (3,1), down-right (3,3) absorbed
+    // Visited: (0,1), (1,1), (2,0), (2,2), (3,1) = 5
+    expect(countBeamCells(grid)).toBe(5);
+  });
+
+  test('multiple beams converge on same cell', () => {
+    // . . S . .
+    // . . ^ . .
+    // . . . . .
+    const grid = [
+      ['.', '.', 'S', '.', '.'],
+      ['.', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    // (0,2) S, moves to (1,2) hits ^
+    // splits: down-left (2,1), down-right (2,3)
+    // Visited: (0,2), (1,2), (2,1), (2,3) = 4
+    expect(countBeamCells(grid)).toBe(4);
+  });
+});
+
+describe('countBeamPaths', () => {
+  test('no splitters - single path straight down', () => {
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  test('single source, 1-row grid - single path', () => {
+    const grid = [['S']];
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  test('example from spec: single splitter gives 2 paths', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  test('example from spec: two splitters gives 4 paths', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    // 4 paths total (including the one absorbed at (3,-1))
+    expect(countBeamPaths(grid)).toBe(4n);
+  });
+
+  test('chain of splitters doubles paths each time', () => {
+    // S
+    // ^
+    // . ^
+    // . . .
+    // With proper grid:
+    // S . . .
+    // ^ . . .
+    // . . . .
+    const grid = [
+      ['S', '.', '.', '.'],
+      ['^', '.', '.', '.'],
+      ['.', '.', '.', '.'],
+    ];
+    // (0,0) S, moves to (1,0) ^
+    // splits: down-left (2,-1) absorbed, down-right (2,1)
+    // 2 paths
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  test('three sequential splitters in a chain', () => {
+    // . . . S . . .
+    // . . . ^ . . .
+    // . . ^ . ^ . .
+    // . ^ . . . ^ .
+    // . . . . . . .
+    const grid = [
+      ['.', '.', '.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '^', '.', '.', '.'],
+      ['.', '.', '^', '.', '^', '.', '.'],
+      ['.', '^', '.', '.', '.', '^', '.'],
+      ['.', '.', '.', '.', '.', '.', '.'],
+    ];
+    // S at (0,3), down to (1,3) ^
+    // splits: (2,2) ^ and (2,4) ^
+    // (2,2) ^ splits: (3,1) ^ and (3,3)
+    // (2,4) ^ splits: (3,3) and (3,5) ^
+    // (3,1) ^ splits: (4,0) and (4,2)
+    // (3,3): two beams arrive, each continues - but (3,3) is '.', so
+    //   beam from (2,2)^ going down-right arrives at (3,3) with direction down-right, continues to (4,4) - wait
+    //   Actually diagonal beams keep their direction.
+    // Let me re-trace:
+    // (0,3) S -> beam going DOWN
+    // (1,3) ^ -> splits: beam DOWN-LEFT and beam DOWN-RIGHT
+    // DOWN-LEFT beam: (2,2) ^ -> splits: DL beam and DR beam
+    //   DL: (3,1) ^ -> splits: DL (4,0) exits, DR (4,2) exits = 2 paths
+    //   DR: (3,3) '.' -> continues DR to (4,4) exits = 1 path
+    // DOWN-RIGHT beam: (2,4) ^ -> splits: DL beam and DR beam
+    //   DL: (3,3) '.' -> continues DL to (4,2) exits = 1 path
+    //   DR: (3,5) ^ -> splits: DL (4,4) exits, DR (4,6) exits = 2 paths
+    // Total: 2 + 1 + 1 + 2 = 6 paths
+    // But wait - beams at (3,3) from different directions. Each is its own beam.
+    // So we have 2^3 = 8 total path segments but some merge... no, paths don't merge.
+    // Actually 3 splitters hit total by each sub-path:
+    // Path through (1,3)->(2,2)->(3,1): 3 splitters, but each produces 2 children
+    // Total paths = each beam from S hits (1,3), producing 2 sub-beams
+    // Left sub-beam hits (2,2), producing 2 sub-beams (2 so far * 2 = 4)
+    //   Left-left hits (3,1) producing 2 sub-beams (contributes 2 paths)
+    //   Left-right goes to (3,3) no splitter (contributes 1 path)
+    // Right sub-beam hits (2,4), producing 2 sub-beams
+    //   Right-left goes to (3,3) no splitter (contributes 1 path)
+    //   Right-right hits (3,5) producing 2 sub-beams (contributes 2 paths)
+    // Total = 2 + 1 + 1 + 2 = 6
+    expect(countBeamPaths(grid)).toBe(6n);
+  });
+
+  test('splitter where one branch is immediately absorbed', () => {
+    const grid = [
+      ['S', '.'],
+      ['^', '.'],
+      ['.', '.'],
+    ];
+    // (0,0) S down to (1,0) ^
+    // DL: (2,-1) absorbed - still counts as a path
+    // DR: (2,1)
+    // 2 paths
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+});
+
+describe('performance', () => {
+  test('200x200 grid with 50 splitters where both branches reconverge completes in under 5 seconds', () => {
+    // Adversarial case: splitters arranged so that both DL and DR beams
+    // from each splitter converge on the next splitter.
+    // Splitter at (r, c): DL goes to (r+1, c-1), DR goes to (r+1, c+1)
+    // If we place the next splitter at (r+2, c), both DL and DR beams
+    // will hit it (DL continues DL to (r+2, c-2) - no, that misses).
+    // Actually: splitter at (r,c) -> DL beam at (r+1,c-1) with dir DL
+    //   -> continues to (r+2,c-2). Splitter at (r,c) -> DR beam at (r+1,c+1) with dir DR
+    //   -> continues to (r+2,c+2). They don't reconverge.
+    //
+    // To reconverge: place TWO splitters at the next level.
+    // (r,c) splits to (r+1,c-1) and (r+1,c+1)
+    // Place splitters at (r+1,c-1) and (r+1,c+1)
+    // Each of those splits again. (r+1,c-1) -> (r+2,c-2) and (r+2,c)
+    // (r+1,c+1) -> (r+2,c) and (r+2,c+2)
+    // Both send a beam to (r+2,c)! If there's a splitter there,
+    // 2 beams converge and each splits again.
+    // This gives a binary tree that folds back, creating exponential paths.
+    //
+    // Pattern: rows spaced 1 apart, alternating between single center and two wings
+    // Row 0: S at col 100
+    // Row 1: ^ at col 100 (hit by down beam)
+    // Row 2: ^ at col 99, ^ at col 101 (hit by DL and DR)
+    // Row 3: ^ at col 100 (hit by DR from 99 and DL from 101) - plus (98) and (102)
+    // But we want maximum reconvergence with only 50 splitters.
+    // Best: alternate single and pair: 1 splitter, then 2, then 1, then 2...
+    // With 50 splitters: ~16-17 layers
+    const rows = 200;
+    const cols = 200;
+    const grid: string[][] = Array.from({ length: rows }, () =>
+      Array.from({ length: cols }, () => '.')
+    );
+    grid[0][100] = 'S';
+
+    let splitterCount = 0;
+    // Layer 0 (row 1): single splitter at center
+    grid[1][100] = '^'; splitterCount++;
+    // Then alternate: pair at +/-1, single at center
+    let r = 2;
+    while (splitterCount < 50 && r < rows) {
+      // Pair layer
+      if (splitterCount + 2 <= 50 && 99 >= 0 && 101 < cols) {
+        grid[r][99] = '^'; splitterCount++;
+        grid[r][101] = '^'; splitterCount++;
+      }
+      r++;
+      if (splitterCount >= 50 || r >= rows) break;
+      // Single center layer
+      grid[r][100] = '^'; splitterCount++;
+      r++;
+    }
+
+    const start = performance.now();
+    const cells = countBeamCells(grid);
+    const paths = countBeamPaths(grid);
+    const elapsed = performance.now() - start;
+
+    expect(cells).toBeGreaterThan(0);
+    expect(paths).toBeGreaterThan(0n);
+    expect(elapsed).toBeLessThan(5000);
+  });
+});
