@@ -0,0 +1,127 @@
+const DIR_DOWN = 0;
+const DIR_DOWN_LEFT = 1;
+const DIR_DOWN_RIGHT = 2;
+type Dir = 0 | 1 | 2;
+
+function findSource(grid: string[][]): number {
+  for (let col = 0; col < grid[0].length; col++) {
+    if (grid[0][col] === 'S') return col;
+  }
+  throw new Error('No source found on top row');
+}
+
+function encodeState(row: number, col: number, dir: Dir, cols: number): number {
+  return (row * cols + col) * 3 + dir;
+}
+
+function advance(row: number, col: number, dir: Dir): [number, number] {
+  switch (dir) {
+    case DIR_DOWN: return [row + 1, col];
+    case DIR_DOWN_LEFT: return [row + 1, col - 1];
+    case DIR_DOWN_RIGHT: return [row + 1, col + 1];
+  }
+}
+
+interface BeamState {
+  row: number;
+  col: number;
+  dir: Dir;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const srcCol = findSource(grid);
+  const visitedCells = new Set<number>();
+  visitedCells.add(srcCol);
+
+  const visitedStates = new Set<number>();
+  visitedStates.add(encodeState(0, srcCol, DIR_DOWN, cols));
+
+  const queue: BeamState[] = [{ row: 0, col: srcCol, dir: DIR_DOWN }];
+
+  while (queue.length > 0) {
+    const { row, col, dir } = queue.pop()!;
+    const [nr, nc] = advance(row, col, dir);
+
+    if (nr < 0 || nr >= rows || nc < 0 || nc >= cols) continue;
+
+    visitedCells.add(nr * cols + nc);
+
+    if (grid[nr][nc] === '^') {
+      const kL = encodeState(nr, nc, DIR_DOWN_LEFT, cols);
+      if (!visitedStates.has(kL)) {
+        visitedStates.add(kL);
+        queue.push({ row: nr, col: nc, dir: DIR_DOWN_LEFT });
+      }
+      const kR = encodeState(nr, nc, DIR_DOWN_RIGHT, cols);
+      if (!visitedStates.has(kR)) {
+        visitedStates.add(kR);
+        queue.push({ row: nr, col: nc, dir: DIR_DOWN_RIGHT });
+      }
+    } else {
+      const k = encodeState(nr, nc, dir, cols);
+      if (!visitedStates.has(k)) {
+        visitedStates.add(k);
+        queue.push({ row: nr, col: nc, dir });
+      }
+    }
+  }
+
+  return visitedCells.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const srcCol = findSource(grid);
+
+  let totalPaths = 0n;
+
+  // Map from encoded state to (beamState, pathCount)
+  let current = new Map<number, [BeamState, bigint]>();
+  const initKey = encodeState(0, srcCol, DIR_DOWN, cols);
+  current.set(initKey, [{ row: 0, col: srcCol, dir: DIR_DOWN }, 1n]);
+
+  while (current.size > 0) {
+    const next = new Map<number, [BeamState, bigint]>();
+
+    for (const [, [state, paths]] of current) {
+      const [nr, nc] = advance(state.row, state.col, state.dir);
+
+      if (nr < 0 || nr >= rows || nc < 0 || nc >= cols) {
+        totalPaths += paths;
+        continue;
+      }
+
+      if (grid[nr][nc] === '^') {
+        const kL = encodeState(nr, nc, DIR_DOWN_LEFT, cols);
+        const existingL = next.get(kL);
+        if (existingL) {
+          existingL[1] += paths;
+        } else {
+          next.set(kL, [{ row: nr, col: nc, dir: DIR_DOWN_LEFT }, paths]);
+        }
+        const kR = encodeState(nr, nc, DIR_DOWN_RIGHT, cols);
+        const existingR = next.get(kR);
+        if (existingR) {
+          existingR[1] += paths;
+        } else {
+          next.set(kR, [{ row: nr, col: nc, dir: DIR_DOWN_RIGHT }, paths]);
+        }
+      } else {
+        const k = encodeState(nr, nc, state.dir, cols);
+        const existing = next.get(k);
+        if (existing) {
+          existing[1] += paths;
+        } else {
+          next.set(k, [{ row: nr, col: nc, dir: state.dir }, paths]);
+        }
+      }
+    }
+
+    current = next;
+  }
+
+  return totalPaths;
+}
