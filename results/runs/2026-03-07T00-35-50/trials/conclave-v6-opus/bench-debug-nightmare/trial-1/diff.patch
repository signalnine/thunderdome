  if (!order) return undefined;\n    if (order.status !== 'confirmed') return undefined;\n\n    // Emit cancellation event, then update status\n    await this.eventBus.emit(ORDER_EVENTS.CANCELLED, {\n      orderId: id,\n      reason,\n      items: order.items.map((i) => ({\n        productId: i.productId,\n        quantity: i.quantity,\n      })),\n      timestamp: Date.now(),\n    });\n\n    this.repo.update(id, { status: 'cancelled' });\n\n    return this.repo.findById(id);\n  }\n\n  async refundOrder(id: string): Promise<Order | undefined> {\n    const order = this.repo.findById(id);\n    if (!order) return undefined;\n    if (order.status !== 'cancelled') return undefined;\n\n    const daysSinceCreation = Math.floor(\n      (Date.now() - order.createdAt) / (1000 * 60 * 60 * 24)\n    );\n\n    if (daysSinceCreation >= REFUND_WINDOW_DAYS) {\n      throw new Error(\n        `Refund window expired: ${daysSinceCreation} days since order (max ${REFUND_WINDOW_DAYS})`\n      );\n    }\n\n    await this.billingService.issueRefund(id, order.total);\n    this.repo.update(id, { status: 'refunded' });\n\n    return this.repo.findById(id);\n  }\n\n  getOrder(id: string): Order | undefined {\n    return this.repo.findById(id);\n  }\n\n  getOrdersByCustomer(customerId: string): Order[] {\n    return this.repo.findByCustomer(customerId);\n  }\n}\n","numLines":119,"startLine":1,"totalLines":119}}}
