index 0000000..6b374e5
--- /dev/null
+++ b/src/evaluator.ts
@@ -0,0 +1,139 @@
+import { ASTNode, CellValue } from './types.js';
+import { expandRange } from './cells.js';
+
+export type CellLookup = (ref: string) => CellValue;
+
+export function evaluate(node: ASTNode, lookup: CellLookup): CellValue {
+  switch (node.type) {
+    case 'number':
+      return node.value;
+    case 'string':
+      return node.value;
+    case 'boolean':
+      return node.value;
+    case 'cell': {
+      const val = lookup(node.ref);
+      return val;
+    }
+    case 'unary': {
+      const operand = evaluate(node.operand, lookup);
+      if (node.op === '-') {
+        return -(toNumber(operand));
+      }
+      throw new Error(`Unknown unary operator: ${node.op}`);
+    }
+    case 'binary':
+      return evaluateBinary(node.op, node.left, node.right, lookup);
+    case 'function':
+      return evaluateFunction(node.name, node.args, lookup);
+    case 'range':
+      throw new Error('Range cannot be evaluated directly');
+  }
+}
+
+function toNumber(val: CellValue): number {
+  if (val === null) return 0;
+  if (typeof val === 'number') return val;
+  if (typeof val === 'boolean') return val ? 1 : 0;
+  const n = Number(val);
+  return isNaN(n) ? 0 : n;
+}
+
+function evaluateBinary(op: string, left: ASTNode, right: ASTNode, lookup: CellLookup): CellValue {
+  const l = evaluate(left, lookup);
+  const r = evaluate(right, lookup);
+  const ln = toNumber(l);
+  const rn = toNumber(r);
+
+  switch (op) {
+    case '+': return ln + rn;
+    case '-': return ln - rn;
+    case '*': return ln * rn;
+    case '/': return ln / rn;
+    case '>': return ln > rn;
+    case '<': return ln < rn;
+    case '>=': return ln >= rn;
+    case '<=': return ln <= rn;
+    case '=': return l === r || ln === rn;
+    case '<>': return l !== r && ln !== rn;
+    default:
+      throw new Error(`Unknown operator: ${op}`);
+  }
+}
+
+function resolveRangeValues(args: ASTNode[], lookup: CellLookup): number[] {
+  const values: number[] = [];
+  for (const arg of args) {
+    if (arg.type === 'range') {
+      const cells = expandRange(arg.start, arg.end);
+      for (const ref of cells) {
+        const val = lookup(ref);
+        if (typeof val === 'number') {
+          values.push(val);
+        }
+      }
+    } else {
+      const val = evaluate(arg, lookup);
+      if (typeof val === 'number') {
+        values.push(val);
+      }
+    }
+  }
+  return values;
+}
+
+function countNumericValues(args: ASTNode[], lookup: CellLookup): number {
+  let count = 0;
+  for (const arg of args) {
+    if (arg.type === 'range') {
+      const cells = expandRange(arg.start, arg.end);
+      for (const ref of cells) {
+        const val = lookup(ref);
+        if (typeof val === 'number') {
+          count++;
+        }
+      }
+    } else {
+      const val = evaluate(arg, lookup);
+      if (typeof val === 'number') {
+        count++;
+      }
+    }
+  }
+  return count;
+}
+
+function evaluateFunction(name: string, args: ASTNode[], lookup: CellLookup): CellValue {
+  switch (name.toUpperCase()) {
+    case 'SUM': {
+      const values = resolveRangeValues(args, lookup);
+      return values.reduce((a, b) => a + b, 0);
+    }
+    case 'AVERAGE': {
+      const values = resolveRangeValues(args, lookup);
+      if (values.length === 0) return 0;
+      return values.reduce((a, b) => a + b, 0) / values.length;
+    }
+    case 'MIN': {
+      const values = resolveRangeValues(args, lookup);
+      if (values.length === 0) return 0;
+      return Math.min(...values);
+    }
+    case 'MAX': {
+      const values = resolveRangeValues(args, lookup);
+      if (values.length === 0) return 0;
+      return Math.max(...values);
+    }
+    case 'COUNT': {
+      return countNumericValues(args, lookup);
+    }
+    case 'IF': {
+      if (args.length < 3) throw new Error('IF requires 3 arguments');
+      const condition = evaluate(args[0], lookup);
+      const isTruthy = typeof condition === 'boolean' ? condition : toNumber(condition) !== 0;
+      return evaluate(isTruthy ? args[1] : args[2], lookup);
+    }
+    default:
+      throw new Error(`Unknown function: ${name}`);
+  }
+}
