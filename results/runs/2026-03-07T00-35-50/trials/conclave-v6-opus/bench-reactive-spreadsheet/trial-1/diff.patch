+++ b/src/index.ts
@@ -0,0 +1,174 @@
+import { CellValue, ASTNode } from './types.js';
+import { parse, extractCellRefs } from './parser.js';
+import { evaluate } from './evaluator.js';
+
+interface CellData {
+  raw: string | number | boolean;
+  formula: ASTNode | null;
+  value: CellValue;
+  dependencies: Set<string>;
+}
+
+export class Spreadsheet {
+  private cells: Map<string, CellData> = new Map();
+  private dependents: Map<string, Set<string>> = new Map();
+
+  set(cell: string, value: string | number | boolean): void {
+    const ref = cell.toUpperCase();
+    const oldData = this.cells.get(ref);
+
+    // Remove old dependency edges
+    if (oldData) {
+      for (const dep of oldData.dependencies) {
+        this.dependents.get(dep)?.delete(ref);
+      }
+    }
+
+    // Parse formula if applicable
+    let formula: ASTNode | null = null;
+    let dependencies = new Set<string>();
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      formula = parse(value.substring(1));
+      const refs = extractCellRefs(formula);
+      dependencies = new Set(refs.map(r => r.toUpperCase()));
+    }
+
+    // Check for circular references before committing
+    if (dependencies.size > 0) {
+      if (this.wouldCreateCycle(ref, dependencies)) {
+        // Restore old dependency edges
+        if (oldData) {
+          for (const dep of oldData.dependencies) {
+            if (!this.dependents.has(dep)) {
+              this.dependents.set(dep, new Set());
+            }
+            this.dependents.get(dep)!.add(ref);
+          }
+        }
+        throw new Error(`Circular reference detected for cell ${ref}`);
+      }
+    }
+
+    // Add new dependency edges
+    for (const dep of dependencies) {
+      if (!this.dependents.has(dep)) {
+        this.dependents.set(dep, new Set());
+      }
+      this.dependents.get(dep)!.add(ref);
+    }
+
+    // Compute value
+    const computed = formula
+      ? evaluate(formula, (r) => this.getCellValue(r))
+      : value;
+
+    const cellData: CellData = {
+      raw: value,
+      formula,
+      value: computed as CellValue,
+      dependencies,
+    };
+
+    this.cells.set(ref, cellData);
+
+    // Reactively update all dependents
+    this.propagateUpdates(ref);
+  }
+
+  get(cell: string): CellValue {
+    return this.getCellValue(cell.toUpperCase());
+  }
+
+  getDisplay(cell: string): string {
+    const val = this.get(cell);
+    if (val === null) return '';
+    if (typeof val === 'boolean') return val ? 'TRUE' : 'FALSE';
+    return String(val);
+  }
+
+  getCells(): Map<string, CellValue> {
+    const result = new Map<string, CellValue>();
+    for (const [ref, data] of this.cells) {
+      result.set(ref, data.value);
+    }
+    return result;
+  }
+
+  private getCellValue(ref: string): CellValue {
+    const data = this.cells.get(ref);
+    if (!data) return null;
+    return data.value;
+  }
+
+  private wouldCreateCycle(cell: string, newDeps: Set<string>): boolean {
+    // Check if cell is in newDeps (self-reference)
+    if (newDeps.has(cell)) return true;
+
+    // DFS from each dependency to see if we can reach cell
+    const visited = new Set<string>();
+    const stack = [...newDeps];
+
+    while (stack.length > 0) {
+      const current = stack.pop()!;
+      if (current === cell) return true;
+      if (visited.has(current)) continue;
+      visited.add(current);
+
+      // Follow the dependency chain of `current`
+      const currentData = this.cells.get(current);
+      if (currentData) {
+        for (const dep of currentData.dependencies) {
+          if (!visited.has(dep)) {
+            stack.push(dep);
+          }
+        }
+      }
+    }
+
+    return false;
+  }
+
+  private propagateUpdates(changedCell: string): void {
+    // Topological sort of all transitive dependents
+    const order = this.getTopologicalOrder(changedCell);
+
+    for (const ref of order) {
+      const data = this.cells.get(ref);
+      if (data && data.formula) {
+        data.value = evaluate(data.formula, (r) => this.getCellValue(r));
+      }
+    }
+  }
+
+  private getTopologicalOrder(startCell: string): string[] {
+    const visited = new Set<string>();
+    const order: string[] = [];
+
+    const visit = (cell: string): void => {
+      if (visited.has(cell)) return;
+      visited.add(cell);
+
+      const deps = this.dependents.get(cell);
+      if (deps) {
+        for (const dep of deps) {
+          visit(dep);
+        }
+      }
+
+      order.push(cell);
+    };
+
+    // Start from the changed cell's dependents
+    const directDeps = this.dependents.get(startCell);
+    if (directDeps) {
+      for (const dep of directDeps) {
+        visit(dep);
+      }
+    }
+
+    // Post-order DFS puts the deepest dependents first in the list.
+    // We need to evaluate in reverse: shallow dependents before deep ones.
+    return order.reverse();
+  }
+}
