+import { describe, test, expect } from 'vitest';
+import { columnToIndex, indexToColumn, parseCellRef, expandRange } from './cells.js';
+
+describe('columnToIndex', () => {
+  test('converts single letter columns', () => {
+    expect(columnToIndex('A')).toBe(0);
+    expect(columnToIndex('B')).toBe(1);
+    expect(columnToIndex('Z')).toBe(25);
+  });
+
+  test('converts multi-letter columns', () => {
+    expect(columnToIndex('AA')).toBe(26);
+    expect(columnToIndex('AB')).toBe(27);
+    expect(columnToIndex('AZ')).toBe(51);
+    expect(columnToIndex('BA')).toBe(52);
+  });
+});
+
+describe('indexToColumn', () => {
+  test('converts index to single letter', () => {
+    expect(indexToColumn(0)).toBe('A');
+    expect(indexToColumn(1)).toBe('B');
+    expect(indexToColumn(25)).toBe('Z');
+  });
+
+  test('converts index to multi-letter', () => {
+    expect(indexToColumn(26)).toBe('AA');
+    expect(indexToColumn(27)).toBe('AB');
+    expect(indexToColumn(51)).toBe('AZ');
+    expect(indexToColumn(52)).toBe('BA');
+  });
+});
+
+describe('parseCellRef', () => {
+  test('parses simple cell references', () => {
+    expect(parseCellRef('A1')).toEqual({ col: 0, row: 0 });
+    expect(parseCellRef('B2')).toEqual({ col: 1, row: 1 });
+    expect(parseCellRef('Z100')).toEqual({ col: 25, row: 99 });
+  });
+
+  test('parses multi-letter column references', () => {
+    expect(parseCellRef('AA1')).toEqual({ col: 26, row: 0 });
+    expect(parseCellRef('AB3')).toEqual({ col: 27, row: 2 });
+  });
+});
+
+describe('expandRange', () => {
+  test('expands column range', () => {
+    expect(expandRange('A1', 'A3')).toEqual(['A1', 'A2', 'A3']);
+  });
+
+  test('expands row range', () => {
+    expect(expandRange('A1', 'C1')).toEqual(['A1', 'B1', 'C1']);
+  });
+
+  test('expands block range', () => {
+    const result = expandRange('A1', 'B2');
+    expect(result).toEqual(['A1', 'A2', 'B1', 'B2']);
+  });
+
+  test('expands single cell range', () => {
+    expect(expandRange('A1', 'A1')).toEqual(['A1']);
+  });
+});
