+export type CellValue = string | number | boolean | null;
+
+export type ASTNode =
+  | NumberLiteral
+  | StringLiteral
+  | BooleanLiteral
+  | CellRef
+  | BinaryOp
+  | UnaryOp
+  | FunctionCall
+  | RangeRef;
+
+export interface NumberLiteral {
+  type: 'number';
+  value: number;
+}
+
+export interface StringLiteral {
+  type: 'string';
+  value: string;
+}
+
+export interface BooleanLiteral {
+  type: 'boolean';
+  value: boolean;
+}
+
+export interface CellRef {
+  type: 'cell';
+  ref: string; // e.g. "A1"
+}
+
+export interface RangeRef {
+  type: 'range';
+  start: string; // e.g. "A1"
+  end: string;   // e.g. "A5"
+}
+
+export interface BinaryOp {
