+      expect(cells.get('A2')).toBe(20);
+      expect(cells.get('A3')).toBe(30);
+    });
+  });
+
+  describe('example from spec', () => {
+    test('matches the example usage exactly', () => {
+      const sheet = new Spreadsheet();
+
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
