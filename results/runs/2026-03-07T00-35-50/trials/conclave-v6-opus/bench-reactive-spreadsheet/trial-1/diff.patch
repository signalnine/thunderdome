+import { describe, test, expect } from 'vitest';
+import { parse } from './parser.js';
+
+describe('parse', () => {
+  test('parses number literals', () => {
+    expect(parse('42')).toEqual({ type: 'number', value: 42 });
+    expect(parse('3.14')).toEqual({ type: 'number', value: 3.14 });
+  });
+
+  test('parses string literals', () => {
+    expect(parse('"hello"')).toEqual({ type: 'string', value: 'hello' });
+  });
+
+  test('parses boolean literals', () => {
+    expect(parse('true')).toEqual({ type: 'boolean', value: true });
+    expect(parse('false')).toEqual({ type: 'boolean', value: false });
+  });
+
+  test('parses cell references', () => {
+    expect(parse('A1')).toEqual({ type: 'cell', ref: 'A1' });
+    expect(parse('AA10')).toEqual({ type: 'cell', ref: 'AA10' });
+  });
+
+  test('parses addition', () => {
+    expect(parse('A1+B1')).toEqual({
+      type: 'binary',
+      op: '+',
+      left: { type: 'cell', ref: 'A1' },
+      right: { type: 'cell', ref: 'B1' },
+    });
+  });
+
+  test('parses subtraction', () => {
+    expect(parse('A1-B1')).toEqual({
+      type: 'binary',
+      op: '-',
+      left: { type: 'cell', ref: 'A1' },
+      right: { type: 'cell', ref: 'B1' },
+    });
+  });
+
+  test('parses multiplication with higher precedence than addition', () => {
+    // A1 + B1 * C1 should be A1 + (B1 * C1)
+    expect(parse('A1+B1*C1')).toEqual({
+      type: 'binary',
+      op: '+',
+      left: { type: 'cell', ref: 'A1' },
+      right: {
+        type: 'binary',
+        op: '*',
+        left: { type: 'cell', ref: 'B1' },
+        right: { type: 'cell', ref: 'C1' },
+      },
+    });
+  });
+
+  test('parses parentheses for grouping', () => {
+    expect(parse('(A1+B1)*2')).toEqual({
+      type: 'binary',
+      op: '*',
+      left: {
+        type: 'binary',
+        op: '+',
+        left: { type: 'cell', ref: 'A1' },
+        right: { type: 'cell', ref: 'B1' },
+      },
+      right: { type: 'number', value: 2 },
+    });
+  });
+
+  test('parses unary minus', () => {
+    expect(parse('-A1')).toEqual({
+      type: 'unary',
+      op: '-',
+      operand: { type: 'cell', ref: 'A1' },
+    });
+  });
+
+  test('parses function calls', () => {
+    expect(parse('SUM(A1:A5)')).toEqual({
+      type: 'function',
+      name: 'SUM',
+      args: [{ type: 'range', start: 'A1', end: 'A5' }],
+    });
+  });
+
+  test('parses IF with comparison', () => {
+    expect(parse('IF(A1>30,"big","small")')).toEqual({
+      type: 'function',
+      name: 'IF',
+      args: [
+        {
+          type: 'binary',
+          op: '>',
+          left: { type: 'cell', ref: 'A1' },
+          right: { type: 'number', value: 30 },
+        },
+        { type: 'string', value: 'big' },
+        { type: 'string', value: 'small' },
+      ],
+    });
+  });
+
+  test('parses comparison operators', () => {
+    expect(parse('A1>=B1')).toEqual({
+      type: 'binary',
+      op: '>=',
+      left: { type: 'cell', ref: 'A1' },
+      right: { type: 'cell', ref: 'B1' },
+    });
+
+    expect(parse('A1<>B1')).toEqual({
+      type: 'binary',
+      op: '<>',
+      left: { type: 'cell', ref: 'A1' },
+      right: { type: 'cell', ref: 'B1' },
+    });
+
+    expect(parse('A1=B1')).toEqual({
+      type: 'binary',
+      op: '=',
+      left: { type: 'cell', ref: 'A1' },
+      right: { type: 'cell', ref: 'B1' },
+    });
+  });
+
+  test('parses division', () => {
+    expect(parse('A1/B1')).toEqual({
+      type: 'binary',
+      op: '/',
+      left: { type: 'cell', ref: 'A1' },
+      right: { type: 'cell', ref: 'B1' },
+    });
+  });
+
+  test('parses nested function calls', () => {
+    expect(parse('SUM(A1,B1)')).toEqual({
+      type: 'function',
+      name: 'SUM',
+      args: [
+        { type: 'cell', ref: 'A1' },
+        { type: 'cell', ref: 'B1' },
+      ],
+    });
+  });
+});
