+import { describe, it, expect } from 'vitest';
+import { createRunner } from './index.js';
+
+describe('RunnerService', () => {
+  const runner = createRunner();
+
+  describe('execute', () => {
+    it('executes simple code and returns result', async () => {
+      const result = await runner.execute('result = 2 + 2');
+      expect(result.success).toBe(true);
+      expect(result.output).toBe(4);
+      expect(result.duration).toBeGreaterThanOrEqual(0);
+      expect(result.memoryUsed).toBeGreaterThanOrEqual(0);
+    });
+
+    it('returns error for failing code', async () => {
+      const result = await runner.execute('throw new Error("boom")');
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('boom');
+    });
+
+    it('passes context variables into sandbox', async () => {
+      const result = await runner.execute('result = x + y', { x: 10, y: 20 });
+      expect(result.success).toBe(true);
+      expect(result.output).toBe(30);
+    });
+
+    it('isolates executions from each other', async () => {
+      await runner.execute('globalValue = 42');
+      const result = await runner.execute('result = typeof globalValue');
+      expect(result.output).toBe('undefined');
+    });
+
+    it('handles syntax errors', async () => {
+      const result = await runner.execute('if (');
+      expect(result.success).toBe(false);
+      expect(result.error).toBeDefined();
+    });
+  });
+
+  describe('executeWithTimeout', () => {
+    it('executes code within timeout', async () => {
+      const result = await runner.executeWithTimeout('result = 1 + 1', 1000);
+      expect(result.success).toBe(true);
+      expect(result.output).toBe(2);
+    });
+
+    it('aborts code that exceeds timeout', async () => {
+      const result = await runner.executeWithTimeout('while(true) {}', 100);
+      expect(result.success).toBe(false);
+      expect(result.error).toBeDefined();
+    });
+
+    it('reports duration accurately', async () => {
+      const result = await runner.executeWithTimeout('result = "fast"', 5000);
+      expect(result.success).toBe(true);
+      expect(result.duration).toBeLessThan(5000);
+    });
+  });
+});
