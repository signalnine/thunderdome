, comment: 'c',\n      });\n\n      const result = reviews.getReviews('plugin-a');\n      expect(result.length).toBe(2);\n    });\n\n    it('returns empty array for plugin with no reviews', () => {\n      expect(reviews.getReviews('unknown')).toEqual([]);\n    });\n  });\n\n  describe('getAverageRating', () => {\n    it('computes average of all non-flagged reviews', () => {\n      reviews.addReview({\n        pluginName: 'p', pluginVersion: '1.0.0',\n        userId: 'u1', rating: 4, comment: 'a',\n      });\n      reviews.addReview({\n        pluginName: 'p', pluginVersion: '1.0.0',\n        userId: 'u2', rating: 2, comment: 'b',\n      });\n      expect(reviews.getAverageRating('p')).toBe(3);\n    });\n\n    it('excludes flagged reviews from average', () => {\n      const r1 = reviews.addReview({\n        pluginName: 'p', pluginVersion: '1.0.0',\n        userId: 'u1', rating: 1, comment: 'spam',\n      });\n      reviews.addReview({\n        pluginName: 'p', pluginVersion: '1.0.0',\n        userId: 'u2', rating: 4, comment: 'good',\n      });\n      reviews.flagReview(r1.id);\n      expect(reviews.getAverageRating('p')).toBe(4);\n    });\n\n    it('returns 0 for plugin with no reviews', () => {\n      expect(reviews.getAverageRating('unknown')).toBe(0);\n    });\n  });\n\n  describe('flagReview', () => {\n    it('marks a review as flagged', () => {\n      const review = reviews.addReview({\n        pluginName: 'p', pluginVersion: '1.0.0',\n        userId: 'u1', rating: 1, comment: 'spam',\n      });\n      reviews.flagReview(review.id);\n      const flagged = reviews.getFlaggedReviews();\n      expect(flagged.length).toBe(1);\n      expect(flagged[0].id).toBe(review.id);\n      expect(flagged[0].flagged).toBe(true);\n    });\n  });\n\n  describe('getFlaggedReviews', () => {\n    it('returns only flagged reviews', () => {\n      const r1 = reviews.addReview({\n        pluginName: 'p', pluginVersion: '1.0.0',\n        userId: 'u1', rating: 1, comment: 'spam',\n      