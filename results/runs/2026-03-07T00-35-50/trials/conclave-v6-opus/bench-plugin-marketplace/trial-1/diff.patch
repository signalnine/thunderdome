+import { describe, it, expect, beforeEach } from 'vitest';
+import type { PluginManifest } from '../types.js';
+import { createRegistry } from './index.js';
+
+function makeManifest(overrides: Partial<PluginManifest> = {}): PluginManifest {
+  return {
+    name: 'test-plugin',
+    version: '1.0.0',
+    description: 'A test plugin',
+    author: 'tester',
+    dependencies: {},
+    entryPoint: 'console.log("hello")',
+    permissions: [],
+    ...overrides,
+  };
+}
+
+describe('RegistryService', () => {
+  let registry: ReturnType<typeof createRegistry>;
+
+  beforeEach(() => {
+    registry = createRegistry();
+  });
+
+  describe('register', () => {
+    it('registers a plugin manifest', () => {
+      const manifest = makeManifest();
+      registry.register(manifest);
+      const result = registry.get('test-plugin');
+      expect(result).not.toBeNull();
+      expect(result!.name).toBe('test-plugin');
+      expect(result!.version).toBe('1.0.0');
+    });
+
+    it('allows registering multiple versions of same plugin', () => {
+      registry.register(makeManifest({ version: '1.0.0' }));
+      registry.register(makeManifest({ version: '2.0.0' }));
+      const versions = registry.listVersions('test-plugin');
+      expect(versions).toContain('1.0.0');
+      expect(versions).toContain('2.0.0');
+    });
+  });
+
+  describe('get', () => {
+    it('returns the latest version by default', () => {
+      registry.register(makeManifest({ version: '1.0.0' }));
+      registry.register(makeManifest({ version: '2.0.0' }));
+      const result = registry.get('test-plugin');
+      expect(result!.version).toBe('2.0.0');
+    });
+
+    it('returns null for unknown plugin', () => {
+      expect(registry.get('nonexistent')).toBeNull();
+    });
+  });
+
+  describe('getVersion', () => {
+    it('returns specific version of a plugin', () => {
+      registry.register(makeManifest({ version: '1.0.0' }));
+      registry.register(makeManifest({ version: '2.0.0' }));
+      const result = registry.getVersion('test-plugin', '1.0.0');
+      expect(result).not.toBeNull();
+      expect(result!.version).toBe('1.0.0');
+    });
+
+    it('returns null for unknown version', () => {
+      registry.register(makeManifest({ version: '1.0.0' }));
+      expect(registry.getVersion('test-plugin', '3.0.0')).toBeNull();
+    });
+  });
+
+  describe('list', () => {
+    it('returns all registered plugins', () => {
+      registry.register(makeManifest({ name: 'a', version: '1.0.0' }));
+      registry.register(makeManifest({ name: 'b', version: '1.0.0' }));
+      const all = registry.list();
+      expect(all.length).toBe(2);
+    });
+
+    it('returns empty array when no plugins registered', () => {
+      expect(registry.list()).toEqual([]);
+    });
+  });
+
+  describe('search', () => {
+    it('searches by name', () => {
+      registry.register(makeManifest({ name: 'image-resize', description: 'Resize images' }));
+      registry.register(makeManifest({ name: 'video-player', description: 'Play videos' }));
+      const results = registry.search('image');
+      expect(results.length).toBe(1);
+      expect(results[0].name).toBe('image-resize');
+    });
+
+    it('searches by description', () => {
+      registry.register(makeManifest({ name: 'foo', description: 'A plugin for image manipulation' }));
+      const results = registry.search('image');
+      expect(results.length).toBe(1);
+    });
+
+    it('is case-insensitive', () => {
+      registry.register(makeManifest({ name: 'Image-Plugin' }));
+      expect(registry.search('image').length).toBe(1);
+      expect(registry.search('IMAGE').length).toBe(1);
+    });
+
+    it('returns empty array for no match', () => {
+      registry.register(makeManifest());
+      expect(registry.search('xyz123')).toEqual([]);
+    });
+  });
+
+  describe('remove', () => {
+    it('removes a specific version', () => {
+      registry.register(makeManifest({ version: '1.0.0' }));
+      registry.register(makeManifest({ version: '2.0.0' }));
+      const result = registry.remove('test-plugin', '1.0.0');
+      expect(result).toBe(true);
+      expect(registry.getVersion('test-plugin', '1.0.0')).toBeNull();
+      expect(registry.getVersion('test-plugin', '2.0.0')).not.toBeNull();
+    });
+
+    it('returns false for nonexistent plugin', () => {
+      expect(registry.remove('nonexistent', '1.0.0')).toBe(false);
+    });
+  });
+
+  describe('listVersions', () => {
