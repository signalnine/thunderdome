+import { describe, it, expect, beforeEach } from 'vitest';
+import { createReviewService } from './index.js';
+
+describe('ReviewService', () => {
+  let reviews: ReturnType<typeof createReviewService>;
+
+  beforeEach(() => {
+    reviews = createReviewService(':memory:');
+  });
+
+  describe('addReview', () => {
+    it('adds a review and returns it with id and timestamp', () => {
+      const review = reviews.addReview({
+        pluginName: 'my-plugin',
+        pluginVersion: '1.0.0',
+        userId: 'user1',
+        rating: 5,
+        comment: 'Great plugin!',
+      });
+      expect(review.id).toBeDefined();
+      expect(review.pluginName).toBe('my-plugin');
+      expect(review.rating).toBe(5);
+      expect(review.flagged).toBe(false);
+      expect(review.createdAt).toBeDefined();
+    });
+
+    it('assigns unique ids to each review', () => {
+      const r1 = reviews.addReview({
+        pluginName: 'p', pluginVersion: '1.0.0',
+        userId: 'u1', rating: 3, comment: 'ok',
+      });
+      const r2 = reviews.addReview({
+        pluginName: 'p', pluginVersion: '1.0.0',
+        userId: 'u2', rating: 4, comment: 'good',
+      });
+      expect(r1.id).not.toBe(r2.id);
+    });
+  });
+
+  describe('getReviews', () => {
+    it('returns all reviews for a plugin', () => {
+      reviews.addReview({
+        pluginName: 'plugin-a', pluginVersion: '1.0.0',
+        userId: 'u1', rating: 5, comment: 'a',
+      });
+      reviews.addReview({
+        pluginName: 'plugin-a', pluginVersion: '1.0.0',
+        userId: 'u2', rating: 4, comment: 'b',
+      });
+      reviews.addReview({
+        pluginName: 'plugin-b', pluginVersion: '1.0.0',
+        userId: 'u1', rating: 3, comment: 'c',
+      });
+
+      const result = reviews.getReviews('plugin-a');
+      expect(result.length).toBe(2);
+    });
+
+    it('returns empty array for plugin with no reviews', () => {
+      expect(reviews.getReviews('unknown')).toEqual([]);
+    });
+  });
+
+  describe('getAverageRating', () => {
+    it('computes average of all non-flagged reviews', () => {
+      reviews.addReview({
+        pluginName: 'p', pluginVersion: '1.0.0',
+        userId: 'u1', rating: 4, comment: 'a',
+      });
+      reviews.addReview({
+        pluginName: 'p', pluginVersion: '1.0.0',
+        userId: 'u2', rating: 2, comment: 'b',
+      });
+      expect(reviews.getAverageRating('p')).toBe(3);
+    });
+
+    it('excludes flagged reviews from average', () => {
+      const r1 = reviews.addReview({
+        pluginName: 'p', pluginVersion: '1.0.0',
+        userId: 'u1', rating: 1, comment: 'spam',
+      });
+      reviews.addReview({
+        pluginName: 'p', pluginVersion: '1.0.0',
+        userId: 'u2', rating: 4, comment: 'good',
+      });
+      reviews.flagReview(r1.id);
+      expect(reviews.getAverageRating('p')).toBe(4);
+    });
+
+    it('returns 0 for plugin with no reviews', () => {
+      expect(reviews.getAverageRating('unknown')).toBe(0);
+    });
+  });
+
+  describe('flagReview', () => {
+    it('marks a review as flagged', () => {
+      const review = reviews.addReview({
+        pluginName: 'p', pluginVersion: '1.0.0',
+        userId: 'u1', rating: 1, comment: 'spam',
+      });
+      reviews.flagReview(review.id);
+      const flagged = reviews.getFlaggedReviews();
+      expect(flagged.length).toBe(1);
+      expect(flagged[0].id).toBe(review.id);
+      expect(flagged[0].flagged).toBe(true);
+    });
+  });
+
+  describe('getFlaggedReviews', () => {
+    it('returns only flagged reviews', () => {
+      const r1 = reviews.addReview({
+        pluginName: 'p', pluginVersion: '1.0.0',
+        userId: 'u1', rating: 1, comment: 'spam',
+      });
+      reviews.addReview({
+        pluginName: 'p', pluginVersion: '1.0.0',
+        userId: 'u2', rating: 4, comment: 'good',
+      });
+      reviews.flagReview(r1.id);
+      const flagged = reviews.getFlaggedReviews();
+      expect(flagged.length).toBe(1);
+    });
+  });
+
+  describe('removeReview', () => {
+    it('removes a review and returns true', () => {
+      const review = reviews.addReview({
+        pluginName: 'p', pluginVersion: '1.0.0',
+        userId: 'u1', rating: 3, comment: 'ok',
+      });
+      expect(reviews.removeReview(review.id)).toBe(true);
+      expect(reviews.getReviews('p')).toEqual([]);
+    });
+
+    it('returns false for nonexistent review', () => {
+      expect(reviews.removeReview(999)).toBe(false);
+    });
+  });
+
+  describe('getReviewsByUser', () => {
+    it('returns all reviews by a specific user', () => {
+      reviews.addReview({
+        pluginName: 'p1', pluginVersion: '1.0.0',
+        userId: 'user-a', rating: 5, comment: 'a',
+      });
+      reviews.addReview({
+        pluginName: 'p2', pluginVersion: '1.0.0',
+        userId: 'user-a', rating: 4, comment: 'b',
+      });
+      reviews.addReview({
+        pluginName: 'p1', pluginVersion: '1.0.0',
+        userId: 'user-b', rating: 3, comment: 'c',
+      });
+      const result = reviews.getReviewsByUser('user-a');
+      expect(result.length).toBe(2);
+      expect(result.every(r => r.userId === 'user-a')).toBe(true);
+    });
+  });
+
+  describe('getReviewCount', () => {
+    it('returns the number of reviews for a plugin', () => {
+      reviews.addReview({
+        pluginName: 'p', pluginVersion: '1.0.0',
+        userId: 'u1', rating: 5, comment: 'a',
+      });
+      reviews.addReview({
+        pluginName: 'p', pluginVersion: '1.0.0',
+        userId: 'u2', rating: 4, comment: 'b',
+      });
+      expect(reviews.getReviewCount('p')).toBe(2);
+    });
+
+    it('returns 0 for unknown plugin', () => {
+      expect(reviews.getReviewCount('unknown')).toBe(0);
+    });
+  });
+});
