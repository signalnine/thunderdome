index 0000000..1b99ca0
--- /dev/null
+++ b/src/deps/deps.test.ts
@@ -0,0 +1,148 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import type { PluginManifest } from '../types.js';
+import { createRegistry } from '../registry/index.js';
+import { createDepsService } from './index.js';
+
+function makeManifest(
+  name: string,
+  version: string,
+  dependencies: Record<string, string> = {}
+): PluginManifest {
+  return {
+    name,
+    version,
+    description: `${name} plugin`,
+    author: 'test',
+    dependencies,
+    entryPoint: 'result = true',
+    permissions: [],
+  };
+}
+
+describe('DepsService', () => {
+  let registry: ReturnType<typeof createRegistry>;
+  const deps = createDepsService();
+
+  beforeEach(() => {
+    registry = createRegistry();
+  });
+
+  describe('buildTree', () => {
+    it('builds a tree with no dependencies', () => {
+      registry.register(makeManifest('leaf', '1.0.0'));
+      const tree = deps.buildTree('leaf', registry);
+      expect(tree.name).toBe('leaf');
+      expect(tree.version).toBe('1.0.0');
+      expect(tree.dependencies).toEqual([]);
+    });
+
+    it('builds a tree with nested dependencies', () => {
+      registry.register(makeManifest('app', '1.0.0', { lib: '^1.0.0' }));
+      registry.register(makeManifest('lib', '1.2.0', { util: '^2.0.0' }));
+      registry.register(makeManifest('util', '2.1.0'));
+
+      const tree = deps.buildTree('app', registry);
+      expect(tree.name).toBe('app');
+      expect(tree.dependencies.length).toBe(1);
+      expect(tree.dependencies[0].name).toBe('lib');
+      expect(tree.dependencies[0].dependencies.length).toBe(1);
+      expect(tree.dependencies[0].dependencies[0].name).toBe('util');
+    });
+  });
+
+  describe('detectCycles', () => {
+    it('returns null for acyclic dependencies', () => {
+      registry.register(makeManifest('a', '1.0.0', { b: '^1.0.0' }));
+      registry.register(makeManifest('b', '1.0.0'));
+      expect(deps.detectCycles('a', registry)).toBeNull();
+    });
+
+    it('detects direct circular dependency', () => {
+      registry.register(makeManifest('a', '1.0.0', { b: '^1.0.0' }));
+      registry.register(makeManifest('b', '1.0.0', { a: '^1.0.0' }));
+      const cycles = deps.detectCycles('a', registry);
+      expect(cycles).not.toBeNull();
+      expect(cycles!.length).toBeGreaterThan(0);
+    });
+
+    it('detects indirect circular dependency', () => {
+      registry.register(makeManifest('a', '1.0.0', { b: '^1.0.0' }));
+      registry.register(makeManifest('b', '1.0.0', { c: '^1.0.0' }));
+      registry.register(makeManifest('c', '1.0.0', { a: '^1.0.0' }));
+      const cycles = deps.detectCycles('a', registry);
+      expect(cycles).not.toBeNull();
+      expect(cycles!.length).toBeGreaterThan(0);
+    });
+  });
+
+  describe('hasCircularDependency', () => {
+    it('returns false for acyclic graph', () => {
+      registry.register(makeManifest('a', '1.0.0', { b: '^1.0.0' }));
+      registry.register(makeManifest('b', '1.0.0'));
+      expect(deps.hasCircularDependency('a', registry)).toBe(false);
+    });
+
+    it('returns true for circular graph', () => {
+      registry.register(makeManifest('a', '1.0.0', { b: '^1.0.0' }));
+      registry.register(makeManifest('b', '1.0.0', { a: '^1.0.0' }));
+      expect(deps.hasCircularDependency('a', registry)).toBe(true);
+    });
+  });
+
+  describe('topologicalSort', () => {
+    it('returns correct topological order', () => {
+      registry.register(makeManifest('app', '1.0.0', { lib: '^1.0.0', util: '^1.0.0' }));
+      registry.register(makeManifest('lib', '1.0.0', { util: '^1.0.0' }));
+      registry.register(makeManifest('util', '1.0.0'));
+
+      const order = deps.topologicalSort('app', registry);
+      // util must come before lib, lib before app
+      const utilIdx = order.indexOf('util');
+      const libIdx = order.indexOf('lib');
+      const appIdx = order.indexOf('app');
+      expect(utilIdx).toBeLessThan(libIdx);
+      expect(libIdx).toBeLessThan(appIdx);
+    });
+
+    it('handles single node with no deps', () => {
+      registry.register(makeManifest('solo', '1.0.0'));
+      expect(deps.topologicalSort('solo', registry)).toEqual(['solo']);
+    });
+  });
+
+  describe('flattenDependencies', () => {
+    it('returns all transitive dependencies', () => {
+      registry.register(makeManifest('app', '1.0.0', { lib: '^1.0.0' }));
+      registry.register(makeManifest('lib', '1.0.0', { util: '^1.0.0' }));
+      registry.register(makeManifest('util', '1.0.0'));
+
+      const flat = deps.flattenDependencies('app', registry);
+      expect(flat).toContain('lib');
+      expect(flat).toContain('util');
+    });
+
+    it('does not include the root plugin itself', () => {
+      registry.register(makeManifest('app', '1.0.0', { lib: '^1.0.0' }));
+      registry.register(makeManifest('lib', '1.0.0'));
+
+      const flat = deps.flattenDependencies('app', registry);
+      expect(flat).not.toContain('app');
+    });
+
+    it('returns empty for plugin with no deps', () => {
+      registry.register(makeManifest('solo', '1.0.0'));
+      expect(deps.flattenDependencies('solo', registry)).toEqual([]);
+    });
+
+    it('deduplicates shared transitive deps', () => {
+      registry.register(makeManifest('app', '1.0.0', { a: '^1.0.0', b: '^1.0.0' }));
+      registry.register(makeManifest('a', '1.0.0', { shared: '^1.0.0' }));
+      registry.register(makeManifest('b', '1.0.0', { shared: '^1.0.0' }));
+      registry.register(makeManifest('shared', '1.0.0'));
+
+      const flat = deps.flattenDependencies('app', registry);
+      const sharedCount = flat.filter(d => d === 'shared').length;
+      expect(sharedCount).toBe(1);
+    });
+  });
+});
