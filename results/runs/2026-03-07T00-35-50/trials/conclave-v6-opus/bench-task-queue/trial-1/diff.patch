endencies completed becomes available', () => {\n    const queue = new TaskQueue();\n    const t1 = queue.add({ step: 1 });\n    const t2 = queue.add({ step: 2 });\n    const t3 = queue.add({ step: 3 }, { dependsOn: [t1.id, t2.id] });\n\n    // Process and complete both dependencies\n    queue.next(); // t1\n    queue.complete(t1.id);\n    queue.next(); // t2\n    queue.complete(t2.id);\n\n    const next = queue.next();\n    expect(next!.id).toBe(t3.id);\n  });\n\n  test('dependencies work across queues via manager', () => {\n    const manager = new TaskQueueManager();\n    const t1 = manager.add('queue-a', { step: 1 });\n    const t2 = manager.add('queue-b', { step: 2 }, { dependsOn: [t1.id] });\n\n    // t2 blocked because t1 not completed\n    expect(manager.next('queue-b')).toBeNull();\n\n    // Complete t1\n    manager.next('queue-a');\n    manager.complete(t1.id);\n\n    // Now t2 should be available\n    const next = manager.next('queue-b');\n    expect(next!.id).toBe(t2.id);\n  });\n\n  test('indirect circular dependencies are detected', () => {\n    const manager = new TaskQueueManager();\n    const a = manager.add('q', { name: 'a' });\n    const b = manager.add('q', { name: 'b' }, { dependsOn: [a.id] });\n    const c = manager.add('q', { name: 'c' }, { dependsOn: [b.id] });\n\n    // d depends on c - fine, no cycle\n    const d = manager.add('q', { name: 'd' }, { dependsOn: [c.id] });\n    expect(d).toBeDefined();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":611,"cache_read_input_tokens":62291,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":611},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"083d7f18-5302-4c12-9e84-dd21da35b9b0","uuid":"ab586032-52e1-4de0-8b16-de88d87fca9d"}
