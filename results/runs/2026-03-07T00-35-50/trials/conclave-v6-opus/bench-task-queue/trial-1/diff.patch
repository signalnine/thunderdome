: string): Task | undefined => {\n    for (const queue of this.queueMap.values()) {\n      const task = queue.getTask(id);\n      if (task) return task;\n    }\n    return undefined;\n  };\n\n  private getOrCreateQueue(name: string): TaskQueue {\n    let queue = this.queueMap.get(name);\n    if (!queue) {\n      queue = new TaskQueue(name);\n      queue.setTaskResolver(this.resolveTaskGlobal);\n      this.queueMap.set(name, queue);\n    }\n    return queue;\n  }\n\n  add<T = unknown>(queueName: string | undefined, payload: T, options?: AddTaskOptions): Task<T> {\n    if (this.isShutdown) {\n      throw new Error('Cannot add tasks after shutdown');\n    }\n    const name = queueName ?? 'default';\n    const queue = this.getOrCreateQueue(name);\n    return queue.add(payload, options);\n  }\n\n  next(queueName?: string): Task | null {\n    const name = queueName ?? 'default';\n    const queue = this.queueMap.get(name);\n    if (!queue) return null;\n    return queue.next();\n  }\n\n  complete(taskId: string): void {\n    const queue = this.findQueueForTask(taskId);\n    if (!queue) throw new Error(`Task not found: ${taskId}`);\n    queue.complete(taskId);\n  }\n\n  fail(taskId: string, error: string): void {\n    const queue = this.findQueueForTask(taskId);\n    if (!queue) throw new Error(`Task not found: ${taskId}`);\n    queue.fail(taskId, error);\n  }\n\n  private findQueueForTask(taskId: string): TaskQueue | undefined {\n    for (const queue of this.queueMap.values()) {\n      if (queue.getTask(taskId)) return queue;\n    }\n    return undefined;\n  }\n\n  queues(): string[] {\n    return Array.from(this.queueMap.keys());\n  }\n\n  getQueue(name: string): TaskQueue | undefined {\n    return this.queueMap.get(name);\n  }\n\n  getTask(taskId: string): Task | undefined {\n    return this.resolveTaskGlobal(taskId);\n  }\n\n  // Scheduling methods\n  addSchedule(queueName: string, cronExpression: string, payload: unknown): string {\n    return this.scheduler.addSchedul