+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018qUyajU1qpiYrE1SbXTdZB","type":"tool_result","content":"     1→import { randomUUID } from 'node:crypto';\n     2→\n     3→export interface Schedule {\n     4→  id: string;\n     5→  queueName: string;\n     6→  cronExpression: string;\n     7→  payload: unknown;\n     8→  lastRun?: Date;\n     9→}\n    10→\n    11→export function parseCronExpression(expression: string): { minute: string; hour: string } {\n    12→  const parts = expression.trim().split(/\\s+/);\n    13→  if (parts.length !== 5) {\n    14→    throw new Error(`Invalid cron expression: ${expression}`);\n    15→  }\n    16→  return {\n    17→    minute: parts[0],\n    18→    hour: parts[1],\n    19→  };\n    20→}\n    21→\n    22→export function cronMatches(expression: string, date: Date): boolean {\n    23→  const { minute, hour } = parseCronExpression(expression);\n    24→  const currentMinute = date.getUTCMinutes();\n    25→  const currentHour = date.getUTCHours();\n    26→\n    27→  const minuteMatches = fieldMatches(minute, currentMinute);\n    28→  const hourMatches = fieldMatches(hour, currentHour);\n    29→\n    30→  return minuteMatches && hourMatches;\n    31→}\n    32→\n    33→function fieldMatches(field: string, value: number): boolean {\n    34→  if (field === '*') return true;\n    35→\n    36→  // */N pattern\n    37→  if (field.startsWith('*/')) {\n    38→    const interval = parseInt(field.slice(2), 10);\n    39→    if (isNaN(interval) || interval <= 0) return false;\n    40→    return value % interval === 0;\n    41→  }\n    42→\n    43→  // Exact value\n    44→  const exact = parseInt(field, 10);\n    45→  if (isNaN(exact)) return false;\n    46→  return value === exact;\n    47→}\n    48→\n    49→export class TaskScheduler {\n    50→  private schedules: Map<string, Schedule> = new Map();\n    51→\n    52→  addSchedule(queueName: string, cronExpression: string, payload: unknown): string {\n    53→    // Validate cron expression\n    54→    parseCronExpression(cronExpression);\n    55→\n    56→    const schedule: Schedule = {\n    57→      id: randomUUID(),\n    58→      queueName,\n    59→      cronExpression,\n    60→      payload,\n    61→    };\n    62→    this.schedules.set(schedule.id, schedule);\n    63→    return schedule.id;\n    64→  }\n    65→\n    66→  removeSchedule(id: string): void {\n    67→    this.schedules.delete(id);\n    68→  }\n    69→\n    70→  listSchedules(): Schedule[] {\n    71→    return Array.from(this.schedules.values());\n    72→  }\n    73→\n    74→  getDueSchedules(now: Date): Schedule[] {\n    75→    const due: Schedule[] = [];\n    76→    for (const schedule of this.schedules.values()) {\n    77→      if (!cronMatches(schedule.cronExpression, now)) continue;\n    78→\n    79→      // Prevent double-enqueue for the same minute\n    80→      if (schedule.lastRun) {\n    81→        const lastMinute = Math.floor(schedule.lastRun.getTime() / 60000);\n    82→        const currentMinute = Math.floor(now.getTime() / 60000);\n    83→        if (lastMinute === currentMinute) continue;\n    84→      }\n    85→\n    86→      schedule.lastRun = now;\n    87→      due.push(schedule);\n    88→    }\n    89→    return due;\n    90→  }\n    91→}\n    92→"}]},"parent_tool_use_id":"toolu_018gV4vpnKRh9Xg9iuEFBrxw","session_id":"083d7f18-5302-4c12-9e84-dd21da35b9b0","uuid":"4b64adae-c9ce-4ea3-a224-dfa81bcc3b04"}
