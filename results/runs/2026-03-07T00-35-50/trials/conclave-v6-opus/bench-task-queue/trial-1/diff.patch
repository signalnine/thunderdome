+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01A2MM1RTEWgHJbWU9cLM3Et","type":"tool_result","content":"diff --git a/src/index.ts b/src/index.ts\nnew file mode 100644\nindex 0000000..a76f544\n--- /dev/null\n+++ b/src/index.ts\n@@ -0,0 +1,6 @@\n+export { TaskQueue } from './queue.js';\n+export { TaskQueueManager } from './manager.js';\n+export type { Task, TaskStatus } from './types.js';\n+export type { AddTaskOptions } from './queue.js';\n+export type { ShutdownResult, ShutdownOptions } from './manager.js';\n+export type { Schedule } from './scheduler.js';\ndiff --git a/src/manager.ts b/src/manager.ts\nnew file mode 100644\nindex 0000000..44316e9\n--- /dev/null\n+++ b/src/manager.ts\n@@ -0,0 +1,210 @@\n+import { TaskQueue } from './queue.js';\n+import { TaskScheduler } from './scheduler.js';\n+import type { Task } from './types.js';\n+import type { AddTaskOptions } from './queue.js';\n+import type { Schedule } from './scheduler.js';\n+\n+export interface ShutdownResult {\n+  completed: number;\n+  forceCancelled: number;\n+  duration: number;\n+}\n+\n+export interface ShutdownOptions {\n+  timeout?: number;\n+}\n+\n+export class TaskQueueManager {\n+  private queueMap: Map<string, TaskQueue> = new Map();\n+  private scheduler = new TaskScheduler();\n+  private isShutdown = false;\n+  private shutdownResult?: ShutdownResult;\n+  private shutdownCallbacks: Array<() => void | Promise<void>> = [];\n+\n+  // Shutdown coordination\n+  private shutdownResolve?: (result: ShutdownResult) => void;\n+  private shutdownStartTime = 0;\n+  private shutdownTrackedIds = new Set<string>();\n+  private shutdownTimedOut = false;\n+\n+  private resolveTaskGlobal = (id: string): Task | undefined => {\n+    for (const queue of this.queueMap.values()) {\n+      const task = queue.getTask(id);\n+      if (task) return task;\n+    }\n+    return undefined;\n+  };\n+\n+  private getOrCreateQueue(name: string): TaskQueue {\n+    let queue = this.queueMap.get(name);\n+    if (!queue) {\n+      queue = new TaskQueue(name);\n+      queue.setTaskResolver(this.resolveTaskGlobal);\n+      this.queueMap.set(name, queue);\n+    }\n+    return queue;\n+  }\n+\n+  add<T = unknown>(queueName: string | undefined, payload: T, options?: AddTaskOptions): Task<T> {\n+    if (this.isShutdown) {\n+      throw new Error('Cannot add tasks after shutdown');\n+    }\n+    const name = queueName ?? 'default';\n+    const queue = this.getOrCreateQueue(name);\n+    return queue.add(payload, options);\n+  }\n+\n+  next(queueName?: string): Task | null {\n+    const name = queueName ?? 'default';\n+    const queue = this.queueMap.get(name);\n+    if (!queue) return null;\n+    return queue.next();\n+  }\n+\n+  complete(taskId: string): void {\n+    const queue = this.findQueueForTask(taskId);\n+    if (!queue) throw new Error(`Task not found: ${taskId}`);\n+    queue.complete(taskId);\n+    this.checkShutdownComplete();\n+  }\n+\n+  fail(taskId: string, error: string): void {\n+    const queue = this.findQueueForTask(taskId);\n+    if (!queue) throw new Error(`Task not found: ${taskId}`);\n+    queue.fail(taskId, error);\n+    this.checkShutdownComplete();\n+  }\n+\n+  private findQueueForTask(taskId: string): TaskQueue | undefined {\n+    for (const queue of this.queueMap.values()) {\n+      if (queue.getTask(taskId)) return queue;\n+    }\n+    return undefined;\n+  }\n+\n+  queues(): string[] {\n+    return Array.from(this.queueMap.keys());\n+  }\n+\n+  getQueue(name: string): TaskQueue | undefined {\n+    return this.queueMap.get(name);\n+  }\n+\n+  getTask(taskId: string): Task | undefined {\n+    return this.resolveTaskGlobal(taskId);\n+  }\n+\n+  // Scheduling methods\n+  addSchedule(queueName: string, cronExpression: string, payload: unknown): string {\n+    return this.scheduler.addSchedule(queueName, cronExpression, payload);\n+  }\n+\n+  removeSchedule(scheduleId: string): void {\n+    this.scheduler.removeSchedule(scheduleId);\n+  }\n+\n+  listSchedules(): Schedule[] {\n+    return this.scheduler.listSchedules();\n+  }\n+\n+  tick(): void {\n+    const now = new Date();\n+    const dueSchedules = this.scheduler.getDueSchedules(now);\n+    for (const schedule of dueSchedules) {\n+      this.add(schedule.queueName, schedule.payload);\n+    }\n+  }\n+\n+  // Shutdown methods\n+  onShutdown(callback: () => void | Promise<void>): void {\n+    this.shutdownCallbacks.push(callback);\n+  }\n+\n+  private getProcessingTasks(): Task[] {\n+    const processing: Task[] = [];\n+    for (const queue of this.queueMap.values()) {\n+      processing.push(...queue.getProcessingTasks());\n+    }\n+    return processing;\n+  }\n+\n+  private checkShutdownComplete(): void {\n+    if (!this.shutdownResolve || this.shutdownTimedOut) return;\n+\n+    const stillProcessing = this.getProcessingTasks();\n+    if (stillProcessing.length === 0) {\n+      let completedCount = 0;\n+      for (const id of this.shutdownTrackedIds) {\n+        const task = this.resolveTaskGlobal(id);\n+        if (task && task.status === 'completed') completedCount++;\n+      }\n+\n+      const resolve = this.shutdownResolve;\n+      this.shutdownResolve = undefined;\n+      resolve({\n+        completed: completedCount,\n+        forceCancelled: 0,\n+        duration: Date.now() - this.shutdownStartTime,\n+      });\n+    }\n+  }\n+\n+  async shutdown(options?: ShutdownOptions): Promise<ShutdownResult> {\n+    if (this.shutdownResult) return this.shutdownResult;\n+\n+    this.isShutdown = true;\n+    this.shutdownStartTime = Date.now();\n+    const timeout = options?.timeout ?? 0;\n+\n+    // Run shutdown callbacks\n+    for (const cb of this.shutdownCallbacks) {\n+      await cb();\n+    }\n+\n+    const processingTasks = this.getProcessingTasks();\n+\n+    if (processingTasks.length === 0) {\n+      this.shutdownResult = { completed: 0, forceCancelled: 0, duration: Date.now() - this.shutdownStartTime };\n+      return this.shutdownResult;\n+    }\n+\n+    this.shutdownTrackedIds = new Set(processingTasks.map(t => t.id));\n+\n+    const promise = new Promise<ShutdownResult>((resolve) => {\n+      this.shutdownResolve = resolve;\n+\n+      if (timeout > 0) {\n+        setTimeout(() => {\n+          if (!this.shutdownResolve) return; // already resolved\n+          this.shutdownTimedOut = true;\n+\n+          const stillProcessing = this.getProcessingTasks();\n+          for (const task of stillProcessing) {\n+            const queue = this.findQueueForTask(task.id);\n+            if (queue) queue.cancel(task.id);\n+          }\n+\n+          let completedCount = 0;\n+          for (const id of this.shutdownTrackedIds) {\n+            const task = this.resolveTaskGlobal(id);\n+            if (task && task.status === 'completed') completedCount++;\n+          }\n+\n+          const resolveRef = this.shutdownResolve;\n+          this.shutdownResolve = undefined;\n+          resolveRef({\n+            completed: completedCount,\n+            forceCancelled: stillProcessing.length,\n+            duration: Date.now() - this.shutdownStartTime,\n+          });\n+        }, timeout);\n+      }\n+\n+      // Check immediately in case all tasks were already completed\n+      this.checkShutdownComplete();\n+    });\n+\n+    this.shutdownResult = await promise;\n+    return this.shutdownResult;\n+  }\n+}\ndiff --git a/src/queue.ts b/src/queue.ts\nnew file mode 100644\nindex 0000000..7da0870\n--- /dev/null\n+++ b/src/queue.ts\n@@ -0,0 +1,323 @@\n+import { randomUUID } from 'node:crypto';\n+import type { Task } from './types.js';\n+\n+export interface AddTaskOptions {\n+  priority?: number;\n+  delay?: number;\n+  availableAt?: Date;\n+  maxRetries?: number;\n+  retryDelay?: number;\n+  dependsOn?: string[];\n+}\n+\n+export type TaskResolver = (id: string) => Task | undefined;\n+\n+export class TaskQueue {\n+  private tasks: Map<string, Task> = new Map();\n+  private insertionOrder: string[] = [];\n+  private dlq: Set<string> = new Set();\n+  private queueName: string;\n+  private externalTaskResolver?: TaskResolver;\n+  private concurrencyLimit = 0; // 0 = unlimited\n+  private progressListeners: Map<string, Array<(progress: number, message?: string) => void>> = new Map();\n+  private middlewareStack: Array<(task: Task, next: () => Promise<void>) => Promise<void>> = [];\n+  private handler?: (task: Task) => Promise<void>;\n+\n+  constructor(name = 'default') {\n+    this.queueName = name;\n+  }\n+\n+  setTaskResolver(resolver: TaskResolver): void {\n+    this.externalTaskResolver = resolver;\n+  }\n+\n+  resolveTask(id: string): Task | undefined {\n+    return this.tasks.get(id) ?? this.externalTaskResolver?.(id);\n+  }\n+\n+  private areDependenciesMet(task: Task): boolean {\n+    if (task.dependsOn.length === 0) return true;\n+    return task.dependsOn.every(depId => {\n+      const dep = this.resolveTask(depId);\n+      return dep?.status === 'completed';\n+    });\n+  }\n+\n+  private detectCircularDeps(taskId: string, dependsOn: string[], visited: Set<string> = new Set()): boolean {\n+    for (const depId of dependsOn) {\n+      if (depId === taskId) return true;\n+      if (visited.has(depId)) continue;\n+      visited.add(depId);\n+      const dep = this.resolveTask(depId);\n+      if (dep && dep.dependsOn.length > 0) {\n+        if (this.detectCircularDeps(taskId, dep.dependsOn, visited)) return true;\n+      }\n+    }\n+    return false;\n+  }\n+\n+  add<T = unknown>(payload: T, options?: AddTaskOptions): Task<T> {\n+    const priority = options?.priority ?? 5;\n+    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n+      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n+    }\n+\n+    const dependsOn = options?.dependsOn ? [...options.dependsOn] : [];\n+\n+    // Validate dependencies exist\n+    for (const depId of dependsOn) {\n+      const dep = this.resolveTask(depId);\n+      if (!dep) {\n+        throw new Error(`Dependency task not found: ${depId}`);\n+      }\n+    }\n+\n+    const now = new Date();\n+    let availableAt = now;\n+    if (options?.availableAt) {\n+      availableAt = options.availableAt;\n+    } else if (options?.delay) {\n+      availableAt = new Date(now.getTime() + options.delay);\n+    }\n+\n+    const id = randomUUID();\n+\n+    // Check circular dependencies\n+    if (dependsOn.length > 0 && this.detectCircularDeps(id, dependsOn)) {\n+      throw new Error('Circular dependency detected');\n+    }\n+\n+    const task: Task<T> = {\n+      id,\n+      status: 'pending',\n+      payload,\n+      createdAt: now,\n+      updatedAt: now,\n+      queue: this.queueName,\n+      priority,\n+      availableAt,\n+      attempts: 0,\n+      maxRetries: options?.maxRetries ?? 3,\n+      retryDelay: options?.retryDelay ?? 1000,\n+      dependsOn,\n+      progress: 0,\n+      failureCount: 0,\n+    };\n+\n+    this.tasks.set(task.id, task as Task);\n+    this.insertionOrder.push(task.id);\n+    return task;\n+  }\n+\n+  next(): Task | null {\n+    // Check concurrency limit\n+    if (this.concurrencyLimit > 0 && this.activeCount() >= this.concurrencyLimit) {\n+      return null;\n+    }\n+\n+    const now = Date.now();\n+    let best: Task | null = null;\n+\n+    for (const id of this.insertionOrder) {\n+      const task = this.tasks.get(id)!;\n+      if (task.status !== 'pending') continue;\n+\n+      const isAvailable = task.availableAt.getTime() <= now;\n+      if (!isAvailable) continue;\n+\n+      if (!this.areDependenciesMet(task)) continue;\n+\n+      if (!best) {\n+        best = task;\n+        continue;\n+      }\n+\n+      // Compare: priority first, then availableAt, then insertion order (FIFO)\n+      if (task.priority < best.priority) {\n+        best = task;\n+      } else if (task.priority === best.priority) {\n+        // Same priority: earlier availableAt wins\n+        if (task.availableAt.getTime() < best.availableAt.getTime()) {\n+          best = task;\n+        }\n+        // If same availableAt, FIFO order is preserved by iteration order\n+      }\n+    }\n+\n+    if (best) {\n+      best.status = 'processing';\n+      best.updatedAt = new Date();\n+    }\n+    return best;\n+  }\n+\n+  waiting(): number {\n+    let count = 0;\n+    for (const task of this.tasks.values()) {\n+      if (task.status === 'pending') count++;\n+    }\n+    return count;\n+  }\n+\n+  complete(taskId: string): void {\n+    const task = this.tasks.get(taskId);\n+    if (!task) throw new Error(`Task not found: ${taskId}`);\n+    task.status = 'completed';\n+    task.updatedAt = new Date();\n+  }\n+\n+  fail(taskId: string, error: string): void {\n+    const task = this.tasks.get(taskId);\n+    if (!task) throw new Error(`Task not found: ${taskId}`);\n+\n+    task.attempts++;\n+    task.error = error;\n+    task.failureCount++;\n+    task.updatedAt = new Date();\n+\n+    if (task.attempts <= task.maxRetries) {\n+      const delay = task.retryDelay * Math.pow(2, task.attempts - 1);\n+      task.status = 'pending';\n+      task.availableAt = new Date(Date.now() + delay);\n+    } else {\n+      task.status = 'failed';\n+      this.dlq.add(task.id);\n+    }\n+  }\n+\n+  deadLetterQueue(): Task[] {\n+    return Array.from(this.dlq).map(id => this.tasks.get(id)!);\n+  }\n+\n+  requeue(taskId: string): void {\n+    const task = this.tasks.get(taskId);\n+    if (!task) throw new Error(`Task not found: ${taskId}`);\n+    if (!this.dlq.has(taskId)) throw new Error(`Task not in DLQ: ${taskId}`);\n+\n+    this.dlq.delete(taskId);\n+    task.status = 'pending';\n+    task.attempts = 0;\n+    task.availableAt = new Date();\n+    task.updatedAt = new Date();\n+  }\n+\n+  clearDeadLetterQueue(): void {\n+    for (const id of this.dlq) {\n+      this.tasks.delete(id);\n+      const idx = this.insertionOrder.indexOf(id);\n+      if (idx !== -1) this.insertionOrder.splice(idx, 1);\n+    }\n+    this.dlq.clear();\n+  }\n+\n+  setConcurrency(limit: