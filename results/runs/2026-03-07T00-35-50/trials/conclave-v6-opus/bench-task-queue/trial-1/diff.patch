+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01GJy1p8XJgTCiSEFqfNj4NZ","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01H29YPEkoSgF35FFMv8oWUV","name":"Write","input":{"file_path":"/workspace/tests/phase-04.test.ts","content":"import { describe, test, expect, vi, afterEach } from 'vitest';\nimport { TaskQueue } from '../src/index.js';\n\ndescribe('Phase 4: Delayed and Scheduled Tasks', () => {\n  afterEach(() => {\n    vi.useRealTimers();\n  });\n\n  test('task with delay is added but not available until delay passes', () => {\n    vi.useFakeTimers();\n    const queue = new TaskQueue();\n    queue.add({ data: 'delayed' }, { delay: 5000 });\n\n    // Not available yet\n    expect(queue.next()).toBeNull();\n\n    // Advance past delay\n    vi.advanceTimersByTime(5000);\n    const task = queue.next();\n    expect(task).not.toBeNull();\n    expect(task!.payload).toEqual({ data: 'delayed' });\n  });\n\n  test('task with specific availableAt time', () => {\n    vi.useFakeTimers();\n    const futureTime = new Date(Date.now() + 3000);\n    const queue = new TaskQueue();\n    queue.add({ data: 'scheduled' }, { availableAt: futureTime });\n\n    expect(queue.next()).toBeNull();\n\n    vi.advanceTimersByTime(3000);\n    const task = queue.next();\n    expect(task).not.toBeNull();\n    expect(task!.payload).toEqual({ data: 'scheduled' });\n  });\n\n  test('non-delayed tasks preferred over not-yet-available delayed tasks', () => {\n    vi.useFakeTimers();\n    const queue = new TaskQueue();\n    queue.add({ data: 'delayed' }, { delay: 5000 });\n    queue.add({ data: 'immediate' });\n\n    const task = queue.next();\n    expect(task!.payload).toEqual({ data: 'immediate' });\n  });\n\n  test('delayed tasks ordered by availability time, then priority, then FIFO', () => {\n    vi.useFakeTimers();\n    const queue = new TaskQueue();\n    // Both become available at same time but different priorities\n    queue.add({ order: 'low-pr