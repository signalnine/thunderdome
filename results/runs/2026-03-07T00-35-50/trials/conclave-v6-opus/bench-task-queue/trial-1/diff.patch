+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';
+
+export interface Task<T = unknown> {
+  id: string;
+  status: TaskStatus;
+  payload: T;
+  createdAt: Date;
+  updatedAt: Date;
+  queue: string;
+  priority: number;
+  availableAt: Date;
+  attempts: number;
+  maxRetries: number;
+  retryDelay: number;
+  dependsOn: string[];
+  progress: number;
+  progressMessage?: string;
+  error?: string;
+  failureCount: number;
+}
diff --git a/tests/edge-cases.test.ts b/tests/edge-cases.test.ts
new file mode 100644
index 0000000..98024fd
--- /dev/null
+++ b/tests/edge-cases.test.ts
@@ -0,0 +1,106 @@
+import { describe, test, expect, vi, afterEach } from 'vitest';
+import { TaskQueue, TaskQueueManager } from '../src/index.js';
+
+describe('Edge Cases: Status Guards', () => {
+  afterEach(() => {
+    vi.useRealTimers();
+  });
+
+  test('cannot complete a non-processing task', () => {
+    const queue = new TaskQueue();
+    const task = queue.add({ data: 'test' });
+    // task is pending, not processing
+    expect(() => queue.complete(task.id)).toThrow();
+  });
+
+  test('cannot complete a cancelled task', () => {
+    const queue = new TaskQueue();
+    const task = queue.add({ data: 'test' });
+    queue.next();
+    queue.cancel(task.id);
+    expect(() => queue.complete(task.id)).toThrow();
+  });
+
+  test('cannot fail a cancelled task', () => {
+    const queue = new TaskQueue();
+    const task = queue.add({ data: 'test' }, { maxRetries: 3 });
+    queue.next();
+    queue.cancel(task.id);
+    expect(() => queue.fail(task.id, 'error')).toThrow();
+  });
+
+  test('cannot fail a pending task', () => {
+    const queue = new TaskQueue();
+    const task = queue.add({ data: 'test' });
+    expect(() => queue.fail(task.id, 'error')).toThrow();
+  });
+
+  test('cannot cancel a completed task', () => {
+    const queue = new TaskQueue();
+    const task = queue.add({ data: 'test' });
+    queue.next();
+    queue.complete(task.id);
+    expect(() => queue.cancel(task.id)).toThrow();
+  });
+
+  test('cannot cancel a failed task', () => {
+    const queue = new TaskQueue();
+    const task = queue.add({ data: 'test' }, { maxRetries: 0 });
+    queue.next();
+    queue.fail(task.id, 'error');
+    expect(() => queue.cancel(task.id)).toThrow();
+  });
+
+  test('cannot update progress on a non-processing task', () => {
+    const queue = new TaskQueue();
+    const task = queue.add({ data: 'test' });
+    expect(() => queue.updateProgress(task.id, 50)).toThrow();
+  });
+
+  test('process() requires task to be in processing state', async () => {
+    const queue = new TaskQueue();
+    queue.setHandler(async () => {});
+    const task = queue.add({ data: 'test' });
+    // task is pending, not processing
+    await expect(queue.process(task.id)).rejects.toThrow();
+  });
+
+  test('setConcurrency rejects negative values', () => {
+    const queue = new TaskQueue();
+    expect(() => queue.setConcurrency(-1)).toThrow();
+  });
+
+  test('setConcurrency rejects NaN', () => {
+    const queue = new TaskQueue();
+    expect(() => queue.setConcurrency(NaN)).toThrow();
+  });
+});
+
+describe('Edge Cases: Shutdown', () => {
+  afterEach(() => {
+    vi.useRealTimers();
+  });
+
+  test('next() returns null after shutdown', async () => {
+    const manager = new TaskQueueManager();
+    manager.add('work', { data: 'a' });
+    manager.add('work', { data: 'b' });
+
+    await manager.shutdown();
+
+    expect(manager.next('work')).toBeNull();
+  });
+
+  test('cron parser rejects non-wildcard day/month/weekday fields', () => {
+    const manager = new TaskQueueManager();
+    expect(() => manager.addSchedule('q', '0 0 1 * *', {})).toThrow();
+    expect(() => manager.addSchedule('q', '0 0 * 6 *', {})).toThrow();
+    expect(() => manager.addSchedule('q', '0 0 * * 1', {})).toThrow();
+  });
+
+  test('cron parser accepts wildcard day/month/weekday fields', () => {
+    const manager = new TaskQueueManager();
+    expect(() => manager.addSchedule('q', '*/5 * * * *', {})).not.toThrow();
+    expect(() => manager.addSchedule('q', '0 0 * * *', {})).not.toThrow();
+  });
+});
