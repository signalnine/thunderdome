askQueueManager();\n\n    // Every 5 minutes\n    manager.addSchedule('emails', '*/5 * * * *', { type: 'digest' });\n\n    manager.tick();\n    const queue = manager.getQueue('emails');\n    // Queue may not exist or have 0 waiting\n    expect(queue?.waiting() ?? 0).toBe(0);\n  });\n\n  test('every hour on the hour pattern', () => {\n    vi.useFakeTimers({ now: new Date('2026-01-01T03:00:00Z') });\n    const manager = new TaskQueueManager();\n\n    manager.addSchedule('reports', '0 * * * *', { type: 'hourly' });\n\n    manager.tick();\n    expect(manager.getQueue('reports')!.waiting()).toBe(1);\n  });\n\n  test('every day at midnight pattern', () => {\n    vi.useFakeTimers({ now: new Date('2026-01-01T00:00:00Z') });\n    const manager = new TaskQueueManager();\n\n    manager.addSchedule('cleanup', '0 0 * * *', { type: 'daily' });\n\n    manager.tick();\n    expect(manager.getQueue('cleanup')!.waiting()).toBe(1);\n  });\n\n  test('daily pattern does not match non-midnight', () => {\n    vi.useFakeTimers({ now: new Date('2026-01-01T12:00:00Z') });\n    const manager = new TaskQueueManager();\n\n    manager.addSchedule('cleanup', '0 0 * * *', { type: 'daily' });\n\n    manager.tick();\n    // Queue may not have been created since no task was enqueued\n    expect(manager.getQueue('cleanup')?.waiting() ?? 0).toBe(0);\n  });\n\n  test('recurring tasks are regular tasks subject to queue rules', () => {\n    vi.useFakeTimers({ now: new Date('2026-01-01T00:00:00Z') });\n    const manager = new TaskQueueManager();\n\n    manager.addSchedule('work', '*/5 * * * *', { type: 'cron-task' });\n    manager.tick();\n\n    const task = manager.next('work');\n    expect(task).not.toBeNull();\n    expect(task!.payload).toEqual({ type: 'cron-task' });\n    expect(task!.status).toBe('processing');\n  });\n\n  test('removing schedule stops future occurrences', () => {\n    vi.useFakeTimers({ now: new Date('2026-01-01T00:00:00Z') });\n    const manager = new TaskQueueManager();\n\n    const