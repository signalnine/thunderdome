+
+  private areDependenciesMet(task: Task): boolean {
+    if (task.dependsOn.length === 0) return true;
+    return task.dependsOn.every(depId => {
+      const dep = this.resolveTask(depId);
+      return dep?.status === 'completed';
+    });
+  }
+
+  private detectCircularDeps(taskId: string, dependsOn: string[], visited: Set<string> = new Set()): boolean {
+    for (const depId of dependsOn) {
+      if (depId === taskId) return true;
+      if (visited.has(depId)) continue;
+      visited.add(depId);
+      const dep = this.resolveTask(depId);
+      if (dep && dep.dependsOn.length > 0) {
+        if (this.detectCircularDeps(taskId, dep.dependsOn, visited)) return true;
+      }
+    }
+    return false;
+  }
+
+  add<T = unknown>(payload: T, options?: AddTaskOptions): Task<T> {
+    const priority = options?.priority ?? 5;
+    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {
+      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);
+    }
+
+    const dependsOn = options?.dependsOn ? [...options.dependsOn] : [];
+
+    // Validate dependencies exist
+    for (const depId of dependsOn) {
+      const dep = this.resolveTask(depId);
+      if (!dep) {
+        throw new Error(`Dependency task not found: ${depId}`);
+      }
+    }
+
+    const now = new Date();
+    let availableAt = now;
+    if (options?.availableAt) {
+      availableAt = options.availableAt;
+    } else if (options?.delay) {
+      availableAt = new Date(now.getTime() + options.delay);
+    }
+
+    const id = randomUUID();
+
+    // Check circular dependencies
+    if (dependsOn.length > 0 && this.detectCircularDeps(id, dependsOn)) {
+      throw new Error('Circular dependency detected');
+    }
+
+    const task: Task<T> = {
+      id,
+      status: 'pending',
+      payload,
+      createdAt: now,
+      updatedAt: now,
+      queue: this.queueName,
+      priority,
+      availableAt,
+      attempts: 0,
+      maxRetries: options?.maxRetries ?? 3,
+      retryDelay: options?.retryDelay ?? 1000,
+      dependsOn,
+      progress: 0,
+      failureCount: 0,
+    };
+
+    this.tasks.set(task.id, task as Task);
+    this.insertionOrder.push(task.id);
+    return task;
+  }
+
+  next(): Task | null {
+    // Check concurrency limit
+    if (this.concurrencyLimit > 0 && this.activeCount() >= this.concurrencyLimit) {
+      return null;
+    }
+
+    const now = Date.now();
+    let best: Task | null = null;
+
+    for (const id of this.insertionOrder) {
+      const task = this.tasks.get(id)!;
+      if (task.status !== 'pending') continue;
+
+      const isAvailable = task.availableAt.getTime() <= now;
+      if (!isAvailable) continue;
+
+      if (!this.areDependenciesMet(task)) continue;
+
+      if (!best) {
+        best = task;
+        continue;
+      }
+
+      // Compare: priority first, then availableAt, then insertion order (FIFO)
+      if (task.priority < best.priority) {
+        best = task;
+      } else if (task.priority === best.priority) {
+        // Same priority: earlier availableAt wins
+        if (task.availableAt.getTime() < best.availableAt.getTime()) {
+          best = task;
+        }
+        // If same availableAt, FIFO order is preserved by iteration order
+      }
+    }
+
+    if (best) {
+      best.status = 'processing';
+      best.updatedAt = new Date();
+    }
+    return best;
+  }
+
+  waiting(): number {
+    let count = 0;
+    for (const task of this.tasks.values()) {
+      if (task.status === 'pending') count++;
+    }
+    return count;
+  }
+
+  complete(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot complete task in '${task.status}' state`);
+    }
+    task.status = 'completed';
+    task.updatedAt = new Date();
+    this.progressListeners.delete(taskId);
+  }
+
+  fail(taskId: string, error: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot fail task in '${task.status}' state`);
+    }
+
+    task.attempts++;
+    task.error = error;
+    task.failureCount++;
+    task.updatedAt = new Date();
+
+    if (task.attempts <= task.maxRetries) {
+      const delay = task.retryDelay * Math.pow(2, task.attempts - 1);
+      task.status = 'pending';
+      task.availableAt = new Date(Date.now() + delay);
+    } else {
+      task.status = 'failed';
+      this.dlq.add(task.id);
+    }
+  }
+
+  deadLetterQueue(): Task[] {
+    return Array.from(this.dlq).map(id => this.tasks.get(id)!);
+  }
+
+  requeue(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (!this.dlq.has(taskId)) throw new Error(`Task not in DLQ: ${taskId}`);
+
+    this.dlq.delete(taskId);
+    task.status = 'pending';
+    task.attempts = 0;
+    task.availableAt = new Date();
+    task.updatedAt = new Date();
+  }
+
+  clearDeadLetterQueue(): void {
+    for (const id of this.dlq) {
+      this.tasks.delete(id);
+      const idx = this.insertionOrder.indexOf(id);
+      if (idx !== -1) this.insertionOrder.splice(idx, 1);
+    }
+    this.dlq.clear();
+  }
+
+  setConcurrency(limit: number): void {
+    if (!Number.isInteger(limit) || limit < 0) {
+      throw new Error(`Invalid concurrency limit: ${limit}. Must be a non-negative integer.`);
+    }
+    this.concurrencyLimit = limit;
+  }
+
+  getConcurrency(): number {
+    return this.concurrencyLimit;
+  }
+
+  activeCount(): number {
+    let count = 0;
+    for (const task of this.tasks.values()) {
+      if (task.status === 'processing') count++;
+    }
+    return count;
+  }
+
+  updateProgress(taskId: string, progress: number, message?: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot update progress on task in '${task.status}' state`);
+    }
+
+    task.progress = progress;
+    task.progressMessage = message;
+    task.updatedAt = new Date();
+
+    const listeners = this.progressListeners.get(taskId);
+    if (listeners) {
+      for (const listener of listeners) {
+        listener(progress, message);
+      }
+    }
+  }
+
+  onProgress(taskId: string, callback: (progress: number, message?: string) => void): () => void {
+    if (!this.progressListeners.has(taskId)) {
+      this.progressListeners.set(taskId, []);
+    }
+    this.progressListeners.get(taskId)!.push(callback);
+
+    return () => {
+      const listeners = this.progressListeners.get(taskId);
+      if (listeners) {
+        const idx = listeners.indexOf(callback);
+        if (idx !== -1) listeners.splice(idx, 1);
+      }
+    };
+  }
+
+  use(middleware: (task: Task, next: () => Promise<void>) => Promise<void>): void {
+    this.middlewareStack.push(middleware);
+  }
+
+  setHandler(handler: (task: Task) => Promise<void>): void {
+    this.handler = handler;
+  }
+
+  async process(taskId: string): Promise<void> {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot process task in '${task.status}' state`);
+    }
+
+    const compose = (middlewares: Array<(task: Task, next: () => Promise<void>) => Promise<void>>, handler?: (task: Task) => Promise<void>) => {
+      let index = 0;
+      const dispatch = async (): Promise<void> => {
+        if (index < middlewares.length) {
+          const mw = middlewares[index++];
+          await mw(task, dispatch);
+        } else if (handler) {
+          await handler(task);
+        }
+      };
+      return dispatch;
+    };
+
+    try {
+      await compose(this.middlewareStack, this.handler)();
+    } catch (err) {
+      this.fail(taskId, (err as Error).message);
+    }
+  }
+
+  cancel(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'pending' && task.status !== 'processing') {
+      throw new Error(`Cannot cancel task in '${task.status}' state`);
+    }
+
+    task.status = 'cancelled';
+    task.updatedAt = new Date();
+    this.progressListeners.delete(taskId);
+  }
+
+  getTask(id: string): Task | undefined {
+    return this.tasks.get(id);
+  }
+
+  getProcessingTasks(): Task[] {
+    const result: Task[] = [];
+    for (const task of this.tasks.values()) {
+      if (task.status === 'processing') result.push(task);
+    }
+    return result;
+  }
+
+  dependencyStatus(taskId: string): Record<string, string> {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+
+    const result: Record<string, string> = {};
+    for (const depId of task.dependsOn) {
+      const dep = this.resolveTask(depId);
+      result[depId] = dep?.status ?? 'unknown';
+    }
+    return result;
+  }
+}
diff --git a/src/scheduler.ts b/src/scheduler.ts
new file mode 100644
index 0000000..0db780b
--- /dev/null
+++ b/src/scheduler.ts
@@ -0,0 +1,95 @@
+import { randomUUID } from 'node:crypto';
+
+export interface Schedule {
+  id: string;
+  queueName: string;
+  cronExpression: string;
+  payload: unknown;
+  lastRun?: Date;
+}
+
+export function parseCronExpression(expression: string): { minute: string; hour: string } {
+  const parts = expression.trim().split(/\s+/);
+  if (parts.length !== 5) {
+    throw new Error(`Invalid cron expression: ${expression}`);
+  }
+  // Only minute and hour fields are supported; day-of-month, month, and day-of-week must be '*'
+  if (parts[2] !== '*' || parts[3] !== '*' || parts[4] !== '*') {
+    throw new Error(`Unsupported cron expression: ${expression}. Only minute and hour fields are supported; day, month, and weekday must be '*'.`);
+  }
+  return {
+    minute: parts[0],
+    hour: parts[1],
+  };
+}
+
+export function cronMatches(expression: string, date: Date): boolean {
+  const { minute, hour } = parseCronExpression(expression);
+  const currentMinute = date.getUTCMinutes();
+  const currentHour = date.getUTCHours();
+
+  const minuteMatches = fieldMatches(minute, currentMinute);
+  const hourMatches = fieldMatches(hour, currentHour);
+
+  return minuteMatches && hourMatches;
+}
+
+function fieldMatches(field: string, value: number): boolean {
+  if (field === '*') return true;
+
+  // */N pattern
+  if (field.startsWith('*/')) {
+    const interval = parseInt(field.slice(2), 10);
+    if (isNaN(interval) || interval <= 0) return false;
+    return value % interval === 0;
+  }
+
+  // Exact value
+  const exact = parseInt(field, 10);
+  if (isNaN(exact)) return false;
+  return value === exact;
+}
+
+export class TaskScheduler {
+  private schedules: Map<string, Schedule> = new Map();
+
+  addSchedule(queueName: string, cronExpression: string, payload: unknown): string {
+    // Validate cron expression
+    parseCronExpression(cronExpression);
+
+    const schedule: Schedule = {
+      id: randomUUID(),
+      queueName,
+      cronExpression,
+      payload,
+    };
+    this.schedules.set(schedule.id, schedule);
+    return schedule.id;
+  }
+
+  removeSchedule(id: string): void {
+    this.schedules.delete(id);
+  }
+
+  listSchedules(): Schedule[] {
+    return Array.from(this.schedules.values());
+  }
+
+  getDueSchedules(now: Date): Schedule[] {
+    const due: Schedule[] = [];
+    for (const schedule of this.schedules.values()) {
+      if (!cronMatches(schedule.cronExpression, now)) continue;
+
+      // Prevent double-enqueue for the same minute
+      if (schedule.lastRun) {
+        const lastMinute = Math.floor(schedule.lastRun.getTime() / 60000);
+        const currentMinute = Math.floor(now.getTime() / 60000);
+        if (lastMinute === currentMinute) continue;
+      }
+
+      schedule.lastRun = now;
+      due.push(schedule);
+    }
+    return due;
+  }
+}
