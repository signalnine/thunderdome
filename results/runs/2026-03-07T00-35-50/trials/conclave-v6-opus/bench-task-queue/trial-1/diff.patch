rTask(taskId);\n    if (!queue) throw new Error(`Task not found: ${taskId}`);\n    queue.complete(taskId);\n  }\n\n  fail(taskId: string, error: string): void {\n    const queue = this.findQueueForTask(taskId);\n    if (!queue) throw new Error(`Task not found: ${taskId}`);\n    queue.fail(taskId, error);\n  }\n\n  private findQueueForTask(taskId: string): TaskQueue | undefined {\n    for (const queue of this.queueMap.values()) {\n      if (queue.getTask(taskId)) return queue;\n    }\n    return undefined;\n  }\n\n  queues(): string[] {\n    return Array.from(this.queueMap.keys());\n  }\n\n  getQueue(name: string): TaskQueue | undefined {\n    return this.queueMap.get(name);\n  }\n\n  getTask(taskId: string): Task | undefined {\n    return this.resolveTaskGlobal(taskId);\n  }\n\n  // Scheduling methods\n  addSchedule(queueName: string, cronExpression: string, payload: unknown): string {\n    return this.scheduler.addSchedule(queueName, cronExpression, payload);\n  }\n\n  removeSchedule(scheduleId: string): void {\n    this.scheduler.removeSchedule(scheduleId);\n  }\n\n  listSchedules(): Schedule[] {\n    return this.scheduler.listSchedules();\n  }\n\n  tick(): void {\n    const now = new Date();\n    const dueSchedules = this.scheduler.getDueSchedules(now);\n    for (const schedule of dueSchedules) {\n      this.add(schedule.queueName, schedule.payload);\n    }\n  }\n\n  // Shutdown methods\n  onShutdown(callback: () => void | Promise<void>): void {\n    this.shutdownCallbacks.push(callback);\n  }\n\n  private getProcessingTasks(): Task[] {\n    const processing: Task[] = [];\n    for (const queue of this.queueMap.values()) {\n      processing.push(...queue.getProcessingTasks());\n    }\n    return processing;\n  }\n\n  async shutdown(options?: ShutdownOptions): Promise<ShutdownResult> {\n    if (this.shutdownPromise) return this.shutdownPromise;\n\n    this.isShutdown = true;\n    const startTime = Date.now();\n    const timeout = options?.timeout ?? 0;\n\n    // Run shutdown callbacks\n    for (const cb of this.shutdownCallbacks) {\n      await cb();\n    }\n\n    this.shutdownPromise = new Promise<ShutdownResult>((resolve) => {\n      const processingTasks = this.getProcessingTasks();\n\n      if (processingTasks.length === 0) {\n        resolve({ completed: 0, forceCancelled: 0, duration: Date.now() - startTime });\n        return;\n      }\n\n      let completedCount = 0;\n      let resolved = false;\n\n      const checkDone = () => {\n        if (resolved) return;\n        const stillProcessing = this.getProcessingTasks();\n        if (stillProcessing.length === 0) {\n          resolved = true;\n          resolve({\n            completed: completedCount,\n            forceCancelled: 0,\n            duration: Date.now() - startTime,\n          });\n        }\n      };\n\n      // Track original processing task IDs\n      const originalProcessingIds = new Set(processingTasks.map(t => t.id));\n\n      // Poll for completion with setInterval\n      const interval = setInterval(() => {\n        // Count newly completed tasks\n        completedCount = 0;\n        for (const id of originalProcessingIds) {\n          const task = this.resolveTaskGlobal(id);\n          if (task && task.status === 'completed') completedCount++;\n        }\n        checkDone();\n      }, 10);\n\n      if (timeout > 0) {\n        setTimeout(() => {\n          if (resolved) return;\n          resolved = true;\n          clearInterval(interval);\n\n          // Force cancel remaining processing tasks\n          const stillProcessing = this.getProcessingTasks();\n          for (const task of stillProcessing) {\n            const queue = this.findQueueForTask(task.id);\n            if (queue) queue.cancel(task.id);\n          }\n\n          // Count completed from the originals\n          completedCount = 0;\n          for (const id of originalProcessingIds) {\n            const task = this.resolveTaskGlobal(id);\n            if (task && task.status === 