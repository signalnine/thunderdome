});\n\n  test('shutdown produces summary with duration', async () => {\n    const manager = new TaskQueueManager();\n    const result = await manager.shutdown();\n\n    expect(result).toHaveProperty('completed');\n    expect(result).toHaveProperty('forceCancelled');\n    expect(result).toHaveProperty('duration');\n    expect(typeof result.duration).toBe('number');\n  });\n\n  test('calling shutdown multiple times returns same result', async () => {\n    const manager = new TaskQueueManager();\n    const result1 = await manager.shutdown();\n    const result2 = await manager.shutdown();\n\n    expect(result1).toEqual(result2);\n  });\n\n  test('immediate completion when no tasks processing', async () => {\n    const manager = new TaskQueueManager();\n    manager.add('work', { data: 'pending' }); // pending, not processing\n\n    const result = await manager.shutdown();\n    expect(result.completed).toBe(0);\n    expect(result.forceCancelled).toBe(0);\n  });\n\n  test('multiple processing tasks across queues', async () => {\n    vi.useFakeTimers();\n    const manager = new TaskQueueManager();\n\n    manager.add('a', { data: 'task-a' });\n    manager.add('b', { data: 'task-b' });\n    const taskA = manager.next('a')!;\n    manager.next('b'); // processing\n\n    const shutdownPromise = manager.shutdown({ timeout: 5000 });\n\n    // Complete one, let the other timeout\n    manager.complete(taskA.id);\n    vi.advanceTimersByTime(5001);\n\n    const result = await shutdownPromise;\n    expect(result.completed).toBe(1);\n    expect(result.forceCancelled).toBe(1);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":612,"cache_read_input_tokens":102597,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":612},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"083d7f18-5302-4