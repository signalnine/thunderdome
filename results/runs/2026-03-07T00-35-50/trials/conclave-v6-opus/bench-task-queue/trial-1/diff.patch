ue.fail(task.id, 'err');\n    // Delay: 1000 * 2^0 = 1000ms\n    vi.advanceTimersByTime(1000);\n    expect(queue.next()!.id).toBe(task.id);\n\n    // Attempt 2\n    queue.fail(task.id, 'err');\n    // Delay: 1000 * 2^1 = 2000ms\n    vi.advanceTimersByTime(1999);\n    expect(queue.next()).toBeNull();\n    vi.advanceTimersByTime(1);\n    expect(queue.next()!.id).toBe(task.id);\n\n    // Attempt 3\n    queue.fail(task.id, 'err');\n    // Delay: 1000 * 2^2 = 4000ms\n    vi.advanceTimersByTime(3999);\n    expect(queue.next()).toBeNull();\n    vi.advanceTimersByTime(1);\n    expect(queue.next()!.id).toBe(task.id);\n  });\n\n  test('default max retries is 3', () => {\n    vi.useFakeTimers();\n    const queue = new TaskQueue();\n    const task = queue.add({ data: 'test' });\n\n    // Exhaust all 3 retries\n    for (let i = 0; i < 3; i++) {\n      queue.next();\n      queue.fail(task.id, `error ${i}`);\n      vi.advanceTimersByTime(100000); // advance past any delay\n    }\n\n    // 4th failure - should stay failed (retries exhausted)\n    queue.next();\n    queue.fail(task.id, 'final error');\n    expect(queue.getTask(task.id)!.status).toBe('failed');\n    expect(queue.getTask(task.id)!.attempts).toBe(4);\n  });\n\n  test('configurable max retries per task', () => {\n    vi.useFakeTimers();\n    const queue = new TaskQueue();\n    const task = queue.add({ data: 'test' }, { maxRetries: 1 });\n\n    queue.next();\n    queue.fail(task.id, 'error 1');\n    vi.advanceTimersByTime(100000);\n\n    // After 1 retry, next failure should leave it failed\n    queue.next();\n    queue.fail(task.id, 'error 2');\n    expect(queue.getTask(task.id)!.status).toBe('failed');\n  });\n\n  test('configurable base backoff delay per task', () => {\n    vi.useFakeTimers();\n    const queue = new TaskQueue();\n    const task = queue.add({ data: 'test' }, { retryDelay: 500 });\n\n    queue.next();\n    queue.fail(task.id, 'error');\n    // Delay should be 500 * 2^0 = 500ms\n    vi.advanceTimersByTim