+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01V498wCYMFC6Bx8PMVqiVHS","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_017DAhBb3uewHJk3Hu9kDU7J","name":"Write","input":{"file_path":"/workspace/tests/edge-cases.test.ts","content":"import { describe, test, expect, vi, afterEach } from 'vitest';\nimport { TaskQueue, TaskQueueManager } from '../src/index.js';\n\ndescribe('Edge Cases: Status Guards', () => {\n  afterEach(() => {\n    vi.useRealTimers();\n  });\n\n  test('cannot complete a non-processing task', () => {\n    const queue = new TaskQueue();\n    const task = queue.add({ data: 'test' });\n    // task is pending, not processing\n    expect(() => queue.complete(task.id)).toThrow();\n  });\n\n  test('cannot complete a cancelled task', () => {\n    const queue = new TaskQueue();\n    const task = queue.add({ data: 'test' });\n    queue.next();\n    queue.cancel(task.id);\n    expect(() => queue.complete(task.id)).toThrow();\n  });\n\n  test('cannot fail a cancelled task', () => {\n    const queue = new TaskQueue();\n    const task = queue.add({ data: 'test' }, { maxRetries: 3 });\n    queue.next();\n    queue.cancel(task.id);\n    expect(() => queue.fail(task.id, 'error')).toThrow();\n  });\n\n  test('cannot fail a pending task', () => {\n    const queue = new TaskQueue();\n    const task = queue.add({ data: 'test' });\n    expect(() => queue.fail(task.id, 'error')).toThrow();\n  });\n\n  test('cannot cancel a completed task', () => {\n    const queue = new TaskQueue();\n    const task = queue.add({ data: 'test' });\n    queue.next();\n    queue.complete(task.id);\n    expect(() => queue.cancel(task.id)).toThrow();\n  });\n\n  test('cannot cancel a failed task', () => {\n    const queue = new TaskQueue();\n    const task = queue.add({ data: 'test' }, { maxRetries: 0 });\n    queue.next();\n    queue.fail(task.id, 'error');\n    expect(() => queue.cancel(task.id)).toThrow();\n  });\n\n  test('cannot update progr