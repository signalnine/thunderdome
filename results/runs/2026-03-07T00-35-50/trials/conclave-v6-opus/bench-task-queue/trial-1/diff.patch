--- /dev/null
+++ b/src/manager.ts
@@ -0,0 +1,211 @@
+import { TaskQueue } from './queue.js';
+import { TaskScheduler } from './scheduler.js';
+import type { Task } from './types.js';
+import type { AddTaskOptions } from './queue.js';
+import type { Schedule } from './scheduler.js';
+
+export interface ShutdownResult {
+  completed: number;
+  forceCancelled: number;
+  duration: number;
+}
+
+export interface ShutdownOptions {
+  timeout?: number;
+}
+
+export class TaskQueueManager {
+  private queueMap: Map<string, TaskQueue> = new Map();
+  private scheduler = new TaskScheduler();
+  private isShutdown = false;
+  private shutdownResult?: ShutdownResult;
+  private shutdownCallbacks: Array<() => void | Promise<void>> = [];
+
+  // Shutdown coordination
+  private shutdownResolve?: (result: ShutdownResult) => void;
+  private shutdownStartTime = 0;
+  private shutdownTrackedIds = new Set<string>();
+  private shutdownTimedOut = false;
+
+  private resolveTaskGlobal = (id: string): Task | undefined => {
+    for (const queue of this.queueMap.values()) {
+      const task = queue.getTask(id);
+      if (task) return task;
+    }
+    return undefined;
+  };
+
+  private getOrCreateQueue(name: string): TaskQueue {
+    let queue = this.queueMap.get(name);
+    if (!queue) {
+      queue = new TaskQueue(name);
+      queue.setTaskResolver(this.resolveTaskGlobal);
+      this.queueMap.set(name, queue);
+    }
+    return queue;
+  }
+
+  add<T = unknown>(queueName: string | undefined, payload: T, options?: AddTaskOptions): Task<T> {
+    if (this.isShutdown) {
+      throw new Error('Cannot add tasks after shutdown');
+    }
+    const name = queueName ?? 'default';
+    const queue = this.getOrCreateQueue(name);
+    return queue.add(payload, options);
+  }
+
+  next(queueName?: string): Task | null {
+    if (this.isShutdown) return null;
+    const name = queueName ?? 'default';
+    const queue = this.queueMap.get(name);
+    if (!queue) return null;
+    return queue.next();
+  }
+
+  complete(taskId: string): void {
+    const queue = this.findQueueForTask(taskId);
+    if (!queue) throw new Error(`Task not found: ${taskId}`);
+    queue.complete(taskId);
+    this.checkShutdownComplete();
+  }
+
+  fail(taskId: string, error: string): void {
+    const queue = this.findQueueForTask(taskId);
+    if (!queue) throw new Error(`Task not found: ${taskId}`);
+    queue.fail(taskId, error);
+    this.checkShutdownComplete();
+  }
+
+  private findQueueForTask(taskId: string): TaskQueue | undefined {
+    for (const queue of this.queueMap.values()) {
+      if (queue.getTask(taskId)) return queue;
+    }
+    return undefined;
+  }
+
+  queues(): string[] {
+    return Array.from(this.queueMap.keys());
+  }
+
+  getQueue(name: string): TaskQueue | undefined {
+    return this.queueMap.get(name);
+  }
+
+  getTask(taskId: string): Task | undefined {
+    return this.resolveTaskGlobal(taskId);
+  }
+
+  // Scheduling methods
+  addSchedule(queueName: string, cronExpression: string, payload: unknown): string {
+    return this.scheduler.addSchedule(queueName, cronExpression, payload);
+  }
+
+  removeSchedule(scheduleId: string): void {
+    this.scheduler.removeSchedule(scheduleId);
+  }
+
+  listSchedules(): Schedule[] {
+    return this.scheduler.listSchedules();
+  }
+
+  tick(): void {
+    const now = new Date();
+    const dueSchedules = this.scheduler.getDueSchedules(now);
+    for (const schedule of dueSchedules) {
+      this.add(schedule.queueName, schedule.payload);
+    }
+  }
+
+  // Shutdown methods
+  onShutdown(callback: () => void | Promise<void>): void {
+    this.shutdownCallbacks.push(callback);
+  }
+
+  private getProcessingTasks(): Task[] {
+    const processing: Task[] = [];
+    for (const queue of this.queueMap.values()) {
+      processing.push(...queue.getProcessingTasks());
+    }
+    return processing;
+  }
+
+  private checkShutdownComplete(): void {
+    if (!this.shutdownResolve || this.shutdownTimedOut) return;
+
+    const stillProcessing = this.getProcessingTasks();
+    if (stillProcessing.length === 0) {
+      let completedCount = 0;
+      for (const id of this.shutdownTrackedIds) {
+        const task = this.resolveTaskGlobal(id);
+        if (task && task.status === 'completed') completedCount++;
+      }
+
+      const resolve = this.shutdownResolve;
+      this.shutdownResolve = undefined;
+      resolve({
+        completed: completedCount,
+        forceCancelled: 0,
+        duration: Date.now() - this.shutdownStartTime,
+      });
+    }
+  }
+
+  async shutdown(options?: ShutdownOptions): Promise<ShutdownResult> {
+    if (this.shutdownResult) return this.shutdownResult;
+
+    this.isShutdown = true;
+    this.shutdownStartTime = Date.now();
+    const timeout = options?.timeout ?? 0;
+
+    // Run shutdown callbacks
+    for (const cb of this.shutdownCallbacks) {
+      await cb();
+    }
+
+    const processingTasks = this.getProcessingTasks();
+
+    if (processingTasks.length === 0) {
+      this.shutdownResult = { completed: 0, forceCancelled: 0, duration: Date.now() - this.shutdownStartTime };
+      return this.shutdownResult;
+    }
+
+    this.shutdownTrackedIds = new Set(processingTasks.map(t => t.id));
+
+    const promise = new Promise<ShutdownResult>((resolve) => {
+      this.shutdownResolve = resolve;
+
+      if (timeout > 0) {
+        setTimeout(() => {
+          if (!this.shutdownResolve) return; // already resolved
+          this.shutdownTimedOut = true;
+
+          const stillProcessing = this.getProcessingTasks();
+          for (const task of stillProcessing) {
+            const queue = this.findQueueForTask(task.id);
+            if (queue) queue.cancel(task.id);
+          }
+
+          let completedCount = 0;
+          for (const id of this.shutdownTrackedIds) {
+            const task = this.resolveTaskGlobal(id);
+            if (task && task.status === 'completed') completedCount++;
+          }
+
+          const resolveRef = this.shutdownResolve;
+          this.shutdownResolve = undefined;
+          resolveRef({
+            completed: completedCount,
+            forceCancelled: stillProcessing.length,
+            duration: Date.now() - this.shutdownStartTime,
+          });
+        }, timeout);
+      }
+
+      // Check immediately in case all tasks were already completed
+      this.checkShutdownComplete();
+    });
+
+    this.shutdownResult = await promise;
+    return this.shutdownResult;
+  }
+}
