--- /dev/null
+++ b/src/ot.ts
@@ -0,0 +1,173 @@
+export interface InsertOp {
+  type: 'insert';
+  position: number;
+  text: string;
+}
+
+export interface DeleteOp {
+  type: 'delete';
+  position: number;
+  count: number;
+}
+
+export type Operation = InsertOp | DeleteOp;
+
+export interface VersionedOperation {
+  op: Operation;
+  version: number;
+  clientId: string;
+}
+
+/**
+ * Apply an operation to a document string.
+ */
+export function applyOp(doc: string, op: Operation): string {
+  if (op.type === 'insert') {
+    const pos = Math.min(Math.max(0, op.position), doc.length);
+    return doc.slice(0, pos) + op.text + doc.slice(pos);
+  } else {
+    const pos = Math.min(Math.max(0, op.position), doc.length);
+    const count = Math.min(op.count, doc.length - pos);
+    if (count <= 0) return doc;
+    return doc.slice(0, pos) + doc.slice(pos + count);
+  }
+}
+
+/**
+ * Transform operation `op` against a previously-applied operation `against`.
+ * Returns the transformed version of `op` that can be applied after `against`.
+ *
+ * Invariant: if doc' = apply(doc, against), then
+ *   apply(apply(doc, against), transform(op, against)) === apply(apply(doc, op), transform(against, op))
+ */
+export function transformOp(op: Operation, against: Operation): Operation[] {
+  if (op.type === 'insert' && against.type === 'insert') {
+    if (op.position <= against.position) {
+      return [{ ...op }];
+    } else {
+      return [{ ...op, position: op.position + against.text.length }];
+    }
+  }
+
+  if (op.type === 'insert' && against.type === 'delete') {
+    if (op.position <= against.position) {
+      return [{ ...op }];
+    } else if (op.position >= against.position + against.count) {
+      return [{ ...op, position: op.position - against.count }];
+    } else {
+      return [{ ...op, position: against.position }];
+    }
+  }
+
+  if (op.type === 'delete' && against.type === 'insert') {
+    if (op.position >= against.position) {
+      return [{ ...op, position: op.position + against.text.length }];
+    } else if (op.position + op.count <= against.position) {
+      return [{ ...op }];
+    } else {
+      // Delete range straddles the insert point.
+      // Split into two deletes: before and after the inserted text.
+      const beforeCount = against.position - op.position;
+      const afterCount = op.count - beforeCount;
+      const ops: Operation[] = [];
+      if (beforeCount > 0) {
+        ops.push({ type: 'delete', position: op.position, count: beforeCount });
+      }
+      if (afterCount > 0) {
+        ops.push({ type: 'delete', position: against.position + against.text.length, count: afterCount });
+      }
+      if (ops.length === 0) {
+        ops.push({ type: 'delete', position: op.position, count: 0 });
+      }
+      return ops;
+    }
+  }
+
+  // Both deletes
+  if (op.type === 'delete' && against.type === 'delete') {
+    const opEnd = op.position + op.count;
+    const againstEnd = against.position + against.count;
+
+    if (opEnd <= against.position) {
+      return [{ ...op }];
+    } else if (op.position >= againstEnd) {
+      return [{ ...op, position: op.position - against.count }];
+    } else if (op.position >= against.position && opEnd <= againstEnd) {
+      // Entirely within — nothing left to delete
+      return [{ type: 'delete', position: against.position, count: 0 }];
+    } else if (op.position <= against.position && opEnd >= againstEnd) {
+      // op fully contains against
+      return [{ ...op, count: op.count - against.count }];
+    } else if (op.position < against.position) {
+      // Overlaps start
+      const overlap = opEnd - against.position;
+      return [{ ...op, count: op.count - overlap }];
+    } else {
+      // Overlaps end
+      const overlap = againstEnd - op.position;
+      return [{ type: 'delete', position: against.position, count: op.count - overlap }];
+    }
+  }
+
+  return [{ ...op } as Operation];
+}
+
+/**
+ * Apply a list of operations sequentially.
+ */
+export function applyOps(doc: string, ops: Operation[]): string {
+  let result = doc;
+  for (const op of ops) {
+    result = applyOp(result, op);
+  }
+  return result;
+}
+
+/**
+ * Transform a single operation against a list of operations that have already been applied.
+ * Returns the transformed operations.
+ */
+export function transformOpAgainstOps(op: Operation, againstOps: Operation[]): Operation[] {
+  let ops: Operation[] = [op];
+  for (const against of againstOps) {
+    const newOps: Operation[] = [];
+    for (const o of ops) {
+      newOps.push(...transformOp(o, against));
+    }
+    ops = newOps;
+  }
+  return ops;
+}
+
+/**
+ * Validate an operation. Returns an error string if invalid, null if valid.
+ */
+export function validateOp(op: unknown): string | null {
+  if (!op || typeof op !== 'object') {
+    return 'Operation must be an object';
+  }
+
+  const o = op as Record<string, unknown>;
+
+  if (o.type === 'insert') {
+    if (typeof o.position !== 'number' || o.position < 0 || !Number.isInteger(o.position)) {
+      return 'Insert operation requires a non-negative integer position';
+    }
+    if (typeof o.text !== 'string' || o.text.length === 0) {
+      return 'Insert operation requires a non-empty text string';
+    }
+    return null;
+  }
+
+  if (o.type === 'delete') {
+    if (typeof o.position !== 'number' || o.position < 0 || !Number.isInteger(o.position)) {
+      return 'Delete operation requires a non-negative integer position';
+    }
+    if (typeof o.count !== 'number' || o.count < 1 || !Number.isInteger(o.count)) {
+      return 'Delete operation requires a positive integer count';
+    }
+    return null;
+  }
+
+  return `Unknown operation type: ${String(o.type)}`;
+}
