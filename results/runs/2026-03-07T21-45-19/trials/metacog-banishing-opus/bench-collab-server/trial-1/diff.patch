 ws.on('error', reject);\n  });\n}\n\nfunction waitForMessage(messages: unknown[], count: number, timeout = 5000): Promise<void> {\n  return new Promise((resolve, reject) => {\n    const start = Date.now();\n    const check = () => {\n      if (messages.length >= count) {\n        resolve();\n        return;\n      }\n      if (Date.now() - start > timeout) {\n        reject(new Error(`Timeout waiting for ${count} messages, got ${messages.length}: ${JSON.stringify(messages)}`));\n        return;\n      }\n      setTimeout(check, 20);\n    };\n    check();\n  });\n}\n\ndescribe('REST API', () => {\n  it('creates a document', async () => {\n    const res = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Test Doc', content: 'Hello' }),\n    });\n    expect(res.status).toBe(201);\n    const doc = await res.json();\n    expect(doc.title).toBe('Test Doc');\n    expect(doc.content).toBe('Hello');\n    expect(doc.id).toBeDefined();\n  });\n\n  it('lists documents', async () => {\n    await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Doc 1' }),\n    });\n    await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Doc 2' }),\n    });\n\n    const res = await fetch(`${baseUrl}/api/documents`);\n    expect(res.status).toBe(200);\n    const docs = await res.json();\n    expect(docs.length).toBe(2);\n  });\n\n  it('gets a document by id', async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'My Doc', content: 'some content' }),\n    });\n    const created = await createRes.json();\n\n    const res = await fetch(`${baseUrl}/api/documents/${created.id}`);\n    expect(res.status).toBe(200);\n    const doc = await res.json();\n    expect(doc.title).toBe('My Doc');\n    expect(doc.content).toBe('some content');\n  });\n\n  it('returns 404 for non-existent document', async () => {\n    const res = await fetch(`${baseUrl}/api/documents/nonexistent`);\n    expect(res.status).toBe(404);\n  });\n\n  it('updates a document', async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Old Title', content: 'old' }),\n    });\n    const created = await createRes.json();\n\n    const res = await fetch(`${baseUrl}/api/documents/${created.id}`, {\n      method: 'PUT',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'New Title', content: 'new' }),\n    });\n    expect(res.status).toBe(200);\n    const doc = await res.json();\n    expect(doc.title).toBe('New Title');\n    expect(doc.content).toBe('new');\n  });\n\n  it('deletes a document', async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Delete Me' }),\n    });\n    const created = await createRes.json();\n\n    const delRes = await fetch(`${baseUrl}/api/documents/${created.id}`, {\n      method: 'DELETE',\n    });\n    expect(delRes.status).toBe(204);\n\n    const getRes = await fetch(`${baseUrl}/api/documents/${created.id}`);\n    expect(getRes.status).toBe(404);\n  });\n\n  it('returns 400 for missing title on create', async () => {\n    const res = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({}),\n    });\n    expect(res.status).toBe(400);\n  });\n\n  it('gets version history', async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Versioned', content: 'v1' }),\n    });\n    const created = await createRes.json();\n\n    const res = await fetch(`${baseUrl}/api/documents/${created.id}/versions`);\n    expect(res.status).toBe(200);\n    const versions = await res.json();\n    expect(versions.length).toBe(1);\n    expect(versions[0].version).toBe(1);\n    expect(versions[0].content).toBe('v1');\n  });\n});\n\ndescribe('WebSocket collaboration', () => {\n  it('receives sync message on connect', async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'WS Test', content: 'initial' }),\n    });\n    const doc = await createRes.json();\n\n    const { ws, messages } = await connectWs(doc.id, 'client1');\n    await waitForMessage(messages, 1);\n\n    const syncMsg = messages[0] as Record<string, unknown>;\n    expect(syncMsg.type).toBe('sync');\n    expect((syncMsg.document as Record<string, unknown>).content).toBe('initial');\n\n    ws.close();\n  });\n\n  it('broadcasts operations to other clients', async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Broadcast Test', content: '' }),\n    });\n    const doc = await createRes.json();\n\n    const client1 = await connectWs(doc.id, 'c1');\n    const client2 = await connectWs(doc.id, 'c2');\n\n    await waitForMessage(client1.messages, 1);\n    await waitForMessage(client2.messages, 1);\n\n    // Client 1 sends an operation\n    client1.ws.send(JSON.stringify({\n      type: 'operation',\n      op: { type: 'insert', position: 0, text: 'hello' },\n      version: (client1.messages[0] as Record<string, unknown>).version,\n    }));\n\n    // Client 1 should get an ack\n    await waitForMessage(client1.messages, 2);\n    expect((client1.messages[1] as Record<string, unknown>).type).toBe('ack');\n\n    // Client 2 should get the operation\n    await waitForMessage(client2.messages, 2);\n    expect((client2.messages[1] as Record<string, unknown>).type).toBe('operation');\n\n    client1.ws.close();\n    client2.ws.close();\n  });\n\n  it('persists changes via WebSocket to REST', async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Persist Test', content: '' }),\n    });\n    const doc = await createRes.json();\n\n    const { ws, messages } = await connectWs(doc.id, 'c1');\n    await waitForMessage(messages, 1);\n    const syncVersion = (messages[0] as Record<string, unknown>).version as number;\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      op: { type: 'insert', position: 0, text: 'persisted!' },\n      version: syncVersion,\n    }));\n\n    await waitForMessage(messages, 2);\n    ws.close();\n\n    // Wait a moment for close handler to persist\n    await new Promise(r => setTimeout(r, 100));\n\n    const res = await fetch(`${baseUrl}/api/documents/${doc.id}`);\n    const updated = await res.json();\n    expect(updated.content).toBe('persisted!');\n  });\n\n  it('handles invalid WebSocket path', async () => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/invalid`);\n    const messages: unknown[] = [];\n\n    ws.on('message', (data) => {\n      messages.push(JSON.parse(data.toString()));\n    });\n\n    await new Promise<void>((resolve) => {\n      ws.on('close', () => resolve());\n    });\n\n    expect(messages.length).toBe(1);\n    expect((messages[0] as Record<string, unknown>).type).toBe('error');\n  });\n\n  it('handles non-existent document', async () => {\n    const ws = new WebSocket(wsUrl('nonexistent-id', 'c1'));\n    const messages: unknown[] = [];\n\n    ws.on('message', (data) => {\n      messages.push(JSON.parse(data.toString()));\n    });\n\n    await new Promise<void>((resolve) => {\n      ws.on('close', () => resolve());\n    });\n\n    expect(messages.length).toBe(1);\n    expect((messages[0] as Record<string, unknown>).type).toBe('error');\n  });\n\n  it('sends error for invalid operation', async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Invalid Op Test', content: '' }),\n    });\n    const doc = await createRes.json();\n\n    const { ws, messages } = await connectWs(doc.id, 'c1');\n    await waitForMessage(messages, 1);\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      op: { type: 'insert', position: -1, text: 'bad' },\n    }));\n\n    await waitForMessage(messages, 2);\n    expect((messages[1] as Record<string, unknown>).type).toBe('error');\n\n    ws.close();\n  });\n\n  it('sends error for unknown message type', async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Unknown Type Test', content: '' }),\n    });\n    const doc = await createRes.json();\n\n    const { ws, messages } = await connectWs(doc.id, 'c1');\n    await waitForMessage(messages, 1);\n\n    ws.send(JSON.stringify({ type: 'unknown' }));\n\n    await waitForMessage(messages, 2);\n    expect((messages[1] as Record<string, unknown>).type).toBe('error');\n\n    ws.close();\n  });\n});\n\ndescribe('concurrent editing convergence', () => {\n  it('two clients inserting at different positions converge', async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Convergence', content: 'abc' }),\n    });\n    const doc = await createRes.json();\n\n    const c1 = await connectWs(doc.id, 'c1');\n    const c2 = await connectWs(doc.id, 'c2');\n\n    await waitForMessage(c1.messages, 1);\n    await waitForMessage(c2.messages, 1);\n\n    const v = (c1.messages[0] as Record<string, unknown>).version as number;\n\n    // Both send at the same base version\n    c1.ws.send(JSON.stringify({\n      type: 'operation',\n      op: { type: 'insert', position: 0, text: 'X' },\n      version: v,\n    }));\n\n    c2.ws.send(JSON.stringify({\n      type: 'operation',\n      op: { type: 'insert', position: 3, text: 'Y' },\n      version: v,\n    }));\n\n    // Wait for acks and broadcasts\n    await waitForMessage(c1.messages, 3);\n    await waitForMessage(c2.messages, 3);\n\n    c1.ws.close();\n    c2.ws.close();\n\n    await new Promise(r => setTimeout(r, 100));\n\n    const res = await fetch(`${baseUrl}/api/documents/${doc.id}`);\n    const updated = await res.json();\n    // Both X and Y should be present\n    expect(updated.content).toContain('X');\n    expect(updated.content).toContain('Y');\n    expect(updated.content).toContain('abc');\n  });\n\n  it('handles 10 concurrent clients without corruption', async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Stress Test', content: '' }),\n    });\n    const doc = await createRes.json();\n\n    const clients: { ws: WebSocket; messages: unknown[] }[] = [];\n\n    // Connect 10 clients\n    for (let i = 0; i < 10; i++) {\n      const c = await connectWs(doc.id, `client${i}`);\n      await waitForMessage(c.messages, 1);\n      clients.push(c);\n    }\n\n    // Each client sends an insert\n    for (let i = 0; i < 10; i++) {\n      const v = (clients[i].messages[0] as Record<string, unknown>).version as number;\n      clients[i].ws.send(JSON.stringify({\n        type: 'operation',\n        op: { type: 'insert', position: 0, text: `${i}` },\n        version: v,\n      }));\n    }\n\n    // Wait for all operations to settle\n    // Each client should get: 1 sync + 1 ack + 9 broadcasts = 11 messages\n    for (const c of clients) {\n      await waitForMessage(c.messages, 11);\n    }\n\n    // Close all\n    for (const c of clients) {\n      c.ws.close();\n    }\n\n    await new Promise(r => setTimeout(r, 200));\n\n    const res = await fetch(`${baseUrl}/api/documents/${doc.id}`);\n    const updated = await res.json();\n\n    // All digits 0-9 should be present in the content\n    for (let i = 0; i < 10; i++) {\n      expect(updated.content).toContain(`${i}`);\n    }\n    // Content should be exactly 10 chars\n    expect(updated.content.length).toBe(10);\n  });\n});\n\ndescribe('version history', () => {\n  it('tracks versions through WebSocket edits', async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Version History', content: '' }),\n    });\n    const doc = await createRes.json();\n\n    const { ws, messages } = await connectWs(doc.id, 'c1');\n    await waitForMessage(messages, 1);\n\n    const v = (messages[0] as Record<string, unknown>).version as number;\n\n    // Send 3 operations\n    ws.send(JSON.stringify({\n      type: 'operation',\n      op: { type: 'insert', position: 0, text: 'a' },\n      version: v,\n    }));\n    await waitForMessage(messages, 2);\n\n    const v2 = (messages[1] as Record<string, unknown>).version as number;\n    ws.send(JSON.stringify({\n      type: 'operation',\n      op: { type: 'insert', position: 1, text: 'b' },\n      version: v2,\n    }));\n    await waitForMessage(messages, 3);\n\n    const v3 = (messages[2] as Record<string, unknown>).version as number;\n    ws.send(JSON.stringify({\n      type: 'operation',\n      op: { type: 'insert', position: 2, text: 'c' },\n      version: v3,\n    }));\n    await waitForMessage(messages, 4);\n\n    ws.close();\n    await new Promise(r => setTimeout(r, 100));\n\n    const versionsRes = await fetch(`${baseUrl}/api/documents/${doc.id}/versions`);\n    const versions = await versionsRes.json();\n    // Initial version + 3 edits = 4 versions\n    expect(versions.length).toBe(4);\n    expect(versions[versions.length - 1].content).toBe('abc');\n  });\n});\n\ndescribe('persistence', () => {\n  it('survives server restart with file-based DB', async () => {\n    const os = await import('os');\n    const path = await import('path');\n    const fs = await import('fs');\n\n    const tmpDir = os.tmpdir();\n    const dbPath = path.join(tmpDir, `collab-test-${Date.now()}.db`);\n\n    try {\n      // Start first server\n      const app1 = createApp(dbPath);\n      const port1 = await app1.start(0);\n      const base1 = `http://localhost:${port1}`;\n\n      // Create a document\n      const createRes = await fetch(`${base1}/api/documents`, {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.stringify({ title: 'Persistent Doc', content: 'survive restart' }),\n      });\n      const doc = await createRes.json();\n\n      // Stop first server\n      await app1.stop();\n\n      // Start second server with same DB\n      const app2 = createApp(dbPath);\n      const port2 = await app2.start(0);\n      const base2 = `http://localhost:${port2}`;\n\n      // Document should still exist\n      const res = await fetch(`${base2}/api/documents/${doc.id}`);\n      expect(res.status).toBe(200);\n      const found = await res.json();\n      expect(found.title).toBe('Persistent Doc');\n      expect(found.content).toBe('survive restart');\n\n      await app2.stop();\n    } finally {\n      try { fs.unlinkSync(dbPath); } catch { /* ignore */ }\n      try { fs.unlinkSync(dbPath + '-wal'); } catch { /* ignore */ }\n      try { fs.unlinkSync(dbPath + '-shm'); } catch { /* ignore */ }\n    }\n  });\n});\n","structuredPatch":[{"oldStart":367,"oldLines":10,"newStart":367,"newLines":13,"lines":[" ","     const res = await fetch(`${baseUrl}/api/documents/${doc.id}`);","     const updated = await res.json();","-    // Both X and Y should be present","+    // Both X and Y should be present, and all original chars too","     expect(updated.content).toContain('X');","     expect(updated.content).toContain('Y');","-    expect(updated.content).toContain('abc');","+    expect(updated.content).toContain('a');","+    expect(updated.content).toContain('b');","+    expect(updated.content).toContain('c');","+    expect(updated.content.length).toBe(5); // 'abc' + 'X' + 'Y'","   });"," ","   it('handles 10 concurrent clients without corruption', async () => {"]}],"userModified":false,"replaceAll":false}}
