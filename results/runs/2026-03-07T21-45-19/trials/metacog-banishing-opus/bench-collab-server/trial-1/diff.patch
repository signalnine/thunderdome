+    ws.send(JSON.stringify({
+      type: 'operation',
+      op: { type: 'insert', position: 0, text: 'a' },
+      version: v,
+    }));
+    await waitForMessage(messages, 2);
+
+    const v2 = (messages[1] as Record<string, unknown>).version as number;
+    ws.send(JSON.stringify({
+      type: 'operation',
+      op: { type: 'insert', position: 1, text: 'b' },
+      version: v2,
+    }));
+    await waitForMessage(messages, 3);
+
+    const v3 = (messages[2] as Record<string, unknown>).version as number;
+    ws.send(JSON.stringify({
+      type: 'operation',
+      op: { type: 'insert', position: 2, text: 'c' },
+      version: v3,
+    }));
+    await waitForMessage(messages, 4);
+
+    ws.close();
+    await new Promise(r => setTimeout(r, 100));
+
+    const versionsRes = await fetch(`${baseUrl}/api/documents/${doc.id}/versions`);
+    const versions = await versionsRes.json();
+    // Initial version + 3 edits = 4 versions
+    expect(versions.length).toBe(4);
+    expect(versions[versions.length - 1].content).toBe('abc');
+  });
+});
