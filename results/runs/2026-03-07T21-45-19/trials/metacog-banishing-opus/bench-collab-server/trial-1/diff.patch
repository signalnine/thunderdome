= new Map();\n  private store: DocumentStore;\n  private wss: WebSocketServer | null = null;\n  private closed = false;\n\n  constructor(store: DocumentStore) {\n    this.store = store;\n  }\n\n  attach(server: HttpServer): void {\n    this.wss = new WebSocketServer({ server });\n\n    this.wss.on('connection', (ws, req) => {\n      const url = req.url || '';\n      // Expect path like /ws/documents/:id\n      const match = url.match(/\\/ws\\/documents\\/([^/?]+)/);\n      if (!match) {\n        ws.send(JSON.stringify({ type: 'error', message: 'Invalid WebSocket path. Use /ws/documents/:id' }));\n        ws.close();\n        return;\n      }\n\n      const documentId = match[1];\n\n      // Parse clientId from query string\n      const queryMatch = url.match(/[?&]clientId=([^&]+)/);\n      const clientId = queryMatch ? decodeURIComponent(queryMatch[1]) : crypto.randomUUID();\n\n      this.handleConnection(ws, documentId, clientId);\n    });\n  }\n\n  private handleConnection(ws: WebSocket, documentId: string, clientId: string): void {\n    const doc = this.store.getDocument(documentId);\n    if (!doc) {\n      ws.send(JSON.stringify({ type: 'error', message: 'Document not found' }));\n      ws.close();\n      return;\n    }\n\n    const session = this.getOrCreateSession(documentId);\n    const clientInfo: ClientInfo = { ws, clientId, documentId };\n    session.clients.set(clientId, clientInfo);\n\n    // Send current document state\n    ws.send(JSON.stringify({\n      type: 'sync',\n      document: {\n        id: doc.id,\n        title: doc.title,\n        content: session.content,\n      },\n      version: session.version,\n      clientId,\n    }));\n\n    ws.on('message', (data) => {\n      try {\n        const message = JSON.parse(data.toString()) as ClientMessage;\n        this.handleMessage(session, clientInfo, message);\n      } catch (err) {\n        ws.send(JSON.stringify({\n          type: 'error',\n          message: `Invalid message: ${err instanceof Error ? err.message : 'parse error'}`,\n        }));\n      }\n    });\n\n    ws.on('close', () => {\n      session.clients.delete(clientId);\n      if (session.clients.size === 0) {\n        if (!this.closed) {\n          this.store.updateDocumentContent(documentId, session.content);\n        }\n        this.sessions.delete(documentId);\n      }\n    });\n\n    ws.on('error', () => {\n      session.clients.delete(clientId);\n    });\n  }\n\n  private getOrCreateSession(documentId: string): DocumentSession {\n    let session = this.sessions.get(documentId);\n    if (session) return session;\n\n    const doc = this.store.getDocument(documentId);\n    if (!doc) throw new Error('Document not found');\n\n    const latestVersion = this.store.getLatestVersion(documentId);\n    const version = latestVersion ? latestVersion.version : 0;\n\n    session = {\n      documentId,\n      clients: new Map(),\n      version,\n      content: doc.content,\n      history: [],\n    };\n    this.sessions.set(documentId, session);\n    return session;\n  }\n\n  private handleMessage(session: DocumentSession, client: ClientInfo, message: ClientMessage): void {\n    if (message.type === 'operation') {\n      this.handleOperation(session, client, message);\n    } else {\n      client.ws.send(JSON.stringify({\n        type: 'error',\n        message: `Unknown message type: ${message.type}`,\n      }));\n    }\n  }\n\n  private handleOperation(session: DocumentSession, client: ClientInfo, message: ClientMessage): void {\n    const error = validateOp(message.op);\n    if (error) {\n      client.ws.send(JSON.stringify({ type: 'error', message: error }));\n      return;\n    }\n\n    const op = message.op as Operation;\n    const clientVersion = typeof message.version === 'number' ? message.version : session.version;\n\n    // Get all operations that happened since the client's version\n    const opsToTransformAgainst = session.history.slice(clientVersion);\n\n    // Transform the incoming operation against all concurrent operations\n    const transformedOps = transformOpAgainstOps(op, opsToTransformAgainst);\n\n    // Apply all transformed operations\n    let newContent = session.content;\n    for (const transformedOp of transformedOps) {\n      // Skip no-op deletes\n      if (transformedOp.type === 'delete' && transformedOp.count <= 0) continue;\n      newContent = applyOps(newContent, [transformedOp]);\n    }\n\n    session.content = newContent;\n    session.version++;\n\n    // Store the first transformed op as the canonical operation for this version\n    const canonicalOp = transformedOps.length > 0 ? transformedOps[0] : op;\n    session.history.push(canonicalOp);\n\n    // Persist to database\n    this.store.addVersion(session.documentId, session.content, canonicalOp);\n    this.store.updateDocumentContent(session.documentId, session.content);\n\n    // Acknowledge to the sender\n    client.ws.send(JSON.stringify({\n      type: 'ack',\n      version: session.version,\n    }));\n\n    // Broadcast to other clients\n    for (const [cid, otherClient] of session.clients) {\n      if (cid === client.clientId) continue;\n      if (otherClient.ws.readyState === WebSocket.OPEN) {\n        otherClient.ws.send(JSON.stringify({\n          type: 'operation',\n          op: canonicalOp,\n          version: session.version,\n          clientId: client.clientId,\n        }));\n      }\n    }\n  }\n\n  closeAll(): void {\n    // Persist all active sessions\n    for (const [, session] of this.sessions) {\n      this.store.updateDocumentContent(session.documentId, session.content);\n      for (const [, client] of session.clients) {\n        client.ws.close();\n      }\n    }\n    this.sessions.clear();\n    if (this.wss) {\n      this.wss.close();\n      this.wss = null;\n    }\n  }\n}\n","structuredPatch":[{"oldStart":202,"oldLines":7,"newStart":202,"newLines":9,"lines":["   }"," ","   closeAll(): void {","-    // Persist all active sessions","+    this.closed = true;",