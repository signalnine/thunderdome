@@ -0,0 +1,59 @@
+import express from 'express';
+import { createServer, type Server as HttpServer } from 'http';
+import { createDatabase, DocumentStore } from './db.js';
+import { createRouter } from './routes.js';
+import { CollaborationManager } from './ws.js';
+
+export interface AppInstance {
+  app: express.Express;
+  start(port?: number): Promise<number>;
+  stop(): Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db = createDatabase(dbPath || ':memory:');
+  const store = new DocumentStore(db);
+  const collaborationManager = new CollaborationManager(store);
+
+  const app = express();
+  app.use('/api', createRouter(store));
+
+  let httpServer: HttpServer | null = null;
+
+  return {
+    app,
+
+    async start(port?: number): Promise<number> {
+      httpServer = createServer(app);
+      collaborationManager.attach(httpServer);
+
+      return new Promise<number>((resolve, reject) => {
+        httpServer!.on('error', reject);
+        httpServer!.listen(port ?? 0, () => {
+          const addr = httpServer!.address();
+          if (addr && typeof addr === 'object') {
+            resolve(addr.port);
+          } else {
+            resolve(0);
+          }
+        });
+      });
+    },
+
+    async stop(): Promise<void> {
+      collaborationManager.closeAll();
+
+      if (httpServer) {
+        await new Promise<void>((resolve, reject) => {
+          httpServer!.close((err) => {
+            if (err) reject(err);
+            else resolve();
+          });
+        });
+        httpServer = null;
+      }
+
+      store.close();
+    },
+  };
+}
