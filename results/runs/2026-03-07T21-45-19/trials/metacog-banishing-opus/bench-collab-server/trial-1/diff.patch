+function wsUrl(docId: string, clientId?: string): string {
+  let url = `ws://localhost:${port}/ws/documents/${docId}`;
+  if (clientId) url += `?clientId=${encodeURIComponent(clientId)}`;
+  return url;
+}
+
+function connectWs(docId: string, clientId?: string): Promise<{ ws: WebSocket; messages: unknown[] }> {
+  return new Promise((resolve, reject) => {
+    const ws = new WebSocket(wsUrl(docId, clientId));
+    const messages: unknown[] = [];
+
+    ws.on('message', (data) => {
+      messages.push(JSON.parse(data.toString()));
+    });
+
+    ws.on('open', () => {
+      resolve({ ws, messages });
+    });
+
+    ws.on('error', reject);
+  });
+}
+
+function waitForMessage(messages: unknown[], count: number, timeout = 5000): Promise<void> {
+  return new Promise((resolve, reject) => {
+    const start = Date.now();
+    const check = () => {
+      if (messages.length >= count) {
+        resolve();
+        return;
+      }
+      if (Date.now() - start > timeout) {
+        reject(new Error(`Timeout waiting for ${count} messages, got ${messages.length}: ${JSON.stringify(messages)}`));
+        return;
+      }
+      setTimeout(check, 20);
+    };
+    check();
+  });
+}
