diff --git a/src/index.ts b/src/index.ts
new file mode 100644
index 0000000..ad19ee7
--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,89 @@
+type Direction = 'down' | 'down-left' | 'down-right';
+
+const dRow: Record<Direction, number> = { down: 1, 'down-left': 1, 'down-right': 1 };
+const dCol: Record<Direction, number> = { down: 0, 'down-left': -1, 'down-right': 1 };
+
+function findSource(grid: string[][]): number {
+  for (let c = 0; c < grid[0].length; c++) {
+    if (grid[0][c] === 'S') {
+      return c;
+    }
+  }
+  return -1;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  const cols = grid[0].length;
+
+  const sourceCol = findSource(grid);
+  if (sourceCol === -1) return 0;
+
+  const visited = new Set<string>();
+  visited.add(`0,${sourceCol}`);
+
+  const processed = new Set<string>();
+  const queue: [number, number, Direction][] = [[0, sourceCol, 'down']];
+
+  while (queue.length > 0) {
+    const [row, col, dir] = queue.shift()!;
+
+    const state = `${row},${col},${dir}`;
+    if (processed.has(state)) continue;
+    processed.add(state);
+
+    const nextRow = row + dRow[dir];
+    const nextCol = col + dCol[dir];
+
+    if (nextRow < 0 || nextRow >= rows || nextCol < 0 || nextCol >= cols) {
+      continue;
+    }
+
+    visited.add(`${nextRow},${nextCol}`);
+
+    if (grid[nextRow][nextCol] === '^') {
+      queue.push([nextRow, nextCol, 'down-left']);
+      queue.push([nextRow, nextCol, 'down-right']);
+    } else {
+      queue.push([nextRow, nextCol, dir]);
+    }
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  const cols = grid[0].length;
+
+  const sourceCol = findSource(grid);
+  if (sourceCol === -1) return 0n;
+
+  const memo = new Map<string, bigint>();
+
+  function countPathsFrom(row: number, col: number, dir: Direction): bigint {
+    const key = `${row},${col},${dir}`;
+    const cached = memo.get(key);
+    if (cached !== undefined) return cached;
+
+    const nextRow = row + dRow[dir];
+    const nextCol = col + dCol[dir];
+
+    let result: bigint;
+
+    if (nextRow < 0 || nextRow >= rows || nextCol < 0 || nextCol >= cols) {
+      result = 1n;
+    } else if (grid[nextRow][nextCol] === '^') {
+      result =
+        countPathsFrom(nextRow, nextCol, 'down-left') +
+        countPathsFrom(nextRow, nextCol, 'down-right');
+    } else {
+      result = countPathsFrom(nextRow, nextCol, dir);
+    }
+
+    memo.set(key, result);
+    return result;
+  }
+
+  return countPathsFrom(0, sourceCol, 'down');
+}
