+import { ContentFile, BuildContext } from '../core/types.js';
+
+export function createSyntaxHighlightPlugin() {
+  const processCodeBlock = (codeBlock: string, originalLang: string): string => {
+    const match = codeBlock.match(/<pre><code\s+class="language-([^"]*)">([\s\S]*?)<\/code><\/pre>/i);
+
+    if (!match) {
+      return codeBlock;
+    }
+
+    const [, lang, codeContent] = match;
+    const hasLang = lang && lang !== 'text';
+
+    if (hasLang) {
+      return codeBlock.replace(
+        /<pre><code\s+class="language-([^"]*)">([\s\S]*?)<\/code><\/pre>/i,
+        `<pre data-language="${originalLang}"><code class="language-${lang} highlighted">${codeContent}</code></pre>`
+      );
+    }
+
+    return codeBlock;
+  };
+
+  return {
+    name: 'syntax-highlight',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: async (file: ContentFile, ctx: BuildContext) => {
+        let html = file.content;
+
+        html = html.replace(/<pre><code(?=[^<]*class="language-)(.*?)>[\s\S]*?<\/code><\/pre>/g, (match: string, lang: string) => {
+          return processCodeBlock(match, lang);
+        });
+
+        return file;
+      }
+    }
+  };
+}
