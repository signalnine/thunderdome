+import { ContentFile, BuildContext } from '../core/types.js';
+
+export function createSearchIndexPlugin() {
+  const stripHtml = (html: string): string => {
+    let text = html;
+    text = text.replace(/<[^>]*>/g, ' ');
+    text = text.replace(/&nbsp;/g, ' ');
+    text = text.replace(/&amp;/g, '&');
+    text = text.replace(/&lt;/g, '<');
+    text = text.replace(/&gt;/g, '>');
+    text = text.replace(/ & /g, ' ');
+    text = text.replace(/  +/g, ' ');
+    return text.trim();
+  };
+
+  return {
+    name: 'search-index',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'syntax-highlight'],
+    hooks: {
+      afterBuild: async (ctx: BuildContext) => {
+        const index = ctx.files.map((file: ContentFile) => {
+          const plainText = stripHtml(file.content);
+
+          return {
+            slug: file.slug,
+            title: file.title,
+            content: plainText,
+            tags: file.tags || []
+          };
+        });
+
+        ctx.output.set('search-index.json', JSON.stringify(index, null, 2));
+      }
+    }
+  };
+}
