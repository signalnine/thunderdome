+import { BuildContext } from '../core/types.js';
+
+export function createSitemapPlugin() {
+  return {
+    name: 'sitemap',
+    version: '1.0.0',
+    dependencies: ['taxonomy', 'rss-feed'],
+    hooks: {
+      afterBuild: async (ctx: BuildContext) => {
+        const baseUrl = ctx.config.baseUrl;
+        const siteUrl = `${baseUrl}/`;
+
+        const urls = new Set<string>();
+        urls.add(siteUrl);
+
+        ctx.output.forEach((_value: string, path: string) => {
+          if (path !== 'sitemap.xml') {
+            urls.add(`${baseUrl}/${path}`);
+          }
+        });
+
+        if (ctx.output.has('feed.xml')) {
+          urls.add(`${baseUrl}/feed.xml`);
+        }
+
+        const urlEntries = Array.from(urls)
+          .map(url => `  <url>
+    <loc>${url}</loc>
+    <lastmod>${new Date().toISOString().split('T')[0]}</lastmod>
+  </url>`)
+          .join('\n');
+
+        const sitemapXml = `<?xml version="1.0" encoding="UTF-8"?>
+<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
+        xmlns:xhtml="http://www.w3.org/1999/xhtml">
+${urlEntries}
+</urlset>`;
+
+        ctx.output.set('sitemap.xml', sitemapXml);
+      }
+    }
+  };
+}
