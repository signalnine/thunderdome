+import { ContentFile, BuildContext } from '../core/types.js';
+
+export function createTaxonomyPlugin() {
+  const generateTagPage = (tag: string, files: ContentFile[]): string => {
+    const escapedTag = tag.replace(/[^a-z0-9]/gi, '-');
+    return `<!DOCTYPE html>
+<html>
+<head>
+  <title>${tag} - Tags</title>
+  <meta charset="UTF-8" />
+  <link rel="stylesheet" href="/assets/style.css" />
+</head>
+<body>
+  <header>
+    <h1>$${tag}</h1>
+    <p>Posts tagged with <strong>${tag}</strong></p>
+  </header>
+  <main>
+    <div class="tags-list">
+${files.map(f => `      <article class="tag-item">
+        <h2><a href="/${f.slug}.html">${f.title}</a></h2>
+      </article>`).join('\n')}
+    </div>
+  </main>
+  <footer>
+    <a href="/tags.html">View all tags</a>
+  </footer>
+</body>
+</html>`;
+  };
+
+  return {
+    name: 'taxonomy',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      beforeBuild: async (ctx: BuildContext) => {
+        const tagMap = new Map<string, ContentFile[]>();
+
+        ctx.files.forEach(file => {
+          const tags = file.tags || [];
+          tags.forEach(tag => {
+            const normalizedTag = tag.toLowerCase();
+            if (!tagMap.has(normalizedTag)) {
+              tagMap.set(normalizedTag, []);
+            }
+            tagMap.get(normalizedTag)!.push(file);
+          });
+        });
+
+        ctx.data.set('taxonomy-tags', tagMap);
+      },
+      afterBuild: async (ctx: BuildContext) => {
+        const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]>;
+        if (!tagMap) return;
+
+        tagMap.forEach((files, tag) => {
+          const tagPageContent = generateTagPage(tag, files);
+          ctx.output.set(`tags/${tag}.html`, tagPageContent);
+        });
+      }
+    }
+  };
+}
