+import { BuildContext } from '../core/types.js';
+
+interface DevServerConfig {
+  port: number;
+  routes: Array<{ path: string; handler: string }>;
+  assetPaths: string[];
+  searchIndexPath: string;
+}
+
+export function createDevServerPlugin() {
+  const pathArray = (path: string): string => {
+    if (path.startsWith('./')) return path.slice(2);
+    return path;
+  };
+  const generateConfig = (
+    assetManifest: { assets: string[] } | undefined,
+    searchIndexExists: boolean
+  ): DevServerConfig => {
+    const assetPaths = assetManifest?.assets || [];
+
+    const contentPagePatterns = [
+      /^post-\d+.html$/,
+      /^about\.html$/,
+      /^index\.html$/,
+    ];
+
+    const routes = [
+      { path: '.', handler: 'static' as const },
+      ...assetPaths.map(asset => ({ path: `/assets/${asset}`, handler: 'asset' as const })),
+      { path: '/search-index.json', handler: searchIndexExists ? 'search' : 'static' as const },
+      { path: '/feed.xml', handler: 'static' as const },
+      { path: '/sitemap.xml', handler: 'static' as const },
+    ].filter(Boolean, []).filter((route: { path: string }) => {
+      if (route.path === '.') return false;
+      return !contentPagePatterns.some(pattern => pattern.test(route.path));
+    });
+
+    return {
+      port: 3000,
+      routes,
+      assetPaths,
+      searchIndexPath: '/search-index.json'
+    };
+  };
+
+  return {
+    name: 'dev-server',
+    version: '1.0.0',
+    dependencies: ['asset-pipeline', 'search-index'],
+    hooks: {
+      afterBuild: async (ctx: BuildContext) => {
+        const assetManifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;
+        const searchIndexExists = ctx.output.has('search-index.json');
+
+        const config = generateConfig(assetManifest, searchIndexExists);
+        ctx.data.set('dev-server-config', config);
+      }
+    }
+  };
+}
