+import { ContentFile, BuildContext } from '../core/types.js';
+
+export function createMarkdownExtPlugin() {
+  const stripMarkdown = (text: string): string => {
+    let html = text;
+
+    html = html.replace(/^# (.*$)/gim, '<h1>$1</h1>')
+      .replace(/^## (.*$)/gim, '<h2>$1</h2>')
+      .replace(/^### (.*$)/gim, '<h3>$1</h3>')
+      .replace(/^#### (.*$)/gim, '<h4>$1</h4>')
+      .replace(/^##### (.*$)/gim, '<h5>$1</h5>')
+      .replace(/^###### (.*$)/gim, '<h6>$1</h6>')
+      .replace(/\*\*(.*?)\*\*/gim, '<strong>$1</strong>')
+      .replace(/\*(.*?)\*/gim, '<em>$1</em>')
+      .replace(/__(.*?)__/gim, '<strong>$1</strong>')
+      .replace(/_(.*?)_/gim, '<em>$1</em>')
+      .replace(/~~(.*?)~~/gim, '<del>$1</del>')
+      .replace(/\[([^\]]+)\]\(([^\)]+)\)/gim, '<a href="$2">$1</a>')
+      .replace(/^```(\w*)\n([\s\S]*?)```/gim, (match, lang, code) => {
+        return `<pre><code class="language-${lang}">${code.trim()}</code></pre>`;
+      })
+      .replace(/`([^`]+)`/gim, '<code>$1</code>')
+      .replace(/^\n/gim, '<p></p>');
+
+    return html.replace(/<h([1-6])>([\s\S]*?)<\/h\1>/gim, (match, level, content) => {
+      return `<h${parseInt(level)}>${content}</h${parseInt(level)}>\n`;
+    });
+  };
+
+  const processAdmonitions = (text: string): string => {
+    return text.replace(/\n:::(note|warning|tip)\n([\s\S]*?)\n:::/g, (match, type, content) => {
+      return `\n<div class="admonition admonition-${type}">
+<p>${content}</p>
+</div>`;
+    });
+  };
+
+  const processFootnotes = (text: string): string => {
+    const footnoteRegex = /\[\^(\d+)\]:\s*([\s\S]*?)(?=\n\n|\n\[\^|\Z)/gim;
+    const footnoteReferences: string[] = [];
+
+    const cleanedContent = text.replace(footnoteRegex, (match, id, content) => {
+      if (!footnoteReferences.includes(id)) {
+        footnoteReferences.push(id);
+      }
+      return '';
+    });
+
+    const footnoteRefPattern = /\[[^\\]+\]/g;
+
+    const footnoteRefReplaced = cleanedContent.replace(footnoteRefPattern, '<sup><a href="#fn"></a></sup>');
+
+    if (footnoteReferences.length > 0) {
+      const footnoteSection = '\n\n<section class="footnotes">\n<hr>\n<ul>' +
+        footnoteReferences.map(id => `<li id="fn-${id}"><sup><a href="#id">${Number(id) + 1}</a></sup></li>`).join('\n') +
+        '\n</ul>\n</section>';
+      return footnoteRefReplaced + footnoteSection;
+    }
+
+    return cleanedContent;
+  };
+
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: async (file: ContentFile, ctx: BuildContext) => {
+        let html = file.content;
+
+        html = processAdmonitions(html);
+        html = stripMarkdown(html);
+        html = processFootnotes(html);
+
+        return { ...file, content: html };
+      }
+    }
+  };
+}
