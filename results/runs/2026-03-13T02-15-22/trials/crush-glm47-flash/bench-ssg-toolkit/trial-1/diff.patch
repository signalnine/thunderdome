+import { ContentFile, BuildContext } from '../core/types.js';
+
+export function createAssetPipelinePlugin() {
+  return {
+    name: 'asset-pipeline',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: async (file: ContentFile, ctx: BuildContext) => {
+        let html = file.content;
+        const assetExtensions = [
+          'png', 'jpg', 'jpeg', 'gif', 'webp', 'svg', 'zip'
+        ];
+
+        let manifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;
+        if (!manifest) {
+          manifest = { assets: [] };
+          ctx.data.set('asset-manifest', manifest);
+        }
+
+        assetExtensions.forEach(ext => {
+          const withDot = `\\.${ext}\\b`;
+          const withoutDot = ext + '\\b';
+
+          const srcRegex = new RegExp(`src=["'](${withDot}|${withoutDot})["']`, 'gi');
+          const hrefRegex = new RegExp(`href=[^>]*(["'](${withDot}|${withoutDot})["'])[^>]*>`, 'gi');
+          const linkRegex = new RegExp(`<link[^>]*href=["'](${withDot}|${withoutDot})["'][^>]*>`, 'gi');
+          const scriptRegex = new RegExp(`src=["'](${withDot}|${withoutDot})["']`, 'gi');
+
+          html = html.replace(srcRegex, (match: string, asset: string) => {
+            const cleanAsset = asset.replace(/^\./, '');
+            if (cleanAsset.startsWith('/') || ctx.assets.has('/' + cleanAsset)) return match;
+            if (!ctx.assets.has(`./${cleanAsset}`) && !ctx.assets.has(cleanAsset)) {
+              if (!manifest!.assets.includes(cleanAsset)) {
+                manifest!.assets.push(cleanAsset);
+              }
+              ctx.assets.set(cleanAsset, Buffer.from(''));
+            }
+            return match.replace(`src="${asset}"`, `src="/assets/${asset}"`);
+          });
+
+          html = html.replace(hrefRegex, (match: string, asset: string) => {
+            const cleanAsset = asset.replace(/^\./, '');
+            if (cleanAsset.startsWith('/') || ctx.assets.has('/' + cleanAsset)) return match;
+            if (!ctx.assets.has(`./${cleanAsset}`) && !ctx.assets.has(cleanAsset)) {
+              if (!manifest!.assets.includes(cleanAsset)) {
+                manifest!.assets.push(cleanAsset);
+              }
+              ctx.assets.set(cleanAsset, Buffer.from(''));
+            }
+            return match.replace(`href="${asset}"`, `href="/assets/${asset}"`);
+          });
+
+          html = html.replace(linkRegex, (match: string, asset: string) => {
+            const cleanAsset = asset.replace(/^\./, '');
+            if (cleanAsset.startsWith('/') || ctx.assets.has('/' + cleanAsset)) return match;
+            if (!ctx.assets.has(`./${cleanAsset}`) && !ctx.assets.has(cleanAsset)) {
+              if (!manifest!.assets.includes(cleanAsset)) {
+                manifest!.assets.push(cleanAsset);
+              }
+              ctx.assets.set(cleanAsset, Buffer.from(''));
+            }
+            return match.replace(`href="${asset}"`, `href="/assets/${asset}"`);
+          });
+
+          html = html.replace(scriptRegex, (match: string, asset: string) => {
+            const cleanAsset = asset.replace(/^\./, '');
+            if (cleanAsset.startsWith('/') || ctx.assets.has('/' + cleanAsset)) return match;
+            if (!ctx.assets.has(`./${cleanAsset}`) && !ctx.assets.has(cleanAsset)) {
+              if (!manifest!.assets.includes(cleanAsset)) {
+                manifest!.assets.push(cleanAsset);
+              }
+              ctx.assets.set(cleanAsset, Buffer.from(''));
+            }
+            return match.replace(`src="${asset}"`, `src="/assets/${asset}"`);
+          });
+        });
+
+        return { ...file, content: html };
+      }
+    }
+  };
+}
