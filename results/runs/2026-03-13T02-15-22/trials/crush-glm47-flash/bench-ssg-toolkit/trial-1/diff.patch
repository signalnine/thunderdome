+import { ContentFile, BuildContext } from '../core/types.js';
+
+export function createRssFeedPlugin() {
+  const generateFeedItem = (file: ContentFile, baseUrl: string, tagMap?: Map<string, ContentFile[]>): string => {
+    const slug = file.slug;
+    const link = `${baseUrl}/${slug}.html`;
+    const formattedDate = file.date || '';
+    const categories = tagMap?.get(slug) || [];
+
+    return `  <item>
+    <title>${file.title}</title>
+    <link>${link}</link>
+    <pubDate>${formattedDate ? new Date(formattedDate).toUTCString() : ''}</pubDate>
+    <guid isPermaLink="false">${link}</guid>
+${categories.map(cat => `    <category>${cat}</category>`).join('\n')}
+  </item>`;
+  };
+
+  return {
+    name: 'rss-feed',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'taxonomy'],
+    hooks: {
+      afterBuild: async (ctx: BuildContext) => {
+        const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]> | undefined;
+        const baseUrl = ctx.config.baseUrl;
+
+        const sortedFiles = [...ctx.files].sort((a, b) => {
+          const dateA = a.date ? new Date(a.date).getTime() : 0;
+          const dateB = b.date ? new Date(b.date).getTime() : 0;
+          return dateB - dateA;
+        });
+
+        const items = sortedFiles.map(file => generateFeedItem(file, baseUrl, tagMap)).join('\n');
+
+        const feedXml = `<?xml version="1.0" encoding="UTF-8"?>
+<rss version="2.0">
+  <channel>
+    <title>${ctx.config.title}</title>
+    <link>${baseUrl}</link>
+    <description>${ctx.config.title}</description>
+    <language>en</language>
+    <lastBuildDate>${new Date().toUTCString()}</lastBuildDate>
+${items}
+  </channel>
+</rss>`;
+
+        ctx.output.set('feed.xml', feedXml);
+      }
+    }
+  };
+}
