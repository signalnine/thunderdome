;\n\n    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    }\n\n    // Validate dependencies\n    const dependsOn = options.dependsOn ?? [];\n    for (const depId of dependsOn) {\n      const depTask = this.tasks.get(depId);\n      if (!depTask) {\n        throw new Error(`Dependency task not found: ${depId}`);\n      }\n    }\n\n    // Detect circular dependencies\n    if (dependsOn.length > 0) {\n      this.detectCircularDependencies(dependsOn);\n    }\n\n    const now = new Date();\n    let availableAt = now;\n    if (options.availableAt) {\n      availableAt = options.availableAt;\n    } else if (options.delay && options.delay > 0) {\n      availableAt = new Date(now.getTime() + options.delay);\n    }\n\n    const task: Task<T> = {\n      id: randomUUID(),\n      payload,\n      status: 'pending',\n      createdAt: now,\n      queue: queueName,\n      priority,\n      availableAt,\n      attempt: 0,\n      maxRetries: options.maxRetries ?? DEFAULT_MAX_RETRIES,\n      backoffDelay: options.backoffDelay ?? DEFAULT_BACKOFF_DELAY,\n      failCount: 0,\n      dependsOn: [...dependsOn],\n      progress: 0,\n      metadata: {},\n    };\n\n    this.tasks.set(task.id, task as Task);\n    this.ensureQueue(queueName);\n    this.queues.get(queueName)!.push(task.id);\n\n    return task;\n  }\n\n  // --- Phase 1 & 2: Get next task ---\n\n  getNextTask(queueName: string = DEFAULT_QUEUE): Task | null {\n    const queue = this.queues.get(queueName);\n    if (!queue) return null;\n\n    // Check concurrency limit\n    const limit = this.concurrencyLimits.get(queueName);\n    if (limit !== undefined) {\n      const activeCount = this.getActiveCount(queueName);\n      if (activeCount >= limit) return null;\n    }\n\n    const now = new Date();\n\n    // Find the best eligible task: highest priority (lowest number), then FIFO\n    let bestIndex = -1;\n    let bestTask: Task | null = null;\n\n    for (let i = 0; i < queue.length; i++) {\n      const task = this.tasks.get(queue[i]);\n      if (!task || task.status !== 'pending') continue;\n\n      // Skip tasks not yet available (delayed)\n      if (task.availableAt > now) continue;\n\n      // Skip tasks with unresolved dependencies\n      if (this.hasUnresolvedDependencies(task)) continue;\n\n      if (\n        bestTask === null ||\n        task.priority < bestTask.priority ||\n        (task.priority === bestTask.priority && task.availableAt < bestTask.availableAt)\n        // FIFO is naturally handled by iteration order for same priority and availableAt\n      ) {\n        bestIndex = i;\n        bestTask = task;\n      }\n    }\n\n    if (bestTask === null || bestIndex === -1) return null;\n\n    bestTask.status = 'processing';\n    bestTask.attempt += 1;\n\n    return bestTask;\n  }\n\n  // --- Phase 1: Waiting count ---\n\n  getWaitingCount(queueName: string = DEFAULT_QUEUE): number {\n    const queue = this.queues.get(queueName);\n    if (!queue) return 0;\n    return queue.filter(id => {\n      const task = this.tasks.get(id);\n      return task && task.status === 'pending';\n    }).length;\n  }\n\n  // --- Phase 2: List queues ---\n\n  getQueueNames(): string[] {\n    return Array.from(this.queues.keys());\n  }\n\n  // --- Phase 5: Complete and fail ---\n\n  completeTask(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${taskId} is not in processing state (current: ${task.status})`);\n    }\n\n    task.status = 'completed';\n    task.progress = 100;\n\n    // Check if any blocked tasks are now unblocked\n    // (handled lazily in getNextTask, no explicit action needed)\n  }\n\n  failTask(taskId: string, error?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${taskId} is not in processing state (current: ${task.status})`);\n    }\n\n    task.error = error;\n    task.failCount += 1;\n\n    if (task.attempt < task.maxRetries) {\n      // Re-queue with backoff delay\n      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);\n      task.status = 'pending';\n      task.availableAt = new Date(Date.now() + delay);\n      task.progress = 0;\n      task.progressMessage = undefined;\n    } else {\n      // Exhausted retries\n      task.status = 'failed';\n\n      // Move to DLQ\n      this.ensureDLQ(task.queue);\n      this.deadLetterQueues.get(task.queue)!.push(task.id);\n    }\n  }\n\n  // --- Phase 6: Dead Letter Queue ---\n\n  getDeadLetterTasks(queueName: string = DEFAULT_QUEUE): Task[] {\n    const dlq = this.deadLetterQueues.get(queueName);\n    if (!dlq) return [];\n    return dlq.map(id => this.tasks.get(id)!).filter(Boolean);\n  }\n\n  redriveTask(taskId: string): Task {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'failed') {\n      throw new Error(`Task ${taskId} is not in failed state`);\n    }\n\n    // Remove from DLQ\n    const dlq = this.deadLetterQueues.get(task.queue);\n    if (dlq) {\n      const idx = dlq.indexOf(taskId);\n      if (idx !== -1) dlq.splice(idx, 1);\n    }\n\n    // Reset for fresh retries\n    task.status = 'pending';\n    task.attempt = 0;\n    task.failCount = 0;\n    task.error = undefined;\n    task.availableAt = new Date();\n    task.progress = 0;\n    task.progressMessage = undefined;\n\n    // Re-add to queue\n    this.ensureQueue(task.queue);\n    this.queues.get(task.queue)!.push(task.id);\n\n    return task;\n  }\n\n  clearDeadLetterQueue(queueName: string = DEFAULT_QUEUE): void {\n    const dlq = this.deadLetterQueues.get(queueName);\n    if (dlq) {\n      for (const id of dlq) {\n        this.tasks.delete(id);\n