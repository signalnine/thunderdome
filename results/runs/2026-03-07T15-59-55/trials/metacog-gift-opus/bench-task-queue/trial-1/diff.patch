t('should support unsubscribe', () => {\n      tq.addTask('unsub-test');\n      const task = tq.getNextTask()!;\n\n      const updates: number[] = [];\n      const unsub = tq.onProgress(task.id, (p) => updates.push(p));\n\n      tq.reportProgress(task.id, 10);\n      unsub();\n      tq.reportProgress(task.id, 20);\n\n      expect(updates).toEqual([10]);\n    });\n\n    it('should cancel pending task', () => {\n      const task = tq.addTask('cancel-me');\n      tq.cancelTask(task.id);\n      expect(tq.getTask(task.id)!.status).toBe('cancelled');\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should cancel processing task', () => {\n      tq.addTask('cancel-processing');\n      const task = tq.getNextTask()!;\n      tq.cancelTask(task.id);\n      expect(tq.getTask(task.id)!.status).toBe('cancelled');\n    });\n\n    it('should not retry cancelled tasks', () => {\n      const task = tq.addTask('no-retry', { maxRetries: 3 });\n      const t = tq.getNextTask()!;\n      tq.cancelTask(t.id);\n      // Cancelled tasks stay cancelled\n      expect(tq.getTask(t.id)!.status).toBe('cancelled');\n    });\n\n    it('should reject invalid progress values', () => {\n      tq.addTask('invalid');\n      const task = tq.getNextTask()!;\n      expect(() => tq.reportProgress(task.id, -1)).toThrow();\n      expect(() => tq.reportProgress(task.id, 101)).toThrow();\n    });\n  });\n\n  // ==================== Phase 10: Recurring Tasks ====================\n  describe('Phase 10: Recurring Tasks', () => {\n    it('should create and list schedules', () => {\n      tq.addSchedule('sched1', '*/5 * * * *', 'default', { type: 'cleanup' });\n      const schedules = tq.getSchedules();\n      expect(schedules.length).toBe(1);\n      expect(schedules[0].id).toBe('sched1');\n    });\n\n    it('should remove schedules', () => {\n      tq.addSchedule('sched1', '*/5 * * * *', 'default', { type: 'cleanup' });\n      tq.removeSchedule('sched1');\n      expect(tq.getSchedules().length).toBe