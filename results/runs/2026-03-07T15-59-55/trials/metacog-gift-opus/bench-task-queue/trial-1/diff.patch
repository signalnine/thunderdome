+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_012CaQefsyWMeUH1NF9nbVyu","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_013FFLGz6mPh62cDN4joUt9C","name":"Write","input":{"file_path":"/workspace/src/TaskQueue.ts","content":"import { randomUUID } from 'node:crypto';\nimport type {\n  Task,\n  TaskOptions,\n  TaskStatus,\n  Schedule,\n  MiddlewareFn,\n  HandlerFn,\n  ProgressListener,\n  ShutdownResult,\n} from './types.js';\n\nconst DEFAULT_QUEUE = 'default';\nconst DEFAULT_PRIORITY = 5;\nconst DEFAULT_MAX_RETRIES = 3;\nconst DEFAULT_BACKOFF_DELAY = 1000;\n\nexport class TaskQueue {\n  // Core storage\n  private tasks = new Map<string, Task>();\n  private queues = new Map<string, string[]>(); // queueName -> taskIds in insertion order\n  private deadLetterQueues = new Map<string, string[]>(); // queueName -> taskIds\n\n  // Concurrency\n  private concurrencyLimits = new Map<string, number>(); // queueName -> max concurrency\n\n  // Progress listeners\n  private progressListeners = new Map<string, Set<ProgressListener>>(); // taskId -> listeners\n\n  // Recurring schedules\n  private schedules = new Map<string, Schedule>();\n\n  // Middleware & handlers\n  private middlewareStacks = new Map<string, MiddlewareFn[]>();\n  private handlers = new Map<string, HandlerFn>();\n\n  // Shutdown\n  private isShuttingDown = false;\n  private shutdownPromise: Promise<ShutdownResult> | null = null;\n  private shutdownCallbacks: (() => void | Promise<void>)[] = [];\n\n  // --- Phase 1 & 2: Add task to queue ---\n\n  addTask<T = unknown>(payload: T, options: TaskOptions = {}): Task<T> {\n    if (this.isShuttingDown) {\n      throw new Error('Cannot add tasks: system is shutting down');\n    }\n\n    const queueName = options.queue ?? DEFAULT_QUEUE;\n    const priority = options.priority ?? DEFAULT_PRIORITY;\n\n    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    }\n\n    // Validate dependencies\n    const dependsOn = options.dependsOn ?? [];\n    for (const depId of dependsOn) {\n      const depTask = this.tasks.get(depId);\n      if (!depTask) {\n        throw new Error(`Dependency task not found: ${depId}`);\n      }\n    }\n\n    // Detect circular dependencies\n    if (dependsOn.length > 0) {\n      this.detectCircularDependencies(dependsOn);\n    }\n\n    const now = new Date();\n    let availableAt = now;\n    if (options.availableAt) {\n      availableAt = options.availableAt;\n    } else if (options.delay && options.delay > 0) {\n      availableAt = new Date(now.getTime() + options.delay);\n    }\n\n    const task: Task<T> = {\n      id: randomUUID(),\n      payload,\n      status: 'pending',\n      createdAt: now,\n      queue: queueName,\n      priority,\n      availableAt,\n      attempt: 0,\n      maxRetries: options.maxRetries ?? DEFAULT_MAX_RETRIES,\n      backoffDelay: options.backoffDelay ?? DEFAULT_BACKOFF_DELAY,\n      failCount: 0,\n      dependsOn: [...dependsOn],\n      progress: 0,\n      metadata: {},\n    };\n\n    this.tasks.set(task.id, task as Task);\n    this.ensureQueue(queueName);\n    this.queues.get(queueName)!.push(task.id);\n\n    return task;\n  }\n\n  // --- Phase 1 & 2: Get next task ---\n\n  getNextTask(queueName: string = DEFAULT_QUEUE): Task | null {\n    const queue = this.queues.get(queueName);\n    if (!queue) return null;\n\n    // Check concurrency limit\n    const limit = this.concurrencyLimits.get(queueName);\n    if (limit !== undefined) {\n      const activeCount = this.getActiveCount(queueName);\n      if (activeCount >= limit) return null;\n    }\n\n    const now = new Date();\n\n    // Find the best eligible task: highest priority (lowest number), then FIFO\n    let bestIndex = -1;\n    let bestTask: Task | null = null;\n\n    for (let i = 0; i < queue.length; i++) {\n      const task = this.tasks.get(queue[i]);\n      if (!task || task.status !== 'pending') continue;\n\n      // Skip tasks not yet available (delayed)\n      if (task.availableAt > now) continue;\n\n      // Skip tasks with unresolved dependencies\n      if (this.hasUnresolvedDependencies(task)) continue;\n\n      if (\n        bestTask === null ||\n        task.priority < bestTask.priority ||\n        (task.priority === bestTask.priority && task.availableAt < bestTask.availableAt)\n        // FIFO is naturally handled by iteration order for same priority and availableAt\n      ) {\n        bestIndex = i;\n        bestTask = task;\n      }\n    }\n\n    if (bestTask === null || bestIndex === -1) return null;\n\n    bestTask.status = 'processing';\n    bestTask.attempt += 1;\n\n    return bestTask;\n  }\n\n  // --- Phase 1: Waiting count ---\n\n  getWaitingCount(queueName: string = DEFAULT_QUEUE): number {\n    const queue = this.queues.get(queueName);\n    if (!queue) return 0;\n    return queue.filter(id => {\n      const task = this.tasks.get(id);\n      return task && task.status === 'pending';\n    }).length;\n  }\n\n  // --- Phase 2: List queues ---\n\n  getQueueNames(): string[] {\n    return Array.from(this.queues.keys());\n  }\n\n  // --- Phase 5: Complete and fail ---\n\n  completeTask(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${taskId} is not in processing state (current: ${task.status})`);\n    }\n\n    task.status = 'completed';\n    task.progress = 100;\n\n    // Check if any blocked tasks are now unblocked\n    // (handled lazily in getNextTask, no explicit action needed)\n  }\n\n  failTask(taskId: string, error?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${taskId} is not in processing state (current: ${task.status})`);\n    }\n\n    task.error = error;\n    task.failCount += 1;\n\n    if (task.attempt < task.maxRetries) {\n      // Re-queue with backoff delay\n      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);\n      task.status = 'pending';\n      task.availableAt = new Date(Date.now() + delay);\n      task.progress = 0;\n      task.progressMessage = undefined;\n    } else {\n      // Exhausted retries\n      task.status = 'failed';\n\n      // Move to DLQ\n      this.ensureDLQ(task.queue);\n      this.deadLetterQueues.get(task.queue)!.push(task.id);\n    }\n  }\n\n  // --- Phase 6: Dead Letter Queue ---\n\n  getDeadLetterTasks(queueName: string = DEFAULT_QUEUE): Task[] {\n    const dlq = this.deadLetterQueues.get(queueName);\n    if (!dlq) return [];\n    return dlq.map(id => this.tasks.get(id)!).filter(Boolean);\n  }\n\n  redriveTask(taskId: string): Task {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'failed') {\n      throw new Error(`Task ${taskId} is not in failed state`);\n    }\n\n    // Remove from DLQ\n    const dlq = this.deadLetterQueues.get(task.queue);\n    if (dlq) {\n      const idx = dlq.indexOf(taskId);\n      if (idx !== -1) dlq.splice(idx, 1);\n    }\n\n    // Reset for fresh retries\n    task.status = 'pending';\n    task.attempt = 0;\n    task.failCount = 0;\n    task.error = undefined;\n    task.availableAt = new Date();\n    task.progress = 0;\n    task.progressMessage = undefined;\n\n    // Re-add to queue\n    this.ensureQueue(task.queue);\n    this.queues.get(task.queue)!.push(task.id);\n\n    return task;\n  }\n\n  clearDeadLetterQueue(queueName: string = DEFAULT_QUEUE): void {\n    const dlq = this.deadLetterQueues.get(queueName);\n    if (dlq) {\n      for (const id of dlq) {\n        this.tasks.delete(id);\n      }\n      dlq.length = 0;\n    }\n  }\n\n  // --- Phase 7: Task Dependencies ---\n\n  getTaskDependencyStatus(taskId: string): { dependsOn: string[]; resolved: string[]; pending: string[] } {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    const resolved: string[] = [];\n    const pending: string[] = [];\n\n    for (const depId of task.dependsOn) {\n      const dep = this.tasks.get(depId);\n      if (dep && dep.status === 'completed') {\n        resolved.push(depId);\n      } else {\n        pending.push(depId);\n      }\n    }\n\n    return { dependsOn: [...task.dependsOn], resolved, pending };\n  }\n\n  // --- Phase 8: Concurrency Control ---\n\n  setConcurrency(queueName: string, limit: number): void {\n    this.concurrencyLimits.set(queueName, limit);\n  }\n\n  getConcurrency(queueName: string): number | undefined {\n    return this.concurrencyLimits.get(queueName);\n  }\n\n  getActiveCount(queueName: string = DEFAULT_QUEUE): number {\n    const queue = this.queues.get(queueName);\n    if (!queue) return 0;\n    return queue.filter(id => {\n      const task = this.tasks.get(id);\n      return task && task.status === 'processing';\n    }).length;\n  }\n\n  // --- Phase 9: Progress Tracking ---\n\n  reportProgress(taskId: string, progress: number, message?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${taskId} is not in processing state`);\n    }\n    if (progress < 0 || progress > 100) {\n      throw new Error(`Progress must be between 0 and 100`);\n    }\n\n    task.progress = progress;\n    task.progressMessage = message;\n\n    const listeners = this.progressListeners.get(taskId);\n    if (listeners) {\n      for (const listener of listeners) {\n        listener(progress, message);\n      }\n    }\n  }\n\n  getProgress(taskId: string): { progress: number; message?: string } {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    return { progress: task.progress, message: task.progressMessage };\n  }\n\n  onProgress(taskId: string, listener: ProgressListener): () => void {\n    if (!this.progressListeners.has(taskId)) {\n      this.progressListeners.set(taskId, new Set());\n    }\n    this.progressListeners.get(taskId)!.add(listener);\n\n    // Return unsubscribe function\n    return () => {\n      const listeners = this.progressListeners.get(taskId);\n      if (listeners) {\n        listeners.delete(listener);\n        if (listeners.size === 0) {\n          this.progressListeners.delete(taskId);\n        }\n      }\n    };\n  }\n\n  // --- Phase 9: Cancellation ---\n\n  cancelTask(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    if (task.status !== 'pending' && task.status !== 'processing') {\n      throw new Error(`Cannot cancel task in ${task.status} state`);\n    }\n\n    task.status = 'cancelled';\n    task.progress = 0;\n    task.progressMessage = undefined;\n  }\n\n  // --- Phase 10: Recurring Tasks ---\n\n  addSchedule(\n    id: string,\n    cron: string,\n    queue: string,\n    payload: unknown,\n    taskOptions?: Omit<TaskOptions, 'queue'>,\n  ): Schedule {\n    if (this.isShuttingDown) {\n      throw new Error('Cannot add schedules: system is shutting down');\n    }\n\n    // Validate cron expression\n    this.parseCron(cron);\n\n    const schedule: Schedule = {\n      id,\n      cron,\n      queue,\n      payload,\n      taskOptions,\n    };\n\n    this.schedules.set(id, schedule);\n    return schedule;\n  }\n\n  removeSchedule(id: string): void {\n    this.schedules.delete(id);\n  }\n\n  getSchedules(): Schedule[] {\n    return Array.from(this.schedules.values());\n  }\n\n  tick(now: Date = new Date()): Task[] {\n    const created: Task[] = [];\n\n    for (const schedule of this.schedules.values()) {\n      if (this.isScheduleDue(schedule, now)) {\n        const task = this.addTask(schedule.payload, {\n          ...schedule.taskOptions,\n          queue: schedule.queue,\n        });\n        created.push(task);\n        schedule.lastRun = now;\n      }\n    }\n\n    return created;\n  }\n\n  // --- Phase 11: Middleware ---\n\n  use(queueName: string, middleware: MiddlewareFn): void {\n    if (!this.middlewareStacks.has(queueName)) {\n      this.middlewareStacks.set(queueName, []);\n    }\n    this.middlewareStacks.get(queueName)!.push(middleware);\n  }\n\n  setHandler(queueName: string, handler: HandlerFn): void {\n    this.handlers.set(queueName, handler);\n  }\n\n  async processNext(queueName: string = DEFAULT_QUEUE): Promise<Task | null> {\n    const task = this.getNextTask(queueName);\n    if (!task) return null;\n\n    const middlewares = this.middlewareStacks.get(queueName) ?? [];\n    const handler = this.handlers.get(queueName);\n\n    try {\n      await this.runMiddlewarePipeline(task, middlewares, handler);\n      if (task.status === 'processing') {\n        this.completeTask(task.id);\n      }\n    } catch (err) {\n      if (task.status === 'processing') {\n        this.failTask(task.id, err instanceof Error ? err.message : String(err));\n      }\n    }\n\n    return task;\n  }\n\n  // --- Phase 12: Graceful Shutdown ---\n\n  onShutdown(callback: () => void | Promise<void>): void {\n    this.shutdownCallbacks.push(callback);\n  }\n\n  async shutdown(timeout: number = 30000): Promise<ShutdownResult> {\n    if (this.shutdownPromise) {\n      return this.shutdownPromise;\n    }\n\n    this.isShuttingDown = true;\n    this.shutdownPromise = this.performShutdown(timeout);\n    return this.shutdownPromise;\n  }\n\n  // --- Task lookup ---\n\n  getTask(taskId: string): Task | null {\n    return this.tasks.get(taskId) ?? null;\n  }\n\n  // --- Private helpers ---\n\n  private ensureQueue(name: string): void {\n    if (!this.queues.has(name)) {\n      this.queues.set(name, []);\n    }\n  }\n\n  private ensureDLQ(name: string): void {\n    if (!this.deadLetterQueues.has(name)) {\n      this.deadLetterQueues.set(name, []);\n    }\n  }\n\n  private hasUnresolvedDependencies(task: Task): boolean {\n    if (task.dependsOn.length === 0) return false;\n    for (const depId of task.dependsOn) {\n      const dep = this.tasks.get(depId);\n      if (!dep || dep.status !== 'completed') {\n        return true;\n      }\n    }\n    return false;\n  }\n\n  private detectCircularDependencies(dependsOn: string[]): void {\n    // BFS/DFS to check if any dependency chain circles back\n    const visited = new Set<string>();\n    const stack = [...dependsOn];\n\n    while (stack.length > 0) {\n      const current = stack.pop()!;\n      if (visited.has(current)) continue;\n      visited.add(current);\n\n      const task = this.tasks.get(current);\n      if (task) {\n        for (const depId of task.dependsOn) {\n          // If a dependency of a dependency points to something already visited\n          // or to a task that depends on tasks being created, that's a cycle\n          stack.push(depId);\n        }\n      }\n    }\n    // Note: For circular detection, we check if the new task's dependencies\n    // would form a cycle. Since the new task doesn't exist yet, cycles\n    // only form if a dependency (or transitive dependency) already depends\n    // on something that would depend on the new task. Since the new task\n    // has no ID yet, direct circular detection is about the dependency\n    // chain among existing tasks - which was validated when those were created.\n    // True circular detection is relevant when a task ID is known in advance.\n  }\n\n  private parseCron(cron: string): { minute: string; hour: string; dayOfMonth: string; month: string; dayOfWeek: string } {\n    const parts = cron.trim().split(/\\s+/);\n    if (parts.length !== 5) {\n      throw new Error(`Invalid cron expression: ${cron}. Expected 5 fields.`);\n    }\n    return {\n      minute: parts[0],\n      hour: parts[1],\n      dayOfMonth: parts[