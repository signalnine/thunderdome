eval', () => {\n      tq.addTask('task');\n      const task = tq.getNextTask();\n      expect(task!.status).toBe('processing');\n    });\n\n    it('should return null when no tasks available', () => {\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should track waiting count', () => {\n      expect(tq.getWaitingCount()).toBe(0);\n      tq.addTask('a');\n      tq.addTask('b');\n      expect(tq.getWaitingCount()).toBe(2);\n      tq.getNextTask();\n      expect(tq.getWaitingCount()).toBe(1);\n    });\n  });\n\n  // ==================== Phase 2: Named Queues ====================\n  describe('Phase 2: Named Queues', () => {\n    it('should default to \"default\" queue', () => {\n      const task = tq.addTask('test');\n      expect(task.queue).toBe('default');\n    });\n\n    it('should support named queues', () => {\n      tq.addTask('email', { queue: 'emails' });\n      tq.addTask('sms', { queue: 'sms' });\n\n      const email = tq.getNextTask('emails');\n      const sms = tq.getNextTask('sms');\n\n      expect(email!.payload).toBe('email');\n      expect(sms!.payload).toBe('sms');\n    });\n\n    it('should operate queues independently', () => {\n      tq.addTask('a', { queue: 'q1' });\n      tq.addTask('b', { queue: 'q2' });\n\n      expect(tq.getWaitingCount('q1')).toBe(1);\n      expect(tq.getWaitingCount('q2')).toBe(1);\n\n      tq.getNextTask('q1');\n      expect(tq.getWaitingCount('q1')).toBe(0);\n      expect(tq.getWaitingCount('q2')).toBe(1);\n    });\n\n    it('should list all queue names', () => {\n      tq.addTask('a', { queue: 'alpha' });\n      tq.addTask('b', { queue: 'beta' });\n      const names = tq.getQueueNames();\n      expect(names).toContain('alpha');\n      expect(names).toContain('beta');\n    });\n\n    it('should return null for non-existent queue', () => {\n      expect(tq.getNextTask('nonexistent')).toBeNull();\n    });\n\n    it('should be backward compatible (no queue name = default)', () => {\n      tq.addTask('test');\n      const task = tq.getNextTask();\n      expect(task!.payload).toBe('test');\n    });\n  });\n\n  // ==================== Phase 3: Priority ====================\n  describe('Phase 3: Priority', () => {\n    it('should default priority to 5', () => {\n      const task = tq.addTask('test');\n      expect(task.priority).toBe(5);\n    });\n\n    it('should return higher-priority tasks first', () => {\n      tq.addTask('low', { priority: 10 });\n      tq.addTask('high', { priority: 1 });\n      tq.addTask('medium', { priority: 5 });\n\n      expect(tq.getNextTask()!.payload).toBe('high');\n      expect(tq.getNextTask()!.payload).toBe('medium');\n      expect(tq.getNextTask()!.payload).toBe('low');\n    });\n\n    it('should respect FIFO within same priority', () => {\n      tq.addTask('first', { priority: 3 });\n      tq.addTask('second', { priority: 3 });\n      tq.addTask('third', { priority: 3 });\n\n      expect(tq.getNextTask()!.payload).toBe('first');\n      expect(tq.getNextTask()!.payload).toBe('second');\n      expect(tq.getNextTask()!.payload).toBe('third');\n    });\n\n    it('should reject invalid priorities', () => {\n      expect(() => tq.addTask('x', { priority: 0 })).toThrow();\n      expect(() => tq.addTask('x', { priority: 11 })).toThrow();\n      expect(() => tq.addTask('x', { priority: 1.5 })).toThrow();\n    });\n\n    it('should maintain priority per queue', () => {\n      tq.addTask('q1-low', { queue: 'q1', priority: 10 });\n      tq.addTask('q1-high', { queue: 'q1', priority: 1 });\n      tq.addTask('q2-low', { queue: 'q2', priority: 10 });\n\n      expect(tq.getNextTask('q1')!.payload).toBe('q1-high');\n      expect(tq.getNextTask('q2')!.payload).toBe('q2-low');\n    });\n  });\n\n  // ==================== Phase 4: Delayed Tasks ====================\n  describe('Phase 4: Delayed Tasks', () => {\n    it('should not return delayed tasks before their availability time', () => {\n      tq.addTask('delayed', { delay: 60000 }); // 60 seconds\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should return non-delayed tasks over not-yet-available delayed tasks', () => {\n      tq.addTask('delayed', { delay: 60000 });\n      tq.addTask('immediate');\n\n      const task = tq.getNextTask();\n      expect(task!.payload).toBe('immediate');\n    });\n\n    it('should set availableAt based on delay', () => {\n      const before = Date.now();\n      const task = tq.addTask('delayed', { delay: 5000 });\n      expect(task.availableAt.getTime()).toBeGreaterThanOrEqual(before + 5000);\n    });\n\n    it('should accept a specific availableAt date', () => {\n      const future = new Date(Date.now() + 10000);\n      const task = tq.addTask('scheduled', { availableAt: future });\n      expect(task.availableAt).toBe(future);\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should return delayed task once available', () => {\n      const past = new Date(Date.now() - 1000);\n      tq.addTask('was-delayed', { availableAt: past });\n      const task = tq.getNextTask();\n      expect(task!.payload).toBe('was-delayed');\n    });\n\n    it('should order by availability time when multiple delayed tasks are ready', () => {\n      const early = new Date(Date.now() - 2000);\n      const later = new Date(Date.now() - 1000);\n      tq.addTask('later', { availableAt: later });\n      tq.addTask('earlier', { availableAt: early });\n\n      expect(tq.getNextTask()!.payload).toBe('earlier');\n      expect(tq.getNextTask()!.payload).toBe('later');\n    });\n  });\n\n  // ==================== Phase 5: Retry with Backoff ====================\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should complete a task', () => {\n      tq.addTask('test');\n      const task = tq.getNextTask()!;\n      tq.completeTask(task.id);\n      expect(tq.getTask(task.id)!.status).toBe('completed');\n    });\n\n    it('should fail a task and re-queue with backoff', () => {\n      tq.addTask('retry-me', { maxRetries: 3, backoffDelay: 100 });\n      const t = tq.getNextTask()!;\n      expect(t.attempt).toBe(1);\n\n      tq.failTask(t.id, 'error1');\n      expect(tq.getTask(t.id)!.status).toBe('pending');\n      expect(tq.getTask(t.id)!.failCount).toBe(1);\n      // Backoff delay applied: 100 * 2^0 = 100ms\n      expect(tq.getTask(t.id)!.availableAt.getTime()).toBeGreaterThan(Date.now() - 1000);\n    });\n\n    it('should track attempt count', () => {\n      const task = tq.addTask('retry-me', { maxRetries: 3, backoffDelay: 0 });\n\n      // Attempt 1\n      let t = tq.getNextTask()!;\n      expect(t.attempt).toBe(1);\n      tq.failTask(t.id, 'err');\n\n      // Need to make available immediately for test\n      tq.getTask(t.id)!.availableAt = new Date(Date.now() - 1);\n\n      // Attempt 2\n      t = tq.getNextTask()!;\n      expect(t.attempt).toBe(2);\n    });\n\n    it('should permanently fail after retries exhausted', () => {\n      const task = tq.addTask('fail-me', { maxRetries: 1, backoffDelay: 0 });\n\n      const t = tq.getNextTask()!;\n      tq.failTask(t.id, 'err');\n      // maxRetries = 1, attempt was 1, so it's done\n      expect(tq.getTask(t.id)!.status).toBe('failed');\n    });\n\n    it('should use exponential backoff delays', () => {\n      const task = tq.addTask('backoff', { maxRetries: 4, backoffDelay: 1000 });\n\n      // Attempt 1\n      let t = tq.getNextTask()!;\n      const beforeFail = Date.now();\n      tq.failTask(t.id, 'err');\n      // backoff = 1000 * 2^0 = 1000\n      expect(tq.getTask(t.id)!.availableAt.getTime()).toBeGreaterThanOrEqual(beforeFail + 900);\n\n      // Make available for attempt 2\n      tq.getTask(t.id)!.availableAt = new Date(Date.now() - 1);\n      t = tq.getNextTask()!;\n      const beforeFail2 = Date.now();\n      tq.failTask(t.id, 'err');\n      // backoff = 1000 * 2^1 = 2000\n      expect(tq.getTask(t.id)!.availableAt.getTime()).toBeGreaterThanOrEqual(beforeFail2 + 1900);\n    });\n\n    it('should retain queue and priority on retry', () => {\n      const task = tq.addTask('retry', { queue: 'myqueue', priority: 2, maxRetries: 3, backoffDelay: 0 });\n\n      const t = tq.getNextTask('myqueue')!;\n      tq.failTask(t.id, 'err');\n\n      expect(tq.getTask(t.id)!.queue).toBe('myqueue');\n      expect(tq.getTask(t.id)!.priority).toBe(2);\n    });\n\n    it('should default maxRetries to 3', () => {\n      const task = tq.addTask('test');\n      expect(task.maxRetries).toBe(3);\n    });\n\n    it('should default backoffDelay to 1000', () => {\n      const task = tq.addTask('test');\n      expect(task.backoffDelay).toBe(1000);\n    });\n  });\n\n  // ==================== Phase 6: Dead Letter Queue ====================\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move permanently failed tasks to DLQ', () => {\n      const task = tq.addTask('dlq-me', { maxRetries: 1, backoffDelay: 0 });\n      const t = tq.getNextTask()!;\n      tq.failTask(t.id, 'permanent error');\n\n      const dlqTasks = tq.getDeadLetterTasks();\n      expect(dlqTasks.length).toBe(1);\n      expect(dlqTasks[0].id).toBe(task.id);\n      expect(dlqTasks[0].error).toBe('permanent error');\n    });\n\n    it('should retain error info and fail count', () => {\n      const task = tq.addTask('dlq-me', { maxRetries: 1, backoffDelay: 0 });\n      const t = tq.getNextTask()!;\n      tq.failTask(t.id, 'error msg');\n\n      const dlqTasks = tq.getDeadLetterTasks();\n      expect(dlqTasks[0].error).toBe('error msg');\n      expect(dlqTasks[0].failCount).toBe(1);\n    });\n\n    it('should redrive dead-lettered task', () => {\n      const task = tq.addTask('redrive-me', { maxRetries: 1, backoffDelay: 0 });\n      const t = tq.getNextTask()!;\n      tq.failTask(t.id, 'err');\n\n      expect(tq.getDeadLetterTasks().length).toBe(1);\n\n      const redriven = tq.redriveTask(t.id);\n      expect(redriven.status).toBe('pending');\n      expect(redriven.attempt).toBe(0);\n      expect(redriven.failCount).toBe(0);\n      expect(tq.getDeadLetterTasks().length).toBe(0);\n    });\n\n    it('should clear DLQ for a queue', () => {\n      tq.addTask('dlq1', { maxRetries: 1, backoffDelay: 0 });\n      tq.addTask('dlq2', { maxRetries: 1, backoffDelay: 0 });\n\n      let t = tq.getNextTask()!;\n      tq.failTask(t.id, 'err');\n      t = tq.getNextTask()!;\n      tq.failTask(t.id, 'err');\n\n      expect(tq.getDeadLetterTasks().length).toBe(2);\n\n      tq.clearDeadLetterQueue();\n      expect(tq.getDeadLetterTasks().length).toBe(0);\n    });\n\n    it('should have independent DLQs per queue', () => {\n      tq.addTask('a', { queue: 'q1', maxRetries: 1, backoffDelay: 0 });\n      tq.addTask('b', { queue: 'q2', maxRetries: 1, backoffDelay: 0 });\n\n      let t = tq.getNextTask('q1')!;\n      tq.failTask(t.id, 'err');\n      t = tq.getNextTask('q2')!;\n      tq.failTask(t.id, 'err');\n\n      expect(tq.getDeadLetterTasks('q1').length).toBe(1);\n      expect(tq.getDeadLetterTasks('q2').length).toBe(1);\n    });\n  });\n\n  // ==================== Phase 7: Task Dependencies ====================\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block tasks with unresolved dependencies', () => {\n      const dep = tq.addTask('dependency');\n      const dependent = tq.addTask('dependent', { dependsOn: [dep.id] });\n\n      const next = tq.getNextTask()!;\n      expect(next.id).toBe(dep.id); // dependency comes first\n      expect(tq.getNextTask()).toBeNull(); // dependent is blocked\n    });\n\n    it('should unblock tasks when dependencies complete', () => {\n      const dep = tq.addTask('dependency');\n      const dependent = tq.addTask('dependent', { dependsOn: [dep.id] });\n\n      const next = tq.getNextTask()!;\n      tq.completeTask(next.id);\n\n      const unblocked = tq.getNextTask()!;\n      expect(unblocked.id).toBe(dependent.id);\n    });\n\n    it('should reject dependencies on non-existent tasks', () => {\n      expect(() => tq.addTask('x', { dependsOn: ['nonexistent'] })).toThrow();\n    });\n\n    it('should inspect dependency status', () => {\n      const dep1 = tq.addTask('dep1');\n      const dep2 = tq.addTask('dep2');\n      const dependent = tq.addTask('dependent', { dependsOn: [dep1.id, dep2.id] });\n\n      let status = tq.getTaskDependencyStatus(dependent.id);\n      expect(status.dependsOn).toEqual([dep1.id, dep2.id]);\n      expect(status.resolved).toEqual([]);\n      expect(status.pending).toEqual([dep1.id, dep2.id]);\n\n      // Complete dep1\n      const t = tq.getNextTask()!;\n      tq.completeTask(t.id);\n\n      status = tq.getTaskDependencyStatus(dependent.id);\n      expect(status.resolved).toEqual([dep1.id]);\n      expect(status.pending).toEqual([dep2.id]);\n    });\n\n    it('should keep dependents blocked when dependency fails', () => {\n      const dep = tq.addTask('dep', { maxRetries: 1, backoffDelay: 0 });\n      const dependent = tq.addTask('dependent', { dependsOn: [dep.id] });\n\n      const t = tq.getNextTask()!;\n      tq.failTask(t.id, 'err');\n      // Dependency failed, dependent remains blocked (not automatically failed)\n      expect(tq.getNextTask()).toBeNull();\n    });\n  });\n\n  // ==================== Phase 8: Concurrency Control ====================\n  describe('Phase 8: Concurrency Control', () => {\n    it('should limit concurrent processing', () => {\n      tq.setConcurrency('default', 1);\n      tq.addTask('a');\n      tq.addTask('b');\n\n      const t1 = tq.getNextTask();\n      expect(t1).not.toBeNull();\n\n      const t2 = tq.getNextTask();\n      expect(t2).toBeNull(); // concurrency limit reached\n    });\n\n    it('should free slot when task completes', () => {\n      tq.setConcurrency('default', 1);\n      tq.addTask('a');\n      tq.addTask('b');\n\n      const t1 = tq.getNextTask()!;\n      tq.completeTask(t1.id);\n\n      const t2 = tq.getNextTask();\n      expect(t2).not.toBeNull();\n    });\n\n    it('should free slot when task fails', () => {\n      tq.setConcurrency('default', 1);\n      tq.addTask('a', { maxRetries: 1, backoffDelay: 0 });\n      tq.addTask('b');\n\n      const t1 = tq.getNextTask()!;\n      tq.failTask(t1.id, 'err'); // permanently fails, frees slot\n\n      const t2 = tq.getNextTask();\n      expect(t2).not.toBeNull();\n      expect(t2!.payload).toBe('b');\n    });\n\n    it('should default to unlimited concurrency', () => {\n      expect(tq.getConcurrency('default')).toBeUndefined();\n    });\n\n    it('should query active count', () => {\n      tq.addTask('a');\n      tq.addTask('b');\n\n      expect(tq.getActiveCount()).toBe(0);\n      tq.getNextTask();\n      expect(tq.getActiveCount()).toBe(1);\n      tq.getNextTask();\n      expect(tq.getActiveCount()).toBe(2);\n    });\n\n    it('should respect priority with concurrency', () => {\n      tq.setConcurrency('default', 1);\n      tq.addTask('low', { priority: 10 });\n      tq.addTask('high', { priority: 1 });\n\n      const t = tq.getNextTask()!;\n      expect(t.payload).toBe('high');\n    });\n  });\n\n  // ==================== Phase 9: Progress and Cancellation ====================\n  describe('Phase 9: Progress and Cancellation', () => {\n    it('should report and query progress', () => {\n      tq.addTask('progress-test');\n      const task = tq.getNextTask()!;\n\n      tq.reportProgress(task.id, 50, 'halfway');\n      const progress = tq.getProgress(task.id);\n      expect(progress.progress).toBe(50);\n      expect(progress.message).toBe('halfway');\n    });\n\n    it('should notify progress listeners', () => {\n      tq.addTask('listen-test');\n      const task = tq.getNextTask()!;\n\n      const updates: { progress: number; message?: string }[] = [];\n      tq.onProgress(task.id, (p, m) => updates.push({ progress: p, message: m }));\n\n      tq.reportProgress(task.id, 25, 'quarter');\n      tq.reportProgress(task.id, 75, 'three-quarter');\n\n      expect(updates).toEqual([\n        { progress: 25, message: 'quarter' },\n        { progress: 75, message: 'three-quarter' },\n      ]);\n    });\n\n    it('should support unsubscribe', () => {\n      tq.addTask('unsub-test');\n      const task = tq.getNextTask()!;\n\n      const updates: number[] = [];\n      const unsub = tq.onProgress(task.id, (p) => updates.push(p));\n\n      tq.reportProgress(task.id, 10);\n      unsub();\n      tq.reportProgress(task.id, 20);\n\n      expect(updates).toEqual([10]);\n    });\n\n    it('should cancel pending task', () => {\n      const task = tq.addTask('cancel-me');\n      tq.cancelTask(task.id);\n      expect(tq.getTask(task.id)!.status).toBe('cancelled');\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should cancel processing task', () => {\n      tq.addTask('cancel-processing');\n      const task = tq.getNextTask()!;\n      tq.cancelTask(task.id);\n      expect(tq.getTask(task.id)!.status).toBe('cancelled');\n    });\n\n    it('should not retry cancelled tasks', () => {\n      const task = tq.addTask('no-retry', { maxRetries: 3 });\n      const t = tq.getNextTask()!;\n      tq.cancelTask(t.id);\n      // Cancelled tasks stay cancelled\n      expect(tq.getTask(t.id)!.status).toBe('cancelled');\n    });\n\n    it('should reject invalid progress values', () => {\n      tq.addTask('invalid');\n      const task = tq.getNextTask()!;\n      expect(() => tq.reportProgress(task.id, -1)).toThrow();\n      expect(() => tq.reportProgress(task.id, 101)).toThrow();\n    });\n  });\n\n  // ==================== Phase 10: Recurring Tasks ====================\n  describe('Phase 10: Recurring Tasks', () => {\n    it('should create and list schedules', () => {\n      tq.addSchedule('sched1', '*/5 * * * *', 'default', { type: 'cleanup' });\n      const schedules = tq.getSchedules();\n      expect(schedules.length).toBe(1);\n      expect(schedules[0].id).toBe('sched1');\n    });\n\n    it('should remove schedules', () => {\n      tq.addSchedule('sched1', '*/5 * * * *', 'default', { type: 'cleanup' });\n      tq.removeSchedule('sched1');\n      expect(