   });\n   526→\n   527→    it('should not retry cancelled tasks', () => {\n   528→      const task = tq.addTask('no-retry', { maxRetries: 3 });\n   529→      const t = tq.getNextTask()!;\n   530→      tq.cancelTask(t.id);\n   531→      // Cancelled tasks stay cancelled\n   532→      expect(tq.getTask(t.id)!.status).toBe('cancelled');\n   533→    });\n   534→\n   535→    it('should reject invalid progress values', () => {\n   536→      tq.addTask('invalid');\n   537→      const task = tq.getNextTask()!;\n   538→      expect(() => tq.reportProgress(task.id, -1)).toThrow();\n   539→      expect(() => tq.reportProgress(task.id, 101)).toThrow();\n   540→    });\n   541→  });\n   542→\n   543→  // ==================== Phase 10: Recurring Tasks ====================\n   544→  describe('Phase 10: Recurring Tasks', () => {\n   545→    it('should create and list schedules', () => {\n   546→      tq.addSchedule('sched1', '*/5 * * * *', 'default', { type: 'cleanup' });\n   547→      const schedules = tq.getSchedules();\n   548→      expect(schedules.length).toBe(1);\n   549→      expect(schedules[0].id).toBe('sched1');\n   550→    });\n   551→\n   552→    it('should remove schedules', () => {\n   553→      tq.addSchedule('sched1', '*/5 * * * *', 'default', { type: 'cleanup' });\n   554→      tq.removeSchedule('sched1');\n   555→      expect(tq.getSchedules().length).toBe(0);\n   556→    });\n   557→\n   558→    it('should enqueue tasks on tick when due', () => {\n   559→      tq.addSchedule('every5', '*/5 * * * *', 'default', { type: 'periodic' });\n   560→\n   561→      // tick at a time that's divisible by 5\n   562→      const dueTime = new Date(2024, 0, 1, 12, 0, 0); // 12:00\n   563→      const tasks = tq.tick(dueTime);\n   564→      expect(tasks.length).toBe(1);\n   565→      expect(tasks[0].payload).toEqual({ type: 'periodic' });\n   566→    });\n   567→\n   568→    it('should not enqueue if not due', () => {\n   569→      tq.addSchedule('hourly', '0 * * * *', 'default',