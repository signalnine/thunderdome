--- /dev/null
+++ b/src/tracker.ts
@@ -0,0 +1,120 @@
+import * as fs from "node:fs";
+import * as path from "node:path";
+
+export interface TimeEntry {
+  task: string;
+  start: string;
+  stop: string | null;
+}
+
+interface StorageData {
+  entries: TimeEntry[];
+}
+
+export interface TimeSummary {
+  [task: string]: number;
+}
+
+export interface GetEntriesOptions {
+  from?: Date;
+  to?: Date;
+}
+
+export class TimeTracker {
+  private filePath: string;
+  private entries: TimeEntry[];
+
+  constructor(filePath: string) {
+    this.filePath = path.resolve(filePath);
+    this.entries = this.load();
+  }
+
+  private load(): TimeEntry[] {
+    try {
+      const data = fs.readFileSync(this.filePath, "utf-8");
+      const parsed: StorageData = JSON.parse(data);
+      return parsed.entries;
+    } catch {
+      return [];
+    }
+  }
+
+  private save(): void {
+    const dir = path.dirname(this.filePath);
+    fs.mkdirSync(dir, { recursive: true });
+    const data: StorageData = { entries: this.entries };
+    fs.writeFileSync(this.filePath, JSON.stringify(data, null, 2), "utf-8");
+  }
+
+  private getRunningEntry(): TimeEntry | undefined {
+    return this.entries.find((e) => e.stop === null);
+  }
+
+  start(task: string): void {
+    if (!task || task.trim().length === 0) {
+      throw new Error("Task name cannot be empty");
+    }
+
+    const running = this.getRunningEntry();
+    if (running) {
+      running.stop = new Date().toISOString();
+    }
+
+    this.entries.push({
+      task,
+      start: new Date().toISOString(),
+      stop: null,
+    });
+
+    this.save();
+  }
+
+  stop(): TimeEntry {
+    const running = this.getRunningEntry();
+    if (!running) {
+      throw new Error("No timer is currently running");
+    }
+
+    running.stop = new Date().toISOString();
+    this.save();
+    return { ...running };
+  }
+
+  getEntries(options?: GetEntriesOptions): TimeEntry[] {
+    if (!options || (!options.from && !options.to)) {
+      return this.entries.map((e) => ({ ...e }));
+    }
+
+    return this.entries
+      .filter((entry) => {
+        const entryStart = new Date(entry.start);
+        if (options.from && entryStart < options.from) {
+          return false;
+        }
+        if (options.to && entryStart > options.to) {
+          return false;
+        }
+        return true;
+      })
+      .map((e) => ({ ...e }));
+  }
+
+  getSummary(): TimeSummary {
+    const summary: TimeSummary = {};
+
+    for (const entry of this.entries) {
+      const start = new Date(entry.start).getTime();
+      const end = entry.stop
+        ? new Date(entry.stop).getTime()
+        : Date.now();
+      const duration = end - start;
+
+      if (summary[entry.task] === undefined) {
+        summary[entry.task] = 0;
+      }
+      summary[entry.task] += duration;
+    }
+
+    return summary;
+  }
+}
