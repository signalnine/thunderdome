+import { describe, it, expect, beforeEach, afterEach } from "vitest";
+import * as fs from "node:fs";
+import * as path from "node:path";
+import * as os from "node:os";
+import { TimeTracker } from "../src/index.js";
+
+function tmpFile(): string {
+  const dir = fs.mkdtempSync(path.join(os.tmpdir(), "time-tracker-"));
+  return path.join(dir, "data.json");
+}
+
+function cleanup(filePath: string): void {
+  try {
+    fs.rmSync(path.dirname(filePath), { recursive: true, force: true });
+  } catch {
+    // ignore
+  }
+}
+
+describe("TimeTracker", () => {
+  let filePath: string;
+
+  beforeEach(() => {
+    filePath = tmpFile();
+  });
+
+  afterEach(() => {
+    cleanup(filePath);
+  });
+
+  describe("start", () => {
+    it("should start a timer", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("coding");
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].task).toBe("coding");
+      expect(entries[0].start).toBeTruthy();
+      expect(entries[0].stop).toBeNull();
+    });
+
+    it("should throw on empty task name", () => {
+      const tracker = new TimeTracker(filePath);
+      expect(() => tracker.start("")).toThrow("Task name cannot be empty");
+    });
+
+    it("should throw on whitespace-only task name", () => {
+      const tracker = new TimeTracker(filePath);
+      expect(() => tracker.start("   ")).toThrow("Task name cannot be empty");
+    });
+
+    it("should auto-stop the previous timer when starting a new one", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("task1");
+      tracker.start("task2");
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(2);
+      expect(entries[0].stop).not.toBeNull();
+      expect(entries[1].stop).toBeNull();
+    });
+  });
+
+  describe("stop", () => {
+    it("should stop a running timer", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("coding");
+      const stopped = tracker.stop();
+      expect(stopped.task).toBe("coding");
+      expect(stopped.stop).not.toBeNull();
+    });
+
+    it("should throw when no timer is running", () => {
+      const tracker = new TimeTracker(filePath);
+      expect(() => tracker.stop()).toThrow("No timer is currently running");
+    });
+
+    it("should throw when stopping after already stopped", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("coding");
+      tracker.stop();
+      expect(() => tracker.stop()).toThrow("No timer is currently running");
+    });
+  });
+
+  describe("persistence", () => {
+    it("should persist entries across instances", () => {
+      const tracker1 = new TimeTracker(filePath);
+      tracker1.start("task1");
+      tracker1.stop();
+
+      const tracker2 = new TimeTracker(filePath);
+      const entries = tracker2.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].task).toBe("task1");
+    });
+
+    it("should create parent directories if they don't exist", () => {
+      const deepPath = path.join(
+        os.tmpdir(),
+        "time-tracker-deep",
+        "a",
+        "b",
+        "c",
+        "data.json"
+      );
+      try {
+        const tracker = new TimeTracker(deepPath);
+        tracker.start("deep-task");
+        tracker.stop();
+        expect(fs.existsSync(deepPath)).toBe(true);
+      } finally {
+        fs.rmSync(path.join(os.tmpdir(), "time-tracker-deep"), {
+          recursive: true,
+          force: true,
+        });
+      }
+    });
+
+    it("should handle missing file gracefully", () => {
+      const tracker = new TimeTracker(filePath);
+      expect(tracker.getEntries()).toEqual([]);
+    });
+  });
+
+  describe("getEntries", () => {
+    it("should return all entries when no filter is given", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("task1");
+      tracker.stop();
+      tracker.start("task2");
+      tracker.stop();
+      expect(tracker.getEntries()).toHaveLength(2);
+    });
+
+    it("should filter entries by date range", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("task1");
+      tracker.stop();
+
+      const from = new Date();
+
+      tracker.start("task2");
+      tracker.stop();
+
+      const to = new Date();
+
+      const filtered = tracker.getEntries({ from, to });
+      expect(filtered).toHaveLength(1);
+      expect(filtered[0].task).toBe("task2");
+    });
+
+    it("should return copies of entries (not references)", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("task1");
+      tracker.stop();
+      const entries = tracker.getEntries();
+      entries[0].task = "modified";
+      expect(tracker.getEntries()[0].task).toBe("task1");
+    });
+  });
+
+  describe("getSummary", () => {
+    it("should summarize time per task", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("coding");
+      tracker.stop();
+      tracker.start("meeting");
+      tracker.stop();
+
+      const summary = tracker.getSummary();
+      expect(summary["coding"]).toBeGreaterThanOrEqual(0);
+      expect(summary["meeting"]).toBeGreaterThanOrEqual(0);
+    });
+
+    it("should sum multiple entries with the same task name", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("coding");
+      tracker.stop();
+      tracker.start("coding");
+      tracker.stop();
+
+      const summary = tracker.getSummary();
+      expect(summary["coding"]).toBeGreaterThanOrEqual(0);
+    });
+
+    it("should use current time for running tasks", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("running-task");
+
+      const summary = tracker.getSummary();
+      expect(summary["running-task"]).toBeGreaterThanOrEqual(0);
+    });
+  });
+
+  describe("unicode support", () => {
+    it("should handle unicode task names", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("编程");
+      tracker.stop();
+      const entries = tracker.getEntries();
+      expect(entries[0].task).toBe("编程");
+    });
+
+    it("should handle emoji task names", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("🚀 Launch");
+      tracker.stop();
+      const entries = tracker.getEntries();
+      expect(entries[0].task).toBe("🚀 Launch");
+
+      const summary = tracker.getSummary();
+      expect(summary["🚀 Launch"]).toBeGreaterThanOrEqual(0);
+    });
+
+    it("should persist unicode names correctly", () => {
+      const tracker1 = new TimeTracker(filePath);
+      tracker1.start("コーディング 💻");
+      tracker1.stop();
+
+      const tracker2 = new TimeTracker(filePath);
+      const entries = tracker2.getEntries();
+      expect(entries[0].task).toBe("コーディング 💻");
+    });
   });
