 419→\n   420→      // Check prerequisites are met\n   421→      if (!presInSet.every((p) => assigned.has(p))) continue;\n   422→\n   423→      // Try to find a room where we can fit by removing one event\n   424→      const eligible = eligibleRooms.get(unschedId)!;\n   425→      for (const room of eligible) {\n   426→        const intervals = roomIntervals.get(room.id)!;\n   427→        const minStart = earliestStart(unschedId);\n   428→\n   429→        // Try removing each interval in this room to make space\n   430→        for (let i = 0; i < intervals.length; i++) {\n   431→          const victim = intervals[i];\n   432→          // Find which event this interval belongs to\n   433→          const victimEventId = currentAssignments.find(\n   434→            (a) =>\n   435→              a.roomId === room.id &&\n   436→              a.startTime === victim.start &&\n   437→              a.endTime === victim.end,\n   438→          )?.eventId;\n   439→          if (!victimEventId) continue;\n   440→\n   441→          // Don't remove a prerequisite of the event we're trying to place\n   442→          if (presInSet.includes(victimEventId)) continue;\n   443→\n   444→          // Check if victim has dependents that are scheduled\n   445→          const victimDeps = dependents.get(victimEventId) ?? [];\n   446→          const hasScheduledDep = victimDeps.some((d) => assigned.has(d));\n   447→          if (hasScheduledDep) continue;\n   448→\n   449→          // Try: remove victim, place unscheduled, then re-place victim\n   450→          removeInterval(room.id, victim.start, victim.end);\n   451→          assigned.delete(victimEventId);\n   452→\n   453→          const slot = findSlot(room.id, unschedEvent.duration, minStart);\n   454→          if (slot !== null) {\n   455→            const endTime = slot + unschedEvent.duration;\n   456→            insertInterval(room.id, slot, endTime);\n   457→            assigned.set(unschedId, { roomId: room.id, startTime: slot, end