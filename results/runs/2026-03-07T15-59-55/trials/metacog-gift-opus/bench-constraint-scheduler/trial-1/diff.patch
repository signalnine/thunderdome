new file mode 100644
index 0000000..9275b42
--- /dev/null
+++ b/src/index.test.ts
@@ -0,0 +1,170 @@
+import { describe, it, expect } from 'vitest';
+import { schedule, Event, Room, ScheduleOptions } from './index.js';
+
+describe('schedule', () => {
+  const rooms: Room[] = [
+    { id: 'r1', name: 'Room 1', capacity: 50 },
+    { id: 'r2', name: 'Room 2', capacity: 30 },
+  ];
+
+  const options: ScheduleOptions = {
+    startTime: 540,  // 9:00
+    endTime: 1020,   // 17:00
+    gap: 15,
+  };
+
+  it('schedules a single event', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60 },
+    ];
+    const result = schedule(events, rooms, options);
+    expect(result.assignments).toHaveLength(1);
+    expect(result.unscheduled).toHaveLength(0);
+    expect(result.assignments[0].eventId).toBe('e1');
+    expect(result.assignments[0].startTime).toBe(540);
+    expect(result.assignments[0].endTime).toBe(600);
+  });
+
+  it('respects room capacity', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Big Event', duration: 60, attendees: 40 },
+    ];
+    const result = schedule(events, rooms, options);
+    expect(result.assignments).toHaveLength(1);
+    // Should be in r1 (capacity 50), not r2 (capacity 30)
+    expect(result.assignments[0].roomId).toBe('r1');
+  });
+
+  it('marks events as unscheduled when capacity too large', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Huge Event', duration: 60, attendees: 100 },
+    ];
+    const result = schedule(events, rooms, options);
+    expect(result.assignments).toHaveLength(0);
+    expect(result.unscheduled).toEqual(['e1']);
+  });
+
+  it('respects time window', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Long Event', duration: 600 }, // 10 hours, window is 8 hours
+    ];
+    const result = schedule(events, rooms, options);
+    expect(result.assignments).toHaveLength(0);
+    expect(result.unscheduled).toEqual(['e1']);
+  });
+
+  it('respects gaps between events in same room', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60 },
+      { id: 'e2', name: 'Event 2', duration: 60 },
+    ];
+    const smallRooms: Room[] = [{ id: 'r1', name: 'Room 1', capacity: 50 }];
+    const result = schedule(events, smallRooms, options);
+    expect(result.assignments).toHaveLength(2);
+    // Both in same room, gap between them
+    const a1 = result.assignments.find(a => a.eventId === 'e1')!;
+    const a2 = result.assignments.find(a => a.eventId === 'e2')!;
+    expect(a1.roomId).toBe('r1');
+    expect(a2.roomId).toBe('r1');
+    const [earlier, later] = a1.startTime < a2.startTime ? [a1, a2] : [a2, a1];
+    expect(later.startTime - earlier.endTime).toBeGreaterThanOrEqual(15);
+  });
+
+  it('respects prerequisites', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60 },
+      { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },
+    ];
+    const result = schedule(events, rooms, options);
+    expect(result.assignments).toHaveLength(2);
+    const a1 = result.assignments.find(a => a.eventId === 'e1')!;
+    const a2 = result.assignments.find(a => a.eventId === 'e2')!;
+    expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + 15);
+  });
+
+  it('throws on prerequisite cycles', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['e2'] },
+      { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },
+    ];
+    expect(() => schedule(events, rooms, options)).toThrow(/[Cc]ycle/);
+  });
+
+  it('throws on self-referencing prerequisite', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['e1'] },
+    ];
+    expect(() => schedule(events, rooms, options)).toThrow(/[Cc]ycle/);
+  });
+
+  it('honors preferred room when possible', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60, preferredRoom: 'r2' },
+    ];
+    const result = schedule(events, rooms, options);
+    expect(result.assignments).toHaveLength(1);
+    expect(result.assignments[0].roomId).toBe('r2');
+  });
+
+  it('uses default gap of 15 when not specified', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60 },
+      { id: 'e2', name: 'Event 2', duration: 60 },
+    ];
+    const smallRooms: Room[] = [{ id: 'r1', name: 'Room 1', capacity: 50 }];
+    const noGapOptions: ScheduleOptions = { startTime: 540, endTime: 1020 };
+    const result = schedule(events, smallRooms, noGapOptions);
+    expect(result.assignments).toHaveLength(2);
+    const a1 = result.assignments.find(a => a.eventId === 'e1')!;
+    const a2 = result.assignments.find(a => a.eventId === 'e2')!;
+    const [earlier, later] = a1.startTime < a2.startTime ? [a1, a2] : [a2, a1];
+    expect(later.startTime - earlier.endTime).toBeGreaterThanOrEqual(15);
+  });
+
+  it('handles empty events list', () => {
+    const result = schedule([], rooms, options);
+    expect(result.assignments).toHaveLength(0);
+    expect(result.unscheduled).toHaveLength(0);
+  });
+
+  it('schedules multiple events across multiple rooms', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60 },
+      { id: 'e2', name: 'Event 2', duration: 60 },
+      { id: 'e3', name: 'Event 3', duration: 60 },
+    ];
+    const result = schedule(events, rooms, options);
+    expect(result.assignments).toHaveLength(3);
+    expect(result.unscheduled).toHaveLength(0);
+  });
+
+  it('maximizes scheduled events when some cannot fit', () => {
+    // 4 events, each 120 minutes, gap=15. Window is 480 minutes (8 hours).
+    // Each room can fit: floor(480 / (120 + 15)) = 3 events (with last one
+    // not needing gap: 3*120 + 2*15 = 390 < 480, 4*120 + 3*15 = 525 > 480)
+    // So 1 room fits 3 events. With 1 room and 4 events, max 3.
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 120 },
+      { id: 'e2', name: 'Event 2', duration: 120 },
+      { id: 'e3', name: 'Event 3', duration: 120 },
+      { id: 'e4', name: 'Event 4', duration: 120 },
+    ];
+    const singleRoom: Room[] = [{ id: 'r1', name: 'Room 1', capacity: 50 }];
+    const result = schedule(events, singleRoom, options);
+    expect(result.assignments).toHaveLength(3);
+    expect(result.unscheduled).toHaveLength(1);
+  });
+
+  it('handles prerequisite gap constraint', () => {
+    // B requires A to finish. Gap also applies between prerequisite events.
+    const events: Event[] = [
+      { id: 'A', name: 'Event A', duration: 60 },
+      { id: 'B', name: 'Event B', duration: 60, prerequisites: ['A'] },
+    ];
+    const result = schedule(events, rooms, { startTime: 540, endTime: 1020, gap: 30 });
+    expect(result.assignments).toHaveLength(2);
+    const aAssignment = result.assignments.find(a => a.eventId === 'A')!;
+    const bAssignment = result.assignments.find(a => a.eventId === 'B')!;
+    expect(bAssignment.startTime).toBeGreaterThanOrEqual(aAssignment.endTime + 30);
+  });
+});
