+// ── Interfaces ──────────────────────────────────────────────
+
+export interface Event {
+  id: string;
+  name: string;
+  duration: number;
+  attendees?: number;
+  prerequisites?: string[];
+  preferredRoom?: string;
+}
+
+export interface Room {
+  id: string;
+  name: string;
+  capacity: number;
+}
+
+export interface ScheduleOptions {
+  startTime: number;
+  endTime: number;
+  gap?: number;
+}
+
+export interface Assignment {
+  eventId: string;
+  roomId: string;
+  startTime: number;
+  endTime: number;
+}
+
+export interface ScheduleResult {
+  assignments: Assignment[];
+  unscheduled: string[];
+}
+
+// ── Cycle detection (topological sort) ──────────────────────
+
+function topologicalSort(events: Event[]): string[] {
+  const ids = new Set(events.map((e) => e.id));
+  const adj = new Map<string, string[]>();
+  const inDeg = new Map<string, number>();
+
+  for (const e of events) {
+    adj.set(e.id, []);
+    inDeg.set(e.id, 0);
+  }
+
+  for (const e of events) {
+    if (!e.prerequisites) continue;
+    for (const pre of e.prerequisites) {
+      // Self-reference is a cycle
+      if (pre === e.id) {
+        throw new Error(
+          `Cycle detected: event "${e.id}" has a self-referencing prerequisite`,
+        );
+      }
+      // Only wire up edges for prerequisites that are in the event set
+      if (ids.has(pre)) {
+        adj.get(pre)!.push(e.id);
+        inDeg.set(e.id, (inDeg.get(e.id) ?? 0) + 1);
+      }
+    }
+  }
+
+  const queue: string[] = [];
+  for (const [id, deg] of inDeg) {
+    if (deg === 0) queue.push(id);
+  }
+
+  const sorted: string[] = [];
+  while (queue.length > 0) {
+    const node = queue.shift()!;
+    sorted.push(node);
+    for (const neighbor of adj.get(node) ?? []) {
+      const newDeg = inDeg.get(neighbor)! - 1;
+      inDeg.set(neighbor, newDeg);
+      if (newDeg === 0) queue.push(neighbor);
+    }
+  }
+
+  if (sorted.length !== ids.size) {
+    throw new Error('Cycle detected in prerequisite graph');
+  }
+
+  return sorted;
+}
+
+// ── Scheduler ───────────────────────────────────────────────
+
+export function schedule(
+  events: Event[],
+  rooms: Room[],
+  options: ScheduleOptions,
+): ScheduleResult {
+  const gap = options.gap ?? 15;
+
+  // Validate & detect cycles (throws on cycle)
+  topologicalSort(events);
+
+  const eventMap = new Map<string, Event>();
+  for (const e of events) {
+    eventMap.set(e.id, e);
+  }
+
+  // Build adjacency: for each event, which events depend on it
+  const dependents = new Map<string, string[]>();
+  const prerequisites = new Map<string, string[]>();
+  for (const e of events) {
+    dependents.set(e.id, []);
+    prerequisites.set(e.id, []);
+  }
+  for (const e of events) {
+    if (!e.prerequisites) continue;
+    for (const pre of e.prerequisites) {
+      if (eventMap.has(pre)) {
+        dependents.get(pre)!.push(e.id);
+        prerequisites.get(e.id)!.push(pre);
+      }
+    }
+  }
+
+  // Eligible rooms for each event (capacity check)
+  const eligibleRooms = new Map<string, Room[]>();
+  for (const e of events) {
+    const att = e.attendees ?? 1;
+    const eligible = rooms.filter((r) => r.capacity >= att);
+    eligibleRooms.set(e.id, eligible);
+  }
+
+  // Sort rooms by capacity ascending (prefer tighter fits)
+  for (const [, roomList] of eligibleRooms) {
+    roomList.sort((a, b) => a.capacity - b.capacity);
+  }
+
+  // ── Backtracking solver ───────────────────────────────────
+  // We try to maximize the number of scheduled events.
+  // Strategy: order events by most constrained first (fewest eligible rooms,
+  // then longest duration, then most prerequisites), then use backtracking
+  // with pruning.
+
+  // For each room, track scheduled intervals as sorted list
+  type Interval = { start: number; end: number };
+  const roomIntervals = new Map<string, Interval[]>();
+  for (const r of rooms) {
+    roomIntervals.set(r.id, []);
+  }
+
+  // Track assignment per event
+  const assigned = new Map<
+    string,
+    { roomId: string; startTime: number; endTime: number }
+  >();
+
+  // Compute earliest possible start for an event given prerequisites
+  function earliestStart(eventId: string): number {
+    let earliest = options.startTime;
+    const pres = prerequisites.get(eventId) ?? [];
+    for (const pre of pres) {
+      const a = assigned.get(pre);
+      if (a) {
+        earliest = Math.max(earliest, a.endTime + gap);
+      }
+    }
+    return earliest;
+  }
+
+  // Find earliest available slot in a room for an event, starting from minStart.
+  // Gap rule: end of one event + gap <= start of next event in the same room.
+  function findSlot(
+    roomId: string,
+    duration: number,
+    minStart: number,
+  ): number | null {
+    const intervals = roomIntervals.get(roomId)!;
+    let candidate = minStart;
+
+    for (const interval of intervals) {
+      // Does the event fit before this existing interval (with gap)?
+      if (candidate + duration + gap <= interval.start) {
+        break; // Yes, there's room before this interval
+      }
+      // No — push candidate to after this interval + gap
+      candidate = Math.max(candidate, interval.end + gap);
+    }
+
+    if (candidate + duration > options.endTime) {
+      return null;
+    }
+    return candidate;
+  }
+
+  // Insert interval into sorted list
+  function insertInterval(roomId: string, start: number, end: number): void {
+    const intervals = roomIntervals.get(roomId)!;
+    let i = 0;
+    while (i < intervals.length && intervals[i].start < start) i++;
+    intervals.splice(i, 0, { start, end });
+  }
+
+  // Remove interval from list
+  function removeInterval(roomId: string, start: number, end: number): void {
+    const intervals = roomIntervals.get(roomId)!;
+    const idx = intervals.findIndex(
+      (iv) => iv.start === start && iv.end === end,
+    );
+    if (idx >= 0) intervals.splice(idx, 1);
+  }
+
+  // Try to place an event, returning all valid (room, startTime) options
+  function getPlacementOptions(
+    eventId: string,
+  ): Array<{ roomId: string; startTime: number }> {
+    const event = eventMap.get(eventId)!;
+    const eligible = eligibleRooms.get(eventId)!;
+    const minStart = earliestStart(eventId);
+    const opts: Array<{ roomId: string; startTime: number; preferred: boolean }> = [];
+
+    for (const room of eligible) {
+      const slot = findSlot(room.id, event.duration, minStart);
+      if (slot !== null) {
+        opts.push({
+          roomId: room.id,
+          startTime: slot,
+          preferred: event.preferredRoom === room.id,
+        });
+      }
+    }
+
+    // Prefer: preferred room first, then earliest start, then smallest room
+    opts.sort((a, b) => {
+      if (a.preferred !== b.preferred) return a.preferred ? -1 : 1;
+      if (a.startTime !== b.startTime) return a.startTime - b.startTime;
+      return 0;
+    });
+
+    return opts;
+  }
+
+  // Order events for scheduling: topological order, then by constraint level
+  // We use a priority-based approach: schedule events with fewer options first
+  // but respect topological ordering (prerequisites before dependents)
+
+  // Compute topological levels
+  const topoOrder = topologicalSort(events);
+  const topoIndex = new Map<string, number>();
+  for (let i = 0; i < topoOrder.length; i++) {
+    topoIndex.set(topoOrder[i], i);
+  }
+
+  // Sort events: topological order first, then by number of eligible rooms (ascending),
+  // then by duration (descending - longer events harder to place)
+  const sortedEvents = [...events].sort((a, b) => {
+    const ai = topoIndex.get(a.id)!;
+    const bi = topoIndex.get(b.id)!;
+    if (ai !== bi) return ai - bi;
+    const aRooms = eligibleRooms.get(a.id)!.length;
+    const bRooms = eligibleRooms.get(b.id)!.length;
+    if (aRooms !== bRooms) return aRooms - bRooms;
+    return b.duration - a.duration;
+  });
+
+  // Greedy placement with look-ahead
+  // For each event, try to place it. If placing it would prevent a dependent
+  // from being placed, try alternative placements.
+
+  // We use an iterative approach with multiple passes to maximize placement.
+  // First pass: greedy with preferred rooms.
+  // If events remain unscheduled, try again with different ordering strategies.
+
+  function greedySchedule(
+    eventOrder: Event[],
+  ): { assignments: Assignment[]; unscheduled: string[] } {
+    // Reset state
+    for (const r of rooms) {
+      roomIntervals.set(r.id, []);
+    }
+    assigned.clear();
+
+    const result: Assignment[] = [];
+    const unscheduled: string[] = [];
+
+    // Track which events are ready (all prerequisites assigned)
+    const remaining = new Set(eventOrder.map((e) => e.id));
+    const scheduled = new Set<string>();
+
+    // Process in waves: each wave schedules events whose prerequisites are met
+    let progress = true;
+    while (remaining.size > 0 && progress) {
+      progress = false;
+      for (const event of eventOrder) {
+        if (!remaining.has(event.id)) continue;
+
+        // Check if all prerequisites are scheduled
+        const pres = prerequisites.get(event.id) ?? [];
+        const presInSet = pres.filter((p) => eventMap.has(p));
+        if (!presInSet.every((p) => scheduled.has(p))) continue;
+
+        // Try to place this event
+        const options = getPlacementOptions(event.id);
+        if (options.length > 0) {
+          const best = options[0];
+          const endTime = best.startTime + event.duration;
+          assigned.set(event.id, {
+            roomId: best.roomId,
+            startTime: best.startTime,
+            endTime,
+          });
+          insertInterval(best.roomId, best.startTime, endTime);
+          result.push({
+            eventId: event.id,
+            roomId: best.roomId,
+            startTime: best.startTime,
+            endTime,
+          });
+          scheduled.add(event.id);
+          remaining.delete(event.id);
+          progress = true;
+        }
+      }
+    }
+
+    // Anything left is unscheduled
+    for (const id of remaining) {
+      unscheduled.push(id);
+    }
+
+    return { assignments: result, unscheduled };
+  }
+
+  // Build multiple orderings and pick the one that maximizes scheduled events
+  const orderings: Event[][] = [];
+
+  // Ordering 1: topological + most constrained first
+  orderings.push(sortedEvents);
+
+  // Ordering 2: topological + shortest duration first (maximizes count)
+  orderings.push(
+    [...events].sort((a, b) => {
+      const ai = topoIndex.get(a.id)!;
+      const bi = topoIndex.get(b.id)!;
+      if (ai !== bi) return ai - bi;
+      return a.duration - b.duration;
+    }),
+  );
+
+  // Ordering 3: topological + longest duration first (place hardest first)
+  orderings.push(
+    [...events].sort((a, b) => {
+      const ai = topoIndex.get(a.id)!;
+      const bi = topoIndex.get(b.id)!;
+      if (ai !== bi) return ai - bi;
+      return b.duration - a.duration;
+    }),
+  );
+
+  // Ordering 4: topological + most attendees first (hardest capacity)
+  orderings.push(
+    [...events].sort((a, b) => {
+      const ai = topoIndex.get(a.id)!;
+      const bi = topoIndex.get(b.id)!;
+      if (ai !== bi) return ai - bi;
+      return (b.attendees ?? 1) - (a.attendees ?? 1);
+    }),
+  );
+
+  // Ordering 5: topological + fewest eligible rooms first, then shortest
+  orderings.push(
+    [...events].sort((a, b) => {
+      const ai = topoIndex.get(a.id)!;
+      const bi = topoIndex.get(b.id)!;
+      if (ai !== bi) return ai - bi;
+      const aRooms = eligibleRooms.get(a.id)!.length;
+      const bRooms = eligibleRooms.get(b.id)!.length;
+      if (aRooms !== bRooms) return aRooms - bRooms;
+      return a.duration - b.duration;
+    }),
+  );
+
+  let best: { assignments: Assignment[]; unscheduled: string[] } | null = null;
+  for (const ordering of orderings) {
+    const result = greedySchedule(ordering);
+    if (!best || result.unscheduled.length < best.unscheduled.length) {
+      best = result;
+    }
+    if (best.unscheduled.length === 0) return best;
+  }
+
+  // If we still have unscheduled events, try swap-based improvement
+  if (best!.unscheduled.length > 0) {
+    const improved = tryImprove(best!);
+    if (improved.unscheduled.length < best!.unscheduled.length) {
+      best = improved;
+    }
+  }
+
+  return best!;
+
+  // Try to improve by removing scheduled events and re-inserting
+  // unscheduled ones (swap-based improvement)
+  function tryImprove(current: {
+    assignments: Assignment[];
+    unscheduled: string[];
+  }): { assignments: Assignment[]; unscheduled: string[] } {
+    // Reset room intervals and assignments from current
+    for (const r of rooms) {
+      roomIntervals.set(r.id, []);
+    }
+    assigned.clear();
+
+    for (const a of current.assignments) {
+      assigned.set(a.eventId, {
+        roomId: a.roomId,
+        startTime: a.startTime,
+        endTime: a.endTime,
+      });
+      insertInterval(a.roomId, a.startTime, a.endTime);
+    }
+
+    const currentAssignments = [...current.assignments];
+    const currentUnscheduled = new Set(current.unscheduled);
+
+    // Strategy 1: For each scheduled event, try removing it and see if we
+    // can fit more unscheduled events in the freed space (net gain > 0)
+    let madeProgress = true;
+    while (madeProgress) {
+      madeProgress = false;
+
+      for (const assignment of [...currentAssignments]) {
+        const victimId = assignment.eventId;
+
+        // Don't remove if any dependent is scheduled
+        const victimDeps = dependents.get(victimId) ?? [];
+        if (victimDeps.some((d) => assigned.has(d))) continue;
+
+        // Save state for rollback
+        const savedIntervals = new Map<string, Array<{ start: number; end: number }>>();
+        for (const r of rooms) {
+          savedIntervals.set(r.id, [...roomIntervals.get(r.id)!]);
+        }
+        const savedAssigned = new Map(assigned);
+
+        // Remove victim
+        removeInterval(assignment.roomId, assignment.startTime, assignment.endTime);
+        assigned.delete(victimId);
+
+        // Try to place unscheduled events
+        const newlyPlaced: Array<{
+          eventId: string;
+          roomId: string;
+          startTime: number;
+          endTime: number;
+        }> = [];
+
+        // Sort unscheduled by duration ascending to pack more in
+        const unschedSorted = [...currentUnscheduled].sort((a, b) => {
+          return (eventMap.get(a)!.duration) - (eventMap.get(b)!.duration);
+        });
+
+        for (const unschedId of unschedSorted) {
+          const pres = prerequisites.get(unschedId) ?? [];
+          const presInSet = pres.filter((p) => eventMap.has(p));
+          if (!presInSet.every((p) => assigned.has(p))) continue;
+
+          const placementOpts = getPlacementOptions(unschedId);
+          if (placementOpts.length > 0) {
+            const opt = placementOpts[0];
+            const event = eventMap.get(unschedId)!;
+            const endTime = opt.startTime + event.duration;
+            insertInterval(opt.roomId, opt.startTime, endTime);
+            assigned.set(unschedId, {
+              roomId: opt.roomId,
+              startTime: opt.startTime,
+              endTime,
+            });
+            newlyPlaced.push({
+              eventId: unschedId,
+              roomId: opt.roomId,
+              startTime: opt.startTime,
+              endTime,
+            });
+          }
+        }
+
+        // Net gain: placed newlyPlaced.length events, removed 1
+        if (newlyPlaced.length > 1) {
+          // Accept the swap: update currentAssignments and currentUnscheduled
+          const victimIdx = currentAssignments.findIndex(
+            (a) => a.eventId === victimId,
+          );
+          currentAssignments.splice(victimIdx, 1);
+          currentUnscheduled.add(victimId);
+          for (const placed of newlyPlaced) {
+            currentAssignments.push(placed);
+            currentUnscheduled.delete(placed.eventId);
+          }
+          madeProgress = true;
+          break; // Restart the loop to find more improvements
+        } else {
+          // Revert: restore intervals and assignments
+          for (const r of rooms) {
+            roomIntervals.set(r.id, savedIntervals.get(r.id)!);
+          }
+          assigned.clear();
+          for (const [k, v] of savedAssigned) {
+            assigned.set(k, v);
+          }
+        }
+      }
+    }
+
+    // Strategy 2: Try to fit remaining unscheduled events directly
+    for (const unschedId of [...currentUnscheduled]) {
+      const pres = prerequisites.get(unschedId) ?? [];
+      const presInSet = pres.filter((p) => eventMap.has(p));
+      if (!presInSet.every((p) => assigned.has(p))) continue;
+
+      const placementOpts = getPlacementOptions(unschedId);
+      if (placementOpts.length > 0) {
+        const opt = placementOpts[0];
+        const event = eventMap.get(unschedId)!;
+        const endTime = opt.startTime + event.duration;
+        insertInterval(opt.roomId, opt.startTime, endTime);
+        assigned.set(unschedId, {
+          roomId: opt.roomId,
+          startTime: opt.startTime,
+          endTime,
+        });
+        currentAssignments.push({
+          eventId: unschedId,
+          roomId: opt.roomId,
+          startTime: opt.startTime,
+          endTime,
+        });
+        currentUnscheduled.delete(unschedId);
+      }
+    }
+
+    return {
+      assignments: currentAssignments,
+      unscheduled: [...currentUnscheduled],
+    };
+  }
+}
