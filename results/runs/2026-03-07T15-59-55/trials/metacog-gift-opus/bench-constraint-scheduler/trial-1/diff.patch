n  for (const [, roomList] of eligibleRooms) {\n    roomList.sort((a, b) => a.capacity - b.capacity);\n  }\n\n  // ── Backtracking solver ───────────────────────────────────\n  // We try to maximize the number of scheduled events.\n  // Strategy: order events by most constrained first (fewest eligible rooms,\n  // then longest duration, then most prerequisites), then use backtracking\n  // with pruning.\n\n  // For each room, track scheduled intervals as sorted list\n  type Interval = { start: number; end: number };\n  const roomIntervals = new Map<string, Interval[]>();\n  for (const r of rooms) {\n    roomIntervals.set(r.id, []);\n  }\n\n  // Track assignment per event\n  const assigned = new Map<\n    string,\n    { roomId: string; startTime: number; endTime: number }\n  >();\n\n  // Compute earliest possible start for an event given prerequisites\n  function earliestStart(eventId: string): number {\n    let earliest = options.startTime;\n    const pres = prerequisites.get(eventId) ?? [];\n    for (const pre of pres) {\n      const a = assigned.get(pre);\n      if (a) {\n        earliest = Math.max(earliest, a.endTime + gap);\n      }\n    }\n    return earliest;\n  }\n\n  // Find earliest available slot in a room for an event, starting from minStart\n  function findSlot(\n    roomId: string,\n    duration: number,\n    minStart: number,\n  ): number | null {\n    const intervals = roomIntervals.get(roomId)!;\n    // Candidate start times: minStart, or after each existing interval + gap\n    let candidate = minStart;\n\n    for (const interval of intervals) {\n      // intervals are sorted by start\n      if (candidate + duration <= interval.start - gap + /* gap is end-to-start */ 0) {\n        // Check: candidate + duration <= interval.start - gap\n        // Actually gap is between end of one event and start of next\n        if (candidate + duration + gap <= interval.start) {\n          break; // fits before this interval\n        }\n        // Doesn't fit before; try after this interval\n        candidate = Math.max(candidate, interval.end + gap);\n      } else if (candidate < interval.end + gap) {\n        candidate = interval.end + gap;\n      }\n    }\n\n    // Check it fits within the time window\n    if (candidate + duration > options.endTime) {\n      return null;\n    }\n    return candidate;\n  }\n\n  // Insert interval into sorted list\n  function insertInterval(roomId: string, start: number, end: number): void {\n    const intervals = roomIntervals.get(roomId)!;\n    let i = 0;\n    while (i < intervals.length && intervals[i].start < start) i++;\n    intervals.splice(i, 0, { start, end });\n  }\n\n  // Remove interval from list\n  function removeInterval(roomId: string, start: number, end: number): void {\n    const intervals = roomIntervals.get(roomId)!;\n    const idx = intervals.findIndex(\n      (iv) => iv.start === start && iv.end === end,\n    );\n    if (idx >= 0) intervals.splice(idx, 1);\n  }\n\n  // Try to place an event, returning all valid (room, startTime) options\n  function getPlacementOptions(\n    eventId: string,\n  ): Array<{ roomId: string; startTime: number }> {\n    const event = eventMap.get(eventId)!;\n    const eligible = eligibleRooms.get(eventId)!;\n    const minStart = earliestStart(eventId);\n    const opts: Array<{ roomId: string; startTime: number; preferred: boolean }> = [];\n\n    for (const room of eligible) {\n      const slot = findSlot(room.id, event.duration, minStart);\n      if (slot !== null) {\n        opts.push({\n          roomId: room.id,\n          startTime: slot,\n          preferred: event.preferredRoom === room.id,\n        });\n      }\n    }\n\n    // Prefer: preferred room first, then earliest start, then smallest room\n    opts.sort((a, b) => {\n      if (a.preferred !== b.preferred) return a.preferred ? -1 : 1;\n      if (a.startTime !== b.startTime) return a.startTime - b.startTime;\n      return 0;\n    });\n\n    return opts;\n  }\n\n  // Order events for scheduling: topological order, then by constraint level\n  // We use a priority-based approach: schedule events with fewer options first\n  // but respect topological ordering (prerequisites before dependents)\n\n  // Compute topological levels\n  const topoOrder = topologicalSort(events);\n  const topoIndex = new Map<string, number>();\n  for (let i = 0; i < topoOrder.length; i++) {\n    topoIndex.set(topoOrder[i], i);\n  }\n\n  // Sort events: topological order first, then by number of eligible rooms (ascending),\n  // then by duration (descending - longer events harder to place)\n  const sortedEvents = [...events].sort((a, b) => {\n    const ai = topoIndex.get(a.id)!;\n    const bi = topoIndex.get(b.id)!;\n    if (ai !== bi) return ai - bi;\n    const aRooms = eligibleRooms.get(a.id)!.length;\n    const bRooms = eligibleRooms.get(b.id)!.length;\n    if (aRooms !== bRooms) return aRooms - bRooms;\n    return b.duration - a.duration;\n  });\n\n  // Greedy placement with look-ahead\n  // For each event, try to place it. If placing it would prevent a dependent\n  // from being placed, try alternative placements.\n\n  const bestResult: { assignments: Assignment[]; count: number } = {\n    assignments: [],\n    count: 0,\n  };\n\n  // We use an iterative approach with multiple passes to maximize placement.\n  // First pass: greedy with preferred rooms.\n  // If events remain unscheduled, try again with different ordering strategies.\n\n  function greedySchedule(\n    eventOrder: Event[],\n  ): { assignments: Assignment[]; unscheduled: string[] } {\n    // Reset state\n    for (const r of rooms) {\n      roomIntervals.set(r.id, []);\n    }\n    assigned.clear();\n\n    const result: Assignment[] = [];\n    const unscheduled: string[] = [];\n\n    // Track which events are ready (all prerequisites assigned)\n    const remaining = new Set(eventOrder.map((e) => e.id));\n    const scheduled = new Set<string>();\n\n    // Process in waves: each wave schedules events whose prerequisites are met\n    let progress = true;\n    while (remaining.size > 0 && progress) {\n      progress = false;\n      for (const event of eventOrder) {\n        if (!remaining.has(event.id)) continue;\n\n        // Check if all prerequisites are scheduled\n        const pres = prerequisites.get(event.id) ?? [];\n        const presInSet = pres.filter((p) => eventMap.has(p));\n        if (!presInSet.every((p) => scheduled.has(p))) continue;\n\n        // Try to place this event\n        const options = getPlacementOptions(event.id);\n        if (options.length > 0) {\n          const best = options[0];\n          const endTime = best.startTime + event.duration;\n          assigned.set(event.id, {\n            roomId: best.roomId,\n            startTime: best.startTime,\n            endTime,\n          });\n          insertInterval(best.roomId, best.startTime, endTime);\n          result.push({\n            eventId: event.id,\n            roomId: best.roomId,\n            startTime: best.startTime,\n            endTime,\n          });\n          scheduled.add(event.id);\n          remaining.delete(event.id);\n          progress = true;\n        }\n      }\n    }\n\n    // Anything left is unscheduled\n    for (const id of remaining) {\n      unscheduled.push(id);\n    }\n\n    return { assignments: result, unscheduled };\n  }\n\n  // Try multiple orderings to maximize placement\n  // Ordering 1: topological + most constrained first\n  const result1 = greedySchedule(sortedEvents);\n\n  if (result1.unscheduled.length === 0) {\n    return result1;\n  }\n\n  // Ordering 2: topological + least constrained first (gives more flexibility)\n  const reverseConstrained = [...events].sort((a, b) => {\n    const ai = topoIndex.get(a.id)!;\n    const bi = topoIndex.get(b.id)!;\n    if (ai !== bi) return ai - bi;\n    const aRooms = eligibleRooms.get(a.id)!.length;\n    const bRooms = eligibleRooms.get(b.id)!.length;\n    if (aRooms !== bRooms) return bRooms - aRooms;\n    return a.duration - b.duration;\n  });\n  const result2 = greedySchedule(reverseConstrained);\n\n  // Ordering 3: by duration descending (place hardest first)\n  const byDuration = [...events].sort((a, b) => {\n    const ai = topoIndex.get(a.id)!;\n    const bi = topoIndex.get(b.id)!;\n    if (ai !== bi) return ai - bi;\n    return b.duration - a.duration;\n  });\n  const result3 = greedySchedule(byDuration);\n\n  // Ordering 4: by attendees descending (place hardest capacity events first)\n  const byAttendees = [...events].sort((a, b) => {\n    const ai = topoIndex.get(a.id)!;\n    const bi = topoIndex.get(b.id)!;\n    if (ai !== bi) return ai - bi;\n    return (b.attendees ?? 1) - (a.attendees ?? 1);\n  });\n  const result4 = greedySchedule(byAttendees);\n\n  // Pick the result with fewest unscheduled\n  const results = [result1, result2, result3, result4];\n  let best = results[0];\n  for (const r of results) {\n    if (r.unscheduled.length < best.unscheduled.length) {\n      best = r;\n    }\n  }\n\n  // If we still have unscheduled events, try a more sophisticated approach:\n  // backtracking on the unscheduled events with the best result as baseline\n  if (best.unscheduled.length > 0 && best.unscheduled.length <= 10) {\n    const improved = tryImprove(best);\n    if (improved.unscheduled.length < best.unscheduled.length) {\n      best = improved;\n    }\n  }\n\n  return best;\n\n  // Try to improve by removing some scheduled events and re-inserting\n  // unscheduled ones (swap-based improvement)\n  function tryImprove(current: {\n    assignments: Assignment[];\n    unscheduled: string[];\n  }): { assignments: Assignment[]; unscheduled: string[] } {\n    // Reset room intervals and assignments from current\n    for (const r of rooms) {\n      roomIntervals.set(r.id, []);\n    }\n    assigned.clear();\n\n    for (const a of current.assignments) {\n      assigned.set(a.eventId, {\n        roomId: a.roomId,\n        startTime: a.startTime,\n        endTime: a.endTim