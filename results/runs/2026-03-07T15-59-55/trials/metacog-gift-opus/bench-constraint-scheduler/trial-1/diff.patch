+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QvZWwLDwhoi514yhXXaEgC","type":"tool_result","content":"     1→// ── Interfaces ──────────────────────────────────────────────\n     2→\n     3→export interface Event {\n     4→  id: string;\n     5→  name: string;\n     6→  duration: number;\n     7→  attendees?: number;\n     8→  prerequisites?: string[];\n     9→  preferredRoom?: string;\n    10→}\n    11→\n    12→export interface Room {\n    13→  id: string;\n    14→  name: string;\n    15→  capacity: number;\n    16→}\n    17→\n    18→export interface ScheduleOptions {\n    19→  startTime: number;\n    20→  endTime: number;\n    21→  gap?: number;\n    22→}\n    23→\n    24→export interface Assignment {\n    25→  eventId: string;\n    26→  roomId: string;\n    27→  startTime: number;\n    28→  endTime: number;\n    29→}\n    30→\n    31→export interface ScheduleResult {\n    32→  assignments: Assignment[];\n    33→  unscheduled: string[];\n    34→}\n    35→\n    36→// ── Cycle detection (topological sort) ──────────────────────\n    37→\n    38→function topologicalSort(events: Event[]): string[] {\n    39→  const ids = new Set(events.map((e) => e.id));\n    40→  const adj = new Map<string, string[]>();\n    41→  const inDeg = new Map<string, number>();\n    42→\n    43→  for (const e of events) {\n    44→    adj.set(e.id, []);\n    45→    inDeg.set(e.id, 0);\n    46→  }\n    47→\n    48→  for (const e of events) {\n    49→    if (!e.prerequisites) continue;\n    50→    for (const pre of e.prerequisites) {\n    51→      // Self-reference is a cycle\n    52→      if (pre === e.id) {\n    53→        throw new Error(\n    54→          `Cycle detected: event \"${e.id}\" has a self-referencing prerequisite`,\n    55→        );\n    56→      }\n    57→      // Only wire up edges for prerequisites that are in the event set\n    58→      if (ids.has(pre)) {\n    59→        adj.get(pre)!.push(e.id);\n    60→        inDeg.set(e.id, (inDeg.get(e.id) ?? 0) + 1);\n    61→      }\n    62→    }\n    63→  }\n    64→\n    65→  const queue: string[] = [];\n    66→  for (const [id, deg] of inDeg) {\n    67→    if (deg === 0) queue.push(id);\n    68→  }\n    69→\n    70→  const sorted: string[] = [];\n    71→  while (queue.length > 0) {\n    72→    const node = queue.shift()!;\n    73→    sorted.push(node);\n    74→    for (const neighbor of adj.get(node) ?? []) {\n    75→      const newDeg = inDeg.get(neighbor)! - 1;\n    76→      inDeg.set(neighbor, newDeg);\n    77→      if (newDeg === 0) queue.push(neighbor);\n    78→    }\n    79→  }\n    80→\n    81→  if (sorted.length !== ids.size) {\n    82→    throw new Error('Cycle detected in prerequisite graph');\n    83→  }\n    84→\n    85→  return sorted;\n    86→}\n    87→\n    88→// ── Scheduler ───────────────────────────────────────────────\n    89→\n    90→export function schedule(\n    91→  events: Event[],\n    92→  rooms: Room[],\n    93→  options: ScheduleOptions,\n    94→): ScheduleResult {\n    95→  const gap = options.gap ?? 15;\n    96→\n    97→  // Validate & detect cycles (throws on cycle)\n    98→  topologicalSort(events);\n    99→\n   100→  const eventMap = new Map<string, Event>();\n   101→  for (const e of events) {\n   102→    eventMap.set(e.id, e);\n   103→  }\n   104→\n   105→  // Build adjacency: for each event, which events depend on it\n   106→  const dependents = new Map<string, string[]>();\n   107→  const prerequisites = new Map<string, string[]>();\n   108→  for (const e of events) {\n   109→    dependents.set(e.id, []);\n   110→    prerequisites.set(e.id, []);\n   111→  }\n   112→  for (const e of events) {\n   113→    if (!e.prerequisites) continue;\n   114→    for (const pre of e.prerequisites) {\n   115→      if (eventMap.has(pre)) {\n   116→        dependents.get(pre)!.push(e.id);\n   117→        prerequisites.get(e.id)!.push(pre);\n   118→      }\n   119→    }\n   120→  }\n   121→\n   122→  // Eligible rooms for each event (capacity check)\n   123→  const eligibleRooms = new Map<string, Room[]>();\n   124→  for (const e of events) {\n   125→    const att = e.attendees ?? 1;\n   126→    const eligible = rooms.filter((r) => r.capacity >= att);\n   127→    eligibleRooms.set(e.id, eligible);\n   128→  }\n   129→\n   130→  // Sort rooms by capacity ascending (prefer tighter fits)\n   131→  for (const [, roomList] of eligibleRooms) {\n   132→    roomList.sort((a, b) => a.capacity - b.capacity);\n   133→  }\n   134→\n   135→  // ── Backtracking solver ───────────────────────────────────\n   136→  // We try to maximize the number of scheduled events.\n   137→  // Strategy: order events by most constrained first (fewest eligible rooms,\n   138→  // then longest duration, then most prerequisites), then use backtracking\n   139→  // with pruning.\n   140→\n   141→  // For each room, track scheduled intervals as sorted list\n   142→  type Interval = { start: number; end: number };\n   143→  const roomIntervals = new Map<string, Interval[]>();\n   144→  for (const r of rooms) {\n   145→    roomIntervals.set(r.id, []);\n   146→  }\n   147→\n   148→  // Track assignment per event\n   149→  const assigned = new Map<\n   150→    string,\n   151→    { roomId: string; startTime: number; endTime: number }\n   152→  >();\n   153→\n   154→  // Compute earliest possible start for an event given prerequisites\n   155→  function earliestStart(eventId: string): number {\n   156→    let earliest = options.startTime;\n   157→    const pres = prerequisites.get(eventId) ?? [];\n   158→    for (const pre of pres) {\n   159→      const a = assigned.get(pre);\n   160→      if (a) {\n   161→        earliest = Math.max(earliest, a.endTime + gap);\n   162→      }\n   163→    }\n   164→    return earliest;\n   165→  }\n   166→\n   167→  // Find earliest available slot in a room for an event, starting from minStart.\n   168→  // Gap rule: end of one event + gap <= start of next event in the same room.\n   169→  function findSlot(\n   170→    roomId: string,\n   171→    duration: number,\n   172→    minStart: number,\n   173→  ): number | null {\n   174→    const intervals = roomIntervals.get(roomId)!;\n   175→    let candidate = minStart;\n   176→\n   177→    for (const interval of intervals) {\n   178→      // Does the event fit before this existing interval (with gap)?\n   179→      if (candidate + duration + gap <= interval.start) {\n   180→        break; // Yes, there's room before this interval\n   181→      }\n   182→      // No — push candidate to after this interval + gap\n   183→      candidate = Math.max(candidate, interval.end + gap);\n   184→    }\n   185→\n   186→    if (candidate + duration > options.endTime) {\n   187→      return null;\n   188→    }\n   189→    return candidate;\n   190→  }\n   191→\n   192→  // Insert interval into sorted list\n   193→  function insertInterval(roomId: string, start: number, end: number): void {\n   194→    const intervals = roomIntervals.get(roomId)!;\n   195→    let i = 0;\n   196→    while (i < intervals.length && intervals[i].start < start) i++;\n   197→    intervals.splice(i, 0, { start, end });\n   198→  }\n   199→\n   200→  // Remove interval from list\n   201→  function removeInterval(roomId: string, start: number, end: number): void {\n   202→    const intervals = roomIntervals.get(roomId)!;\n   203→    const idx = intervals.findIndex(\n   204→      (iv) => iv.start === start && iv.end === end,\n   205→    );\n   206→    if (idx >= 0) intervals.splice(idx, 1);\n   207→  }\n   208→\n   209→  // Try to place an event, returning all valid (room, startTime) options\n   210→  function getPlacementOptions(\n   211→    eventId: string,\n   212→  ): Array<{ roomId: string; startTime: number }> {\n   213→    const event = eventMap.get(eventId)!;\n   214→    const eligible = eligibleRooms.get(eventId)!;\n   215→    const minStart = earliestStart(eventId);\n   216→    const opts: Array<{ roomId: string; startTime: number; preferred: boolean }> = [];\n   217→\n   218→    for (const room of eligible) {\n   219→      const slot = findSlot(room.id, event.duration, minStart);\n   220→      if (slot !== null) {\n   221→        opts.push({\n   222→          roomId: room.id,\n   223→          startTime: slot,\n   224→          preferred: event.preferredRoom === room.id,\n   225→        });\n   226→      }\n   227→    }\n   228→\n   229→    // Prefer: preferred room first, then earliest start, then smallest room\n   230→    opts.sort((a, b) => {\n   231→      if (a.preferred !== b.preferred) return a.preferred ? -1 : 1;\n   232→      if (a.startTime !== b.startTime) return a.startTime - b.startTime;\n   233→      return 0;\n   234→    });\n   235→\n   236→    return opts;\n   237→  }\n   238→\n   239→  // Order events for scheduling: topological order, then by constraint level\n   240→  // We use a priority-based approach: schedule events with fewer options first\n   241→  // but respect topological ordering (prerequisites before dependents)\n   242→\n   243→  // Compute topological levels\n   244→  const topoOrder = topologicalSort(events);\n   245→  const topoIndex = new Map<string, number>();\n   246→  for (let i = 0; i < topoOrder.length; i++) {\n   247→    topoIndex.set(topoOrder[i], i);\n   248→  }\n   249→\n   250→  // Sort events: topological order first, then by number of eligible rooms (ascending),\n   251→  // then by duration (descending - longer events harder to place)\n   252→  const sortedEvents = [...events].sort((a, b) => {\n   253→    const ai = topoIndex.get(a.id)!;\n   254→    const bi = topoIndex.get(b.id)!;\n   255→    if (ai !== bi) return ai - bi;\n   256→    const aRooms = eligibleRooms.get(a.id)!.length;\n   257→    const bRooms = eligibleRooms.get(b.id)!.length;\n   258→    if (aRooms !== bRooms) return aRooms - bRooms;\n   259→    return b.duration - a.duration;\n   260→  });\n   261→\n   262→  // Greedy placement with look-ahead\n   263→  // For each event, try to place it. If placing it would prevent a dependent\n   264→  // from being placed, try alternative placements.\n   265→\n   266→  // We use an iterative approach with multiple passes to maximize placement.\n   267→  // First pass: greedy with preferred rooms.\n   268→  // If events remain unscheduled, try again with different ordering strategies.\n   269→\n   270→  function greedySchedule(\n   271→    eventOrder: Event[],\n   272→  ): { assignments: Assignment[]; unscheduled: string[] } {\n   273→    // Reset state\n   274→    for (const r of rooms) {\n   275→      roomIntervals.set(r.id, []);\n   276→    }\n   277→    assigned.clear();\n   278→\n   279→    const result: Assignment[] = [];\n   280→    const unscheduled: string[] = [];\n   281→\n   282→    // Track which events are ready (all prerequisites assigned)\n   283→    const remaining = new Set(eventOrder.map((e) => e.id));\n   284→    const scheduled = new Set<string>();\n   285→\n   286→    // Process in waves: each wave schedules events whose prerequisites are met\n   287→    let progress = true;\n   288→    while (remaining.size > 0 && progress) {\n   289→      progress = false;\n   290→      for (const event of eventOrder) {\n   291→        if (!remaining.has(event.id)) continue;\n   292→\n   293→        // Check if all prerequisites are scheduled\n   294→        const pres = prerequisites.get(event.id) ?? [];\n   295→        const presInSet = pres.filter((p) => eventMap.has(p));\n   296→        if (!presInSet.every((p) => scheduled.has(p))) continue;\n   297→\n   298→        // Try to place this event\n   299→        const options = getPlacementOptions(event.id);\n   300→        if (options.length > 0) {\n   301→          const best = options[0];\n   302→          const endTime = best.startTime + event.duration;\n   303→          assigned.set(event.id, {\n   304→            roomId: best.roomId,\n   305→            startTime: best.startTime,\n   306→            endTime,\n   307→          });\n   308→          insertInterval(best.roomId, best.startTime, endTime);\n   309→          result.push({\n   310→            eventId: event.id,\n   311→            roomId: best.roomId,\n   312→            startTime: best.startTime,\n   313→            endTime,\n   314→          });\n   315→          scheduled.add(event.id);\n   316→          remaining.delete(event.id);\n   317→          progress = true;\n   318→        }\n   319→      }\n   320→    }\n   321→\n   322→    // Anything left is unscheduled\n   323→    for (const id of remaining) {\n   324→      unscheduled.push(id);\n   325→    }\n   326→\n   327→    return { assignments: result, unscheduled };\n   328→  }\n   329→\n   330→  // Try multiple orderings to maximize placement\n   331→  // Ordering 1: topological + most constrained first\n   332→  const result1 = greedySchedule(sortedEvents);\n   333→\n   334→  if (result1.unscheduled.length === 0) {\n   335→    return result1;\n   336→  }\n   337→\n   338→  // Ordering 2: topological + least constrained first (gives more flexibility)\n   339→  const reverseConstrained = [...events].sort((a, b) => {\n   340→    const ai = topoIndex.get(a.id)!;\n   341→    const bi = topoIndex.get(b.id)!;\n   342→    if (ai !== bi) return ai - bi;\n   343→    const aRooms = eligibleRooms.get(a.id)!.length;\n   344→    const bRooms = eligibleRooms.get(b.id)!.length;\n   345→    if (aRooms !== bRooms) return bRooms - aRooms;\n   346→    return a.duration - b.duration;\n   347→  });\n   348→  const result2 = greedySchedule(reverseConstrained);\n   349→\n   350→  // Ordering 3: by duration descending (place hardest first)\n   351→  const byDuration = [...events].sort((a, b) => {\n   352→    const ai = topoIndex.get(a.id)!;\n   353→    const bi = topoIndex.get(b.id)!;\n   354→    if (ai !== bi) return ai - bi;\n   355→    return b.duration - a.duration;\n   356→  });\n   357→  const result3 = greedySchedule(byDuration);\n   358→\n   359→  // Ordering 4: by attendees descending (place hardest capacity events first)\n   360→  const byAttendees = [...events].sort((a, b) => {\n   361→    const ai = topoIndex.get(a.id)!;\n   362→    const bi = topoIndex.get(b.id)!;\n   363→    if (ai !== bi) return ai - bi;\n   364→    return (b.attendees ?? 1) - (a.attendees ?? 1);\n   365→  });\n   366→  const result4 = greedySchedule(byAttendees);\n   367→\n   368→  // Pick the result with fewest unscheduled\n   369→  const results = [result1, result2, result3, result4];\n   370→  let best = results[0];\n   371→  for (const r of results) {\n   372→    if (r.unscheduled.length < best.unscheduled.length) {\n   373→      best = r;\n   374→    }\n   375→  }\n   376→\n   377→  // If we still have unscheduled events, try a more sophisticated approach:\n   378→  // backtracking on the unscheduled events with the best result as baseline\n   379→  if (best.unscheduled.length > 0 && best.unscheduled.length <= 10) {\n   380→    const improved = tryImprove(best);\n   381→    if (improved.unscheduled.length < best.unscheduled.length) {\n   382→      best = improved;\n   383→    }\n   384→  }\n   385→\n   386→  return best;\n   387→\n   388→  // Try to improve by removing some scheduled events and re-inserting\n   389→  // unscheduled ones (swap-based improvement)\n   390→  function tryImprove(current: {\n   391→    assignments: Assignment[];\n   392→    unscheduled: string[];\n   393→  }): { assignments: Assignment[]; unscheduled: string[] } {\n   394→    // Reset room intervals and assignments from current\n   395→    for (const r of rooms) {\n   396→      roomIntervals.set(r.id, []);\n   397→    }\n   398→    assigned.clear();\n   399→\n   400→    for (const a of current.assignments) {\n   401→      assigned.set(a.eventId, {\n   402→        roomId: a.roomId,\n   403→        startTime: a.startTime,\n   404→        endTime: a.endTime,\n   405→      });\n   406→      insertInterval(a.roomId, a.startTime, a.endTime);\n   407→    }\n   408→\n   409→    let improved = false;\n   410→    const currentAssignments = [...current.assignments];\n   411→    const currentUnscheduled = [...current.unscheduled];\n   412→\n   413→    // For each unscheduled event, see if removing a conflicting scheduled event\n   414→    // and rescheduling both results in more events scheduled\n   415→    for (const unschedId of [...currentUnscheduled]) {\n   416→      const unschedEvent = eventMap.get(unschedId)!;\n   417→      const pres = prerequisites.get(unschedId) ?? [];\n   418→      const presInSet = pres.filter((p) => eventMap.has(p));\n   419→\n   420→      // Check prerequisites are met\n   421→      if (!presInSet.every((p) => assigned.has(p))) continue;\n   422→\n   423→      // Try to find a room where we can fit by removing one event\n   424→      const eligible = eligibleRooms.get(unschedId)!;\n   425→      for (const room of eligible) {\n   426→        const intervals = roomIntervals.get(room.id)!;\n   427→        const minStart = earliestStart(unschedId);\n   428→\n   429→        // Try removing each interval in this room to make space\n   430→        for (let i = 0; i < intervals.length; i++) {\n   431→          const victim = intervals[i];\n   432→          // Find which event this interval belongs to\n   433→          const victimEventId = currentAssignments.find(\n   434→            (a) =>\n   435→              a.roomId === room.id &&\n   436→              a.startTime === victim.start &&\n   437→              a.endTime === victim.end,\n   438→          )?.eventId;\n   439→          if (!victimEventId) continue;\n   440→\n   441→          // Don't remove a prerequisite of the event we're trying to place\n   442→          if (presInSet.includes(victimEventId)) continue;\n   443→\n   444→          // Check if victim has dependents that are scheduled\n   445→          const victimDeps = dependents.get(victimEventId) ?? [];\n   446→          const hasScheduledDep = victimDeps.some((d) => assigned.has(d));\n   447→          if (hasScheduledDep) continue;\n   448→\n   449→          // Try: remove victim, place unscheduled, then re-place victim\n   450→          removeInterval(room.id, victim.start, victim.end);\n   451→          assigned.delete(victimEventId);\n   452→\n   453→          const slot = findSlot(room.id, unschedEvent.duration, minStart);\n   454→          if (slot !== null) {\n   455→            const endTime = slot + unschedEvent.duration;\n   456→            insertInterval(room.id, slot, endTime);\n   457→            assigned.set(unschedId, { roomId: room.id, startTime: slot, endTime });\n   458→\n   459→            // Try to re-place victim\n   460→            const victimEvent = eventMap.get(victimEventId)!;\n   461→            const victimOptions = getPlacementOptions(victimEventId);\n   462→            if (victimOptions.length > 0) {\n   463→              const vo = victimOptions[0];\n   464→              const vEnd = vo.startTime + victimEvent.duration;\n   465→              insertInterval(vo.roomId, vo.startTime, vEnd);\n   466→              assigned.set(victimEventId, {\n   467→                roomId: vo.roomId,\n   468→                startTime: vo.startTime,\n   469→                endTime: vEnd,\n   470→              });\n   471→\n   472→              // Update assignments list\n   473→              const victimIdx = currentAssignments.findIndex(\n   474→                (a) => a.eventId === victimEventId,\n   475→              );\n   476→              currentAssignments[victimIdx] = {\n   477→                eventId: victimEventId,\n   478→                roomId: vo.roomId,\n   479→                startTime: vo.startTime,\n   480→                endTime: vEnd,\n   481→              };\n   482→              currentAssignments.push({\n   483→                eventId: unschedId,\n   484→                roomId: room.id,\n   485→                startTime: slot,\n   486→                endTime,\n   487→              });\n   488→              const unIdx = currentUnscheduled.indexOf(unschedId);\n   489→              currentUnscheduled.splice(unIdx, 1);\n   490→              improved = true;\n   491→              break;\n   492→            } else {\n   493→              // Can't re-place victim, revert\n   494→              removeInterval(room.id, slot, endTime);\n   495→              assigned.delete(unschedId);\n   496→              insertInterval(room.id, victim.start, victim.end);\n   497→              assigned.set(victimEventId, {\n   498→                roomId: room.id,\n   499→                startTime: victim.start,\n   500→                endTime: victim.end,\n   501→              });\n   502→            }\n   503→          } else {\n   504→            // Revert\n   505→            insertInterval(room.id, victim.start, victim.end);\n   506→            assigned.set(victimEventId, {\n   507→              roomId: room.id,\n   508→              startTime: victim.start,\n   509→              endTime: victim.end,\n   510→            });\n   511→          }\n   512→        }\n   513→        if (improved) break;\n   514→      }\n   515→      if (improved) {\n   516→        improved = false; // Reset for next iteration\n   517→      }\n   518→    }\n   519→\n   520→    return { assignments: currentAssignments, unscheduled: currentUnscheduled };\n   521→  }\n   522→}\n   523→"}]},"parent_tool_use_id":null,"session_id":"7131b56f-75f1-427d-9af7-12f5c1f4813d","uuid":"e3bbbe90-d86a-4593-ae1c-4766c146e57c","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/index.ts","content":"// ── Interfaces ──────────────────────────────────────────────\n\nexport interface Event {\n  id: string;\n  name: string;\n  duration: number;\n  attendees?: number;\n  prerequisites?: string[];\n  preferredRoom?: string;\n}\n\nexport interface Room {\n  id: string;\n  name: string;\n  capacity: number;\n}\n\nexport interface ScheduleOptions {\n  startTime: number;\n  endTime: number;\n  gap?: number;\n}\n\nexport interface Assignment {\n  eventId: string;\n  roomId: string;\n  startTime: number;\n  endTime: number;\n}\n\nexport interface ScheduleResult {\n  assignments: Assignment[];\n  unscheduled: string[];\n}\n\n// ── Cycle detection (topological sort) ──────────────────────\n\nfunction topologicalSort(events: Event[]): string[] {\n  const ids = new Set(events.map((e) => e.id));\n  const adj = new Map<string, string[]>();\n  const inDeg = new Map<string, number>();\n\n  for (const e of events) {\n    adj.set(e.id, []);\n    inDeg.set(e.id, 0);\n  }\n\n  for (const e of events) {\n    if (!e.prerequisites) continue;\n    for (const pre of e.prerequisites) {\n      // Self-reference is a cycle\n      if (pre === e.id) {\n        throw new Error(\n          `Cycle detected: event \"${e.id}\" has a self-referencing prerequisite`,\n        );\n      }\n      // Only wire up edges for prerequisites that are in the event set\n      if (ids.has(pre)) {\n        adj.get(pre)!.push(e.id);\n        inDeg.set(e.id, (inDeg.get(e.id) ?? 0) + 1);\n      }\n    }\n  }\n\n  const queue: string[] = [];\n  for (const [id, deg] of inDeg) {\n    if (deg === 0) queue.push(id);\n  }\n\n  const sorted: string[] = [];\n  while (queue.length > 0) {\n    const node = queue.shift()!;\n    sorted.push(node);\n    for (const neighbor of adj.get(node) ?? []) {\n      const newDeg = inDeg.get(neighbor)! - 1;\n      inDeg.set(neighbor, newDeg);\n      if (newDeg === 0) queue.push(neighbor);\n    }\n  }\n\n  if (sorted.length !== ids.size) {\n    throw new Error('Cycle detected in prerequisite graph');\n  }\n\n  return sorted;\n}\n\n// ── Scheduler ───────────────────────────────────────────────\n\nexport function schedule(\n  events: Event[],\n  rooms: Room[],\n  options: ScheduleOptions,\n): ScheduleResult {\n  const gap = options.gap ?? 15;\n\n  // Validate & detect cycles (throws on cycle)\n  topologicalSort(events);\n\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  // Build adjacency: for each event, which events depend on it\n  const dependents = new Map<string, string[]>();\n  const prerequisites = new Map<string, string[]>();\n  for (const e of events) {\n    dependents.set(e.id, []);\n    prerequisites.set(e.id, []);\n  }\n  for (const e of events) {\n    if (!e.prerequisites) continue;\n    for (const pre of e.prerequisites) {\n      if (eventMap.has(pre)) {\n        dependents.get(pre)!.push(e.id);\n        prerequisites.get(e.id)!.push(pre);\n      }\n    }\n  }\n\n  // Eligible rooms for each event (capacity check)\n  const eligibleRooms = new Map<string, Room[]>();\n  for (const e of events) {\n    const att = e.attendees ?? 1;\n    const eligible = rooms.filter((r) => r.capacity >= att);\n    eligibleRooms.set(e.id, eligible);\n  }\n\n  // Sort rooms by capacity ascending (prefer tighter fits)\n  for (const [, roomList] of eligibleRooms) {\n    roomList.sort((a, b) => a.capacity - b.capacity);\n  }\n\n  // ── Backtracking solver ───────────────────────────────────\n  // We try to maximize the number of scheduled events.\n  // Strategy: order events by most constrained first (fewest eligible rooms,\n  // then longest duration, then most prerequisites), then use backtracking\n  // with pruning.\n\n  // For each room, track scheduled intervals as sorted list\n  type Interval = { start: number; end: number };\n  const roomIntervals = new Map<string, Interval[]>();\n  for (const r of rooms) {\n    roomIntervals.set(r.id, []);\n  }\n\n  // Track assignment per event\n  const assigned = new Map<\n    string,\n    { roomId: string; startTime: number; endTime: number }\n  >();\n\n  // Compute earliest possible start for an event given prerequisites\n  function earliestStart(eventId: string): number {\n    let earliest = options.startTime;\n    const pres = prerequisites.get(eventId) ?? [];\n    for (const pre of pres) {\n      const a = assigned.get(pre);\n      if (a) {\n        earliest = Math.max(earliest, a.endTime + gap);\n      }\n    }\n    return earliest;\n  }\n\n  // Find earliest available slot in a room for an event, starting from minStart.\n  // Gap rule: end of one event + gap <= start of next event in the same room.\n  function findSlot(\n    roomId: string,\n    duration: number,\n    minStart: number,\n  ): number | null {\n    const intervals = roomIntervals.get(roomId)!;\n    let candidate = minStart;\n\n    for (const interval of intervals) {\n      // Does the event fit before this existing interval (with gap)?\n      if (candidate + duration + gap <= interval.start) {\n        break; // Yes, there's room before this interval\n      }\n      // No — push candidate to after this interval + gap\n      candidate = Math.max(candidate, interval.end + gap);\n    }\n\n    if (candidate + duration > options.endTime) {\n      return null;\n    }\n    return candidate;\n  }\n\n  // Insert interval into sorted list\n  function insertInterval(roomId: string, start: number, end: number): void {\n    const intervals = roomIntervals.get(roomId)!;\n    let i = 0;\n    while (i < intervals.length && intervals[i].start < start) i++;\n    intervals.splice(i, 0, { start, end });\n  }\n\n  // Remove interval from list\n  function removeInterval(roomId: string, start: number, end: number): void {\n    const intervals = roomIntervals.get(roomId)!;\n    const idx = intervals.findIndex(\n      (iv) => iv.start === start && iv.end === end,\n    );\n    if (idx >= 0) intervals.splice(idx, 1);\n  }\n\n  // Try to place an event, returning all valid (room, startTime) options\n  function getPlacementOptions(\n    eventId: string,\n  ): Array<{ roomId: string; startTime: number }> {\n    const event = eventMap.get(eventId)!;\n    const eligible = eligibleRooms.get(eventId)!;\n    const minStart = earliestStart(eventId);\n    const opts: Array<{ roomId: string; startTime: number; preferred: boolean }> = [];\n\n    for (const room of eligible) {\n      const slot = findSlot(room.id, event.duration, minStart);\n      if (slot !== null) {\n        opts.push({\n          roomId: room.id,\n          startTime: slot,\n          preferred: event.preferredRoom === room.id,\n        });\n      }\n    }\n\n    // Prefer: preferred room first, then earliest start, then smallest room\n    opts.sort((a, b) => {\n      if (a.preferred !== b.preferred) return a.preferred ? -1 : 1;\n      if (a.startTime !== b.startTime) return a.startTime - b.startTime;\n      return 0;\n    });\n\n    return opts;\n  }\n\n  // Order events for scheduling: topological order, then by constraint level\n  // We use a priority-based approach: schedule events with fewer options first\n  // but respect topological ordering (prerequisites before dependents)\n\n  // Compute topological levels\n  const topoOrder = topologicalSort(events);\n  const topoIndex = new Map<string, number>();\n  for (let i = 0; i < topoOrder.length; i++) {\n    topoIndex.set(topoOrder[i], i);\n  }\n\n  // Sort events: topological order first, then by number of eligible rooms (ascending),\n  // then by duration (descending - longer events harder to place)\n  const sortedEvents = [...events].sort((a, b) => {\n    const ai = topoIndex.get(a.id)!;\n    const bi = topoIndex.get(b.id)!;\n    if (ai !== bi) return ai - bi;\n    const aRooms = eligibleRooms.get(a.id)!.length;\n    const bRooms = eligibleRooms.get(b.id)!.length;\n    if (aRooms !== bRooms) return aRooms - bRooms;\n    return b.duration - a.duration;\n  });\n\n  // Greedy placement with look-ahead\n  // For each event, try to place it. If placing it would prevent a dependent\n  // from being placed, try alternative placements.\n\n  // We use an iterative approach with multiple passes to maximize placement.\n  // First pass: greedy with preferred rooms.\n  // If events remain unscheduled, try again with different ordering strategies.\n\n  function greedySchedule(\n    eventOrder: Event[],\n  ): { assignments: Assignment[]; unscheduled: string[] } {\n    // Reset state\n    for (const r of rooms) {\n      roomIntervals.set(r.id, []);\n    }\n    assigned.clear();\n\n    const result: Assignment[] = [];\n    const unscheduled: string[] = [];\n\n    // Track which events are ready (all prerequisites assigned)\n    const remaining = new Set(eventOrder.map((e) => e.id));\n    const scheduled = new Set<string>();\n\n    // Process in waves: each wave schedules events whose prerequisites are met\n    let progress = true;\n    while (remaining.size > 0 && progress) {\n      progress = false;\n      for (const event of eventOrder) {\n        if (!remaining.has(event.id)) continue;\n\n        // Check if all prerequisites are scheduled\n        const pres = prerequisites.get(event.id) ?? [];\n        const presInSet = pres.filter((p) => eventMap.has(p));\n        if (!presInSet.every((p) => scheduled.has(p))) continue;\n\n        // Try to place this event\n        const options = getPlacementOptions(event.id);\n        if (options.length > 0) {\n          const best = options[0];\n          const endTime = best.startTime + event.duration;\n          assigned.set(event.id, {\n            roomId: best.roomId,\n            startTime: best.startTime,\n            endTime,\n          });\n          insertInterval(best.roomId, best.startTime, endTime);\n          result.push({\n            eventId: event.id,\n            roomId: best.roomId,\n            startTime: best.startTime,\n            endTime,\n          });\n          scheduled.add(event.id);\n          remaining.delete(event.id);\n          progress = true;\n        }\n      }\n    }\n\n    // Anything left is unscheduled\n    for (const id of remaining) {\n      unscheduled.push(id);\n    }\n\n    return { assignments: result, unscheduled };\n  }\n\n  // Try multiple orderings to maximize placement\n  // Ordering 1: topological + most constrained first\n  const result1 = greedySchedule(sortedEvents);\n\n  if (result1.unscheduled.length === 0) {\n    return result1;\n  }\n\n  // Ordering 2: topological + least constrained first (gives more flexibility)\n  const reverseConstrained = [...events].sort((a, b) => {\n    const ai = topoIndex.get(a.id)!;\n    const bi = topoIndex.get(b.id)!;\n    if (ai !== bi) return ai - bi;\n    const aRooms = eligibleRooms.get(a.id)!.length;\n    const bRooms = eligibleRooms.get(b.id)!.length;\n    if (aRooms !== bRooms) return bRooms - aRooms;\n    return a.duration - b.duration;\n  });\n  const result2 = greedySchedule(reverseConstrained);\n\n  // Ordering 3: by duration descending (place hardest first)\n  const byDuration = [...events].sort((a, b) => {\n    const ai = topoIndex.get(a.id)!;\n    const bi = topoIndex.get(b.id)!;\n    if (ai !== bi) return ai - bi;\n    return b.duration - a.duration;\n  });\n  const result3 = greedySchedule(byDuration);\n\n  // Ordering 4: by attendees descending (place hardest capacity events first)\n  const byAttendees = [...events].sort((a, b) => {\n    const ai = topoIndex.get(a.id)!;\n    const bi = topoIndex.get(b.id)!;\n    if (ai !== bi) return ai - bi;\n    return (b.attendees ?? 1) - (a.attendees ?? 1);\n  });\n  const result4 = greedySchedule(byAttendees);\n\n  // Pick the result with fewest unscheduled\n  const results = [result1, result2, result3, result4];\n  let best = results[0];\n  for (const r of results) {\n    if (r.unscheduled.length < best.unscheduled.length) {\n      best = r;\n    }\n  }\n\n  // If we still have unscheduled events, try a more sophisticated approach:\n  // backtracking on the unscheduled events with the best result as baseline\n  if (best.unscheduled.length > 0 && best.unscheduled.length <= 10) {\n    const improved = tryImprove(best);\n    if (improved.unscheduled.length < best.unscheduled.length) {\n      best = improved;\n    }\n  }\n\n  return best;\n\n  // Try to improve by removing some scheduled events and re-inserting\n  // unscheduled ones (swap-based improvement)\n  function tryImprove(current: {\n    assignments: Assignment[];\n    unscheduled: string[];\n  }): { assignments: Assignment[];