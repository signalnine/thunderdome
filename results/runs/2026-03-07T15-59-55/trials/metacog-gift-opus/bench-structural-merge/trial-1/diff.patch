DocumentsMap(docs: Map<string, DocumentEntry>): Map<string, DocumentEntry> {\n  const cloned = new Map<string, DocumentEntry>();\n  for (const [id, entry] of docs) {\n    cloned.set(id, cloneDocumentEntry(entry));\n  }\n  return cloned;\n}\n\nfunction isPlainObject(val: unknown): val is Record<string, unknown> {\n  return val !== null && typeof val === 'object' && !Array.isArray(val);\n}\n\nfunction mergeField(\n  documentId: string,\n  base: unknown,\n  ours: unknown,\n  theirs: unknown,\n  path: string,\n  conflicts: Conflict[],\n  parent: Record<string, unknown>,\n  key: string,\n): void {\n  // If ours and theirs are deep equal, no conflict\n  if (JSON.stringify(ours) === JSON.stringify(theirs)) {\n    parent[key] = deepClone(ours);\n    return;\n  }\n\n  const oursChanged = JSON.stringify(base) !== JSON.stringify(ours);\n  const theirsChanged = JSON.stringify(base) !== JSON.stringify(theirs);\n\n  if (!oursChanged && !theirsChanged) {\n    parent[key] = deepClone(base);\n    return;\n  }\n\n  if (!oursChanged && theirsChanged) {\n    parent[key] = deepClone(theirs);\n    return;\n  }\n\n  if (oursChanged && !theirsChanged) {\n    parent[key] = deepClone(ours);\n    return;\n  }\n\n  // Both changed to different values\n  if (isPlainObject(base) && isPlainObject(ours) && isPlainObject(theirs)) {\n    const mergedChild: Record<string, unknown> = {};\n    const allKeys = new Set([\n      ...Object.keys(base),\n      ...Object.keys(ours),\n      ...Object.keys(theirs),\n    ]);\n\n    for (const childKey of allKeys) {\n      const childPath = path ? `${path}.${childKey}` : childKey;\n      mergeField(\n        documentId,\n        base[childKey],\n        ours[childKey],\n        theirs[childKey],\n        childPath,\n        conflicts,\n        mergedChild,\n        childKey,\n      );\n    }\n\n    parent[key] = mergedChild;\n    return;\n  }\n\n  // If base is not an object but both sides are objects, recurse with empty base\n  if (isPlainObject(ours) && isPlainObject(theirs)) {\n    const baseObj = isPlainObject(base) ? base : {};\n    const mergedChild: Record<string, unknown> = {};\n    const allKeys = new Set([\n      ...Object.keys(baseObj),\n      ...Object.keys(ours),\n      ...Object.keys(theirs),\n    ]);\n\n    for (const childKey of allKeys) {\n      const childPath = path ? `${path}.${childKey}` : childKey;\n      mergeField(\n        documentId,\n        baseObj[childKey],\n        ours[childKey],\n        theirs[childKey],\n        childPath,\n        conflicts,\n        mergedChild,\n        childKey,\n      );\n    }\n\n    parent[key] = mergedChild;\n    return;\n  }\n\n  // Conflict: both changed to different values\n  conflicts.push({\n    documentId,\n    path,\n    base: deepClone(base),\n    ours: deepClone(ours),\n    theirs: deepClone(theirs),\n  });\n  // Favor ours in merged output\n  parent[key] = deepClone(ours);\n}\n\nfunction mergeDocumentContents(\n  documentId: string,\n  base: object,\n  ours: object,\n  theirs: object,\n): { merged: object; conflicts: Conflict[] } {\n  const conflicts: Conflict[] = [];\n  const merged: Record<string, unknown> = {};\n\n  const baseObj = base as Record<string, unknown>;\n  const oursObj = ours as Record<string, unknown>;\n  const theirsObj = theirs as Record<string, unknown>;\n\n  const allKeys = new Set([\n    ...Object.keys(baseObj),\n    ...Object.keys(oursObj),\n    ...Object.keys(theirsObj),\n  ]);\n\n  for (const key of allKeys) {\n    mergeField(\n      documentId,\n      baseObj[key],\n      oursObj[key],\n      theirsObj[key],\n      key,\n      conflicts,\n      merged,\n      key,\n    );\n  }\n\n  return { merged, conflicts };\n}\n\nexport class DocumentStore {\n  private branches: Map<string, BranchData> = new Map();\n  private currentBranch: string = 'main';\n\n  constructor() {\n    this.branches.set('main', {\n      documents: new Map(),\n      parentBranch: null,\n      branchPoint: null,\n    });\n  }\n\n  // --- Document CRUD ---\n\n  create(id: string, content: object): void {\n    const branch = this.getCurrentBranchData();\n    const existing = branch.documents.get(id);\n    if (existing && !existing.deleted) {\n      throw new Error(`Document \"${id}\" already exists`);\n    }\n\n    const version: Version = {\n      id: generateVersionId(),\n      timestamp: Date.now(),\n      content: deepClone(content),\n    };\n\n    branch.documents.set(id, {\n      content: deepClone(content),\n      versions: [version],\n      deleted: false,\n    });\n  }\n\n  get(id: string): object {\n    const branch = this.getCurrentBranchData();\n    const entry = branch.documents.get(id);\n    if (!entry || entry.deleted) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    return deepClone(entry.content);\n  }\n\n  update(id: string, content: object): void {\n    const branch = this.getCurrentBranchData();\n    const entry = branch.documents.get(id);\n    if (!entry || entry.deleted) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n\n    const version: Version = {\n      id: generateVersionId(),\n      timestamp: Date.now(),\n      content: deepClone(content),\n    };\n\n    entry.content = deepClone(content);\n    entry.versions.push(version);\n  }\n\n  delete(id: string): void {\n    const branch = this.getCurrentBranchData();\n    const entry = branch.documents.get(id);\n    if (!entry || entry.deleted) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    entry.deleted = true;\n  }\n\n  // --- Version History ---\n\n  getHistory(id: string): Version[] {\n    const branch = this.getCurrentBranchData();\n    const entry = branch.documents.get(id);\n    if (!entry) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    return entry.versions.map(v => ({\n      id: v.id,\n      timestamp: v.timestamp,\n      content: deepClone(v.content),\n    }));\n  }\n\n  getVersion(id: string, versionId: string): object {\n    const branch = this.getCurrentBranchData();\n    const entry = branch.documents.get(id);\n    if (!entry) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    const version = entry.versions.find(v => v.id === versionId);\n    if (!version) {\n      throw new Error(`Version \"${versionId}\" not found for document \"${id}\"`);\n    }\n    return deepClone(version.content);\n  }\n\n  // --- Branching ---\n\n  createBranch(name: string, fromBranch?: string): void {\n    if (this.branches.has(name)) {\n      throw new Error(`Branch \"${name}\" already exists`);\n    }\n\n    const sourceName = fromBranch ?? this.currentBranch;\n    const source = this.branches.get(sourceName);\n    if (!source) {\n      throw new Error(`Branch \"${sourceName}\" not found`);\n    }\n\n    this.branches.set(name, {\n      documents: cloneDocumentsMap(source.documents),\n      parentBranch: sourceName,\n      branchPoint: cloneDocumentsMap(source.documents),\n    });\n  }\n\n  switchBranch(name: string): void {\n    if (!this.branches.has(name)) {\n      throw new Error(`Branch \"${name}\" not found`);\n    }\n    this.currentBranch = name;\n  }\n\n  getBranch(): string {\n    return this.currentBranch;\n  }\n\n  listBranches(): string[] {\n    return Array.from(this.branches.keys());\n  }\n\n  // --- Merging ---\n\n  merge(sourceBranch: string): MergeResult {\n    const sourceBranchData = this.branches.get(sourceBranch);\n    if (!sourceBranchData) {\n      throw new Error(`Branch \"${sourceBranch}\" not found`);\n    }\n\n    const targetBranchData = this.getCurrentBranchData();\n\n    // Find the common ancestor (branch point)\n    // The ancestor is the state at the time the source branch was created\n    const ancestor = sourceBranchData.branchPoint;\n\n    // If no ancestor (shouldn't happen for proper branches, but handle it)\n    if (!ancestor) {\n      throw new Error(`Cannot determine common ancestor between \"${this.currentBranch}\" and \"${sourceBranch}\"`);\n    }\n\n    const allDocIds = new Set<string>();\n    for (const id of ancestor.keys()) allDocIds.add(id);\n    for (const id of targetBranchData.documents.keys()) allDocIds.add(id);\n    for (const id of sourceBranchData.documents.keys()) allDocIds.add(id);\n\n    const merged: Record<string, object> = {};\n    const allConflicts: Conflict[] = [];\n    let hasChanges = false;\n\n    for (const docId of allDocIds) {\n      const baseEntry = ancestor.get(docId);\n      const oursEntry = targetBranchData.documents.get(docId);\n      const theirsEntry = sourceBranchData.documents.get(docId);\n\n      const baseContent = baseEntry && !baseEntry.deleted ? baseEntry.content : undefined;\n      const oursContent = oursEntry && !oursEntry.deleted ? oursEntry.content : undefined;\n      const theirsContent = theirsEntry && !theirsEntry.deleted ? theirsEntry.content : undefined;\n\n      // If both sides are the same as base, nothing to do\n      if (\n        JSON.stringify(oursContent) === JSON.stringify(baseContent) &&\n        JSON.stringify(theirsContent) === JSON.stringify(baseContent)\n      ) {\n        // No changes to this doc — keep current state\n        if (oursContent !== undefined) {\n          merged[docId] = deepClone(oursContent);\n        }\n        continue;\n      }\n\n      hasChanges = true;\n\n      const oursChanged = JSON.stringify(oursContent) !== JSON.stringify(baseContent);\n      const theirsChanged = JSON.stringify(theirsContent) !== JSON.stringify(baseContent);\n\n      // Document only changed on one side\n      if (!oursChanged && theirsChanged) {\n        if (theirsContent !== undefined) {\n          merged[docId] = deepClone(theirsContent);\n        }\n        // If theirs deleted it (undefined), don't include in merged\n        continue;\n      }\n\n      if (oursChanged && !theirsChanged) {\n        if (oursContent !== undefined) {\n          merged[docId] = deepClone(oursContent);\n        }\n        continue;\n      }\n\n      // Both changed\n      if (JSON.stringify(oursContent) === JSON.stringify(theirsContent)) {\n        // Same change on both sides\n        if (oursContent !== undefined) {\n          merged[docId] = deepClone(oursContent);\n        }\n        continue;\n      }\n\n      // Both changed differently\n      // Handle cases where one or both deleted the doc\n      if (oursContent === undefined || theirsContent === undefined) {\n        // One deleted, other modified — conflict at document level\n        allConflicts.push({\n          documentId: docId,\n          path: '',\n          base: baseContent !== undefined ? deepClone(baseContent) : undefined,\n          ours: oursContent !== undefined ? deepClone(oursContent) : undefined,\n          theirs: theirsContent !== undefined ? deepClone(theirsContent) : undefined,\n        });\n        // Favor ours\n        if (oursContent !== undefined) {\n          merged[docId] = deepClone(oursContent);\n        }\n        continue;\n      }\n\n      // Both exist and differ — three-way structural merge\n      const base = baseContent ?? {};\n      const result = mergeDocumentContents(docId, base, oursContent, theirsContent);\n      merged[docId] = result.merged;\n      allConflicts.push(...result.conflicts);\n    }\n\n    // If no changes at all, fast-forward\n    if (!hasChanges) {\n      // Include current docs in merged\n      const currentMerged: Record<string, object> = {};\n      for (const [id, entry] of targetBranchData.documents) {\n        if (!entry.deleted) {\n          currentMerged[id] = deepClone(entry.content);\n        }\n      }\n      return { merged: currentMerged, conflicts: [], applied: true };\n    }\n\n    const applied = allConflicts.length === 0;\n\n    if (applied) {\n      // Apply merge to current branch\n      // For documents in merged, update/create them\n      // For documents not in merged that were in ancestor, they were deleted\n      for (const docId of allDocIds) {\n        if (docId in merged) {\n          const existingEntry = targetBranchData.documents.get(docId);\n          if (existingEntry && !existingEntry.deleted) {\n            // Update existing doc\n            if (JSON.stringify(existingEntry.content) !== JSON.stringify(merged[docId])) {\n              const version: Version = {\n                id: generateVersionId(),\n                timestamp: Date.now(),\n                content: deepClone(merged[docId]),\n              };\n              existingEntry.content = deepClone(merged[docId]);\n              existingEntry.versions.push(version);\n            }\n          } else {\n            // Create/restore doc\n            const version: Version = {\n              id: generateVersionId(),\n              timestamp: Date.now(),\n              content: deepClone(merged[docId]),\n            };\n            targetBranchData.documents.set(docId, {\n              content: deepClone(merged[docId]),\n              versions: [version],\n              deleted: false,\n            });\n          }\n        } else {\n          // Document was deleted in merge\n          const existingEntry = targetBranchData.documents.get(docId);\n          if (existingEntry && !existingEntry.deleted) {\n            existingEntry.deleted = true;\n          }\n        }\n      }\n    }\n\n    return { merged, conflicts: allConflicts, applied };\n  }\n\n  // --- Private helpers ---\n\n  private getCurrentBranchData(): BranchData {\n    const data = this.branches.get(this.currentBranch);\n    if (!data) {\n      throw new Error(`Branch \"${this.currentBranch}\" not found`);\n    }\n    return data;\n  }\n}\n","structuredPatch":[{"oldStart":7,"oldLines":9,"newStart":7,"newLines":12,"lines":[" export interface Conflict {","   documentId: string;","   path: string;","-  base: unknown;","-  ours: unknown;","-  theirs: unknown;","+  // eslint-disable-next-line @typescript-eslint/no-explicit-any","+  base: any;","+  // eslint-disable-next-line @typescript-eslint/no-explicit-any","+  ours: any;","+  // eslint-disable-next-l