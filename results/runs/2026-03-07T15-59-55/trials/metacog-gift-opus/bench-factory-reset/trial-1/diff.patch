gth;\n  const m = buttons.length;\n\n  const t: number[] = target.map((v) => (v ? 1 : 0));\n\n  // Build augmented matrix [A | b] over GF(2)\n  // Row per light, column per button, last column is target\n  const aug: number[][] = [];\n  for (let i = 0; i < n; i++) {\n    const row = new Array(m + 1).fill(0);\n    for (let j = 0; j < m; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    row[m] = t[i];\n    aug.push(row);\n  }\n\n  // Gaussian elimination over GF(2) with full row reduction\n  const pivotCol: number[] = [];\n  let row = 0;\n  for (let col = 0; col < m && row < n; col++) {\n    let pivotRow = -1;\n    for (let r = row; r < n; r++) {\n      if (aug[r][col] === 1) {\n        pivotRow = r;\n        break;\n      }\n    }\n    if (pivotRow === -1) continue;\n\n    [aug[row], aug[pivotRow]] = [aug[pivotRow], aug[row]];\n    pivotCol.push(col);\n\n    for (let r = 0; r < n; r++) {\n      if (r !== row && aug[r][col] === 1) {\n        for (let c = 0; c < m + 1; c++) {\n          aug[r][c] ^= aug[row][c];\n        }\n      }\n    }\n    row++;\n  }\n\n  const rank = pivotCol.length;\n\n  // Check consistency\n  for (let r = rank; r < n; r++) {\n    if (aug[r][m] === 1) return null;\n  }\n\n  // Identify free variables\n  const pivotSet = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let j = 0; j < m; j++) {\n    if (!pivotSet.has(j)) freeVars.push(j);\n  }\n\n  const numFree = freeVars.length;\n\n  // For each pivot row r, the pivot variable pivotCol[r] equals:\n  //   aug[r][m] XOR sum(aug[r][freeVars[fi]] * freeVal[fi])\n  // We store which free vars affect each pivot\n  const pivotInfo: { col: number; base: number; freeIndices: number[] }[] = [];\n  for (let r = 0; r < rank; r++) {\n    const freeIndices: number[] = [];\n    for (let fi = 0; fi < numFree; fi++) {\n      if (aug[r][freeVars[fi]] === 1) {\n        freeIndices.push(fi);\n      }\n    }\n    pivotInfo.push({ col: pivotCol[r], base: aug[r][m], fre