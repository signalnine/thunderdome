  it(\"solves with overlapping buttons\", () => {","-    // 2 counters, 2 buttons, mod 5","-    // button 0 affects [0, 1], button 1 affects [1]","-    // target: counter 0 = 2, counter 1 = 3","-    // Equations: b0 = 2, b0 + b1 = 3 => b1 = 1","-    // Solution: [2, 1], total = 3","-    expect(solveCounter([2, 3], [[0, 1], [1]], 5)).toEqual([2, 1]);","+    const result = solveCounter([2, 3], [[0, 1], [1]], 5);","+    expect(result).toEqual([2, 1]);","+    expect(verifyCounter([2, 3], [[0, 1], [1]], 5, result!)).toBe(true);","   });","+","+  it(\"handles larger modulus\", () => {","+    // mod 97, simple case","+    const result = solveCounter([50], [[0]], 97);","+    expect(result).toEqual([50]);","+    expect(verifyCounter([50], [[0]], 97, result!)).toBe(true);","+  });","+","+  it(\"handles system with dependent equations\", () => {","+    // 3 counters, 2 buttons, mod 5","+    // button 0 affects [0, 1], button 1 affects [1, 2]","+    // target: [1, 2, 1]","+    // Equations: b0 = 1, b0 + b1 = 2, b1 = 1","+    // Solution: b0=1, b1=1","+    const result = solveCounter([1, 2, 1], [[0, 1], [1, 2]], 5);","+    expect(result).toEqual([1, 1]);","+    expect(verifyCounter([1, 2, 1], [[0, 1], [1, 2]], 5, result!)).toBe(true);","+  });","+","+  it(\"handles free variables with minimum total\", () => {","+    // 1 counter, 2 buttons both affecting counter 0, mod 5","+    // target: 2","+    // b0 + b1 = 2 (mod 5)","+    // Solutions: [0,2] total=2, [1,1] total=2, [2,0] total=2","+    // Also: [3,4] total=7, [4,3] total=7","+    // Minimum total = 2","+    // Lex smallest with total 2: [0, 2]","+    const result = solveCounter([2], [[0], [0]], 5);","+    expect(result).toEqual([0, 2]);","+    expect(verifyCounter([2], [[0], [0]], 5, result!)).toBe(true);","+  });","+","+  it(\"handles all-zero target with non-trivial buttons\", () => {","+    const result = solveCounter([0, 0], [[0, 1], [0], [1]], 7);","+    expect(result).toEqual([0, 0, 0]);","+  });","+","+  it(\"handles