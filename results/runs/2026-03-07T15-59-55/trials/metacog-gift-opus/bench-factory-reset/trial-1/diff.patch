s lexicographically smallest for tied press count\", () => {\n    // target: [T]\n    // button 0 toggles [0], button 1 toggles [0]\n    // Both are 1-press solutions: {0} and {1}\n    // Lex smallest: {0}\n    expect(\n      solveToggle({\n        target: [true],\n        buttons: [[0], [0]],\n      })\n    ).toEqual([0]);\n  });\n\n  it(\"handles overlapping buttons\", () => {\n    // target: [T, T, T]\n    // button 0: [0, 1, 2] -> press it => all on\n    expect(\n      solveToggle({\n        target: [true, true, true],\n        buttons: [[0, 1, 2]],\n      })\n    ).toEqual([0]);\n  });\n\n  it(\"handles no buttons with non-trivial target\", () => {\n    expect(\n      solveToggle({\n        target: [true],\n        buttons: [],\n      })\n    ).toBeNull();\n  });\n\n  it(\"handles no buttons with all-off target\", () => {\n    expect(\n      solveToggle({\n        target: [false, false],\n        buttons: [],\n      })\n    ).toEqual([]);\n  });\n\n  it(\"handles larger puzzle\", () => {\n    // 5 lights, 5 buttons each toggling one light => identity matrix\n    const result = solveToggle({\n      target: [true, false, true, false, true],\n      buttons: [[0], [1], [2], [3], [4]],\n    });\n    expect(result).toEqual([0, 2, 4]);\n  });\n\n  it(\"returns null for inconsistent system\", () => {\n    // 2 lights, 1 button toggling light 0\n    // target: light 0 on, light 1 on\n    // Can't turn light 1 on\n    expect(\n      solveToggle({\n        target: [true, true],\n        buttons: [[0]],\n      })\n    ).toBeNull();\n  });\n});\n\ndescribe(\"solveCounter\", () => {\n  it(\"returns all zeros when target is all zero\", () => {\n    expect(solveCounter([0, 0, 0], [[0, 1], [1, 2]], 5)).toEqual([0, 0]);\n  });\n\n  it(\"solves a simple single-button case\", () => {\n    // counter 0 target 3, button 0 affects counter 0, mod 5\n    // press 3 times\n    expect(solveCounter([3], [[0]], 5)).toEqual([3]);\n  });\n\n  it(\"returns null for impossible case\", () => {\n    // counter 0 target 1, no buttons, mod 5\n    expect(solveCounter([1], [], 5)).toBeNull();\n  });\n\n  it(\"solves with two independent buttons\", () => {\n    // counter 0 target 2, counter 1 target 3, mod 5\n    // button 0 affects [0], button 1 affects [1]\n    expect(solveCounter([2, 3], [[0], [1]], 5)).toEqual([2, 3]);\n  });\n\n  it(\"selects minimum total presses\", () => {\n    // counter 0 target 4, mod 5\n    // button 0 affects [0]\n    // press 4 times: total 4\n    // But also: mod 5, pressing 4 times = pressing -1 times = not possible\n    // Actually with mod 5, pressing 4 times gives counter value 4. That's the only option.\n    expect(solveCounter([4], [[0]], 5)).toEqual([4]);\n  });\n\n  it(\"handles modular arithmetic\", () => {\n    // counter 0 target 0, mod 3\n    // button 0 affects [0]\n    // Solutions: press 0 times (total 0) or press 3 times (but max is mod-1=2)\n    // So just 0\n    expect(solveCounter([0], [[0]], 3)).toEqual([0]);\n  });\n\n  it(\"returns null for inconsistent system with prime modulus\", () => {\n    // 2 counters, 1 button affecting both\n    // target: counter 0 = 1, counter 1 = 2, mod 3\n    // button 0 affects [0, 1]\n    // pressing x times: counter 0 = x, counter 1 = x\n    // Need x = 1 and x = 2 simultaneously: impossible\n    expect(solveCounter([1, 2], [[0, 1]], 3)).toBeNull();\n  });\n\n  it(\"selects lex smallest for tied total\", () => {\n    // 1 counter target 1, mod 3\n    // button 0 affects [0], button 1 affects [0]\n    // Solutions: [1, 0] total=1, [0, 1] total=1\n    // Lex smallest: [0, 1]\n    expect(solveCounter([1], [[0], [0]], 3)).toEqual([0, 1]);\n  });\n\n  it(\"handles larger system\", () => {\n    // 3 counters, 3 buttons (identity), mod 7\n    const result = solveCounter([1, 2, 3], [[0], [1], [2]], 7);\n    expect(result).toEqual([1, 2, 3]);\n  });\n\n  it(\"solves with overlapping buttons\", () => {\n    // 2 counters, 2 buttons, mod 5\n    // button 0 affects [0, 1], button 1 affects [1]\n    // target: counter 0 = 2, counter 1 = 3\n    // Equations: b0 = 2, b0 + b1 = 3 => b1 = 1\n    // Solution: [2, 1], total = 3\n    expect(solveCounter([2, 3], [[0, 1], [1]], 5)).toEqual([2, 1]);\n  });\n});\n"}}
