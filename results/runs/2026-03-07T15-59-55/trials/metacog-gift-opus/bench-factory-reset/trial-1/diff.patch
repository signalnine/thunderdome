ating free variable assignments\n  return findMinSolGF2(m, numFree, pivots, freeVars);\n}\n\nfunction findMinSolGF2(\n  m: number,\n  numFree: number,\n  pivots: { col: number; base: number; freeBits: number[] }[],\n  freeVars: number[]\n): number[] {\n  if (numFree === 0) {\n    // Unique solution\n    const sol = new Array(m).fill(0);\n    for (const p of pivots) sol[p.col] = p.base;\n    return solToIndices(sol);\n  }\n\n  // For up to ~25 free vars, brute force is fast enough\n  // For more, use meet-in-the-middle\n  if (numFree <= 25) {\n    return bruteForceFreeGF2(m, numFree, pivots, freeVars);\n  }\n  return mitmGF2(m, numFree, pivots, freeVars);\n}\n\nfunction bruteForceFreeGF2(\n  m: number,\n  numFree: number,\n  pivots: { col: number; base: number; freeBits: number[] }[],\n  freeVars: number[]\n): number[] {\n  let bestCount = m + 1;\n  let bestSol: number[] | null = null;\n\n  const total = 1 << numFree;\n  for (let mask = 0; mask < total; mask++) {\n    let count = popcount(mask, numFree);\n    if (count >= bestCount) continue;\n\n    const sol = new Array(m).fill(0);\n    for (let fi = 0; fi < numFree; fi++) {\n      if ((mask >> fi) & 1) sol[freeVars[fi]] = 1;\n    }\n\n    let skip = false;\n    for (const p of pivots) {\n      let val = p.base;\n      for (const fi of p.freeBits) val ^= (mask >> fi) & 1;\n      sol[p.col] = val;\n      count += val;\n      if (count >= bestCount) { skip = true; break; }\n    }\n    if (skip) continue;\n\n    if (count < bestCount || (count === bestCount && bestSol !== null && lexSmaller(sol, bestSol))) {\n      bestCount = count;\n      bestSol = sol;\n    }\n  }\n\n  return solToIndices(bestSol!);\n}\n\nfunction mitmGF2(\n  m: number,\n  numFree: number,\n  pivots: { col: number; base: number; freeBits: number[] }[],\n  freeVars: number[]\n): number[] {\n  const half1 = Math.floor(numFree / 2);\n  const half2 = numFree - half1;\n  const rank = pivots.length;\n\n  // Split pivot deps into halves\n  const pH1: numbe