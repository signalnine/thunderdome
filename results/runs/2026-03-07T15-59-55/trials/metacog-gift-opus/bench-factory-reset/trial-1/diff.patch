+interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const n = target.length;
+  const m = buttons.length;
+
+  // Build augmented matrix over GF(2): row per light, col per button
+  const aug: number[][] = [];
+  for (let i = 0; i < n; i++) {
+    const row = new Array(m + 1).fill(0);
+    for (let j = 0; j < m; j++) {
+      if (buttons[j].includes(i)) {
+        row[j] = 1;
+      }
+    }
+    row[m] = target[i] ? 1 : 0;
+    aug.push(row);
+  }
+
+  // Gaussian elimination (reduced row echelon form) over GF(2)
+  const pivotCols: number[] = [];
+  let curRow = 0;
+  for (let col = 0; col < m && curRow < n; col++) {
+    let pr = -1;
+    for (let r = curRow; r < n; r++) {
+      if (aug[r][col]) { pr = r; break; }
+    }
+    if (pr === -1) continue;
+    [aug[curRow], aug[pr]] = [aug[pr], aug[curRow]];
+    pivotCols.push(col);
+    for (let r = 0; r < n; r++) {
+      if (r !== curRow && aug[r][col]) {
+        for (let c = 0; c < m + 1; c++) aug[r][c] ^= aug[curRow][c];
+      }
+    }
+    curRow++;
+  }
+
+  const rank = pivotCols.length;
+
+  // Consistency check
+  for (let r = rank; r < n; r++) {
+    if (aug[r][m]) return null;
+  }
+
+  // Free variables
+  const pivotSet = new Set(pivotCols);
+  const freeVars: number[] = [];
+  for (let j = 0; j < m; j++) {
+    if (!pivotSet.has(j)) freeVars.push(j);
+  }
+  const numFree = freeVars.length;
+
+  // Build pivot dependency info
+  const pivots: { col: number; base: number; freeBits: number[] }[] = [];
+  for (let r = 0; r < rank; r++) {
+    const bits: number[] = [];
+    for (let fi = 0; fi < numFree; fi++) {
+      if (aug[r][freeVars[fi]]) bits.push(fi);
+    }
+    pivots.push({ col: pivotCols[r], base: aug[r][m], freeBits: bits });
+  }
+
+  // Find minimum-weight, lex-smallest solution by enumerating free variable assignments
+  return findMinSolGF2(m, numFree, pivots, freeVars);
+}
+
+function findMinSolGF2(
+  m: number,
+  numFree: number,
+  pivots: { col: number; base: number; freeBits: number[] }[],
+  freeVars: number[]
+): number[] {
+  if (numFree === 0) {
+    // Unique solution
+    const sol = new Array(m).fill(0);
+    for (const p of pivots) sol[p.col] = p.base;
+    return solToIndices(sol);
+  }
+
+  // For up to ~25 free vars, brute force is fast enough
+  // For more, use meet-in-the-middle
+  if (numFree <= 25) {
+    return bruteForceFreeGF2(m, numFree, pivots, freeVars);
+  }
+  return mitmGF2(m, numFree, pivots, freeVars);
+}
+
+function bruteForceFreeGF2(
+  m: number,
+  numFree: number,
+  pivots: { col: number; base: number; freeBits: number[] }[],
+  freeVars: number[]
+): number[] {
+  let bestCount = m + 1;
+  let bestSol: number[] | null = null;
+
+  const totalMasks = 1 << numFree;
+  for (let mask = 0; mask < totalMasks; mask++) {
+    let count = popcount(mask, numFree);
+    if (count > bestCount) continue;
+
+    const sol = new Array(m).fill(0);
+    for (let fi = 0; fi < numFree; fi++) {
+      if ((mask >> fi) & 1) sol[freeVars[fi]] = 1;
+    }
+
+    let skip = false;
+    for (const p of pivots) {
+      let val = p.base;
+      for (const fi of p.freeBits) val ^= (mask >> fi) & 1;
+      sol[p.col] = val;
+      count += val;
+      if (count > bestCount) { skip = true; break; }
+    }
+    if (skip) continue;
+
+    if (count < bestCount || (count === bestCount && bestSol !== null && setLexSmaller(sol, bestSol))) {
+      bestCount = count;
+      bestSol = sol;
+    }
+  }
+
+  return solToIndices(bestSol!);
+}
+
+function mitmGF2(
+  m: number,
+  numFree: number,
+  pivots: { col: number; base: number; freeBits: number[] }[],
+  freeVars: number[]
+): number[] {
+  const half1 = Math.floor(numFree / 2);
+  const half2 = numFree - half1;
+  const rank = pivots.length;
+
+  // Split pivot deps into halves
+  const pH1: number[][] = [];
+  const pH2: number[][] = [];
+  for (const p of pivots) {
+    const h1: number[] = [];
+    const h2: number[] = [];
+    for (const fi of p.freeBits) {
+      if (fi < half1) h1.push(fi);
+      else h2.push(fi - half1);
+    }
+    pH1.push(h1);
+    pH2.push(h2);
+  }
+
+  // Encode pivot signatures as integers for fast lookup
+  // sig is a rank-bit number where bit r = XOR contribution to pivot r
+  function computeSig1(mask: number): number {
+    let sig = 0;
+    for (let pi = 0; pi < rank; pi++) {
+      let x = 0;
+      for (const fi of pH1[pi]) x ^= (mask >> fi) & 1;
+      if (x) sig |= (1 << pi);
+    }
+    return sig;
+  }
+
+  function computeSig2(mask: number): number {
+    let sig = 0;
+    for (let pi = 0; pi < rank; pi++) {
+      let x = 0;
+      for (const fi of pH2[pi]) x ^= (mask >> fi) & 1;
+      if (x) sig |= (1 << pi);
+    }
+    return sig;
+  }
+
+  // Build first-half map: sig -> {count, mask}
+  // Keep minimum count entry per sig (then smallest mask for lex)
+  const firstMap = new Map<number, { count: number; mask: number }>();
+
+  for (let mask1 = 0; mask1 < (1 << half1); mask1++) {
+    const count1 = popcount(mask1, half1);
+    const sig = computeSig1(mask1);
+    const existing = firstMap.get(sig);
+    if (!existing || count1 < existing.count ||
+        (count1 === existing.count && mask1 < existing.mask)) {
+      firstMap.set(sig, { count: count1, mask: mask1 });
+    }
+  }
+
+  // Build second-half map: sig -> {count, mask}
+  const secondMap = new Map<number, { count: number; mask: number }>();
+
+  for (let mask2 = 0; mask2 < (1 << half2); mask2++) {
+    const count2 = popcount(mask2, half2);
+    const sig = computeSig2(mask2);
+    const existing = secondMap.get(sig);
+    if (!existing || count2 < existing.count ||
+        (count2 === existing.count && mask2 < existing.mask)) {
+      secondMap.set(sig, { count: count2, mask: mask2 });
+    }
+  }
+
+  // Compute base pivot signature
+  let baseSig = 0;
+  for (let pi = 0; pi < rank; pi++) {
+    if (pivots[pi].base) baseSig |= (1 << pi);
+  }
+
+  let bestCount = m + 1;
+  let bestSol: number[] | null = null;
+
+  // For each possible pivot outcome vector v (2^rank possibilities):
+  //   pivotCost = popcount(v)
+  //   required: baseSig ^ sig1 ^ sig2 = v => sig1 ^ sig2 = baseSig ^ v = targetSig
+  //   For each sig1 in firstMap: sig2 = sig1 ^ targetSig, look up in secondMap
+  for (let v = 0; v < (1 << rank); v++) {
+    const pivotCost = popcount(v, rank);
+    if (pivotCost >= bestCount) continue;
+
+    const targetSig = baseSig ^ v;
+
+    for (const [sig1, entry1] of firstMap) {
+      if (entry1.count + pivotCost > bestCount) continue;
+
+      const requiredSig2 = sig1 ^ targetSig;
+      const entry2 = secondMap.get(requiredSig2);
+      if (!entry2) continue;
+
+      const total = entry1.count + entry2.count + pivotCost;
+      if (total > bestCount) continue;
+
+      // Build solution
+      const sol = new Array(m).fill(0);
+      for (let fi = 0; fi < half1; fi++) {
+        if ((entry1.mask >> fi) & 1) sol[freeVars[fi]] = 1;
+      }
+      for (let fi = 0; fi < half2; fi++) {
+        if ((entry2.mask >> fi) & 1) sol[freeVars[half1 + fi]] = 1;
+      }
+      // Compute actual pivot values from v
+      for (let pi = 0; pi < rank; pi++) {
+        sol[pivots[pi].col] = (v >> pi) & 1;
+      }
+
+      if (total < bestCount || (total === bestCount && bestSol !== null && setLexSmaller(sol, bestSol))) {
+        bestCount = total;
+        bestSol = sol;
+      }
+    }
+  }
+
+  return solToIndices(bestSol!);
+}
+
+
+// For GF(2): compare solution vectors as sets of pressed indices.
+// At first differing position, having 1 (index in set) means smaller set.
+function setLexSmaller(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] !== b[i]) return a[i] > b[i]; // 1 > 0 means a has earlier index
+  }
+  return false;
+}
+
+function popcount(x: number, bits: number): number {
+  let c = 0;
+  for (let i = 0; i < bits; i++) {
+    if ((x >> i) & 1) c++;
+  }
+  return c;
+}
+
+function lexSmaller(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] !== b[i]) return a[i] < b[i];
+  }
+  return false;
+}
+
+function solToIndices(sol: number[]): number[] {
+  const result: number[] = [];
+  for (let i = 0; i < sol.length; i++) {
+    if (sol[i]) result.push(i);
+  }
+  return result;
+}
+
+// ============================================================
+// Part 2: Counter Puzzle over GF(p)
+// ============================================================
+
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const n = lights.length;
+  const m = buttons.length;
+
+  // Build augmented matrix [A | b] over GF(p)
+  const aug: number[][] = [];
+  for (let i = 0; i < n; i++) {
+    const row = new Array(m + 1).fill(0);
+    for (let j = 0; j < m; j++) {
+      if (buttons[j].includes(i)) {
+        row[j] = 1;
+      }
+    }
+    row[m] = ((lights[i] % modulus) + modulus) % modulus;
+    aug.push(row);
+  }
+
+  // Gaussian elimination (RREF) over GF(p)
+  const pivotCols: number[] = [];
+  let curRow = 0;
+
+  for (let col = 0; col < m && curRow < n; col++) {
+    let pr = -1;
+    for (let r = curRow; r < n; r++) {
+      if (aug[r][col]) { pr = r; break; }
+    }
+    if (pr === -1) continue;
+    [aug[curRow], aug[pr]] = [aug[pr], aug[curRow]];
+    pivotCols.push(col);
+
+    const inv = modInverse(aug[curRow][col], modulus);
+    for (let c = 0; c < m + 1; c++) {
+      aug[curRow][c] = (aug[curRow][c] * inv) % modulus;
+    }
+
+    for (let r = 0; r < n; r++) {
+      if (r !== curRow && aug[r][col]) {
+        const factor = aug[r][col];
+        for (let c = 0; c < m + 1; c++) {
+          aug[r][c] = ((aug[r][c] - factor * aug[curRow][c]) % modulus + modulus) % modulus;
+        }
+      }
+    }
+    curRow++;
+  }
+
+  const rank = pivotCols.length;
+
+  // Consistency check
+  for (let r = rank; r < n; r++) {
+    if (aug[r][m]) return null;
+  }
+
+  // Free variables
+  const pivotSet = new Set(pivotCols);
+  const freeVars: number[] = [];
+  for (let j = 0; j < m; j++) {
+    if (!pivotSet.has(j)) freeVars.push(j);
+  }
+  const numFree = freeVars.length;
+
+  // Pivot dependencies
+  const pivots: { col: number; base: number; deps: { fi: number; coeff: number }[] }[] = [];
+  for (let r = 0; r < rank; r++) {
+    const deps: { fi: number; coeff: number }[] = [];
+    for (let fi = 0; fi < numFree; fi++) {
+      if (aug[r][freeVars[fi]]) {
+        deps.push({ fi, coeff: aug[r][freeVars[fi]] });
+      }
+    }
+    pivots.push({ col: pivotCols[r], base: aug[r][m], deps });
+  }
+
+  if (numFree === 0) {
+    const sol = new Array(m).fill(0);
+    for (const p of pivots) sol[p.col] = p.base;
+    return sol;
+  }
+
+  // Decide enumeration strategy based on total combinations
+  const logTotal = numFree * Math.log2(modulus);
+  if (logTotal <= 27) { // ~134M combinations - brute force feasible within 5s
+    return bruteForceGFp(m, numFree, pivots, freeVars, modulus);
+  }
+  return mitmGFp(m, numFree, pivots, freeVars, modulus);
+}
+
+function bruteForceGFp(
+  m: number,
+  numFree: number,
+  pivots: { col: number; base: number; deps: { fi: number; coeff: number }[] }[],
+  freeVars: number[],
+  modulus: number
+): number[] {
+  let bestTotal = Infinity;
+  let bestSol: number[] | null = null;
+
+  const fv = new Array(numFree).fill(0);
+  for (let done = false; !done;) {
+    const sol = new Array(m).fill(0);
+    let total = 0;
+
+    for (let fi = 0; fi < numFree; fi++) {
+      sol[freeVars[fi]] = fv[fi];
+      total += fv[fi];
+    }
+
+    if (total <= bestTotal) {
+      let skip = false;
+      for (const p of pivots) {
+        let val = p.base;
+        for (const d of p.deps) {
+          val = ((val - d.coeff * fv[d.fi]) % modulus + modulus) % modulus;
+        }
+        sol[p.col] = val;
+        total += val;
+        if (total > bestTotal) { skip = true; break; }
+      }
+      if (!skip) {
+        if (total < bestTotal || (total === bestTotal && bestSol !== null && lexSmaller(sol, bestSol))) {
+          bestTotal = total;
+          bestSol = sol.slice();
+        }
+      }
+    }
+
+    // Increment odometer
+    done = true;
+    for (let fi = numFree - 1; fi >= 0; fi--) {
+      fv[fi]++;
+      if (fv[fi] >= modulus) { fv[fi] = 0; }
+      else { done = false; break; }
+    }
+  }
+
+  return bestSol!;
+}
+
+function mitmGFp(
+  m: number,
+  numFree: number,
+  pivots: { col: number; base: number; deps: { fi: number; coeff: number }[] }[],
+  freeVars: number[],
+  modulus: number
+): number[] {
+  // Split free vars: first half as small as possible to fit in memory,
+  // second half for iteration
+  const half1 = Math.floor(numFree / 2);
+  const half2 = numFree - half1;
+
+  // Split pivot deps
+  const pH1: { fi: number; coeff: number }[][] = [];
+  const pH2: { fi: number; coeff: number }[][] = [];
+  for (const p of pivots) {
+    const h1: { fi: number; coeff: number }[] = [];
+    const h2: { fi: number; coeff: number }[] = [];
+    for (const d of p.deps) {
+      if (d.fi < half1) h1.push(d);
+      else h2.push({ fi: d.fi - half1, coeff: d.coeff });
+    }
+    pH1.push(h1);
+    pH2.push(h2);
+  }
+
+  // Build first-half map: pivotContribution -> best {count, freeVals}
+  // Pivot contribution from first half for pivot pi:
+  //   sum(dep.coeff * fv[dep.fi]) mod p
+  const firstMap = new Map<string, { count: number; freeVals: number[] }>();
+
+  const fv1 = new Array(half1).fill(0);
+  for (let done1 = false; !done1;) {
+    let count = 0;
+    for (let fi = 0; fi < half1; fi++) count += fv1[fi];
+
+    const contribs: number[] = [];
+    for (let pi = 0; pi < pivots.length; pi++) {
+      let c = 0;
+      for (const d of pH1[pi]) c = (c + d.coeff * fv1[d.fi]) % modulus;
+      contribs.push(c);
+    }
+
+    const key = contribs.join(",");
+    const existing = firstMap.get(key);
+    if (!existing || count < existing.count ||
+        (count === existing.count && lexSmaller(fv1, existing.freeVals))) {
+      firstMap.set(key, { count, freeVals: fv1.slice() });
+    }
+
+    done1 = true;
+    for (let fi = half1 - 1; fi >= 0; fi--) {
+      fv1[fi]++;
+      if (fv1[fi] >= modulus) { fv1[fi] = 0; }
+      else { done1 = false; break; }
+    }
+  }
+
+  let bestTotal = Infinity;
+  let bestSol: number[] | null = null;
+
+  const fv2 = new Array(half2).fill(0);
+  for (let done2 = false; !done2;) {
+    let count2 = 0;
+    for (let fi = 0; fi < half2; fi++) count2 += fv2[fi];
+
+    if (count2 < bestTotal) {
+      const contribs2: number[] = [];
+      for (let pi = 0; pi < pivots.length; pi++) {
+        let c = 0;
+        for (const d of pH2[pi]) c = (c + d.coeff * fv2[d.fi]) % modulus;
+        contribs2.push(c);
+      }
+
+      // Ideal key: make all pivots 0
+      const idealContribs: number[] = [];
+      for (let pi = 0; pi < pivots.length; pi++) {
+        idealContribs.push(((pivots[pi].base - contribs2[pi]) % modulus + modulus) % modulus);
+      }
+      const idealKey = idealContribs.join(",");
+      const idealEntry = firstMap.get(idealKey);
+
+      if (idealEntry) {
+        const total = idealEntry.count + count2; // all pivots = 0
+        if (total < bestTotal) {
+          bestTotal = total;
+          bestSol = buildSolCounterMitm(m, freeVars, half1, idealEntry.freeVals, fv2.slice(), pivots, pH1, contribs2, modulus);
+        } else if (total === bestTotal) {
+          const candidate = buildSolCounterMitm(m, freeVars, half1, idealEntry.freeVals, fv2.slice(), pivots, pH1, contribs2, modulus);
+          if (bestSol === null || lexSmaller(candidate, bestSol)) {
+            bestSol = candidate;
+          }
+        }
+      }
+
+      // Check all first-half entries for potentially better solutions
+      // (non-zero pivots but lower free var count)
+      for (const [, entry] of firstMap) {
+        if (entry.count + count2 >= bestTotal) continue;
+
+        let pivotSum = 0;
+        for (let pi = 0; pi < pivots.length; pi++) {
+          let c1 = 0;
+          for (const d of pH1[pi]) c1 = (c1 + d.coeff * entry.freeVals[d.fi]) % modulus;
+          const pv = ((pivots[pi].base - c1 - contribs2[pi]) % modulus + modulus) % modulus;
+          pivotSum += pv;
+        }
+        const total = entry.count + count2 + pivotSum;
+        if (total < bestTotal) {
+          bestTotal = total;
+          bestSol = buildSolCounterMitm(m, freeVars, half1, entry.freeVals, fv2.slice(), pivots, pH1, contribs2, modulus);
+        } else if (total === bestTotal) {
+          const candidate = buildSolCounterMitm(m, freeVars, half1, entry.freeVals, fv2.slice(), pivots, pH1, contribs2, modulus);
+          if (bestSol === null || lexSmaller(candidate, bestSol)) {
+            bestSol = candidate;
+          }
+        }
+      }
+    }
+
+    done2 = true;
+    for (let fi = half2 - 1; fi >= 0; fi--) {
+      fv2[fi]++;
+      if (fv2[fi] >= modulus) { fv2[fi] = 0; }
+      else { done2 = false; break; }
+    }
+  }
+
+  return bestSol!;
+}
+
+function buildSolCounterMitm(
+  m: number,
+  freeVars: number[],
+  half1: number,
+  fv1: number[],
+  fv2: number[],
+  pivots: { col: number; base: number; deps: { fi: number; coeff: number }[] }[],
+  pH1: { fi: number; coeff: number }[][],
+  contribs2: number[],
+  modulus: number
+): number[] {
+  const sol = new Array(m).fill(0);
+  for (let fi = 0; fi < half1; fi++) sol[freeVars[fi]] = fv1[fi];
+  for (let fi = 0; fi < fv2.length; fi++) sol[freeVars[half1 + fi]] = fv2[fi];
+  for (let pi = 0; pi < pivots.length; pi++) {
+    let c1 = 0;
+    for (const d of pH1[pi]) c1 = (c1 + d.coeff * fv1[d.fi]) % modulus;
+    sol[pivots[pi].col] = ((pivots[pi].base - c1 - contribs2[pi]) % modulus + modulus) % modulus;
+  }
+  return sol;
+}
+
+function modInverse(a: number, mod: number): number {
+  let [old_r, r] = [((a % mod) + mod) % mod, mod];
+  let [old_s, s] = [1, 0];
+  while (r !== 0) {
+    const q = Math.floor(old_r / r);
+    [old_r, r] = [r, old_r - q * r];
+    [old_s, s] = [s, old_s - q * s];
+  }
+  return ((old_s % mod) + mod) % mod;
+}
