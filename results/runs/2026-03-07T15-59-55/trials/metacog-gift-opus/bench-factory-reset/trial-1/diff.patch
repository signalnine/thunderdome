ee = freeVars.length;\n  for (let fi = half1; fi < numFree; fi++) {\n    if ((mask2 >> (fi - half1)) & 1) sol[freeVars[fi]] = 1;\n  }\n  for (let pi = 0; pi < pivots.length; pi++) {\n    sol[pivots[pi].col] = pivots[pi].base ^ sig1[pi] ^ sig2[pi];\n  }\n  return sol;\n}\n\nfunction popcount(x: number, bits: number): number {\n  let c = 0;\n  for (let i = 0; i < bits; i++) {\n    if ((x >> i) & 1) c++;\n  }\n  return c;\n}\n\nfunction lexSmaller(a: number[], b: number[]): boolean {\n  for (let i = 0; i < a.length; i++) {\n    if (a[i] !== b[i]) return a[i] < b[i];\n  }\n  return false;\n}\n\nfunction solToIndices(sol: number[]): number[] {\n  const result: number[] = [];\n  for (let i = 0; i < sol.length; i++) {\n    if (sol[i]) result.push(i);\n  }\n  return result;\n}\n\n// ============================================================\n// Part 2: Counter Puzzle over GF(p)\n// ============================================================\n\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const n = lights.length;\n  const m = buttons.length;\n\n  // Build augmented matrix [A | b] over GF(p)\n  const aug: number[][] = [];\n  for (let i = 0; i < n; i++) {\n    const row = new Array(m + 1).fill(0);\n    for (let j = 0; j < m; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    row[m] = ((lights[i] % modulus) + modulus) % modulus;\n    aug.push(row);\n  }\n\n  // Gaussian elimination (RREF) over GF(p)\n  const pivotCols: number[] = [];\n  let curRow = 0;\n\n  for (let col = 0; col < m && curRow < n; col++) {\n    let pr = -1;\n    for (let r = curRow; r < n; r++) {\n      if (aug[r][col]) { pr = r; break; }\n    }\n    if (pr === -1) continue;\n    [aug[curRow], aug[pr]] = [aug[pr], aug[curRow]];\n    pivotCols.push(col);\n\n    const inv = modInverse(aug[curRow][col], modulus);\n    for (let c = 0; c < m + 1; c++) {\n      aug[curRow][c] = (aug[curRow][c] * inv) % modu