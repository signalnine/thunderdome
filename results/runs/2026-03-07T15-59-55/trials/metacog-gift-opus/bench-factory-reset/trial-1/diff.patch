 b1 = 2, b1 = 1\n    // Solution: b0=1, b1=1\n    const result = solveCounter([1, 2, 1], [[0, 1], [1, 2]], 5);\n    expect(result).toEqual([1, 1]);\n    expect(verifyCounter([1, 2, 1], [[0, 1], [1, 2]], 5, result!)).toBe(true);\n  });\n\n  it(\"handles free variables with minimum total\", () => {\n    // 1 counter, 2 buttons both affecting counter 0, mod 5\n    // target: 2\n    // b0 + b1 = 2 (mod 5)\n    // Solutions: [0,2] total=2, [1,1] total=2, [2,0] total=2\n    // Also: [3,4] total=7, [4,3] total=7\n    // Minimum total = 2\n    // Lex smallest with total 2: [0, 2]\n    const result = solveCounter([2], [[0], [0]], 5);\n    expect(result).toEqual([0, 2]);\n    expect(verifyCounter([2], [[0], [0]], 5, result!)).toBe(true);\n  });\n\n  it(\"handles all-zero target with non-trivial buttons\", () => {\n    const result = solveCounter([0, 0], [[0, 1], [0], [1]], 7);\n    expect(result).toEqual([0, 0, 0]);\n  });\n\n  it(\"handles medium system with mod 3\", () => {\n    // 5 counters, 5 buttons (identity), mod 3\n    const target = [1, 2, 0, 1, 2];\n    const buttons = [[0], [1], [2], [3], [4]];\n    const result = solveCounter(target, buttons, 3);\n    expect(result).toEqual([1, 2, 0, 1, 2]);\n    expect(verifyCounter(target, buttons, 3, result!)).toBe(true);\n  });\n});\n","structuredPatch":[{"oldStart":1,"oldLines":127,"newStart":1,"newLines":148,"lines":[" import { describe, it, expect } from \"vitest\";"," import { solveToggle, solveCounter } from \"./index.js\";"," ","+// Helper: verify a toggle solution is correct","+function verifyToggle(","+  target: boolean[],","+  buttons: number[][],","+  solution: number[] | null","+): boolean {","+  if (solution === null) return true; // null means no solution; can't verify","+  const state = new Array(target.length).fill(false);","+  for (const bi of solution) {","+    for (const li of buttons[bi]) {","+      state[li] = !state[li];","+    }","+  }","+  return state.every((v, i) => v === target[i]);","+}","+","+// He