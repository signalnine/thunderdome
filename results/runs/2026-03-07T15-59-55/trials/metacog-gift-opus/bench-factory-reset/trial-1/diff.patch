ount1 + freeCount2 + pivotCount\n    // To minimize total: want pivotCount minimal\n    // The ideal: xor1[r] = base[r] ^ xor2[r] for all r (making all pivots 0)\n\n    // Try all first-half entries (we must since different keys give different pivot counts)\n    // But we can optimize: iterate firstMap entries and compute pivotCount\n    for (const [keyStr, arr] of firstMap) {\n      const xor1 = keyStr.split(\",\").map(Number);\n      let pivotCount = 0;\n      for (let pi = 0; pi < pivotInfo.length; pi++) {\n        pivotCount += pivotInfo[pi].base ^ xor1[pi] ^ pivotXors2[pi];\n      }\n\n      // Best from this key is arr[0] (sorted by freeCount)\n      const best1 = arr[0];\n      const total = best1.freeCount + freeCount2 + pivotCount;\n      if (total > bestTotal) continue;\n\n      if (total < bestTotal) {\n        bestTotal = total;\n        bestSol = buildSolMitm(m, freeVars, half1, best1.mask, mask2, pivotInfo, xor1, pivotXors2);\n      } else {\n        // Same total, check lex\n        // Need to find best lex among all arr entries with same total\n        for (const entry of arr) {\n          if (entry.freeCount + freeCount2 + pivotCount > bestTotal) break;\n          const candidate = buildSolMitm(m, freeVars, half1, entry.mask, mask2, pivotInfo, xor1, pivotXors2);\n          if (bestSol === null || lexSmaller(candidate, bestSol)) {\n            bestSol = candidate;\n          }\n        }\n      }\n    }\n  }\n\n  return solToIndices(bestSol!);\n}\n\nfunction buildSolMitm(\n  m: number,\n  freeVars: number[],\n  half1: number,\n  mask1: number,\n  mask2: number,\n  pivotInfo: { col: number; base: number; freeIndices: number[] }[],\n  xor1: number[],\n  xor2: number[]\n): number[] {\n  const sol = new Array(m).fill(0);\n  for (let fi = 0; fi < half1; fi++) {\n    if ((mask1 >> fi) & 1) sol[freeVars[fi]] = 1;\n  }\n  const numFree = freeVars.length;\n  const half2 = numFree - half1;\n  for (let fi = 0; fi < half2; fi++) {\n    if ((mask2 >> fi) & 1) sol