 this.repo.reserve(item.productId, item.quantity);\n      if (!success) {\n        // Rollback previous reservations\n        for (const res of reservations) {\n          this.repo.release(res.productId, res.quantity);\n        }\n        throw new Error(\n          `Insufficient stock for product ${item.productId}`\n        );\n      }\n      reservations.push({ productId: item.productId, quantity: item.quantity });\n    }\n\n    await this.eventBus.emit(ORDER_EVENTS.STOCK_RESERVED, {\n      orderId: event.orderId,\n      items: reservations,\n      timestamp: Date.now(),\n    });\n  }\n\n  private async handleOrderCancelled(data: unknown): Promise<void> {\n    const event = data as OrderCancelledEvent;\n    // Release reserved stock — look up original order items from the event\n    // The order service attaches items to the cancellation event\n    const eventWithItems = data as OrderCancelledEvent & {\n      items?: Array<{ productId: string; quantity: number }>;\n      status?: string;\n    };\n\n    if (eventWithItems.status !== 'cancelled') return;\n\n    if (eventWithItems.items) {\n      for (const item of eventWithItems.items) {\n        this.repo.release(item.productId, item.quantity);\n      }\n    }\n\n    await this.eventBus.emit(ORDER_EVENTS.STOCK_RELEASED, {\n      orderId: event.orderId,\n      timestamp: Date.now(),\n    });\n  }\n\n  setStock(productId: string, quantity: number): void {\n    this.repo.setStock(productId, quantity);\n  }\n\n  getStock(productId: string) {\n    return this.repo.getStock(productId);\n  }\n}\n","numLines":72,"startLine":1,"totalLines":72}}}
