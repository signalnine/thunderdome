diff --git a/src/deps/deps.test.ts b/src/deps/deps.test.ts
new file mode 100644
index 0000000..0635215
--- /dev/null
+++ b/src/deps/deps.test.ts
@@ -0,0 +1,116 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { createDepsService } from './index.js';
+import { createRegistry } from '../registry/index.js';
+import type { DepsService, RegistryService, PluginManifest } from '../types.js';
+
+function makeManifest(
+  name: string,
+  deps: Record<string, string> = {}
+): PluginManifest {
+  return {
+    name,
+    version: '1.0.0',
+    description: `${name} plugin`,
+    author: 'tester',
+    dependencies: deps,
+    entryPoint: 'true',
+    permissions: [],
+  };
+}
+
+describe('DependencyGraph', () => {
+  let depsService: DepsService;
+  let registry: RegistryService;
+
+  beforeEach(() => {
+    depsService = createDepsService();
+    registry = createRegistry();
+  });
+
+  it('should build a tree with no dependencies', () => {
+    registry.register(makeManifest('a'));
+    const tree = depsService.buildTree('a', registry);
+    expect(tree.name).toBe('a');
+    expect(tree.version).toBe('1.0.0');
+    expect(tree.dependencies).toHaveLength(0);
+  });
+
+  it('should build a tree with dependencies', () => {
+    registry.register(makeManifest('a', { b: '^1.0.0', c: '^1.0.0' }));
+    registry.register(makeManifest('b'));
+    registry.register(makeManifest('c', { d: '^1.0.0' }));
+    registry.register(makeManifest('d'));
+
+    const tree = depsService.buildTree('a', registry);
+    expect(tree.name).toBe('a');
+    expect(tree.dependencies).toHaveLength(2);
+    expect(tree.dependencies[0].name).toBe('b');
+    expect(tree.dependencies[1].name).toBe('c');
+    expect(tree.dependencies[1].dependencies[0].name).toBe('d');
+  });
+
+  it('should handle unknown plugins in tree', () => {
+    const tree = depsService.buildTree('unknown', registry);
+    expect(tree.name).toBe('unknown');
+    expect(tree.version).toBe('unknown');
+  });
+
+  it('should detect no cycles in acyclic graph', () => {
+    registry.register(makeManifest('a', { b: '^1.0.0' }));
+    registry.register(makeManifest('b'));
+    const cycles = depsService.detectCycles('a', registry);
+    expect(cycles).toBeNull();
+  });
+
+  it('should detect circular dependencies', () => {
+    registry.register(makeManifest('a', { b: '^1.0.0' }));
+    registry.register(makeManifest('b', { a: '^1.0.0' }));
+    const cycles = depsService.detectCycles('a', registry);
+    expect(cycles).not.toBeNull();
+    expect(cycles!.length).toBeGreaterThan(0);
+  });
+
+  it('should detect transitive circular dependencies', () => {
+    registry.register(makeManifest('a', { b: '^1.0.0' }));
+    registry.register(makeManifest('b', { c: '^1.0.0' }));
+    registry.register(makeManifest('c', { a: '^1.0.0' }));
+    const cycles = depsService.detectCycles('a', registry);
+    expect(cycles).not.toBeNull();
+  });
+
+  it('should do topological sort', () => {
+    registry.register(makeManifest('a', { b: '^1.0.0', c: '^1.0.0' }));
+    registry.register(makeManifest('b', { d: '^1.0.0' }));
+    registry.register(makeManifest('c'));
+    registry.register(makeManifest('d'));
+
+    const sorted = depsService.topologicalSort('a', registry);
+    expect(sorted.indexOf('d')).toBeLessThan(sorted.indexOf('b'));
+    expect(sorted.indexOf('b')).toBeLessThan(sorted.indexOf('a'));
+    expect(sorted.indexOf('c')).toBeLessThan(sorted.indexOf('a'));
+    expect(sorted).toContain('a');
+  });
+
+  it('should flatten dependencies', () => {
+    registry.register(makeManifest('a', { b: '^1.0.0', c: '^1.0.0' }));
+    registry.register(makeManifest('b', { d: '^1.0.0' }));
+    registry.register(makeManifest('c'));
+    registry.register(makeManifest('d'));
+
+    const flat = depsService.flattenDependencies('a', registry);
+    expect(flat).toContain('b');
+    expect(flat).toContain('c');
+    expect(flat).toContain('d');
+    expect(flat).not.toContain('a');
+  });
+
+  it('should check hasCircularDependency', () => {
+    registry.register(makeManifest('a', { b: '^1.0.0' }));
+    registry.register(makeManifest('b'));
+    expect(depsService.hasCircularDependency('a', registry)).toBe(false);
+
+    registry.register(makeManifest('x', { y: '^1.0.0' }));
+    registry.register(makeManifest('y', { x: '^1.0.0' }));
+    expect(depsService.hasCircularDependency('x', registry)).toBe(true);
+  });
+});
