+import { describe, it, expect, beforeEach } from 'vitest';
+import { createRunner } from './index.js';
+import type { RunnerService } from '../types.js';
+
+describe('SandboxedRunner', () => {
+  let runner: RunnerService;
+
+  beforeEach(() => {
+    runner = createRunner();
+  });
+
+  it('should execute simple code and return result', async () => {
+    const result = await runner.execute('2 + 2');
+    expect(result.success).toBe(true);
+    expect(result.output).toBe(4);
+    expect(result.duration).toBeGreaterThanOrEqual(0);
+    expect(result.memoryUsed).toBeGreaterThanOrEqual(0);
+  });
+
+  it('should execute code with context', async () => {
+    const result = await runner.execute('x + y', { x: 10, y: 20 });
+    expect(result.success).toBe(true);
+    expect(result.output).toBe(30);
+  });
+
+  it('should handle errors gracefully', async () => {
+    const result = await runner.execute('throw new Error("test error")');
+    expect(result.success).toBe(false);
+    expect(result.error).toBe('test error');
+  });
+
+  it('should handle syntax errors', async () => {
+    const result = await runner.execute('function {{{ invalid');
+    expect(result.success).toBe(false);
+    expect(result.error).toBeDefined();
+  });
+
+  it('should enforce timeouts', async () => {
+    const result = await runner.executeWithTimeout('while(true) {}', 100);
+    expect(result.success).toBe(false);
+    expect(result.error).toBeDefined();
+  });
+
+  it('should provide console.log captured output', async () => {
+    const result = await runner.execute('console.log("hello world")');
+    expect(result.success).toBe(true);
+  });
+
+  it('should track duration', async () => {
+    const result = await runner.execute('let s = 0; for(let i=0;i<10000;i++) s+=i; s');
+    expect(result.success).toBe(true);
+    expect(result.duration).toBeGreaterThan(0);
+  });
+
+  it('should isolate context between executions', async () => {
+    await runner.execute('var secret = 42');
+    const result = await runner.execute('typeof secret');
+    expect(result.output).toBe('undefined');
+  });
+});
