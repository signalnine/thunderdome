    gA.out = b;\n    gB.out = a;\n    gateByOutput.set(a, gB);\n    gateByOutput.set(b, gA);\n    swapped.add(a);\n    swapped.add(b);\n  }\n\n  // Bit-by-bit tracing approach.\n  // For each bit, verify the expected adder structure and fix swaps.\n  let carry = '';\n\n  // Bit 0: x00 XOR y00 -> z00, x00 AND y00 -> carry\n  {\n    const xorGate = findGate('XOR', 'x00', 'y00')!;\n    if (xorGate.out !== 'z00') {\n      doSwap(xorGate.out, 'z00');\n    }\n\n    const andGate = findGate('AND', 'x00', 'y00')!;\n    carry = andGate.out;\n\n    // Check if carry has a structural problem (e.g., swapped with z)\n    // Carry should NOT be a z wire (except possibly zFinal for 1-bit adder)\n    if (carry.startsWith('z') && carry !== zFinal) {\n      // Carry from bit 0 should feed into XOR and AND for bit 1\n      // Find the non-initial XOR for bit 1 that should use carry\n      const x01 = 'x01';\n      const y01 = 'y01';\n      const xorXY1 = findGate('XOR', x01, y01);\n      if (xorXY1) {\n        // The non-initial XOR for bit 1 should use carry and partial sum\n        // If carry is wrongly named as a z wire, find the correct wire\n        // by looking at what the non-initial XOR actually references\n        const xorGates1 = findGatesWithInput(xorXY1.out, 'XOR');\n        for (const g of xorGates1) {\n          if (g !== xorXY1) {\n            // This is the non-initial XOR for bit 1\n            const otherInput =\n              g.in1 === xorXY1.out ? g.in2 : g.in1;\n            if (otherInput !== carry) {\n              doSwap(carry, otherInput);\n              carry = otherInput;\n            }\n            break;\n          }\n        }\n      }\n    }\n  }\n\n  // Bits 1..N-1\n  for (let i = 1; i < numBits; i++) {\n    const nn = i.toString().padStart(2, '0');\n    const x = `x${nn}`;\n    const y = `y${nn}`;\n    const z = `z${nn}`;\n\n    // Step 1: Find initial XOR (xNN XOR yNN)\n    const xorXY = findGate('XOR', x, y)!;\n    let t = xorXY.out;\n\n    // Step 2: Find non-initial XOR (t XOR carry -> z)\n    let xorTC = findGate('XOR', t, carry);\n\n    if (!xorTC) {\n      // Either t or carry has been swapped with something else.\n      // Strategy: find the non-initial XOR that uses carry as input.\n      // Its other input should be t, but if t was swapped, it won't match.\n      const xorWithCarry = findGatesWithInput(carry, 'XOR').filter(\n        (g) => !hasXYInput(g)\n      );\n      if (xorWithCarry.length === 1) {\n        // Found the non-initial XOR that uses carry. Its other input\n        // is what t should be — but t was swapped.\n        const correctT =\n          xorWithCarry[0].in1 === carry\n            ? xorWithCarry[0].in2\n            : xorWithCarry[0].in1;\n        doSwap(t, correctT);\n        t = correctT;\n        xorTC = xorWithCarry[0];\n      } else {\n        // carry might be swapped. Find the non-initial XOR that uses t.\n        const xorWithT = findGatesWithInput(t, 'XOR').filter(\n          (g) => !hasXYInput(g)\n        );\n        if (xorWithT.length === 1) {\n          const correctCarry =\n            xorWithT[0].in1 === t ? xorWithT[0].in2 : xorWithT[0].in1;\n          doSwap(carry, correctCarry);\n          carry = correctCarry;\n          xorTC = xorWithT[0];\n        }\n      }\n    }\n\n    if (xorTC) {\n      // The output should be z\n      if (xorTC.out !== z) {\n        doSwap(xorTC.out, z);\n      }\n    }\n\n    // Step 3: Find AND gates and OR gate for carry computation\n    const andXY = findGate('AND', x, y)!;\n    const a = andXY.out;\n\n    const andTC = findGate('AND', t, carry);\n    if (!andTC) {\n      // This shouldn't happen after fixing t and carry above.\n      // If it does, skip this bit.\n      continue;\n    }\n    const b = andTC.out;\n\n    // Step 4: Find OR gate (a OR b -> carry_out)\n    let orAB = findGate('OR', a, b);\n\n    if (!orAB) {\n      // a or b has been swapped. Find the OR gate that uses one of them.\n      const orWithA = findGatesWithInput(a, 'OR');\n      const orWithB = findGatesWithInput(b, 'OR');\n\n      if (orWithA.length === 1) {\n        const correctB =\n          orWithA[0].in1 === a ? orWithA[0].in2 : orWithA[0].in1;\n        doSwap(b, correctB);\n        orAB = orWithA[0];\n      } else if (orWithB.length === 1) {\n        const correctA =\n          orWithB[0].in1 === b ? orWithB[0].in2 : orWithB[0].in1;\n        doSwap(a, correctA);\n        orAB = orWithB[0];\n      }\n    }\n\n    if (orAB) {\n      carry = orAB.out;\n    }\n\n    // For the last bit, carry should be zFinal\n    if (i === numBits - 1 && carry !== zFinal) {\n      doSwap(carry, zFinal);\n      carry = zFinal;\n    }\n  }\n\n  return [...swapped].sort();\n}","originalFile":"export interface Gate {\n  op: 'AND' | 'OR' | 'XOR';\n  in1: string;\n  in2: string;\n  out: string;\n}\n\nexport function simulate(\n  gates: Gate[],\n  inputs: Record<string, number>\n): Record<string, number> {\n  const wires: Record<string, number> = { ...inputs };\n  const remaining = [...gates];\n  let changed = true;\n\n  while (remaining.length > 0 && changed) {\n    changed = false;\n    for (let i = remaining.length - 1; i >= 0; i--) {\n      const gate = remaining[i];\n      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {\n        const a = wires[gate.in1];\n        const b = wires[gate.in2];\n        switch (gate.op) {\n          case 'AND':\n            wires[gate.out] = a & b;\n            break;\n          case 'OR':\n            wires[gate.out] = a | b;\n            break;\n          case 'XOR':\n            wires[gate.out] = a ^ b;\n            break;\n        }\n        remaining.splice(i, 1);\n        changed = true;\n      }\n    }\n  }\n\n  return wires;\n}\n\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Work on a copy so we don't mutate the caller's data\n  const gs: Gate[] = gates.map((g) => ({ ...g }));\n\n  const gateByOutput = new Map<string, Gate>();\n  for (const g of gs) {\n    gateByOutput.set(g.out, g);\n  }\n\n  function findGate(op: string, a: string, b: string): Gate | undefined {\n    for (const g of gs) {\n      if (\n        g.op === op &&\n        ((g.in1 === a && g.in2 === b) || (g.in1 === b && g.in2 === a))\n      ) {\n        return g;\n      }\n    }\n    return undefined;\n  }\n\n  // Determine number of input bits\n  let maxBit = 0;\n  for (const g of gs) {\n    for (const w of [g.in1, g.in2, g.out]) {\n      const m = w.match(/^[xy](\\d+)$/);\n      if (m) {\n        maxBit = Math.max(maxBit, parseInt(m[1], 10));\n      }\n    }\n  }\n  const numBits = maxBit + 1;\n  const zFinal = `z${numBits.toString().padStart(2, '0')}`;\n\n  const swapped = new Set<string>();\n\n  function doSwap(a: string, b: string): void {\n    const gA = gateByOutput.get(a)!;\n    const gB = gateByOutput.get(b)!;\n    gA.out = b;\n    gB.out = a;\n    gateByOutput.set(a, gB);\n    gateByOutput.set(b, gA);\n    swapped.add(a);\n    swapped.add(b);\n  }\n\n  // Helper: check if a wire is used as input to a gate with given op\n  function isInputTo(wire: string, op: string): boolean {\n    for (const g of gs) {\n      if (g.op === op && (g.in1 === wire || g.in2 === wire)) {\n        return true;\n      }\n    }\n    return false;\n  }\n\n  function hasXYInput(g: Gate): boolean {\n    return /^[xy]\\d+$/.test(g.in1) || /^[xy]\\d+$/.test(g.in2);\n  }\n\n  // Phase 1: Structural rules to detect and fix obvious swaps.\n  // We iterate fixing one swap at a time until no more structural violations found.\n  for (let iteration = 0; iteration < 10 && swapped.size < 8; iteration++) {\n    let foundSwap = false;\n\n    for (const g of gs) {\n      const out = g.out;\n\n      if (g.op === 'XOR' && hasXYInput(g)) {\n        const bitStr = g.in1.slice(1);\n        if (bitStr === '00') {\n          // Bit 0 initial XOR should output z00\n          if (out !== 'z00') {\n            doSwap(out, 'z00');\n            foundSwap = true;\n            break;\n          }\n        } else {\n          // Other bits: initial XOR should NOT output z\n          if (out.startsWith('z')) {\n            for (const g2 of gs) {\n              if (\n                g2.op === 'XOR' &&\n                !hasXYInput(g2) &&\n                (g2.in1 === out || g2.in2 === out)\n              ) {\n                doSwap(out, g2.out);\n                foundSwap = true;\n                break;\n              }\n            }\n            if (foundSwap) break;\n          } else if (!isInputTo(out, 'XOR')) {\n            // Output doesn't feed into any XOR - it's been swapped\n            const zWire = `z${bitStr}`;\n            const zGate = gateByOutput.get(zWire);\n            if (zGate && zGate.op === 'XOR') {\n              const inp1Gate = gateByOutput.get(zGate.in1);\n              const inp2Gate = gateByOutput.get(zGate.in2);\n              let swapPartner: string | undefined;\n              if (\n                inp1Gate &&\n                (inp1Gate.op === 'OR' ||\n                  (inp1Gate.op === 'AND' && hasXYInput(inp1Gate)))\n              ) {\n                swapPartner = zGate.in2;\n              } else if (\n                inp2Gate &&\n                (inp2Gate.op === 'OR' ||\n                  (inp2Gate.op === 'AND' && hasXYInput(inp2Gate)))\n              ) {\n                swapPartner = zGate.in1;\n              }\n              if (swapPartner) {\n                doSwap(out, swapPartner);\n                foundSwap = true;\n                break;\n              }\n            }\n          }\n        }\n      } else if (g.op === 'XOR' && !hasXYInput(g)) {\n        // Non-initial XOR should output z (but not zFinal)\n        if (!out.startsWith('z')) {\n          let bitFromInput: string | undefined;\n          for (const inp of [g.in1, g.in2]) {\n            const inputGate = gateByOutput.get(inp);\n            if (\n              inputGate &&\n              inputGate.op === 'XOR' &&\n              hasXYInput(inputGate)\n            ) {\n              bitFromInput = inputGate.in1.slice(1);\n              break;\n            }\n          }\n          if (bitFromInput) {\n            const zWire = `z${bitFromInput}`;\n            doSwap(out, zWire);\n            foundSwap = true;\n            break;\n          }\n        }\n        // Non-initial XOR should NOT output zFinal\n        if (out === zFinal) {\n          // Find the OR gate that should output zFinal but outputs something else\n          for (const g2 of gs) {\n            if (\n              g2.op === 'OR' &&\n              g2.out.startsWith('z') &&\n              g2.out !== zFinal\n            ) {\n              doSwap(out, g2.out);\n              foundSwap = true;\n              break;\n            }\n          }\n          if (foundSwap) break;\n        }\n      } else if (g.op === 'AND') {\n        if (hasXYInput(g) && /00$/.test(g.in1)) continue;\n        if (!isInputTo(out, 'OR')) {\n          // AND output doesn't feed into OR - find the swap partner\n          if (out.startsWith('z') && out !== zFinal) {\n            for (const g2 of gs) {\n              if (g2.op === 'OR') {\n                const in1Gate = gateByOutput.get(g2.in1);\n                const in2Gate = gateByOutput.get(g2.in2);\n                if (\n                  in1Gate &&\n                  in1Gate.op !== 'AND' &&\n                  in1Gate.out !== out\n                ) {\n                  doSwap(out, in1Gate.out);\n                  foundSwap = true;\n                  break;\n                }\n                if (\n                  in2Gate &&\n                  in2Gate.op !== 'AND' &&\n                  in2Gate.out !== out\n                ) {\n                  doSwap(out, in2Gate.out);\n                  foundSwap = true;\n                  break;\n                }\n              }\n            }\n            if (foundSwap) break;\n          }\n        }\n      } else if (g.op === 'OR') {\n        if (out.startsWith('z') && out !== zFinal) {\n          // OR should not output z (except zFinal)\n          // Find swap partner: non-initial XOR not outputting z, or\n          // non-initial XOR outputting zFinal\n          for (const g2 of gs) {\n            if (\n              g2.op === 'XOR' &&\n              !hasXYInput(g2) &&\n              (!g2.out.startsWith('z') || g2.out === zFinal)\n            ) {\n              doSwap(out, g2.out);\n              foundSwap = true;\n              break;\n            }\n          }\n          if (foundSwap) break;\n        }\n      }\n    }\n\n    if (!foundSwap) break;\n  }\n\n  // Phase 2: Simulation-based detection for remaining \"transparent\" swaps.\n  // If we haven't found all 8 swapped wires yet, use simulation to find them.\n  if (swapped.size < 8) {\n    // Try to find swaps by testing the adder with known inputs\n    // For each bit position, test if it computes correctly\n    // If a bit is wrong, identify the swap by trying candidates\n\n    // Build the set of all output wires (potential swap candidates)\n    const allOutputs = gs.map((g) => g.out);\n\n    // Test the circuit with a few test cases to find which bits are broken\n    function testCircuit(testGates: Gate[]): boolean {\n      // Test with a few different input pairs\n      for (const [x, y] of [\n        [0, 0],\n        [1, 0],\n        [0, 1],\n        [1, 1],\n      ]) {\n        const inputs: Record<string, number> = {};\n        for (let i = 0; i < numBits; i++) {\n          const nn = i.toString().padStart(2, '0');\n          inputs[`x${nn}`] = i === 0 ? x : 0;\n          inputs[`y${nn}`] = i === 0 ? y : 0;\n        }\n        const result = simulate(testGates, inputs);\n        const expected = x + y;\n        let actual = 0;\n        for (let i = 0; i <= numBits; i++) {\n          const nn = i.toString().padStart(2, '0');\n          if (result[`z${nn}`]) {\n            actual |= 1 << i;\n          }\n        }\n        if (actual !== expected) return false;\n      }\n      // Test with all bits set\n      const inputs2: Record<string, number> = {};\n      for (let i = 0; i < numBits; i++) {\n        const nn = i.toString().padStart(2, '0');\n        inputs2[`x${nn}`] = 1;\n        inputs2[`y${nn}`] = 1;\n      }\n      const result2 = simulate(gs, inputs2);\n      const allOnes = (1 << numBits) - 1;\n      const expected2 = allOnes + allOnes;\n      let actual2 = 0;\n      for (let i = 0; i <= numBits; i++) {\n        const nn = i.toString().padStart(2, '0');\n        if (result2[`z${nn}`]) {\n          actual2 |= 1 << i;\n        }\n      }\n      if (actual2 !== expected2) return false;\n      return true;\n    }\n\n    // Find which bit first fails by testing each bit position\n    function findFirstBrokenBit(): number {\n      for (let bit = 0; bit < numBits; bit++) {\n        // Test with carry propagation up to this bit\n        const inputs: Record<string, number> = {};\n        for (let i = 0; i < numBits; i++) {\n          const nn = i.toString().padStart(2, '0');\n          inputs[`x${nn}`] = i === bit ? 1 : 0;\n          inputs[`y${nn}`] = i === bit ? 1 : 0;\n        }\n        const result = simulate(gs, inputs);\n        // Expected: bit position should be 0, bit+1 should be 1 (carry)\n        const zBit = `z${bit.toString().padStart(2, '0')}`;\n        const zNext = `z${(bit + 1).toString().padStart(2, '0')}`;\n        if (result[zBit] !== 0 || result[zNext] !== 1) {\n          return bit;\n        }\n      }\n      return -1;\n    }\n\n    if (!testCircuit(gs)) {\n      const brokenBit = findFirstBrokenBit();\n      if (brokenBit >= 0) {\n        // Try swapping each pair of outputs in the vicinity of the broken bit\n        // to find which pair fixes the issue\n        const candidateWires: string[] = [];\n        // Collect wires related to the broken bit and adjacent bits\n        for (const g of gs) {\n          // Check if this gate is related to the broken bit area\n          for (const w of [g.in1, g.in2]) {\n        