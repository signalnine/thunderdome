       if (foundSwap) break;\n        }\n        // Also check: OR gate output should be used as input to XOR and AND\n        if (!out.startsWith('z') && out !== zFinal) {\n          if (!isInputTo(out, 'XOR') && !isInputTo(out, 'AND')) {\n            // OR output isn't used as carry input anywhere — it's swapped\n            // This case might be complex. Skip for now, other rules should catch it.\n          }\n        }\n      }\n    }\n\n    if (!foundSwap) break;\n  }\n\n  return [...swapped].sort();\n}","originalFile":"export interface Gate {\n  op: 'AND' | 'OR' | 'XOR';\n  in1: string;\n  in2: string;\n  out: string;\n}\n\nexport function simulate(\n  gates: Gate[],\n  inputs: Record<string, number>\n): Record<string, number> {\n  const wires: Record<string, number> = { ...inputs };\n  const remaining = [...gates];\n  let changed = true;\n\n  while (remaining.length > 0 && changed) {\n    changed = false;\n    for (let i = remaining.length - 1; i >= 0; i--) {\n      const gate = remaining[i];\n      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {\n        const a = wires[gate.in1];\n        const b = wires[gate.in2];\n        switch (gate.op) {\n          case 'AND':\n            wires[gate.out] = a & b;\n            break;\n          case 'OR':\n            wires[gate.out] = a | b;\n            break;\n          case 'XOR':\n            wires[gate.out] = a ^ b;\n            break;\n        }\n        remaining.splice(i, 1);\n        changed = true;\n      }\n    }\n  }\n\n  return wires;\n}\n\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Build lookup structures\n  const gateByOutput = new Map<string, Gate>();\n  for (const g of gates) {\n    gateByOutput.set(g.out, g);\n  }\n\n  // Find a gate by its op and input wires (order-independent)\n  function findGate(op: string, a: string, b: string): Gate | undefined {\n    for (const g of gates) {\n      if (\n        g.op === op &&\n        ((g.in1 === a && g.in2 === b) || (g.in1 === b && g.in2 === a))\n      ) {\n        return g;\n      }\n    }\n    return undefined;\n  }\n\n  // Determine number of input bits\n  let maxBit = 0;\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2, g.out]) {\n      const m = w.match(/^[xy](\\d+)$/);\n      if (m) {\n        maxBit = Math.max(maxBit, parseInt(m[1], 10));\n      }\n    }\n  }\n  const numBits = maxBit + 1;\n\n  const swapped = new Set<string>();\n\n  function swap(a: string, b: string): void {\n    // Swap the output wires of two gates\n    const gA = gateByOutput.get(a)!;\n    const gB = gateByOutput.get(b)!;\n    gA.out = b;\n    gB.out = a;\n    gateByOutput.set(a, gB);\n    gateByOutput.set(b, gA);\n    swapped.add(a);\n    swapped.add(b);\n  }\n\n  // Walk through the adder structure bit by bit and verify/fix\n  // Bit 0: x00 XOR y00 -> z00, x00 AND y00 -> c00\n  // We trace the expected structure and when we find a mismatch, we identify the swap.\n\n  let carry = '';\n\n  // Bit 0\n  {\n    const x = 'x00';\n    const y = 'y00';\n    const z = 'z00';\n\n    const xorGate = findGate('XOR', x, y);\n    if (xorGate && xorGate.out !== z) {\n      // xorGate.out should be z00 - find what currently outputs z00 and swap\n      swap(xorGate.out, z);\n    }\n\n    const andGate = findGate('AND', x, y);\n    carry = andGate!.out;\n  }\n\n  // Bits 1..N-1\n  for (let i = 1; i < numBits; i++) {\n    const x = `x${i.toString().padStart(2, '0')}`;\n    const y = `y${i.toString().padStart(2, '0')}`;\n    const z = `z${i.toString().padStart(2, '0')}`;\n\n    // Step 1: xNN XOR yNN -> tNN (partial sum)\n    const xorXY = findGate('XOR', x, y);\n    if (!xorXY) continue;\n    let t = xorXY.out;\n\n    // Step 2: tNN XOR carry -> zNN (final sum)\n    let xorTC = findGate('XOR', t, carry);\n\n    if (!xorTC) {\n      // The carry or t might be swapped. Let's check if there's a XOR gate\n      // that uses carry and produces z - then its other input should be t\n      // Or check if there's a XOR gate that uses t and produces z\n      // Actually, if t is swapped with something, we need to find the XOR\n      // gate that uses carry as one input.\n\n      // Find any XOR gate that has carry as an input (not xNN/yNN)\n      let xorWithCarry: Gate | undefined;\n      for (const g of gates) {\n        if (\n          g.op === 'XOR' &&\n          (g.in1 === carry || g.in2 === carry) &&\n          !g.in1.match(/^[xy]\\d+$/) &&\n          !g.in2.match(/^[xy]\\d+$/)\n        ) {\n          xorWithCarry = g;\n          break;\n        }\n      }\n\n      if (xorWithCarry) {\n        // The other input should be t, but t was swapped\n        const otherInput =\n          xorWithCarry.in1 === carry ? xorWithCarry.in2 : xorWithCarry.in1;\n        swap(t, otherInput);\n        t = otherInput;\n        xorTC = xorWithCarry;\n      }\n    }\n\n    if (xorTC) {\n      // The output should be zNN\n      if (xorTC.out !== z) {\n        swap(xorTC.out, z);\n      }\n    }\n\n    // Step 3: xNN AND yNN -> aNN (generate carry)\n    const andXY = findGate('AND', x, y);\n    if (!andXY) continue;\n    const a = andXY.out;\n\n    // Step 4: tNN AND carry -> bNN (propagate carry)\n    const andTC = findGate('AND', t, carry);\n    if (!andTC) continue;\n    const b = andTC.out;\n\n    // Step 5: aNN OR bNN -> cNN (carry out)\n    let orAB = findGate('OR', a, b);\n\n    if (!orAB) {\n      // a or b might be swapped. Let's try to find the OR gate that uses\n      // one of them and determine the swap.\n      let orWithA: Gate | undefined;\n      let orWithB: Gate | undefined;\n      for (const g of gates) {\n        if (g.op === 'OR') {\n          if (g.in1 === a || g.in2 === a) orWithA = g;\n          if (g.in1 === b || g.in2 === b) orWithB = g;\n        }\n      }\n\n      if (orWithA) {\n        const otherInput =\n          orWithA.in1 === a ? orWithA.in2 : orWithA.in1;\n        swap(b, otherInput);\n        orAB = orWithA;\n      } else if (orWithB) {\n        const 