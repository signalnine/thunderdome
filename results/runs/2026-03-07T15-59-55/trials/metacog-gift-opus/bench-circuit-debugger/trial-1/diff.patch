 {\n            if (\n              g2.op === 'XOR' &&\n              !hasXYInput(g2) &&\n              (!g2.out.startsWith('z') || g2.out === zFinal)\n            ) {\n              doSwap(out, g2.out);\n              foundSwap = true;\n              break;\n            }\n          }\n          if (foundSwap) break;\n        }\n      }\n    }\n\n    if (!foundSwap) break;\n  }\n\n  // Phase 2: Simulation-based detection for remaining \"transparent\" swaps.\n  // If we haven't found all 8 swapped wires yet, use simulation to find them.\n  if (swapped.size < 8) {\n    // Try to find swaps by testing the adder with known inputs\n    // For each bit position, test if it computes correctly\n    // If a bit is wrong, identify the swap by trying candidates\n\n    // Build the set of all output wires (potential swap candidates)\n    const allOutputs = gs.map((g) => g.out);\n\n    // Test the circuit with a few test cases to find which bits are broken\n    function testCircuit(testGates: Gate[]): boolean {\n      // Test with a few different input pairs\n      for (const [x, y] of [\n        [0, 0],\n        [1, 0],\n        [0, 1],\n        [1, 1],\n      ]) {\n        const inputs: Record<string, number> = {};\n        for (let i = 0; i < numBits; i++) {\n          const nn = i.toString().padStart(2, '0');\n          inputs[`x${nn}`] = i === 0 ? x : 0;\n          inputs[`y${nn}`] = i === 0 ? y : 0;\n        }\n        const result = simulate(testGates, inputs);\n        const expected = x + y;\n        let actual = 0;\n        for (let i = 0; i <= numBits; i++) {\n          const nn = i.toString().padStart(2, '0');\n          if (result[`z${nn}`]) {\n            actual |= 1 << i;\n          }\n        }\n        if (actual !== expected) return false;\n      }\n      // Test with all bits set\n      const inputs2: Record<string, number> = {};\n      for (let i = 0; i < numBits; i++) {\n        const nn = i.toString().padStart(2, '0');\n        inputs2[`x${nn}`] = 1;\n        inputs2[`y${nn}`] = 1;\n      }\n      const result2 = simulate(gs, inputs2);\n      const allOnes = (1 << numBits) - 1;\n      const expected2 = allOnes + allOnes;\n      let actual2 = 0;\n      for (let i = 0; i <= numBits; i++) {\n        const nn = i.toString().padStart(2, '0');\n        if (result2[`z${nn}`]) {\n          actual2 |= 1 << i;\n        }\n      }\n      if (actual2 !== expected2) return false;\n      return true;\n    }\n\n    // Find which bit first fails by testing each bit position\n    function findFirstBrokenBit(): number {\n      for (let bit = 0; bit < numBits; bit++) {\n        // Test with carry propagation up to this bit\n        const inputs: Record<string, number> = {};\n        for (let i = 0; i < numBits; i++) {\n          const nn = i.toString().padStart(2, '0');\n          inputs[`x${nn}`] = i === bit ? 1 : 0;\n          inputs[`y${nn}`] = i === bit ? 1 : 0;\n        }\n        const result = simulate(gs, inputs);\n        // Expected: bit position should be 0, bit+1 should be 1 (carry)\n        const zBit = `z${bit.toString().padStart(2, '0')}`;\n        const zNext = `z${(bit + 1).toString().padStart(2, '0')}`;\n        if (result[zBit] !== 0 || result[zNext] !== 1) {\n          return bit;\n        }\n      }\n      return -1;\n    }\n\n    if (!testCircuit(gs)) {\n      const brokenBit = findFirstBrokenBit();\n      if (brokenBit >= 0) {\n        // Try swapping each pair of outputs in the vicinity of the broken bit\n        // to find which pair fixes the issue\n        const candidateWires: string[] = [];\n        // Collect wires related to the broken bit and adjacent bits\n        for (const g of gs) {\n          // Check if this gate is related to the broken bit area\n          for (const w of [g.in1, g.in2]) {\n            const m = w.match(/^[xy](\\d+)$/);\n            if (m) {\n              const b = parseInt(m[1], 10);\n              if (Math.abs(b - brokenBit) <= 1) {\n                candidateWires.push(g.out);\n              }\n            }\n          }\n        }\n        // Also add wires used by gates in the area\n        const wireSet = new Set(candidateWires);\n        for (const g of gs) {\n          if (wireSet.has(g.in1) || wireSet.has(g.in2)) {\n            wireSet.add(g.out);\n          }\n          if (wireSet.has(g.out)) {\n            wireSet.add(g.in1);\n            wireSet.add(g.in2);\n          }\n        }\n        // Add all gate outputs that reference candidate wires as inputs\n        for (const g of gs) {\n          if (wireSet.has(g.in1) || wireSet.has(g.in2)) {\n            wireSet.add(g.out);\n          }\n        }\n        const candidates = [...wireSet].filter(\n          (w) =>\n            !w.match(/^[xy]\\d+$/) &&\n            !swapped.has(w) &&\n            gateByOutput.has(w)\n        );\n\n        // Try all pairs of candidates\n        for (let i = 0; i < candidates.length && swapped.size < 8; i++) {\n          for (let j = i + 1; j < candidates.length; j++) {\n            const a = candidates[i];\n            const b = candidates[j];\n            // Temporarily swap\n            const gA = gateByOutput.get(a)!;\n            const gB = gateByOutput.get(b)!;\n            gA.out = b;\n            gB.out = a;\n            gateByOutput.set(a, gB);\n            gateByOutput.set(b, gA);\n\n            if (testCircuit(gs)) {\n              swapped.add(a);\n              swapped.add(b);\n              break;\n            }\n\n            // Undo swap\n            gA.out = a;\n            gB.out = b;\n            gateByOutput.set(a, gA);\n            gateByOutput.set(b, gB);\n          }\n        }\n      }\n    }\n  }\n\n  return [...swapped].sort();\n}","originalFile":"export interface Gate {\n  op: 'AND' | 'OR' | 'XOR';\n  in1: string;\n  in2: string;\n  out: string;\n}\n\nexport function simulate(\n  gates: Gate[],\n  inputs: Record<string, number>\n): Record<string, number> {\n  const wires: Record<string, number> = { ...inputs };\n  const remaining = [...gates];\n  let changed = true;\n\n  while (remaining.length > 0 && changed) {\n    changed = false;\n    for (let i = remaining.length - 1; i >= 0; i--) {\n      const gate = remaining[i];\n      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {\n        const a = wires[gate.in1];\n        const b = wires[gate.in2];\n        switch (gate.op) {\n          case 'AND':\n            wires[gate.out] = a & b;\n            break;\n          case 'OR':\n            wires[gate.out] = a | b;\n            break;\n          case 'XOR':\n            wires[gate.out] = a ^ b;\n            break;\n        }\n        remaining.splice(i, 1);\n        changed = true;\n      }\n    }\n  }\n\n  return wires;\n}\n\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Work on a copy so we don't mutate the caller's data\n  const gs: Gate[] = gates.map((g) => ({ ...g }));\n\n  const gateByOutput = new Map<string, Gate>();\n  for (const g of gs) {\n    gateByOutput.set(g.out, g);\n  }\n\n  function findGate(op: string, a: string, b: string): Gate | undefined {\n    for (const g of gs) {\n      if (\n        g.op === op &&\n        ((g.in1 === a && g.in2 === b) || (g.in1 === b && g.in2 === a))\n      ) {\n        return g;\n      }\n    }\n    return undefined;\n  }\n\n  // Determine number of input bits\n  let maxBit = 0;\n  for (const g of gs) {\n    for (const w of [g.in1, g.in2, g.out]) {\n      const m = w.match(/^[xy](\\d+)$/);\n      if (m) {\n        maxBit = Math.max(maxBit, parseInt(m[1], 10));\n      }\n    }\n  }\n  const numBits = maxBit + 1;\n  const zFinal = `z${numBits.toString().padStart(2, '0')}`;\n\n  const swapped = new Set<string>();\n\n  function doSwap(a: string, b: string): void {\n    const gA = gateByOutput.get(a)!;\n    const gB = gateByOutput.get(b)!;\n    gA.out = b;\n    gB.out = a;\n    gateByOutput.set(a, gB);\n    gateByOutput.set(b, gA);\n    swapped.add(a);\n    swapped.add(b);\n  }\n\n  // Helper: check if a wire is used as input to a gate with given op\n  function isInputTo(wire: string, op: string): boolean {\n    for (const g of gs) {\n      if (g.op === op && (g.in1 === wire || g.in2 === wire)) {\n        return true;\n      }\n    }\n    return false;\n  }\n\n  function hasXYInput(g: Gate): boolean {\n    return /^[xy]\\d+$/.test(g.in1) || /^[xy]\\d+$/.test(g.in2);\n  }\n\n  // Apply structural rules to detect swapped wires.\n  // In a correct ripple-carry adder:\n  //\n  // Rule 1: z-outputs (except z00 and zFinal) must come from non-initial XOR gates\n  //         (XOR gates whose inputs are NOT x/y wires).\n  // Rule 2: XOR gates with x/y inputs (except bit 0) must NOT output to z directly.\n  //         Their output should feed into another XOR gate.\n  // Rule 3: AND gates (except the bit-0 AND: x00 AND y00) should output to an OR gate.\n  // Rule 4: OR gates should NOT output to z (except zFinal which is the carry out).\n  //         OR gate outputs should be used as input to both XOR and AND gates.\n  // Rule 5: Non-initial XOR gates (inputs not x/y) must output to z.\n\n  // We iterate and fix swaps. Each iteration may fix one swap, so we repeat.\n  // With 4 swaps, at most 4 iterations are needed.\n\n  for (let iteration = 0; iteration < 8 && swapped.size < 8; iteration++) {\n    let foundSwap = false;\n\n    for (const g of gs) {\n      const out = g.out;\n\n      if (g.op === 'XOR' && hasXYInput(g)) {\n        // This is an initial XOR (xNN XOR yNN -> partial sum)\n        // For bit 0, output should be z00\n        // For other bits, output should NOT be z and should feed into another XOR\n        const bitStr = g.in1.slice(1);\n        if (bitStr === '00') {\n          if (out !== 'z00') {\n            doSwap(out, 'z00');\n            foundSwap = true;\n            break;\n          }\n        } else {\n          // Output should not be a z wire\n          if (out.startsWith('z')) {\n            // This XOR's output is wrongly going to a z wire.\n            // Find the non-initial XOR that should output this z wire.\n            // That gate's output should be swapped with ours.\n            // The non-initial XOR that should go to this z is the one\n            // whose output was swapped to be something other than this z.\n            // Actually, we can find the correct target: there should be\n            // a non-initial XOR gate whose output is NOT a z and should be.\n            // But it's simpler: we know this gate's output should feed into\n            // another XOR. If it outputs z, z is wrong. Find the gate\n            // that currently outputs the wire that this should output,\n            // but that's complex. Instead, use rule 5:\n            // The non-initial XOR whose output should be this z must have\n            // had its output swapped to something else. But we don't know\n            // which. Instead, find what our output *should* be:\n            // Our output should feed into another XOR gate. But since it's\n            // wrongly set to z, and the correct z should come from a\n            // non-initial XOR, we need to find the partner.\n            // The non-initial XOR for this bit would have this gate's output\n            // as one of its inputs. Let's find it.\n\n            // Actually, simpler: our output should NOT be z. The correct\n            // output wire is something that feeds into a XOR and AND.\n            // The gate currently producing that wire should be swapped with us.\n            // We don't know which wire. But we can apply rule 5 to find\n            // the non-initial XOR that outputs a non-z wire and should output z.\n            // That non-initial XOR for the same bit has this gate's output\n            // as one input. But we don't know the carry input name.\n            // Let's just look for the counterpart using the bit number.\n\n            // For bit N (N>0), the z output should come from a gate\n            // XOR(t, carry) where t is what we produce. But t is currently\n            // set to a z-wire, so the downstream XOR gate uses this z as input.\n            // Find the XOR gate that has our output (the z-wire) as input.\n            for (const g2 of gs) {\n              if (\n                g2.op === 'XOR' &&\n                !hasXYInput(g2) &&\n                (g2.in1 === out || g2.in2 === out)\n              ) {\n                // g2 is the non-initial XOR using our output. Its output\n                // should be this z-wire but isn't. Swap them.\n                doSwap(out, g2.out);\n                foundSwap = true;\n                break;\n              }\n            }\n            if (foundSwap) break;\n          } else if (!isInputTo(out, 'XOR')) {\n            // Output doesn't go to any XOR — it's been swapped with something.\n            // Find the non-initial XOR for this bit. It reads carry and partial sum.\n            // We know the partial sum wire name (out), but no XOR reads it.\n            // The XOR that should read it must be reading the swapped partner instead.\n            // Find that XOR: it's the one that outputs the corresponding z wire.\n            const zWire = `z${bitStr}`;\n            const zGate = gateByOutput.get(zWire);\n            if (zGate && zGate.op === 'XOR') {\n              // This XOR gate reads carry and some wire that was swapped with our output.\n              // The swapped partner is whichever of its inputs is not the carry.\n              // We need to figure out which input is carry and which is the\n              // swapped partner. The carry should come from an OR gate (or AND for bit 0).\n              const inp1Gate = gateByOutput.get(zGate.in1);\n              const inp2Gate = gateByOutput.get(zGate.in2);\n              // The carry input comes from OR (or AND for bit 1's carry from bit 0)\n              // The swapped partner comes from whatever replaced our output\n              let swapPartner: string | undefined;\n              if (inp1Gate && (inp1Gate.op === 'OR' || (inp1Gate.op === 'AND' && hasXYInput(inp1Gate)))) {\n                swapPartner = zGate.in2;\n              } else if (inp2Gate && (inp2Gate.op === 'OR' || (inp2Gate.op === 'AND' && hasXYInput(inp2Gate)))) {\n                swapPartner = zGate.in1;\n              }\n              if (swapPartner) {\n                doSwap(out, swapPartner);\n                foundSwap = true;\n                break;\n              }\n            }\n          }\n        }\n      } else if (g.op === 'XOR' && !hasXYInput(g)) {\n        // Non-initial XOR: should output to z\n        if (!out.startsWith('z')) {\n          // Should output z. Find the correct z for this bit.\n          // This is tricky without knowing the bit number.\n          // But we know that the z wire should exist and be produced by\n          // some other gate incorrectly.\n          // Actually, the simplest rule: this gate should output z,\n          // so swap our output with whatever z-wire is misconfigured.\n          // We can determine the bit from the input wires:\n          // One input is carry (from OR or AND), other is partial sum (from XOR with x/y).\n          // The partial sum input tells us the bit number.\n          let bitFromInput: string | undefined;\n          for (const inp of [g.in1, g.in2]) {\n            const inputGate = gateByOutput.get(inp);\n            if (inputGate && inputGate.op === 'XOR' && hasXYInput(inputGate)) {\n              bitFromInput = inputGate.in1.slice(1);\n              break;\n            }\n          }\n          if (bitFromInput) {\n            const zWire = `z${bitFromInput}`;\n            doSwap(out, zWire);\n            foundSwap = true;\n            break;\n          }\n        }\n      } else if (g.op === 'AND') {\n        // AND gate output should feed into an OR gate\n        // Exception: x00 AND y00 produces the initial carry, which feeds\n        // into XOR and AND (not OR) for bit 1. So skip bit 0's AND.\n        if (hasXYInput(g) && /00$/.test(g.in1)) continue;\n\n        if (!isInputTo(out, 'OR')) {\n          // Our output doesn't feed into any OR. It's been swapped.\n          // The correct wire should feed into an OR gate.\n          // Our output currently goes somewhere wrong.\n          // If our output is a z-wire, we can find the correct swap partner.\n          if (out.startsWith('z') && out !== zFinal) {\n            // Find what should output this z wire (a non-initial XOR).\n            // Actually, just find the OR gate that should use our output.\n            // Our gate's output should be one of the inputs to the OR gate\n            // for the same bit's carry computation.\n            // The OR gate for this bit takes two AND outputs.\n            // Find the OR gate that has a \"hole\" — one of its inputs\n            // doesn't come from an AND gate (because it was swapped).\n            for (const g2 of gs) {\n              if (g2.op === 'OR') {\n                const in1Gate = gateByOutput.get(g2.in1);\n                const in2Gate = gateByOutput.get(g2.in2);\n                if (in1Gate && in1Gate.op !== 'AND' && in1Gate.out !== out) {\n                  // in1 doesn't come from AND — it's the swap partner\n                  doSwap(out, in1Gate.out);\n                  foundSwap = true;\n                  break;\n                }\n                if (in2Gate && in2Gate.op !== 'AND' && in2Gate.out !== out) {\n                  doSwap(out, in2Gate.out);\n                  foundSwap = true;\n                  break;\n                }\n              }\n            }\n            if (foundSwap) break;\n          }\n        }\n      } else if (g.op === 'OR') {\n        // OR gate output should NOT be a z-wire (except zFinal)\n        if (out.startsWith('z') && out !== zFinal) {\n          // This OR outputs to z incorrectly. It should output carry.\n          // The correct z output should come from a non-initial XOR.\n          // Find the XOR gate that should output this z but currently outputs\n          // something else.\n          const zWire = out; // e.g., z03\n          // Find the non-initial XOR whose output should be this z.\n          // We can find it by: it's the XOR whose inputs are (partial_sum, carry)\n          // for the corresponding bit. But that's hard to determine directly.\n          // Instead: the OR gate's output should be carry (not z).\n          // The wire it should output is used as input to a XOR and AND gate\n          // downstream. Find the non-initial XOR that currently has a\n          // mismatched output.\n\n          // Actually, use a different approach: find the gate that currently\n          // outputs the wire that our OR gate should output.\n          // Our OR gate computes carry for some bit. That carry is used as\n          // input to the XOR and AND gates of the next bit.\n          // But we don't easily know which bit.\n\n          // Simpler: find the non-initial XOR that doesn't output a z-wire\n          // but should. That's the swap partner.\n          for (const g2 of gs) {\n            if (\n              g2.op === 'XOR' &&\n              !hasXYInput(g2) &&\n              !g2.out.startsWith('z')\n            ) {\n              doSwap(out, g2.out);\n              foundSwap = true;\n              break;\n            }\n          }\n          if (foundSwap) break;\n        }\n        // Also check: OR gate output should be used as input to XOR and AND\n        if (!out.startsWith('z') && out !== zFinal) {\n          if (!isInputTo(out, 'XOR') && !isInputTo(out, 'AND')) {\n            // OR output isn't used as carry input anywhere — it's swapped\n            // This case might be complex. Skip for now, other rules should catch it.\n          }\n        }\n      }\n    }\n\n    if (!foundSwap) break;\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[{"oldStart":101,"oldLines":82,"newStart":101,"newLines":32,"lines":["     return /^[xy]\\d+$/.te