+import express from 'express';
+import { createServer, Server } from 'http';
+import { createDb, DocumentStore } from './db.js';
+import { createRouter } from './routes.js';
+import { CollaborationServer } from './collaboration.js';
+
+export interface AppInstance {
+  app: express.Express;
+  start(port?: number): Promise<number>;
+  stop(): Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db = createDb(dbPath);
+  const store = new DocumentStore(db);
+
+  const app = express();
+  app.use(express.json());
+  app.use('/api', createRouter(store));
+
+  let httpServer: Server | null = null;
+  let collaboration: CollaborationServer | null = null;
+
+  return {
+    app,
+    async start(port = 0): Promise<number> {
+      return new Promise((resolve, reject) => {
+        httpServer = createServer(app);
+        collaboration = new CollaborationServer(httpServer, store);
+
+        httpServer.on('error', reject);
+        httpServer.listen(port, () => {
+          const addr = httpServer!.address();
+          if (addr && typeof addr === 'object') {
+            resolve(addr.port);
+          } else {
+            resolve(port);
+          }
+        });
+      });
+    },
+    async stop(): Promise<void> {
+      if (collaboration) {
+        collaboration.closeAll();
+        collaboration = null;
+      }
+      if (httpServer) {
+        await new Promise<void>((resolve, reject) => {
+          httpServer!.close((err) => {
+            if (err) reject(err);
+            else resolve();
+          });
+        });
+        httpServer = null;
+      }
+      db.close();
+    },
+  };
+}
