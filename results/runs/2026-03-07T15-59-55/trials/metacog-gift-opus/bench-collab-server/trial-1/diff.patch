+import { describe, it, expect, beforeAll, afterAll, beforeEach, afterEach } from 'vitest';
+import { createApp, AppInstance } from './server.js';
+import WebSocket from 'ws';
+
+// Helper to make HTTP requests
+async function request(
+  port: number,
+  method: string,
+  path: string,
+  body?: unknown
+): Promise<{ status: number; body: unknown }> {
+  const res = await fetch(`http://localhost:${port}${path}`, {
+    method,
+    headers: body ? { 'Content-Type': 'application/json' } : {},
+    body: body ? JSON.stringify(body) : undefined,
+  });
+  const text = await res.text();
+  let parsed: unknown;
+  try {
+    parsed = JSON.parse(text);
+  } catch {
+    parsed = text;
+  }
+  return { status: res.status, body: parsed };
+}
+
+// Helper to connect a WebSocket and get the sync message
+function connectWs(
+  port: number,
+  docId: string
+): Promise<{ ws: WebSocket; sync: { type: string; content: string; version: number; docId: string } }> {
+  return new Promise((resolve, reject) => {
+    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/${docId}`);
+    ws.on('error', reject);
+    ws.on('message', (data) => {
+      const msg = JSON.parse(data.toString());
+      if (msg.type === 'sync') {
+        resolve({ ws, sync: msg });
+      }
+    });
+    // Timeout after 5s
+    setTimeout(() => reject(new Error('WebSocket connection timeout')), 5000);
+  });
+}
+
+// Helper to wait for a specific message type from a WebSocket
+function waitForMessage(
+  ws: WebSocket,
+  type: string,
+  timeout = 5000
+): Promise<Record<string, unknown>> {
+  return new Promise((resolve, reject) => {
+    const timer = setTimeout(() => reject(new Error(`Timeout waiting for ${type}`)), timeout);
+    const handler = (data: WebSocket.Data) => {
+      const msg = JSON.parse(data.toString());
+      if (msg.type === type) {
+        clearTimeout(timer);
+        ws.off('message', handler);
+        resolve(msg);
+      }
+    };
+    ws.on('message', handler);
+  });
+}
+
+describe('REST API', () => {
+  let appInstance: AppInstance;
+  let port: number;
+
+  beforeAll(async () => {
+    appInstance = createApp();
+    port = await appInstance.start(0);
+  });
+
+  afterAll(async () => {
+    await appInstance.stop();
+  });
+
+  it('should create a document', async () => {
+    const res = await request(port, 'POST', '/api/documents', {
+      title: 'Test Doc',
+      content: 'Hello World',
+    });
+    expect(res.status).toBe(201);
+    const doc = res.body as Record<string, unknown>;
+    expect(doc.title).toBe('Test Doc');
+    expect(doc.content).toBe('Hello World');
+    expect(doc.id).toBeDefined();
+  });
+
+  it('should require title when creating', async () => {
+    const res = await request(port, 'POST', '/api/documents', { content: 'No title' });
+    expect(res.status).toBe(400);
+  });
+
+  it('should list documents', async () => {
+    const res = await request(port, 'GET', '/api/documents');
+    expect(res.status).toBe(200);
+    expect(Array.isArray(res.body)).toBe(true);
+  });
+
+  it('should get a document by id', async () => {
+    const createRes = await request(port, 'POST', '/api/documents', {
+      title: 'Get Test',
+      content: 'Get content',
+    });
+    const doc = createRes.body as Record<string, string>;
+
+    const res = await request(port, 'GET', `/api/documents/${doc.id}`);
+    expect(res.status).toBe(200);
+    expect((res.body as Record<string, string>).title).toBe('Get Test');
+  });
+
+  it('should return 404 for non-existent document', async () => {
+    const res = await request(port, 'GET', '/api/documents/non-existent');
+    expect(res.status).toBe(404);
+  });
+
+  it('should update a document', async () => {
+    const createRes = await request(port, 'POST', '/api/documents', {
+      title: 'Update Test',
+      content: 'Original',
+    });
+    const doc = createRes.body as Record<string, string>;
+
+    const res = await request(port, 'PUT', `/api/documents/${doc.id}`, {
+      title: 'Updated Title',
+      content: 'Updated content',
+    });
+    expect(res.status).toBe(200);
+    expect((res.body as Record<string, string>).title).toBe('Updated Title');
+    expect((res.body as Record<string, string>).content).toBe('Updated content');
+  });
+
+  it('should delete a document', async () => {
+    const createRes = await request(port, 'POST', '/api/documents', {
+      title: 'Delete Test',
+    });
+    const doc = createRes.body as Record<string, string>;
+
+    const res = await request(port, 'DELETE', `/api/documents/${doc.id}`);
+    expect(res.status).toBe(204);
+
+    const getRes = await request(port, 'GET', `/api/documents/${doc.id}`);
+    expect(getRes.status).toBe(404);
+  });
+
+  it('should track version history', async () => {
+    const createRes = await request(port, 'POST', '/api/documents', {
+      title: 'Version Test',
+      content: 'v0 content',
+    });
+    const doc = createRes.body as Record<string, string>;
+
+    const versionsRes = await request(port, 'GET', `/api/documents/${doc.id}/versions`);
+    expect(versionsRes.status).toBe(200);
+    const versions = versionsRes.body as Array<Record<string, unknown>>;
+    expect(versions.length).toBeGreaterThanOrEqual(1);
+    expect(versions[0].version).toBe(0);
+    expect(versions[0].content).toBe('v0 content');
+  });
+
+  it('should get a specific version', async () => {
+    const createRes = await request(port, 'POST', '/api/documents', {
+      title: 'Version Get Test',
+      content: 'initial',
+    });
+    const doc = createRes.body as Record<string, string>;
+
+    const res = await request(port, 'GET', `/api/documents/${doc.id}/versions/0`);
+    expect(res.status).toBe(200);
+    expect((res.body as Record<string, unknown>).version).toBe(0);
+  });
+});
+
+describe('WebSocket Collaboration', () => {
+  let appInstance: AppInstance;
+  let port: number;
+
+  beforeEach(async () => {
+    appInstance = createApp();
+    port = await appInstance.start(0);
+  });
+
+  afterEach(async () => {
+    await appInstance.stop();
+  });
+
+  it('should send sync message on connection', async () => {
+    const createRes = await request(port, 'POST', '/api/documents', {
+      title: 'WS Test',
+      content: 'Hello',
+    });
+    const doc = createRes.body as Record<string, string>;
+
+    const { ws, sync } = await connectWs(port, doc.id);
+    expect(sync.type).toBe('sync');
+    expect(sync.content).toBe('Hello');
+    expect(sync.version).toBe(0);
+    ws.close();
+  });
+
+  it('should apply and acknowledge an operation', async () => {
+    const createRes = await request(port, 'POST', '/api/documents', {
+      title: 'Op Test',
+      content: 'Hello',
+    });
+    const doc = createRes.body as Record<string, string>;
+
+    const { ws, sync } = await connectWs(port, doc.id);
+    expect(sync.version).toBe(0);
+
+    // Insert " World" at position 5
+    const ackPromise = waitForMessage(ws, 'ack');
+    ws.send(
+      JSON.stringify({
+        type: 'op',
+        version: 0,
+        components: [
+          { type: 'retain', count: 5 },
+          { type: 'insert', text: ' World' },
+        ],
+      })
+    );
+
+    const ack = await ackPromise;
+    expect(ack.version).toBe(1);
+
+    // Verify via REST
+    const getRes = await request(port, 'GET', `/api/documents/${doc.id}`);
+    expect((getRes.body as Record<string, string>).content).toBe('Hello World');
+
+    ws.close();
+  });
+
+  it('should broadcast operations to other clients', async () => {
+    const createRes = await request(port, 'POST', '/api/documents', {
+      title: 'Broadcast Test',
+      content: 'AB',
+    });
+    const doc = createRes.body as Record<string, string>;
+
+    const { ws: ws1 } = await connectWs(port, doc.id);
+    const { ws: ws2 } = await connectWs(port, doc.id);
+
+    // ws1 sends an operation, ws2 should receive it
+    const opPromise = waitForMessage(ws2, 'op');
+    ws1.send(
+      JSON.stringify({
+        type: 'op',
+        version: 0,
+        components: [
+          { type: 'retain', count: 1 },
+          { type: 'insert', text: 'X' },
+          { type: 'retain', count: 1 },
+        ],
+      })
+    );
+
+    const opMsg = await opPromise;
+    expect(opMsg.type).toBe('op');
+    expect(opMsg.version).toBe(1);
+
+    ws1.close();
+    ws2.close();
+  });
+
+  it('should handle concurrent edits with OT', async () => {
+    const createRes = await request(port, 'POST', '/api/documents', {
+      title: 'OT Test',
+      content: 'AB',
+    });
+    const doc = createRes.body as Record<string, string>;
+
+    const { ws: ws1, sync: sync1 } = await connectWs(port, doc.id);
+    const { ws: ws2, sync: sync2 } = await connectWs(port, doc.id);
+
+    expect(sync1.version).toBe(0);
+    expect(sync2.version).toBe(0);
+
+    // Both clients concurrently edit from version 0
+    // Client 1: insert 'X' at position 1 => "AXB"
+    // Client 2: insert 'Y' at position 1 => "AYB"
+    // After OT, result should contain both X and Y
+
+    const ack1Promise = waitForMessage(ws1, 'ack');
+    ws1.send(
+      JSON.stringify({
+        type: 'op',
+        version: 0,
+        components: [
+          { type: 'retain', count: 1 },
+          { type: 'insert', text: 'X' },
+          { type: 'retain', count: 1 },
+        ],
+      })
+    );
+    await ack1Promise;
+
+    // Client 2 sends op against version 0 (doesn't know about X yet)
+    const ack2Promise = waitForMessage(ws2, 'ack');
+    ws2.send(
+      JSON.stringify({
+        type: 'op',
+        version: 0,
+        components: [
+          { type: 'retain', count: 1 },
+          { type: 'insert', text: 'Y' },
+          { type: 'retain', count: 1 },
+        ],
+      })
+    );
+    await ack2Promise;
+
+    // Verify the document contains both insertions
+    const getRes = await request(port, 'GET', `/api/documents/${doc.id}`);
+    const content = (getRes.body as Record<string, string>).content;
+    expect(content).toContain('X');
+    expect(content).toContain('Y');
+    expect(content).toContain('A');
+    expect(content).toContain('B');
+    expect(content.length).toBe(4); // "A" + "X" + "Y" + "B"
+
+    ws1.close();
+    ws2.close();
+  });
+
+  it('should handle 10 concurrent clients', async () => {
+    const createRes = await request(port, 'POST', '/api/documents', {
+      title: 'Concurrency Test',
