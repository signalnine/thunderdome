+/**
+ * Operational Transform engine for collaborative text editing.
+ *
+ * Operations are arrays of components:
+ *   - retain(n): skip n characters
+ *   - insert(s): insert string s at current position
+ *   - delete(n): delete n characters at current position
+ *
+ * An operation's "input length" must equal the document length it's applied to.
+ * After applying, the document length equals the operation's "output length".
+ */
+
+export type OpComponent =
+  | { type: 'retain'; count: number }
+  | { type: 'insert'; text: string }
+  | { type: 'delete'; count: number };
+
+export interface Operation {
+  docId: string;
+  version: number;       // the document version this op was created against
+  components: OpComponent[];
+  clientId?: string;
+}
+
+/** Calculate the input length an operation expects. */
+export function inputLength(components: OpComponent[]): number {
+  let len = 0;
+  for (const c of components) {
+    if (c.type === 'retain') len += c.count;
+    else if (c.type === 'delete') len += c.count;
+    // insert doesn't consume input
+  }
+  return len;
+}
+
+/** Calculate the output length an operation produces. */
+export function outputLength(components: OpComponent[]): number {
+  let len = 0;
+  for (const c of components) {
+    if (c.type === 'retain') len += c.count;
+    else if (c.type === 'insert') len += c.text.length;
+    // delete doesn't produce output
+  }
+  return len;
+}
+
+/** Apply an operation to a document string. */
+export function applyOp(doc: string, components: OpComponent[]): string {
+  const expectedLen = inputLength(components);
+  if (expectedLen !== doc.length) {
+    throw new Error(
+      `Operation input length (${expectedLen}) doesn't match document length (${doc.length})`
+    );
+  }
+
+  let result = '';
+  let pos = 0;
+
+  for (const c of components) {
+    switch (c.type) {
+      case 'retain':
+        result += doc.slice(pos, pos + c.count);
+        pos += c.count;
+        break;
+      case 'insert':
+        result += c.text;
+        break;
+      case 'delete':
+        pos += c.count;
+        break;
+    }
+  }
+
+  return result;
+}
+
+/**
+ * Normalize an operation by merging adjacent same-type components
+ * and removing no-ops.
+ */
+function normalize(components: OpComponent[]): OpComponent[] {
+  const result: OpComponent[] = [];
+  for (const c of components) {
+    if (c.type === 'retain' && c.count === 0) continue;
+    if (c.type === 'delete' && c.count === 0) continue;
+    if (c.type === 'insert' && c.text === '') continue;
+
+    const last = result[result.length - 1];
+    if (last && last.type === c.type) {
+      if (last.type === 'retain' && c.type === 'retain') {
+        last.count += c.count;
+      } else if (last.type === 'delete' && c.type === 'delete') {
+        last.count += c.count;
+      } else if (last.type === 'insert' && c.type === 'insert') {
+        last.text += c.text;
+      }
+    } else {
+      result.push({ ...c } as OpComponent);
+    }
+  }
+  return result;
+}
+
+/**
+ * Transform two concurrent operations (a and b) so they can both be applied.
+ *
+ * Given:
+ *   - a and b were both created against the same document state
+ *   - We want to apply a first, then b' (transformed b)
+ *   - Or apply b first, then a' (transformed a)
+ *
+ * Returns [a', b'] such that:
+ *   apply(apply(doc, a), b') === apply(apply(doc, b), a')
+ *
+ * This implements the standard OT transform for text operations.
+ */
+export function transform(
+  a: OpComponent[],
+  b: OpComponent[]
+): [OpComponent[], OpComponent[]] {
+  const aPrime: OpComponent[] = [];
+  const bPrime: OpComponent[] = [];
+
+  let ia = 0;
+  let ib = 0;
+  let oa: OpComponent | null = a[ia] ? { ...a[ia] } as OpComponent : null;
+  let ob: OpComponent | null = b[ib] ? { ...b[ib] } as OpComponent : null;
+
+  function nextA(): OpComponent | null {
+    ia++;
+    return a[ia] ? { ...a[ia] } as OpComponent : null;
+  }
+  function nextB(): OpComponent | null {
+    ib++;
+    return b[ib] ? { ...b[ib] } as OpComponent : null;
+  }
+
+  while (oa !== null || ob !== null) {
+    // If a is insert, it goes first (insert vs anything)
+    if (oa !== null && oa.type === 'insert') {
+      aPrime.push({ type: 'insert', text: oa.text });
+      bPrime.push({ type: 'retain', count: oa.text.length });
+      oa = nextA();
+      continue;
+    }
+
+    // If b is insert, it goes next
+    if (ob !== null && ob.type === 'insert') {
+      bPrime.push({ type: 'insert', text: ob.text });
+      aPrime.push({ type: 'retain', count: ob.text.length });
+      ob = nextB();
+      continue;
+    }
+
+    // Both must be retain or delete at this point
+    if (oa === null || ob === null) {
+      throw new Error('Operations have mismatched lengths during transform');
+    }
+
+    if (oa.type === 'retain' && ob.type === 'retain') {
+      const minLen = Math.min(oa.count, ob.count);
+      aPrime.push({ type: 'retain', count: minLen });
+      bPrime.push({ type: 'retain', count: minLen });
+      if (oa.count > minLen) {
+        oa.count -= minLen;
+      } else {
+        oa = nextA();
+      }
+      if (ob.count > minLen) {
+        ob.count -= minLen;
+      } else {
+        ob = nextB();
+      }
+    } else if (oa.type === 'delete' && ob.type === 'delete') {
+      const minLen = Math.min(oa.count, ob.count);
+      // Both deleted the same region — cancel out
+      if (oa.count > minLen) {
+        oa.count -= minLen;
+      } else {
+        oa = nextA();
+      }
+      if (ob.count > minLen) {
+        ob.count -= minLen;
+      } else {
+        ob = nextB();
+      }
+    } else if (oa.type === 'delete' && ob.type === 'retain') {
+      const minLen = Math.min(oa.count, ob.count);
+      aPrime.push({ type: 'delete', count: minLen });
+      // b's retain is consumed by a's delete — nothing in bPrime
+      if (oa.count > minLen) {
+        oa.count -= minLen;
+      } else {
+        oa = nextA();
+      }
+      if (ob.count > minLen) {
+        ob.count -= minLen;
+      } else {
+        ob = nextB();
+      }
+    } else if (oa.type === 'retain' && ob.type === 'delete') {
+      const minLen = Math.min(oa.count, ob.count);
+      bPrime.push({ type: 'delete', count: minLen });
+      // a's retain is consumed by b's delete — nothing in aPrime
+      if (oa.count > minLen) {
+        oa.count -= minLen;
+      } else {
+        oa = nextA();
+      }
+      if (ob.count > minLen) {
+        ob.count -= minLen;
+      } else {
+        ob = nextB();
+      }
+    }
+  }
+
+  return [normalize(aPrime), normalize(bPrime)];
+}
+
+/** Validate that an operation's components are well-formed. */
+export function validateComponents(components: unknown): components is OpComponent[] {
+  if (!Array.isArray(components)) return false;
+  for (const c of components) {
+    if (typeof c !== 'object' || c === null) return false;
+    if (!('type' in c)) return false;
+    const comp = c as Record<string, unknown>;
+    switch (comp.type) {
+      case 'retain':
+        if (typeof comp.count !== 'number' || comp.count < 0 || !Number.isInteger(comp.count)) return false;
+        break;
+      case 'insert':
+        if (typeof comp.text !== 'string') return false;
+        break;
+      case 'delete':
+        if (typeof comp.count !== 'number' || comp.count < 0 || !Number.isInteger(comp.count)) return false;
+        break;
+      default:
+        return false;
+    }
+  }
+  return true;
+}
