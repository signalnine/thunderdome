ingMessage = SyncMessage | AckMessage | OpMessage | ErrorMessage;\n\nexport class CollaborationServer {\n  private wss: WebSocketServer;\n  private sessions: Map<string, DocumentSession> = new Map();\n  private store: DocumentStore;\n\n  constructor(server: Server, store: DocumentStore) {\n    this.store = store;\n    this.wss = new WebSocketServer({ server, path: undefined });\n\n    // Handle upgrade manually to extract document ID from URL\n    server.on('upgrade', (request: IncomingMessage, socket, head) => {\n      const url = request.url || '';\n      const match = url.match(/^\\/ws\\/documents\\/([^/?]+)/);\n      if (!match) {\n        socket.write('HTTP/1.1 400 Bad Request\\r\\n\\r\\n');\n        socket.destroy();\n        return;\n      }\n\n      const docId = match[1];\n      const doc = store.getDocument(docId);\n      if (!doc) {\n        socket.write('HTTP/1.1 404 Not Found\\r\\n\\r\\n');\n        socket.destroy();\n        return;\n      }\n\n      this.wss.handleUpgrade(request, socket, head, (ws) => {\n        this.wss.emit('connection', ws, request, docId);\n      });\n    });\n\n    this.wss.on('connection', (ws: WebSocket, _request: IncomingMessage, docId: string) => {\n      this.handleConnection(ws, docId);\n    });\n  }\n\n  private getOrCreateSession(docId: string): DocumentSession {\n    let session = this.sessions.get(docId);\n    if (!session) {\n      const doc = this.store.getDocument(docId);\n      if (!doc) throw new Error(`Document ${docId} not found`);\n\n      const latestVersion = this.store.getLatestVersion(docId);\n      const version = latestVersion ? latestVersion.version : 0;\n\n      session = {\n        docId,\n        content: doc.content,\n        version,\n        clients: new Map(),\n        history: [],\n      };\n      this.sessions.set(docId, session);\n    }\n    return session;\n  }\n\n  private handleConnection(ws: WebSocket, docId: string): void {\n    const session = this.getOrCreateSession(docId);\n    const clientId = crypto.randomUUID();\n\n    const client: ClientConnection = { ws, clientId, docId };\n    session.clients.set(clientId, client);\n\n    // Send sync message with current state\n    const syncMsg: SyncMessage = {\n      type: 'sync',\n      content: session.content,\n      version: session.version,\n      docId,\n    };\n    this.send(ws, syncMsg);\n\n    ws.on('message', (data) => {\n      try {\n        const message = JSON.parse(data.toString());\n        this.handleMessage(client, session, message);\n      } catch (err) {\n        const errMsg: ErrorMessage = {\n          type: 'error',\n          message: err instanceof Error ? err.message : 'Invalid message',\n        };\n        this.send(ws, errMsg);\n      }\n    });\n\n    ws.on('close', () => {\n      session.clients.delete(clientId);\n      if (session.clients.size === 0) {\n        // Keep session around for a while (it caches the doc state)\n        // but we could also clean it up\n      }\n    });\n\n    ws.on('error', () => {\n      session.clients.delete(clientId);\n    });\n  }\n\n  private handleMessage(\n    client: ClientConnection,\n    session: DocumentSession,\n    message: unknown\n  ): void {\n    if (typeof message !== 'object' || message === null) {\n      this.send(client.ws, { type: 'error', message: 'Invalid message format' });\n      return;\n    }\n\n    const msg = message as Record<string, unknown>;\n\n    if (msg.type !== 'op') {\n      this.send(client.ws, { type: 'error', message: `Unknown message type: ${String(msg.type)}` });\n      return;\n    }\n\n    if (!validateComponents(msg.components)) {\n      this.send(client.ws, { type: 'error', message: 'Invalid operation components' });\n      return;\n    }\n\n    const clientVersion = typeof msg.version === 'number' ? msg.version : -1;\n    if (clientVersion < 0 || clientVersion > session.version) {\n      this.send(client.ws, {\n        type: 'error',\n        message: `Invalid version: ${clientVersion}. Current version: ${session.version}`,\n      });\n      return;\n    }\n\n    let components: OpComponent[] = msg.components;\n\n    // Transform against all operations that happened since the client's version\n    const startIdx = clientVersion - (session.version - session.history.length);\n    for (let i = Math.max(0, startIdx); i < session.history.length; i++) {\n      const serverOp = session.history[i];\n      try {\n        const [, transformedClient] = transform(serverOp.components, components);\n        components = transformedClient;\n      } catch (err) {\n        this.send(client.ws, {\n          type: 'error',\n          message: `Transform failed: ${err instanceof Error ? err.message : 'unknown error'}`,\n        });\n        return;\n      }\n    }\n\n    // Validate against current document\n    const expectedLen = inputLength(components);\n    if (expectedLen !== session.content.length) {\n      this.send(client.ws, {\n        type: 'error',\n        message: `Operation input length (${expectedLen}) doesn't match document length (${session.content.length})`,\n      });\n      return;\n    }\n\n    // Apply the transformed operation\n    try {\n      session.content = applyOp(session.content, components);\n    } catch (err) {\n      this.send(client.ws, {\n        type: 'error',\n        message: `Apply failed: ${err instanceof Error ? err.message : 'unknown error'}`,\n      });\n      return;\n    }\n\n    session.version++;\n\n    const op: Operation = {\n      docId: session.docId,\n      version: session.version,\n      components,\n      clientId: client.clientId,\n    };\n\n    session.history.push(op);\n\n    // Persist to database\n    try {\n      this.store.updateContent(\n        session.docId,\n        session.content,\n        session.version,\n        JSON.stringify(components)\n      );\n    } catch {\n      // Log but don't fail the operation — it's already applied in memory\n    }\n\n    // Acknowledge to sender\n    const ack: AckMessage = { typ