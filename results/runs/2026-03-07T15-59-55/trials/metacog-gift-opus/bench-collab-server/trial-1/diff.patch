+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01RE8WLRbAYzW12aJY2bAbn9","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01XJH569m2yvrxBuipxVpbt3","name":"Write","input":{"file_path":"/workspace/src/server.test.ts","content":"import { describe, it, expect, beforeAll, afterAll, beforeEach, afterEach } from 'vitest';\nimport { createApp, AppInstance } from './server.js';\nimport WebSocket from 'ws';\n\n// Helper to make HTTP requests\nasync function request(\n  port: number,\n  method: string,\n  path: string,\n  body?: unknown\n): Promise<{ status: number; body: unknown }> {\n  const res = await fetch(`http://localhost:${port}${path}`, {\n    method,\n    headers: body ? { 'Content-Type': 'application/json' } : {},\n    body: body ? JSON.stringify(body) : undefined,\n  });\n  const text = await res.text();\n  let parsed: unknown;\n  try {\n    parsed = JSON.parse(text);\n  } catch {\n    parsed = text;\n  }\n  return { status: res.status, body: parsed };\n}\n\n// Helper to connect a WebSocket and get the sync message\nfunction connectWs(\n  port: number,\n  docId: string\n): Promise<{ ws: WebSocket; sync: { type: string; content: string; version: number; docId: string } }> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/${docId}`);\n    ws.on('error', reject);\n    ws.on('message', (data) => {\n      const msg = JSON.parse(data.toString());\n      if (msg.type === 'sync') {\n        resolve({ ws, sync: msg });\n      }\n    });\n    // Timeout after 5s\n    setTimeout(() => reject(new Error('WebSocket connection timeout')), 5000);\n  });\n}\n\n// Helper to wait for a specific message type from a WebSocket\nfunction waitForMessage(\n  ws: WebSocket,\n  type: string,\n  timeout = 5000\n): Promise<Record<string, unknown>> {\n  return new Promise((resolve, reject) => {\n    const timer = setTimeout(() => reject(new Error(`Timeout waiting for ${type}`)), timeout);\n    const handler = (data: WebSocket.Data) => {\n      const msg = JSON.parse(data.toString());\n      if (msg.type === type) {\n        clearTimeout(timer);\n        ws.off('message', handler);\n        resolve(msg);\n      }\n    };\n    ws.on('message', handler);\n  });\n}\n\ndescribe('REST API', () => {\n  let appInstance: AppInstance;\n  let port: number;\n\n  beforeAll(async () => {\n    appInstance = createApp();\n    port = await appInstance.start(0);\n  });\n\n  afterAll(async () => {\n    await appInstance.stop();\n  });\n\n  it('should create a document', async () => {\n    const res = await request(port, 'POST', '/api/documents', {\n      title: 'Test Doc',\n      content: 'Hello World',\n    });\n    expect(res.status).toBe(201);\n    const doc = res.body as Record<string, unknown>;\n    expect(doc.title).toBe('Test Doc');\n    expect(doc.content).toBe('Hello World');\n    expect(doc.id).toBeDefined();\n  });\n\n  it('should require title when creating', async () => {\n    const res = await request(port, 'POST', '/api/documents', { content: 'No title' });\n    expect(res.status).toBe(400);\n  });\n\n  it('should list documents', async () => {\n    const res = await request(port, 'GET', '/api/documents');\n    expect(res.status).toBe(200);\n    expect(Array.isArray(res.body)).toBe(true);\n  });\n\n  it('should get a document by id', async () => {\n    const createRes = await request(port, 'POST', '/api/documents', {\n      title: 'Get Test',\n      content: 'Get content',\n    });\n    const doc = createRes.body as Record<string, string>;\n\n    const res = await request(port, 'GET', `/api/documents/${doc.id}`);\n    expect(res.status).toBe(200);\n    expect((res.body as Record<string, string>).title).toBe('Get Test');\n  });\n\n  it('should return 404 for non-existent document', async () => {\n    const res = await request(port, 'GET', '/api/documents/non-existent');\n    expect(res.status).toBe(404);\n  });\n\n  it('should update a document', async () => {\n    const createRes = await request(port, 'POST', '/api/documents', {\n      title: 'Update Test',\n      content: 'Original',\n    });\n    const doc = createRes.body as Record<string, string>;\n\n    const res = await request(port, 'PUT', `/api/documents/${doc.id}`, {\n      title: 'Updated Title',\n      content: 'Updated content',\n    });\n    expect(res.status).toBe(200);\n    expect((res.body as Record<string, string>).title).toBe('Updated Title');\n    expect((res.body as Record<string, string>).content).toBe('Updated content');\n  });\n\n  it('should delete a document', async () => {\n    const createRes = await request(port, 'POST', '/api/documents', {\n      title: 'Delete Test',\n    });\n    const doc = createRes.body as Record<string, string>;\n\n    const res = await request(port, 'DELETE', `/api/documents/${doc.id}`);\n    expect(res.status).toBe(204);\n\n    const getRes = await request(port, 'GET', `/api/documents/${doc.id}`);\n    expect(getRes.status).toBe(404);\n  });\n\n  it('should track version history', async () => {\n    const createRes = await request(port, 'POST', '/api/documents', {\n      title: 'Version Test',\n      content: 'v0 content',\n    });\n    const doc = createRes.body as Record<string, string>;\n\n    const versionsRes = await request(port, 'GET', `/api/documents/${doc.id}/versions`);\n    expect(versionsRes.status).toBe(200);\n    const versions = versionsRes.body as Array<Record<string, unknown>>;\n    expect(versions.length).toBeGreaterThanOrEqual(1);\n    expect(versions[0].version).toBe(0);\n    expect(versions[0].content).toBe('v0 content');\n  });\n\n  it('should get a specific version', async () => {\n    const createRes = await request(port, 'POST', '/api/documents', {\n      title: 'Version Get Test',\n      content: 'initial',\n    });\n    const doc = createRes.body as Record<string, string>;\n\n    const res = await request(port, 'GET', `/api/documents/${doc.id}/versions/0`);\n    expect(res.status).toBe(200);\n    expect((res.body as Record<string, unknown>).version).toBe(0);\n  });\n});\n\ndescribe('WebSocket Collaboration', () => {\n  let appInstance: AppInstance;\n  let port: number;\n\n  beforeEach(async () => {\n    appInstance = createApp();\n    port = await appInstance.start(0);\n  });\n\n  afterEach(async () => {\n    await appInstance.stop();\n  });\n\n  it('should send sync message on connection', async () => {\n    const createRes = await request(port, 'POST', '/api/documents', {\n      title: 'WS Test',\n      content: 'Hello',\n    });\n    const doc = createRes.body as Record<string, string>;\n\n    const { ws, sync } = await connectWs(port, doc.id);\n    expect(sync.type).toBe('sync');\n    expect(sync.content).toBe('Hello');\n    expect(sync.version).toBe(0);\n    ws.close();\n  });\n\n  it('should apply and acknowledge an operation', async () => {\n    const createRes = await request(port, 'POST', '/api/documents', {\n      title: 'Op Test',\n      content: 'Hello',\n    });\n    const doc = createRes.body as Record<string, string>;\n\n    const { ws, sync } = await connectWs(port, doc.id);\n    expect(sync.version).toBe(0);\n\n    // Insert \" World\" at position 5\n    const ackPromise = waitForMessage(ws, 'ack');\n    ws.send(\n      JSON.stringify({\n        type: 'op',\n        version: 0,\n        components: [\n          { type: 'retain', count: 5 },\n          { type: 'insert', text: ' World' },\n        ],\n      })\n    );\n\n    const ack = await ackPromise;\n    expect(ack.version).toBe(1);\n\n    // Verify via REST\n    const getRes = await request(port, 'GET', `/api/documents/${doc.id}`);\n    expect((getRes.body as Record<string, string>).content).toBe('Hello World');\n\n    ws.close();\n  });\n\n  it('should broadcast operations to other clients', async () => {\n    const createRes = await request(port, 'POST', '/api/documents', {\n      title: 'Broadcast Test',\n      content: 'AB',\n    });\n    const doc = createRes.body as Record<string, string>;\n\n    const { ws: ws1 } = await connectWs(port, doc.id);\n    const { ws: ws2 } = await connectWs(port, doc.id);\n\n    // ws1 sends an operation, ws2 should receive it\n    const opPromise = waitForMessage(ws2, 'op');\n    ws1.send(\n      JSON.stringify({\n        type: 'op',\n        version: 0,\n        components: [\n          { type: 'retain', count: 1 },\n          { type: 'insert', text: 'X' },\n          { type: 'retain', count: 1 },\n        ],\n      })\n    );\n\n    const opMsg = await opPromise;\n    expect(opMsg.type).toBe('op');\n    expect(opMsg.version).toBe(1);\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should handle concurrent edits with OT', async () => {\n    const createRes = await request(port, 'POST', '/api/documents', {\n      title: 'OT Test',\n      content: 'AB',\n    });\n    const doc = createRes.body as Record<string, string>;\n\n    const { ws: ws1, sync: sync1 } = await connectWs(port, doc.id);\n    const { ws: ws2, sync: sync2 } = await connectWs(port, doc.id);\n\n    expect(sync1.version).toBe(0);\n    expect(sync2.version).toBe(0);\n\n    // Both clients concurrently edit from version 0\n    // Client 1: insert 'X' at position 1 => \"AXB\"\n    // Client 2: insert 'Y' at position 1 => \"AYB\"\n    // After OT, result should contain both X and Y\n\n    const ack1Promise = waitForMessage(ws1, 'ack');\n    ws1.send(\n      JSON.stringify({\n        type: 'op',\n        version: 0,\n        components: [\n          { type: 'retain', count: 1 },\n          { type: 'insert', text: 'X' },\n          { type: 'retain', count: 1 },\n        ],\n      })\n    );\n    await ack1Promise;\n\n    // Client 2 sends op against version 0 (doesn't know about X yet)\n    const ack2Promise = waitForMessage(ws2, 'ack');\n    ws2.send(\n      JSON.stringify({\n        type: 'op',\n        version: 0,\n        components: [\n          { type: 'retain', count: 1 },\n          { type: 'insert', text: 'Y' },\n          { type: 'retain', count: 1 },\n        ],\n      })\n    );\n    await ack2Promise;\n\n    // Verify the document contains both insertions\n    const getRes = await request(port, 'GET', `/api/documents/${doc.id}`);\n    const content = (getRes.body as Record<string, string>).content;\n    expect(content).toContain('X');\n    expect(content).toContain('Y');\n    expect(content).toContain('A');\n    expect(content).toContain('B');\n    expect(content.length).toBe(4); // \"A\" + \"X\" + \"Y\" + \"B\"\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should handle 10 concurrent clients', async () => {\n    const createRes = await request(port, 'POST', '/api/documents', {\n      title: 'Concurrency Test',\n      content: '',\n    });\n    const doc = createRes.body as Record<string, string>;\n\n    // Connect 10 clients\n    const clients: Array<{ ws: WebSocket; sync: { version: number } }> = [];\n    for (let i = 0; i < 10; i++) {\n      const client = await connectWs(port, doc.id);\n      clients.push(client);\n    }\n\n    // Each client inserts a character sequentially (to avoid race conditions in test)\n    for (let i = 0; i < 10; i++) {\n      const { ws } = clients[i];\n      const ackPromise = waitForMessage(ws, 'ack');\n      ws.send(\n        JSON.stringify({\n          type: 'op',\n          version: i, // Each sees the version after previous ops\n          components: [\n            ...(i > 0 ? [{ type: 'retain', count: i }] : []),\n            { type: 'insert', text: String(i) },\n          ],\n        })\n      );\n      await ackPromise;\n    }\n\n    // Verify final state\n    const getRes = await request(port, 'GET', `/api/documents/${doc.id}`);\n    const content = (getRes.body as Record<string, string>).content;\n    expect(content.length).toBe(10);\n    // All digits 0-9 should be present\n    for (let i = 0; i < 10; i++) {\n      expect(content).toContain(String(i));\n    }\n\n    for (const c of clients) c.ws.close();\n  });\n\n  it('should reject malformed operations', async () => {\n    const createRes = await request(port, 'POST', '/api/documents', {\n      title: 'Error Test',\n      content: 'Hi',\n    });\n    const doc = createRes.body as Record<string, string>;\n\n    const { ws } = await connectWs(port, doc.id);\n\n    // Send invalid op (bad component type)\n    const errPromise = waitForMessage(ws, 'error');\n    ws.send(\n      JSON.stringify({\n        type: 'op',\n        version: 0,\n        components: [{ type: 'invalid_type', count: 5 }],\n      })\n    );\n    const err = await errPromise;\n    expect(err.type).toBe('error');\n\n    ws.close();\n  });\n\n  it('should reject operations with wrong input length', async () => {\n    const createRes = await request(port, 'POST', '/api/documents', {\n      title: 'Length Test',\n      content: 'Hi',\n    });\n    const doc = createRes.body as Record<string, string>;\n\n    const { ws } = await connectWs(port, doc.id);\n\n    // Send op that expects document length of 10 but doc is length 2\n    const errPromise = waitForMessage(ws, 'error');\n    ws.send(\n      JSON.stringify({\n        type: 'op',\n        version: 0,\n        components: [{ type: 'retain', count: 10 }],\n      })\n    );\n    const err = await errPromise;\n    expect(err.type).toBe('error');\n\n    ws.close();\n  });\n\n  it('should persist across server restarts', async () => {\n    const dbPath = '/tmp/test-persist-' + Date.now() + '.db';\n\n    // Create a document, apply an edit, then stop\n    const app1 = createApp(dbPath);\n    const port1 = await app1.start(0);\n\n    const createRes = await request(port1, 'POST', '/api/documents', {\n      title: 'Persist Test',\n      content: 'Before',\n    });\n    const doc = createRes.body as Record<string, string>;\n\n    // Connect via WS and apply an edit\n    const { ws } = await connectWs(port1, doc.id);\n    const ackPromise = waitForMessage(ws, 'ack');\n    ws.send(\n      JSON.stringify({\n        type: 'op',\n        version: 0,\n        components: [\n          { type: 'delete', count: 6 },\n          { type: 'insert', text: 'After' },\n        ],\n      })\n    );\n    await ackPromise;\n    ws.close();\n    await app1.stop();\n\n    // Restart with same db\n    const app2 = createApp(dbPath);\n    const port2 = await app2.start(0);\n\n    const getRes = await request(port2, 'GET', `/api/documents/${doc.id}`);\n    expect(getRes.status).toBe(200);\n    expect((getRes.body as Record<string, string>).content).toBe('After');\n\n    // Version history should include both versions\n    const versionsRes = await request(port2, 'GET', `/api/documents/${doc.id}/versions`);\n    const versions = versionsRes.body as Array<Record<string, unknown>>;\n    expect(versions.length).toBe(2);\n\n    await app2.stop();\n  });\n\n  it('should handle delete operations in OT', async () => {\n    const createRes = await request(port, 'POST', '/api/documents', {\n      title: 'Delete OT Test',\n      content: 'ABCDEF',\n    });\n    const doc = createRes.body as Record<string, string>;\n\n    const { ws: ws1 } = await connectWs(port, doc.id);\n    const { ws: ws2 } = await connectWs(port, doc.id);\n\n    // Client 1: delete \"BC\" (positions 1-2) => \"ADEF\"\n    const ack1Promise = waitForMessage(ws1, 'ack');\n    ws1.send(\n      JSON.stringify({\n        type: 'op',\n        version: 0,\n        components: [\n          { type: 'retain', count: 1 },\n          { type: 'delete', count: 2 },\n          { type: 'retain', count: 3 },\n        ],\n      })\n    );\n    await ack1Promise;\n\n    // Client 2: insert \"X\" at position 4 (between D and E) based on version 0\n    const ack2Promise = waitForMessage(ws2, 'ack');\n    ws2.send(\n      JSON.stringify({\n        type: 'op',\n        version: 0,\n        components: [\n          { type: 'retain', count: 4 },\n          { type: 'insert', text: 'X' },\n          { type: 'retain', count: 2 },\n        ],\n      })\n    );\n    await ack2Promise;\n\n    // Verify: document should have BC deleted and X inserted\n    const getRes = await request(port, 'GET', `/api/documents/${doc.id}`);\n    const content = (getRes.body as Record<string, string>).content;\n    expect(content).not.toContain('B');\n    expect(content).not.toContain('C');\n    expect(content).toContain('X');\n    expect(content).toContain('A');\n    expect(content).toContain('D');\n    expect(content).toContain('E');\n    expect(content).toContain('F');\n\n    ws1.close();\n    ws2.close();\n  });\n});\n\ndescribe('OT Engine', () => {\n  it('should apply simple insert', async () => {\n    const { applyOp } = await import('./ot.js');\n    const result = applyOp('Hello', [\n      { type: 'retain', count: 5 },\n      { type: 'insert', text: ' World' },\n    ]);\n    expect(result).toBe('Hello World');\n  });\n\n  it('should apply simple delete', async () => {\n    const { applyOp } = await import('./ot.js');\n    const result = applyOp('Hello World', [\n      { type: 'retain', count: 5 },\n      { type: 'delete', count: 6 },\n    ]);\n    expect(result).toBe('Hello');\n  });\n\n  it('should transform two inserts at different positions', async () => {\n    const { transform, applyOp } = await import('./ot.js');\n    const doc = 'AB';\n    const a = [\n      { type: 'retain' as const, count: 1 },\n      { type: 'insert' as const, text: 'X' },\n      { type: 'retain' as const, count: 1 },\n    ];\n    const b = [\n      { type: 'retain' as const, count: 2 },\n      { type: 'insert' as const, text: 'Y' },\n    ];\n\n    const [aPrime, bPrime] = transform(a, b);\n\n    // Apply a then b' should equal apply b then a'\n    const resultAB = applyOp(applyOp(doc, a), bPrime);\n    const resultBA = applyOp(applyOp(doc, b), aPrime);\n    expect(resultAB).toBe(resultBA);\n    expect(resultAB).toContain('X');\n    expect(resultAB).toContain('Y');\n  });\n\n  it('should transform two inserts at same position', async () => {\n    const { transform, applyOp } = await import('./ot.js');\n    const doc = 'AB';\n    const a = [\n      { type: 'retain' as const, count: 1 },\n      { type: 'insert' as const, text: 'X' },\n      { type: 'retain' as const, count: 1 },\n    ];\n    const b = [\n      { type: 'retain' as const, count: 1 },\n      { type: 'insert' as const, text: 'Y' },\n      { type: 'retain' as const, count: 1 },\n    ];\n\n    const [aPrime, bPrime] = transform(a, b);\n\n    const resultAB = applyOp(applyOp(doc, a), bPrime);\n    const resultBA = applyOp(applyOp(doc, b), aPrime);\n    expect(resultAB).toBe(resultBA);\n    expect(resultAB).toContain('X');\n    expect(resultAB).toContain('Y');\n  });\n\n  it('should validate components', async () => {\n    const { validateComponents } = await import('./ot.js');\n    expect(validateComponents([{ type: 'retain', count: 5 }])).toBe(true);\n    expect(validateComponents([{ type: 'insert', text: 'hi' }])).toBe(true);\n    expect(validateComponents([{ type: 'delete', count: 3 }])).toBe(true);\n    expect(validateComponents([{ type: 'unknown' }])).toBe(false);\n    expect(validateComponents('not an array')).toBe(false);\n    expect(validateComponents([{ type: 'retain', count: -1 }])).toBe(false);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":336,"cache_read_input_tokens":30895,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":336},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"6a955188-b096-45b0-a9db-a3b68f15b32f","uuid":"945d37d2-74a7-4dde-86a0-6200a44a3429"}
+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XJH569m2yvrxBuipxVpbt3","type":"tool_result","content":"File created successfully at: /workspace/src/server.test.ts"}]},"parent_tool_use_id":null,"session_id":"6a955188-b096-45b0-a9db-a3b68f15b32f","uuid":"573cb90c-351c-461c-aa99-58abcf80320b","tool_use_result":{"type":"create","filePath":"/workspace/src/server.test.ts","content":"import { describe, it, expect, beforeAll, afterAll, beforeEach, afterEach } from 'vitest';\nimport { createApp, AppInstance } from './server.js';\nimport WebSocket from 'ws';\n\n// Helper to make HTTP requests\nasync function request(\n  port: number,\n  method: string,\n  path: string,\n  body?: unknown\n): Promise<{ status: number; body: unknown }> {\n  const res = await fetch(`http://localhost:${port}${path}`, {\n    method,\n    headers: body ? { 'Content-Type': 'application/json' } : {},\n    body: body ? JSON.stringify(body) : undefined,\n  });\n  const text = await res.text();\n  let parsed: unknown;\n  try {\n    parsed = JSON.parse(text);\n  } catch {\n    parsed = text;\n  }\n  return { status: res.status, body: parsed };\n}\n\n// Helper to connect a WebSocket and get the sync message\nfunction connectWs(\n  port: number,\n  docId: string\n): Promise<{ ws: WebSocket; sync: { type: string; content: string; version: number; docId: string } }> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/${docId}`);\n    ws.on('error', reject);\n    ws.on('message', (data) => {\n      const msg = JSON.parse(data.toString());\n      if (msg.type === 'sync') {\n        resolve({ ws, sync: msg });\n      }\n    });\n    // Timeout after 5s\n    setTimeout(() => reject(new Error('WebSocket connection timeout')), 5000);\n  });\n}\n\n// Helper to wait for a specific message type from a WebSocket\nfunction waitForMessage(\n  ws: WebSocket,\n  type: string,\n  timeout = 5000\n): Promise<Record<string, unknown>> {\n  return new Promise((resolve, reject) => {\n    const timer = setTimeout(() => reject(new Error(`Timeout waiting for ${type}`)), timeout);\n    const handler = (data: WebSocket.Data) => {\n      const msg = JSON.parse(data.toString());\n      if (msg.type === type) {\n        clearTimeout(timer);\n        ws.off('message', handler);\n        resolve(msg);\n      }\n    };\n    ws.on('message', handler);\n  });\n}\n\ndescribe('REST API', () => {\n  let appInstance: AppInstance;\n  let port: number;\n\n  beforeAll(async () => {\n    appInstance = createApp();\n    port = await appInstance.start(0);\n  });\n\n  afterAll(async () => {\n    await appInstance.stop();\n  });\n\n  it('should create a document', async () => {\n    const res = await request(port, 'POST', '/api/documents', {\n      title: 'Test Doc',\n      content: 'Hello World',\n    });\n    expect(res.status).toBe(201);\n    const doc = res.body as Record<string, unknown>;\n    expect(doc.title).toBe('Test Doc');\n    expect(doc.content).toBe('Hello World');\n    expect(doc.id).toBeDefined();\n  });\n\n  it('should require title when creating', async () => {\n    const res = await request(port, 'POST', '/api/documents', { content: 'No title' });\n    expect(res.status).toBe(400);\n  });\n\n  it('should list documents', async () => {\n    const res = await request(port, 'GET', '/api/documents');\n    expect(res.status).toBe(200);\n    expect(Array.isArray(res.body)).toBe(true);\n  });\n\n  it('should get a document by id', async () => {\n    const createRes = await request(port, 'POST', '/api/documents', {\n      title: 'Get Test',\n      content: 'Get content',\n    });\n    const doc = createRes.body as Record<string, string>;\n\n    const res = await request(port, 'GET', `/api/documents/${doc.id}`);\n    expect(res.status).toBe(200);\n    expect((res.body as Record<string, string>).title).toBe('Get Test');\n  });\n\n  it('should return 404 for non-existent document', async () => {\n    const res = await request(port, 'GET', '/api/documents/non-existent');\n    expect(res.status).toBe(404);\n  });\n\n  it('should update a document', async () => {\n    const createRes = await request(port, 'POST', '/api/documents', {\n      title: 'Update Test',\n      content: 'Original',\n    });\n    const doc = createRes.body as Record<string, string>;\n\n    const res = await request(port, 'PUT', `/api/documents/${doc.id}`, {\n      title: 'Updated Title',\n      content: 'Updated content',\n    });\n    expect(res.status).toBe(200);\n    expect((res.body as Record<string, string>).title).toBe('Updated Title');\n    expect((res.body as Record<string, string>).content).toBe('Updated content');\n  });\n\n  it('should delete a document', async () => {\n    const createRes = await request(port, 'POST', '/api/documents', {\n      title: 'Delete Test',\n    });\n    const doc = createRes.body as Record<string, string>;\n\n    const res = await request(port, 'DELETE', `/api/documents/${doc.id}`);\n    expect(res.status).toBe(204);\n\n    const getRes = await request(port, 'GET', `/api/documents/${doc.id}`);\n    expect(getRes.status).toBe(404);\n  });\n\n  it('should track version history', async () => {\n    const createRes = await request(port, 'POST', '/api/documents', {\n      title: 'Version Test',\n      content: 'v0 content',\n    });\n    const doc = createRes.body as Record<string, string>;\n\n    const versionsRes = await request(port, 'GET', `/api/documents/${doc.id}/versions`);\n    expect(versionsRes.status).toBe(200);\n    const versions = versionsRes.body as Array<Record<string, unknown>>;\n    expect(versions.length).toBeGreaterThanOrEqual(1);\n    expect(versions[0].version).toBe(0);\n    expect(versions[0].content).toBe('v0 content');\n  });\n\n  it('should get a specific version', async () => {\n    const createRes = await request(port, 'POST', '/api/documents', {\n      title: 'Version Get Test',\n      content: 'initial',\n    });\n    const doc = createRes.body as Record<string, string>;\n\n    const res = await request(port, 'GET', `/api/documents/${doc.id}/versions/0`);\n    expect(res.status).toBe(200);\n    expect((res.body as Record<string, unknown>).version).toBe(0);\n  });\n});\n\ndescribe('WebSocket Collaboration', () => {\n  let appInstance: AppInstance;\n  let port: number;\n\n  beforeEach(async () => {\n    appInstance = createApp();\n    port = await appInstance.start(0);\n  });\n\n  afterEach(async () => {\n    await appInstance.stop();\n  });\n\n  it('should send sync message on connection', async () => {\n    const createRes = await request(port, 'POST', '/api/documents', {\n      title: 'WS Test',\n      content: 'Hello',\n    });\n    const doc = createRes.body as Record<string, string>;\n\n    const { ws, sync } = await connectWs(port, doc.id);\n    expect(sync.type).toBe('sync');\n    expect(sync.content).toBe('Hello');\n    expect(sync.version).toBe(0);\n    ws.close();\n  });\n\n  it('should apply and acknowledge an operation', async () => {\n    const createRes = await request(port, 'POST', '/api/documents', {\n      title: 'Op Test',\n      content: 'Hello',\n    });\n    const doc = createRes.body as Record<string, string>;\n\n    const { ws, sync } = await connectWs(port, doc.id);\n    expect(sync.version).toBe(0);\n\n    // Insert \" World\" at position 5\n    const ackPromise = waitForMessage(ws, 'ack');\n    ws.send(\n      JSON.stringify({\n        type: 'op',\n        version: 0,\n        components: [\n          { type: 'retain', count: 5 },\n          { type: 'insert', text: ' World' },\n        ],\n      })\n    );\n\n    const ack = await ackPromise;\n    expect(ack.version).toBe(1);\n\n    // Verify via REST\n    const getRes = await request(port, 'GET', `/api/documents/${doc.id}`);\n    expect((getRes.body as Record<string, string>).content).toBe('Hello World');\n\n    ws.close();\n  });\n\n  it('should broadcast operations to other clients', async () => {\n    const createRes = await request(port, 'POST', '/api/documents', {\n      title: 'Broadcast Test',\n      content: 'AB',\n    });\n    const doc = createRes.body as Record<string, string>;\n\n    const { ws: ws1 } = await connectWs(port, doc.id);\n    const { ws: ws2 } = await connectWs(port, doc.id);\n\n    // ws1 sends an operation, ws2 should receive it\n    const opPromise = waitForMessage(ws2, 'op');\n    ws1.send(\n      JSON.stringify({\n        type: 'op',\n        version: 0,\n        components: [\n          { type: 'retain', count: 1 },\n          { type: 'insert', text: 'X' },\n          { type: 'retain', count: 1 },\n        ],\n      })\n    );\n\n    const opMsg = await opPromise;\n    expect(opMsg.type).toBe('op');\n    expect(opMsg.version).toBe(1);\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should handle concurrent edits with OT', async () => {\n    const createRes = await request(port, 'POST', '/api/documents', {\n      title: 'OT Test',\n      content: 'AB',\n    });\n    const doc = createRes.body as Record<string, string>;\n\n    const { ws: ws1, sync: sync1 } = await connectWs(port, doc.id);\n    const { ws: ws2, sync: sync2 } = await connectWs(port, doc.id);\n\n    expect(sync1.version).toBe(0);\n    expect(sync2.version).toBe(0);\n\n    // Both clients concurrently edit from version 0\n    // Client 1: insert 'X' at position 1 => \"AXB\"\n    // Client 2: insert 'Y' at position 1 => \"AYB\"\n    // After OT, result should contain both X and Y\n\n    const ack1Promise = waitForMessage(ws1, 'ack');\n    ws1.send(\n      JSON.stringify({\n        type: 'op',\n        version: 0,\n        components: [\n          { type: 'retain', count: 1 },\n          { type: 'insert', text: 'X' },\n          { type: 'retain', count: 1 },\n        ],\n      })\n    );\n    await ack1Promise;\n\n    // Client 2 sends op against version 0 (doesn't know about X yet)\n    const ack2Promise = waitForMessage(ws2, 'ack');\n    ws2.send(\n      JSON.stringify({\n        type: 'op',\n        version: 0,\n        components: [\n          { type: 'retain', count: 1 },\n          { type: 'insert', text: 'Y' },\n          { type: 'retain', count: 1 },\n        ],\n      })\n    );\n    await ack2Promise;\n\n    // Verify the document contains both insertions\n    const getRes = await request(port, 'GET', `/api/documents/${doc.id}`);\n    const content = (getRes.body as Record<string, string>).content;\n    expect(content).toContain('X');\n    expect(content).toContain('Y');\n    expect(content).toContain('A');\n    expect(content).toContain('B');\n    expect(content.length).toBe(4); // \"A\" + \"X\" + \"Y\" + \"B\"\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should handle 10 concurrent clients', async () => {\n    const createRes = await request(port, 'POST', '/api/documents', {\n      title: 'Concurrency Test',\n      content: '',\n    });\n    const doc = createRes.body as Record<string, string>;\n\n    // Connect 10 clients\n    const clients: Array<{ ws: WebSocket; sync: { version: number } }> = [];\n    for (let i = 0; i < 10; i++) {\n      const client = await connectWs(port, doc.id);\n      clients.push(client);\n    }\n\n    // Each client inserts a character sequentially (to avoid race conditions in test)\n    for (let i = 0; i < 10; i++) {\n      const { ws } = clients[i];\n      const ackPromise = waitForMessage(ws, 'ack');\n      ws.send(\n        JSON.stringify({\n          type: 'op',\n          version: i, // Each sees the version after previous ops\n          components: [\n            ...(i > 0 ? [{ type: 'retain', count: i }] : []),\n            { type: 'insert', text: String(i) },\n          ],\n        })\n      );\n      await ackPromise;\n    }\n\n    // Verify final state\n    const getRes = await request(port, 'GET', `/api/documents/${doc.id}`);\n    const content = (getRes.body as Record<string, string>).content;\n    expect(content.length).toBe(10);\n    // All digits 0-9 should be present\n    for (let i = 0; i < 