+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PfaijhbDRPBnD6EniXnK8Q","type":"tool_result","content":"     1→import Database from 'better-sqlite3';\n     2→\n     3→export function createDatabase(filename: string = ':memory:'): Database.Database {\n     4→  const db = new Database(filename);\n     5→\n     6→  db.pragma('journal_mode = WAL');\n     7→\n     8→  db.exec(`\n     9→    CREATE TABLE IF NOT EXISTS invoices (\n    10→      id INTEGER PRIMARY KEY AUTOINCREMENT,\n    11→      customer_id TEXT NOT NULL,\n    12→      date TEXT NOT NULL,\n    13→      subtotal REAL NOT NULL,\n    14→      discount_rate REAL NOT NULL DEFAULT 0,\n    15→      tax_rate REAL NOT NULL DEFAULT 0,\n    16→      total REAL NOT NULL,\n    17→      status TEXT NOT NULL DEFAULT 'draft'\n    18→    );\n    19→\n    20→    CREATE TABLE IF NOT EXISTS line_items (\n    21→      id INTEGER PRIMARY KEY AUTOINCREMENT,\n    22→      invoice_id INTEGER NOT NULL,\n    23→      description TEXT NOT NULL,\n    24→      quantity INTEGER NOT NULL,\n    25→      unit_price REAL NOT NULL,\n    26→      FOREIGN KEY (invoice_id) REFERENCES invoices(id)\n    27→    );\n    28→  `);\n    29→\n    30→  return db;\n    31→}\n    32→"}]},"parent_tool_use_id":"toolu_01BqufdbpgQPmXRkTE73mw36","session_id":"37bc168c-cd1d-4e54-8680-ae552c9c71b7","uuid":"bc659949-9f00-4e34-8e76-033a8ea58bab"}
