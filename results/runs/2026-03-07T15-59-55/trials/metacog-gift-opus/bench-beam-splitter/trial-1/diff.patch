+import { describe, it, expect } from 'vitest';
+import { countBeamCells, countBeamPaths } from '../src/index.js';
+
+describe('countBeamCells', () => {
+  it('simple beam with no splitters', () => {
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    // Beam: (0,1) → (1,1) → (2,1)
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  it('example 1: one splitter', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(5);
+  });
+
+  it('example 2: two splitters in second row', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(6);
+  });
+
+  it('no source returns 0', () => {
+    const grid = [
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(0);
+  });
+
+  it('source only, 1 row grid', () => {
+    const grid = [['S']];
+    // Source is visited, beam tries to go down but exits
+    expect(countBeamCells(grid)).toBe(1);
+  });
+
+  it('beam goes off edge via splitter', () => {
+    const grid = [
+      ['S', '.', '.'],
+      ['^', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    // (0,0) → (1,0) hits splitter
+    // down-left → (2,-1) OOB
+    // down-right → (2,1) in bounds
+    // Visited: (0,0), (1,0), (2,1) → 3
+    expect(countBeamCells(grid)).toBe(3);
+  });
+});
+
+describe('countBeamPaths', () => {
+  it('simple beam with no splitters', () => {
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('example 1: one splitter', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it('example 2: two splitters in second row', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(4n);
+  });
+
+  it('no source returns 0n', () => {
+    const grid = [
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(0n);
+  });
+
+  it('source only, 1 row grid', () => {
+    const grid = [['S']];
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('beam goes off edge via splitter', () => {
+    const grid = [
+      ['S', '.', '.'],
+      ['^', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    // Splits at (1,0): down-left absorbed, down-right exits at bottom
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it('handles large number of splitters', () => {
+    // Create a grid where beam hits many splitters in sequence
+    const rows = 200;
+    const cols = 200;
+    const grid: string[][] = Array.from({ length: rows }, () =>
+      Array.from({ length: cols }, () => '.')
+    );
+    grid[0][100] = 'S';
+    // Place splitters along the straight-down path
+    for (let r = 1; r <= 50 && r < rows; r += 2) {
+      grid[r][100] = '^';
+    }
+    // This should complete in under 5 seconds
+    const start = performance.now();
+    const result = countBeamPaths(grid);
+    const elapsed = performance.now() - start;
+    expect(result).toBeGreaterThan(0n);
+    expect(elapsed).toBeLessThan(5000);
+  });
