+type Direction = 0 | 1 | 2; // 0=down, 1=down-left, 2=down-right
+
+function findSource(grid: string[][]): number {
+  for (let col = 0; col < grid[0].length; col++) {
+    if (grid[0][col] === 'S') return col;
+  }
+  return -1;
+}
+
+// Direction deltas: [dRow, dCol]
+const DIR_DELTA: [number, number][] = [
+  [1, 0],   // down
+  [1, -1],  // down-left
+  [1, 1],   // down-right
+];
+
+export function countBeamCells(grid: string[][]): number {
+  if (grid.length === 0 || grid[0].length === 0) return 0;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const sourceCol = findSource(grid);
+  if (sourceCol < 0) return 0;
+
+  const visited = new Set<number>(); // row * cols + col
+  const seenStates = new Set<number>(); // row * cols * 3 + col * 3 + dir
+
+  // Start: beam at source going down
+  visited.add(sourceCol); // row 0, col sourceCol
+
+  interface Beam { row: number; col: number; dir: Direction }
+  const stack: Beam[] = [{ row: 0, col: sourceCol, dir: 0 }];
+  seenStates.add(sourceCol * 3);
+
+  while (stack.length > 0) {
+    const { row, col, dir } = stack.pop()!;
+    const [dr, dc] = DIR_DELTA[dir];
+    const nr = row + dr;
+    const nc = col + dc;
+
+    if (nr < 0 || nr >= rows || nc < 0 || nc >= cols) continue;
+
+    visited.add(nr * cols + nc);
+
+    if (grid[nr][nc] === '^') {
+      // Split into down-left and down-right
+      for (const newDir of [1, 2] as Direction[]) {
+        const stateKey = nr * cols * 3 + nc * 3 + newDir;
+        if (!seenStates.has(stateKey)) {
+          seenStates.add(stateKey);
+          stack.push({ row: nr, col: nc, dir: newDir });
+        }
+      }
+    } else {
+      const stateKey = nr * cols * 3 + nc * 3 + dir;
+      if (!seenStates.has(stateKey)) {
+        seenStates.add(stateKey);
+        stack.push({ row: nr, col: nc, dir });
+      }
+    }
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  if (grid.length === 0 || grid[0].length === 0) return 0n;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const sourceCol = findSource(grid);
+  if (sourceCol < 0) return 0n;
+
+  // Process row by row. For each row, track active beams as Map<stateKey, pathCount>
+  // stateKey encodes (col, direction)
+  // A beam at (row, col, dir) with N paths means N distinct paths reach this state.
+
+  // Start: 1 path at (row=0, col=sourceCol, dir=down)
+  // We use a map from (col * 3 + dir) -> pathCount for each row
+  let currentBeams = new Map<number, bigint>();
+  currentBeams.set(sourceCol * 3 + 0, 1n); // col=sourceCol, dir=down
+
+  let totalPaths = 0n;
+
+  for (let row = 0; row < rows; row++) {
+    const nextBeams = new Map<number, bigint>();
+
+    for (const [stateKey, paths] of currentBeams) {
+      const col = (stateKey / 3) | 0;
+      const dir = stateKey % 3;
+      const [dr, dc] = DIR_DELTA[dir];
+      const nr = row + dr;
+      const nc = col + dc;
+
+      if (nr < 0 || nr >= rows || nc < 0 || nc >= cols) {
+        // Beam exits grid
+        totalPaths += paths;
+        continue;
+      }
+
+      if (grid[nr][nc] === '^') {
+        // Split into down-left and down-right
+        for (const newDir of [1, 2]) {
+          const newKey = nc * 3 + newDir;
+          nextBeams.set(newKey, (nextBeams.get(newKey) ?? 0n) + paths);
+        }
+      } else {
+        const newKey = nc * 3 + dir;
+        nextBeams.set(newKey, (nextBeams.get(newKey) ?? 0n) + paths);
+      }
+    }
+
+    currentBeams = nextBeams;
+  }
+
+  // Any beams still active after the last row exit the grid
+  for (const paths of currentBeams.values()) {
+    totalPaths += paths;
+  }
+
+  return totalPaths;
+}
