@@ -0,0 +1,44 @@
+import { Plugin, BuildContext } from '../core/types.js';
+
+interface Route {
+  path: string;
+  handler: string;
+}
+
+export function createDevServerPlugin(): Plugin {
+  return {
+    name: 'dev-server',
+    version: '1.0.0',
+    dependencies: ['asset-pipeline', 'search-index'],
+    hooks: {
+      afterBuild(ctx: BuildContext): void {
+        const routes: Route[] = [];
+        const assetManifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;
+        const assetPaths: string[] = assetManifest ? [...assetManifest.assets] : [];
+
+        // Add asset routes
+        for (const asset of assetPaths) {
+          routes.push({ path: `/assets/${asset}`, handler: 'asset' });
+        }
+
+        // Determine search index path
+        const hasSearchIndex = ctx.output.has('search-index.json');
+        const searchIndexPath = hasSearchIndex ? '/search-index.json' : '';
+
+        // Add content routes for HTML files in output
+        for (const path of ctx.output.keys()) {
+          if (path.endsWith('.html')) {
+            routes.push({ path: `/${path}`, handler: 'static' });
+          }
+        }
+
+        ctx.data.set('dev-server-config', {
+          port: 3000,
+          routes,
+          assetPaths,
+          searchIndexPath,
+        });
+      },
+    },
+  };
+}
