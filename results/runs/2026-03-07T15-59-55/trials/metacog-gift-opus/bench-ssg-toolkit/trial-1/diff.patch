sync () => {\n    const output = new Map<string, string>();\n    output.set('post-1.html', '<html></html>');\n    const ctx = makeCtx(output);\n    await plugin.hooks.afterBuild!(ctx);\n    expect(ctx.output.has('sitemap.xml')).toBe(true);\n  });\n\n  it('includes all content page URLs', async () => {\n    const output = new Map<string, string>();\n    output.set('post-1.html', '<html></html>');\n    output.set('post-2.html', '<html></html>');\n    const ctx = makeCtx(output);\n    await plugin.hooks.afterBuild!(ctx);\n    const sitemap = ctx.output.get('sitemap.xml')!;\n    expect(sitemap).toContain('https://example.com/post-1.html');\n    expect(sitemap).toContain('https://example.com/post-2.html');\n  });\n\n  it('includes taxonomy tag page URLs', async () => {\n    const output = new Map<string, string>();\n    output.set('tags/javascript.html', '<html>js tag page</html>');\n    const tagMap = new Map<string, ContentFile[]>();\n    tagMap.set('javascript', []);\n    const data = new Map<string, unknown>();\n    data.set('taxonomy-tags', tagMap);\n    const ctx = makeCtx(output, data);\n    await plugin.hooks.afterBuild!(ctx);\n    const sitemap = ctx.output.get('sitemap.xml')!;\n    expect(sitemap).toContain('https://example.com/tags/javascript.html');\n  });\n\n  it('includes feed.xml URL', async () => {\n    const output = new Map<string, string>();\n    output.set('feed.xml', '<rss></rss>');\n    const ctx = makeCtx(output);\n    await plugin.hooks.afterBuild!(ctx);\n    const sitemap = ctx.output.get('sitemap.xml')!;\n    expect(sitemap).toContain('https://example.com/feed.xml');\n  });\n\n  it('URLs use baseUrl from config', async () => {\n    const output = new Map<string, string>();\n    output.set('about.html', '<html></html>');\n    const ctx = makeCtx(output);\n    await plugin.hooks.afterBuild!(ctx);\n    const sitemap = ctx.output.get('sitemap.xml')!;\n    expect(sitemap).toContain('https://example.com/about.html');\n  });\n\n  it('sitemap is valid X