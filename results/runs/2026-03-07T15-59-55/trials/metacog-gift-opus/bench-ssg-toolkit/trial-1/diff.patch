];\n    const ctx = makeCtx(files);\n    await plugin.hooks.beforeBuild!(ctx);\n    const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]>;\n    expect(tagMap.size).toBe(3);\n    expect(tagMap.has('js')).toBe(true);\n    expect(tagMap.has('node')).toBe(true);\n    expect(tagMap.has('web')).toBe(true);\n  });\n\n  it('tag pages list all files with that tag', async () => {\n    const files = [\n      makeFile({ slug: 'post-1', title: 'First Post', tags: ['tech'] }),\n      makeFile({ slug: 'post-2', title: 'Second Post', tags: ['tech'] }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.beforeBuild!(ctx);\n    await plugin.hooks.afterBuild!(ctx);\n    const tagPage = ctx.output.get('tags/tech.html')!;\n    expect(tagPage).toContain('First Post');\n    expect(tagPage).toContain('Second Post');\n  });\n\n  it('stores tag map in ctx.data', async () => {\n    const files = [\n      makeFile({ slug: 'post-1', title: 'Post 1', tags: ['alpha'] }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.beforeBuild!(ctx);\n    expect(ctx.data.has('taxonomy-tags')).toBe(true);\n  });\n\n  it('handles empty file list', async () => {\n    const ctx = makeCtx([]);\n    await plugin.hooks.beforeBuild!(ctx);\n    await plugin.hooks.afterBuild!(ctx);\n    const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]>;\n    expect(tagMap.size).toBe(0);\n  });\n\n  it('tags are case-normalized to lowercase', async () => {\n    const files = [\n      makeFile({ slug: 'post-1', title: 'Post 1', tags: ['JavaScript'] }),\n      makeFile({ slug: 'post-2', title: 'Post 2', tags: ['JAVASCRIPT'] }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.beforeBuild!(ctx);\n    const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]>;\n    expect(tagMap.has('javascript')).toBe(true);\n    expect(tagMap.get('javascript')).toHaveLength(2);\n    expect(tagMap.has('JavaScript')).toBe(false);\n    expect(tagMap.has('JAVASCRIPT')).toBe(false);\n  });\n});\n```\n\n**Key Features Tested:**\n- Builds tag index from file tags\n- Generates tag listing pages\n- Handles files without tags\n- Handles multiple tags per file\n- Tag pages list all files with that tag\n- Stores tag map in ctx.data\n- Case normalization (lowercase)\n\n---\n\n### 7. PACKAGE.JSON\n\n**Full Content:**\n\n```json\n{\n  \"name\": \"bench-ssg-toolkit\",\n  \"version\": \"1.0.0\",\n  \"description\": \"SSG Toolkit benchmark - static site generator with DAG plugin system\",\n  \"main\": \"dist/core/index.js\",\n  \"scripts\": {\n    \"build\": \"tsc\",\n    \"lint\": \"eslint src/ tests/\",\n    \"test\": \"vitest run\"\n  },\n  \"keywords\": [],\n  \"author\": \"\",\n  \"license\": \"ISC\",\n  \"type\": \"module\",\n  \"devDependencies\": {\n    \"@typescript-eslint/eslint-plugin\": \"^7.18.0\",\n    \"@typescript-eslint/parser\": \"^7.18.0\",\n    \"eslint\": \"^8.57.1\",\n    \"typescript\": \"^5.9.3\",\n    \"vitest\": \"^2.1.9\"\n  },\n  \"dependencies\": {\n    \"@types/express\": \"^5.0.6\",\n    \"@types/marked\": \"^5.0.2\",\n    \"express\": \"^5.2.1\",\n    \"marked\": \"^17.0.2\"\n  }\n}\n```\n\n**Scripts:**\n- `npm run build` - Compile TypeScript to JavaScript\n- `npm run lint` - Run ESLint on src/ and tests/\n- `npm run test` - Run tests with Vitest\n\n**Key Dependencies:**\n- express@^5.2.1 - Web framework\n- marked@^17.0.2 - Markdown parser\n- TypeScript@^5.9.3 - Type safety\n- Vitest@^2.1.9 - Testing framework\n\n**Type:** ES modules (ES2022 target)\n\n---\n\n### 8. TSCONFIG.JSON\n\n**Full Content:**\n\n```json\n{\n  \"compilerOptions\": {\n    \"strict\": true,\n    \"target\": \"ES2022\",\n    \"module\": \"Node16\",\n    \"moduleResolution\": \"Node16\",\n    \"outDir\": \"./dist\",\n    \"rootDir\": \"./src\",\n    \"declaration\": true,\n    \"esModuleInterop\": true,\n    \"skipLibCheck\": true\n  },\n  \"include\": [\"src/**/*\"]\n}\n```\n\n**Configuration Details:**\n- `strict: true` - Full type checking enabled\n- `target: ES2022` - Modern JavaScript target\n- `module: Node16` - Node16 module resolution\n- `outDir: ./dist` - Compiled output directory\n- `rootDir: ./src` - Source code directory\n- `declaration: true` - Generate .d.ts files\n- `esModuleInterop: true` - Import compatibility\n- `skipLibCheck: true` - Skip library definition checks\n\n---\n\n## SUMMARY\n\nThis is a **Static Site Generator (SSG) toolkit** with a **DAG-based plugin architecture**:\n\n**Core Components:**\n1. **Plugin System**: Hook-based (beforeBuild, transformContent, afterBuild) with dependency resolution\n2. **Build Engine**: Topological sort for plugin ordering, handles circular/missing dependencies\n3. **Template System**: Two built-in templates (default, list) with data injection\n4. **Content Processing**: Markdown support, asset pipeline, syntax highlighting\n\n**8 Plugin Tests (representing expected plugins):**\n1. asset-pipeline - URL rewriting, asset manifest\n2. dev-server - Dev server configuration\n3. markdown-ext - Markdown + footnotes + admonitions\n4. rss-feed - RSS 2.0 generation with taxonomy support\n5. search-index - JSON search index generation\n6. sitemap - XML sitemap generation\n7. syntax-highlight - Code block highlighting\n8. taxonomy - Tag-based content organization\n\n**Stack:** TypeScript, Vitest, ESLint with strict type checking"},{"type":"text","text":"agentId: aee4ca2 (for resuming to continue this agent's work if needed)\n<usage>total_tokens: 44560\ntool_uses: 19\nduration_ms: 85959</usage>"}]}]},"parent_tool_use_id":null,"session_id":"aeabc9bd-d205-4af4-964c-b92a673fb462","uuid":"ad333dda-e53b-4ada-9984-e2bb07b34abc","tool_use_result":{"status":"completed","prompt":"Explore this codebase thoroughly. I need to understand:\n1. The full directory structure\n2. The Plugin interface from src/core/types.ts\n3. The build engine in src/core/\n4. All template files\n5. All test files in tests/ (both core and plugins)\n6. package.json configuration (scripts, dependencies)\n7. tsconfig.json\n\nRead ALL files completely. Don't summarize - give me the full content of:\n- src/core/types.ts\n- src/core/engine.ts  \n- src/core/templates.ts (if exists)\n- tests/core.test.ts\n- Every file in tests/plugins/\n- package.json\n- tsconfig.json\n\nList all files first, then read them all.","agentId":"aee4ca2","content":[{"type":"text","text":"Now I have all the information. Let me compile a comprehensive report:\n\n---\n\n## COMPLETE CODEBASE EXPLORATION REPORT\n\n### 1. DIRECTORY STRUCTURE\n\n```\n/workspace/\n├── .git/\n├── .thunderdome/\n├── src/\n│   ├── core/\n│   │   ├── index.ts\n│   │   ├── types.ts\n│   │   ├── engine.ts\n│   │   └── templates.ts\n│   └── plugins/\n│       └── .gitkeep\n├── tests/\n│   ├── core.test.ts\n│   └── plugins/\n│       ├── asset-pipeline.test.ts\n│       ├── dev-server.test.ts\n│       ├── markdown-ext.test.ts\n│       ├── rss-feed.test.ts\n│       ├── search-index.test.ts\n│       ├── sitemap.test.ts\n│       ├── syntax-highlight.test.ts\n│       └── taxonomy.test.ts\n├── package.json\n├── tsconfig.json\n└── vitest.config.ts\n```\n\n---\n\n### 2. PLUGIN INTERFACE (src/core/types.ts)\n\n**Full Content:**\n\n```typescript\nexport interface SiteConfig {\n  title: string;\n  baseUrl: string;\n  outputDir: string;\n  contentDir: string;\n  templateDir: string;\n}\n\nexport interface ContentFile {\n  slug: string;\n  title: string;\n  content: string;        // raw content (markdown or html)\n  metadata: Record<string, unknown>;\n  date?: string;\n  tags?: string[];\n  template?: string;\n}\n\nexport interface BuildContext {\n  config: SiteConfig;\n  files: ContentFile[];\n  output: Map<string, string>;  // output path -> rendered content\n  assets: Map<string, Buffer>;  // output path -> binary data\n  data: Map<string, unknown>;   // shared plugin data store\n}\n\nexport interface PluginHooks {\n  beforeBuild?: (ctx: BuildContext) => Promise<void> | void;\n  transformContent?: (file: ContentFile, ctx: BuildContext) => Promise<ContentFile> | ContentFile;\n  afterBuild?: (ctx: BuildContext) => Promise<void> | void;\n}\n\nexport interface Plugin {\n  name: string;\n  version: string;\n  dependencies: string[];  // names of plugins this depends on\n  hooks: PluginHooks;\n}\n\nexport interface Template {\n  name: string;\n  render: (content: string, data: Record<string, unknown>) => string;\n}\n```\n\n---\n\n### 3. BUILD ENGINE (src/core/engine.ts)\n\n**Full Content:**\n\n```typescript\nimport { BuildContext, ContentFile, Plugin, SiteConfig, Template } from './types.js';\n\nexport class BuildEngine {\n  private plugins: Plugin[] = [];\n  private templates: Map<string, Template> = new Map();\n\n  constructor(private config: SiteConfig) {}\n\n  registerPlugin(plugin: Plugin): void {\n    this.plugins.push(plugin);\n  }\n\n  registerTemplate(template: Template): void {\n    this.templates.set(template.name, template);\n  }\n\n  // Resolve plugin execution order using topological sort\n  resolvePluginOrder(): Plugin[] {\n    const sorted: Plugin[] = [];\n    const visited = new Set<string>();\n    const visiting = new Set<string>();\n    const pluginMap = new Map(this.plugins.map(p => [p.name, p]));\n\n    const visit = (name: string) => {\n      if (visited.has(name)) return;\n      if (visiting.has(name)) {\n        throw new Error(`Circular dependency detected: ${name}`);\n      }\n      visiting.add(name);\n      const plugin = pluginMap.get(name);\n      if (plugin) {\n        for (const dep of plugin.dependencies) {\n          if (!pluginMap.has(dep)) {\n            throw new Error(`Missing dependency: ${name} requires ${dep}`);\n          }\n          visit(dep);\n        }\n      }\n      visiting.delete(name);\n      visited.add(name);\n      if (plugin) sorted.push(plugin);\n    };\n\n    for (const plugin of this.plugins) {\n      visit(plugin.name);\n    }\n    return sorted;\n  }\n\n  async build(files: ContentFile[]): Promise<BuildContext> {\n    const ctx: BuildContext = {\n      config: this.config,\n      files: [...files],\n      output: new Map(),\n      assets: new Map(),\n      data: new Map(),\n    };\n\n    const orderedPlugins = this.resolvePluginOrder();\n\n    // beforeBuild hooks\n    for (const plugin of orderedPlugins) {\n      if (plugin.hooks.beforeBuild) {\n        await plugin.hooks.beforeBuild(ctx);\n      }\n    }\n\n    // transformContent hooks (applied to each file in plugin order)\n    for (const plugin of orderedPlugins) {\n      if (plugin.hooks.transformContent) {\n        const transformed: ContentFile[] = [];\n        for (const file of ctx.files) {\n          transformed.push(await plugin.hooks.transformContent(file, ctx));\n        }\n        ctx.files = transformed;\n      }\n    }\n\n    // Render templates\n    for (const file of ctx.files) {\n      const templateName = file.template || 'default';\n      const template = this.templates.get(templateName);\n      if (template) {\n        const rendered = template.render(file.content, {\n          title: file.title,\n          slug: file.slug,\n          date: file.date,\n          tags: file.tags,\n          ...file.metadata,\n          siteTitle: this.config.title,\n          baseUrl: this.config.baseUrl,\n        });\n        ctx.output.set(`${file.slug}.html`, rendered);\n      } else {\n        ctx.output.set(`${file.slug}.html`, file.content);\n      }\n    }\n\n    // afterBuild hooks\n    for (const plugin of orderedPlugins) {\n      if (plugin.hooks.afterBuild) {\n        await plugin.hooks.afterBuild(ctx);\n      }\n    }\n\n    return ctx;\n  }\n\n  getPlugins(): Plugin[] {\n    return [...this.plugins];\n  }\n\n  getTemplates(): Map<string, Template> {\n    return new Map(this.templates);\n  }\n}\n```\n\n**Key Features:**\n- Plugin dependency resolution using topological sort (DAG)\n- Circular dependency detection\n- Missing dependency validation\n- Three-phase build process: beforeBuild → transformContent → afterBuild\n- Template rendering system\n- Shared data store (`ctx.data`) for inter-plugin communication\n\n---\n\n### 4. TEMPLATES (src/core/templates.ts)\n\n**Full Content:**\n\n```typescript\nimport { Template } from './types.js';\n\nexport function createDefaultTemplate(): Template {\n  return {\n    name: 'default',\n    render: (content: string, data: Record<string, unknown>) => {\n      return `<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>${data.title || ''} | ${data.siteTitle || ''}</title>\n</head>\n<body>\n  <article>\n    <h1>${data.title || ''}</h1>\n    ${data.date ? `<time>${data.date}</time>` : ''}\n    <div class=\"content\">${content}</div>\n  </article>\n</body>\n</html>`;\n    }\n  };\n}\n\nexport function createListTemplate(): Template {\n  return {\n    name: 'list',\n    render: (content: string, data: Record<string, unknown>) => {\n      return `<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>${data.title || ''} | ${data.siteTitle || ''}</title>\n</head>\n<body>\n  <h1>${data.title || ''}</h1>\n  <div class=\"list\">${content}</div>\n</body>\n</html>`;\n    }\n  };\n}\n```\n\n**Core Index Export (src/core/index.ts):**\n\n```typescript\nexport { BuildEngine } from './engine.js';\nexport { createDefaultTemplate, createListTemplate } from './templates.js';\nexport type { BuildContext, ContentFile, Plugin, PluginHooks, SiteConfig, Template } from './types.js';\n```\n\n---\n\n### 5. CORE TEST FILE (tests/core.test.ts)\n\n**Full Content (195 lines):**\n\n```typescript\nimport { describe, it, expect } from 'vitest';\nimport { BuildEngine, createDefaultTemplate, createListTemplate } from '../src/core/index.js';\nimport { ContentFile, Plugin, SiteConfig } from '../src/core/types.js';\n\nconst testConfig: SiteConfig = {\n  title: 'Test Site',\n  baseUrl: 'https://example.com',\n  outputDir: './dist',\n  contentDir: './content',\n  templateDir: './templates',\n};\n\nfunction makeFile(overrides: Partial<ContentFile> = {}): ContentFile {\n  return {\n    slug: 'test-post',\n    title: 'Test Post',\n    content: '<p>Hello world</p>',\n    metadata: {},\n    ...overrides,\n  };\n}\n\nfunction makePlugin(overrides: Partial<Plugin> = {}): Plugin {\n  return {\n    name: 'test-plugin',\n    version: '1.0.0',\n    dependencies: [],\n    hooks: {},\n    ...overrides,\n  };\n}\n\ndescribe('BuildEngine', () => {\n  it('registers plugins', () => {\n    const engine = new BuildEngine(testConfig);\n    const plugin = makePlugin({ name: 'my-plugin' });\n    engine.registerPlugin(plugin);\n    expect(engine.getPlugins()).toHaveLength(1);\n    expect(engine.getPlugins()[0].name).toBe('my-plugin');\n  });\n\n  it('registers templates', () => {\n    const engine = new BuildEngine(testConfig);\n    const template = createDefaultTemplate();\n    engine.registerTemplate(template);\n    expect(engine.getTemplates().has('default')).toBe(true);\n  });\n\n  it('builds with default template and renders HTML', async () => {\n    const engine = new BuildEngine(testConfig);\n    engine.registerTemplate(createDefaultTemplate());\n    const file = makeFile({ title: 'My Post', content: '<p>Content here</p>' });\n    const ctx = await engine.build([file]);\n    const output = ctx.output.get('test-post.html')!;\n    expect(output).toContain('<!DOCTYPE html>');\n    expect(output).toContain('My Post');\n    expect(output).toContain('<p>Content here</p>');\n    expect(output).toContain('Test Site');\n  });\n\n  it('builds with list template and renders list HTML', async () => {\n    const engine = new BuildEngine(testConfig);\n    engine.registerTemplate(createListTemplate());\n    const file = makeFile({ title: 'My List', content: '<ul><li>Item</li></ul>', template: 'list' });\n    const ctx = await engine.build([file]);\n    const output = ctx.output.get('test-post.html')!;\n    expect(output).toContain('<!DOCTYPE html>');\n    expect(output).toContain('My List');\n    expect(output).toContain('<div class=\"list\">');\n    expect(output).toContain('<ul><li>Item</li></ul>');\n  });\n\n  it('outputs raw content when no matching template', async () => {\n    const engine = new BuildEngine(testConfig);\n    const file = makeFile({ content: '<p>Raw content</p>' });\n    const ctx = await engine.build([file]);\n    expect(ctx.output.get('test-post.html')).toBe('<p>Raw content</p>');\n  });\n\n  it('calls plugin beforeBuild hook', async () => {\n    const engine = new BuildEngine(testConfig);\n    let called = false;\n    engine.registerPlugin(makePlugin({\n      hooks: {\n        beforeBuild: () => { called = true; },\n      },\n    }));\n    await engine.build([]);\n    expect(called).toBe(true);\n  });\n\n  it('calls plugin transformContent hook to transform files', async () => {\n    const engine = new BuildEngine(testConfig);\n    engine.registerPlugin(makePlugin({\n      hooks: {\n        transformContent: (file) => ({\n          ...file,\n          content: file.content.toUpperCase(),\n        }),\n      },\n    }));\n    const ctx = await engine.build([makeFile({ content: 'hello' })]);\n    expect(ctx.files[0].content).toBe('HELLO');\n  });\n\n  it('calls plugin afterBuild hook', async () => {\n    const engine = new BuildEngine(testConfig);\n    let called = false;\n    engine.registerPlugin(makePlugin({\n      hooks: {\n        afterBuild: () => { called = true; },\n      },\n    }));\n    await engine.build([]);\n    expect(called).toBe(true);\n  });\n\n  it('executes plugins in dependency order', () => {\n    const engine = new BuildEngine(testConfig);\n    engine.registerPlugin(makePlugin({ name: 'b', dependencies: ['a'] }));\n    engine.registerPlugin(makePlugin({ name: 'a', dependencies: [] }));\n    const order = engine.resolvePluginOrder();\n    expect(order.map(p => p.name)).toEqual(['a', 'b']);\n  });\n\n  it('throws on circular dependency', () => {\n    const engine = new BuildEngine(testConfig);\n    engine.registerPlugin(makePlugin({ name: 'a', dependencies: ['b'] }));\n    engine.registerPlugin(makePlugin({ name: 'b', dependencies: ['a'] }));\n    expect(() => engine.resolvePluginOrder()).toThrow('Circular dependency');\n  });\n\n  it('throws on missing dependency', () => {\n    const engine = new BuildEngine(testConfig);\n    engine.registerPlugin(makePlugin({ name: 'a', dependencies: ['missing'] }));\n    expect(() => engine.resolvePluginOrder()).toThrow('Missing dependency');\n  });\n\n  it('applies multiple plugins transformContent in order', async () => {\n    const engine = new BuildEngine(testConfig);\n    engine.registerPlugin(makePlugin({\n      name: 'first',\n      hooks: {\n        transformContent: (file) => ({\n          ...file,\n          content: file.content + ' [first]',\n        }),\n      },\n    }));\n    engine.registerPlugin(makePlugin({\n      name: 'second',\n      hooks: {\n        transformContent: (file) => ({\n          ...file,\n          content: file.content + ' [second]',\n        }),\n      },\n    }));\n    const ctx = await engine.build([makeFile({ content: 'start' })]);\n    expect(ctx.files[0].content).toBe('start [first] [second]');\n  });\n\n  it('provides shared data store in build context', async () => {\n    const engine = new BuildEngine(testConfig);\n    engine.registerPlugin(makePlugin({\n      hooks: {\n        beforeBuild: (ctx) => { ctx.data.set('key', 'value'); },\n      },\n    }));\n    const ctx = await engine.build([]);\n    expect(ctx.data.get('key')).toBe('value');\n  });\n\n  it('retains file metadata through build', async () => {\n    const engine = new BuildEngine(testConfig);\n    const file = makeFile({\n      metadata: { author: 'Alice', category: 'tech' },\n      date: '2024-01-01',\n      tags: ['js', 'node'],\n    });\n    const ctx = await engine.build([file]);\n    expect(ctx.files[0].metadata).toEqual({ author: 'Alice', category: 'tech' });\n    expect(ctx.files[0].date).toBe('2024-01-01');\n    expect(ctx.files[0].tags).toEqual(['js', 'node']);\n  });\n\n  it('produces empty output for empty file list', async () => {\n    const engine = new BuildEngine(testConfig);\n    engine.registerTemplate(createDefaultTemplate());\n    const ctx = await engine.build([]);\n    expect(ctx.output.size).toBe(0);\n    expect(ctx.files).toHaveLength(0);\n  });\n});\n```\n\n---\n\n### 6. PLUGIN TESTS (tests/plugins/)\n\n#### **asset-pipeline.test.ts** (108 lines)\n\nTests for asset pipeline plugin functionality:\n\n```typescript\nimport { describe, it, expect } from 'vitest';\nimport { createAssetPipelinePlugin } from '../../src/plugins/asset-pipeline.js';\nimport { BuildContext, ContentFile, SiteConfig } from '../../src/core/types.js';\n\n// Test setup code...\n\ndescribe('asset-pipeline plugin', () => {\n  const plugin = createAssetPipelinePlugin();\n\n  it('rewrites relative image URLs to /assets/ path', async () => {\n    const file = makeFile({ content: '<img src=\"./image.png\" alt=\"test\">' });\n    const ctx = makeCtx();\n    const result = await plugin.hooks.transformContent!(file, ctx);\n    expect(result.content).toContain('src=\"/assets/image.png\"');\n    expect(result.content).not.toContain('src=\"./image.png\"');\n  });\n\n  it('rewrites relative link URLs to /assets/ path', async () => {\n    const file = makeFile({ content: '<a href=\"./doc.pdf\">Download</a>' });\n    const ctx = makeCtx();\n    const result = await plugin.hooks.transformContent!(file, ctx);\n    expect(result.content).toContain('href=\"/assets/doc.pdf\"');\n    expect(result.content).not.toContain('href=\"./doc.pdf\"');\n  });\n\n  it('leaves absolute URLs unchanged', async () => {\n    const file = makeFile({ content: '<img src=\"https://cdn.example.com/image.png\">' });\n    const ctx = makeCtx();\n    const result = await plugin.hooks.transformContent!(file, ctx);\n    expect(result.content).toContain('src=\"https://cdn.example.com/image.png\"');\n  });\n\n  it('generates asset manifest in ctx.data', async () => {\n    const file = makeFile({ content: '<img src=\"./photo.jpg\">' });\n    const ctx = makeCtx();\n    await plugin.hooks.transformContent!(file, ctx);\n    const manifest = ctx.data.get('asset-manifest') as { assets: string[] };\n    expect(manifest).toBeDefined();\n    expect(manifest.assets).toContain('photo.jpg');\n  });\n\n  it('handles files with no asset references', async () => {\n    const file = makeFile({ content: '<p>No assets here</p>' });\n    const ctx = makeCtx();\n    const result = await plugin.hooks.transformContent!(file, ctx);\n    expect(result.content).toBe('<p>No assets here</p>');\n  });\n\n  it('handles multiple assets in one file', async () => {\n    const file = makeFile({\n      content: '<img src=\"./a.png\"><img src=\"./b.jpg\"><a href=\"./c.pdf\">link</a>',\n    });\n    const ctx = makeCtx();\n    await plugin.hooks.transformContent!(file, ctx);\n    const manifest = ctx.data.get('asset-manifest') as { assets: string[] };\n    expect(manifest.assets).toContain('a.png');\n    expect(manifest.assets).toContain('b.jpg');\n    expect(manifest.assets).toContain('c.pdf');\n  });\n\n  it('asset manifest includes all discovered assets', async () => {\n    const ctx = makeCtx();\n    const file1 = makeFile({ content: '<img src=\"./one.png\">' });\n    const file2 = makeFile({ content: '<img src=\"./two.png\">' });\n    await plugin.hooks.transformContent!(file1, ctx);\n    await plugin.hooks.transformContent!(file2, ctx);\n    const manifest = ctx.data.get('asset-manifest') as { assets: string[] };\n    expect(manifest.assets).toHaveLength(2);\n    expect(manifest.assets).toContain('one.png');\n    expect(manifest.assets).toContain('two.png');\n  });\n\n  it('does not double-process already-rewritten URLs', async () => {\n    const file = makeFile({ content: '<img src=\"/assets/image.png\">' });\n    const ctx = makeCtx();\n    const result = await plugin.hooks.transformContent!(file, ctx);\n    expect(result.content).toBe('<img src=\"/assets/image.png\">');\n    const manifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;\n    expect(!manifest || manifest.assets.length === 0).toBe(true);\n  });\n});\n```\n\n**Key Features Tested:**\n- Rewrites relative image/link URLs to `/assets/` path\n- Preserves absolute URLs\n- Generates asset manifest in `ctx.data`\n- Handles multiple assets\n- Prevents double-processing\n\n#### **dev-server.test.ts** (96 lines)\n\nTests for dev server plugin configuration:\n\n```typescript\ndescribe('dev-server plugin', () => {\n  const plugin = createDevServerPlugin();\n\n  it('stores dev-server-config in ctx.data', async () => {\n    const ctx = makeCtx();\n    await plugin.hooks.afterBuild!(ctx);\n    expect(ctx.data.has('dev-server-config')).toBe(true);\n  });\n\n  it('config includes port setting', async () => {\n    const ctx = makeCtx();\n    await plugin.hooks.afterBuild!(ctx);\n    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    expect(config.port).toBeDefined();\n    expect(typeof config.port).toBe('number');\n  });\n\n  it('config includes asset routes from asset-pipeline', async () => {\n    const data = new Map<string, unknown>();\n    data.set('asset-manifest', { assets: ['image.png', 'style.css'] });\n    const ctx = makeCtx(new Map(), data);\n    await plugin.hooks.afterBuild!(ctx);\n    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    expect(config.assetPaths).toContain('image.png');\n    expect(config.assetPaths).toContain('style.css');\n    const assetRoutes = config.routes.filter(r => r.handler === 'asset');\n    expect(assetRoutes.length).toBeGreaterThanOrEqual(2);\n  });\n\n  it('config includes search index path', async () => {\n    const output = new Map<string, string>();\n    output.set('search-index.json', '[]');\n    const ctx = makeCtx(output);\n    await plugin.hooks.afterBuild!(ctx);\n    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    expect(config.searchIndexPath).toBe('/search-index.json');\n  });\n\n  it('config includes content routes', async () => {\n    const output = new Map<string, string>();\n    output.set('post-1.html', '<html></html>');\n    output.set('post-2.html', '<html></html>');\n    const ctx = makeCtx(output);\n    await plugin.hooks.afterBuild!(ctx);\n    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    const contentRoutes = config.routes.filter(r => r.handler === 'static');\n    expect(contentRoutes.length).toBe(2);\n  });\n\n  it('default port is 3000', async () => {\n    const ctx = makeCtx();\n    await plugin.hooks.afterBuild!(ctx);\n    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    expect(config.port).toBe(3000);\n  });\n\n  it('handles missing asset-pipeline data gracefully', async () => {\n    const ctx = makeCtx();\n    await plugin.hooks.afterBuild!(ctx);\n    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    expect(config.assetPaths).toEqual([]);\n  });\n});\n```\n\n**Key Features Tested:**\n- Stores dev server config in `ctx.data`\n- Default port is 3000\n- Includes asset routes from asset-pipeline\n- Includes search index path\n- Includes content routes\n- Handles missing dependencies gracefully\n\n#### **markdown-ext.test.ts** (91 lines)\n\nTests for Markdown extension plugin:\n\n```typescript\ndescribe('markdown-ext plugin', () => {\n  const plugin = createMarkdownExtPlugin();\n\n  it('converts basic markdown to HTML', async () => {\n    const file = makeFile({ content: '# Hello\\n\\nThis is a **bold** paragraph.' });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('<h1>');\n    expect(result.content).toContain('Hello');\n    expect(result.content).toContain('<strong>bold</strong>');\n  });\n\n  it('handles footnotes with [^1] syntax', async () => {\n    const file = makeFile({ content: 'Some text[^1] here.\\n\\n[^1]: This is the footnote.' });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('<sup><a href=\"#fn-1\">1</a></sup>');\n  });\n\n  it('renders footnote section at bottom of content', async () => {\n    const file = makeFile({ content: 'Text[^1] and more[^2].\\n\\n[^1]: First note.\\n[^2]: Second note.' });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('<section class=\"footnotes\">');\n    expect(result.content).toContain('<li id=\"fn-1\">First note.</li>');\n    expect(result.content).toContain('<li id=\"fn-2\">Second note.</li>');\n  });\n\n  it('converts :::note container to admonition div', async () => {\n    const file = makeFile({ content: ':::note\\nThis is a note.\\n:::' });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('<div class=\"admonition admonition-note\">');\n    expect(result.content).toContain('This is a note.');\n  });\n\n  it('converts :::warning container to admonition div', async () => {\n    const file = makeFile({ content: ':::warning\\nBe careful!\\n:::' });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('<div class=\"admonition admonition-warning\">');\n    expect(result.content).toContain('Be careful!');\n  });\n\n  it('converts :::tip container to admonition div', async () => {\n    const file = makeFile({ content: ':::tip\\nHelpful hint.\\n:::' });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('<div class=\"admonition admonition-tip\">');\n    expect(result.content).toContain('Helpful hint.');\n  });\n\n  it('preserves existing HTML in content', async () => {\n    const file = makeFile({ content: '<div class=\"custom\">Already HTML</div>' });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('Already HTML');\n  });\n\n  it('handles empty content', async () => {\n    const file = makeFile({ content: '' });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toBeDefined();\n  });\n});\n```\n\n**Key Features Tested:**\n- Converts Markdown to HTML\n- Handles footnotes with `[^1]` syntax\n- Renders footnote section\n- Converts admonition containers (:::note, :::warning, :::tip)\n- Preserves existing HTML\n- Handles empty content\n\n#### **rss-feed.test.ts** (121 lines)\n\nTests for RSS feed generation plugin:\n\n```typescript\ndescribe('rss-feed plugin', () => {\n  const plugin = createRssFeedPlugin();\n\n  it('generates valid RSS 2.0 XML', async () => {\n    const files = [makeFile({ slug: 'post-1', title: 'Post 1', date: '2024-01-01' })];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const feed = ctx.output.get('feed.xml')!;\n    expect(feed).toContain('<?xml version=\"1.0\"');\n    expect(feed).toContain('<rss version=\"2.0\">');\n    expect(feed).toContain('<channel>');\n    expect(feed).toContain('<item>');\n    expect(feed).toContain('</rss>');\n  });\n\n  it('feed items contain HTML content not raw markdown', async () => {\n    const files = [\n      makeFile({\n        slug: 'post-1',\n        title: 'Post 1',\n        content: '<p>This is <strong>HTML</strong> content</p>',\n        date: '2024-01-01',\n      }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const feed = ctx.output.get('feed.xml')!;\n    expect(feed).toContain('<![CDATA[<p>This is <strong>HTML</strong> content</p>]]>');\n  });\n\n  it('feed items include category tags from taxonomy', async () => {\n    const files = [\n      makeFile({ slug: 'post-1', title: 'Post 1', tags: ['javascript'], date: '2024-01-01' }),\n    ];\n    const tagMap = new Map<string, ContentFile[]>();\n    tagMap.set('javascript', [files[0]]);\n    const data = new Map<string, unknown>();\n    data.set('taxonomy-tags', tagMap);\n    const ctx = makeCtx(files, data);\n    await plugin.hooks.afterBuild!(ctx);\n    const feed = ctx.output.get('feed.xml')!;\n    expect(feed).toContain('<category>javascript</category>');\n  });\n\n  it('feed includes channel title from config', async () => {\n    const files = [makeFile({ slug: 'post-1', title: 'Post 1' })];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const feed = ctx.output.get('feed.xml')!;\n    expect(feed).toContain('<title>Test Site</title>');\n  });\n\n  it('feed items sorted by date newest first', async () => {\n    const files = [\n      makeFile({ slug: 'old', title: 'Old Post', date: '2023-01-01' }),\n      makeFile({ slug: 'new', title: 'New Post', date: '2024-06-15' }),\n      makeFile({ slug: 'mid', title: 'Mid Post', date: '2024-01-01' }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const feed = ctx.output.get('feed.xml')!;\n    const newIdx = feed.indexOf('New Post');\n    const midIdx = feed.indexOf('Mid Post');\n    const oldIdx = feed.indexOf('Old Post');\n    expect(newIdx).toBeLessThan(midIdx);\n    expect(midIdx).toBeLessThan(oldIdx);\n  });\n\n  it('handles files without dates', async () => {\n    const files = [\n      makeFile({ slug: 'no-date', title: 'No Date Post', content: '<p>No date</p>' }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const feed = ctx.output.get('feed.xml')!;\n    expect(feed).toContain('No Date Post');\n    expect(feed).not.toContain('<pubDate>undefined</pubDate>');\n  });\n\n  it('feed link uses baseUrl from config', async () => {\n    const files = [makeFile({ slug: 'post-1', title: 'Post 1' })];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const feed = ctx.output.get('feed.xml')!;\n    expect(feed).toContain('<link>https://example.com</link>');\n    expect(feed).toContain('<link>https://example.com/post-1.html</link>');\n  });\n});\n```\n\n**Key Features Tested:**\n- Generates valid RSS 2.0 XML\n- Wraps content in CDATA sections\n- Includes category tags from taxonomy\n- Uses channel title from config\n- Sorts items by date (newest first)\n- Handles files without dates\n- Uses baseUrl for feed links\n\n#### **search-index.test.ts** (115 lines)\n\nTests for search index generation:\n\n```typescript\ndescribe('search-index plugin', () => {\n  const plugin = createSearchIndexPlugin();\n\n  it('generates search-index.json in ctx.output', async () => {\n    const files = [makeFile({ slug: 'post-1', title: 'Post 1', content: '<p>Hello</p>' })];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    expect(ctx.output.has('search-index.json')).toBe(true);\n  });\n\n  it('index entries have title, slug, and plain text content', async () => {\n    const files = [makeFile({ slug: 'my-post', title: 'My Post', content: '<p>Some text here</p>' })];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const index = JSON.parse(ctx.output.get('search-index.json')!);\n    expect(index[0].slug).toBe('my-post');\n    expect(index[0].title).toBe('My Post');\n    expect(index[0].content).toBe('Some text here');\n  });\n\n  it('HTML tags stripped from indexed content', async () => {\n    const files = [\n      makeFile({\n        slug: 'post',\n        title: 'Post',\n        content: '<h1>Title</h1><p>This is <strong>bold</strong> text.</p>',\n      }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const index = JSON.parse(ctx.output.get('search-index.json')!);\n    expect(index[0].content).not.toContain('<');\n    expect(index[0].content).not.toContain('>');\n    expect(index[0].content).toContain('bold');\n    expect(index[0].content).toContain('text');\n  });\n\n  it('code blocks included in searchable text', async () => {\n    const files = [\n      makeFile({\n        slug: 'post