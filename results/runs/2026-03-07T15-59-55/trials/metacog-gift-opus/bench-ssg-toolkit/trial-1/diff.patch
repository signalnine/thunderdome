@@ -0,0 +1,69 @@
+import { marked } from 'marked';
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+function processFootnotes(content: string): string {
+  const footnoteDefRegex = /^\[\^(\d+)\]:\s*(.+)$/gm;
+  const footnoteDefs: Map<string, string> = new Map();
+
+  let match: RegExpExecArray | null;
+  while ((match = footnoteDefRegex.exec(content)) !== null) {
+    footnoteDefs.set(match[1], match[2]);
+  }
+
+  if (footnoteDefs.size === 0) {
+    return content;
+  }
+
+  // Remove footnote definitions from content
+  let processed = content.replace(/^\[\^(\d+)\]:\s*(.+)$/gm, '');
+
+  // Replace footnote references with superscript links
+  processed = processed.replace(/\[\^(\d+)\]/g, (_match, num: string) => {
+    return `<sup><a href="#fn-${num}">${num}</a></sup>`;
+  });
+
+  // Build footnotes section
+  const footnoteItems = Array.from(footnoteDefs.entries())
+    .map(([num, text]) => `<li id="fn-${num}">${text}</li>`)
+    .join('\n');
+
+  processed += `\n<section class="footnotes">\n<ol>\n${footnoteItems}\n</ol>\n</section>`;
+
+  return processed;
+}
+
+function processAdmonitions(content: string): string {
+  return content.replace(
+    /^:::(note|warning|tip)\n([\s\S]*?)^:::/gm,
+    (_match, type: string, body: string) => {
+      return `<div class="admonition admonition-${type}">\n${body.trim()}\n</div>`;
+    }
+  );
+}
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file: ContentFile, _ctx: BuildContext): ContentFile {
+        let content = file.content;
+
+        // Process admonitions before markdown (they use ::: syntax)
+        content = processAdmonitions(content);
+
+        // Process footnotes before markdown conversion
+        content = processFootnotes(content);
+
+        // Convert markdown to HTML
+        content = marked(content, { async: false }) as string;
+
+        return {
+          ...file,
+          content,
+        };
+      },
+    },
+  };
+}
