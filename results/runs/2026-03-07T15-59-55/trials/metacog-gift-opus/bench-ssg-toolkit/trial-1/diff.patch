tores tag map in ctx.data', async () => {\n    97→    const files = [\n    98→      makeFile({ slug: 'post-1', title: 'Post 1', tags: ['alpha'] }),\n    99→    ];\n   100→    const ctx = makeCtx(files);\n   101→    await plugin.hooks.beforeBuild!(ctx);\n   102→    expect(ctx.data.has('taxonomy-tags')).toBe(true);\n   103→  });\n   104→\n   105→  it('handles empty file list', async () => {\n   106→    const ctx = makeCtx([]);\n   107→    await plugin.hooks.beforeBuild!(ctx);\n   108→    await plugin.hooks.afterBuild!(ctx);\n   109→    const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]>;\n   110→    expect(tagMap.size).toBe(0);\n   111→  });\n   112→\n   113→  it('tags are case-normalized to lowercase', async () => {\n   114→    const files = [\n   115→      makeFile({ slug: 'post-1', title: 'Post 1', tags: ['JavaScript'] }),\n   116→      makeFile({ slug: 'post-2', title: 'Post 2', tags: ['JAVASCRIPT'] }),\n   117→    ];\n   118→    const ctx = makeCtx(files);\n   119→    await plugin.hooks.beforeBuild!(ctx);\n   120→    const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]>;\n   121→    expect(tagMap.has('javascript')).toBe(true);\n   122→    expect(tagMap.get('javascript')).toHaveLength(2);\n   123→    expect(tagMap.has('JavaScript')).toBe(false);\n   124→    expect(tagMap.has('JAVASCRIPT')).toBe(false);\n   125→  });\n   126→});\n   127→"}]},"parent_tool_use_id":"toolu_013K4an7G37xmMBYEG1nM3mC","session_id":"aeabc9bd-d205-4af4-964c-b92a673fb462","uuid":"07bd8972-624b-40a8-a777-9b408ab0b0a3"}
