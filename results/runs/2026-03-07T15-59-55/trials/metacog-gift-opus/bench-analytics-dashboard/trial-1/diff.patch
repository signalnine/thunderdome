@@ -0,0 +1,154 @@
+import { Router } from "express";
+import type Database from "better-sqlite3";
+import { authMiddleware, AuthenticatedRequest } from "../auth.js";
+
+export function createQueryRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Count events matching a filter
+  router.post("/count", authMiddleware, (req: AuthenticatedRequest, res) => {
+    const { eventName, startDate, endDate, filters } = req.body;
+    const tenantId = req.user!.tenantId;
+
+    let sql = "SELECT COUNT(*) as count FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [tenantId];
+
+    if (eventName) {
+      sql += " AND name = ?";
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value as string);
+      }
+    }
+
+    const result = db.prepare(sql).get(...params) as { count: number };
+    res.json({ count: result.count });
+  });
+
+  // Timeseries query - bucket event counts over time
+  router.post("/timeseries", authMiddleware, (req: AuthenticatedRequest, res) => {
+    const { eventName, startDate, endDate, interval, filters } = req.body;
+    const tenantId = req.user!.tenantId;
+
+    // Default interval is 'day'
+    const groupInterval = interval || "day";
+    let dateFormat: string;
+
+    switch (groupInterval) {
+      case "hour":
+        dateFormat = "%Y-%m-%dT%H:00:00";
+        break;
+      case "month":
+        dateFormat = "%Y-%m-01";
+        break;
+      case "week":
+        dateFormat = "%Y-W%W";
+        break;
+      case "day":
+      default:
+        dateFormat = "%Y-%m-%d";
+        break;
+    }
+
+    let sql = `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: unknown[] = [tenantId];
+
+    if (eventName) {
+      sql += " AND name = ?";
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value as string);
+      }
+    }
+
+    sql += " GROUP BY bucket ORDER BY bucket ASC";
+
+    const results = db.prepare(sql).all(...params) as Array<{ bucket: string; count: number }>;
+    res.json({ interval: groupInterval, data: results });
+  });
+
+  // Breakdown - group event counts by a property value
+  router.post("/breakdown", authMiddleware, (req: AuthenticatedRequest, res) => {
+    const { eventName, property, startDate, endDate, filters, limit: queryLimit } = req.body;
+    const tenantId = req.user!.tenantId;
+
+    if (!property) {
+      res.status(400).json({ error: "property is required for breakdown queries" });
+      return;
+    }
+
+    let sql = `SELECT json_extract(properties, ?) as property_value, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: unknown[] = [`$.${property}`, tenantId];
+
+    if (eventName) {
+      sql += " AND name = ?";
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value as string);
+      }
+    }
+
+    sql += " GROUP BY property_value ORDER BY count DESC";
+
+    if (queryLimit && typeof queryLimit === "number") {
+      sql += ` LIMIT ${Math.floor(queryLimit)}`;
+    }
+
+    const results = db.prepare(sql).all(...params) as Array<{
+      property_value: string;
+      count: number;
+    }>;
+
+    res.json({
+      property,
+      data: results.map((r) => ({
+        value: r.property_value,
+        count: r.count,
+      })),
+    });
+  });
+
+  return router;
+}
