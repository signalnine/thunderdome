@@ -0,0 +1,82 @@
+import { Router } from "express";
+import { v4 as uuidv4 } from "uuid";
+import type Database from "better-sqlite3";
+import { authMiddleware, AuthenticatedRequest } from "../auth.js";
+
+export function createEventRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Ingest single event
+  router.post("/", authMiddleware, (req: AuthenticatedRequest, res) => {
+    const { name, properties, timestamp, sessionId } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: "Event name is required" });
+      return;
+    }
+
+    const id = uuidv4();
+    const tenantId = req.user!.tenantId;
+    const userId = req.user!.userId;
+    const eventTimestamp = timestamp || new Date().toISOString();
+    const eventProperties = properties ? JSON.stringify(properties) : "{}";
+
+    db.prepare(
+      "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    ).run(id, tenantId, name, eventProperties, eventTimestamp, userId, sessionId || null);
+
+    res.status(201).json({
+      id,
+      tenantId,
+      name,
+      properties: properties || {},
+      timestamp: eventTimestamp,
+      userId,
+      sessionId: sessionId || null,
+    });
+  });
+
+  // Ingest batch of events
+  router.post("/batch", authMiddleware, (req: AuthenticatedRequest, res) => {
+    const { events } = req.body;
+
+    if (!Array.isArray(events) || events.length === 0) {
+      res.status(400).json({ error: "events array is required and must not be empty" });
+      return;
+    }
+
+    const tenantId = req.user!.tenantId;
+    const userId = req.user!.userId;
+
+    const insert = db.prepare(
+      "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    );
+
+    const results: Array<{ id: string; name: string }> = [];
+
+    const insertMany = db.transaction(() => {
+      for (const event of events) {
+        if (!event.name) continue;
+        const id = uuidv4();
+        const eventTimestamp = event.timestamp || new Date().toISOString();
+        const eventProperties = event.properties ? JSON.stringify(event.properties) : "{}";
+        insert.run(
+          id,
+          tenantId,
+          event.name,
+          eventProperties,
+          eventTimestamp,
+          userId,
+          event.sessionId || null
+        );
+        results.push({ id, name: event.name });
+      }
+    });
+
+    insertMany();
+
+    res.status(201).json({ inserted: results.length, events: results });
+  });
+
+  return router;
+}
diff --git a/src/routes/exports.ts b/src/routes/exports.ts
new file mode 100644
index 0000000..41d5910
--- /dev/null
+++ b/src/routes/exports.ts
@@ -0,0 +1,188 @@
+import { Router } from "express";
+import type Database from "better-sqlite3";
+import { authMiddleware, AuthenticatedRequest } from "../auth.js";
+
+interface EventRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string | null;
+  session_id: string | null;
+}
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+interface WidgetRow {
+  id: string;
+  dashboard_id: string;
+  type: string;
+  config: string;
+  position_x: number;
+  position_y: number;
+  width: number;
+  height: number;
+}
+
+function escapeCsvField(value: string): string {
+  if (value.includes(",") || value.includes('"') || value.includes("\n")) {
+    return `"${value.replace(/"/g, '""')}"`;
+  }
+  return value;
+}
+
+function eventsToCsv(events: EventRow[]): string {
+  const header = "id,name,properties,timestamp,user_id,session_id";
+  const rows = events.map(
+    (e) =>
+      `${escapeCsvField(e.id)},${escapeCsvField(e.name)},${escapeCsvField(e.properties)},${escapeCsvField(e.timestamp)},${escapeCsvField(e.user_id || "")},${escapeCsvField(e.session_id || "")}`
+  );
+  return [header, ...rows].join("\n");
+}
+
+function dashboardsToCsv(dashboards: Array<DashboardRow & { widgets?: WidgetRow[] }>): string {
+  const header = "id,name,owner_id,config,created_at,updated_at";
+  const rows = dashboards.map(
+    (d) =>
+      `${escapeCsvField(d.id)},${escapeCsvField(d.name)},${escapeCsvField(d.owner_id)},${escapeCsvField(d.config)},${escapeCsvField(d.created_at)},${escapeCsvField(d.updated_at)}`
+  );
+  return [header, ...rows].join("\n");
+}
+
+export function createExportRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Export events as JSON
+  router.get("/events/json", authMiddleware, (req: AuthenticatedRequest, res) => {
+    const tenantId = req.user!.tenantId;
+    const { eventName, startDate, endDate } = req.query;
+
+    let sql = "SELECT * FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [tenantId];
+
+    if (eventName) {
+      sql += " AND name = ?";
+      params.push(eventName as string);
+    }
+
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate as string);
+    }
+
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate as string);
+    }
+
+    sql += " ORDER BY timestamp DESC";
+
+    const events = db.prepare(sql).all(...params) as EventRow[];
+
+    const formatted = events.map((e) => ({
+      id: e.id,
+      name: e.name,
+      properties: JSON.parse(e.properties),
+      timestamp: e.timestamp,
+      userId: e.user_id,
+      sessionId: e.session_id,
+    }));
+
+    res.setHeader("Content-Type", "application/json");
+    res.setHeader("Content-Disposition", 'attachment; filename="events.json"');
+    res.json(formatted);
+  });
+
+  // Export events as CSV
+  router.get("/events/csv", authMiddleware, (req: AuthenticatedRequest, res) => {
+    const tenantId = req.user!.tenantId;
+    const { eventName, startDate, endDate } = req.query;
+
+    let sql = "SELECT * FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [tenantId];
+
+    if (eventName) {
+      sql += " AND name = ?";
+      params.push(eventName as string);
+    }
+
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate as string);
+    }
+
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate as string);
+    }
+
+    sql += " ORDER BY timestamp DESC";
+
+    const events = db.prepare(sql).all(...params) as EventRow[];
+
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader("Content-Disposition", 'attachment; filename="events.csv"');
+    res.send(eventsToCsv(events));
+  });
+
+  // Export dashboards as JSON
+  router.get("/dashboards/json", authMiddleware, (req: AuthenticatedRequest, res) => {
+    const tenantId = req.user!.tenantId;
+
+    const dashboards = db
+      .prepare("SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC")
+      .all(tenantId) as DashboardRow[];
+
+    const formatted = dashboards.map((d) => {
+      const widgets = db
+        .prepare("SELECT * FROM widgets WHERE dashboard_id = ?")
+        .all(d.id) as WidgetRow[];
+
+      return {
+        id: d.id,
+        name: d.name,
+        ownerId: d.owner_id,
+        config: JSON.parse(d.config),
+        createdAt: d.created_at,
+        updatedAt: d.updated_at,
+        widgets: widgets.map((w) => ({
+          id: w.id,
+          type: w.type,
+          config: JSON.parse(w.config),
+          positionX: w.position_x,
+          positionY: w.position_y,
+          width: w.width,
+          height: w.height,
+        })),
+      };
+    });
+
+    res.setHeader("Content-Type", "application/json");
+    res.setHeader("Content-Disposition", 'attachment; filename="dashboards.json"');
+    res.json(formatted);
+  });
+
+  // Export dashboards as CSV
+  router.get("/dashboards/csv", authMiddleware, (req: AuthenticatedRequest, res) => {
+    const tenantId = req.user!.tenantId;
+
+    const dashboards = db
+      .prepare("SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC")
+      .all(tenantId) as DashboardRow[];
+
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader("Content-Disposition", 'attachment; filename="dashboards.csv"');
+    res.send(dashboardsToCsv(dashboards));
+  });
+
+  return router;
+}
