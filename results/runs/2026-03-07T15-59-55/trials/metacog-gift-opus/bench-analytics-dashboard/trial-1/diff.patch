+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_019VhbsmPm2zYjM457sTqtrG","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Rg1LvpKA66ULGmZeSUvvwi","name":"Write","input":{"file_path":"/workspace/src/routes/dashboards.ts","content":"import { Router } from \"express\";\nimport { v4 as uuidv4 } from \"uuid\";\nimport type Database from \"better-sqlite3\";\nimport { authMiddleware, AuthenticatedRequest } from \"../auth.js\";\n\ninterface DashboardRow {\n  id: string;\n  tenant_id: string;\n  name: string;\n  owner_id: string;\n  config: string;\n  created_at: string;\n  updated_at: string;\n}\n\ninterface WidgetRow {\n  id: string;\n  dashboard_id: string;\n  type: string;\n  config: string;\n  position_x: number;\n  position_y: number;\n  width: number;\n  height: number;\n}\n\nexport function createDashboardRoutes(db: Database.Database): Router {\n  const router = Router();\n\n  // Create dashboard\n  router.post(\"/\", authMiddleware, (req: AuthenticatedRequest, res) => {\n    const { name, config } = req.body;\n\n    if (!name) {\n      res.status(400).json({ error: \"Dashboard name is required\" });\n      return;\n    }\n\n    const id = uuidv4();\n    const tenantId = req.user!.tenantId;\n    const ownerId = req.user!.userId;\n    const dashConfig = config ? JSON.stringify(config) : \"{}\";\n    const now = new Date().toISOString();\n\n    db.prepare(\n      \"INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)\"\n    ).run(id, tenantId, name, ownerId, dashConfig, now, now);\n\n    res.status(201).json({\n      id,\n      tenantId,\n      name,\n      ownerId,\n      config: config || {},\n      createdAt: now,\n      updatedAt: now,\n    });\n  });\n\n  // List dashboards for tenant\n  router.get(\"/\", authMiddleware, (req: AuthenticatedRequest, res) => {\n    const tenantId = req.user!.tenantId;\n\n    const dashboards = db\n      .prepare(\"SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC\")\n      .all(tenantId) as DashboardRow[];\n\n    res.json(\n      dashboards.map((d) => ({\n        id: d.id,\n        tenantId: d.tenant_id,\n        name: d.name,\n        ownerId: d.owner_id,\n        config: JSON.parse(d.config),\n        createdAt: d.created_at,\n        updatedAt: d.updated_at,\n      }))\n    );\n  });\n\n  // Get single dashboard\n  router.get(\"/:id\", authMiddleware, (req: AuthenticatedRequest, res) => {\n    const tenantId = req.user!.tenantId;\n    const dashboard = db\n      .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n      .get(req.params.id, tenantId) as DashboardRow | undefined;\n\n    if (!dashboard) {\n      res.status(404).json({ error: \"Dashboard not found\" });\n      return;\n    }\n\n    const widgets = db\n      .prepare(\"SELECT * FROM widgets WHERE dashboard_id = ?\")\n      .all(dashboard.id) as WidgetRow[];\n\n    res.json({\n      id: dashboard.id,\n      tenantId: dashboard.tenant_id,\n      name: dashboard.name,\n      ownerId: dashboard.owner_id,\n      config: JSON.parse(dashboard.config),\n      createdAt: dashboard.created_at,\n      updatedAt: dashboard.updated_at,\n      widgets: widgets.map((w) => ({\n        id: w.id,\n        type: w.type,\n        config: JSON.parse(w.config),\n        positionX: w.position_x,\n        positionY: w.position_y,\n        width: w.width,\n        height: w.height,\n      })),\n    });\n  });\n\n  // Update dashboard\n  router.put(\"/:id\", authMiddleware, (req: AuthenticatedRequest, res) => {\n    const tenantId = req.user!.tenantId;\n    const { name, config } = req.body;\n\n    const existing = db\n      .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n      .get(req.params.id, tenantId) as DashboardRow | undefined;\n\n    if (!existing) {\n      res.status(404).json({ error: \"Dashboard not found\" });\n      return;\n    }\n\n    const updatedName = name || existing.name;\n    const updatedConfig = config ? JSON.stringify(config) : existing.config;\n    const now = new Date().toISOString();\n\n    db.prepare(\"UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?\").run(\n      updatedName,\n      updatedConfig,\n      now,\n      req.params.id\n    );\n\n    res.json({\n      id: existing.id,\n      tenantId: existing.tenant_id,\n      name: updatedName,\n      ownerId: existing.owner_id,\n      config: JSON.parse(updatedConfig),\n      createdAt: existing.created_at,\n      updatedAt: now,\n    });\n  });\n\n  // Delete dashboard\n  router.delete(\"/:id\", authMiddleware, (req: AuthenticatedRequest, res) => {\n    const tenantId = req.user!.tenantId;\n\n    const existing = db\n      .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n      .get(req.params.id, tenantId) as DashboardRow | undefined;\n\n    if (!existing) {\n      res.status(404).json({ error: \"Dashboard not found\" });\n      return;\n    }\n\n    db.prepare(\"DELETE FROM widgets WHERE dashboard_id = ?\").run(req.params.id);\n    db.prepare(\"DELETE FROM dashboards WHERE id = ?\").run(req.params.id);\n\n    res.status(204).send();\n  });\n\n  // Add widget to dashboard\n  router.post(\"/:id/widgets\", authMiddleware, (req: AuthenticatedRequest, res) => {\n    const tenantId = req.user!.tenantId;\n\n    const dashboard = db\n      .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n      .get(req.params.id, tenantId) as DashboardRow | undefined;\n\n    if (!dashboard) {\n      res.status(404).json({ error: \"Dashboard not found\" });\n      return;\n    }\n\n    const { type, config, positionX, positionY, width, height } = req.body;\n\n    if (!type || ![\"counter\", \"timeseries\", \"breakdown\", \"funnel\"].includes(type)) {\n      res.status(400).json({ error: \"Valid widget type is required\" });\n      return;\n    }\n\n    const id = uuidv4();\n    const widgetConfig = config ? JSON.stringify(config) : \"{}\";\n\n    db.prepare(\n      \"INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)\"\n    ).run(\n      id,\n      req.params.id,\n      type,\n      widgetConfig,\n      positionX || 0,\n      positionY || 0,\n      width || 1,\n      height || 1\n    );\n\n    res.status(201).json({\n      id,\n      dashboardId: req.params.id,\n      type,\n      config: config || {},\n      positionX: positionX || 0,\n      positionY: positionY || 0,\n      width: width || 1,\n      height: height || 1,\n    });\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":415,"cache_read_input_tokens":28131,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":415},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"c9715316-9b96-42a3-9894-e583dea0bd1e","uuid":"081c4ed3-afba-4c34-a096-d17c8ca50e1f"}
