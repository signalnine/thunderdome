+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_012DWPKzkDWqL65D6LBcqeyT","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01QwGCQQeAFWuXW7RjtDTG2v","name":"Write","input":{"file_path":"/workspace/tests/services.test.ts","content":"import { describe, it, expect, beforeEach } from 'vitest';\nimport { EventBus } from '../src/bus.js';\nimport {\n  createCatalogService,\n  createInventoryService,\n  createCartService,\n  createPricingService,\n  createOrderService,\n  createPaymentService,\n  createNotificationService,\n  createAnalyticsService,\n} from '../src/index.js';\nimport { OrderStatus, PaymentStatus, Events } from '../src/types.js';\n\nlet bus: EventBus;\n\nbeforeEach(() => {\n  bus = new EventBus();\n});\n\ndescribe('CatalogService', () => {\n  it('should create and retrieve a product', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    const product = catalog.getProduct(id);\n    expect(product).toEqual({ id, name: 'Widget', price: 9.99, category: 'gadgets' });\n  });\n\n  it('should list products, optionally filtered by category', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('A', 1, 'cat1');\n    catalog.createProduct('B', 2, 'cat2');\n    catalog.createProduct('C', 3, 'cat1');\n    expect(catalog.listProducts()).toHaveLength(3);\n    expect(catalog.listProducts('cat1')).toHaveLength(2);\n    expect(catalog.listProducts('cat2')).toHaveLength(1);\n  });\n\n  it('should search products by name', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('Blue Widget', 5, 'gadgets');\n    catalog.createProduct('Red Widget', 6, 'gadgets');\n    catalog.createProduct('Green Thing', 7, 'stuff');\n    expect(catalog.searchProducts('widget')).toHaveLength(2);\n    expect(catalog.searchProducts('green')).toHaveLength(1);\n  });\n\n  it('should update and remove products', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Old', 1, 'cat');\n    catalog.updateProduct(id, { name: 'New', price: 2 });\n    expect(catalog.getProduct(id)!.name).toBe('New');\n    expect(catalog.getProduct(id)!.price).toBe(2);\n    expect(catalog.removeProduct(id)).toBe(true);\n    expect(catalog.getProduct(id)).toBeNull();\n    expect(catalog.removeProduct('nonexistent')).toBe(false);\n  });\n\n  it('should emit product:created event', async () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('Foo', 10, 'bar');\n    // Give async emit time\n    await new Promise(resolve => setTimeout(resolve, 10));\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.PRODUCT_CREATED)).toBe(true);\n  });\n});\n\ndescribe('InventoryService', () => {\n  it('should set and get stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 100);\n    expect(inventory.getStock('p1')).toBe(100);\n    expect(inventory.getStock('nonexistent')).toBe(0);\n  });\n\n  it('should reserve and release stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 10);\n    expect(inventory.reserve('p1', 5)).toBe(true);\n    expect(inventory.reserve('p1', 6)).toBe(false); // only 5 available\n    expect(inventory.reserve('p1', 5)).toBe(true); // exactly 5 remaining\n    expect(inventory.reserve('p1', 1)).toBe(false); // nothing left\n    inventory.release('p1', 3);\n    expect(inventory.reserve('p1', 3)).toBe(true);\n  });\n\n  it('should emit low stock alert', async () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 100);\n    inventory.setLowStockThreshold('p1', 5);\n    inventory.setStock('p1', 3);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.LOW_STOCK_ALERT)).toBe(true);\n  });\n});\n\ndescribe('CartService', () => {\n  it('should create cart and add/remove items', () => {\n    const cart = createCartService(bus);\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 2);\n    cart.addItem(cartId, 'p2', 1);\n    const data = cart.getCart(cartId);\n    expect(data!.items).toHaveLength(2);\n    expect(data!.userId).toBe('user1');\n  });\n\n  it('should consolidate duplicate product items', () => {\n    const cart = createCartService(bus);\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 2);\n    cart.addItem(cartId, 'p1', 3);\n    const data = cart.getCart(cartId);\n    expect(data!.items).toHaveLength(1);\n    expect(data!.items[0].quantity).toBe(5);\n  });\n\n  it('should update quantity and clear cart', () => {\n    const cart = createCartService(bus);\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 2);\n    cart.updateQuantity(cartId, 'p1', 10);\n    expect(cart.getCart(cartId)!.items[0].quantity).toBe(10);\n    cart.clearCart(cartId);\n    expect(cart.getCart(cartId)!.items).toHaveLength(0);\n  });\n\n  it('should remove specific items', () => {\n    const cart = createCartService(bus);\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 2);\n    cart.addItem(cartId, 'p2', 1);\n    cart.removeItem(cartId, 'p1');\n    expect(cart.getCart(cartId)!.items).toHaveLength(1);\n    expect(cart.getCart(cartId)!.items[0].productId).toBe('p2');\n  });\n\n  it('should return null for nonexistent cart', () => {\n    const cart = createCartService(bus);\n    expect(cart.getCart('nonexistent')).toBeNull();\n  });\n});\n\ndescribe('PricingService', () => {\n  it('should calculate total with tax', () => {\n    const pricing = createPricingService(bus);\n    const result = pricing.calculateTotal([\n      { productId: 'p1', quantity: 2, price: 10 },\n      { productId: 'p2', quantity: 1, price: 5 },\n    ]);\n    expect(result.subtotal).toBe(25);\n    expect(result.discount).toBe(0);\n    expect(result.tax).toBe(2.5);\n    expect(result.total).toBe(27.5);\n  });\n\n  it('should apply discount code before tax', () => {\n    const pricing = createPricingService(bus);\n    pricing.addDiscountCode('SAVE10', 10);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'SAVE10',\n    );\n    expect(result.subtotal).toBe(100);\n    expect(result.discount).toBe(10);\n    expect(result.tax).toBe(9); // 10% of 90\n    expect(result.total).toBe(99);\n  });\n\n  it('should track prices from product:created events', async () => {\n    const pricing = createPricingService(bus);\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 42, 'gadgets');\n    await new Promise(resolve => setTimeout(resolve, 10));\n    expect(pricing.getPrice(id)).toBe(42);\n  });\n\n  it('should ignore invalid discount codes', () => {\n    const pricing = createPricingService(bus);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'INVALID',\n    );\n    expect(result.discount).toBe(0);\n    expect(result.total).toBe(110);\n  });\n});\n\ndescribe('OrderService', () => {\n  it('should create an order with PENDING status', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    const order = orders.getOrder(id);\n    expect(order).not.toBeNull();\n    expect(order!.status).toBe(OrderStatus.PENDING);\n    expect(order!.total).toBe(50);\n  });\n\n  it('should follow valid status transitions', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.CONFIRMED);\n    orders.updateStatus(id, OrderStatus.SHIPPED);\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.SHIPPED);\n    orders.updateStatus(id, OrderStatus.DELIVERED);\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.DELIVERED);\n  });\n\n  it('should reject invalid status transitions', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(id, OrderStatus.SHIPPED); // can't skip CONFIRMED\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.PENDING);\n    orders.updateStatus(id, OrderStatus.DELIVERED);\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.PENDING);\n  });\n\n  it('should allow cancellation from PENDING or CONFIRMED', () => {\n    const orders = createOrderService(bus);\n    const id1 = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(id1, OrderStatus.CANCELLED);\n    expect(orders.getOrder(id1)!.status).toBe(OrderStatus.CANCELLED);\n\n    const id2 = orders.createOrder('user1', 'cart2', 60);\n    orders.updateStatus(id2, OrderStatus.CONFIRMED);\n    orders.updateStatus(id2, OrderStatus.CANCELLED);\n    expect(orders.getOrder(id2)!.status).toBe(OrderStatus.CANCELLED);\n  });\n\n  it('should not cancel after shipping', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    orders.updateStatus(id, OrderStatus.SHIPPED);\n    orders.updateStatus(id, OrderStatus.CANCELLED);\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.SHIPPED);\n  });\n\n  it('should list orders for a user', () => {\n    const orders = createOrderService(bus);\n    orders.createOrder('user1', 'c1', 10);\n    orders.createOrder('user1', 'c2', 20);\n    orders.createOrder('user2', 'c3', 30);\n    expect(orders.listOrders('user1')).toHaveLength(2);\n    expect(orders.listOrders('user2')).toHaveLength(1);\n  });\n\n  it('should emit events on creation and status change', async () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.ORDER_CREATED)).toBe(true);\n    expect(log.some(e => e.event === Events.ORDER_STATUS_CHANGED)).toBe(true);\n    const statusEvent = log.find(e => e.event === Events.ORDER_STATUS_CHANGED);\n    expect((statusEvent!.payload as { previousStatus: string }).previousStatus).toBe(OrderStatus.PENDING);\n  });\n});\n\ndescribe('PaymentService', () => {\n  it('should process successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.SUCCESS);\n    expect(result.transactionId).toBeDefined();\n  });\n\n  it('should simulate failure', async () => {\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.FAILED);\n    expect(result.error).toBeDefined();\n  });\n\n  it('should simulate timeout', async () => {\n    const payment = createPaymentService(bus, { simulateTimeout: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.TIMEOUT);\n  });\n\n  it('should refund successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    expect(await payment.refund(result.transactionId!)).toBe(true);\n  });\n\n  it('should not refund invalid transaction', async () => {\n    const payment = createPaymentService(bus);\n    expect(await payment.refund('invalid')).toBe(false);\n  });\n\n  it('should emit payment processed event', async () => {\n    const payment = createPaymentService(bus);\n    await payment.processPayment('order1', 100);\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.PAYMENT_PROCESSED)).toBe(true);\n  });\n});\n\ndescribe('NotificationService', () => {\n  it('should deliver notifications to subscribed users on order events', async () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n\n    notifications.subscribe('user1');\n    const orderId = orders.createOrder('user1', 'cart1', 50);\n    // Wait for async events\n    await new Promise(resolve => setTimeout(resolve, 50));\n\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    await new Promise(resolve => setTimeout(resolve, 50));\n\n    const notes = notifications.getNotifications('user1');\n    expect(notes.length).toBeGreaterThanOrEqual(2); // order created + status change\n    expect(notes.some(n => n.type === 'order_created')).toBe(true);\n    expect(notes.some(n => n.type === 'order_status')).toBe(true);\n  });\n\n  it('should deliver notifications on payment events', async () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n\n    notifications.subscribe('user1');\n    const orderId = orders.createOrder('user1', 'cart1', 50);\n    await payment.processPayment(orderId, 50);\n    await new Promise(resolve => setTimeout(resolve, 50));\n\n    const notes = notifications.getNotifications('user1');\n    expect(notes.some(n => n.type === 'payment')).toBe(true);\n  });\n\n  it('should not deliver to unsubscribed users', async () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n\n    orders.createOrder('user1', 'cart1', 50);\n    await new Promise(resolve => setTimeout(resolve, 50));\n\n    expect(notifications.getNotifications('user1')).toHaveLength(0);\n  });\n});\n\ndescribe('AnalyticsService', () => {\n  it('should count events by type', async () => {\n    const analytics = createAnalyticsService(bus);\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('A', 1, 'cat');\n    catalog.createProduct('B', 2, 'cat');\n    await new Promise(resolve => setTimeout(resolve, 50));\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n  });\n\n  it('should track revenue from successful payments', async () => {\n    const analytics = createAnalyticsService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    await payment.processPayment(orderId, 100);\n    await new Promise(resolve => setTimeout(resolve, 50));\n\n    expect(analytics.getRevenue()).toBe(100);\n  });\n\n  it('should not count revenue from failed payments', async () => {\n    const analytics = createAnalyticsService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus, { simulateFailure: true });\n\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    await payment.processPayment(orderId, 100);\n    await new Promise(resolve => setTimeout(resolve, 50));\n\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  it('should calculate conversion rate', async () => {\n    const analytics = createAnalyticsService(bus);\n    const cartService = createCartService(bus);\n    const orders = createOrderService(bus);\n\n    // Create 4 carts, 2 orders\n    const c1 = cartService.createCart('u1');\n    cartService.addItem(c1, 'p1', 1);\n    const c2 = cartService.createCart('u2');\n    cartService.addItem(c2, 'p2', 1);\n    const c3 = cartService.createCart('u3');\n    cartService.addItem(c3, 'p3', 1);\n    const c4 = cartService.createCart('u4');\n    cartService.addItem(c4, 'p4', 1);\n\n    await new Promise(resolve => setTimeout(resolve, 50));\n\n    orders.createOrder('u1', c1, 10);\n    orders.createOrder('u2', c2, 20);\n    await new Promise(resolve => setTimeout(resolve, 50));\n\n    expect(analytics.getConversionRate()).toBe(0.5); // 2 orders / 4 carts\n  });\n\n  it('should rank products by order quantity', async () => {\n    const analytics = createAnalyticsService(bus);\n    const cartService = createCartService(bus);\n    const orders = createOrderService(bus);\n\n    const c1 = cartService.createCart('u1');\n    cartService.addItem(c1, 'p1', 5);\n    cartService.addItem(c1, 'p2', 3);\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    orders.createOrder('u1', c1, 50);\n    await new Promise(resolve => setTimeout(resolve, 50));\n\n    const top = analytics.getTopProducts(10);\n    expect(top[0]).toEqual({ productId: 'p1', count: 5 });\n    expect(top[1]).toEqual({ productId: 'p2', count: 3 });\n  });\n});\n\ndescribe('Integration: full e-commerce flow', () => {\n  it('should handle a complete purchase flow', async () => {\n    // Set up all services on the same bus\n    const catalog = createCatalogService(bus);\n    const inventory = createInventoryService(bus);\n    const cartService = createCartService(bus);\n    const pricing = createPricingService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    const notifications = createNotificationService(bus);\n    const analytics = createAnalyticsService(bus);\n\n    // Subscribe user for notifications\n    notifications.subscribe('user1');\n\n    // Create products\n    const p1 = catalog.createProduct('Laptop', 999, 'electronics');\n    const p2 = catalog.createProduct('Mouse', 29, 'electronics');\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    // Set inventory\n    inventory.setStock(p1, 10);\n    inventory.setStock(p2, 50);\n\n    // Add to cart\n    const cartId = cartService.createCart('user1');\n    cartService.addItem(cartId, p1, 1);\n    cartService.addItem(cartId, p2, 2);\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    // Calculate pricing\n    const cartData = cartService.getCart(cartId)!;\n    const items = cartData.items.map(item => ({\n      productId: item.productId,\n      quantity: item.quantity,\n      price: pricing.getPrice(item.productId),\n    }));\n    pricing.addDiscountCode('WELCOME', 5);\n    const totals = pricing.calculateTotal(items, 'WELCOME');\n    expect(totals.subtotal).toBe(1057); // 999 + 29*2\n    expect(totals.discount).toBeCloseTo(52.85);\n\n    // Reserve inventory\n    expect(inventory.reserve(p1, 1)).toBe(true);\n    expect(inventory.reserve(p2, 2)).toBe(true);\n\n    // Create order\n    const orderId = orders.createOrder('user1', cartId, totals.total);\n    expect(orders.getOrder(orderId)!.status).toBe(OrderStatus.PENDING);\n\n    // Process payment\n    const payResult = await payment.processPayment(orderId, totals.total);\n    expect(payResult.status).toBe(PaymentStatus.SUCCESS);\n\n    // Update order status\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    orders.updateStatus(orderId, OrderStatus.SHIPPED);\n    orders.updateStatus(orderId, OrderStatus.DELIVERED);\n    await new Promise(resolve => setTimeout(resolve, 50));\n\n    expect(orders.getOrder(orderId)!.status).toBe(OrderStatus.DELIVERED);\n\n    // Check notifications\n    const notes = notifications.getNotifications('user1');\n    expect(notes.length).toBeGreaterThanOrEqual(4); // created + payment + 3 status changes\n\n    // Check analytics\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n    expect(analytics.getRevenue()).toBe(totals.total);\n    expect(analytics.getConversionRate()).toBeGreaterThan(0);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":251,"cache_read_input_tokens":34087,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":251},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"34abe27a-c9cf-43ea-9dda-14a37ee577d3","uuid":"2da45829-393e-4035-84d5-21fc9b7d9309"}
+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QwGCQQeAFWuXW7RjtDTG2v","type":"tool_result","content":"File created successfully at: /workspace/tests/services.test.ts"}]},"parent_tool_use_id":null,"session_id":"34abe27a-c9cf-43ea-9dda-14a37ee577d3","uuid":"27b41931-36de-494e-8f49-1531997d43bb","tool_use_result":{"type":"create","filePath":"/workspace/tests/services.test.ts","content":"import { describe, it, expect, beforeEach } from 'vitest';\nimport { EventBus } from '../src/bus.js';\nimport {\n  createCatalogService,\n  createInventoryService,\n  createCartService,\n  createPricingService,\n  createOrderService,\n  createPaymentService,\n  createNotificationService,\n  createAnalyticsService,\n} from '../src/index.js';\nimport { OrderStatus, PaymentStatus, Events } from '../src/types.js';\n\nlet bus: EventBus;\n\nbeforeEach(() => {\n  bus = new EventBus();\n});\n\ndescribe('CatalogService', () => {\n  it('should create and retrieve a product', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    const product = catalog.getProduct(id);\n    expect(product).toEqual({ id, name: 'Widget', price: 9.99, category: 'gadgets' });\n  });\n\n  it('should list products, optionally filtered by category', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('A', 1, 'cat1');\n    catalog.createProduct('B', 2, 'cat2');\n    catalog.createProduct('C', 3, 'cat1');\n    expect(catalog.listProducts()).toHaveLength(3);\n    expect(catalog.listProducts('cat1')).toHaveLength(2);\n    expect(catalog.listProducts('cat2')).toHaveLength(1);\n  });\n\n  it('should search products by name', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('Blue Widget', 5, 'gadgets');\n    catalog.createProduct('Red Widget', 6, 'gadgets');\n    catalog.createProduct('Green Thing', 7, 'stuff');\n    expect(catalog.searchProducts('widget')).toHaveLength(2);\n    expect(catalog.searchProducts('green')).toHaveLength(1);\n  });\n\n  it('should update and remove products', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Old', 1, 'cat');\n    catalog.updateProduct(id, { name: 'New', price: 2 });\n    expect(catalog.getProduct(id)!.name).toBe('New');\n    expect(catalog.getProduct(id)!.price).toBe(2);\n    expect(catalog.removeProduct(id)).toBe(true);\n    expect(catalog.getProduct(id)).toBeNull();\n    expect(catalog.removeProduct('nonexistent')).toBe(false);\n  });\n\n  it('should emit product:created event', async () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('Foo', 10, 'bar');\n    // Give async emit time\n    await new Promise(resolve => setTimeout(resolve, 10));\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.PRODUCT_CREATED)).toBe(true);\n  });\n});\n\ndescribe('InventoryService', () => {\n  it('should set and get stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 100);\n    expect(inventory.getStock('p1')).toBe(100);\n    expect(inventory.getStock('nonexistent')).toBe(0);\n  });\n\n  it('should reserve and release stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 10);\n    expect(inventory.reserve('p1', 5)).toBe(true);\n    expect(inventory.reserve('p1', 6)).toBe(false); // only 5 available\n    expect(inventory.reserve('p1', 5)).toBe(true); // exactly 5 remaining\n    expect(inventory.reserve('p1', 1)).toBe(false); // nothing left\n    inventory.release('p1', 3);\n    expect(inventory.reserve('p1', 3)).toBe(true);\n  });\n\n  it('should emit low stock alert', async () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 100);\n    inventory.setLowStockThreshold('p1', 5);\n    inventory.setStock('p1', 3);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.LOW_STOCK_ALERT)).toBe(true);\n  });\n});\n\ndescribe('CartService', () => {\n  it('should create cart and add/remove items', () => {\n    const cart = createCartService(bus);\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 2);\n    cart.addItem(cartId, 'p2', 1);\n    const data = cart.getCart(cartId);\n    expect(data!.items).toHaveLength(2);\n    expect(data!.userId).toBe('user1');\n  });\n\n  it('should consolidate duplicate product items', () => {\n    const cart = createCartService(bus);\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 2);\n    cart.addItem(cartId, 'p1', 3);\n    const data = cart.getCart(cartId);\n    expect(data!.items).toHaveLength(1);\n    expect(data!.items[0].quantity).toBe(5);\n  });\n\n  it('should update quantity and clear cart', () => {\n    const cart = createCartService(bus);\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 2);\n    cart.updateQuantity(cartId, 'p1', 10);\n    expect(cart.getCart(cartId)!.items[0].quantity).toBe(10);\n    cart.clearCart(cartId);\n    expect(cart.getCart(cartId)!.items).toHaveLength(0);\n  });\n\n  it('should remove specific items', () => {\n    const cart = createCartService(bus);\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 2);\n    cart.addItem(cartId, 'p2', 1);\n    cart.removeItem(cartId, 'p1');\n    expect(cart.getCart(cartId)!.items).toHaveLength(1);\n    expect(cart.getCart(cartId)!.items[0].productId).toBe('p2');\n  });\n\n  it('should return null for nonexistent cart', () => {\n    const cart = createCartService(bus);\n    expect(cart.getCart('nonexistent')).toBeNull();\n  });\n});\n\ndescribe('PricingService', () => {\n  it('should calculate total with tax', () => {\n    const pricing = createPricingService(bus);\n    const result = pricing.calculateTotal([\n      { productId: 'p1', quantity: 2, price: 10 },\n      { productId: 'p2', quantity: 1, price: 5 },\n    ]);\n    expect(result.subtotal).toBe(25);\n    expect(result.discount).toBe(0);\n    expect(result.tax).toBe(2.5);\n    expect(result.total).toBe(27.5);\n  });\n\n  it('should apply discount code before tax', () => {\n    const pricing = createPricingService(bus);\n    pricing.addDiscountCode('SAVE10', 10);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'SAVE10',\n    );\n    expect(result.subtotal).toBe(100);\n    expect(result.discount).toBe(10);\n    expect(result.tax).toBe(9); // 10% of 90\n    expect(result.total).toBe(99);\n  });\n\n  it('should track prices from product:created events', async () => {\n    const pricing = createPricingService(bus);\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 42, 'gadgets');\n    await new Promise(resolve => setTimeout(resolve, 10));\n    expect(pricing.getPrice(id)).toBe(42);\n  });\n\n  it('should ignore invalid discount codes', () => {\n    const pricing = createPricingService(bus);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'INVALID',\n    );\n    expect(result.discount).toBe(0);\n    expect(result.total).toBe(110);\n  });\n});\n\ndescribe('OrderService', () => {\n  it('should create an order with PENDING status', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    const order = orders.getOrder(id);\n    expect(order).not.toBeNull();\n    expect(order!.status).toBe(OrderStatus.PENDING);\n    expect(order!.total).toBe(50);\n  });\n\n  it('should follow valid status transitions', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.CONFIRMED);\n    orders.updateStatus(id, OrderStatus.SHIPPED);\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.SHIPPED);\n    orders.updateStatus(id, OrderStatus.DELIVERED);\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.DELIVERED);\n  });\n\n  it('should reject invalid status transitions', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(id, OrderStatus.SHIPPED); // can't skip CONFIRMED\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.PENDING);\n    orders.updateStatus(id, OrderStatus.DELIVERED);\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.PENDING);\n  });\n\n  it('should allow cancellation from PENDING or CONFIRMED', () => {\n    const orders = createOrderService(bus);\n    const id1 = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(id1, OrderStatus.CANCELLED);\n    expect(orders.getOrder(id1)!.status).toBe(OrderStatus.CANCELLED);\n\n    const id2 = orders.createOrder('user1', 'cart2', 60);\n    orders.updateStatus(id2, OrderStatus.CONFIRMED);\n    orders.updateStatus(id2, OrderStatus.CANCELLED);\n    expect(orders.getOrder(id2)!.status).toBe(OrderStatus.CANCELLED);\n  });\n\n  it('should not cancel after shipping', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    orders.updateStatus(id, OrderStatus.SHIPPED);\n    orders.updateStatus(id, OrderStatus.CANCELLED);\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.SHIPPED);\n  });\n\n  it('should list orders for a user', () => {\n    const orders = createOrderService(bus);\n    orders.createOrder('user1', 'c1', 10);\n    orders.createOrder('user1', 'c2', 20);\n    orders.createOrder('user2', 'c3', 30);\n    expect(orders.listOrders('user1')).toHaveLength(2);\n    expect(orders.listOrders('user2')).toHaveLength(1);\n  });\n\n  it('should emit events on creation and status change', async () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.ORDER_CREATED)).toBe(true);\n    expect(log.some(e => e.event === Events.ORDER_STATUS_CHANGED)).toBe(true);\n    const statusEvent = log.find(e => e.event === Events.ORDER_STATUS_CHANGED);\n    expect((statusEvent!.payload as { previousStatus: string }).previousStatus).toBe(OrderStatus.PENDING);\n  });\n});\n\ndescribe('PaymentService', () => {\n  it('should process successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.SUCCESS);\n    expect(result.transactionId).toBeDefined();\n  });\n\n  it('should simulate failure', async () => {\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.FAILED);\n    expect(result.error).toBeDefined();\n  });\n\n  it('should simulate timeout', async () => {\n    const payment = createPaymentService(bus, { simulateTimeout: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.TIMEOUT);\n  });\n\n  it('should refund successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    expect(await payment.refund(result.transactionId!)).toBe(true);\n  });\n\n  it('should not refund invalid transaction', async () => {\n    const payment = createPaymentService(bus);\n    expect(await payment.refund('invalid')).toBe(false);\n  });\n\n  it('should emit payment processed event', async () => {\n    const payment = createPaymentService(bus);\n    await payment.processPayment('order1', 100);\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.PAYMENT_PROCESSED)).toBe(true);\n  });\n});\n\ndescribe('NotificationService', () => {\n  it('should deliver notifications to subscribed users on order events', async () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n\n    notifications.subscribe('user1');\n    const orderId = orders.createOrder('user1', 'cart1', 50);\n    // Wait for async events\n    await new Promise(resolve => setTimeout(resolve, 50));\n\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    await new Promise(resolve => setTimeout(resolve, 50));\n\n    const notes = notifications.getNotifications('user1');\n    expect(notes.length).toBeGreaterThanOrEqual(2); // order created + status change\n    expect(notes.some(n => n.type === 'order_created')).toBe(true);\n    expect(notes.some(n => n.type === 'order_status')).toBe(true);\n  });\n\n  it('should deliver notifications on payment events', async () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n\n    notifications.subscribe('user1');\n    const orderId = orders.createOrder('user1', 'cart1', 50);\n    await payment.processPayment(orderId, 50);\n    await new Promise(resolve => setTimeout(resolve, 50));\n\n    const notes = notifications.getNotifications('user1');\n    expect(notes.some(n => n.type === 'payment')).toBe(true);\n  });\n\n  it('should not deliver to unsubscribed users', async () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n\n    orders.createOrder('user1', 'cart1', 50);\n    await new Promise(resolve => setTimeout(resolve, 50));\n\n    expect(notifications.getNotifications('user1')).toHaveLength