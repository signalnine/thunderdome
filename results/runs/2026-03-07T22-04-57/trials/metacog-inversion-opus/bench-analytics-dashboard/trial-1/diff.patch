entsBatch(req.user!.tenantId, mappedEvents);\n\n    res.status(201).json({\n      inserted: inserted.length,\n      events: inserted.map((event) => ({\n        id: event.id,\n        tenantId: event.tenant_id,\n        name: event.name,\n        properties: JSON.parse(event.properties),\n        timestamp: event.timestamp,\n        userId: event.user_id,\n        sessionId: event.session_id,\n      })),\n    });\n  }\n);\n\nexport default router;\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":429,"cache_read_input_tokens":29091,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":429},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"e6f729fa-b4ee-444d-a100-7dff85710c4e","uuid":"32f20bd0-952d-47c6-955d-f8aa0ff39e90"}
