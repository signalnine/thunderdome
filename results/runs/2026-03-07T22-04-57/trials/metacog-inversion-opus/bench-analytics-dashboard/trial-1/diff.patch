+import { Router, Request, Response } from "express";
+import { insertEvent, insertEventsBatch } from "../db.js";
+import { authMiddleware } from "../auth.js";
+
+const router = Router();
+
+// POST /api/events - ingest a single event
+router.post(
+  "/events",
+  authMiddleware,
+  (req: Request, res: Response): void => {
+    const { name, properties, timestamp, sessionId } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: "Event name is required" });
+      return;
+    }
+
+    const event = insertEvent(
+      req.user!.tenantId,
+      name,
+      properties || {},
+      timestamp,
+      req.user!.userId,
+      sessionId
+    );
+
+    res.status(201).json({
+      id: event.id,
+      tenantId: event.tenant_id,
+      name: event.name,
+      properties: JSON.parse(event.properties),
+      timestamp: event.timestamp,
+      userId: event.user_id,
+      sessionId: event.session_id,
+    });
+  }
+);
+
+// POST /api/events/batch - ingest multiple events
+router.post(
+  "/events/batch",
+  authMiddleware,
+  (req: Request, res: Response): void => {
+    const { events } = req.body;
+
+    if (!Array.isArray(events) || events.length === 0) {
+      res.status(400).json({ error: "Events array is required and must not be empty" });
+      return;
+    }
+
+    const mappedEvents = events.map(
+      (e: {
+        name: string;
+        properties?: Record<string, unknown>;
+        timestamp?: string;
+        sessionId?: string;
+      }) => ({
+        name: e.name,
+        properties: e.properties,
+        timestamp: e.timestamp,
+        userId: req.user!.userId,
+        sessionId: e.sessionId,
+      })
+    );
+
+    const inserted = insertEventsBatch(req.user!.tenantId, mappedEvents);
+
+    res.status(201).json({
+      inserted: inserted.length,
+      events: inserted.map((event) => ({
+        id: event.id,
+        tenantId: event.tenant_id,
+        name: event.name,
+        properties: JSON.parse(event.properties),
+        timestamp: event.timestamp,
+        userId: event.user_id,
+        sessionId: event.session_id,
+      })),
+    });
+  }
+);
+
+export default router;
