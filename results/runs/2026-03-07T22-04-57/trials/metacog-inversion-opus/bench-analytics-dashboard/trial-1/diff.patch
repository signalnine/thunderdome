+import { Router, Request, Response } from "express";
+import { countEvents, timeseriesQuery, breakdownQuery } from "../db.js";
+import { authMiddleware } from "../auth.js";
+
+const router = Router();
+
+// POST /api/queries/count
+router.post(
+  "/queries/count",
+  authMiddleware,
+  (req: Request, res: Response): void => {
+    const { name, startDate, endDate } = req.body;
+
+    const count = countEvents(req.user!.tenantId, {
+      name,
+      startDate,
+      endDate,
+    });
+
+    res.json({ count });
+  }
+);
+
+// POST /api/queries/timeseries
+router.post(
+  "/queries/timeseries",
+  authMiddleware,
+  (req: Request, res: Response): void => {
+    const { name, startDate, endDate, interval } = req.body;
+
+    const data = timeseriesQuery(req.user!.tenantId, {
+      name,
+      startDate,
+      endDate,
+      interval,
+    });
+
+    res.json({ data });
+  }
+);
+
+// POST /api/queries/breakdown
+router.post(
+  "/queries/breakdown",
+  authMiddleware,
+  (req: Request, res: Response): void => {
+    const { property, name, startDate, endDate } = req.body;
+
+    if (!property) {
+      res.status(400).json({ error: "Property name is required for breakdown queries" });
+      return;
+    }
+
+    const data = breakdownQuery(req.user!.tenantId, property, {
+      name,
+      startDate,
+      endDate,
+    });
+
+    res.json({ data });
+  }
+);
+
+export default router;
