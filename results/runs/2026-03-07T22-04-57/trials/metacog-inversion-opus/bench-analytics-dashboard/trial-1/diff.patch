+import { Router, Request, Response } from "express";
+import {
+  getEvents,
+  eventsToCSV,
+  getDashboardById,
+  getDashboards,
+  getWidgetsByDashboard,
+} from "../db.js";
+import { authMiddleware } from "../auth.js";
+
+const router = Router();
+
+// GET /api/export/events?format=csv|json&name=...&startDate=...&endDate=...
+router.get(
+  "/export/events",
+  authMiddleware,
+  (req: Request, res: Response): void => {
+    const format = (req.query.format as string) || "json";
+    const name = req.query.name as string | undefined;
+    const startDate = req.query.startDate as string | undefined;
+    const endDate = req.query.endDate as string | undefined;
+
+    const events = getEvents(req.user!.tenantId, { name, startDate, endDate });
+
+    if (format === "csv") {
+      const csv = eventsToCSV(events);
+      res.setHeader("Content-Type", "text/csv");
+      res.setHeader(
+        "Content-Disposition",
+        "attachment; filename=events.csv"
+      );
+      res.send(csv);
+      return;
+    }
+
+    // Default: JSON
+    res.json({
+      events: events.map((e) => ({
+        id: e.id,
+        tenantId: e.tenant_id,
+        name: e.name,
+        properties: JSON.parse(e.properties),
+        timestamp: e.timestamp,
+        userId: e.user_id,
+        sessionId: e.session_id,
+      })),
+    });
+  }
+);
+
+// GET /api/export/dashboards?format=csv|json
+router.get(
+  "/export/dashboards",
+  authMiddleware,
+  (req: Request, res: Response): void => {
+    const format = (req.query.format as string) || "json";
+    const dashboards = getDashboards(req.user!.tenantId);
+
+    const data = dashboards.map((d) => {
+      const widgets = getWidgetsByDashboard(req.user!.tenantId, d.id);
+      return {
+        id: d.id,
+        tenantId: d.tenant_id,
+        name: d.name,
+        ownerId: d.owner_id,
+        config: JSON.parse(d.config),
+        createdAt: d.created_at,
+        updatedAt: d.updated_at,
+        widgets: widgets.map((w) => ({
+          id: w.id,
+          type: w.type,
+          config: JSON.parse(w.config),
+          position: {
+            x: w.position_x,
+            y: w.position_y,
+            width: w.width,
+            height: w.height,
+          },
+        })),
+      };
+    });
+
+    if (format === "csv") {
+      const headers = [
+        "id",
+        "tenantId",
+        "name",
+        "ownerId",
+        "config",
+        "createdAt",
+        "updatedAt",
+        "widgetCount",
+      ];
+      const rows = data.map((d) => {
+        const values = [
+          d.id,
+          d.tenantId,
+          d.name,
+          d.ownerId,
+          JSON.stringify(d.config),
+          d.createdAt,
+          d.updatedAt,
+          String(d.widgets.length),
+        ];
+        return values
+          .map((v) => {
+            if (v.includes(",") || v.includes('"') || v.includes("\n")) {
+              return `"${v.replace(/"/g, '""')}"`;
+            }
+            return v;
+          })
+          .join(",");
+      });
+      const csv = [headers.join(","), ...rows].join("\n");
+      res.setHeader("Content-Type", "text/csv");
+      res.setHeader(
+        "Content-Disposition",
+        "attachment; filename=dashboards.csv"
+      );
+      res.send(csv);
+      return;
+    }
+
+    res.json({ dashboards: data });
+  }
+);
+
+// GET /api/export/dashboards/:id?format=csv|json
+router.get(
+  "/export/dashboards/:id",
+  authMiddleware,
+  (req: Request, res: Response): void => {
+    const format = (req.query.format as string) || "json";
+    const dashboard = getDashboardById(req.user!.tenantId, req.params.id);
+
+    if (!dashboard) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const widgets = getWidgetsByDashboard(req.user!.tenantId, dashboard.id);
+
+    const data = {
+      id: dashboard.id,
+      tenantId: dashboard.tenant_id,
+      name: dashboard.name,
+      ownerId: dashboard.owner_id,
+      config: JSON.parse(dashboard.config),
+      createdAt: dashboard.created_at,
+      updatedAt: dashboard.updated_at,
+      widgets: widgets.map((w) => ({
+        id: w.id,
+        type: w.type,
+        config: JSON.parse(w.config),
+        position: {
+          x: w.position_x,
+          y: w.position_y,
+          width: w.width,
+          height: w.height,
+        },
+      })),
+    };
+
+    if (format === "csv") {
+      const headers = [
+        "id",
+        "tenantId",
+        "name",
+        "ownerId",
+        "config",
+        "createdAt",
+        "updatedAt",
+        "widgetCount",
+      ];
+      const values = [
+        data.id,
+        data.tenantId,
+        data.name,
+        data.ownerId,
+        JSON.stringify(data.config),
+        data.createdAt,
+        data.updatedAt,
+        String(data.widgets.length),
+      ];
+      const row = values
+        .map((v) => {
+          if (v.includes(",") || v.includes('"') || v.includes("\n")) {
+            return `"${v.replace(/"/g, '""')}"`;
+          }
+          return v;
+        })
+        .join(",");
+      const csv = [headers.join(","), row].join("\n");
+      res.setHeader("Content-Type", "text/csv");
+      res.setHeader(
+        "Content-Disposition",
+        `attachment; filename=dashboard-${dashboard.id}.csv`
+      );
+      res.send(csv);
+      return;
+    }
+
+    res.json(data);
+  }
+);
+
+export default router;
