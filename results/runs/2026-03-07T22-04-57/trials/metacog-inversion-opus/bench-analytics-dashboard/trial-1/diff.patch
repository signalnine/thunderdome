shboards.length).toBeGreaterThan(0);\n  });\n\n  it(\"should export dashboards as CSV\", async () => {\n    const res = await request(app)\n      .get(\"/api/export/dashboards?format=csv\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n  });\n\n  it(\"should return 401 for unauthenticated export\", async () => {\n    const res = await request(app).get(\"/api/export/events\");\n    expect(res.status).toBe(401);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":476,"cache_read_input_tokens":41518,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":476},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"e6f729fa-b4ee-444d-a100-7dff85710c4e","uuid":"15fc402b-53cf-4f12-b175-dc68c9c0a787"}
