@@ -0,0 +1,62 @@
+import { Request, Response, NextFunction } from "express";
+import jwt from "jsonwebtoken";
+
+const JWT_SECRET = process.env.JWT_SECRET || "analytics-dashboard-secret-key";
+
+export interface AuthPayload {
+  userId: string;
+  email: string;
+  tenantId: string;
+  role: string;
+}
+
+// Type augmentation is in types.d.ts
+
+export function generateToken(payload: AuthPayload): string {
+  return jwt.sign(payload, JWT_SECRET, { expiresIn: "24h" });
+}
+
+export function verifyToken(token: string): AuthPayload {
+  return jwt.verify(token, JWT_SECRET) as AuthPayload;
+}
+
+export function authMiddleware(
+  req: Request,
+  res: Response,
+  next: NextFunction
+): void {
+  const authHeader = req.headers.authorization;
+
+  if (!authHeader) {
+    res.status(401).json({ error: "Authentication required" });
+    return;
+  }
+
+  const token = authHeader.startsWith("Bearer ")
+    ? authHeader.slice(7)
+    : authHeader;
+
+  try {
+    const payload = verifyToken(token);
+    req.user = payload;
+    next();
+  } catch {
+    res.status(401).json({ error: "Invalid or expired token" });
+  }
+}
+
+export function requireRole(...roles: string[]) {
+  return (req: Request, res: Response, next: NextFunction): void => {
+    if (!req.user) {
+      res.status(401).json({ error: "Authentication required" });
+      return;
+    }
+
+    if (!roles.includes(req.user.role)) {
+      res.status(403).json({ error: "Insufficient permissions" });
+      return;
+    }
+
+    next();
+  };
+}
diff --git a/src/db.ts b/src/db.ts
new file mode 100644
index 0000000..f58e426
--- /dev/null
+++ b/src/db.ts
@@ -0,0 +1,475 @@
+import Database from "better-sqlite3";
+import * as fs from "fs";
+import * as path from "path";
+import * as crypto from "crypto";
+import { v4 as uuidv4 } from "uuid";
+
+let db: Database.Database;
+
+export function getDb(): Database.Database {
+  if (!db) {
+    db = initDb();
+  }
+  return db;
+}
+
+export function initDb(dbPath?: string): Database.Database {
+  const instance = new Database(dbPath || ":memory:");
+  instance.pragma("journal_mode = WAL");
+  instance.pragma("foreign_keys = ON");
+
+  const schemaPath = path.join(__dirname, "..", "schema.sql");
+  if (fs.existsSync(schemaPath)) {
+    const schema = fs.readFileSync(schemaPath, "utf-8");
+    instance.exec(schema);
+  }
+
+  db = instance;
+  return instance;
+}
+
+export function closeDb(): void {
+  if (db) {
+    db.close();
+  }
+}
+
+// ---- Password hashing (simple crypto-based) ----
+
+export function hashPassword(password: string): string {
+  const salt = crypto.randomBytes(16).toString("hex");
+  const hash = crypto.scryptSync(password, salt, 64).toString("hex");
+  return `${salt}:${hash}`;
+}
+
+export function verifyPassword(password: string, stored: string): boolean {
+  const [salt, hash] = stored.split(":");
+  const computed = crypto.scryptSync(password, salt, 64).toString("hex");
+  return hash === computed;
+}
+
+// ---- User operations (tenant-scoped where applicable) ----
+
+export interface User {
+  id: string;
+  email: string;
+  password_hash: string;
+  tenant_id: string;
+  role: string;
+  created_at: string;
+}
+
+export function createUser(
+  email: string,
+  passwordHash: string,
+  tenantId: string,
+  role: string = "viewer"
+): User {
+  const id = uuidv4();
+  const stmt = getDb().prepare(
+    "INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)"
+  );
+  stmt.run(id, email, passwordHash, tenantId, role);
+  return getUserById(id)!;
+}
+
+export function getUserByEmail(email: string): User | undefined {
+  const stmt = getDb().prepare("SELECT * FROM users WHERE email = ?");
+  return stmt.get(email) as User | undefined;
+}
+
+export function getUserById(id: string): User | undefined {
+  const stmt = getDb().prepare("SELECT * FROM users WHERE id = ?");
+  return stmt.get(id) as User | undefined;
+}
+
+export function getUserByIdAndTenant(
+  id: string,
+  tenantId: string
+): User | undefined {
+  const stmt = getDb().prepare(
+    "SELECT * FROM users WHERE id = ? AND tenant_id = ?"
+  );
+  return stmt.get(id, tenantId) as User | undefined;
+}
+
+export function updateUserRole(
+  userId: string,
+  tenantId: string,
+  newRole: string
+): boolean {
+  const stmt = getDb().prepare(
+    "UPDATE users SET role = ? WHERE id = ? AND tenant_id = ?"
+  );
+  const result = stmt.run(newRole, userId, tenantId);
+  return result.changes > 0;
+}
+
+// ---- Event operations (always tenant-scoped) ----
+
+export interface AnalyticsEvent {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string | null;
+  session_id: string | null;
+}
+
+export function insertEvent(
+  tenantId: string,
+  name: string,
+  properties: Record<string, unknown> = {},
+  timestamp?: string,
+  userId?: string,
+  sessionId?: string
+): AnalyticsEvent {
+  const id = uuidv4();
+  const ts = timestamp || new Date().toISOString().replace("T", " ").replace("Z", "");
+  const stmt = getDb().prepare(
+    "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+  );
+  stmt.run(id, tenantId, name, JSON.stringify(properties), ts, userId || null, sessionId || null);
+  return { id, tenant_id: tenantId, name, properties: JSON.stringify(properties), timestamp: ts, user_id: userId || null, session_id: sessionId || null };
+}
+
+export function insertEventsBatch(
+  tenantId: string,
+  events: Array<{
+    name: string;
+    properties?: Record<string, unknown>;
+    timestamp?: string;
+    userId?: string;
+    sessionId?: string;
+  }>
+): AnalyticsEvent[] {
+  const stmt = getDb().prepare(
+    "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+  );
+
+  const insertMany = getDb().transaction(
+    (
+      items: Array<{
+        name: string;
+        properties?: Record<string, unknown>;
+        timestamp?: string;
+        userId?: string;
+        sessionId?: string;
+      }>
+    ) => {
+      const results: AnalyticsEvent[] = [];
+      for (const event of items) {
+        const id = uuidv4();
+        const ts =
+          event.timestamp ||
+          new Date().toISOString().replace("T", " ").replace("Z", "");
+        const props = JSON.stringify(event.properties || {});
+        stmt.run(
+          id,
+          tenantId,
+          event.name,
+          props,
+          ts,
+          event.userId || null,
+          event.sessionId || null
+        );
+        results.push({
+          id,
+          tenant_id: tenantId,
+          name: event.name,
+          properties: props,
+          timestamp: ts,
+          user_id: event.userId || null,
+          session_id: event.sessionId || null,
+        });
+      }
+      return results;
+    }
+  );
+
+  return insertMany(events);
+}
+
+// ---- Query operations (always tenant-scoped) ----
+
+export function countEvents(
+  tenantId: string,
+  filters: { name?: string; startDate?: string; endDate?: string } = {}
+): number {
+  let sql = "SELECT COUNT(*) as count FROM events WHERE tenant_id = ?";
+  const params: unknown[] = [tenantId];
+
+  if (filters.name) {
+    sql += " AND name = ?";
+    params.push(filters.name);
+  }
+  if (filters.startDate) {
+    sql += " AND timestamp >= ?";
+    params.push(filters.startDate);
+  }
+  if (filters.endDate) {
+    sql += " AND timestamp <= ?";
+    params.push(filters.endDate);
+  }
+
+  const row = getDb().prepare(sql).get(...params) as { count: number };
+  return row.count;
+}
+
+export function timeseriesQuery(
+  tenantId: string,
+  filters: {
+    name?: string;
+    startDate?: string;
+    endDate?: string;
+    interval?: string;
+  } = {}
+): Array<{ period: string; count: number }> {
+  const interval = filters.interval || "day";
+
+  let dateFormat: string;
+  switch (interval) {
+    case "hour":
+      dateFormat = "%Y-%m-%d %H:00:00";
+      break;
+    case "month":
+      dateFormat = "%Y-%m-01";
+      break;
+    case "day":
+    default:
+      dateFormat = "%Y-%m-%d";
+      break;
+  }
+
+  let sql = `SELECT strftime('${dateFormat}', timestamp) as period, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+  const params: unknown[] = [tenantId];
+
+  if (filters.name) {
+    sql += " AND name = ?";
+    params.push(filters.name);
+  }
+  if (filters.startDate) {
+    sql += " AND timestamp >= ?";
+    params.push(filters.startDate);
+  }
+  if (filters.endDate) {
+    sql += " AND timestamp <= ?";
+    params.push(filters.endDate);
+  }
+
+  sql += " GROUP BY period ORDER BY period ASC";
+
+  return getDb().prepare(sql).all(...params) as Array<{
+    period: string;
+    count: number;
+  }>;
+}
+
+export function breakdownQuery(
+  tenantId: string,
+  propertyName: string,
+  filters: { name?: string; startDate?: string; endDate?: string } = {}
+): Array<{ value: string; count: number }> {
+  let sql = `SELECT json_extract(properties, '$.' || ?) as value, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+  const params: unknown[] = [propertyName, tenantId];
+
+  if (filters.name) {
+    sql += " AND name = ?";
+    params.push(filters.name);
+  }
+  if (filters.startDate) {
+    sql += " AND timestamp >= ?";
+    params.push(filters.startDate);
+  }
+  if (filters.endDate) {
+    sql += " AND timestamp <= ?";
+    params.push(filters.endDate);
+  }
+
+  sql += " GROUP BY value ORDER BY count DESC";
+
+  return getDb().prepare(sql).all(...params) as Array<{
+    value: string;
+    count: number;
+  }>;
+}
+
+// ---- Dashboard operations (always tenant-scoped) ----
+
+export interface Dashboard {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export function createDashboard(
+  tenantId: string,
+  name: string,
+  ownerId: string,
+  config: Record<string, unknown> = {}
+): Dashboard {
+  const id = uuidv4();
+  const stmt = getDb().prepare(
+    "INSERT INTO dashboards (id, tenant_id, name, owner_id, config) VALUES (?, ?, ?, ?, ?)"
+  );
+  stmt.run(id, tenantId, name, ownerId, JSON.stringify(config));
+  return getDashboardById(tenantId, id)!;
+}
+
+export function getDashboards(tenantId: string): Dashboard[] {
+  const stmt = getDb().prepare(
+    "SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC"
+  );
+  return stmt.all(tenantId) as Dashboard[];
+}
+
+export function getDashboardById(
+  tenantId: string,
+  dashboardId: string
+): Dashboard | undefined {
+  const stmt = getDb().prepare(
+    "SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?"
+  );
+  return stmt.get(dashboardId, tenantId) as Dashboard | undefined;
+}
+
+export function updateDashboard(
+  tenantId: string,
+  dashboardId: string,
+  updates: { name?: string; config?: Record<string, unknown> }
+): Dashboard | undefined {
+  const existing = getDashboardById(tenantId, dashboardId);
+  if (!existing) return undefined;
+
+  const name = updates.name ?? existing.name;
+  const config =
+    updates.config !== undefined
+      ? JSON.stringify(updates.config)
+      : existing.config;
+
+  const stmt = getDb().prepare(
+    "UPDATE dashboards SET name = ?, config = ?, updated_at = datetime('now') WHERE id = ? AND tenant_id = ?"
+  );
+  stmt.run(name, config, dashboardId, tenantId);
+  return getDashboardById(tenantId, dashboardId);
+}
+
+export function deleteDashboard(
+  tenantId: string,
+  dashboardId: string
+): boolean {
+  const stmt = getDb().prepare(
+    "DELETE FROM dashboards WHERE id = ? AND tenant_id = ?"
+  );
+  const result = stmt.run(dashboardId, tenantId);
+  return result.changes > 0;
+}
+
+// ---- Widget operations ----
+
+export interface Widget {
+  id: string;
+  dashboard_id: string;
+  type: string;
+  config: string;
+  position_x: number;
+  position_y: number;
+  width: number;
+  height: number;
+}
+
+export function createWidget(
+  tenantId: string,
+  dashboardId: string,
+  type: string,
+  config: Record<string, unknown> = {},
+  position?: { x?: number; y?: number; width?: number; height?: number }
+): Widget | undefined {
+  const dashboard = getDashboardById(tenantId, dashboardId);
+  if (!dashboard) return undefined;
+
+  const id = uuidv4();
+  const stmt = getDb().prepare(
+    "INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)"
+  );
+  stmt.run(
+    id,
+    dashboardId,
+    type,
+    JSON.stringify(config),
+    position?.x ?? 0,
+    position?.y ?? 0,
+    position?.width ?? 1,
+    position?.height ?? 1
+  );
+  return getDb().prepare("SELECT * FROM widgets WHERE id = ?").get(id) as Widget;
+}
+
+export function getWidgetsByDashboard(
+  tenantId: string,
+  dashboardId: string
+): Widget[] {
+  const dashboard = getDashboardById(tenantId, dashboardId);
+  if (!dashboard) return [];
+
+  return getDb()
+    .prepare("SELECT * FROM widgets WHERE dashboard_id = ?")
+    .all(dashboardId) as Widget[];
+}
+
+// ---- Export operations (always tenant-scoped) ----
+
+export function getEvents(
+  tenantId: string,
+  filters: { name?: string; startDate?: string; endDate?: string } = {}
+): AnalyticsEvent[] {
+  let sql = "SELECT * FROM events WHERE tenant_id = ?";
+  const params: unknown[] = [tenantId];
+
+  if (filters.name) {
+    sql += " AND name = ?";
+    params.push(filters.name);
+  }
+  if (filters.startDate) {
+    sql += " AND timestamp >= ?";
+    params.push(filters.startDate);
+  }
+  if (filters.endDate) {
+    sql += " AND timestamp <= ?";
+    params.push(filters.endDate);
+  }
+
+  sql += " ORDER BY timestamp ASC";
+
+  return getDb().prepare(sql).all(...params) as AnalyticsEvent[];
+}
+
+export function eventsToCSV(events: AnalyticsEvent[]): string {
+  const headers = [
+    "id",
+    "tenant_id",
+    "name",
+    "properties",
+    "timestamp",
+    "user_id",
+    "session_id",
+  ];
+  const rows = events.map((e) =>
+    headers
+      .map((h) => {
+        const val = e[h as keyof AnalyticsEvent];
+        const str = val === null || val === undefined ? "" : String(val);
+        if (str.includes(",") || str.includes('"') || str.includes("\n")) {
+          return `"${str.replace(/"/g, '""')}"`;
+        }
+        return str;
+      })
+      .join(",")
+  );
+  return [headers.join(","), ...rows].join("\n");
+}
