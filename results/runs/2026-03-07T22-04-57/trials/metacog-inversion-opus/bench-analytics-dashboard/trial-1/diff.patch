).send({\n      email: \"admin@test.com\",\n      password: \"password123\",\n    });\n    expect(res.status).toBe(200);\n    expect(res.body.token).toBeDefined();\n    token = res.body.token;\n  });\n\n  it(\"should reject invalid login\", async () => {\n    const res = await request(app).post(\"/api/auth/login\").send({\n      email: \"admin@test.com\",\n      password: \"wrongpassword\",\n    });\n    expect(res.status).toBe(401);\n  });\n\n  it(\"should get current user profile\", async () => {\n    const res = await request(app)\n      .get(\"/api/users/me\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.email).toBe(\"admin@test.com\");\n    expect(res.body.id).toBe(userId);\n  });\n\n  it(\"should return 401 for unauthenticated profile request\", async () => {\n    const res = await request(app).get(\"/api/users/me\");\n    expect(res.status).toBe(401);\n  });\n\n  it(\"should update user role (admin only)\", async () => {\n    // Register a viewer in same tenant\n    const viewerRes = await request(app).post(\"/api/auth/register\").send({\n      email: \"viewer@test.com\",\n      password: \"password123\",\n      tenantId,\n      role: \"viewer\",\n    });\n    expect(viewerRes.status).toBe(201);\n    const viewerId = viewerRes.body.user.id;\n\n    // Update role\n    const res = await request(app)\n      .put(`/api/users/${viewerId}/role`)\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ role: \"editor\" });\n    expect(res.status).toBe(200);\n    expect(res.body.role).toBe(\"editor\");\n  });\n});\n\ndescribe(\"Authentication\", () => {\n  it(\"should return 401 for protected routes without token\", async () => {\n    const routes = [\n      { method: \"post\", path: \"/api/events\" },\n      { method: \"post\", path: \"/api/queries/count\" },\n      { method: \"get\", path: \"/api/dashboards\" },\n      { method: \"get\", path: \"/api/export/events\" },\n    ];\n\n    for (const route of routes) {\n      const res = await (request(app) as unknown as Record<string, (path: string) => request.Test>)[route.method](route.path);\n      expect(res.status).toBe(401);\n    }\n  });\n});\n\ndescribe(\"Event Ingestion\", () => {\n  let token: string;\n\n  beforeAll(async () => {\n    const res = await request(app).post(\"/api/auth/register\").send({\n      email: \"events@test.com\",\n      password: \"password123\",\n    });\n    token = res.body.token;\n  });\n\n  it(\"should ingest a single event\", async () => {\n    const res = await request(app)\n      .post(\"/api/events\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({\n        name: \"page_view\",\n        properties: { url: \"/home\", browser: \"chrome\" },\n        timestamp: \"2024-01-15 10:00:00\",\n      });\n    expect(res.status).toBe(201);\n    expect(res.body.name).toBe(\"page_view\");\n    expect(res.body.properties.url).toBe(\"/home\");\n  });\n\n  it(\"should ingest batch events\", async () => {\n    const res = await request(app)\n      .post(\"/api/events/batch\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({\n        events: [\n          { name: \"page_view\", properties: { url: \"/about\" }, timestamp: \"2024-01-15 11:00:00\" },\n          { name: \"page_view\", properties: { url: \"/contact\" }, timestamp: \"2024-01-15 12:00:00\" },\n          { name: \"click\", properties: { button: \"signup\" }, timestamp: \"2024-01-15 13:00:00\" },\n          { name: \"page_view\", properties: { url: \"/home\" }, timestamp: \"2024-01-16 10:00:00\" },\n        ],\n      });\n    expect(res.status).toBe(201);\n    expect(res.body.inserted).toBe(4);\n  });\n\n  it(\"should reject event without name\", async () => {\n    const res = await request(app)\n      .post(\"/api/events\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ properties: { url: \"/home\" } });\n    expect(res.status).toBe(400);\n  });\n});\n\ndescribe(\"Query Engine\", () 