 it(\"should delete a dashboard\", async () => {\n    const res = await request(app)\n      .delete(`/api/dashboards/${dashboardId}`)\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(204);\n\n    const getRes = await request(app)\n      .get(`/api/dashboards/${dashboardId}`)\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(getRes.status).toBe(404);\n  });\n});\n\ndescribe(\"Data Export\", () => {\n  let token: string;\n\n  beforeAll(async () => {\n    const reg = await request(app).post(\"/api/auth/register\").send({\n      email: \"export@test.com\",\n      password: \"password123\",\n    });\n    token = reg.body.token;\n\n    await request(app)\n      .post(\"/api/events/batch\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({\n        events: [\n          { name: \"page_view\", properties: { url: \"/home\" }, timestamp: \"2024-01-15 10:00:00\" },\n          { name: \"click\", properties: { button: \"buy\" }, timestamp: \"2024-01-15 11:00:00\" },\n        ],\n      });\n  });\n\n  it(\"should export events as JSON\", async () => {\n    const res = await request(app)\n      .get(\"/api/export/events?format=json\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.events).toHaveLength(2);\n  });\n\n  it(\"should export events as CSV\", async () => {\n    const res = await request(app)\n      .get(\"/api/export/events?format=csv\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n    expect(res.text).toContain(\"id,tenant_id,name\");\n  });\n\n  it(\"should export dashboards as JSON\", async () => {\n    // Create a dashboard first\n    await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Export Test\" });\n\n    const res = await request(app)\n      .get(\"/api/export/dash