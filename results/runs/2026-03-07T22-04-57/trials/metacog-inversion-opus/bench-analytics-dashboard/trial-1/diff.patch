+import { Router, Request, Response } from "express";
+import {
+  createDashboard,
+  getDashboards,
+  getDashboardById,
+  updateDashboard,
+  deleteDashboard,
+  getWidgetsByDashboard,
+  createWidget,
+} from "../db.js";
+import { authMiddleware } from "../auth.js";
+
+const router = Router();
+
+// POST /api/dashboards
+router.post(
+  "/dashboards",
+  authMiddleware,
+  (req: Request, res: Response): void => {
+    const { name, config } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: "Dashboard name is required" });
+      return;
+    }
+
+    const dashboard = createDashboard(
+      req.user!.tenantId,
+      name,
+      req.user!.userId,
+      config || {}
+    );
+
+    res.status(201).json({
+      id: dashboard.id,
+      tenantId: dashboard.tenant_id,
+      name: dashboard.name,
+      ownerId: dashboard.owner_id,
+      config: JSON.parse(dashboard.config),
+      createdAt: dashboard.created_at,
+      updatedAt: dashboard.updated_at,
+    });
+  }
+);
+
+// GET /api/dashboards
+router.get(
+  "/dashboards",
+  authMiddleware,
+  (req: Request, res: Response): void => {
+    const dashboards = getDashboards(req.user!.tenantId);
+
+    res.json({
+      dashboards: dashboards.map((d) => ({
+        id: d.id,
+        tenantId: d.tenant_id,
+        name: d.name,
+        ownerId: d.owner_id,
+        config: JSON.parse(d.config),
+        createdAt: d.created_at,
+        updatedAt: d.updated_at,
+      })),
+    });
+  }
+);
+
+// GET /api/dashboards/:id
+router.get(
+  "/dashboards/:id",
+  authMiddleware,
+  (req: Request, res: Response): void => {
+    const dashboard = getDashboardById(req.user!.tenantId, req.params.id);
+
+    if (!dashboard) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const widgets = getWidgetsByDashboard(req.user!.tenantId, dashboard.id);
+
+    res.json({
+      id: dashboard.id,
+      tenantId: dashboard.tenant_id,
+      name: dashboard.name,
+      ownerId: dashboard.owner_id,
+      config: JSON.parse(dashboard.config),
+      createdAt: dashboard.created_at,
+      updatedAt: dashboard.updated_at,
+      widgets: widgets.map((w) => ({
+        id: w.id,
+        type: w.type,
+        config: JSON.parse(w.config),
+        position: {
+          x: w.position_x,
+          y: w.position_y,
+          width: w.width,
+          height: w.height,
+        },
+      })),
+    });
+  }
+);
+
+// PUT /api/dashboards/:id
+router.put(
+  "/dashboards/:id",
+  authMiddleware,
+  (req: Request, res: Response): void => {
+    const { name, config } = req.body;
+
+    const updated = updateDashboard(req.user!.tenantId, req.params.id, {
+      name,
+      config,
+    });
+
+    if (!updated) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    res.json({
+      id: updated.id,
+      tenantId: updated.tenant_id,
+      name: updated.name,
+      ownerId: updated.owner_id,
+      config: JSON.parse(updated.config),
+      createdAt: updated.created_at,
+      updatedAt: updated.updated_at,
+    });
+  }
+);
+
+// DELETE /api/dashboards/:id
+router.delete(
+  "/dashboards/:id",
+  authMiddleware,
+  (req: Request, res: Response): void => {
+    const success = deleteDashboard(req.user!.tenantId, req.params.id);
+
+    if (!success) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    res.status(204).send();
+  }
+);
+
+// POST /api/dashboards/:id/widgets
+router.post(
+  "/dashboards/:id/widgets",
+  authMiddleware,
+  (req: Request, res: Response): void => {
+    const { type, config, position } = req.body;
+
+    if (!type || !["counter", "timeseries", "breakdown", "funnel"].includes(type)) {
+      res.status(400).json({
+        error: "Valid widget type required (counter, timeseries, breakdown, funnel)",
+      });
+      return;
+    }
+
+    const widget = createWidget(
+      req.user!.tenantId,
+      req.params.id,
+      type,
+      config || {},
+      position
+    );
+
+    if (!widget) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    res.status(201).json({
+      id: widget.id,
+      dashboardId: widget.dashboard_id,
+      type: widget.type,
+      config: JSON.parse(widget.config),
+      position: {
+        x: widget.position_x,
+        y: widget.position_y,
+        width: widget.width,
+        height: widget.height,
+      },
+    });
+  }
+);
+
+export default router;
