@@ -0,0 +1,51 @@
+import { marked } from 'marked';
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: async (file: ContentFile, _ctx: BuildContext): Promise<ContentFile> => {
+        let content = file.content;
+
+        // 1. Admonition containers :::note, :::warning, :::tip
+        content = content.replace(/:::(note|warning|tip)\n([\s\S]*?)\n:::/g, (_match, type, inner) => {
+          return `<div class="admonition admonition-${type}">\n${inner}\n</div>`;
+        });
+
+        // 2. Footnotes [^1] and [^1]: ...
+        const footnotes: Map<string, string> = new Map();
+        
+        // Extract definitions (must be at start of line or after newline)
+        content = content.replace(/^\[\^(\d+)\]: (.*)$/gm, (_match, id, text) => {
+          footnotes.set(id, text);
+          return '';
+        });
+
+        // Replace references
+        content = content.replace(/\[\^(\d+)\]/g, (_match, id) => {
+          return `<sup><a href="#fn-${id}">${id}</a></sup>`;
+        });
+
+        // 3. Convert Markdown to HTML using marked
+        let html = await marked.parse(content);
+
+        // 4. Append footnote section if any
+        if (footnotes.size > 0) {
+          let footnotesSection = '\n<section class="footnotes">\n<ol>\n';
+          // Sort by ID to ensure order as per tests
+          const sortedIds = Array.from(footnotes.keys()).sort((a, b) => parseInt(a) - parseInt(b));
+          for (const id of sortedIds) {
+            footnotesSection += `  <li id="fn-${id}">${footnotes.get(id)}</li>\n`;
+          }
+          footnotesSection += '</ol>\n</section>';
+          html += footnotesSection;
+        }
+
+        return { ...file, content: html.trim() };
+      },
+    },
+  };
+}
