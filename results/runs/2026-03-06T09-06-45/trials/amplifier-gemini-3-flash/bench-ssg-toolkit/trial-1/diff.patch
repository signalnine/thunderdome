@@ -0,0 +1,36 @@
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createAssetPipelinePlugin(): Plugin {
+  return {
+    name: 'asset-pipeline',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: async (file: ContentFile, ctx: BuildContext): Promise<ContentFile> => {
+        // Regex to match src="./..." or href="./..."
+        const assetRegex = /(src|href)="(\.\/([^"\s]+\.(?:png|jpg|jpeg|gif|pdf|svg|webp|css)))"/g;
+        let content = file.content;
+
+        let manifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;
+        if (!manifest) {
+          manifest = { assets: [] };
+          ctx.data.set('asset-manifest', manifest);
+        }
+
+        const matches = content.matchAll(assetRegex);
+        for (const match of matches) {
+          const assetName = match[3];
+          if (!manifest.assets.includes(assetName)) {
+            manifest.assets.push(assetName);
+          }
+        }
+
+        content = content.replace(assetRegex, (match, attr, _fullPath, assetName) => {
+          return `${attr}="/assets/${assetName}"`;
+        });
+
+        return { ...file, content };
+      },
+    },
+  };
+}
