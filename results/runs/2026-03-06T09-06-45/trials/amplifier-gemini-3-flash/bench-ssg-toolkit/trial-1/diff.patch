+import { Plugin, BuildContext } from '../core/types.js';
+
+export function createRssFeedPlugin(): Plugin {
+  return {
+    name: 'rss-feed',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'taxonomy'],
+    hooks: {
+      afterBuild: async (ctx: BuildContext): Promise<void> => {
+        const { config, files } = ctx;
+        
+        // Sort files by date, newest first
+        const sortedFiles = [...files].sort((a, b) => {
+          const dateA = a.date ? new Date(a.date).getTime() : 0;
+          const dateB = b.date ? new Date(b.date).getTime() : 0;
+          return dateB - dateA;
+        });
+
+        let rss = `<?xml version="1.0" encoding="UTF-8" ?>\n`;
+        rss += `<rss version="2.0">\n`;
+        rss += `  <channel>\n`;
+        rss += `    <title>${config.title}</title>\n`;
+        rss += `    <link>${config.baseUrl}</link>\n`;
+        rss += `    <description>${config.title} RSS Feed</description>\n`;
+
+        for (const file of sortedFiles) {
+          rss += `    <item>\n`;
+          rss += `      <title>${file.title}</title>\n`;
+          rss += `      <link>${config.baseUrl}/${file.slug}.html</link>\n`;
+          if (file.date) {
+            rss += `      <pubDate>${new Date(file.date).toUTCString()}</pubDate>\n`;
+          }
+          if (file.tags) {
+            for (const tag of file.tags) {
+              rss += `      <category>${tag}</category>\n`;
+            }
+          }
+          rss += `      <description><![CDATA[${file.content}]]></description>\n`;
+          rss += `    </item>\n`;
+        }
+
+        rss += `  </channel>\n`;
+        rss += `</rss>`;
+
+        ctx.output.set('feed.xml', rss);
+      }
+    }
+  };
+}
