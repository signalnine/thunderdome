diff --git a/src/index.test.ts b/src/index.test.ts
new file mode 100644
index 0000000..c2f25d6
--- /dev/null
+++ b/src/index.test.ts
@@ -0,0 +1,177 @@
+import { Express } from 'express';
+import { describe, it, expect, beforeEach } from 'vitest';
+import request from 'supertest';
+import { createApp, Activity } from './index.js';
+
+describe('Permission Maze API', () => {
+  let app: Express;
+  let token1: string;
+  let token2: string;
+  let user2Id: string;
+
+  beforeEach(async () => {
+    app = createApp();
+
+    // Register user 1
+    await request(app)
+      .post('/auth/register')
+      .send({ username: 'user1', password: 'password1' });
+
+    // Login user 1
+    const login1 = await request(app)
+      .post('/auth/login')
+      .send({ username: 'user1', password: 'password1' });
+    token1 = login1.body.token;
+
+    // Register user 2
+    const res2 = await request(app)
+      .post('/auth/register')
+      .send({ username: 'user2', password: 'password2' });
+    user2Id = res2.body.id;
+
+    // Login user 2
+    const login2 = await request(app)
+      .post('/auth/login')
+      .send({ username: 'user2', password: 'password2' });
+    token2 = login2.body.token;
+  });
+
+  it('should register and login users', () => {
+    expect(token1).toBeDefined();
+    expect(token2).toBeDefined();
+  });
+
+  it('should create and get folders', async () => {
+    const res = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${token1}`)
+      .send({ name: 'Root Folder' });
+    
+    expect(res.status).toBe(201);
+    expect(res.body.name).toBe('Root Folder');
+    const folderId = res.body.id;
+
+    const getRes = await request(app)
+      .get(`/folders/${folderId}`)
+      .set('Authorization', `Bearer ${token1}`);
+    
+    expect(getRes.status).toBe(200);
+    expect(getRes.body.name).toBe('Root Folder');
+  });
+
+  it('should create and get documents', async () => {
+    const folderRes = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${token1}`)
+      .send({ name: 'Folder' });
+    const folderId = folderRes.body.id;
+
+    const docRes = await request(app)
+      .post('/documents')
+      .set('Authorization', `Bearer ${token1}`)
+      .send({ title: 'Doc', content: 'Hello', folderId });
+    
+    expect(docRes.status).toBe(201);
+    expect(docRes.body.title).toBe('Doc');
+    const docId = docRes.body.id;
+
+    const getRes = await request(app)
+      .get(`/documents/${docId}`)
+      .set('Authorization', `Bearer ${token1}`);
+    
+    expect(getRes.status).toBe(200);
+    expect(getRes.body.content).toBe('Hello');
+  });
+
+  it('should handle permissions correctly (viewer)', async () => {
+    const folderRes = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${token1}`)
+      .send({ name: 'Private Folder' });
+    const folderId = folderRes.body.id;
+
+    // User 2 tries to access
+    const failRes = await request(app)
+      .get(`/folders/${folderId}`)
+      .set('Authorization', `Bearer ${token2}`);
+    expect(failRes.status).toBe(403);
+
+    // Share as viewer
+    await request(app)
+      .post('/share')
+      .set('Authorization', `Bearer ${token1}`)
+      .send({
+        resourceId: folderId,
+        resourceType: 'folder',
+        targetUserId: user2Id,
+        role: 'viewer'
+      });
+
+    // User 2 should now have access
+    const successRes = await request(app)
+      .get(`/folders/${folderId}`)
+      .set('Authorization', `Bearer ${token2}`);
+    expect(successRes.status).toBe(200);
+
+    // User 2 tries to edit
+    const editRes = await request(app)
+      .put(`/folders/${folderId}`)
+      .set('Authorization', `Bearer ${token2}`)
+      .send({ name: 'Hacked Name' });
+    expect(editRes.status).toBe(403);
+  });
+
+  it('should handle hierarchical permissions', async () => {
+    const rootRes = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${token1}`)
+      .send({ name: 'Root' });
+    const rootId = rootRes.body.id;
+
+    const subRes = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${token1}`)
+      .send({ name: 'Sub', parentId: rootId });
+    const subId = subRes.body.id;
+
+    const docRes = await request(app)
+      .post('/documents')
+      .set('Authorization', `Bearer ${token1}`)
+      .send({ title: 'Doc', folderId: subId });
+    const docId = docRes.body.id;
+
+    // Share Root with User 2 as editor
+    await request(app)
+      .post('/share')
+      .set('Authorization', `Bearer ${token1}`)
+      .send({
+        resourceId: rootId,
+        resourceType: 'folder',
+        targetUserId: user2Id,
+        role: 'editor'
+      });
+
+    // User 2 should be able to edit the document in the subfolder
+    const editRes = await request(app)
+      .put(`/documents/${docId}`)
+      .set('Authorization', `Bearer ${token2}`)
+      .send({ title: 'Updated Doc' });
+    expect(editRes.status).toBe(200);
+    expect(editRes.body.title).toBe('Updated Doc');
+  });
+
+  it('should track activities', async () => {
+    await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${token1}`)
+      .send({ name: 'Activity Folder' });
+
+    const res = await request(app)
+      .get('/activity')
+      .set('Authorization', `Bearer ${token1}`);
+    
+    expect(res.status).toBe(200);
+    expect(res.body.length).toBeGreaterThan(0);
+    expect(res.body.some((a: Activity) => a.type === 'folder_created')).toBe(true);
+  });
+});
