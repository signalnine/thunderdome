+++ b/src/index.ts
@@ -0,0 +1,334 @@
+import express, { Request, Response, NextFunction } from 'express';
+
+export type Role = 'viewer' | 'editor' | 'owner';
+
+export interface User {
+  id: string;
+  username: string;
+  password: string;
+}
+
+export interface Folder {
+  id: string;
+  name: string;
+  parentId: string | null;
+  ownerId: string;
+}
+
+export interface Document {
+  id: string;
+  title: string;
+  content: string;
+  folderId: string;
+  ownerId: string;
+}
+
+export interface Share {
+  id: string;
+  resourceId: string;
+  resourceType: 'folder' | 'document';
+  userId: string;
+  role: Role;
+}
+
+export interface Activity {
+  id: string;
+  type: string;
+  userId: string;
+  resourceId: string;
+  resourceType: 'folder' | 'document';
+  timestamp: number;
+}
+
+interface AuthRequest extends Request {
+  userId?: string;
+}
+
+export function createApp() {
+  // In-memory storage
+  const users = new Map<string, User>();
+  const folders = new Map<string, Folder>();
+  const documents = new Map<string, Document>();
+  const shares = new Map<string, Share>();
+  const activities: Activity[] = [];
+
+  // Simple token storage (token -> userId)
+  const tokens = new Map<string, string>();
+
+  const app = express();
+  app.use(express.json());
+
+  // Middleware for authentication
+  const authenticate = (req: Request, res: Response, next: NextFunction) => {
+    const authHeader = req.headers.authorization;
+    if (!authHeader || !authHeader.startsWith('Bearer ')) {
+      return res.status(401).json({ error: 'Unauthorized' });
+    }
+    const token = authHeader.split(' ')[1];
+    const userId = tokens.get(token);
+    if (!userId) {
+      return res.status(401).json({ error: 'Unauthorized' });
+    }
+    (req as AuthRequest).userId = userId;
+    next();
+  };
+
+  // Auth Routes
+  app.post('/auth/register', (req: Request, res: Response) => {
+    const { username, password } = req.body;
+    if (!username || !password) {
+      return res.status(400).json({ error: 'Username and password required' });
+    }
+    if (Array.from(users.values()).some(u => u.username === username)) {
+      return res.status(400).json({ error: 'User already exists' });
+    }
+    const id = Math.random().toString(36).substring(7);
+    users.set(id, { id, username, password });
+    res.status(201).json({ id, username });
+  });
+
+  app.post('/auth/login', (req: Request, res: Response) => {
+    const { username, password } = req.body;
+    const user = Array.from(users.values()).find(u => u.username === username && u.password === password);
+    if (!user) {
+      return res.status(401).json({ error: 'Invalid credentials' });
+    }
+    const token = Math.random().toString(36).substring(2) + Math.random().toString(36).substring(2);
+    tokens.set(token, user.id);
+    res.json({ token });
+  });
+
+  // Helper to get effective permission
+  const getEffectiveRole = (userId: string, resourceId: string, resourceType: 'folder' | 'document'): Role | null => {
+    if (resourceType === 'document') {
+      const doc = documents.get(resourceId);
+      if (!doc) return null;
+      if (doc.ownerId === userId) return 'owner';
+
+      let maxRole: Role | null = null;
+      const roles: Role[] = ['viewer', 'editor', 'owner'];
+
+      // Direct share
+      for (const share of shares.values()) {
+        if (share.resourceId === resourceId && share.resourceType === 'document' && share.userId === userId) {
+          if (!maxRole || roles.indexOf(share.role) > roles.indexOf(maxRole)) {
+            maxRole = share.role;
+          }
+        }
+      }
+
+      // Folder share
+      const folderRole = getEffectiveRole(userId, doc.folderId, 'folder');
+      if (folderRole) {
+        if (!maxRole || roles.indexOf(folderRole) > roles.indexOf(maxRole)) {
+          maxRole = folderRole;
+        }
+      }
+      return maxRole;
+    } else {
+      const folder = folders.get(resourceId);
+      if (!folder) return null;
+      if (folder.ownerId === userId) return 'owner';
+
+      let maxRole: Role | null = null;
+      const roles: Role[] = ['viewer', 'editor', 'owner'];
+
+      // Direct share
+      for (const share of shares.values()) {
+        if (share.resourceId === resourceId && share.resourceType === 'folder' && share.userId === userId) {
+          if (!maxRole || roles.indexOf(share.role) > roles.indexOf(maxRole)) {
+            maxRole = share.role;
+          }
+        }
+      }
+
+      // Parent folder share
+      if (folder.parentId) {
+        const parentRole = getEffectiveRole(userId, folder.parentId, 'folder');
+        if (parentRole) {
+          if (!maxRole || roles.indexOf(parentRole) > roles.indexOf(maxRole)) {
+            maxRole = parentRole;
+          }
+        }
+      }
+      return maxRole;
+    }
+  };
+
+  const logActivity = (type: string, userId: string, resourceId: string, resourceType: 'folder' | 'document') => {
+    activities.push({
+      id: Math.random().toString(36).substring(7),
+      type,
+      userId,
+      resourceId,
+      resourceType,
+      timestamp: Date.now(),
+    });
+  };
+
+  // Folder Routes
+  app.post('/folders', authenticate, (req: AuthRequest, res: Response) => {
+    const { name, parentId } = req.body;
+    const userId = req.userId!;
+    if (!name) return res.status(400).json({ error: 'Name required' });
+    
+    if (parentId) {
+      const parentRole = getEffectiveRole(userId, parentId, 'folder');
+      if (!parentRole || (parentRole !== 'editor' && parentRole !== 'owner')) {
+        return res.status(403).json({ error: 'Insufficient permissions on parent folder' });
+      }
+    }
+
+    const id = Math.random().toString(36).substring(7);
+    const folder: Folder = { id, name, parentId: parentId || null, ownerId: userId };
+    folders.set(id, folder);
+    logActivity('folder_created', userId, id, 'folder');
+    res.status(201).json(folder);
+  });
+
+  app.get('/folders/:id', authenticate, (req: AuthRequest, res: Response) => {
+    const userId = req.userId!;
+    const folder = folders.get(req.params.id);
+    if (!folder) return res.status(404).json({ error: 'Folder not found' });
+
+    const role = getEffectiveRole(userId, folder.id, 'folder');
+    if (!role) return res.status(403).json({ error: 'Forbidden' });
+
+    res.json(folder);
+  });
+
+  app.put('/folders/:id', authenticate, (req: AuthRequest, res: Response) => {
+    const userId = req.userId!;
+    const folder = folders.get(req.params.id);
+    if (!folder) return res.status(404).json({ error: 'Folder not found' });
+
+    const role = getEffectiveRole(userId, folder.id, 'folder');
+    if (!role || (role !== 'editor' && role !== 'owner')) {
+      return res.status(403).json({ error: 'Forbidden' });
+    }
+
+    const { name, parentId } = req.body;
+    if (name) folder.name = name;
+    if (parentId !== undefined) folder.parentId = parentId;
+    
+    logActivity('folder_updated', userId, folder.id, 'folder');
+    res.json(folder);
+  });
+
+  app.delete('/folders/:id', authenticate, (req: AuthRequest, res: Response) => {
+    const userId = req.userId!;
+    const folder = folders.get(req.params.id);
+    if (!folder) return res.status(404).json({ error: 'Folder not found' });
+
+    const role = getEffectiveRole(userId, folder.id, 'folder');
+    if (role !== 'owner') return res.status(403).json({ error: 'Forbidden' });
+
+    folders.delete(req.params.id);
+    logActivity('folder_deleted', userId, req.params.id, 'folder');
+    res.status(204).send();
+  });
+
+  // Document Routes
+  app.post('/documents', authenticate, (req: AuthRequest, res: Response) => {
+    const { title, content, folderId } = req.body;
+    const userId = req.userId!;
+    if (!title || !folderId) return res.status(400).json({ error: 'Title and folderId required' });
+
+    const folderRole = getEffectiveRole(userId, folderId, 'folder');
+    if (!folderRole || (folderRole !== 'editor' && folderRole !== 'owner')) {
+      return res.status(403).json({ error: 'Insufficient permissions on folder' });
+    }
+
+    const id = Math.random().toString(36).substring(7);
+    const doc: Document = { id, title, content: content || '', folderId, ownerId: userId };
+    documents.set(id, doc);
+    logActivity('document_created', userId, id, 'document');
+    res.status(201).json(doc);
+  });
+
+  app.get('/documents/:id', authenticate, (req: AuthRequest, res: Response) => {
+    const userId = req.userId!;
+    const doc = documents.get(req.params.id);
+    if (!doc) return res.status(404).json({ error: 'Document not found' });
+
+    const role = getEffectiveRole(userId, doc.id, 'document');
+    if (!role) return res.status(403).json({ error: 'Forbidden' });
+
+    res.json(doc);
+  });
+
+  app.put('/documents/:id', authenticate, (req: AuthRequest, res: Response) => {
+    const userId = req.userId!;
+    const doc = documents.get(req.params.id);
+    if (!doc) return res.status(404).json({ error: 'Document not found' });
+
+    const role = getEffectiveRole(userId, doc.id, 'document');
+    if (!role || (role !== 'editor' && role !== 'owner')) {
+      return res.status(403).json({ error: 'Forbidden' });
+    }
+
+    const { title, content, folderId } = req.body;
+    if (title) doc.title = title;
+    if (content !== undefined) doc.content = content;
+    if (folderId) {
+      const folderRole = getEffectiveRole(userId, folderId, 'folder');
+      if (!folderRole || (folderRole !== 'editor' && folderRole !== 'owner')) {
+        return res.status(403).json({ error: 'Insufficient permissions on target folder' });
+      }
+      doc.folderId = folderId;
+    }
+
+    logActivity('document_updated', userId, doc.id, 'document');
+    res.json(doc);
+  });
+
+  app.delete('/documents/:id', authenticate, (req: AuthRequest, res: Response) => {
+    const userId = req.userId!;
+    const doc = documents.get(req.params.id);
+    if (!doc) return res.status(404).json({ error: 'Document not found' });
+
+    const role = getEffectiveRole(userId, doc.id, 'document');
+    if (role !== 'owner') return res.status(403).json({ error: 'Forbidden' });
+
+    documents.delete(req.params.id);
+    logActivity('document_deleted', userId, req.params.id, 'document');
+    res.status(204).send();
+  });
+
+  // Sharing Routes
+  app.post('/share', authenticate, (req: AuthRequest, res: Response) => {
+    const { resourceId, resourceType, targetUserId, role } = req.body;
+    const userId = req.userId!;
+
+    if (!resourceId || !resourceType || !targetUserId || !role) {
+      return res.status(400).json({ error: 'Missing required fields' });
+    }
+
+    if (resourceType !== 'folder' && resourceType !== 'document') {
+      return res.status(400).json({ error: 'Invalid resourceType' });
+    }
+
+    const currentRole = getEffectiveRole(userId, resourceId, resourceType);
+    if (!currentRole || (currentRole !== 'editor' && currentRole !== 'owner')) {
+      return res.status(403).json({ error: 'Insufficient permissions to share' });
+    }
+
+    if (!users.has(targetUserId)) {
+      return res.status(404).json({ error: 'Target user not found' });
+    }
+
+    const shareId = Math.random().toString(36).substring(7);
+    const share: Share = { id: shareId, resourceId, resourceType, userId: targetUserId, role };
+    shares.set(shareId, share);
+    
+    logActivity('resource_shared', userId, resourceId, resourceType);
+    res.status(201).json(share);
+  });
+
+  // Activity Log
+  app.get('/activity', authenticate, (req: Request, res: Response) => {
+    res.json(activities);
+  });
+
+  return app;
+}
