+  router.get('/dashboards/:dashboardId/widgets', getWidgetsHandler);
+  router.put('/widgets/:id', updateWidgetHandler);
+  router.delete('/widgets/:id', deleteWidgetHandler);
+
+  app.use('/api', router);
+}
