+import { Request, Response } from 'express';
+import { createEvent, createEvents, getEvents, countEvents, getTimeseries, getBreakdown } from '../services/event.service';
+
+/**
+ * Ingest a single event
+ */
+export async function ingestEvent(req: Request, res: Response) {
+  try {
+    const { name, properties, timestamp } = req.body;
+    const tenantId = req.user.tenantId;
+    const userId = req.user.userId;
+
+    if (!name) {
+      return res.status(400).json({ error: 'Event name is required' });
+    }
+
+    const event = await createEvent({
+      tenant_id: tenantId,
+      name,
+      properties: properties || {},
+      timestamp,
+      user_id: userId
+    });
+
+    res.status(201).json(event);
+  } catch (error) {
+    console.error('Ingest event error:', error);
+    res.status(500).json({ error: 'Internal server error' });
+  }
+}
+
+/**
+ * Ingest multiple events in a batch
+ */
+export async function ingestEvents(req: Request, res: Response) {
+  try {
+    const events = req.body;
+    const tenantId = req.user.tenantId;
+    const userId = req.user.userId;
+
+    if (!Array.isArray(events)) {
+      return res.status(400).json({ error: 'Events must be an array' });
+    }
+
+    // Validate each event has a name
+    for (const event of events) {
+      if (!event.name) {
+        return res.status(400).json({ error: 'Each event must have a name' });
+      }
+    }
+
+    // Prepare events for insertion
+    const preparedEvents = events.map((event: { name: string; properties?: Record<string, unknown>; timestamp?: string; session_id?: string }) => ({
+      tenant_id: tenantId,
+      name: event.name,
+      properties: event.properties ?? {},
+      timestamp: event.timestamp,
+      user_id: userId,
+      session_id: event.session_id
+    }));
+
+    const createdEvents = await createEvents(preparedEvents);
+
+    res.status(201).json(createdEvents);
+  } catch (error) {
+    console.error('Ingest events error:', error);
+    res.status(500).json({ error: 'Internal server error' });
+  }
+}
+
+/**
+ * Query events (with filtering)
+ */
+export async function queryEvents(req: Request, res: Response) {
+  try {
+    const tenantId = req.user.tenantId;
+    const { name, startTime, endTime, limit, offset } = req.query;
+
+    const options: {
+      name?: string;
+      startTime?: string;
+      endTime?: string;
+      limit?: number;
+      offset?: number;
+    } = {};
+    if (name) options.name = String(name);
+    if (startTime) options.startTime = String(startTime);
+    if (endTime) options.endTime = String(endTime);
+    if (limit) options.limit = Number(limit);
+    if (offset) options.offset = Number(offset);
+
+    const events = await getEvents(tenantId, options);
+    res.json(events);
+  } catch (error) {
+    console.error('Query events error:', error);
+    res.status(500).json({ error: 'Internal server error' });
+  }
+}
+
+/**
+ * Count events
+ */
+export async function countEventsHandler(req: Request, res: Response) {
+  try {
+    const tenantId = req.user.tenantId;
+    const { name, startTime, endTime } = req.query;
+
+    const options: {
+      name?: string;
+      startTime?: string;
+      endTime?: string;
+    } = {};
+    if (name) options.name = String(name);
+    if (startTime) options.startTime = String(startTime);
+    if (endTime) options.endTime = String(endTime);
+
+    const count = await countEvents(tenantId, options);
+    res.json({ count });
+  } catch (error) {
+    console.error('Count events error:', error);
+    res.status(500).json({ error: 'Internal server error' });
+  }
+}
+
+/**
+ * Get timeseries data
+ */
+export async function getTimeseriesHandler(req: Request, res: Response) {
+  try {
+    const tenantId = req.user.tenantId;
+    const { name, startTime, endTime, interval } = req.query;
+
+    if (!interval || !['hour', 'day', 'week', 'month'].includes(interval as string)) {
+      return res.status(400).json({ error: 'Valid interval (hour, day, week, month) is required' });
+    }
+
+    const options: {
+      name?: string;
+      startTime?: string;
+      endTime?: string;
+      interval: 'hour' | 'day' | 'week' | 'month';
+    } = {
+      interval: interval as 'hour' | 'day' | 'week' | 'month'
+    };
+    if (name) options.name = String(name);
+    if (startTime) options.startTime = String(startTime);
+    if (endTime) options.endTime = String(endTime);
+
+    const timeseries = await getTimeseries(tenantId, options);
+    res.json(timeseries);
+  } catch (error) {
+    console.error('Get timeseries error:', error);
+    res.status(500).json({ error: 'Internal server error' });
+  }
+}
+
+/**
+ * Get breakdown of events by a property
+ */
+export async function getBreakdownHandler(req: Request, res: Response) {
+  try {
+    const tenantId = req.user.tenantId;
+    const { name, startTime, endTime, property, limit } = req.query;
+
+    if (!property) {
+      return res.status(400).json({ error: 'Property is required for breakdown' });
+    }
+
+    const options: {
+      name?: string;
+      startTime?: string;
+      endTime?: string;
+      property: string;
+      limit?: number;
+    } = {
+      property: String(property)
+    };
+    if (name) options.name = String(name);
+    if (startTime) options.startTime = String(startTime);
+    if (endTime) options.endTime = String(endTime);
+    if (limit) options.limit = Number(limit);
+
+    const breakdown = await getBreakdown(tenantId, options);
+    res.json(breakdown);
+  } catch (error) {
+    console.error('Get breakdown error:', error);
+    res.status(500).json({ error: 'Internal server error' });
+  }
+}
