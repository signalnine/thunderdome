+import { v4 as uuidv4 } from 'uuid';
+import { getDb } from '../database';
+
+const db = getDb();
+
+export interface Dashboard {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: Record<string, unknown>;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface Widget {
+  id: string;
+  dashboard_id: string;
+  type: 'counter' | 'timeseries' | 'breakdown' | 'funnel';
+  config: Record<string, unknown>;
+  position_x: number;
+  position_y: number;
+  width: number;
+  height: number;
+}
+
+/**
+ * Create a new dashboard
+ */
+export function createDashboard(dashboard: Omit<Dashboard, 'id' | 'created_at' | 'updated_at'>): Dashboard {
+  const id = uuidv4();
+  const now = new Date().toISOString();
+  
+  db.prepare(`
+    INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at)
+    VALUES (?, ?, ?, ?, ?, ?, ?)
+  `).run(
+    id,
+    dashboard.tenant_id,
+    dashboard.name,
+    dashboard.owner_id,
+    JSON.stringify(dashboard.config),
+    now,
+    now
+  );
+
+  return { id, ...dashboard, created_at: now, updated_at: now };
+}
+
+/**
+ * Get a dashboard by ID
+ */
+export function getDashboardById(id: string): Dashboard | null {
+  const row = db.prepare('SELECT * FROM dashboards WHERE id = ?').get(
+    id
+  ) as {
+    id: string;
+    tenant_id: string;
+    name: string;
+    owner_id: string;
+    config: string;
+    created_at: string;
+    updated_at: string;
+  } | undefined;
+
+  if (!row) return null;
+  
+  return {
+    id: row.id,
+    tenant_id: row.tenant_id,
+    name: row.name,
+    owner_id: row.owner_id,
+    config: JSON.parse(row.config),
+    created_at: row.created_at,
+    updated_at: row.updated_at
+  };
+}
+
+/**
+ * Get dashboards for a tenant
+ */
+export function getDashboardsByTenant(tenantId: string): Dashboard[] {
+  const rows = db.prepare('SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC').all(
+    tenantId
+  ) as {
+    id: string;
+    tenant_id: string;
+    name: string;
+    owner_id: string;
+    config: string;
+    created_at: string;
+    updated_at: string;
+  }[];
+  
+  return rows.map(row => ({
+    id: row.id,
+    tenant_id: row.tenant_id,
+    name: row.name,
+    owner_id: row.owner_id,
+    config: JSON.parse(row.config),
+    created_at: row.created_at,
+    updated_at: row.updated_at
+  }));
+}
+
+/**
+ * Update a dashboard
+ */
+export function updateDashboard(id: string, updates: Partial<Omit<Dashboard, 'id' | 'tenant_id' | 'owner_id' | 'created_at'>>): Dashboard | null {
+  const dashboard = getDashboardById(id);
+  if (!dashboard) return null;
+
+  const fields: string[] = [];
+  const values: (string | number | boolean)[] = [];
+
+  if (updates.name !== undefined) {
+    fields.push('name = ?');
+    values.push(updates.name);
+  }
+  if (updates.config !== undefined) {
+    fields.push('config = ?');
+    values.push(JSON.stringify(updates.config));
+  }
+  // Always update updated_at
+  fields.push('updated_at = ?');
+  values.push(new Date().toISOString());
+
+  if (fields.length === 0) {
+    return dashboard;
+  }
+
+  values.push(id); // for WHERE clause
+
+  db.prepare(`
+    UPDATE dashboards
+    SET ${fields.join(', ')}
+    WHERE id = ?
+  `).run(values);
+
+  return getDashboardById(id);
+}
+
+/**
+ * Delete a dashboard
+ */
+export function deleteDashboard(id: string): boolean {
+  const result = db.prepare('DELETE FROM dashboards WHERE id = ?').run(id);
+  return result.changes > 0;
+}
+
+/**
+ * Create a widget on a dashboard
+ */
+export function createWidget(widget: Omit<Widget, 'id'>): Widget {
+  const id = uuidv4();
+  
+  db.prepare(`
+    INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height)
+    VALUES (?, ?, ?, ?, ?, ?, ?, ?)
+  `).run(
+    id,
+    widget.dashboard_id,
+    widget.type,
+    JSON.stringify(widget.config),
+    widget.position_x,
+    widget.position_y,
+    widget.width,
+    widget.height
+  );
+
+  return { id, ...widget };
+}
+
+/**
+ * Get widgets for a dashboard
+ */
+export function getWidgetsByDashboard(dashboardId: string): Widget[] {
+  const rows = db.prepare('SELECT * FROM widgets WHERE dashboard_id = ?').all(
+    dashboardId
+  ) as {
+    id: string;
+    dashboard_id: string;
+    type: string;
+    config: string;
+    position_x: number;
+    position_y: number;
+    width: number;
+    height: number;
+  }[];
+  
+  return rows.map(row => ({
+    id: row.id,
+    dashboard_id: row.dashboard_id,
+    type: row.type as 'counter' | 'timeseries' | 'breakdown' | 'funnel',
+    config: JSON.parse(row.config),
+    position_x: row.position_x,
+    position_y: row.position_y,
+    width: row.width,
+    height: row.height
+  }));
+}
+
+/**
+ * Update a widget
+ */
+export function updateWidget(id: string, updates: Partial<Omit<Widget, 'id' | 'dashboard_id'>>): Widget | null {
+  const widget = getWidgetById(id);
+  if (!widget) return null;
+
+  const fields: string[] = [];
+  const values: (string | number | boolean)[] = [];
+
+  if (updates.type !== undefined) {
+    fields.push('type = ?');
+    values.push(updates.type);
+  }
+  if (updates.config !== undefined) {
+    fields.push('config = ?');
+    values.push(JSON.stringify(updates.config));
+  }
+  if (updates.position_x !== undefined) {
+    fields.push('position_x = ?');
+    values.push(updates.position_x);
+  }
+  if (updates.position_y !== undefined) {
+    fields.push('position_y = ?');
+    values.push(updates.position_y);
+  }
+  if (updates.width !== undefined) {
+    fields.push('width = ?');
+    values.push(updates.width);
+  }
+  if (updates.height !== undefined) {
+    fields.push('height = ?');
+    values.push(updates.height);
+  }
+
+  if (fields.length === 0) {
+    return widget;
+  }
+
+  values.push(id); // for WHERE clause
+
+  db.prepare(`
+    UPDATE widgets
+    SET ${fields.join(', ')}
+    WHERE id = ?
+  `).run(values);
+
+  return getWidgetById(id);
+}
+
+/**
+ * Delete a widget
+ */
+export function deleteWidget(id: string): boolean {
+  const result = db.prepare('DELETE FROM widgets WHERE id = ?').run(id);
+  return result.changes > 0;
+}
+
+/**
+ * Get a widget by ID
+ */
+export function getWidgetById(id: string): Widget | null {
+  const row = db.prepare('SELECT * FROM widgets WHERE id = ?').get(
+    id
+  ) as {
+    id: string;
+    dashboard_id: string;
+    type: string;
+    config: string;
+    position_x: number;
+    position_y: number;
+    width: number;
+    height: number;
+  } | undefined;
+  
+  if (!row) return null;
+  
+  return {
+    id: row.id,
+    dashboard_id: row.dashboard_id,
+    type: row.type as 'counter' | 'timeseries' | 'breakdown' | 'funnel',
+    config: JSON.parse(row.config),
+    position_x: row.position_x,
+    position_y: row.position_y,
+    width: row.width,
+    height: row.height
+  };
+}
