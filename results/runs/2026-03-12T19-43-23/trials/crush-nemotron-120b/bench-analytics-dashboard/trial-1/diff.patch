+++ b/src/controllers/dashboard.controller.ts
@@ -0,0 +1,289 @@
+import { Request, Response } from 'express';
+import { 
+  createDashboard, 
+  getDashboardById, 
+  getDashboardsByTenant, 
+  updateDashboard, 
+  deleteDashboard,
+  createWidget,
+  getWidgetsByDashboard,
+  updateWidget,
+  deleteWidget,
+  getWidgetById
+} from '../services/dashboard.service';
+
+/**
+ * Create a new dashboard
+ */
+export async function createDashboardHandler(req: Request, res: Response) {
+  try {
+    const { name, config } = req.body;
+    const tenantId = req.user.tenantId;
+    const ownerId = req.user.userId;
+
+    if (!name) {
+      return res.status(400).json({ error: 'Dashboard name is required' });
+    }
+
+    const dashboard = await createDashboard({
+      tenant_id: tenantId,
+      name,
+      owner_id: ownerId,
+      config: config || {}
+    });
+
+    res.status(201).json(dashboard);
+  } catch (error) {
+    console.error('Create dashboard error:', error);
+    res.status(500).json({ error: 'Internal server error' });
+  }
+}
+
+/**
+ * Get a dashboard by ID
+ */
+export async function getDashboardHandler(req: Request, res: Response) {
+  try {
+    const { id } = req.params;
+    const tenantId = req.user.tenantId;
+
+    const dashboard = await getDashboardById(id);
+    if (!dashboard) {
+      return res.status(404).json({ error: 'Dashboard not found' });
+    }
+
+    // Check tenant isolation
+    if (dashboard.tenant_id !== tenantId) {
+      return res.status(403).json({ error: 'Access denied' });
+    }
+
+    res.json(dashboard);
+  } catch (error) {
+    console.error('Get dashboard error:', error);
+    res.status(500).json({ error: 'Internal server error' });
+  }
+}
+
+/**
+ * Get all dashboards for the current tenant
+ */
+export async function getDashboardsHandler(req: Request, res: Response) {
+  try {
+    const tenantId = req.user.tenantId;
+    const dashboards = await getDashboardsByTenant(tenantId);
+    res.json(dashboards);
+  } catch (error) {
+    console.error('Get dashboards error:', error);
+    res.status(500).json({ error: 'Internal server error' });
+  }
+}
+
+/**
+ * Update a dashboard
+ */
+export async function updateDashboardHandler(req: Request, res: Response) {
+  try {
+    const { id } = req.params;
+    const { name, config } = req.body;
+    const tenantId = req.user.tenantId;
+
+    // Check if dashboard exists and belongs to tenant
+    const dashboard = await getDashboardById(id);
+    if (!dashboard) {
+      return res.status(404).json({ error: 'Dashboard not found' });
+    }
+
+    if (dashboard.tenant_id !== tenantId) {
+      return res.status(403).json({ error: 'Access denied' });
+    }
+
+    const updated = await updateDashboard(id, { name, config });
+    if (!updated) {
+      return res.status(500).json({ error: 'Failed to update dashboard' });
+    }
+
+    res.json(updated);
+  } catch (error) {
+    console.error('Update dashboard error:', error);
+    res.status(500).json({ error: 'Internal server error' });
+  }
+}
+
+/**
+ * Delete a dashboard
+ */
+export async function deleteDashboardHandler(req: Request, res: Response) {
+  try {
+    const { id } = req.params;
+    const tenantId = req.user.tenantId;
+
+    // Check if dashboard exists and belongs to tenant
+    const dashboard = await getDashboardById(id);
+    if (!dashboard) {
+      return res.status(404).json({ error: 'Dashboard not found' });
+    }
+
+    if (dashboard.tenant_id !== tenantId) {
+      return res.status(403).json({ error: 'Access denied' });
+    }
+
+    const success = await deleteDashboard(id);
+    if (!success) {
+      return res.status(500).json({ error: 'Failed to delete dashboard' });
+    }
+
+    res.json({ message: 'Dashboard deleted successfully' });
+  } catch (error) {
+    console.error('Delete dashboard error:', error);
+    res.status(500).json({ error: 'Internal server error' });
+  }
+}
+
+/**
+ * Create a widget on a dashboard
+ */
+export async function createWidgetHandler(req: Request, res: Response) {
+  try {
+    const { dashboardId } = req.params;
+    const { type, config, position_x, position_y, width, height } = req.body;
+    const tenantId = req.user.tenantId;
+
+    // Check if dashboard exists and belongs to tenant
+    const dashboard = await getDashboardById(dashboardId);
+    if (!dashboard) {
+      return res.status(404).json({ error: 'Dashboard not found' });
+    }
+
+    if (dashboard.tenant_id !== tenantId) {
+      return res.status(403).json({ error: 'Access denied' });
+    }
+
+    // Validate widget type
+    const validTypes = ['counter', 'timeseries', 'breakdown', 'funnel'];
+    if (!validTypes.includes(type)) {
+      return res.status(400).json({ error: 'Invalid widget type' });
+    }
+
+    const widget = await createWidget({
+      dashboard_id: dashboardId,
+      type,
+      config: config || {},
+      position_x: position_x || 0,
+      position_y: position_y || 0,
+      width: width || 1,
+      height: height || 1
+    });
+
+    res.status(201).json(widget);
+  } catch (error) {
+    console.error('Create widget error:', error);
+    res.status(500).json({ error: 'Internal server error' });
+  }
+}
+
+/**
+ * Get widgets for a dashboard
+ */
+export async function getWidgetsHandler(req: Request, res: Response) {
+  try {
+    const { dashboardId } = req.params;
+    const tenantId = req.user.tenantId;
+
+    // Check if dashboard exists and belongs to tenant
+    const dashboard = await getDashboardById(dashboardId);
+    if (!dashboard) {
+      return res.status(404).json({ error: 'Dashboard not found' });
+    }
+
+    if (dashboard.tenant_id !== tenantId) {
+      return res.status(403).json({ error: 'Access denied' });
+    }
+
+    const widgets = await getWidgetsByDashboard(dashboardId);
+    res.json(widgets);
+  } catch (error) {
+    console.error('Get widgets error:', error);
+    res.status(500).json({ error: 'Internal server error' });
+  }
+}
+
+/**
+ * Update a widget
+ */
+export async function updateWidgetHandler(req: Request, res: Response) {
+  try {
+    const { id } = req.params;
+    const { type, config, position_x, position_y, width, height } = req.body;
+    const tenantId = req.user.tenantId;
+
+    // Get the widget by id
+    const widget = getWidgetById(id);
+    if (!widget) {
+      return res.status(404).json({ error: 'Widget not found' });
+    }
+
+    // Check the dashboard for tenant ownership
+    const dashboard = await getDashboardById(widget.dashboard_id);
+    if (!dashboard) {
+      return res.status(404).json({ error: 'Dashboard not found' });
+    }
+
+    if (dashboard.tenant_id !== tenantId) {
+      return res.status(403).json({ error: 'Access denied' });
+    }
+
+    // Validate widget type if provided
+    if (type !== undefined) {
+      const validTypes = ['counter', 'timeseries', 'breakdown', 'funnel'];
+      if (!validTypes.includes(type)) {
+        return res.status(400).json({ error: 'Invalid widget type' });
+      }
+    }
+
+    const updated = await updateWidget(id, { type, config, position_x, position_y, width, height });
+    if (!updated) {
+      return res.status(500).json({ error: 'Failed to update widget' });
+    }
+
+    res.json(updated);
+  } catch (error) {
+    console.error('Update widget error:', error);
+    res.status(500).json({ error: 'Internal server error' });
+  }
+}
+
+/**
+ * Delete a widget
+ */
+export async function deleteWidgetHandler(req: Request, res: Response) {
+  try {
+    const { id } = req.params;
+    const tenantId = req.user.tenantId;
+
+    // Get the widget by id
+    const widget = getWidgetById(id);
+    if (!widget) {
+      return res.status(404).json({ error: 'Widget not found' });
+    }
+
+    // Check the dashboard for tenant ownership
+    const dashboard = await getDashboardById(widget.dashboard_id);
+    if (!dashboard) {
+      return res.status(404).json({ error: 'Dashboard not found' });
+    }
+
+    if (dashboard.tenant_id !== tenantId) {
+      return res.status(403).json({ error: 'Access denied' });
+    }
+
+    const success = await deleteWidget(id);
+    if (!success) {
+      return res.status(500).json({ error: 'Failed to delete widget' });
+    }
+
+    res.json({ message: 'Widget deleted successfully' });
+  } catch (error) {
+    console.error('Delete widget error:', error);
+    res.status(500).json({ error: 'Internal server error' });
+  }
+}
