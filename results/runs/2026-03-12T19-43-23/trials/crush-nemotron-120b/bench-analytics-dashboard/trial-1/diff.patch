+import { Router, Application } from 'express';
+import { register, login, getProfile, updateRole } from '../controllers/user.controller';
+import { 
+  ingestEvent, 
+  ingestEvents, 
+  queryEvents, 
+  countEventsHandler, 
+  getTimeseriesHandler, 
+  getBreakdownHandler 
+} from '../controllers/event.controller';
+import {
+  createDashboardHandler,
+  getDashboardHandler,
+  getDashboardsHandler,
+  updateDashboardHandler,
+  deleteDashboardHandler,
+  createWidgetHandler,
+  getWidgetsHandler,
+  updateWidgetHandler,
+  deleteWidgetHandler
+} from '../controllers/dashboard.controller';
+import { authenticateToken } from '../utils/jwt.utils';
+
+export function initializeRoutes(app: Application) {
+  const router = Router();
+
+  // Auth routes (public)
+  router.post('/auth/register', register);
+  router.post('/auth/login', login);
+
+  // Protected routes (require authentication)
+  router.use(authenticateToken);
+
+  // User routes
+  router.get('/users/profile', getProfile);
+  router.put('/users/role', updateRole);
+
+  // Event routes
+  router.post('/events', ingestEvent);
+  router.post('/events/batch', ingestEvents);
+  router.get('/events', queryEvents);
+  router.get('/events/count', countEventsHandler);
+  router.get('/events/timeseries', getTimeseriesHandler);
+  router.get('/events/breakdown', getBreakdownHandler);
+
+  // Dashboard routes
+  router.post('/dashboards', createDashboardHandler);
+  router.get('/dashboards', getDashboardsHandler);
+  router.get('/dashboards/:id', getDashboardHandler);
+  router.put('/dashboards/:id', updateDashboardHandler);
+  router.delete('/dashboards/:id', deleteDashboardHandler);
