+import { v4 as uuidv4 } from 'uuid';
+import { getDb } from '../database';
+
+const db = getDb();
+
+export interface Event {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: Record<string, unknown>;
+  timestamp?: string;
+  user_id?: string;
+  session_id?: string;
+}
+
+/**
+ * Create a single event
+ */
+export function createEvent(event: Omit<Event, 'id'>): Event {
+  const id = uuidv4();
+  const now = new Date().toISOString();
+  
+  db.prepare(`
+    INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id)
+    VALUES (?, ?, ?, ?, ?, ?, ?)
+  `).run(
+    id,
+    event.tenant_id,
+    event.name,
+    JSON.stringify(event.properties),
+    event.timestamp || now,
+    event.user_id,
+    event.session_id
+  );
+
+  return { id, ...event, timestamp: event.timestamp || now };
+}
+
+/**
+ * Create multiple events in a batch
+ */
+export function createEvents(events: Omit<Event, 'id'>[]): Event[] {
+  const now = new Date().toISOString();
+  const stmt = db.prepare(`
+    INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id)
+    VALUES (?, ?, ?, ?, ?, ?, ?)
+  `);
+
+  return events.map(event => {
+    const id = uuidv4();
+    stmt.run(
+      id,
+      event.tenant_id,
+      event.name,
+      JSON.stringify(event.properties),
+      event.timestamp || now,
+      event.user_id,
+      event.session_id
+    );
+    return { id, ...event, timestamp: event.timestamp || now };
+  });
+}
+
+/**
+ * Get events for a tenant with optional filtering
+ */
+export function getEvents(
+  tenantId: string,
+  options: {
+    name?: string;
+    startTime?: string;
+    endTime?: string;
+    limit?: number;
+    offset?: number;
+  } = {}
+): Event[] {
+  let query = 'SELECT * FROM events WHERE tenant_id = ?';
+  const params: (string | number)[] = [tenantId];
+
+  if (options.name) {
+    query += ' AND name = ?';
+    params.push(options.name);
+  }
+  if (options.startTime) {
+    query += ' AND timestamp >= ?';
+    params.push(options.startTime);
+  }
+  if (options.endTime) {
+    query += ' AND timestamp <= ?';
+    params.push(options.endTime);
+  }
+
+  query += ' ORDER BY timestamp DESC';
+
+  if (options.limit !== undefined) {
+    query += ' LIMIT ?';
+    params.push(options.limit);
+  }
+  if (options.offset !== undefined) {
+    query += ' OFFSET ?';
+    params.push(options.offset);
+  }
+
+  const stmt = db.prepare(query);
+  const rowsAll = stmt.all(params) as {
+    id: string;
+    tenant_id: string;
+    name: string;
+    properties: string;
+    timestamp: string;
+    user_id?: string;
+    session_id?: string;
+  }[];
+  
+  return rowsAll.map(row => ({
+    ...row,
+    properties: typeof row.properties === 'string' ? JSON.parse(row.properties) : row.properties
+  }));
+}
+
+/**
+ * Count events for a tenant with optional filtering
+ */
+export function countEvents(
+  tenantId: string,
+  options: {
+    name?: string;
+    startTime?: string;
+    endTime?: string;
+  } = {}
+): number {
+  let query = 'SELECT COUNT(*) as count FROM events WHERE tenant_id = ?';
+  const params: (string | number)[] = [tenantId];
+
+  if (options.name) {
+    query += ' AND name = ?';
+    params.push(options.name);
+  }
+  if (options.startTime) {
+    query += ' AND timestamp >= ?';
+    params.push(options.startTime);
+  }
+  if (options.endTime) {
+    query += ' AND timestamp <= ?';
+    params.push(options.endTime);
+  }
+
+  const row = db.prepare(query).get(params);
+  return row ? (row as { count: number }).count : 0;
+}
+
+/**
+ * Get timeseries data for events
+ */
+export function getTimeseries(
+  tenantId: string,
+  options: {
+    name?: string;
+    startTime?: string;
+    endTime?: string;
+    interval: 'hour' | 'day' | 'week' | 'month';
+  }
+): { timestamp: string; count: number }[] {
+  // We'll use SQLite's date/time functions to bucket by interval
+  let formatStr = '';
+  switch (options.interval) {
+    case 'hour':
+      formatStr = '%Y-%m-%d %H:00:00';
+      break;
+    case 'day':
+      formatStr = '%Y-%m-%d 00:00:00';
+      break;
+    case 'week':
+      formatStr = '%Y-%W 00:00:00'; // Note: SQLite's %W is week of year (0-53) starting on Monday
+      break;
+    case 'month':
+      formatStr = '%Y-%m-01 00:00:00';
+      break;
+  }
+
+  let query = `
+    SELECT 
+      strftime('${formatStr}', timestamp) as bucket,
+      COUNT(*) as count
+    FROM events 
+    WHERE tenant_id = ?
+  `;
+  const params: (string | number)[] = [tenantId];
+
+  if (options.name) {
+    query += ' AND name = ?';
+    params.push(options.name);
+  }
+  if (options.startTime) {
+    query += ' AND timestamp >= ?';
+    params.push(options.startTime);
+  }
+  if (options.endTime) {
+    query += ' AND timestamp <= ?';
+    params.push(options.endTime);
+  }
+
+  query += ' GROUP BY bucket ORDER BY bucket';
+
+  const rows = db.prepare(query).all(params) as { bucket: string; count: number }[];
+  return rows.map(row => ({
+    timestamp: row.bucket,
+    count: row.count
+  }));
+}
+
+/**
+ * Get breakdown of events by a property
+ */
+export function getBreakdown(
+  tenantId: string,
+  options: {
+    name?: string;
+    startTime?: string;
+    endTime?: string;
+    property: string;
+    limit?: number;
+  }
+): { key: string; count: number }[] {
+  // Note: properties are stored as JSON string. We need to extract the property.
+  // SQLite's JSON1 extension is required. We assume it's available (better-sqlite3 includes it).
+  let query = `
+    SELECT 
+      json_extract(properties, '$.${options.property}') as key,
+      COUNT(*) as count
+    FROM events 
+    WHERE tenant_id = ?
+  `;
+  const params: (string | number)[] = [tenantId];
+
+  if (options.name) {
+    query += ' AND name = ?';
+    params.push(options.name);
+  }
+  if (options.startTime) {
+    query += ' AND timestamp >= ?';
+    params.push(options.startTime);
+  }
+  if (options.endTime) {
+    query += ' AND timestamp <= ?';
+    params.push(options.endTime);
+  }
+
+  query += ` GROUP BY key ORDER BY count DESC`;
+
+  if (options.limit !== undefined) {
+    query += ' LIMIT ?';
+    params.push(options.limit);
+  }
+
+  const rows = db.prepare(query).all(params) as { key: string | null; count: number }[];
+  // Filter out null keys (if property doesn't exist)
+  return rows
+    .filter(row => row.key !== null)
+    .map(row => ({ key: row.key as string, count: row.count }));
+}
