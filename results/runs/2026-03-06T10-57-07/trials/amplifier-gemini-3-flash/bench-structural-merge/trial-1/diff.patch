+      // Change on main
+      store.update('doc1', { base: true, common: 'value', mainChange: true });
+      
+      // Change on feature
+      store.switchBranch('feature');
+      store.update('doc1', { base: true, common: 'value', featureChange: true });
+      
+      // Merge feature into main
+      store.switchBranch('main');
