new file mode 100644
index 0000000..8a4d758
--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,338 @@
+export interface Version {
+  id: string;
+  timestamp: number;
+  content: object;
+}
+
+export interface Conflict {
+  documentId: string;
+  path: string;
+  base: unknown;
+  ours: unknown;
+  theirs: unknown;
+}
+
+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+export interface DocumentStore {
+  create(id: string, content: object): void;
+  get(id: string): object;
+  update(id: string, content: object): void;
+  delete(id: string): void;
+  getHistory(id: string): Version[];
+  getVersion(id: string, versionId: string): object;
+  createBranch(name: string, fromBranch?: string): void;
+  switchBranch(name: string): void;
+  getBranch(): string;
+  listBranches(): string[];
+  merge(sourceBranch: string): MergeResult;
+}
+
+class Commit {
+  id: string;
+  parentId: string | null;
+  // docId -> versionId
+  documents: Map<string, string>;
+
+  constructor(parentId: string | null, documents: Map<string, string>) {
+    this.id = Math.random().toString(36).substring(2, 15);
+    this.parentId = parentId;
+    this.documents = new Map(documents);
+  }
+}
+
+export class DocumentStoreImpl implements DocumentStore {
+  private versions = new Map<string, Version>();
+  private branches = new Map<string, string>(); // branchName -> commitId
+  private commits = new Map<string, Commit>();
+  private currentBranchName = 'main';
+
+  constructor() {
+    const initialCommit = new Commit(null, new Map());
+    this.commits.set(initialCommit.id, initialCommit);
+    this.branches.set('main', initialCommit.id);
+  }
+
+  private deepClone<T>(obj: T): T {
+    return JSON.parse(JSON.stringify(obj));
+  }
+
+  private getHead(): Commit {
+    const commitId = this.branches.get(this.currentBranchName);
+    if (!commitId) throw new Error(`Branch ${this.currentBranchName} not found`);
+    return this.commits.get(commitId)!;
+  }
+
+  private createVersion(content: object): string {
+    const id = Math.random().toString(36).substring(2, 15);
+    this.versions.set(id, {
+      id,
+      timestamp: Date.now(),
+      content: this.deepClone(content),
+    });
+    return id;
+  }
+
+  create(id: string, content: object): void {
+    const head = this.getHead();
+    if (head.documents.has(id)) {
+      throw new Error(`Document ${id} already exists`);
+    }
+    const versionId = this.createVersion(content);
+    const nextDocs = new Map(head.documents);
+    nextDocs.set(id, versionId);
+    const nextCommit = new Commit(head.id, nextDocs);
+    this.commits.set(nextCommit.id, nextCommit);
+    this.branches.set(this.currentBranchName, nextCommit.id);
+  }
+
+  get(id: string): object {
+    const head = this.getHead();
+    const versionId = head.documents.get(id);
+    if (!versionId) throw new Error(`Document ${id} not found`);
+    const version = this.versions.get(versionId);
+    if (!version) throw new Error(`Version ${versionId} not found`);
+    return this.deepClone(version.content);
+  }
+
+  update(id: string, content: object): void {
+    const head = this.getHead();
+    if (!head.documents.has(id)) {
+      throw new Error(`Document ${id} not found`);
+    }
+    const versionId = this.createVersion(content);
+    const nextDocs = new Map(head.documents);
+    nextDocs.set(id, versionId);
+    const nextCommit = new Commit(head.id, nextDocs);
+    this.commits.set(nextCommit.id, nextCommit);
+    this.branches.set(this.currentBranchName, nextCommit.id);
+  }
+
+  delete(id: string): void {
+    const head = this.getHead();
+    if (!head.documents.has(id)) {
+      throw new Error(`Document ${id} not found`);
+    }
+    const nextDocs = new Map(head.documents);
+    nextDocs.delete(id);
+    const nextCommit = new Commit(head.id, nextDocs);
+    this.commits.set(nextCommit.id, nextCommit);
+    this.branches.set(this.currentBranchName, nextCommit.id);
+  }
+
+  getHistory(id: string): Version[] {
+    const history: Version[] = [];
+    let currentCommitId: string | null = this.branches.get(this.currentBranchName) || null;
+    const seenVersions = new Set<string>();
+
+    while (currentCommitId) {
+      const commit = this.commits.get(currentCommitId)!;
+      const versionId = commit.documents.get(id);
+      if (versionId && !seenVersions.has(versionId)) {
+        const version = this.versions.get(versionId)!;
+        history.unshift(version);
+        seenVersions.add(versionId);
+      }
+      currentCommitId = commit.parentId;
+    }
+    return history.map(v => ({ ...v, content: this.deepClone(v.content) }));
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const version = this.versions.get(versionId);
+    if (!version) throw new Error(`Version ${versionId} not found`);
+    return this.deepClone(version.content);
+  }
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch ${name} already exists`);
+    }
+    const sourceBranch = fromBranch || this.currentBranchName;
+    const commitId = this.branches.get(sourceBranch);
+    if (!commitId) throw new Error(`Source branch ${sourceBranch} not found`);
+    this.branches.set(name, commitId);
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch ${name} not found`);
+    }
+    this.currentBranchName = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranchName;
+  }
+
+  listBranches(): string[] {
+    return Array.from(this.branches.keys());
+  }
+
+  merge(sourceBranch: string): MergeResult {
+    const sourceCommitId = this.branches.get(sourceBranch);
+    if (!sourceCommitId) throw new Error(`Source branch ${sourceBranch} not found`);
+    const targetCommitId = this.branches.get(this.currentBranchName)!;
+
+    if (sourceCommitId === targetCommitId) {
+      return { merged: {}, conflicts: [], applied: true };
+    }
+
+    const ancestorCommitId = this.findCommonAncestor(sourceCommitId, targetCommitId);
+    if (!ancestorCommitId) {
+      throw new Error('No common ancestor found');
+    }
+
+    const ancestor = this.commits.get(ancestorCommitId)!;
+    const source = this.commits.get(sourceCommitId)!;
+    const target = this.commits.get(targetCommitId)!;
+
+    const allDocIds = new Set([
+      ...ancestor.documents.keys(),
+      ...source.documents.keys(),
+      ...target.documents.keys(),
+    ]);
+
+    const merged: Record<string, object> = {};
+    const conflicts: Conflict[] = [];
+    const nextDocs = new Map(target.documents);
+
+    for (const docId of allDocIds) {
+      const baseVerId = ancestor.documents.get(docId);
+      const oursVerId = target.documents.get(docId);
+      const theirsVerId = source.documents.get(docId);
+
+      if (oursVerId === theirsVerId) continue;
+
+      const base = baseVerId ? this.versions.get(baseVerId)!.content : undefined;
+      const ours = oursVerId ? this.versions.get(oursVerId)!.content : undefined;
+      const theirs = theirsVerId ? this.versions.get(theirsVerId)!.content : undefined;
+
+      // Simple case: one side changed/deleted, other didn't
+      if (oursVerId === baseVerId) {
+        if (theirsVerId === undefined) {
+          nextDocs.delete(docId);
+        } else {
+          nextDocs.set(docId, theirsVerId);
+          merged[docId] = theirs as object;
+        }
+        continue;
+      }
+      if (theirsVerId === baseVerId) {
+        continue;
+      }
+
+      // Both changed
+      if (ours === undefined || theirs === undefined) {
+        // One deleted, other modified or both deleted but different versions
+        conflicts.push({
+          documentId: docId,
+          path: '',
+          base,
+          ours,
+          theirs,
+        });
+        const mergedVal = ours || theirs;
+        if (mergedVal) {
+          merged[docId] = mergedVal as object;
+        }
+        continue;
+      }
+
+      // Both exist and are different from base and each other
+      const docMerge = this.mergeObjects(docId, '', base || {}, ours, theirs);
+      conflicts.push(...docMerge.conflicts);
+      merged[docId] = docMerge.merged;
+      
+      if (docMerge.conflicts.length === 0) {
+        const newVerId = this.createVersion(docMerge.merged);
+        nextDocs.set(docId, newVerId);
+      }
+    }
+
+    const applied = conflicts.length === 0;
+    if (applied) {
+      const nextCommit = new Commit(targetCommitId, nextDocs);
+      this.commits.set(nextCommit.id, nextCommit);
+      this.branches.set(this.currentBranchName, nextCommit.id);
+    }
+
+    return { merged, conflicts, applied };
+  }
+
+  private findCommonAncestor(id1: string, id2: string): string | null {
+    const path1 = new Set<string>();
+    let curr: string | null = id1;
+    while (curr) {
+      path1.add(curr);
+      curr = this.commits.get(curr)!.parentId;
+    }
+
+    curr = id2;
+    while (curr) {
+      if (path1.has(curr)) return curr;
+      curr = this.commits.get(curr)!.parentId;
+    }
+    return null;
+  }
+
+  private mergeObjects(docId: string, path: string, base: unknown, ours: unknown, theirs: unknown): { merged: object, conflicts: Conflict[] } {
+    if (typeof ours !== 'object' || ours === null || typeof theirs !== 'object' || theirs === null) {
+      if (JSON.stringify(ours) === JSON.stringify(theirs)) {
+        return { merged: ours as object, conflicts: [] };
+      }
+      return {
+        merged: ours as object,
+        conflicts: [{ documentId: docId, path, base, ours, theirs }]
+      };
+    }
+
+    const allKeys = new Set([
+      ...Object.keys(base as object || {}),
+      ...Object.keys(ours as object),
+      ...Object.keys(theirs as object)
+    ]);
+    const merged: Record<string, unknown> = {};
+    const conflicts: Conflict[] = [];
+
+    for (const key of allKeys) {
+      const b = (base as Record<string, unknown>)?.[key];
+      const o = (ours as Record<string, unknown>)?.[key];
+      const t = (theirs as Record<string, unknown>)?.[key];
+      const currentPath = path ? `${path}.${key}` : key;
+
+      if (JSON.stringify(o) === JSON.stringify(t)) {
+        if (o !== undefined) merged[key] = o;
+        continue;
+      }
+      if (JSON.stringify(o) === JSON.stringify(b)) {
+        if (t !== undefined) merged[key] = t;
+        continue;
+      }
+      if (JSON.stringify(t) === JSON.stringify(b)) {
+        if (o !== undefined) merged[key] = o;
+        continue;
+      }
+
+      // Both changed
+      if (typeof o === 'object' && o !== null && typeof t === 'object' && t !== null) {
+        const subMerge = this.mergeObjects(docId, currentPath, b || {}, o, t);
+        merged[key] = subMerge.merged;
+        conflicts.push(...subMerge.conflicts);
+      } else {
+        conflicts.push({ documentId: docId, path: currentPath, base: b, ours: o, theirs: t });
+        merged[key] = o;
+      }
+    }
+
+    return { merged: merged as object, conflicts };
+  }
+}
+
+export function createDocumentStore(): DocumentStore {
+  return new DocumentStoreImpl();
+}
