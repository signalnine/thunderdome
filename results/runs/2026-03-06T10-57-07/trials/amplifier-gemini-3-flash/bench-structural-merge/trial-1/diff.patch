+import { describe, it, expect, beforeEach } from 'vitest';
+import { createDocumentStore } from '../src/index';
+
+describe('DocumentStore', () => {
+  let store: any;
+
+  beforeEach(() => {
+    store = createDocumentStore();
+  });
+
+  describe('Basic CRUD', () => {
+    it('should create and get a document', () => {
+      store.create('doc1', { a: 1 });
+      expect(store.get('doc1')).toEqual({ a: 1 });
+    });
+
+    it('should throw when creating a duplicate ID', () => {
+      store.create('doc1', { a: 1 });
+      expect(() => store.create('doc1', { b: 2 })).toThrow();
+    });
+
+    it('should update a document', () => {
+      store.create('doc1', { a: 1 });
+      store.update('doc1', { a: 2 });
+      expect(store.get('doc1')).toEqual({ a: 2 });
+    });
+
+    it('should delete a document', () => {
+      store.create('doc1', { a: 1 });
+      store.delete('doc1');
+      expect(() => store.get('doc1')).toThrow();
+    });
+
+    it('should deep clone on storage and retrieval', () => {
+      const content = { a: { b: 1 } };
+      store.create('doc1', content);
+      content.a.b = 2;
+      expect(store.get('doc1')).toEqual({ a: { b: 1 } });
+
+      const retrieved = store.get('doc1');
+      retrieved.a.b = 3;
+      expect(store.get('doc1')).toEqual({ a: { b: 1 } });
+    });
+  });
+
+  describe('Version History', () => {
+    it('should track version history', () => {
+      store.create('doc1', { v: 1 });
+      store.update('doc1', { v: 2 });
+      store.update('doc1', { v: 3 });
+
+      const history = store.getHistory('doc1');
+      expect(history).toHaveLength(3);
+      expect(history[0].content).toEqual({ v: 1 });
+      expect(history[1].content).toEqual({ v: 2 });
+      expect(history[2].content).toEqual({ v: 3 });
+    });
+
+    it('should get a specific version', () => {
+      store.create('doc1', { v: 1 });
+      const v1Id = store.getHistory('doc1')[0].id;
+      store.update('doc1', { v: 2 });
+      
+      expect(store.getVersion('doc1', v1Id)).toEqual({ v: 1 });
+    });
+  });
+
+  describe('Branching', () => {
