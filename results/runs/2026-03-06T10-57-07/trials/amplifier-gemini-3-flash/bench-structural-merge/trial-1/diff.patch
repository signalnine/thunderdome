+      store.create('doc1', { main: true });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      
+      store.update('doc1', { feature: true });
+      store.create('doc2', { new: true });
+
+      expect(store.get('doc1')).toEqual({ feature: true });
+      expect(store.get('doc2')).toEqual({ new: true });
+
+      store.switchBranch('main');
+      expect(store.get('doc1')).toEqual({ main: true });
+      expect(() => store.get('doc2')).toThrow();
+    });
+
+    it('should branch from a specific branch', () => {
+      store.create('doc1', { v: 1 });
+      store.createBranch('b1');
+      store.switchBranch('b1');
+      store.update('doc1', { v: 2 });
+
+      store.createBranch('b2', 'main');
+      store.switchBranch('b2');
+      expect(store.get('doc1')).toEqual({ v: 1 });
+    });
+  });
+
