+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01172LFur9xQJymg23nZrdzh","type":"tool_result","content":"     1→export type EventHandler = (data: unknown) => void | Promise<void>;\n     2→\n     3→export class EventBus {\n     4→  private handlers: Map<string, EventHandler[]> = new Map();\n     5→\n     6→  on(event: string, handler: EventHandler): void {\n     7→    const existing = this.handlers.get(event) ?? [];\n     8→    existing.push(handler);\n     9→    this.handlers.set(event, existing);\n    10→  }\n    11→\n    12→  off(event: string, handler: EventHandler): void {\n    13→    const existing = this.handlers.get(event);\n    14→    if (!existing) return;\n    15→    this.handlers.set(\n    16→      event,\n    17→      existing.filter((h) => h !== handler)\n    18→    );\n    19→  }\n    20→\n    21→  async emit(event: string, data: unknown): Promise<void> {\n    22→    const handlers = this.handlers.get(event) ?? [];\n    23→    for (const handler of handlers) {\n    24→      await handler(data);\n    25→    }\n    26→  }\n    27→\n    28→  clear(): void {\n    29→    this.handlers.clear();\n    30→  }\n    31→}\n    32→"}]},"parent_tool_use_id":"toolu_012GRMDjjZ3otF3nNG2pvbFD","session_id":"521eca6f-3726-4f18-85a3-333e4a3a5d84","uuid":"f6068df8-e2b5-4481-99fc-443dee3f21d9"}
