e event\n    44→    // The order service attaches items to the cancellation event\n    45→    const eventWithItems = data as OrderCancelledEvent & {\n    46→      items?: Array<{ productId: string; quantity: number }>;\n    47→    };\n    48→\n    49→    if (eventWithItems.items) {\n    50→      for (const item of eventWithItems.items) {\n    51→        this.repo.release(item.productId, item.quantity);\n    52→      }\n    53→    }\n    54→\n    55→    await this.eventBus.emit(ORDER_EVENTS.STOCK_RELEASED, {\n    56→      orderId: event.orderId,\n    57→      timestamp: Date.now(),\n    58→    });\n    59→  }\n    60→\n    61→  setStock(productId: string, quantity: number): void {\n    62→    this.repo.setStock(productId, quantity);\n    63→  }\n    64→\n    65→  getStock(productId: string) {\n    66→    return this.repo.getStock(productId);\n    67→  }\n    68→}\n    69→"}]},"parent_tool_use_id":null,"session_id":"521eca6f-3726-4f18-85a3-333e4a3a5d84","uuid":"762d100d-1160-47f1-9e17-5bb63bc56b37","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/inventory/service.ts","content":"import { EventBus } from '../events/bus.js';\nimport { ORDER_EVENTS, OrderCreatedEvent, OrderCancelledEvent } from '../events/types.js';\nimport { InventoryRepository } from './repository.js';\n\nexport class InventoryService {\n  constructor(\n    private repo: InventoryRepository,\n    private eventBus: EventBus\n  ) {}\n\n  registerHandlers(): void {\n    this.eventBus.on(ORDER_EVENTS.CREATED, this.handleOrderCreated.bind(this));\n    this.eventBus.on(ORDER_EVENTS.CANCELLED, this.handleOrderCancelled.bind(this));\n  }\n\n  private async handleOrderCreated(data: unknown): Promise<void> {\n    const event = data as OrderCreatedEvent;\n    const reservations: Array<{ productId: string; quantity: number }> = [];\n\n    for (const item of event.items) {\n      const success = this.repo.reserve(item.productId, item.quantity);\n      if (!success) {\n        // Rollback previous