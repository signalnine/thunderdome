mail\", async () => {\n      await registerUser(\"dup@example.com\", \"t1\");\n      const res = await request(app)\n        .post(\"/auth/register\")\n        .send({ email: \"dup@example.com\", password: \"pass123\", tenant_id: \"t1\" });\n      expect(res.status).toBe(409);\n    });\n\n    it(\"should login\", async () => {\n      await registerUser(\"login@example.com\", \"t1\");\n      const res = await request(app)\n        .post(\"/auth/login\")\n        .send({ email: \"login@example.com\", password: \"password123\" });\n      expect(res.status).toBe(200);\n      expect(res.body.token).toBeDefined();\n    });\n\n    it(\"should reject bad credentials\", async () => {\n      const res = await request(app)\n        .post(\"/auth/login\")\n        .send({ email: \"nobody@example.com\", password: \"wrong\" });\n      expect(res.status).toBe(401);\n    });\n\n    it(\"should get user profile\", async () => {\n      const user = await registerUser(\"me@example.com\", \"t1\");\n      const res = await request(app)\n        .get(\"/auth/me\")\n        .set(\"Authorization\", `Bearer ${user.token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.email).toBe(\"me@example.com\");\n    });\n\n    it(\"should reject unauthenticated /me\", async () => {\n      const res = await request(app).get(\"/auth/me\");\n      expect(res.status).toBe(401);\n    });\n\n    it(\"should allow admin to change user role\", async () => {\n      const admin = await registerUser(\"admin@t1.com\", \"t1\", \"admin\");\n      const viewer = await registerUser(\"viewer@t1.com\", \"t1\", \"viewer\");\n      const res = await request(app)\n        .put(`/auth/users/${viewer.id}/role`)\n        .set(\"Authorization\", `Bearer ${admin.token}`)\n        .send({ role: \"editor\" });\n      expect(res.status).toBe(200);\n      expect(res.body.role).toBe(\"editor\");\n    });\n\n    it(\"should prevent non-admin from changing roles\", async () => {\n      const viewer1 = await registerUse