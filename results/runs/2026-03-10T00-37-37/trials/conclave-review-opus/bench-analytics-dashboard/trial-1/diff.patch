+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012JgEdPTBxQEBHpkt7b7rdS","type":"tool_result","content":"     1→import { Response, Router } from \"express\";\n     2→import type Database from \"better-sqlite3\";\n     3→import { authenticate, AuthRequest } from \"./auth.js\";\n     4→\n     5→interface EventRow {\n     6→  id: string;\n     7→  tenant_id: string;\n     8→  name: string;\n     9→  properties: string;\n    10→  timestamp: string;\n    11→  user_id: string | null;\n    12→  session_id: string | null;\n    13→}\n    14→\n    15→interface DashboardRow {\n    16→  id: string;\n    17→  tenant_id: string;\n    18→  name: string;\n    19→  owner_id: string;\n    20→  config: string;\n    21→  created_at: string;\n    22→  updated_at: string;\n    23→}\n    24→\n    25→function escapeCsvField(value: string): string {\n    26→  if (value.includes(\",\") || value.includes('\"') || value.includes(\"\\n\")) {\n    27→    return `\"${value.replace(/\"/g, '\"\"')}\"`;\n    28→  }\n    29→  return value;\n    30→}\n    31→\n    32→function eventsToCsv(events: EventRow[]): string {\n    33→  const headers = [\"id\", \"tenant_id\", \"name\", \"properties\", \"timestamp\", \"user_id\", \"session_id\"];\n    34→  const lines = [headers.join(\",\")];\n    35→\n    36→  for (const event of events) {\n    37→    const row = headers.map((h) => {\n    38→      const val = event[h as keyof EventRow];\n    39→      return escapeCsvField(String(val ?? \"\"));\n    40→    });\n    41→    lines.push(row.join(\",\"));\n    42→  }\n    43→\n    44→  return lines.join(\"\\n\");\n    45→}\n    46→\n    47→function dashboardsToCsv(dashboards: DashboardRow[]): string {\n    48→  const headers = [\"id\", \"tenant_id\", \"name\", \"owner_id\", \"config\", \"created_at\", \"updated_at\"];\n    49→  const lines = [headers.join(\",\")];\n    50→\n    51→  for (const dash of dashboards) {\n    52→    const row = headers.map((h) => {\n    53→      const val = dash[h as keyof DashboardRow];\n    54→      return escapeCsvField(String(val ?? \"\"));\n    55→    });\n    56→    lines.push(row.join(\",\"));\n    57→  }\n    58→\n    59→  return lines.join(\"\\n\");\n    60→}\n    61→\n    62→export function createExportRouter(db: Database.Database): Router {\n    63→  const router = Router();\n    64→\n    65→  router.use(authenticate);\n    66→\n    67→  // Export events as JSON\n    68→  router.get(\"/events/json\", (req: AuthRequest, res: Response) => {\n    69→    const tenant_id = req.user!.tenant_id;\n    70→\n    71→    let sql = \"SELECT * FROM events WHERE tenant_id = ?\";\n    72→    const params: unknown[] = [tenant_id];\n    73→\n    74→    if (req.query.event_name) {\n    75→      sql += \" AND name = ?\";\n    76→      params.push(req.query.event_name);\n    77→    }\n    78→\n    79→    if (req.query.start_date) {\n    80→      sql += \" AND timestamp >= ?\";\n    81→      params.push(req.query.start_date);\n    82→    }\n    83→\n    84→    if (req.query.end_date) {\n    85→      sql += \" AND timestamp <= ?\";\n    86→      params.push(req.query.end_date);\n    87→    }\n    88→\n    89→    sql += \" ORDER BY timestamp DESC\";\n    90→\n    91→    const events = db.prepare(sql).all(...params) as EventRow[];\n    92→\n    93→    const parsed = events.map((e) => ({\n    94→      ...e,\n    95→      properties: JSON.parse(e.properties),\n    96→    }));\n    97→\n    98→    res.setHeader(\"Content-Type\", \"application/json\");\n    99→    res.setHeader(\"Content-Disposition\", \"attachment; filename=events.json\");\n   100→    res.json({ events: parsed });\n   101→  });\n   102→\n   103→  // Export events as CSV\n   104→  router.get(\"/events/csv\", (req: AuthRequest, res: Response) => {\n   105→    const tenant_id = req.user!.tenant_id;\n   106→\n   107→    let sql = \"SELECT * FROM events WHERE tenant_id = ?\";\n   108→    const params: unknown[] = [tenant_id];\n   109→\n   110→    if (req.query.event_name) {\n   111→      sql += \" AND name = ?\";\n   112→      params.push(req.query.event_name);\n   113→    }\n   114→\n   115→    if (req.query.start_date) {\n   116→      sql += \" AND timestamp >= ?\";\n   117→      params.push(req.query.start_date);\n   118→    }\n   119→\n   120→    if (req.query.end_date) {\n   121→      sql += \" AND timestamp <= ?\";\n   122→      params.push(req.query.end_date);\n   123→    }\n   124→\n   125→    sql += \" ORDER BY timestamp DESC\";\n   126→\n   127→    const events = db.prepare(sql).all(...params) as EventRow[];\n   128→\n   129→    res.setHeader(\"Content-Type\", \"text/csv\");\n   130→    res.setHeader(\"Content-Disposition\", \"attachment; filename=events.csv\");\n   131→    res.send(eventsToCsv(events));\n   132→  });\n   133→\n   134→  // Export dashboards as JSON\n   135→  router.get(\"/dashboards/json\", (req: AuthRequest, res: Response) => {\n   136→    const tenant_id = req.user!.tenant_id;\n   137→\n   138→    const dashboards = db\n   139→      .prepare(\"SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC\")\n   140→      .all(tenant_id) as DashboardRow[];\n   141→\n   142→    const parsed = dashboards.map((d) => ({\n   143→      ...d,\n   144→      config: JSON.parse(d.config),\n   145→    }));\n   146→\n   147→    res.setHeader(\"Content-Type\", \"application/json\");\n   148→    res.setHeader(\"Content-Disposition\", \"attachment; filename=dashboards.json\");\n   149→    res.json({ dashboards: parsed });\n   150→  });\n   151→\n   152→  // Export dashboards as CSV\n   153→  router.get(\"/dashboards/csv\", (req: AuthRequest, res: Response) => {\n   154→    const tenant_id = req.user!.tenant_id;\n   155→\n   156→    const dashboards = db\n   157→      .prepare(\"SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC\")\n   158→      .all(tenant_id) as DashboardRow[];\n   159→\n   160→    res.setHeader(\"Content-Type\", \"text/csv\");\n   161→    res.setHeader(\"Content-Disposition\", \"attachment; filename=dashboards.csv\");\n   162→    res.send(dashboardsToCsv(dashboards));\n   163→  });\n   164→\n   165→  return router;\n   166→}\n   167→"}]},"parent_tool_use_id":"toolu_01PUVMTsUbEKcpUv5AWMs2Aq","session_id":"677d5b3d-c8fe-44c2-8ac4-7d510609b2a9","uuid":"78daa269-5026-4902-8e45-501ea5d581fa"}
