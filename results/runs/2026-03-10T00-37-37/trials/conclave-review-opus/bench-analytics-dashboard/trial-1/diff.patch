+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DwCWmxD6TtPTmvPXZRqfzh","type":"tool_result","content":"     1→import { Request, Response, NextFunction, Router } from \"express\";\n     2→import jwt from \"jsonwebtoken\";\n     3→import crypto from \"crypto\";\n     4→import { v4 as uuidv4 } from \"uuid\";\n     5→import type Database from \"better-sqlite3\";\n     6→\n     7→const JWT_SECRET = process.env.JWT_SECRET || \"analytics-dashboard-secret\";\n     8→\n     9→export interface AuthUser {\n    10→  id: string;\n    11→  email: string;\n    12→  tenant_id: string;\n    13→  role: string;\n    14→}\n    15→\n    16→export interface AuthRequest extends Request {\n    17→  user?: AuthUser;\n    18→}\n    19→\n    20→function hashPassword(password: string): string {\n    21→  return crypto.createHash(\"sha256\").update(password).digest(\"hex\");\n    22→}\n    23→\n    24→export function authenticate(\n    25→  req: AuthRequest,\n    26→  res: Response,\n    27→  next: NextFunction\n    28→): void {\n    29→  const header = req.headers.authorization;\n    30→  if (!header || !header.startsWith(\"Bearer \")) {\n    31→    res.status(401).json({ error: \"Authentication required\" });\n    32→    return;\n    33→  }\n    34→\n    35→  const token = header.slice(7);\n    36→  try {\n    37→    const payload = jwt.verify(token, JWT_SECRET) as AuthUser;\n    38→    req.user = payload;\n    39→    next();\n    40→  } catch {\n    41→    res.status(401).json({ error: \"Invalid token\" });\n    42→  }\n    43→}\n    44→\n    45→export function createAuthRouter(db: Database.Database): Router {\n    46→  const router = Router();\n    47→\n    48→  router.post(\"/register\", (req: Request, res: Response) => {\n    49→    const { email, password, tenant_id, role } = req.body;\n    50→\n    51→    if (!email || !password || !tenant_id) {\n    52→      res.status(400).json({ error: \"email, password, and tenant_id are required\" });\n    53→      return;\n    54→    }\n    55→\n    56→    const validRoles = [\"admin\", \"editor\", \"viewer\"];\n    57→    const userRole = role && validRoles.includes(role) ? role : \"viewer\";\n    58→\n    59→    const id = uuidv4();\n    60→    const password_hash = hashPassword(password);\n    61→\n    62→    try {\n    63→      db.prepare(\n    64→        \"INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)\"\n    65→      ).run(id, email, password_hash, tenant_id, userRole);\n    66→\n    67→      const token = jwt.sign(\n    68→        { id, email, tenant_id, role: userRole },\n    69→        JWT_SECRET,\n    70→        { expiresIn: \"24h\" }\n    71→      );\n    72→\n    73→      res.status(201).json({ id, email, tenant_id, role: userRole, token });\n    74→    } catch (err: unknown) {\n    75→      const message = err instanceof Error ? err.message : \"Unknown error\";\n    76→      if (message.includes(\"UNIQUE constraint\")) {\n    77→        res.status(409).json({ error: \"Email already exists\" });\n    78→      } else {\n    79→        res.status(500).json({ error: message });\n    80→      }\n    81→    }\n    82→  });\n    83→\n    84→  router.post(\"/login\", (req: Request, res: Response) => {\n    85→    const { email, password } = req.body;\n    86→\n    87→    if (!email || !password) {\n    88→      res.status(400).json({ error: \"email and password are required\" });\n    89→      return;\n    90→    }\n    91→\n    92→    const password_hash = hashPassword(password);\n    93→    const user = db\n    94→      .prepare(\"SELECT id, email, tenant_id, role FROM users WHERE email = ? AND password_hash = ?\")\n    95→      .get(email, password_hash) as AuthUser | undefined;\n    96→\n    97→    if (!user) {\n    98→      res.status(401).json({ error: \"Invalid credentials\" });\n    99→      return;\n   100→    }\n   101→\n   102→    const token = jwt.sign(\n   103→      { id: user.id, email: user.email, tenant_id: user.tenant_id, role: user.role },\n   104→      JWT_SECRET,\n   105→      { expiresIn: \"24h\" }\n   106→    );\n   107→\n   108→    res.json({ token, user });\n   109→  });\n   110→\n   111→  router.get(\"/me\", authenticate, (req: AuthRequest, res: Response) => {\n   112→    const user = db\n   113→      .prepare(\"SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?\")\n   114→      .get(req.user!.id);\n   115→\n   116→    if (!user) {\n   117→      res.status(404).json({ error: \"User not found\" });\n   118→      return;\n   119→    }\n   120→\n   121→    res.json(user);\n   122→  });\n   123→\n   124→  router.put(\"/users/:userId/role\", authenticate, (req: AuthRequest, res: Response) => {\n   125→    if (req.user!.role !== \"admin\") {\n   126→      res.status(403).json({ error: \"Admin access required\" });\n   127→      return;\n   128→    }\n   129→\n   130→    const { role } = req.body;\n   131→    const { userId } = req.params;\n   132→\n   133→    const validRoles = [\"admin\", \"editor\", \"viewer\"];\n   134→    if (!role || !validRoles.includes(role)) {\n   135→      res.status(400).json({ error: \"Valid role required (admin, editor, viewer)\" });\n   136→      return;\n   137→    }\n   138→\n   139→    const targetUser = db\n   140→      .prepare(\"SELECT id, tenant_id FROM users WHERE id = ?\")\n   141→      .get(userId) as { id: string; tenant_id: string } | undefined;\n   142→\n   143→    if (!targetUser) {\n   144→      res.status(404).json({ error: \"User not found\" });\n   145→      return;\n   146→    }\n   147→\n   148→    if (targetUser.tenant_id !== req.user!.tenant_id) {\n   149→      res.status(403).json({ error: \"Cannot modify users outside your tenant\" });\n   150→      return;\n   151→    }\n   152→\n   153→    db.prepare(\"UPDATE users SET role = ? WHERE id = ?\").run(role, userId);\n   154→\n   155→    res.json({ id: userId, role });\n   156→  });\n   157→\n   158→  return router;\n   159→}\n   160→"}]},"parent_tool_use_id":"