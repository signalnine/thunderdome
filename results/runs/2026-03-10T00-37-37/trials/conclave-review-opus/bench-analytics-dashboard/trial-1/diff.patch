01-02T11:00:00Z\" },\n          ],\n        });\n    });\n\n    it(\"should count events\", async () => {\n      const res = await request(app)\n        .post(\"/query/count\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ event_name: \"page_view\" });\n      expect(res.status).toBe(200);\n      expect(res.body.count).toBe(3);\n    });\n\n    it(\"should count all events\", async () => {\n      const res = await request(app)\n        .post(\"/query/count\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({});\n      expect(res.body.count).toBe(4);\n    });\n\n    it(\"should count events with date filter\", async () => {\n      const res = await request(app)\n        .post(\"/query/count\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ event_name: \"page_view\", start_date: \"2024-01-02T00:00:00Z\" });\n      expect(res.body.count).toBe(1);\n    });\n\n    it(\"should return timeseries\", async () => {\n      const res = await request(app)\n        .post(\"/query/timeseries\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ event_name: \"page_view\", interval: \"day\" });\n      expect(res.status).toBe(200);\n      expect(res.body.timeseries.length).toBe(2);\n    });\n\n    it(\"should return breakdown\", async () => {\n      const res = await request(app)\n        .post(\"/query/breakdown\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ event_name: \"page_view\", property: \"url\" });\n      expect(res.status).toBe(200);\n      expect(res.body.breakdown.length).toBe(2);\n      expect(res.body.breakdown[0].count).toBe(2); // /home appears twice\n    });\n\n    it(\"should require property for breakdown\", async () => {\n      const res = await request(app)\n        .post(\"/query/breakdown\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ event_name: \"page_view\" });\n      expect(res.status).toBe(400);\n    });\n\n    it(\"should enforce tenant isolation in queries\", async () => {\n      const user2 = await registerUser(\"q2@t2.com\", \"t2\");\n      const res = await request(app)\n        .post(\"/query/count\")\n        .set(\"Authorization\", `Bearer ${user2.token}`)\n        .send({});\n      expect(res.body.count).toBe(0);\n    });\n  });\n\n  describe(\"Dashboards\", () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const user = await registerUser(\"dash@t1.com\", \"t1\");\n      token = user.token;\n    });\n\n    it(\"should create a dashboard\", async () => {\n      const res = await request(app)\n        .post(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"My Dashboard\", config: { layout: \"grid\" } });\n      expect(res.status).toBe(201);\n      expect(res.body.name).toBe(\"My Dashboard\");\n      expect(res.body.id).toBeDefined();\n    });\n\n    it(\"should list dashboards\", async () => {\n      await request(app)\n        .post(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"Dashboard 1\" });\n\n      const res = await request(app)\n        .get(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.dashboards.length).toBe(1);\n    });\n\n    it(\"should get a single dashboard\", async () => {\n      const created = await request(app)\n        .post(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"Test Dash\" });\n\n      const res = await request(app)\n        .get(`/dashboards/${created.body.id}`)\n        .set(\"Authorization\", `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe(\"Test Dash\");\n      expect(res.body.widgets).toBeDefined();\n    });\n\n    it(\"should update a dashboard\", async () => {\n      const created = await request(app)\n        .post(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"Old Name\" });\n\n      const res = await request(app)\n        .put(`/dashboards/${created.body.id}`)\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"New Name\" });\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe(\"New Name\");\n    });\n\n    it(\"should delete a dashboard\", async () => {\n      const created = await request(app)\n        .post(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"To Delete\" });\n\n      const res = await request(app)\n        .delete(`/dashboards/${created.body.id}`)\n        .set(\"Authorization\", `Bearer ${token}`);\n      expect(res.status).toBe(204);\n\n      const getRes = await request(app)\n        .get(`/dashboards/${created.body.id}`)\n        .set(\"Authorization\", `Bearer ${token}`);\n      expect(getRes.status).toBe(404);\n    });\n\n    it(\"should enforce tenant isolation for dashboards\", async () => {\n      const created = await request(app)\n        .post(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"T1 Dashboard\" });\n\n      const user2 = await registerUser(\"dash@t2.com\", \"t2\");\n      const res = await request(app)\n        .get(`/dashboards/${created.body.id}`)\n        .set(\"Authorization\", `Bearer ${user2.token}`);\n      expect(res.status).toBe(404);\n    });\n\n    it(\"should add widgets to a dashboard\", async () => {\n      const created = await request(app)\n        .post(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"Widget Dash\" });\n\n      const res = await request(app)\n        .post(`/dashboards/${created.body.id}/widgets`)\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ type: \"counter\", config: { event_name: \"page_view\" } });\n      expect(res.status).toBe(201);\n      expect(res.body.type).toBe(\"counter\");\n    });\n  });\n\n  describe(\"Export\", () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const user = await registerUser(\"exp@t1.com\", \"t1\");\n      token = user.token;\n      await request(app)\n        .post(\"/events/batch\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({\n          events: [\n            { name: \"page_view\", properties: { url: \"/home\" } },\n            { name: \"click\", properties: { element: \"btn\" } },\n          ],\n        });\n      await request(app)\n        .post(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"Export Dash\" });\n    });\n\n    it(\"should export events as JSON\", async () => {\n      const res = await request(app)\n        .get(\"/export/events/json\")\n        .set(\"Authorization\", `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.events.length).toBe(2);\n    });\n\n    it(\"should export events as CSV\", async () => {\n      const res = await request(app)\n        .get(\"/export/events/csv\")\n        .set(\"Authorization\", `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n      expect(res.text).toContain(\"id,tenant_id,name\");\n    });\n\n    it(\"should export dashboards as JSON\", async () => {\n      const res = await request(app)\n        .get(\"/export/dashboards/json\")\n        .set(\"Authorization\", `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.dashboards.length).toBe(1);\n    });\n\n    it(\"should export dashboards as CSV\", async () => {\n      const res = await request(app)\n        .get(\"/export/dashboards/csv\")\n        .set(\"Authorization\", `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n    });\n\n    it(\"should enforce tenant isolation on exports\", async () => {\n      const user2 = await registerUser(\"exp@t2.com\", \"t2\");\n      const res = await request(app)\n        .get(\"/export/events/json\")\n        .set(\"Authorization\", `Bearer ${user2.token}`);\n      expect(res.body.events.length).toBe(0);\n    });\n\n    it(\"should require auth for exports\", async () => {\n      const res = await request(app).get(\"/export/events/json\");\n      expect(res.status).toBe(401);\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
