+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012Q6kcYSbor4k9JXvQezKYJ","type":"tool_result","content":"     1→import { Response, Router } from \"express\";\n     2→import { v4 as uuidv4 } from \"uuid\";\n     3→import type Database from \"better-sqlite3\";\n     4→import { authenticate, AuthRequest } from \"./auth.js\";\n     5→\n     6→export function createDashboardsRouter(db: Database.Database): Router {\n     7→  const router = Router();\n     8→\n     9→  router.use(authenticate);\n    10→\n    11→  // Create dashboard\n    12→  router.post(\"/\", (req: AuthRequest, res: Response) => {\n    13→    const { name, config } = req.body;\n    14→\n    15→    if (!name) {\n    16→      res.status(400).json({ error: \"Dashboard name is required\" });\n    17→      return;\n    18→    }\n    19→\n    20→    const id = uuidv4();\n    21→    const tenant_id = req.user!.tenant_id;\n    22→    const owner_id = req.user!.id;\n    23→    const dashConfig = JSON.stringify(config || {});\n    24→    const now = new Date().toISOString();\n    25→\n    26→    db.prepare(\n    27→      \"INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)\"\n    28→    ).run(id, tenant_id, name, owner_id, dashConfig, now, now);\n    29→\n    30→    res.status(201).json({ id, name, tenant_id, owner_id, config: config || {}, created_at: now, updated_at: now });\n    31→  });\n    32→\n    33→  // List dashboards for tenant\n    34→  router.get(\"/\", (req: AuthRequest, res: Response) => {\n    35→    const tenant_id = req.user!.tenant_id;\n    36→\n    37→    const rows = db\n    38→      .prepare(\"SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC\")\n    39→      .all(tenant_id);\n    40→\n    41→    const dashboards = rows.map((r) => {\n    42→      const row = r as Record<string, unknown>;\n    43→      return {\n    44→        ...row,\n    45→        config: typeof row.config === \"string\" ? JSON.parse(row.config) : row.config,\n    46→      };\n    47→    });\n    48→\n    49→    res.json({ dashboards });\n    50→  });\n    51→\n    52→  // Get single dashboard\n    53→  router.get(\"/:id\", (req: AuthRequest, res: Response) => {\n    54→    const tenant_id = req.user!.tenant_id;\n    55→\n    56→    const dashboard = db\n    57→      .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n    58→      .get(req.params.id, tenant_id) as Record<string, unknown> | undefined;\n    59→\n    60→    if (!dashboard) {\n    61→      res.status(404).json({ error: \"Dashboard not found\" });\n    62→      return;\n    63→    }\n    64→\n    65→    const widgets = db\n    66→      .prepare(\"SELECT * FROM widgets WHERE dashboard_id = ?\")\n    67→      .all(req.params.id);\n    68→\n    69→    res.json({\n    70→      ...dashboard,\n    71→      config: typeof dashboard.config === \"string\" ? JSON.parse(dashboard.config as string) : dashboard.config,\n    72→      widgets: widgets.map((wd) => {\n    73→        const w = wd as Record<string, unknown>;\n    74→        return {\n    75→          ...w,\n    76→          config: typeof w.config === \"string\" ? JSON.parse(w.config) : w.config,\n    77→        };\n    78→      }),\n    79→    });\n    80→  });\n    81→\n    82→  // Update dashboard\n    83→  router.put(\"/:id\", (req: AuthRequest, res: Response) => {\n    84→    const tenant_id = req.user!.tenant_id;\n    85→    const { name, config } = req.body;\n    86→\n    87→    const existing = db\n    88→      .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n    89→      .get(req.params.id, tenant_id) as Record<string, unknown> | undefined;\n    90→\n    91→    if (!existing) {\n    92→      res.status(404).json({ error: \"Dashboard not found\" });\n    93→      return;\n    94→    }\n    95→\n    96→    const updatedName = name || existing.name;\n    97→    const updatedConfig = config !== undefined ? JSON.stringify(config) : existing.config;\n    98→    const now = new Date().toISOString();\n    99→\n   100→    db.prepare(\"UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?\").run(\n   101→      updatedName,\n   102→      updatedConfig,\n   103→      now,\n   104→      req.params.id\n   105→    );\n   106→\n   107→    res.json({\n   108→      id: req.params.id,\n   109→      name: updatedName,\n   110→      config: config !== undefined ? config : (typeof existing.config === \"string\" ? JSON.parse(existing.config as string) : existing.config),\n   111→      updated_at: now,\n   112→    });\n   113→  });\n   114→\n   115→  // Delete dashboard\n   116→  router.delete(\"/:id\", (req: AuthRequest, res: Response) => {\n   117→    const tenant_id = req.user!.tenant_id;\n   118→\n   119→    const existing = db\n   120→      .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n   121→      .get(req.params.id, tenant_id);\n   122→\n   123→    if (!existing) {\n   124→      res.status(404).json({ error: \"Dashboard not found\" });\n   125→      return;\n   126→    }\n   127→\n   128→    db.prepare(\"DELETE FROM dashboards WHERE id = ?\").run(req.params.id);\n   129→\n   130→    res.status(204).send();\n   131→  });\n   132→\n   133→  // Widget CRUD for a dashboard\n   134→  router.post(\"/:id/widgets\", (req: AuthRequest, res: Response) => {\n   135→    const tenant_id = req.user!.tenant_id;\n   136→\n   137→    const dashboard = db\n   138→      .prepare(\"SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?\")\n   139→      .get(req.params.id, tenant_id);\n   140→\n   141→    if (!dashboard) {\n   142→      res.status(404).json({ error: \"Dashboard not found\" });\n   143→      return;\n   144→    }\n   145→\n   146→    const { type, config, position_x, position_y, width, height } = req.body;\n   147→\n   148→    if (!type) {\n   149→      res.status(400).json({ error: \"Widget type is required\" });\n   150→      return;\n   151→    }\n   152→\n   153→    const id = uuidv4();\n   154→    const widgetConfig = JSON.stringify(config || {});\n   155→\n   156→    db.prepare(\n   157→      \"INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)\"\n   158→    ).run(id, req.params.id, type, widgetConfig, position_x || 0, position_y || 0, width || 1, height || 1);\n   159→\n   160→    res.status(201).json({\n   161→      id,\n   162→      dashboard_id: req.params.id,\n   163→      type,\n   164→      config: config || {},\n   165→      position_x: position_x || 0,\n   166→      position_y: position_y || 0,\n   167→      width: width || 1,\n   168→      height: height || 1,\n   169→    });\n   170→  });\n   171→\n   172→  return router;\n   173→}\n   174→"}]},"parent_tool_use_id":"toolu_01PUVMTsUbEKcpUv5AWMs2Aq","session_id":"677d5b3d-c8fe-44c2-8ac4-7d510609b2a9","uuid":"b5ade71e-62e3-4ad0-8883-b5804741fac6"}
