gets`)\n   360→        .set(\"Authorization\", `Bearer ${token}`)\n   361→        .send({ type: \"counter\", config: { event_name: \"page_view\" } });\n   362→      expect(res.status).toBe(201);\n   363→      expect(res.body.type).toBe(\"counter\");\n   364→    });\n   365→  });\n   366→\n   367→  describe(\"Export\", () => {\n   368→    let token: string;\n   369→\n   370→    beforeEach(async () => {\n   371→      const user = await registerUser(\"exp@t1.com\", \"t1\");\n   372→      token = user.token;\n   373→      await request(app)\n   374→        .post(\"/events/batch\")\n   375→        .set(\"Authorization\", `Bearer ${token}`)\n   376→        .send({\n   377→          events: [\n   378→            { name: \"page_view\", properties: { url: \"/home\" } },\n   379→            { name: \"click\", properties: { element: \"btn\" } },\n   380→          ],\n   381→        });\n   382→      await request(app)\n   383→        .post(\"/dashboards\")\n   384→        .set(\"Authorization\", `Bearer ${token}`)\n   385→        .send({ name: \"Export Dash\" });\n   386→    });\n   387→\n   388→    it(\"should export events as JSON\", async () => {\n   389→      const res = await request(app)\n   390→        .get(\"/export/events/json\")\n   391→        .set(\"Authorization\", `Bearer ${token}`);\n   392→      expect(res.status).toBe(200);\n   393→      expect(res.body.events.length).toBe(2);\n   394→    });\n   395→\n   396→    it(\"should export events as CSV\", async () => {\n   397→      const res = await request(app)\n   398→        .get(\"/export/events/csv\")\n   399→        .set(\"Authorization\", `Bearer ${token}`);\n   400→      expect(res.status).toBe(200);\n   401→      expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n   402→      expect(res.text).toContain(\"id,tenant_id,name\");\n   403→    });\n   404→\n   405→    it(\"should export dashboards as JSON\", async () => {\n   406→      const res = await request(app)\n   407→        .get(\"/export/das