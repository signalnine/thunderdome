+import { Response, Router } from "express";
+import type Database from "better-sqlite3";
+import { authenticate, AuthRequest } from "./auth.js";
+
+export function createQueryRouter(db: Database.Database): Router {
+  const router = Router();
+
+  router.use(authenticate);
+
+  // Count query
+  router.post("/count", (req: AuthRequest, res: Response) => {
+    const tenant_id = req.user!.tenant_id;
+    const { event_name, start_date, end_date, filters } = req.body;
+
+    let sql = "SELECT COUNT(*) as count FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [tenant_id];
+
+    if (event_name) {
+      sql += " AND name = ?";
+      params.push(event_name);
+    }
+
+    if (start_date) {
+      sql += " AND timestamp >= ?";
+      params.push(start_date);
+    }
+
+    if (end_date) {
+      sql += " AND timestamp <= ?";
+      params.push(end_date);
+    }
+
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value);
+      }
+    }
+
+    const result = db.prepare(sql).get(...params) as { count: number };
+    res.json({ count: result.count });
+  });
+
+  // Timeseries query
+  router.post("/timeseries", (req: AuthRequest, res: Response) => {
+    const tenant_id = req.user!.tenant_id;
+    const { event_name, start_date, end_date, interval, filters } = req.body;
+
+    const FORMAT_MAP: Record<string, string> = {
+      hour: "%Y-%m-%dT%H:00:00",
+      day: "%Y-%m-%d",
+      month: "%Y-%m-01",
+    };
+    const bucket = interval || "day";
+    const dateFormat = FORMAT_MAP[bucket as string] ?? FORMAT_MAP["day"];
+
+    // dateFormat is guaranteed to be one of the hardcoded format strings above
+    let sql = `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: unknown[] = [tenant_id];
+
+    if (event_name) {
+      sql += " AND name = ?";
+      params.push(event_name);
+    }
+
+    if (start_date) {
+      sql += " AND timestamp >= ?";
+      params.push(start_date);
+    }
+
+    if (end_date) {
+      sql += " AND timestamp <= ?";
+      params.push(end_date);
+    }
+
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value);
+      }
+    }
+
+    sql += " GROUP BY bucket ORDER BY bucket ASC";
+
+    const rows = db.prepare(sql).all(...params);
+    res.json({ timeseries: rows, interval: bucket });
+  });
+
+  // Breakdown query
+  router.post("/breakdown", (req: AuthRequest, res: Response) => {
+    const tenant_id = req.user!.tenant_id;
+    const { event_name, property, start_date, end_date, filters } = req.body;
+
+    if (!property) {
+      res.status(400).json({ error: "property is required for breakdown queries" });
+      return;
+    }
+
+    let sql = `SELECT json_extract(properties, ?) as value, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: unknown[] = [`$.${property}`, tenant_id];
+
+    if (event_name) {
+      sql += " AND name = ?";
+      params.push(event_name);
+    }
+
+    if (start_date) {
+      sql += " AND timestamp >= ?";
+      params.push(start_date);
+    }
+
+    if (end_date) {
+      sql += " AND timestamp <= ?";
+      params.push(end_date);
+    }
+
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value);
+      }
+    }
+
+    sql += " GROUP BY value ORDER BY count DESC";
+
+    const rows = db.prepare(sql).all(...params);
+    res.json({ breakdown: rows, property });
+  });
+
+  return router;
+}
