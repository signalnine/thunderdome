+import { Response, Router } from "express";
+import { v4 as uuidv4 } from "uuid";
+import type Database from "better-sqlite3";
+import { authenticate, AuthRequest } from "./auth.js";
+
+export function createEventsRouter(db: Database.Database): Router {
+  const router = Router();
+
+  router.use(authenticate);
+
+  // Ingest a single event
+  router.post("/", (req: AuthRequest, res: Response) => {
+    const { name, properties, timestamp, session_id } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: "Event name is required" });
+      return;
+    }
+
+    const id = uuidv4();
+    const tenant_id = req.user!.tenant_id;
+    const user_id = req.user!.id;
+    const eventTimestamp = timestamp || new Date().toISOString();
+    const eventProperties = JSON.stringify(properties || {});
+
+    db.prepare(
+      "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    ).run(id, tenant_id, name, eventProperties, eventTimestamp, user_id, session_id || null);
+
+    res.status(201).json({ id, name, tenant_id, timestamp: eventTimestamp });
+  });
+
+  // Batch ingest events
+  router.post("/batch", (req: AuthRequest, res: Response) => {
+    const { events } = req.body;
+
+    if (!Array.isArray(events) || events.length === 0) {
+      res.status(400).json({ error: "events array is required" });
+      return;
+    }
+
+    const tenant_id = req.user!.tenant_id;
+    const user_id = req.user!.id;
+
+    const insert = db.prepare(
+      "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    );
+
+    const insertMany = db.transaction((evts: typeof events) => {
+      const results: Array<{ id: string; name: string }> = [];
+      for (const evt of evts) {
+        if (!evt.name) continue;
+        const id = uuidv4();
+        const eventTimestamp = evt.timestamp || new Date().toISOString();
+        const eventProperties = JSON.stringify(evt.properties || {});
+        insert.run(id, tenant_id, evt.name, eventProperties, eventTimestamp, user_id, evt.session_id || null);
+        results.push({ id, name: evt.name });
+      }
+      return results;
+    });
+
+    const results = insertMany(events);
+    res.status(201).json({ inserted: results.length, events: results });
+  });
+
+  // List events for tenant
+  router.get("/", (req: AuthRequest, res: Response) => {
+    const tenant_id = req.user!.tenant_id;
+    const limit = Math.min(parseInt(req.query.limit as string) || 100, 1000);
+    const offset = parseInt(req.query.offset as string) || 0;
+
+    const rows = db
+      .prepare("SELECT * FROM events WHERE tenant_id = ? ORDER BY timestamp DESC LIMIT ? OFFSET ?")
+      .all(tenant_id, limit, offset);
+
+    const events = rows.map((r) => {
+      const row = r as Record<string, unknown>;
+      return {
+        ...row,
+        properties: typeof row.properties === "string" ? JSON.parse(row.properties as string) : row.properties,
+      };
+    });
+
+    res.json({ events, limit, offset });
+  });
+
+  return router;
+}
