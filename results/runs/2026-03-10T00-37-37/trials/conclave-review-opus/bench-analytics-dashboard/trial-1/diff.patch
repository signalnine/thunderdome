+import { Response, Router } from "express";
+import { v4 as uuidv4 } from "uuid";
+import type Database from "better-sqlite3";
+import { authenticate, AuthRequest } from "./auth.js";
+
+export function createDashboardsRouter(db: Database.Database): Router {
+  const router = Router();
+
+  router.use(authenticate);
+
+  // Create dashboard
+  router.post("/", (req: AuthRequest, res: Response) => {
+    const { name, config } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: "Dashboard name is required" });
+      return;
+    }
+
+    const id = uuidv4();
+    const tenant_id = req.user!.tenant_id;
+    const owner_id = req.user!.id;
+    const dashConfig = JSON.stringify(config || {});
+    const now = new Date().toISOString();
+
+    db.prepare(
+      "INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    ).run(id, tenant_id, name, owner_id, dashConfig, now, now);
+
+    res.status(201).json({ id, name, tenant_id, owner_id, config: config || {}, created_at: now, updated_at: now });
+  });
+
+  // List dashboards for tenant
+  router.get("/", (req: AuthRequest, res: Response) => {
+    const tenant_id = req.user!.tenant_id;
+
+    const rows = db
+      .prepare("SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC")
+      .all(tenant_id);
+
+    const dashboards = rows.map((r) => {
+      const row = r as Record<string, unknown>;
+      return {
+        ...row,
+        config: typeof row.config === "string" ? JSON.parse(row.config) : row.config,
+      };
+    });
+
+    res.json({ dashboards });
+  });
+
+  // Get single dashboard
+  router.get("/:id", (req: AuthRequest, res: Response) => {
+    const tenant_id = req.user!.tenant_id;
+
+    const dashboard = db
+      .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(req.params.id, tenant_id) as Record<string, unknown> | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const widgets = db
+      .prepare("SELECT * FROM widgets WHERE dashboard_id = ?")
+      .all(req.params.id);
+
+    res.json({
+      ...dashboard,
+      config: typeof dashboard.config === "string" ? JSON.parse(dashboard.config as string) : dashboard.config,
+      widgets: widgets.map((wd) => {
+        const w = wd as Record<string, unknown>;
+        return {
+          ...w,
+          config: typeof w.config === "string" ? JSON.parse(w.config) : w.config,
+        };
+      }),
+    });
+  });
+
+  // Update dashboard
+  router.put("/:id", (req: AuthRequest, res: Response) => {
+    const tenant_id = req.user!.tenant_id;
+    const { name, config } = req.body;
+
+    const existing = db
+      .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(req.params.id, tenant_id) as Record<string, unknown> | undefined;
+
+    if (!existing) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const updatedName = name || existing.name;
+    const updatedConfig = config !== undefined ? JSON.stringify(config) : existing.config;
+    const now = new Date().toISOString();
+
+    db.prepare("UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?").run(
+      updatedName,
+      updatedConfig,
+      now,
+      req.params.id
+    );
+
+    res.json({
+      id: req.params.id,
+      name: updatedName,
+      config: config !== undefined ? config : (typeof existing.config === "string" ? JSON.parse(existing.config as string) : existing.config),
+      updated_at: now,
+    });
+  });
+
+  // Delete dashboard
+  router.delete("/:id", (req: AuthRequest, res: Response) => {
+    const tenant_id = req.user!.tenant_id;
+
+    const existing = db
+      .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(req.params.id, tenant_id);
+
+    if (!existing) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    db.prepare("DELETE FROM dashboards WHERE id = ?").run(req.params.id);
+
+    res.status(204).send();
+  });
+
+  // Widget CRUD for a dashboard
+  router.post("/:id/widgets", (req: AuthRequest, res: Response) => {
+    const tenant_id = req.user!.tenant_id;
+
+    const dashboard = db
+      .prepare("SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(req.params.id, tenant_id);
+
+    if (!dashboard) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const { type, config, position_x, position_y, width, height } = req.body;
+
+    if (!type) {
+      res.status(400).json({ error: "Widget type is required" });
+      return;
+    }
+
+    const id = uuidv4();
+    const widgetConfig = JSON.stringify(config || {});
+
+    db.prepare(
+      "INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)"
+    ).run(id, req.params.id, type, widgetConfig, position_x || 0, position_y || 0, width || 1, height || 1);
+
+    res.status(201).json({
+      id,
+      dashboard_id: req.params.id,
+      type,
+      config: config || {},
+      position_x: position_x || 0,
+      position_y: position_y || 0,
+      width: width || 1,
+      height: height || 1,
+    });
+  });
+
+  // Delete widget
+  router.delete("/:id/widgets/:widgetId", (req: AuthRequest, res: Response) => {
+    const tenant_id = req.user!.tenant_id;
+
+    const dashboard = db
+      .prepare("SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(req.params.id, tenant_id);
+
+    if (!dashboard) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const result = db
+      .prepare("DELETE FROM widgets WHERE id = ? AND dashboard_id = ?")
+      .run(req.params.widgetId, req.params.id);
+
+    if (result.changes === 0) {
+      res.status(404).json({ error: "Widget not found" });
+      return;
+    }
+
+    res.status(204).send();
+  });
+
+  return router;
+}
