@@ -0,0 +1,166 @@
+import { Response, Router } from "express";
+import type Database from "better-sqlite3";
+import { authenticate, AuthRequest } from "./auth.js";
+
+interface EventRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string | null;
+  session_id: string | null;
+}
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+function escapeCsvField(value: string): string {
+  if (value.includes(",") || value.includes('"') || value.includes("\n")) {
+    return `"${value.replace(/"/g, '""')}"`;
+  }
+  return value;
+}
+
+function eventsToCsv(events: EventRow[]): string {
+  const headers = ["id", "tenant_id", "name", "properties", "timestamp", "user_id", "session_id"];
+  const lines = [headers.join(",")];
+
+  for (const event of events) {
+    const row = headers.map((h) => {
+      const val = event[h as keyof EventRow];
+      return escapeCsvField(String(val ?? ""));
+    });
+    lines.push(row.join(","));
+  }
+
+  return lines.join("\n");
+}
+
+function dashboardsToCsv(dashboards: DashboardRow[]): string {
+  const headers = ["id", "tenant_id", "name", "owner_id", "config", "created_at", "updated_at"];
+  const lines = [headers.join(",")];
+
+  for (const dash of dashboards) {
+    const row = headers.map((h) => {
+      const val = dash[h as keyof DashboardRow];
+      return escapeCsvField(String(val ?? ""));
+    });
+    lines.push(row.join(","));
+  }
+
+  return lines.join("\n");
+}
+
+export function createExportRouter(db: Database.Database): Router {
+  const router = Router();
+
+  router.use(authenticate);
+
+  // Export events as JSON
+  router.get("/events/json", (req: AuthRequest, res: Response) => {
+    const tenant_id = req.user!.tenant_id;
+
+    let sql = "SELECT * FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [tenant_id];
+
+    if (req.query.event_name) {
+      sql += " AND name = ?";
+      params.push(req.query.event_name);
+    }
+
+    if (req.query.start_date) {
+      sql += " AND timestamp >= ?";
+      params.push(req.query.start_date);
+    }
+
+    if (req.query.end_date) {
+      sql += " AND timestamp <= ?";
+      params.push(req.query.end_date);
+    }
+
+    sql += " ORDER BY timestamp DESC";
+
+    const events = db.prepare(sql).all(...params) as EventRow[];
+
+    const parsed = events.map((e) => ({
+      ...e,
+      properties: JSON.parse(e.properties),
+    }));
+
+    res.setHeader("Content-Type", "application/json");
+    res.setHeader("Content-Disposition", "attachment; filename=events.json");
+    res.json({ events: parsed });
+  });
+
+  // Export events as CSV
+  router.get("/events/csv", (req: AuthRequest, res: Response) => {
+    const tenant_id = req.user!.tenant_id;
+
+    let sql = "SELECT * FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [tenant_id];
+
+    if (req.query.event_name) {
+      sql += " AND name = ?";
+      params.push(req.query.event_name);
+    }
+
+    if (req.query.start_date) {
+      sql += " AND timestamp >= ?";
+      params.push(req.query.start_date);
+    }
+
+    if (req.query.end_date) {
+      sql += " AND timestamp <= ?";
+      params.push(req.query.end_date);
+    }
+
+    sql += " ORDER BY timestamp DESC";
+
+    const events = db.prepare(sql).all(...params) as EventRow[];
+
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader("Content-Disposition", "attachment; filename=events.csv");
+    res.send(eventsToCsv(events));
+  });
+
+  // Export dashboards as JSON
+  router.get("/dashboards/json", (req: AuthRequest, res: Response) => {
+    const tenant_id = req.user!.tenant_id;
+
+    const dashboards = db
+      .prepare("SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC")
+      .all(tenant_id) as DashboardRow[];
+
+    const parsed = dashboards.map((d) => ({
+      ...d,
+      config: JSON.parse(d.config),
+    }));
+
+    res.setHeader("Content-Type", "application/json");
+    res.setHeader("Content-Disposition", "attachment; filename=dashboards.json");
+    res.json({ dashboards: parsed });
+  });
+
+  // Export dashboards as CSV
+  router.get("/dashboards/csv", (req: AuthRequest, res: Response) => {
+    const tenant_id = req.user!.tenant_id;
+
+    const dashboards = db
+      .prepare("SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC")
+      .all(tenant_id) as DashboardRow[];
+
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader("Content-Disposition", "attachment; filename=dashboards.csv");
+    res.send(dashboardsToCsv(dashboards));
+  });
+
+  return router;
+}
