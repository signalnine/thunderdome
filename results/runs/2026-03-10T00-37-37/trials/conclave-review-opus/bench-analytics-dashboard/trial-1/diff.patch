+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01G9bLL1CZaqJZssZugEtCeE","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach } from \"vitest\";\n     2→import request from \"supertest\";\n     3→import { createApp } from \"./app.js\";\n     4→import type { Express } from \"express\";\n     5→\n     6→describe(\"Analytics Dashboard API\", () => {\n     7→  let app: Express;\n     8→\n     9→  beforeEach(() => {\n    10→    app = createApp(\":memory:\");\n    11→  });\n    12→\n    13→  // Helper to register and get token\n    14→  async function registerUser(email: string, tenant: string, role = \"admin\") {\n    15→    const res = await request(app)\n    16→      .post(\"/auth/register\")\n    17→      .send({ email, password: \"password123\", tenant_id: tenant, role });\n    18→    return res.body;\n    19→  }\n    20→\n    21→  describe(\"Health check\", () => {\n    22→    it(\"should return ok\", async () => {\n    23→      const res = await request(app).get(\"/health\");\n    24→      expect(res.status).toBe(200);\n    25→      expect(res.body.status).toBe(\"ok\");\n    26→    });\n    27→  });\n    28→\n    29→  describe(\"Auth\", () => {\n    30→    it(\"should register a user\", async () => {\n    31→      const res = await request(app)\n    32→        .post(\"/auth/register\")\n    33→        .send({ email: \"test@example.com\", password: \"pass123\", tenant_id: \"t1\" });\n    34→      expect(res.status).toBe(201);\n    35→      expect(res.body.token).toBeDefined();\n    36→      expect(res.body.email).toBe(\"test@example.com\");\n    37→      expect(res.body.tenant_id).toBe(\"t1\");\n    38→      expect(res.body.role).toBe(\"viewer\");\n    39→    });\n    40→\n    41→    it(\"should register a user with a specific role\", async () => {\n    42→      const res = await request(app)\n    43→        .post(\"/auth/register\")\n    44→        .send({ email: \"admin@example.com\", password: \"pass123\", tenant_id: \"t1\", role: \"admin\" });\n    45→      expect(res.status).toBe(201);\n    46→      expect(res.body.role).toBe(\"admin\");\n    47→    });\n    48→\n    49→    it(\"should reject duplicate email\", async () => {\n    50→      await registerUser(\"dup@example.com\", \"t1\");\n    51→      const res = await request(app)\n    52→        .post(\"/auth/register\")\n    53→        .send({ email: \"dup@example.com\", password: \"pass123\", tenant_id: \"t1\" });\n    54→      expect(res.status).toBe(409);\n    55→    });\n    56→\n    57→    it(\"should login\", async () => {\n    58→      await registerUser(\"login@example.com\", \"t1\");\n    59→      const res = await request(app)\n    60→        .post(\"/auth/login\")\n    61→        .send({ email: \"login@example.com\", password: \"password123\" });\n    62→      expect(res.status).toBe(200);\n    63→      expect(res.body.token).toBeDefined();\n    64→    });\n    65→\n    66→    it(\"should reject bad credentials\", async () => {\n    67→      const res = await request(app)\n    68→        .post(\"/auth/login\")\n    69→        .send({ email: \"nobody@example.com\", password: \"wrong\" });\n    70→      expect(res.status).toBe(401);\n    71→    });\n    72→\n    73→    it(\"should get user profile\", async () => {\n    74→      const user = await registerUser(\"me@example.com\", \"t1\");\n    75→      const res = await request(app)\n    76→        .get(\"/auth/me\")\n    77→        .set(\"Authorization\", `Bearer ${user.token}`);\n    78→      expect(res.status).toBe(200);\n    79→      expect(res.body.email).toBe(\"me@example.com\");\n    80→    });\n    81→\n    82→    it(\"should reject unauthenticated /me\", async () => {\n    83→      const res = await request(app).get(\"/auth/me\");\n    84→      expect(res.status).toBe(401);\n    85→    });\n    86→\n    87→    it(\"should allow admin to change user role\", async () => {\n    88→      const admin = await registerUser(\"admin@t1.com\", \"t1\", \"admin\");\n    89→      const viewer = await registerUser(\"viewer@t1.com\", \"t1\", \"viewer\");\n    90→      const res = await request(app)\n    91→        .put(`/auth/users/${viewer.id}/role`)\n    92→        .set(\"Authorization\", `Bearer ${admin.token}`)\n    93→        .send({ role: \"editor\" });\n    94→      expect(res.status).toBe(200);\n    95→      expect(res.body.role).toBe(\"editor\");\n    96→    });\n    97→\n    98→    it(\"should prevent non-admin from changing roles\", async () => {\n    99→      const viewer1 = await registerUser(\"v1@t1.com\", \"t1\", \"viewer\");\n   100→      const viewer2 = await registerUser(\"v2@t1.com\", \"t1\", \"viewer\");\n   101→      const res = await request(app)\n   102→        .put(`/auth/users/${viewer2.id}/role`)\n   103→        .set(\"Authorization\", `Bearer ${viewer1.token}`)\n   104→        .send({ role: \"editor\" });\n   105→      expect(res.status).toBe(403);\n   106→    });\n   107→\n   108→    it(\"should prevent admin from changing roles cross-tenant\", async () => {\n   109→      const admin1 = await registerUser(\"admin@t1.com\", \"t1\", \"admin\");\n   110→      const user2 = await registerUser(\"user@t2.com\", \"t2\", \"viewer\");\n   111→      const res = await request(app)\n   112→        .put(`/auth/users/${user2.id}/role`)\n   113→        .set(\"Authorization\", `Bearer ${admin1.token}`)\n   114→        .send({ role: \"editor\" });\n   115→      expect(res.status).toBe(403);\n   116→    });\n   117→  });\n   118→\n   119→  describe(\"Events\", () => {\n   120→    it(\"should require auth\", async () => {\n   121→      const res = await request(app).post(\"/events\").send({ name: \"pageview\" });\n   122→      expect(res.status).toBe(401);\n   123→    });\n   124→\n   125→    it(\"should ingest a single event\", async () => {\n   126→      const user = await registerUser(\"ev@t1.com\", \"t1\");\n   127→      const res = await request(app)\n   128→        .post(\"/events\")\n   129→        .set(\"Authorization\", `Bearer ${user.token}`)\n   130→        .send({ name: \"page_view\", properties: { url: \"/home\" } });\n   131→      expect(res.status).toBe(201);\n   132→      expect(res.body.id).toBeDefined();\n   133→      expect(res.body.name).toBe(\"page_view\");\n   134→    });\n   135→\n   136→    it(\"should ingest batch events\", async () => {\n   137→      const user = await registerUser(\"batch@t1.com\", \"t1\");\n   138→      const res = await request(app)\n   139→        .post(\"/events/batch\")\n   140→        .set(\"Authorization\", `Bearer ${user.token}`)\n   141→        .send({\n   142→          events: [\n   143→            { name: \"page_view\", properties: { url: \"/home\" } },\n   144→            { name: \"click\", properties: { element: \"button\" } },\n   145→            { name: \"page_view\", properties: { url: \"/about\" } },\n   146→          ],\n   147→        });\n   148→      expect(res.status).toBe(201);\n   149→      expect(res.body.inserted).toBe(3);\n   150→    });\n   151→\n   152→    it(\"should list events\", async () => {\n   153→      const user = await registerUser(\"list@t1.com\", \"t1\");\n   154→      await request(app)\n   155→        .post(\"/events\")\n   156→        .set(\"Authorization\", `Bearer ${user.token}`)\n   157→        .send({ name: \"test_event\" });\n   158→\n   159→      const res = await request(app)\n   160→        .get(\"/events\")\n   161→        .set(\"Authorization\", `Bearer ${user.token}`);\n   162→      expect(res.status).toBe(200);\n   163→      expect(res.body.events.length).toBe(1);\n   164→    });\n   165→\n   166→    it(\"should enforce tenant isolation on events\", async () => {\n   167→      const user1 = await registerUser(\"u1@t1.com\", \"t1\");\n   168→      const user2 = await registerUser(\"u2@t2.com\", \"t2\");\n   169→\n   170→      await request(app)\n   171→        .post(\"/events\")\n   172→        .set(\"Authorization\", `Bearer ${user1.token}`)\n   173→        .send({ name: \"t1_event\" });\n   174→\n   175→      const res = await request(app)\n   176→        .get(\"/events\")\n   177→        .set(\"Authorization\", `Bearer ${user2.token}`);\n   178→      expect(res.body.events.length).toBe(0);\n   179→    });\n   180→  });\n   181→\n   182→  describe(\"Query Engine\", () => {\n   183→    let token: string;\n   184→\n   185→    beforeEach(async () => {\n   186→      const user = await registerUser(\"q@t1.com\", \"t1\");\n   187→      token = user.token;\n   188→      await request(app)\n   189→        .post(\"/events/batch\")\n   190→        .set(\"Authorization\", `Bearer ${token}`)\n   191→        .send({\n   192→          events: [\n   193→            { name: \"page_view\", properties: { url: \"/home\" }, timestamp: \"2024-01-01T10:00:00Z\" },\n   194→            { name: \"page_view\", properties: { url: \"/about\" }, timestamp: \"2024-01-01T14:00:00Z\" },\n   195→            { name: \"page_view\", properties: { url: \"/home\" }, timestamp: \"2024-01-02T10:00:00Z\" },\n   196→            { name: \"click\", properties: { element: \"btn\" }, timestamp: \"2024-01-02T11:00:00Z\" },\n   197→          ],\n   198→        });\n   199→    });\n   200→\n   201→    it(\"should count events\", async () => {\n   202→      const res = await request(app)\n   203→        .post(\"/query/count\")\n   204→        .set(\"Authorization\", `Bearer ${token}`)\n   205→        .send({ event_name: \"page_view\" });\n   206→      expect(res.status).toBe(200);\n   207→      expect(res.body.count).toBe(3);\n   208→    });\n   209→\n   210→    it(\"should count all events\", async () => {\n   211→      const res = await request(app)\n   212→        .post(\"/query/count\")\n   213→        .set(\"Authorization\", `Bearer ${token}`)\n   214→        .send({});\n   215→      expect(res.body.count).toBe(4);\n   216→    });\n   217→\n   218→    it(\"should count events with date filter\", async () => {\n   219→      const res = await request(app)\n   220→        .post(\"/query/count\")\n   221→        .set(\"Authorization\", `Bearer ${token}`)\n   222→        .send({ event_name: \"page_view\", start_date: \"2024-01-02T00:00:00Z\" });\n   223→      expect(res.body.count).toBe(1);\n   224→    });\n   225→\n   226→    it(\"should return timeseries\", async () => {\n   227→      const res = await request(app)\n   228→        .post(\"/query/timeseries\")\n   229→        .set(\"Authorization\", `Bearer ${token}`)\n   230→        .send({ event_name: \"page_view\", interval: \"day\" });\n   231→      expect(res.status).toBe(200);\n   232→      expect(res.body.timeseries.length).toBe(2);\n   233→    });\n   234→\n   235→    it(\"should return breakdown\", async () => {\n   236→      const res = await request(app)\n   237→        .post(\"/query/breakdown\")\n   238→        .set(\"Authorization\", `Bearer ${token}`)\n   239→        .send({ event_name: \"page_view\", property: \"url\" });\n   240→      expect(res.status).toBe(200);\n   241→      expect(res.body.breakdown.length).toBe(2);\n   242→      expect(res.body.breakdown[0].count).toBe(2); // /home appears twice\n   243→    });\n   244→\n   245→    it(\"should require property for breakdown\", async () => {\n   246→      const res = await request(app)\n   247→        .post(\"/query/breakdown\")\n   248→        .set(\"Authorization\", `Bearer ${token}`)\n   249→        .send({ event_name: \"page_view\" });\n   250→      expect(res.status).toBe(400);\n   251→    });\n   252→\n   253→    it(\"should enforce tenant isolation in queries\", async () => {\n   254→      const user2 = await registerUser(\"q2@t2.com\", \"t2\");\n   255→      const res = await request(app)\n   256→        .post(\"/query/count\")\n   257→        .set(\"Authorization\", `Bearer ${user2.token}`)\n   258→        .send({});\n   259→      expect(res.body.count).toBe(0);\n   260→    });\n   261→  });\n   262→\n   263→  describe(\"Dashboards\", () => {\n   264→    let token: string;\n   265→\n   266→    beforeEach(async () => {