  46→        'npx madge --circular --extensions ts packages/',\n    47→        { cwd: ROOT_DIR, encoding: 'utf-8', timeout: 30000, stdio: ['pipe', 'pipe', 'pipe'] }\n    48→      );\n    49→    } catch (err) {\n    50→      const error = err as { stdout?: string; stderr?: string; status?: number };\n    51→      stdout = error.stdout || '';\n    52→      exitCode = error.status || 1;\n    53→    }\n    54→\n    55→    if (exitCode !== 0) {\n    56→      throw new Error(`Circular dependencies found:\\n${stdout}`);\n    57→    }\n    58→  });\n    59→\n    60→  it('has no merge conflict markers in any TypeScript file', () => {\n    61→    const tsFiles = getAllTsFiles(join(ROOT_DIR, 'packages'));\n    62→    const filesWithMarkers: string[] = [];\n    63→\n    64→    for (const file of tsFiles) {\n    65→      const content = readFileSync(file, 'utf-8');\n    66→      if (\n    67→        content.includes('<<<<<<<') ||\n    68→        content.includes('>>>>>>>') ||\n    69→        content.includes('=======\\n')\n    70→      ) {\n    71→        filesWithMarkers.push(file.replace(ROOT_DIR + '/', ''));\n    72→      }\n    73→    }\n    74→\n    75→    expect(filesWithMarkers).toEqual([]);\n    76→  });\n    77→\n    78→  it('has no .env files with secrets', () => {\n    79→    const allFiles = getAllFiles(ROOT_DIR);\n    80→    const envFiles = allFiles.filter((f) => {\n    81→      const name = f.split('/').pop() || '';\n    82→      return name === '.env' || name.match(/^\\.env\\./);\n    83→    });\n    84→\n    85→    const envFilesWithSecrets: string[] = [];\n    86→    for (const envFile of envFiles) {\n    87→      const content = readFileSync(envFile, 'utf-8');\n    88→      if (\n    89→        content.includes('PASSWORD') ||\n    90→        content.includes('SECRET') ||\n    91→        content.includes('TOKEN') ||\n    92→        content.includes('API_KEY')\n    93→      ) {\n    94→        envFilesWithSecrets.push(envFile.replace(ROOT_DIR + '/', ''));\n    95→      }\n    96→    }\n    97→\n    98→    expect(envFilesWithSecrets).toEqual([]);\n    99→  });\n   100→\n   101→  it('all packages build successfully', () => {\n   102→    try {\n   103→      execSync('npx tsc -b --force', {\n   104→        cwd: ROOT_DIR,\n   105→        encoding: 'utf-8',\n   106→        timeout: 60000,\n   107→      });\n   108→    } catch (err) {\n   109→      const error = err as { stdout?: string; stderr?: string };\n   110→      throw new Error(\n   111→        `Build failed:\\n${error.stdout || ''}${error.stderr || ''}`\n   112→      );\n   113→    }\n   114→  });\n   115→\n   116→  it('TypeScript strict mode is enabled in all packages', () => {\n   117→    const packages = ['core', 'api', 'worker'];\n   118→\n   119→    for (const pkg of packages) {\n   120→      const tsconfigPath = join(ROOT_DIR, 'packages', pkg, 'tsconfig.json');\n   121→      expect(existsSync(tsconfigPath), `${pkg}/tsconfig.json must exist`).toBe(\n   122→        true\n   123→      );\n   124→\n   125→      const tsconfig = JSON.parse(readFileSync(tsconfigPath, 'utf-8'));\n   126→      expect(\n   127→        tsconfig.compilerOptions?.strict,\n   128→        `${pkg} must have strict: true`\n   129→      ).toBe(true);\n   130→    }\n   131→  });\n   132→});\n   133→"}]},"parent_tool_use_id":"toolu_01FwS1gxoKVvZH8cvGj31YvD","session_id":"c38aba28-4281-4b29-a669-0c622193f7bb","uuid":"d40ebefa-f29f-403e-bdf7-c395f4282a05"}
