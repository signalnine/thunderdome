+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CvFC8yBLyGRqfssygGKvmu","type":"tool_result","content":"/**\n * Data sync job.\n * Syncs external user data into the local database.\n */\n\nimport {\n  createUser,\n  getUserById,\n  getAllUsers,\n  type CreateUserInput,\n} from '@monorepo/core';\n\ninterface ExternalUser {\n  name: string;\n  email: string;\n  role: 'admin' | 'user' | 'viewer';\n}\n\n// Simulated external data source\nfunction fetchExternalUsers(): ExternalUser[] {\n  return [\n    { name: 'External User 1', email: 'ext1@example.com', role: 'user' },\n    { name: 'External User 2', email: 'ext2@example.com', role: 'viewer' },\n  ];\n}\n\nexport async function syncJob(): Promise<void> {\n  const externalUsers = fetchExternalUsers();\n  const existingUsers = getAllUsers();\n  const existingEmails = new Set(existingUsers.map((u) => u.email));\n\n  let synced = 0;\n  let skipped = 0;\n\n  for (const extUser of externalUsers) {\n    if (existingEmails.has(extUser.email)) {\n      skipped++;\n      continue;\n    }\n\n    const input: CreateUserInput = {\n      name: extUser.name,\n      email: extUser.email,\n      role: extUser.role,\n    };\n\n    try {\n      const newUser = createUser(input);\n      if (newUser.id) {\n        synced++;\n      }\n    } catch (err) {\n      console.error(`Failed to sync user ${extUser.email}:`, err);\n    }\n  }\n\n  console.log(`Sync complete: ${synced} synced, ${skipped} skipped`);\n}\n\nexport async function syncSingleUser(userId: number): Promise<boolean> {\n  const user = getUserById(userId);\n  if (!user) {\n    console.error(`User ${userId} not found for sync`);\n    return false;\n  }\n\n  // In a real app, we'd sync to an external service here\n  console.log(`Synced user ${user.name} (${user.email})`);\n  return true;\n}","is_error":false}]},"parent_tool_use_id":"toolu_01PVWCrTF5tikHVGQcHuGaVF","session_id":"c38aba28-4281-4b29-a669-0c622193f7bb","uuid":"00da181a-525a-41dd-91be-9de7c50813a3"}
