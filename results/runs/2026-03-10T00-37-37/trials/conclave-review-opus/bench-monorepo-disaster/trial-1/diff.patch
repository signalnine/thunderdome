+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012LuBjvxRRutHApFeUHmCT2","type":"tool_result","content":"import { describe, it, expect, beforeEach } from 'vitest';\nimport request from 'supertest';\nimport { createApp } from '../src/index.js';\nimport { resetDefaultConnection } from '@monorepo/core';\n\ndescribe('User Routes', () => {\n  let app: ReturnType<typeof createApp>;\n\n  beforeEach(() => {\n    resetDefaultConnection();\n    app = createApp();\n  });\n\n<<<<<<< HEAD\n  it('creates user with valid data', async () => {\n    const res = await request(app)\n      .post('/users')\n      .set('x-user-role', 'admin')\n      .send({ name: 'Test', email: 'test@test.com' });\n    expect(res.status).toBe(201);\n=======\n  it('registers user with valid data', async () => {\n    const res = await request(app)\n      .post('/users')\n      .set('x-user-role', 'admin')\n      .send({ name: 'Test', email: 'test@test.com', role: 'user' });\n    expect(res.status).toBe(201);\n>>>>>>> refactor/user-system\n    expect(res.body.user.name).toBe('Test');\n  });\n\n  it('rejects user creation without admin role', async () => {\n    const res = await request(app)\n      .post('/users')\n      .set('x-user-role', 'viewer')\n      .send({ name: 'Test', email: 'test@test.com', role: 'user' });\n    expect(res.status).toBe(403);\n  });\n\n  it('returns 400 for invalid user data', async () => {\n    const res = await request(app)\n      .post('/users')\n      .set('x-user-role', 'admin')\n      .send({ name: '', email: 'not-email', role: 'user' });\n    expect(res.status).toBe(400);\n  });\n\n  it('lists all users', async () => {\n    // Create a user first\n    await request(app)\n      .post('/users')\n      .set('x-user-role', 'admin')\n      .send({ name: 'Alice', email: 'alice@test.com', role: 'user' });\n\n    const res = await request(app)\n      .get('/users')\n      .set('x-user-role', 'admin');\n    expect(res.status).toBe(200);\n    expect(res.body