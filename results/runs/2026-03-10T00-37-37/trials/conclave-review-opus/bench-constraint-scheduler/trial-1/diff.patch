new file mode 100644
index 0000000..93de60b
--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,515 @@
+export interface Event {
+  id: string;
+  name: string;
+  duration: number;
+  attendees?: number;
+  prerequisites?: string[];
+  preferredRoom?: string;
+}
+
+export interface Room {
+  id: string;
+  name: string;
+  capacity: number;
+}
+
+export interface ScheduleOptions {
+  startTime: number;
+  endTime: number;
+  gap?: number;
+}
+
+export interface Assignment {
+  eventId: string;
+  roomId: string;
+  startTime: number;
+  endTime: number;
+}
+
+export interface ScheduleResult {
+  assignments: Assignment[];
+  unscheduled: string[];
+}
+
+function topologicalSort(events: Event[]): string[] {
+  const eventMap = new Map<string, Event>();
+  for (const e of events) {
+    eventMap.set(e.id, e);
+  }
+
+  const WHITE = 0, GRAY = 1, BLACK = 2;
+  const color = new Map<string, number>();
+  for (const e of events) {
+    color.set(e.id, WHITE);
+  }
+
+  const order: string[] = [];
+
+  function dfs(id: string): void {
+    if (color.get(id) === GRAY) {
+      throw new Error(`Prerequisite cycle detected involving event "${id}"`);
+    }
+    if (color.get(id) === BLACK) return;
+
+    color.set(id, GRAY);
+    const ev = eventMap.get(id);
+    if (ev?.prerequisites) {
+      for (const pre of ev.prerequisites) {
+        if (pre === id) {
+          throw new Error(`Prerequisite cycle detected: event "${id}" references itself`);
+        }
+        if (eventMap.has(pre)) {
+          dfs(pre);
+        }
+      }
+    }
+    color.set(id, BLACK);
+    order.push(id);
+  }
+
+  for (const e of events) {
+    if (color.get(e.id) === WHITE) {
+      dfs(e.id);
+    }
+  }
+
+  return order;
+}
+
+export function schedule(
+  events: Event[],
+  rooms: Room[],
+  options: ScheduleOptions
+): ScheduleResult {
+  const gap = options.gap ?? 15;
+  const { startTime, endTime } = options;
+
+  if (events.length === 0) {
+    return { assignments: [], unscheduled: [] };
+  }
+
+  // Detect cycles (will throw if cycle found)
+  const topoOrder = topologicalSort(events);
+
+  const eventMap = new Map<string, Event>();
+  for (const e of events) {
+    eventMap.set(e.id, e);
+  }
+
+  // Sort rooms by capacity ascending for efficient packing
+  const sortedRooms = [...rooms].sort((a, b) => a.capacity - b.capacity);
+
+  // Get eligible rooms for an event (capacity >= attendees)
+  function getEligibleRooms(event: Event): Room[] {
+    const att = event.attendees ?? 1;
+    return sortedRooms.filter(r => r.capacity >= att);
+  }
+
+  // Track room schedules: roomId -> sorted list of [start, end]
+  type TimeSlot = { start: number; end: number };
+  type RoomSchedule = Map<string, TimeSlot[]>;
+
+  function findEarliestSlot(
+    roomSchedule: RoomSchedule,
+    roomId: string,
+    duration: number,
+    earliestStart: number
+  ): number | null {
+    const slots = roomSchedule.get(roomId) ?? [];
+    const effectiveStart = Math.max(startTime, earliestStart);
+
+    if (effectiveStart + duration > endTime) return null;
+
+    if (slots.length === 0) {
+      return effectiveStart;
+    }
+
+    // Try before first slot
+    if (effectiveStart + duration + gap <= slots[0].start) {
+      return effectiveStart;
+    }
+
+    // Try after each existing slot
+    for (let i = 0; i < slots.length; i++) {
+      const candidateStart = Math.max(effectiveStart, slots[i].end + gap);
+      if (i + 1 < slots.length) {
+        // Between two slots: must end + gap <= next slot start
+        if (candidateStart + duration + gap <= slots[i + 1].start) {
+          return candidateStart;
+        }
+      } else {
+        // After last slot: must end <= endTime
+        if (candidateStart + duration <= endTime) {
+          return candidateStart;
+        }
+      }
+    }
+
+    return null;
+  }
+
+  function insertSlot(roomSchedule: RoomSchedule, roomId: string, slot: TimeSlot): void {
+    const slots = roomSchedule.get(roomId);
+    if (!slots) {
+      roomSchedule.set(roomId, [slot]);
+      return;
+    }
+    // Insert in sorted order
+    let idx = 0;
+    while (idx < slots.length && slots[idx].start < slot.start) {
+      idx++;
+    }
+    slots.splice(idx, 0, slot);
+  }
+
+  // Use backtracking with optimization to maximize scheduled events
+  // For efficiency, try a greedy approach first, then attempt to improve
+
+  // Greedy scheduling following topological order
+  function greedySchedule(eventOrder: string[]): {
+    assignments: Map<string, Assignment>;
+    unscheduled: Set<string>;
+  } {
+    const assignments = new Map<string, Assignment>();
+    const unscheduled = new Set<string>();
+    const roomSchedule: RoomSchedule = new Map();
+
+    for (const eventId of eventOrder) {
+      const event = eventMap.get(eventId)!;
+      const eligibleRooms = getEligibleRooms(event);
+
+      if (eligibleRooms.length === 0) {
+        unscheduled.add(eventId);
+        continue;
+      }
+
+      // Calculate earliest start based on prerequisites
+      let earliestStart = startTime;
+      let prereqSatisfied = true;
+      if (event.prerequisites) {
+        for (const preId of event.prerequisites) {
+          if (!eventMap.has(preId)) continue;
+          const preAssignment = assignments.get(preId);
+          if (!preAssignment) {
+            // Prerequisite wasn't scheduled, can't schedule this
+            prereqSatisfied = false;
+            break;
+          }
+          earliestStart = Math.max(earliestStart, preAssignment.endTime + gap);
+        }
+      }
+
+      if (!prereqSatisfied) {
+        unscheduled.add(eventId);
+        continue;
+      }
+
+      // Try preferred room first
+      let bestRoom: string | null = null;
+      let bestStart = Infinity;
+
+      if (event.preferredRoom) {
+        const prefRoom = eligibleRooms.find(r => r.id === event.preferredRoom);
+        if (prefRoom) {
+          const slot = findEarliestSlot(roomSchedule, prefRoom.id, event.duration, earliestStart);
+          if (slot !== null) {
+            bestRoom = prefRoom.id;
+            bestStart = slot;
+          }
+        }
+      }
+
+      // If preferred room didn't work or no preference, try all eligible rooms
+      if (bestRoom === null) {
+        for (const room of eligibleRooms) {
+          const slot = findEarliestSlot(roomSchedule, room.id, event.duration, earliestStart);
+          if (slot !== null && slot < bestStart) {
+            bestRoom = room.id;
+            bestStart = slot;
+          }
+        }
+      }
+
+      if (bestRoom !== null) {
+        const assignment: Assignment = {
+          eventId: event.id,
+          roomId: bestRoom,
+          startTime: bestStart,
+          endTime: bestStart + event.duration,
+        };
+        assignments.set(event.id, assignment);
+        insertSlot(roomSchedule, bestRoom, { start: bestStart, end: bestStart + event.duration });
+      } else {
+        unscheduled.add(eventId);
+      }
+    }
+
+    return { assignments, unscheduled };
+  }
+
+  // Try greedy scheduling
+  let result = greedySchedule(topoOrder);
+
+  // If there are unscheduled events, try to improve by rescheduling
+  if (result.unscheduled.size > 0) {
+    // Try different orderings: prioritize events by constraints
+    // Strategy: try scheduling "harder" events first (more prerequisites, fewer eligible rooms, longer duration)
+
+    const strategies: ((a: string, b: string) => number)[] = [
+      // By fewest eligible rooms (most constrained first)
+      (a, b) => {
+        const aRooms = getEligibleRooms(eventMap.get(a)!).length;
+        const bRooms = getEligibleRooms(eventMap.get(b)!).length;
+        return aRooms - bRooms;
+      },
+      // By longest duration first
+      (a, b) => {
+        return eventMap.get(b)!.duration - eventMap.get(a)!.duration;
+      },
+      // By most attendees first (most constrained room-wise)
+      (a, b) => {
+        return (eventMap.get(b)!.attendees ?? 1) - (eventMap.get(a)!.attendees ?? 1);
+      },
+    ];
+
+    for (const comparator of strategies) {
+      // Re-sort topological order with secondary sort by strategy
+      // Maintain topological ordering but sort within levels
+      const levels = computeTopologicalLevels(topoOrder, eventMap);
+      const sortedOrder = sortByLevels(levels, comparator);
+
+      const candidate = greedySchedule(sortedOrder);
+      if (candidate.unscheduled.size < result.unscheduled.size) {
+        result = candidate;
+      }
+      if (result.unscheduled.size === 0) break;
+    }
+  }
+
+  // If still unscheduled, try a more aggressive approach: backtracking for small instances
+  if (result.unscheduled.size > 0 && events.length <= 20) {
+    const btResult = backtrackSchedule(topoOrder, eventMap, sortedRooms, gap, startTime, endTime);
+    if (btResult.unscheduled.size < result.unscheduled.size) {
+      result = btResult;
+    }
+  }
+
+  const assignments: Assignment[] = [];
+  const unscheduled: string[] = [];
+
+  for (const eventId of topoOrder) {
+    const assignment = result.assignments.get(eventId);
+    if (assignment) {
+      assignments.push(assignment);
+    } else {
+      unscheduled.push(eventId);
+    }
+  }
+
+  return { assignments, unscheduled };
+}
+
+function computeTopologicalLevels(
+  topoOrder: string[],
+  eventMap: Map<string, Event>
+): Map<string, number> {
+  const levels = new Map<string, number>();
+
+  for (const id of topoOrder) {
+    const event = eventMap.get(id)!;
+    let level = 0;
+    if (event.prerequisites) {
+      for (const pre of event.prerequisites) {
+        if (eventMap.has(pre) && levels.has(pre)) {
+          level = Math.max(level, levels.get(pre)! + 1);
+        }
+      }
+    }
+    levels.set(id, level);
+  }
+
+  return levels;
+}
+
+function sortByLevels(
+  levels: Map<string, number>,
+  tiebreaker: (a: string, b: string) => number
+): string[] {
+  const entries = [...levels.entries()];
+  entries.sort((a, b) => {
+    if (a[1] !== b[1]) return a[1] - b[1]; // sort by level first
+    return tiebreaker(a[0], b[0]); // then by tiebreaker
+  });
+  return entries.map(e => e[0]);
+}
+
+function backtrackSchedule(
+  topoOrder: string[],
+  eventMap: Map<string, Event>,
+  sortedRooms: Room[],
+  gap: number,
+  startTime: number,
+  endTime: number
+): { assignments: Map<string, Assignment>; unscheduled: Set<string> } {
+  type TimeSlot = { start: number; end: number };
+  type RoomSchedule = Map<string, TimeSlot[]>;
+
+  let bestAssignments = new Map<string, Assignment>();
+  let bestCount = 0;
+
+  function getEligibleRooms(event: Event): Room[] {
+    const att = event.attendees ?? 1;
+    return sortedRooms.filter(r => r.capacity >= att);
+  }
+
+  function findAllSlots(
+    roomSchedule: RoomSchedule,
+    roomId: string,
+    duration: number,
+    earliestStart: number
+  ): number[] {
+    const slots = roomSchedule.get(roomId) ?? [];
+    const effectiveStart = Math.max(startTime, earliestStart);
+    const results: number[] = [];
+
+    if (effectiveStart + duration > endTime) return results;
+
+    // Collect all possible start times
+    const candidateStarts: number[] = [effectiveStart];
+
+    for (const s of slots) {
+      candidateStarts.push(s.end + gap);
+    }
+
+    for (const candidate of candidateStarts) {
+      if (candidate < effectiveStart) continue;
+      if (candidate + duration > endTime) continue;
+
+      // Check no overlap with any existing slot (including gaps)
+      let valid = true;
+      for (const s of slots) {
+        if (!(candidate + duration + gap <= s.start || candidate >= s.end + gap)) {
+          valid = false;
+          break;
+        }
+      }
+      if (valid) results.push(candidate);
+    }
+
+    return results;
+  }
+
+  function insertSlot(roomSchedule: RoomSchedule, roomId: string, slot: TimeSlot): void {
+    const slots = roomSchedule.get(roomId);
+    if (!slots) {
+      roomSchedule.set(roomId, [slot]);
+      return;
+    }
+    let idx = 0;
+    while (idx < slots.length && slots[idx].start < slot.start) {
+      idx++;
+    }
+    slots.splice(idx, 0, slot);
+  }
+
+  function removeSlot(roomSchedule: RoomSchedule, roomId: string, slot: TimeSlot): void {
+    const slots = roomSchedule.get(roomId);
+    if (!slots) return;
+    const idx = slots.findIndex(s => s.start === slot.start && s.end === slot.end);
+    if (idx >= 0) slots.splice(idx, 1);
+  }
+
+  const totalEvents = topoOrder.length;
+  let iterations = 0;
+  const maxIterations = 100000;
+
+  function solve(
+    idx: number,
+    assignments: Map<string, Assignment>,
+    roomSchedule: RoomSchedule,
+    count: number
+  ): void {
+    if (iterations++ > maxIterations) return;
+
+    if (count > bestCount) {
+      bestCount = count;
+      bestAssignments = new Map(assignments);
+    }
+
+    if (count === totalEvents) return; // All scheduled
+    if (idx >= topoOrder.length) return;
+
+    // Pruning: even if we schedule all remaining, can we beat best?
+    if (count + (topoOrder.length - idx) <= bestCount) return;
+
+    const eventId = topoOrder[idx];
+    const event = eventMap.get(eventId)!;
+    const eligibleRooms = getEligibleRooms(event);
+
+    // Calculate earliest start based on prerequisites
+    let earliestStart = startTime;
+    let prereqSatisfied = true;
+    if (event.prerequisites) {
+      for (const preId of event.prerequisites) {
+        if (!eventMap.has(preId)) continue;
+        const preAssignment = assignments.get(preId);
+        if (!preAssignment) {
+          prereqSatisfied = false;
+          break;
+        }
+        earliestStart = Math.max(earliestStart, preAssignment.endTime + gap);
+      }
+    }
+
+    if (prereqSatisfied && eligibleRooms.length > 0) {
+      // Sort rooms: preferred first, then by earliest available slot
+      const roomOrder = [...eligibleRooms];
+      if (event.preferredRoom) {
+        roomOrder.sort((a, b) => {
+          if (a.id === event.preferredRoom) return -1;
+          if (b.id === event.preferredRoom) return 1;
+          return 0;
+        });
+      }
+
+      for (const room of roomOrder) {
+        const possibleStarts = findAllSlots(roomSchedule, room.id, event.duration, earliestStart);
+        // Try earliest start for efficiency
+        for (const start of possibleStarts.slice(0, 3)) { // limit branching
+          const slot = { start, end: start + event.duration };
+          const assignment: Assignment = {
+            eventId,
+            roomId: room.id,
+            startTime: start,
+            endTime: start + event.duration,
+          };
+
+          assignments.set(eventId, assignment);
+          insertSlot(roomSchedule, room.id, slot);
+
+          solve(idx + 1, assignments, roomSchedule, count + 1);
+
+          if (bestCount === totalEvents) return; // Found optimal
+
+          assignments.delete(eventId);
+          removeSlot(roomSchedule, room.id, slot);
+        }
+      }
+    }
+
+    // Try skipping this event
+    solve(idx + 1, assignments, roomSchedule, count);
+  }
+
+  const initialSchedule: RoomSchedule = new Map();
+  solve(0, new Map(), initialSchedule, 0);
+
+  const unscheduled = new Set<string>();
+  for (const id of topoOrder) {
+    if (!bestAssignments.has(id)) {
+      unscheduled.add(id);
+    }
+  }
+
+  return { assignments: bestAssignments, unscheduled };
+}
diff --git a/src/scheduler.test.ts b/src/scheduler.test.ts
