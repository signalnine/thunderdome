ber; end: number };\n  type RoomSchedule = Map<string, TimeSlot[]>;\n\n  let bestAssignments = new Map<string, Assignment>();\n  let bestCount = 0;\n\n  function getEligibleRooms(event: Event): Room[] {\n    const att = event.attendees ?? 1;\n    return sortedRooms.filter(r => r.capacity >= att);\n  }\n\n  function findAllSlots(\n    roomSchedule: RoomSchedule,\n    roomId: string,\n    duration: number,\n    earliestStart: number\n  ): number[] {\n    const slots = roomSchedule.get(roomId) ?? [];\n    const effectiveStart = Math.max(startTime, earliestStart);\n    const results: number[] = [];\n\n    if (effectiveStart + duration > endTime) return results;\n\n    // Collect all possible start times\n    const candidateStarts: number[] = [effectiveStart];\n\n    for (const s of slots) {\n      candidateStarts.push(s.end + gap);\n    }\n\n    for (const candidate of candidateStarts) {\n      if (candidate < effectiveStart) continue;\n      if (candidate + duration > endTime) continue;\n\n      // Check no overlap with any existing slot (including gaps)\n      let valid = true;\n      for (const s of slots) {\n        if (!(candidate + duration + gap <= s.start || candidate >= s.end + gap)) {\n          valid = false;\n          break;\n        }\n      }\n      if (valid) results.push(candidate);\n    }\n\n    return results;\n  }\n\n  function insertSlot(roomSchedule: RoomSchedule, roomId: string, slot: TimeSlot): void {\n    const slots = roomSchedule.get(roomId);\n    if (!slots) {\n      roomSchedule.set(roomId, [slot]);\n      return;\n    }\n    let idx = 0;\n    while (idx < slots.length && slots[idx].start < slot.start) {\n      idx++;\n    }\n    slots.splice(idx, 0, slot);\n  }\n\n  function removeSlot(roomSchedule: RoomSchedule, roomId: string, slot: TimeSlot): void {\n    const slots = roomSchedule.get(roomId);\n    if (!slots) return;\n    const idx = slots.findIndex(s => s.start === slot.start && s.end === slot.end);\n    if (idx >= 0) slots.splice(idx,