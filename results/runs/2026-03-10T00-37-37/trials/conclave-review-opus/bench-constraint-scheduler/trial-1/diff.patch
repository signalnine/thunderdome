st', () => {\n      const result = schedule([], defaultRooms, defaultOptions);\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toHaveLength(0);\n    });\n\n    it('should default gap to 15 minutes', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n        { id: 'e2', name: 'Event 2', duration: 60 },\n      ];\n      const rooms: Room[] = [\n        { id: 'room-a', name: 'Room A', capacity: 10 },\n      ];\n      const result = schedule(events, rooms, { startTime: 540, endTime: 1020 });\n      expect(result.assignments).toHaveLength(2);\n      // Both in same room, second should start at least 15 min after first ends\n      const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n      const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n      if (a1.startTime < a2.startTime) {\n        expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + 15);\n      } else {\n        expect(a1.startTime).toBeGreaterThanOrEqual(a2.endTime + 15);\n      }\n    });\n  });\n\n  describe('room capacity', () => {\n    it('should not assign an event to a room that is too small', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, attendees: 15 },\n      ];\n      const rooms: Room[] = [\n        { id: 'room-a', name: 'Room A', capacity: 10 },\n        { id: 'room-b', name: 'Room B', capacity: 20 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('room-b');\n    });\n\n    it('should mark event as unscheduled if no room has sufficient capacity', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, attendees: 50 },\n      ];\n      const rooms: Room[] = [\n        { id: 'room-a', name: 'Room A', capacity: 10 },\n        { id: 'room-b', name: 'Room B', capacity: 20 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toContain('e1');\n    });\n\n    it('should default attendees to 1', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n      ];\n      const rooms: Room[] = [\n        { id: 'room-a', name: 'Room A', capacity: 1 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n    });\n  });\n\n  describe('time window', () => {\n    it('should not schedule events outside the time window', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n      ];\n      const result = schedule(events, defaultRooms, {\n        startTime: 540,\n        endTime: 560, // only 20 minutes available\n      });\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toContain('e1');\n    });\n\n    it('should fit events exactly within the time window', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n      ];\n      const result = schedule(events, defaultRooms, {\n        startTime: 540,\n        endTime: 600,\n      });\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].startTime).toBe(540);\n      expect(result.assignments[0].endTime).toBe(600);\n    });\n  });\n\n  describe('room gaps', () => {\n    it('should maintain gap between events in the same room', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n        { id: 'e2', name: 'Event 2', duration: 60 },\n      ];\n      const rooms: Room[] = [\n        { id: 'room-a', name: 'Room A', capacity: 10 },\n      ];\n      const result = schedule(events, rooms, { ...defaultOptions, gap: 30 });\n      expect(result.assignments).toHaveLength(2);\n      const [first, second] = result.assignments.sort((