eGreaterThanOrEqual(a1.endTime + (defaultOptions.gap ?? 15));\n    });\n\n    it('should handle chain of prerequisites', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 30 },\n        { id: 'e2', name: 'Event 2', duration: 30, prerequisites: ['e1'] },\n        { id: 'e3', name: 'Event 3', duration: 30, prerequisites: ['e2'] },\n      ];\n      const result = schedule(events, defaultRooms, defaultOptions);\n      expect(result.assignments).toHaveLength(3);\n      const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n      const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n      const a3 = result.assignments.find(a => a.eventId === 'e3')!;\n      expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + 15);\n      expect(a3.startTime).toBeGreaterThanOrEqual(a2.endTime + 15);\n    });\n\n    it('should throw error on prerequisite cycle', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['e2'] },\n        { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },\n      ];\n      expect(() => schedule(events, defaultRooms, defaultOptions)).toThrow();\n    });\n\n    it('should throw error on self-referencing prerequisite', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['e1'] },\n      ];\n      expect(() => schedule(events, defaultRooms, defaultOptions)).toThrow();\n    });\n\n    it('should throw error on longer cycles', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 30, prerequisites: ['e3'] },\n        { id: 'e2', name: 'Event 2', duration: 30, prerequisites: ['e1'] },\n        { id: 'e3', name: 'Event 3', duration: 30, prerequisites: ['e2'] },\n      ];\n      expect(() => schedule(events, defaultRooms, defaultOptions)).toThrow();\n    });\n\n    it('should not schedule event if prerequisite cannot be scheduled', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, attendees: 100 }, // can't fit any room\n        { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },\n      ];\n      const rooms: Room[] = [\n        { id: 'room-a', name: 'Room A', capacity: 10 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.unscheduled).toContain('e1');\n      expect(result.unscheduled).toContain('e2');\n    });\n\n    it('should handle prerequisites referencing non-existent events', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['nonexistent'] },\n      ];\n      const result = schedule(events, defaultRooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n    });\n  });\n\n  describe('preferred room', () => {\n    it('should honor preferred room when possible', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, preferredRoom: 'room-b' },\n      ];\n      const result = schedule(events, defaultRooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('room-b');\n    });\n\n    it('should use another room if preferred room has insufficient capacity', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, attendees: 15, preferredRoom: 'room-a' },\n      ];\n      const rooms: Room[] = [\n        { id: 'room-a', name: 'Room A', capacity: 10 },\n        { id: 'room-b', name: 'Room B', capacity: 20 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('room-b');\n    });\n\n    it('should use another room when preferred room is full', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 450, preferredRoom: 'room-a' }, // takes almost all day\n        { id: 'e2', name: 'Event 2', duration: 60, preferredRoom: 'room-a' },\n      ];\n      const rooms: Room[] = [\n        { id: 'room-a', name: 'Room A', capacity: 10 },\n        { id: 'room-b', name: 'Room B', capacity: 20 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(2);\n      const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n      // e2 should be in room-b since room-a is full\n      expect(a2.roomId).toBe('room-b');\n    });\n  });\n\n  describe('batch optimization', () => {\n    it('should maximize scheduled events rather than greedily blocking', () => {\n      // Scenario: One room, tight schedule. If we greedily place a long event first,\n      // we might not fit two shorter events.\n      const events: Event[] = [\n        { id: 'long', name: 'Long Event', duration: 400 },\n        { id: 'short1', name: 'Short 1', duration: 120 },\n        { id: 'short2', name: 'Short 2', duration: 120 },\n      ];\n      const rooms: Room[] = [\n        { id: 'room-a', name: 'Room A', capacity: 10 },\n      ];\n      // Window: 9:00-5:00 = 480 minutes\n      // Long=400 + gap=15 = 415, leaving 65 min -> only 1 more short (120 > 65) -> total 1 + long = 2\n      // Two shorts: 120 + 15 + 120 = 255 -> both fit -> total 2\n      // So max is 2 either way, but scheduler should figure out the best combo\n      const result = schedule(events, rooms, defaultOptions);\n      // Should schedule at least 2 events\n      expect(result.assignments.length).toBeGreaterThanOrEqual(2);\n    });\n\n    it('should optimize placement across multiple rooms', () => {\n      const events: Event[] = [];\n      // Fill 6 events of 60 min each, should fit 6 events across 2 rooms in 8-hour day\n      for (let i = 0; i < 6; i++) {\n        events.push({ id: `e${i}`, name: `Event ${i}`, duration: 60 });\n      }\n      const result = schedule(events, defaultRooms, defaultOptions);\n      expect(result.