  expect(result.unscheduled).toHaveLength(0);\n    });\n\n    it('should default gap to 15 minutes', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n        { id: 'e2', name: 'Event 2', duration: 60 },\n      ];\n      const rooms: Room[] = [\n        { id: 'room-a', name: 'Room A', capacity: 10 },\n      ];\n      const result = schedule(events, rooms, { startTime: 540, endTime: 1020 });\n      expect(result.assignments).toHaveLength(2);\n      // Both in same room, second should start at least 15 min after first ends\n      const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n      const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n      if (a1.startTime < a2.startTime) {\n        expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + 15);\n      } else {\n        expect(a1.startTime).toBeGreaterThanOrEqual(a2.endTime + 15);\n      }\n    });\n  });\n\n  describe('room capacity', () => {\n    it('should not assign an event to a room that is too small', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, attendees: 15 },\n      ];\n      const rooms: Room[] = [\n        { id: 'room-a', name: 'Room A', capacity: 10 },\n        { id: 'room-b', name: 'Room B', capacity: 20 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('room-b');\n    });\n\n    it('should mark event as unscheduled if no room has sufficient capacity', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, attendees: 50 },\n      ];\n      const rooms: Room[] = [\n        { id: 'room-a', name: 'Room A', capacity: 10 },\n        { id: 'room-b', name: 'Room B', capacity: 20 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toContain('e1');\n    });\n\n    it('should default attendees to 1', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n      ];\n      const rooms: Room[] = [\n        { id: 'room-a', name: 'Room A', capacity: 1 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n    });\n  });\n\n  describe('time window', () => {\n    it('should not schedule events outside the time window', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n      ];\n      const result = schedule(events, defaultRooms, {\n        startTime: 540,\n        endTime: 560, // only 20 minutes available\n      });\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toContain('e1');\n    });\n\n    it('should fit events exactly within the time window', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n      ];\n      const result = schedule(events, defaultRooms, {\n        startTime: 540,\n        endTime: 600,\n      });\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].startTime).toBe(540);\n      expect(result.assignments[0].endTime).toBe(600);\n    });\n  });\n\n  describe('room gaps', () => {\n    it('should maintain gap between events in the same room', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n        { id: 'e2', name: 'Event 2', duration: 60 },\n      ];\n      const rooms: Room[] = [\n        { id: 'room-a', name: 'Room A', capacity: 10 },\n      ];\n      const result = schedule(events, rooms, { ...defaultOptions, gap: 30 });\n      expect(result.assignments).toHaveLength(2);\n      const [first, second] = result.assignments.sort((a, b) => a.startTime - b.startTime);\n      expect(second.startTime).toBeGreaterThanOrEqual(first.endTime + 30);\n    });\n\n    it('should allow events in different rooms without gap constraint between them', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n        { id: 'e2', name: 'Event 2', duration: 60 },\n      ];\n      const result = schedule(events, defaultRooms, defaultOptions);\n      expect(result.assignments).toHaveLength(2);\n      // With 2 rooms, events can overlap in time\n      const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n      const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n      // They may or may not be in different rooms, but both should be scheduled\n    });\n\n    it('should use custom gap value', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n        { id: 'e2', name: 'Event 2', duration: 60 },\n      ];\n      const rooms: Room[] = [\n        { id: 'room-a', name: 'Room A', capacity: 10 },\n      ];\n      const result = schedule(events, rooms, { ...defaultOptions, gap: 0 });\n      expect(result.assignments).toHaveLength(2);\n      const [first, second] = result.assignments.sort((a, b) => a.startTime - b.startTime);\n      // With gap=0, events can be back to back\n      expect(second.startTime).toBeGreaterThanOrEqual(first.endTime);\n    });\n  });\n\n  describe('prerequisites', () => {\n    it('should schedule prerequisite before dependent event', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n        { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },\n      ];\n      const result = schedule(events, defaultRooms, defaultOptions);\n      expect(result.assignments).toHaveLength(2);\n      const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n      const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n      expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + (defaultOptions.gap ?? 15));\n    });\n\n    it('should handle chain of prerequisites', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 30 },\n        { id: 'e2', name: 'Event 2', duration: 30, prerequisites: ['e1'] },\n        { id: 'e3', name: 'Event 3', duration: 30, prerequisites: ['e2'] },\n      ];\n      const result = schedule(events, defaultRooms, defaultOptions);\n      expect(result.assignments).toHaveLength(3);\n      const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n      const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n      const a3 = result.assignments.find(a => a.eventId === 'e3')!;\n      expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + 15);\n      expect(a3.startTime).toBeGreaterThanOrEqual(a2.endTime + 15);\n    });\n\n    it('should throw error on prerequisite cycle', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['e2'] },\n        { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },\n      ];\n      expect(() => schedule(events, defaultRooms, defaultOptions)).toThrow();\n    });\n\n    it('should throw error on self-referencing prerequisite', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['e1'] },\n      ];\n      expect(() => schedule(events, defaultRooms, defaultOptions)).toThrow();\n    });\n\n    it('should throw error on longer cycles', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 30, prerequisites: ['e3'] },\n        { id: 'e2', name: 'Event 2', duration: 30, prerequisites: ['e1'] },\n        { id: 'e3', name: 'Event 3', duration: 30, prerequisites: ['e2'] },\n      ];\n      expect(() => schedule(events, defaultRooms, defaultOptions)).toThrow();\n    });\n\n    it('should not schedule event if prerequisite cannot be scheduled', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, attendees: 100 }, // can't fit any room\n        { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },\n      ];\n      const rooms: Room[] = [\n        { id: 'room-a', name: 'Room A', capacity: 10 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.unscheduled).toContain('e1');\n      expect(result.unscheduled).toContain('e2');\n    });\n\n    it('should handle prerequisites referencing non-existent events', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['nonexistent'] },\n      ];\n      const result = schedule(events, defaultRooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n    });\n  });\n\n  describe('preferred room', () => {\n    it('should honor preferred room when possible', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, preferredRoom: 'room-b' },\n      ];\n      const result = schedule(events, defaultRooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('room-b');\n    });\n\n    it('should use another room if preferred room has insufficient capacity', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, attendees: 15, preferredRoom: 'room-a' },\n      ];\n      const rooms: Room[] = [\n        { id: 'room-a', name: 'Room A', capacity: 10 },\n        { id: 'room-b', name: 'Room B', capacity: 20 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('room-b');\n    });\n\n    it('should use another room when preferred room is full', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 450, preferredRoom: 'room-a' }, // takes almost all day\n        { id: 'e2', name: 'Event 2', duration: 60, preferredRoom: 'room-a' },\n      ];\n      const rooms: Room[] = [\n        { id: 'room-a', name: 'Room A', capacity: 10 },\n        { id: 'room-b', name: 'Room B', capacity: 20 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(2);\n      const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n      // e2 should be in room-b since room-a is full\n      expect(a2.roomId).toBe('room-b');\n    });\n  });\n\n  describe('batch optimization', () => {\n    it('should maximize scheduled events rather than greedily blocking', () => {\n      // Scenario: One room, tight schedule. If we greedily place a long event first,\n      // we might not fit two shorter events.\n      const events: Event[] = [\n        { id: 'long', name: 'Long Event', duration: 400 },\n        { id: 'short1', name: 'Short 1', duration: 120 },\n        { id: 'short2', name: 'Short 2', duration: 120 },\n      ];\n      const rooms: Room[] = [\n        { id: 'room-a', name: 'Room A', capacity: 10 },\n      ];\n      // Window: 9:00-5:00 = 480 minutes\n      // Long=400 + gap=15 = 415, leaving 65 min -> only 1 more short (120 > 65) -> total 1 + long = 2\n      // Two shorts: 120 + 15 + 120 = 255 -> both fit -> total 2\n      // So max is 2 either way, but scheduler should figure out the best combo\n      const result = schedule(events, rooms, defaultOptions);\n      // Should schedule at least 2 events\n      expect(result.assignments.length).toBeGreaterThanOrEqual(2);\n    });\n\n    it('should optimize placement across multiple rooms', () => {\n      const events: Event[] = [];\n      // Fill 6 events of 60 min each, should fit 6 events across 2 rooms in 8-hour day\n      for (let i = 0; i < 6; i++) {\n        events.push({ id: `e${i}`, name: `Event ${i}`, duration: 60 });\n      }\n      const result = schedule(events, defaultRooms, defaultOptions);\n      expect(result.assignments).toHaveLength(6);\n      expect(result.unscheduled).toHaveLength(0);\n    });\n\n    it('should handle when some events must be unscheduled', () => {\n      // One room, 2-hour window, 3 events of 60 min each\n      // 60 + 15 + 60 = 135 < 120. Only 1 can fit in 120 min window\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n        { id: 'e2', name: 'Event 2', duration: 60 },\n        { id: 'e3', name: 'Event 3', duration: 60 },\n      ];\n      const rooms: Room[] = [\n        { id: 'room-a', name: 'Room A', capacity: 10 },\n      ];\n      const result = schedule(events, rooms, { startTime: 540, endTime: 660, gap: 15 });\n      // 120 min window: 60 + 15 + 60 = 135 > 120. Only 1 event fits.\n      expect(result.assignments.length).toBe(1);\n      expect(result.unscheduled.length).toBe(2);\n    });\n  });\n\n  describe('edge cases', () => {\n    it('should handle events with 0 gap', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n        { id: 'e2', name: 'Event 2', duration: 60 },\n      ];\n      const rooms: Room[] = [\n        { id: 'room-a', name: 'Room A', capacity: 10 },\n      ];\n      const result = schedule(events, rooms, { startTime: 540, endTime: 660, gap: 0 });\n      expect(result.assignments).toHaveLength(2);\n    });\n\n    it('should handle many events with prerequisites', () => {\n      const events: Event[] = [];\n      for (let i = 0; i < 10; i++) {\n        events.push({\n          id: `e${i}`,\n          name: `Event ${i}`,\n          duration: 30,\n          prerequisites: i > 0 ? [`e${i - 1}`] : [],\n        });\n      }\n      // Chain of 10 events, each 30 min with 15 min gap = 45 min each = 450 min total\n      // Window is 480 min, so all should fit\n      const result = schedule(events, defaultRooms, defaultOptions);\n      expect(result.assignments).toHaveLength(10);\n\n      // Verify ordering\n      for (let i = 1; i < 10; i++) {\n        const prev = result.assignments.find(a => a.eventId === `e${i - 1}`)!;\n        const curr = result.assignments.find(a => a.eventId === `e${i}`)!;\n        expect(curr.startTime).toBeGreaterThanOrEqual(prev.endTime + 15);\n      }\n    });\n\n    it('should handle single room', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n      ];\n      const rooms: Room[] = [\n        { id: 'room-a', name: 'Room A', capacity: 10 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('room-a');\n    });\n\n    it('should handle no rooms', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n      ];\n      const result = schedule(events, [], defaultOptions);\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toContain('e1');\n    });\n\n    it('should ensure all assignments have valid time ranges', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n        { id: 'e2', name: 'Event 2', duration: 90 },\n        { id: 'e3', name: 'Event 3', duration: 30, prerequisites: ['e1'] },\n      ];\n      const result = schedule(events, defaultRooms, defaultOptions);\n      for (const a of result.assignments) {\n        expect(a.startTime).toBeGreaterThanOrEqual(defaultOptions.startTime);\n        expect(a.endTime).toBeLessThanOrEqual(defaultOptions.endTime);\n        expect(a.endTime - a.startTime).toBeGreaterThan(0);\n      }\n    });\n  });\n\n  describe('comprehensive constraint satisfaction', () => {\n    it('should satisfy all constraints simultaneously', () => {\n      const events: Event[] = [\n        { id: 'keynote', name: 'Keynote', duration: 90, attendees: 15, preferredRoom: 'room-b' },\n        { id: 'workshop', name: 'Workshop', duration: 120, attendees: 8, prerequisites: ['keynote'] },\n        { id: 'talk1', name: 'Talk 1', duration: 45, attendees: 5 },\n        { id: 'talk2', name: 'Talk 2', duration: 45, attendees: 