@@ -0,0 +1,68 @@
+import semver from 'semver';
+import type { PluginManifest, RegistryService } from '../types.js';
+
+export function createRegistry(): RegistryService {
+  // Store plugins keyed by "name@version"
+  const plugins = new Map<string, PluginManifest>();
+
+  return {
+    register(manifest: PluginManifest): void {
+      const key = `${manifest.name}@${manifest.version}`;
+      plugins.set(key, { ...manifest });
+    },
+
+    get(name: string): PluginManifest | null {
+      // Return the latest version (highest semver) of the plugin
+      const versions = this.listVersions(name);
+      if (versions.length === 0) return null;
+      const latest = versions[versions.length - 1];
+      return this.getVersion(name, latest);
+    },
+
+    getVersion(name: string, version: string): PluginManifest | null {
+      const key = `${name}@${version}`;
+      const manifest = plugins.get(key);
+      return manifest ? { ...manifest } : null;
+    },
+
+    list(): PluginManifest[] {
+      return Array.from(plugins.values()).map(m => ({ ...m }));
+    },
+
+    search(query: string): PluginManifest[] {
+      const lower = query.toLowerCase();
+      return Array.from(plugins.values())
+        .filter(m =>
+          m.name.toLowerCase().includes(lower) ||
+          m.description.toLowerCase().includes(lower) ||
+          m.author.toLowerCase().includes(lower)
+        )
+        .map(m => ({ ...m }));
+    },
+
+    remove(name: string, version: string): boolean {
+      const key = `${name}@${version}`;
+      return plugins.delete(key);
+    },
+
+    listVersions(name: string): string[] {
+      const versions: string[] = [];
+      for (const manifest of plugins.values()) {
+        if (manifest.name === name) {
+          versions.push(manifest.version);
+        }
+      }
+      versions.sort(semver.compare);
+      return versions;
+    },
+
+    update(name: string, version: string, updates: Partial<PluginManifest>): void {
+      const key = `${name}@${version}`;
+      const existing = plugins.get(key);
+      if (!existing) {
+        throw new Error(`Plugin ${name}@${version} not found`);
+      }
+      plugins.set(key, { ...existing, ...updates, name, version });
+    },
+  };
+}
