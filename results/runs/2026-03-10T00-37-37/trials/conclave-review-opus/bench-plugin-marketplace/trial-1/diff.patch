ion: '1.0.0', userId: 'u1', rating: 5, comment: 'great' });\n      reviews.addReview({ pluginName: 'plugin-b', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: 'ok' });\n      reviews.addReview({ pluginName: 'plugin-a', pluginVersion: '1.0.0', userId: 'u3', rating: 4, comment: 'good' });\n\n      const result = reviews.getReviews('plugin-a');\n      expect(result).toHaveLength(2);\n      expect(result.every(r => r.pluginName === 'plugin-a')).toBe(true);\n    });\n\n    it('should return empty array for plugin with no reviews', () => {\n      expect(reviews.getReviews('nonexistent')).toHaveLength(0);\n    });\n  });\n\n  describe('getAverageRating', () => {\n    it('should compute average rating', () => {\n      reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 4, comment: '' });\n      reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u2', rating: 2, comment: '' });\n      expect(reviews.getAverageRating('p')).toBe(3);\n    });\n\n    it('should exclude flagged reviews from average', () => {\n      const r1 = reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });\n      reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: '' });\n      reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u3', rating: 1, comment: 'spam' });\n      reviews.flagReview(r1.id);\n\n      // Only unflagged: 3 and 1, average = 2\n      expect(reviews.getAverageRating('p')).toBe(2);\n    });\n\n    it('should return 0 for plugin with no reviews', () => {\n      expect(reviews.getAverageRating('nonexistent')).toBe(0);\n    });\n  });\n\n  describe('flagReview', () => {\n    it('should flag a review', () => {\n      const review = reviews.addReview({\n        pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 1, comment: 'spam',\n      });\n      reviews.flagReview(review.id);\n      const flagged = reviews.getFlaggedReviews();\n      expect(flagged).toHaveLength(1);\n      expect(flagged[0].id).toBe(review.id);\n    });\n\n    it('should throw for non-existent review', () => {\n      expect(() => reviews.flagReview(999)).toThrow();\n    });\n  });\n\n  describe('getFlaggedReviews', () => {\n    it('should return only flagged reviews', () => {\n      const r1 = reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 1, comment: 'spam' });\n      reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u2', rating: 5, comment: 'good' });\n      reviews.flagReview(r1.id);\n\n      const flagged = reviews.getFlaggedReviews();\n      expect(flagged).toHaveLength(1);\n      expect(flagged[0].flagged).toBe(true);\n    });\n  });\n\n  describe('removeReview', () => {\n    it('should remove a review', () => {\n      const review = reviews.addReview({\n        pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 3, comment: 'ok',\n      });\n      expect(reviews.removeReview(review.id)).toBe(true);\n      expect(reviews.getReviews('p')).toHaveLength(0);\n    });\n\n    it('should return false for non-existent review', () => {\n      expect(reviews.removeReview(999)).toBe(false);\n    });\n  });\n\n  describe('getReviewsByUser', () => {\n    it('should return reviews by a specific user', () => {\n      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'alice', rating: 5, comment: '' });\n      reviews.addReview({ pluginName: 'p2', pluginVersion: '1.0.0', userId: 'bob', rating: 3, comment: '' });\n      reviews.addReview({ pluginName: 'p3', pluginVersion: '1.0.0', userId: 'alice', rating: 4, comment: '' });\n\n      const aliceReviews = reviews.getReviewsByUser('alice');\n      expect(aliceReviews).toHaveLength(2);\n      expect(aliceReviews.every(r => r.userId === 'alice')).toBe(true);\n    });\n  });\n\n  describe('getReviewCount', () => {\n    it('should return the total count of reviews for a plugin', () => {\n     