n    50→      expect(() =>\n    51→        resolver.resolve(\n    52→          [{ name: 'dep-a', range: '^3.0.0' }],\n    53→          { 'dep-a': ['1.0.0', '2.0.0'] }\n    54→        )\n    55→      ).toThrow('No version of dep-a satisfies');\n    56→    });\n    57→  });\n    58→\n    59→  describe('satisfies', () => {\n    60→    it('should return true for matching version', () => {\n    61→      expect(resolver.satisfies('1.2.3', '^1.0.0')).toBe(true);\n    62→    });\n    63→\n    64→    it('should return false for non-matching version', () => {\n    65→      expect(resolver.satisfies('2.0.0', '^1.0.0')).toBe(false);\n    66→    });\n    67→\n    68→    it('should handle tilde ranges', () => {\n    69→      expect(resolver.satisfies('1.2.5', '~1.2.0')).toBe(true);\n    70→      expect(resolver.satisfies('1.3.0', '~1.2.0')).toBe(false);\n    71→    });\n    72→  });\n    73→\n    74→  describe('maxSatisfying', () => {\n    75→    it('should return the highest matching version', () => {\n    76→      expect(resolver.maxSatisfying(['1.0.0', '1.5.0', '2.0.0'], '^1.0.0')).toBe('1.5.0');\n    77→    });\n    78→\n    79→    it('should return null when no version matches', () => {\n    80→      expect(resolver.maxSatisfying(['1.0.0', '2.0.0'], '^3.0.0')).toBeNull();\n    81→    });\n    82→  });\n    83→\n    84→  describe('validRange', () => {\n    85→    it('should return true for valid ranges', () => {\n    86→      expect(resolver.validRange('^1.0.0')).toBe(true);\n    87→      expect(resolver.validRange('~1.2.0')).toBe(true);\n    88→      expect(resolver.validRange('>=1.0.0 <2.0.0')).toBe(true);\n    89→      expect(resolver.validRange('*')).toBe(true);\n    90→    });\n    91→\n    92→    it('should return false for invalid ranges', () => {\n    93→      expect(resolver.validRange('not-a-range')).toBe(false);\n    94→    });\n    95→  });\n    96→});\n    97→"}]},"parent_tool_use_id":"toolu_01YT8F5rgLBc8r8tzQkKC76C","session_id":"237a11d6-ff14-48e4-9c28-bac459c3