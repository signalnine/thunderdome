 47→    listVersions(name: string): string[] {\n    48→      const versions: string[] = [];\n    49→      for (const manifest of plugins.values()) {\n    50→        if (manifest.name === name) {\n    51→          versions.push(manifest.version);\n    52→        }\n    53→      }\n    54→      // Sort by semver\n    55→      versions.sort((a, b) => {\n    56→        const partsA = a.split('.').map(Number);\n    57→        const partsB = b.split('.').map(Number);\n    58→        for (let i = 0; i < 3; i++) {\n    59→          if ((partsA[i] || 0) !== (partsB[i] || 0)) {\n    60→            return (partsA[i] || 0) - (partsB[i] || 0);\n    61→          }\n    62→        }\n    63→        return 0;\n    64→      });\n    65→      return versions;\n    66→    },\n    67→\n    68→    update(name: string, version: string, updates: Partial<PluginManifest>): void {\n    69→      const key = `${name}@${version}`;\n    70→      const existing = plugins.get(key);\n    71→      if (!existing) {\n    72→        throw new Error(`Plugin ${name}@${version} not found`);\n    73→      }\n    74→      plugins.set(key, { ...existing, ...updates, name, version });\n    75→    },\n    76→  };\n    77→}\n    78→"}]},"parent_tool_use_id":"toolu_01YT8F5rgLBc8r8tzQkKC76C","session_id":"237a11d6-ff14-48e4-9c28-bac459c3caeb","uuid":"d2be22c8-6af5-4621-bb49-9061dd711435"}
