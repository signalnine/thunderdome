   90→    });\n    91→\n    92→    it('should search by author', () => {\n    93→      registry.register(makeManifest({ name: 'plugin-a', author: 'alice' }));\n    94→      registry.register(makeManifest({ name: 'plugin-b', author: 'bob' }));\n    95→      const results = registry.search('alice');\n    96→      expect(results).toHaveLength(1);\n    97→    });\n    98→\n    99→    it('should be case-insensitive', () => {\n   100→      registry.register(makeManifest({ name: 'Auth-Plugin' }));\n   101→      const results = registry.search('AUTH');\n   102→      expect(results).toHaveLength(1);\n   103→    });\n   104→  });\n   105→\n   106→  describe('remove', () => {\n   107→    it('should remove a specific version', () => {\n   108→      registry.register(makeManifest({ version: '1.0.0' }));\n   109→      registry.register(makeManifest({ version: '2.0.0' }));\n   110→      const removed = registry.remove('test-plugin', '1.0.0');\n   111→      expect(removed).toBe(true);\n   112→      expect(registry.getVersion('test-plugin', '1.0.0')).toBeNull();\n   113→      expect(registry.getVersion('test-plugin', '2.0.0')).not.toBeNull();\n   114→    });\n   115→\n   116→    it('should return false for non-existent plugin', () => {\n   117→      expect(registry.remove('nonexistent', '1.0.0')).toBe(false);\n   118→    });\n   119→  });\n   120→\n   121→  describe('listVersions', () => {\n   122→    it('should list all versions sorted', () => {\n   123→      registry.register(makeManifest({ version: '2.0.0' }));\n   124→      registry.register(makeManifest({ version: '1.0.0' }));\n   125→      registry.register(makeManifest({ version: '1.5.0' }));\n   126→      const versions = registry.listVersions('test-plugin');\n   127→      expect(versions).toEqual(['1.0.0', '1.5.0', '2.0.0']);\n   128→    });\n   129→\n   130→    it('should return empty for non-existent plugin', () => {\n   131→      expect(registry.listVersions('nonexistent')).toEqual([]);\n   132→    });\n   133→  });\n   