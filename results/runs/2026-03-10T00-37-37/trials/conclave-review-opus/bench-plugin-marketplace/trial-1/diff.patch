n', () => {\n      registry.register(makeManifest({ version: '1.0.0' }));\n      registry.register(makeManifest({ version: '2.0.0' }));\n      const result = registry.getVersion('test-plugin', '1.0.0');\n      expect(result).not.toBeNull();\n      expect(result!.version).toBe('1.0.0');\n    });\n\n    it('should return null for non-existent version', () => {\n      registry.register(makeManifest({ version: '1.0.0' }));\n      expect(registry.getVersion('test-plugin', '3.0.0')).toBeNull();\n    });\n  });\n\n  describe('list', () => {\n    it('should list all registered plugins', () => {\n      registry.register(makeManifest({ name: 'plugin-a', version: '1.0.0' }));\n      registry.register(makeManifest({ name: 'plugin-b', version: '1.0.0' }));\n      const list = registry.list();\n      expect(list).toHaveLength(2);\n    });\n\n    it('should return empty array when no plugins', () => {\n      expect(registry.list()).toHaveLength(0);\n    });\n  });\n\n  describe('search', () => {\n    it('should search by name', () => {\n      registry.register(makeManifest({ name: 'auth-plugin' }));\n      registry.register(makeManifest({ name: 'db-plugin' }));\n      const results = registry.search('auth');\n      expect(results).toHaveLength(1);\n      expect(results[0].name).toBe('auth-plugin');\n    });\n\n    it('should search by description', () => {\n      registry.register(makeManifest({ name: 'plugin-a', description: 'Handles authentication' }));\n      registry.register(makeManifest({ name: 'plugin-b', description: 'Database connector' }));\n      const results = registry.search('authentication');\n      expect(results).toHaveLength(1);\n    });\n\n    it('should search by author', () => {\n      registry.register(makeManifest({ name: 'plugin-a', author: 'alice' }));\n      registry.register(makeManifest({ name: 'plugin-b', author: 'bob' }));\n      const results = registry.search('alice');\n      expect(results).toHaveLength(1);\n    });\n\n    it('should be case-insensitive', () => {\n      registry.register(makeManifest({ name: 'Auth-Plugin' }));\n      const results = registry.search('AUTH');\n      expect(results).toHaveLength(1);\n    });\n  });\n\n  describe('remove', () => {\n    it('should remove a specific version', () => {\n      registry.register(makeManifest({ version: '1.0.0' }));\n      registry.register(makeManifest({ version: '2.0.0' }));\n      const removed = registry.remove('test-plugin', '1.0.0');\n      expect(removed).toBe(true);\n      expect(registry.getVersion('test-plugin', '1.0.0')).toBeNull();\n      expect(registry.getVersion('test-plugin', '2.0.0')).not.toBeNull();\n    });\n\n    it('should return false for non-existent plugin', () => {\n      expect(registry.remove('nonexistent', '1.0.0')).toBe(false);\n    });\n  });\n\n  describe('listVersions', () => {\n    it('should list all versions sorted', () => {\n      registry.register(makeManifest({ version: '2.0.0' }));\n      registry.register(makeManifest({ version: '1.0.0' }));\n      registry.register(makeManifest({ version: '1.5.0' }));\n      const versions = registry.listVersions('test-plugin');\n      expect(versions).toEqual(['1.0.0', '1.5.0', '2.0.0']);\n    });\n\n    it('should return empty for non-existent plugin', () => {\n      expect(registry.listVersions('nonexistent')).toEqual([]);\n    });\n  });\n\n  describe('update', () => {\n    it('should update plugin fields', () => {\n      registry.register(makeManifest());\n      registry.update('test-plugin', '1.0.0', { description: 'Updated description' });\n      const result = registry.getVersion('test-plugin', '1.0.0');\n      expect(result!.description).toBe('Updated description');\n    });\n\n    it('should throw for non-existent plugin', () => {\n      expect(() => registry.update('nonexistent', '1.0.0', {})).toThrow();\n    });\n\n    it('should not change name or version', () => {\n      registry.register(makeManifest());\n      registry.update('test-plugin', '1.0.0', { name: 'other', version: '9.9.9' } as Partial<PluginManifest>);\n      const result = registry.getVersion('test-plugin', '1.0.0');\n      expect(result!.name).toBe('test-plugin');\n      expect(result!.version).toBe('1.0.0');\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
