+++ b/src/deps/index.ts
@@ -0,0 +1,122 @@
+import type { DependencyNode, DepsService, RegistryService } from '../types.js';
+
+export function createDepsService(): DepsService {
+  function buildTreeInternal(
+    name: string,
+    registry: RegistryService,
+    visited: Set<string>
+  ): DependencyNode {
+    const manifest = registry.get(name);
+    if (!manifest) {
+      return { name, version: 'unknown', dependencies: [] };
+    }
+
+    const node: DependencyNode = {
+      name: manifest.name,
+      version: manifest.version,
+      dependencies: [],
+    };
+
+    if (visited.has(name)) {
+      // Circular dependency - return node without further expansion
+      return node;
+    }
+
+    visited.add(name);
+
+    for (const depName of Object.keys(manifest.dependencies)) {
+      const childNode = buildTreeInternal(depName, registry, new Set(visited));
+      node.dependencies.push(childNode);
+    }
+
+    return node;
+  }
+
+  function detectCyclesInternal(
+    name: string,
+    registry: RegistryService,
+    path: string[],
+    allCycles: string[][]
+  ): void {
+    const cycleStart = path.indexOf(name);
+    if (cycleStart !== -1) {
+      const cycle = path.slice(cycleStart).concat(name);
+      allCycles.push(cycle);
+      return;
+    }
+
+    const manifest = registry.get(name);
+    if (!manifest) return;
+
+    path.push(name);
+    for (const depName of Object.keys(manifest.dependencies)) {
+      detectCyclesInternal(depName, registry, [...path], allCycles);
+    }
+  }
+
+  function collectAllDeps(
+    name: string,
+    registry: RegistryService,
+    visited: Set<string>,
+    result: string[]
+  ): void {
+    const manifest = registry.get(name);
+    if (!manifest) return;
+
+    for (const depName of Object.keys(manifest.dependencies)) {
+      if (!visited.has(depName)) {
+        visited.add(depName);
+        collectAllDeps(depName, registry, visited, result);
+        result.push(depName);
+      }
+    }
+  }
+
+  function topoSort(
+    name: string,
+    registry: RegistryService,
+    visited: Set<string>,
+    stack: string[]
+  ): void {
+    visited.add(name);
+    const manifest = registry.get(name);
+    if (manifest) {
+      for (const depName of Object.keys(manifest.dependencies)) {
+        if (!visited.has(depName)) {
+          topoSort(depName, registry, visited, stack);
+        }
+      }
+    }
+    stack.push(name);
+  }
+
+  return {
+    buildTree(name: string, registry: RegistryService): DependencyNode {
+      return buildTreeInternal(name, registry, new Set());
+    },
+
+    detectCycles(name: string, registry: RegistryService): string[][] | null {
+      const allCycles: string[][] = [];
+      detectCyclesInternal(name, registry, [], allCycles);
+      return allCycles.length > 0 ? allCycles : null;
+    },
+
+    topologicalSort(name: string, registry: RegistryService): string[] {
+      const visited = new Set<string>();
+      const stack: string[] = [];
+      topoSort(name, registry, visited, stack);
+      return stack;
+    },
+
+    flattenDependencies(name: string, registry: RegistryService): string[] {
+      const visited = new Set<string>();
+      const result: string[] = [];
+      collectAllDeps(name, registry, visited, result);
+      return result;
+    },
+
+    hasCircularDependency(name: string, registry: RegistryService): boolean {
+      return this.detectCycles(name, registry) !== null;
+    },
+  };
+}
