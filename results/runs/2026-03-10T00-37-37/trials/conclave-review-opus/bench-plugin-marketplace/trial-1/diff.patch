tree.dependencies).toHaveLength(1);\n    45→      expect(tree.dependencies[0].name).toBe('child');\n    46→      expect(tree.dependencies[0].dependencies).toHaveLength(1);\n    47→      expect(tree.dependencies[0].dependencies[0].name).toBe('grandchild');\n    48→    });\n    49→\n    50→    it('should handle non-existent plugins', () => {\n    51→      const tree = deps.buildTree('nonexistent', registry);\n    52→      expect(tree.name).toBe('nonexistent');\n    53→      expect(tree.version).toBe('unknown');\n    54→    });\n    55→  });\n    56→\n    57→  describe('detectCycles', () => {\n    58→    it('should return null when no cycles exist', () => {\n    59→      registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0' } }));\n    60→      registry.register(makeManifest({ name: 'b' }));\n    61→      expect(deps.detectCycles('a', registry)).toBeNull();\n    62→    });\n    63→\n    64→    it('should detect direct circular dependency', () => {\n    65→      registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0' } }));\n    66→      registry.register(makeManifest({ name: 'b', dependencies: { a: '^1.0.0' } }));\n    67→      const cycles = deps.detectCycles('a', registry);\n    68→      expect(cycles).not.toBeNull();\n    69→      expect(cycles!.length).toBeGreaterThan(0);\n    70→    });\n    71→\n    72→    it('should detect indirect circular dependency', () => {\n    73→      registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0' } }));\n    74→      registry.register(makeManifest({ name: 'b', dependencies: { c: '^1.0.0' } }));\n    75→      registry.register(makeManifest({ name: 'c', dependencies: { a: '^1.0.0' } }));\n    76→      const cycles = deps.detectCycles('a', registry);\n    77→      expect(cycles).not.toBeNull();\n    78→    });\n    79→  });\n    80→\n    81→  describe('topologicalSort', () => {\n    82→    it('should sort single plugin', () => {\n    83→      registry.register(makeManifest({ name: 'a' }));\n    84→      const sorted = deps.topologicalSort('a', registry);\n    85→      expect(sorted).toEqual(['a']);\n    86→    });\n    87→\n    88→    it('should sort with dependencies (deps before dependents)', () => {\n    89→      registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0', c: '^1.0.0' } }));\n    90→      registry.register(makeManifest({ name: 'b', dependencies: { c: '^1.0.0' } }));\n    91→      registry.register(makeManifest({ name: 'c' }));\n    92→\n    93→      const sorted = deps.topologicalSort('a', registry);\n    94→      // c should come before b, b should come before a\n    95→      expect(sorted.indexOf('c')).toBeLessThan(sorted.indexOf('b'));\n    96→      expect(sorted.indexOf('b')).toBeLessThan(sorted.indexOf('a'));\n    97→    });\n    98→  });\n    99→\n   100→  describe('flattenDependencies', () => {\n   101→    it('should return empty array for plugin with no deps', () => {\n   102→      registry.register(makeManifest({ name: 'a' }));\n   103→      expect(deps.flattenDependencies('a', registry)).toEqual([]);\n   104→    });\n   105→\n   106→    it('should flatten all transitive dependencies', () => {\n   107→      registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0' } }));\n   108→      registry.register(makeManifest({ name: 'b', dependencies: { c: '^1.0.0' } }));\n   109→      registry.register(makeManifest({ name: 'c' }));\n   110→\n   111→      const flat = deps.flattenDependencies('a', registry);\n   112→      expect(flat).toContain('b');\n   113→      expect(flat).toContain('c');\n   114→      expect(flat).not.toContain('a');\n   115→    });\n   116→\n   117→    it('should not include duplicates', () => {\n   118→      registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0', c: '^1.0.0' } }));\n   119→      registry.register(makeManifest({ name: 'b', dependencies: { c: '^1.0.0' } }));\n   120→      registry.register(makeManifest({ name: 'c' }));\n   121→\n   122→      const flat = deps.flattenDependencies('a', registry);\n   123→      const uniqueSet = new Set(flat);\n   124→      expect(flat.length).toBe(uniqueSet.size);\n   125→    });\n   126→  });\n   127→\n   128→  describe('hasCircularDependency', () => {\n   129→    it('should return false when no cycles', () => {\n   130→      registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0' } }));\n   131→      registry.register(makeManifest({ name: 'b' }));\n   132→      expect(deps.hasCircularDependency('a', registry)).toBe(false);\n   133→    });\n   134→\n   135→    it('should return true when cycles exist', () => {\n   136→      registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0' } }));\n   137→      registry.register(makeManifest({ name: 'b', dependencies: { a: '^1.0.0' } }));\n   138→      expect(deps.hasCircularDependency('a', registry)).toBe(true);\n   139→    });\n   140→  });\n   141→});\n   142→"}]},"parent_tool_use_id":"toolu_01YT8F5rgLBc8r8tzQkKC76C","session_id":"237a11d6-ff14-48e4-9c28-bac459c3caeb","uuid":"10d801a5-0d84-4bb7-b17f-5d280e7e8ad0"}
