);\n    47→\n    48→      const registered = marketplace.registry.get('test-plugin');\n    49→      expect(registered).not.toBeNull();\n    50→      expect(registered!.name).toBe('test-plugin');\n    51→    });\n    52→\n    53→    it('should reject plugin without name', async () => {\n    54→      const manifest = makeManifest({ name: '' });\n    55→      await expect(marketplace.installPlugin(manifest)).rejects.toThrow('name');\n    56→    });\n    57→\n    58→    it('should reject plugin without version', async () => {\n    59→      const manifest = makeManifest({ version: '' });\n    60→      await expect(marketplace.installPlugin(manifest)).rejects.toThrow('version');\n    61→    });\n    62→\n    63→    it('should reject plugin without entryPoint', async () => {\n    64→      const manifest = makeManifest({ entryPoint: '' });\n    65→      await expect(marketplace.installPlugin(manifest)).rejects.toThrow('entryPoint');\n    66→    });\n    67→\n    68→    it('should resolve dependencies against registry', async () => {\n    69→      // First register a dependency\n    70→      marketplace.registry.register(makeManifest({ name: 'dep-a', version: '1.0.0' }));\n    71→      marketplace.registry.register(makeManifest({ name: 'dep-a', version: '1.5.0' }));\n    72→\n    73→      const manifest = makeManifest({\n    74→        name: 'my-plugin',\n    75→        dependencies: { 'dep-a': '^1.0.0' },\n    76→        entryPoint: '\"hello\"',\n    77→      });\n    78→\n    79→      const result = await marketplace.installPlugin(manifest);\n    80→      expect(result.resolvedDependencies).toHaveLength(1);\n    81→      expect(result.resolvedDependencies[0].name).toBe('dep-a');\n    82→      expect(result.resolvedDependencies[0].version).toBe('1.5.0');\n    83→    });\n    84→\n    85→    it('should reject plugins with circular dependencies', async () => {\n    86→      // Register a plugin that depends on our plugin\n    87→      marketplace.registry.register(makeManifest({\n    88→        name: 'dep-a',\n    89→        version: '1.0.0',\n    90→        dependencies: { 'my-plugin': '^1.0.0' },\n    91→      }));\n    92→\n    93→      const manifest = makeManifest({\n    94→        name: 'my-plugin',\n    95→        dependencies: { 'dep-a': '^1.0.0' },\n    96→        entryPoint: '\"hello\"',\n    97→      });\n    98→\n    99→      await expect(marketplace.installPlugin(manifest)).rejects.toThrow('Circular dependency');\n   100→    });\n   101→\n   102→    it('should remove plugin from registry when circular dependency is detected', async () => {\n   103→      marketplace.registry.register(makeManifest({\n   104→        name: 'dep-a',\n   105→        version: '1.0.0',\n   106→        dependencies: { 'my-plugin': '^1.0.0' },\n   107→      }));\n   108→\n   109→      const manifest = makeManifest({\n   110→        name: 'my-plugin',\n   111→        dependencies: { 'dep-a': '^1.0.0' },\n   112→        entryPoint: '\"hello\"',\n   113→      });\n   114→\n   115→      try {\n   116→        await marketplace.installPlugin(manifest);\n   117→      } catch {\n   118→        // expected\n   119→      }\n   120→\n   121→      expect(marketplace.registry.get('my-plugin')).toBeNull();\n   122→    });\n   123→\n   124→    it('should execute entryPoint code and return sandbox result', async () => {\n   125→      const manifest = makeManifest({ entryPoint: '\"result: \" + (40 + 2)' });\n   126→      const result = await marketplace.installPlugin(manifest);\n   127→      expect(result.executionResult.success).toBe(true);\n   128→      expect(result.executionResult.output).toBe('result: 42');\n   129→    });\n   130→\n   131→    it('should handle entryPoint execution failure', async () => {\n   132→      const manifest = makeManifest({ entryPoint: 'throw new Error(\"plugin failed\")' });\n   133→      const result = await marketplace.installPlugin(manifest);\n   134→      expect(result.executionResult.success).toBe(false);\n   135→      expect(res