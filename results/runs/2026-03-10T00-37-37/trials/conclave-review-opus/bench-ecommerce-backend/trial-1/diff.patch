+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01X7ddSmZ2R7cqG72YXGxgdQ","type":"tool_result","content":"     1→import { EventBus } from '../bus.js';\n     2→import { InventoryService, Events, InventoryUpdatedEvent, LowStockAlertEvent } from '../types.js';\n     3→\n     4→export function createInventoryService(bus: EventBus): InventoryService {\n     5→  const stock = new Map<string, number>();\n     6→  const reserved = new Map<string, number>();\n     7→  const thresholds = new Map<string, number>();\n     8→\n     9→  function checkLowStock(productId: string): void {\n    10→    const threshold = thresholds.get(productId);\n    11→    if (threshold === undefined) return;\n    12→    const current = stock.get(productId) ?? 0;\n    13→    if (current <= threshold) {\n    14→      const event: LowStockAlertEvent = { productId, currentQuantity: current, threshold };\n    15→      bus.emit(Events.LOW_STOCK_ALERT, event);\n    16→    }\n    17→  }\n    18→\n    19→  return {\n    20→    setStock(productId: string, quantity: number): void {\n    21→      stock.set(productId, quantity);\n    22→      const event: InventoryUpdatedEvent = { productId, quantity };\n    23→      bus.emit(Events.INVENTORY_UPDATED, event);\n    24→      checkLowStock(productId);\n    25→    },\n    26→\n    27→    getStock(productId: string): number {\n    28→      return stock.get(productId) ?? 0;\n    29→    },\n    30→\n    31→    reserve(productId: string, quantity: number): boolean {\n    32→      const available = (stock.get(productId) ?? 0) - (reserved.get(productId) ?? 0);\n    33→      if (available < quantity) return false;\n    34→      reserved.set(productId, (reserved.get(productId) ?? 0) + quantity);\n    35→      // Reduce actual stock by reserved amount\n    36→      stock.set(productId, (stock.get(productId) ?? 0) - quantity);\n    37→      const event: InventoryUpdatedEvent = { productId, quantity: stock.get(productId)! };\n    38→      bus.emit(Events.INVENTORY_UPDATED, event);\n    39→      checkLowStock(productId);\n    40→      return true;\n    41→    },\n    42→\n    43→    release(productId: string, quantity: number): void {\n    44→      const currentReserved = reserved.get(productId) ?? 0;\n    45→      const releaseAmount = Math.min(quantity, currentReserved);\n    46→      reserved.set(productId, currentReserved - releaseAmount);\n    47→      stock.set(productId, (stock.get(productId) ?? 0) + releaseAmount);\n    48→      const event: InventoryUpdatedEvent = { productId, quantity: stock.get(productId)! };\n    49→      bus.emit(Events.INVENTORY_UPDATED, event);\n    50→    },\n    51→\n    52→    setLowStockThreshold(productId: string, threshold: number): void {\n    53→      thresholds.set(productId, threshold);\n    54→      checkLowStock(productId);\n    55→    },\n    56→  };\n    57→}\n    58→"}]},"parent_tool_use_id":"toolu_01BYaPnNvqH6hAgSi9n56jBG","session_id":"12f90088-b94b-4ba8-b368-3b87b2260173","uuid":"9af2d171-e3aa-441b-9c1c-c2739160ff03"}
