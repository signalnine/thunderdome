+describe('Integration: end-to-end flow', () => {
+  it('runs a complete purchase flow', async () => {
+    const bus = new EventBus();
+
+    const catalog = createCatalogService(bus);
+    const inventory = createInventoryService(bus);
+    const cart = createCartService(bus);
+    const pricing = createPricingService(bus);
+    const orders = createOrderService(bus);
+    const payment = createPaymentService(bus);
+    const notifications = createNotificationService(bus);
+    const analytics = createAnalyticsService(bus);
+
+    // Subscribe for notifications
+    notifications.subscribe('user1');
+
+    // Create products
+    const p1 = catalog.createProduct('Laptop', 999.99, 'electronics');
+    const p2 = catalog.createProduct('Mouse', 29.99, 'electronics');
+
+    // Wait for product events to propagate
+    await new Promise(resolve => setTimeout(resolve, 10));
+
+    // Set inventory
+    inventory.setStock(p1, 10);
+    inventory.setStock(p2, 50);
+
+    // Create cart and add items
+    const cartId = cart.createCart('user1');
+    cart.addItem(cartId, p1, 1);
+    cart.addItem(cartId, p2, 2);
+
+    // Calculate pricing
+    const cartData = cart.getCart(cartId)!;
+    const items = cartData.items.map(i => ({
+      productId: i.productId,
+      quantity: i.quantity,
+      price: pricing.getPrice(i.productId),
+    }));
+    const totals = pricing.calculateTotal(items);
+    expect(totals.subtotal).toBeCloseTo(1059.97);
+    expect(totals.tax).toBeCloseTo(106.0);
+
+    // Reserve inventory
+    expect(inventory.reserve(p1, 1)).toBe(true);
+    expect(inventory.reserve(p2, 2)).toBe(true);
+
+    // Create order
+    const orderId = orders.createOrder('user1', cartId, totals.total);
+
+    // Wait for event propagation
+    await new Promise(resolve => setTimeout(resolve, 10));
+
+    // Process payment
+    const paymentResult = await payment.processPayment(orderId, totals.total);
+    expect(paymentResult.status).toBe(PaymentStatus.SUCCESS);
+
+    // Update order status
+    orders.updateStatus(orderId, OrderStatus.CONFIRMED);
+    orders.updateStatus(orderId, OrderStatus.SHIPPED);
+    orders.updateStatus(orderId, OrderStatus.DELIVERED);
+
+    // Wait for event propagation
+    await new Promise(resolve => setTimeout(resolve, 10));
+
+    // Verify notifications
+    const notifs = notifications.getNotifications('user1');
+    expect(notifs.length).toBeGreaterThanOrEqual(4);
+
+    // Verify analytics
+    expect(analytics.getRevenue()).toBeCloseTo(totals.total);
+    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBe(1);
+    expect(analytics.getConversionRate()).toBeGreaterThan(0);
+
+    // Verify inventory was reduced
+    expect(inventory.getStock(p1)).toBe(9);
+    expect(inventory.getStock(p2)).toBe(48);
+  });
+});
