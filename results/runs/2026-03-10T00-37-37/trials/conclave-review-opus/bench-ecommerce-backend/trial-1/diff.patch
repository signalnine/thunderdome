+import { describe, it, expect, beforeEach } from 'vitest';
+import { EventBus } from '../src/bus.js';
+import { Events, OrderStatus, PaymentStatus } from '../src/types.js';
+import { createCatalogService } from '../src/catalog/index.js';
+import { createInventoryService } from '../src/inventory/index.js';
+import { createCartService } from '../src/cart/index.js';
+import { createPricingService } from '../src/pricing/index.js';
+import { createOrderService } from '../src/orders/index.js';
+import { createPaymentService } from '../src/payment/index.js';
+import { createNotificationService } from '../src/notifications/index.js';
+import { createAnalyticsService } from '../src/analytics/index.js';
+
+describe('CatalogService', () => {
+  let bus: EventBus;
+
+  beforeEach(() => {
+    bus = new EventBus();
+  });
+
+  it('creates a product and returns id', () => {
+    const catalog = createCatalogService(bus);
+    const id = catalog.createProduct('Widget', 9.99, 'tools');
+    expect(id).toBeTruthy();
+  });
+
+  it('retrieves a created product', () => {
+    const catalog = createCatalogService(bus);
+    const id = catalog.createProduct('Widget', 9.99, 'tools');
+    const product = catalog.getProduct(id);
+    expect(product).toEqual({ id, name: 'Widget', price: 9.99, category: 'tools' });
+  });
+
+  it('returns null for unknown product', () => {
+    const catalog = createCatalogService(bus);
+    expect(catalog.getProduct('nonexistent')).toBeNull();
+  });
+
+  it('lists all products', () => {
+    const catalog = createCatalogService(bus);
+    catalog.createProduct('A', 1, 'cat1');
+    catalog.createProduct('B', 2, 'cat2');
+    expect(catalog.listProducts()).toHaveLength(2);
+  });
+
+  it('lists products filtered by category', () => {
+    const catalog = createCatalogService(bus);
+    catalog.createProduct('A', 1, 'cat1');
+    catalog.createProduct('B', 2, 'cat2');
+    catalog.createProduct('C', 3, 'cat1');
+    expect(catalog.listProducts('cat1')).toHaveLength(2);
+  });
+
+  it('searches products by name', () => {
+    const catalog = createCatalogService(bus);
+    catalog.createProduct('Blue Widget', 9.99, 'tools');
+    catalog.createProduct('Red Gadget', 19.99, 'tools');
+    const results = catalog.searchProducts('widget');
+    expect(results).toHaveLength(1);
+    expect(results[0].name).toBe('Blue Widget');
+  });
+
+  it('searches products by category', () => {
+    const catalog = createCatalogService(bus);
+    catalog.createProduct('Item', 9.99, 'electronics');
+    const results = catalog.searchProducts('electron');
+    expect(results).toHaveLength(1);
+  });
+
+  it('updates a product', () => {
+    const catalog = createCatalogService(bus);
+    const id = catalog.createProduct('Widget', 9.99, 'tools');
+    catalog.updateProduct(id, { price: 14.99 });
+    expect(catalog.getProduct(id)!.price).toBe(14.99);
+  });
+
+  it('removes a product', () => {
+    const catalog = createCatalogService(bus);
+    const id = catalog.createProduct('Widget', 9.99, 'tools');
+    expect(catalog.removeProduct(id)).toBe(true);
+    expect(catalog.getProduct(id)).toBeNull();
+  });
+
+  it('returns false removing nonexistent product', () => {
+    const catalog = createCatalogService(bus);
+    expect(catalog.removeProduct('xxx')).toBe(false);
+  });
+
+  it('emits product:created event', async () => {
+    const catalog = createCatalogService(bus);
+    const id = catalog.createProduct('Widget', 9.99, 'tools');
+    const log = bus.getLog();
+    const productEvent = log.find(e => e.event === Events.PRODUCT_CREATED);
+    expect(productEvent).toBeTruthy();
+    expect((productEvent!.payload as { productId: string }).productId).toBe(id);
+  });
+});
+
+describe('InventoryService', () => {
+  let bus: EventBus;
+
+  beforeEach(() => {
+    bus = new EventBus();
+  });
+
+  it('sets and gets stock', () => {
+    const inventory = createInventoryService(bus);
+    inventory.setStock('p1', 100);
+    expect(inventory.getStock('p1')).toBe(100);
+  });
+
+  it('returns 0 for unknown product stock', () => {
+    const inventory = createInventoryService(bus);
+    expect(inventory.getStock('unknown')).toBe(0);
+  });
+
+  it('reserves stock successfully', () => {
+    const inventory = createInventoryService(bus);
+    inventory.setStock('p1', 10);
+    expect(inventory.reserve('p1', 5)).toBe(true);
+    expect(inventory.getStock('p1')).toBe(5);
+  });
+
+  it('fails to reserve when insufficient stock', () => {
+    const inventory = createInventoryService(bus);
+    inventory.setStock('p1', 3);
+    expect(inventory.reserve('p1', 5)).toBe(false);
+  });
+
+  it('releases reserved stock', () => {
+    const inventory = createInventoryService(bus);
+    inventory.setStock('p1', 10);
+    inventory.reserve('p1', 5);
+    inventory.release('p1', 3);
+    expect(inventory.getStock('p1')).toBe(8);
+  });
+
+  it('emits low stock alert', async () => {
+    const bus = new EventBus();
+    const inventory = createInventoryService(bus);
+    let alertFired = false;
+    bus.on(Events.LOW_STOCK_ALERT, () => { alertFired = true; });
+    inventory.setStock('p1', 10);
+    inventory.setLowStockThreshold('p1', 5);
+    inventory.reserve('p1', 6);
+    // After reserve, stock = 4 which is <= threshold 5
+    expect(alertFired).toBe(true);
+  });
+
+  it('emits low stock alert when setting threshold above current stock', async () => {
+    const bus = new EventBus();
+    const inventory = createInventoryService(bus);
+    let alertFired = false;
+    bus.on(Events.LOW_STOCK_ALERT, () => { alertFired = true; });
+    inventory.setStock('p1', 3);
+    inventory.setLowStockThreshold('p1', 5);
+    expect(alertFired).toBe(true);
+  });
+});
+
+describe('CartService', () => {
+  let bus: EventBus;
+
+  beforeEach(() => {
+    bus = new EventBus();
+  });
+
+  it('creates a cart and returns id', () => {
+    const cart = createCartService(bus);
+    const id = cart.createCart('user1');
+    expect(id).toBeTruthy();
+  });
+
+  it('adds items to cart', () => {
+    const cart = createCartService(bus);
+    const id = cart.createCart('user1');
+    cart.addItem(id, 'p1', 2);
+    const c = cart.getCart(id);
+    expect(c!.items).toHaveLength(1);
+    expect(c!.items[0]).toEqual({ productId: 'p1', quantity: 2 });
+  });
+
+  it('consolidates same product', () => {
+    const cart = createCartService(bus);
+    const id = cart.createCart('user1');
+    cart.addItem(id, 'p1', 2);
+    cart.addItem(id, 'p1', 3);
+    const c = cart.getCart(id);
+    expect(c!.items).toHaveLength(1);
+    expect(c!.items[0].quantity).toBe(5);
+  });
+
+  it('removes item from cart', () => {
+    const cart = createCartService(bus);
+    const id = cart.createCart('user1');
+    cart.addItem(id, 'p1', 2);
+    cart.addItem(id, 'p2', 1);
+    cart.removeItem(id, 'p1');
+    expect(cart.getCart(id)!.items).toHaveLength(1);
+    expect(cart.getCart(id)!.items[0].productId).toBe('p2');
+  });
+
+  it('clears cart', () => {
+    const cart = createCartService(bus);
+    const id = cart.createCart('user1');
+    cart.addItem(id, 'p1', 2);
+    cart.clearCart(id);
+    expect(cart.getCart(id)!.items).toHaveLength(0);
+  });
+
+  it('updates quantity', () => {
+    const cart = createCartService(bus);
+    const id = cart.createCart('user1');
+    cart.addItem(id, 'p1', 2);
+    cart.updateQuantity(id, 'p1', 10);
+    expect(cart.getCart(id)!.items[0].quantity).toBe(10);
+  });
+
+  it('returns null for unknown cart', () => {
+    const cart = createCartService(bus);
+    expect(cart.getCart('unknown')).toBeNull();
+  });
+
+  it('emits cart:updated event on addItem', () => {
+    const cart = createCartService(bus);
+    const id = cart.createCart('user1');
+    cart.addItem(id, 'p1', 2);
+    const log = bus.getLog();
+    expect(log.some(e => e.event === Events.CART_UPDATED)).toBe(true);
+  });
+});
+
+describe('PricingService', () => {
+  let bus: EventBus;
+
+  beforeEach(() => {
+    bus = new EventBus();
+  });
+
+  it('calculates total with tax', () => {
+    const pricing = createPricingService(bus);
+    const result = pricing.calculateTotal([{ productId: 'p1', quantity: 2, price: 10 }]);
+    expect(result.subtotal).toBe(20);
+    expect(result.discount).toBe(0);
+    expect(result.tax).toBe(2); // 10% of 20
+    expect(result.total).toBe(22);
+  });
+
+  it('applies discount code', () => {
+    const pricing = createPricingService(bus);
+    pricing.addDiscountCode('SAVE20', 20);
+    const result = pricing.calculateTotal(
+      [{ productId: 'p1', quantity: 1, price: 100 }],
+      'SAVE20',
+    );
+    expect(result.subtotal).toBe(100);
+    expect(result.discount).toBe(20);
+    expect(result.tax).toBe(8); // 10% of 80
+    expect(result.total).toBe(88);
+  });
+
+  it('ignores unknown discount code', () => {
+    const pricing = createPricingService(bus);
+    const result = pricing.calculateTotal(
+      [{ productId: 'p1', quantity: 1, price: 100 }],
+      'INVALID',
+    );
+    expect(result.discount).toBe(0);
+    expect(result.total).toBe(110);
+  });
+
+  it('tracks product prices from events', async () => {
+    const pricing = createPricingService(bus);
+    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'Widget', price: 9.99, category: 'tools' });
+    expect(pricing.getPrice('p1')).toBe(9.99);
+  });
+
+  it('returns 0 for unknown product price', () => {
+    const pricing = createPricingService(bus);
+    expect(pricing.getPrice('unknown')).toBe(0);
+  });
+});
+
+describe('OrderService', () => {
+  let bus: EventBus;
+
+  beforeEach(() => {
+    bus = new EventBus();
+  });
+
+  it('creates an order in pending state', () => {
+    const orders = createOrderService(bus);
