+type Direction = 'down' | 'down-left' | 'down-right';
+
+function advance(row: number, col: number, dir: Direction): { row: number; col: number } {
+  switch (dir) {
+    case 'down': return { row: row + 1, col };
+    case 'down-left': return { row: row + 1, col: col - 1 };
+    case 'down-right': return { row: row + 1, col: col + 1 };
+  }
+}
+
+function findSource(grid: string[][]): { row: number; col: number } {
+  for (let col = 0; col < grid[0].length; col++) {
+    if (grid[0][col] === 'S') {
+      return { row: 0, col };
+    }
+  }
+  throw new Error('No source found on top row');
+}
+
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const source = findSource(grid);
+  const visited = new Set<string>();
+  const seen = new Set<string>();
+
+  visited.add(`${source.row},${source.col}`);
+
+  const beams: Array<{ row: number; col: number; dir: Direction }> = [
+    { row: source.row, col: source.col, dir: 'down' },
+  ];
+  seen.add(`${source.row},${source.col},down`);
+
+  while (beams.length > 0) {
+    const beam = beams.pop()!;
+    const next = advance(beam.row, beam.col, beam.dir);
+
+    if (next.row < 0 || next.row >= rows || next.col < 0 || next.col >= cols) {
+      continue;
+    }
+
+    visited.add(`${next.row},${next.col}`);
+
+    if (grid[next.row][next.col] === '^') {
+      for (const dir of ['down-left', 'down-right'] as Direction[]) {
+        const key = `${next.row},${next.col},${dir}`;
+        if (!seen.has(key)) {
+          seen.add(key);
+          beams.push({ row: next.row, col: next.col, dir });
+        }
+      }
+    } else {
+      const key = `${next.row},${next.col},${beam.dir}`;
+      if (!seen.has(key)) {
+        seen.add(key);
+        beams.push({ row: next.row, col: next.col, dir: beam.dir });
+      }
+    }
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const source = findSource(grid);
+
+  // Trace a beam from (row,col) in direction dir until it hits a splitter or exits.
+  function trace(
+    row: number,
+    col: number,
+    dir: Direction,
+  ): { row: number; col: number } | null {
+    let r = row;
+    let c = col;
+    // A beam can travel at most rows steps downward before exiting
+    for (let step = 0; step < rows; step++) {
+      const next = advance(r, c, dir);
+      if (next.row < 0 || next.row >= rows || next.col < 0 || next.col >= cols) {
+        return null;
+      }
+      if (grid[next.row][next.col] === '^') {
+        return { row: next.row, col: next.col };
+      }
+      r = next.row;
+      c = next.col;
+    }
+    return null;
+  }
+
+  // Memoized: how many paths emerge from position (row,col) going in direction dir?
+  const memo = new Map<string, bigint>();
+
+  function pathsFrom(row: number, col: number, dir: Direction): bigint {
+    const key = `${row},${col},${dir}`;
+    const cached = memo.get(key);
+    if (cached !== undefined) return cached;
+
+    const target = trace(row, col, dir);
+    let result: bigint;
+    if (target === null) {
+      result = 1n; // beam exits grid = 1 path
+    } else {
+      // Beam hits splitter, producing two sub-beams
+      result =
+        pathsFrom(target.row, target.col, 'down-left') +
+        pathsFrom(target.row, target.col, 'down-right');
+    }
+    memo.set(key, result);
+    return result;
+  }
+
+  return pathsFrom(source.row, source.col, 'down');
+}
