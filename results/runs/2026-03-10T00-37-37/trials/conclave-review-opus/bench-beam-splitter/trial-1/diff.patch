ams.push({ row: next.row, col: next.col, dir: 'down-left' });\n      beams.push({ row: next.row, col: next.col, dir: 'down-right' });\n    } else {\n      beams.push({ row: next.row, col: next.col, dir: beam.dir });\n    }\n  }\n\n  return visited.size;\n}\n\nexport function countBeamPaths(grid: string[][]): bigint {\n  const rows = grid.length;\n  const cols = grid[0].length;\n  const source = findSource(grid);\n\n  // Trace a beam from (row,col) in direction dir until it hits a splitter or exits.\n  function trace(\n    row: number,\n    col: number,\n    dir: Direction,\n  ): { row: number; col: number } | null {\n    let r = row;\n    let c = col;\n    // A beam can travel at most rows steps downward before exiting\n    for (let step = 0; step < rows; step++) {\n      const next = advance(r, c, dir);\n      if (next.row < 0 || next.row >= rows || next.col < 0 || next.col >= cols) {\n        return null;\n      }\n      if (grid[next.row][next.col] === '^') {\n        return { row: next.row, col: next.col };\n      }\n      r = next.row;\n      c = next.col;\n    }\n    return null;\n  }\n\n  // Memoized: how many paths emerge from position (row,col) going in direction dir?\n  const memo = new Map<string, bigint>();\n\n  function pathsFrom(row: number, col: number, dir: Direction): bigint {\n    const key = `${row},${col},${dir}`;\n    const cached = memo.get(key);\n    if (cached !== undefined) return cached;\n\n    const target = trace(row, col, dir);\n    let result: bigint;\n    if (target === null) {\n      result = 1n; // beam exits grid = 1 path\n    } else {\n      // Beam hits splitter, producing two sub-beams\n      result =\n        pathsFrom(target.row, target.col, 'down-left') +\n        pathsFrom(target.row, target.col, 'down-right');\n    }\n    memo.set(key, result);\n    return result;\n  }\n\n  return pathsFrom(source.row, source.col, 'down');\n}\n","structuredPatch":[{"oldStart":22,"oldLines":12,"newStart":22,"newLines":14,"lines":["   const co