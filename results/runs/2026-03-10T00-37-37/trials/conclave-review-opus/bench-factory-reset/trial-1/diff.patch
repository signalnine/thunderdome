n    if (a[i] > b[i]) return false;\n  }\n  return false;\n}\n\nfunction solveCounterMITM(\n  matrix: number[][],\n  rank: number,\n  pivotCol: number[],\n  freeCols: number[],\n  m: number,\n  modulus: number\n): number[] | null {\n  const numFree = freeCols.length;\n\n  // Compute the particular solution (all free vars = 0)\n  function computeSolution(freeValues: number[]): number[] {\n    const solution = new Array<number>(m).fill(0);\n    for (let i = 0; i < numFree; i++) {\n      solution[freeCols[i]] = freeValues[i];\n    }\n    for (let r = rank - 1; r >= 0; r--) {\n      const pc = pivotCol[r];\n      let val = matrix[r][m];\n      for (let col = 0; col < m; col++) {\n        if (col !== pc) {\n          val = ((val - matrix[r][col] * solution[col]) % modulus + modulus) % modulus;\n        }\n      }\n      solution[pc] = val;\n    }\n    return solution;\n  }\n\n  // For the kernel: each free variable i, when set to value v (and others to 0),\n  // produces a kernel vector. The kernel vectors are linear combinations over GF(p).\n  // We need to find z in the kernel such that (x0 + z) mod p has minimum sum, then lex smallest.\n\n  // Get kernel basis vectors (each corresponds to setting one free var to 1, others to 0)\n  const kernelBasis: number[][] = [];\n  for (const fc of freeCols) {\n    const vec = new Array<number>(m).fill(0);\n    vec[fc] = 1;\n    for (let r = 0; r < rank; r++) {\n      if (matrix[r][fc] !== 0) {\n        vec[pivotCol[r]] = (modulus - matrix[r][fc]) % modulus;\n      }\n    }\n    kernelBasis.push(vec);\n  }\n\n  const x0 = computeSolution(new Array<number>(numFree).fill(0));\n\n  // Meet in the middle: split free variables into two halves\n  const half1 = Math.min(Math.floor(numFree / 2), 6); // Limit to keep map size reasonable\n  const _half2 = numFree - half1;\n\n  // But if half2 is still too large, we need to limit further.\n  // With modulus up to 97 and half = 6, we get 97^6 ≈ 8e11 which is too much.\n  // Let's use a differ