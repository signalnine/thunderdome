         improved = true;","+        } else {","+          coeffs[i] = origCoeff;","+        }","       }","     }","+","+    if (currentTotal < bestTotal || (currentTotal === bestTotal && lexSmallerArr(currentSol, bestSolution))) {","+      bestTotal = currentTotal;","+      bestSolution = currentSol;","+    }","   }"," ","   return bestSolution;"]}],"originalFile":"interface Machine {\n  target: boolean[];\n  buttons: number[][];\n}\n\n/**\n * Solve a toggle puzzle over GF(2) using Gaussian elimination.\n * Find minimum button presses, then lexicographically smallest among ties.\n */\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const n = target.length; // number of lights\n  const m = buttons.length; // number of buttons\n\n  // Build the augmented matrix over GF(2).\n  // Each column represents a button variable, last column is the target.\n  // Each row represents a light equation.\n  // matrix[light][button] = 1 if button toggles that light\n  // matrix[light][m] = target value\n\n  // We want to solve A * x = t over GF(2), where A[i][j] = 1 if button j affects light i.\n  // We want minimum weight x, then lex smallest.\n\n  // Build matrix: rows = lights, cols = buttons + 1 (augmented)\n  const rows = n;\n  const cols = m + 1;\n\n  // Use bitwise representation for efficiency\n  // Each row is a BigInt where bit j represents column j\n  const matrix: bigint[] = new Array(rows);\n  for (let i = 0; i < rows; i++) {\n    matrix[i] = 0n;\n  }\n\n  for (let j = 0; j < m; j++) {\n    for (const lightIdx of buttons[j]) {\n      if (lightIdx < n) {\n        matrix[lightIdx] |= 1n << BigInt(j);\n      }\n    }\n  }\n\n  // Set augmented column (target)\n  for (let i = 0; i < n; i++) {\n    if (target[i]) {\n      matrix[i] |= 1n << BigInt(m);\n    }\n  }\n\n  // Gaussian elimination with column pivoting\n  // Track which column is the pivot for each row\n  const pivotCol: number[] = new Array(rows).fill(-1);\n  const pivotRow: number[] = new Array(cols).fill(-1); // pivotRow[col] = row that has pivot in this col\n  let rank = 0;\n\n  for (let col = 0; col < m; col++) {\n    // Find a row with a 1 in this column, starting from 'rank'\n    let found = -1;\n    for (let row = rank; row < rows; row++) {\n      if ((matrix[row] >> BigInt(col)) & 1n) {\n        found = row;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    // Swap rows\n    [matrix[rank], matrix[found]] = [matrix[found], matrix[rank]];\n\n    pivotCol[rank] = col;\n    pivotRow[col] = rank;\n\n    // Eliminate this column from all other rows\n    for (let row = 0; row < rows; row++) {\n      if (row !== rank && ((matrix[row] >> BigInt(col)) & 1n)) {\n        matrix[row] ^= matrix[rank];\n      }\n    }\n\n    rank++;\n  }\n\n  // Check for inconsistency: any row that is all zeros in button columns but 1 in target\n  for (let row = rank; row < rows; row++) {\n    if ((matrix[row] >> BigInt(m)) & 1n) {\n      return null; // No solution\n    }\n  }\n\n  // Now we have a reduced row echelon form.\n  // Pivot columns are determined variables, non-pivot columns are free variables.\n  const pivotCols = new Set<number>();\n  for (let r = 0; r < rank; r++) {\n    pivotCols.add(pivotCol[r]);\n  }\n\n  const freeCols: number[] = [];\n  for (let col = 0; col < m; col++) {\n    if (!pivotCols.has(col)) {\n      freeCols.push(col);\n    }\n  }\n\n  const numFree = freeCols.length;\n\n  // For each assignment of free variables, compute the determined variables\n  // and find the solution with minimum weight, then lex smallest.\n  // With up to 40 buttons, free variables could be up to 40, but in practice\n  // the rank is usually close to min(n, m), so free vars should be manageable.\n  // However, worst case we might have many free variables.\n  // We need a smarter approach for large free variable counts.\n\n  if (numFree > 25) {\n    // For very large free variable spaces, use a heuristic or different approach.\n    // But per constraints (40 buttons, 40 lights), rank is at most 40,\n    // so free vars = m - rank. If m=40 and rank=0, we'd have 40 free vars.\n    // We need a smarter approach.\n    return solveToggleMinWeight(matrix, rank, pivotCol, freeCols, m);\n  }\n\n  // Enumerate all 2^numFree assignments\n  let bestSolution: number[] | null = null;\n  let bestWeight = m + 1;\n\n  const totalCombinations = 1 << numFree;\n\n  for (let mask = 0; mask < totalCombinations; mask++) {\n    const solution = new Array<number>(m).fill(0);\n\n    // Set free variables\n    for (let i = 0; i < numFree; i++) {\n      if (mask & (1 << i)) {\n        solution[freeCols[i]] = 1;\n      }\n    }\n\n    // Compute pivot variables from the matrix\n    for (let r = rank - 1; r >= 0; r--) {\n      const pc = pivotCol[r];\n      let val = Number((matrix[r] >> BigInt(m)) & 1n); // RHS\n      for (let col = 0; col < m; col++) {\n        if (col !== pc && ((matrix[r] >> BigInt(col)) & 1n)) {\n          val ^= solution[col];\n        }\n      }\n      solution[pc] = val;\n    }\n\n    // Count weight\n    let weight = 0;\n    for (let i = 0; i < m; i++) {\n      weight += solution[i];\n    }\n\n    if (weight < bestWeight || (weight === bestWeight && lexSmallerToggle(solution, bestSolution!))) {\n      bestWeight = weight;\n      bestSolution = solution.slice();\n    }\n  }\n\n  if (bestSolution === null) return null;\n\n  const result: number[] = [];\n  for (let i = 0; i < m; i++) {\n    if (bestSolution[i]) result.push(i);\n  }\n  return result;\n}\n\nfunction lexSmallerToggle(a: number[], b: number[]): boolean {\n  // Compare by the resulting sorted sets of pressed button indices.\n  // First, the set with fewer elements wins (fewer presses).\n  // Among same size, compare element by element.\n  const setA: number[] = [];\n  const setB: number[] = [];\n  for (let i = 0; i < a.length; i++) {\n    if (a[i]) setA.push(i);\n    if (b[i]) setB.push(i);\n  }\n  if (setA.length !== setB.length) return setA.length < setB.length;\n  for (let i = 0; i < setA.length; i++) {\n    if (setA[i] < setB[i]) return true;\n    if (setA[i] > setB[i]) return false;\n  }\n  return false;\n}\n\n/**\n * For cases with too many free variables, use a smarter minimum-weight approach.\n * We use BFS/DFS over free variable assignments ordered by weight.\n */\nfunction solveToggleMinWeight(\n  matrix: bigint[],\n  rank: number,\n  pivotCol: number[],\n  freeCols: number[],\n  m: number\n): number[] | null {\n  // For minimum weight codeword finding in a linear code over GF(2),\n  // we can use the approach of iterating free variable assignments by weight.\n  // But with 40 free vars this is still too many.\n  //\n  // Alternative: since we're looking for minimum weight solution to Ax=b over GF(2),\n  // we can reformulate. The solution space is x0 + ker(A) where x0 is any particular solution.\n  // We want min weight element of this coset.\n  //\n  // For the practical constraint (up to 40 buttons/lights), the rank is at most 40,\n  // so free vars = m - rank <= 40. But typically m and n are both <= 40 and rank ~ min(m,n).\n  //\n  // Let's use a meet-in-the-middle approach for large free variable counts.\n\n  const numFree = freeCols.length;\n\n  if (numFree > 40) {\n    // Shouldn't happen with constraints\n    return null;\n  }\n\n  // Get a particular solution (all free vars = 0)\n  const x0 = new Array<number>(m).fill(0);\n  for (let r = rank - 1; r >= 0; r--) {\n    x0[pivotCol[r]] = Number((matrix[r] >> BigInt(m)) & 1n);\n  }\n\n  // Get the kernel basis vectors\n  // Each free variable gives one basis vector\n  const kernelBasis: number[][] = [];\n  for (const fc of freeCols) {\n    const vec = new Array<number>(m).fill(0);\n    vec[fc] = 1;\n    for (let r = 0; r < rank; r++) {\n      if ((matrix[r] >> BigInt(fc)) & 1n) {\n        vec[pivotCol[r]] = 1;\n      }\n    }\n    kernelBasis.push(vec);\n  }\n\n  // Now we want to find z in span(kernelBasis) over GF(2) such that x0 XOR z has minimum weight.\n  // Meet in the middle: split kernel basis into two halves.\n  const half1 = Math.floor(numFree / 2);\n  const half2 = numFree - half1;\n\n  // For first half, enumerate all 2^half1 combinations and store (resulting xor vector) -> (weight, mask)\n  // For second half, enumerate all 2^half2 combinations\n  // For each second-half combination, compute x0 XOR z1 XOR z2 and find minimum weight\n\n  // Actually, let's store the XOR with x0 for the first half\n  // Then for each second-half combination, we compute x0 XOR z_total and check weight\n\n  // Better: enumerate first half -> store the partial XOR (x0 XOR z1) as a bigint key -> best weight/lex\n  // Then enumerate second half, for each z2, compute final = partialXOR XOR z2, compute weight\n\n  // But with m=40, the vectors are 40 bits, which fits in a bigint or even number.\n  // Let's use bigints for the XOR vectors.\n\n  function xorVecs(a: number[], b: number[]): number[] {\n    const result = new Array<number>(m);\n    for (let i = 0; i < m; i++) {\n      result[i] = a[i] ^ b[i];\n    }\n    return result;\n  }\n\n  function weight(v: number[]): number {\n    let w = 0;\n    for (let i = 0; i < m; i++) w += v[i];\n    return w;\n  }\n\n  // Simple enumeration for meet-in-the-middle\n  // First half\n  const firstHalfSize = 1 << half1;\n  const firstHalfVecs: number[][] = new Array(firstHalfSize);\n\n  for (let mask = 0; mask < firstHalfSize; mask++) {\n    let vec = x0.slice();\n    for (let i = 0; i < half1; i++) {\n      if (mask & (1 << i)) {\n        vec = xorVecs(vec, kernelBasis[i]);\n      }\n    }\n    firstHalfVecs[mask] = vec;\n  }\n\n  let bestWeight = m + 1;\n  let bestSolution: number[] | null = null;\n\n  const secondHalfSize = 1 << half2;\n\n  for (let mask2 = 0; mask2 < secondHalfSize; mask2++) {\n    // Compute z2\n    let z2 = new Array<number>(m).fill(0);\n    for (let i = 0; i < half2; i++) {\n      if (mask2 & (1 << i)) {\n        z2 = xorVecs(z2, kernelBasis[half1 + i]);\n      }\n    }\n\n    // For each first-half vector, XOR with z2 and check\n    for (let mask1 = 0; mask1 < firstHalfSize; mask1++) {\n      const candidate = xorVecs(firstHalfVecs[mask1], z2);\n      const w = weight(candidate);\n      if (w < bestWeight || (w === bestWeight && lexSmallerToggle(candidate, bestSolution!))) {\n        bestWeight = w;\n        bestSolution = candidate;\n      }\n    }\n  }\n\n  if (bestSolution === null) return null;\n\n  const result: number[] = [];\n  for (let i = 0; i < m; i++) {\n    if (bestSolution[i]) result.push(i);\n  }\n  return result;\n}\n\n\n/**\n * Solve a counter puzzle over GF(p) using Gaussian elimination.\n */\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const n = lights.length; // number of counters\n  const m = buttons.length; // number of buttons\n\n  // Build augmented matrix over GF(modulus)\n  // matrix[i][j] = number of times button j affects counter i (0 or 1)\n  // matrix[i][m] = target value for counter i\n  const matrix: number[][] = [];\n  for (let i = 0; i < n; i++) {\n    const row = new Array<number>(m + 1).fill(0);\n    row[m] = lights[i] % modulus;\n    matrix.push(row);\n  }\n\n  for (let j = 0; j < m; j++) {\n    for (const counterIdx of buttons[j]) {\n      if (counterIdx < n) {\n        matrix[counterIdx][j] = (matrix[counterIdx][j] + 1) % modulus;\n      }\n    }\n  }\n\n  // Modular inverse using Fermat's little theorem (modulus is prime)\n  function modInverse(a: number, p: number): number {\n    return modPow(((a % p) + p) % p, p - 2, p);\n  }\n\n  function modPow(base: number, exp: number, mod: number): number {\n    let result = 1;\n    base = base % mod;\n    while (exp > 0) {\n      if (exp & 1) result = (result * base) % mod;\n      exp >>= 1;\n      base = (base * base) % mod;\n    }\n    return result;\n  }\n\n  // Gaussian elimination\n  const pivotCol: number[] = new Array(n).fill(-1);\n  let rank = 0;\n\n  for (let col = 0; col < m; col++) {\n    // Find pivot row\n    let found = -1;\n    for (let row = rank; row < n; row++) {\n      if (matrix[row][col] !== 0) {\n        found = row;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    // Swap\n    [matrix[rank], matrix[found]] = [matrix[found], matrix[rank]];\n\n    pivotCol[rank] = col;\n\n    // Scale pivot row so pivot element = 1\n    const inv = modInverse(matrix[rank][col], modulus);\n    for (let j = 0; j <= m; j++) {\n      matrix[rank][j] = (matrix[rank][j] * inv) % modulus;\n    }\n\n    // Eliminate column from all other rows\n    for (let row = 0; row < n; row++) {\n      if (row !== rank && matrix[row][col] !== 0) {\n        const factor = matrix[row][col];\n        for (let j = 0; j <= m; j++) {\n          matrix[row][j] = ((matrix[row][j] - factor * matrix[rank][j]) % modulus + modulus) % modulus;\n        }\n      }\n    }\n\n    rank++;\n  }\n\n  // Check for inconsistency\n  for (let row = rank; row < n; row++) {\n    if (matrix[row][m] !== 0) {\n      return null;\n    }\n  }\n\n  // Identify pivot and free columns\n  const pivotCols = new Set<number>();\n  for (let r = 0; r < rank; r++) {\n    pivotCols.add(pivotCol[r]);\n  }\n\n  const freeCols: number[] = [];\n  for (let col = 0; col < m; col++) {\n    if (!pivotCols.has(col)) {\n      freeCols.push(col);\n    }\n  }\n\n  const numFree = freeCols.length;\n\n  // For each assignment of free variables (each can be 0..modulus-1),\n  // compute determined variables, find minimum total presses, then lex smallest.\n\n  // Total combinations = modulus^numFree. For modulus=97 and numFree=20, this is way too much.\n  // We need a smarter approach for large free variable spaces.\n\n  // For small free variable counts, enumerate directly.\n  const totalCombinations = Math.pow(modulus, numFree);\n\n  if (numFree === 0 || totalCombinations <= 5000000) {\n    // Direct enumeration\n    let bestSolution: num