plus\n  // some pivot columns (those rows where the free column has a 1).\n  // Store these as bigints for fast XOR.\n  const freeEffects: bigint[] = new Array(numFree);\n  for (let i = 0; i < numFree; i++) {\n    let effect = 1n << BigInt(freeCols[i]); // the free variable itself\n    for (let r = 0; r < rank; r++) {\n      if ((matrix[r] >> BigInt(freeCols[i])) & 1n) {\n        effect |= 1n << BigInt(pivotCol[r]);\n      }\n    }\n    freeEffects[i] = effect;\n  }\n\n  // Compute base solution (all free vars = 0)\n  let currentSol = 0n;\n  for (let r = 0; r < rank; r++) {\n    if ((matrix[r] >> mBig) & 1n) {\n      currentSol |= 1n << BigInt(pivotCol[r]);\n    }\n  }\n\n  function popcount(v: bigint): number {\n    let count = 0;\n    while (v) {\n      v &= v - 1n;\n      count++;\n    }\n    return count;\n  }\n\n  let bestSol = currentSol;\n  let bestWeight = popcount(currentSol);\n\n  // Gray code enumeration: iterate through all 2^numFree combinations\n  // by flipping one free variable at a time.\n  const total = 1 << numFree;\n  for (let i = 1; i < total; i++) {\n    // Find which bit changed (lowest set bit of i in Gray code transition)\n    const bit = i & (-i);\n    let bitIdx = 0;\n    let tmp = bit;\n    while (tmp > 1) { tmp >>= 1; bitIdx++; }\n\n    currentSol ^= freeEffects[bitIdx];\n    const w = popcount(currentSol);\n\n    if (w < bestWeight) {\n      bestWeight = w;\n      bestSol = currentSol;\n    } else if (w === bestWeight) {\n      // Compare as sets: lower index pressed first is lex smaller\n      // In bigint representation, we want the set that has the earlier first difference\n      // where one has a 1 and the other doesn't.\n      // If bestSol has a 1 at position p and currentSol has 0, bestSol is \"larger\" (it includes p).\n      // Actually: for lex comparison of sorted sets, the set whose first differing element\n      // is smaller wins. But if one set includes a smaller index that the other doesn't,\n      // the one that includes it comes first.\n      // Wait: [0,2] vs [1] -> [0,2] is lex smaller because first element 0 < 1.\n      // But both have different sizes. For same-size sets, [0,2] < [0,3].\n      // For different sizes: fewest presses wins first (already filtered by weight).\n      // Among same weight, compare lex.\n      // For lex smallest set: find the first bit position where they differ.\n      // If currentSol has a 1 and bestSol has 0, currentSol includes that index and bestSol doesn't -> currentSol < bestSol.\n      // If bestSol has a 1 and currentSol has 0, bestSol < currentSol.\n      const diff = currentSol ^ bestSol;\n      if (diff) {\n        // Find lowest differing bit\n        const lowestDiff = diff & (-diff);\n        if (currentSol & lowestDiff) {\n          // currentSol has this bit, bestSol doesn't -> currentSol is lex smaller\n          bestSol = currentSol;\n        }\n      }\n    }\n  }\n\n  const result: number[] = [];\n  for (let i = 0; i < m; i++) {\n    if ((bestSol >> BigInt(i)) & 1n) result.push(i);\n  }\n  return result;\n}","originalFile":"interface Machine {\n  target: boolean[];\n  buttons: number[][];\n}\n\n/**\n * Solve a toggle puzzle over GF(2) using Gaussian elimination.\n * Find minimum button presses, then lexicographically smallest set of indices.\n */\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const n = target.length;\n  const m = buttons.length;\n\n  // Build augmented matrix over GF(2) using BigInt for bit operations.\n  // Rows = lights, Cols = buttons + 1 (augmented with target)\n  const matrix: bigint[] = new Array(n);\n  for (let i = 0; i < n; i++) {\n    matrix[i] = 0n;\n  }\n\n  for (let j = 0; j < m; j++) {\n    for (const lightIdx of buttons[j]) {\n      if (lightIdx < n) {\n        matrix[lightIdx] |= 1n << BigInt(j);\n      }\n    }\n  }\n  for (let i = 0; i < n; i++) {\n    if (target[i]) {\n      matrix[i] |= 1n << BigInt(m);\n    }\n  }\n\n  // Gaussian elimination\n  const pivotCol: number[] = [];\n  let rank = 0;\n\n  for (let col = 0; col < m; col++) {\n    let found = -1;\n    for (let row = rank; row < n; row++) {\n      if ((matrix[row] >> BigInt(col)) & 1n) {\n        found = row;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    [matrix[rank], matrix[found]] = [matrix[found], matrix[rank]];\n    pivotCol.push(col);\n\n    for (let row = 0; row < n; row++) {\n      if (row !== rank && ((matrix[row] >> BigInt(col)) & 1n)) {\n        matrix[row] ^= matrix[rank];\n      }\n    }\n    rank++;\n  }\n\n  // Check consistency\n  for (let row = rank; row < n; row++) {\n    if ((matrix[row] >> BigInt(m)) & 1n) {\n      return null;\n    }\n  }\n\n  // Identify free columns\n  const pivotColSet = new Set(pivotCol);\n  const freeCols: number[] = [];\n  for (let col = 0; col < m; col++) {\n    if (!pivotColSet.has(col)) {\n      freeCols.push(col);\n    }\n  }\n\n  const numFree = freeCols.length;\n\n  // For numFree <= 25, enumerate directly. For larger, use meet-in-the-middle.\n  if (numFree <= 25) {\n    return solveToggleEnumerate(matrix, rank, pivotCol, freeCols, m);\n  }\n  return solveToggleMITM(matrix, rank, pivotCol, freeCols, m);\n}\n\nfunction solveToggleEnumerate(\n  matrix: bigint[],\n  rank: number,\n  pivotCol: number[],\n  freeCols: number[],\n  m: number\n): number[] {\n  const numFree = freeCols.length;\n  let bestSolution: number[] | null = null;\n  let bestWeight = m + 1;\n  const mBig = BigInt(m);\n\n  for (let mask = 0; mask < (1 << numFree); mask++) {\n    const solution = new Array<number>(m).fill(0);\n\n    for (let i = 0; i < numFree; i++) {\n      if (mask & (1 << i)) {\n        solution[freeCols[i]] = 1;\n      }\n    }\n\n    for (let r = rank - 1; r >= 0; r--) {\n      const pc = pivotCol[r];\n      let val = Number((matrix[r] >> mBig) & 1n);\n      for (let col = 0; col < m; col++) {\n        if (col !== pc && ((matrix[r] >> BigInt(col)) & 1n)) {\n          val ^=