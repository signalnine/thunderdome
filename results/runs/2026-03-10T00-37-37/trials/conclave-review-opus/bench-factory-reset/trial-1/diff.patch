o free vars = m - rank. If m=40 and rank=0, we'd have 40 free vars.\n    // We need a smarter approach.\n    return solveToggleMinWeight(matrix, rank, pivotCol, freeCols, m);\n  }\n\n  // Enumerate all 2^numFree assignments\n  let bestSolution: number[] | null = null;\n  let bestWeight = m + 1;\n\n  const totalCombinations = 1 << numFree;\n\n  for (let mask = 0; mask < totalCombinations; mask++) {\n    const solution = new Array<number>(m).fill(0);\n\n    // Set free variables\n    for (let i = 0; i < numFree; i++) {\n      if (mask & (1 << i)) {\n        solution[freeCols[i]] = 1;\n      }\n    }\n\n    // Compute pivot variables from the matrix\n    for (let r = rank - 1; r >= 0; r--) {\n      const pc = pivotCol[r];\n      let val = Number((matrix[r] >> BigInt(m)) & 1n); // RHS\n      for (let col = 0; col < m; col++) {\n        if (col !== pc && ((matrix[r] >> BigInt(col)) & 1n)) {\n          val ^= solution[col];\n        }\n      }\n      solution[pc] = val;\n    }\n\n    // Count weight\n    let weight = 0;\n    for (let i = 0; i < m; i++) {\n      weight += solution[i];\n    }\n\n    if (weight < bestWeight || (weight === bestWeight && lexSmaller(solution, bestSolution!))) {\n      bestWeight = weight;\n      bestSolution = solution.slice();\n    }\n  }\n\n  if (bestSolution === null) return null;\n\n  const result: number[] = [];\n  for (let i = 0; i < m; i++) {\n    if (bestSolution[i]) result.push(i);\n  }\n  return result;\n}\n\nfunction lexSmaller(a: number[], b: number[]): boolean {\n  // Compare as sets of pressed buttons (indices where value is 1)\n  // Lex smallest set: compare element by element\n  for (let i = 0; i < a.length; i++) {\n    if (a[i] < b[i]) return true;\n    if (a[i] > b[i]) return false;\n  }\n  return false;\n}\n\n/**\n * For cases with too many free variables, use a smarter minimum-weight approach.\n * We use BFS/DFS over free variable assignments ordered by weight.\n */\nfunction solveToggleMinWeight(\n  matrix: bigint[],\n  rank: number,\n  pivotCol: number[],\n  freeCols: number[],\n  m: number\n): number[] | null {\n  // For minimum weight codeword finding in a linear code over GF(2),\n  // we can use the approach of iterating free variable assignments by weight.\n  // But with 40 free vars this is still too many.\n  //\n  // Alternative: since we're looking for minimum weight solution to Ax=b over GF(2),\n  // we can reformulate. The solution space is x0 + ker(A) where x0 is any particular solution.\n  // We want min weight element of this coset.\n  //\n  // For the practical constraint (up to 40 buttons/lights), the rank is at most 40,\n  // so free vars = m - rank <= 40. But typically m and n are both <= 40 and rank ~ min(m,n).\n  //\n  // Let's use a meet-in-the-middle approach for large free variable counts.\n\n  const numFree = freeCols.length;\n\n  if (numFree > 40) {\n    // Shouldn't happen with constraints\n    return null;\n  }\n\n  // Get a particular solution (all free vars = 0)\n  const x0 = new Array<number>(m).fill(0);\n  for (let r = rank - 1; r >= 0; r--) {\n    x0[pivotCol[r]] = Number((matrix[r] >> BigInt(m)) & 1n);\n  }\n\n  // Get the kernel basis vectors\n  // Each free variable gives one basis vector\n  const kernelBasis: number[][] = [];\n  for (const fc of freeCols) {\n    const vec = new Array<number>(m).fill(0);\n    vec[fc] = 1;\n    for (let r = 0; r < rank; r++) {\n      if ((matrix[r] >> BigInt(fc)) & 1n) {\n        vec[pivotCol[r]] = 1;\n      }\n    }\n    kernelBasis.push(vec);\n  }\n\n  // Now we want to find z in span(kernelBasis) over GF(2) such that x0 XOR z has minimum weight.\n  // Meet in the middle: split kernel basis into two halves.\n  const half1 = Math.floor(numFree / 2);\n  const half2 = numFree - half1;\n\n  // For first half, enumerate all 2^half1 combinations and store (resulting xor vector) -> (weight, mask)\n  // For second half, enumerate all 2^half2 combinations\n  // For each second-half combination, compute x0 XOR z1 XOR z2 and find minimum weight\n\n  // Actually, let's store the XOR with x0 for the first half\n  // Then for each second-half combination, we compute x0 XOR z_total and check weight\n\n  // Better: enumerate first half -> store the partial XOR (x0 XOR z1) as a bigint key -> best weight/lex\n  // Then enumerate second half, for each z2, compute final = partialXOR XOR z2, compute weight\n\n  // But with m=40, the vectors are 40 bits, which fits in a bigint or even number.\n  // Let's use bigints for the XOR vectors.\n\n  function vecToBigInt(v: number[]): bigint {\n    let result = 0n;\n    for (let i = 0; i < m; i++) {\n      if (v[i]) result |= 1n << BigInt(i);\n    }\n    return result;\n  }\n\n  function xorVecs(a: number[], b: number[]): number[] {\n    const result = new Array<number>(m);\n    for (let i = 0; i < m; i++) {\n      result[i] = a[i] ^ b[i];\n    }\n    return result;\n  }\n\n  function weight(v: number[]): number {\n    let w = 0;\n    for (let i = 0; i < m; i++) w += v[i];\n    return w;\n  }\n\n  // Simple enumeration for meet-in-the-middle\n  // First half\n  const firstHalfSize = 1 << half1;\n  const firstHalfVecs: number[][] = new Array(firstHalfSize);\n\n  for (let mask = 0; mask < firstHalfSize; mask++) {\n    let vec = x0.slice();\n    for (let i = 0; i < half1; i++) {\n      if (mask & (1 << i)) {\n        vec = xorVecs(vec, kernelBasis[i]);\n      }\n    }\n    firstHalfVecs[mask] = vec;\n  }\n\n  let bestWeight = m + 1;\n  let bestSolution: number[] | null = null;\n\n  const secondHalfSize = 1 << half2;\n\n  for (let mask2 = 0; mask2 < secondHalfSize; mask2++) {\n    // Compute z2\n    let z2 = new Array<number>(m).fill(0);\n    for (let i = 0; i < half2; i++) {\n      if (mask2 & (1 << i)) {\n        z2 = xorVecs(z2, kernelBasis[half1 + i]);\n      }\n    }\n\n    // For each first-half vector, XOR with z2 and check\n    for (let mask1 = 0; mask1 < firstHalfSize; mask1++) {\n      const candidate = xorVecs(firstHalfVecs[mask1], z2);\n      const w