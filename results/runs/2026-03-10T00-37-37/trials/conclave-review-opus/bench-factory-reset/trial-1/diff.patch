ght += solution[i];\n   153→    }\n   154→\n   155→    if (weight < bestWeight || (weight === bestWeight && lexSmallerToggle(solution, bestSolution!))) {\n   156→      bestWeight = weight;\n   157→      bestSolution = solution.slice();\n   158→    }\n   159→  }\n   160→\n   161→  if (bestSolution === null) return null;\n   162→\n   163→  const result: number[] = [];\n   164→  for (let i = 0; i < m; i++) {\n   165→    if (bestSolution[i]) result.push(i);\n   166→  }\n   167→  return result;\n   168→}\n   169→\n   170→function lexSmallerToggle(a: number[], b: number[]): boolean {\n   171→  // Compare by the resulting sorted sets of pressed button indices.\n   172→  // First, the set with fewer elements wins (fewer presses).\n   173→  // Among same size, compare element by element.\n   174→  const setA: number[] = [];\n   175→  const setB: number[] = [];\n   176→  for (let i = 0; i < a.length; i++) {\n   177→    if (a[i]) setA.push(i);\n   178→    if (b[i]) setB.push(i);\n   179→  }\n   180→  if (setA.length !== setB.length) return setA.length < setB.length;\n   181→  for (let i = 0; i < setA.length; i++) {\n   182→    if (setA[i] < setB[i]) return true;\n   183→    if (setA[i] > setB[i]) return false;\n   184→  }\n   185→  return false;\n   186→}\n   187→\n   188→/**\n   189→ * For cases with too many free variables, use a smarter minimum-weight approach.\n   190→ * We use BFS/DFS over free variable assignments ordered by weight.\n   191→ */\n   192→function solveToggleMinWeight(\n   193→  matrix: bigint[],\n   194→  rank: number,\n   195→  pivotCol: number[],\n   196→  freeCols: number[],\n   197→  m: number\n   198→): number[] | null {\n   199→  // For minimum weight codeword finding in a linear code over GF(2),\n   200→  // we can use the approach of iterating free variable assignments by weight.\n   201→  // But with 40 free vars this is still too many.\n   202→  //\n   203→  // Alternative: since we're looking for minimum weight solution to Ax=b over GF(2),\n   204→  // we can reformulate. The solution space is x0 + ker(A) where x0 is any particular solution.\n   205→  // We want min weight element of this coset.\n   206→  //\n   207→  // For the practical constraint (up to 40 buttons/lights), the rank is at most 40,\n   208→  // so free vars = m - rank <= 40. But typically m and n are both <= 40 and rank ~ min(m,n).\n   209→  //\n   210→  // Let's use a meet-in-the-middle approach for large free variable counts.\n   211→\n   212→  const numFree = freeCols.length;\n   213→\n   214→  if (numFree > 40) {\n   215→    // Shouldn't happen with constraints\n   216→    return null;\n   217→  }\n   218→\n   219→  // Get a particular solution (all free vars = 0)\n   220→  const x0 = new Array<number>(m).fill(0);\n   221→  for (let r = rank - 1; r >= 0; r--) {\n   222→    x0[pivotCol[r]] = Number((matrix[r] >> BigInt(m)) & 1n);\n   223→  }\n   224→\n   225→  // Get the kernel basis vectors\n   226→  // Each free variable gives one basis vector\n   227→  const kernelBasis: number[][] = [];\n   228→  for (const fc of freeCols) {\n   229→    const vec = new Array<number>(m).fill(0);\n   230→    vec[fc] = 1;\n   231→    for (let r = 0; r < rank; r++) {\n   232→      if ((matrix[r] >> BigInt(fc)) & 1n) {\n   233→        vec[pivotCol[r]] = 1;\n   234→      }\n   235→    }\n   236→    kernelBasis.push(vec);\n   237→  }\n   238→\n   239→  // Now we want to find z in span(kernelBasis) over GF(2) such that x0 XOR z has minimum weight.\n   240→  // Meet in the middle: split kernel basis into two halves.\n   241→  const half1 = Math.floor(numFree / 2);\n   242→  const half2 = numFree - half1;\n   243→\n   244→  // For first half, enumerate all 2^half1 combinations and store (resulting xor vector) -> (weight, mask)\n   245→  // For second half, enumerate all 2^half2 combinations\n   246→  // For each second-half combination, compute x0 XOR z1 XOR z2 and find minimum weight\n   247→\n   248→  // Actually, let's store the XOR with x0 for the first half\n   249→  // Then for each second-half combination, we compute x0 XOR z_total and check weight\n   250→\n   251→  // Better: enumerate first half -> store the partial XOR (x0 XOR z1) as a bigint key -> best weight/lex\n   252→  // Then enumerate second half, for each z2, compute final = partialXOR XOR z2, compute weight\n   253→\n   254→  // But with m=40, the vectors are 40 bits, which fits in a bigint or even number.\n   255→  // Let's use bigints for the XOR vectors.\n   256→\n   257→  function xorVecs(a: number[], b: number[]): number[] {\n   258→    const result = new Array<number>(m);\n   259→    for (let i = 0; i < m; i++) {\n   260→      result[i] = a[i] ^ b[i];\n   261→    }\n   262→    return result;\n   263→  }\n   264→\n   265→  function weight(v: number[]): number {\n   266→    let w = 0;\n   267→    for (let i = 0; i < m; i++) w += v[i];\n   268→    return w;\n   269→  }\n   270→\n   271→  // Simple enumeration for meet-in-the-middle\n   272→  // First half\n   273→  const firstHalfSize = 1 << half1;\n   274→  const firstHalfVecs: number[][] = new Array(firstHalfSize);\n   275→\n   276→  for (let mask = 0; mask < firstHalfSize; mask++) {\n   277→    let vec = x0.slice();\n   278→    for (let i = 0; i < half1; i++) {\n   279→      if (mask & (1 << i)) {\n   280→        vec = xorVecs(vec, kernelBasis[i]);\n   281→      }\n   282→    }\n   283→    firstHalfVecs[mask] = vec;\n   284→  }\n   285→\n   286→  let bestWeight = m + 1;\n   287→  let bestSolution: number[] | null = null;\n   288→\n   289→  const secondHalfSize = 1 << half2;\n   290→\n   291→  for (let mask2 = 0; mask2 < secondHalfSize; mask2++) {\n   292→    // Compute z2\n   293→    let z2 = new Array<number>(m).fill(0);\n   294→    for (let i = 0; i < half2; i++) {\n   295→      if (mask2 & (1 << i)) {\n   296→        z2 = xorVecs(z2, kernelBasis[half1 + i]);\n   297→      }\n   298→    }\n   299→\n   300→    // For each first-half vector, XOR with z2 and check\n   301→    for (let mask1 = 0; mask1 < firstHalfSize; mask1++) {\n   302→      const candidate = xorVecs(firstHalfVecs[mask1], z2);\n   303→      const w = weight(candidate);\n   304→      if (w < bestWeight || (w === bestWeight && lexSmallerToggle(candidate, bestSolution!))) {\n   305→        bestWeight = w;\n   306→        bestSolution = candidate;\n   307→      }\n   308→    }\n   309→  }\n   310→\n   311→  if (bestSolution === null) return null;\n   312→\n   313→  const result: number[] = [];\n   314→  for (let i = 0; i < m; i++) {\n   315→    if (bestSolution[i]) result.push(i);\n   316→  }\n   317→  return result;\n   318→}\n   319→\n   320→\n   321→/**\n   322→ * Solve a counter puzzle over GF(p) using Gaussian elimination.\n   323→ */\n   324→export function solveCounter(\n   325→  lights: number[],\n   326→  buttons: number[][],\n   327→  modulus: number\n   328→): number[] | null {\n   329→  const n = lights.length; // number of counters\n   330→  const m = buttons.length; // number of buttons\n   331→\n   332→  // Build augmented matrix over GF(modulus)\n   333→  // matrix[i][j] = number of times button j affects counter i (0 or 1)\n   334→  // matrix[i][m] = target value for counter i\n   335→  const matrix: number[][] = [];\n   336→  for (let i = 0; i < n; i++) {\n   337→    const row = new Array<number>(m + 1).fill(0);\n   338→    row[m] = lights[i] % modulus;\n   339→    matrix.push(row);\n   340→  }\n   341→\n   342→  for (let j = 0; j < m; j++) {\n   343→    for (const counterIdx of buttons[j]) {\n   344→      if (counterIdx < n) {\n   345→        matrix[counterIdx][j] = (matrix[counterIdx][j] + 1) % modulus;\n   346→      }\n   347→    }\n   348→  }\n   349→\n   350→  // Modular inverse using Fermat's little theorem (modulus is prime)\n   351→  function modInverse(a: number, p: number): number {\n   352→    return modPow(((a % p) + p) % p, p - 2, p);\n   353→  }\n   354→\n   355→  function modPow(base: number, exp: number, mod: number): number {\n   356→    let result = 1;\n   357→    base = base % mod;\n   358→    while (exp > 0) {\n   359→      if (exp & 1) result = (result * base) % mod;\n   360→      exp >>= 1;\n   361→      base = (base * base) % mod;\n   362→    }\n   363→    return result;\n   364→  }\n   365→\n   366→  // Gaussian elimination\n   367→  const pivotCol: number[] = new Array(n).fill(-1);\n   368→  let rank = 0;\n   369→\n   370→  for (let col = 0; col < m; col++) {\n   371→    // Find pivot row\n   372→    let found = -1;\n   373→    for (let row = rank; row < n; row++) {\n   374→      if (matrix[row][col] !== 0) {\n   375→        found = row;\n   376→        break;\n   377→      }\n   378→    }\n   379→    if (found === -1) continue;\n   380→\n   381→    // Swap\n   382→    [matrix[rank], matrix[found]] = [matrix[found], matrix[rank]];\n   383→\n   384→    pivotCol[rank] = col;\n   385→\n   386→    // Scale pivot row so pivot element = 1\n   387→    const inv = modInverse(matrix[rank][col], modulus);\n   388→    for (let j = 0; j <= m; j++) {\n   389→      matrix[rank][j] = (matrix[rank][j] * inv) % modulus;\n   390→    }\n   391→\n   392→    // Eliminate column from all other rows\n   393→    for (let row = 0; row < n; row++) {\n   394→      if (row !== rank && matrix[row][col] !== 0) {\n   395→        const factor = matrix[row][col];\n   396→        for (let j = 0; j <= m; j++) {\n   397→          matrix[row][j] = ((matrix[row][j] - factor * matrix[rank][j]) % modulus + modulus) % modulus;\n   398→        }\n   399→      }\n   400→    }\n   401→\n   402→    rank++;\n   403→  }\n   404→\n   405→  // Check for inconsistency\n   406→  for (let row = rank; row < n; row++) {\n   407→    if (matrix[row][m] !== 0) {\n   408→      return null;\n   409→    }\n   410→  }\n   411→\n   412→  // Identify pivot and free columns\n   413→  const pivotCols = new Set<number>();\n   414→  for (let r = 0; r < rank; r++) {\n   415→    pivotCols.add(pivotCol[r]);\n   416→  }\n   417→\n   418→  const freeCols: number[] = [];\n   419→  for (let col = 0; col < m; col++) {\n   420→    if (!pivotCols.has(col)) {\n   421→      freeCols.push(col);\n   422→    }\n   423→  }\n   424→\n   425→  const numFree = freeCols.length;\n   426→\n   427→  // For each assignment of free variables (each can be 0..modulus-1),\n   428→  // compute determined variables, find minimum total presses, then lex smallest.\n   429→\n   430→  // Total combinations = modulus^numFree. For modulus=97 and numFree=20, this is way too much.\n   431→  // We need a smarter approach for large free variable spaces.\n   432→\n   433→  // For small free variable counts, enumerate directly.\n   434→  const totalCombinations = Math.pow(modulus, numFree);\n   435→\n   436→  if (numFree === 0 || totalCombinations <= 5000000) {\n   437→    // Direct enumeration\n   438→    let bestSolution: number[] | null = null;\n   439→    let bestTotal = Infinity;\n   440→\n   441→    const freeAssignment = new Array<number>(numFree).fill(0);\n   442→\n   443→    const enumerate = (): void => {\n   444→      // Iterate through all assignments\n   445→      let done = false;\n   446→      while (!done) {\n   447→        const solution = new Array<number>(m).fill(0);\n   448→\n   449→        // Set free variables\n   450→        for (let i = 0; i < numFree; i++) {\n   451→          solution[freeCols[i]] = freeAssignment[i];\n   452→        }\n   453→\n   454→        // Compute pivot variables\n   455→        for (let r = rank - 1; r >= 0; r--) {\n   456→          const pc = pivotCol[r];\n   457→          let val = matrix[r][m];\n   458→          for (let col = 0; col < m; col++) {\n   459→            if (col !== pc) {\n   460→              val = ((val - matrix[r][col] * solution[col]) % modulus + modulus) % modulus;\n   461→            }\n   462→          }\n   463→          solution[pc] = val;\n   464→        }\n   465→\n   466→        // Compute total presses\n   467→        let total = 0;\n   468→        for (let i = 0; i < m; i++) {\n   469→          total += solution[i];\n   470→        }\n   471→\n   472→        if (total < bestTotal || (total === bestTotal && lexSmallerArr(solution, bestSolution!))) {\n   473→          bestTotal = total;\n   474→          bestSolution = solution.slice();\n   475→        }\n   476→\n   477→        // Increment assignment\n   478→        let carry = true;\n   479→        for (let i = numFree - 1; i >= 0 && carry; i--) {\n   480→          freeAssignment[i]++;\n   481→          if (freeAssignment[i] >= modulus) {\n   482→            freeAssignment[i] = 0;\n   483→          } else {\n   484→            carry = false;\n   485→          }\n   486→        }\n   487→        if (carry) done = true;\n   488→      }\n   489→    };\n   490→\n   491→    enumerate();\n   492→\n   493→    return bestSolution;\n   494→  }\n   495→\n   496→  // For larger free variable spaces, we need a different strategy.\n   497→  // Since modulus is prime and small (<=97), and we have at most 40 free variables,\n   498→  // we use a meet-in-the-middle approach.\n   499→  return solveCounterMITM(matrix, rank, pivotCol, freeCols, m, modulus);\n   500→}\n   501→\n   502→function lexSmallerArr(a: number[], b: number[]): boolean {\n   503→  for (let i = 0; i < a.length; i++) {\n   504→    if (a[i] < b[i]) return true;\n   505→    if (a[i] > b[i]) return false;\n   506→  }\n   507→  return false;\n   508→}\n   509→\n   510→function solveCounterMITM(\n   511→  matrix: number[][],\n   512→  rank: number,\n   513→  pivotCol: number[],\n   514→  freeCols: number[],\n   515→  m: number,\n   516→  modulus: number\n   517→): number[] | null {\n   518→  const numFree = freeCols.length;\n   519→\n   520→  // Compute the particular solution (all free vars = 0)\n   521→  function computeSolution(freeValues: number[]): number[] {\n   522→    const solution = new Array<number>(m).fill(0);\n   523→    for (let i = 0; i < numFree; i++) {\n   524→      solution[freeCols[i]] = freeValues[i];\n   525→    }\n   526→    for (let r = ra