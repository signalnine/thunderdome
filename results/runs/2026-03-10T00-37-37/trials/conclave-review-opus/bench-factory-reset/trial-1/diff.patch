 }\n      }\n      expect(state).toEqual(target);\n    }\n  });\n});\n\ndescribe('performance: solveCounter', () => {\n  it('should handle 40 counters and 40 buttons (identity-like) with mod 97', () => {\n    const n = 40;\n    const targets: number[] = [];\n    const buttons: number[][] = [];\n    for (let i = 0; i < n; i++) {\n      targets.push(i + 1);\n      buttons.push([i]);\n    }\n    const result = solveCounter(targets, buttons, 97);\n    expect(result).not.toBeNull();\n    expect(result).toEqual(targets);\n  });\n\n  it('should handle system with free variables and mod 5', () => {\n    // 2 counters, 5 buttons (3 free variables)\n    const result = solveCounter(\n      [3, 2],\n      [[0, 1], [0], [1], [0, 1], [0, 1]],\n      5\n    );\n    if (result !== null) {\n      expect(result.length).toBe(5);\n      // Verify solution\n      const counters = [0, 0];\n      for (let i = 0; i < 5; i++) {\n        for (const idx of [[0, 1], [0], [1], [0, 1], [0, 1]][i]) {\n          counters[idx] = (counters[idx] + result[i]) % 5;\n        }\n      }\n      expect(counters[0]).toBe(3);\n      expect(counters[1]).toBe(2);\n    }\n  });\n});","originalFile":"import { describe, it, expect } from 'vitest';\nimport { solveToggle, solveCounter } from './index.js';\n\ndescribe('solveToggle', () => {\n  it('should return null when no solution exists (example from spec)', () => {\n    const result = solveToggle({\n      target: [true, true, false, true],\n      buttons: [[0, 1], [1, 2, 3], [0, 3]],\n    });\n    expect(result).toBeNull();\n  });\n\n  it('should return empty array when target is all off', () => {\n    const result = solveToggle({\n      target: [false, false, false],\n      buttons: [[0, 1], [1, 2]],\n    });\n    expect(result).toEqual([]);\n  });\n\n  it('should solve a simple single-button case', () => {\n    const result = solveToggle({\n      target: [true, true],\n      buttons: [[0, 1]],\n    });\n    expect(result).toEqual([0]);\n  });\n\n  it('should find minimum button presses', () => {\n    // Light 0 needs to be on.\n    // Button 0 toggles [0], Button 1 toggles [0]\n    // Pressing both cancels out. Pressing one is sufficient.\n    // Minimum is 1 press. Lex smallest is [0].\n    const result = solveToggle({\n      target: [true],\n      buttons: [[0], [0]],\n    });\n    expect(result).toEqual([0]);\n  });\n\n  it('should return lex smallest among ties', () => {\n    // Both button 0 and button 1 toggle light 0 only.\n    // Either one alone solves it. Lex smallest is [0].\n    const result = solveToggle({\n      target: [true],\n      buttons: [[0], [0]],\n    });\n    expect(result).toEqual([0]);\n  });\n\n  it('should handle two buttons needed', () => {\n    // Lights: 3\n    // Target: [true, true, true]\n    // Button 0: [0, 1], Button 1: [1, 2]\n    // Press both: light 0 on, light 1 on+off=off, light 2 on => [T, F, T] - not matching\n    // Need button 2 or different buttons.\n    // Let's make a solvable case:\n    // Button 0: [0], Button 1: [1], Button 2: [2]\n    // Press all three => [T, T, T]\n    const result = solveToggle({\n      target: [true, true, true],\n      buttons: [[0], [1], [2]],\n    });\n    expect(result).toEqual([0, 1, 2]);\n  });\n\n  it('should handle overlapping toggles', () => {\n    // Target: [true, false]\n    // Button 0: [0, 1], Button 1: [1]\n    // Press both: light 0 toggled once (on), light 1 toggled twice (off) => [T, F] ✓\n    const result = solveToggle({\n      target: [true, false],\n      buttons: [[0, 1], [1]],\n    });\n    expect(result).toEqual([0, 1]);\n  });\n\n  it('should return null when target is unreachable', () => {\n    const result = solveToggle({\n      target: [true],\n      buttons: [], // no buttons\n    });\n    expect(result).toBeNull();\n  });\n\n  it('should handle no lights needed and buttons available', () => {\n    const result = solveToggle({\n      target: [false, false],\n      buttons: [[0], [1]],\n    });\n    expect(result).toEqual([]);\n  });\n\n  it('should prefer fewer presses over lex order', () => {\n    // Target: [true]\n    // Button 0: [0], Button 1: [], Button 2: [0]\n    // Solutions: [0] (1 press), [2] (1 press), [0,1,2] (3 presses - toggles light 0 twice + once=on, nope)\n    // Actually [0] and [2] both work. [0] is lex smallest.\n    const result = solveToggle({\n      target: [true],\n      buttons: [[0], [], [0]],\n    });\n    expect(result).toEqual([0]);\n  });\n\n  it('should handle larger puzzle', () => {\n    // 5 lights, 5 buttons, each button toggles one light\n    const result = solveToggle({\n      target: [true, false, true, false, true],\n      buttons: [[0], [1], [2], [3], [4]],\n    });\n    expect(result).toEqual([0, 2, 4]);\n  });\n});\n\ndescribe('solveCounter', () => {\n  it('should return all zeros when target is all zeros', () => {\n    const result = solveCounter([0, 0, 0], [[0], [1], [2]], 5);\n    expect(result).toEqual([0, 0, 0]);\n  });\n\n  it('should solve simple single button case', () => {\n    const result = solveCounter([3], [[0]], 5);\n    expect(result).toEqual([3]);\n  });\n\n  it('should return null when no solution exists', () => {\n    // No buttons affect counter 0\n    const result = solveCounter([1], [], 5);\n    expect(result).toBeNull();\n  });\n\n  it('should handle wrapping with modulus', () => {\n    // Counter 0 needs to be 1, modulus 3\n    // Button 0 affects counter 0\n    // Press 1 time => counter = 1 ✓\n    // Press 4 times => counter = 4 mod 3 = 1 ✓ but 1 press is fewer\n    const result = solveCounter([1], [[0]], 3);\n    expect(result).toEqual([1]);\n  });\n\n  it('should handle multiple buttons affecting same counter', () => {\n    // Counter 0 target = 3, mod 5\n    // Button 0 affects counter 0, Button 1 affects counter 0\n    // Minimum: press one button 3 times, or press both (1+2, 2+1, etc.)\n    // Min total presses: 3 (button 0 pressed 3 times or button 1 pressed 3 times)\n    // Lex smallest with 3 total: [0, 3] 