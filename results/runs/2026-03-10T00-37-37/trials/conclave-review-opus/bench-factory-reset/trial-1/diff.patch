+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+/**
+ * Solve a toggle puzzle over GF(2) using Gaussian elimination.
+ * Find minimum button presses, then lexicographically smallest set of indices.
+ */
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const n = target.length;
+  const m = buttons.length;
+
+  // Build augmented matrix over GF(2) using BigInt for bit operations.
+  const matrix: bigint[] = new Array(n);
+  for (let i = 0; i < n; i++) matrix[i] = 0n;
+
+  for (let j = 0; j < m; j++) {
+    for (const lightIdx of buttons[j]) {
+      if (lightIdx < n) {
+        matrix[lightIdx] |= 1n << BigInt(j);
+      }
+    }
+  }
+  for (let i = 0; i < n; i++) {
+    if (target[i]) matrix[i] |= 1n << BigInt(m);
+  }
+
+  // Gaussian elimination to RREF
+  const pivotCol: number[] = [];
+  let rank = 0;
+
+  for (let col = 0; col < m; col++) {
+    let found = -1;
+    for (let row = rank; row < n; row++) {
+      if ((matrix[row] >> BigInt(col)) & 1n) {
+        found = row;
+        break;
+      }
+    }
+    if (found === -1) continue;
+
+    [matrix[rank], matrix[found]] = [matrix[found], matrix[rank]];
+    pivotCol.push(col);
+
+    for (let row = 0; row < n; row++) {
+      if (row !== rank && ((matrix[row] >> BigInt(col)) & 1n)) {
+        matrix[row] ^= matrix[rank];
+      }
+    }
+    rank++;
+  }
+
+  // Check consistency
+  for (let row = rank; row < n; row++) {
+    if ((matrix[row] >> BigInt(m)) & 1n) return null;
+  }
+
+  // Identify free columns
+  const pivotColSet = new Set(pivotCol);
+  const freeCols: number[] = [];
+  for (let col = 0; col < m; col++) {
+    if (!pivotColSet.has(col)) freeCols.push(col);
+  }
+
+  return solveToggleEnumerate(matrix, rank, pivotCol, freeCols, m);
+}
+
+function solveToggleEnumerate(
+  matrix: bigint[],
+  rank: number,
+  pivotCol: number[],
+  freeCols: number[],
+  m: number
+): number[] {
+  const numFree = freeCols.length;
+  const mBig = BigInt(m);
+
+  // Precompute the effect of toggling each free variable on the full solution.
+  const freeEffects: bigint[] = new Array(numFree);
+  for (let i = 0; i < numFree; i++) {
+    let effect = 1n << BigInt(freeCols[i]);
+    for (let r = 0; r < rank; r++) {
+      if ((matrix[r] >> BigInt(freeCols[i])) & 1n) {
+        effect |= 1n << BigInt(pivotCol[r]);
+      }
+    }
+    freeEffects[i] = effect;
+  }
+
+  // Compute base solution (all free vars = 0)
+  let currentSol = 0n;
+  for (let r = 0; r < rank; r++) {
+    if ((matrix[r] >> mBig) & 1n) {
+      currentSol |= 1n << BigInt(pivotCol[r]);
+    }
+  }
+
+  let bestSol = currentSol;
+  let bestWeight = popcount(currentSol);
+
+  // Gray code enumeration
+  const total = 1 << numFree;
+  for (let i = 1; i < total; i++) {
+    const bit = i & (-i);
+    let bitIdx = 0;
+    let tmp = bit;
+    while (tmp > 1) { tmp >>= 1; bitIdx++; }
+
+    currentSol ^= freeEffects[bitIdx];
+    const w = popcount(currentSol);
+
+    if (w < bestWeight) {
+      bestWeight = w;
+      bestSol = currentSol;
+    } else if (w === bestWeight && isLexSmaller(currentSol, bestSol)) {
+      bestSol = currentSol;
+    }
+  }
+
+  const result: number[] = [];
+  for (let i = 0; i < m; i++) {
+    if ((bestSol >> BigInt(i)) & 1n) result.push(i);
+  }
+  return result;
+}
+
+function popcount(v: bigint): number {
+  let count = 0;
+  while (v) { v &= v - 1n; count++; }
+  return count;
+}
+
+/** Check if set a (as bigint) is lexicographically smaller than set b (as bigint). Same popcount assumed. */
+function isLexSmaller(a: bigint, b: bigint): boolean {
+  const diff = a ^ b;
+  if (!diff) return false;
+  const lowestDiff = diff & (-diff);
+  return !!(a & lowestDiff);
+}
+
+
+/**
+ * Solve a counter puzzle over GF(p) using Gaussian elimination.
+ */
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const n = lights.length;
+  const m = buttons.length;
+
+  if (m === 0) {
+    for (let i = 0; i < n; i++) {
+      if (((lights[i] % modulus) + modulus) % modulus !== 0) return null;
+    }
+    return [];
+  }
+
+  // Build augmented matrix over GF(p)
+  const matrix: number[][] = [];
+  for (let i = 0; i < n; i++) {
+    const row = new Array<number>(m + 1).fill(0);
+    row[m] = ((lights[i] % modulus) + modulus) % modulus;
+    matrix.push(row);
+  }
+
+  for (let j = 0; j < m; j++) {
+    for (const counterIdx of buttons[j]) {
+      if (counterIdx < n) {
+        matrix[counterIdx][j] = (matrix[counterIdx][j] + 1) % modulus;
+      }
+    }
+  }
+
+  // Modular arithmetic helpers
+  function modPow(base: number, exp: number, mod: number): number {
+    let result = 1;
+    base = base % mod;
+    while (exp > 0) {
+      if (exp & 1) result = (result * base) % mod;
+      exp >>= 1;
+      base = (base * base) % mod;
+    }
+    return result;
+  }
+
+  function modInverse(a: number, p: number): number {
+    return modPow(((a % p) + p) % p, p - 2, p);
+  }
+
+  // Gaussian elimination over GF(p)
+  const pivotCol: number[] = [];
+  let rank = 0;
+
+  for (let col = 0; col < m; col++) {
+    let found = -1;
+    for (let row = rank; row < n; row++) {
+      if (matrix[row][col] !== 0) {
+        found = row;
+        break;
+      }
+    }
+    if (found === -1) continue;
+
+    [matrix[rank], matrix[found]] = [matrix[found], matrix[rank]];
+    pivotCol.push(col);
+
+    const inv = modInverse(matrix[rank][col], modulus);
+    for (let j = 0; j <= m; j++) {
+      matrix[rank][j] = (matrix[rank][j] * inv) % modulus;
+    }
+
+    for (let row = 0; row < n; row++) {
+      if (row !== rank && matrix[row][col] !== 0) {
+        const factor = matrix[row][col];
+        for (let j = 0; j <= m; j++) {
+          matrix[row][j] = ((matrix[row][j] - factor * matrix[rank][j]) % modulus + modulus) % modulus;
+        }
+      }
+    }
+    rank++;
+  }
+
+  // Check consistency
+  for (let row = rank; row < n; row++) {
+    if (matrix[row][m] !== 0) return null;
+  }
+
+  // Identify free columns
+  const pivotColSet = new Set(pivotCol);
+  const freeCols: number[] = [];
+  for (let col = 0; col < m; col++) {
+    if (!pivotColSet.has(col)) freeCols.push(col);
+  }
+
+  const numFree = freeCols.length;
+
+  if (numFree === 0) {
+    return computeCounterBaseSolution(matrix, rank, pivotCol, m);
+  }
+
+  // Get kernel basis vectors for incremental updates.
+  // kernelBasis[i][j] = effect of incrementing free variable i by 1 on solution component j.
+  // For pivot variable at row r: incrementing free var i by 1 changes pivot var by -matrix[r][freeCols[i]] mod p.
+  // For free variable itself: +1.
+  const kernelBasis: number[][] = [];
+  for (const fc of freeCols) {
+    const vec = new Array<number>(m).fill(0);
+    vec[fc] = 1;
+    for (let r = 0; r < rank; r++) {
+      if (matrix[r][fc] !== 0) {
+        vec[pivotCol[r]] = (modulus - matrix[r][fc]) % modulus;
+      }
+    }
+    kernelBasis.push(vec);
+  }
+
+  // Check if enumeration is feasible
+  let totalCombinations = 1;
+  let feasible = true;
+  for (let i = 0; i < numFree; i++) {
+    totalCombinations *= modulus;
+    if (totalCombinations > 5_000_000) {
+      feasible = false;
+      break;
+    }
+  }
+
+  if (feasible) {
+    return solveCounterEnumerate(matrix, rank, pivotCol, freeCols, m, modulus, kernelBasis);
+  }
+
+  // For large free variable spaces, use coordinate descent with deterministic starts
+  return solveCounterCoordinateDescent(matrix, rank, pivotCol, freeCols, m, modulus, kernelBasis);
+}
+
+function computeCounterBaseSolution(
+  matrix: number[][],
+  rank: number,
+  pivotCol: number[],
+  m: number
+): number[] {
+  const solution = new Array<number>(m).fill(0);
+  for (let r = 0; r < rank; r++) {
+    solution[pivotCol[r]] = matrix[r][m];
+  }
+  return solution;
+}
+
+function solveCounterEnumerate(
+  matrix: number[][],
+  rank: number,
+  pivotCol: number[],
+  freeCols: number[],
+  m: number,
+  modulus: number,
+  kernelBasis: number[][]
+): number[] {
+  const numFree = freeCols.length;
+
+  // Compute base solution (all free vars = 0)
+  const baseSolution = new Array<number>(m).fill(0);
+  for (let r = 0; r < rank; r++) {
+    baseSolution[pivotCol[r]] = matrix[r][m];
+  }
+
+  // Use incremental enumeration: as we increment free variables,
+  // we add kernel basis vectors to update the solution.
+  const currentSol = baseSolution.slice();
+  let bestSolution = currentSol.slice();
+  let bestTotal = totalPresses(currentSol, m);
+
+  // Enumerate using "odometer" style with incremental updates
+  const freeVals = new Array<number>(numFree).fill(0);
+
+  // Process the base solution (already done above)
+
+  // Now iterate through remaining assignments
+  let count = 1;
+  const total = Math.pow(modulus, numFree);
+
+  while (count < total) {
+    // Increment odometer: find rightmost non-maxed digit
+    let digit = numFree - 1;
+    while (digit >= 0 && freeVals[digit] === modulus - 1) {
+      // Reset this digit to 0: subtract (modulus-1) * kernelBasis[digit] from solution
+      // which is equivalent to adding 1 * kernelBasis[digit] (since -(p-1) ≡ 1 mod p)
+      for (let j = 0; j < m; j++) {
+        currentSol[j] = (currentSol[j] + kernelBasis[digit][j]) % modulus;
+      }
+      freeVals[digit] = 0;
+      digit--;
+    }
+    if (digit < 0) break;
+
+    // Increment this digit by 1: add kernelBasis[digit] to solution
+    freeVals[digit]++;
+    for (let j = 0; j < m; j++) {
+      currentSol[j] = (currentSol[j] + kernelBasis[digit][j]) % modulus;
+    }
+
+    const t = totalPresses(currentSol, m);
+    if (t < bestTotal || (t === bestTotal && lexSmallerArr(currentSol, bestSolution))) {
+      bestTotal = t;
+      bestSolution = currentSol.slice();
+    }
+
+    count++;
+  }
+
+  return bestSolution;
+}
+
+function totalPresses(sol: number[], m: number): number {
+  let sum = 0;
+  for (let i = 0; i < m; i++) sum += sol[i];
+  return sum;
+}
+
+function lexSmallerArr(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return false;
+}
+
+function solveCounterCoordinateDescent(
+  matrix: number[][],
+  rank: number,
+  pivotCol: number[],
+  freeCols: number[],
+  m: number,
+  modulus: number,
+  kernelBasis: number[][]
+): number[] {
+  const numFree = freeCols.length;
+
+  // Particular solution (all free vars = 0)
+  const x0 = new Array<number>(m).fill(0);
+  for (let r = 0; r < rank; r++) {
+    x0[pivotCol[r]] = matrix[r][m];
+  }
+
+  function applyKernel(coeffs: number[]): number[] {
+    const sol = x0.slice();
+    for (let i = 0; i < numFree; i++) {
+      if (coeffs[i] !== 0) {
+        for (let j = 0; j < m; j++) {
+          sol[j] = (sol[j] + coeffs[i] * kernelBasis[i][j]) % modulus;
+        }
+      }
+    }
+    return sol;
+  }
+
+  // Incremental kernel application: when changing coeff[idx] from old to new,
+  // update solution in-place. delta = (newCoeff - oldCoeff + modulus) % modulus
+  function updateSolution(sol: number[], idx: number, delta: number): void {
+    if (delta === 0) return;
+    for (let j = 0; j < m; j++) {
+      sol[j] = (sol[j] + delta * kernelBasis[idx][j]) % modulus;
+    }
+  }
+
+  let bestSolution = x0.slice();
+  let bestTotal = totalPresses(bestSolution, m);
+
+  // Deterministic starting points: try all-zeros plus evenly spaced points
+  const starts: number[][] = [new Array<number>(numFree).fill(0)];
+
+  // Add deterministic systematic starts
+  for (let v = 0; v < modulus; v++) {
+    const start = new Array<number>(numFree).fill(v);
+    starts.push(start);
+  }
+
+  // Add starts that try each free variable individually at each value
+  for (let i = 0; i < Math.min(numFree, 10); i++) {
+    for (let v = 1; v < modulus; v++) {
+      const start = new Array<number>(numFree).fill(0);
+      start[i] = v;
+      starts.push(start);
+    }
+  }
+
+  for (const startCoeffs of starts) {
+    const coeffs = startCoeffs.slice();
+    const currentSol = applyKernel(coeffs);
+    let currentTotal = totalPresses(currentSol, m);
+
+    let improved = true;
+    while (improved) {
+      improved = false;
+      for (let i = 0; i < numFree; i++) {
+        const origCoeff = coeffs[i];
+        let bestCoeff = origCoeff;
+        let bestLocalTotal = currentTotal;
+
+        for (let c = 0; c < modulus; c++) {
+          if (c === origCoeff) continue;
+          const delta = (c - origCoeff + modulus) % modulus;
+          updateSolution(currentSol, i, delta);
+          coeffs[i] = c;
+
+          const t = totalPresses(currentSol, m);
+          if (t < bestLocalTotal || (t === bestLocalTotal && lexSmallerArr(currentSol, bestSolution))) {
+            bestLocalTotal = t;
+            bestCoeff = c;
+          }
+
+          // Undo
+          const undoDelta = (origCoeff - c + modulus) % modulus;
+          updateSolution(currentSol, i, undoDelta);
+          coeffs[i] = origCoeff;
+        }
+
+        if (bestCoeff !== origCoeff) {
+          const delta = (bestCoeff - origCoeff + modulus) % modulus;
+          updateSolution(currentSol, i, delta);
+          coeffs[i] = bestCoeff;
+          currentTotal = bestLocalTotal;
+          improved = true;
+        }
+      }
+    }
+
+    if (currentTotal < bestTotal || (currentTotal === bestTotal && lexSmallerArr(currentSol, bestSolution))) {
+      bestTotal = currentTotal;
+      bestSolution = currentSol.slice();
+    }
+  }
+
+  return bestSolution;
+}
