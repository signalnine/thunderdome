+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+/**
+ * Simulate a logic gate circuit given initial wire values.
+ * Process gates in dependency order until all gates have fired.
+ */
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>,
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = new Set<number>(gates.map((_, i) => i));
+
+  let progress = true;
+  while (remaining.size > 0 && progress) {
+    progress = false;
+    for (const idx of remaining) {
+      const gate = gates[idx];
+      const v1 = wires[gate.in1];
+      const v2 = wires[gate.in2];
+      if (v1 !== undefined && v2 !== undefined) {
+        let result: number;
+        switch (gate.op) {
+          case 'AND':
+            result = v1 & v2;
+            break;
+          case 'OR':
+            result = v1 | v2;
+            break;
+          case 'XOR':
+            result = v1 ^ v2;
+            break;
+        }
+        wires[gate.out] = result;
+        remaining.delete(idx);
+        progress = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+/**
+ * Find the 8 wires involved in 4 output-wire swaps in a ripple-carry adder circuit.
+ *
+ * Strategy: Walk the adder structure bit by bit, identifying and fixing swaps
+ * as we go. When we detect a structural violation, we determine which two
+ * output wires must have been swapped and record them.
+ */
+export function findSwappedWires(gates: Gate[]): string[] {
+  // Work on a copy so we don't mutate the caller's data
+  const gatesCopy: Gate[] = gates.map(g => ({ ...g }));
+
+  // Determine the number of input bits
+  let N = 0;
+  for (const gate of gatesCopy) {
+    for (const wire of [gate.in1, gate.in2]) {
+      const m = wire.match(/^x(\d+)$/);
+      if (m) {
+        const bit = parseInt(m[1], 10);
+        if (bit >= N) N = bit + 1;
+      }
+    }
+  }
+
+  // Build lookup structures
+  const gateByOutput = new Map<string, Gate>();
+  const gatesByInput = new Map<string, Gate[]>();
+  const inputKeyToGate = new Map<string, Gate>();
+
+  function rebuildMaps(): void {
+    gateByOutput.clear();
+    gatesByInput.clear();
+    inputKeyToGate.clear();
+    for (const gate of gatesCopy) {
+      gateByOutput.set(gate.out, gate);
+      const key = makeKey(gate.op, gate.in1, gate.in2);
+      inputKeyToGate.set(key, gate);
+      for (const wire of [gate.in1, gate.in2]) {
+        const list = gatesByInput.get(wire);
+        if (list) list.push(gate);
+        else gatesByInput.set(wire, [gate]);
+      }
+    }
+  }
+  rebuildMaps();
+
+  const swapped: string[] = [];
+
+  function doSwap(a: string, b: string): void {
+    swapped.push(a, b);
+    const gateA = gateByOutput.get(a)!;
+    const gateB = gateByOutput.get(b)!;
+    gateA.out = b;
+    gateB.out = a;
+    rebuildMaps();
+  }
+
+  function findGate(op: string, in1: string, in2: string): Gate | undefined {
+    return inputKeyToGate.get(makeKey(op, in1, in2));
+  }
+
+  function findGateWithOneInput(
+    op: string,
+    wire: string,
+    exclude?: Set<Gate>,
+  ): Gate | undefined {
+    const candidates = gatesByInput.get(wire);
+    if (!candidates) return undefined;
+    return candidates.find(g => g.op === op && (!exclude || !exclude.has(g)));
+  }
+
+  // Walk through each bit position to verify and fix the adder structure
+  let carry = '';
+
+  for (let i = 0; i < N; i++) {
+    const xi = `x${String(i).padStart(2, '0')}`;
+    const yi = `y${String(i).padStart(2, '0')}`;
+    const zi = `z${String(i).padStart(2, '0')}`;
+
+    if (i === 0) {
+      // Bit 0: half adder
+      // z00 = x00 XOR y00
+      const xorGate = findGate('XOR', xi, yi)!;
+      if (xorGate.out !== zi) {
+        doSwap(xorGate.out, zi);
+      }
+
+      // c00 = x00 AND y00
+      const andGate = findGate('AND', xi, yi)!;
+      carry = andGate.out;
+    } else {
+      // Bit i: full adder
+      // t_i = x_i XOR y_i
+      const xorGate = findGate('XOR', xi, yi)!;
+      let ti = xorGate.out;
+
+      // z_i = t_i XOR carry
+      let sumGate = findGate('XOR', ti, carry);
+
+      if (!sumGate) {
+        // ti or carry is wrong. Try to find the XOR gate that uses carry.
+        const excludeXor = new Set([xorGate]);
+        const xorWithCarry = findGateWithOneInput('XOR', carry, excludeXor);
+        if (xorWithCarry) {
+          // Found a XOR gate using carry; the other input should be ti
+          const otherInput = xorWithCarry.in1 === carry ? xorWithCarry.in2 : xorWithCarry.in1;
+          doSwap(ti, otherInput);
+          ti = otherInput;
+          sumGate = xorWithCarry;
+        } else {
+          // carry might be wrong; look for a XOR gate that uses ti
+          const xorWithTi = gatesByInput.get(ti)?.find(
+            g => g.op === 'XOR' && g !== xorGate,
+          );
+          if (xorWithTi) {
+            const otherInput = xorWithTi.in1 === ti ? xorWithTi.in2 : xorWithTi.in1;
+            doSwap(carry, otherInput);
+            carry = otherInput;
+            sumGate = xorWithTi;
+          }
+        }
+      }
+
+      if (sumGate && sumGate.out !== zi) {
+        doSwap(sumGate.out, zi);
+      }
+
+      // a_i = x_i AND y_i
+      const genGate = findGate('AND', xi, yi)!;
+      const ai = genGate.out;
+
+      // b_i = t_i AND carry
+      const propGate = findGate('AND', ti, carry);
+      const bi = propGate ? propGate.out : undefined;
+
+      // c_i = a_i OR b_i
+      if (bi !== undefined) {
+        const carryGate = findGate('OR', ai, bi);
+        if (carryGate) {
+          carry = carryGate.out;
+        } else {
+          // Find the OR gate that uses ai or bi
+          const orWithAi = findGateWithOneInput('OR', ai);
+          if (orWithAi) {
+            const otherInput = orWithAi.in1 === ai ? orWithAi.in2 : orWithAi.in1;
+            doSwap(bi, otherInput);
+            carry = orWithAi.out;
+          } else {
+            const orWithBi = findGateWithOneInput('OR', bi);
+            if (orWithBi) {
+              const otherInput = orWithBi.in1 === bi ? orWithBi.in2 : orWithBi.in1;
+              doSwap(ai, otherInput);
+              carry = orWithBi.out;
+            }
+          }
+        }
+      }
+    }
+  }
+
+  // Check the final carry: it should be z_N
+  const zN = `z${String(N).padStart(2, '0')}`;
+  if (carry && carry !== zN && gateByOutput.has(zN)) {
+    doSwap(carry, zN);
+  }
+
+  return [...swapped].sort();
+}
+
+function makeKey(op: string, in1: string, in2: string): string {
+  const [a, b] = in1 < in2 ? [in1, in2] : [in2, in1];
+  return `${op}:${a}:${b}`;
+}
