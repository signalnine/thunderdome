ates, 'z30', 'a30');\n    swapOutputs(gates, 'z40', 'b40');\n\n    const start = Date.now();\n    const result = findSwappedWires(gates);\n    const elapsed = Date.now() - start;\n\n    expect(result).toHaveLength(8);\n    expect(result).toEqual(\n      ['a10', 'a30', 'b20', 'b40', 'z10', 'z20', 'z30', 'z40'].sort(),\n    );\n    expect(elapsed).toBeLessThan(5000);\n  });\n\n  it('should handle randomized wire names', () => {\n    // Build a 4-bit adder with random internal wire names\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'abc' },  // c00 -> abc\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 'def' },  // t01 -> def\n      { op: 'XOR', in1: 'def', in2: 'abc', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'ghi' },  // a01 -> ghi\n      { op: 'AND', in1: 'def', in2: 'abc', out: 'jkl' },  // b01 -> jkl\n      { op: 'OR', in1: 'ghi', in2: 'jkl', out: 'mno' },   // c01 -> mno\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 'pqr' },  // t02 -> pqr\n      { op: 'XOR', in1: 'pqr', in2: 'mno', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'stu' },  // a02 -> stu\n      { op: 'AND', in1: 'pqr', in2: 'mno', out: 'vwx' },  // b02 -> vwx\n      { op: 'OR', in1: 'stu', in2: 'vwx', out: 'yza' },   // c02 -> yza\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 'yzb' },  // t03 -> yzb\n      { op: 'XOR', in1: 'yzb', in2: 'yza', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'yzc' },  // a03 -> yzc\n      { op: 'AND', in1: 'yzb', in2: 'yza', out: 'yzd' },  // b03 -> yzd\n      { op: 'OR', in1: 'yzc', in2: 'yzd', out: 'yze' },   // c03 -> yze\n    ];\n\n    // Swap z01 <-> ghi, and z03 <-> yzc, pqr <-> mno, z00 <-> abc\n    swapOutputs(gates, 'z01', 'ghi');\n    swapOutputs(gates, 'z03', 'yzc');\n    swapOutputs(gates, 'pqr', 'mno');\n    swapOutputs(gates, 'z00', 'abc');\n\n    const result = findSwappedWires(gates);\n    expect(result)