py);\n   222→  });\n   223→\n   224→  it('should handle randomized wire names', () => {\n   225→    // Build a 4-bit adder with random internal wire names\n   226→    const gates: Gate[] = [\n   227→      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n   228→      { op: 'AND', in1: 'x00', in2: 'y00', out: 'abc' },  // c00 -> abc\n   229→      { op: 'XOR', in1: 'x01', in2: 'y01', out: 'def' },  // t01 -> def\n   230→      { op: 'XOR', in1: 'def', in2: 'abc', out: 'z01' },\n   231→      { op: 'AND', in1: 'x01', in2: 'y01', out: 'ghi' },  // a01 -> ghi\n   232→      { op: 'AND', in1: 'def', in2: 'abc', out: 'jkl' },  // b01 -> jkl\n   233→      { op: 'OR', in1: 'ghi', in2: 'jkl', out: 'mno' },   // c01 -> mno\n   234→      { op: 'XOR', in1: 'x02', in2: 'y02', out: 'pqr' },  // t02 -> pqr\n   235→      { op: 'XOR', in1: 'pqr', in2: 'mno', out: 'z02' },\n   236→      { op: 'AND', in1: 'x02', in2: 'y02', out: 'stu' },  // a02 -> stu\n   237→      { op: 'AND', in1: 'pqr', in2: 'mno', out: 'vwx' },  // b02 -> vwx\n   238→      { op: 'OR', in1: 'stu', in2: 'vwx', out: 'yza' },   // c02 -> yza\n   239→      { op: 'XOR', in1: 'x03', in2: 'y03', out: 'yzb' },  // t03 -> yzb\n   240→      { op: 'XOR', in1: 'yzb', in2: 'yza', out: 'z03' },\n   241→      { op: 'AND', in1: 'x03', in2: 'y03', out: 'yzc' },  // a03 -> yzc\n   242→      { op: 'AND', in1: 'yzb', in2: 'yza', out: 'yzd' },  // b03 -> yzd\n   243→      { op: 'OR', in1: 'yzc', in2: 'yzd', out: 'yze' },   // c03 -> yze\n   244→    ];\n   245→\n   246→    // Swap z01 <-> ghi (z01 <-> a01), z03 <-> yzc (z03 <-> a03),\n   247→    // z02 <-> vwx (z02 <-> b02), z00 <-> abc (z00 <-> c00)\n   248→    swapOutputs(gates, 'z01', 'ghi');\n   249→    swapOutputs(gates, 'z03', 'yzc');\n   250→    swapOutputs(gates, 'z02', 'vwx');\n   251→    swapOutputs(gates, 'z00', 'abc');\n   252→\n   253→    const result = findSwappedWires(gates);\n   254→    expect(result).toHaveLength(8);\n   255→    expect(result).toEqual(\n   256→      ['ab