('should evaluate XOR gate', () => {\n    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toMatchObject({ c: 0 });\n    expect(simulate(gates, { a: 1, b: 0 })).toMatchObject({ c: 1 });\n    expect(simulate(gates, { a: 0, b: 1 })).toMatchObject({ c: 1 });\n    expect(simulate(gates, { a: 0, b: 0 })).toMatchObject({ c: 0 });\n  });\n\n  it('should handle chained gates in dependency order', () => {\n    const gates: Gate[] = [\n      { op: 'AND', in1: 'a', in2: 'b', out: 'mid' },\n      { op: 'OR', in1: 'mid', in2: 'c', out: 'result' },\n    ];\n    expect(simulate(gates, { a: 0, b: 0, c: 0 })).toMatchObject({ result: 0 });\n    expect(simulate(gates, { a: 1, b: 1, c: 0 })).toMatchObject({ result: 1 });\n    expect(simulate(gates, { a: 0, b: 0, c: 1 })).toMatchObject({ result: 1 });\n  });\n\n  it('should return all wire values including inputs', () => {\n    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n    const result = simulate(gates, { a: 1, b: 0 });\n    expect(result).toEqual({ a: 1, b: 0, c: 0 });\n  });\n\n  it('should simulate a correct 4-bit adder: 3 + 5 = 8', () => {\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n      { op: 'OR', in1: 'a03', in2: 'b03', out: 'c03' },\n    ];\n\n    // 3 = 0011, 5 = 0101  -> 8 = 01000\n    const inputs: Record<string, number> = {\n      x00: 1, x01: 1, x02: 0, x03: 0,\n      y00: 1, y01: 0, y02: 1, y03: 0,\n    };\n\n    const result = simulate(gates, inputs);\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(0);\n    expect(result.z02).toBe(0);\n    expect(result.z03).toBe(1);\n  });\n\n  it('should handle gates in any order (reverse dependency)', () => {\n    const gates: Gate[] = [\n      { op: 'OR', in1: 'mid', in2: 'c', out: 'result' },\n      { op: 'AND', in1: 'a', in2: 'b', out: 'mid' },\n    ];\n    const result = simulate(gates, { a: 1, b: 1, c: 0 });\n    expect(result.result).toBe(1);\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  function makeAdder(bits: number): Gate[] {\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n    ];\n    for (let i = 1; i < bits; i++) {\n      const ii = String(i).padStart(2, '0');\n      const pi = String(i - 1).padStart(2, '0');\n      gates.push(\n        { op: 'XOR', in1: `x${ii}`, in2: `y${ii}`, out: `t${ii}` },\n        { op: 'XOR', in1: `t${ii}`, in2: `c${pi}`, out: `z${ii}` },\n        { op: 'AND', in1: `x${ii}`, in2: `y${ii}`, out: `a${ii}` },\n        { op: 'AND', in1: `t${ii}`, in2: `c${pi}`, out: `b${ii}` },\n        { op: 'OR', in1: `a${ii}`, in2: `b${ii}`, out: `c${ii}` },\n      );\n    }\n    return gates;\n  }\n\n  function swapOutputs(gates: Gate[], wire1: string, wire2: string): void {\n    const g1 = gates.find(g => g.out === wire1)!;\n    const g2 = gates.find(g => g.out === wire2)!;\n    g1.out = wire2;\n    g2.out = wire1;\n  }\n\n  it('should find swaps: z output swapped with internal wires', () => {\n    const gates = makeAdder(8);\n\n    // Swap z wires with generate/propagate wires at different bit levels\n    swapOutputs(gates, 'z01', 'a01');\n    swapOutputs(gates, 'z03', 'b03');\n    swapOutputs(gates, 'z05', 'a05');\n    swapOutputs(gates, 'z07', 'b07');\n\n    const result = findSwappedWires(gates);\n    expect(result).toHaveLength(8);\n    expect(result).toEqual(\n      ['a01', 'a05', 'b03', 'b07', 'z01', 'z03', 'z05', 'z07'].sort(),\n    );\n  });\n\n  it('should find swaps: carry swapped across non-adjacent levels', () => {\n    const gates = makeAdder(8);\n\n    // Swap carry with wire at a different (non-adjacent) level\n    swapOutputs(gates, 'c01', 'a03');\n    swapOutputs(gates, 'c04', 'b06');\n    swapOutputs(gates, 'z02', 'b02');\n    swapOutputs(gates, 'z07', 'a07');\n\n    const result = findSwappedWires(gates);\n    expect(result).toHaveLength(8);\n    expect(result).toEqual(\n      ['a03', 'a07', 'b02', 'b06', 'c01', 'c04', 'z02', 'z07'].sort(),\n    );\n  });\n\n  it('should return sorted wire names', () => {\n    const gates = makeAdder(8);\n    swapOutputs(gates, 'z01', 'a01');\n    swapOutputs(gates, 'z02', 'a02');\n    swapOutputs(gates, 'z03', 'a03');\n    swapOutputs(gates, 'z04', 'a04');\n\n    const result = findSwappedWires(gates);\n    const sorted = [...result].sort();\n    expect(result).toEqual(sorted);\n  });\n\n  it('should handle 45-bit adder within time limit', () => {\n    const gates = makeAdder(45);\n\n    swapOutputs(gates, 'z10', 'a10');\n    swapOutputs(gates, 'z20', 'b20');\n    swapOutputs(gates, 'z30', 'a30');\n    swapOutputs(gates, 'z40', 'b40');\n\n    const start = Date.now();\n    const result = findSwappedWires(gates);\n    const elapsed = Date.now() - start;\n\n    expect(result).toHaveLength(8);\n    expect(result).toEqual(\n      ['a10', 'a30', 'b20', 'b40', 'z10', 'z20', 'z30', 'z40'].sort(),\n    );\n    expect(elapsed).toBeLessThan(5000);\n  });\n\n  it('should handle swaps involving carry output', () => {\n    const gates = makeAdder(8);\n\n    // Swap carry with z wire, and other cross-level swaps\n    swapOutputs(gates, 'c02', 'z05');\n    swapOutputs(gates, 'c05', 'z07');\n    swapOutputs(gates, 'z01', 'a01');\n    swapOutputs(gates, 'z03', 'b03');\n\n    const result = findSwappedWires(gates);\n    expect(result).toHaveLength(8);\n    expect(result).toEqual(\n      ['a01', 'b03', 'c02', 'c05', 'z01', 'z03', 'z05', 'z07'].sort(),\n    );\n  });\n\n  it('should handle swaps between generate and carry at different levels', () => {\n    const gates = makeAdder(8);\n\n    // generate at level 2 swapped with carry at level 4\n    swapOutputs(gates, 'a02', 'c04');\n    // z wire swaps\n    swapOutputs(gates, 'z01', 'b01');\n    swapOutputs(gates, 'z03', 'a03');\n    swapOutputs(gates, 'z06', 'b06');\n\n    const result = findSwappedWires(gates);\n    expect(result).toHaveLength(8);\n    expect(result).toEqual(\n      ['a02', 'a03', 'b01', 'b06', 'c04', 'z01', 'z03', 'z06'].sort(),\n    );\n  });\n\n  it('should not mutate the original gates array', () => {\n    const gates = makeAdder(8);\n    swapOutputs(gates, 'z01', 'a01');\n    swapOutputs(gates, 'z03', 'b03');\n    swapOutputs(gates, 'z05', 'a05');\n    swapOutputs(gates, 'z07', 'b07');\n\n    const gatesCopy = JSON.parse(JSON.stringify(gates));\n    findSwappedWires(gates);\n    expect(gates).toEqual(gatesCopy);\n  });\n\n  it('should handle randomized wire names', () => {\n    // Build a 4-bit adder with random internal wire names\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'abc' },  // c00 -> abc\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 'def' },  // t01 -> def\n      { op: 'XOR', in1: 'def', in2: 'abc', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'ghi' },  // a01 -> ghi\n      { op: 'AND', in1: 'def', in2: 'abc', out: 'jkl' },  // b01 -> jkl\n      { op: 'OR', in1: 'ghi', in2: 'jkl', out: 'mno' },   // c01 -> mno\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 'pqr' },  // t02 -> pqr\n      { op: 'XOR', in1: 'pqr', in2: 'mno', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'stu' },  // a02 -> stu\n      { op: 'AND', in1: 'pqr', in2: 'mno', out: 'vwx' },  // b02 -> vwx\n      { op: 'OR', in1: 'stu', in2: 'vwx', out: 'yza' },   // c02 -> yza\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 'yzb' },  // t03 -> yzb\n      { op: 'XOR', in1: 'yzb', in2: 'yza', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'yzc' },  // a03 -> yzc\n      { op: 'AND', in1: 'yzb', in2: 'yza', out: 'yzd' },  // b03 -> yzd\n      { op: 'OR', in1: 'yzc', in2: 'yzd', out: 'yze' },   // c03 -> yze\n    ];\n\n    // Swap z01 <-> ghi (z01 <-> a01), z03 <-> yzc (z03 <-> a03),\n    // z02 <-> vwx (z02 <-> b02), z00 <-> abc (z00 <-> c00)\n    swapOutputs(gates, 'z01', 'ghi');\n    swapOutputs(gates, 'z03', 'yzc');\n    swapOutputs(gates, 'z02', 'vwx');\n    swapOutputs(gates, 'z00', 'abc');\n\n    const result = findSwappedWires(gates);\n    expect(result).toHaveLength(8);\n    expect(result).toEqual(\n      ['abc', 'ghi', 'vwx', 'yzc', 'z00', 'z01', 'z02', 'z03'].sort(),\n    );\n  });\n});\n","structuredPatch":[{"oldStart":209,"oldLines":6,"newStart":209,"newLines":21,"lines":["     );","   });"," ","+  it('should handle bit-0 carry swap', () => {","+    const gates = makeAdder(8);","+    // Swap the initial carry c00 with z03","+    swapOutputs(gates, 'c00', 'z03');","+    swapOutputs(gates, 'z01', 'a01');","+    swapOutputs(gates, 'z05', 'b05');","+    swapOutputs(gates, 'z07', 'a07');","+","+    const result = findSwappedWires(gates);","+    expect(result).toHaveLength(8);","+    expect(result).toEqual(","+      ['a01', 'a07', 'b05', 'c00', 'z01', 'z03', 'z05', 'z07'].sort(),","+    );","+  });","+","   it('should not mutate the original gates array', () => {","     const gates = makeAdder(8);","     swapOutputs(gates, 'z01', 'a01');"]}],"userModified":false,"replaceAll":fals