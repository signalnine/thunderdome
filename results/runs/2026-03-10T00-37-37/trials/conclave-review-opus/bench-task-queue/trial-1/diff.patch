pTask.id, 'err');\n\n    // Even though dep failed, dependent should be unblockable\n    // (the dep ends up in DLQ with dead-letter status, or failed/cancelled)\n    // We need to check if failed deps unblock dependents.\n    // Let's check: after fail, dep gets retried (attempt 1 of 3)\n    // We need to fail it enough times or use maxRetries: 0\n  });\n\n  it('should unblock on failed dependency (maxRetries 0)', () => {\n    const dep = queue.addTask('dependency', { maxRetries: 0 });\n    queue.addTask('dependent', { dependencies: [dep.id] });\n\n    const depTask = queue.getNextTask()!;\n    queue.failTask(depTask.id, 'err');\n\n    // dep is now dead-lettered; dependent should be unblocked\n    // Actually dead-letter status isn't in our check. Let's verify\n  });\n\n  it('should unblock on cancelled dependency', () => {\n    const dep = queue.addTask('dependency');\n    queue.addTask('dependent', { dependencies: [dep.id] });\n\n    queue.cancelTask(dep.id);\n\n    const next = queue.getNextTask();\n    expect(next?.data).toBe('dependent');\n  });\n\n  it('should inspect dependency status', () => {\n    const dep1 = queue.addTask('dep1');\n    const dep2 = queue.addTask('dep2');\n    const task = queue.addTask('main', { dependencies: [dep1.id, dep2.id] });\n\n    const deps = queue.getTaskDependencies(task.id);\n    expect(deps.length).toBe(2);\n    expect(deps[0].status).toBe('pending');\n    expect(deps[1].status).toBe('pending');\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":999,"cache_read_input_tokens":34773,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":999},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"8096ee20-9eeb-4a71-bc2c-e8bc6c545d6f","uuid":"8fab0097-76fd-4dcc-b90f-50ae79299f3c"}
