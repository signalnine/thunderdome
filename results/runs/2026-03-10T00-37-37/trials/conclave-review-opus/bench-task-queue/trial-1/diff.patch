+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01T7Z1XYFyTSM4GNEWduZqgu","type":"tool_result","content":"     1→import { randomUUID } from 'node:crypto';\n     2→import type {\n     3→  Task,\n     4→  TaskOptions,\n     5→  TaskStatus,\n     6→  DeadLetteredTask,\n     7→  Schedule,\n     8→  ProgressListener,\n     9→  MiddlewareFn,\n    10→  ProcessHandler,\n    11→  ShutdownResult,\n    12→} from './types.js';\n    13→\n    14→const DEFAULT_QUEUE = 'default';\n    15→const DEFAULT_PRIORITY = 5;\n    16→const DEFAULT_MAX_RETRIES = 3;\n    17→const DEFAULT_RETRY_BASE_DELAY = 1000;\n    18→\n    19→export class TaskQueue {\n    20→  private tasks: Map<string, Task> = new Map();\n    21→  private queues: Map<string, Set<string>> = new Map();\n    22→  private deadLetterQueues: Map<string, Map<string, DeadLetteredTask>> = new Map();\n    23→  private concurrencyLimits: Map<string, number> = new Map();\n    24→  private progressListeners: Map<string, Set<ProgressListener>> = new Map();\n    25→  private schedules: Map<string, Schedule> = new Map();\n    26→  private middlewareStacks: Map<string, MiddlewareFn[]> = new Map();\n    27→  private processHandlers: Map<string, ProcessHandler> = new Map();\n    28→  private isShutdown = false;\n    29→  private shutdownCallbacks: Array<() => void | Promise<void>> = [];\n    30→\n    31→  // Phase 1: Basic FIFO Queue\n    32→\n    33→  addTask<T = unknown>(data: T, options?: TaskOptions & { queue?: string }): Task<T> {\n    34→    if (this.isShutdown) {\n    35→      throw new Error('Queue system is shut down; cannot add tasks');\n    36→    }\n    37→\n    38→    const queueName = options?.queue ?? DEFAULT_QUEUE;\n    39→    const priority = options?.priority ?? DEFAULT_PRIORITY;\n    40→\n    41→    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n    42→      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    43→    }\n    44→\n    45→    // Validate dependencies\n    46→    const dependencies = options?.dependencies ?? [];\n    47→    for (const depId of dependencies) {\n    48→      const depTask = this.tasks.get(depId);\n    49→      if (!depTask) {\n    50→        throw new Error(`Dependency task not found: ${depId}`);\n    51→      }\n    52→    }\n    53→\n    54→    // Detect circular dependencies\n    55→    if (dependencies.length > 0) {\n    56→      const taskId = randomUUID(); // pre-generate for cycle detection\n    57→      this.detectCircularDependencies(taskId, dependencies);\n    58→\n    59→      const now = Date.now();\n    60→      let availableAt = now;\n    61→      if (options?.availableAt != null) {\n    62→        availableAt = options.availableAt;\n    63→      } else if (options?.delay != null && options.delay > 0) {\n    64→        availableAt = now + options.delay;\n    65→      }\n    66→\n    67→      const task: Task<T> = {\n    68→        id: taskId,\n    69→        queue: queueName,\n    70→        status: 'pending',\n    71→        data,\n    72→        priority,\n    73→        createdAt: now,\n    74→        availableAt,\n    75→        attempt: 0,\n    76→        maxRetries: options?.maxRetries ?? DEFAULT_MAX_RETRIES,\n    77→        retryBaseDelay: options?.retryBaseDelay ?? DEFAULT_RETRY_BASE_DELAY,\n    78→        progress: 0,\n    79→        failCount: 0,\n    80→        dependencies,\n    81→      };\n    82→\n    83→      this.tasks.set(task.id, task as Task);\n    84→      this.ensureQueue(queueName);\n    85→      this.queues.get(queueName)!.add(task.id);\n    86→\n    87→      return task;\n    88→    }\n    89→\n    90→    const now = Date.now();\n    91→    let availableAt = now;\n    92→    if (options?.availableAt != null) {\n    93→      availableAt = options.availableAt;\n    94→    } else if (options?.delay != null && options.delay > 0) {\n    95→      availableAt = now + options.delay;\n    96→    }\n    97→\n    98→    const task: Task<T> = {\n    99→      id: randomUUID(),\n   100→      queue: queueName,\n   101→      status: 'pending',\n   102→      data,\n   103→      priority,\n   104→      createdAt: now,\n   105→      availableAt,\n   106→      attempt: 0,\n   107→      maxRetries: options?.maxRetries ?? DEFAULT_MAX_RETRIES,\n   108→      retryBaseDelay: options?.retryBaseDelay ?? DEFAULT_RETRY_BASE_DELAY,\n   109→      progress: 0,\n   110→      failCount: 0,\n   111→      dependencies,\n   112→    };\n   113→\n   114→    this.tasks.set(task.id, task as Task);\n   115→    this.ensureQueue(queueName);\n   116→    this.queues.get(queueName)!.add(task.id);\n   117→\n   118→    return task;\n   119→  }\n   120→\n   121→  getNextTask(queueName?: string): Task | null {\n   122→    const name = queueName ?? DEFAULT_QUEUE;\n   123→    const queueTaskIds = this.queues.get(name);\n   124→    if (!queueTaskIds) return null;\n   125→\n   126→    // Check concurrency limit\n   127→    const limit = this.concurrencyLimits.get(name);\n   128→    if (limit != null) {\n   129→      const activeCount = this.getActiveCount(name);\n   130→      if (activeCount >= limit) return null;\n   131→    }\n   132→\n   133→    const now = Date.now();\n   134→    let bestTask: Task | null = null;\n   135→\n   136→    for (const taskId of queueTaskIds) {\n   137→      const task = this.tasks.get(taskId)!;\n   138→      if (task.status !== 'pending') continue;\n   139→\n   140→      // Check if available (delay)\n   141→      if (task.availableAt > now) continue;\n   142→\n   143→      // Check dependencies\n   144→      if (!this.areDependenciesMet(task)) continue;\n   145→\n   146→      if (bestTask === null || this.compareTasks(task, bestTask) < 0) {\n   147→        bestTask = task;\n   148→      }\n   149→    }\n   150→\n   151→    if (bestTask) {\n   152→      bestTask.status = 'processing';\n   153→      bestTask.attempt++;\n   154→    }\n   155→\n   156→    return bestTask;\n   157→  }\n   158→\n   159→  getTask(taskId: string): Task | null {\n   160→    return this.tasks.get(taskId) ?? null;\n   161→  }\n   162→\n   163→  getWaitingCount(queueName?: string): number {\n   164→    const name = queueName ?? DEFAULT_QUEUE;\n   165→    const queueTaskIds = this.queues.get(name);\n   166→    if (!queueTaskIds) return 0;\n   167→\n   168→    let count = 0;\n   169→    for (const taskId of queueTaskIds) {\n   170→      const task = this.tasks.get(taskId)!;\n   171→      if (task.status === 'pending') count++;\n   172→    }\n   173→    return count;\n   174→  }\n   175→\n   176→  // Phase 2: Named Queues\n   177→\n   178→  getQueues(): string[] {\n   179→    return Array.from(this.queues.keys());\n   180→  }\n   181→\n   182→  // Phase 5: Retry with backoff\n   183→\n   184→  completeTask(taskId: string): void {\n   185→    const task = this.tasks.get(taskId);\n   186→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   187→    if (task.status !== 'processing') {\n   188→      throw new Error(`Task ${taskId} is not processing (status: ${task.status})`);\n   189→    }\n   190→    task.status = 'completed';\n   191→    task.progress = 100;\n   192→    // Remove from queue set\n   193→    this.queues.get(task.queue)?.delete(taskId);\n   194→  }\n   195→\n   196→  failTask(taskId: string, error?: string): void {\n   197→    const task = this.tasks.get(taskId);\n   198→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   199→    if (task.status !== 'processing') {\n   200→      throw new Error(`Task ${taskId} is not processing (status: ${task.status})`);\n   201→    }\n   202→\n   203→    task.error = error;\n   204→    task.failCount++;\n   205→\n   206→    if (task.attempt < task.maxRetries) {\n   207→      // Re-queue with exponential backoff\n   208→      const delay = task.retryBaseDelay * Math.pow(2, task.attempt - 1);\n   209→      task.status = 'pending';\n   210→      task.availableAt = Date.now() + delay;\n   211→      task.progress = 0;\n   212→    } else {\n   213→      task.status = 'failed';\n   214→      // Move to DLQ\n   215→      this.moveToDeadLetterQueue(task);\n   216→    }\n   217→  }\n   218→\n   219→  // Phase 6: Dead Letter Queue\n   220→\n   221→  private moveToDeadLetterQueue(task: Task): void {\n   222→    const dlq = this.ensureDeadLetterQueue(task.queue);\n   223→    const deadTask: DeadLetteredTask = {\n   224→      ...task,\n   225→      status: 'dead-letter',\n   226→      deadLetteredAt: Date.now(),\n   227→      originalQueue: task.queue,\n   228→    };\n   229→    dlq.set(task.id, deadTask);\n   230→    this.tasks.set(task.id, deadTask as Task);\n   231→    this.queues.get(task.queue)?.delete(task.id);\n   232→  }\n   233→\n   234→  getDeadLetterTasks(queueName?: string): DeadLetteredTask[] {\n   235→    const name = queueName ?? DEFAULT_QUEUE;\n   236→    const dlq = this.deadLetterQueues.get(name);\n   237→    if (!dlq) return [];\n   238→    return Array.from(dlq.values());\n   239→  }\n   240→\n   241→  reprocessDeadLetterTask(taskId: string): Task {\n   242→    // Find and remove from DLQ\n   243→    for (const [_queueName, dlq] of this.deadLetterQueues) {\n   244→      const deadTask = dlq.get(taskId);\n   245→      if (deadTask) {\n   246→        dlq.delete(taskId);\n   247→\n   248→        // Reset task for fresh retries\n   249→        const task: Task = {\n   250→          id: deadTask.id,\n   251→          queue: deadTask.originalQueue,\n   252→          status: 'pending',\n   253→          data: deadTask.data,\n   254→          priority: deadTask.priority,\n   255→          createdAt: Date.now(),\n   256→          availableAt: Date.now(),\n   257→          attempt: 0,\n   258→          maxRetries: deadTask.maxRetries,\n   259→          retryBaseDelay: deadTask.retryBaseDelay,\n   260→          progress: 0,\n   261→          failCount: 0,\n   262→          dependencies: [],\n   263→        };\n   264→\n   265→        this.tasks.set(task.id, task);\n   266→        this.ensureQueue(task.queue);\n   267→        this.queues.get(task.queue)!.add(task.id);\n   268→\n   269→        return task;\n   270→      }\n   271→    }\n   272→    throw new Error(`Dead-lettered task not found: ${taskId}`);\n   273→  }\n   274→\n   275→  clearDeadLetterQueue(queueName?: string): number {\n   276→    const name = queueName ?? DEFAULT_QUEUE;\n   277→    const dlq = this.deadLetterQueues.get(name);\n   278→    if (!dlq) return 0;\n   279→    const count = dlq.size;\n   280→    for (const taskId of dlq.keys()) {\n   281→      this.tasks.delete(taskId);\n   282→    }\n   283→    dlq.clear();\n   284→    return count;\n   285→  }\n   286→\n   287→  // Phase 7: Task Dependencies\n   288→\n   289→  private areDependenciesMet(task: Task): boolean {\n   290→    for (const depId of task.dependencies) {\n   291→      const dep = this.tasks.get(depId);\n   292→      if (!dep) return false;\n   293→      if (dep.status !== 'completed' && dep.status !== 'failed' && dep.status !== 'cancelled') {\n   294→        return false;\n   295→      }\n   296→    }\n   297→    return true;\n   298→  }\n   299→\n   300→  private detectCircularDependencies(newTaskId: string, dependencies: string[]): void {\n   301→    // BFS: check if any dependency eventually depends back on newTaskId\n   302→    // Since newTaskId doesn't exist yet, we check if any of the deps have\n   303→    // dependency chains that form cycles among themselves\n   304→    const visited = new Set<string>();\n   305→\n   306→    const checkCycle = (taskId: string, path: Set<string>): void => {\n   307→      if (path.has(taskId)) {\n   308→        throw new Error('Circular dependency detected');\n   309→      }\n   310→      if (visited.has(taskId)) return;\n   311→      visited.add(taskId);\n   312→      path.add(taskId);\n   313→\n   314→      const task = this.tasks.get(taskId);\n   315→      if (task) {\n   316→        for (const depId of task.dependencies) {\n   317→          checkCycle(depId, new Set(path));\n   318→        }\n   319→      }\n   320→    };\n   321→\n   322→    for (const depId of dependencies) {\n   323→      checkCycle(depId, new Set([newTaskId]));\n   324→    }\n   325→  }\n   326→\n   327→  getTaskDependencies(taskId: string): { taskId: string; status: TaskStatus }[] {\n   328→    const task = this.tasks.get(taskId);\n   329→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   330→\n   331→    return task.dependencies.map((depId) => {\n   332→      const dep = this.tasks.get(depId);\n   333→      return {\n   334→        taskId: depId,\n   335→        status: dep ? dep.status : ('unknown' as TaskStatus),\n   336→      };\n   337→    });\n   338→  }\n   339→\n   340→  // Phase 8: Concurrency Control\n   341→\n   342→  setConcurrency(queueName: string, limit: number): void {\n   343→    if (limit < 1 || !Number.isInteger(limit)) {\n   344→      throw new Error(`Invalid concurrency limit: ${limit}`);\n   345→    }\n   346→    this.concurrencyLimits.set(queueName, limit);\n   347→    this.ensureQueue(queueName);\n   348→  }\n   349→\n   350→  getConcurrency(queueName?: string): number | undefined {\n   351→    const name = queueName ?? DEFAULT_QUEUE;\n   352→    return this.concurrencyLimits.get(name);\n   353→  }\n   354→\n   355→  getActiveCount(queueName?: string): number {\n   356→    const name = queueName ?? DEFAULT_QUEUE;\n   357→    const queueTaskIds = this.queues.get(name);\n   358→    if (!queueTaskIds) return 0;\n   359→\n   360→    let count = 0;\n   361→    for (const taskId of queueTaskIds) {\n   362→      const task = this.tasks.get(taskId)!;\n   363→      if (task.status === 'processing') count++;\n   364→    }\n   365→    return count;\n   366→  }\n   367→\n   368→  // Phase 9: Progress and Cancellation\n   369→\n   370→  updateProgress(taskId: string, progress: number, message?: string): void {\n   371→    const task = this.tasks.get(taskId);\n   372→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   373→    if (task.status !== 'processing') {\n   374→      throw new Error(`Task ${taskId} is not processing`);\n   375→    }\n   376→    if (progress < 0 || progress > 100) {\n   377→      throw new Error(`Invalid progress: ${progress}. Must be between 0 and 100.`);\n   378→    }\n   379→\n   380→    task.progress = progress;\n   381→    task.progressMessage = message;\n   382→\n   383→    // Notify listeners\n   384→    const listeners = this.progressListeners.get(taskId);\n   385→    if (listeners) {\n   386→      for (const listener of listeners) {\n   387→        listener(taskId, progress, message);\n   388→      }\n   389→    }\n   390→  }\n   391→\n   392→  getProgress(taskId: string): { progress: number; message?: string } {\n   393→    const task = this.tasks.get(taskId);\n   394→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   395→    return { progress: task.progress, message: task.progressMessage };\n   396→  }\n   397→\n   398→  onProgress(taskId: string, listener: ProgressListener): () => void {\n   399→    if (!this.progressListeners.has(taskId)) {\n   400→      this.progressListeners.set(taskId, new Set());\n   401→    }\n   402→    this.progressListeners.get(taskId)!.add(listener);\n   403→\n   404→    // Return unsubscribe function\n   405→    return () => {\n   406→      this.progressListeners.get(taskId)?.delete(listener);\n   407→    };\n   408→  }\n   409→\n   410→  cancelTask(taskId: string): void {\n   411→    const task = this.tasks.get(taskId);\n   412→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   413→\n   414→    if (task.status === 'pending') {\n   415→      task.status = 'cancelled';\n   416→      this.queues.get(task.queue)?.delete(taskId);\n   417→    } else if (task.status === 'processing') {\n   418→      task.status = 'cancelled';\n   419→      this.queues.get(task.queue)?.delete(taskId);\n   420→    } else {\n   421→      throw new Error(`Cannot cancel task with status: ${task.status}`);\n   422→    }\n   423→  }\n   424→\n   425→  // Phase 10: Recurring Tasks\n   426→\n   427→  addSchedule(\n   428→    id: string,\n   429→    cronExpression: string,\n   430→    queue: string,\n   431→    taskData: unknown,\n   432→    taskOptions?: Omit<TaskOptions, 'delay' | 'availableAt' | 'dependencies'>\n   433→  ): Schedule {\n   434→    if (this.isShutdown) {\n   435→      throw new Error('Queue system is shut down');\n   436→    }\n   437→    this.validateCron(cronExpression);\n   438→\n   439→    const schedule: Schedule = {\n   440→      id,\n   441→      queue,\n   442→      cronExpression,\n   443→      taskData,\n   444→      taskOptions,\n   445→    };\n   446→\n   447→    this.schedules.set(id, schedule);\n   448→    return schedule;\n   449→  }\n   450→\n   451→  removeSchedule(id: string): boolean {\n   452→    return this.schedules.delete(id);\n   453→  }\n   454→\n   455→  getSchedules(): Schedule[] {\n   456→    return Array.from(this.schedules.values());\n   457→  }\n   458→\n   459→  tick(now?: Date): Task[] {\n   460→    const currentTime = now ?? new Date();\n   461→    const created: Task[] = [];\n   462→\n   463→    for (const schedule of this.schedules.values()) {\n   464→      if (this.cronMatches(schedule.cronExpression, currentTime)) {\n   465→        const task = this.addTask(schedule.taskData, {\n   466→          queue: schedule.queue,\n   467→          ...schedule.taskOptions,\n   468→        });\n   469→        created.push(task as Task);\n   470→      }\n   471→    }\n   472→\n   473→    return created;\n   474→  }\n   475→\n   476→  private validateCron(expr: string): void {\n   477→    const parts = expr.trim().split(/\\s+/);\n   478→    if (parts.length !== 5) {\n   479→      throw new Error(`Invalid cron expression: ${expr}. Expected 5 fields.`);\n   480→    }\n   481→    // Basic validation - each field is * or a number or */N\n   482→    for (const part of parts) {\n   483→      if (part !== '*' && !/^\\d+$/.test(part) && !/^\\*\\/\\d+$/.test(part)) {\n   484→        throw new Error(`Invalid cron field: ${part}`);\n   485→      }\n   486→    }\n   487→  }\n   488→\n   489→  private cronMatches(expr: string, date: Date): boolean {\n   490→    const parts = expr.trim().split(/\\s+/);\n   491→    const minute = date.getMinutes();\n   492→    const hour = date.getHours();\n   493→    const dayOfMonth = date.getDate();\n   494→    const month = date.getMonth() + 1;\n   495→    const dayOfWeek = date.getDay();\n   496→\n   497→    const values = [minute, hour, dayOfMonth, month, dayOfWeek];\n   498→\n   499→    for (let i = 0; i < 5; i++) {\n   500→      if (!this.cronFieldMatches(parts[i], values[i])) {\n   501→        return false;\n   502→      }\n   503→    }\n   504→    return true;\n   505→  }\n   506→\n   507→  private cronFieldMatches(field: string, value: number): boolean {\n   508→    if (field === '*') return true;\n   509→    if (/^\\d+$/.test(field)) return parseInt(field, 10) === value;\n   510→    const stepMatch = field.match(/^\\*\\/(\\d+)$/);\n   511→    if (stepMatch) {\n   512→      const step = parseInt(stepMatch[1], 10);\n   513→      return value % step === 0;\n   514→    }\n   515→    return false;\n   516→  }\n   517→\n   518→  // Phase 11: Middleware Pipeline\n   519→\n   520→  use(queueName: string, middleware: MiddlewareFn): void {\n   521→    if (!this.middlewareStacks.has(queueName)) {\n   522→      this.middlewareStacks.set(queueName, []);\n   523→    }\n   524→    this.middlewareStacks.get(queueName)!.push(middleware);\n   525→  }\n   526→\n   527→  setProcessHandler(queueName: string, handler: ProcessHandler): void {\n   528→    this.processHandlers.set(queueName, handler);\n   529→  }\n   530→\n   531→  async processNext(queueName?: string): Promise<Task | null> {\n   532→    const name = queueName ?? DEFAULT_QUEUE;\n   533→    const task = this.getNextTask(name);\n   534→    if (!task) return null;\n   535→\n   536→    const middlewares = this.middlewareStacks.get(name) ?? [];\n   537→    const handler = this.processHandlers.get(name);\n   538→\n   539→    try {\n   540→      await this.runMiddlewarePipeline(task, middlewares, handler);\n   541→      if (task.status === 'processing') {\n   542→        this.completeTask(task.id);\n   543→      }\n   544→    } catch (err: unknown) {\n   545→      if (task.status === 'processing') {\n   546→        const errorMessage = err instanceof Error ? err.message : String(err);\n   547→        this.failTask(task.id, errorMessage);\n   548→      }\n   549→    }\n   550→\n   551→    return task;\n   552→  }\n   553→\n   554→  private async runMiddlewarePipeline(\n   555→    task: Task,\n   556→    middlewares: MiddlewareFn[],\n   557→    handler?: ProcessHandler\n   558→  ): Promise<void> {\n   559→    let index = 0;\n   560→\n   561→    const next = async (): Promise<void> => {\n   562→      if (index < middlewares.length) {\n   563→        const mw = middlewares[index++];\n   564→        await mw(task, next);\n   565→      } else if (handler) {\n   566→        await handler(task);\n   567→      }\n   568→    };\n   569→\n   570→    if (middlewares.length > 0) {\n   571→      const mw = middlewares[index++];\n   572→      await mw(task, next);\n   573→    } else if (handler) {\n   574→      await handler(task);\n   575→    }\n   576→  }\n   577→\n   578→  // Phase 12: Graceful Shutdown\n   579→\n   580→  onShutdown(callback: () => void | Promise<void>): void {\n   581→    this.shutdownCallbacks.push(callback);\n   582→  }\n   583→\n   584→  async shutdown(timeout?: number): Promise<ShutdownResult> {\n   585→    const startTime = Date.now();\n   586→    this.isShutdown = true;\n   587→\n   588→    // Run shutdown callbacks\n   589→    for (const cb of this.shutdownCallbacks) {\n   590→      await cb();\n   591→    }\n   592→\n   593→    let completed = 0;\n   594→    let forceCancelled = 0;\n   595→\n   596→    // Gather all processing tasks\n   597→    const processingTasks = this.getProcessingTasks();\n   598→\n   599→    if (processingTasks.length === 0) {\n   600→      return { completed: 0, forceCancelled: 0, elapsed: Date.now() - startTime };\n   601→    }\n   602→\n   603→    if (timeout != null && timeout > 0) {\n   604→      // Wait for processing tasks with timeout\n   605→      const result = await this.waitForProcessingTasks(timeout);\n   606→      completed = result.completed;\n   607→\n   608→      // Force-cancel remaining\n   609→      const remaining = this.getProcessingTasks();\n   610→      for (const task of remaining) {\n   611→        task.status = 'cancelled';\n   612→        this.queues.get(task.queue)?.delete(task.id);\n   613→        forceCancelled++;\n   614→      }\n   615→    } else if (timeout === 0) {\n   616→      // Immediate force-cancel\n   617→      for (const task of processingTasks) {\n   618→        task.status = 'cancelled';\n   619→        this.queues.get(task.queue)?.delete(task.id);\n   620→        forceCancelled++;\n   621→      }\n   622→    } else {\n   623→      // No timeout: wait indefinitely (but in practice they should complete)\n   624→      const result = await this.waitForProcessingTasks(30000);\n   625→      completed = result.completed;\n   626→      const remaining = this.getProcessingTasks();\n   627→      for (const task of remaining) {\n   628→        task.status = 'cancelled';\n   629→        this.queues.get(task.queue)?.delete(task.id);\n   630→        forceCancelled++;\n   631→      }\n   632→    }\n   633→\n   634→    return { completed, forceCancelled, elapsed: Date.now() - startTime };\n   635→  }\n   636→\n   637→  private getProcessingTasks(): Task[] {\n   638→    const result: Task[] = [];\n   639→    for (const task of this.tasks.values()) {\n   640→      if (task.status === 'processing') {\n   641→        result.push(task);\n   642→      }\n   643→    }\n   644→    return result;\n   645→  }\n   646→\n   647→  private async waitForProcessingTasks(timeout: number): Promise<{ completed: number }> {\n   648→