+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EBtag4ycTFEtpE75advseY","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach } from 'vitest';\n     2→import { TaskQueue } from '../TaskQueue.js';\n     3→\n     4→describe('Phase 5: Retry with Backoff', () => {\n     5→  let queue: TaskQueue;\n     6→\n     7→  beforeEach(() => {\n     8→    queue = new TaskQueue();\n     9→  });\n    10→\n    11→  it('should complete a task', () => {\n    12→    const task = queue.addTask('data');\n    13→    const next = queue.getNextTask()!;\n    14→    queue.completeTask(next.id);\n    15→    expect(queue.getTask(task.id)?.status).toBe('completed');\n    16→  });\n    17→\n    18→  it('should re-queue failed task with retries remaining', () => {\n    19→    const task = queue.addTask('data', { maxRetries: 3 });\n    20→    queue.getNextTask();\n    21→    queue.failTask(task.id, 'oops');\n    22→\n    23→    const updated = queue.getTask(task.id)!;\n    24→    expect(updated.status).toBe('pending');\n    25→    expect(updated.attempt).toBe(1);\n    26→    expect(updated.failCount).toBe(1);\n    27→  });\n    28→\n    29→  it('should apply exponential backoff delay', () => {\n    30→    const task = queue.addTask('data', { maxRetries: 3, retryBaseDelay: 1000 });\n    31→    const before = Date.now();\n    32→\n    33→    queue.getNextTask();\n    34→    queue.failTask(task.id, 'fail-1');\n    35→    const updated = queue.getTask(task.id)!;\n    36→    // First retry: baseDelay * 2^0 = 1000ms\n    37→    expect(updated.availableAt).toBeGreaterThanOrEqual(before + 1000);\n    38→  });\n    39→\n    40→  it('should track attempt count through retries', () => {\n    41→    const task = queue.addTask('data', {\n    42→      maxRetries: 3,\n    43→      retryBaseDelay: 0,\n    44→    });\n    45→\n    46→    // First attempt\n    47→    queue.getNextTask();\n    48→    expect(queue.getTask(task.id)?.attempt).toBe(1);\n    49→    queue.failTask(task.id, 'fail');\n    50→\n    51→    // Force availability for immediate pickup\n    52→    const t = queue.getTask(task.id)!;\n    53→    t.availableAt = Date.now() - 1;\n    54→\n    55→    // Second attempt\n    56→    queue.getNextTask();\n    57→    expect(queue.getTask(task.id)?.attempt).toBe(2);\n    58→    queue.failTask(task.id, 'fail');\n    59→\n    60→    t.availableAt = Date.now() - 1;\n    61→\n    62→    // Third attempt (last)\n    63→    queue.getNextTask();\n    64→    expect(queue.getTask(task.id)?.attempt).toBe(3);\n    65→    queue.failTask(task.id, 'fail');\n    66→\n    67→    // Should be failed now\n    68→    expect(queue.getTask(task.id)?.status).toBe('dead-letter');\n    69→  });\n    70→\n    71→  it('should keep original queue and priority on retry', () => {\n    72→    const task = queue.addTask('data', {\n    73→      queue: 'myq',\n    74→      priority: 2,\n    75→      maxRetries: 3,\n    76→      retryBaseDelay: 0,\n    77→    });\n    78→\n    79→    queue.getNextTask('myq');\n    80→    queue.failTask(task.id, 'fail');\n    81→\n    82→    const updated = queue.getTask(task.id)!;\n    83→    expect(updated.queue).toBe('myq');\n    84→    expect(updated.priority).toBe(2);\n    85→  });\n    86→\n    87→  it('should store error message on fail', () => {\n    88→    const task = queue.addTask('data', { maxRetries: 1 });\n    89→    queue.getNextTask();\n    90→    queue.failTask(task.id, 'something went wrong');\n    91→    expect(queue.getTask(task.id)?.error).toBe('something went wrong');\n    92→  });\n    93→\n    94→  it('should throw when completing non-processing task', () => {\n    95→    const task = queue.addTask('data');\n    96→    expect(() => queue.completeTask(task.id)).toThrow();\n    97→  });\n    98→\n    99→  it('should default to 3 retries', () => {\n   100→    const task = queue.addTask('data');\n   101→    expect(task.maxRetries).toBe(3);\n   102→  });\n   103→});\n   104→"}]},"parent_tool_use_id