+      queue.getNextTask();
+      queue.cancelTask(task.id);
+      expect(queue.getTask(task.id)?.status).toBe('cancelled');
+    });
+
+    it('should not cancel completed task', () => {
+      const task = queue.addTask('work');
+      queue.getNextTask();
+      queue.completeTask(task.id);
+      expect(() => queue.cancelTask(task.id)).toThrow();
+    });
+
+    it('should not retry cancelled tasks', () => {
+      const task = queue.addTask('work', { maxRetries: 3 });
+      queue.getNextTask();
+      queue.cancelTask(task.id);
+
+      // Should stay cancelled, not pending
+      expect(queue.getTask(task.id)?.status).toBe('cancelled');
+    });
+  });
+});
