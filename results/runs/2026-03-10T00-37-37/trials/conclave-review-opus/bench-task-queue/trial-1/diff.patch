+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../TaskQueue.js';
+
+describe('Phase 9: Progress Tracking and Cancellation', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  describe('Progress', () => {
+    it('should update progress on processing task', () => {
+      const task = queue.addTask('work');
+      queue.getNextTask();
+      queue.updateProgress(task.id, 50, 'halfway');
+
+      const progress = queue.getProgress(task.id);
+      expect(progress.progress).toBe(50);
+      expect(progress.message).toBe('halfway');
+    });
+
+    it('should reject progress on non-processing task', () => {
+      const task = queue.addTask('work');
+      expect(() => queue.updateProgress(task.id, 50)).toThrow();
+    });
+
+    it('should reject invalid progress values', () => {
+      const task = queue.addTask('work');
+      queue.getNextTask();
+      expect(() => queue.updateProgress(task.id, -1)).toThrow();
+      expect(() => queue.updateProgress(task.id, 101)).toThrow();
+    });
+
+    it('should notify progress listeners', () => {
+      const task = queue.addTask('work');
+      queue.getNextTask();
+
+      const updates: Array<{ progress: number; message?: string }> = [];
+      queue.onProgress(task.id, (_id, p, m) => {
+        updates.push({ progress: p, message: m });
+      });
+
+      queue.updateProgress(task.id, 25, 'quarter');
+      queue.updateProgress(task.id, 75, 'three-quarter');
+
+      expect(updates.length).toBe(2);
+      expect(updates[0].progress).toBe(25);
+      expect(updates[1].progress).toBe(75);
+    });
+
+    it('should support unsubscribe from progress', () => {
+      const task = queue.addTask('work');
+      queue.getNextTask();
+
+      let callCount = 0;
+      const unsub = queue.onProgress(task.id, () => {
+        callCount++;
+      });
+
+      queue.updateProgress(task.id, 25);
+      unsub();
+      queue.updateProgress(task.id, 50);
+
+      expect(callCount).toBe(1);
+    });
+  });
+
+  describe('Cancellation', () => {
+    it('should cancel pending task', () => {
+      const task = queue.addTask('work');
+      queue.cancelTask(task.id);
