@@ -0,0 +1,69 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../TaskQueue.js';
+
+describe('Phase 1: Basic FIFO Queue', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
