+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../TaskQueue.js';
+
+describe('Phase 10: Recurring Tasks', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should create a schedule', () => {
+    const schedule = queue.addSchedule('cleanup', '*/5 * * * *', 'maintenance', { action: 'cleanup' });
+    expect(schedule.id).toBe('cleanup');
+    expect(schedule.cronExpression).toBe('*/5 * * * *');
+  });
+
+  it('should list schedules', () => {
+    queue.addSchedule('s1', '0 * * * *', 'q1', {});
+    queue.addSchedule('s2', '0 0 * * *', 'q2', {});
+    expect(queue.getSchedules().length).toBe(2);
+  });
+
+  it('should remove a schedule', () => {
+    queue.addSchedule('s1', '0 * * * *', 'q1', {});
+    expect(queue.removeSchedule('s1')).toBe(true);
+    expect(queue.getSchedules().length).toBe(0);
+  });
+
+  it('should create tasks on tick when cron matches', () => {
+    queue.addSchedule('every5', '*/5 * * * *', 'default', { type: 'recurring' });
+
+    // Minute 0 matches */5
+    const tasks = queue.tick(new Date(2024, 0, 1, 12, 0, 0));
+    expect(tasks.length).toBe(1);
+    expect(tasks[0].data).toEqual({ type: 'recurring' });
+  });
+
+  it('should not create tasks when cron does not match', () => {
+    queue.addSchedule('every5', '*/5 * * * *', 'default', { type: 'recurring' });
+
+    // Minute 3 does not match */5
+    const tasks = queue.tick(new Date(2024, 0, 1, 12, 3, 0));
+    expect(tasks.length).toBe(0);
+  });
+
+  it('should stop creating tasks after schedule removal', () => {
+    queue.addSchedule('s1', '*/5 * * * *', 'default', {});
+    queue.removeSchedule('s1');
+
+    const tasks = queue.tick(new Date(2024, 0, 1, 12, 0, 0));
+    expect(tasks.length).toBe(0);
+  });
+
+  it('should create regular tasks from recurring', () => {
+    queue.addSchedule('s1', '* * * * *', 'default', { msg: 'hi' });
+    const tasks = queue.tick(new Date());
+    expect(tasks.length).toBe(1);
+
+    const next = queue.getNextTask();
+    expect(next?.data).toEqual({ msg: 'hi' });
+  });
+
+  it('should reject invalid cron expressions', () => {
+    expect(() => queue.addSchedule('bad', 'invalid', 'q', {})).toThrow();
+  });
+});
