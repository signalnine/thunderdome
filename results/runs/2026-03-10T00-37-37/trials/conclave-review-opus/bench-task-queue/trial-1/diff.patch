MAX_RETRIES = 3;\nconst DEFAULT_RETRY_BASE_DELAY = 1000;\n\nexport class TaskQueue {\n  private tasks: Map<string, Task> = new Map();\n  private queues: Map<string, Set<string>> = new Map();\n  private deadLetterQueues: Map<string, Map<string, DeadLetteredTask>> = new Map();\n  private concurrencyLimits: Map<string, number> = new Map();\n  private progressListeners: Map<string, Set<ProgressListener>> = new Map();\n  private schedules: Map<string, Schedule> = new Map();\n  private middlewareStacks: Map<string, MiddlewareFn[]> = new Map();\n  private processHandlers: Map<string, ProcessHandler> = new Map();\n  private isShutdown = false;\n  private shutdownCallbacks: Array<() => void | Promise<void>> = [];\n\n  // Phase 1: Basic FIFO Queue\n\n  addTask<T = unknown>(data: T, options?: TaskOptions & { queue?: string }): Task<T> {\n    if (this.isShutdown) {\n      throw new Error('Queue system is shut down; cannot add tasks');\n    }\n\n    const queueName = options?.queue ?? DEFAULT_QUEUE;\n    const priority = options?.priority ?? DEFAULT_PRIORITY;\n\n    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    }\n\n    // Validate dependencies\n    const dependencies = options?.dependencies ?? [];\n    for (const depId of dependencies) {\n      const depTask = this.tasks.get(depId);\n      if (!depTask) {\n        throw new Error(`Dependency task not found: ${depId}`);\n      }\n    }\n\n    // Detect circular dependencies\n    if (dependencies.length > 0) {\n      const taskId = randomUUID(); // pre-generate for cycle detection\n      this.detectCircularDependencies(taskId, dependencies);\n\n      const now = Date.now();\n      let availableAt = now;\n      if (options?.availableAt != null) {\n        availableAt = options.availableAt;\n      } else if (options?.delay != null && options.delay > 0) {\n        availableAt = now + options.delay;\n      }\n\n      const task: Task<T> = {\n        id: taskId,\n        queue: queueName,\n        status: 'pending',\n        data,\n        priority,\n        createdAt: now,\n        availableAt,\n        attempt: 0,\n        maxRetries: options?.maxRetries ?? DEFAULT_MAX_RETRIES,\n        retryBaseDelay: options?.retryBaseDelay ?? DEFAULT_RETRY_BASE_DELAY,\n        progress: 0,\n        failCount: 0,\n        dependencies,\n      };\n\n      this.tasks.set(task.id, task as Task);\n      this.ensureQueue(queueName);\n      this.queues.get(queueName)!.add(task.id);\n\n      return task;\n    }\n\n    const now = Date.now();\n    let availableAt = now;\n    if (options?.availableAt != null) {\n      availableAt = options.availableAt;\n    } else if (options?.delay != null && options.delay > 0) {\n      availableAt = now + options.delay;\n    }\n\n    const task: Task<T> = {\n      id: randomUUID(),\n      queue: queueName,\n      status: 'pending',\n      data,\n      priority,\n      createdAt: now,\n      availableAt,\n      attempt: 0,\n      maxRetries: options?.maxRetries ?? DEFAULT_MAX_RETRIES,\n      retryBaseDelay: options?.retryBaseDelay ?? DEFAULT_RETRY_BASE_DELAY,\n      progress: 0,\n      failCount: 0,\n      dependencies,\n    };\n\n    this.tasks.set(task.id, task as Task);\n    this.ensureQueue(queueName);\n    this.queues.get(queueName)!.add(task.id);\n\n    return task;\n  }\n\n  getNextTask(queueName?: string): Task | null {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const queueTaskIds = this.queues.get(name);\n    if (!queueTaskIds) return null;\n\n    // Check concurrency limit\n    const limit = this.concurrencyLimits.get(name);\n    if (limit != null) {\n      const activeCount = this.getActiveCount(name);\n      if (activeCount >= limit) return null;\n    }\n\n    const now = Date.now();\n    let bestTask: Task | null = null;\n\n    for (const taskId of queueTaskIds) {\n      const task = this.tasks.get(taskId)!;\n      if (task.status !== 'pending') continue;\n\n      // Check if available (delay)\n      if (task.availableAt > now) continue;\n\n      // Check dependencies\n      if (!this.areDependenciesMet(task)) continue;\n\n      if (bestTask === null || this.compareTasks(task, bestTask) < 0) {\n        bestTask = task;\n      }\n    }\n\n    if (bestTask) {\n      bestTask.status = 'processing';\n      bestTask.attempt++;\n    }\n\n    return bestTask;\n  }\n\n  getTask(taskId: string): Task | null {\n    return this.tasks.get(taskId) ?? null;\n  }\n\n  getWaitingCount(queueName?: string): number {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const queueTaskIds = this.queues.get(name);\n    if (!queueTaskIds) return 0;\n\n    let count = 0;\n    for (const taskId of queueTaskIds) {\n      const task = this.tasks.get(taskId)!;\n      if (task.status === 'pending') count++;\n    }\n    return count;\n  }\n\n  // Phase 2: Named Queues\n\n  getQueues(): string[] {\n    return Array.from(this.queues.keys());\n  }\n\n  // Phase 5: Retry with backoff\n\n  completeTask(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${taskId} is not processing (status: ${task.status})`);\n    }\n    task.status = 'completed';\n    task.progress = 100;\n    // Remove from queue set\n    this.queues.get(task.queue)?.delete(taskId);\n  }\n\n  failTask(taskId: string, error?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${taskId} is not processing (status: ${task.status})`);\n    }\n\n    task.error = error;\n    task.failCount++;\n\n    if (task.attempt < task.maxRetries) {\n      // Re-queue with exponential backoff\n      const delay = task.retryBaseDelay * Math.pow(2, task.attempt - 1);\n      task.status = 'pending';\n      task.availableAt = Date.now() + delay;\n      task.progress = 0;\n    } else {\n      task.status = 'failed';\n      // Move to DLQ\n      this.moveToDeadLetterQueue(task);\n    }\n  }\n\n  // Phase 6: Dead Letter Queue\n\n  private moveToDeadLetterQueue(task: Task): void {\n    const dlq = this.ensureDeadLetterQueue(task.queue);\n    const deadTask: DeadLetteredTask = {\n      ...task,\n      status: 'dead-letter',\n      deadLetteredAt: Date.now(),\n      originalQueue: task.queue,\n    };\n    dlq.set(task.id, deadTask);\n    this.tasks.set(task.id, deadTask as Task);\n    this.queues.get(task.queue)?.delete(task.id);\n  }\n\n  getDeadLetterTasks(queueName?: string): DeadLetteredTask[] {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const dlq = this.deadLetterQueues.get(name);\n    if (!dlq) return [];\n    return Array.from(dlq.values());\n  }\n\n  reprocessDeadLetterTask(taskId: string): Task {\n    // Find and remove from DLQ\n    for (const [_queueName, dlq] of this.deadLetterQueues) {\n      const deadTask = dlq.get(taskId);\n      if (deadTask) {\n        dlq.delete(taskId);\n\n        // Reset task for fresh retries\n        const task: Task = {\n          id: deadTask.id,\n          queue: deadTask.originalQueue,\n          status: 'pending',\n          data: deadTask.data,\n          priority: deadTask.priority,\n          createdAt: Date.now(),\n          availableAt: Date.now(),\n          attempt: 0,\n          maxRetries: deadTask.maxRetries,\n          retryBaseDelay: deadTask.retryBaseDelay,\n          progress: 0,\n          failCount: 0,\n          dependencies: [],\n        };\n\n        this.tasks.set(task.id, task);\n        this.ensureQueue(task.queue);\n        this.queues.get(task.queue)!.add(task.id);\n\n        return task;\n      }\n    }\n    throw new Error(`Dead-lettered task not found: ${taskId}`);\n  }\n\n  clearDeadLetterQueue(queueName?: string): number {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const dlq = this.deadLetterQueues.get(name);\n    if (!dlq) return 0;\n    const count = dlq.size;\n    for (const taskId of dlq.keys()) {\n      this.tasks.delete(taskId);\n    }\n    dlq.clear();\n    return count;\n  }\n\n  // Phase 7: Task Dependencies\n\n  private areDependenciesMet(task: Task): boolean {\n    for (const depId of task.dependencies) {\n      const dep = this.tasks.get(depId);\n      if (!dep) return false;\n      if (dep.status !== 'completed' && dep.status !== 'failed' && dep.status !== 'cancelled') {\n        return false;\n      }\n    }\n    return true;\n  }\n\n  private detectCircularDependencies(newTaskId: string, dependencies: string[]): void {\n    // BFS: check if any dependency eventually depends back on newTaskId\n    // Since newTaskId doesn't exist yet, we check if any of the deps have\n    // dependency chains that form cycles among themselves\n    const visited = new Set<string>();\n\n    const checkCycle = (taskId: string, path: Set<string>): void => {\n      if (path.has(taskId)) {\n        throw new Error('Circular dependency detected');\n      }\n      if (visited.has(taskId)) return;\n      visited.add(taskId);\n      path.add(taskId);\n\n      const task = this.tasks.get(taskId);\n      if (task) {\n        for (const depId of task.dependencies) {\n          checkCycle(depId, new Set(path));\n        }\n      }\n    };\n\n    for (const depId of dependencies) {\n      checkCycle(depId, new Set([newTaskId]));\n    }\n  }\n\n  getTaskDependencies(taskId: string): { taskId: string; status: TaskStatus }[] {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    return task.dependencies.map((depId) => {\n      const dep = this.tasks.get(depId);\n      return {\n        taskId: depId,\n        status: dep ? dep.status : ('unknown' as TaskStatus),\n      };\n    });\n  }\n\n  // Phase 8: Concurrency Control\n\n  setConcurrency(queueName: string, limit: number): void {\n    if (limit < 1 || !Number.isInteger(limit)) {\n      throw new Error(`Invalid concurrency limit: ${limit}`);\n    }\n    this.concurrencyLimits.set(queueName, limit);\n    this.ensureQueue(queueName);\n  }\n\n  getConcurrency(queueName?: string): number | undefined {\n    const name = queueName ?? DEFAULT_QUEUE;\n    return this.concurrencyLimits.get(name);\n  }\n\n  getActiveCount(queueName?: string): number {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const queueTaskIds = this.queues.get(name);\n    if (!queueTaskIds) return 0;\n\n    let count = 0;\n    for (const taskId of queueTaskIds) {\n      const task = this.tasks.get(taskId)!;\n      if (task.status === 'processing') count++;\n    }\n    return count;\n  }\n\n  // Phase 9: Progress and Cancellation\n\n  updateProgress(taskId: string, progress: number, message?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${taskId} is not processing`);\n    }\n    if (progress < 0 || progress > 100) {\n      throw new Error(`Invalid progress: ${progress}. Must be between 0 and 100.`);\n    }\n\n    task.progress = progress;\n    task.progressMessage = message;\n\n    // Notify listeners\n    const listeners = this.progressListeners.get(taskId);\n    if (listeners) {\n      for (const listener of listeners) {\n        listener(taskId, progress, message);\n      }\n    }\n  }\n\n  getProgress(taskId: string): { progress: number; message?: string } {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    return { progress: task.progress, message: task.progressMessage };\n  }\n\n  onProgress(taskId: string, listener: ProgressListener): () => void {\n    if (!this.progressListeners.has(taskId)) {\n      this.progressListeners.set(taskId, new Set());\n    }\n    this.progressListeners.get(taskId)!.add(listener);\n\n    // Return unsubscribe function\n    return () => {\n      this.progressListeners.get(taskId)?.delete(listener);\n    };\n  }\n\n  cancelTask(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    if (task.status === 'pending') {\n      task.status = 'cancelled';\n      this.queues.get(task.queue)?.delete(taskId);\n    } else if (task.status === 'processing') {\n      task.status = 'cancelled';\n      this.queues.get(task.queue)?.delete(taskId);\n    } else {\n      throw new Error(`Cannot cancel task with status: ${task.status}`);\n    }\n  }\n\n  // Phase 10: Recurring Tasks\n\n  addSchedule(\n    id: string,\n    cronExpression: string,\n    queue: string,\n    taskData: unknown,\n    taskOptions?: Omit<TaskOptions, 'delay' | 'availableAt' | 'dependencies'>\n  ): Schedule {\n    if (this.isShutdown) {\n      throw new Error('Queue system is shut down');\n    }\n    this.validateCron(cronExpression);\n\n    const schedule: Schedule = {\n      id,\n      queue,\n      cronExpression,\n      taskData,\n      taskOptions,\n    };\n\n    this.schedules.set(id, schedule);\n    return schedule;\n  }\n\n  removeSchedule(id: string): boolean {\n    return this.schedules.delete(id);\n  }\n\n  getSchedules(): Schedule[] {\n    return Array.from(this.schedules.values());\n  }\n\n  tick(now?: Date): Task[] {\n    const currentTime = now ?? new Date();\n    const created: Task[] = [];\n\n    for (const schedule of this.schedules.values()) {\n      if (this.cronMatches(schedule.cronExpression, currentTime)) {\n        const task = this.addTask(schedule.taskData, {\n          queue: schedule.queue,\n          ...schedule.taskOptions,\n        });\n        created.push(task as Task);\n      }\n    }\n\n    return created;\n  }\n\n  private validateCron(expr: string): void {\n    const parts = expr.trim().split(/\\s+/);\n    if (parts.length !== 5) {\n      throw new Error(`Invalid cron expression: ${expr}. Expected 5 fields.`);\n    }\n    // Basic validation - each field is * or a number or */N\n    for (const part of parts) {\n      if (part !== '*' && !/^\\d+$/.test(part) && !/^\\*\\/\\d+$/.test(part)) {\n        throw new Error(`Invalid cron field: ${part}`);\n      }\n    }\n  }\n\n  private cronMatches(expr: string, date: Date): boolean {\n    const parts = expr.trim().split(/\\s+/);\n    const minute = date.getMinutes();\n    const hour = date.getHours();\n    const dayOfMonth = date.getDate();\n    const month = date.getMonth() + 1;\n    const dayOfWeek = date.getDay();\n\n    const values = [minute, hour, dayOfMonth, month, dayOfWeek];\n\n    for (let i = 0; i < 5; i++) {\n      if (!this.cronFieldMatches(parts[i], values[i])) {\n        return false;\n      }\n    }\n    return true;\n  }\n\n  private cronFieldMatches(field: string, value: number): boolean {\n    if (field === '*') return true;\n    if (/^\\d+$/.test(field)) return parseInt(field, 10) === value;\n    const stepMatch = field.match(/^\\*\\/(\\d+)$/);\n    if (stepMatch) {\n      const step = parseInt(stepMatch[1], 10);\n      return value % step === 0;\n    }\n    return false;\n  }\n\n  // Phase 11: Middleware Pipeline\n\n  use(queueName: string, middleware: MiddlewareFn): void {\n    if (!this.middlewareStacks.has(queueName)) {\n      this.middlewareStacks.set(queueName, []);\n    }\n    this.middlewareStacks.get(queueName)!.push(middleware);\n  }\n\n  setProcessHandler(queueName: string, handler: ProcessHandler): void {\n    this.processHandlers.set(queueName, handler);\n  }\n\n  async processNext(queueName?: string): Promise<Task | null> {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const task = this.getNextTask(name);\n    if (!task) return null;\n\n    const middlewares = this.middlewareStacks.get(name) ?? [];\n    const handler = this.processHandlers.get(name);\n\n    try {\n      await this.runMiddlewarePipeline(task, middlewares, handler);\n      if (task.status === 'processing') {\n        this.completeTask(task.id);\n      }\n    } catch (err: unknown) {\n      if (task.status === 'processing') {\n        const errorMessage = err instanceof Error ? err.message : String(err);\n        this.failTask(task.id, errorMessage);\n      }\n    }\n\n    return task;\n  }\n\n  private async runMiddlewarePipeline(\n    task: Task,\n    middlewares: MiddlewareFn[],\n    handler?: ProcessHandler\n  ): Promise<void> {\n    let index = 0;\n    let nextCalled = false;\n\n    const next = async (): Promise<void> => {\n      nextCalled = true;\n      if (index < middlewares.length) {\n        const mw = middlewares[index++];\n        nextCalled = false;\n        await mw(task, next);\n      } else if (handler) {\n        await handler(task);\n      }\n    };\n\n    if (middlewares.length > 0) {\n      const mw = middlewares[index++];\n      nextCalled = false;\n      await mw(task, next);\n    } else if (handler) {\n      await handler(task);\n    }\n  }\n\n  // Phase 12: Graceful Shutdown\n\n  onShutdown(callback: () => void | Promise<void>): void {\n    this.shutdownCallbacks.push(callback);\n  }\n\n  async shutdown(timeout?: number): Promise<ShutdownResult> {\n    const startTime = Date.now();\n    this.isShutdown = true;\n\n    // Run shutdown callbacks\n    for (const cb of this.shutdownCallbacks) {\n      await cb();\n    }\n\n    let completed = 0;\n    let forceCancelled = 0;\n\n    // Gather all processing tasks\n    const processingTasks = this.getProcessingTasks();\n\n    if (processingTasks.length === 0) {\n      return { completed: 0, forceCancelled: 0, elapsed: Date.now() - startTime };\n    }\n\n    if (timeout != null && timeout > 0) {\n      // Wait for processing tasks with timeout\n      const result = await this.waitForProcessingTasks(timeout);\n      completed = result.completed;\n\n      // Force-cancel remaining\n      const remaining = this.getProcessingTasks();\n      for (const task of remaining) {\n        task.status = 'cancelled';\n        this.queues.get(task.queue)?.delete(task.id);\n        forceCancelled++;\n      }\n    } else if (timeout === 0) {\n      // Immediate force-cancel\n      for (const task of processingTasks) {\n        task.status = 'cancelled';\n        this.queues.get(task.queue)?.delete(task.id);\n        forceCancelled++;\n      }\n    } else {\n      // No timeout: wait indefinitely (but in practice they should complete)\n      const result = await this.waitForProcessingTasks(30000);\n      completed = result.completed;\n      const remaining = this.getProcessingTasks();\n      for (const task of remaining) {\n        task.status = 'cancelled';\n        this.queues.get(task.queue)?.delete(task.id);\n        forceCancelled++;\n      }\n    }\n\n    return { completed, forceCancelled, elapsed: Date.now() - startTime };\n  }\n\n  private getProcessingTasks(): Task[] {\n    const result: Task[] = [];\n    for (const task of this.tasks.values()) {\n      if (task.status === 'processing') {\n        result.push(task);\n      }\n    }\n    return result;\n  }\n\n  private async waitForProcessingTasks(timeout: number): Promise<{ completed: number }> {\n    const deadline = Date.now() + timeout;\n    let completed = 0;\n\n    while (Date.now() < deadline) {\n      const processing = this.getProcessingTasks();\n      if (processing.length === 0) break;\n\n      await new Promise((resolve) => setTimeout(resolve, Math.min(50, deadline - Date.now())));\n\n      // Count any that completed during the wait\n      for (const task of processing) {\n        if (task.status === 'completed' || task.status === 'failed') {\n          completed++;\n        }\n      }\n    }\n\n    return { completed };\n  }\n\n  // Helpers\n\n  private ensureQueue(name: string): void {\n    if (!this.queues.has(name)) {\n      this.queues.set(name, new Set());\n    }\n  }\n\n  private ensureDeadLetterQueue(name: string): Map<string, DeadLetteredTask> {\n    if (!this.deadLetterQueues.has(name)) {\n      this.deadLetterQueues.set(name, new Map());\n    }\n    return this.deadLetterQueues.get(name)!;\n  }\n\n  private compareTasks(a: Task, b: Task): number {\n    // Lower priority number = higher priority (1 is highest)\n    if (a.priority !== b.priority) return a.priority - b.priority;\n    // For delayed tasks that are now available, sort by availableAt\n    if (a.availableAt !== b.availableAt) return a.availableAt - b.availableAt;\n    // FIFO: earlier created first\n    if (a.createdAt !== b.createdAt) return a.createdAt - b.createdAt;\n    return 0;\n  }\n}\n","structuredPatch":[{"oldStart":557,"oldLines":13,"newStart":557,"newLines":10,"lines":["     handler?: ProcessHandler","   ): Promise<void> {","     let index = 0;","-    let nextCalled = false;"," ","     const next = async (): Promise<void> => {","-      nextCalled = true;","       if (index < middlewares.length) {","         const mw = middlewares[index++];","-        nextCalled = false;","         await mw(task, next);","       } else if (handler) {","         await handler(task);"]},{"oldStart":572,"oldLines":7,"newStart":569,"newLines":6,"lines":[" ","     if (middlewares.length > 0) {","       const mw = middlewares[index++];","-      nextCalled = false;","       await mw(task, next);","     } else if (handler) {","       await handler(task);"]}],"userModified":false,"replaceAll":false}}
