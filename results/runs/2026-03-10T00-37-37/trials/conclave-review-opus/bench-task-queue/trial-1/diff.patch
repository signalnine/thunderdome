+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../TaskQueue.js';
+
+describe('Phase 11: Middleware Pipeline', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should run middleware in order', async () => {
+    const order: string[] = [];
+
+    queue.use('default', async (_task, next) => {
+      order.push('first');
+      await next();
+    });
+    queue.use('default', async (_task, next) => {
+      order.push('second');
+      await next();
+    });
+    queue.setProcessHandler('default', async () => {
+      order.push('handler');
+    });
+
+    queue.addTask('data');
+    await queue.processNext();
+
+    expect(order).toEqual(['first', 'second', 'handler']);
+  });
+
+  it('should skip processing if middleware does not call next', async () => {
+    const handlerCalled = { value: false };
+
+    queue.use('default', async (_task, _next) => {
+      // Deliberately not calling next
+    });
+    queue.setProcessHandler('default', async () => {
+      handlerCalled.value = true;
+    });
+
+    queue.addTask('data');
+    await queue.processNext();
+
+    expect(handlerCalled.value).toBe(false);
+  });
+
+  it('should allow middleware to modify task', async () => {
+    queue.use('default', async (task, next) => {
+      (task.data as Record<string, unknown>).modified = true;
+      await next();
+    });
+
+    let receivedData: unknown;
+    queue.setProcessHandler('default', async (task) => {
+      receivedData = task.data;
+    });
+
+    queue.addTask({ original: true });
+    await queue.processNext();
+
+    expect(receivedData).toEqual({ original: true, modified: true });
+  });
+
+  it('should fail task if middleware throws', async () => {
+    queue.use('default', async () => {
+      throw new Error('middleware error');
+    });
+
+    const task = queue.addTask('data', { maxRetries: 0 });
+    await queue.processNext();
+
+    const updated = queue.getTask(task.id)!;
+    expect(updated.error).toBe('middleware error');
+  });
+
+  it('should have independent middleware stacks per queue', async () => {
+    const q1Order: string[] = [];
+    const q2Order: string[] = [];
+
+    queue.use('q1', async (_task, next) => {
+      q1Order.push('q1-mw');
+      await next();
+    });
+    queue.use('q2', async (_task, next) => {
+      q2Order.push('q2-mw');
+      await next();
+    });
+
+    queue.setProcessHandler('q1', async () => { q1Order.push('q1-handler'); });
+    queue.setProcessHandler('q2', async () => { q2Order.push('q2-handler'); });
+
+    queue.addTask('d1', { queue: 'q1' });
+    queue.addTask('d2', { queue: 'q2' });
+
+    await queue.processNext('q1');
+    await queue.processNext('q2');
+
+    expect(q1Order).toEqual(['q1-mw', 'q1-handler']);
+    expect(q2Order).toEqual(['q2-mw', 'q2-handler']);
+  });
+
+  it('should complete task after successful processing', async () => {
+    queue.setProcessHandler('default', async () => {
+      // Success
+    });
+
+    const task = queue.addTask('data');
+    await queue.processNext();
+
+    expect(queue.getTask(task.id)?.status).toBe('completed');
+  });
+});
