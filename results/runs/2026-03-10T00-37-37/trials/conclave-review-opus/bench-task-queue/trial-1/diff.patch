+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01G4XA8ovsxP3Sd4dx6LzbCu","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach } from 'vitest';\n     2→import { TaskQueue } from '../TaskQueue.js';\n     3→\n     4→describe('Phase 6: Dead Letter Queue', () => {\n     5→  let queue: TaskQueue;\n     6→\n     7→  beforeEach(() => {\n     8→    queue = new TaskQueue();\n     9→  });\n    10→\n    11→  it('should move exhausted tasks to DLQ', () => {\n    12→    const task = queue.addTask('data', { maxRetries: 2, retryBaseDelay: 0 });\n    13→\n    14→    // Attempt 1: fail, re-queue (attempt 1 < maxRetries 2)\n    15→    queue.getNextTask();\n    16→    queue.failTask(task.id, 'fail');\n    17→    queue.getTask(task.id)!.availableAt = Date.now() - 1;\n    18→\n    19→    // Attempt 2: fail, exhausted (attempt 2 >= maxRetries 2)\n    20→    queue.getNextTask();\n    21→    queue.failTask(task.id, 'fail again');\n    22→\n    23→    const dlqTasks = queue.getDeadLetterTasks();\n    24→    expect(dlqTasks.length).toBe(1);\n    25→    expect(dlqTasks[0].id).toBe(task.id);\n    26→    expect(dlqTasks[0].status).toBe('dead-letter');\n    27→  });\n    28→\n    29→  it('should retain error info in DLQ', () => {\n    30→    const task = queue.addTask('data', { maxRetries: 0 });\n    31→    queue.getNextTask();\n    32→    queue.failTask(task.id, 'critical error');\n    33→\n    34→    const dlqTasks = queue.getDeadLetterTasks();\n    35→    expect(dlqTasks[0].error).toBe('critical error');\n    36→  });\n    37→\n    38→  it('should reprocess dead-lettered task', () => {\n    39→    const task = queue.addTask('data', { maxRetries: 0 });\n    40→    queue.getNextTask();\n    41→    queue.failTask(task.id, 'error');\n    42→\n    43→    const reprocessed = queue.reprocessDeadLetterTask(task.id);\n    44→    expect(reprocessed.status).toBe('pending');\n    45→    expect(reprocessed.attempt).toBe(0);\n    46→\n    47→    // Should be available for processing\n    48→    const next = queue.getNextTask();\n    49→    expect(next?.id).toBe(task.id);\n    50→  });\n    51→\n    52→  it('should clear DLQ for a queue', () => {\n    53→    const task = queue.addTask('data', { maxRetries: 0 });\n    54→    queue.getNextTask();\n    55→    queue.failTask(task.id, 'error');\n    56→\n    57→    const cleared = queue.clearDeadLetterQueue();\n    58→    expect(cleared).toBe(1);\n    59→    expect(queue.getDeadLetterTasks().length).toBe(0);\n    60→  });\n    61→\n    62→  it('should have independent DLQs per queue', () => {\n    63→    const t1 = queue.addTask('d1', { queue: 'q1', maxRetries: 0 });\n    64→    const t2 = queue.addTask('d2', { queue: 'q2', maxRetries: 0 });\n    65→\n    66→    queue.getNextTask('q1');\n    67→    queue.failTask(t1.id, 'err');\n    68→    queue.getNextTask('q2');\n    69→    queue.failTask(t2.id, 'err');\n    70→\n    71→    expect(queue.getDeadLetterTasks('q1').length).toBe(1);\n    72→    expect(queue.getDeadLetterTasks('q2').length).toBe(1);\n    73→\n    74→    queue.clearDeadLetterQueue('q1');\n    75→    expect(queue.getDeadLetterTasks('q1').length).toBe(0);\n    76→    expect(queue.getDeadLetterTasks('q2').length).toBe(1);\n    77→  });\n    78→});\n    79→"}]},"parent_tool_use_id":"toolu_01LUD2kdh2huqAkWZLirPxn9","session_id":"8096ee20-9eeb-4a71-bc2c-e8bc6c545d6f","uuid":"08ea85ab-c05c-4f28-930d-2e94013218af"}
