+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011iQ3bUAxDutRQDDfrYoqRD","type":"tool_result","content":"     1→export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled' | 'dead-letter';\n     2→\n     3→export interface TaskOptions {\n     4→  priority?: number;\n     5→  delay?: number;\n     6→  availableAt?: number;\n     7→  maxRetries?: number;\n     8→  retryBaseDelay?: number;\n     9→  dependencies?: string[];\n    10→}\n    11→\n    12→export interface Task<T = unknown> {\n    13→  id: string;\n    14→  queue: string;\n    15→  status: TaskStatus;\n    16→  data: T;\n    17→  priority: number;\n    18→  createdAt: number;\n    19→  availableAt: number;\n    20→  attempt: number;\n    21→  maxRetries: number;\n    22→  retryBaseDelay: number;\n    23→  progress: number;\n    24→  progressMessage?: string;\n    25→  error?: string;\n    26→  failCount: number;\n    27→  dependencies: string[];\n    28→}\n    29→\n    30→export interface DeadLetteredTask<T = unknown> extends Task<T> {\n    31→  status: 'dead-letter';\n    32→  deadLetteredAt: number;\n    33→  originalQueue: string;\n    34→}\n    35→\n    36→export interface Schedule {\n    37→  id: string;\n    38→  queue: string;\n    39→  cronExpression: string;\n    40→  taskData: unknown;\n    41→  taskOptions?: Omit<TaskOptions, 'delay' | 'availableAt' | 'dependencies'>;\n    42→}\n    43→\n    44→export type ProgressListener = (taskId: string, progress: number, message?: string) => void;\n    45→\n    46→export type MiddlewareFn = (task: Task, next: () => Promise<void>) => Promise<void>;\n    47→\n    48→export type ProcessHandler = (task: Task) => Promise<void>;\n    49→\n    50→export interface ShutdownResult {\n    51→  completed: number;\n    52→  forceCancelled: number;\n    53→  elapsed: number;\n    54→}\n    55→"}]},"parent_tool_use_id":"toolu_01LUD2kdh2huqAkWZLirPxn9","session_id":"8096ee20-9eeb-4a71-bc2c-e8bc6c545d6f","uuid":"1f34020a