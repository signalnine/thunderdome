+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../TaskQueue.js';
+
+describe('Phase 4: Delayed and Scheduled Tasks', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should not return delayed tasks before their available time', () => {
+    queue.addTask('delayed', { delay: 60000 });
+    expect(queue.getNextTask()).toBeNull();
+  });
+
+  it('should return non-delayed tasks even when delayed tasks exist', () => {
+    queue.addTask('delayed', { delay: 60000 });
+    queue.addTask('immediate');
+
+    const task = queue.getNextTask();
+    expect(task?.data).toBe('immediate');
+  });
+
+  it('should support availableAt for scheduling', () => {
+    const futureTime = Date.now() + 60000;
+    queue.addTask('future', { availableAt: futureTime });
+    expect(queue.getNextTask()).toBeNull();
+  });
+
+  it('should return delayed tasks once time passes', () => {
+    const pastTime = Date.now() - 1000;
+    queue.addTask('ready', { availableAt: pastTime });
+
+    const task = queue.getNextTask();
+    expect(task?.data).toBe('ready');
+  });
+
+  it('should still respect priority among available tasks', () => {
+    queue.addTask('low-priority', { priority: 8 });
+    queue.addTask('high-priority', { priority: 2 });
+
+    expect(queue.getNextTask()?.data).toBe('high-priority');
+  });
+
+  it('should work with named queues', () => {
+    queue.addTask('delayed', { queue: 'myq', delay: 60000 });
+    queue.addTask('immediate', { queue: 'myq' });
+
+    expect(queue.getNextTask('myq')?.data).toBe('immediate');
+  });
+});
