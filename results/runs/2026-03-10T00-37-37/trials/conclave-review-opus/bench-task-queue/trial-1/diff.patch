+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WDitmopZwdbxQdkdiBK78Q","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach } from 'vitest';\n     2→import { TaskQueue } from '../TaskQueue.js';\n     3→\n     4→describe('Phase 11: Middleware Pipeline', () => {\n     5→  let queue: TaskQueue;\n     6→\n     7→  beforeEach(() => {\n     8→    queue = new TaskQueue();\n     9→  });\n    10→\n    11→  it('should run middleware in order', async () => {\n    12→    const order: string[] = [];\n    13→\n    14→    queue.use('default', async (_task, next) => {\n    15→      order.push('first');\n    16→      await next();\n    17→    });\n    18→    queue.use('default', async (_task, next) => {\n    19→      order.push('second');\n    20→      await next();\n    21→    });\n    22→    queue.setProcessHandler('default', async () => {\n    23→      order.push('handler');\n    24→    });\n    25→\n    26→    queue.addTask('data');\n    27→    await queue.processNext();\n    28→\n    29→    expect(order).toEqual(['first', 'second', 'handler']);\n    30→  });\n    31→\n    32→  it('should skip processing if middleware does not call next', async () => {\n    33→    const handlerCalled = { value: false };\n    34→\n    35→    queue.use('default', async (_task, _next) => {\n    36→      // Deliberately not calling next\n    37→    });\n    38→    queue.setProcessHandler('default', async () => {\n    39→      handlerCalled.value = true;\n    40→    });\n    41→\n    42→    queue.addTask('data');\n    43→    await queue.processNext();\n    44→\n    45→    expect(handlerCalled.value).toBe(false);\n    46→  });\n    47→\n    48→  it('should allow middleware to modify task', async () => {\n    49→    queue.use('default', async (task, next) => {\n    50→      (task.data as Record<string, unknown>).modified = true;\n    51→      await next();\n    52→    });\n    53→\n    54→    let receivedData: unknown;\n    55→    queue.setProcessHandler('default', async (task) => {\n    56→      receivedData = task.data;\n    57→    });\n    58→\n    59→    queue.addTask({ original: true });\n    60→    await queue.processNext();\n    61→\n    62→    expect(receivedData).toEqual({ original: true, modified: true });\n    63→  });\n    64→\n    65→  it('should fail task if middleware throws', async () => {\n    66→    queue.use('default', async () => {\n    67→      throw new Error('middleware error');\n    68→    });\n    69→\n    70→    const task = queue.addTask('data', { maxRetries: 0 });\n    71→    await queue.processNext();\n    72→\n    73→    const updated = queue.getTask(task.id)!;\n    74→    expect(updated.error).toBe('middleware error');\n    75→  });\n    76→\n    77→  it('should have independent middleware stacks per queue', async () => {\n    78→    const q1Order: string[] = [];\n    79→    const q2Order: string[] = [];\n    80→\n    81→    queue.use('q1', async (_task, next) => {\n    82→      q1Order.push('q1-mw');\n    83→      await next();\n    84→    });\n    85→    queue.use('q2', async (_task, next) => {\n    86→      q2Order.push('q2-mw');\n    87→      await next();\n    88→    });\n    89→\n    90→    queue.setProcessHandler('q1', async () => { q1Order.push('q1-handler'); });\n    91→    queue.setProcessHandler('q2', async () => { q2Order.push('q2-handler'); });\n    92→\n    93→    queue.addTask('d1', { queue: 'q1' });\n    94→    queue.addTask('d2', { queue: 'q2' });\n    95→\n    96→    await queue.processNext('q1');\n    97→    await queue.processNext('q2');\n    98→\n    99→    expect(q1Order).toEqual(['q1-mw', 'q1-handler']);\n   100→    expect(q2Order).toEqual(['q2-mw', 'q2-handler']);\n   101→  });\n   102→\n   103→  it('should complete task after successful processing', async () => {\n   104→    queue.setProcessHandler('default', async () => {\n   105→      // Success\n   106→    });\n   107→\n   108→    const task = queue.addTask('data');\n   109→    await queue.processNext();\n   110→\n   111→    expect(queue.getTask(task.id)?.status).toBe('completed');\n   112→  });\n   113→});\n   114→"}]},"parent_tool_use_id":"toolu_01LUD2kdh2huqAkWZLirPxn9","session_id":"8096ee20-9eeb-4a71-bc2c-e8bc6c545d6f","uuid":"34ced908-9aab-4f55-a864-3db7568c921a"}
