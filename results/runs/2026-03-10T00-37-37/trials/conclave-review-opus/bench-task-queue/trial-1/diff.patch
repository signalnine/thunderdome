24→\n   425→  // Phase 10: Recurring Tasks\n   426→\n   427→  addSchedule(\n   428→    id: string,\n   429→    cronExpression: string,\n   430→    queue: string,\n   431→    taskData: unknown,\n   432→    taskOptions?: Omit<TaskOptions, 'delay' | 'availableAt' | 'dependencies'>\n   433→  ): Schedule {\n   434→    if (this.isShutdown) {\n   435→      throw new Error('Queue system is shut down');\n   436→    }\n   437→    this.validateCron(cronExpression);\n   438→\n   439→    const schedule: Schedule = {\n   440→      id,\n   441→      queue,\n   442→      cronExpression,\n   443→      taskData,\n   444→      taskOptions,\n   445→    };\n   446→\n   447→    this.schedules.set(id, schedule);\n   448→    return schedule;\n   449→  }\n   450→\n   451→  removeSchedule(id: string): boolean {\n   452→    return this.schedules.delete(id);\n   453→  }\n   454→\n   455→  getSchedules(): Schedule[] {\n   456→    return Array.from(this.schedules.values());\n   457→  }\n   458→\n   459→  tick(now?: Date): Task[] {\n   460→    const currentTime = now ?? new Date();\n   461→    const created: Task[] = [];\n   462→\n   463→    for (const schedule of this.schedules.values()) {\n   464→      if (this.cronMatches(schedule.cronExpression, currentTime)) {\n   465→        const task = this.addTask(schedule.taskData, {\n   466→          queue: schedule.queue,\n   467→          ...schedule.taskOptions,\n   468→        });\n   469→        created.push(task as Task);\n   470→      }\n   471→    }\n   472→\n   473→    return created;\n   474→  }\n   475→\n   476→  private validateCron(expr: string): void {\n   477→    const parts = expr.trim().split(/\\s+/);\n   478→    if (parts.length !== 5) {\n   479→      throw new Error(`Invalid cron expression: ${expr}. Expected 5 fields.`);\n   480→    }\n   481→    // Basic validation - each field is * or a number or */N\n   482→    for (const part of parts) {\n   483→      if (part !== '*' && !/^\\d+$/.test(part) && !/^\\*\\/\\d+$/.test(part)) {\n   484→        throw new Error(`Invalid cron field: ${part}`);\n   485→      }\n   486→    }\n   487→  }\n   488→\n   489→  private cronMatches(expr: string, date: Date): boolean {\n   490→    const parts = expr.trim().split(/\\s+/);\n   491→    const minute = date.getMinutes();\n   492→    const hour = date.getHours();\n   493→    const dayOfMonth = date.getDate();\n   494→    const month = date.getMonth() + 1;\n   495→    const dayOfWeek = date.getDay();\n   496→\n   497→    const values = [minute, hour, dayOfMonth, month, dayOfWeek];\n   498→\n   499→    for (let i = 0; i < 5; i++) {\n   500→      if (!this.cronFieldMatches(parts[i], values[i])) {\n   501→        return false;\n   502→      }\n   503→    }\n   504→    return true;\n   505→  }\n   506→\n   507→  private cronFieldMatches(field: string, value: number): boolean {\n   508→    if (field === '*') return true;\n   509→    if (/^\\d+$/.test(field)) return parseInt(field, 10) === value;\n   510→    const stepMatch = field.match(/^\\*\\/(\\d+)$/);\n   511→    if (stepMatch) {\n   512→      const step = parseInt(stepMatch[1], 10);\n   513→      return value % step === 0;\n   514→    }\n   515→    return false;\n   516→  }\n   517→\n   518→  // Phase 11: Middleware Pipeline\n   519→\n   520→  use(queueName: string, middleware: MiddlewareFn): void {\n   521→    if (!this.middlewareStacks.has(queueName)) {\n   522→      this.middlewareStacks.set(queueName, []);\n   523→    }\n   524→    this.middlewareStacks.get(queueName)!.push(middleware);\n   525→  }\n   526→\n   527→  setProcessHandler(queueName: string, handler: ProcessHandler): void {\n   528→    this.processHandlers.set(queueName, handler);\n   529→  }\n   530→\n   531→  async processNext(queueName?: string): Promise<Task | null> {\n   532→    const name = queueName ?? DEFAULT_QUEUE;\n   533→    const task = this.getNextTask(name);\n   534→    if (!task) return null;\n   535→\n   536→    const middlewares = this.middlewareStacks.get(name) ?? [];\n   537→    const handler = this.processHandlers.get(name);\n   538→\n   539→    try {\n   540→      await this.runMiddlewarePipeline(task, middlewares, handler);\n   541→      if (task.status === 'processing') {\n   542→        this.completeTask(task.id);\n   543→      }\n   544→    } catch (err: unknown) {\n   545→      if (task.status === 'processing') {\n   546→        const errorMessage = err instanceof Error ? err.message : String(err);\n   547→        this.failTask(task.id, errorMessage);\n   548→      }\n   549→    }\n   550→\n   551→    return task;\n   552→  }\n   553→\n   554→  private async runMiddlewarePipeline(\n   555→    task: Task,\n   556→    middlewares: MiddlewareFn[],\n   557→    handler?: ProcessHandler\n   558→  ): Promise<void> {\n   559→    let index = 0;\n   560→\n   561→    const next = async (): Promise<void> => {\n   562→      if (index < middlewares.length) {\n   563→        const mw = middlewares[index++];\n   564→        await mw(task, next);\n   565→      } else if (handler) {\n   566→        await handler(task);\n   567→      }\n   568→    };\n   569→\n   570→    if (middlewares.length > 0) {\n   571→      const mw = middlewares[index++];\n   572→      await mw(task, next);\n   573→    } else if (handler) {\n   574→      await handler(task);\n   575→    }\n   576→  }\n   577→\n   578→  // Phase 12: Graceful Shutdown\n   579→\n   580→  onShutdown(callback: () => void | Promise<void>): void {\n   581→    this.shutdownCallbacks.push(callback);\n   582→  }\n   583→\n   584→  async shutdown(timeout?: number): Promise<ShutdownResult> {\n   585→    const startTime = Date.now();\n   586→    this.isShutdown = true;\n   587→\n   588→    // Run shutdown callbacks\n   589→    for (const cb of this.shutdownCallbacks) {\n   590→      await cb();\n   591→    }\n   592→\n   593→    let completed = 0;\n   594→    let forceCancelled = 0;\n   595→\n   596→    // Gather all processing tasks\n   597→    const processingTasks = this.getProcessingTasks();\n   598→\n   599→    if (processingTasks.length === 0) {\n   600→      return { completed: 0, forceCancelled: 0, elapsed: Date.now() - startTime };\n   601→    }\n   602→\n   603→    if (timeout != null && timeout > 0) {\n   604→      // Wait for processing tasks with timeout\n   605→      const result = await this.waitForProcessingTasks(timeout);\n   606→      completed = result.completed;\n   607→\n   608→      // Force-cancel remaining\n   609→      const remaining = this.getProcessingTasks();\n   610→      for (const task of remaining) {\n   611→        task.status = 'cancelled';\n   612→        this.queues.get(task.queue)?.delete(task.id);\n   613→        forceCancelled++;\n   614→      }\n   615→    } else if (timeout === 0) {\n   616→      // Immediate force-cancel\n   617→      for (const task of processingTasks) {\n   618→        task.status = 'cancelled';\n   619→        this.queues.get(task.queue)?.delete(task.id);\n   620→        forceCancelled++;\n   621→      }\n   622→    } else {\n   623→      // No timeout: wait indefinitely (but in practice they should complete)\n   624→      const result = await this.waitForProcessingTasks(30000);\n   625→      completed = result.completed;\n   626→      const remaining = this.getProcessingTasks();\n   627→      for (const task of remaining) {\n   628→        task.status = 'cancelled';\n   629→        this.queues.get(task.queue)?.delete(task.id);\n   630→        forceCancelled++;\n   631→      }\n   632→    }\n   633→\n   634→    return { completed, forceCancelled, elapsed: Date.now() - startTime };\n   635→  }\n   636→\n   637→  private getProcessingTasks(): Task[] {\n   638→    const result: Task[] = [];\n   639→    for (const task of this.tasks.values()) {\n   640→      if (task.status === 'processing') {\n   641→        result.push(task);\n   642→      }\n   643→    }\n   644→    return result;\n   645→  }\n   646→\n   647→  private async waitForProcessingTasks(timeout: number): Promise<{ completed: number }> {\n   648→    const deadline = Date.now() + timeout;\n   649→    let completed = 0;\n   650→\n   651→    while (Date.now() < deadline) {\n   652→      const processing = this.getProcessingTasks();\n   653→      if (processing.length === 0) break;\n   654→\n   655→      await new Promise((resolve) => setTimeout(resolve, Math.min(50, deadline - Date.now())));\n   656→\n   657→      // Count any that completed during the wait\n   658→      for (const task of processing) {\n   659→        if (task.status === 'completed' || task.status === 'failed') {\n   660→          completed++;\n   661→        }\n   662→      }\n   663→    }\n   664→\n   665→    return { completed };\n   666→  }\n   667→\n   668→  // Helpers\n   669→\n   670→  private ensureQueue(name: string): void {\n   671→    if (!this.queues.has(name)) {\n   672→      this.queues.set(name, new Set());\n   673→    }\n   674→  }\n   675→\n   676→  private ensureDeadLetterQueue(name: string): Map<string, DeadLetteredTask> {\n   677→    if (!this.deadLetterQueues.has(name)) {\n   678→      this.deadLetterQueues.set(name, new Map());\n   679→    }\n   680→    return this.deadLetterQueues.get(name)!;\n   681→  }\n   682→\n   683→  private compareTasks(a: Task, b: Task): number {\n   684→    // Lower priority number = higher priority (1 is highest)\n   685→    if (a.priority !== b.priority) return a.priority - b.priority;\n   686→    // For delayed tasks that are now available, sort by availableAt\n   687→    if (a.availableAt !== b.availableAt) return a.availableAt - b.availableAt;\n   688→    // FIFO: earlier created first\n   689→    if (a.createdAt !== b.createdAt) return a.createdAt - b.createdAt;\n   690→    return 0;\n   691→  }\n   692→}\n   693→"}]},"parent_tool_use_id":"toolu_01LUD2kdh2huqAkWZLirPxn9","session_id":"8096ee20-9eeb-4a71-bc2c-e8bc6c545d6f","uuid":"7979cc4f-26ee-45ba-a5cb-4fa06fd553e1"}
