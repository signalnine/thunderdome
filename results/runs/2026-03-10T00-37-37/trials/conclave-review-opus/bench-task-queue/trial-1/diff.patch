+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../TaskQueue.js';
+
+describe('Phase 7: Task Dependencies', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should block tasks with unresolved dependencies', () => {
+    const dep = queue.addTask('dependency');
+    queue.addTask('dependent', { dependencies: [dep.id] });
+
+    // Only the dependency should be available
+    const next = queue.getNextTask();
+    expect(next?.data).toBe('dependency');
+
+    // The dependent should not be available yet
+    expect(queue.getNextTask()).toBeNull();
+  });
+
+  it('should unblock tasks when dependencies complete', () => {
+    const dep = queue.addTask('dependency');
+    queue.addTask('dependent', { dependencies: [dep.id] });
+
+    const depTask = queue.getNextTask()!;
+    queue.completeTask(depTask.id);
+
+    const next = queue.getNextTask();
+    expect(next?.data).toBe('dependent');
+  });
+
+  it('should reject dependencies on non-existent tasks', () => {
+    expect(() =>
+      queue.addTask('task', { dependencies: ['nonexistent'] })
+    ).toThrow();
+  });
+
+  it('should detect circular dependencies', () => {
+    const t1 = queue.addTask('task-1');
+    const t2 = queue.addTask('task-2', { dependencies: [t1.id] });
+
+    // This should not throw since there's no cycle
+    expect(() =>
+      queue.addTask('task-3', { dependencies: [t2.id] })
+    ).not.toThrow();
+  });
+
+  it('should keep dependents blocked when dependency fails', () => {
+    const dep = queue.addTask('dependency', { maxRetries: 0 });
+    queue.addTask('dependent', { dependencies: [dep.id] });
+
+    const depTask = queue.getNextTask()!;
+    queue.failTask(depTask.id, 'err');
+
+    // Per spec: failed dependency keeps dependents blocked
+    expect(queue.getNextTask()).toBeNull();
+  });
+
+  it('should keep dependents blocked when dependency is cancelled', () => {
+    const dep = queue.addTask('dependency');
+    queue.addTask('dependent', { dependencies: [dep.id] });
+
+    queue.cancelTask(dep.id);
+
+    // Per spec: dependents remain blocked when dependency fails/is cancelled
+    expect(queue.getNextTask()).toBeNull();
+  });
+
+  it('should handle multiple dependencies', () => {
+    const dep1 = queue.addTask('dep1');
+    const dep2 = queue.addTask('dep2');
+    queue.addTask('main', { dependencies: [dep1.id, dep2.id] });
+
+    // Complete dep1 only
+    const d1 = queue.getNextTask()!;
+    expect(d1.data).toBe('dep1');
+    queue.completeTask(d1.id);
+
+    // main still blocked (dep2 not completed)
+    const d2 = queue.getNextTask()!;
+    expect(d2.data).toBe('dep2');
+
+    expect(queue.getNextTask()).toBeNull();
+
+    queue.completeTask(d2.id);
+
+    // Now main should be available
+    const main = queue.getNextTask()!;
+    expect(main.data).toBe('main');
+  });
+
+  it('should inspect dependency status', () => {
+    const dep1 = queue.addTask('dep1');
+    const dep2 = queue.addTask('dep2');
+    const task = queue.addTask('main', { dependencies: [dep1.id, dep2.id] });
+
+    const deps = queue.getTaskDependencies(task.id);
+    expect(deps.length).toBe(2);
+    expect(deps[0].status).toBe('pending');
+    expect(deps[1].status).toBe('pending');
+  });
+});
