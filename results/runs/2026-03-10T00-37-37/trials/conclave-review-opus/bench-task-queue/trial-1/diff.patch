@@ -0,0 +1,103 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../TaskQueue.js';
+
+describe('Phase 5: Retry with Backoff', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should complete a task', () => {
+    const task = queue.addTask('data');
+    const next = queue.getNextTask()!;
+    queue.completeTask(next.id);
+    expect(queue.getTask(task.id)?.status).toBe('completed');
+  });
+
+  it('should re-queue failed task with retries remaining', () => {
+    const task = queue.addTask('data', { maxRetries: 3 });
+    queue.getNextTask();
+    queue.failTask(task.id, 'oops');
+
+    const updated = queue.getTask(task.id)!;
+    expect(updated.status).toBe('pending');
+    expect(updated.attempt).toBe(1);
+    expect(updated.failCount).toBe(1);
+  });
+
+  it('should apply exponential backoff delay', () => {
+    const task = queue.addTask('data', { maxRetries: 3, retryBaseDelay: 1000 });
+    const before = Date.now();
+
+    queue.getNextTask();
+    queue.failTask(task.id, 'fail-1');
+    const updated = queue.getTask(task.id)!;
+    // First retry: baseDelay * 2^0 = 1000ms
+    expect(updated.availableAt).toBeGreaterThanOrEqual(before + 1000);
+  });
+
+  it('should track attempt count through retries', () => {
+    const task = queue.addTask('data', {
+      maxRetries: 3,
+      retryBaseDelay: 0,
+    });
+
+    // First attempt
+    queue.getNextTask();
+    expect(queue.getTask(task.id)?.attempt).toBe(1);
+    queue.failTask(task.id, 'fail');
+
+    // Force availability for immediate pickup
+    const t = queue.getTask(task.id)!;
+    t.availableAt = Date.now() - 1;
+
+    // Second attempt
+    queue.getNextTask();
+    expect(queue.getTask(task.id)?.attempt).toBe(2);
+    queue.failTask(task.id, 'fail');
+
+    t.availableAt = Date.now() - 1;
+
+    // Third attempt (last)
+    queue.getNextTask();
+    expect(queue.getTask(task.id)?.attempt).toBe(3);
+    queue.failTask(task.id, 'fail');
+
+    // Should be failed now
+    expect(queue.getTask(task.id)?.status).toBe('dead-letter');
+  });
+
+  it('should keep original queue and priority on retry', () => {
+    const task = queue.addTask('data', {
+      queue: 'myq',
+      priority: 2,
+      maxRetries: 3,
+      retryBaseDelay: 0,
+    });
+
+    queue.getNextTask('myq');
+    queue.failTask(task.id, 'fail');
+
+    const updated = queue.getTask(task.id)!;
+    expect(updated.queue).toBe('myq');
+    expect(updated.priority).toBe(2);
+  });
+
+  it('should store error message on fail', () => {
+    const task = queue.addTask('data', { maxRetries: 1 });
+    queue.getNextTask();
+    queue.failTask(task.id, 'something went wrong');
+    expect(queue.getTask(task.id)?.error).toBe('something went wrong');
+  });
+
+  it('should throw when completing non-processing task', () => {
+    const task = queue.addTask('data');
+    expect(() => queue.completeTask(task.id)).toThrow();
+  });
+
+  it('should default to 3 retries', () => {
+    const task = queue.addTask('data');
+    expect(task.maxRetries).toBe(3);
+  });
+});
