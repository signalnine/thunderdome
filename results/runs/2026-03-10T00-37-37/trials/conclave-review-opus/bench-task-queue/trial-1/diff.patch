+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../TaskQueue.js';
+
+describe('Phase 6: Dead Letter Queue', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should move exhausted tasks to DLQ', () => {
+    const task = queue.addTask('data', { maxRetries: 2, retryBaseDelay: 0 });
+
+    // Attempt 1: fail, re-queue (attempt 1 < maxRetries 2)
+    queue.getNextTask();
+    queue.failTask(task.id, 'fail');
+    queue.getTask(task.id)!.availableAt = Date.now() - 1;
+
+    // Attempt 2: fail, exhausted (attempt 2 >= maxRetries 2)
+    queue.getNextTask();
+    queue.failTask(task.id, 'fail again');
+
+    const dlqTasks = queue.getDeadLetterTasks();
+    expect(dlqTasks.length).toBe(1);
+    expect(dlqTasks[0].id).toBe(task.id);
+    expect(dlqTasks[0].status).toBe('dead-letter');
+  });
+
+  it('should retain error info in DLQ', () => {
+    const task = queue.addTask('data', { maxRetries: 0 });
+    queue.getNextTask();
+    queue.failTask(task.id, 'critical error');
+
+    const dlqTasks = queue.getDeadLetterTasks();
+    expect(dlqTasks[0].error).toBe('critical error');
+  });
+
+  it('should reprocess dead-lettered task', () => {
+    const task = queue.addTask('data', { maxRetries: 0 });
+    queue.getNextTask();
+    queue.failTask(task.id, 'error');
+
+    const reprocessed = queue.reprocessDeadLetterTask(task.id);
+    expect(reprocessed.status).toBe('pending');
+    expect(reprocessed.attempt).toBe(0);
+
+    // Should be available for processing
+    const next = queue.getNextTask();
+    expect(next?.id).toBe(task.id);
+  });
+
+  it('should clear DLQ for a queue', () => {
+    const task = queue.addTask('data', { maxRetries: 0 });
+    queue.getNextTask();
+    queue.failTask(task.id, 'error');
+
+    const cleared = queue.clearDeadLetterQueue();
+    expect(cleared).toBe(1);
+    expect(queue.getDeadLetterTasks().length).toBe(0);
+  });
+
+  it('should have independent DLQs per queue', () => {
+    const t1 = queue.addTask('d1', { queue: 'q1', maxRetries: 0 });
+    const t2 = queue.addTask('d2', { queue: 'q2', maxRetries: 0 });
+
+    queue.getNextTask('q1');
+    queue.failTask(t1.id, 'err');
+    queue.getNextTask('q2');
+    queue.failTask(t2.id, 'err');
+
+    expect(queue.getDeadLetterTasks('q1').length).toBe(1);
+    expect(queue.getDeadLetterTasks('q2').length).toBe(1);
+
+    queue.clearDeadLetterQueue('q1');
+    expect(queue.getDeadLetterTasks('q1').length).toBe(0);
+    expect(queue.getDeadLetterTasks('q2').length).toBe(1);
+  });
+});
