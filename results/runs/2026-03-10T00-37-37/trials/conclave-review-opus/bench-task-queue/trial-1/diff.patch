@@ -0,0 +1,62 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../TaskQueue.js';
+
+describe('Phase 12: Graceful Shutdown', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should reject new tasks after shutdown', async () => {
+    await queue.shutdown();
+    expect(() => queue.addTask('data')).toThrow(/shut down/);
+  });
+
+  it('should return immediately if no processing tasks', async () => {
+    const result = await queue.shutdown();
+    expect(result.completed).toBe(0);
+    expect(result.forceCancelled).toBe(0);
+    expect(result.elapsed).toBeGreaterThanOrEqual(0);
+  });
+
+  it('should force-cancel processing tasks on timeout 0', async () => {
+    queue.addTask('work');
+    queue.getNextTask(); // now processing
+
+    const result = await queue.shutdown(0);
+    expect(result.forceCancelled).toBe(1);
+  });
+
+  it('should run shutdown callbacks', async () => {
+    let called = false;
+    queue.onShutdown(() => {
+      called = true;
+    });
+    await queue.shutdown();
+    expect(called).toBe(true);
+  });
+
+  it('should handle multiple shutdown calls safely', async () => {
+    const r1 = await queue.shutdown();
+    const r2 = await queue.shutdown();
+    expect(r1).toBeDefined();
+    expect(r2).toBeDefined();
+  });
+
+  it('should return shutdown summary', async () => {
+    queue.addTask('t1');
+    queue.addTask('t2');
+    queue.getNextTask();
+    queue.getNextTask();
+
+    const result = await queue.shutdown(0);
+    expect(result.forceCancelled).toBe(2);
+    expect(typeof result.elapsed).toBe('number');
+  });
+
+  it('should reject schedules after shutdown', async () => {
+    await queue.shutdown();
+    expect(() => queue.addSchedule('s', '* * * * *', 'q', {})).toThrow(/shut down/);
+  });
+});
