+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../TaskQueue.js';
+
+describe('Phase 8: Concurrency Control', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should default to unlimited concurrency', () => {
+    expect(queue.getConcurrency()).toBeUndefined();
+  });
+
+  it('should set concurrency limit', () => {
+    queue.setConcurrency('default', 2);
+    expect(queue.getConcurrency('default')).toBe(2);
+  });
+
+  it('should respect concurrency limit', () => {
+    queue.setConcurrency('default', 1);
+    queue.addTask('task-1');
+    queue.addTask('task-2');
+
+    const t1 = queue.getNextTask();
+    expect(t1).not.toBeNull();
+
+    // Should return null because limit reached
+    const t2 = queue.getNextTask();
+    expect(t2).toBeNull();
+  });
+
+  it('should free slot on completion', () => {
+    queue.setConcurrency('default', 1);
+    queue.addTask('task-1');
+    queue.addTask('task-2');
+
+    const t1 = queue.getNextTask()!;
+    queue.completeTask(t1.id);
+
+    const t2 = queue.getNextTask();
+    expect(t2).not.toBeNull();
+  });
+
+  it('should free slot on failure', () => {
+    queue.setConcurrency('default', 1);
+    queue.addTask('task-1', { maxRetries: 0 });
+    queue.addTask('task-2');
+
+    const t1 = queue.getNextTask()!;
+    queue.failTask(t1.id, 'err');
+
+    const t2 = queue.getNextTask();
+    expect(t2).not.toBeNull();
+  });
+
+  it('should track active count', () => {
+    queue.addTask('task-1');
+    queue.addTask('task-2');
+
+    expect(queue.getActiveCount()).toBe(0);
+    queue.getNextTask();
+    expect(queue.getActiveCount()).toBe(1);
+    queue.getNextTask();
+    expect(queue.getActiveCount()).toBe(2);
+  });
+
+  it('should respect priority within concurrency', () => {
+    queue.setConcurrency('default', 1);
+    queue.addTask('low', { priority: 8 });
+    queue.addTask('high', { priority: 2 });
+
+    const task = queue.getNextTask();
+    expect(task?.data).toBe('high');
+  });
+});
