+export { TaskQueue } from './TaskQueue.js';
+export type {
+  Task,
+  TaskOptions,
+  TaskStatus,
+  DeadLetteredTask,
+  Schedule,
+  ProgressListener,
+  MiddlewareFn,
+  ProcessHandler,
+  ShutdownResult,
+} from './types.js';
diff --git a/src/types.ts b/src/types.ts
new file mode 100644
index 0000000..950de86
--- /dev/null
+++ b/src/types.ts
@@ -0,0 +1,54 @@
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled' | 'dead-letter';
+
+export interface TaskOptions {
+  priority?: number;
+  delay?: number;
+  availableAt?: number;
+  maxRetries?: number;
+  retryBaseDelay?: number;
+  dependencies?: string[];
+}
+
+export interface Task<T = unknown> {
+  id: string;
+  queue: string;
+  status: TaskStatus;
+  data: T;
+  priority: number;
+  createdAt: number;
+  availableAt: number;
+  attempt: number;
+  maxRetries: number;
+  retryBaseDelay: number;
+  progress: number;
+  progressMessage?: string;
+  error?: string;
+  failCount: number;
+  dependencies: string[];
+}
+
+export interface DeadLetteredTask<T = unknown> extends Task<T> {
+  status: 'dead-letter';
+  deadLetteredAt: number;
+  originalQueue: string;
+}
+
+export interface Schedule {
+  id: string;
+  queue: string;
+  cronExpression: string;
+  taskData: unknown;
+  taskOptions?: Omit<TaskOptions, 'delay' | 'availableAt' | 'dependencies'>;
+}
+
+export type ProgressListener = (taskId: string, progress: number, message?: string) => void;
+
+export type MiddlewareFn = (task: Task, next: () => Promise<void>) => Promise<void>;
+
+export type ProcessHandler = (task: Task) => Promise<void>;
+
+export interface ShutdownResult {
+  completed: number;
+  forceCancelled: number;
+  elapsed: number;
+}
