+import { describe, it, expect, beforeEach, afterEach } from "vitest";
+import * as fs from "node:fs";
+import * as path from "node:path";
+import * as os from "node:os";
+import { TimeTracker } from "../src/index.js";
+
+function tmpFile(): string {
+  const dir = fs.mkdtempSync(path.join(os.tmpdir(), "tracker-test-"));
+  return path.join(dir, "data.json");
+}
+
+function cleanup(filePath: string): void {
+  try {
+    fs.rmSync(path.dirname(filePath), { recursive: true, force: true });
+  } catch {
+    // ignore
+  }
+}
+
+describe("TimeTracker", () => {
+  let filePath: string;
+
+  beforeEach(() => {
+    filePath = tmpFile();
+  });
+
+  afterEach(() => {
+    cleanup(filePath);
+  });
+
+  describe("start/stop", () => {
+    it("should start and stop a timer", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("coding");
+      expect(tracker.isRunning()).toBe(true);
+      tracker.stop();
+      expect(tracker.isRunning()).toBe(false);
+
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].task).toBe("coding");
+      expect(entries[0].start).toBeTruthy();
+      expect(entries[0].stop).toBeTruthy();
+    });
+
+    it("should auto-stop previous timer when starting a new one", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("task1");
+      tracker.start("task2");
+
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(2);
+      expect(entries[0].task).toBe("task1");
+      expect(entries[0].stop).not.toBeNull();
+      expect(entries[1].task).toBe("task2");
+      expect(entries[1].stop).toBeNull();
+    });
+
+    it("should throw when starting with empty name", () => {
+      const tracker = new TimeTracker(filePath);
+      expect(() => tracker.start("")).toThrow("Task name cannot be empty");
+      expect(() => tracker.start("  ")).toThrow("Task name cannot be empty");
+    });
+
+    it("should throw when stopping with no running timer", () => {
+      const tracker = new TimeTracker(filePath);
+      expect(() => tracker.stop()).toThrow("No timer is currently running");
+    });
+  });
+
+  describe("persistence", () => {
+    it("should persist entries across instances", () => {
+      const tracker1 = new TimeTracker(filePath);
+      tracker1.start("coding");
+      tracker1.stop();
+
+      const tracker2 = new TimeTracker(filePath);
+      const entries = tracker2.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].task).toBe("coding");
+    });
+
+    it("should create directories if they don't exist", () => {
+      const deepPath = path.join(
+        os.tmpdir(),
+        "tracker-test-deep",
+        "a",
+        "b",
+        "c",
+        "data.json"
+      );
+      const tracker = new TimeTracker(deepPath);
+      tracker.start("test");
+      tracker.stop();
+      expect(fs.existsSync(deepPath)).toBe(true);
+      fs.rmSync(path.join(os.tmpdir(), "tracker-test-deep"), {
+        recursive: true,
+        force: true,
+      });
+    });
+  });
+
+  describe("getEntries with date filtering", () => {
+    it("should filter entries by date range", () => {
+      const tracker = new TimeTracker(filePath);
+
+      // Manually write entries with specific dates
+      const data = {
+        entries: [
+          {
+            task: "old",
+            start: "2024-01-01T00:00:00.000Z",
+            stop: "2024-01-01T01:00:00.000Z",
+          },
+          {
+            task: "recent",
+            start: "2024-06-15T00:00:00.000Z",
+            stop: "2024-06-15T01:00:00.000Z",
+          },
+          {
+            task: "new",
+            start: "2024-12-01T00:00:00.000Z",
+            stop: "2024-12-01T01:00:00.000Z",
+          },
+        ],
+      };
+      fs.writeFileSync(filePath, JSON.stringify(data), "utf-8");
+
+      const tracker2 = new TimeTracker(filePath);
+      const filtered = tracker2.getEntries(
+        new Date("2024-06-01"),
+        new Date("2024-07-01")
+      );
+      expect(filtered).toHaveLength(1);
+      expect(filtered[0].task).toBe("recent");
+    });
+
+    it("should return all entries when no filter is provided", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("a");
+      tracker.stop();
+      tracker.start("b");
+      tracker.stop();
+
+      expect(tracker.getEntries()).toHaveLength(2);
+    });
+  });
+
+  describe("getSummary", () => {
+    it("should sum durations per task", () => {
+      const data = {
+        entries: [
+          {
+            task: "coding",
+            start: "2024-06-15T00:00:00.000Z",
+            stop: "2024-06-15T01:00:00.000Z",
+          },
+          {
+            task: "review",
+            start: "2024-06-15T01:00:00.000Z",
+            stop: "2024-06-15T01:30:00.000Z",
+          },
+          {
+            task: "coding",
+            start: "2024-06-15T02:00:00.000Z",
+            stop: "2024-06-15T03:00:00.000Z",
+          },
+        ],
+      };
+      fs.writeFileSync(filePath, JSON.stringify(data), "utf-8");
+
+      const tracker = new TimeTracker(filePath);
+      const summary = tracker.getSummary();
+
+      expect(summary["coding"]).toBe(2 * 60 * 60 * 1000); // 2 hours
+      expect(summary["review"]).toBe(30 * 60 * 1000); // 30 minutes
+    });
+
+    it("should use current time for running entries", () => {
+      // Write an entry that started 10 seconds ago and is still running
+      const tenSecondsAgo = new Date(Date.now() - 10_000).toISOString();
+      const data = {
+        entries: [
+          { task: "active", start: tenSecondsAgo, stop: null },
+        ],
+      };
+      fs.writeFileSync(filePath, JSON.stringify(data), "utf-8");
+
+      const tracker = new TimeTracker(filePath);
+      const summary = tracker.getSummary();
+      expect(summary["active"]).toBeGreaterThanOrEqual(9_000);
+    });
+  });
+
+  describe("unicode support", () => {
+    it("should handle unicode task names", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("编码工作");
+      tracker.stop();
+      tracker.start("🚀 deploy");
+      tracker.stop();
+
+      const entries = tracker.getEntries();
+      expect(entries[0].task).toBe("编码工作");
+      expect(entries[1].task).toBe("🚀 deploy");
+
+      // Verify persistence
+      const tracker2 = new TimeTracker(filePath);
+      const entries2 = tracker2.getEntries();
+      expect(entries2[0].task).toBe("编码工作");
+      expect(entries2[1].task).toBe("🚀 deploy");
+    });
+
+    it("should handle emoji in summaries", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("🎯 focus");
+      tracker.stop();
+      tracker.start("🎯 focus");
+      tracker.stop();
+
+      const summary = tracker.getSummary();
+      expect(summary["🎯 focus"]).toBeGreaterThanOrEqual(0);
+    });
   });
