start < from) return false;\n      if (to && start > to) return false;\n      return true;\n    });\n  }\n\n  getSummary(from?: Date, to?: Date): Record<string, number> {\n    const entries = this.getEntries(from, to);\n    const summary: Record<string, number> = {};\n\n    for (const entry of entries) {\n      const start = new Date(entry.start).getTime();\n      const end = entry.stop\n        ? new Date(entry.stop).getTime()\n        : Date.now();\n      const duration = end - start;\n\n      if (summary[entry.task] === undefined) {\n        summary[entry.task] = 0;\n      }\n      summary[entry.task] += duration;\n    }\n\n    return summary;\n  }\n\n  isRunning(): boolean {\n    return this.getRunningEntry() !== null;\n  }\n\n  private getRunningEntry(): TimeEntry | null {\n    for (let i = this.entries.length - 1; i >= 0; i--) {\n      if (this.entries[i].stop === null) {\n        return this.entries[i];\n      }\n    }\n    return null;\n  }\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":226,"cache_read_input_tokens":19853,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":226},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"b799b196-ceed-4add-a96a-c5def10c589e","uuid":"62c486ee-dc9f-4719-964a-3cdea1d23904"}
